// Benchmark: PB-003 - List operations performance
// Priority: High
// Expected: Performance comparison across tiers

fn main() {
    // List creation and iteration
    let start = now();

    let mut sum = 0;
    let list = [i for i in 0..10000];
    for x in list {
        sum = sum + x;
    }

    let elapsed = now() - start;
    print(f"Sum of 0..10000 = {sum} in {elapsed}ms");

    // List map/filter operations
    let start = now();

    let squares = [x * x for x in 0..10000];
    let evens = [x for x in squares if x % 2 == 0];
    let sum_evens = evens.fold(0, |acc, x| acc + x);

    let elapsed = now() - start;
    print(f"Sum of even squares = {sum_evens} in {elapsed}ms");

    // Nested iteration
    let start = now();

    let mut count = 0;
    for i in 0..100 {
        for j in 0..100 {
            count = count + 1;
        }
    }

    let elapsed = now() - start;
    print(f"Nested iteration count = {count} in {elapsed}ms");
}
