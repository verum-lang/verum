// Multi-module project main entry point
// Test: MP-001 - Basic multi-file project

link lib.math;
link lib.types.Point;

fn main() {
    // Using math module
    let sum = math.add(2, 3);
    print(f"Sum: {sum}");

    let product = math.multiply(4, 5);
    print(f"Product: {product}");

    // Using types module
    let p = Point.new(10, 20);
    print(f"Point: ({p.x}, {p.y})");

    let distance = p.distance_from_origin();
    print(f"Distance: {distance}");
}
