// Test accessing a context method from a `using`-annotated function.
// Modernized to the v5.1 provide-a-value form.

context Logger {
    fn log(message: Text);
}

type ConsoleLogger is {
    prefix: Text,
};

implement Logger for ConsoleLogger {
    fn log(&self, message: Text) {
        print(f"[LOG] {message}");
    }
}

fn greet(name: Text) using Logger {
    Logger.log(f"Hello, {name}");
}

fn main() {
    provide Logger = ConsoleLogger { prefix: "ACC" };

    greet("World");
}
