// Test context reachability across closure calls: a closure invoked
// inside the provided dynamic scope can call a `using`-annotated fn.
// Modernized to the v5.1 provide-a-value form.

context Logger {
    fn log(message: Text);
}

type ConsoleLogger is {
    prefix: Text,
};

implement Logger for ConsoleLogger {
    fn log(&self, message: Text) {
        print(f"[LOG] {message}");
    }
}

fn log_line(message: Text) using Logger {
    Logger.log(message);
}

fn main() {
    print("=== Test 1: Closure with context ===");

    provide Logger = ConsoleLogger { prefix: "CLS" };

    let log_twice = |m: Text| {
        log_line(m);
        log_line(m);
    };
    log_twice("from closure");

    print("Context reachable through closure calls");
}
