// Test: Closures - Closures and lambda expressions
// Priority: Critical
// Expected output: Closure operations

type Maybe<T> is
    | Some(T)
    | None;

type Result<T, E> is
    | Ok(T)
    | Err(E);

async fn main() {
    // 1. Basic closure without parameters
    let greet = || {
        print(f"Hello, world!");
    };
    greet();

    // 2. Basic closure with single parameter
    let double = |x: Int| -> Int {
        x * 2
    };
    let result = double(21);
    print(f"Double: {result}");

    // 3. Closure with multiple parameters
    let add = |a: Int, b: Int| -> Int {
        a + b
    };
    print(f"Sum: {add(10, 20)}");

    // 4. Closure with inferred types
    let square = |x| x * x;
    print(f"Square: {square(5)}");

    // 5. Closure capturing environment
    let base = 10;
    let add_base = |x: Int| -> Int {
        x + base
    };
    print(f"With base: {add_base(5)}");

    // 6. Closure with block body
    let complex = |x: Int| -> Int {
        let temp = x * 2;
        let result = temp + 10;
        result
    };
    print(f"Complex: {complex(5)}");

    // 7. Closure returning closure
    let make_adder = |n: Int| -> fn(Int) -> Int {
        |x: Int| -> Int { x + n }
    };
    let add5 = make_adder(5);
    print(f"Add 5: {add5(10)}");

    // 8. Closure passed as argument
    fn apply<T, U>(f: fn(T) -> U, value: T) -> U {
        f(value)
    }

    let triple = |x: Int| -> Int { x * 3 };
    print(f"Applied: {apply(triple, 7)}");

    // 9. Closure with map operation
    let numbers = [1, 2, 3, 4, 5];
    let doubled = numbers.map(|x| x * 2);
    print(f"Mapped: {doubled}");

    // 10. Closure with filter operation
    let evens = numbers.filter(|x| x % 2 == 0);
    print(f"Filtered: {evens}");

    // 11. Closure with fold/reduce
    let sum = numbers.fold(0, |acc, x| acc + x);
    print(f"Sum: {sum}");

    // 12. Mutable closure
    let mut counter = 0;
    let mut increment = || {
        counter = counter + 1;
        counter
    };
    print(f"Count 1: {increment()}");
    print(f"Count 2: {increment()}");
    print(f"Count 3: {increment()}");

    // 13. Closure with multiple captures
    let x = 10;
    let y = 20;
    let combined = |z: Int| -> Int {
        x + y + z
    };
    print(f"Combined: {combined(5)}");

    // 14. Nested closures
    let outer = |a: Int| -> fn(Int) -> Int {
        let inner = |b: Int| -> Int {
            a + b
        };
        inner
    };
    let add10 = outer(10);
    print(f"Nested: {add10(5)}");

    // 15. Closure composition
    let f = |x: Int| -> Int { x + 1 };
    let g = |x: Int| -> Int { x * 2 };
    let composed = |x: Int| -> Int { g(f(x)) };
    print(f"Composed: {composed(5)}");

    // 16. Closure returning tuple
    let split = |n: Int| -> (Int, Int) {
        (n / 2, n % 2)
    };
    let (div, rem) = split(7);
    print(f"Split: {div}, {rem}");

    // 17. Closure with pattern matching
    let unwrap_or = |m: Maybe<Int>, default: Int| -> Int {
        match m {
            Maybe.Some(v) => v,
            Maybe.None => default,
        }
    };
    print(f"Unwrap: {unwrap_or(Maybe.Some(42), 0)}");
    print(f"Unwrap: {unwrap_or(Maybe.None, 99)}");

    // 18. Closure with conditional
    let abs = |x: Int| -> Int {
        if x < 0 {
            -x
        } else {
            x
        }
    };
    print(f"Abs: {abs(-5)}");
    print(f"Abs: {abs(5)}");

    // 19. Async closure
    let async_double = async |x: Int| -> Int {
        x * 2
    };
    let async_result = async_double(21).await;
    print(f"Async double: {async_result}");

    // 20. Higher-order function with closure
    fn twice<T>(f: fn(T) -> T, value: T) -> T {
        f(f(value))
    }

    let inc = |x: Int| -> Int { x + 1 };
    print(f"Twice: {twice(inc, 10)}");

    // 21. Closure with early return
    let check_positive = |x: Int| -> Bool {
        if x <= 0 {
            return false;
        }
        true
    };
    print(f"Positive: {check_positive(5)}");
    print(f"Positive: {check_positive(-5)}");

    // 22. Closure capturing by reference
    let mut value = 100;
    let get_and_increment = || {
        let current = value;
        value = value + 1;
        current
    };
    print(f"Value: {get_and_increment()}");
    print(f"Value: {get_and_increment()}");

    // 23. Closure with generic type
    fn map_option<T, U>(opt: Maybe<T>, f: fn(T) -> U) -> Maybe<U> {
        match opt {
            Maybe.Some(v) => Maybe.Some(f(v)),
            Maybe.None => Maybe.None,
        }
    }

    let some_num = Maybe.Some(10);
    let mapped_opt = map_option(some_num, |x| x * 2);
    match mapped_opt {
        Maybe.Some(v) => print(f"Mapped option: {v}"),
        Maybe.None => print(f"None"),
    }

    // 24. Closure chain
    let process = |x: Int| -> Int {
        let step1 = |n| n + 10;
        let step2 = |n| n * 2;
        let step3 = |n| n - 5;
        step3(step2(step1(x)))
    };
    print(f"Processed: {process(5)}");

    // 25. Closure with loop
    let sum_up_to = |n: Int| -> Int {
        let mut total = 0;
        let mut i = 1;
        while i <= n {
            total = total + i;
            i = i + 1;
        }
        total
    };
    print(f"Sum 1-10: {sum_up_to(10)}");

    // 26. Closure as struct field
    type Calculator is {
        operation: fn(Int, Int) -> Int
    };

    let calc = Calculator {
        operation: |a, b| a + b
    };
    print(f"Calculator: {(calc.operation)(10, 20)}");

    // 27. Closure with try/? operator
    let safe_divide = |a: Int, b: Int| -> Result<Int, Text> {
        if b == 0 {
            Result.Err("Division by zero")
        } else {
            Result.Ok(a / b)
        }
    };

    match safe_divide(10, 2) {
        Result.Ok(v) => print(f"Division: {v}"),
        Result.Err(e) => print(f"Error: {e}"),
    }

    // 28. Closure with for loop
    let sum_array = |arr: [Int; 5]| -> Int {
        let mut total = 0;
        for x in arr {
            total = total + x;
        }
        total
    };
    print(f"Array sum: {sum_array([1, 2, 3, 4, 5])}");
}
