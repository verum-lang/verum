// Async/Await Showcase - All Working Features
// This file demonstrates all successfully tested async features

// 1. Basic async function
async fn fetch_value(x: Int) -> Int {
    x * 10
}

// 2. Async function calling async function
async fn process_value(x: Int) -> Int {
    let fetched = fetch_value(x).await;
    fetched + 100
}

// 3. Result type with async
type Result<T, E> is
    | Ok(T)
    | Err(E);

async fn safe_divide(a: Int, b: Int) -> Result<Int, Text> {
    if b == 0 {
        Result.Err("Division by zero")
    } else {
        Result.Ok(a / b)
    }
}

// 4. Generic async function
async fn async_identity<T>(value: T) -> T {
    value
}

// 5. Async with defer
async fn with_cleanup(x: Int) -> Int {
    defer {
        print("  [Cleanup executed]");
    };
    x * 2
}

fn main() {
    print("=== Verum Async/Await Showcase ===\n");

    // Test 1: Basic async with .await
    print("1. Basic async function:");
    let result1 = fetch_value(5).await;
    print(f"   fetch_value(5) = {result1}\n");

    // Test 2: Chained async calls
    print("2. Chained async calls:");
    let result2 = process_value(3).await;
    print(f"   process_value(3) = {result2}\n");

    // Test 3: Spawn for concurrency
    print("3. Concurrent execution with spawn:");
    let h1 = spawn process_value(1);
    let h2 = spawn process_value(2);
    let h3 = spawn process_value(3);
    print(f"   Parallel: {h1.await}, {h2.await}, {h3.await}\n");

    // Test 4: Async closures
    print("4. Async closure:");
    let async_square = async |x: Int| -> Int {
        x * x
    };
    let result4 = async_square(7).await;
    print(f"   Square of 7 = {result4}\n");

    // Test 5: Async blocks
    print("5. Async block:");
    let future = async {
        let a = 10;
        let b = 20;
        a + b
    };
    print(f"   Async block result = {future.await}\n");

    // Test 6: Nested async closures
    print("6. Nested async closures:");
    let outer = async || -> Int {
        let inner = async || -> Int { 42 };
        inner().await + 8
    };
    print(f"   Nested result = {outer().await}\n");

    // Test 7: Error handling with Result
    print("7. Error handling:");
    let success = safe_divide(10, 2).await;
    match success {
        Result.Ok(v) => print(f"   10 / 2 = {v}"),
        Result.Err(e) => print(f"   Error: {e}"),
    }
    let failure = safe_divide(10, 0).await;
    match failure {
        Result.Ok(v) => print(f"   10 / 0 = {v}"),
        Result.Err(e) => print(f"   Error: {e}"),
    }
    print("");

    // Test 8: Generic async
    print("8. Generic async functions:");
    let int_result = async_identity(42).await;
    let text_result = async_identity("Hello").await;
    print(f"   Int identity: {int_result}");
    print(f"   Text identity: {text_result}\n");

    // Test 9: Defer with async
    print("9. Defer in async:");
    let result9 = with_cleanup(21).await;
    print(f"   Result: {result9}\n");

    // Test 10: Future storage and delayed await
    print("10. Store future, await later:");
    let future_to_await = fetch_value(7);
    print(f"   Future stored: {future_to_await}");
    print(f"   Now awaiting...");
    print(f"   Result: {future_to_await.await}\n");

    // Test 11: Spawn with async blocks
    print("11. Spawn with async blocks:");
    let task1 = spawn async { 10 + 5 };
    let task2 = spawn async { 20 * 2 };
    print(f"   Results: {task1.await}, {task2.await}\n");

    // Test 12: Complex async pipeline
    print("12. Complex async pipeline:");
    let step1 = spawn async_identity(5);
    let step2_value = step1.await;
    let step2 = spawn fetch_value(step2_value);
    let step3_value = step2.await;
    let step3 = spawn process_value(step3_value / 10);
    print(f"   Pipeline result: {step3.await}\n");

    print("=== All tests completed successfully! ===");
}
