// Test basic context definition and usage.
//
// v5.1 canonical form (was pre-v5 `provide Logger = { fn log … }`):
// a context is provided with a VALUE whose type carries an
// `implement Logger for T` block — see
// vcs/specs/L2-standard/contexts/runtime/context_method_call.vr.

context Logger {
    fn log(message: Text);
}

type ConsoleLogger is {
    prefix: Text,
};

implement Logger for ConsoleLogger {
    fn log(&self, message: Text) {
        print(f"[LOG] {message}");
    }
}

fn greet(name: Text) using Logger {
    Logger.log(f"Hello, {name}!");
}

fn main() {
    let logger = ConsoleLogger { prefix: "APP" };
    provide Logger = logger;

    greet("World");

    print(f"Context system test complete");
}
