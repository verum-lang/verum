// Test basic closure functionality
fn main() {
    // Simple closure
    let add_one = |x: Int| x + 1;
    let result = add_one(5);
    print(f"Add one: {result}");

    // Closure with multiple params
    let add = |a: Int, b: Int| a + b;
    print(f"Add: {add(3, 4)}");

    // Closure capturing environment
    let base = 10;
    let add_base = |x: Int| x + base;
    print(f"Add base: {add_base(5)}");
}
