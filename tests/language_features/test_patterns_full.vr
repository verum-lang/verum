    test_literal_patterns();
    test_identifier_patterns();
    test_wildcard_patterns();
    test_rest_patterns();
    test_tuple_patterns();
    test_array_patterns();
    test_slice_patterns();
    test_record_patterns();
    test_variant_patterns();
    test_reference_patterns();
    test_range_patterns();
    test_or_patterns();
    test_guards_if();
    test_guards_where();
    test_nested_patterns();
    test_at_bindings();
    test_let_patterns();
    test_complex_combined();

    print(f"╔════════════════════════════════════════════════════════════╗");
    print(f"║  ✓ ALL PATTERN MATCHING TESTS COMPLETE!                   ║");
    print(f"║  • 18 test sections                                       ║");
    print(f"║  • 150+ individual pattern tests                          ║");
    print(f"║  • Full grammar coverage                                  ║");
    print(f"╚════════════════════════════════════════════════════════════╝\n");
}
