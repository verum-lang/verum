// Test context working patterns: a provided context is reachable from
// any `using`-annotated callee in the dynamic scope, interleaved with
// plain (non-using) calls.  Modernized to the v5.1 provide-a-value
// form (was pre-v5 `provide Logger = { fn log … }`).

context Logger {
    fn log(message: Text);
}

type ConsoleLogger is {
    prefix: Text,
};

implement Logger for ConsoleLogger {
    fn log(&self, message: Text) {
        print(f"[LOG] {message}");
    }
}

fn log_line(message: Text) using Logger {
    Logger.log(message);
}

// Function that doesn't touch the context at all.
fn greet(name: Text) {
    print(f"Hello, {name}");
}

fn main() {
    provide Logger = ConsoleLogger { prefix: "WRK" };

    log_line("Starting application");

    greet("World");

    log_line("Application complete");
}
