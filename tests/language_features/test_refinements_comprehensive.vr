// Test: Refinements Comprehensive - ALL refinement type features
// Priority: Critical
// Expected output: Complete validation of all refinement syntax forms
// Status: Based on working examples from test_refinements.vr and grammar specification

// ============================================================================
// REFINEMENT TYPE FEATURE CATALOG
// ============================================================================
// 1. Inline refinement: type Positive is Int{> 0};
// 2. Inline with explicit it: type Bounded is Float{0.0 <= it && it <= 1.0};
// 3. Declarative refinement: type Email is Text where valid_email;
// 4. Lambda refinement: type Age is Int where |x| x >= 0 && x <= 150;
// 5. Sigma type: type ValidEmail is email: Text where email.contains('@');
// 6. Refinement in function params: fn divide(a: Int, b: Int{!= 0}) -> Int
// 7. Refinement in return types: fn abs(x: Int) -> Int{>= 0}

// ============================================================================
// SECTION 1: INLINE REFINEMENTS
// Grammar: type Name is BaseType{predicate};
// ============================================================================

// 1.1 Simple inline refinements with implicit 'it'
type Positive is Int{> 0};
type Negative is Int{< 0};
type NonZero is Int{!= 0};
type Zero is Int{== 0};

// 1.2 Inline refinements with explicit 'it'
type Bounded is Float{0.0 <= it && it <= 1.0};
type Percentage is Int{it >= 0 && it <= 100};
type UnitInterval is Float{it >= 0.0 && it <= 1.0};

// 1.3 Inline refinements with method calls
type NonEmptyText is Text{it.len() > 0};
type ShortText is Text{it.len() <= 256};
type ValidPassword is Text{it.len() >= 8 && it.len() <= 128};

// 1.4 Multiple inline predicates (comma-separated)
type Probability is Float{>= 0.0, <= 1.0};
type ValidAge is Int{>= 0, <= 150};
type DayOfMonth is Int{>= 1, <= 31};

// ============================================================================
// SECTION 2: INLINE REFINEMENT WITH EXPLICIT 'IT'
// Grammar: type Name is BaseType{it operator value};
// ============================================================================

type ExplicitBounded is Int{it >= -100 && it <= 100};
type ExplicitPositive is Float{it > 0.0};
type ExplicitRange is Int{it >= 10 && it <= 20};

// Complex expressions with 'it'
type EvenPositive is Int{it > 0 && it % 2 == 0};
type OddNegative is Int{it < 0 && it % 2 != 0};

// ============================================================================
// SECTION 3: DECLARATIVE REFINEMENTS (WHERE + named predicate)
// Grammar: type Name is BaseType where predicate_name;
// ============================================================================

// 3.1 Named predicate functions
fn is_valid_email(s: Text) -> Bool {
    s.contains("@") && s.len() >= 5
}

fn is_even(x: Int) -> Bool {
    x % 2 == 0
}

fn is_prime(n: Int) -> Bool {
    if n <= 1 {
        return false;
    }
    if n <= 3 {
        return true;
    }
    if n % 2 == 0 {
        return false;
    }
    if n % 3 == 0 {
        return false;
    }
    true
}

// 3.2 Declarative refinements using named predicates
type Email is Text where is_valid_email;
type EvenInt is Int where is_even;
type PrimeInt is Int where is_prime;

// ============================================================================
// SECTION 4: LAMBDA REFINEMENTS (WHERE + lambda)
// Grammar: type Name is BaseType where |param| expression;
// ============================================================================

// 4.1 Lambda refinements with single parameter
type LambdaAge is Int where |x| x >= 0 && x <= 150;
type LambdaPercentage is Float where |p| p >= 0.0 && p <= 100.0;
type LambdaNonEmpty is Text where |s| s.len() > 0;

// 4.2 Lambda refinements with complex predicates
type LambdaEven is Int where |n| n % 2 == 0;
type LambdaOdd is Int where |n| n % 2 != 0;
type LambdaInRange is Int where |x| x >= 1 && x <= 10;

// ============================================================================
// SECTION 5: SIGMA TYPE REFINEMENTS (explicit binding)
// Grammar: type Name is variable: BaseType where predicate;
// ============================================================================

// 5.1 Sigma types with explicit variable binding
type ValidEmail is email: Text where email.contains("@");
type BoundedInt is n: Int where n >= 0 && n <= 100;
type ValidText is s: Text where s.len() > 5;

// 5.2 Sigma types with complex predicates
type SafeIndex is i: Int where i >= 0 && i < 1000;
type PositiveSigma is x: Int where x > 0;
type ValidRange is value: Int where value >= 10 && value <= 90;

// ============================================================================
// SECTION 6: REFINEMENT IN FUNCTION PARAMETERS
// Grammar: fn name(param: Type{refinement}) -> ReturnType
// ============================================================================

// 6.1 Single refined parameter
fn divide(numerator: Int, denominator: Int{!= 0}) -> Int {
    numerator / denominator
}

// 6.2 Multiple refined parameters
fn calculate_ratio(a: Int{> 0}, b: Int{> 0}) -> Int {
    a / b
}

// 6.3 Refined parameter with type alias
fn square(x: Positive) -> Int {
    x * x
}

// 6.4 Mixed refined and unrefined parameters
fn clamp(value: Int, min: Int{<= 0}, max: Int{>= 0}) -> Int {
    if value < min {
        min
    } else if value > max {
        max
    } else {
        value
    }
}

// ============================================================================
// SECTION 7: REFINEMENT IN RETURN TYPES
// Grammar: fn name(params) -> Type{refinement}
// ============================================================================

// 7.1 Inline refinement in return type
fn abs(x: Int) -> Int{>= 0} {
    if x < 0 {
        -x
    } else {
        x
    }
}

// 7.2 Return type with complex refinement
fn get_percentage() -> Int{>= 0 && <= 100} {
    50
}

// 7.3 Type alias as return type
fn get_positive() -> Positive {
    42
}

// 7.4 Both parameter and return refined
fn double_positive(x: Positive) -> Positive {
    x * 2
}

// 7.5 Complex refinement with method calls
fn get_non_empty_text() -> Text{it.len() > 0} {
    "hello"
}

// ============================================================================
// SECTION 8: NESTED AND COMPOSED REFINEMENTS
// ============================================================================

// 8.1 Nested refinements (refinement of refinement)
type AdultAge is ValidAge where it >= 18;
type LegalDrinkingAge is AdultAge where it >= 21;

// 8.2 Record types with refined fields
type Rectangle is {
    width: Int{> 0},
    height: Int{> 0}
};

type Circle is {
    radius: Float{> 0.0},
    center_x: Float,
    center_y: Float
};

// 8.3 Functions using refined record types
fn area(rect: Rectangle) -> Int{> 0} {
    rect.width * rect.height
}

fn circumference(circle: Circle) -> Float{> 0.0} {
    2.0 * 3.14159 * circle.radius
}

// 8.4 Variant types with refined fields
type SafeResult is
    | Success(Positive)
    | Failure(NonEmptyText);

// ============================================================================
// SECTION 9: ADVANCED REFINEMENT PATTERNS
// ============================================================================

// 9.1 Date components with refinements
type MonthOfYear is Int{>= 1 && <= 12};
type Year is Int{>= 1900 && <= 2100};

type Date is {
    day: DayOfMonth,
    month: MonthOfYear,
    year: Year
};

// 9.2 Multiple refinement styles in one program
type Score is Int{>= 0 && <= 100};
type Grade is Text where |g| g == "A" || g == "B" || g == "C" || g == "D" || g == "F";

type StudentRecord is {
    name: NonEmptyText,
    age: ValidAge,
    score: Score
};

// ============================================================================
// MAIN TEST FUNCTION
// ============================================================================

fn main() {
    print("╔════════════════════════════════════════════════════════════════╗");
    print("║         COMPREHENSIVE REFINEMENT TYPES TEST - VERUM           ║");
    print("╚════════════════════════════════════════════════════════════════╝");
    print("");

    // ========================================================================
    // TEST 1: INLINE REFINEMENTS
    // ========================================================================
    print("═══════════════════════════════════════════════════════════════");
    print("TEST 1: INLINE REFINEMENTS");
    print("═══════════════════════════════════════════════════════════════");
    print("");

    print("✓ Simple inline refinements:");
    let pos: Positive = 42;
    let neg: Negative = -10;
    let nonzero: NonZero = 7;
    let zero: Zero = 0;
    print(f"  • Positive: {pos}");
    print(f"  • Negative: {neg}");
    print(f"  • NonZero: {nonzero}");
    print(f"  • Zero: {zero}");
    print("");

    print("✓ Inline refinements with explicit 'it':");
    let bounded: Bounded = 0.5;
    let pct: Percentage = 75;
    let unit: UnitInterval = 0.25;
    print(f"  • Bounded [0.0, 1.0]: {bounded}");
    print(f"  • Percentage [0-100]: {pct}");
    print(f"  • UnitInterval [0.0, 1.0]: {unit}");
    print("");

    print("✓ Inline refinements with method calls:");
    let non_empty: NonEmptyText = "hello";
    let short: ShortText = "short";
    print(f"  • NonEmptyText: {non_empty}");
    print(f"  • ShortText: {short}");
    print("");

    print("✓ Multiple predicates (comma-separated):");
    let prob: Probability = 0.8;
    let age: ValidAge = 30;
    let day: DayOfMonth = 15;
    print(f"  • Probability: {prob}");
    print(f"  • ValidAge: {age}");
    print(f"  • DayOfMonth: {day}");
    print("");

    // ========================================================================
    // TEST 2: INLINE WITH EXPLICIT IT
    // ========================================================================
    print("═══════════════════════════════════════════════════════════════");
    print("TEST 2: INLINE REFINEMENT WITH EXPLICIT 'IT'");
    print("═══════════════════════════════════════════════════════════════");
    print("");

    let explicit_bounded: ExplicitBounded = 50;
    let explicit_positive: ExplicitPositive = 3.14;
    let explicit_range: ExplicitRange = 15;
    print(f"✓ ExplicitBounded [-100, 100]: {explicit_bounded}");
    print(f"✓ ExplicitPositive (> 0.0): {explicit_positive}");
    print(f"✓ ExplicitRange [10, 20]: {explicit_range}");
    print("");

    let even_pos: EvenPositive = 42;
    let odd_neg: OddNegative = -7;
    print(f"✓ EvenPositive (> 0 and even): {even_pos}");
    print(f"✓ OddNegative (< 0 and odd): {odd_neg}");
    print("");

    // ========================================================================
    // TEST 3: DECLARATIVE REFINEMENTS
    // ========================================================================
    print("═══════════════════════════════════════════════════════════════");
    print("TEST 3: DECLARATIVE REFINEMENTS (WHERE + named predicate)");
    print("═══════════════════════════════════════════════════════════════");
    print("");

    print("✓ Named predicate functions defined:");
    print("  • is_valid_email(s: Text) -> Bool");
    print("  • is_even(x: Int) -> Bool");
    print("  • is_prime(n: Int) -> Bool");
    print("");

    print("✓ Declarative refinement types:");
    print("  • type Email is Text where is_valid_email;");
    print("  • type EvenInt is Int where is_even;");
    print("  • type PrimeInt is Int where is_prime;");
    print("");

    // ========================================================================
    // TEST 4: LAMBDA REFINEMENTS
    // ========================================================================
    print("═══════════════════════════════════════════════════════════════");
    print("TEST 4: LAMBDA REFINEMENTS (WHERE + lambda)");
    print("═══════════════════════════════════════════════════════════════");
    print("");

    print("✓ Lambda refinements defined:");
    print("  • type LambdaAge is Int where |x| x >= 0 && x <= 150;");
    print("  • type LambdaPercentage is Float where |p| p >= 0.0 && p <= 100.0;");
    print("  • type LambdaNonEmpty is Text where |s| s.len() > 0;");
    print("");

    print("✓ Complex lambda refinements:");
    print("  • type LambdaEven is Int where |n| n % 2 == 0;");
    print("  • type LambdaOdd is Int where |n| n % 2 != 0;");
    print("  • type LambdaInRange is Int where |x| x >= 1 && x <= 10;");
    print("");

    // ========================================================================
    // TEST 5: SIGMA TYPE REFINEMENTS
    // ========================================================================
    print("═══════════════════════════════════════════════════════════════");
    print("TEST 5: SIGMA TYPE REFINEMENTS (explicit binding)");
    print("═══════════════════════════════════════════════════════════════");
    print("");

    print("✓ Sigma types with explicit variable binding:");
    print("  • type ValidEmail is email: Text where email.contains('@');");
    print("  • type BoundedInt is n: Int where n >= 0 && n <= 100;");
    print("  • type ValidText is s: Text where s.len() > 5;");
    print("");

    print("✓ Complex sigma types:");
    print("  • type SafeIndex is i: Int where i >= 0 && i < 1000;");
    print("  • type PositiveSigma is x: Int where x > 0;");
    print("  • type ValidRange is value: Int where value >= 10 && value <= 90;");
    print("");

    // ========================================================================
    // TEST 6: REFINEMENT IN FUNCTION PARAMETERS
    // ========================================================================
    print("═══════════════════════════════════════════════════════════════");
    print("TEST 6: REFINEMENT IN FUNCTION PARAMETERS");
    print("═══════════════════════════════════════════════════════════════");
    print("");

    print("✓ Functions with refined parameters:");
    let div_result = divide(10, 2);
    let ratio_result = calculate_ratio(20, 5);
    let square_result = square(7);
    print(f"  • divide(10, 2) = {div_result}");
    print(f"  • calculate_ratio(20, 5) = {ratio_result}");
    print(f"  • square(7) = {square_result}");
    print("");

    let clamped = clamp(150, -10, 100);
    print(f"✓ Mixed parameters: clamp(150, -10, 100) = {clamped}");
    print("");

    // ========================================================================
    // TEST 7: REFINEMENT IN RETURN TYPES
    // ========================================================================
    print("═══════════════════════════════════════════════════════════════");
    print("TEST 7: REFINEMENT IN RETURN TYPES");
    print("═══════════════════════════════════════════════════════════════");
    print("");

    print("✓ Functions with refined return types:");
    let abs_result1 = abs(-42);
