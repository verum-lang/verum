type Maybe<T> is
    | Some(T)
    | None;

type Color is
    | Red
    | Green
    | Blue;

fn main() {
    // 1. Literal patterns
    print(f"Testing literal patterns...");
    let x = 5;
    match x {
        0 => print(f"  zero"),
        1 => print(f"  one"),
        5 => print(f"  five"),
        _ => print(f"  other"),
    }

    // 2. Tuple patterns
    print(f"Testing tuple patterns...");
    let pair = (1, 2);
    match pair {
        (0, 0) => print(f"  origin"),
        (x, y) => print(f"  point: {x}, {y}"),
    }

    // 3. Or patterns
    print(f"Testing or patterns...");
    let n = 3;
    match n {
        1 | 2 | 3 => print(f"  small"),
        _ => print(f"  big"),
    }

    // 4. Guards
    print(f"Testing guard patterns...");
    let val = 15;
    match val {
        n if n < 10 => print(f"  small: {n}"),
        n if n < 20 => print(f"  medium: {n}"),
        _ => print(f"  large"),
    }

    // 5. Unit variant patterns
    print(f"Testing unit variant patterns...");
    let color = Color.Red;
    match color {
        Color.Red => print(f"  Red"),
        Color.Green => print(f"  Green"),
        Color.Blue => print(f"  Blue"),
    }

    // 6. Tuple variant patterns
    print(f"Testing tuple variant patterns...");
    let maybe_val = Maybe.Some(42);
    match maybe_val {
        Maybe.Some(x) => print(f"  Some: {x}"),
        Maybe.None => print(f"  None"),
    }

    print(f"All pattern tests complete!");
}
