// Test async generators: `async fn*` + `for await` consumption.
// Grammar authority: fn_keyword = 'fn' , [ '*' ] — yield requires the
// generator marker; async generators are consumed with `for await`
// (grammar/verum.ebnf for_await_loop). The pre-v5 form of this test
// (`async fn` + yield + awaiting the call) was never valid Verum.
async fn* generator_test() -> Int {
    yield 1;
    yield 2;
    yield 3;
}

async fn main() {
    print("Test: Async with yield");
    let mut sum = 0;
    for await v in generator_test() {
        sum = sum + v;
    }
    assert(sum == 6);
    print(f"Result: {sum}");
}
