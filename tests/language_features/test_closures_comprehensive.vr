// Test: Comprehensive Closure Testing
// Purpose: Exhaustive test coverage for ALL closure features per grammar
// Grammar Reference: verum.ebnf lines 716-717
//   closure_expr = [ 'async' ] , closure_params , [ '->' , type_expr ] , expression ;
//   closure_params = '|' , [ param_list_lambda ] , '|' ;
//
// This test covers:
// 1. Basic closures (zero to many parameters)
// 2. Type annotations (explicit and inferred)
// 3. Return type annotations
// 4. Async closures
// 5. Expression vs block bodies
// 6. Capture semantics (immutable and mutable)
// 7. Higher-order functions (closures as args/returns)
// 8. Closure composition and chaining
// 9. Closures with control flow
// 10. Closures with pattern matching
// 11. Generic closures
// 12. Closure type annotations in function signatures
// 13. Nested closures and lexical scoping
// 14. Closures with references
// 15. Complex real-world scenarios

// =============================================================================
// SECTION 1: TYPE DEFINITIONS
// =============================================================================

type Maybe<T> is
    | Some(T)
    | None;

type Result<T, E> is
    | Ok(T)
    | Err(E);

type Pair<A, B> is {
    first: A,
    second: B
};

type Triple<A, B, C> is (A, B, C);

type Point is {
    x: Int,
    y: Int
};

type Calculator is {
    name: Text,
    operation: fn(Int, Int) -> Int
};

type Processor<T, U> is {
    transform: fn(T) -> U
};

// =============================================================================
// SECTION 2: BASIC CLOSURES
// =============================================================================

fn test_basic_closures() {
    print("=== SECTION 2: Basic Closures ===");

    // Test 2.1: Zero-parameter closure
    let greet = || {
        print("Hello from closure!");
    };
    greet();

    // Test 2.2: Zero-parameter closure with return value
    let get_answer = || 42;
    let answer = get_answer();
    print(f"Answer: {answer}");

    // Test 2.3: Single parameter, no type annotation
    let double = |x| x * 2;
    print(f"Double 5: {double(5)}");

    // Test 2.4: Single parameter with type annotation
    let triple = |x: Int| x * 3;
    print(f"Triple 5: {triple(5)}");

    // Test 2.5: Single parameter with return type
    let quadruple = |x: Int| -> Int { x * 4 };
    print(f"Quadruple 5: {quadruple(5)}");

    // Test 2.6: Two parameters, inferred types
    let add = |a, b| a + b;
    print(f"Add 3+7: {add(3, 7)}");

    // Test 2.7: Two parameters with types
    let multiply = |a: Int, b: Int| a * b;
    print(f"Multiply 4*5: {multiply(4, 5)}");

    // Test 2.8: Two parameters with return type
    let subtract = |a: Int, b: Int| -> Int { a - b };
    print(f"Subtract 10-3: {subtract(10, 3)}");

    // Test 2.9: Three parameters
    let sum3 = |a: Int, b: Int, c: Int| a + b + c;
    print(f"Sum3 1+2+3: {sum3(1, 2, 3)}");

    // Test 2.10: Four parameters
    let sum4 = |a: Int, b: Int, c: Int, d: Int| a + b + c + d;
    print(f"Sum4 1+2+3+4: {sum4(1, 2, 3, 4)}");

    print("");
}

// =============================================================================
// SECTION 3: EXPRESSION VS BLOCK BODIES
// =============================================================================

fn test_expression_vs_block_bodies() {
    print("=== SECTION 3: Expression vs Block Bodies ===");

    // Test 3.1: Simple expression body
    let add_one = |x: Int| x + 1;
    print(f"Add one to 5: {add_one(5)}");

    // Test 3.2: Block body with single statement
    let add_two = |x: Int| {
        x + 2
    };
    print(f"Add two to 5: {add_two(5)}");

    // Test 3.3: Block body with multiple statements
    let complex_calc = |x: Int| {
        let step1 = x * 2;
        let step2 = step1 + 10;
        let step3 = step2 / 2;
        step3
    };
    print(f"Complex calc of 5: {complex_calc(5)}");

    // Test 3.4: Block body with early return
    let check_positive = |x: Int| {
        if x <= 0 {
            return false;
        }
        true
    };
    print(f"Check positive 5: {check_positive(5)}");
    print(f"Check positive -3: {check_positive(-3)}");

    // Test 3.5: Block body with let bindings
    let process = |x: Int| {
        let double = x * 2;
        let square = double * double;
        let result = square + x;
        result
    };
    print(f"Process 3: {process(3)}");

    print("");
}

// =============================================================================
// SECTION 4: CAPTURE SEMANTICS
// =============================================================================

fn test_capture_semantics() {
    print("=== SECTION 4: Capture Semantics ===");

    // Test 4.1: Capturing single immutable variable
    let base = 10;
    let add_base = |x: Int| x + base;
    print(f"Add base 10 to 5: {add_base(5)}");

    // Test 4.2: Capturing multiple immutable variables
    let x = 5;
    let y = 7;
    let z = 3;
    let combine = |n: Int| n + x + y + z;
    print(f"Combine with 2: {combine(2)}");

    // Test 4.3: Capturing mutable variable
    let mut counter = 0;
    let increment = || {
        counter = counter + 1;
        counter
    };
    print(f"Counter call 1: {increment()}");
    print(f"Counter call 2: {increment()}");
    print(f"Counter call 3: {increment()}");
    print(f"Final counter: {counter}");

    // Test 4.4: Capturing and modifying multiple mutables
    let mut sum = 0;
    let mut product = 1;
    let update_both = |n: Int| {
        sum = sum + n;
        product = product * n;
        (sum, product)
    };
    let (s1, p1) = update_both(2);
    print(f"After 2: sum={s1}, product={p1}");
    let (s2, p2) = update_both(3);
    print(f"After 3: sum={s2}, product={s2}");

    // Test 4.5: Nested capture
    let outer_val = 100;
    let outer_closure = |x: Int| {
        let inner_val = x + outer_val;
        let inner_closure = |y: Int| y + inner_val;
        inner_closure(5)
    };
    print(f"Nested capture: {outer_closure(10)}");

    // Test 4.6: Capturing in loop
    let mut results = [0, 0, 0, 0, 0];
    let multiplier = 3;
    let mut i = 0;
    while i < 5 {
        let compute = |idx: Int| idx * multiplier;
        results[i] = compute(i);
        i = i + 1;
    }
    print(f"Captured in loop: {results[2]}");

    print("");
}

// =============================================================================
// SECTION 5: ASYNC CLOSURES
// =============================================================================

async fn test_async_closures() {
    print("=== SECTION 5: Async Closures ===");

    // Test 5.1: Basic async closure
    let async_double = async |x: Int| x * 2;
    let result1 = async_double(21).await;
    print(f"Async double: {result1}");

    // Test 5.2: Async closure with block body
    let async_compute = async |x: Int| {
        let temp = x * 2;
        temp + 10
    };
    let result2 = async_compute(5).await;
    print(f"Async compute: {result2}");

    // Test 5.3: Async closure with multiple parameters
    let async_add = async |a: Int, b: Int| a + b;
    let result3 = async_add(15, 25).await;
    print(f"Async add: {result3}");

    // Test 5.4: Async closure with return type
    let async_multiply = async |a: Int, b: Int| -> Int {
        a * b
    };
    let result4 = async_multiply(6, 7).await;
    print(f"Async multiply: {result4}");

    // Test 5.5: Async closure capturing environment
    let base_value = 100;
    let async_add_base = async |x: Int| x + base_value;
    let result5 = async_add_base(50).await;
    print(f"Async with capture: {result5}");

    // Test 5.6: Nested async closures
    let outer_async = async |x: Int| {
        let inner_async = async |y: Int| y * 2;
        let doubled = inner_async(x).await;
        doubled + 1
    };
    let result6 = outer_async(10).await;
    print(f"Nested async: {result6}");

    print("");
}

// =============================================================================
// SECTION 6: HIGHER-ORDER FUNCTIONS
// =============================================================================

fn test_higher_order_functions() {
    print("=== SECTION 6: Higher-Order Functions ===");

    // Test 6.1: Closure as function parameter
    fn apply<T, U>(f: fn(T) -> U, value: T) -> U {
        f(value)
    }
    let double = |x: Int| x * 2;
    let result1 = apply(double, 5);
    print(f"Apply double to 5: {result1}");

    // Test 6.2: Multiple closures as parameters
    fn apply_binary<T, U, V>(f: fn(T, U) -> V, a: T, b: U) -> V {
        f(a, b)
    }
    let add = |x: Int, y: Int| x + y;
    let result2 = apply_binary(add, 10, 20);
    print(f"Apply binary add: {result2}");

    // Test 6.3: Closure returning closure
    let make_adder = |n: Int| -> fn(Int) -> Int {
        |x: Int| x + n
    };
    let add5 = make_adder(5);
    let add10 = make_adder(10);
    print(f"Make adder 5: {add5(3)}");
    print(f"Make adder 10: {add10(3)}");

    // Test 6.4: Closure returning closure (inferred syntax)
    let make_multiplier = |n: Int| |x: Int| x * n;
    let times3 = make_multiplier(3);
    let times7 = make_multiplier(7);
    print(f"Make multiplier 3: {times3(4)}");
    print(f"Make multiplier 7: {times7(4)}");

    // Test 6.5: Function accepting and returning closures
    fn compose<T>(f: fn(T) -> T, g: fn(T) -> T) -> fn(T) -> T {
        |x: T| g(f(x))
    }
    let add1 = |x: Int| x + 1;
    let mul2 = |x: Int| x * 2;
    let composed = compose(add1, mul2);
    print(f"Compose (x+1)*2 at 5: {composed(5)}");

    // Test 6.6: Apply twice pattern
    fn twice<T>(f: fn(T) -> T, value: T) -> T {
        f(f(value))
    }
    let inc = |x: Int| x + 1;
    print(f"Twice increment 10: {twice(inc, 10)}");

    // Test 6.7: Chain of applications
    fn apply_chain(funcs: [fn(Int) -> Int; 3], value: Int) -> Int {
        let r1 = funcs[0](value);
        let r2 = funcs[1](r1);
        let r3 = funcs[2](r2);
        r3
    }
    let f1 = |x: Int| x + 2;
    let f2 = |x: Int| x * 3;
    let f3 = |x: Int| x - 1;
    let result7 = apply_chain([f1, f2, f3], 5);
    print(f"Chain application: {result7}");

    print("");
}

// =============================================================================
// SECTION 7: CLOSURE COMPOSITION AND CHAINING
// =============================================================================

fn test_closure_composition() {
    print("=== SECTION 7: Closure Composition ===");

    // Test 7.1: Manual composition
    let f = |x: Int| x + 1;
    let g = |x: Int| x * 2;
    let composed = |x: Int| g(f(x));
    print(f"Composed (x+1)*2 at 5: {composed(5)}");

    // Test 7.2: Three-way composition
    let h1 = |x: Int| x + 10;
    let h2 = |x: Int| x * 2;
    let h3 = |x: Int| x - 5;
    let triple_composed = |x: Int| h3(h2(h1(x)));
    print(f"Triple composition at 5: {triple_composed(5)}");

    // Test 7.3: Closure chain with intermediate results
    let process = |x: Int| {
        let step1 = |n: Int| n + 10;
        let step2 = |n: Int| n * 2;
        let step3 = |n: Int| n - 5;
        let r1 = step1(x);
        let r2 = step2(r1);
        let r3 = step3(r2);
        r3
    };
    print(f"Chained process: {process(5)}");

    // Test 7.4: Nested closure definitions
    let outer = |x: Int| {
        let inner1 = |a: Int| a * 2;
        let inner2 = |b: Int| b + 3;
        inner2(inner1(x))
    };
    print(f"Nested definitions: {outer(7)}");

    // Test 7.5: Closure returning multiple closures
    let make_operators = |factor: Int| {
        let adder = |x: Int| x + factor;
        let multiplier = |x: Int| x * factor;
        (adder, multiplier)
    };
    let (add3, mul3) = make_operators(3);
    print(f"Add factor: {add3(10)}");
    print(f"Mul factor: {mul3(10)}");

    print("");
}

// =============================================================================
// SECTION 8: CLOSURES WITH CONTROL FLOW
// =============================================================================

fn test_closures_with_control_flow() {
    print("=== SECTION 8: Closures with Control Flow ===");

    // Test 8.1: If-else in closure
    let abs = |x: Int| {
        if x < 0 {
            -x
        } else {
            x
        }
    };
    print(f"Abs of -5: {abs(-5)}");
    print(f"Abs of 5: {abs(5)}");

    // Test 8.2: Multiple if-else branches
    let classify = |x: Int| {
        if x < 0 {
            "negative"
        } else if x == 0 {
            "zero"
        } else {
            "positive"
        }
    };
    print(f"Classify -3: {classify(-3)}");
    print(f"Classify 0: {classify(0)}");
    print(f"Classify 7: {classify(7)}");

    // Test 8.3: While loop in closure
    let sum_to_n = |n: Int| {
        let mut sum = 0;
        let mut i = 1;
        while i <= n {
            sum = sum + i;
            i = i + 1;
        }
        sum
    };
    print(f"Sum to 10: {sum_to_n(10)}");

    // Test 8.4: For loop in closure
    let sum_array = |arr: [Int; 5]| {
        let mut total = 0;
        for x in arr {
            total = total + x;
        }
        total
    };
    print(f"Sum array: {sum_array([1, 2, 3, 4, 5])}");

    // Test 8.5: Loop with early break
    let find_first_even = |arr: [Int; 5]| {
        let mut result = -1;
        for x in arr {
            if x % 2 == 0 {
                result = x;
                break;
            }
        }
        result
    };
    print(f"First even: {find_first_even([1, 3, 5, 8, 9])}");

    // Test 8.6: Loop with continue
    let count_odds = |arr: [Int; 6]| {
        let mut count = 0;
        for x in arr {
            if x % 2 == 0 {
                continue;
            }
            count = count + 1;
        }
        count
    };
    print(f"Count odds: {count_odds([1, 2, 3, 4, 5, 6])}");

    // Test 8.7: Nested loops
    let nested_sum = |n: Int| {
        let mut total = 0;
        let mut i = 1;
        while i <= n {
            let mut j = 1;
            while j <= i {
                total = total + 1;
                j = j + 1;
            }
            i = i + 1;
        }
        total
    };
    print(f"Nested sum: {nested_sum(5)}");

    print("");
}

// =============================================================================
// SECTION 9: CLOSURES WITH PATTERN MATCHING
// =============================================================================

fn test_closures_with_pattern_matching() {
    print("=== SECTION 9: Closures with Pattern Matching ===");

    // Test 9.1: Match on Maybe
    let unwrap_or = |opt: Maybe<Int>, default: Int| {
        match opt {
            Maybe.Some(v) => v,
            Maybe.None => default,
        }
    };
    print(f"Unwrap Some: {unwrap_or(Maybe.Some(42), 0)}");
    print(f"Unwrap None: {unwrap_or(Maybe.None, 99)}");

    // Test 9.2: Match on Result
    let get_or_zero = |res: Result<Int, Text>| {
        match res {
            Result.Ok(v) => v,
            Result.Err(_) => 0,
        }
    };
    print(f"Result Ok: {get_or_zero(Result.Ok(55))}");
    print(f"Result Err: {get_or_zero(Result.Err(\"error\"))}");

    // Test 9.3: Match with multiple patterns
    let describe = |n: Int| {
        match n {
            0 => "zero",
            1 => "one",
            2 => "two",
            _ => "many",
        }
    };
    print(f"Describe 0: {describe(0)}");
    print(f"Describe 1: {describe(1)}");
    print(f"Describe 5: {describe(5)}");

    // Test 9.4: Match with guards
    let classify_number = |x: Int| {
        match x {
            n where n < 0 => "negative",
            n where n == 0 => "zero",
            n where n > 0 => "positive",
            _ => "unknown",
        }
    };
    print(f"Classify -5: {classify_number(-5)}");
    print(f"Classify 0: {classify_number(0)}");
    print(f"Classify 7: {classify_number(7)}");

    // Test 9.5: Nested match with explicit type
    // Note: Nested variant matching may have type inference limitations
    let flatten_maybe = |outer: Maybe<Int>| {
        match outer {
            Maybe.Some(v) => v,
            Maybe.None => -1,
        }
    };
    let wrapped = Maybe.Some(42);
    print(f"Flatten Some: {flatten_maybe(wrapped)}");
    print(f"Flatten None: {flatten_maybe(Maybe.None)}");

    print("");
}

// =============================================================================
// SECTION 10: CLOSURES WITH TUPLES AND STRUCTS
// =============================================================================

fn test_closures_with_tuples_and_structs() {
    print("=== SECTION 10: Closures with Tuples and Structs ===");

    // Test 10.1: Closure returning tuple
    let split = |n: Int| -> (Int, Int) {
        (n / 2, n % 2)
    };
    let (quotient, remainder) = split(17);
    print(f"Split 17: q={quotient}, r={remainder}");

    // Test 10.2: Closure accepting tuple
    let add_tuple = |t: (Int, Int)| {
        let (a, b) = t;
        a + b
    };
    print(f"Add tuple: {add_tuple((15, 25))}");

    // Test 10.3: Closure with struct construction
    let make_point = |x: Int, y: Int| Point { x: x, y: y };
    let p = make_point(10, 20);
    print(f"Point: ({p.x}, {p.y})");

    // Test 10.4: Closure with struct field access
    let distance_from_origin = |pt: Point| {
        let x_sq = pt.x * pt.x;
        let y_sq = pt.y * pt.y;
        x_sq + y_sq
    };
    let dist = distance_from_origin(Point { x: 3, y: 4 });
    print(f"Distance squared: {dist}");

    // Test 10.5: Closure in struct field
    let calc = Calculator {
        name: "Adder",
        operation: |a, b| a + b,
    };
    let sum = (calc.operation)(30, 12);
    print(f"Calculator {calc.name}: {sum}");

    // Test 10.6: Multiple closures in struct
    let processor = Processor {
        transform: |x: Int| x * 2,
    };
    let processed = (processor.transform)(15);
    print(f"Processed: {processed}");

    // Test 10.7: Closure working with Pair
    let make_pair = |a: Int, b: Text| Pair { first: a, second: b };
    let pair = make_pair(42, "answer");
    print(f"Pair: ({pair.first}, {pair.second})");

    // Test 10.8: Closure returning Triple (tuple)
    let make_triple = |a: Int, b: Bool, c: Text| (a, b, c);
    let triple = make_triple(1, true, "test");
    let (n, flag, msg) = triple;
    print(f"Triple: {n}, {flag}, {msg}");

    print("");
}

// =============================================================================
// SECTION 11: GENERIC CLOSURES
// =============================================================================

fn test_generic_closures() {
    print("=== SECTION 11: Generic Closures ===");

    // Test 11.1: Generic function with closure
    fn map_option<T, U>(opt: Maybe<T>, f: fn(T) -> U) -> Maybe<U> {
        match opt {
            Maybe.Some(v) => Maybe.Some(f(v)),
            Maybe.None => Maybe.None,
        }
    }

    let some_int = Maybe.Some(10);
    let doubled = map_option(some_int, |x| x * 2);
    match doubled {
        Maybe.Some(v) => print(f"Mapped Some: {v}"),
        Maybe.None => print("Mapped None"),
    }

    let none_int = Maybe.None;
    let doubled_none = map_option(none_int, |x: Int| x * 2);
    match doubled_none {
        Maybe.Some(v) => print(f"Mapped Some: {v}"),
        Maybe.None => print("Mapped None"),
    }

    // Test 11.2: Generic filter
    fn filter_option<T>(opt: Maybe<T>, predicate: fn(T) -> Bool) -> Maybe<T> {
        match opt {
            Maybe.Some(v) => {
                if predicate(v) {
                    Maybe.Some(v)
                } else {
                    Maybe.None
                }
            },
            Maybe.None => Maybe.None,
        }
    }

    let some_val = Maybe.Some(15);
    let filtered = filter_option(some_val, |x: Int| x > 10);
    match filtered {
        Maybe.Some(v) => print(f"Filtered Some: {v}"),
        Maybe.None => print("Filtered None"),
    }

    // Test 11.3: Generic fold
    fn fold_result<T, E, U>(
        result: Result<T, E>,
        on_ok: fn(T) -> U,
        on_err: fn(E) -> U
    ) -> U {
        match result {
            Result.Ok(v) => on_ok(v),
            Result.Err(e) => on_err(e),
        }
    }

    let ok_result = Result.Ok(42);
    let folded = fold_result(
        ok_result,
        |v: Int| v * 2,
        |_e: Text| 0
    );
    print(f"Folded Ok: {folded}");

    let err_result = Result.Err("error");
    let folded_err = fold_result(
        err_result,
        |v: Int| v * 2,
        |_e: Text| -1
    );
    print(f"Folded Err: {folded_err}");

    print("");
}

// =============================================================================
// SECTION 12: NESTED CLOSURES AND LEXICAL SCOPING
// =============================================================================

fn test_nested_closures() {
    print("=== SECTION 12: Nested Closures ===");

    // Test 12.1: Two-level nesting
    let outer = |x: Int| {
        let inner = |y: Int| x + y;
        inner(5)
    };
    print(f"Two-level nesting: {outer(10)}");

    // Test 12.2: Three-level nesting
    let level1 = |a: Int| {
        let level2 = |b: Int| {
            let level3 = |c: Int| a + b + c;
            level3(3)
        };
        level2(2)
    };
    print(f"Three-level nesting: {level1(1)}");

    // Test 12.3: Nested with different captures
    let x = 100;
    let nested_capture = |y: Int| {
        let z = 10;
        let inner = |w: Int| x + y + z + w;
        inner(1)
    };
    print(f"Nested capture: {nested_capture(5)}");

    // Test 12.4: Closure returning nested closure
    let make_nested = |outer_val: Int| {
        |inner_val: Int| {
            outer_val + inner_val
        }
    };
    let nested_fn = make_nested(100);
    print(f"Nested function: {nested_fn(50)}");

    // Test 12.5: Multiple nested closures with shared capture
    let shared = 42;
    let closure_a = |x: Int| {
        let closure_b = |y: Int| x + y + shared;
        closure_b(3)
    };
    print(f"Shared capture: {closure_a(5)}");

    // Test 12.6: Deeply nested with mutation
    let mut accumulator = 0;
    let nest1 = || {
        accumulator = accumulator + 1;
        let nest2 = || {
            accumulator = accumulator + 10;
            let nest3 = || {
                accumulator = accumulator + 100;
                accumulator
            };
            nest3()
        };
        nest2()
    };
    let final_value = nest1();
    print(f"Deeply nested mutation: {final_value}");

    print("");
}

// =============================================================================
// SECTION 13: CLOSURES WITH REFERENCES
// =============================================================================

fn test_closures_with_references() {
    print("=== SECTION 13: Closures with References ===");

    // Test 13.1: Closure accepting reference
    let double_ref = |r: &Int| *r * 2;
    let value = 21;
    print(f"Double via ref: {double_ref(&value)}");

    // Test 13.2: Closure with multiple references
    let add_refs = |a: &Int, b: &Int| *a + *b;
    let x = 10;
    let y = 20;
    print(f"Add refs: {add_refs(&x, &y)}");

    // Test 13.3: Closure returning reference to captured value
    // Note: This may have lifetime constraints in actual implementation
    let container = 100;
    let get_container_ref = || &container;
    let ref_value = *get_container_ref();
    print(f"Container via ref closure: {ref_value}");

    // Test 13.4: Closure modifying through reference
    let mut data = 50;
    let modify_data = |r: &mut Int| {
        *r = *r + 10;
    };
    modify_data(&mut data);
    print(f"Modified data: {data}");

    print("");
}

// =============================================================================
// SECTION 14: REAL-WORLD SCENARIOS
// =============================================================================

fn test_real_world_scenarios() {
    print("=== SECTION 14: Real-World Scenarios ===");

    // Test 14.1: Safe division
    let safe_divide = |a: Int, b: Int| -> Result<Int, Text> {
        if b == 0 {
            Result.Err("Division by zero")
        } else {
            Result.Ok(a / b)
        }
    };

    match safe_divide(10, 2) {
        Result.Ok(v) => print(f"Division result: {v}"),
        Result.Err(e) => print(f"Division error: {e}"),
    }

    match safe_divide(10, 0) {
        Result.Ok(v) => print(f"Division result: {v}"),
        Result.Err(e) => print(f"Division error: {e}"),
    }

    // Test 14.2: Validator closure
    let is_valid_age = |age: Int| age >= 0 && age <= 150;
    print(f"Valid age 25: {is_valid_age(25)}");
    print(f"Valid age -5: {is_valid_age(-5)}");
    print(f"Valid age 200: {is_valid_age(200)}");

    // Test 14.3: Formatter closure
    let format_currency = |amount: Int| {
        if amount < 0 {
            f"-${-amount}"
        } else {
            f"${amount}"
        }
    };
    print(f"Format: {format_currency(100)}");
    print(f"Format: {format_currency(-50)}");

    // Test 14.4: Parser closure
    let parse_bool = |s: Text| -> Maybe<Bool> {
        if s == "true" {
            Maybe.Some(true)
        } else if s == "false" {
            Maybe.Some(false)
        } else {
            Maybe.None
        }
    };

    match parse_bool("true") {
        Maybe.Some(b) => print(f"Parsed: {b}"),
        Maybe.None => print("Parse failed"),
    }

    // Test 14.5: Memoization pattern (simplified)
    let mut cache = -1;
    let mut cache_input = -1;
    let expensive_computation = |n: Int| {
        if cache_input == n {
            print(f"Cache hit for {n}");
            cache
        } else {
            print(f"Computing for {n}");
            let result = n * n * n;
            cache = result;
            cache_input = n;
            result
        }
    };

    let r1 = expensive_computation(5);
    print(f"Result: {r1}");
    let r2 = expensive_computation(5);
    print(f"Result: {r2}");
    let r3 = expensive_computation(6);
    print(f"Result: {r3}");

    // Test 14.6: State machine using closure
    let mut state = 0;
    let next_state = || {
        state = match state {
            0 => 1,
            1 => 2,
            2 => 0,
            _ => 0,
        };
        state
    };

    print(f"State: {next_state()}");
    print(f"State: {next_state()}");
    print(f"State: {next_state()}");
    print(f"State: {next_state()}");

    // Test 14.7: Event handler pattern
    let mut click_count = 0;
    let on_click = || {
        click_count = click_count + 1;
        print(f"Button clicked {click_count} times");
    };

    on_click();
    on_click();
    on_click();

    // Test 14.8: Builder pattern with closures
    let mut config_value = 0;
    let mut config_name = "default";

    let set_value = |v: Int| {
        config_value = v;
    };

    let set_name = |n: Text| {
        config_name = n;
    };

    let build_config = || {
        print(f"Config: name={config_name}, value={config_value}");
    };

    set_value(42);
    set_name("production");
    build_config();

    print("");
}

// =============================================================================
// SECTION 15: CLOSURE TYPE ANNOTATIONS
// =============================================================================

fn test_closure_type_annotations() {
    print("=== SECTION 15: Closure Type Annotations ===");

    // Test 15.1: Function accepting typed closure
    fn apply_transform(x: Int, transform: fn(Int) -> Int) -> Int {
        transform(x)
    }

    let double = |n: Int| n * 2;
    print(f"Apply transform: {apply_transform(7, double)}");

    // Test 15.2: Function returning typed closure
    fn get_adder(n: Int) -> fn(Int) -> Int {
        |x: Int| x + n
    }

    let add_20 = get_adder(20);
    print(f"Get adder: {add_20(5)}");

    // Test 15.3: Complex function type
    fn chain_transforms(
        f1: fn(Int) -> Int,
        f2: fn(Int) -> Int,
        f3: fn(Int) -> Int
    ) -> fn(Int) -> Int {
        |x: Int| f3(f2(f1(x)))
    }

    let t1 = |x: Int| x + 1;
    let t2 = |x: Int| x * 2;
    let t3 = |x: Int| x - 3;
    let chained = chain_transforms(t1, t2, t3);
    print(f"Chained: {chained(10)}");

    // Test 15.4: Function with multiple closure params
    fn combine(
        a: Int,
        b: Int,
        op1: fn(Int, Int) -> Int,
        op2: fn(Int) -> Int
    ) -> Int {
        let intermediate = op1(a, b);
        op2(intermediate)
    }

    let add = |x: Int, y: Int| x + y;
    let square = |x: Int| x * x;
    print(f"Combine: {combine(3, 4, add, square)}");

    print("");
}

// =============================================================================
// SECTION 16: EDGE CASES AND STRESS TESTS
// =============================================================================

fn test_edge_cases() {
    print("=== SECTION 16: Edge Cases ===");

    // Test 16.1: Closure with no operations
    let noop = |x: Int| x;
    print(f"No-op: {noop(42)}");

    // Test 16.2: Closure always returning constant
    let constant = |_x: Int| 999;
    print(f"Constant: {constant(123)}");

    // Test 16.3: Deeply nested closures (5 levels)
    let l1 = |x: Int| {
        let l2 = |y: Int| {
            let l3 = |z: Int| {
                let l4 = |w: Int| {
                    let l5 = |v: Int| x + y + z + w + v;
                    l5(5)
                };
                l4(4)
            };
            l3(3)
        };
        l2(2)
    };
    print(f"5-level nesting: {l1(1)}");

    // Test 16.4: Closure with many parameters
    let sum8 = |a: Int, b: Int, c: Int, d: Int, e: Int, f: Int, g: Int, h: Int| {
        a + b + c + d + e + f + g + h
    };
    print(f"8 params: {sum8(1, 2, 3, 4, 5, 6, 7, 8)}");

    // Test 16.5: Closure capturing many variables
    let v1 = 1;
    let v2 = 2;
    let v3 = 3;
    let v4 = 4;
    let v5 = 5;
    let v6 = 6;
    let v7 = 7;
    let v8 = 8;
    let capture_many = |x: Int| x + v1 + v2 + v3 + v4 + v5 + v6 + v7 + v8;
    print(f"Capture many: {capture_many(0)}");

    // Test 16.6: Recursive closure pattern
    let mut factorial = |n: Int| -> Int {
        if n <= 1 {
            1
        } else {
            // Direct recursion not supported, use iteration
            let mut result = 1;
            let mut i = 2;
            while i <= n {
                result = result * i;
                i = i + 1;
            }
            result
        }
    };
    print(f"Factorial 5: {factorial(5)}");

    // Test 16.7: Closure with very long body
    let long_computation = |x: Int| {
        let a = x + 1;
        let b = a * 2;
        let c = b - 3;
        let d = c + 4;
        let e = d * 5;
        let f = e - 6;
        let g = f + 7;
        let h = g * 8;
        let i = h - 9;
        let j = i + 10;
        j
    };
    print(f"Long computation: {long_computation(1)}");

    print("");
}

