// ============================================================================
// COMPREHENSIVE PROTOCOL FEATURES TEST
// Tests: ALL protocol features per grammar/verum.ebnf
// ============================================================================
//
// Coverage:
// 1. Basic protocol definition
// 2. Protocol with multiple methods
// 3. Protocol with associated types
// 4. Protocol extension (extends)
// 5. Protocol implementation
// 6. Generic protocol implementation
// 7. Default method implementations
// 8. Self type usage in protocols
// 9. Protocol const (definition only - impl not yet supported)
// 10. Protocol bounds (single and multiple)
// 11. Where clauses in protocols
// 12. Inherent implementations (no protocol)
//
// ============================================================================

// ============================================================================
// Test 1: Basic Protocol Definition
// Grammar: type_def -> 'protocol' '{' protocol_items '}'
// ============================================================================

type Display is protocol {
    fn fmt(&self) -> Text;
};

type Debug is protocol {
    fn fmt_debug(&self) -> Text;
};

// ============================================================================
// Test 2: Protocol with Multiple Methods
// Grammar: protocol_items = { protocol_item }
// ============================================================================

type Collection is protocol {
    fn len(&self) -> Int;
    fn is_empty(&self) -> Bool;
    fn clear(&mut self);
};

// ============================================================================
// Test 3: Protocol with Associated Types
// Grammar: protocol_type = 'type' identifier ';'
// NOTE: Using associated types in method signatures (Self.Item) not yet fully supported
// ============================================================================

type Iterator is protocol {
    type Item;

    fn next(&mut self) -> Int;
};

type Container is protocol {
    type Element;

    fn get(&self, index: Int) -> Int;
    fn set(&mut self, index: Int, value: Int);
};

// ============================================================================
// Test 4: Protocol Extension
// Grammar: protocol extends trait_path
// ============================================================================

type Eq is protocol {
    fn eq(&self, other: &Self) -> Bool;
};

type Ord is protocol extends Eq {
    fn cmp(&self, other: &Self) -> Int;
};

type PartialOrd is protocol extends Eq {
    fn partial_cmp(&self, other: &Self) -> Maybe<Int>;
};

// ============================================================================
// Test 5: Protocol with Default Method Implementations
// Grammar: default_impl = block_expr | '=' expression ';'
// ============================================================================

type Comparable is protocol {
    fn eq_comparable(&self, other: &Self) -> Bool;

    fn ne(&self, other: &Self) -> Bool {
        !self.eq_comparable(other)
    }
};

type Ordered is protocol extends Comparable {
    fn cmp_ordered(&self, other: &Self) -> Int;

    fn lt(&self, other: &Self) -> Bool {
        self.cmp_ordered(other) < 0
    }

    fn le(&self, other: &Self) -> Bool {
        self.cmp_ordered(other) <= 0
    }

    fn gt(&self, other: &Self) -> Bool {
        self.cmp_ordered(other) > 0
    }

    fn ge(&self, other: &Self) -> Bool {
        self.cmp_ordered(other) >= 0
    }
};

// ============================================================================
// Test 6: Protocol with Const
// Grammar: protocol_const = 'const' identifier ':' type_expr ';'
// NOTE: Const in implementation blocks not yet supported
// ============================================================================

type Sized is protocol {
    const SIZE: Int;

    fn byte_size(&self) -> Int;
};

type FixedArray is protocol {
    const LENGTH: Int;
    const CAPACITY: Int;

    fn length(&self) -> Int;
};

// ============================================================================
// Test 7: Self Type Usage in Protocols
// Protocol methods using Self extensively
// ============================================================================

type Cloneable is protocol {
    fn clone(&self) -> Self;
    fn clone_from(&mut self, other: &Self);
};

type Builder is protocol {
    fn new() -> Self;
    fn with_value(self, value: Int) -> Self;
    fn build(self) -> Self;
};

// ============================================================================
// Test 8: Generic Protocol
// ============================================================================

type Converter<T> is protocol {
    fn convert(&self) -> Int;
};

// ============================================================================
// RECORD AND VARIANT TYPES FOR TESTING
// ============================================================================

type Point is { x: Int, y: Int };

type Rectangle is {
    width: Int,
    height: Int
};

type Counter is {
    count: Int
};

type Pair<T> is {
    first: T,
    second: T
};

type Wrapper<T> is {
    value: T
};

type Option<T> is
    | Some(T)
    | None;

type Result<T, E> is
    | Ok(T)
    | Err(E);

type SimpleList is {
    items: Int,
    capacity: Int
};

// ============================================================================
// Test 9: Basic Protocol Implementation
// Grammar: implement type_expr 'for' type_expr '{' impl_item '}'
// ============================================================================

implement Display for Point {
    fn fmt(&self) -> Text {
        f"Point({self.x}, {self.y})"
    }
}

implement Debug for Point {
    fn fmt_debug(&self) -> Text {
        f"Point(x={self.x}, y={self.y})"
    }
}

implement Eq for Point {
    fn eq(&self, other: &Self) -> Bool {
        self.x == other.x && self.y == other.y
    }
}

implement Ord for Point {
    fn cmp(&self, other: &Self) -> Int {
        if self.x < other.x {
            -1
        } else if self.x > other.x {
            1
        } else if self.y < other.y {
            -1
        } else if self.y > other.y {
            1
        } else {
            0
        }
    }
}

implement Comparable for Point {
    fn eq_comparable(&self, other: &Self) -> Bool {
        self.x == other.x && self.y == other.y
    }
}

implement Cloneable for Point {
    fn clone(&self) -> Self {
        Point { x: self.x, y: self.y }
    }

    fn clone_from(&mut self, other: &Self) {
        self.x = other.x;
        self.y = other.y;
    }
}

// ============================================================================
// Test 10: Protocol Implementation with Associated Types
// Grammar: type_alias in impl_item
// ============================================================================

implement Iterator for Counter {
    type Item = Int;

    fn next(&mut self) -> Int {
        if self.count < 10 {
            self.count = self.count + 1;
            self.count
        } else {
            0
        }
    }
}

implement Container for SimpleList {
    type Element = Int;

    fn get(&self, index: Int) -> Int {
        if index >= 0 && index < self.items {
            42
        } else {
            -1
        }
    }

    fn set(&mut self, index: Int, value: Int) {
        self.items = value;
    }
}

// ============================================================================
// Test 11: Collection Protocol Implementation
// ============================================================================

implement Collection for SimpleList {
    fn len(&self) -> Int {
        self.items
    }

    fn is_empty(&self) -> Bool {
        self.items == 0
    }

    fn clear(&mut self) {
        self.items = 0;
    }
}

implement Sized for Rectangle {
    fn byte_size(&self) -> Int {
        16
    }
}

implement FixedArray for SimpleList {
    fn length(&self) -> Int {
        10
    }
}

// ============================================================================
// Test 12: Inherent Implementation (no protocol)
// Grammar: implement type_expr '{' impl_item '}'
// ============================================================================

implement Point {
    fn new(x: Int, y: Int) -> Point {
        Point { x: x, y: y }
    }

    fn origin() -> Point {
        Point { x: 0, y: 0 }
    }

    fn distance(&self, other: &Point) -> Int {
        let dx = self.x - other.x;
        let dy = self.y - other.y;
        dx * dx + dy * dy
    }

    fn translate(&mut self, dx: Int, dy: Int) {
        self.x = self.x + dx;
        self.y = self.y + dy;
    }
}

implement Rectangle {
    fn new(width: Int, height: Int) -> Rectangle {
        Rectangle { width: width, height: height }
    }

    fn area(&self) -> Int {
        self.width * self.height
    }

    fn perimeter(&self) -> Int {
        2 * (self.width + self.height)
    }

    fn is_square(&self) -> Bool {
        self.width == self.height
    }
}

// ============================================================================
// Test 13: Generic Functions with Protocol Bounds
// ============================================================================

fn display<T>(value: &T) -> Text where type T: Display {
    value.fmt()
}

fn debug<T>(value: &T) -> Text where type T: Debug {
    value.fmt_debug()
}

fn equals<T>(a: &T, b: &T) -> Bool where type T: Eq {
    a.eq(b)
}

fn compare<T>(a: &T, b: &T) -> Int where type T: Ord {
    a.cmp(b)
}

fn clone_value<T>(value: &T) -> T where type T: Cloneable {
    value.clone()
}

fn display_and_debug<T>(value: &T) where type T: Display + Debug {
    print(value.fmt());
    print(value.fmt_debug());
}

fn print_collection<C>(collection: &C) where type C: Collection {
    let len = collection.len();
    let empty = collection.is_empty();
    print(f"Collection: len={len}, empty={empty}");
}

// ============================================================================
// Test 14: Functions Using Associated Types
// ============================================================================

fn iterate<I>(iter: &mut I) where type I: Iterator {
    let val = iter.next();
    print(f"Iterator: next={val}");
}

fn get_from_container<C>(container: &C, index: Int) where type C: Container {
    let item = container.get(index);
    print(f"Container[{index}] = {item}");
}

// ============================================================================
// MAIN FUNCTION: Test All Protocol Features
// ============================================================================

fn main() {
    print(f"=== COMPREHENSIVE PROTOCOL FEATURES TEST ===");

    // Test 1: Basic protocol implementations
    print(f"--- Test 1: Basic Protocols ---");
    let p1 = Point { x: 10, y: 20 };
    let p2 = Point { x: 5, y: 15 };
    print(p1.fmt());
    print(p1.fmt_debug());

    // Test 2: Eq and Ord protocols
    print(f"--- Test 2: Eq and Ord Protocols ---");
    let is_equal = p1.eq(&p2);
    let cmp_result = p1.cmp(&p2);
    print(f"Equality: {is_equal}, Comparison: {cmp_result}");

    // Test 3: Comparable with default methods
    print(f"--- Test 3: Default Method Implementations ---");
    let eq_comp = p1.eq_comparable(&p2);
    let ne_comp = p1.ne(&p2);
    print(f"eq_comparable: {eq_comp}, ne: {ne_comp}");

    // Test 4: Cloneable protocol
    print(f"--- Test 4: Cloneable Protocol ---");
    let p3 = p1.clone();
    print(f"Clone created: {p3.fmt()}");

    // Test 5: Iterator protocol with associated type
    print(f"--- Test 5: Iterator Protocol ---");
    let mut counter = Counter { count: 0 };
    let val1 = counter.next();
    let val2 = counter.next();
    print(f"Iterator: val1={val1}, val2={val2}");

    // Test 6: Container protocol with associated type
    print(f"--- Test 6: Container Protocol ---");
    let mut list = SimpleList { items: 5, capacity: 10 };
    let elem = list.get(2);
    list.set(2, 42);
    print(f"Container: elem={elem}");

    // Test 7: Inherent implementations
    print(f"--- Test 7: Inherent Implementations ---");
    let origin = Point.origin();
    let custom = Point.new(100, 200);
    let dist = p1.distance(&p2);
    print(f"Inherent: origin={origin.fmt()}, custom={custom.fmt()}, dist={dist}");

    let rect = Rectangle.new(100, 50);
    let area = rect.area();
    let perim = rect.perimeter();
    let is_sq = rect.is_square();
    print(f"Rectangle: area={area}, perimeter={perim}, square={is_sq}");

    // Test 8: Collection protocol
    print(f"--- Test 8: Collection Protocol ---");
    let len = list.len();
    let empty = list.is_empty();
    list.clear();
    print(f"Collection: len={len}, empty={empty}");

    // Test 9: Protocol with const and methods
    print(f"--- Test 9: Protocol Constants ---");
    let byte_size = rect.byte_size();
    let list_length = list.length();
    print(f"Sized: byte_size={byte_size}, length={list_length}");

    // Test 10: Generic functions with bounds
    print(f"--- Test 10: Generic Functions with Bounds ---");
    let displayed = display(&p1);
    let debugged = debug(&p1);
    let are_equal = equals(&p1, &p2);
    let comparison = compare(&p1, &p2);
    let cloned = clone_value(&p1);
    print(f"Generic funcs: display={displayed}, debug={debugged}");
    print(f"Generic funcs: equal={are_equal}, cmp={comparison}");
    display_and_debug(&p1);

    // Test 11: Functions with associated types
    print(f"--- Test 11: Functions with Associated Types ---");
    iterate(&mut counter);
    get_from_container(&list, 0);
    print_collection(&list);

    // Test 12: Protocol extension
    print(f"--- Test 12: Protocol Extension ---");
    let ord_cmp = p1.cmp(&p2);
    let partial_cmp = p1.partial_cmp(&p2);
    print(f"Protocol extension: ord_cmp={ord_cmp}");

    // Test 13: Ordered protocol with default methods
    print(f"--- Test 13: Ordered Protocol Defaults ---");
    let p4 = Point { x: 10, y: 20 };
    let p5 = Point { x: 10, y: 20 };
    let pair_cmp = p4.cmp_ordered(&p5);
    let pair_lt = p4.lt(&p5);
    let pair_le = p4.le(&p5);
    let pair_gt = p4.gt(&p5);
    let pair_ge = p4.ge(&p5);
    print(f"Ordered: cmp={pair_cmp}, lt={pair_lt}, le={pair_le}, gt={pair_gt}, ge={pair_ge}");

    print(f"=== ALL PROTOCOL TESTS COMPLETE ===");
}
