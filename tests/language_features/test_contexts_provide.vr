// Test the provide statement itself (value-form, v5.1).

context Logger {
    fn log(message: Text);
}

type ConsoleLogger is {
    prefix: Text,
};

implement Logger for ConsoleLogger {
    fn log(&self, message: Text) {
        print(f"[LOG] {message}");
    }
}

fn main() {
    provide Logger = ConsoleLogger { prefix: "PRV" };

    print("Provide statement works");
}
