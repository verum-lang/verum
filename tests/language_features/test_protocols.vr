// Test: Protocols - Protocol definitions and implementations
// Priority: Critical
// Expected output: Protocol method calls and implementations

// Basic protocol
type Display is protocol {
    fn fmt(&self) -> Text;
};

// Record types
type Point is { x: Int, y: Int };
type Rect is { width: Int, height: Int };

// Implement Display for Point
implement Display for Point {
    fn fmt(&self) -> Text {
        f"Point({self.x}, {self.y})"
    }
}

// Implement Display for Rect
implement Display for Rect {
    fn fmt(&self) -> Text {
        f"Rect({self.width}x{self.height})"
    }
}

fn main() {
    // Test Display protocol
    let p1 = Point { x: 10, y: 20 };
    print(f"Point formatted: {p1.fmt()}");

    let p2 = Point { x: 5, y: 15 };
    print(f"Another point: {p2.fmt()}");

    // Test Display for Rect
    let r = Rect { width: 100, height: 50 };
    print(f"Rect formatted: {r.fmt()}");

    print(f"Protocol tests complete!");
}
