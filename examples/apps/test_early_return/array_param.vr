// Array param early return test

fn find_first_even(arr: [Int; 5]) -> Int {
    let mut i = 0;
    while i < 5 {
        if arr[i] % 2 == 0 {
            return arr[i];
        }
        i = i + 1;
    }
    -1
}

fn main() {
    let arr = [1, 3, 5, 6, 9];
    print(f"find_first_even = {find_first_even(arr)}");
}
