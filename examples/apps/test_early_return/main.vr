// Early Return Test

fn find_first_even(arr: [Int; 5]) -> Int {
    let mut i = 0;
    while i < 5 {
        if arr[i] % 2 == 0 {
            return arr[i];
        }
        i = i + 1;
    }
    -1
}

fn is_prime(n: Int) -> Bool {
    if n < 2 { return false; }
    let mut i = 2;
    while i * i <= n {
        if n % i == 0 {
            return false;
        }
        i = i + 1;
    }
    true
}

fn early_return_simple(n: Int) -> Int {
    if n > 10 {
        return 100;
    }
    return n;
}

fn main() {
    print("=== Early Return Test ===");

    // Simple early return
    print(f"early_return_simple(5) = {early_return_simple(5)}");
    print(f"early_return_simple(15) = {early_return_simple(15)}");

    // Early return in loop
    let arr1 = [1, 3, 5, 6, 9];
    let arr2 = [1, 3, 5, 7, 9];
    print(f"find_first_even([1,3,5,6,9]) = {find_first_even(arr1)}");
    print(f"find_first_even([1,3,5,7,9]) = {find_first_even(arr2)}");

    // Prime check
    print(f"is_prime(2) = {is_prime(2)}");
    print(f"is_prime(17) = {is_prime(17)}");
    print(f"is_prime(15) = {is_prime(15)}");
    print(f"is_prime(97) = {is_prime(97)}");

    print("=== Done ===");
}
