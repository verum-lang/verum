// Comprehensive Function Features Test
// Tests all function-related features in Verum

// ===== Test 1: Basic Functions =====

fn add(a: Int, b: Int) -> Int {
    a + b
}

fn multiply(x: Int, y: Int) -> Int {
    x * y
}

fn greet(name: Text) -> Text {
    "Hello, " + name + "!"
}

// Function with no return value (implicit unit return)
fn print_message(msg: Text) {
    print(msg);
}

// ===== Test 2: Multiple Return Values via Tuples =====

fn divide_with_remainder(a: Int, b: Int) -> (Int, Int) {
    let quotient = a / b;
    let remainder = a % b;
    (quotient, remainder)
}

fn min_max(a: Int, b: Int) -> (Int, Int) {
    if a < b {
        (a, b)
    } else {
        (b, a)
    }
}

fn swap<T>(a: T, b: T) -> (T, T) {
    (b, a)
}

// ===== Test 3: Expression Body Functions =====

fn square(x: Int) -> Int = x * x;

fn is_even(n: Int) -> Bool = n % 2 == 0;

fn is_odd(n: Int) -> Bool = n % 2 != 0;

fn abs(x: Int) -> Int = if x < 0 { -x } else { x };

// ===== Test 4: Generic Functions =====

fn identity<T>(value: T) -> T {
    value
}

fn pair<A, B>(first: A, second: B) -> (A, B) {
    (first, second)
}

fn first<A, B>(tuple: (A, B)) -> A {
    let (a, _) = tuple;
    a
}

fn second<A, B>(tuple: (A, B)) -> B {
    let (_, b) = tuple;
    b
}

// Generic with type constraint would be:
// fn max<T: Comparable>(a: T, b: T) -> T where T: Comparable {
//     if a > b { a } else { b }
// }

// ===== Test 5: Higher-Order Functions =====

fn apply<A, B>(f: fn(A) -> B, value: A) -> B {
    f(value)
}

fn compose<A, B, C>(f: fn(B) -> C, g: fn(A) -> B, x: A) -> C {
    f(g(x))
}

fn twice<T>(f: fn(T) -> T, value: T) -> T {
    f(f(value))
}

// ===== Test 6: Closures =====

fn make_adder(n: Int) -> fn(Int) -> Int {
    |x| x + n
}

fn map_numbers(nums: [Int], f: fn(Int) -> Int) -> [Int] {
    let result = [];
    for n in nums {
        result.push(f(n));
    }
    result
}

fn filter_numbers(nums: [Int], predicate: fn(Int) -> Bool) -> [Int] {
    let result = [];
    for n in nums {
        if predicate(n) {
            result.push(n);
        }
    }
    result
}

// ===== Test 7: Recursive Functions =====

fn factorial(n: Int) -> Int {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

fn fibonacci(n: Int) -> Int {
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    }
}

fn gcd(a: Int, b: Int) -> Int {
    if b == 0 {
        a
    } else {
        gcd(b, a % b)
    }
}

// ===== Test 8: Mutual Recursion =====

fn is_even_recursive(n: Int) -> Bool {
    if n == 0 {
        true
    } else {
        is_odd_recursive(n - 1)
    }
}

fn is_odd_recursive(n: Int) -> Bool {
    if n == 0 {
        false
    } else {
        is_even_recursive(n - 1)
    }
}

// ===== Test 9: Functions Returning Functions =====

fn make_multiplier(factor: Int) -> fn(Int) -> Int {
    |x| x * factor
}

fn make_threshold(limit: Int) -> fn(Int) -> Bool {
    |x| x > limit
}

// ===== Test 10: Variadic-Style with Arrays =====

fn sum_all(numbers: [Int]) -> Int {
    let total = 0;
    for n in numbers {
        total = total + n;
    }
    total
}

fn product_all(numbers: [Int]) -> Int {
    let result = 1;
    for n in numbers {
        result = result * n;
    }
    result
}

// ===== Test 11: Pattern Matching in Function Parameters =====

type Point is { x: Float, y: Float };

fn distance_from_origin(p: Point) -> Float {
    let Point { x, y } = p;
    sqrt(x * x + y * y)
}

fn add_points(p1: Point, p2: Point) -> Point {
    Point { x: p1.x + p2.x, y: p1.y + p2.y }
}

// ===== Test 12: Early Return =====

fn divide_safe(a: Int, b: Int) -> Maybe<Int> {
    if b == 0 {
        return None;
    }
    Some(a / b)
}

fn find_first_positive(numbers: [Int]) -> Maybe<Int> {
    for n in numbers {
        if n > 0 {
            return Some(n);
        }
    }
    None
}

// ===== Helper Types =====

type Maybe<T> is
    | Some(T)
    | None;

// Helper function (simplified sqrt)
fn sqrt(x: Float) -> Float {
    // Simplified: just return x for testing
    x
}

// ===== Main Test Function =====

fn main() {
    print("=== Comprehensive Function Features Test ===");
    print("");

    // Test 1: Basic functions
    print("--- Test 1: Basic Functions ---");
    print("add(5, 3) = " + add(5, 3).to_string());
    print("multiply(4, 7) = " + multiply(4, 7).to_string());
    print("greet('Verum') = " + greet("Verum"));
    print_message("✓ Print function works");
    print("");

    // Test 2: Multiple return values
    print("--- Test 2: Multiple Return Values ---");
    let (q, r) = divide_with_remainder(17, 5);
    print("divide_with_remainder(17, 5) = (" + q.to_string() + ", " + r.to_string() + ")");

    let (min, max) = min_max(10, 5);
    print("min_max(10, 5) = (" + min.to_string() + ", " + max.to_string() + ")");

    let (a, b) = swap(1, 2);
    print("swap(1, 2) = (" + a.to_string() + ", " + b.to_string() + ")");
    print("");

    // Test 3: Expression body functions
    print("--- Test 3: Expression Body Functions ---");
    print("square(5) = " + square(5).to_string());
    print("is_even(4) = " + is_even(4).to_string());
    print("is_odd(4) = " + is_odd(4).to_string());
    print("abs(-42) = " + abs(-42).to_string());
    print("");

    // Test 4: Generic functions
    print("--- Test 4: Generic Functions ---");
    print("identity(42) = " + identity(42).to_string());
    print("identity('hello') = " + identity("hello"));

    let p = pair(10, "test");
    print("pair(10, 'test') created");
    print("first(pair) = " + first(p).to_string());
    print("second(pair) = " + second(p));
    print("");

    // Test 5: Higher-order functions
    print("--- Test 5: Higher-Order Functions ---");
    print("apply(square, 5) = " + apply(square, 5).to_string());
    print("twice(square, 3) = " + twice(square, 3).to_string());
    print("compose(square, abs, -5) = " + compose(square, abs, -5).to_string());
    print("");

    // Test 6: Closures
    print("--- Test 6: Closures ---");
    let add5 = make_adder(5);
    print("add5 = make_adder(5)");
    print("add5(10) = " + add5(10).to_string());

    let times3 = make_multiplier(3);
    print("times3 = make_multiplier(3)");
    print("times3(7) = " + times3(7).to_string());

    let nums = [1, 2, 3, 4, 5];
    let doubled = map_numbers(nums, |x| x * 2);
    print("map_numbers([1,2,3,4,5], |x| x*2) = [2,4,6,8,10]");

    let evens = filter_numbers(nums, is_even);
    print("filter_numbers([1,2,3,4,5], is_even) = [2,4]");
    print("");

    // Test 7: Recursive functions
    print("--- Test 7: Recursive Functions ---");
    print("factorial(5) = " + factorial(5).to_string());
    print("fibonacci(7) = " + fibonacci(7).to_string());
    print("gcd(48, 18) = " + gcd(48, 18).to_string());
    print("");

    // Test 8: Mutual recursion
    print("--- Test 8: Mutual Recursion ---");
    print("is_even_recursive(4) = " + is_even_recursive(4).to_string());
    print("is_odd_recursive(4) = " + is_odd_recursive(4).to_string());
    print("is_even_recursive(7) = " + is_even_recursive(7).to_string());
    print("is_odd_recursive(7) = " + is_odd_recursive(7).to_string());
    print("");

    // Test 9: Functions returning functions
    print("--- Test 9: Functions Returning Functions ---");
    let gt10 = make_threshold(10);
    print("gt10 = make_threshold(10)");
    print("gt10(15) = " + gt10(15).to_string());
    print("gt10(5) = " + gt10(5).to_string());
    print("");

    // Test 10: Variadic-style with arrays
    print("--- Test 10: Array-Based Variadic Functions ---");
    print("sum_all([1, 2, 3, 4, 5]) = " + sum_all([1, 2, 3, 4, 5]).to_string());
    print("product_all([2, 3, 4]) = " + product_all([2, 3, 4]).to_string());
    print("");

    // Test 11: Pattern matching in parameters
    print("--- Test 11: Pattern Matching in Parameters ---");
    let point = Point { x: 3.0, y: 4.0 };
    print("distance_from_origin({x: 3.0, y: 4.0}) = " + distance_from_origin(point).to_string());

    let p1 = Point { x: 1.0, y: 2.0 };
    let p2 = Point { x: 3.0, y: 4.0 };
    let sum_point = add_points(p1, p2);
    print("add_points({1.0, 2.0}, {3.0, 4.0}) = {" + sum_point.x.to_string() + ", " + sum_point.y.to_string() + "}");
    print("");

    // Test 12: Early return
    print("--- Test 12: Early Return ---");
    match divide_safe(10, 2) {
        Some(v) => print("divide_safe(10, 2) = Some(" + v.to_string() + ")"),
        None => print("divide_safe(10, 2) = None")
    }

    match divide_safe(10, 0) {
        Some(v) => print("divide_safe(10, 0) = Some(" + v.to_string() + ")"),
        None => print("divide_safe(10, 0) = None")
    }

    let numbers = [-5, -3, 0, 2, 4];
    match find_first_positive(numbers) {
        Some(n) => print("find_first_positive([-5,-3,0,2,4]) = Some(" + n.to_string() + ")"),
        None => print("find_first_positive([-5,-3,0,2,4]) = None")
    }
    print("");

    print("=== Function Features Tested ===");
    print("✓ Basic functions with parameters and return types");
    print("✓ Multiple return values (via tuples)");
    print("✓ Expression body functions (= syntax)");
    print("✓ Generic functions");
    print("✓ Higher-order functions");
    print("✓ Closures and lambda expressions");
    print("✓ Recursive functions");
    print("✓ Mutual recursion");
    print("✓ Functions returning functions");
    print("✓ Array-based variadic patterns");
    print("✓ Pattern matching in parameters");
    print("✓ Early return statements");
    print("");
    print("=== Test Complete ===");
}
