// Sorting Algorithms Demo
// Demonstrates: arrays, loops, comparisons

// Find minimum in array of 5
fn find_min_5(arr: [Float]) -> Float {
    let mut min = arr[0];
    if arr[1] < min { min = arr[1]; };
    if arr[2] < min { min = arr[2]; };
    if arr[3] < min { min = arr[3]; };
    if arr[4] < min { min = arr[4]; };
    min
}

// Find maximum in array of 5
fn find_max_5(arr: [Float]) -> Float {
    let mut max = arr[0];
    if arr[1] > max { max = arr[1]; };
    if arr[2] > max { max = arr[2]; };
    if arr[3] > max { max = arr[3]; };
    if arr[4] > max { max = arr[4]; };
    max
}

// Check if sorted
fn is_sorted_5(arr: [Float]) -> Bool {
    if arr[0] > arr[1] { return false; };
    if arr[1] > arr[2] { return false; };
    if arr[2] > arr[3] { return false; };
    if arr[3] > arr[4] { return false; };
    true
}

// Print array
fn print_array_5(name: Text, arr: [Float]) {
    let _ = print(f"{name}: [{arr[0]}, {arr[1]}, {arr[2]}, {arr[3]}, {arr[4]}]");
}

// Manual bubble sort pass
fn bubble_pass(a0: Float, a1: Float, a2: Float, a3: Float, a4: Float) -> (Float, Float, Float, Float, Float) {
    let mut v0 = a0;
    let mut v1 = a1;
    let mut v2 = a2;
    let mut v3 = a3;
    let mut v4 = a4;

    if v0 > v1 { let t = v0; v0 = v1; v1 = t; };
    if v1 > v2 { let t = v1; v1 = v2; v2 = t; };
    if v2 > v3 { let t = v2; v2 = v3; v3 = t; };
    if v3 > v4 { let t = v3; v3 = v4; v4 = t; };

    (v0, v1, v2, v3, v4)
}

fn main() {
    let _ = print("=== Sorting Demo ===");
    let _ = print("");

    // Test array
    let arr = [64.0, 34.0, 25.0, 12.0, 22.0];
    print_array_5("Original", arr);

    let _ = print(f"Minimum: {find_min_5(arr)}");
    let _ = print(f"Maximum: {find_max_5(arr)}");
    let _ = print(f"Is sorted: {is_sorted_5(arr)}");
    let _ = print("");

    // Manual sort demonstration
    let _ = print("After bubble passes:");
    let (s0, s1, s2, s3, s4) = bubble_pass(arr[0], arr[1], arr[2], arr[3], arr[4]);
    let _ = print(f"Pass 1: [{s0}, {s1}, {s2}, {s3}, {s4}]");

    let (t0, t1, t2, t3, t4) = bubble_pass(s0, s1, s2, s3, s4);
    let _ = print(f"Pass 2: [{t0}, {t1}, {t2}, {t3}, {t4}]");

    let (u0, u1, u2, u3, u4) = bubble_pass(t0, t1, t2, t3, t4);
    let _ = print(f"Pass 3: [{u0}, {u1}, {u2}, {u3}, {u4}]");

    let (v0, v1, v2, v3, v4) = bubble_pass(u0, u1, u2, u3, u4);
    let _ = print(f"Pass 4: [{v0}, {v1}, {v2}, {v3}, {v4}]");

    let sorted = [v0, v1, v2, v3, v4];
    let _ = print(f"Final is sorted: {is_sorted_5(sorted)}");

    let _ = print("");
    let _ = print("=== Done ===");
}
