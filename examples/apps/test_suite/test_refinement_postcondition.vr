// Test 4: Function Postconditions
// Spec: 03-type-system.md Section 1.3 - Function refinements
// Syntax: fn name(params) -> Type where ensures predicate

// Test 4.1: Simple postcondition with result variable
fn abs(x: Int) -> Int where ensures result >= 0 {
    if x < 0 {
        0 - x
    } else {
        x
    }
}

// Test 4.2: Postcondition relating result to input
fn increment(x: Int) -> Int where ensures result > x {
    x + 1
}

// Test 4.3: Postcondition with range constraint
fn clamp(x: Int) -> Int where ensures result >= 0 && result <= 100 {
    if x < 0 {
        0
    } else if x > 100 {
        100
    } else {
        x
    }
}

// Test 4.4: Postcondition for list length
fn make_list(n: Int) -> List<Int> where ensures result.len() == n {
    let mut list = [];
    let mut i = 0;
    while i < n {
        list.push(i);
        i = i + 1;
    }
    list
}

// Test 4.5: Postcondition for non-empty result
fn concat(a: Text, b: Text) -> Text where ensures result.len() >= a.len() {
    a + b
}

// Test 4.6: Multiple postconditions
fn safe_divide(a: Int, b: Int) -> Maybe<Int>
    where requires b != 0
    where ensures result.is_some() {
    Some(a / b)
}

// Test 4.7: Postcondition with logical operators
fn max(a: Int, b: Int) -> Int where ensures result >= a && result >= b {
    if a > b {
        a
    } else {
        b
    }
}

// Test 4.8: Test postconditions
fn main() {
    // Test abs
    let a1 = abs(-5);
    let _ = print(f"abs(-5) = {a1}");

    let a2 = abs(10);
    let _ = print(f"abs(10) = {a2}");

    // Test increment
    let inc = increment(5);
    let _ = print(f"increment(5) = {inc}");

    // Test clamp
    let c1 = clamp(-10);
    let _ = print(f"clamp(-10) = {c1}");

    let c2 = clamp(150);
    let _ = print(f"clamp(150) = {c2}");

    let c3 = clamp(50);
    let _ = print(f"clamp(50) = {c3}");

    // Test make_list
    let list = make_list(5);
    let list_len = list.len();
    let _ = print(f"make_list(5) length: {list_len}");

    // Test concat
    let text = concat("Hello", " World");
    let _ = print(f"concat result: {text}");

    // Test max
    let maximum = max(10, 20);
    let _ = print(f"max(10, 20) = {maximum}");
}
