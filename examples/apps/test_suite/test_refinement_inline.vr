// Test 1: Inline Refinement Types
// Spec: 03-type-system.md Section 1.3 - Rule 1 (Inline)
// Syntax: Type{predicate} with implicit 'it' binding

// Test 1.1: Simple inline refinement with comparison
type Positive is Int{it > 0};

// Test 1.2: Inline refinement with range check
type Percent is Int{it >= 0 && it <= 100};

// Test 1.3: Inline refinement with method call
type NonEmptyText is Text{it.len() > 0};

// Test 1.4: Function accepting refined type
fn increment(x: Positive) -> Int {
    x + 1
}

// Test 1.5: Function returning refined type
fn abs(x: Int) -> Int{it >= 0} {
    if x < 0 {
        0 - x
    } else {
        x
    }
}

// Test 1.6: Creating refined values
fn main() {
    // Should work: 5 satisfies > 0
    let p: Positive = 5;
    let _ = print(f"Positive value: {p}");

    // Test increment function
    let result = increment(p);
    let _ = print(f"Incremented: {result}");

    // Test abs function
    let abs_val = abs(-10);
    let _ = print(f"Absolute value: {abs_val}");

    // Test percentage type
    let pct: Percent = 75;
    let _ = print(f"Percentage: {pct}%");
}
