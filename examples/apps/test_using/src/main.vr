// Test 1: Define simple contexts
context Logger {
    fn log(msg: Text)
}

context Database {
    fn query(sql: Text) -> Text
}

context FileSystem {
    fn read(path: Text) -> Text
}

// Test 2: Function using single context (single_context from grammar)
fn greet(name: Text) using Logger {
    Logger.log(f"Hello, {name}!");
}

// Test 3: Function using multiple contexts (context_list from grammar)
fn loadUserData(userId: Text) using [Logger, Database] {
    Logger.log(f"Loading user: {userId}");
    let data = Database.query(f"SELECT * FROM users WHERE id = {userId}");
    Logger.log(f"Loaded data: {data}");
}

// Test 4: Function using three contexts (testing multiple items in context_list)
fn processFile(path: Text) using [Logger, Database, FileSystem] {
    Logger.log(f"Processing file: {path}");
    let content = FileSystem.read(path);
    Logger.log(f"Read {content}");
    Database.query(f"INSERT INTO files VALUES ('{path}', '{content}')");
}

// Test 5: Nested context usage
fn saveAndLog(message: Text) using [Logger, Database] {
    // Call another function that uses Logger
    greet("User");
    Logger.log(message);
    Database.query(f"INSERT INTO logs VALUES ('{message}')");
}

fn main() {
    print("=== Context System Test ===");
    print("");

    print("Grammar Test Results:");
    print("---------------------");

    print("");
    print("Test 1: Single context syntax (using Logger)");
    print("  Syntax: fn greet(name: Text) using Logger");
    print("  Grammar: context_spec -> single_context");
    print("  Status: PARSED");

    print("");
    print("Test 2: Multiple contexts syntax (using [Logger, Database])");
    print("  Syntax: fn loadUserData(userId: Text) using [Logger, Database]");
    print("  Grammar: context_spec -> context_list (2 items)");
    print("  Status: PARSED");

    print("");
    print("Test 3: Three contexts syntax (using [Logger, Database, FileSystem])");
    print("  Syntax: fn processFile(path: Text) using [Logger, Database, FileSystem]");
    print("  Grammar: context_spec -> context_list (3 items)");
    print("  Status: PARSED");

    print("");
    print("Test 4: Nested context usage");
    print("  Syntax: fn saveAndLog calls greet internally");
    print("  Grammar: context propagation through call chain");
    print("  Status: PARSED");

    print("");
    print("Context Declaration Tests:");
    print("-------------------------");
    print("  context Logger { fn log(msg: Text) }");
    print("  context Database { fn query(sql: Text) -> Text }");
    print("  context FileSystem { fn read(path: Text) -> Text }");
    print("  All declarations: PARSED");

    print("");
    print("=== All Context System Grammar Tests PASSED ===");
}
