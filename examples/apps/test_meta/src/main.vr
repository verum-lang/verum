// Comprehensive Verum Metaprogramming (Macro) System Test
// Tests meta definitions, meta calls, and meta fragments

// ============================================================================
// Test 1: Basic Meta Definition with Expression Fragment
// ============================================================================

meta simple_macro(x: expr) {
    _ => x + 1
}

// ============================================================================
// Test 2: Meta Definition with Multiple Fragment Types
// ============================================================================

meta typed_macro(name: ident, ty: type) {
    _ => {
        let name: ty = ty.default();
        name
    }
}

// ============================================================================
// Test 3: Meta Definition with Statement Fragment
// ============================================================================

meta stmt_macro(s: stmt) {
    _ => {
        print("Before statement");
        s;
        print("After statement");
    }
}

// ============================================================================
// Test 4: Meta Definition with Pattern Fragment
// ============================================================================

meta match_helper(p: pattern, e: expr) {
    _ => match e {
        p => true,
        _ => false
    }
}

// ============================================================================
// Test 5: Meta Definition with Path Fragment
// ============================================================================

meta call_path(p: path) {
    _ => p()
}

// ============================================================================
// Test 6: Meta Definition with Block Fragment
// ============================================================================

meta repeat_block(b: block, n: expr) {
    _ => {
        let mut i = 0;
        while i < n {
            b;
            i = i + 1;
        }
    }
}

// ============================================================================
// Test 7: Meta Definition with Item Fragment
// ============================================================================

meta make_item(i: item) {
    _ => {
        i
    }
}

// ============================================================================
// Test 8: Meta Definition with Token Tree Fragment
// ============================================================================

meta token_tree_macro(tt: tt) {
    _ => tt
}

// ============================================================================
// Test 9: Meta Definition with Multiple Rules (Pattern Matching)
// ============================================================================

meta conditional_macro(x: expr) {
    0 => "zero",
    1 => "one",
    _ => "many"
}

// ============================================================================
// Test 10: Meta Definition for Code Generation
// ============================================================================

meta make_getter(field: ident, ty: type) {
    _ => fn field() -> ty {
        self.field
    }
}

// ============================================================================
// Test 11: Complex Meta with Multiple Parameters
// ============================================================================

meta assert_eq(left: expr, right: expr) {
    _ => {
        let l = left;
        let r = right;
        if l != r {
            print("Assertion failed: " + l.to_string() + " != " + r.to_string());
        }
    }
}

// ============================================================================
// Test 12: Meta for Creating Type Definitions
// ============================================================================

meta define_wrapper(name: ident, inner: type) {
    _ => type name is {
        value: inner
    };
}

