// =============================================================================
// term_compose_demo.vr — CSS Flexbox + generics + protocols on core.term
// =============================================================================
// Exercises the full Flexbox Level 1 solver in `core.term.layout` over a
// realistic three-pane layout. Along the way the file hits five advanced
// language features in a single pass:
//
//   1. Protocols with method dispatch (`Sizable` → `Pane`)
//   2. Generics (`fn summarize<P: Sizable>(panes: &List<P>)`)
//   3. Refinement-type parameter (`Int{>= 0}` validated by the checker)
//   4. Builder-chain composition (`FlexItem.new().min(...).grow(...)`)
//   5. `&list[i]` interior references + field access
//
// Run:
//   verum run examples/term_compose_demo.vr          # interpreter
// =============================================================================

mount core.term.layout.{Rect, FlexLayout, FlexItem, JustifyContent};

// ---------------------------------------------------------------------------
// 1. Domain type.
// ---------------------------------------------------------------------------

type Pane is {
    name:     Text,
    min_cols: Int,
    grow:     Float,
};

// ---------------------------------------------------------------------------
// 2. Protocol.
// ---------------------------------------------------------------------------

type Sizable is protocol {
    fn min_size(&self) -> Int;
    fn weight(&self)   -> Float;
};

implement Sizable for Pane {
    fn min_size(&self) -> Int   { self.min_cols }
    fn weight(&self)   -> Float { self.grow     }
}

// ---------------------------------------------------------------------------
// 3. Generic visitor using `&list[i]` — interior-ref + field-access
//    path landed with the VBC struct-layout fix.
// ---------------------------------------------------------------------------

fn summarize<P: Sizable>(panes: &List<P>) -> Int {
    let mut total = 0;
    for i in 0..panes.len() {
        let r = &panes[i];
        total = total + r.min_size();
    }
    total
}

// ---------------------------------------------------------------------------
// 4. Refinement-typed helper — call-site arguments gated by the checker.
// ---------------------------------------------------------------------------

fn checked_width(w: Int{>= 0}) -> Int { w * 2 }

// ---------------------------------------------------------------------------
// 5. Builder chain on a stdlib struct.
// ---------------------------------------------------------------------------

fn to_flex_items(panes: &List<Pane>) -> List<FlexItem> {
    let mut items = List.new();
    for i in 0..panes.len() {
        let p = panes[i];
        let item = FlexItem.new().min(p.min_cols).grow(p.grow);
        items.push(item);
    }
    items
}

// ---------------------------------------------------------------------------
// 6. Main — lay out a 3-pane row inside an 80-column container.
// ---------------------------------------------------------------------------

fn main() {
    let mut panes = List.new();
    panes.push(Pane { name: "toolbar", min_cols: 10, grow: 0.0 });
    panes.push(Pane { name: "main",    min_cols: 20, grow: 1.0 });
    panes.push(Pane { name: "sidebar", min_cols: 15, grow: 0.0 });

    // Protocol-based summary generic over the pane type.
    let min_total = summarize(&panes);
    print(f"sum of min widths: {min_total} (expected 45)");
    assert_eq(min_total, 45);

    // Refinement type.
    let doubled = checked_width(80);
    assert_eq(doubled, 160);
    print(f"checked_width(80) = {doubled}");

    // Rect geometry.
    let area = Rect.new(0, 0, 80, 24);
    assert_eq(area.right(),  80);
    assert_eq(area.bottom(), 24);
    print(f"rect {area.width}x{area.height}  right={area.right()}  bottom={area.bottom()}");

    // Flex solver: 80-col row, gap = 1.
    let layout = FlexLayout.row().justify(JustifyContent.FlexStart).gap(1);
    let items  = to_flex_items(&panes);
    let rects  = layout.compute(area, &items);
    assert_eq(rects.len(), 3);

    print("flex layout (80-col row, gap=1):");
    let mut covered = 0;
    for i in 0..rects.len() {
        let r = rects[i];
        let p = panes[i];
        print(f"  {p.name}  x={r.x}  w={r.width}  h={r.height}");
        assert(r.width >= p.min_cols);
        covered = covered + r.width;
    }
    // With grow on the middle pane the solver fills precisely:
    //   10 (fixed) + 1 (gap) + G (grow) + 1 (gap) + 15 (fixed) = 80
    //   → G = 53
    print(f"total covered cells: {covered}  (target 78 = 80 - 2 gaps)");
    assert_eq(covered, 78);

    print("term_compose_demo: OK");
}
