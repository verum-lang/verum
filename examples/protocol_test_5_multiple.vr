// Test 5: Multiple protocol implementations for different types

type Display is protocol {
    fn display(self) -> Text;
}

type Point is {
    x: Int,
    y: Int
}

type Rectangle is {
    width: Int,
    height: Int
}

implement Display for Point {
    fn display(self) -> Text {
        f"Point({self.x}, {self.y})"
    }
}

implement Display for Rectangle {
    fn display(self) -> Text {
        f"Rectangle(w: {self.width}, h: {self.height})"
    }
}

implement Display for Int {
    fn display(self) -> Text {
        f"Int({self})"
    }
}

fn main() {
    print("Test 5: Multiple protocol implementations");

    let p = Point { x: 5, y: 10 };
    print(p.display());

    let r = Rectangle { width: 100, height: 50 };
    print(r.display());

    let n = 42;
    print(n.display());

    print("SUCCESS: Multiple protocol implementations work");
}
