//     let _v4 = y * z;
//     let _v5 = _v3 + _v4;
//
//     // Backward pass
//     let grad_output = grad_output;
//
//     // Gradient through addition
//     let _grad3 = grad_output * 1.0;  // grad to x*y
//     let _grad4 = grad_output * 1.0;  // grad to y*z
//
//     // Gradient through x*y
//     let _grad0 = _grad3 * y;         // grad_x
//     let _grad1_from_xy = _grad3 * x; // grad_y (partial)
//
//     // Gradient through y*z
//     let _grad1_from_yz = _grad4 * z; // grad_y (partial)
//     let _grad2 = _grad4 * y;         // grad_z
//
//     // Accumulate y gradients
//     let _grad1 = _grad1_from_xy + _grad1_from_yz;
//
//     let grad_x = _grad0;
//     let grad_y = _grad1;
//     let grad_z = _grad2;
//
//     (grad_x, grad_y, grad_z)
// }

fn example_multi_param() {
    let x = 2.0;
    let y = 3.0;
    let z = 4.0;

    let result = multi_param(x, y, z);  // 6 + 12 = 18
    let (grad_x, grad_y, grad_z) = multi_param_vjp(x, y, z, 1.0);
    // grad_x = 3.0 (= y)
    // grad_y = 6.0 (= x + z = 2 + 4)
    // grad_z = 3.0 (= y)
}

