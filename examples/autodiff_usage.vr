// ============================================================================
// Example 4: Chain Rule (Composite Functions)
// ============================================================================

/// Composite function demonstrating chain rule
/// f(x) = sin(x²)
/// df/dx = cos(x²) * 2x
@differentiable(wrt = "x")
fn sin_squared(x: Float) -> Float {
    let x_sq = x * x;
    sin(x_sq)
}

// AUTO-GENERATED:
//
// fn sin_squared_vjp(x: Float, grad_output: Float) -> Float {
//     // Forward pass
//     let _v1 = x * x;        // x²
//     let _v2 = sin(_v1);     // sin(x²)
//
//     // Backward pass (reverse order)
//     let grad_output = grad_output;
//
//     // ∂sin(_v1)/∂_v1 = cos(_v1)
//     let _grad1 = grad_output * cos(_v1);  // grad for x²
//
//     // ∂(x * x)/∂x = 2x (both uses of x)
//     let _grad0_from_left = _grad1 * x;    // from left operand
//     let _grad0_from_right = _grad1 * x;   // from right operand
//     let _grad0 = _grad0_from_left + _grad0_from_right;  // accumulate
//
//     let grad_x = _grad0;
//     grad_x
// }

fn example_chain_rule() {
    let x = 2.0;
    let result = sin_squared(x);  // sin(4) ≈ -0.7568
    let grad_x = sin_squared_vjp(x, 1.0);
    // grad_x = cos(4) * 4 ≈ -2.614
}

// ============================================================================
// Example 5: Gradient Accumulation
// ============================================================================

/// Function using same variable multiple times
/// f(x) = x² + x³
/// df/dx = 2x + 3x²
@differentiable(wrt = "x")
fn polynomial(x: Float) -> Float {
    let x_sq = x * x;
    let x_cubed = x_sq * x;
    x_sq + x_cubed
}

