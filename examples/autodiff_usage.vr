//
// fn polynomial_vjp(x: Float, grad_output: Float) -> Float {
//     // Forward pass
//     let _v1 = x * x;         // x²
//     let _v2 = _v1 * x;       // x³
//     let _v3 = _v1 + _v2;     // x² + x³
//
//     // Backward pass
//     let grad_output = grad_output;
//
//     // Gradient of addition: both addends get full gradient
//     let _grad1_from_add = grad_output * 1.0;  // grad to x²
//     let _grad2 = grad_output * 1.0;            // grad to x³
//
//     // Gradient of x³ = x² * x
//     let _grad1_from_mul = _grad2 * x;          // grad to x² (right operand)
//     let _grad0_from_x3 = _grad2 * _v1;         // grad to x (left of x³)
//
//     // Accumulate gradients to x² from both paths
//     let _grad1 = _grad1_from_add + _grad1_from_mul;
//
//     // Gradient of x² = x * x
//     let _grad0_from_x2_left = _grad1 * x;      // grad to x (left)
//     let _grad0_from_x2_right = _grad1 * x;     // grad to x (right)
//
//     // Final accumulation: all paths through x
//     let grad_x = _grad0_from_x2_left + _grad0_from_x2_right + _grad0_from_x3;
//
//     grad_x
// }

fn example_accumulation() {
    let x = 3.0;
    let result = polynomial(x);  // 9 + 27 = 36
    let grad_x = polynomial_vjp(x, 1.0);
    // grad_x = 2*3 + 3*9 = 6 + 27 = 33
}

// ============================================================================
// Example 6: Multi-Parameter Function
// ============================================================================

/// Function with multiple parameters
/// f(x, y, z) = x*y + y*z
/// ∂f/∂x = y, ∂f/∂y = x + z, ∂f/∂z = y
@differentiable(wrt = "x, y, z")
fn multi_param(x: Float, y: Float, z: Float) -> Float {
    let xy = x * y;
    let yz = y * z;
    xy + yz
}

// AUTO-GENERATED:
//
// fn multi_param_vjp(x: Float, y: Float, z: Float, grad_output: Float)
//     -> (Float, Float, Float)
// {
