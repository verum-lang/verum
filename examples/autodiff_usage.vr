// ============================================================================
// Example 8: Dense Neural Network Layer
// ============================================================================

/// Dense (fully-connected) layer
/// output = weights · input + bias
///
/// Gradients:
/// - ∂L/∂weights = input^T ⊗ grad_output
/// - ∂L/∂bias = grad_output
@differentiable(wrt = "weights, bias")
fn dense_layer(
    input: &Tensor<f32, [128]>,
    weights: &Tensor<f32, [128, 64]>,
    bias: &Tensor<f32, [64]>
) -> Tensor<f32, [64]> {
    let matmul_result = matmul(input, weights);
    matmul_result + bias
}

// AUTO-GENERATED:
//
// fn dense_layer_vjp(
//     input: &Tensor<f32, [128]>,
//     weights: &Tensor<f32, [128, 64]>,
//     bias: &Tensor<f32, [64]>,
//     grad_output: &Tensor<f32, [64]>
// ) -> (Tensor<f32, [128, 64]>, Tensor<f32, [64]>)
// {
//     // Forward pass
//     let _v3 = matmul(input, weights);
//     let _v4 = _v3 + bias;
//
//     // Backward pass
//     let grad_output = grad_output.clone();
//
//     // Gradient through addition (broadcast)
//     let _grad3 = grad_output.clone();  // grad to matmul
//     let grad_bias = grad_output.clone();  // grad to bias
//
//     // Gradient through matmul
//     // ∂(A@B)/∂B = A^T @ grad
//     let input_t = input.reshape.<128, 1>();
//     let grad_out_reshaped = grad_output.reshape.<1, 64>();
//     let grad_weights = matmul(&input_t, &grad_out_reshaped);
//
//     (grad_weights, grad_bias)
// }

fn example_dense_layer() using [Logger] {
    let input = Tensor.<f32, [128]>.zeros();
    let weights = Tensor.<f32, [128, 64]>.randn();
    let bias = Tensor.<f32, [64]>.zeros();

    // Forward pass
    let output = dense_layer(&input, &weights, &bias);

    // Backward pass (during training)
    let grad_output = Tensor.<f32, [64]>.ones();  // upstream gradient
    let (grad_weights, grad_bias) = dense_layer_vjp(
        &input,
        &weights,
        &bias,
        &grad_output
    );

    // Update weights (gradient descent)
    let learning_rate = 0.001;
    weights -= learning_rate * grad_weights;
    bias -= learning_rate * grad_bias;
}

// ============================================================================
// Example 9: Selective Differentiation
// ============================================================================

/// Only differentiate with respect to specific parameters
/// ∂f/∂w is computed, but not ∂f/∂x (x is input, not trainable)
@differentiable(wrt = "w, b")  // Only differentiate w.r.t. w and b
fn linear_model(x: Float, w: Float, b: Float) -> Float {
    w * x + b
}

