// ============================================================================
// Example 10: Custom VJP (Advanced)
// ============================================================================

/// Function with custom VJP implementation
/// Useful for operations with special gradient handling
@differentiable(wrt = "x", custom_vjp = "sqrt_stable_vjp")
fn sqrt_stable(x: Float) -> Float {
    sqrt(x)
}

// User-provided custom VJP for numerical stability
fn sqrt_stable_vjp(x: Float, grad_output: Float) -> Float {
    let result = sqrt(x);

    // Numerically stable gradient: avoid division by zero
    if result.abs() < 1e-10 {
        0.0  // Gradient is zero at x=0
    } else {
        grad_output / (2.0 * result)
    }
}

// ============================================================================
// Example 11: Forward-Mode (JVP) Differentiation
// ============================================================================

/// Forward-mode autodiff (efficient for few inputs, many outputs)
@differentiable(wrt = "x", mode = "forward")
fn jacobian_demo(x: Float) -> (Float, Float, Float) {
    (sin(x), cos(x), exp(x))
}

