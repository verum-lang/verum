//! Automatic Differentiation Usage Examples
//!
//! This file demonstrates complete VJP (Vector-Jacobian Product) backward pass
//! generation for @differentiable functions in Verum.
//!
//! # Features Demonstrated
//!
//! 1. Basic @differentiable functions
//! 2. VJP function generation
//! 3. Gradient computation
//! 4. Chain rule application
//! 5. Multi-parameter differentiation
//! 6. Neural network layer gradients
//!
//! Spec: docs/detailed/06-compilation-pipeline.md Section 10
//! Spec: docs/detailed/17-meta-system.md Section 19.4

// ============================================================================
// Example 1: Simple Scalar Function
// ============================================================================

/// Simple addition function
/// Gradients: ∂f/∂x = 1, ∂f/∂y = 1
@differentiable(wrt = "x, y")
fn add(x: Float, y: Float) -> Float {
    x + y
}

// AUTO-GENERATED by Phase 4a:
//
// fn add_vjp(x: Float, y: Float, grad_output: Float) -> (Float, Float) {
//     // Forward pass (for gradient computation)
//     let _v2 = x + y;
//
//     // Backward pass (reverse topological order)
//     let grad_output = grad_output;
//     let _grad0 = grad_output * 1.0;  // grad_x
//     let _grad1 = grad_output * 1.0;  // grad_y
//     let grad_x = _grad0;
//     let grad_y = _grad1;
//
//     (grad_x, grad_y)
// }
//
// fn add_grad(x: Float, y: Float) -> (Float, Float) {
//     add_vjp(x, y, 1.0)
// }

// Usage:
fn example_add() {
    let x = 3.0;
    let y = 5.0;

    // Forward pass
    let result = add(x, y);  // = 8.0

    // Backward pass (VJP)
    let (grad_x, grad_y) = add_vjp(x, y, 1.0);
    // grad_x = 1.0, grad_y = 1.0

    // Gradient (convenience function for scalar outputs)
    let (dx, dy) = add_grad(x, y);
    // dx = 1.0, dy = 1.0
}

// ============================================================================
// Example 2: Multiplication (Product Rule)
// ============================================================================

/// Multiplication function
/// Gradients: ∂f/∂x = y, ∂f/∂y = x
@differentiable(wrt = "x, y")
fn multiply(x: Float, y: Float) -> Float {
    x * y
}

// AUTO-GENERATED:
//
// fn multiply_vjp(x: Float, y: Float, grad_output: Float) -> (Float, Float) {
//     // Forward pass
//     let _v2 = x * y;
//
//     // Backward pass
//     let grad_output = grad_output;
//     let _grad0 = grad_output * y;  // grad_x = grad * y
//     let _grad1 = grad_output * x;  // grad_y = grad * x
//     let grad_x = _grad0;
//     let grad_y = _grad1;
//
//     (grad_x, grad_y)
// }

fn example_multiply() {
    let x = 4.0;
    let y = 3.0;

    let result = multiply(x, y);  // = 12.0
    let (grad_x, grad_y) = multiply_vjp(x, y, 1.0);
    // grad_x = 3.0 (= y), grad_y = 4.0 (= x)
}

