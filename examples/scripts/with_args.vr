#!/usr/bin/env verum
//
// with_args.vr — command-line argument handling in a script.
//
// Demonstrates: `core.base.env::args()` for reading argv from a
// shebang script. Scripts MUST NOT declare `fn main` — the file
// IS the entry. Use `args()` from the stdlib instead.
//
// Run:
//   ./with_args.vr Alice
//   ./with_args.vr           # missing arg -> exit 2

mount core.base.env;

let args = env.args();
if args.len() < 2 {
    print("usage: with_args.vr <name>");
    2
} else {
    print("hello, ");
    print(args[1]);
    0
}
