// Test: Reference conversions and CBGR tiers
// Tests &T, &checked T, &unsafe T and conversions

// Test 1: Standard CBGR reference (&T)
fn test_standard_ref() {
    print("Test 1: Standard CBGR reference (&T)");

    let x = 42;
    let ref_x = &x;

    print("Standard reference created with CBGR protection");
    print("Reference has ~15ns overhead");

    print("Test 1 PASS");
}

// Test 2: Checked reference (&checked T)
fn test_checked_ref() {
    print("Test 2: Checked reference (&checked T)");

    let y = 100;
    let checked_ref = &checked y;

    print("Checked reference created");
    print("Compiler-proven safe, 0ns overhead");

    print("Test 2 PASS");
}

// Test 3: Unsafe reference (&unsafe T)
fn test_unsafe_ref() {
    print("Test 3: Unsafe reference (&unsafe T)");

    unsafe {
        let z = 200;
        let unsafe_ref = &unsafe z;

        print("Unsafe reference created in unsafe block");
        print("Manual safety proof, 0ns overhead");
    }

    print("Test 3 PASS");
}

// Test 4: Mutable references
fn test_mut_refs() {
    print("Test 4: Mutable references");

    let mut a = 10;
    let ref_a = &mut a;

    print("Mutable reference created");
    print("Allows modification through reference");

    print("Test 4 PASS");
}

// Test 5: Reference comparison
fn test_ref_comparison() {
    print("Test 5: Reference comparison");

    let val1 = 42;
    let val2 = 42;

    let ref1 = &val1;
    let ref2 = &val2;

    print("Two references to different values");
    print("References can be compared");

    print("Test 5 PASS");
}

// Test 6: References in function parameters
fn takes_ref(r: &Int) {
    print("Function received reference");
    print("Reference value accessible");
}

fn takes_checked_ref(r: &checked Int) {
    print("Function received checked reference");
    print("No runtime overhead");
}

fn test_ref_params() {
    print("Test 6: References in function parameters");

    let x = 42;
    takes_ref(&x);

    let y = 100;
    takes_checked_ref(&checked y);

    print("Test 6 PASS");
}

// Test 7: Reference to different types
fn test_ref_types() {
    print("Test 7: References to different types");

    let int_val = 42;
    let int_ref = &int_val;
    print("&Int reference");

    let float_val = 3.14;
    let float_ref = &float_val;
    print("&Float reference");

    let bool_val = true;
    let bool_ref = &bool_val;
    print("&Bool reference");

    print("Test 7 PASS");
}

// Test 8: Reference lifetime
fn test_ref_lifetime() {
    print("Test 8: Reference lifetime");

    let outer = 42;
    let outer_ref = &outer;

    print("Reference created in outer scope");

    {
        let inner = 100;
        let inner_ref = &inner;

        print("Reference created in inner scope");
    }

    print("Inner reference out of scope");
    print("Outer reference still valid");

    print("Test 8 PASS");
}

// Test 9: Const pointer to reference conversion concept
fn test_ptr_ref_concept() {
    print("Test 9: Pointer/reference conversion concept");

    // Conceptual test - actual conversion would be unsafe
    print("*const T can be converted to &T in unsafe blocks");
    print("*mut T can be converted to &mut T in unsafe blocks");
    print("Requires manual safety proofs");

    print("Test 9 PASS");
}

// Test 10: References in structs
type Container is {
    value: Int,
}

fn takes_container_ref(c: &Container) {
    print("Function received container reference");
}

fn test_struct_refs() {
    print("Test 10: References to structs");

    let container = Container { value: 42 };
    let container_ref = &container;

    takes_container_ref(container_ref);

    print("Test 10 PASS");
}

fn main() {
    print("=== Reference Conversion Test ===");

    test_standard_ref();
    test_checked_ref();
    test_unsafe_ref();
    test_mut_refs();
    test_ref_comparison();
    test_ref_params();
    test_ref_types();
    test_ref_lifetime();
    test_ptr_ref_concept();
    test_struct_refs();

    print("All reference conversion tests PASS");
}
