// Test comprehensions with operators
fn test_operators() -> Int {
    let nums = [1, 2, 3, 4, 5];

    // All arithmetic operators
    let add = [x + 1 for x in nums];
    let sub = [x - 1 for x in nums];
    let mul = [x * 2 for x in nums];
    let div = [x / 2 for x in nums];
    let rem = [x % 2 for x in nums];
    let pow = [x ** 2 for x in nums];  // If power operator is supported

    // Comparison operators in filter
    let lt = [x for x in nums if x < 3];
    let le = [x for x in nums if x <= 3];
    let gt = [x for x in nums if x > 3];
    let ge = [x for x in nums if x >= 3];
    let eq = [x for x in nums if x == 3];
    let ne = [x for x in nums if x != 3];

    // Logical operators in filter
    let and_op = [x for x in nums if x > 2 if x < 5];  // Using multiple ifs
    // let or_op = [x for x in nums if x < 2 || x > 4];  // If OR is supported in filter

    0
}
