// Test edge cases for comprehensions

fn main() -> Int {
    test_empty_comprehensions();
    test_single_element_comprehensions();
    test_type_inference();
    test_pattern_matching_in_comprehensions();
    test_comprehension_ordering();

    0
}

// Test empty comprehensions
fn test_empty_comprehensions() -> Int {
    // Empty list comprehension
    let empty_list: [Int] = [];
    let result1 = [x * 2 for x in empty_list];
    // Expected: []

    // Empty stream comprehension
    let result2 = stream[x * 2 for x in empty_list];
    // Expected: empty stream

    // Filter that produces empty result
    let numbers = [1, 2, 3];
    let result3 = [x for x in numbers if x > 100];
    // Expected: []

    0
}

// Test single element comprehensions
fn test_single_element_comprehensions() -> Int {
    let single = [42];
    let doubled = [x * 2 for x in single];
    // Expected: [84]

    let filtered = [x for x in single if x > 0];
    // Expected: [42]

    let with_let = [y for x in single let y = x + 1];
    // Expected: [43]

    0
}

// Test type inference in comprehensions
fn test_type_inference() -> Int {
    // Compiler should infer Int
    let ints = [x for x in [1, 2, 3]];

    // Compiler should infer Text
    let strings = [s for s in ["a", "b", "c"]];

    // Mixed operations - should infer correctly
    let mixed = [x + 1 for x in [1, 2, 3]];

    // Type annotation should work
    let annotated: [Int] = [x * 2 for x in [1, 2, 3]];

    0
}

// Test pattern matching in comprehensions
fn test_pattern_matching_in_comprehensions() -> Int {
    // Tuple destructuring
    let pairs = [(1, 2), (3, 4), (5, 6)];
    let sums = [a + b for (a, b) in pairs];
    // Expected: [3, 7, 11]

    // Pattern with wildcards
    let ignore_second = [a for (a, _) in pairs];
    // Expected: [1, 3, 5]

    // Nested patterns
    let nested = [((1, 2), 3), ((4, 5), 6)];
    let flat = [a + b + c for ((a, b), c) in nested];
    // Expected: [6, 15]

    0
}

// Test comprehension clause ordering
fn test_comprehension_ordering() -> Int {
    let numbers = [1, 2, 3];

    // Filter before let
    let order1 = [y for x in numbers if x > 1 let y = x * 2];
    // Filter first: [2, 3], then let: [4, 6]

    // Let before filter
    let order2 = [y for x in numbers let y = x * 2 if y > 2];
    // Let first: [2, 4, 6], then filter: [4, 6]

    // Multiple clauses - order matters
    let order3 = [z for x in [1, 2]
                  for y in [10, 20]
                  if x > 1
                  let z = x + y];
    // x=1: filtered out
    // x=2, y=10: z=12
    // x=2, y=20: z=22
    // Expected: [12, 22]

    0
}

