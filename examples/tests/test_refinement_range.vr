// Test 8: Range-based refinement
type Percentage is Int where it >= 0 && it <= 100;
type Grade is Text where it == "A" || it == "B" || it == "C" || it == "D" || it == "F";

fn calculate_grade(score: Percentage) -> Grade {
    if score >= 90 {
        "A"
    } else if score >= 80 {
        "B"
    } else if score >= 70 {
        "C"
    } else if score >= 60 {
        "D"
    } else {
        "F"
    }
}

fn main() {
    let score: Percentage = 85;
    let grade = calculate_grade(score);
    let _ = println(f"Score {score} = Grade {grade}");
}
