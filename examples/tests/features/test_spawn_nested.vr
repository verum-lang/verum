// Test nested spawn expressions
async fn inner_task(x: Int) -> Int {
    println("Inner task");
    x * 2
}

async fn outer_task(x: Int) -> Int {
    println("Outer task");
    let handle = spawn inner_task(x);
    let result = handle.await;
    result + 10
}

fn main() {
    println("Testing nested spawn");
    let handle = spawn outer_task(5);
    let result = handle.await;
    println("Result: ");
    println(result);
}
