fn box_maybe<T>(x: T) -> Box<Maybe<T>> {
    Box { value: Some(x) }
}

fn pair_of_boxes<A, B>(a: A, b: B) -> Pair<Box<A>, Box<B>> {
    Pair {
        first: Box { value: a },
        second: Box { value: b }
    }
}

// ==============================================================================
// 10. Type Inference with Generics
// ==============================================================================

fn infer_from_usage() -> Int {
    let x = identity(42);           // Infer T = Int
    let _ = identity(3.14);         // Infer T = Float (separate call)
    let _ = identity("hello");      // Infer T = Text (separate call)
    x
}

fn infer_from_return() -> Maybe<Int> {
    Some(42)                         // Infer T = Int from context
}

fn infer_nested() -> Box<Int> {
    Box { value: 100 }               // Infer T = Int
}

// ==============================================================================
// 11. Complex Generic Scenarios
// ==============================================================================

fn chain_maybe<A, B, C>(
    m: Maybe<A>,
    f: fn(A) -> Maybe<B>,
    g: fn(B) -> Maybe<C>
) -> Maybe<C> {
    match m {
        Some(x) => match f(x) {
            Some(y) => g(y),
            None => None
        },
        None => None
    }
}

// Array syntax with generics not yet supported
// fn sequence_maybe<T>(list: [Maybe<T>; 3]) -> Maybe<[T; 3]] {
//     None
// }

// ==============================================================================
// 12. Generic Swap and Transform
// ==============================================================================

fn swap<A, B>(pair: Pair<A, B>) -> Pair<B, A> {
    Pair { first: pair.second, second: pair.first }
}

fn transform_pair<A, B, C, D>(
    pair: Pair<A, B>,
    fa: fn(A) -> C,
    fb: fn(B) -> D
) -> Pair<C, D> {
    Pair { first: fa(pair.first), second: fb(pair.second) }
}

