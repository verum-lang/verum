// Comprehensive Test: Generic Features in Verum
// This test covers all generic features based on verum.ebnf grammar
// Tests: generic functions, types, variants, bounds, where clauses, meta parameters, inference

// ==============================================================================
// 1. Generic Functions (Basic)
// ==============================================================================

fn identity<T>(x: T) -> T {
    x
}

fn swap_pair<A, B>(a: A, b: B) -> (B, A) {
    (b, a)
}

fn first<T>(a: T, b: T) -> T {
    a
}

fn const_fn<T, U>(x: T, y: U) -> T {
    x
}

// ==============================================================================
// 2. Generic Types (Record)
// ==============================================================================

type Box<T> is { value: T };

type Pair<A, B> is { first: A, second: B };

type Triple<X, Y, Z> is { x: X, y: Y, z: Z };

// ==============================================================================
// 3. Generic Variants
// ==============================================================================

type Maybe<T> is Some(T) | None;

type Result<T, E> is Ok(T) | Err(E);

type Either<L, R> is Left(L) | Right(R);

// ==============================================================================
// 4. Generic Functions with Pattern Matching
// ==============================================================================

fn map_maybe<A, B>(m: Maybe<A>, f: fn(A) -> B) -> Maybe<B> {
    match m {
        Some(x) => Some(f(x)),
        None => None
    }
}

fn unwrap_or<T>(m: Maybe<T>, default: T) -> T {
    match m {
        Some(x) => x,
        None => default
    }
}

fn is_some<T>(m: Maybe<T>) -> Bool {
    match m {
        Some(_) => true,
        None => false
    }
}

fn result_map<T, E, U>(r: Result<T, E>, f: fn(T) -> U) -> Result<U, E> {
    match r {
        Ok(x) => Ok(f(x)),
        Err(e) => Err(e)
    }
}

fn result_unwrap_or<T, E>(r: Result<T, E>, default: T) -> T {
    match r {
        Ok(x) => x,
        Err(_) => default
    }
}

