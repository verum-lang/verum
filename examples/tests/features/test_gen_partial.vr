// ==============================================================================
// 8. Generic Method Calls (Higher-order functions)
// ==============================================================================

fn apply<A, B>(x: A, f: fn(A) -> B) -> B {
    f(x)
}

fn compose<A, B, C>(f: fn(A) -> B, g: fn(B) -> C) -> fn(A) -> C {
    |x: A| -> C { g(f(x)) }
}

// ==============================================================================
// 9. Nested Generics
// ==============================================================================

// BUG: Nested variant constructors cause "infinite type" error
