// Test 7: Try/Recover/Finally - Simplified

fn risky_operation() -> Int {
    42
}

fn main() {
    let _ = println("=== Testing Try/Recover/Finally ===");

    // Test 1: Basic try/recover
    let result1 = try {
        let result = risky_operation();
        result
    } recover {
        0
    };
    let _ = println(f"Result: {result1}");

    // Test 2: Try/finally without recover
    try {
        println("Executing operation");
    } finally {
        println("Always executed");
    };

    let _ = println("=== PASSED ===");
}
