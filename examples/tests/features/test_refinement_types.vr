// ============================================================================
// Test 5: Functions Accepting Refined Types
// Functions with refined type parameters
// ============================================================================

fn increment_positive(x: Positive) -> Int {
    x + 1
}

fn double_even(x: Even) -> Int {
    x * 2
}

// Note: Float refinements not yet fully supported
// fn scale_percentage(p: Percentage) -> Float {
//     p / 100.0
// }

fn clamp_range(x: InRange) -> Int {
    if x < 50 {
        50
    } else {
        x
    }
}

// Note: Float refinements not yet fully supported
// fn compute_discount(price: Price, discount: Discount) -> Float {
//     price * (1.0 - discount)
// }

fn test_functions_with_refined_params() {
    let _ = print("\n=== Test 5: Functions with Refined Parameters ===");

    // Test increment positive
    let pos: Positive = 5;
    let incremented = increment_positive(pos);
    let _ = print(f"Increment {pos} -> {incremented}");

    // Test double even
    let even: Even = 10;
    let doubled = double_even(even);
    let _ = print(f"Double even {even} -> {doubled}");

    // Note: Float refinements not yet fully supported
    // let pct: Percentage = 75.0;
    // let scaled = scale_percentage(pct);
    // let _ = print(f"Scale {pct}% -> {scaled}");

    // Test clamp range
    let val1: InRange = 25;
    let val2: InRange = 75;
    let clamped1 = clamp_range(val1);
    let clamped2 = clamp_range(val2);
    let _ = print(f"Clamp {val1} -> {clamped1}, {val2} -> {clamped2}");

    // Note: Float refinements not yet fully supported
    // let price: Price = 100.0;
    // let discount: Discount = 0.20;
    // let final_price = compute_discount(price, discount);
    // let _ = print(f"Price ${price} with {discount} discount -> ${final_price}");

    let _ = print("✓ Function with refined parameter tests passed");
}

// ============================================================================
// Test 6: Functions Returning Refined Types
// Functions that produce refined types
// ============================================================================

fn make_positive(x: Int) -> Int {
    if x > 0 {
        x
    } else {
        1
    }
}

fn make_even(x: Int) -> Int {
    if x % 2 == 0 {
        x
    } else {
        x + 1
    }
}

// Note: Float refinements not yet fully supported
// fn normalize_percentage(x: Float) -> Float {
//     if x < 0.0 {
//         0.0
//     } else if x > 100.0 {
//         100.0
//     } else {
//         x
//     }
// }

fn make_port(x: Int) -> Int {
    if x >= 1 && x <= 65535 {
        x
    } else {
        8080
    }
}

fn test_functions_returning_refined() {
    let _ = print("\n=== Test 6: Functions Returning Refined Types ===");

    // Test make positive
    let pos1 = make_positive(10);
    let pos2 = make_positive(-5);
    let _ = print(f"make_positive(10) -> {pos1}");
    let _ = print(f"make_positive(-5) -> {pos2}");

    // Test make even
    let even1 = make_even(8);
    let even2 = make_even(7);
    let _ = print(f"make_even(8) -> {even1}");
    let _ = print(f"make_even(7) -> {even2}");

    // Note: Float refinements not yet fully supported
    // let pct1 = normalize_percentage(50.0);
    // let pct2 = normalize_percentage(150.0);
    // let pct3 = normalize_percentage(-10.0);
    // let _ = print(f"normalize_percentage(50.0) -> {pct1}");
    // let _ = print(f"normalize_percentage(150.0) -> {pct2}");
    // let _ = print(f"normalize_percentage(-10.0) -> {pct3}");

    // Test make port
    let port1 = make_port(8080);
    let port2 = make_port(99999);
    let _ = print(f"make_port(8080) -> {port1}");
    let _ = print(f"make_port(99999) -> {port2}");

    let _ = print("✓ Function returning refined type tests passed");
}

// ============================================================================
// Test 7: Pattern Matching with Refined Types
// Using refined types in pattern matching contexts
// ============================================================================

type Number is Positive | Negative | Zero;
type Zero is Int{== 0};

type Result<T> is Success(T) | Error(Text);

fn classify_number(n: Int) -> Text {
    match n {
        x where x > 0 => "positive",
        x where x < 0 => "negative",
        _ => "zero"
    }
}

fn process_positive_result(r: Result<Positive>) -> Text {
    match r {
        Success(val) => f"Got positive value: {val}",
        Error(msg) => f"Error: {msg}"
    }
}

fn test_pattern_matching() {
    let _ = print("\n=== Test 7: Pattern Matching with Refined Types ===");

    // Test classify number
    let _ = print(f"classify_number(10) = {classify_number(10)}");
    let _ = print(f"classify_number(-5) = {classify_number(-5)}");
    let _ = print(f"classify_number(0) = {classify_number(0)}");

    // Test result with positive
    let success: Result<Positive> = Success(42);
    let error: Result<Positive> = Error("Invalid input");
    let _ = print(process_positive_result(success));
    let _ = print(process_positive_result(error));

    // Test match with guards on refined types
    let pos: Positive = 50;
    match pos {
        x where x < 10 => { let _ = print(f"Small positive: {x}"); },
        x where x < 50 => { let _ = print(f"Medium positive: {x}"); },
        x => { let _ = print(f"Large positive: {x}"); }
    }

    let _ = print("✓ Pattern matching tests passed");
}

// ============================================================================
// Test 8: Complex Refinement Predicates
// Advanced refinement conditions
// ============================================================================

type ValidYear is Int{it >= 1900 && it <= 2100};
type ValidMonth is Int{it >= 1 && it <= 12};
type ValidDay is Int{it >= 1 && it <= 31};
type PositiveEven is Int{it > 0 && it % 2 == 0};
type NegativeOdd is Int{it < 0 && it % 2 != 0};
type AlphaText is Text{len(it) > 0};

fn test_complex_refinements() {
    let _ = print("\n=== Test 8: Complex Refinement Predicates ===");

    // Test date components
    let year: ValidYear = 2024;
    let month: ValidMonth = 12;
    let day: ValidDay = 10;
    let _ = print(f"Date: {year}-{month}-{day}");

    // Test combined refinements
    let pos_even: PositiveEven = 10;
    let _ = print(f"Positive even: {pos_even}");

    let neg_odd: NegativeOdd = -5;
    let _ = print(f"Negative odd: {neg_odd}");

    // Test text refinements
    let alpha: AlphaText = "abc123";
    let _ = print(f"Alpha text: {alpha}");

    let _ = print("✓ Complex refinement tests passed");
}

// ============================================================================
// Test 9: Refined Types with Arithmetic Operations
// Ensuring refined types work properly with operations
// ============================================================================

fn add_positive(a: Positive, b: Positive) -> Int {
    a + b
}

fn multiply_positive(a: Positive, b: Positive) -> Int {
    a * b
}

fn subtract_natural(a: NaturalNumber, b: NaturalNumber) -> Int {
    a - b
}

fn test_refined_arithmetic() {
    let _ = print("\n=== Test 9: Refined Types with Arithmetic ===");

    let pos1: Positive = 10;
    let pos2: Positive = 20;

    let sum = add_positive(pos1, pos2);
    let _ = print(f"{pos1} + {pos2} = {sum}");

    let product = multiply_positive(pos1, pos2);
    let _ = print(f"{pos1} * {pos2} = {product}");

    let nat1: NaturalNumber = 50;
    let nat2: NaturalNumber = 30;
    let diff = subtract_natural(nat1, nat2);
    let _ = print(f"{nat1} - {nat2} = {diff}");

    let _ = print("✓ Refined arithmetic tests passed");
}

// ============================================================================
// Test 10: Nested Refined Types
// Refined types containing other refined types
// ============================================================================

// Note: Using concrete array size instead of slice for type alias
type PositiveRange is (Positive, Positive);
type PositiveResult is Result<Positive>;

fn sum_positive_list(a: Positive, b: Positive, c: Positive, d: Positive, e: Positive) -> Int {
    a + b + c + d + e
}

fn range_size(range: (Positive, Positive)) -> Int {
    let (start, end) = range;
    end - start
}

fn test_nested_refined() {
    let _ = print("\n=== Test 10: Nested Refined Types ===");

    // Test positive values in function
    let pos1: Positive = 1;
    let pos2: Positive = 2;
    let pos3: Positive = 3;
    let pos4: Positive = 4;
    let pos5: Positive = 5;
    let sum = sum_positive_list(pos1, pos2, pos3, pos4, pos5);
    let _ = print(f"Sum of positive values: {sum}");

    // Test positive range
    let range: (Positive, Positive) = (10, 50);
    let size = range_size(range);
    let _ = print(f"Range size: {size}");

    // Test positive result
    let result: PositiveResult = Success(42);
    match result {
        Success(val) => { let _ = print(f"Success with positive: {val}"); },
        Error(msg) => { let _ = print(f"Error: {msg}"); }
    }

    let _ = print("✓ Nested refined type tests passed");
}

