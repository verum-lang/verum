    let _ = print("╚════════════════════════════════════════════════════════════╝");

    test_inline_refinements();
    test_lambda_refinements();
    test_sigma_refinements();
    test_type_aliases();
    test_functions_with_refined_params();
    test_functions_returning_refined();
    test_pattern_matching();
    test_complex_refinements();
    test_refined_arithmetic();
    test_nested_refined();

    let _ = print("\n╔════════════════════════════════════════════════════════════╗");
    let _ = print("║     ALL REFINEMENT TYPE TESTS PASSED!                     ║");
    let _ = print("╚════════════════════════════════════════════════════════════╝");
}
