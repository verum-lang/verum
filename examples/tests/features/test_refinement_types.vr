// Comprehensive Refinement Types Test Suite
// Tests all five refinement type binding rules from spec 03-type-system.md

// ============================================================================
// Test 1: Simple Inline Refinement Types (Rule 1 - Preferred)
// Syntax: type Name is BaseType{predicate};
// Uses implicit 'it' reference
// ============================================================================

type Positive is Int{> 0};
type Negative is Int{< 0};
type NonZero is Int{!= 0};
type Email is Text{len(it) > 5 && it.contains('@')};
type Port is Int{it >= 1 && it <= 65535};
// type BoundedFloat is Float{0.0 <= it && it <= 1.0}; // Float refinements not yet fully supported
type NonEmpty is Text{len(it) > 0};
type SmallInt is Int{it >= -100 && it <= 100};

fn test_inline_refinements() {
    let _ = print("\n=== Test 1: Inline Refinement Types (Rule 1) ===");

    // Test positive integers
    let pos1: Positive = 5;
    let pos2: Positive = 100;
    let _ = print(f"Positive values: {pos1}, {pos2}");

    // Test negative integers
    let neg1: Negative = -10;
    let neg2: Negative = -50;
    let _ = print(f"Negative values: {neg1}, {neg2}");

    // Test port numbers
    let port: Port = 8080;
    let _ = print(f"Valid port: {port}");

    // Note: Float refinements not yet fully supported
    // let bounded: BoundedFloat = 0.5;
    // let _ = print(f"Bounded float (0-1): {bounded}");

    // Test non-empty text
    let text: NonEmpty = "Hello";
    let _ = print(f"Non-empty text: {text}");

    let _ = print("✓ Inline refinement tests passed");
}

// ============================================================================
// Test 2: Lambda-Style Where Clause Refinements (Rule 2 - Recommended)
// Syntax: type Name is BaseType where |param| predicate;
// Uses explicit lambda parameter binding
// ============================================================================

type Even is Int where |x| x % 2 == 0;
type Odd is Int where |x| x % 2 != 0;
type ValidText is Text where |s| len(s) > 5 && len(s) < 100;
type InRange is Int where |n| n >= 0 && n <= 100;
// type Percentage is Float where |p| 0.0 <= p && p <= 100.0;
type LongText is Text where |t| len(t) > 20;

fn test_lambda_refinements() {
    let _ = print("\n=== Test 2: Lambda-Style Where Clause (Rule 2) ===");

    // Test even numbers
    let even1: Even = 10;
    let even2: Even = 42;
    let _ = print(f"Even numbers: {even1}, {even2}");

    // Test odd numbers
    let odd1: Odd = 5;
    let odd2: Odd = 99;
    let _ = print(f"Odd numbers: {odd1}, {odd2}");

    // Test in-range values
    let val: InRange = 50;
    let _ = print(f"In-range value (0-100): {val}");

    // Note: Float refinements not yet fully supported
    // let pct: Percentage = 75.5;
    // let _ = print(f"Percentage: {pct}%");

    // Test valid text
    let text: ValidText = "Hello World";
    let _ = print(f"Valid text: {text}");

    let _ = print("✓ Lambda-style refinement tests passed");
}

// ============================================================================
// Test 3: Sigma-Type Refinements (Rule 3 - Dependent Types)
// Syntax: variable: BaseType where predicate;
// Explicitly names the variable being refined
// ============================================================================

type NaturalNumber is n: Int where n >= 0;
type Index is i: Int where i >= 0 && i < 1000;
type ValidEmail is email: Text where email.contains('@') && len(email) > 5;
// type Score is score: Float where 0.0 <= score && score <= 100.0;
type NonEmptyString is s: Text where len(s) > 0;

fn test_sigma_refinements() {
    let _ = print("\n=== Test 3: Sigma-Type Refinements (Rule 3) ===");

    // Test natural numbers
    let nat1: NaturalNumber = 0;
    let nat2: NaturalNumber = 42;
    let _ = print(f"Natural numbers: {nat1}, {nat2}");

    // Test indices
    let idx1: Index = 0;
    let idx2: Index = 500;
    let _ = print(f"Valid indices: {idx1}, {idx2}");

    // Note: Float refinements not yet fully supported
    // let score: Score = 95.5;
    // let _ = print(f"Score: {score}");

    // Test non-empty strings
    let text: NonEmptyString = "Verum";
    let _ = print(f"Non-empty string: {text}");

    let _ = print("✓ Sigma-type refinement tests passed");
}

