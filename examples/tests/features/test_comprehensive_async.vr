async fn spawn_and_await_single() -> Int {
    let task = spawn async_computation(10);
    task.await
}

async fn spawn_and_await_multiple() -> Int {
    let task1 = spawn async_computation(5);
    let task2 = spawn async_computation(10);

    let result1 = task1.await;
    let result2 = task2.await;

    result1 + result2
}

async fn spawn_conditional() -> Int {
    let should_spawn = true;
    if should_spawn {
        let task = spawn async_computation(15);
        task.await
    } else {
        0
    }
}

