// ========================================
// 11. ERROR HANDLING IN ASYNC
// ========================================

async fn async_may_fail(should_fail: Bool) -> Result<Int, AsyncError> {
    if should_fail {
        Err(GenericError("operation failed"))
    } else {
        Ok(100)
    }
}

async fn handle_async_error(should_fail: Bool) -> Int {
    let result = async_may_fail(should_fail).await;
    match result {
        Ok(val) => val,
        Err(NetworkError(msg)) => -1,
        Err(TimeoutError) => -2,
        Err(ParseError(msg)) => -3,
        Err(GenericError(msg)) => -4
    }
}

fn test_async_error_handling() {
    let _ = print("\n=== Test 10: Error Handling in Async ===");

    let _ = print("async function with error types defined");
    let _ = print("async error handler with pattern matching defined");
}

// ========================================
// 12. DEFER WITH ASYNC
// ========================================

async fn async_with_defer() -> Int {
    defer {
        let _ = print("defer: cleanup executed");
    };

    let result = async_computation(5).await;
    result
}

async fn multiple_defers() -> Int {
    defer {
        let _ = print("defer 1: first cleanup");
    };

    defer {
        let _ = print("defer 2: second cleanup");
    };

    let x = 10;
    let y = 20;
    x + y
}

fn test_defer_with_async() {
    let _ = print("\n=== Test 11: Defer with Async ===");

    let _ = print("async function with defer statement defined");
    let _ = print("async function with multiple defers defined");
}

// ========================================
// 13. COMPLEX ASYNC PATTERNS
// ========================================

async fn complex_async_workflow() -> Int {
    // Step 1: Spawn background tasks
    let task1 = spawn async_computation(10);
    let task2 = spawn async_computation(20);

    // Step 2: Perform local computation
    let local_result = 5;

    // Step 3: Await tasks
    let result1 = task1.await;
    let result2 = task2.await;

    // Step 4: Combine results
    local_result + result1 + result2
}

async fn async_pipeline(x: Int) -> Int {
    let step1 = async_computation(x).await;
    let step2 = async_computation(step1).await;
    let step3 = async_computation(step2).await;
    step3
}

async fn conditional_async(condition: Bool) -> Int {
    if condition {
        let result = async_computation(10).await;
        result
    } else {
        let task = spawn async_computation(20);
        task.await
    }
}

fn test_complex_async_patterns() {
    let _ = print("\n=== Test 12: Complex Async Patterns ===");

    let _ = print("complex async workflow with spawn and await defined");
    let _ = print("async pipeline with sequential operations defined");
    let _ = print("conditional async with branching defined");
}

// ========================================
// 14. ASYNC TASK TYPES
// ========================================

async fn create_task<T>(id: Int, data: T) -> Task<T> {
    Task { id: id, data: data }
}

async fn process_task<T>(task: Task<T>) -> Int {
    task.id
}

async fn generic_async_workflow<T>(id: Int, data: T) -> Int {
    let task = create_task(id, data).await;
    let result = process_task(task).await;
    result
}

fn test_async_generics() {
    let _ = print("\n=== Test 13: Async with Generics ===");

    let _ = print("generic async task creation defined");
    let _ = print("generic async task processing defined");
    let _ = print("generic async workflow defined");
}

