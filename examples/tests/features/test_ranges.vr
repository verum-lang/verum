// Test range expressions and loops

fn test_while_loop() {
    let mut i = 0;
    let mut sum = 0;
    while i < 10 {
        sum = sum + i;
        i = i + 1;
    }
    let _ = print(f"While loop sum 0-9: {sum}");
}

fn test_loop_with_break() {
    let mut count = 0;
    loop {
        count = count + 1;
        if count >= 5 {
            break;
        }
    }
    let _ = print(f"Loop with break: {count}");
}

fn main() {
    let _ = print("=== Range and Loop Tests ===");

    test_while_loop();
    test_loop_with_break();

    let _ = print("=== Tests Complete ===");
}
