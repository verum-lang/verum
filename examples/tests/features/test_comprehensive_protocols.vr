// For now, we define separate protocols
type Show is protocol {
    fn show(self) -> Text;
};

implement Show for Point {
    fn show(self) -> Text {
        self.display()
    }
}

fn test_protocol_extension() {
    let _ = print("\n=== Test 9: Protocol Extension Concept ===");

    let p = Point { x: 9.0, y: 11.0 };
    let _ = print(f"Point.show(): {p.show()}");
}

// ========================================
// 11. GENERIC FUNCTIONS WITH PROTOCOLS
// ========================================

fn format_list<T>(items: T, separator: Text) -> Text where type T: Display {
    // In a real implementation, this would iterate over a list
    // For now, just demonstrate the type constraint
    items.display()
}

fn log_value<T>(value: T, prefix: Text) where type T: Debug {
    let debug_str = value.debug();
    let _ = print(f"{prefix}: {debug_str}");
}

fn test_generic_protocol_functions() {
    let _ = print("\n=== Test 10: Generic Functions with Protocols ===");

    let p = Point { x: 12.0, y: 13.0 };
    let formatted = format_list(p, ", ");
    let _ = print(f"format_list: {formatted}");

    log_value(p, "Point value");

    let person = Person { name: "Charlie", age: 35 };
    log_value(person, "Person value");
}

// ========================================
// 12. PROTOCOLS WITH SELF TYPE
// ========================================

type Cloneable is protocol {
    fn clone(self) -> Self;
};

implement Cloneable for Point {
    fn clone(self) -> Self {
        Point { x: self.x, y: self.y }
    }
}

implement Cloneable for Person {
    fn clone(self) -> Self {
        Person { name: self.name, age: self.age }
    }
}

fn duplicate<T>(value: T) -> T where type T: Cloneable {
    value.clone()
}

fn test_self_type_protocol() {
    let _ = print("\n=== Test 11: Protocols with Self Type ===");

    let p1 = Point { x: 14.0, y: 15.0 };
    let p2 = duplicate(p1);
    let _ = print(f"Original: {p1.display()}");
    let _ = print(f"Clone: {p2.display()}");

    let person1 = Person { name: "Dave", age: 40 };
    let person2 = duplicate(person1);
    let _ = print(f"Original: {person1.display()}");
    let _ = print(f"Clone: {person2.display()}");
}

// ========================================
// 13. CONDITIONAL PROTOCOL IMPLEMENTATION
// ========================================

// Implement Debug for Pair only when both types implement Debug
implement<A, B> Debug for Pair<A, B> where type A: Debug, type B: Debug {
    fn debug(self) -> Text {
        f"Pair({self.first.debug()}, {self.second.debug()})"
    }

    fn verbose_debug(self) -> Text {
        f"Pair with first={self.first.debug()}, second={self.second.debug()}"
    }
}

fn test_conditional_implementation() {
    let _ = print("\n=== Test 12: Conditional Protocol Implementation ===");

    let pair_points: Pair<Point, Point> = Pair {
        first: Point { x: 1.0, y: 2.0 },
        second: Point { x: 3.0, y: 4.0 }
    };
    let _ = print(f"Pair<Point, Point>.debug(): {pair_points.debug()}");

    let pair_mixed: Pair<Point, Person> = Pair {
        first: Point { x: 5.0, y: 6.0 },
        second: Person { name: "Eve", age: 28 }
    };
    let _ = print(f"Pair<Point, Person>.debug(): {pair_mixed.debug()}");
}

