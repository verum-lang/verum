// Test 7: Try/Recover/Finally

fn risky_operation() -> Int {
    42
}

fn might_fail(should_fail: Bool) -> Int {
    if should_fail {
        panic("Operation failed")
    } else {
        100
    }
}

fn cleanup() {
    println("Cleanup called");
}

fn main() {
    let _ = println("=== Testing Try/Recover/Finally ===");

    // Test 1: Basic try/recover
    let _ = println("\nTest 1: Basic try/recover");
    let result1 = try {
        let result = risky_operation();
        result
    } recover {
        0
    };
    let _ = println(f"Result: {result1}");

    // Test 2: Try/recover/finally
    let _ = println("\nTest 2: Try/recover/finally");
    try {
        let value = might_fail(false);
        println(value);
    } recover {
        println(-1);
    } finally {
        cleanup();
    };

    // Test 3: Try/finally without recover
    let _ = println("\nTest 3: Try/finally without recover");
    try {
        println("Executing operation");
    } finally {
        println("Always executed");
    };

    // Test 4: Recover from failure
    let _ = println("\nTest 4: Recover from failure");
    try {
        let value = might_fail(true);
        println(value);
    } recover {
        println("Recovered from error!");
    } finally {
        println("Finally block");
    };

    let _ = println("\n=== PASSED ===");
}
