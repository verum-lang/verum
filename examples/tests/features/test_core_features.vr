// Comprehensive Core Features Test
// Tests all fundamental Verum language features
//
// Coverage:
// 1. Basic types (Float, Text, Bool)
// 2. Collection types (Arrays, Tuples)
// 3. Variant types (Maybe, Result, custom variants)
// 4. Pattern matching
// 5. Functions with generic types
// 6. Error handling with Result
// 7. F-string interpolation
// 8. Closures and higher-order functions
// 9. Control flow (while, loop, if/else)
// 10. Recursion

// ========================================
// 1. TYPE DEFINITIONS
// ========================================
type Color is Red | Green | Blue | Custom(Float, Float, Float);
type Maybe<T> is Some(T) | None;
type Result<T, E> is Ok(T) | Err(E);

type Point is {
    x: Float,
    y: Float
};

type Pair<A, B> is {
    first: A,
    second: B
};

// ========================================
// 2. FUNCTIONS
// ========================================
fn add(a: Float, b: Float) -> Float {
    a + b
}

fn identity<T>(x: T) -> T {
    x
}

fn factorial(n: Float) -> Float {
    if n <= 1.0 { 1.0 } else { n * factorial(n - 1.0) }
}

// ========================================
// 3. PATTERN MATCHING
// ========================================
fn color_name(c: Color) -> Text {
    match c {
        Red => "red",
        Green => "green",
        Blue => "blue",
        Custom(r, g, b) => "custom"
    }
}

// Result functions for error handling
fn safe_divide(a: Float, b: Float) -> Result<Float, Text> {
    if b == 0.0 {
        Err("division by zero")
    } else {
        Ok(a / b)
    }
}

fn unwrap_or(opt: Maybe<Float>, default: Float) -> Float {
    match opt {
        Some(v) => v,
        None => default
    }
}

// ========================================
// 4. CLOSURES
// ========================================
fn make_adder(n: Float) -> fn(Float) -> Float {
    |x: Float| -> Float { x + n }
}

fn apply<T, U>(f: fn(T) -> U, x: T) -> U {
    f(x)
}

// ========================================
// 5. CONTROL FLOW
// ========================================
fn sum_to(n: Float) -> Float {
    let mut sum = 0.0;
    let mut i = 1.0;
    while i <= n {
        sum = sum + i;
        i = i + 1.0;
    }
    sum
}

fn count_down(n: Float) -> Float {
    let mut count = n;
    loop {
        count = count - 1.0;
        if count <= 0.0 {
            break;
        }
    }
    count
}

// ========================================
// MAIN
// ========================================
fn main() {
    let _ = print("╔════════════════════════════════════════╗");
    let _ = print("║  Verum Core Features Test Suite       ║");
    let _ = print("╚════════════════════════════════════════╝");
    let _ = print("");

    // Arithmetic
    let _ = print("-- Arithmetic --");
    let _ = print(f"5 + 3 = {add(5.0, 3.0)}");
    let _ = print(f"factorial(6) = {factorial(6.0)}");
    let _ = print("");

    // Generics
    let _ = print("-- Generics --");
    let _ = print(f"identity(42) = {identity(42.0)}");
    let s = identity("hello");
    let _ = print(f"identity(hello) = {s}");
    let _ = print("");

    // Variants
    let _ = print("-- Variants --");
    let _ = print(f"color_name(Red) = {color_name(Red)}");
    let _ = print(f"color_name(Blue) = {color_name(Blue)}");
    let custom_color = Custom(0.5, 0.5, 0.5);
    let _ = print(f"color_name(Custom) = {color_name(custom_color)}");
    let _ = print("");

    // Result Error Handling
    let _ = print("-- Result Error Handling --");
    let div_ok = safe_divide(10.0, 2.0);
    let div_err = safe_divide(10.0, 0.0);

    match div_ok {
        Ok(v) => { let _ = print(f"safe_divide(10, 2) = Ok({v})"); },
        Err(msg) => { let _ = print(f"Error: {msg}"); }
    }

    match div_err {
        Ok(v) => { let _ = print(f"safe_divide(10, 0) = Ok({v})"); },
        Err(msg) => { let _ = print(f"safe_divide(10, 0) = Err(\"{msg}\")"); }
    }
    let _ = print("");

    // Maybe
    let _ = print("-- Maybe --");
    let some_val: Maybe<Float> = Some(42.0);
    let none_val: Maybe<Float> = None;
    let _ = print(f"unwrap_or(Some(42), 0) = {unwrap_or(some_val, 0.0)}");
    let _ = print(f"unwrap_or(None, 0) = {unwrap_or(none_val, 0.0)}");
    let _ = print("");

    // Records
    let _ = print("-- Records --");
    let p = Point { x: 3.0, y: 4.0 };
    let _ = print(f"Point: ({p.x}, {p.y})");
    let _ = print("");

    // Closures
    let _ = print("-- Closures --");
    let add5 = make_adder(5.0);
    let _ = print(f"add5(10) = {add5(10.0)}");
    let double = |x: Float| x * 2.0;
    let _ = print(f"apply(double, 7) = {apply(double, 7.0)}");
    let _ = print("");

    // Control flow
    let _ = print("-- Control Flow --");
    let _ = print(f"sum_to(10) = {sum_to(10.0)}");
    let _ = print(f"count_down(5) = {count_down(5.0)}");
    let _ = print("");

    // Arrays
    let _ = print("-- Arrays --");
    let arr = [1.0, 2.0, 3.0];
    let _ = print(f"arr[0] = {arr[0]}, arr[1] = {arr[1]}, arr[2] = {arr[2]}");
    let _ = print("");

    // Tuples
    let _ = print("-- Tuples --");
    let pair = (100.0, 200.0);
    let (a, b) = pair;
    let _ = print(f"pair: ({a}, {b})");
    let _ = print("");

    let _ = print("╔════════════════════════════════════════╗");
    let _ = print("║  All Core Features Tests PASSED! ✓    ║");
    let _ = print("╚════════════════════════════════════════╝");
}
