    test_refinement_types();
    test_generics();
    test_three_tier_references();
    test_defer();
    test_multiple_defers();
    let _ = println("  STATUS: PASSED");
    test_try_recover_finally();

    let _ = println("\n╔════════════════════════════════════════════════════════════╗");
    let _ = println("║                    ALL TESTS PASSED                        ║");
    let _ = println("╚════════════════════════════════════════════════════════════╝");

    let _ = println("\nWORKING FEATURES:");
    let _ = println("  ✓ Refinement types (Int{it > 0}, Text{len(it) > 0})");
    let _ = println("  ✓ Generic functions");
    let _ = println("  ✓ Three-tier references (&T, &checked T, &unsafe T)");
    let _ = println("  ✓ Defer statements (including LIFO ordering)");
    let _ = println("  ✓ Try/recover/finally blocks");

    let _ = println("\nNOT YET WORKING:");
    let _ = println("  ✗ Protocol definitions and implementations");
    let _ = println("  ✗ Context system (context/provide/using)");
}
