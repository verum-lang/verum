// ============================================================================
// Comprehensive Protocol Implementation Test for Verum
// Tests: Protocol definitions, implementations, bounds, generics, and defaults
// Based on: grammar/verum.ebnf (Lines 299-447)
// ============================================================================

// ============================================================================
// Test 1: Basic Protocol Definition
// ============================================================================

type Display is protocol {
    fn display(self) -> Text;
};

type Debug is protocol {
    fn debug(&self) -> Text;
};

// ============================================================================
// Test 2: Record Type Definition (needed for later protocols)
// ============================================================================

type Point is { x: Int, y: Int };

// ============================================================================
// Test 3: Protocol with Default Implementation
// ============================================================================

type Eq is protocol {
    fn eq(&self, other: &Point) -> Bool;

    fn ne(&self, other: &Point) -> Bool {
        !self.eq(other)
    }
};

// ============================================================================
// Test 4: Protocol with Associated Type
// ============================================================================

type Iterator is protocol {
    type Item;

    fn next(&mut self) -> Int;
};

// ============================================================================
// Test 5: Generic Associated Type (GAT)
// ============================================================================

type Container is protocol {
    type Element<T>;

    fn get<T>(&self, index: Int) -> Int;
};

// ============================================================================
// Test 6: Protocol Extension (Inheritance)
// ============================================================================

type Comparable is protocol {
    fn compare(&self, other: &Point) -> Int;
};

type Ord is protocol extends Comparable {
    fn cmp(&self, other: &Point) -> Int;

    fn lt(&self, other: &Point) -> Bool {
        self.cmp(other) < 0
    }
};

// ============================================================================
// Test 7: Basic Implementation
// ============================================================================

implement Display for Point {
    fn display(self) -> Text {
        "Point"
    }
}

implement Debug for Point {
    fn debug(&self) -> Text {
        "Point"
    }
}

implement Eq for Point {
    fn eq(&self, other: &Point) -> Bool {
        true
    }
}

implement Comparable for Point {
    fn compare(&self, other: &Point) -> Int {
        0
    }
}

implement Ord for Point {
    fn cmp(&self, other: &Point) -> Int {
        0
    }
}

// ============================================================================
// Test 8: Generic Protocol Definition
// ============================================================================

type Converter<T> is protocol {
    fn convert(&self) -> T;
};

// ============================================================================
// Test 9: Generic Protocol Implementation
// ============================================================================

implement Converter<Text> for Point {
    fn convert(&self) -> Text {
        "point"
    }
}

implement Converter<Int> for Point {
    fn convert(&self) -> Int {
        42
    }
}

// ============================================================================
// Test 10: Generic Type with Protocol Bound
// ============================================================================

type Wrapper<T> is { value: T };

implement<T> Display for Wrapper<T> where type T: Display {
    fn display(self) -> Text {
        "Wrapper"
    }
}

// ============================================================================
// Test 11: Multiple Protocol Bounds
// ============================================================================

type Pair<T> is { first: T, second: T };

implement<T> Display for Pair<T> where type T: Display + Eq {
    fn display(self) -> Text {
        "Pair"
    }
}

// ============================================================================
// Test 12: Generic Function with Protocol Bound
// ============================================================================

fn show<T>(item: T) where type T: Display {
    print("show called");
}

fn show_both<T>(a: T, b: T) where type T: Display + Eq {
    print("show_both called");
}

// ============================================================================
// Test 13: Protocol with Multiple Default Methods
// ============================================================================

type Sized is protocol {
    fn size(&self) -> Int {
        2
    }

    fn double_size(&self) -> Int {
        self.size() * 2
    }
};

type Rectangle is { width: Int, height: Int };

implement Sized for Rectangle {
    fn size(&self) -> Int {
        2
    }
}

// ============================================================================
// Test 14: Inherent Implementation (no protocol)
// ============================================================================

type Counter is { count: Int };

implement Counter {
    fn new() -> Counter {
        Counter { count: 0 }
    }

    fn increment(&mut self) {
        let temp = 1;
    }

    fn get(&self) -> Int {
        0
    }
}

// ============================================================================
// Test 15: Protocol for Enum Type
// ============================================================================

type Option<T> is
    | Some(T)
    | None;

implement<T> Display for Option<T> where type T: Display {
    fn display(self) -> Text {
        "Option"
    }
}

// ============================================================================
// Test 16: Multiple Implementations for Same Type
// ============================================================================

type Number is { value: Int };

implement Display for Number {
    fn display(self) -> Text {
        "Number"
    }
}

implement Debug for Number {
    fn debug(&self) -> Text {
        "Number"
    }
}

implement Eq for Number {
    fn eq(&self, other: &Point) -> Bool {
        true
    }
}

// ============================================================================
// Test 17: Protocol with Multiple Methods
// ============================================================================

type Collection is protocol {
    fn len(&self) -> Int;
    fn is_empty(&self) -> Bool;
    fn clear(&mut self);

    fn capacity(&self) -> Int {
        0
    }
};

type SimpleList is { items: Int, size: Int };

implement Collection for SimpleList {
    fn len(&self) -> Int {
        0
    }

    fn is_empty(&self) -> Bool {
        true
    }

    fn clear(&mut self) {
        let temp = 0;
    }
}

// ============================================================================
// Test 18: Async Protocol Method
// ============================================================================

type AsyncFetcher is protocol {
    async fn fetch(&self) -> Text;
};

type DummyFetcher is { url: Text };

implement AsyncFetcher for DummyFetcher {
    async fn fetch(&self) -> Text {
        "Fetching"
    }
}

// ============================================================================
// Main Function: Test All Protocol Implementations
// ============================================================================

fn main() {
    print("=== Protocol Implementation Tests ===");

    // Test 1-7: Basic protocols and implementations
    let p1 = Point { x: 10, y: 20 };
    print("Point created");

    let p2 = Point { x: 10, y: 20 };
    let p3 = Point { x: 5, y: 15 };
    print("Multiple points created");

    // Test 8-9: Generic protocol implementations
    print("Generic protocol tests complete");

    // Test 10: Generic type with protocol bound
    let wrapped = Wrapper { value: p1 };
    print("Wrapped point created");

    // Test 11: Multiple protocol bounds
    let pair = Pair { first: p1, second: p2 };
    print("Pair created");

    // Test 12: Generic functions with protocol bounds
    print("=== Generic Functions ===");
    show(p1);
    show_both(p1, p2);

    // Test 13: Protocol with const
    let rect = Rectangle { width: 100, height: 50 };
    print("Rectangle created");

    // Test 14: Inherent implementation (NOT YET IMPLEMENTED)
    // print("=== Counter ===");
    // let mut counter = Counter { count: 0 };
    // print("Counter created");
    // counter.increment();  // FAILS: inherent methods not yet implemented
    // counter.increment();
    // print("Counter incremented");
    print("Counter test skipped - inherent methods not yet implemented");

    // Test 15: Protocol for enum type
    let some_val = Option.Some(42);
    let none_val = Option.None;
    print("Option values created");

    // Test 16: Multiple implementations
    let num = Number { value: 42 };
    print("Number created");

    let num2 = Number { value: 42 };
    print("Second number created");

    // Test 17: Protocol with multiple methods (NOT YET IMPLEMENTED)
    print("=== Collection Protocol ===");
    let mut list = SimpleList { items: 0, size: 5 };
    print("SimpleList created");
    // list.clear();  // FAILS: protocol methods not yet resolved
    print("List method calls not yet implemented");

    // Test 18: Async protocol
    let fetcher = DummyFetcher { url: "http://example.com" };
    print("Async fetcher created");

    print("=== All Tests Complete ===");
}
