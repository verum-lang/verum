// ============================================================================
// Test 9: Result to Maybe conversion
// NOTE: Currently disabled - .ok() method requires stdlib Result integration
// ============================================================================

fn test_result_maybe_conversion() {
    println("\n=== Test 9: Result to Maybe conversion ===");
    println("DISABLED: .ok() method requires stdlib Result type integration");

    // Manual conversion works:
    let ok_result: Result<Int, Text> = Result.Ok(42);
    match ok_result {
        Result.Ok(v) => {
            let maybe_val: Maybe<Int> = Maybe.Some(v);
            match maybe_val {
                Maybe.Some(x) => println(x),
                Maybe.None => println("None"),
            }
        },
        Result.Err(_) => {
            let maybe_val: Maybe<Int> = Maybe.None;
            println("None");
        },
    }
}

// ============================================================================
// Test 10: Maybe type operations
// ============================================================================

fn test_maybe_operations() {
    println("\n=== Test 10: Maybe type operations ===");

    let some_val: Maybe<Int> = Maybe.Some(42);
    let none_val: Maybe<Int> = Maybe.None;

    println(some_val.is_some());
    println(none_val.is_none());

    // unwrap_or
    let unwrapped = none_val.unwrap_or(100);
    println(unwrapped);

    // Match on Maybe
    match some_val {
        Maybe.Some(v) => println(v),
        Maybe.None => println("None"),
    }

    // Null coalescing operator
    let x: Maybe<Int> = Maybe.None;
    let z = x ?? 0;
    println(z);

    println("Maybe operations completed");
}

// ============================================================================
// Main test runner
// ============================================================================

fn main() {
    println("========================================");
    println("Comprehensive Error Handling Test Suite");
    println("========================================\n");

    test_basic_try();
    test_try_recover();
    test_try_finally();
    test_try_recover_finally();
    test_panic_recover();
    test_nested_try();
    test_result_operations();
    test_question_operator();
    test_result_maybe_conversion();
    test_maybe_operations();

    println("\n========================================");
    println("Error Handling Tests Complete");
    println("========================================");
}
