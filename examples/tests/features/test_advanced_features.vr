// Advanced Features Test
// Tests: Refinement types, Generics, Protocols, Context system, Three-tier references, defer, try/recover

// ============================================================================
// 1. REFINEMENT TYPES
// ============================================================================

type PositiveInt is Int{it > 0};
type NonEmptyText is Text{len(it) > 0};

fn test_refinement_types() {
    let _ = println("Testing Refinement Types...");

    // Basic refinement type usage
    let x: PositiveInt = 42;
    let name: NonEmptyText = "Alice";

    let _ = println(f"  PositiveInt: {x}");
    let _ = println(f"  NonEmptyText: {name}");
}

// ============================================================================
// 2. GENERIC FUNCTIONS
// ============================================================================

fn identity<T>(x: T) -> T {
    x
}

fn pair<A, B>(first: A, second: B) -> (A, B) {
    (first, second)
}

fn test_generics() {
    let _ = println("Testing Generic Functions...");

    let num = identity(42);
    let text = identity("hello");
    let p = pair(1, "one");

    let _ = println(f"  identity(42): {num}");
    let _ = println(f"  identity(\"hello\"): {text}");
    let _ = println("  pair result created");
}

// ============================================================================
// 3. PROTOCOL DEFINITIONS AND IMPLEMENTATIONS
// ============================================================================

type Show is protocol {
    fn show(self) -> Text;
};

type Person is {
    name: Text,
    age: Int
};

impl Show for Person {
    fn show(self) -> Text {
        f"{self.name} ({self.age})"
    }
}

impl Show for Int {
    fn show(self) -> Text {
        f"{self}"
    }
}

fn test_protocols() {
    let _ = println("Testing Protocols...");

    let person = Person { name: "Bob", age: 30 };
    let num = 42;

    let person_text = person.show();
    let num_text = num.show();

    let _ = println(f"  Person.show(): {person_text}");
    let _ = println(f"  Int.show(): {num_text}");
}

// ============================================================================
// 4. CONTEXT SYSTEM
// ============================================================================

context Logger {
    fn log(message: Text);
}

context Config {
    fn get_value(key: Text) -> Text;
}

fn log_message(msg: Text) using Logger {
    Logger.log(msg);
}

fn get_config_value(key: Text) using Config -> Text {
    Config.get_value(key)
}

fn test_context_system() {
    let _ = println("Testing Context System...");

    // Mock logger provider
    provide Logger {
        fn log(message: Text) {
            let _ = println(f"  [LOG] {message}");
        }
    } in {
        log_message("Context system working!");
    };

    // Mock config provider
    provide Config {
        fn get_value(key: Text) -> Text {
            if key == "app_name" {
                "VerumTest"
            } else {
                "unknown"
            }
        }
    } in {
        let app_name = get_config_value("app_name");
        let _ = println(f"  Config value: {app_name}");
    };
}

// ============================================================================
// 5. THREE-TIER REFERENCES
// ============================================================================

fn test_basic_ref(x: &Int) -> Int {
    *x + 1
}

fn test_checked_ref(x: &checked Int) -> Int {
    *x + 2
}

fn test_unsafe_ref(x: &unsafe Int) -> Int {
    *x + 3
}

fn test_three_tier_references() {
    let _ = println("Testing Three-Tier References...");

    let value = 10;

    // Tier 0: Basic reference with CBGR protection
    let result1 = test_basic_ref(&value);
    let _ = println(f"  &T result: {result1}");

    // Tier 1: Checked reference (compiler-proven safe)
    let result2 = test_checked_ref(&checked value);
    let _ = println(f"  &checked T result: {result2}");

    // Tier 2: Unsafe reference (manual proof required)
    let result3 = test_unsafe_ref(&unsafe value);
    let _ = println(f"  &unsafe T result: {result3}");
}

// ============================================================================
// 6. DEFER STATEMENTS
// ============================================================================

fn test_defer() {
    let _ = println("Testing Defer Statements...");

    let _ = println("  Before defer");

    defer {
        let _ = println("  Defer executed (cleanup)");
    }

    let _ = println("  After defer declaration");
    let _ = println("  Function returning...");
}

fn test_multiple_defers() {
    let _ = println("Testing Multiple Defers (LIFO order)...");

    defer {
        let _ = println("  Defer 1 (last)");
    }

    defer {
        let _ = println("  Defer 2 (middle)");
    }

    defer {
        let _ = println("  Defer 3 (first)");
    }

    let _ = println("  Main execution");
}

// ============================================================================
// 7. TRY/RECOVER/FINALLY
// ============================================================================

fn may_fail(should_fail: Bool) -> Int {
    if should_fail {
        fail("Operation failed!")
    } else {
        42
    }
}

fn test_try_recover() {
    let _ = println("Testing Try/Recover...");

    // Success case
    try {
        let result = may_fail(false);
        let _ = println(f"  Success: {result}");
    } recover {
        let _ = println("  Should not reach here");
    };

    // Failure case
    try {
        let result = may_fail(true);
        let _ = println(f"  Should not reach here: {result}");
    } recover {
        let _ = println("  Recovered from failure!");
    };
}

fn test_try_finally() {
    let _ = println("Testing Try/Finally...");

    try {
        let _ = println("  Try block executing");
        let x = 10 + 20;
        let _ = println(f"  Result: {x}");
    } finally {
        let _ = println("  Finally block executed");
    };
}

fn test_try_recover_finally() {
    let _ = println("Testing Try/Recover/Finally (failure case)...");

    try {
        let _ = println("  Attempting operation...");
        may_fail(true);
    } recover {
        let _ = println("  Recovered!");
    } finally {
        let _ = println("  Cleanup in finally");
    };
}

// ============================================================================
// MAIN TEST RUNNER
// ============================================================================

fn main() {
    let _ = println("=== VERUM ADVANCED FEATURES TEST ===");
    let _ = println("");

    test_refinement_types();
    let _ = println("");

    test_generics();
    let _ = println("");

    test_protocols();
    let _ = println("");

    test_context_system();
    let _ = println("");

    test_three_tier_references();
    let _ = println("");

    test_defer();
    let _ = println("");

    test_multiple_defers();
    let _ = println("");

    test_try_recover();
    let _ = println("");

    test_try_finally();
    let _ = println("");

    test_try_recover_finally();
    let _ = println("");

    let _ = println("=== TEST COMPLETE ===");
}
