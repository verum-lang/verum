// ==============================================================================
// 6. Where Clauses (Pattern Guards)
// ==============================================================================

// BUG: Having both Float and Int where clause guards in same file causes type mismatch
// fn check_positive(x: Float) -> Text {
//     match x {
//         n where n > 0.0 => "positive",
//         n where n < 0.0 => "negative",
//         _ => "zero"
//     }
// }

fn categorize_int(x: Int) -> Text {
    match x {
        n where n > 100 => "large",
        n where n > 10 => "medium",
        n where n > 0 => "small",
        _ => "non-positive"
    }
}

