// =============================================================================
// Section 7: Advanced Stream Patterns
// =============================================================================

fn test_advanced_patterns() -> Int {
    println("--- Test 7: Advanced Stream Patterns ---");

    // Test 7.1: Destructuring in pattern
    let pairs = [(1, 2), (3, 4), (5, 6)];
    let sums = stream[x + y for (x, y) in pairs];
    println("7.1: Destructuring pattern - stream[x + y for (x, y) in pairs]");

    // Test 7.2: Array pattern in stream
    let arrays = [[1, 2], [3, 4], [5, 6]];
    let firsts = stream[a for [a, b] in arrays];
    println("7.2: Array pattern - stream[a for [a, b] in arrays]");

    // Test 7.3: Nested destructuring
    let nested = [((1, 2), 3), ((4, 5), 6)];
    let computed = stream[a + b + c for ((a, b), c) in nested];
    println("7.3: Nested destructuring - stream[a + b + c for ((a, b), c) in nested]");

    // Test 7.4: Multiple patterns with filter
    let multi_pattern = stream[x * y for (x, y) in pairs if x > 1];
    println("7.4: Pattern with filter - stream[x * y for (x, y) in pairs if x > 1]");

    // Test 7.5: Pattern with let
    let pattern_let = stream[sum for (x, y) in pairs let sum = x + y];
    println("7.5: Pattern with let - stream[sum for (x, y) in pairs let sum = x + y]");

    println("");
    0
}

