// Comprehensive Refinement Types Test for Verum
// Testing all refinement syntax forms according to grammar spec
//
// Based on:
// - verum.ebnf Section 2.3
// - 05-syntax-grammar.md Section 2.3
// - Existing test_refinements/src/main.vr

// ============================================================================
// TEST 1: INLINE REFINEMENTS - Basic comparisons
// Grammar: inline_refinement = '{' , refinement_predicates , '}' ;
// Status: WORKING (verified in existing tests)
// ============================================================================

// Single comparison predicates
type Positive is Int{> 0};
type Negative is Int{< 0};
type NonNegative is Int{>= 0};
type NonPositive is Int{<= 0};
type NonZero is Int{!= 0};
type ExactlyZero is Int{== 0};

// Float refinements
type PositiveFloat is Float{> 0.0};
type NegativeFloat is Float{< 0.0};
type NormalizedFloat is Float{>= 0.0};

// ============================================================================
// TEST 2: MULTIPLE PREDICATES - Comma-separated
// Grammar: refinement_predicates = refinement_predicate , { ',' , refinement_predicate }
// ============================================================================

// Multiple inline predicates
type Probability is Float{>= 0.0, <= 1.0};
type ValidAge is Int{>= 0, <= 150};
type UnitInterval is Float{>= 0.0, <= 1.0};

// ============================================================================
// TEST 3: REFINED FUNCTION PARAMETERS
// ============================================================================

// Inline refinement in parameter
fn safe_divide(numerator: Int, denominator: Int{!= 0}) -> Int {
    numerator / denominator
}

// Multiple refined parameters
// fn calculate_discount(price: Float{> 0.0}, discount_pct: Float{>= 0.0, <= 100.0}) -> Float {
//     price * (1.0 - discount_pct / 100.0)
// }

// Type alias as parameter
fn square_positive(x: Positive) -> Positive {
    x * x
}

// ============================================================================
// TEST 4: REFINED FUNCTION RETURNS
// ============================================================================

// Inline refinement on return type
fn abs_value(x: Int) -> Int{>= 0} {
    if x < 0 {
        -x
    } else {
        x
    }
}

// Type alias as return
fn get_positive_value() -> Positive {
    42
}

// Both parameter and return refined
fn double_positive(x: Positive) -> Positive {
    x * 2
}

// ============================================================================
// TEST 5: DECLARATIVE REFINEMENTS WITH 'WHERE' - Named predicates
// Grammar: declarative_refinement = 'where' , refinement_method
//          refinement_method = predicate_name | lambda_expr
// ============================================================================

// Named predicate function
fn is_valid_email(s: Text) -> Bool {
    let has_at = s.contains("@");
    let has_dot = s.contains(".");
    let min_length = s.len() >= 5;
    has_at && has_dot && min_length
}

// Declarative refinement with named predicate
type Email is Text where is_valid_email;

// ============================================================================
// TEST 6: LAMBDA REFINEMENTS
// Grammar: lambda_expr = '|' , param_list_lambda , '|' , expression
// ============================================================================

// Lambda refinement with single parameter
type LambdaAge is Int where |x| x >= 0 && x <= 150;

// Lambda refinement for percentage
type LambdaPercentage is Float where |p| p >= 0.0 && p <= 100.0;

// ============================================================================
// TEST 7: SIGMA TYPE REFINEMENTS
// Grammar: sigma_type = identifier , ':' , type_expr , [ 'where' , expression ]
// ============================================================================

// Sigma type with explicit variable binding
type ValidText is s: Text where s.len() > 5;

// Sigma type with complex predicate
type BoundedInt is n: Int where n >= 0 && n <= 100;

// ============================================================================
// TEST 8: COMPLEX COMPOSITIONS
// ============================================================================

// Record with refined fields
// Note: Commented out to avoid potential type system issues in current version
// type User is {
//     name: Text,
//     age: ValidAge,
//     email: Email
// };

// Record with inline refined fields
type Point is {
    x: Float,
    y: Float
};

type PositivePoint is {
    x: Float{> 0.0},
    y: Float{> 0.0}
};

// Function using refined record
