// Test mutable variables

fn main() {
    let _ = print("=== Mutability Test ===");

    // Mutable variable
    let mut counter = 0.0;
    let _ = print(f"Initial: {counter}");

    counter = counter + 1.0;
    let _ = print(f"After +1: {counter}");

    counter = counter + 1.0;
    let _ = print(f"After +2: {counter}");

    // Mutable in loop
    let mut sum = 0.0;
    let mut i = 0.0;
    while i < 5.0 {
        sum = sum + i;
        i = i + 1.0;
    }
    let _ = print(f"Sum 0-4: {sum}");

    let _ = print("=== Done ===");
}
