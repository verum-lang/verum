// Test 18: Async with stream
async fn test_async_stream() -> Int {
    let base = simple_async().await;
    let nums = [1, 2, 3];
    let result = stream [x + base for x in nums];
    println("Async with stream completed");
    0
}

// Test 19: Complex async pattern - spawn async function
async fn async_task() -> Int {
    let x = simple_async().await;
    x + 10
}

async fn test_spawn_async() -> Int {
    let task = spawn async_task();
    println("Spawned async function");
    0
}

// Test 20: Async with multiple awaits and computation
async fn test_complex_async() -> Int {
    let a = simple_async().await;
    let b = async_computation(5, 10).await;
    let c = async_with_await().await;
    println("Complex async completed");
    a + b + c
}

// Main entry point to test all features
async fn main() {
    println("=== Async Features Test Suite ===");

    // Test 1-5: Async/Await
    println("\n--- Test 1: Simple async ---");
    let t1 = simple_async().await;
    println(t1);

    println("\n--- Test 2: Async with await ---");
    let t2 = async_with_await().await;
    println(t2);

    println("\n--- Test 3: Multiple awaits ---");
    let t3 = multiple_awaits().await;
    println(t3);

    println("\n--- Test 4: Async computation ---");
    let t4 = async_computation(5, 10).await;
    println(t4);

    println("\n--- Test 5: Chained async ---");
    let t5 = chained_async().await;
    println(t5);

    // Test 6-9: Spawn expressions
    println("\n--- Test 6: Spawn block ---");
    let t6 = test_spawn_block();
    println(t6);

    println("\n--- Test 7: Spawn function ---");
    let t7 = test_spawn_function();
    println(t7);

    println("\n--- Test 8: Spawn computation ---");
    let t8 = test_spawn_computation();
    println(t8);

    println("\n--- Test 9: Multiple spawns ---");
    let t9 = test_multiple_spawns();
    println(t9);

    // Test 10-14: Stream comprehensions
    println("\n--- Test 10: Stream basic ---");
    let t10 = test_stream_basic();
    println(t10);

    println("\n--- Test 11: Stream filter ---");
    let t11 = test_stream_filter();
    println(t11);

    println("\n--- Test 12: Stream map ---");
    let t12 = test_stream_map();
    println(t12);

    println("\n--- Test 13: Stream map filter ---");
    let t13 = test_stream_map_filter();
    println(t13);

    println("\n--- Test 14: Stream nested ---");
    let t14 = test_stream_nested();
    println(t14);

    // Test 15-17: Yield expressions - NOT YET IMPLEMENTED
    // println("\n--- Test 15: Yield basic ---");
    // let t15 = test_yield_basic();
    // println(t15);

    // println("\n--- Test 16: Yield loop ---");
    // let t16 = test_yield_loop();
    // println(t16);

    // println("\n--- Test 17: Yield conditional ---");
    // let t17 = test_yield_conditional();
    // println(t17);

    // Test 18-20: Advanced async patterns
    println("\n--- Test 18: Async with stream ---");
    let t18 = test_async_stream().await;
    println(t18);

    println("\n--- Test 19: Spawn async ---");
    let t19 = test_spawn_async().await;
    println(t19);

    println("\n--- Test 20: Complex async ---");
    let t20 = test_complex_async().await;
    println(t20);

    println("\n=== Test Suite Complete ===");
}
