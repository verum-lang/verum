// Edge Cases Test for Generics
// Tests specific edge cases and corner cases in generics implementation

type Maybe<T> is Some(T) | None;
type Result<T, E> is Ok(T) | Err(E);
type Pair<A, B> is { first: A, second: B };

// Edge Case 1: Self-referential generics with different type params
type Either<L, R> is
    | Left(L)
    | Right(R)
    | Both(L, R);

fn either_test() -> Either<Int, Text> {
    Both(42, "answer")
}

// Edge Case 2: Generic function with closure
fn apply_twice<T>(f: fn(T) -> T, x: T) -> T {
    f(f(x))
}

// Edge Case 3: Multiple instantiations of same generic in return type
fn pair_same<T>(x: T, y: T) -> Pair<T, T> {
    Pair { first: x, second: y }
}

// Edge Case 4: Generic with Int metadata (unit type causes issues)
type Container<T> is { value: T, metadata: Int };

fn with_metadata<T>(val: T) -> Container<T> {
    Container { value: val, metadata: 0 }
}

// Edge Case 5: Nested pattern matching - simplified
fn has_value<T>(m: Maybe<T>) -> Bool {
    match m {
        Some(_) => true,
        None => false
    }
}

// Edge Case 6: Generic function with multiple Maybe instantiations
fn maybe_to_result<T>(m: Maybe<T>, err: Text) -> Result<T, Text> {
    match m {
        Some(v) => Ok(v),
        None => Err(err)
    }
}

// Edge Case 7: Polymorphic recursion (same type param, recursive call)
fn repeat<T>(x: T, n: Int) -> Maybe<T> {
    if n <= 0 {
        None
    } else if n == 1 {
        Some(x)
    } else {
        Some(x)  // Simplified - would normally build list
    }
}

// Edge Case 8: Generic function that doesn't use all type params
fn ignore_second<A, B>(a: A, b: B) -> A {
    a
}

// Edge Case 9: Generic with Bool (simpler than unit type)
fn wrap_bool() -> Maybe<Bool> {
    Some(true)
}

fn main() {
    print("=== Generics Edge Cases Test ===");
    print("");

    // Test 1: Three-variant Either
    print("Test 1: Three-variant Either");
    let both = either_test();
    match both {
        Left(l) => print("Left: " + l.to_string()),
        Right(r) => print("Right: " + r),
        Both(l, r) => print("Both: " + l.to_string() + ", " + r)
    }
    print("");

    // Test 2: Apply twice with closure
    print("Test 2: Apply function twice");
    let double = |x| x * 2;
    let result = apply_twice(double, 5);
    print("apply_twice(double, 5) = " + result.to_string());
    print("");

    // Test 3: Same type twice
    print("Test 3: Generic with same type twice");
    let pair1 = pair_same(42, 99);
    let pair2 = pair_same("hello", "world");
    print("pair_same(42, 99): (" + pair1.first.to_string() + ", " + pair1.second.to_string() + ")");
    print("pair_same(\"hello\", \"world\"): (" + pair2.first + ", " + pair2.second + ")");
    print("");

    // Test 4: Generic with metadata
    print("Test 4: Generic with metadata");
    let container = with_metadata(100);
    print("Container with metadata created, value = " + container.value.to_string());
    print("");

    // Test 5: Has value check
    print("Test 5: Has value check");
    let val1 = Some(42);
    let val2: Maybe<Int> = None;

    print("has_value(Some(42)) = " + has_value(val1).to_string());
    print("has_value(None) = " + has_value(val2).to_string());
    print("");

    // Test 6: Maybe to Result conversion
    print("Test 6: Maybe to Result conversion");
    let some_val = Some(42);
    let none_val: Maybe<Int> = None;

    let result1 = maybe_to_result(some_val, "no value");
    let result2 = maybe_to_result(none_val, "no value");

    match result1 {
        Ok(v) => print("maybe_to_result(Some(42)) = Ok(" + v.to_string() + ")"),
        Err(e) => print("maybe_to_result(Some(42)) = Err(" + e + ")")
    }
    match result2 {
        Ok(v) => print("maybe_to_result(None) = Ok(" + v.to_string() + ")"),
        Err(e) => print("maybe_to_result(None) = Err(" + e + ")")
    }
    print("");

    // Test 7: Polymorphic recursion
    print("Test 7: Polymorphic recursion");
    let rep1 = repeat(42, 3);
    let rep2 = repeat("test", 0);
    match rep1 {
        Some(v) => print("repeat(42, 3) = Some(" + v.to_string() + ")"),
        None => print("repeat(42, 3) = None")
    }
    match rep2 {
        Some(v) => print("repeat(\"test\", 0) = Some(" + v + ")"),
        None => print("repeat(\"test\", 0) = None")
    }
    print("");

    // Test 8: Unused type parameter
    print("Test 8: Unused type parameter");
    let val1 = ignore_second(42, "ignored");
    let val2 = ignore_second("kept", 100);
    print("ignore_second(42, \"ignored\") = " + val1.to_string());
    print("ignore_second(\"kept\", 100) = " + val2);
    print("");

    // Test 9: Bool wrapping
    print("Test 9: Bool in Maybe");
    let bool_maybe = wrap_bool();
    match bool_maybe {
        Some(v) => print("wrap_bool() = Some(" + v.to_string() + ")"),
        None => print("wrap_bool() = None")
    }
    print("");

    print("=== All Edge Case Tests Complete ===");
}
