// Test: For loops with ranges
// Tests that for loops work with Range<Int> and RangeInclusive<Int>

fn test_range() -> Int {
    let mut sum = 0;
    for i in 1..5 {
        sum = sum + i;
    }
    sum  // Should be 1 + 2 + 3 + 4 = 10
}

fn test_range_inclusive() -> Int {
    let mut sum = 0;
    for i in 1..=5 {
        sum = sum + i;
    }
    sum  // Should be 1 + 2 + 3 + 4 + 5 = 15
}

fn test_range_zero_start() -> Int {
    let mut sum = 0;
    for i in 0..3 {
        sum = sum + i;
    }
    sum  // Should be 0 + 1 + 2 = 3
}

fn main() {
    let result1 = test_range();
    print(f"Range 1..5: {result1}");

    let result2 = test_range_inclusive();
    print(f"Range 1..=5: {result2}");

    let result3 = test_range_zero_start();
    print(f"Range 0..3: {result3}");
}
