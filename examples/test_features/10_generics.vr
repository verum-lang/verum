// Test generic types and functions
fn identity<T>(x: T) -> T {
    x
}

fn swap<A, B>(a: A, b: B) -> (B, A) {
    (b, a)
}

type Pair<T> is {
    first: T,
    second: T
};

fn make_pair<T>(a: T, b: T) -> Pair<T> {
    Pair { first: a, second: b }
}

fn main() {
    // Generic identity
    let x = identity(42)
    let s = identity("hello")
    print(f"Identity int: {x}")
    print(f"Identity text: {s}")
    
    // Generic swap
    let swapped = swap(1, "one")
    print(f"Swapped: {swapped}")
    
    // Generic record
    let int_pair = make_pair(10, 20)
    print(f"Pair: {int_pair.first}, {int_pair.second}")
}
