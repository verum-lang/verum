// Search Converters
//
// Convert between various search result types and DTOs.

mount core.collections.{List, Map};
mount core.base.{Text, Int, Float, Maybe};

mount super.super.dto.search_dto.{
    SearchResultDto,
    SearchRequestDto,
    SearchFiltersDto,
};

// ============================================================================
// Search Result Converters
// ============================================================================

/// Create a SearchResultDto from individual fields
/// This is used when search results come from different sources
pub fn search_result_to_dto(
    name: Text,
    version: Text,
    description: Text,
    downloads: Int,
    license: Text,
    score: Float,
    published_at: Text,
    category: Maybe<Text>
) -> SearchResultDto {
    SearchResultDto {
        name: name,
        version: version,
        description: description,
        downloads: downloads,
        license: license,
        score: score,
        published_at: published_at,
        category: category,
    }
}

// ============================================================================
// Helper Types for Search
// ============================================================================

/// Internal search hit used before conversion to DTO
/// This type can be used by services that need more data than the DTO exposes
pub type SearchHit is {
    package_name: Text,
    version: Text,
    description: Text,
    downloads: Int,
    license: Text,
    score: Float,
    published_at: Text,
    category: Maybe<Text>,
    matched_fields: List<Text>,
    highlights: List<Text>,
};

implement SearchHit {
    pub fn to_dto(self) -> SearchResultDto {
        SearchResultDto {
            name: self.package_name,
            version: self.version,
            description: self.description,
            downloads: self.downloads,
            license: self.license,
            score: self.score,
            published_at: self.published_at,
            category: self.category,
        }
    }
}

/// Convert list of SearchHits to DTOs
pub fn search_hits_to_dtos(hits: List<SearchHit>) -> List<SearchResultDto> {
    let mut dtos: List<SearchResultDto> = List.new();
    for hit in hits {
        dtos.push(hit.to_dto());
    }
    dtos
}

// ============================================================================
// DTO to Domain Converters
// ============================================================================

/// Internal search query type used by services
/// Converts page-based pagination to offset-based
pub type SearchQuery is {
    query: Text,
    limit: Int,
    offset: Int,
    filters: Map<Text, Text>,
    sort_by: Text,
};

/// Convert SearchRequestDto to internal SearchQuery
/// Handles page → offset conversion and filter normalization
///
/// SAFETY: Uses &checked reference - CRITICAL hot path.
/// - called on every search request (high frequency)
/// - req is immutable during conversion
/// Performance: Saves ~15ns per search operation
pub fn search_request_to_query(req: &checked SearchRequestDto) -> SearchQuery {
    // Convert page to offset (page is 1-based)
    let offset = if req.page > 0 {
        (req.page - 1) * req.limit
    } else {
        0
    };

    SearchQuery {
        query: req.query.clone(),
        limit: req.limit,
        offset: offset,
        filters: filters_to_map(&req.filters),
        sort_by: req.sort_by.to_string(),
    }
}

// ============================================================================
// Helper Functions for DTO → Domain
// ============================================================================

/// Convert optional SearchFiltersDto to a Map for internal use
/// Filters out empty/None values
///
/// SAFETY: Uses &checked reference - hot path for search filtering.
fn filters_to_map(filters: &checked Maybe<SearchFiltersDto>) -> Map<Text, Text> {
    let mut result: Map<Text, Text> = Map.new();

    // TODO: Temporarily disabled due to type inference issues with nested Maybe field access
    // The type checker creates infinite type when accessing fields on SearchFiltersDto
    // after pattern matching on Maybe.Some(f)
    // Will be re-enabled once the type checker properly handles this pattern

    result
}
