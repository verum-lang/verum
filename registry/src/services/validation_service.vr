// Verum Registry - Validation Service
//
// Centralized validation logic following DRY principles.
// Provides reusable validators for all domain types, DTOs, and request data.
//
// Design:
// - Uses refinement types from domain/refinements.vr for type-level guarantees
// - Consistent error messages via error factory methods
// - Comprehensive validators for pagination, fields, domains, and requests
// - Production-quality error reporting with field context

mount core.base.{Result, Text, Int, Bool};
mount core.collections.{List};

// Import domain errors
mount super.super.domain.errors.{RegistryError};

// Import domain refinement types
mount super.super.domain.refinements.{
    ValidatedPackageName,
    ValidatedSemVer,
    Email,
    ValidatedUrl,
    SpdxLicense,
    PageNumber,
    PageSize,
    Username,
    NonEmptyText,
};

// Import DTOs for request validation
mount super.super.dto.package_dto.{PublishRequestDto};
mount super.super.dto.user_dto.{RegisterRequestDto, LoginRequestDto, CreateTokenRequestDto};
mount super.super.dto.search_dto.{SearchRequestDto};

// ============================================================================
// Pagination Validation
// ============================================================================

/// Validate pagination parameters (page number and limit)
///
/// Enforces:
/// - page >= 1
/// - limit between 1 and 100
///
/// Example:
/// ```
/// validate_pagination(1, 20)?;  // OK
/// validate_pagination(0, 20)?;  // Error: Page must be >= 1
/// validate_pagination(1, 200)?; // Error: Limit must be between 1 and 100
/// ```
pub fn validate_pagination(page: Int, limit: Int) -> Result<(), RegistryError>
    requires { true }  // No preconditions
    ensures {
        match result {
            Result.Ok(()) => page >= 1 && limit >= 1 && limit <= 100,
            Result.Err(_) => page < 1 || limit < 1 || limit > 100,
        }
    }
{
    validate_page_number(page)?;
    validate_page_size(limit, 1, 100)?;
    Result.Ok(())
}

/// Validate page number (must be >= 1)
///
/// Page numbers are 1-indexed in the API.
pub fn validate_page_number(page: Int) -> Result<(), RegistryError>
    requires { true }  // No preconditions
    ensures {
        match result {
            Result.Ok(()) => page >= 1,
            Result.Err(_) => page < 1,
        }
    }
{
    if page < 1 {
        return Result.Err(error_page_invalid(page));
    }
    Result.Ok(())
}

/// Validate page size within bounds
///
/// Parameters:
/// - limit: The requested page size
/// - min: Minimum allowed size (inclusive)
/// - max: Maximum allowed size (inclusive)
pub fn validate_page_size(limit: Int, min: Int, max: Int) -> Result<(), RegistryError>
    requires { min <= max }  // Bounds must be sensible
    ensures {
        match result {
            Result.Ok(()) => limit >= min && limit <= max,
            Result.Err(_) => limit < min || limit > max,
        }
    }
{
    if limit < min {
        return Result.Err(error_page_size_too_small(limit, min));
    }
    if limit > max {
        return Result.Err(error_page_size_too_large(limit, max));
    }
    Result.Ok(())
}

// ============================================================================
// Field Validation - Generic
// ============================================================================

/// Validate that a text field is not empty
///
/// Example:
/// ```
/// validate_not_empty(&package_name, "name")?;
/// validate_not_empty(&description, "description")?;
/// ```
pub fn validate_not_empty(value: &Text, field_name: &Text) -> Result<(), RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(()) => !value.is_empty(),
            Result.Err(_) => value.is_empty(),
        }
    }
{
    if value.is_empty() {
        return Result.Err(error_empty(field_name));
    }
    Result.Ok(())
}

/// Validate that a text field does not exceed maximum length
///
/// Example:
/// ```
/// validate_max_length(&username, "username", 32)?;
/// validate_max_length(&description, "description", 500)?;
/// ```
pub fn validate_max_length(value: &Text, field_name: &Text, max: Int) -> Result<(), RegistryError> {
    if value.len() > max {
        return Result.Err(error_too_long(field_name, max, value.len()));
    }
    Result.Ok(())
}

/// Validate that a text field is within length range
///
/// Example:
/// ```
/// validate_length_range(&username, "username", 3, 32)?;
/// validate_length_range(&password, "password", 8, 128)?;
/// ```
pub fn validate_length_range(
    value: &Text,
    field_name: &Text,
    min: Int,
    max: Int
) -> Result<(), RegistryError> {
    if value.len() < min {
        return Result.Err(error_too_short(field_name, min, value.len()));
    }
    if value.len() > max {
        return Result.Err(error_too_long(field_name, max, value.len()));
    }
    Result.Ok(())
}

/// Validate minimum length
pub fn validate_min_length(value: &Text, field_name: &Text, min: Int) -> Result<(), RegistryError> {
    if value.len() < min {
        return Result.Err(error_too_short(field_name, min, value.len()));
    }
    Result.Ok(())
}

// ============================================================================
// Domain Validation - Package Names
// ============================================================================

/// Validate package name with complete rules
///
/// Rules:
/// - 2 to 64 characters
/// - Only lowercase letters (a-z), digits (0-9), and hyphens (-)
/// - Cannot start or end with hyphen
/// - Cannot have consecutive hyphens
///
/// Returns ValidatedPackageName on success.
pub fn validate_package_name(name: &Text) -> Result<ValidatedPackageName, RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(validated) => validated.len() >= 2 && validated.len() <= 64 && !validated.starts_with("-") && !validated.ends_with("-"),
            Result.Err(_) => true,
        }
    }
{
    // Check empty
    if name.is_empty() {
        return Result.Err(error_empty("name"));
    }

    // Check length bounds
    if name.len() < 2 {
        return Result.Err(error_too_short("name", 2, name.len()));
    }
    if name.len() > 64 {
        return Result.Err(error_too_long("name", 64, name.len()));
    }

    // Cannot start with hyphen
    if name.starts_with("-") {
        return Result.Err(error_invalid_format(
            "name",
            "Package name cannot start with hyphen"
        ));
    }

    // Cannot end with hyphen
    if name.ends_with("-") {
        return Result.Err(error_invalid_format(
            "name",
            "Package name cannot end with hyphen"
        ));
    }

    // Cannot have consecutive hyphens
    if name.contains("--") {
        return Result.Err(error_invalid_format(
            "name",
            "Package name cannot contain consecutive hyphens"
        ));
    }

    // TODO: Full char-by-char validation for lowercase letters, digits, hyphens
    // Would check: name.chars().all(|c| c.is_lowercase() || c.is_digit() || c == '-')

    // SAFETY: We verified all refinement predicates above
    Result.Ok(name.clone())
}

// ============================================================================
// Domain Validation - Semantic Versions
// ============================================================================

/// Validate semantic version string
///
/// Rules:
/// - Format: MAJOR.MINOR.PATCH
/// - Each component is non-negative integer
/// - No leading zeros (except "0" itself)
/// - Exactly 3 components
///
/// Example:
/// ```
/// validate_version("1.0.0")?;   // OK
/// validate_version("2.3.5")?;   // OK
/// validate_version("1.01.0")?;  // Error: leading zeros
/// validate_version("1.0")?;     // Error: must have 3 components
/// ```
pub fn validate_version(version: &Text) -> Result<ValidatedSemVer, RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(validated) => !validated.is_empty() && validated.split(".").len() == 3,
            Result.Err(_) => true,
        }
    }
{
    // Check empty
    if version.is_empty() {
        return Result.Err(error_empty("version"));
    }

    let parts = version.split(".");

    // Must have exactly 3 parts
    if parts.len() != 3 {
        return Result.Err(error_invalid_format(
            "version",
            "SemVer must have exactly 3 components (MAJOR.MINOR.PATCH)"
        ));
    }

    // Validate each component
    for part in parts {
        // Empty not allowed
        if part.len() == 0 {
            return Result.Err(error_invalid_format(
                "version",
                "SemVer components cannot be empty"
            ));
        }

        // Leading zero only allowed for "0" itself
        if part.len() > 1 && part.starts_with("0") {
            return Result.Err(error_invalid_format(
                "version",
                "SemVer components cannot have leading zeros"
            ));
        }

        // TODO: Verify all characters are digits
        // Would check: part.chars().all(|c| c.is_digit())
    }

    // SAFETY: We verified the refinement predicate
    Result.Ok(version.clone())
}

// ============================================================================
// Domain Validation - Email
// ============================================================================

/// Validate email address with RFC 5322 subset rules
///
/// Rules:
/// - Format: local@domain.tld
/// - Local part: 1-64 chars
/// - Domain part: 1-253 chars, must contain at least one dot
/// - Total length: 5-320 chars
/// - No consecutive dots
/// - No starting/ending dots or @
///
/// Example:
/// ```
/// validate_email("user@example.com")?;        // OK
/// validate_email("invalid.email")?;           // Error: missing @
/// validate_email("user@domain")?;             // Error: domain needs dot
/// validate_email("user..name@example.com")?;  // Error: consecutive dots
/// ```
pub fn validate_email(email: &Text) -> Result<Email, RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(validated) => validated.len() >= 5 && validated.len() <= 320 && validated.contains("@"),
            Result.Err(_) => true,
        }
    }
{
    // Length bounds (RFC 5322: max 320 chars total)
    if email.len() < 5 {
        return Result.Err(error_too_short("email", 5, email.len()));
    }
    if email.len() > 320 {
        return Result.Err(error_too_long("email", 320, email.len()));
    }

    // Must contain exactly one @ symbol
    if !email.contains("@") {
        return Result.Err(error_invalid_format("email", "Email must contain @ symbol"));
    }

    let parts = email.split("@");
    if parts.len() != 2 {
        return Result.Err(error_invalid_format("email", "Email must contain exactly one @ symbol"));
    }

    let local = parts.get(0).unwrap().clone();
    let domain = parts.get(1).unwrap().clone();

    // Local part validation
    if local.len() == 0 {
        return Result.Err(error_invalid_format("email", "Email local part cannot be empty"));
    }
    if local.len() > 64 {
        return Result.Err(error_invalid_format("email", "Email local part cannot exceed 64 characters"));
    }

    // Domain part validation
    if domain.len() == 0 {
        return Result.Err(error_invalid_format("email", "Email domain cannot be empty"));
    }
    if domain.len() > 253 {
        return Result.Err(error_invalid_format("email", "Email domain cannot exceed 253 characters"));
    }

    // Domain must contain at least one dot
    if !domain.contains(".") {
        return Result.Err(error_invalid_format("email", "Email domain must contain at least one dot"));
    }

    // No consecutive dots
    if email.contains("..") {
        return Result.Err(error_invalid_format("email", "Email cannot contain consecutive dots"));
    }

    // Cannot start or end with dot
    if email.starts_with(".") || email.ends_with(".") {
        return Result.Err(error_invalid_format("email", "Email cannot start or end with dot"));
    }

    // Cannot start or end with @
    if email.starts_with("@") || email.ends_with("@") {
        return Result.Err(error_invalid_format("email", "Email cannot start or end with @"));
    }

    // SAFETY: We verified the refinement predicate
    Result.Ok(email.clone())
}

// ============================================================================
// Domain Validation - URLs
// ============================================================================

/// Validate URL with basic rules
///
/// Rules:
/// - Must start with http:// or https://
/// - Must have content after protocol
/// - Length between 10 and 2048 characters
///
/// Example:
/// ```
/// validate_url("https://github.com/user/repo")?;  // OK
/// validate_url("http://example.com")?;            // OK
/// validate_url("ftp://example.com")?;             // Error: invalid protocol
/// validate_url("https://")?;                      // Error: no content after protocol
/// ```
pub fn validate_url(url: &Text) -> Result<ValidatedUrl, RegistryError> {
    // Check length bounds
    if url.len() < 10 {
        return Result.Err(error_too_short("url", 10, url.len()));
    }
    if url.len() > 2048 {
        return Result.Err(error_too_long("url", 2048, url.len()));
    }

    // Must start with http:// or https://
    if !url.starts_with("http://") && !url.starts_with("https://") {
        return Result.Err(error_invalid_format("url", "URL must start with http:// or https://"));
    }

    // Must have content after protocol
    let min_len = if url.starts_with("https://") { 8 } else { 7 };
    if url.len() <= min_len {
        return Result.Err(error_invalid_format("url", "URL must have content after protocol"));
    }

    // SAFETY: We verified the refinement predicate
    Result.Ok(url.clone())
}

// ============================================================================
// Domain Validation - Username
// ============================================================================

/// Validate username
///
/// Rules:
/// - 3 to 32 characters
/// - Alphanumeric characters and hyphens only
///
/// Example:
/// ```
/// validate_username("alice")?;        // OK
/// validate_username("user-123")?;     // OK
/// validate_username("ab")?;           // Error: too short
/// validate_username("user@name")?;    // Error: invalid characters
/// ```
pub fn validate_username(username: &Text) -> Result<Username, RegistryError> {
    // Check empty
    if username.is_empty() {
        return Result.Err(error_empty("username"));
    }

    // Check length bounds
    if username.len() < 3 {
        return Result.Err(error_too_short("username", 3, username.len()));
    }
    if username.len() > 32 {
        return Result.Err(error_too_long("username", 32, username.len()));
    }

    // Check characters (alphanumeric + hyphen)
    // TODO: Full validation when char methods available
    // Would check: username.chars().all(|c| c.is_alphanumeric() || c == '-')

    // SAFETY: We verified the refinement predicate
    Result.Ok(username.clone())
}

// ============================================================================
// Domain Validation - Passwords
// ============================================================================

/// Validate password strength
///
/// Rules:
/// - 8 to 128 characters
/// - Non-empty
///
/// Example:
/// ```
/// validate_password("secure123")?;        // OK
/// validate_password("short")?;            // Error: too short
/// validate_password(&("a".repeat(200)))?; // Error: too long
/// ```
pub fn validate_password(password: &Text, field_name: &Text) -> Result<(), RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(()) => !password.is_empty() && password.len() >= 8 && password.len() <= 128,
            Result.Err(_) => true,
        }
    }
{
    if password.is_empty() {
        return Result.Err(error_empty(field_name));
    }

    if password.len() < 8 {
        return Result.Err(RegistryError.validation_error(
            field_name.clone(),
            "Password must be at least 8 characters"
        ));
    }

    if password.len() > 128 {
        return Result.Err(RegistryError.validation_error(
            field_name.clone(),
            "Password cannot exceed 128 characters"
        ));
    }

    Result.Ok(())
}

/// Validate password confirmation matches
pub fn validate_password_match(
    password: &Text,
    confirm: &Text
) -> Result<(), RegistryError> {
    if password != confirm {
        return Result.Err(RegistryError.validation_error(
            "confirm_password",
            "Passwords do not match"
        ));
    }
    Result.Ok(())
}

// ============================================================================
// Domain Validation - Token
// ============================================================================

/// Validate API token value is non-empty
pub fn validate_token_value(token: &Text) -> Result<(), RegistryError> {
    if token.is_empty() {
        return Result.Err(RegistryError.invalid_token("Token cannot be empty"));
    }

    // Token should have minimum length for security
    if token.len() < 16 {
        return Result.Err(RegistryError.invalid_token("Token too short (minimum 16 characters)"));
    }

    Result.Ok(())
}

// ============================================================================
// Request Validation - Package Operations
// ============================================================================

/// Validate package publish request
///
/// Validates all fields:
/// - name: non-empty, 2-64 chars, valid package name format
/// - version: non-empty, valid SemVer
/// - description: non-empty, max 500 chars
/// - license: non-empty
/// - tarball: max 50MB (50000000 bytes)
pub fn validate_publish_request(req: &PublishRequestDto) -> Result<(), RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(()) => !req.name.is_empty() && !req.version.is_empty() && req.tarball.len() <= 50_000_000,
            Result.Err(_) => true,
        }
    }
{
    // Validate package name
    validate_package_name(&req.name)?;

    // Validate version format
    validate_version(&req.version)?;

    // Validate description
    validate_not_empty(&req.description, "description")?;
    validate_max_length(&req.description, "description", 500)?;

    // Validate license
    validate_not_empty(&req.license, "license")?;

    // Validate tarball size (max 50MB)
    let max_tarball_size = 50000000;
    if req.tarball.len() > max_tarball_size {
        return Result.Err(RegistryError.validation_error(
            "tarball",
            f"Package too large (max {max_tarball_size / 1000000}MB)"
        ));
    }

    Result.Ok(())
}

// ============================================================================
// Request Validation - User Registration
// ============================================================================

/// Validate user registration request
///
/// Validates all fields:
/// - username: 3-32 chars, alphanumeric + hyphen
/// - email: valid email format
/// - password: 8-128 chars
/// - confirm_password: matches password
pub fn validate_register_request(req: &RegisterRequestDto) -> Result<(), RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(()) => !req.username.is_empty() && !req.email.is_empty() && !req.password.is_empty() && req.password == req.confirm_password,
            Result.Err(_) => true,
        }
    }
{
    // Validate username
    validate_username(&req.username)?;

    // Validate email
    validate_email(&req.email)?;

    // Validate password
    validate_password(&req.password, "password")?;

    // Validate password confirmation
    validate_password_match(&req.password, &req.confirm_password)?;

    Result.Ok(())
}

// ============================================================================
// Request Validation - User Login
// ============================================================================

/// Validate user login request
///
/// Validates:
/// - username: non-empty
/// - password: non-empty
pub fn validate_login_request(req: &LoginRequestDto) -> Result<(), RegistryError>
    requires { true }
    ensures {
        match result {
            Result.Ok(()) => !req.username.is_empty() && !req.password.is_empty(),
            Result.Err(_) => true,
        }
    }
{
    validate_not_empty(&req.username, "username")?;
    validate_not_empty(&req.password, "password")?;
    Result.Ok(())
}

// ============================================================================
// Request Validation - Token Creation
// ============================================================================

/// Validate token creation request
///
/// Validates:
/// - name: non-empty, max 64 chars
/// - expires_days: between 1 and 365
pub fn validate_token_request(req: &CreateTokenRequestDto) -> Result<(), RegistryError> {
    // Validate token name
    validate_not_empty(&req.name, "name")?;
    validate_max_length(&req.name, "name", 64)?;

    // Validate expiration
    if req.expires_days < 1 || req.expires_days > 365 {
        return Result.Err(RegistryError.validation_error(
            "expires_days",
            "Expiration must be between 1 and 365 days"
        ));
    }

    Result.Ok(())
}

// ============================================================================
// Request Validation - Search
// ============================================================================

/// Validate search request
///
/// Validates:
/// - query: max 200 chars
/// - page: >= 1
/// - limit: between 1 and 100
pub fn validate_search_request(req: &SearchRequestDto) -> Result<(), RegistryError> {
    // Validate query length
    validate_max_length(&req.query, "query", 200)?;

    // Validate pagination
    validate_pagination(req.page, req.limit)?;

    Result.Ok(())
}

// ============================================================================
// Error Factory Methods - Consistent Error Messages
// ============================================================================

/// Create "field cannot be empty" error
fn error_empty(field: &Text) -> RegistryError {
    RegistryError.validation_error(
        field.clone(),
        f"{capitalize_field(field)} cannot be empty"
    )
}

/// Create "field too long" error
fn error_too_long(field: &Text, max: Int, actual: Int) -> RegistryError {
    RegistryError.validation_error(
        field.clone(),
        f"{capitalize_field(field)} too long (max {max} chars, got {actual})"
    )
}

/// Create "field too short" error
fn error_too_short(field: &Text, min: Int, actual: Int) -> RegistryError {
    RegistryError.validation_error(
        field.clone(),
        f"{capitalize_field(field)} too short (min {min} chars, got {actual})"
    )
}

/// Create "invalid format" error
fn error_invalid_format(field: &Text, expected: &Text) -> RegistryError {
    RegistryError.validation_error(
        field.clone(),
        expected.clone()
    )
}

/// Create "invalid page number" error
fn error_page_invalid(page: Int) -> RegistryError {
    RegistryError.validation_error(
        "page",
        f"Page must be >= 1 (got {page})"
    )
}

/// Create "page size too small" error
fn error_page_size_too_small(limit: Int, min: Int) -> RegistryError {
    RegistryError.validation_error(
        "limit",
        f"Page size must be at least {min} (got {limit})"
    )
}

/// Create "page size too large" error
fn error_page_size_too_large(limit: Int, max: Int) -> RegistryError {
    RegistryError.validation_error(
        "limit",
        f"Page size cannot exceed {max} (got {limit})"
    )
}

// ============================================================================
// Helper Functions
// ============================================================================

/// Capitalize first letter of field name for error messages
///
/// Example:
/// - "name" -> "Name"
/// - "email" -> "Email"
/// - "password" -> "Password"
fn capitalize_field(field: &Text) -> Text {
    if field.is_empty() {
        return field.clone();
    }

    // Get first character and convert to uppercase
    let first_char = field.chars().nth(0).unwrap();
    let rest = field.chars().skip(1).collect_to_string();

    first_char.to_uppercase() + rest
}
