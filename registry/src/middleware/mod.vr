// Verum Registry - Middleware Module
//
// Composable middleware layer for request/response processing.
// Follows SOLID principles with context-based dependency injection.
//
// Architecture:
// - All middleware are async and composable
// - Use context protocols for dependencies
// - Return Result<T, E> for error handling
// - Support middleware chaining via functional composition

module auth;
module rate_limit;
module logging;
module error_handler;

// Re-export middleware types and functions
pub import .auth.{
    AuthMiddleware,
    AuthConfig,
    ValidatedToken,
    create_auth_middleware,
    validate_request_token,
};

pub import .rate_limit.{
    RateLimiter,
    RateLimitConfig,
    TokenBucket,
    RateLimitExceeded,
    create_rate_limiter,
    check_rate_limit,
};

pub import .logging.{
    RequestLogger,
    LogConfig,
    RequestMetadata,
    ResponseMetadata,
    create_request_logger,
    log_request,
    log_response,
};

pub import .error_handler.{
    ErrorHandler,
    ErrorResponse,
    ErrorContext,
    create_error_handler,
    handle_error,
    recover_from_error,
};
