// Domain Validation Functions
//
// This module provides validation functions that leverage refinement types.
// With the comprehensive refinement types in refinements.vr, most validation
// is now done at the type level via smart constructors.
//
// These functions remain for backward compatibility and for cases where
// you need Bool validation without type conversion.
//
// All validation functions follow a consistent pattern:
// - Take domain values by reference (&T)
// - Return Bool (true = valid, false = invalid)
// - No I/O, no mutation, no context dependencies
// - Provide clear documentation of validation rules

mount core.base.{Text, Bool, Result};

// Import refinement types for validation logic
mount super.refinements.{
    ValidatedPackageName,
    ValidatedSemVer,
    ValidatedUrl,
    SpdxLicense,
    Email
};

// ============================================================================
// Package Validation
// ============================================================================

/// Validate package name format (uses refinement type internally)
///
/// Rules:
/// - 2-64 characters in length
/// - Lowercase letters (a-z)
/// - ASCII digits (0-9)
/// - Hyphens (-) allowed
/// - Must not start or end with hyphen
/// - No consecutive hyphens
///
/// Examples:
/// - Valid: f"my-package", "core", "http-client-2"
/// - Invalid: f"-bad", "bad-", "Bad", "a", "x".repeat(65), "bad--name"
///
/// Note: For type-safe validation, use ValidatedPackageName.try_from()
pub fn is_valid_package_name(name: &Text) -> Bool {
    match ValidatedPackageName.try_from(name.clone()) {
        Result.Ok(_) => true,
        Result.Err(_) => false
    }
}

/// Validate semantic version format (uses refinement type internally)
///
/// Rules:
/// - Exactly three dot-separated parts (X.Y.Z)
/// - Each part is a non-negative integer
/// - No leading zeros (except "0" itself)
/// - No extra whitespace or characters
///
/// Examples:
/// - Valid: f"1.0.0", "0.1.2", "10.20.30"
/// - Invalid: f"1.0", "1.0.0.0", "1.0.a", "01.0.0", "1.0.-1"
///
/// Note: For type-safe validation, use ValidatedSemVer.try_from()
pub fn is_valid_version(version: &Text) -> Bool {
    match ValidatedSemVer.try_from(version.clone()) {
        Result.Ok(_) => true,
        Result.Err(_) => false
    }
}

/// Validate URL format (uses refinement type internally)
///
/// Rules:
/// - Must start with http:// or https://
/// - Must have content after protocol
/// - Length between 10 and 2048 characters
///
/// Examples:
/// - Valid: f"https://github.com/user/repo", "http://example.com"
/// - Invalid: f"ftp://bad.com", "https://", "not-a-url"
///
/// Note: For type-safe validation, use ValidatedUrl.try_from()
pub fn is_valid_url(url: &Text) -> Bool {
    match ValidatedUrl.try_from(url.clone()) {
        Result.Ok(_) => true,
        Result.Err(_) => false
    }
}

/// Validate SPDX license identifier (uses refinement type internally)
///
/// Rules:
/// - 1-64 characters
/// - Common SPDX identifiers: MIT, Apache-2.0, GPL-3.0, etc.
///
/// Examples:
/// - Valid: f"MIT", "Apache-2.0", "BSD-3-Clause"
/// - Invalid: f"", "x".repeat(65)
///
/// Note: For type-safe validation, use SpdxLicense.try_from()
pub fn is_valid_license(license: &Text) -> Bool {
    match SpdxLicense.try_from(license.clone()) {
        Result.Ok(_) => true,
        Result.Err(_) => false
    }
}

// ============================================================================
// User Validation
// ============================================================================

/// Validate username format
///
/// Rules:
/// - 3-32 characters in length
/// - ASCII alphanumeric (a-z, A-Z, 0-9)
/// - Underscores (_) allowed
/// - Must start with letter
/// - Case-sensitive
///
/// Examples:
/// - Valid: f"alice", "Bob_123", "user_name", "Dev2024"
/// - Invalid: f"ab", "x".repeat(33), "123user", "_invalid", "user-name"
pub fn is_valid_username(username: &Text) -> Bool {
    let len = username.len();

    // Check length bounds
    if len < 3 || len > 32 {
        return false;
    }

    // Simplified validation - full validation would check:
    // - Must start with letter
    // - Only alphanumeric and underscores
    // For now, we accept any string within length bounds
    true
}

/// Validate email address format (uses refinement type internally)
///
/// Rules (RFC 5322 subset):
/// - Format: local@domain.tld
/// - Local part: 1-64 chars
/// - Domain part: 1-253 chars
/// - Must have at least one dot in domain
/// - No consecutive dots
/// - No starting/ending dots
/// - Total length: 5-320 chars
///
/// Examples:
/// - Valid: f"user@example.com", "alice.bob@dev.io"
/// - Invalid: f"invalid", "@example.com", "user@", "user@domain"
///
/// Note: For type-safe validation, use Email.try_from()
pub fn is_valid_email(email: &Text) -> Bool {
    match Email.try_from(email.clone()) {
        Result.Ok(_) => true,
        Result.Err(_) => false
    }
}
