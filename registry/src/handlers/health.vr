/// Check message queue health
async fn check_queue_health() -> ComponentHealthDto
    using [Queue]
{
    let timer = Timer.start();
    let result = Queue.ping().await;
    let elapsed = timer.stop();

    if result.is_ok() {
        ComponentHealthDto {
            name: "queue",
