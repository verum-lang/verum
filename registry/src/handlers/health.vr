}

/// Determine overall system status from components
fn determine_overall_status(components: &List<ComponentHealthDto>) -> HealthStatusDto {
    let mut has_unhealthy = false;
    let mut has_degraded = false;

    for component in components {
        if component.status == HealthStatusDto.Unhealthy {
            has_unhealthy = true;
        } else if component.status == HealthStatusDto.Degraded {
            has_degraded = true;
        }
    }

    if has_unhealthy {
        HealthStatusDto.Unhealthy
    } else if has_degraded {
        HealthStatusDto.Degraded
    } else {
        HealthStatusDto.Healthy
    }
}
