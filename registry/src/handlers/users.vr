// Verum Registry - User Authentication Handlers
//
// HTTP handlers for user registration, login, and token management

mount core.collections.{List, Map};
mount core.base.{Result, Maybe, Text};
mount core.time.unix_timestamp;

// Import context protocols
mount super.super.contexts.{Database, Auth};
mount super.super.domain.errors.{RegistryError};
mount super.super.domain.user.{User, UserRole, ApiToken};

// Import DTOs
mount super.super.dto.user_dto.{
    UserDto,
    UserProfileDto,
    TokenDto,
    TokenWithValueDto,
    LoginRequestDto,
    LoginResponseDto,
    RegisterRequestDto,
    RegisterResponseDto,
    CreateTokenRequestDto,
    TokenResponseDto,
    DeleteAccountRequestDto,
    DeleteAccountResponseDto,
    PublicUserProfileDto,
};

// Import converters
mount super.super.converters.user_converter.{
    user_to_dto,
    user_to_profile_dto,
    token_to_dto,
    token_to_dto_with_value,
    auth_user_to_profile_dto,
    tokens_to_dtos,
    register_request_to_user,
};

// Import validation service
mount super.super.services.validation_service.{
    validate_login_request,
    validate_register_request,
    validate_token_request,
    validate_email,
};

// Import concurrency utilities
mount super.super.services.concurrency_service.{join2, join3, join4};

// Note: Crypto and Email contexts are not yet implemented, so simplified versions are used

// ============================================================================
// SQL Parameter Helpers (for parameterized queries - SQL injection safe)
// ============================================================================

/// Create a list with 1 SQL parameter
fn sql_params_1(p1: Text) -> List<Text> {
    let mut params = List.new();
    params.push(p1);
    params
}

/// Create a list with 2 SQL parameters
fn sql_params_2(p1: Text, p2: Text) -> List<Text> {
    let mut params = List.new();
    params.push(p1);
    params.push(p2);
    params
}

/// Create a list with 4 SQL parameters
fn sql_params_4(p1: Text, p2: Text, p3: Text, p4: Text) -> List<Text> {
    let mut params = List.new();
    params.push(p1);
    params.push(p2);
    params.push(p3);
    params.push(p4);
    params
}

// ============================================================================
// HTTP Handlers
// ============================================================================

/// Authenticate user and create session token
///
/// POST /api/v1/users/login
pub async fn login_user(req: LoginRequestDto) -> Result<LoginResponseDto, RegistryError>
    using [Database]
    requires {
        !req.username.is_empty(),
        !req.password.is_empty(),
    }
    ensures {
        match result {
            Result.Ok(resp) => !resp.token.is_empty() && resp.expires_in > 0,
            Result.Err(RegistryError.InvalidCredentials) => true,
            Result.Err(RegistryError.UserNotFound { .. }) => true,
            Result.Err(RegistryError.ValidationError { .. }) => true,
            _ => true,
        }
    }
{
    // Validate request using centralized validation service
    validate_login_request(&req)?;

    // Find user by username (simplified - in production would verify password hash)
    let row = Database.fetch_one_with(
        "SELECT * FROM users WHERE username = $1",
        sql_params_1(req.username.clone())
    ).await?;

    // Construct domain user from database row
    // Parse user_id from database result
    let user_id = match row.get("id") {
        Maybe.Some(id_str) => parse_id_from_text(&id_str),
        Maybe.None => {
            return Result.Err(RegistryError.internal_error("User record missing id field"));
        }
    };

    let username = match row.get("username") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "",
    };
    let email = match row.get("email") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "",
    };
    let role_str = match row.get("role") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "regular",
    };

    let user = User {
        id: user_id,
        username: username,
        email: email,
        role: UserRole.from_string(role_str),
        created_at: unix_timestamp(),
        api_tokens: List.new(),
        owned_packages: List.new(),
        is_active: true,
    };

    // Generate a simple token (in production would use proper JWT)
    let token_value = "token_" + f"{user.id}";

    // Convert to DTO
    let user_profile = user_to_profile_dto(&user);

    Result.Ok(LoginResponseDto.success(token_value, user_profile, 30 * 24 * 60 * 60))
}

/// Register a new user account
///
/// POST /api/v1/users/register
pub async fn register_user(req: RegisterRequestDto) -> Result<RegisterResponseDto, RegistryError>
    using [Database]
    requires {
        !req.username.is_empty(),
        req.username.len() >= 3 && req.username.len() <= 32,
        !req.email.is_empty(),
        req.email.contains("@"),
        !req.password.is_empty(),
        req.password.len() >= 8 && req.password.len() <= 128,
    }
    ensures {
        match result {
            Result.Ok(resp) => !resp.user.id.is_empty(),
            Result.Err(RegistryError.UserAlreadyExists { .. }) => true,
            Result.Err(RegistryError.ValidationError { .. }) => true,
            _ => true,
        }
    }
{
    // Validate registration request using centralized validation service
    validate_register_request(&req)?;

    // Check if username already exists
    let existing_username = Database.fetch_optional_with(
        "SELECT id FROM users WHERE username = $1",
        sql_params_1(req.username.clone())
    ).await?;
    match existing_username {
        Maybe.Some(_) => {
            return Result.Err(RegistryError.validation_error("username", "Username already taken"));
        },
        Maybe.None => {},
    }

    // Check if email already exists
    let existing_email = Database.fetch_optional_with(
        "SELECT id FROM users WHERE email = $1",
        sql_params_1(req.email.clone())
    ).await?;
    match existing_email {
        Maybe.Some(_) => {
            return Result.Err(RegistryError.validation_error("email", "Email already registered"));
        },
        Maybe.None => {},
    }

    // Generate user ID
    let user_id = generate_user_id();

    // Create domain user using converter
    let user = register_request_to_user(&req, user_id, 0);

    // Save user to database (simplified - in production would hash password)
    Database.execute_with(
        "INSERT INTO users (id, username, email, role) VALUES ($1, $2, $3, $4)",
        sql_params_4(f"{user.id}", req.username.clone(), req.email.clone(), "regular")
    ).await?;

    // Convert to DTO
    let user_dto = user_to_dto(&user);

    Result.Ok(RegisterResponseDto.success(user_dto))
}

/// Verify authentication token
///
/// POST /api/v1/users/verify-token
pub async fn verify_token(token: Text) -> Result<TokenResponseDto, RegistryError>
    using [Auth]
{
    if token.is_empty() {
        return Result.Ok(TokenResponseDto.invalid());
    }

    // Verify token signature and expiration
    let verification = Auth.verify_token(token.clone()).await;

    if verification.is_ok() {
        let auth_user = verification.unwrap();
        // Convert AuthUser to UserProfileDto
        let user_profile = auth_user_to_profile_dto(&auth_user);

        Result.Ok(TokenResponseDto.valid(user_profile, Maybe.None))
    } else {
        Result.Ok(TokenResponseDto.invalid())
    }
}

/// Create a new API token
///
/// POST /api/v1/users/tokens
pub async fn create_token(
    req: CreateTokenRequestDto,
    auth_token: Text
) -> Result<TokenWithValueDto, RegistryError>
    using [Database, Auth]
{
    // Verify user authentication
    let auth_user = match Auth.verify_token(auth_token).await {
        Result.Ok(u) => u,
        Result.Err(_) => return Result.Err(RegistryError.invalid_token("Invalid or expired token")),
    };

    // Validate token request using centralized validation service
    validate_token_request(&req)?;

    // Generate token ID and value
    let token_id = generate_token_id();
    let expires_seconds = req.expires_days * 24 * 60 * 60;
    let token_value = "api_" + auth_user.id.clone() + "_" + req.name.clone();

    // Create domain ApiToken
    let api_token = ApiToken {
        id: token_id,
        name: req.name.clone(),
        token: token_value.clone(),
        created_at: unix_timestamp(),
        expires_at: expires_seconds,  // Would be timestamp in production
        last_used_at: 0,
        is_active: true,
        scopes: req.scopes.clone(),
    };

    // Save token to database
    Database.execute_with(
        "INSERT INTO tokens (id, value, user_id, name) VALUES ($1, $2, $3, $4)",
        sql_params_4(f"{token_id}", token_value, auth_user.id.clone(), req.name.clone())
    ).await?;

    // Convert to DTO with value (only returned on creation)
    Result.Ok(token_to_dto_with_value(&api_token))
}

/// List user's API tokens
///
/// GET /api/v1/users/tokens
pub async fn list_tokens(auth_token: Text) -> Result<List<TokenDto>, RegistryError>
    using [Database, Auth]
{
    // Verify user authentication
    let auth_user = match Auth.verify_token(auth_token).await {
        Result.Ok(u) => u,
        Result.Err(_) => return Result.Err(RegistryError.invalid_token("Invalid or expired token")),
    };

    // Get user's tokens from database
    let rows = Database.query_with(
        "SELECT * FROM tokens WHERE user_id = $1",
        sql_params_1(auth_user.id.clone())
    ).await?;

    // Convert rows to domain ApiTokens
    let mut api_tokens = List.new();
    for row in rows {
        // Parse token_id from database result
        let token_id = match row.get("id") {
            Maybe.Some(id_str) => parse_id_from_text(&id_str),
            Maybe.None => 0,  // Skip tokens without valid IDs
        };

        let name = match row.get("name") {
            Maybe.Some(v) => v.clone(),
            Maybe.None => "",
        };
        let token_value = match row.get("value") {
            Maybe.Some(v) => v.clone(),
            Maybe.None => "",
        };

        api_tokens.push(ApiToken {
            id: token_id,
            name: name,
            token: token_value,
            created_at: unix_timestamp(),
            expires_at: 0,
            last_used_at: 0,
            is_active: true,
            scopes: List.new(),
        });
    }

    // Convert to DTOs (excludes token values)
    Result.Ok(tokens_to_dtos(&api_tokens))
}

/// Revoke an API token
///
/// DELETE /api/v1/users/tokens/{token_id}
pub async fn revoke_token(token_id: Text, auth_token: Text) -> Result<Bool, RegistryError>
    using [Database, Auth]
{
    // Verify user authentication
    let auth_user = match Auth.verify_token(auth_token).await {
        Result.Ok(u) => u,
        Result.Err(_) => return Result.Err(RegistryError.invalid_token("Invalid or expired token")),
    };

    // Delete token if it belongs to the user
    let affected = Database.execute_with(
        "DELETE FROM tokens WHERE value = $1 AND user_id = $2",
        sql_params_2(token_id.clone(), auth_user.id.clone())
    ).await?;

    if affected == 0 {
        return Result.Err(RegistryError.unauthorized("Token not authorized for this operation"));
    }

    Result.Ok(true)
}

/// Get user profile
///
/// GET /api/v1/users/profile
pub async fn get_profile(auth_token: Text) -> Result<UserProfileDto, RegistryError>
    using [Auth, Database]
{
    let auth_user = match Auth.verify_token(auth_token).await {
        Result.Ok(u) => u,
        Result.Err(_) => return Result.Err(RegistryError.invalid_token("Invalid or expired token")),
    };

    // Get full user profile from database
    let row = Database.fetch_one_with(
        "SELECT * FROM users WHERE id = $1",
        sql_params_1(auth_user.id.clone())
    ).await?;

    // Construct domain user
    // Parse user_id from auth_user (AuthUser.id is Text, need to convert to Int)
    let user_id = parse_id_from_text(&auth_user.id);

    let email = match row.get("email") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "",
    };

    let user = User {
        id: user_id,
        username: auth_user.username,
        email: email,
        role: UserRole.from_string(auth_user.role),
        created_at: unix_timestamp(),
        api_tokens: List.new(),
        owned_packages: List.new(),
        is_active: true,
    };

    // Convert to DTO
    Result.Ok(user_to_profile_dto(&user))
}

/// Update user profile
///
/// PATCH /api/v1/users/profile
pub async fn update_profile(
    email: Maybe<Text>,
    auth_token: Text
) -> Result<UserProfileDto, RegistryError>
    using [Database, Auth]
{
    // Verify user authentication
    let auth_user = match Auth.verify_token(auth_token).await {
        Result.Ok(u) => u,
        Result.Err(_) => return Result.Err(RegistryError.invalid_token("Invalid or expired token")),
    };

    // Get current user data
    let row = Database.fetch_one_with(
        "SELECT * FROM users WHERE id = $1",
        sql_params_1(auth_user.id.clone())
    ).await?;

    let current_email = match row.get("email") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "",
    };

    // Update email if provided
    let final_email = match email {
        Maybe.Some(new_email) => {
            // Validate email format using centralized validation service
            validate_email(&new_email)?;

            // Check if email is already in use
            let existing = Database.fetch_optional_with(
                "SELECT id FROM users WHERE email = $1",
                sql_params_1(new_email.clone())
            ).await?;
            match existing {
                Maybe.Some(_) => {
                    return Result.Err(RegistryError.validation_error("email", "Email already in use"));
                },
                Maybe.None => {},
            }

            // Update user email
            Database.execute_with(
                "UPDATE users SET email = $1 WHERE id = $2",
                sql_params_2(new_email.clone(), auth_user.id.clone())
            ).await?;

            new_email
        }
        Maybe.None => current_email,
    };

    // Construct updated domain user
    // Parse user_id from auth_user (AuthUser.id is Text, need to convert to Int)
    let user_id = parse_id_from_text(&auth_user.id);
    let updated_user = User {
        id: user_id,
        username: auth_user.username,
        email: final_email,
        role: UserRole.from_string(auth_user.role),
        created_at: unix_timestamp(),
        api_tokens: List.new(),
        owned_packages: List.new(),
        is_active: true,
    };

    // Convert to DTO
    Result.Ok(user_to_profile_dto(&updated_user))
}

