/// Delete user account
///
/// DELETE /api/v1/users/me
pub async fn delete_account(
    req: DeleteAccountRequestDto,
    auth_token: Text
) -> Result<DeleteAccountResponseDto, RegistryError>
    using [Database, Auth]
{
    // Verify user authentication
    let auth_user = match Auth.verify_token(auth_token.clone()).await {
        Result.Ok(u) => u,
        Result.Err(_) => return Result.Err(RegistryError.invalid_token("Invalid or expired token")),
    };

    // Validate password (simplified - in production would verify password hash)
    if req.password.is_empty() {
        return Result.Err(RegistryError.validation_error("password", "Password is required to delete account"));
    }

    // Get user details
    let user_row = Database.fetch_one_with(
        "SELECT username, email FROM users WHERE id = $1",
        sql_params_1(auth_user.id.clone())
    ).await?;

    let username = match user_row.get("username") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "",
    };

    // Handle package transfer or orphaning
    match req.transfer_packages_to {
        Maybe.Some(transfer_to) => {
            // Verify transfer target user exists
            let target_user = Database.fetch_optional_with(
                "SELECT id FROM users WHERE username = $1",
                sql_params_1(transfer_to.clone())
            ).await?;

            match target_user {
                Maybe.None => {
                    return Result.Err(RegistryError.validation_error(
                        "transfer_packages_to",
                        "Target user does not exist"
                    ));
                },
                Maybe.Some(target_row) => {
                    let target_id = match target_row.get("id") {
                        Maybe.Some(id) => id.clone(),
                        Maybe.None => "",
                    };

                    // Transfer package ownership
                    Database.execute_with(
                        "UPDATE packages SET owner = $1 WHERE owner = $2",
                        sql_params_2(target_id, auth_user.id.clone())
                    ).await?;
                }
            }
        },
        Maybe.None => {
            // Orphan packages (mark as unowned or delete them)
            // For now, we'll delete the packages
            Database.execute_with(
                "DELETE FROM packages WHERE owner = $1",
                sql_params_1(auth_user.id.clone())
            ).await?;
        }
    }

    // Revoke all user's API tokens
    Database.execute_with(
        "DELETE FROM tokens WHERE user_id = $1",
        sql_params_1(auth_user.id.clone())
    ).await?;

    // Delete user account
    Database.execute_with(
        "DELETE FROM users WHERE id = $1",
        sql_params_1(auth_user.id.clone())
    ).await?;

    Result.Ok(DeleteAccountResponseDto.success(username))
}

/// Get public user profile by username
///
/// GET /api/v1/users/{username}
pub async fn get_public_profile(username: Text) -> Result<PublicUserProfileDto, RegistryError>
    using [Database]
{
    // Validate username
    if username.is_empty() {
        return Result.Err(RegistryError.validation_error("username", "Username cannot be empty"));
    }

    // Get user details (without email for privacy)
    let user_row = Database.fetch_optional_with(
        "SELECT id, username, created_at FROM users WHERE username = $1",
        sql_params_1(username.clone())
    ).await?;

    let (user_id, created_at) = match user_row {
        Maybe.None => {
            return Result.Err(RegistryError.validation_error("username", "User not found"));
        },
        Maybe.Some(row) => {
            let id = match row.get("id") {
                Maybe.Some(v) => v.clone(),
                Maybe.None => "",
            };
            let created = match row.get("created_at") {
                Maybe.Some(v) => v.clone(),
                Maybe.None => "0",
            };
            (id, created)
        }
    };

    // Get user's owned packages
    let package_rows = Database.query_with(
        "SELECT name FROM packages WHERE owner = $1",
        sql_params_1(user_id)
    ).await?;

    let mut packages = List.new();
    let mut total_downloads = 0;

    for row in package_rows {
        let package_name = match row.get("name") {
            Maybe.Some(v) => v.clone(),
            Maybe.None => "",
        };

        if !package_name.is_empty() {
            packages.push(package_name.clone());

            // Get package download count
            let download_row = Database.fetch_optional_with(
                "SELECT downloads FROM packages WHERE name = $1",
                sql_params_1(package_name)
            ).await?;

            match download_row {
                Maybe.Some(dl_row) => {
                    match dl_row.get("downloads") {
                        Maybe.Some(d) => {
                            total_downloads = total_downloads + parse_id_from_text(&d);
                        },
                        Maybe.None => {},
                    }
                },
                Maybe.None => {},
            }
        }
    }

    // Create public profile
    let mut profile = PublicUserProfileDto.new(username, created_at);
    profile = profile.with_packages(packages, total_downloads);

    Result.Ok(profile)
}

// ============================================================================
// Dashboard Endpoints (with Concurrent Data Fetching)
// ============================================================================

/// Get user dashboard with all data loaded concurrently
///
/// GET /api/v1/users/dashboard
///
/// Loads user profile, owned packages, API tokens, and stats in parallel.
pub async fn get_user_dashboard(auth_token: Text) -> Result<UserDashboardDto, RegistryError>
    using [Database, Auth]
{
    // Verify authentication
    let auth_user = match Auth.verify_token(auth_token).await {
        Result.Ok(u) => u,
        Result.Err(_) => return Result.Err(RegistryError.invalid_token("Invalid or expired token")),
    };

    let user_id = auth_user.id.clone();

    // Load all dashboard data concurrently for fast response
    let (profile_row, packages, tokens, total_downloads) = join4(
        Database.fetch_one_with(
            "SELECT * FROM users WHERE id = $1",
            sql_params_1(user_id.clone())
        ),
        Database.query_with(
            "SELECT name, version, downloads, description FROM packages WHERE owner = $1 ORDER BY downloads DESC",
            sql_params_1(user_id.clone())
        ),
        Database.query_with(
            "SELECT id, name, created_at, last_used_at FROM tokens WHERE user_id = $1",
            sql_params_1(user_id.clone())
        ),
        Database.fetch_one_with(
            "SELECT COALESCE(SUM(downloads), 0) as total FROM packages WHERE owner = $1",
            sql_params_1(user_id.clone())
        )
    ).await?;

    // Parse user profile
    let email = match profile_row.get("email") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "",
    };

    let created_at = match profile_row.get("created_at") {
        Maybe.Some(v) => v.clone(),
        Maybe.None => "0",
    };

    // Parse total downloads
    let downloads_count = match total_downloads.get("total") {
        Maybe.Some(d) => parse_id_from_text(&d),
        Maybe.None => 0,
    };

    // Build package list
    let mut package_list = List.new();
    for pkg_row in packages {
        let name = match pkg_row.get("name") {
            Maybe.Some(v) => v.clone(),
            Maybe.None => "",
        };
        package_list.push(name);
    }

    // Build token list
    let mut token_list = List.new();
    for token_row in tokens {
        let token_name = match token_row.get("name") {
            Maybe.Some(v) => v.clone(),
            Maybe.None => "",
        };
        token_list.push(token_name);
    }

    Result.Ok(UserDashboardDto {
        username: auth_user.username,
        email: email,
        created_at: created_at,
        owned_packages: package_list,
        total_packages: package_list.len(),
        total_downloads: downloads_count,
        active_tokens: token_list.len(),
        role: auth_user.role,
    })
}

// ============================================================================
// Dashboard DTO
// ============================================================================

/// User dashboard data with all information loaded concurrently
pub struct UserDashboardDto {
    pub username: Text,
    pub email: Text,
    pub created_at: Text,
    pub owned_packages: List<Text>,
    pub total_packages: Int,
    pub total_downloads: Int,
    pub active_tokens: Int,
    pub role: Text,
}
