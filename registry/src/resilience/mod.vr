// Resilience Patterns Module
//
// Industrial-grade fault tolerance patterns for building robust distributed systems.
//
// This module provides five core resilience patterns that can be composed together:
//
// 1. Circuit Breaker - Prevents cascading failures by stopping requests to failing services
// 2. Retry - Automatically retries failed operations with exponential backoff
// 3. Timeout - Prevents indefinite blocking with configurable timeouts
// 4. Bulkhead - Isolates resources to prevent resource exhaustion
// 5. Fallback - Provides graceful degradation with alternative operations
//
// ## Usage Examples
//
// ### Basic Circuit Breaker
// ```
// let cb = CircuitBreaker.new(5, 3, 30000);  // Open after 5 failures
// let (result, updated_cb) = execute_with_circuit_breaker(
//     cb,
//     || Database.query("SELECT * FROM users"),
//     || Result.Err(RegistryError.service_unavailable("Circuit open"))
// );
// ```
//
// ### Retry with Exponential Backoff
// ```
// let result = with_retry(
//     || ExternalApi.call(),
//     RetryConfig.default(),
//     |err| err.is_recoverable()
// );
// ```
//
// ### Timeout Protection
// ```
// let result = with_timeout(
//     || SlowOperation.execute(),
//     5000  // 5 second timeout
// ).await;
// ```
//
// ### Bulkhead Isolation
// ```
// let bulkhead = Bulkhead.new(10, 100);  // 10 concurrent, queue 100
// let (result, updated_bulkhead) = with_bulkhead(
//     bulkhead,
//     || Database.query("SELECT * FROM packages")
// ).await;
// ```
//
// ### Fallback Pattern
// ```
// let result = with_fallback(
//     || Database.get_package(name),
//     |err| Cache.get_package(name)
// );
// ```
//
// ## Composing Patterns
//
// These patterns can be composed for comprehensive protection:
//
// ```
// let db_circuit = CircuitBreaker.new(5, 3, 30000);
// let db_bulkhead = Bulkhead.new(10, 50);
//
// pub async fn get_package_resilient(name: Text) -> Result<PackageDto, RegistryError>
//     using [Database, Cache]
// {
//     // Check circuit breaker
//     if !db_circuit.should_allow() {
//         return with_fallback(
//             || Cache.get(f"pkg:{name}"),
//             |_| Result.Err(RegistryError.service_unavailable("Database circuit open"))
//         );
//     }
//
//     // Apply bulkhead, retry, and timeout
//     let (result, updated_bulkhead) = with_bulkhead(
//         db_bulkhead,
//         || with_retry(
//             || with_timeout(
//                 || Database.fetch_package(name),
//                 5000  // 5 second timeout
//             ),
//             RetryConfig.aggressive(),
//             |err| err.is_recoverable()
//         )
//     ).await;
//
//     // Update circuit breaker based on result
//     match result {
//         Result.Ok(pkg) => {
//             db_circuit = db_circuit.record_success();
//             Result.Ok(pkg)
//         },
//         Result.Err(err) => {
//             db_circuit = db_circuit.record_failure();
//             // Fallback to cache
//             with_fallback(
//                 || Cache.get(f"pkg:{name}"),
//                 |_| Result.Err(err)
//             )
//         }
//     }
// }
// ```

