// ============================================================================
// User Test Fixtures
// ============================================================================

/// Create a test user with default values
///
/// Example:
/// ```
/// let user = create_test_user("alice");
/// ```
pub fn create_test_user(username: Text) -> User {
    User {
        id: generate_test_id(),
        username: username,
        email: username + "@test.example.com",
        role: UserRole.Regular,
        created_at: test_timestamp(),
        api_tokens: List.new(),
        owned_packages: List.new(),
        is_active: true,
    }
}

/// Create an admin user for testing
///
/// Returns authentication token for the admin user.
pub fn create_admin_user(username: Text, email: Text) -> Text {
    // Register admin user
    register_user(RegisterRequestDto {
        username: username.clone(),
        email: email,
        password: "admin123",
        confirm_password: "admin123",
    }).await;

    // In production, would elevate user to admin role
    // For now, return login token

    login_user(LoginRequestDto {
        username: username,
        password: "admin123",
    }).await.unwrap().token
}

/// Login a test user and return authentication token
///
/// Example:
/// ```
/// let token = login_test_user("alice", "password123");
/// ```
pub fn login_test_user(username: Text, password: Text) -> Text {
    let login_req = LoginRequestDto {
        username: username,
        password: password,
    };

    login_user(login_req).await.unwrap().token
}

// ============================================================================
// Package Test Fixtures
// ============================================================================

/// Create a test package with default values
pub fn create_test_package(name: Text, owner: Text) -> Package {
    Package {
        name: name,
        description: "Test package",
        owner: owner,
        created_at: test_timestamp(),
        updated_at: test_timestamp(),
        versions: List.new(),
        downloads: 0,
        repository_url: "https://github.com/test/repo",
        homepage_url: "https://example.com",
        license: "MIT",
        keywords: List.new(),
    }
}

/// Publish a test package with minimal required fields
///
/// Returns the published package version.
pub async fn publish_test_package(
    name: Text,
    version: Text,
    auth_token: Text
) -> PublishResponseDto {
    let req = PublishRequestDto {
        name: name,
        version: version,
        description: "Test package for integration tests",
        license: "MIT",
        tarball: generate_test_tarball(),
        dependencies: List.new(),
        dev_dependencies: List.new(),
        keywords: List.new(),
        categories: List.new(),
        homepage: "https://example.com",
        repository: "https://github.com/test/repo",
    };

    publish_package(req, auth_token).await.unwrap()
}

/// Generate a test tarball (simulated binary data)
pub fn generate_test_tarball() -> List<Int> {
    // In production, would generate actual tarball bytes
    // For now, return placeholder bytes
    let mut tarball = List.new();
    for i in 0..100 {
        tarball.push(i % 256);
    }
    tarball
}

// ============================================================================
// Assertion Helpers
// ============================================================================

/// Assert that a Result is Ok
///
/// Example:
/// ```
/// assert_ok(&result);
/// ```
pub fn assert_ok<T, E>(result: &Result<T, E>) {
    match result {
        Result.Ok(_) => {
            // Success
        },
        Result.Err(_) => {
            panic("Expected Ok, got Err");
        }
    }
}

/// Assert that a Result is Err
///
/// Example:
/// ```
/// assert_err(&result);
/// ```
pub fn assert_err<T, E>(result: &Result<T, E>) {
    match result {
        Result.Ok(_) => {
            panic("Expected Err, got Ok");
        },
        Result.Err(_) => {
            // Success
        }
    }
}

/// Assert that two values are equal
///
/// Example:
/// ```
/// assert_eq(&actual, &expected);
/// ```
pub fn assert_eq<T: Eq>(actual: &T, expected: &T) {
    if actual != expected {
        panic(f"Assertion failed: {actual} != {expected}");
    }
}

/// Assert that two values are not equal
///
/// Example:
/// ```
/// assert_ne(&actual, &unexpected);
/// ```
pub fn assert_ne<T: Eq>(actual: &T, unexpected: &T) {
    if actual == unexpected {
        panic(f"Assertion failed: {actual} == {unexpected}");
    }
}

/// Assert that a boolean is true
///
/// Example:
/// ```
/// assert(&condition);
/// ```
pub fn assert(condition: &Bool) {
    if !condition {
        panic("Assertion failed: expected true, got false");
    }
}

/// Assert that a boolean is false
pub fn assert_false(condition: &Bool) {
    if condition {
        panic("Assertion failed: expected false, got true");
    }
}

