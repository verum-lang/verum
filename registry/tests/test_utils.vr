}

/// Generate random string of specified length
pub fn random_string(length: Int) -> Text {
    // In production, would generate cryptographically secure random string
    // For now, return placeholder
    "random" + f"{length}"
}

/// Generate random email
pub fn random_email() -> Text {
    random_string(8) + "@test.example.com"
}

/// Generate random package name
pub fn random_package_name() -> Text {
    "test-pkg-" + random_string(6)
}

