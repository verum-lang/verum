@test
fn test_package_metadata_update() {
    setup_test_db();
    let token = login_test_user("alice", "password123");

    // Publish package
    let req = PublishRequestDto {
        name: "metadata-test",
        version: "1.0.0",
        description: "Original description",
        license: "MIT",
        tarball: generate_test_tarball(),
        dependencies: List.new(),
        dev_dependencies: List.new(),
        keywords: List.new(),
        categories: List.new(),
        homepage: "https://example.com/old",
        repository: "https://github.com/old/repo",
    };

    publish_package(req, token.clone()).await;

    // Update metadata
    let mut keywords = List.new();
    keywords.push("testing");
    keywords.push("integration");

    let mut categories = List.new();
    categories.push("development");

    let update_req = UpdatePackageMetadataDto {
        description: "Updated description with new features",
        homepage: "https://example.com/new",
        repository: "https://github.com/new/repo",
        keywords: keywords,
        categories: categories,
    };

    let update_result = update_package_metadata("metadata-test", update_req, token).await;
    assert_ok(&update_result);

    let update_response = update_result.unwrap();
    assert_eq(&update_response.success, &true);
    assert_eq(&update_response.package_name, &"metadata-test");

    // TODO: Retrieve package and verify changes
    // Would require a get_package_metadata endpoint

    cleanup_test_db();
}

@test
fn test_package_metadata_update_authorization() {
    setup_test_db();
    let alice_token = login_test_user("alice", "password123");
    let bob_token = login_test_user("bob", "password456");

    // Alice publishes package
    let req = PublishRequestDto {
        name: "auth-metadata-test",
        version: "1.0.0",
        description: "Testing metadata update auth",
        license: "MIT",
        tarball: generate_test_tarball(),
        dependencies: List.new(),
        dev_dependencies: List.new(),
        keywords: List.new(),
        categories: List.new(),
        homepage: "",
        repository: "",
    };

    publish_package(req, alice_token).await;

    // Bob tries to update Alice's package (should fail)
    let update_req = UpdatePackageMetadataDto {
        description: "Bob's unauthorized update",
        homepage: "",
        repository: "",
        keywords: List.new(),
        categories: List.new(),
    };

    let update_result = update_package_metadata("auth-metadata-test", update_req, bob_token).await;
    assert_err(&update_result);

    match update_result {
        Result.Err(RegistryError.Unauthorized { message }) => {
            assert(&message.contains("owner") || &message.contains("admin"));
        },
        _ => panic("Expected Unauthorized error"),
    }

    cleanup_test_db();
}

