@test
fn test_package_search_pagination() {
    setup_test_db();
    let token = login_test_user("alice", "password123");

    // Publish 25 packages
    for i in 1..26 {
        let req = PublishRequestDto {
            name: f"package-{i}",
            version: "1.0.0",
            description: f"Package number {i}",
            license: "MIT",
            tarball: generate_test_tarball(),
            dependencies: List.new(),
            dev_dependencies: List.new(),
            keywords: List.new(),
            categories: List.new(),
            homepage: "",
            repository: "",
        };

        publish_package(req, token.clone()).await;
    }

    // Test pagination with list_packages
    let page1 = list_packages(1, 10).await;
    assert_ok(&page1);
    assert_eq(&page1.unwrap().packages.len(), &10);

    let page2 = list_packages(2, 10).await;
    assert_ok(&page2);
    assert_eq(&page2.unwrap().packages.len(), &10);

    let page3 = list_packages(3, 10).await;
    assert_ok(&page3);
    assert_eq(&page3.unwrap().packages.len(), &5);  // Remaining packages

    cleanup_test_db();
}

// ============================================================================
// Package Stats Tests
// ============================================================================

@test
fn test_package_stats() {
    setup_test_db();
    let token = login_test_user("alice", "password123");

    // Publish package with multiple versions
    let versions = ["1.0.0", "1.1.0", "2.0.0"];

    for version in versions {
        let req = PublishRequestDto {
            name: "stats-test",
            version: version.clone(),
            description: f"Version {version}",
            license: "MIT",
            tarball: generate_test_tarball(),
            dependencies: List.new(),
            dev_dependencies: List.new(),
            keywords: List.new(),
            categories: List.new(),
            homepage: "",
            repository: "",
        };

        publish_package(req, token.clone()).await;
    }

    // Download different versions to create stats
    download_package_artifact("stats-test", "1.0.0").await;
    download_package_artifact("stats-test", "1.0.0").await;
    download_package_artifact("stats-test", "1.1.0").await;
    download_package_artifact("stats-test", "2.0.0").await;

    // Get stats
    let stats_result = get_package_stats("stats-test").await;
    assert_ok(&stats_result);

    let stats = stats_result.unwrap();
    assert_eq(&stats.package_name, &"stats-test");
    assert_eq(&stats.total_downloads, &4);

    // Verify version breakdown
    assert_eq(&stats.version_breakdown.len(), &3);

    // Version 1.0.0 should have 2 downloads (most popular)
    let v1_stats = stats.version_breakdown.iter()
        .find(|v| v.version == "1.0.0")
        .unwrap();
    assert_eq(&v1_stats.downloads, &2);

    cleanup_test_db();
}
