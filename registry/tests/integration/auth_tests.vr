// ============================================================================
// Invalid Token Tests
// ============================================================================

@test
fn test_invalid_token_rejected() {
    setup_test_db();

    // Try to verify completely invalid token
    let garbage_tokens = [
        "",
        "invalid",
        "not-a-real-token",
        "x".repeat(1000),
        "token_with_special_chars_!@#$%",
    ];

    for garbage in garbage_tokens {
        let result = verify_token(garbage.clone()).await;
        assert_ok(&result);  // verify_token returns Ok(TokenResponseDto) with valid=false

        let response = result.unwrap();
        assert_eq(&response.valid, &false);
    }

    cleanup_test_db();
}

@test
fn test_token_format_validation() {
    setup_test_db();

    // Register and login
    let register_req = RegisterRequestDto {
        username: "formattest",
        email: "format@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(register_req).await;

    let auth_token = login_user(LoginRequestDto {
        username: "formattest",
        password: "password123",
    }).await.unwrap().token;

    // Create valid token
    let api_token = create_token(CreateTokenRequestDto {
        name: "format-token",
        expires_days: 30,
        scopes: List.new(),
    }, auth_token).await.unwrap().token;

    // Verify token has expected format
    assert_ne(&api_token, &"");
    assert(&api_token.len() > 16);  // Tokens should have minimum length

    cleanup_test_db();
}

