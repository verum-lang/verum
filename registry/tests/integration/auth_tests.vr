    let api_token = create_token(create_req, auth_token).await.unwrap().token;

    // Token should work immediately
    let verify_immediate = verify_token(api_token.clone()).await;
    assert_ok(&verify_immediate);
    assert_eq(&verify_immediate.unwrap().valid, &true);

    // In production, would wait for expiry and verify token is invalid
