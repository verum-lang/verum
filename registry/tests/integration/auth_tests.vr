@test
fn test_token_with_scopes() {
    setup_test_db();

    // Register and login
    let register_req = RegisterRequestDto {
        username: "scopeuser",
        email: "scope@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(register_req).await;

    let auth_token = login_user(LoginRequestDto {
        username: "scopeuser",
        password: "password123",
    }).await.unwrap().token;

    // Create token with specific scopes
    let mut scopes = List.new();
    scopes.push("publish");
    scopes.push("yank");
    scopes.push("update");

    let create_req = CreateTokenRequestDto {
        name: "scoped-token",
        expires_days: 90,
        scopes: scopes.clone(),
    };

    let token_response = create_token(create_req, auth_token).await;
    assert_ok(&token_response);

    let token_dto = token_response.unwrap();
    assert_eq(&token_dto.scopes.len(), &3);

    // In production, would test that token can only perform allowed operations
    // For now, this verifies scopes are correctly stored

    cleanup_test_db();
}

@test
fn test_token_without_scopes() {
    setup_test_db();

    // Register and login
    let register_req = RegisterRequestDto {
        username: "noscopeuser",
        email: "noscope@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(register_req).await;

    let auth_token = login_user(LoginRequestDto {
        username: "noscopeuser",
        password: "password123",
    }).await.unwrap().token;

    // Create token without scopes (full access)
    let create_req = CreateTokenRequestDto {
        name: "full-access-token",
        expires_days: 30,
        scopes: List.new(),  // Empty scopes = full access
    };

    let token_response = create_token(create_req, auth_token).await;
    assert_ok(&token_response);

    let token_dto = token_response.unwrap();
    assert_eq(&token_dto.scopes.len(), &0);

    cleanup_test_db();
}

// ============================================================================
// Token Security Tests
// ============================================================================

@test
fn test_token_not_reused_across_users() {
    setup_test_db();

    // Register two users
    let user1 = RegisterRequestDto {
        username: "user1",
        email: "user1@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(user1).await;

    let user2 = RegisterRequestDto {
        username: "user2",
        email: "user2@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(user2).await;

    // Get tokens for both users
    let token1 = login_user(LoginRequestDto {
        username: "user1",
        password: "password123",
    }).await.unwrap().token;

    let token2 = login_user(LoginRequestDto {
        username: "user2",
        password: "password123",
    }).await.unwrap().token;

    // Tokens should be different
    assert_ne(&token1, &token2);

    // Each token should only verify for its own user
    let verify1 = verify_token(token1).await.unwrap();
    assert_eq(&verify1.user.username, &"user1");

    let verify2 = verify_token(token2).await.unwrap();
    assert_eq(&verify2.user.username, &"user2");

    cleanup_test_db();
}
