    let auth_token = login_user(LoginRequestDto {
        username: "expiryuser",
        password: "password123",
    }).await.unwrap().token;

    // Create token with very short expiry (1 day)
    let create_req = CreateTokenRequestDto {
        name: "short-lived-token",
        expires_days: 1,
        scopes: List.new(),
