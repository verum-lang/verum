// ============================================================================
// Password Hashing Tests
// ============================================================================

mount super.super.src.services.user_service.{
    hash_password,
    verify_password,
    generate_user_id,
    generate_token,
};

@test
fn test_password_hashing_produces_valid_format() {
    // Test that password hashing produces valid Argon2id PHC format
    let password = "my_secure_password";
    let hash_result = hash_password(&password);

    assert_ok(&hash_result);

    let hash = hash_result.unwrap();

    // Verify PHC format: $argon2id$v=19$m=...,t=...,p=...$salt$hash
    assert(&hash.starts_with("$argon2id$v=19$m="));
    assert(&hash.contains(",t="));
    assert(&hash.contains(",p="));

    // Count $ separators (should be 5 for PHC format)
    let parts = hash.split("$");
    assert_eq(&parts.len(), &6);
}

@test
fn test_password_hashing_empty_password_fails() {
    // Empty password should fail validation
    let password = "";
    let hash_result = hash_password(&password);

    assert_err(&hash_result);

    match hash_result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"password");
            assert(&message.contains("empty"));
        },
        _ => panic("Expected ValidationError for empty password"),
    }
}

@test
fn test_password_verification_correct_password() {
    // Hash a password and verify it matches
    let password = "correct_password_123";
    let hash_result = hash_password(&password);
    assert_ok(&hash_result);
    let hash = hash_result.unwrap();

    // Verify with correct password
    let verify_result = verify_password(&password, &hash);
    assert_ok(&verify_result);
    assert_eq(&verify_result.unwrap(), &true);
}

@test
fn test_password_verification_wrong_password() {
    // Hash a password and verify wrong password fails
    let password = "correct_password";
    let hash_result = hash_password(&password);
    assert_ok(&hash_result);
    let hash = hash_result.unwrap();

    // Verify with wrong password
    let wrong_password = "wrong_password";
    let verify_result = verify_password(&wrong_password, &hash);
    assert_ok(&verify_result);
    assert_eq(&verify_result.unwrap(), &false);
}

@test
fn test_password_verification_invalid_hash_format() {
    // Invalid hash format should fail
    let password = "password";
    let invalid_hash = "not_a_valid_hash";

    let verify_result = verify_password(&password, &invalid_hash);
    assert_err(&verify_result);

    match verify_result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"password_hash");
            assert(&message.contains("Invalid hash format"));
        },
        _ => panic("Expected ValidationError for invalid hash format"),
    }
}

@test
fn test_password_hashing_produces_unique_hashes() {
    // Same password should produce different hashes (due to random salt)
    let password = "same_password";

    let hash1_result = hash_password(&password);
    let hash2_result = hash_password(&password);

    assert_ok(&hash1_result);
    assert_ok(&hash2_result);

    let hash1 = hash1_result.unwrap();
    let hash2 = hash2_result.unwrap();

    // Hashes should be different due to different salts
    // Note: In deterministic test mode, salts might be same
    // but in production mode, they should differ
    // For this test, we just verify both are valid
    assert(&hash1.starts_with("$argon2id$"));
    assert(&hash2.starts_with("$argon2id$"));
}

// ============================================================================
// ID Generation Tests
// ============================================================================

@test
fn test_user_id_is_valid_uuid_format() {
    let user_id = generate_user_id(&"testuser");

    // UUID v4 format: xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx
    let parts = user_id.split("-");
    assert_eq(&parts.len(), &5);

    // Verify lengths: 8-4-4-4-12
    let p0 = parts.get(0).unwrap_or("");
    let p1 = parts.get(1).unwrap_or("");
    let p2 = parts.get(2).unwrap_or("");
    let p3 = parts.get(3).unwrap_or("");
    let p4 = parts.get(4).unwrap_or("");

    assert_eq(&p0.len(), &8);
    assert_eq(&p1.len(), &4);
    assert_eq(&p2.len(), &4);
    assert_eq(&p3.len(), &4);
    assert_eq(&p4.len(), &12);

    // Verify version 4 indicator
    assert(&p2.starts_with("4"));
}

@test
fn test_token_generation_has_prefix() {
    let token = generate_token(&"user123");

    // Token should have vrm_ prefix
    assert(&token.starts_with("vrm_"));

    // Token should be sufficiently long (vrm_ + ~43 base64 chars)
    assert(&(token.len() >= 40));
}

