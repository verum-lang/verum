// ============================================================================
// User Deletion Tests
// ============================================================================

@test
fn test_user_delete_account() {
    setup_test_db();

    // Register user
    let register_req = RegisterRequestDto {
        username: "deletetest",
        email: "delete@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(register_req).await;

    // Login
    let login_req = LoginRequestDto {
        username: "deletetest",
        password: "password123",
    };
    let token = login_user(login_req).await.unwrap().token;

    // Delete account with password confirmation
    let delete_req = DeleteAccountRequestDto {
        password: "password123",
        transfer_packages_to: Maybe.None,  // Delete packages
    };

    let delete_result = delete_account(delete_req, token.clone()).await;
    assert_ok(&delete_result);

    let delete_response = delete_result.unwrap();
    assert_eq(&delete_response.success, &true);
    assert_eq(&delete_response.username, &"deletetest");

    // Verify user is deleted (login should fail)
    let login_after = login_user(LoginRequestDto {
        username: "deletetest",
        password: "password123",
    }).await;
    assert_err(&login_after);

    cleanup_test_db();
}

