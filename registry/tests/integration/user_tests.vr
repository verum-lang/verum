@test
fn test_get_error_type_returns_snake_case() {
    let error = RegistryError.package_not_found("test");
    let error_type = get_error_type(&error);

    assert_eq(&error_type, &"package_not_found");
}

@test
fn test_get_error_details_returns_json() {
    let error = RegistryError.package_not_found("my-pkg");
    let details = get_error_details(&error);

    assert(&details.contains("resource_type"));
    assert(&details.contains("package"));
    assert(&details.contains("my-pkg"));
}

@test
fn test_get_error_details_hides_sensitive_info() {
    // For security errors, details should not expose internal info
    let error = RegistryError.invalid_token("secret internal message");
    let details = get_error_details(&error);

    // Should contain hint, not the internal message
    assert(&details.contains("hint"));
    assert(!details.contains("secret internal message"));
}
