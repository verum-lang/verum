// ============================================================================
// User Profile Tests
// ============================================================================

@test
fn test_user_profile_update() {
    setup_test_db();

    // Register and login
    let register_req = RegisterRequestDto {
        username: "profiletest",
        email: "old@example.com",
        password: "password123",
        confirm_password: "password123",
    };

    register_user(register_req).await;

    let login_req = LoginRequestDto {
        username: "profiletest",
        password: "password123",
    };

    let login_response = login_user(login_req).await.unwrap();
    let token = login_response.token;

    // Get initial profile
    let initial_profile = get_profile(token.clone()).await;
    assert_ok(&initial_profile);
    assert_eq(&initial_profile.unwrap().email, &"old@example.com");

    // Update email
    let update_result = update_profile(Maybe.Some("new@example.com"), token.clone()).await;
    assert_ok(&update_result);

    // Get updated profile and verify change
    let updated_profile = get_profile(token).await;
    assert_ok(&updated_profile);
    assert_eq(&updated_profile.unwrap().email, &"new@example.com");

    cleanup_test_db();
}

@test
fn test_user_profile_update_duplicate_email() {
    setup_test_db();

    // Register two users
    let user1 = RegisterRequestDto {
        username: "user1",
        email: "user1@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(user1).await;

    let user2 = RegisterRequestDto {
        username: "user2",
        email: "user2@example.com",
        password: "password123",
        confirm_password: "password123",
    };
    register_user(user2).await;

    // Login as user2
    let login_req = LoginRequestDto {
        username: "user2",
        password: "password123",
    };
    let token = login_user(login_req).await.unwrap().token;

    // Try to update to user1's email (should fail)
    let update_result = update_profile(Maybe.Some("user1@example.com"), token).await;
    assert_err(&update_result);

    match update_result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"email");
            assert(&message.contains("already in use"));
        },
        _ => panic("Expected ValidationError for duplicate email"),
    }

    cleanup_test_db();
}

