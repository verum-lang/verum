@test
fn test_user_registration_validation() {
    setup_test_db();

    // Test username too short
    let short_username = RegisterRequestDto {
        username: "ab",  // Too short (min 3)
        email: "test@example.com",
        password: "password123",
        confirm_password: "password123",
    };

    let result1 = register_user(short_username).await;
    assert_err(&result1);

    // Test invalid email
    let invalid_email = RegisterRequestDto {
        username: "validuser",
        email: "not-an-email",  // Invalid format
        password: "password123",
        confirm_password: "password123",
    };

    let result2 = register_user(invalid_email).await;
    assert_err(&result2);

    // Test password too short
    let short_password = RegisterRequestDto {
        username: "validuser",
        email: "test@example.com",
        password: "short",  // Too short (min 8)
        confirm_password: "short",
    };

    let result3 = register_user(short_password).await;
    assert_err(&result3);

    // Test password mismatch
    let password_mismatch = RegisterRequestDto {
        username: "validuser",
        email: "test@example.com",
        password: "password123",
        confirm_password: "different456",  // Doesn't match
    };

    let result4 = register_user(password_mismatch).await;
    assert_err(&result4);

    cleanup_test_db();
}

