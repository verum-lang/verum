mount super.super.src.handlers.users.{parse_id_from_text_safe};

@test
fn test_parse_id_valid_positive_integer() {
    let result = parse_id_from_text_safe(&"12345");
    assert_ok(&result);
    assert_eq(&result.unwrap(), &12345);
}

@test
fn test_parse_id_valid_negative_integer() {
    let result = parse_id_from_text_safe(&"-456");
    assert_ok(&result);
    assert_eq(&result.unwrap(), &-456);
}

@test
fn test_parse_id_valid_zero() {
    let result = parse_id_from_text_safe(&"0");
    assert_ok(&result);
    assert_eq(&result.unwrap(), &0);
}

@test
fn test_parse_id_empty_string_fails() {
    let result = parse_id_from_text_safe(&"");
    assert_err(&result);

    match result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"id");
            assert(&message.contains("empty"));
        },
        _ => panic("Expected ValidationError for empty string"),
    }
}

@test
fn test_parse_id_only_minus_sign_fails() {
    let result = parse_id_from_text_safe(&"-");
    assert_err(&result);

    match result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"id");
            assert(&message.contains("only minus sign"));
        },
        _ => panic("Expected ValidationError for only minus sign"),
    }
}

@test
fn test_parse_id_invalid_characters_fails() {
    let result = parse_id_from_text_safe(&"123abc");
    assert_err(&result);

    match result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"id");
            assert(&message.contains("unexpected character"));
        },
        _ => panic("Expected ValidationError for invalid characters"),
    }
}

@test
fn test_parse_id_alphabetic_string_fails() {
    let result = parse_id_from_text_safe(&"abc");
    assert_err(&result);

    match result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"id");
        },
        _ => panic("Expected ValidationError for alphabetic string"),
    }
}

@test
fn test_parse_id_overflow_protection() {
    // Test with a very large number that would overflow
    let result = parse_id_from_text_safe(&"99999999999999999999999999");
    assert_err(&result);

    match result {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"id");
            assert(&message.contains("exceeds maximum"));
        },
        _ => panic("Expected ValidationError for overflow"),
    }
}

@test
fn test_parse_id_large_valid_number() {
    // Test with a large but valid number
    let result = parse_id_from_text_safe(&"9223372036854775");
    assert_ok(&result);
    assert_eq(&result.unwrap(), &9223372036854775);
}

