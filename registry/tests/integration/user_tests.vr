// Verum Registry - User Integration Tests
//
// Comprehensive integration tests for user authentication and profile management
// Tests registration, login, token management, and profile operations

mount core.collections.{List};
mount core.base.{Result, Maybe, Text, Int, Bool};

// Import test utilities
mount super.super.test_utils.{
    setup_test_db,
    cleanup_test_db,
    assert_ok,
    assert_err,
    assert_eq,
    assert_ne,
};

// Import domain types
mount super.super.src.domain.errors.{RegistryError};
mount super.super.src.domain.user.{User, UserRole};

// Import DTOs
mount super.super.src.dto.user_dto.{
    RegisterRequestDto,
    LoginRequestDto,
    CreateTokenRequestDto,
    DeleteAccountRequestDto,
};

// Import handlers
mount super.super.src.handlers.users.{
    register_user,
    login_user,
    verify_token,
    create_token,
    list_tokens,
    revoke_token,
    get_profile,
    update_profile,
    delete_account,
    get_public_profile,
};

// ============================================================================
// User Registration and Login Tests
// ============================================================================

@test
fn test_user_registration_and_login() {
    setup_test_db();

    // Register new user
    let register_req = RegisterRequestDto {
        username: "alice",
        email: "alice@example.com",
        password: "secure123",
        confirm_password: "secure123",
    };

    let register_result = register_user(register_req).await;
    assert_ok(&register_result);

    let register_response = register_result.unwrap();
    assert_eq(&register_response.success, &true);
    assert_eq(&register_response.user.username, &"alice");
    assert_eq(&register_response.user.email, &"alice@example.com");

    // Login with credentials
    let login_req = LoginRequestDto {
        username: "alice",
        password: "secure123",
    };

    let login_result = login_user(login_req).await;
    assert_ok(&login_result);

    let login_response = login_result.unwrap();
    assert_ne(&login_response.token, &"");
    assert_eq(&login_response.user.username, &"alice");
    assert_eq(&login_response.expires_in, &(30 * 24 * 60 * 60));  // 30 days

    cleanup_test_db();
}

@test
fn test_user_registration_duplicate_username() {
    setup_test_db();

    // Register first user
    let register_req1 = RegisterRequestDto {
        username: "duplicate",
        email: "user1@example.com",
        password: "password123",
        confirm_password: "password123",
    };

    let result1 = register_user(register_req1).await;
    assert_ok(&result1);

    // Try to register with same username
    let register_req2 = RegisterRequestDto {
        username: "duplicate",  // Same username
        email: "user2@example.com",  // Different email
        password: "password456",
        confirm_password: "password456",
    };

    let result2 = register_user(register_req2).await;
    assert_err(&result2);

    match result2 {
        Result.Err(RegistryError.ValidationError { field_name, message }) => {
            assert_eq(&field_name, &"username");
            assert(&message.contains("already taken"));
        },
        _ => panic("Expected ValidationError for duplicate username"),
    }

    cleanup_test_db();
}

@test
fn test_user_registration_duplicate_email() {
