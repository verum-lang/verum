fn database_operation() async -> Result<Text, RegistryError> {
    // Simulated database operation
    // Behavior controlled by test utilities
    Result.Ok("success")
}

fn slow_database_operation() async -> Result<Text, RegistryError> {
    // Simulated slow operation
    // Duration controlled by test utilities
    Result.Ok("success")
}

fn get_from_cache(key: Text) async -> Result<PackageStats, RegistryError> {
    // Simulated cache operation
    Result.Err(RegistryError.internal_error("Cache miss"))
}

type PackageStats is {
    total_downloads: Int,
    is_placeholder: Bool,
};

fn create_placeholder_stats() -> PackageStats {
    PackageStats {
        total_downloads: 0,
        is_placeholder: true,
    }
}

fn current_time_ms() -> Int {
    // Return current time in milliseconds
    // In production, would use std.time
    0
}
