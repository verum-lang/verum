// Integration tests for version repository constraint matching
// Tests the find_matching_versions functionality

mount core.base.{Result, List};
mount crate.domain.version.SemVer;
mount crate.domain.package.{PackageVersion, Dependency};
mount crate.domain.refinements.ValidatedPackageName;
mount crate.domain.semver_constraint.{parse_constraint, satisfies, sort_versions_descending};

// Helper to create a test package version
fn make_version(name: Text, major: Int, minor: Int, patch: Int) -> PackageVersion {
    let validated_name = ValidatedPackageName.try_from(name).unwrap();
    let semver = SemVer.new(major, minor, patch);

    PackageVersion.new(validated_name, semver, "test-publisher")
}

@test
fn test_filter_versions_with_caret_constraint() {
    let pkg_name = "test-package";

    // Create test versions
    let mut versions = List.new();
    versions.push(make_version(pkg_name, 1, 0, 0));
    versions.push(make_version(pkg_name, 1, 2, 0));
    versions.push(make_version(pkg_name, 1, 5, 3));
    versions.push(make_version(pkg_name, 2, 0, 0));
    versions.push(make_version(pkg_name, 2, 1, 0));

    // Parse constraint ^1.0.0
    let constraint = parse_constraint("^1.0.0").unwrap();

    // Filter matching versions
    let mut matching = List.new();
    for version in versions {
        if satisfies(version.version, constraint) {
            matching.push(version);
        }
    }

    // Should match 1.0.0, 1.2.0, 1.5.3 but not 2.x.x
    assert(matching.len() == 3, "Should match 3 versions with ^1.0.0");
}

@test
fn test_filter_versions_with_greater_than_constraint() {
    let pkg_name = "test-package";

    let mut versions = List.new();
    versions.push(make_version(pkg_name, 0, 9, 0));
    versions.push(make_version(pkg_name, 1, 0, 0));
    versions.push(make_version(pkg_name, 1, 0, 1));
    versions.push(make_version(pkg_name, 2, 0, 0));

    let constraint = parse_constraint(">=1.0.0").unwrap();

    let mut matching = List.new();
    for version in versions {
        if satisfies(version.version, constraint) {
            matching.push(version);
        }
    }

    // Should match 1.0.0, 1.0.1, 2.0.0 but not 0.9.0
    assert(matching.len() == 3, "Should match 3 versions with >=1.0.0");
}

@test
fn test_sort_versions_descending() {
    let pkg_name = "test-package";

    let mut versions = List.new();
    versions.push(make_version(pkg_name, 1, 0, 0));
    versions.push(make_version(pkg_name, 2, 0, 0));
    versions.push(make_version(pkg_name, 1, 5, 3));
    versions.push(make_version(pkg_name, 1, 2, 0));

    sort_versions_descending(&mut versions);

    // After sorting: 2.0.0, 1.5.3, 1.2.0, 1.0.0
    assert(versions.get(0).unwrap().version.major == 2, "First should be 2.0.0");
    assert(versions.get(1).unwrap().version.minor == 5, "Second should be 1.5.3");
    assert(versions.get(2).unwrap().version.minor == 2, "Third should be 1.2.0");
    assert(versions.get(3).unwrap().version.patch == 0, "Fourth should be 1.0.0");
}

@test
fn test_wildcard_matching() {
    let pkg_name = "test-package";

    let mut versions = List.new();
    versions.push(make_version(pkg_name, 1, 2, 0));
    versions.push(make_version(pkg_name, 1, 2, 5));
    versions.push(make_version(pkg_name, 1, 3, 0));
    versions.push(make_version(pkg_name, 2, 2, 0));

    let constraint = parse_constraint("1.2.*").unwrap();

    let mut matching = List.new();
    for version in versions {
        if satisfies(version.version, constraint) {
            matching.push(version);
        }
    }

    // Should match 1.2.0 and 1.2.5 but not 1.3.0 or 2.2.0
    assert(matching.len() == 2, "Should match 2 versions with 1.2.*");
}

@test
fn test_any_wildcard_matching() {
    let pkg_name = "test-package";

    let mut versions = List.new();
    versions.push(make_version(pkg_name, 0, 0, 1));
    versions.push(make_version(pkg_name, 1, 0, 0));
    versions.push(make_version(pkg_name, 2, 5, 3));

    let constraint = parse_constraint("*").unwrap();

    let mut matching = List.new();
    for version in versions {
        if satisfies(version.version, constraint) {
            matching.push(version);
        }
    }

    // Should match all versions
    assert(matching.len() == 3, "Should match all versions with *");
}

@test
fn test_tilde_constraint_filtering() {
    let pkg_name = "test-package";

    let mut versions = List.new();
    versions.push(make_version(pkg_name, 1, 0, 0));
    versions.push(make_version(pkg_name, 1, 0, 5));
    versions.push(make_version(pkg_name, 1, 1, 0));

    let constraint = parse_constraint("~1.0.0").unwrap();

    let mut matching = List.new();
    for version in versions {
        if satisfies(version.version, constraint) {
            matching.push(version);
        }
    }

    // Should match 1.0.0 and 1.0.5 but not 1.1.0
    assert(matching.len() == 2, "Should match 2 versions with ~1.0.0");
}
