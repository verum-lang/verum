// Comprehensive integration test for all implemented Verum features
// Tests timing, validation, concurrency, semver, and domain types together

mount core.base.{Result, List, Text, Maybe};
mount core.time.{unix_timestamp, unix_timestamp_millis};
mount super.src.services.timing_service.{Timer, get_uptime_seconds, init_server_timing};
mount super.src.services.concurrency_service.{RetryConfig, parallel_map};
mount super.src.domain.version.SemVer;
mount super.src.domain.semver_constraint.{parse_constraint, satisfies};
mount super.src.domain.errors.RegistryError;

// ============================================================================
// Integration Test: Timing + Validation
// ============================================================================

@test
fn test_version_validation_with_timing() {
    let timer = Timer.start();

    // Create and validate multiple versions
    let v1 = SemVer.new(1, 0, 0);
    let v2 = SemVer.new(2, 5, 3);
    let v3 = SemVer.new(0, 1, 0);

    assert(v1.major == 1, "v1 major should be 1");
    assert(v2.minor == 5, "v2 minor should be 5");
    assert(v3.patch == 0, "v3 patch should be 0");

    let elapsed = timer.stop();
    assert(elapsed >= 0, "Timer should work");

    print(f"Version validation completed in {elapsed}ms");
}

// ============================================================================
// Integration Test: Semver + Character Validation
// ============================================================================

@test
fn test_version_string_parsing() {
    // Test that version strings are properly validated
    let valid_versions = ["1.0.0", "2.5.3", "0.1.0"];
    let mut parsed_count = 0;

    for version_str in valid_versions {
        let result = parse_constraint(version_str);
        match result {
            Result.Ok(_) => {
                parsed_count = parsed_count + 1;
            },
            Result.Err(_) => {
                assert(false, f"Failed to parse valid version: {version_str}");
            }
        }
    }

    assert(parsed_count == 3, "Should parse all 3 valid versions");
    print(f"Parsed {parsed_count} version strings successfully");
}

// ============================================================================
// Integration Test: Concurrency + Timing
// ============================================================================

@test
async fn test_parallel_version_checking() {
    let versions = [
        SemVer.new(1, 0, 0),
        SemVer.new(1, 2, 3),
        SemVer.new(1, 9, 0),
        SemVer.new(2, 0, 0),
    ];

    let constraint = parse_constraint("^1.2.0").unwrap();
    let timer = Timer.start();

    // Check each version against the constraint in parallel
    async fn check_version(v: SemVer) -> Result<Bool, RegistryError> {
        let result = satisfies(v, constraint);
        Result.Ok(result)
    }

    let results = parallel_map(versions, check_version).await;

    let elapsed = timer.stop();

    match results {
        Result.Ok(checks) => {
            assert(checks.len() == 4, "Should check all 4 versions");
            assert(!checks[0], "1.0.0 should NOT satisfy ^1.2.0");
            assert(checks[1], "1.2.3 should satisfy ^1.2.0");
            assert(checks[2], "1.9.0 should satisfy ^1.2.0");
            assert(!checks[3], "2.0.0 should NOT satisfy ^1.2.0");
            print(f"Parallel version checking completed in {elapsed}ms");
        },
        Result.Err(_) => {
            assert(false, "Parallel checking should not fail");
        }
    }
}

// ============================================================================
// Integration Test: Retry + Timing + Validation
// ============================================================================

@test
async fn test_retry_with_version_validation() {
    let mut attempt_count = 0;

    async fn validate_version_eventually() -> Result<SemVer, RegistryError> {
        attempt_count = attempt_count + 1;

        // Succeed on third attempt
        if attempt_count >= 3 {
            Result.Ok(SemVer.new(1, 2, 3))
        } else {
            Result.Err(RegistryError.validation_error(
                "version",
                "Temporary validation failure"
            ))
        }
    }

    let config = RetryConfig {
        max_attempts: 5,
        initial_delay_ms: 10,
        max_delay_ms: 100,
        multiplier: 2.0,
        jitter: false,
    };

    let timer = Timer.start();
    let result = retry_with_config(validate_version_eventually, config).await;
    let elapsed = timer.stop();

    match result {
        Result.Ok(version) => {
            assert(version.major == 1, "Should return version 1.2.3");
            assert(attempt_count == 3, "Should succeed on third attempt");
            print(f"Retry validation succeeded after {attempt_count} attempts in {elapsed}ms");
        },
        Result.Err(_) => {
            assert(false, "Should eventually succeed");
        }
    }
}

// ============================================================================
// Integration Test: Complex Semver Constraint Matching
// ============================================================================

@test
fn test_comprehensive_semver_constraints() {
    let test_cases = [
        // (version, constraint, should_match)
        ("1.0.0", "^1.0.0", true),
        ("1.9.9", "^1.0.0", true),
        ("2.0.0", "^1.0.0", false),
        ("1.2.3", "~1.2.0", true),
        ("1.3.0", "~1.2.0", false),
        ("1.5.0", ">=1.0.0", true),
        ("0.9.0", ">=1.0.0", false),
    ];

    let mut passed = 0;
    let mut failed = 0;

    for (version_str, constraint_str, expected) in test_cases {
        let version = SemVer.from_string(version_str).unwrap();
        let constraint = parse_constraint(constraint_str).unwrap();
        let result = satisfies(version, constraint);

        if result == expected {
            passed = passed + 1;
        } else {
            failed = failed + 1;
            print(f"FAILED: {version_str} vs {constraint_str} (expected {expected}, got {result})");
        }
    }

    assert(failed == 0, f"All constraint tests should pass, but {failed} failed");
    print(f"Comprehensive semver tests: {passed} passed, {failed} failed");
}

// ============================================================================
// Integration Test: Uptime Tracking with Version Management
// ============================================================================

@test
fn test_uptime_with_version_operations() {
    init_server_timing();
    let start_uptime = get_uptime_seconds();

    // Simulate some version operations
    let versions = [
        SemVer.new(1, 0, 0),
        SemVer.new(2, 0, 0),
        SemVer.new(3, 0, 0),
    ];

    let mut operation_count = 0;
    for version in versions {
        // Compare versions
        if version.major > 0 {
            operation_count = operation_count + 1;
        }
    }

    let end_uptime = get_uptime_seconds();

    assert(end_uptime >= start_uptime, "Uptime should not decrease");
    assert(operation_count == 3, "Should process all versions");
    print(f"Version operations: {operation_count} processed, uptime: {start_uptime}s -> {end_uptime}s");
}

// ============================================================================
// Integration Test: Text Processing with Semver
// ============================================================================

@test
fn test_version_text_processing() {
    let version = SemVer.new(1, 2, 3);
    let version_string = f"{version.major}.{version.minor}.{version.patch}";

    // Verify string construction
    assert(version_string.len() > 0, "Version string should not be empty");

    // Parse it back
    let parsed = parse_constraint(version_string);
    match parsed {
        Result.Ok(_) => {
            print(f"Successfully round-tripped version: {version_string}");
        },
        Result.Err(_) => {
            assert(false, "Should parse back successfully");
        }
    }
}

// ============================================================================
// Integration Test: Timestamp Consistency
// ============================================================================

@test
fn test_timestamp_consistency_across_operations() {
    let ts1 = unix_timestamp();
    let ts_millis1 = unix_timestamp_millis();

    // Do some work
    let version = SemVer.new(1, 0, 0);
    let constraint = parse_constraint("^1.0.0").unwrap();
    let matches = satisfies(version, constraint);

    let ts2 = unix_timestamp();
    let ts_millis2 = unix_timestamp_millis();

    assert(ts2 >= ts1, "Timestamps should not go backward");
    assert(ts_millis2 >= ts_millis1, "Millis timestamps should not go backward");
    assert(matches, "Version should match constraint");

    print(f"Timestamp consistency: {ts1}s -> {ts2}s, operations completed successfully");
}

// ============================================================================
// Integration Test: Error Handling Chain
// ============================================================================

@test
fn test_error_handling_with_validation() {
    // Test invalid version constraint
    let invalid_constraint = parse_constraint("not-a-version");

    match invalid_constraint {
        Result.Ok(_) => {
            assert(false, "Should fail to parse invalid constraint");
        },
        Result.Err(err) => {
            print(f"Correctly caught error: {err}");
        }
    }

    // Test valid constraint
    let valid_constraint = parse_constraint("1.0.0");

    match valid_constraint {
        Result.Ok(_) => {
            print("Valid constraint parsed successfully");
        },
        Result.Err(_) => {
            assert(false, "Should parse valid constraint");
        }
    }
}

// ============================================================================
// Integration Test: List Operations with Versions
// ============================================================================

@test
fn test_version_list_operations() {
    let mut versions: List<SemVer> = List.new();

    // Add versions
    versions.push(SemVer.new(1, 0, 0));
    versions.push(SemVer.new(2, 0, 0));
    versions.push(SemVer.new(1, 5, 0));

    assert(versions.len() == 3, "Should have 3 versions");

    // Filter versions matching constraint
    let constraint = parse_constraint("^1.0.0").unwrap();
    let mut matching_versions: List<SemVer> = List.new();

    for version in versions {
        if satisfies(version, constraint) {
            matching_versions.push(version);
        }
    }

    assert(matching_versions.len() == 2, "Should have 2 matching versions (1.0.0 and 1.5.0)");
    print(f"Version filtering: {versions.len()} total, {matching_versions.len()} matching ^1.0.0");
}

