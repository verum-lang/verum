# Verum.toml - Complete LLVM Optimization Configuration Example
# This file demonstrates all available LLVM backend and optimization settings.
#
# Section name is `[cog]` (Verum's term for a package/crate).  Pre-fix
# this example used `[package]` which the parser would silently ignore ‚Äî
# users got an error like "missing field `name`" with no clue why.

[cog]
name = "my-verum-project"
version = "0.1.0"
authors = ["Your Name <you@example.com>"]
description = "A high-performance Verum application"
license = "MIT OR Apache-2.0"

# Language profile determines available features
# Options: application (default), systems, research
[language]
profile = "application"

# ============================================================================
# LLVM Backend Configuration
# ============================================================================
#
# Three load-bearing fields (LlvmConfig in
# crates/verum_cli/src/config.rs).  All others (`reloc_mode` /
# `code_model` / `pic` / `pie`) are not parsed and would silently
# no-op.  PIC / PIE selection is currently driven by `[linker]`
# section + LLVM defaults for the chosen target.

[llvm]
# Target triple for compilation.  Load-bearing.
# Examples:
#   - "x86_64-unknown-linux-gnu" (Linux x86_64)
#   - "aarch64-apple-darwin" (macOS ARM64)
#   - "x86_64-pc-windows-msvc" (Windows)
# Default: host triple (auto-detected).
target_triple = "x86_64-unknown-linux-gnu"

# CPU model for optimization.  Load-bearing.
# Options:
#   - "native" - detect host CPU (best for local builds)
#   - "generic" - portable across CPUs
#   - Specific: "skylake", "apple-m1", "cortex-a72", etc.
# Default: unset (LLVM picks based on target_triple).
target_cpu = "native"

# CPU features (enable with '+', disable with '-').  Load-bearing.
# Examples:
#   - "+avx2,+fma" - Enable AVX2 and FMA instructions
#   - "+neon" - Enable ARM NEON SIMD
#   - "-sse4.2" - Disable SSE4.2
# Default: unset (auto-detect from target_cpu).
target_features = "+avx2,+fma"

# ============================================================================
# Optimization Pass Configuration
# ============================================================================
#
# NOTE ‚Äî forward-looking section.  The parser (OptimizationConfig in
# crates/verum_cli/src/config.rs) recognises only `level` / `size_opt`
# / `inline` today.  The active codegen optimization knob is
# `[profile.<dev|release>].optimization` (per-profile `opt_level`)
# which IS load-bearing.  Setting fields below logs a debug-trace
# observation but does NOT change LLVM pass selection.
#
# Vectorize / loop-unroll / SLP / LICM / merge-functions / function-
# inlining are all driven implicitly by `opt_level` through LLVM's
# `default<O0..O3>` pass pipeline.

[optimization]
# Optimization level (0-3).  Forward-looking ‚Äî see note above.
# Default: 0 (use profile.opt_level instead).
# level = 2

# Enable size optimization (analogous to LLVM `-Os`).  Forward-looking.
# Default: false.
# size_opt = false

# Enable function-inlining hint.  Forward-looking ‚Äî current inlining
# is driven by `[codegen].inline_depth` (load-bearing) which maps to
# LLVM's per-function `inline-threshold` string attribute.
# Default: false.
# inline = false

# ============================================================================
# Link-Time Optimization (LTO) Configuration
# ============================================================================
#
# NOTE ‚Äî forward-looking section.  The parser (LtoConfig) recognises
# only `enabled` / `mode` today.  The ACTIVE LTO control is
# `[linker].lto = "thin" | "full"` (handled by
# verum_compiler::linker_config::LinkerSection ‚Äî load-bearing).
#
# Setting `[lto]` fields below logs a debug-trace observation but
# does NOT change linker behaviour.  `incremental` / `import_instr_limit`
# / `aggressive_inlining` / `enable_devirtualization` /
# `enable_global_dce` / `max_threads` / `cache_dir` are not parsed.

[lto]
# Enable LTO.  Forward-looking ‚Äî use `[linker].lto` instead.
# Default: false.
# enabled = false

# LTO mode: "thin" or "full".  Forward-looking.
# Default: unset.
# mode = "thin"

# ============================================================================
# Profile-Guided Optimization (PGO) Configuration
# ============================================================================
#
# NOTE ‚Äî forward-looking section.  The parser (PgoConfig) recognises
# only `enabled` / `profile_path` today.  PGO integration is not yet
# wired into the LLVM/MLIR backend.  Setting fields below logs a
# debug-trace observation but does NOT instrument the produced
# binary.  `mode` / `profile_dir` / `hot_threshold` /
# `enable_bb_reordering` / `hot_inline_multiplier` / `use_sampling`
# are not parsed.

[pgo]
# Enable PGO workflow.  Forward-looking.
# Default: false.
# enabled = false

# Path to profile data file (the .profraw or .profdata produced by
# a previous instrumented run).  Forward-looking.
# Default: unset.
# profile_path = "target/pgo/release.profdata"

# ============================================================================
# Cross-Compilation Configuration
# ============================================================================
#
# NOTE ‚Äî forward-looking section.  The parser (CrossCompileConfig)
# recognises only `target` / `sysroot` / `linker` today.  The ACTIVE
# cross-compile path goes through `[llvm].target_triple` (consumed
# by the LLVM backend at codegen) and the `--target` CLI flag.
# Setting `[cross_compile]` fields below logs a tracing::warn!
# observation but does NOT change toolchain invocation.
# `enabled` / `link_args` / `linking_strategy` / `strip_symbols` /
# `universal_binary` / `minimal_runtime` are not parsed.

[cross_compile]
# Target triple for cross-compilation.  Forward-looking ‚Äî use
# `[llvm].target_triple` instead.
# Default: unset.
# target = "aarch64-unknown-linux-gnu"

# Sysroot path for cross-compilation.  Forward-looking ‚Äî not yet
# wired into the toolchain invocation.
# Default: unset.
# sysroot = "/usr/aarch64-linux-gnu"

# Custom linker path.  Forward-looking.
# Default: unset.
# linker = "/usr/bin/aarch64-linux-gnu-gcc"

# ============================================================================
# Build Profiles
# ============================================================================

[profile.dev]
# Development profile - fast compilation, easy debugging
tier = 0  # Interpreter
verification = "runtime"
opt_level = 0
debug = true
debug_assertions = true
overflow_checks = true
lto = false
incremental = true
codegen_units = 256
cbgr_checks = "all"

[profile.release]
# Release profile - maximum performance
tier = 2  # AOT compilation
verification = "runtime"
opt_level = 3
debug = false
debug_assertions = false
overflow_checks = false
lto = true
incremental = false
codegen_units = 16
cbgr_checks = "optimized"

[profile.release-with-debug]
# Release with debug info (for profiling)
tier = 2
verification = "runtime"
opt_level = 3
debug = true  # Enable debug symbols
debug_assertions = false
overflow_checks = false
lto = true
incremental = false
codegen_units = 16
cbgr_checks = "optimized"

[profile.size]
# Size-optimized profile
tier = 2
verification = "runtime"
opt_level = 2  # Os optimization
debug = false
debug_assertions = false
overflow_checks = false
lto = true
incremental = false
codegen_units = 1
cbgr_checks = "optimized"

# ============================================================================
# Example recipes ‚Äî forward-looking sections
# ============================================================================
#
# The PGO / advanced cross-compile / aggressive-vectorize recipes that
# previously lived here referenced fields the parser does not yet
# accept (`inline_threshold` / `aggressive_inlining` / `mode = "fat"`
# / `hot_inline_multiplier` / `vectorization_strategy` etc.).  See
# the `[optimization]` / `[lto]` / `[pgo]` / `[cross_compile]`
# sections above for the load-bearing field set.  Recipe blocks
# will be reinstated once the corresponding parser surfaces land.
#
# Today the active production-tuning surfaces are:
#   * `[profile.<dev|release>].opt_level` ‚Äî controls LLVM's
#     `default<O0..O3>` pass pipeline.
#   * `[linker].lto = "thin" | "full"` ‚Äî controls link-time
#     optimization.
#   * `[llvm].target_triple` + `[llvm].target_cpu` +
#     `[llvm].target_features` ‚Äî controls codegen target.

# ============================================================================
# Dependencies
# ============================================================================

[dependencies]
verum_std = "0.1"

[dev_dependencies]

[build_dependencies]
