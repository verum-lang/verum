#![allow(
    dead_code,
    unused_imports,
    unused_variables,
    unused_mut,
    unused_must_use,
    unused_unsafe,
    deprecated,
    unexpected_cfgs,
    unused_comparisons,
    forgetting_copy_types,
    useless_ptr_null_checks,
    unused_assignments
)]
// Deref Protocol Implementation Tests
//
// Deref protocol: automatic dereferencing for reference types (&T, &checked T, &unsafe T)
//
// This test suite verifies the Deref protocol implementations for all three
// reference types: ManagedRef (ThinRef), CheckedRef, and UnsafeRef.
//
// Test categories:
// - Correctness: Verify correct dereferencing behavior
// - Safety: Verify safety checks (for ManagedRef)
// - Performance: Benchmark deref overhead
// - Edge cases: Null pointers, invalid references, etc.

use verum_types::references::{CheckedRef, CheckedRefMut, UnsafeRef, UnsafeRefMut};
use verum_cbgr_runtime::ThinRef;

// ==================== CheckedRef Tests ====================

#[test]
fn test_checked_ref_deref() {
    // CheckedRef zero-cost deref: &checked T dereferences with no runtime overhead (statically verified)
    let value = 42;
    let checked_ref = CheckedRef::from_ref(&value);

    // Test Deref
    assert_eq!(*checked_ref, 42);
    assert_eq!(*checked_ref, value);
}

#[test]
fn test_checked_ref_deref_string() {
    let s = "hello".to_string();
    let checked_ref = CheckedRef::from_ref(&s);

    assert_eq!(*checked_ref, "hello");
    assert_eq!(checked_ref.len(), 5);
}

#[test]
fn test_checked_ref_deref_struct() {
    #[derive(Debug, PartialEq)]
    struct Point {
        x: i32,
        y: i32,
    }

    let point = Point { x: 10, y: 20 };
    let checked_ref = CheckedRef::from_ref(&point);

    assert_eq!(checked_ref.x, 10);
    assert_eq!(checked_ref.y, 20);
    assert_eq!(*checked_ref, point);
}

#[test]
fn test_checked_ref_multiple_deref() {
    let value = 100;
    let checked_ref = CheckedRef::from_ref(&value);

    // Multiple dereferences should all work (zero-cost)
    for _ in 0..1000 {
        assert_eq!(*checked_ref, 100);
    }
}

#[test]
fn test_checked_ref_mut_deref() {
    // CheckedRefMut zero-cost deref: &checked mut T dereferences with no runtime overhead
    let mut value = 42;
    let checked_ref_mut = CheckedRefMut::from_mut(&mut value);

    // Test immutable deref
    assert_eq!(*checked_ref_mut, 42);
}

#[test]
fn test_checked_ref_mut_deref_mut() {
    let mut value = 42;
    let mut checked_ref_mut = CheckedRefMut::from_mut(&mut value);

    // Test mutable deref
    *checked_ref_mut = 100;
    assert_eq!(*checked_ref_mut, 100);
    assert_eq!(value, 100);
}

#[test]
fn test_checked_ref_mut_modify_string() {
    let mut s = "hello".to_string();
    let mut checked_ref_mut = CheckedRefMut::from_mut(&mut s);

    checked_ref_mut.push_str(" world");
    assert_eq!(*checked_ref_mut, "hello world");
    assert_eq!(s, "hello world");
}

#[test]
fn test_checked_ref_debug() {
    let value = 42;
    let checked_ref = CheckedRef::from_ref(&value);

    let debug_str = format!("{:?}", checked_ref);
    assert!(debug_str.contains("CheckedRef"));
}

#[test]
fn test_checked_ref_pointer() {
    let value = 42;
    let checked_ref = CheckedRef::from_ref(&value);

    let ptr_str = format!("{:p}", checked_ref);
    assert!(!ptr_str.is_empty());
}

// ==================== UnsafeRef Tests ====================

#[test]
fn test_unsafe_ref_deref() {
    // UnsafeRef zero-cost deref: &unsafe T dereferences with no checks (programmer responsibility)
    let value = 42;
    let unsafe_ref = unsafe { UnsafeRef::from_ref(&value) };

    // Test Deref
    assert_eq!(*unsafe_ref, 42);
    assert_eq!(*unsafe_ref, value);
}

#[test]
fn test_unsafe_ref_deref_string() {
    let s = "hello".to_string();
    let unsafe_ref = unsafe { UnsafeRef::from_ref(&s) };

    assert_eq!(*unsafe_ref, "hello");
    assert_eq!(unsafe_ref.len(), 5);
}

#[test]
fn test_unsafe_ref_deref_struct() {
    #[derive(Debug, PartialEq)]
    struct Point {
        x: i32,
        y: i32,
    }

    let point = Point { x: 10, y: 20 };
    let unsafe_ref = unsafe { UnsafeRef::from_ref(&point) };

    assert_eq!(unsafe_ref.x, 10);
    assert_eq!(unsafe_ref.y, 20);
    assert_eq!(*unsafe_ref, point);
}

#[test]
fn test_unsafe_ref_multiple_deref() {
    let value = 100;
    let unsafe_ref = unsafe { UnsafeRef::from_ref(&value) };

    // Multiple dereferences should all work (zero-cost)
    for _ in 0..1000 {
        assert_eq!(*unsafe_ref, 100);
