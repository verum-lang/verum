}

#[test]
fn test_unsafe_ref_mut_deref() {
    // UnsafeRefMut zero-cost deref: &unsafe mut T dereferences with no checks
    let mut value = 42;
    let unsafe_ref_mut = unsafe { UnsafeRefMut::from_mut(&mut value) };

    // Test immutable deref
    assert_eq!(*unsafe_ref_mut, 42);
