// =============================================================================
// core-tests/net/unix/regression_test.vr
// =============================================================================
//
// Regression pins for `core/net/unix.vr`. Live AF_UNIX operations
// (`UnixListener.bind` / `UnixStream.connect` / AsyncRead+Write /
// SO_PEERCRED query / SCM_RIGHTS FD-passing) require a path-based
// socket harness and are `@ignore`'d here — see `audit.md §3.1`
// for the harness gate.
//
// Active pins cover:
//
//   * UNIX-6 UnixError variant payload preservation across clones.
//   * UNIX-7 PeerCred negative-pid sentinel preserved through
//     record construction (POSIX kernels return -1 for unknown).
//   * UNIX-8 FdPassingError.NotImplemented stub marker — pinned
//     until the SCM_RIGHTS backend lands (audit.md §3.3).
//
// Pattern reference: `core-tests/net/cidr/regression_test.vr`.
// =============================================================================

mount core.net.unix.{UnixError, PeerCred, FdPassingError};

// =============================================================================
// UNIX-1 — UnixListener.bind(&Text path)
// =============================================================================

@ignore("UNIX-1: UnixListener.bind needs a path-based socket harness. See audit.md §3.1.")
@test
fn regression_unix_listener_bind_path() {
    assert(true);
}

// =============================================================================
// UNIX-2 — UnixStream.connect(&Text path)
// =============================================================================

@ignore("UNIX-2: UnixStream.connect needs a listening peer from harness. See audit.md §3.1.")
@test
fn regression_unix_stream_connect_path() {
    assert(true);
}

