// =============================================================================
// core-tests/net/quic/packet/unit_test.vr — RFC 9000 §17 packet types
// =============================================================================
//
// `core/net/quic/packet.vr`:
//
//   * LongPacketType 4-variant (Initial/ZeroRtt/Handshake/Retry) + to_bits
//     (RFC 9000 §17.2 long-header type bits).
//   * PacketError ADT.
// =============================================================================

mount core.net.quic.packet.{LongPacketType, PacketError};

// =============================================================================
// Section 1: long-header type bits (RFC 9000 §17.2)
// =============================================================================

@test
fn test_qpkt_initial_bits_00() { assert_eq(LongPacketType.Initial.to_bits(), 0b00_u8); }

@test
fn test_qpkt_zero_rtt_bits_01() { assert_eq(LongPacketType.ZeroRtt.to_bits(), 0b01_u8); }

@test
fn test_qpkt_handshake_bits_10() { assert_eq(LongPacketType.Handshake.to_bits(), 0b10_u8); }

@test
fn test_qpkt_retry_bits_11() { assert_eq(LongPacketType.Retry.to_bits(), 0b11_u8); }

@test
fn test_qpkt_type_bits_pairwise_distinct() {
    // The 4 long-header types occupy the 4 distinct 2-bit codepoints.
    assert(!(LongPacketType.Initial.to_bits() == LongPacketType.ZeroRtt.to_bits()));
    assert(!(LongPacketType.Initial.to_bits() == LongPacketType.Handshake.to_bits()));
    assert(!(LongPacketType.Initial.to_bits() == LongPacketType.Retry.to_bits()));
    assert(!(LongPacketType.ZeroRtt.to_bits() == LongPacketType.Handshake.to_bits()));
    assert(!(LongPacketType.ZeroRtt.to_bits() == LongPacketType.Retry.to_bits()));
    assert(!(LongPacketType.Handshake.to_bits() == LongPacketType.Retry.to_bits()));
}

@test
fn test_qpkt_type_bits_within_2_bits() {
    // Every code fits in 2 bits (≤ 3).
    assert(LongPacketType.Initial.to_bits() <= 3_u8);
    assert(LongPacketType.ZeroRtt.to_bits() <= 3_u8);
    assert(LongPacketType.Handshake.to_bits() <= 3_u8);
    assert(LongPacketType.Retry.to_bits() <= 3_u8);
}

fn main() {}
