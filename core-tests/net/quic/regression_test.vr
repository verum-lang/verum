// =============================================================================
// core-tests/net/quic/regression_test.vr
// =============================================================================
//
// LOCK-IN pins for `core/net/quic/`:
//
//   * Active pins fix wire-format constants — every TransportErrorCode
//     RFC 9000 §20.1 value + QUIC version IDs (RFC 9000 §15 + RFC 9369).
//     These flow directly into `quic_encode_into` / `quic_decode` and
//     are consumed by the recovery / connection state machine.
//
//   * `@ignore`'d pins document the functional surface (frame codec
//     round-trips, ACK + transport-parameter codec, packet-number
//     management, handshake state machine). See `audit.md §3.1` (QUIC-1)
//     and `§3.2` (QUIC-2 — v2 / multipath roadmap).
//
// =============================================================================

mount core.net.quic.version.{VERSION_NEGOTIATION, VERSION_1, VERSION_2,
                              is_supported, is_greased};
mount core.net.quic.error.{TransportErrorCode, ApplicationErrorCode, QuicError};
mount core.net.quic.frame.{QuicFrame, AckRange, EcnCounts, StreamFlags, FrameError};

// =============================================================================
// Section 1: Active LOCK-IN pins — QUIC version constants
// =============================================================================

@test
fn regression_quic_version_negotiation_pinned_0x00000000() {
    // RFC 9000 §17.2.1: Version Negotiation packets carry version=0.
    // The packet parser reads this literal to dispatch into the VN code path.
    assert_eq(VERSION_NEGOTIATION, 0x00000000_u32);
}

@test
fn regression_quic_v1_pinned_0x00000001() {
    // RFC 9000 §15: QUIC v1 wire version. Every endpoint negotiation
    // against an IETF QUIC v1 peer depends on this value.
    assert_eq(VERSION_1, 0x00000001_u32);
}

@test
fn regression_quic_v2_pinned_0x6B3343CF() {
    // RFC 9369: QUIC v2 wire version. The version-negotiation packet
    // codec must produce this exact value to be recognised by IETF
    // QUIC v2 peers (rustls, ngtcp2, quiche, msquic).
    assert_eq(VERSION_2, 0x6B3343CF_u32);
}

// =============================================================================
// Section 2: Active LOCK-IN pins — TransportErrorCode RFC 9000 §20.1 wire
// =============================================================================
//
// Each value is IANA-registered and locked-in here as a single-line
// regression pin. Drift would silently produce non-interoperable CLOSE
// frames against every standards-conformant QUIC peer.
// =============================================================================

@test
fn regression_quic_te_no_error_pinned_0x00() {
    // RFC 9000 §20.1: NO_ERROR — clean close.
    assert_eq(TransportErrorCode.NO_ERROR, 0x00_u64);
}

@test
fn regression_quic_te_protocol_violation_pinned_0x0A() {
    // RFC 9000 §20.1: PROTOCOL_VIOLATION — generic frame-decode failure
    // dispatch target.
    assert_eq(TransportErrorCode.PROTOCOL_VIOLATION, 0x0A_u64);
}

@test
fn regression_quic_te_crypto_error_base_pinned_0x0100() {
    // RFC 9000 §20.1: CRYPTO_ERROR_BASE — actual code is base + TLS
    // alert (so 0x0100 + 0x28 = 0x0128 maps to handshake_failure).
    assert_eq(TransportErrorCode.CRYPTO_ERROR_BASE, 0x0100_u64);
}

@test
fn regression_quic_te_no_viable_path_pinned_0x10() {
    // RFC 9000 §20.1: NO_VIABLE_PATH — multipath / migration failure.
    assert_eq(TransportErrorCode.NO_VIABLE_PATH, 0x10_u64);
}

@test
fn regression_quic_te_flow_control_error_pinned_0x03() {
    // RFC 9000 §20.1: FLOW_CONTROL_ERROR — receiver detected
    // peer exceeded a flow-control limit.
    assert_eq(TransportErrorCode.FLOW_CONTROL_ERROR, 0x03_u64);
}

// =============================================================================
// Section 3: Active LOCK-IN pins — predicate behaviour
// =============================================================================

@test
fn regression_quic_v1_is_supported_pinned() {
    // The pure-Verum v0.1 stdlib supports only VERSION_1 — explicit
    // pin so changes to is_supported are surfaced via diff.
    assert(is_supported(VERSION_1));
    assert(!is_supported(VERSION_2));
    assert(!is_supported(VERSION_NEGOTIATION));
}

// =============================================================================
// Section 4: @ignore'd functional pins — QUIC-1 codec + state machine
// =============================================================================

@ignore("QUIC-1: QuicFrame encode/decode round-trip requires harness. See audit.md §3.1.")
@test
fn regression_quic_frame_padding_round_trip() {
    // PADDING=0x00. Encode a PaddingRun(N) -> N x 0x00 bytes,
    // decode aggregates back to PaddingRun(N).
    let f = QuicFrame.PaddingRun(8);
    assert(f is QuicFrame.PaddingRun);
}

@ignore("QUIC-1: AckFrame range-set encode/decode requires harness. See audit.md §3.1.")
@test
fn regression_quic_ack_frame_with_ecn_round_trip() {
    // RFC 9000 §19.3: ACK with ECN counts (type 0x03 variant). Codec
    // round-trip gated on harness.
    let ranges: List<AckRange> = [];
    let ecn = Maybe.Some(EcnCounts { ect0: 0_u64, ect1: 0_u64, ce: 0_u64 });
    let f = QuicFrame.AckFrame {
        largest_acked: 100_u64,
        ack_delay: 0_u64,
        ranges: ranges,
        ecn: ecn,
    };
    assert(f is QuicFrame.AckFrame);
}

@ignore("QUIC-1: Connection state machine + 1-RTT data dispatch gated on harness. See audit.md §3.1.")
@test
fn regression_quic_connection_state_machine_dispatch() {
    // RFC 9000 §17.2 + connection_sm.vr: Initial → Handshake →
    // ZeroRtt → OneRtt typed state machine. End-to-end coverage at L2.
    assert(true);
}

@ignore("QUIC-1: Transport-parameter codec round-trip (RFC 9000 §18) deferred. See audit.md §3.1.")
@test
fn regression_quic_transport_parameter_codec_round_trip() {
    // RFC 9000 §18 — TransportParams encode + decode via varint codec.
    // The 19 well-known parameter IDs (0x00-0x10 + 0x20 +
    // 0x2ab2) live in `transport_params.vr` as module-private consts;
    // round-trip pinning requires either re-exporting them or testing
    // through the encode/decode API.
    assert(true);
}

@ignore("QUIC-2: RFC 9369 v2 dual-stack handshake support gated on stdlib. See audit.md §3.2.")
@test
fn regression_quic_v2_handshake_negotiation() {
    // VERSION_2 constant pinned (0x6B3343CF) but functional v2
    // handshake support (RFC 9369 §5 packet protection + label change
    // for initial salt) not yet wired.
    assert(true);
}

@ignore("QUIC-1: Multipath QUIC scheduler + path validation gated on harness. See audit.md §3.3.")
@test
fn regression_quic_multipath_scheduler_round_trip() {
    // IETF Multipath QUIC extension partial impl in multipath.vr.
    // End-to-end multipath frame dispatch covered at L2 specs.
    assert(true);
}
