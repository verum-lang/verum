// =============================================================================
// core-tests/net/quic/transport_params/unit_test.vr — RFC 9000 §18.2
// =============================================================================
//
// `core/net/quic/transport_params.vr`:
//
//   * Public bound constants: MAX_STREAMS_LIMIT (2^60), MAX_ACK_DELAY_EXPONENT
//     (20), MIN_ACTIVE_CID_LIMIT (2), MIN_MAX_UDP_PAYLOAD_SIZE (1200).
//   * TransportParams.defaults() satisfies bounds_ok().
// =============================================================================

mount core.net.quic.transport_params.{
    TransportParams, MAX_STREAMS_LIMIT, MAX_ACK_DELAY_EXPONENT,
    MIN_ACTIVE_CID_LIMIT, MIN_MAX_UDP_PAYLOAD_SIZE
};

// =============================================================================
// Section 1: RFC 9000 §18.2 / §22 bound constants
// =============================================================================

@test
fn test_qtp_max_streams_limit_2_pow_60() {
    // RFC 9000 §18.2: MAX_STREAMS transport params must not exceed 2^60.
    assert_eq(MAX_STREAMS_LIMIT, 1152921504606846976_u64);
}

@test
fn test_qtp_max_ack_delay_exponent_20() {
    // RFC 9000 §18.2: ack_delay_exponent MUST NOT exceed 20.
    assert_eq(MAX_ACK_DELAY_EXPONENT, 20_u8);
}

@test
fn test_qtp_min_active_cid_limit_2() {
    // RFC 9000 §18.2: active_connection_id_limit MUST be at least 2.
    assert_eq(MIN_ACTIVE_CID_LIMIT, 2_u64);
}

@test
fn test_qtp_min_max_udp_payload_size_1200() {
    // RFC 9000 §18.2: max_udp_payload_size MUST be at least 1200.
    assert_eq(MIN_MAX_UDP_PAYLOAD_SIZE, 1200_u64);
}

// =============================================================================
// Section 2: defaults satisfy bounds
// =============================================================================

@test
fn test_qtp_defaults_bounds_ok() {
    let tp = TransportParams.defaults();
    assert(tp.bounds_ok());
}

fn main() {}
