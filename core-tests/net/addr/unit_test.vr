// =============================================================================
// core-tests/net/addr/unit_test.vr
// =============================================================================
//
// `core/net/addr.vr` — IP address primitives.
//   * Ipv4Addr: new / localhost / unspecified / broadcast + octets +
//     is_loopback / is_unspecified / is_private / is_multicast /
//     is_broadcast + to_u32 / from_u32 + parse
//   * Ipv6Addr: new / localhost / unspecified + segments + octets +
//     is_loopback / is_unspecified / is_multicast / is_link_local /
//     is_unique_local + parse (full + compressed + ipv4-mapped)
//   * IpAddr: v4 / v6 + is_ipv4 / is_ipv6 + is_loopback /
//     is_unspecified / is_multicast
//   * SocketAddrV4 / SocketAddrV6: new + ip + port + set_port (V4)
//   * SocketAddr: new_v4 / new_v6 / ip / port + is_ipv4 / is_ipv6 /
//     parse / from_text
//   * AddrParseError: InvalidFormat / InvalidOctet / InvalidPort
//     disjoint + Display + Debug
// =============================================================================

mount core.net.addr.{Ipv4Addr, Ipv6Addr, IpAddr, SocketAddrV4, SocketAddrV6, SocketAddr, AddrParseError};
mount core.base.result.{Result, Ok, Err};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: Ipv4Addr.new + octets accessor
// =============================================================================

@test
fn test_ipv4_new_preserves_octets() {
    let a = Ipv4Addr.new(192_u8, 168_u8, 1_u8, 100_u8);
    let (o0, o1, o2, o3) = a.octets();
    assert_eq(o0, 192_u8);
    assert_eq(o1, 168_u8);
    assert_eq(o2, 1_u8);
    assert_eq(o3, 100_u8);
}

@test
fn test_ipv4_new_zero() {
    let a = Ipv4Addr.new(0_u8, 0_u8, 0_u8, 0_u8);
    let (o0, _, _, _) = a.octets();
    assert_eq(o0, 0_u8);
}

@test
fn test_ipv4_new_max() {
    let a = Ipv4Addr.new(255_u8, 255_u8, 255_u8, 255_u8);
    let (_, _, _, o3) = a.octets();
    assert_eq(o3, 255_u8);
}

// =============================================================================
// Section 2: Canonical Ipv4 addresses
// =============================================================================

@test
fn test_localhost_is_127_0_0_1() {
    let l = Ipv4Addr.localhost();
    let (o0, o1, o2, o3) = l.octets();
    assert_eq(o0, 127_u8);
    assert_eq(o1, 0_u8);
    assert_eq(o2, 0_u8);
    assert_eq(o3, 1_u8);
}

@test
fn test_unspecified_is_0_0_0_0() {
    let u = Ipv4Addr.unspecified();
    let (o0, o1, o2, o3) = u.octets();
    assert_eq(o0, 0_u8);
    assert_eq(o1, 0_u8);
    assert_eq(o2, 0_u8);
    assert_eq(o3, 0_u8);
}

@test
fn test_broadcast_is_255_255_255_255() {
    let b = Ipv4Addr.broadcast();
    let (o0, o1, o2, o3) = b.octets();
    assert_eq(o0, 255_u8);
    assert_eq(o1, 255_u8);
    assert_eq(o2, 255_u8);
    assert_eq(o3, 255_u8);
}

// =============================================================================
// Section 3: is_loopback — RFC 5735 §3 loopback 127.0.0.0/8
// =============================================================================

@test
fn test_is_loopback_127_0_0_1() {
    assert(Ipv4Addr.localhost().is_loopback());
}

@test
fn test_is_loopback_127_anything() {
    assert(Ipv4Addr.new(127_u8, 0_u8, 0_u8, 1_u8).is_loopback());
    assert(Ipv4Addr.new(127_u8, 255_u8, 255_u8, 254_u8).is_loopback());
}

@test
fn test_is_not_loopback_public() {
    assert(!Ipv4Addr.new(8_u8, 8_u8, 8_u8, 8_u8).is_loopback());
    assert(!Ipv4Addr.new(192_u8, 168_u8, 1_u8, 1_u8).is_loopback());
}

// =============================================================================
// Section 4: is_unspecified — only 0.0.0.0
// =============================================================================

@test
fn test_is_unspecified_zero() {
    assert(Ipv4Addr.unspecified().is_unspecified());
}

@test
fn test_is_not_unspecified_localhost() {
    assert(!Ipv4Addr.localhost().is_unspecified());
}

// =============================================================================
// Section 5: is_private — RFC 1918 ranges
// =============================================================================

@test
fn test_is_private_10_0_0_0() {
    assert(Ipv4Addr.new(10_u8, 0_u8, 0_u8, 1_u8).is_private());
    assert(Ipv4Addr.new(10_u8, 255_u8, 255_u8, 254_u8).is_private());
}

@test
fn test_is_private_172_16_to_31() {
    assert(Ipv4Addr.new(172_u8, 16_u8, 0_u8, 0_u8).is_private());
    assert(Ipv4Addr.new(172_u8, 20_u8, 1_u8, 1_u8).is_private());
    assert(Ipv4Addr.new(172_u8, 31_u8, 255_u8, 255_u8).is_private());
}

@test
fn test_is_not_private_172_15() {
    assert(!Ipv4Addr.new(172_u8, 15_u8, 0_u8, 0_u8).is_private());
}

@test
fn test_is_not_private_172_32() {
    assert(!Ipv4Addr.new(172_u8, 32_u8, 0_u8, 0_u8).is_private());
}

@test
fn test_is_private_192_168() {
    assert(Ipv4Addr.new(192_u8, 168_u8, 0_u8, 1_u8).is_private());
    assert(Ipv4Addr.new(192_u8, 168_u8, 255_u8, 254_u8).is_private());
}

@test
fn test_is_not_private_192_167() {
    assert(!Ipv4Addr.new(192_u8, 167_u8, 0_u8, 0_u8).is_private());
}

@test
fn test_is_not_private_8_8_8_8() {
    assert(!Ipv4Addr.new(8_u8, 8_u8, 8_u8, 8_u8).is_private());
}

// =============================================================================
// Section 6: is_multicast — RFC 5771 224.0.0.0/4
// =============================================================================

@test
fn test_is_multicast_224() {
    assert(Ipv4Addr.new(224_u8, 0_u8, 0_u8, 1_u8).is_multicast());
    assert(Ipv4Addr.new(239_u8, 255_u8, 255_u8, 254_u8).is_multicast());
}

@test
fn test_is_not_multicast_223() {
    assert(!Ipv4Addr.new(223_u8, 255_u8, 255_u8, 255_u8).is_multicast());
}

@test
fn test_is_not_multicast_240() {
    assert(!Ipv4Addr.new(240_u8, 0_u8, 0_u8, 0_u8).is_multicast());
}

// =============================================================================
// Section 7: is_broadcast — only 255.255.255.255
// =============================================================================

@test
fn test_is_broadcast_global() {
    assert(Ipv4Addr.broadcast().is_broadcast());
}

@test
fn test_is_not_broadcast_subnet_max() {
    assert(!Ipv4Addr.new(192_u8, 168_u8, 1_u8, 255_u8).is_broadcast());
}

// =============================================================================
// Section 8: to_u32 / from_u32 round-trip
// =============================================================================

@test
fn test_to_u32_localhost() {
    let l = Ipv4Addr.localhost();
    assert_eq(l.to_u32(), 0x7F000001);
}

@test
fn test_to_u32_zero() {
    assert_eq(Ipv4Addr.unspecified().to_u32(), 0);
}

@test
fn test_to_u32_broadcast() {
    let b = Ipv4Addr.broadcast();
    assert_eq(b.to_u32(), 0xFFFFFFFF);
}

@test
fn test_from_u32_localhost() {
    let l = Ipv4Addr.from_u32(0x7F000001);
    let (o0, _, _, o3) = l.octets();
    assert_eq(o0, 127_u8);
    assert_eq(o3, 1_u8);
}

@test
fn test_to_from_u32_round_trip() {
    let original = Ipv4Addr.new(10_u8, 0_u8, 0_u8, 1_u8);
    let bits = original.to_u32();
    let recovered = Ipv4Addr.from_u32(bits);
    let (a, b, c, d) = recovered.octets();
    assert_eq(a, 10_u8);
    assert_eq(b, 0_u8);
    assert_eq(c, 0_u8);
    assert_eq(d, 1_u8);
}

// =============================================================================
// Section 9: Ipv4Addr.parse — happy paths
// =============================================================================

@test
fn test_parse_ipv4_localhost() {
    let s = "127.0.0.1".clone();
    match Ipv4Addr.parse(&s) {
        Ok(a) => {
            let (o0, o1, o2, o3) = a.octets();
            assert_eq(o0, 127_u8);
            assert_eq(o1, 0_u8);
            assert_eq(o2, 0_u8);
            assert_eq(o3, 1_u8);
        }
        Err(_) => panic("127.0.0.1 should parse"),
    }
}

@test
fn test_parse_ipv4_private() {
    let s = "192.168.1.100".clone();
    match Ipv4Addr.parse(&s) {
        Ok(a) => {
            let (o0, o1, o2, o3) = a.octets();
            assert_eq(o0, 192_u8);
            assert_eq(o1, 168_u8);
            assert_eq(o2, 1_u8);
            assert_eq(o3, 100_u8);
        }
        Err(_) => panic("192.168.1.100 should parse"),
    }
}

@test
fn test_parse_ipv4_zero() {
    let s = "0.0.0.0".clone();
    match Ipv4Addr.parse(&s) {
        Ok(a) => assert(a.is_unspecified()),
        Err(_) => panic("0.0.0.0 should parse"),
    }
}

@test
fn test_parse_ipv4_max() {
    let s = "255.255.255.255".clone();
    match Ipv4Addr.parse(&s) {
        Ok(a) => assert(a.is_broadcast()),
        Err(_) => panic("255.255.255.255 should parse"),
    }
}

// =============================================================================
// Section 10: Ipv4Addr.parse — error paths
// =============================================================================

@test
fn test_parse_ipv4_too_few_segments() {
    let s = "1.2.3".clone();
    match Ipv4Addr.parse(&s) {
        Ok(_) => panic("`1.2.3` must reject"),
        Err(e) => assert(e == AddrParseError.InvalidFormat),
    }
}

@test
fn test_parse_ipv4_too_many_segments() {
    let s = "1.2.3.4.5".clone();
    match Ipv4Addr.parse(&s) {
        Ok(_) => panic("`1.2.3.4.5` must reject"),
        Err(e) => assert(e == AddrParseError.InvalidFormat),
    }
}

@test
fn test_parse_ipv4_octet_overflow() {
    let s = "256.0.0.0".clone();
    match Ipv4Addr.parse(&s) {
        Ok(_) => panic("256.x.x.x must reject"),
        Err(e) => assert(e == AddrParseError.InvalidOctet),
    }
}

@test
fn test_parse_ipv4_non_numeric() {
    let s = "a.b.c.d".clone();
    match Ipv4Addr.parse(&s) {
        Ok(_) => panic("non-numeric must reject"),
        Err(e) => assert(e == AddrParseError.InvalidOctet),
    }
}

@test
fn test_parse_ipv4_empty() {
    let s = "".clone();
    match Ipv4Addr.parse(&s) {
        Ok(_) => panic("empty must reject"),
        Err(_) => assert(true),
    }
}

// =============================================================================
// Section 11: Ipv6Addr.new + segments
// =============================================================================

@test
fn test_ipv6_new_segments() {
    let a = Ipv6Addr.new(0x2001, 0x0db8, 0x85a3, 0, 0, 0x8a2e, 0x0370, 0x7334);
    let (s0, _, _, _, _, _, _, s7) = a.segments();
    assert_eq(s0, 0x2001);
    assert_eq(s7, 0x7334);
}

@test
fn test_ipv6_localhost_is_one() {
    let l = Ipv6Addr.localhost();
    let (s0, s1, s2, s3, s4, s5, s6, s7) = l.segments();
    assert_eq(s0, 0);
    assert_eq(s1, 0);
    assert_eq(s2, 0);
    assert_eq(s3, 0);
    assert_eq(s4, 0);
    assert_eq(s5, 0);
    assert_eq(s6, 0);
    assert_eq(s7, 1);
}

@test
fn test_ipv6_unspecified_all_zero() {
    let u = Ipv6Addr.unspecified();
    let (s0, _, _, _, _, _, _, s7) = u.segments();
    assert_eq(s0, 0);
    assert_eq(s7, 0);
}

// =============================================================================
// Section 12: Ipv6Addr predicates
// =============================================================================

@test
fn test_ipv6_is_loopback_localhost() {
    assert(Ipv6Addr.localhost().is_loopback());
}

@test
fn test_ipv6_is_not_loopback_other() {
    assert(!Ipv6Addr.new(0x2001, 0xdb8, 0, 0, 0, 0, 0, 1).is_loopback());
}

@test
fn test_ipv6_is_unspecified_zero() {
    assert(Ipv6Addr.unspecified().is_unspecified());
}

@test
fn test_ipv6_is_not_unspecified_one() {
    assert(!Ipv6Addr.localhost().is_unspecified());
}

@test
fn test_ipv6_is_multicast_ff00() {
    assert(Ipv6Addr.new(0xff00, 0, 0, 0, 0, 0, 0, 1).is_multicast());
    assert(Ipv6Addr.new(0xff02, 0, 0, 0, 0, 0, 0, 1).is_multicast());
}

@test
fn test_ipv6_is_not_multicast_2001() {
    assert(!Ipv6Addr.new(0x2001, 0xdb8, 0, 0, 0, 0, 0, 1).is_multicast());
}

@test
fn test_ipv6_is_link_local_fe80() {
    assert(Ipv6Addr.new(0xfe80, 0, 0, 0, 0, 0, 0, 1).is_link_local());
}

@test
fn test_ipv6_is_not_link_local_fe90() {
    assert(!Ipv6Addr.new(0xfe90, 0, 0, 0, 0, 0, 0, 1).is_link_local());
}

@test
fn test_ipv6_is_unique_local_fc00() {
    assert(Ipv6Addr.new(0xfc00, 0, 0, 0, 0, 0, 0, 1).is_unique_local());
    assert(Ipv6Addr.new(0xfd00, 0, 0, 0, 0, 0, 0, 1).is_unique_local());
}

@test
fn test_ipv6_is_not_unique_local_fe00() {
    assert(!Ipv6Addr.new(0xfe00, 0, 0, 0, 0, 0, 0, 1).is_unique_local());
}

// =============================================================================
// Section 13: Ipv6Addr.octets — 16-byte form
// =============================================================================

@test
fn test_ipv6_octets_localhost() {
    let l = Ipv6Addr.localhost();
    let o = l.octets();
    assert_eq(o[0], 0_u8);
    assert_eq(o[14], 0_u8);
    assert_eq(o[15], 1_u8);
}

@test
fn test_ipv6_octets_big_endian_segment() {
    // Segment 0 = 0x2001 → octets [0]=0x20, [1]=0x01
    let a = Ipv6Addr.new(0x2001, 0, 0, 0, 0, 0, 0, 0);
    let o = a.octets();
    assert_eq(o[0], 0x20_u8);
    assert_eq(o[1], 0x01_u8);
}

// =============================================================================
// Section 14: Ipv6Addr.parse — happy paths
// =============================================================================

@test
fn test_parse_ipv6_localhost_compressed() {
    let s = "::1".clone();
    match Ipv6Addr.parse(&s) {
        Ok(a) => assert(a.is_loopback()),
        Err(_) => panic("::1 should parse"),
    }
}

@test
fn test_parse_ipv6_unspecified_compressed() {
    let s = "::".clone();
    match Ipv6Addr.parse(&s) {
        Ok(a) => assert(a.is_unspecified()),
        Err(_) => panic(":: should parse"),
    }
}

@test
fn test_parse_ipv6_full_notation() {
    let s = "2001:0db8:85a3:0000:0000:8a2e:0370:7334".clone();
    match Ipv6Addr.parse(&s) {
        Ok(a) => {
            let (s0, _, _, _, _, _, _, s7) = a.segments();
            assert_eq(s0, 0x2001);
            assert_eq(s7, 0x7334);
        }
        Err(_) => panic("full ipv6 should parse"),
    }
}

@test
fn test_parse_ipv6_compressed_middle() {
    let s = "2001:db8::1".clone();
    match Ipv6Addr.parse(&s) {
        Ok(a) => {
            let (s0, s1, s2, _, _, _, _, s7) = a.segments();
            assert_eq(s0, 0x2001);
            assert_eq(s1, 0x0db8);
            assert_eq(s2, 0);
            assert_eq(s7, 1);
        }
        Err(_) => panic("2001:db8::1 should parse"),
    }
}

// =============================================================================
// Section 15: Ipv6Addr.parse — error paths
// =============================================================================

@test
fn test_parse_ipv6_empty() {
    let s = "".clone();
    match Ipv6Addr.parse(&s) {
        Ok(_) => panic("empty must reject"),
        Err(_) => assert(true),
    }
}

@test
fn test_parse_ipv6_double_double_colon() {
    let s = "1::2::3".clone();
    match Ipv6Addr.parse(&s) {
        Ok(_) => panic("two `::` must reject (RFC 4291)"),
        Err(_) => assert(true),
    }
}

@test
fn test_parse_ipv6_invalid_hex() {
    let s = "xyzg::1".clone();
    match Ipv6Addr.parse(&s) {
        Ok(_) => panic("non-hex must reject"),
        Err(_) => assert(true),
    }
}

// =============================================================================
// Section 16: IpAddr — construction + ipv4/ipv6 discriminator
// =============================================================================

@test
fn test_ip_addr_v4_construction() {
    let a = IpAddr.v4(127_u8, 0_u8, 0_u8, 1_u8);
    assert(a.is_ipv4());
    assert(!a.is_ipv6());
}

@test
fn test_ip_addr_v6_construction() {
    let a = IpAddr.v6(0, 0, 0, 0, 0, 0, 0, 1);
    assert(!a.is_ipv4());
    assert(a.is_ipv6());
}

@test
fn test_ip_addr_v4_is_loopback() {
    let a = IpAddr.v4(127_u8, 0_u8, 0_u8, 1_u8);
    assert(a.is_loopback());
}

@test
fn test_ip_addr_v6_is_loopback() {
    let a = IpAddr.v6(0, 0, 0, 0, 0, 0, 0, 1);
    assert(a.is_loopback());
}

@test
fn test_ip_addr_v4_is_unspecified() {
    let a = IpAddr.v4(0_u8, 0_u8, 0_u8, 0_u8);
    assert(a.is_unspecified());
}

@test
fn test_ip_addr_v6_is_unspecified() {
    let a = IpAddr.v6(0, 0, 0, 0, 0, 0, 0, 0);
    assert(a.is_unspecified());
}

@test
fn test_ip_addr_v4_is_multicast() {
    let a = IpAddr.v4(224_u8, 0_u8, 0_u8, 1_u8);
    assert(a.is_multicast());
}

@test
fn test_ip_addr_v6_is_multicast() {
    let a = IpAddr.v6(0xff00, 0, 0, 0, 0, 0, 0, 1);
    assert(a.is_multicast());
}

// =============================================================================
// Section 17: SocketAddrV4 — construction + accessors
// =============================================================================

@test
fn test_socket_addr_v4_new() {
    let s = SocketAddrV4.new(Ipv4Addr.localhost(), 8080);
    assert_eq(s.port(), 8080);
}

@test
fn test_socket_addr_v4_port_zero() {
    let s = SocketAddrV4.new(Ipv4Addr.unspecified(), 0);
    assert_eq(s.port(), 0);
}

@test
fn test_socket_addr_v4_port_max() {
    let s = SocketAddrV4.new(Ipv4Addr.localhost(), 65535);
    assert_eq(s.port(), 65535);
}

@test
fn test_socket_addr_v4_set_port() {
    let mut s = SocketAddrV4.new(Ipv4Addr.localhost(), 80);
    s.set_port(8443);
    assert_eq(s.port(), 8443);
}

// =============================================================================
// Section 18: SocketAddrV6 — construction + accessors
// =============================================================================

@test
fn test_socket_addr_v6_new() {
    let s = SocketAddrV6.new(Ipv6Addr.localhost(), 8080, 0, 0);
    assert_eq(s.port(), 8080);
}

@test
fn test_socket_addr_v6_port_max() {
    let s = SocketAddrV6.new(Ipv6Addr.localhost(), 65535, 0, 0);
    assert_eq(s.port(), 65535);
}

// =============================================================================
// Section 19: SocketAddr — discriminator + accessors
// =============================================================================

@test
fn test_socket_addr_new_v4_is_ipv4() {
    let s = SocketAddr.new_v4(Ipv4Addr.localhost(), 80);
    assert(s.is_ipv4());
    assert(!s.is_ipv6());
}

@test
fn test_socket_addr_new_v6_is_ipv6() {
    let s = SocketAddr.new_v6(Ipv6Addr.localhost(), 80);
    assert(!s.is_ipv4());
    assert(s.is_ipv6());
}

@test
fn test_socket_addr_v4_port() {
    let s = SocketAddr.new_v4(Ipv4Addr.localhost(), 443);
    assert_eq(s.port(), 443);
}

@test
fn test_socket_addr_v6_port() {
    let s = SocketAddr.new_v6(Ipv6Addr.localhost(), 443);
    assert_eq(s.port(), 443);
}

// =============================================================================
// Section 20: SocketAddr.parse — happy paths
// =============================================================================

@test
fn test_socket_addr_parse_ipv4() {
    let s = "127.0.0.1:8080".clone();
    match SocketAddr.parse(&s) {
        Ok(a) => {
            assert(a.is_ipv4());
            assert_eq(a.port(), 8080);
        }
        Err(_) => panic("127.0.0.1:8080 should parse"),
    }
}

@test
fn test_socket_addr_parse_ipv6_bracketed() {
    let s = "[::1]:8080".clone();
    match SocketAddr.parse(&s) {
        Ok(a) => {
            assert(a.is_ipv6());
            assert_eq(a.port(), 8080);
        }
        Err(_) => panic("[::1]:8080 should parse"),
    }
}

@test
fn test_socket_addr_parse_port_zero() {
    let s = "0.0.0.0:0".clone();
    match SocketAddr.parse(&s) {
        Ok(a) => assert_eq(a.port(), 0),
        Err(_) => panic("0.0.0.0:0 should parse"),
    }
}

@test
fn test_socket_addr_parse_port_max() {
    let s = "0.0.0.0:65535".clone();
    match SocketAddr.parse(&s) {
        Ok(a) => assert_eq(a.port(), 65535),
        Err(_) => panic("port 65535 should parse"),
    }
}

@test
fn test_socket_addr_from_text_alias() {
    let s = "127.0.0.1:80".clone();
    match SocketAddr.from_text(&s) {
        Ok(a) => assert_eq(a.port(), 80),
        Err(_) => panic("from_text should mirror parse"),
    }
}

// =============================================================================
// Section 21: SocketAddr.parse — error paths
// =============================================================================

@test
fn test_socket_addr_parse_no_port() {
    let s = "127.0.0.1".clone();
    match SocketAddr.parse(&s) {
        Ok(_) => panic("no port must reject"),
        Err(_) => assert(true),
    }
}

@test
fn test_socket_addr_parse_port_overflow() {
    let s = "127.0.0.1:99999".clone();
    match SocketAddr.parse(&s) {
        Ok(_) => panic("port > 65535 must reject"),
        Err(e) => assert(e == AddrParseError.InvalidPort),
    }
}

@test
fn test_socket_addr_parse_negative_port() {
    let s = "127.0.0.1:-1".clone();
    match SocketAddr.parse(&s) {
        Ok(_) => panic("negative port must reject"),
        Err(_) => assert(true),
    }
}

@test
fn test_socket_addr_parse_non_numeric_port() {
    let s = "127.0.0.1:http".clone();
    match SocketAddr.parse(&s) {
        Ok(_) => panic("non-numeric port must reject"),
        Err(e) => assert(e == AddrParseError.InvalidPort),
    }
}

// =============================================================================
// Section 22: AddrParseError — variant disjointness + Eq
// =============================================================================

@test
fn test_addr_parse_error_invalid_format_eq() {
    assert(AddrParseError.InvalidFormat == AddrParseError.InvalidFormat);
}

@test
fn test_addr_parse_error_invalid_octet_eq() {
    assert(AddrParseError.InvalidOctet == AddrParseError.InvalidOctet);
}

@test
fn test_addr_parse_error_invalid_port_eq() {
    assert(AddrParseError.InvalidPort == AddrParseError.InvalidPort);
}

@test
fn test_addr_parse_error_disjoint_format_vs_octet() {
    assert(!(AddrParseError.InvalidFormat == AddrParseError.InvalidOctet));
}

@test
fn test_addr_parse_error_disjoint_format_vs_port() {
    assert(!(AddrParseError.InvalidFormat == AddrParseError.InvalidPort));
}

@test
fn test_addr_parse_error_disjoint_octet_vs_port() {
    assert(!(AddrParseError.InvalidOctet == AddrParseError.InvalidPort));
}
