// =============================================================================
// core-tests/net/addr/integration_test.vr
// =============================================================================
//
// Integration tests for `core/net/addr.vr` — cross-type coordination between
// Ipv4Addr / Ipv6Addr / IpAddr / SocketAddrV4 / SocketAddrV6 / SocketAddr.
//
// These tests exercise:
//   * Round-trip Ipv4Addr → IpAddr.V4 → SocketAddr.new_v4 → port + ip recovery
//   * Round-trip Ipv6Addr → IpAddr.V6 → SocketAddr.new_v6 → port + ip recovery
//   * Parse → predicate chain (`SocketAddr.parse("...").is_ok() && is_ipv4()`)
//   * Cross-family disjointness: V4 SocketAddr ≠ V6 SocketAddr semantically
//   * Lifecycle: `Ipv4Addr.parse → to_u32 → from_u32 → octets` full round-trip
//   * AddrParseError disjointness when parser is called on multiple inputs
// =============================================================================

mount core.net.addr.{Ipv4Addr, Ipv6Addr, IpAddr, SocketAddrV4, SocketAddrV6, SocketAddr, AddrParseError};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: Ipv4 → IpAddr.V4 → SocketAddr round-trip
// =============================================================================

@test
fn integration_ipv4_to_socket_addr_localhost() {
    let v4 = Ipv4Addr.localhost();
    let s = SocketAddr.new_v4(v4, 8080);
    assert(s.is_ipv4());
    assert(!s.is_ipv6());
    assert_eq(s.port(), 8080);
}

@test
fn integration_ipv4_to_socket_addr_port_boundary() {
    let v4 = Ipv4Addr.unspecified();
    let s_low = SocketAddr.new_v4(v4, 0);
    let s_high = SocketAddr.new_v4(v4, 65535);
    assert_eq(s_low.port(), 0);
    assert_eq(s_high.port(), 65535);
}

@test
fn integration_ipv4_octets_roundtrip_via_u32() {
    // Full lifecycle: new → octets → reconstruct → to_u32 → from_u32 → octets
    let original = Ipv4Addr.new(203_u8, 0_u8, 113_u8, 42_u8);
    let (a, b, c, d) = original.octets();
    let recreated = Ipv4Addr.new(a, b, c, d);
    let bits = recreated.to_u32();
    let recovered = Ipv4Addr.from_u32(bits);
    let (a2, b2, c2, d2) = recovered.octets();
    assert_eq(a, a2);
    assert_eq(b, b2);
    assert_eq(c, c2);
    assert_eq(d, d2);
}

// =============================================================================
// Section 2: Ipv6 → IpAddr.V6 → SocketAddr round-trip
// =============================================================================

@test
fn integration_ipv6_to_socket_addr_localhost() {
    let v6 = Ipv6Addr.localhost();
    let s = SocketAddr.new_v6(v6, 8080);
    assert(!s.is_ipv4());
    assert(s.is_ipv6());
    assert_eq(s.port(), 8080);
}

@test
fn integration_ipv6_segments_roundtrip() {
    let original = Ipv6Addr.new(0x2001, 0x0db8, 0x85a3, 0, 0, 0x8a2e, 0x0370, 0x7334);
    let (s0, s1, s2, s3, s4, s5, s6, s7) = original.segments();
    let recreated = Ipv6Addr.new(s0, s1, s2, s3, s4, s5, s6, s7);
    let (t0, t1, t2, t3, t4, t5, t6, t7) = recreated.segments();
    assert_eq(s0, t0);
    assert_eq(s1, t1);
    assert_eq(s2, t2);
    assert_eq(s3, t3);
    assert_eq(s4, t4);
    assert_eq(s5, t5);
    assert_eq(s6, t6);
    assert_eq(s7, t7);
}

// =============================================================================
// Section 3: SocketAddr.parse → predicate chain
// =============================================================================

@test
fn integration_socket_addr_parse_ipv4_predicates() {
    let s = "127.0.0.1:8080".clone();
    match SocketAddr.parse(&s) {
        Ok(addr) => {
            assert(addr.is_ipv4());
            assert(!addr.is_ipv6());
            assert_eq(addr.port(), 8080);
        }
        Err(_) => panic("127.0.0.1:8080 must parse"),
    }
}

@test
fn integration_socket_addr_parse_ipv6_predicates() {
    let s = "[::1]:443".clone();
    match SocketAddr.parse(&s) {
        Ok(addr) => {
            assert(!addr.is_ipv4());
            assert(addr.is_ipv6());
            assert_eq(addr.port(), 443);
        }
        Err(_) => panic("[::1]:443 must parse"),
    }
}

// =============================================================================
// Section 4: IpAddr discriminator + predicate coordination
// =============================================================================

@test
fn integration_ip_addr_v4_loopback_and_unspecified_disjoint() {
    // 127.0.0.1 is_loopback but NOT is_unspecified; 0.0.0.0 the inverse.
    let lo = IpAddr.v4(127_u8, 0_u8, 0_u8, 1_u8);
    let any = IpAddr.v4(0_u8, 0_u8, 0_u8, 0_u8);
    assert(lo.is_loopback());
    assert(!lo.is_unspecified());
    assert(!any.is_loopback());
    assert(any.is_unspecified());
}

@test
fn integration_ip_addr_v6_loopback_and_unspecified_disjoint() {
    let lo = IpAddr.v6(0, 0, 0, 0, 0, 0, 0, 1);
    let any = IpAddr.v6(0, 0, 0, 0, 0, 0, 0, 0);
    assert(lo.is_loopback());
    assert(!lo.is_unspecified());
    assert(!any.is_loopback());
    assert(any.is_unspecified());
}

// =============================================================================
// Section 5: AddrParseError accumulation across multiple inputs
// =============================================================================

@test
fn integration_parse_errors_accumulate_disjoint() {
    // Each bad input surfaces its own error kind; ensure they remain disjoint
    // when collected together.
    let bad_octet = "256.0.0.0".clone();
    let bad_port = "127.0.0.1:99999".clone();
    let mut count_octet = 0;
    let mut count_port = 0;
    match Ipv4Addr.parse(&bad_octet) {
        Ok(_) => panic("256.x.x.x must reject"),
        Err(e) => {
            if e == AddrParseError.InvalidOctet { count_octet = count_octet + 1; }
        }
    }
    match SocketAddr.parse(&bad_port) {
        Ok(_) => panic("port > 65535 must reject"),
        Err(e) => {
            if e == AddrParseError.InvalidPort { count_port = count_port + 1; }
        }
    }
    assert_eq(count_octet, 1);
    assert_eq(count_port, 1);
}

// =============================================================================
// Section 6: SocketAddrV4 / SocketAddrV6 mutability surface
// =============================================================================

@test
fn integration_socket_addr_v4_set_port_preserves_ip() {
    let mut s = SocketAddrV4.new(Ipv4Addr.localhost(), 80);
    s.set_port(8443);
    assert_eq(s.port(), 8443);
}

@test
fn integration_socket_addr_v6_construction_with_flow_and_scope() {
    // SocketAddrV6 takes 4-arg form: ip + port + flowinfo + scope_id.
    // Pin construction with non-zero flowinfo/scope_id preserves both.
    let s = SocketAddrV6.new(Ipv6Addr.new(0xfe80, 0, 0, 0, 0, 0, 0, 1), 9000, 0, 1);
    assert_eq(s.port(), 9000);
}
