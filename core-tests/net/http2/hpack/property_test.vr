// =============================================================================
// core-tests/net/http2/hpack/property_test.vr — RFC 7541 algebraic laws
// =============================================================================
//
// Laws, not examples:
//
//   * Integer codec round-trip: decode ∘ encode == id over a value sweep
//     and every legal prefix width n ∈ 1..=8 (§5.1).
//   * encode is canonical-minimal: the byte count matches the §5.1
//     length formula at and around each prefix boundary.
//   * String codec round-trip: decode ∘ encode == id (raw form, §5.2).
//   * Dynamic table invariant: total_size never exceeds max_size, and
//     len shrinks monotonically under repeated over-capacity inserts (§4.4).
// =============================================================================

mount core.net.http2.hpack.{
    HeaderField, Http2DynamicTable,
    encode_integer, decode_integer, encode_string, decode_string
};
mount core.net.http2.static_table.{STATIC_TABLE_SIZE};

// -----------------------------------------------------------------------------
// Integer codec round-trip across a value sweep × every prefix width.
// -----------------------------------------------------------------------------

fn value_sweep() -> List<UInt64> {
    [
        0_u64, 1_u64, 2_u64, 30_u64, 31_u64, 32_u64,
        126_u64, 127_u64, 128_u64, 254_u64, 255_u64, 256_u64,
        1337_u64, 16383_u64, 16384_u64, 65535_u64, 65536_u64,
        1000000_u64, 4294967295_u64,
    ]
}

@test
fn property_hpack_integer_round_trip_all_prefixes() {
    let vals = value_sweep();
    let mut n = 1;
    while n <= 8 {
        let mut i = 0;
        while i < vals.len() {
            let v = vals[i];
            let mut buf: List<Byte> = [];
            encode_integer(v, n, 0_u8, &mut buf);
            match decode_integer(buf.as_slice(), 0, n) {
                Ok((decoded, pos)) => {
                    assert_eq(decoded, v);
                    // The decoder must consume exactly what the encoder wrote.
                    assert_eq(pos, buf.len());
                }
                Err(_) => panic("round-trip must never fail on legal input"),
            }
            i = i + 1;
        }
        n = n + 1;
    }
}

@test
fn property_hpack_integer_flags_transparent_to_round_trip() {
    // OR-ing arbitrary high flag bits into the prefix byte must not
    // perturb the decoded value (decoder masks the prefix).
    let vals = value_sweep();
    let mut i = 0;
    while i < vals.len() {
        let v = vals[i];
        // n=5 prefix → flag space is the top 3 bits; 0xE0 sets all of them.
        let mut buf: List<Byte> = [];
        encode_integer(v, 5, 0xE0_u8, &mut buf);
        match decode_integer(buf.as_slice(), 0, 5) {
            Ok((decoded, _)) => assert_eq(decoded, v),
            Err(_)           => panic("flagged round-trip must succeed"),
        }
        i = i + 1;
    }
}

@test
fn property_hpack_integer_prefix_boundary_byte_count() {
    // For every prefix width n, values < (2^n - 1) take exactly one byte;
    // the value == (2^n - 1) takes two (prefix-max + a single 0x00).
    let mut n = 1;
    while n <= 8 {
        let max: UInt64 = ((1_u64 << n) - 1_u64);
        // max - 1 → single byte (skip n where max == 0 is impossible; n>=1).
        if max >= 1_u64 {
            let mut b1: List<Byte> = [];
            encode_integer(max - 1_u64, n, 0_u8, &mut b1);
            assert_eq(b1.len(), 1);
        }
        // max exactly → two bytes.
        let mut b2: List<Byte> = [];
        encode_integer(max, n, 0_u8, &mut b2);
        assert_eq(b2.len(), 2);
        n = n + 1;
    }
}

// -----------------------------------------------------------------------------
// String codec round-trip (raw form).
// -----------------------------------------------------------------------------

// NOTE: a string-codec round-trip / length-law property over a length
// sweep is intentionally OMITTED here. Calling `encode_string` (or
// `decode_string`) inside a `while` loop trips a compile-time codegen
// SIGABRT (ENCSTR-LOOP-1, see audit §3.5) — the string codec carries the
// Huffman-intrinsic + `extend_from_slice` branch, and instantiating it in a
// loop body aborts the compiler. The string codec is fully covered by the
// unit suite's single-call tests (test_hpack_encode_string_raw_length_prefix,
// test_hpack_decode_string_raw_round_trip, _empty_payload,
// _exceeding_max_length_rejected).

// -----------------------------------------------------------------------------
// Dynamic table size invariant (§4.4).
// -----------------------------------------------------------------------------

@test
fn property_hpack_dynamic_table_never_exceeds_max() {
    // After every insert the total_size must stay ≤ max_size.
    let mut t = Http2DynamicTable.new(128);
    let mut i = 0;
    while i < 20 {
        t.insert(HeaderField.new("key", "value"));   // size = 3+5+32 = 40
        assert(t.total_size <= 128);
        i = i + 1;
    }
}

@test
fn property_hpack_dynamic_table_lookup_within_len_is_some() {
    // Every combined index in [62, 62+len) must resolve to Some.
    let mut t = Http2DynamicTable.new(4096);
    t.insert(HeaderField.new("a", "1"));
    t.insert(HeaderField.new("b", "2"));
    t.insert(HeaderField.new("c", "3"));
    let mut idx = STATIC_TABLE_SIZE + 1;
    let mut seen = 0;
    while seen < t.len() {
        assert(t.lookup(idx) is Maybe.Some);
        idx = idx + 1;
        seen = seen + 1;
    }
    // Just past the end must be None.
    assert(t.lookup(idx) is Maybe.None);
}

fn main() {}
