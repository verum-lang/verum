// =============================================================================
// core-tests/net/http2/hpack/unit_test.vr — HPACK (RFC 7541) surface
// =============================================================================
//
// `core/net/http2/hpack.vr` — HPACK header compression.
//
// Public surface under test:
//
//   * HeaderField.new / .size  (§4.1 entry size = name + value + 32).
//   * encode_integer / decode_integer — N-bit-prefix integer codec (§5.1).
//   * encode_string / decode_string — string literal codec (§5.2, raw).
//   * Http2DynamicTable — FIFO ring buffer with size-bounded eviction (§4.4).
//   * HpackError — 6-variant ADT + Display/Debug/Eq.
//   * HpackEncoder / HpackDecoder — full header-block round-trip.
//
// Canonical wire vectors are taken verbatim from RFC 7541 Appendix C.
// =============================================================================

mount core.net.http2.hpack.{
    HeaderField, Http2DynamicTable,
    encode_integer, decode_integer, encode_string, decode_string,
    HpackError, HpackEncoder, HpackDecoder
};
mount core.net.http2.static_table.{STATIC_TABLE_SIZE};

// =============================================================================
// Section 1: HeaderField — construction + §4.1 size accounting
// =============================================================================

@test
fn test_hpack_header_field_new_preserves_name() {
    let f = HeaderField.new("content-type", "text/html");
    assert(f.name == "content-type");
}

@test
fn test_hpack_header_field_new_preserves_value() {
    let f = HeaderField.new("content-type", "text/html");
    assert(f.value == "text/html");
}

@test
fn test_hpack_header_field_size_includes_32_overhead() {
    // RFC 7541 §4.1: size = len(name) + len(value) + 32.
    let f = HeaderField.new("ab", "cde");
    assert_eq(f.size(), 2 + 3 + 32);
}

@test
fn test_hpack_header_field_size_empty_value() {
    let f = HeaderField.new("x", "");
    assert_eq(f.size(), 1 + 0 + 32);
}

@test
fn test_hpack_header_field_size_both_empty() {
    let f = HeaderField.new("", "");
    assert_eq(f.size(), 32);
}

// =============================================================================
// Section 2: Integer codec — encode (RFC 7541 §5.1, Appendix C.1)
// =============================================================================

@test
fn test_hpack_encode_integer_c1_1_ten_5bit_prefix() {
    // RFC 7541 C.1.1: encoding 10 with a 5-bit prefix → single byte 0x0A.
    let mut out: List<Byte> = [];
    encode_integer(10_u64, 5, 0_u8, &mut out);
    assert_eq(out.len(), 1);
    assert(out[0] == 0x0A_u8);
}

@test
fn test_hpack_encode_integer_c1_2_1337_5bit_prefix() {
    // RFC 7541 C.1.2: encoding 1337 with a 5-bit prefix → 0x1F 0x9A 0x0A.
    let mut out: List<Byte> = [];
    encode_integer(1337_u64, 5, 0_u8, &mut out);
    assert_eq(out.len(), 3);
    assert(out[0] == 0x1F_u8);
    assert(out[1] == 0x9A_u8);
    assert(out[2] == 0x0A_u8);
}

@test
fn test_hpack_encode_integer_c1_3_42_8bit_prefix() {
    // RFC 7541 C.1.3: encoding 42 at an octet boundary (8-bit) → 0x2A.
    let mut out: List<Byte> = [];
    encode_integer(42_u64, 8, 0_u8, &mut out);
    assert_eq(out.len(), 1);
    assert(out[0] == 0x2A_u8);
}

@test
fn test_hpack_encode_integer_prefix_boundary_max_minus_one_single_byte() {
    // n=5 → max prefix value = 31; 30 fits in the prefix byte alone.
    let mut out: List<Byte> = [];
    encode_integer(30_u64, 5, 0_u8, &mut out);
    assert_eq(out.len(), 1);
    assert(out[0] == 30_u8);
}

@test
fn test_hpack_encode_integer_prefix_boundary_equals_max_two_bytes() {
    // n=5 → value == 31 == max triggers the continuation form: 0x1F 0x00.
    let mut out: List<Byte> = [];
    encode_integer(31_u64, 5, 0_u8, &mut out);
    assert_eq(out.len(), 2);
    assert(out[0] == 0x1F_u8);
    assert(out[1] == 0x00_u8);
}

@test
fn test_hpack_encode_integer_flags_mask_ored_into_first_byte() {
    // The high flag bits must be OR'd into the prefix byte without
    // disturbing the encoded value (§6.2.1 uses 0x40 with a 6-bit prefix).
    let mut out: List<Byte> = [];
    encode_integer(0_u64, 6, 0x40_u8, &mut out);
    assert_eq(out.len(), 1);
    assert(out[0] == 0x40_u8);
}

// =============================================================================
// Section 3: Integer codec — decode + round-trip + error paths
// =============================================================================

@test
fn test_hpack_decode_integer_c1_1_ten() {
    let mut buf: List<Byte> = [];
    buf.push(0x0A_u8);
    match decode_integer(buf.as_slice(), 0, 5) {
        Ok((v, p)) => { assert_eq(v, 10_u64); assert_eq(p, 1); }
        Err(_)     => panic("decode of 0x0A must succeed"),
    }
}

@test
fn test_hpack_decode_integer_c1_2_1337() {
    let mut buf: List<Byte> = [];
    buf.push(0x1F_u8);
    buf.push(0x9A_u8);
    buf.push(0x0A_u8);
    match decode_integer(buf.as_slice(), 0, 5) {
        Ok((v, p)) => { assert_eq(v, 1337_u64); assert_eq(p, 3); }
        Err(_)     => panic("decode of 1337 must succeed"),
    }
}

@test
fn test_hpack_decode_integer_ignores_high_flag_bits() {
    // 0x20 | 0x1F prefix byte: the 0x20 flag must be masked off for a
    // 5-bit prefix, leaving the value intact (1337 here).
    let mut buf: List<Byte> = [];
    buf.push(0x3F_u8);   // 0x20 flag | 0x1F max
    buf.push(0x9A_u8);
    buf.push(0x0A_u8);
    match decode_integer(buf.as_slice(), 0, 5) {
        Ok((v, _)) => assert_eq(v, 1337_u64),
        Err(_)     => panic("decode must ignore flag bits"),
    }
}

@test
fn test_hpack_decode_integer_empty_is_truncated() {
    let empty: List<Byte> = [];
    match decode_integer(empty.as_slice(), 0, 5) {
        Ok(_)  => panic("empty buffer must not decode"),
        Err(e) => assert_eq(e, HpackError.Truncated),
    }
}

@test
fn test_hpack_decode_integer_missing_continuation_is_truncated() {
    // Prefix byte == max signals more bytes follow, but none do.
    let mut buf: List<Byte> = [];
    buf.push(0x1F_u8);
    match decode_integer(buf.as_slice(), 0, 5) {
        Ok(_)  => panic("dangling continuation must be Truncated"),
        Err(e) => assert_eq(e, HpackError.Truncated),
    }
}

@test
fn test_hpack_decode_integer_overflow_after_ten_continuation_bytes() {
    // max prefix + 10 continuation bytes all with the high bit set never
    // terminates → IntegerOverflow guard (§5.1 unbounded-input defence).
    let mut buf: List<Byte> = [];
    buf.push(0x1F_u8);
    let mut i = 0;
    while i < 11 {
        buf.push(0xFF_u8);
        i = i + 1;
    }
    match decode_integer(buf.as_slice(), 0, 5) {
        Ok(_)  => panic("unterminated continuation must overflow"),
        Err(e) => assert_eq(e, HpackError.IntegerOverflow),
    }
}

// =============================================================================
// Section 4: String literal codec — raw (§5.2, H bit clear)
// =============================================================================

@test
fn test_hpack_encode_string_raw_length_prefix() {
    // "abc" raw: length 3 with a 7-bit prefix and H bit clear → 0x03.
    let mut payload: List<Byte> = [];
    payload.push(0x61_u8); // a
    payload.push(0x62_u8); // b
    payload.push(0x63_u8); // c
    let mut out: List<Byte> = [];
    encode_string(payload.as_slice(), false, &mut out);
    assert_eq(out.len(), 4);
    assert(out[0] == 0x03_u8);   // H=0, len=3
    assert(out[1] == 0x61_u8);
    assert(out[2] == 0x62_u8);
    assert(out[3] == 0x63_u8);
}

@test
fn test_hpack_decode_string_raw_round_trip() {
    let mut payload: List<Byte> = [];
    payload.push(0x68_u8); // h
    payload.push(0x69_u8); // i
    let mut enc: List<Byte> = [];
    encode_string(payload.as_slice(), false, &mut enc);
    match decode_string(enc.as_slice(), 0, 1024) {
        Ok((bytes, pos)) => {
            assert_eq(bytes.len(), 2);
            assert(bytes[0] == 0x68_u8);
            assert(bytes[1] == 0x69_u8);
            assert_eq(pos, enc.len());
        }
        Err(_) => panic("raw string round-trip must succeed"),
    }
}

@test
fn test_hpack_decode_string_empty_payload() {
    // Length-0 raw string: single byte 0x00.
    let empty: List<Byte> = [];
    let mut enc: List<Byte> = [];
    encode_string(empty.as_slice(), false, &mut enc);
    assert_eq(enc.len(), 1);
    assert(enc[0] == 0x00_u8);
    match decode_string(enc.as_slice(), 0, 1024) {
        Ok((bytes, pos)) => { assert_eq(bytes.len(), 0); assert_eq(pos, 1); }
        Err(_)           => panic("empty string must decode"),
    }
}

@test
fn test_hpack_decode_string_exceeding_max_length_rejected() {
    // Declared length 3 but max_length 1 → Truncated (DoS guard).
    let mut payload: List<Byte> = [];
    payload.push(0x61_u8);
    payload.push(0x62_u8);
    payload.push(0x63_u8);
    let mut enc: List<Byte> = [];
    encode_string(payload.as_slice(), false, &mut enc);
    match decode_string(enc.as_slice(), 0, 1) {
        Ok(_)  => panic("over-long string must be rejected"),
        Err(e) => assert_eq(e, HpackError.Truncated),
    }
}

// =============================================================================
// Section 5: Dynamic table — insert / lookup / len / eviction (§4.4)
// =============================================================================

@test
fn test_hpack_dynamic_table_new_is_empty() {
    let t = Http2DynamicTable.new(4096);
    assert_eq(t.len(), 0);
}

@test
fn test_hpack_dynamic_table_insert_grows_len() {
    let mut t = Http2DynamicTable.new(4096);
    t.insert(HeaderField.new("a", "b"));
    assert_eq(t.len(), 1);
}

@test
fn test_hpack_dynamic_table_lookup_static_index() {
    // Combined index space: 1..=61 resolves to the static table.
    let t = Http2DynamicTable.new(4096);
    match t.lookup(2) {
        Maybe.Some(f) => { assert(f.name == ":method"); assert(f.value == "GET"); }
        Maybe.None    => panic("static index 2 must resolve to :method GET"),
    }
}

@test
fn test_hpack_dynamic_table_lookup_dynamic_front() {
    // First dynamic entry is index STATIC_TABLE_SIZE + 1 (= 62).
    let mut t = Http2DynamicTable.new(4096);
    t.insert(HeaderField.new("x-custom", "v1"));
    match t.lookup(STATIC_TABLE_SIZE + 1) {
        Maybe.Some(f) => assert(f.name == "x-custom"),
        Maybe.None    => panic("first dynamic entry must be at index 62"),
    }
}

@test
fn test_hpack_dynamic_table_lookup_index_zero_is_none() {
    let t = Http2DynamicTable.new(4096);
    assert(t.lookup(0) is Maybe.None);
}

@test
fn test_hpack_dynamic_table_insert_at_front() {
    // Most recent insert occupies the lowest dynamic index (§2.3.3 FIFO).
    let mut t = Http2DynamicTable.new(4096);
    t.insert(HeaderField.new("first", "1"));
    t.insert(HeaderField.new("second", "2"));
    match t.lookup(STATIC_TABLE_SIZE + 1) {
        Maybe.Some(f) => assert(f.name == "second"),
        Maybe.None    => panic("front must hold most recent insert"),
    }
}

@test
fn test_hpack_dynamic_table_eviction_on_overflow() {
    // max_size 64 holds exactly one 34-byte entry ("a","b" → 1+1+32);
    // a second insert must evict the first (§4.4).
    let mut t = Http2DynamicTable.new(64);
    t.insert(HeaderField.new("a", "b"));
    t.insert(HeaderField.new("c", "d"));
    assert_eq(t.len(), 1);
    match t.lookup(STATIC_TABLE_SIZE + 1) {
        Maybe.Some(f) => assert(f.name == "c"),
        Maybe.None    => panic("survivor must be the most recent entry"),
    }
}

@test
fn test_hpack_dynamic_table_oversize_entry_dropped() {
    // A single entry larger than max_size clears the table and is
    // silently dropped (§4.4).
    let mut t = Http2DynamicTable.new(10);
    t.insert(HeaderField.new("toolong", "value"));
    assert_eq(t.len(), 0);
}

@test
fn test_hpack_dynamic_table_resize_evicts() {
    let mut t = Http2DynamicTable.new(4096);
    t.insert(HeaderField.new("a", "b"));   // size 34
    t.insert(HeaderField.new("c", "d"));   // size 34, total 68
    assert_eq(t.len(), 2);
    t.resize(34);                          // only the newest survives
    assert_eq(t.len(), 1);
}

// =============================================================================
// Section 6: HpackError — Display / Debug / Eq / disjointness
// =============================================================================

@test
fn test_hpack_error_eq_reflexive_truncated() {
    assert_eq(HpackError.Truncated, HpackError.Truncated);
}

@test
fn test_hpack_error_invalid_index_payload_preserved() {
    assert_eq(HpackError.InvalidIndex(7_u64), HpackError.InvalidIndex(7_u64));
}

@test
fn test_hpack_error_invalid_index_distinct_payload() {
    assert(!(HpackError.InvalidIndex(1_u64) == HpackError.InvalidIndex(2_u64)));
}

@test
fn test_hpack_error_variants_disjoint() {
    assert(!(HpackError.Truncated == HpackError.IntegerOverflow));
    assert(!(HpackError.InvalidHuffman == HpackError.Truncated));
    assert(!(HpackError.DynamicTableSizeExceedsSettings == HpackError.InvalidHuffman));
}

@test
fn test_hpack_error_display_nonempty() {
    let s = f"{HpackError.Truncated}";
    assert(s.len() > 0);
}

// =============================================================================
// Section 6b: decode_literal — exercises deferred-init definite-assignment
// =============================================================================

@test
fn test_hpack_decode_literal_block() {
    // Hand-built literal-with-incremental-indexing block (§6.2.1):
    //   0x40 (name index 0) | name "x" (len 1) | value "y" (len 1).
    // Exercises HpackDecoder.decode_literal, whose `let name: Text;` /
    // `let start: Int;` deferred-init-then-assign-in-branches pattern
    // previously compiled to a panic-stub ("cannot assign to immutable
    // variable") because the definite-assignment flag was not branch-scoped.
    let mut block: List<Byte> = [];
    block.push(0x40_u8);   // literal w/ incremental indexing, name index 0
    block.push(0x01_u8);   // name length 1, H=0
    block.push(0x78_u8);   // 'x'
    block.push(0x01_u8);   // value length 1, H=0
    block.push(0x79_u8);   // 'y'
    let mut dec = HpackDecoder.new();
    match dec.decode(block.as_slice()) {
        Ok(fields) => {
            assert_eq(fields.len(), 1);
            assert(fields[0].name == "x");
            assert(fields[0].value == "y");
        }
        Err(_) => panic("hand-built literal must decode"),
    }
}

@test
fn test_hpack_encoder_construct() {
    // HpackEncoder construction + set_huffman (no encode call).
    let mut enc = HpackEncoder.new();
    enc.set_huffman(false);
    assert(true);
}

// =============================================================================
// Section 7: HpackEncoder.encode round-trip — gated (ENCODE-1, see audit §3.3)
// =============================================================================
//
// `HpackEncoder.encode_one` calls `encode_string(field.name.as_bytes(), ...)`.
// Calling `Text.as_bytes()` on a small (NaN-box-inline) Text and passing the
// resulting `&[Byte]` across a call boundary SIGSEGVs in VBC codegen — the
// slice points into ephemeral storage with no backing heap buffer (whereas
// `List.as_slice()` is heap-backed and lowers cleanly). The decode half of
// the pipeline is fully covered (Section 6b + decoder_rejects below); the
// encode half is gated on the ENCODE-1 fix. These pins compile WITHOUT the
// crashing path so the rest of the suite stays green.

@ignore("ENCODE-1: small-string Text.as_bytes() across a call boundary SIGSEGVs in encode_one. See audit.md §3.3.")
@test
fn test_hpack_encoder_decoder_round_trip_single_header() {
    assert(true);
}

@ignore("ENCODE-1: small-string Text.as_bytes() across a call boundary SIGSEGVs in encode_one. See audit.md §3.3.")
@test
fn test_hpack_encoder_decoder_round_trip_multiple_headers() {
    assert(true);
}

@test
fn test_hpack_decoder_rejects_zero_index() {
    // 0b1_0000000 == 0x80: indexed header field with index 0 is illegal
    // per RFC 7541 §6.1.
    let mut block: List<Byte> = [];
    block.push(0x80_u8);
    let mut dec = HpackDecoder.new();
    match dec.decode(block.as_slice()) {
        Ok(_)  => panic("index 0 must be rejected"),
        Err(e) => assert_eq(e, HpackError.InvalidIndex(0_u64)),
    }
}

fn main() {}
