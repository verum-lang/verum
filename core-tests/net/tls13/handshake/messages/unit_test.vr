// =============================================================================
// core-tests/net/tls13/handshake/messages/unit_test.vr — RFC 8446 §4 msg types
// =============================================================================
//
// `core/net/tls13/handshake/messages.vr` HandshakeType byte constants
// (RFC 8446 §4 / IANA TLS HandshakeType registry).
// =============================================================================

mount core.net.tls13.handshake.messages.{
    HST_CLIENT_HELLO, HST_SERVER_HELLO, HST_NEW_SESSION_TICKET,
    HST_END_OF_EARLY_DATA, HST_ENCRYPTED_EXTENSIONS, HST_CERTIFICATE,
    HST_CERTIFICATE_REQUEST, HST_CERTIFICATE_VERIFY, HST_FINISHED,
    HST_KEY_UPDATE, HST_MESSAGE_HASH
};

// =============================================================================
// Section 1: RFC 8446 §4 canonical HandshakeType values
// =============================================================================

@test
fn test_hst_client_hello_is_1() { assert_eq(HST_CLIENT_HELLO, 1_u8); }
@test
fn test_hst_server_hello_is_2() { assert_eq(HST_SERVER_HELLO, 2_u8); }
@test
fn test_hst_new_session_ticket_is_4() { assert_eq(HST_NEW_SESSION_TICKET, 4_u8); }
@test
fn test_hst_end_of_early_data_is_5() { assert_eq(HST_END_OF_EARLY_DATA, 5_u8); }
@test
fn test_hst_encrypted_extensions_is_8() { assert_eq(HST_ENCRYPTED_EXTENSIONS, 8_u8); }
@test
fn test_hst_certificate_is_11() { assert_eq(HST_CERTIFICATE, 11_u8); }
@test
fn test_hst_certificate_request_is_13() { assert_eq(HST_CERTIFICATE_REQUEST, 13_u8); }
@test
fn test_hst_certificate_verify_is_15() { assert_eq(HST_CERTIFICATE_VERIFY, 15_u8); }
@test
fn test_hst_finished_is_20() { assert_eq(HST_FINISHED, 20_u8); }
@test
fn test_hst_key_update_is_24() { assert_eq(HST_KEY_UPDATE, 24_u8); }
@test
fn test_hst_message_hash_is_254() { assert_eq(HST_MESSAGE_HASH, 254_u8); }

// =============================================================================
// Section 2: ordering / distinctness invariants
// =============================================================================

@test
fn test_hst_client_before_server_hello() {
    assert(HST_CLIENT_HELLO < HST_SERVER_HELLO);
}

@test
fn test_hst_finished_after_certificate_verify() {
    assert(HST_FINISHED > HST_CERTIFICATE_VERIFY);
}

@test
fn test_hst_message_hash_is_max_synthetic() {
    // 254 is the synthetic HRR-transcript message-hash type — the highest.
    assert(HST_MESSAGE_HASH > HST_KEY_UPDATE);
    assert(HST_MESSAGE_HASH > HST_FINISHED);
}
