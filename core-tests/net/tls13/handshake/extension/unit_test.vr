// =============================================================================
// core-tests/net/tls13/handshake/extension/unit_test.vr — RFC 8446 §4.2
// =============================================================================
//
// `core/net/tls13/handshake/extension.vr`:
//
//   * EXT_* extension-type IANA codepoints (RFC 8446 §4.2 + related RFCs).
// =============================================================================

mount core.net.tls13.handshake.extension.{
    EXT_SERVER_NAME, EXT_MAX_FRAGMENT_LENGTH, EXT_STATUS_REQUEST,
    EXT_SUPPORTED_GROUPS, EXT_SIGNATURE_ALGORITHMS, EXT_USE_SRTP,
    EXT_HEARTBEAT, EXT_ALPN, EXT_SIGNED_CERTIFICATE_TIMESTAMP,
    EXT_CLIENT_CERTIFICATE_TYPE, EXT_SERVER_CERTIFICATE_TYPE,
    EXT_PADDING, EXT_RECORD_SIZE_LIMIT, EXT_COMPRESS_CERTIFICATE
};

// =============================================================================
// Section 1: IANA extension-type codepoints (RFC 8446 §4.2 + RFC 6066/7301/…)
// =============================================================================

@test
fn test_tls13ext_server_name_0() { assert_eq(EXT_SERVER_NAME, 0_u16); }

@test
fn test_tls13ext_max_fragment_length_1() { assert_eq(EXT_MAX_FRAGMENT_LENGTH, 1_u16); }

@test
fn test_tls13ext_status_request_5() { assert_eq(EXT_STATUS_REQUEST, 5_u16); }

@test
fn test_tls13ext_supported_groups_10() { assert_eq(EXT_SUPPORTED_GROUPS, 10_u16); }

@test
fn test_tls13ext_signature_algorithms_13() { assert_eq(EXT_SIGNATURE_ALGORITHMS, 13_u16); }

@test
fn test_tls13ext_use_srtp_14() { assert_eq(EXT_USE_SRTP, 14_u16); }

@test
fn test_tls13ext_heartbeat_15() { assert_eq(EXT_HEARTBEAT, 15_u16); }

@test
fn test_tls13ext_alpn_16() { assert_eq(EXT_ALPN, 16_u16); }

@test
fn test_tls13ext_sct_18() { assert_eq(EXT_SIGNED_CERTIFICATE_TIMESTAMP, 18_u16); }

@test
fn test_tls13ext_client_cert_type_19() { assert_eq(EXT_CLIENT_CERTIFICATE_TYPE, 19_u16); }

@test
fn test_tls13ext_server_cert_type_20() { assert_eq(EXT_SERVER_CERTIFICATE_TYPE, 20_u16); }

@test
fn test_tls13ext_padding_21() { assert_eq(EXT_PADDING, 21_u16); }

@test
fn test_tls13ext_compress_certificate_27() { assert_eq(EXT_COMPRESS_CERTIFICATE, 27_u16); }

@test
fn test_tls13ext_record_size_limit_28() { assert_eq(EXT_RECORD_SIZE_LIMIT, 28_u16); }

@test
fn test_tls13ext_signature_algorithms_distinct_from_supported_groups() {
    assert(!(EXT_SIGNATURE_ALGORITHMS == EXT_SUPPORTED_GROUPS));
}

fn main() {}
