// =============================================================================
// core-tests/net/tcp/regression_test.vr
// =============================================================================
//
// Regression pins for `core/net/tcp.vr`. Most functional surface
// (connect / bind / accept / read / write / socket options) requires
// a loopback or socketpair harness and is `@ignore`'d here — see
// `audit.md §3.1` for the harness gate and `vcs/specs/L2-standard/net/tcp/`
// for the live coverage.
//
// LOCK-IN pins (active) cover the `Shutdown` 3-variant algebraic
// surface — these are wire-stable wrt SHUT_RD / SHUT_WR / SHUT_RDWR
// per POSIX, but the integer constants are private inside `tcp.vr`
// (audit.md §3.3) so the algebraic identity (variant disjointness
// + reflexive matching via `is`) is pinned instead.
//
// Pattern reference: `core-tests/net/cidr/regression_test.vr` for
// the @ignore'd functional surface + active LOCK-IN section split.
// =============================================================================

mount core.net.tcp.{Shutdown};

// =============================================================================
// TCP-1 — TcpStream.connect against loopback fixture
// =============================================================================

@ignore("TCP-1: TcpStream.connect needs loopback fixture harness. See audit.md §3.1.")
@test
fn regression_tcp_stream_connect_loopback() {
    // Live connect target on 127.0.0.1:<port> — gated on harness.
    // Placeholder body keeps the registration point reachable so
    // un-ignoring once the harness lands is a one-line flip.
    assert(true);
}

