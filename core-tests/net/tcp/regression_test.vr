// TCP-2 — TcpListener.bind + accept
// =============================================================================

@ignore("TCP-2: TcpListener.bind + accept needs harness. See audit.md §3.1.")
@test
fn regression_tcp_listener_bind_accept() {
    assert(true);
}

// =============================================================================
// TCP-3 — AsyncRead / AsyncWrite round-trip
// =============================================================================

@ignore("TCP-3: AsyncRead/AsyncWrite round-trip needs harness. See audit.md §3.1.")
@test
fn regression_tcp_stream_async_read_write_round_trip() {
    assert(true);
}

// =============================================================================
// TCP-4 — socket options: set_nodelay / set_keepalive / set_linger
// =============================================================================

@ignore("TCP-4: socket-option setters need bound TcpStream from harness. See audit.md §3.1.")
@test
fn regression_tcp_stream_socket_options() {
    assert(true);
}

// =============================================================================
// TCP-5..7 — Shutdown wire-constant LOCK-IN (variant disjointness)
// =============================================================================
//
// SHUT_RD / SHUT_WR / SHUT_RDWR are POSIX-stable integers but the
// kernel constants live inside `tcp.vr` (audit.md §3.3) and are not
// re-exported. We pin the variant disjointness identity here so
// downstream code that branches on `Shutdown` cannot silently
// re-order the tag wire layout under us.

@test
fn regression_shutdown_read_serializes_distinctly() {
    // TCP-5: Shutdown.Read must remain a distinct variant tag from
    // Shutdown.Write / Shutdown.Both so the syscall-side mapping
    // table in `tcp.vr` does not collapse onto a single SHUT_*
    // value.
    let s: Shutdown = Shutdown.Read;
    assert(s is Shutdown.Read);
    assert(!(s is Shutdown.Write));
    assert(!(s is Shutdown.Both));
}

@test
fn regression_shutdown_write_serializes_distinctly() {
    // TCP-6: Shutdown.Write — same distinctness invariant.
    let s: Shutdown = Shutdown.Write;
    assert(s is Shutdown.Write);
    assert(!(s is Shutdown.Read));
    assert(!(s is Shutdown.Both));
}

@test
fn regression_shutdown_both_serializes_distinctly() {
    // TCP-7: Shutdown.Both — same distinctness invariant.
    let s: Shutdown = Shutdown.Both;
    assert(s is Shutdown.Both);
    assert(!(s is Shutdown.Read));
    assert(!(s is Shutdown.Write));
}
