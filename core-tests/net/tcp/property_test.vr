// =============================================================================
// core-tests/net/tcp/property_test.vr
// =============================================================================
//
// Algebraic laws for `core/net/tcp.vr` — Shutdown 3-variant lattice.
//
// `Shutdown` does not derive `Eq` in `core/net/tcp.vr` (audit confirms
// no `implement Eq for Shutdown` block); equality on variants is
// expressed via the `is` pattern operator, matching the convention
// used in `core-tests/net/tcp/unit_test.vr` and in
// `core-tests/net/unix/unit_test.vr` for `ShutdownKind`.
//
// Laws covered:
//
//   * 3-variant lattice: Read ⊕ Write ≡ Both (pinned via the
//     construction triple — the three together form the closed
//     algebra; no fourth variant exists).
//   * Pairwise disjointness: 3 × 3 = 9 cases (3 reflexive + 6
//     mutually-exclusive) over the `is` operator.
//   * `is` operator reflexive: every variant satisfies its own tag.
// =============================================================================

mount core.net.tcp.{Shutdown};

// =============================================================================
// Section 1: 3-variant lattice — Read ⊕ Write ≡ Both
// =============================================================================

@test
fn prop_shutdown_lattice_triple_construction() {
    // Pin the three variants as the closed algebra. Semantically
    // Both ≡ Read ⊕ Write at the kernel layer (SHUT_RDWR
    // = SHUT_RD | SHUT_WR). At the Verum type layer we surface
    // this as three distinct tags — pinning the triple keeps any
    // future "add a 4th variant" review explicit.
    let r: Shutdown = Shutdown.Read;
    let w: Shutdown = Shutdown.Write;
    let b: Shutdown = Shutdown.Both;
    assert(r is Shutdown.Read);
    assert(w is Shutdown.Write);
    assert(b is Shutdown.Both);
}

@test
fn prop_shutdown_lattice_no_overlap_between_halves() {
    // Read does not subsume Write and vice-versa.
    let r: Shutdown = Shutdown.Read;
    let w: Shutdown = Shutdown.Write;
    assert(!(r is Shutdown.Write));
    assert(!(w is Shutdown.Read));
}

@test
fn prop_shutdown_lattice_both_is_distinct_from_halves() {
    // Both is its own tag — NOT pattern-equal to either half. Wire
    // mapping (Read | Write) → Both lives in tcp.vr, not in the
    // pattern algebra here.
    let b: Shutdown = Shutdown.Both;
    assert(!(b is Shutdown.Read));
    assert(!(b is Shutdown.Write));
}

// =============================================================================
// Section 2: Pairwise disjointness — 3 × 3 = 9 cases
// =============================================================================

@test
fn prop_shutdown_reflexive_read() {
    // 1 of 3 reflexive: (Read, Read)
    let s: Shutdown = Shutdown.Read;
    assert(s is Shutdown.Read);
}

@test
fn prop_shutdown_reflexive_write() {
    // 2 of 3 reflexive: (Write, Write)
    let s: Shutdown = Shutdown.Write;
    assert(s is Shutdown.Write);
}

@test
fn prop_shutdown_reflexive_both() {
    // 3 of 3 reflexive: (Both, Both)
    let s: Shutdown = Shutdown.Both;
    assert(s is Shutdown.Both);
}

@test
fn prop_shutdown_disjoint_read_write() {
    // (Read, Write) + (Write, Read) — symmetric disjoint pair
    let r: Shutdown = Shutdown.Read;
    let w: Shutdown = Shutdown.Write;
    assert(!(r is Shutdown.Write));
    assert(!(w is Shutdown.Read));
}

@test
fn prop_shutdown_disjoint_read_both() {
    // (Read, Both) + (Both, Read) — symmetric disjoint pair
    let r: Shutdown = Shutdown.Read;
    let b: Shutdown = Shutdown.Both;
    assert(!(r is Shutdown.Both));
    assert(!(b is Shutdown.Read));
}

@test
fn prop_shutdown_disjoint_write_both() {
    // (Write, Both) + (Both, Write) — symmetric disjoint pair
    let w: Shutdown = Shutdown.Write;
    let b: Shutdown = Shutdown.Both;
    assert(!(w is Shutdown.Both));
    assert(!(b is Shutdown.Write));
}

// =============================================================================
// Section 3: Eq via direct construction + `is`
// =============================================================================
//
// `Shutdown` lacks an explicit `implement Eq for Shutdown` block, so
// equality is pattern-checked via `is` (NOT the `==` operator).

@test
fn prop_shutdown_is_operator_construction_round_trip_read() {
    let s: Shutdown = Shutdown.Read;
    let t: Shutdown = Shutdown.Read;
    // Both construct to the same tag; `is` reflexivity pins
    // construction → tag determinism.
    assert(s is Shutdown.Read);
    assert(t is Shutdown.Read);
}

@test
fn prop_shutdown_is_operator_construction_round_trip_write() {
    let s: Shutdown = Shutdown.Write;
    let t: Shutdown = Shutdown.Write;
    assert(s is Shutdown.Write);
    assert(t is Shutdown.Write);
}

@test
fn prop_shutdown_is_operator_construction_round_trip_both() {
    let s: Shutdown = Shutdown.Both;
    let t: Shutdown = Shutdown.Both;
    assert(s is Shutdown.Both);
    assert(t is Shutdown.Both);
}
