// =============================================================================
// core-tests/net/proxy/unit_test.vr — data-surface coverage
// =============================================================================
//
// `core/net/proxy/*` (~7 files) — HTTP/HTTPS forward + reverse proxy
// middleware. Upstream pool, health check, load balancer, circuit
// breaker, retry, rate limiter.
//
// Tests cover the algebraic types:
//
//   * LoadBalancer 3-variant (RoundRobin / Random / WeightedLeastConn).
//   * RateDecision variant disjointness.
//   * CHEAP_COST / HEAVY_COST rate-limit cost constants.
// =============================================================================

mount core.net.proxy.loadbalancer.{LoadBalancer};
mount core.net.proxy.rate_limit.{RateDecision, CHEAP_COST, HEAVY_COST};

// =============================================================================
// Section 1: LoadBalancer — 3-variant disjointness
// =============================================================================

@test
fn test_load_balancer_round_robin_construction() {
    let lb: LoadBalancer = LoadBalancer.RoundRobin;
    assert(lb is LoadBalancer.RoundRobin);
}

@test
fn test_load_balancer_random_construction() {
    let lb: LoadBalancer = LoadBalancer.Random;
    assert(lb is LoadBalancer.Random);
}

@test
fn test_load_balancer_weighted_least_conn_construction() {
    let lb: LoadBalancer = LoadBalancer.WeightedLeastConn;
    assert(lb is LoadBalancer.WeightedLeastConn);
}

@test
fn test_load_balancer_disjoint_rr_vs_random() {
    let a: LoadBalancer = LoadBalancer.RoundRobin;
    let b: LoadBalancer = LoadBalancer.Random;
    assert(!(a is LoadBalancer.Random));
    assert(!(b is LoadBalancer.RoundRobin));
}

@test
fn test_load_balancer_disjoint_random_vs_wlc() {
    let a: LoadBalancer = LoadBalancer.Random;
    let b: LoadBalancer = LoadBalancer.WeightedLeastConn;
    assert(!(a is LoadBalancer.WeightedLeastConn));
    assert(!(b is LoadBalancer.Random));
}

// =============================================================================
// Section 2: Rate-limit cost constants
// =============================================================================

@test
fn test_cheap_cost_1() {
    assert_eq(CHEAP_COST, 1_u64);
}

@test
fn test_heavy_cost_10() {
    assert_eq(HEAVY_COST, 10_u64);
}

@test
fn test_cost_relative_order() {
    assert(HEAVY_COST > CHEAP_COST);
}
