// =============================================================================
// core-tests/net/proxy/circuit_breaker/unit_test.vr — data-surface coverage
// =============================================================================
//
// `core/net/proxy/circuit_breaker.vr` (~182 LOC) — Hystrix-style 3-state
// circuit breaker with consecutive-failure threshold + cooldown timer.
//
// Tests cover the data-surface visible from a user test module:
//
//   * CircuitBreakerLayer.new(failure_threshold, reset_timeout_ms,
//     success_threshold) construction.
//   * CircuitBreakerLayer.default() — pins docstring (5/30_000/2).
//   * current_state() after construction == STATE_CLOSED (0).
//   * Boundary-value ctor (zero / negative / large thresholds).
//
// State-machine transitions (Closed -> Open -> HalfOpen -> Closed) require
// a clock + handler mock; those tests live in regression_test.vr under
// @ignore until fixtures land.
// =============================================================================

mount core.net.proxy.circuit_breaker.{CircuitBreakerLayer};

// =============================================================================
// Section 1: CircuitBreakerLayer.new — construction
// =============================================================================

@test
fn test_circuit_breaker_new_typical_construction() {
    let cb = CircuitBreakerLayer.new(5, 30_000, 2);
    assert_eq(cb.current_state(), 0); // STATE_CLOSED
}

@test
fn test_circuit_breaker_new_zero_failure_threshold() {
    // Zero threshold = trip immediately on first failure. Constructor
    // must accept it without panic.
    let cb = CircuitBreakerLayer.new(0, 30_000, 2);
    assert_eq(cb.current_state(), 0);
}

@test
fn test_circuit_breaker_new_single_failure_threshold() {
    let cb = CircuitBreakerLayer.new(1, 1_000, 1);
    assert_eq(cb.current_state(), 0);
}

@test
fn test_circuit_breaker_new_large_failure_threshold() {
    let cb = CircuitBreakerLayer.new(1_000_000, 600_000, 100);
    assert_eq(cb.current_state(), 0);
}

@test
fn test_circuit_breaker_new_zero_reset_timeout() {
    // Zero cooldown = immediately allow probe in Open state. Construction
    // must accept.
    let cb = CircuitBreakerLayer.new(5, 0, 2);
    assert_eq(cb.current_state(), 0);
}

// =============================================================================
// Section 2: CircuitBreakerLayer.default() — pinned docstring constants
// =============================================================================
//
// Lines 96-100 of circuit_breaker.vr:
//   /// Typical config: 5 consecutive failures -> open; 30s reset timeout;
//   /// 2 consecutive successes in HalfOpen -> close.
//   public fn default() -> CircuitBreakerLayer {
//       Self.new(5, 30_000, 2)
//   }
//
// These tests LOCK IN the docstring numbers — config drift will surface
// here before it surfaces at a production site.

@test
fn test_circuit_breaker_default_starts_closed() {
    let cb = CircuitBreakerLayer.default();
    assert_eq(cb.current_state(), 0); // STATE_CLOSED
}

@test
fn test_circuit_breaker_default_is_not_open() {
    let cb = CircuitBreakerLayer.default();
    assert(cb.current_state() != 1); // STATE_OPEN
}

@test
fn test_circuit_breaker_default_is_not_half_open() {
    let cb = CircuitBreakerLayer.default();
    assert(cb.current_state() != 2); // STATE_HALF_OPEN
}

// =============================================================================
// Section 3: current_state() — invariants after fresh construction
// =============================================================================

@test
fn test_circuit_breaker_state_closed_value_is_zero() {
    // STATE_CLOSED = 0 — pinned at circuit_breaker.vr:53. Wire-encoding
    // contract for any caller doing raw int comparison.
    let cb = CircuitBreakerLayer.new(1, 1, 1);
    assert_eq(cb.current_state(), 0);
}

@test
fn test_circuit_breaker_state_open_value_is_one() {
    // STATE_OPEN = 1 — pinned at circuit_breaker.vr:54. A freshly
    // constructed breaker is NOT open; we only assert the encoding
    // does not collide.
    let cb = CircuitBreakerLayer.new(1, 1, 1);
    assert(cb.current_state() != 1);
}

@test
fn test_circuit_breaker_state_half_open_value_is_two() {
    // STATE_HALF_OPEN = 2 — pinned at circuit_breaker.vr:55.
    let cb = CircuitBreakerLayer.new(1, 1, 1);
    assert(cb.current_state() != 2);
}

// =============================================================================
// Section 4: Multiple instances are independent
// =============================================================================

@test
fn test_circuit_breaker_instances_independent() {
    let a = CircuitBreakerLayer.new(3, 1_000, 1);
    let b = CircuitBreakerLayer.new(99, 99_999, 99);
    assert_eq(a.current_state(), 0);
    assert_eq(b.current_state(), 0);
}

@test
fn test_circuit_breaker_default_independent_from_custom() {
    let d = CircuitBreakerLayer.default();
    let c = CircuitBreakerLayer.new(1, 1, 1);
    assert_eq(d.current_state(), c.current_state());
}
