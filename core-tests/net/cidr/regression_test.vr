// =============================================================================
// core-tests/net/cidr/regression_test.vr
// =============================================================================
//
// LOCK-IN pins for CIDR-1 — calling `cidr.parse(&Text)` (or any path
// that transitively calls it, including `CidrSet.add_text`) from a
// USER test module triggers an LLVM-level SIGSEGV inside
// `llvm::SmallVectorBase<unsigned long long>::grow_pod` during the
// precompile cascade for cidr.vr.
//
// Stable trigger: any reachable callsite of `parse(&Text)` in cidr.vr.
// The crash signature is identical across attempts and is independent
// of the test body — even an empty function body that merely calls
// the function panics.
//
// Direct `Cidr.V4 { addr: _, prefix_len: _ }` / `Cidr.V6 { ... }`
// variant construction does NOT trigger the crash (see unit_test.vr),
// so the conformance suite exercises the algebraic surface through
// that path. The parser-path tests in this file are @ignore'd until
// the underlying defect closes.
//
// See `audit.md §3.1` for diagnostic isolation and the candidate
// fix paths (closure codegen, Result `?` in stdlib parse functions,
// precompile cascade `.as_bytes()` interaction).
// =============================================================================

mount core.net.cidr.{Cidr, CidrSet, CidrError, parse as cidr_parse};
mount core.net.addr.{IpAddr, Ipv4Addr};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// CIDR-1 — `cidr.parse(&Text)` SIGSEGV during precompile cascade
// =============================================================================

@ignore("CIDR-1: cidr.parse SIGSEGVs in LLVM SmallVector during precompile cascade. See audit.md §3.1.")
@test
fn regression_parse_v4_8() {
    let s = "10.0.0.0/8".clone();
    match cidr_parse(&s) {
        Ok(c) => assert_eq(c.prefix_len(), 8),
        Err(_) => panic("expected Ok"),
    }
}

@ignore("CIDR-1: cidr.parse SIGSEGV. See audit.md §3.1.")
@test
fn regression_parse_v6_32() {
    let s = "2001:db8::/32".clone();
    match cidr_parse(&s) {
        Ok(c) => assert_eq(c.prefix_len(), 32),
        Err(_) => panic("expected Ok"),
    }
}

@ignore("CIDR-1: transitive call into cidr.parse via CidrSet.add_text SIGSEGVs. See audit.md §3.1.")
@test
fn regression_set_add_text_v4() {
    let mut set = CidrSet.new();
    let s = "10.0.0.0/8".clone();
    let res = set.add_text(&s);
    assert(res.is_ok());
    assert(set.contains(&IpAddr.v4(10_u8, 1_u8, 1_u8, 1_u8)));
}

@ignore("CIDR-1: cidr.parse error paths SIGSEGV before validation runs. See audit.md §3.1.")
@test
fn regression_parse_invalid_prefix_len() {
    let s = "10.0.0.0/33".clone();
    match cidr_parse(&s) {
        Ok(_) => panic("/33 must reject"),
        Err(e) => assert(e == CidrError.InvalidPrefixLen(33)),
    }
}

@ignore("CIDR-1: cidr.parse error paths SIGSEGV. See audit.md §3.1.")
@test
fn regression_parse_no_slash() {
    let s = "10.0.0.0".clone();
    match cidr_parse(&s) {
        Ok(_) => panic("missing slash must reject"),
        Err(_) => assert(true),
    }
}
