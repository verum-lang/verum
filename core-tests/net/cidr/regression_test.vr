// =============================================================================
// core-tests/net/cidr/regression_test.vr
// =============================================================================
//
// LOCK-IN regression pins for `core.net.cidr` parse + matcher surface.
//
// CIDR-1 (CLOSED 2026-05-28) — `cidr.parse(&Text)` SIGSEGV during
// precompile cascade. Closed by source-side discipline applied across
// 3 commits:
//
//   * f649312c6 — closure-free `parse_int().ok_or_else()` → `match
//     Maybe.Some/None` (eliminated closure desugaring through `?`).
//   * be64f4e1e — `slice_text` byte-by-byte push instead of
//     `extend_from_slice(&src[start..end])` (eliminated List-payload
//     intrinsic dispatch chain).
//   * 8ed55522c — discard Ipv6Addr.parse Err payload (eliminated
//     cross-type `CidrError.AddrParseFailed(AddrParseError)` variant
//     construction).
//
// Validated post-binary-rebuild 2026-05-28 — 4/5 regression tests
// transition from @ignore'd-SIGSEGV to GREEN under `--interp`.
//
// CIDR-2 (open) — `CidrSet.contains` after `add_text` returns false
// for valid IPs. Manifest as `regression_set_add_text_v4` AssertionFailed
// at the set.contains assertion (set.add_text succeeds, but contains
// fails). Sister of URL-1 / URL-7 / URL-8 cross-module record-field
// corruption defect class.
// =============================================================================

mount core.net.cidr.{Cidr, CidrSet, CidrError, parse as cidr_parse};
mount core.net.addr.{IpAddr, Ipv4Addr};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// CIDR-1 — CLOSED 2026-05-28 — formerly SIGSEGV'd during precompile cascade
// =============================================================================

@test
fn regression_parse_v4_8() {
    let s = "10.0.0.0/8".clone();
    match cidr_parse(&s) {
        Ok(c) => assert_eq(c.prefix_len(), 8),
        Err(_) => panic("expected Ok"),
    }
}

@test
fn regression_parse_v6_32() {
    let s = "2001:db8::/32".clone();
    match cidr_parse(&s) {
        Ok(c) => assert_eq(c.prefix_len(), 32),
        Err(_) => panic("expected Ok"),
    }
}

@ignore("CIDR-2: CidrSet.contains after add_text returns false for valid IPs — cross-module record-field corruption on CidrSet.blocks. Sister of URL-1/URL-7/URL-8. Multi-day VBC compile_field_access fix.")
@test
fn regression_set_add_text_v4() {
    let mut set = CidrSet.new();
    let s = "10.0.0.0/8".clone();
    let res = set.add_text(&s);
    assert(res.is_ok());
    assert(set.contains(&IpAddr.v4(10_u8, 1_u8, 1_u8, 1_u8)));
}

@test
fn regression_parse_invalid_prefix_len() {
    let s = "10.0.0.0/33".clone();
    match cidr_parse(&s) {
        Ok(_) => panic("/33 must reject"),
        Err(e) => assert(e == CidrError.InvalidPrefixLen(33)),
    }
}

@test
fn regression_parse_no_slash() {
    let s = "10.0.0.0".clone();
    match cidr_parse(&s) {
        Ok(_) => panic("missing slash must reject"),
        Err(_) => assert(true),
    }
}
