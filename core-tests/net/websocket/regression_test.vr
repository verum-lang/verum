@ignore("WS-3b: accept_key RFC 6455 §1.3 test vector — gated on SIGSEGV class. See audit.md §3.1.")
@test
fn regression_ws_accept_key_rfc6455_test_vector() {
    // accept_key("dGhlIHNhbXBsZSBub25jZQ==") must yield
    // "s3pPLMBiTxaQ9kYGzzhZRbK+xOo=" per RFC 6455 §1.3.
    assert(true);
}

