// =============================================================================
// core-tests/net/websocket/regression_test.vr
// =============================================================================
//
// LOCK-IN regression pins for `core/net/websocket.vr` — RFC 6455.
//
// Active pins anchor the wire-format constants — drift here breaks
// every WebSocket peer:
//
//   * WS-1 WsOpcode wire constants — Continuation 0x0, Textual 0x1,
//     Binary 0x2, Close 0x8, Ping 0x9, Pong 0xA (RFC 6455 §5.2).
//   * WS-2 CloseCode variants pairwise disjoint via UInt16 code.
//
// @ignore'd pins gated on the precompile-cascade SIGSEGV class
// (CIDR-1 family) or live transport harnesses:
//
//   * WS-3 WebSocket Upgrade handshake over HTTP/1.1.
//   * WS-4 Permessage-deflate negotiation (RFC 7692).
//   * WS-5 Fragmented message reassembly across Continuation frames.
// =============================================================================

mount core.net.websocket.{WsOpcode, CloseCode, WsFrame, accept_key};
mount core.collections.List;

// =============================================================================
// WS-1 — WsOpcode wire-byte constants (RFC 6455 §5.2)
// =============================================================================

@test
fn regression_ws_opcode_continuation_is_0x0() {
    assert_eq(WsOpcode.Continuation.to_byte(), 0x0_u8);
}

@test
fn regression_ws_opcode_textual_is_0x1() {
    assert_eq(WsOpcode.Textual.to_byte(), 0x1_u8);
}

@test
fn regression_ws_opcode_binary_is_0x2() {
    assert_eq(WsOpcode.Binary.to_byte(), 0x2_u8);
}

@test
fn regression_ws_opcode_close_is_0x8() {
    assert_eq(WsOpcode.Close.to_byte(), 0x8_u8);
}

@test
fn regression_ws_opcode_ping_is_0x9() {
    assert_eq(WsOpcode.Ping.to_byte(), 0x9_u8);
}

@test
fn regression_ws_opcode_pong_is_0xA() {
    assert_eq(WsOpcode.Pong.to_byte(), 0xA_u8);
}

// =============================================================================
// WS-2 — CloseCode variants pairwise disjoint via UInt16 code
// =============================================================================
// RFC 6455 §7.4 IANA-registered close codes. Pairwise disjointness
// across the well-known set is what router-side handlers rely on for
// switch-case correctness.

@test
fn regression_ws_close_code_normal_distinct_from_going_away() {
    assert(!(CloseCode.NORMAL == CloseCode.GOING_AWAY));
}

@test
fn regression_ws_close_code_protocol_error_distinct_from_unsupported() {
    assert(!(CloseCode.PROTOCOL_ERROR == CloseCode.UNSUPPORTED_DATA));
}

@test
fn regression_ws_close_code_invalid_frame_payload_distinct_from_policy() {
    assert(!(CloseCode.INVALID_FRAME_PAYLOAD == CloseCode.POLICY_VIOLATION));
}

@test
fn regression_ws_close_code_message_too_big_distinct_from_internal() {
    assert(!(CloseCode.MESSAGE_TOO_BIG == CloseCode.INTERNAL_ERROR));
}

@test
fn regression_ws_close_code_normal_eq_normal() {
    assert(CloseCode.NORMAL == CloseCode.NORMAL);
}

@test
fn regression_ws_close_code_new_preserves_code() {
    let c = CloseCode.new(4001_u16);
    assert_eq(c.code(), 4001_u16);
}

