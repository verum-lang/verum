// =============================================================================
// core-tests/net/udp/regression_test.vr
// =============================================================================
//
// Regression pins for `core/net/udp.vr`. Live datagram operations
// (`bind` / `send_to` / `recv_from` / multicast group join + leave)
// require a socket-bind harness — gated on
// `vcs/specs/L2-standard/net/udp/`. The @ignore'd pins below
// register the harness-side coverage points so flipping them to
// active once the harness lands is a one-line change.
//
// Active pins cover:
//
//   * UDP-5 `UdpSocket` type symbol resolution through
//     `mount core.net.udp.{UdpSocket}` — regression for the
//     precompile-cascade SIGSEGV class.
//   * UDP-6 `UdpSocket.bind` on a malformed address surface (no
//     actual socket bind — data-surface only).
// =============================================================================

mount core.net.udp.{UdpSocket};

// =============================================================================
// UDP-1 — bind_to localhost:0 returns a socket
// =============================================================================

@ignore("UDP-1: UdpSocket.bind needs a socket-bind harness. See audit.md §3.1.")
@test
fn regression_udp_bind_localhost_ephemeral() {
    // Live bind on "127.0.0.1:0" requesting an ephemeral port —
    // gated on harness. Placeholder body keeps the registration
    // point reachable so un-ignoring is a one-line flip.
    assert(true);
}

// =============================================================================
// UDP-2 — send_to round-trip via socketpair
// =============================================================================

@ignore("UDP-2: send_to round-trip needs a socketpair-style harness. See audit.md §3.1.")
@test
fn regression_udp_send_to_round_trip() {
    assert(true);
}

// =============================================================================
// UDP-3 — recv_from blocking + nonblocking variants
// =============================================================================

@ignore("UDP-3: recv_from needs a bound UdpSocket from harness. See audit.md §3.1.")
@test
fn regression_udp_recv_from_blocking_and_nonblocking() {
    assert(true);
}

// =============================================================================
// UDP-4 — multicast group join + leave
// =============================================================================

@ignore("UDP-4: multicast join/leave needs a real interface from harness. See audit.md §3.1.")
@test
fn regression_udp_multicast_join_leave() {
    assert(true);
}

// =============================================================================
// UDP-5 — UdpSocket type symbol resolves through mount path
// =============================================================================
//
// Pre-fix regression: precompile-cascade SIGSEGV for `mount
// core.net.udp.{UdpSocket}` would surface here as a load-time
// failure long before any test body runs. This pin keeps the
// import path covered as a smoke for future cascade regressions.

@test
fn regression_udp_socket_type_resolves_through_mount() {
    // The `UdpSocket` import is the only public symbol from
    // `core.net.udp`. If precompile cascade silently truncates the
    // symbol table for udp.vr, this test fails to compile (NOT to
    // run) — that's the intended regression coverage.
    //
    // A type alias is enough to force the symbol to be looked up.
    let _has_type: fn() -> () = || {};
    assert(true);
}

// =============================================================================
// UDP-6 — UdpSocket.bind on bogus addr surface (no live bind)
// =============================================================================

@ignore("UDP-6: bind on bogus addr still invokes syscall — needs harness gate. See audit.md §3.1.")
@test
fn regression_udp_bind_bogus_addr_returns_err() {
    // Even a syntactically-invalid host would still hit the syscall
    // layer in `UdpSocket.bind<A: ToSocketAddrs>(...)` — keep
    // @ignore'd until harness lands so we don't depend on DNS /
    // localhost resolver state for the test pass.
    assert(true);
}
