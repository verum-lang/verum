// =============================================================================
// core-tests/net/http/property_test.vr
// =============================================================================
//
// Algebraic laws for `core/net/http.vr`:
//
//   * Method.from_str(M.as_str()) == M — round-trip identity over the
//     9-variant Method (RFC 7231 + RFC 5789).
//   * Method.from_str case-insensitive: lower/upper/mixed all parse.
//   * Method.is_safe — exactly {Get, Head, Options, Trace} per RFC
//     7231 §4.2.1; others are NOT safe.
//   * Method.is_idempotent — exactly {Get, Head, Put, Delete, Options,
//     Trace} per RFC 7231 §4.2.2; {Post, Patch, Connect} are NOT.
//   * Method.has_body — exactly {Post, Put, Patch} per RFC 7230 §3.3.
//   * StatusCode classification — 1xx Informational / 2xx Success /
//     3xx Redirection / 4xx ClientError / 5xx ServerError boundaries.
//   * Common codes — 200 OK / 301 MovedPermanently / 404 NotFound /
//     500 InternalServerError reason-phrase pinning.
//   * Version — Http10 / Http11 / Http2 / Http3 pairwise disjoint via
//     Eq.
// =============================================================================

mount core.net.http.{Method, StatusCode, Version};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: Method round-trip — from_str(as_str()) == M
// =============================================================================

@test
fn prop_method_round_trip_get() {
    let s = Method.Get.as_str();
    match Method.from_str(&s) {
        Some(m) => assert(m is Method.Get),
        None => panic("from_str(Get.as_str()) must succeed"),
    }
}

@test
fn prop_method_round_trip_head() {
    let s = Method.Head.as_str();
    match Method.from_str(&s) {
        Some(m) => assert(m is Method.Head),
        None => panic("from_str(Head.as_str()) must succeed"),
    }
}

@test
fn prop_method_round_trip_post() {
    let s = Method.Post.as_str();
    match Method.from_str(&s) {
        Some(m) => assert(m is Method.Post),
        None => panic("from_str(Post.as_str()) must succeed"),
    }
}

@test
fn prop_method_round_trip_put() {
    let s = Method.Put.as_str();
    match Method.from_str(&s) {
        Some(m) => assert(m is Method.Put),
        None => panic("from_str(Put.as_str()) must succeed"),
    }
}

@test
fn prop_method_round_trip_delete() {
    let s = Method.Delete.as_str();
    match Method.from_str(&s) {
        Some(m) => assert(m is Method.Delete),
        None => panic("from_str(Delete.as_str()) must succeed"),
    }
}

@test
fn prop_method_round_trip_connect() {
    let s = Method.Connect.as_str();
    match Method.from_str(&s) {
        Some(m) => assert(m is Method.Connect),
