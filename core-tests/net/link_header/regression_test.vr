// =============================================================================
// core-tests/net/link_header/regression_test.vr
// =============================================================================
//
// LOCK-IN pins for LINKHDR-1 — calling `parse(&Text)`, `find_rel`,
// or `format_link_header` from a USER test module triggers the
// precompile SIGSEGV class shared with CIDR-1 / URITPL-1 /
// HTTPRNG-1 / CONNEG-1.
//
// See `audit.md §3.1`.
// =============================================================================

mount core.net.link_header.{parse as link_parse, find_rel, format_link_header, LinkEntry, LinkHeaderError};
mount core.collections.List;
mount core.base.result.{Result, Ok, Err};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// LINKHDR-1 — parse / find_rel / format SIGSEGV during precompile cascade
// =============================================================================

@test
fn regression_parse_single_entry_no_params() {
    let s = "</next>".clone();
    match link_parse(&s) {
        Ok(entries) => assert_eq(entries.len(), 1),
        Err(_) => panic("expected Ok"),
    }
}

@test
fn regression_parse_with_rel() {
    let s = "</page/2>; rel=\"next\"".clone();
    match link_parse(&s) {
        Ok(entries) => {
            assert_eq(entries.len(), 1);
            assert_eq(entries[0].params.len(), 1);
        }
        Err(_) => panic("expected Ok"),
    }
}

@test
fn regression_parse_pagination_pair() {
    let s = "</page/1>; rel=\"prev\", </page/3>; rel=\"next\"".clone();
    match link_parse(&s) {
        Ok(entries) => assert_eq(entries.len(), 2),
        Err(_) => panic("expected Ok"),
    }
}

@test
fn regression_find_rel_matches() {
    let s = "</page/2>; rel=\"next\"".clone();
    let entries = link_parse(&s).unwrap();
    match find_rel(&entries, "next") {
        Maybe.Some(_) => assert(true),
        Maybe.None => panic("expected match"),
    }
}

@test
fn regression_find_rel_case_insensitive() {
    let s = "</page/2>; rel=\"NEXT\"".clone();
    let entries = link_parse(&s).unwrap();
    match find_rel(&entries, "next") {
        Maybe.Some(_) => assert(true),
        Maybe.None => panic("expected case-insensitive match"),
    }
}

@test
fn regression_find_rel_no_match() {
    let s = "</page/2>; rel=\"next\"".clone();
    let entries = link_parse(&s).unwrap();
    match find_rel(&entries, "prev") {
        Maybe.Some(_) => panic("should be no match"),
        Maybe.None => assert(true),
    }
}

@test
fn regression_format_round_trip() {
    let s = "</page/2>; rel=\"next\"".clone();
    let entries = link_parse(&s).unwrap();
    let _formatted = format_link_header(&entries);
    assert(entries.len() == 1);
}

@test
fn regression_parse_missing_close_angle() {
    let s = "</foo; rel=\"x\"".clone();
    match link_parse(&s) {
        Ok(_) => panic("missing '>' must reject"),
        Err(_) => assert(true),
    }
}

// REGRESSION (net-conformance-20260705): TUPLE-DESTRUCTURE-INDEXED.
// Binding a tuple via a destructuring `let (a, b) = &list[i]` on an
// INDEXED (or iterator-yielded) list element reads GARBAGE — the tuple
// elements come back as unrelated bits (e.g. a `Text` renders as
// "0.0"). Tuple-INDEX access on the same element (`list[i].0`,
// `list[i].1`) lowers correctly. `find_rel` / `format_link_header` were
// rewritten to use tuple-index (core/net/link_header.vr); this pin
// reproduces the broken destructure shape so a fix flips it live.
// @ignore'd: the garbage read makes the assertion fail (not a crash).
@ignore
@test
fn regression_tuple_destructure_indexed_reads_garbage() {
    let mut pairs: List<(Text, Text)> = [];
    pairs.push(("rel".clone(), "next".clone()));
    // BROKEN shape: destructure of an indexed tuple.
    let (name, value) = &pairs[0];
    assert_eq(name.as_str(), "rel");
    assert_eq(value.as_str(), "next");
}
