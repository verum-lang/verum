// =============================================================================
// core-tests/storage/s3/signing/unit_test.vr
// =============================================================================
//
// `core/storage/s3/signing.vr` — AWS SigV4 request signing.
//
// Tested:
//   * AwsCredentials record construction + field preservation
//   * SignedHeaders record construction
//   * AwsCredentials.session_token Maybe<Text> field independence
//
// Live SigV4 string-to-sign / signature computation deferred behind
// the SHA-256 / HMAC entry points (byte-array compile-time class).
// =============================================================================

mount core.storage.s3.signing.{AwsCredentials, SignedHeaders};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: AwsCredentials construction (permanent IAM-user keys)
// =============================================================================

@test
fn test_aws_credentials_permanent_user_no_session_token() {
    let c: AwsCredentials = AwsCredentials {
        access_key_id:     "AKIAIOSFODNN7EXAMPLE".to_text(),
        secret_access_key: "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY".to_text(),
        session_token:     Maybe.None,
    };
    assert_eq(c.access_key_id, "AKIAIOSFODNN7EXAMPLE");
    assert_eq(c.secret_access_key, "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY");
}

// =============================================================================
// Section 2: AwsCredentials construction (STS session)
// =============================================================================

@test
fn test_aws_credentials_sts_session_has_token() {
    let c: AwsCredentials = AwsCredentials {
        access_key_id:     "ASIAYYYYYYYYYYYYY".to_text(),
        secret_access_key: "secret-xyz".to_text(),
        session_token:     Maybe.Some("session-token-payload".to_text()),
    };
    assert_eq(c.access_key_id, "ASIAYYYYYYYYYYYYY");
    assert_eq(c.secret_access_key, "secret-xyz");
}

@test
fn test_aws_credentials_session_token_none_field_preserved() {
    let c: AwsCredentials = AwsCredentials {
        access_key_id:     "x".to_text(),
        secret_access_key: "y".to_text(),
        session_token:     Maybe.None,
    };
    // session_token is Maybe<Text>; we only check the wrapper-variant tag.
    let st: Maybe<Text> = c.session_token;
    assert(st is Maybe.None);
}

@test
fn test_aws_credentials_session_token_some_field_preserved() {
    let c: AwsCredentials = AwsCredentials {
        access_key_id:     "x".to_text(),
        secret_access_key: "y".to_text(),
        session_token:     Maybe.Some("tok".to_text()),
    };
    let st: Maybe<Text> = c.session_token;
    assert(st is Maybe.Some);
}

// =============================================================================
// Section 3: AwsCredentials field independence across instances
// =============================================================================

@test
fn test_aws_credentials_field_independence() {
    let a: AwsCredentials = AwsCredentials {
        access_key_id:     "AKIA1".to_text(),
        secret_access_key: "s1".to_text(),
        session_token:     Maybe.None,
    };
    let b: AwsCredentials = AwsCredentials {
        access_key_id:     "AKIA2".to_text(),
        secret_access_key: "s2".to_text(),
        session_token:     Maybe.None,
    };
    assert_eq(a.access_key_id, "AKIA1");
    assert_eq(b.access_key_id, "AKIA2");
    assert_eq(a.secret_access_key, "s1");
    assert_eq(b.secret_access_key, "s2");
}

// =============================================================================
// Section 4: SignedHeaders record construction
// =============================================================================

@test
fn test_signed_headers_empty_map_construction() {
    let h: SignedHeaders = SignedHeaders { headers: Map.new() };
    assert_eq(h.headers.len(), 0);
}

@test
fn test_signed_headers_with_entries() {
    let mut m: Map<Text, Text> = Map.new();
    m.insert("authorization".to_text(), "AWS4-HMAC-SHA256 ...".to_text());
    m.insert("x-amz-date".to_text(), "20260528T120000Z".to_text());
    m.insert("x-amz-content-sha256".to_text(), "abc123".to_text());
    let h: SignedHeaders = SignedHeaders { headers: m };
    assert_eq(h.headers.len(), 3);
}

fn main() {}
