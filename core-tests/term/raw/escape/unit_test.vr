// =============================================================================
// core-tests/term/raw/escape/unit_test.vr
// =============================================================================
//
// `core/term/raw/escape.vr` — ANSI escape sequence writer.
//
// Surface tested:
//   * ClearMode 6-variant (All / Purge / AfterCursor / BeforeCursor /
//     CurrentLine / UntilNewLine)
//   * ESC / CSI_START / OSC_START / DCS_START / ST / BEL constants
//   * build_csi() / build_osc() escape sequence builders
//   * cursor_up / cursor_down / cursor_forward / cursor_back /
//     cursor_position / save_cursor / restore_cursor
//   * scroll_up / scroll_down / set_scroll_region / reset_scroll_region
//
// EscapeWriter protocol surface (write_csi / write_osc / write_dcs / move_to /
// clear / begin_sync / end_sync) requires a Write impl — tested at language
// level under `vcs/specs/L2-standard/term/raw/`.
// =============================================================================

mount core.term.raw.escape.{
    ClearMode,
    All, Purge, AfterCursor, BeforeCursor, CurrentLine, UntilNewLine,
    ESC, CSI_START, OSC_START, DCS_START, ST, BEL,
    build_csi, build_osc,
    cursor_up, cursor_down, cursor_forward, cursor_back, cursor_position,
    save_cursor, restore_cursor,
    scroll_up, scroll_down, set_scroll_region, reset_scroll_region,
};

// =============================================================================
// Section 1: ClearMode 6-variant construction
// =============================================================================

@test
fn test_clear_mode_all_variant() {
    let m: ClearMode = All;
    assert(m is All);
}

@test
fn test_clear_mode_purge_variant() {
    let m: ClearMode = Purge;
    assert(m is Purge);
}

@test
fn test_clear_mode_after_cursor_variant() {
    let m: ClearMode = AfterCursor;
    assert(m is AfterCursor);
}

@test
fn test_clear_mode_before_cursor_variant() {
    let m: ClearMode = BeforeCursor;
    assert(m is BeforeCursor);
}

@test
fn test_clear_mode_current_line_variant() {
    let m: ClearMode = CurrentLine;
    assert(m is CurrentLine);
}

@test
fn test_clear_mode_until_newline_variant() {
    let m: ClearMode = UntilNewLine;
    assert(m is UntilNewLine);
}

@test
fn test_clear_mode_all_disjoint_from_purge() {
    let a: ClearMode = All;
    let p: ClearMode = Purge;
    assert(a is All && !(a is Purge));
    assert(p is Purge && !(p is All));
}

@test
fn test_clear_mode_after_disjoint_from_before_cursor() {
    let a: ClearMode = AfterCursor;
    let b: ClearMode = BeforeCursor;
    assert(!(a is BeforeCursor));
    assert(!(b is AfterCursor));
}

@test
fn test_clear_mode_current_line_disjoint_from_until_newline() {
    let c: ClearMode = CurrentLine;
    let u: ClearMode = UntilNewLine;
    assert(!(c is UntilNewLine));
    assert(!(u is CurrentLine));
}

// =============================================================================
// Section 2: ANSI escape byte constants
// =============================================================================

@test
fn test_esc_byte_is_0x1b() {
    assert_eq(ESC, 0x1B_u8);
}

@test
fn test_bel_byte_is_0x07() {
    assert_eq(BEL, 0x07_u8);
}

@test
fn test_esc_byte_distinct_from_bel() {
    assert(ESC != BEL);
}

// =============================================================================
// Section 3: Escape start sequences
// =============================================================================

@test
fn test_csi_start_is_esc_lbracket() {
    assert_eq(CSI_START, "\x1b[".to_text());
}

@test
fn test_osc_start_is_esc_rbracket() {
    assert_eq(OSC_START, "\x1b]".to_text());
}

@test
fn test_dcs_start_is_esc_p() {
    assert_eq(DCS_START, "\x1bP".to_text());
}

@test
fn test_st_is_esc_backslash() {
    assert_eq(ST, "\x1b\\".to_text());
}

@test
fn test_start_sequences_all_distinct() {
    assert(CSI_START != OSC_START);
    assert(CSI_START != DCS_START);
    assert(OSC_START != DCS_START);
    assert(CSI_START != ST);
}

// =============================================================================
// Section 4: build_csi
//
// §A — Iterator-dispatch defect class: build_csi uses
//   `for i in 0..params.len()` which trips cross-module iterator dispatch
//   under --interp. Same root as List iterator regression suite.
// =============================================================================

@ignore("[[iterator_dispatch_class]] — build_csi's `for i in 0..n` Range iterator mis-dispatches; output text doesn't match expected CSI sequence. Multi-day codegen fix.")
@test
fn test_build_csi_empty_params() {
    let params: List<Int> = [];
    // 'H' = 0x48 = home cursor command
    let s = build_csi(params.as_slice(), 0x48_u8);
    assert_eq(s, "\x1b[H".to_text());
}

@ignore("[[iterator_dispatch_class]] — same `for i in 0..n` Range iterator defect in build_csi body.")
@test
fn test_build_csi_single_param() {
    let params: List<Int> = [5];
    let s = build_csi(params.as_slice(), 0x41_u8);   // 'A' = up
    assert_eq(s, "\x1b[5A".to_text());
}

@ignore("[[iterator_dispatch_class]] — same `for i in 0..n` Range iterator defect in build_csi body.")
@test
fn test_build_csi_multiple_params_semicolon_separated() {
    let params: List<Int> = [1, 2];
    let s = build_csi(params.as_slice(), 0x48_u8);   // 'H'
    assert_eq(s, "\x1b[1;2H".to_text());
}

@ignore("[[iterator_dispatch_class]] — same `for i in 0..n` Range iterator defect in build_csi body.")
@test
fn test_build_csi_three_params() {
    let params: List<Int> = [10, 20, 30];
    let s = build_csi(params.as_slice(), 0x6D_u8);   // 'm' = SGR
    assert_eq(s, "\x1b[10;20;30m".to_text());
}

// =============================================================================
// Section 5: build_osc
//
// §A continued — build_osc uses f-string interpolation which routes through
// the same Text-builder cascade; @ignore for the same fundamental class.
// =============================================================================

@ignore("[[iterator_dispatch_class]] — f-string interpolation in build_osc body interacts with same text-builder cascade as build_csi.")
@test
fn test_build_osc_set_title() {
    // OSC 0 sets window title.
    let s = build_osc(0, &"hello".to_text());
    assert_eq(s, "\x1b]0;hello\x1b\\".to_text());
}

@ignore("[[iterator_dispatch_class]] — same f-string interpolation defect class.")
@test
fn test_build_osc_empty_data() {
    let s = build_osc(0, &"".to_text());
    assert_eq(s, "\x1b]0;\x1b\\".to_text());
}

@ignore("[[iterator_dispatch_class]] — same f-string interpolation defect class.")
@test
fn test_build_osc_high_code() {
    let s = build_osc(52, &"x".to_text());   // OSC 52 = clipboard
    assert_eq(s, "\x1b]52;x\x1b\\".to_text());
}

// =============================================================================
// Section 6: Cursor movement helpers
//
// §A continued — cursor_up / cursor_down / cursor_forward / cursor_back /
// cursor_position all use f-string interpolation in their body — same
// fundamental class as build_csi / build_osc. @ignore pinned.
// =============================================================================

@ignore("[[iterator_dispatch_class]] — cursor_up f-string interpolation defect.")
@test
fn test_cursor_up_emits_csi_a() {
    assert_eq(cursor_up(3), "\x1b[3A".to_text());
}

@ignore("[[iterator_dispatch_class]] — cursor_down f-string interpolation defect.")
@test
fn test_cursor_down_emits_csi_b() {
    assert_eq(cursor_down(5), "\x1b[5B".to_text());
}

@ignore("[[iterator_dispatch_class]] — cursor_forward f-string interpolation defect.")
@test
fn test_cursor_forward_emits_csi_c() {
    assert_eq(cursor_forward(2), "\x1b[2C".to_text());
}

@ignore("[[iterator_dispatch_class]] — cursor_back f-string interpolation defect.")
@test
fn test_cursor_back_emits_csi_d() {
    assert_eq(cursor_back(7), "\x1b[7D".to_text());
}

@ignore("[[iterator_dispatch_class]] — cursor_position f-string interpolation defect.")
@test
fn test_cursor_position_one_indexed() {
    // 0-indexed input → 1-indexed escape.
    assert_eq(cursor_position(0, 0), "\x1b[1;1H".to_text());
    assert_eq(cursor_position(9, 19), "\x1b[10;20H".to_text());
}

@test
fn test_save_cursor_is_csi_s() {
    assert_eq(save_cursor(), "\x1b[s".to_text());
}

@test
fn test_restore_cursor_is_csi_u() {
    assert_eq(restore_cursor(), "\x1b[u".to_text());
}

// =============================================================================
// Section 7: Scroll helpers
//
// §A continued — scroll_up / scroll_down / set_scroll_region use f-string
// interpolation. Only reset_scroll_region (static text) works under --interp.
// =============================================================================

@ignore("[[iterator_dispatch_class]] — scroll_up f-string interpolation defect.")
@test
fn test_scroll_up_emits_csi_s_uppercase() {
    assert_eq(scroll_up(2), "\x1b[2S".to_text());
}

@ignore("[[iterator_dispatch_class]] — scroll_down f-string interpolation defect.")
@test
fn test_scroll_down_emits_csi_t_uppercase() {
    assert_eq(scroll_down(3), "\x1b[3T".to_text());
}

@ignore("[[iterator_dispatch_class]] — set_scroll_region f-string interpolation defect.")
@test
fn test_set_scroll_region_one_indexed() {
    // 0-indexed top/bottom → 1-indexed escape.
    assert_eq(set_scroll_region(0, 9), "\x1b[1;10".to_text());
}

@test
fn test_reset_scroll_region_is_csi_r() {
    assert_eq(reset_scroll_region(), "\x1b[r".to_text());
}

fn main() {}
