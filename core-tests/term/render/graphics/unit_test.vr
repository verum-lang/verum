// =============================================================================
// core-tests/term/render/graphics/unit_test.vr
// =============================================================================
//
// `core/term/render/graphics.vr` —
//   * ImageFormat 4-variant (Png / Jpeg / Rgb24 / Rgba32)
// =============================================================================

mount core.term.render.graphics.ImageFormat;
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

@test
fn test_image_format_png_variant() {
    let f: ImageFormat = ImageFormat.Png;
    assert(f is ImageFormat.Png);
}

@test
fn test_image_format_jpeg_variant() {
    let f: ImageFormat = ImageFormat.Jpeg;
    assert(f is ImageFormat.Jpeg);
}

@test
fn test_image_format_rgb24_variant() {
    let f: ImageFormat = ImageFormat.Rgb24;
    assert(f is ImageFormat.Rgb24);
}

@test
fn test_image_format_rgba32_variant() {
    let f: ImageFormat = ImageFormat.Rgba32;
    assert(f is ImageFormat.Rgba32);
}

@test
fn test_image_format_png_disjoint() {
    let f: ImageFormat = ImageFormat.Png;
    assert(!(f is ImageFormat.Jpeg));
    assert(!(f is ImageFormat.Rgb24));
    assert(!(f is ImageFormat.Rgba32));
}

@test
fn test_image_format_jpeg_disjoint() {
    let f: ImageFormat = ImageFormat.Jpeg;
    assert(!(f is ImageFormat.Png));
    assert(!(f is ImageFormat.Rgb24));
    assert(!(f is ImageFormat.Rgba32));
}

@test
fn test_image_format_rgb24_disjoint() {
    let f: ImageFormat = ImageFormat.Rgb24;
    assert(!(f is ImageFormat.Png));
    assert(!(f is ImageFormat.Jpeg));
    assert(!(f is ImageFormat.Rgba32));
}

@test
fn test_image_format_rgba32_disjoint() {
    let f: ImageFormat = ImageFormat.Rgba32;
    assert(!(f is ImageFormat.Png));
    assert(!(f is ImageFormat.Jpeg));
    assert(!(f is ImageFormat.Rgb24));
}

fn main() {}
