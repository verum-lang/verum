// =============================================================================
// core-tests/text/char/regression_test.vr
// =============================================================================
//
// One @test per defect surfaced by `core/text/char.vr`. Each test names the
// defect, points to its audit.md row, and is `@ignore`d while the defect
// is open.
//
// Defect classes:
//   §A  &mut Char mutation in make_ascii_{upper,lower}case
//   §B  eq_ignore_ascii_case false-negative on cross-case pair
//   §C  from_digit returns wrong Char for hex values >= 10
//   §D  general_category misroutes Lu/Ll/Nd/Zs
//   §E  AnyChar / char_any_of: Iterator.next on inner chars list
// =============================================================================

mount core.text.char.{GeneralCategory, AnyChar, char_any_of, char_range};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// §A — `Char.make_ascii_uppercase` (and lowercase) does not mutate (audit.md §A)
// REGRESSION: `let mut c: Char = 'a'; c.make_ascii_uppercase();` leaves c == 'a'.
// The mutation `*self = self.to_ascii_uppercase();` inside the impl does not
// commit at the runtime level — `&mut Char` deref-assign is broken.
// =============================================================================

// §A closed 2026-05-14 via a Tier-0 `char_runtime` intercept that
// operates directly on the caller's Char slot via the CBGR-ref
// writeback discipline.  Same architectural pattern as hasher_runtime
// (closes the precompiled-stdlib-body DerefMut-emit defect).
@test
fn regression_a_make_ascii_uppercase_pinned() {
    let mut c: Char = 'a';
    c.make_ascii_uppercase();
    assert_eq(c, 'A');
}

@test
fn regression_a_make_ascii_lowercase_pinned() {
    let mut c: Char = 'Z';
    c.make_ascii_lowercase();
    assert_eq(c, 'z');
}

// =============================================================================
// §B — eq_ignore_ascii_case CLOSED transitively when §A
// (`Char.make_ascii_uppercase` / `make_ascii_lowercase` via the
// char_runtime intercept) closed.  `eq_ignore_ascii_case`'s body is
// `self.to_ascii_lowercase() == other.to_ascii_lowercase()` —
// both sides go through the pure-conversion path (no `&mut self`),
// which has always worked once the dispatch surface for Char
// methods on Int-shaped receivers was widened (audit char §A).
// Verified 2026-05-17 green under `--interp`.  Active guard going
// forward.
// =============================================================================

@test
fn regression_b_eq_ignore_ascii_case_pinned() {
    let a: Char = 'A';
    let b: Char = 'a';
    assert(a.eq_ignore_ascii_case(&b));
}

@test
fn regression_b_eq_ignore_ascii_case_symmetric_pinned() {
    let a: Char = 'a';
    let b: Char = 'A';
    assert(a.eq_ignore_ascii_case(&b));
}

@test
fn regression_b_eq_ignore_ascii_case_distinct_letters_pinned() {
    let a: Char = 'A';
    let b: Char = 'B';
    assert(!a.eq_ignore_ascii_case(&b));
}

@test
fn regression_b_eq_ignore_ascii_case_non_letter_pinned() {
    // Non-letters compare bit-equal; case folding is identity outside [A-Z]/[a-z].
    let a: Char = '5';
    let b: Char = '5';
    assert(a.eq_ignore_ascii_case(&b));
}

// =============================================================================
// §C — Char.from_digit hex returns wrong char (audit.md §C)
// REGRESSION: `Char.from_digit(10, 16)` returns 'A' (codepoint 65)
// instead of 'a' (codepoint 97).  The user-side body at
// `core/text/char.vr::from_digit` correctly uses `'a' as Int + digit - 10`
// for digit >= 10, and the Tier-0 dispatch_primitive_method intercept
// at `crates/verum_vbc/.../method_dispatch.rs:3412` uses Rust's
// `char::from_digit` which returns lowercase — yet the runtime path
// surfaces uppercase.  Empirically confirmed 2026-05-16 against the
// freshly-built binary embedding the latest precompiled stdlib
// archive.  Root cause is *higher* in the dispatch chain — likely an
// embedded-archive code-gen path that bypasses both the intercept
// and the source-level body, producing the uppercase offset.
// Tracked as task §Y-ALT: dispatch-routing audit for
// `Char.from_digit`.
// =============================================================================

@ignore
@test
fn regression_c_from_digit_hex_pinned() {
    match Char.from_digit(10, 16) {
        Some(c) => assert_eq(c, 'a'),
        None => panic("from_digit(10, 16) should be Some('a')"),
    }
}

@ignore
@test
fn regression_c_from_digit_hex_boundary_pinned() {
    // Full boundary sweep: digit 0..36 in base 36 with lowercase-letter
    // convention for digit >= 10.
    match Char.from_digit(15, 16) {
        Some(c) => assert_eq(c, 'f'),
        None => panic("from_digit(15, 16) should be Some('f')"),
    }
    match Char.from_digit(35, 36) {
        Some(c) => assert_eq(c, 'z'),
        None => panic("from_digit(35, 36) should be Some('z')"),
    }
    match Char.from_digit(0, 10) {
        Some(c) => assert_eq(c, '0'),
        None => panic("from_digit(0, 10) should be Some('0')"),
    }
    match Char.from_digit(9, 10) {
        Some(c) => assert_eq(c, '9'),
        None => panic("from_digit(9, 10) should be Some('9')"),
    }
    // Out-of-range — must return None
    match Char.from_digit(16, 16) {
        Some(_) => panic("from_digit(16, 16) must be None"),
        None => {},
    }
}

// =============================================================================
// §D — Char.general_category misroutes (audit.md §D)
// REGRESSION: `'a'.general_category()` does not return `Lu`/`Ll`/`Nd`/`Zs`
// for the obvious inputs.
// =============================================================================

@ignore
@test
fn regression_d_general_category_lower_letter_pinned() {
    let cat = 'a'.general_category();
    assert(cat is GeneralCategory.Ll);
}

@ignore
@test
fn regression_d_general_category_upper_letter_pinned() {
    let cat = 'A'.general_category();
    assert(cat is GeneralCategory.Lu);
}

@ignore
@test
fn regression_d_general_category_decimal_digit_pinned() {
    let cat = '5'.general_category();
    assert(cat is GeneralCategory.Nd);
}

@ignore
@test
fn regression_d_general_category_space_separator_pinned() {
    let cat = ' '.general_category();
    assert(cat is GeneralCategory.Zs);
}

// =============================================================================
// §E — AnyChar.matches via internal iteration (audit.md §E)
// REGRESSION: `char_any_of(&['a','b','c']).matches('a')` panics with
// "method 'next' not found on receiver of runtime kind `Int`". Same root as
// the text/text §C iterator dispatch defect — AnyChar.matches uses
// `chars.iter().any(...)` internally.
// =============================================================================

@ignore
@test
fn regression_e_any_of_matches_pinned() {
    let p = char_any_of(&['a', 'e', 'i']);
    assert(p.matches('a'));
    assert(!p.matches('z'));
}

// =============================================================================
// Active PASS-GUARDs — locks in already-green Char API surface
// =============================================================================

@test
fn guard_ascii_classify() {
    assert('a'.is_ascii_alphabetic());
    assert('A'.is_ascii_alphabetic());
    assert('5'.is_ascii_digit());
    assert('!'.is_ascii_punctuation());
    assert(' '.is_ascii_whitespace());
}

@test
fn guard_ascii_case_pure_conversion() {
    assert_eq('a'.to_ascii_uppercase(), 'A');
    assert_eq('A'.to_ascii_lowercase(), 'a');
    assert_eq('5'.to_ascii_uppercase(), '5');  // identity on non-letters
    assert_eq('5'.to_ascii_lowercase(), '5');
}

@test
fn guard_to_digit_decimal() {
    match '7'.to_digit(10) {
        Some(n) => assert_eq(n, 7),
        None => panic("'7' is a digit"),
    }
}

@test
fn guard_len_utf8_ascii_is_one() {
    assert_eq('a'.len_utf8(), 1);
    assert_eq('Z'.len_utf8(), 1);
    assert_eq('0'.len_utf8(), 1);
    assert_eq(' '.len_utf8(), 1);
}

@test
fn guard_char_range_match() {
    let r = char_range('0', '9');
    assert(r.matches('5'));
    assert(!r.matches('a'));
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {}
