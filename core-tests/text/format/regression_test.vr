// =============================================================================
// core-tests/text/format/regression_test.vr
// =============================================================================
//
// Defects pinned for `core/text/format.vr`. The format module is largely
// healthy — 39 / 41 unit tests pass. The two failures concentrate in
// the `format_display` and `format_debug` free functions, which take a
// generic-typed argument and route through a closure dispatch path.
//
// Defect classes:
//   §A  format_display<T: Display> / format_debug<T: Debug> trigger
//       "TypeMismatch: expected closure, got non-pointer"
//   §H  `(&Int).to_hex()` (value-self method via reference receiver)
//       passes raw pointer-bits as `self` instead of dereferencing.
//       Surfaced 2026-05-27 via the format_hex / format_binary /
//       format_octal module-level wrappers (which took `value: &Int`
//       and called `value.to_hex()`).  Workaround applied: explicit
//       `*value` deref in the wrappers (see format.vr).  Pinning the
//       underlying defect class here so re-introduction surfaces.
// =============================================================================

mount core.text.{Text};
mount core.text.format.{
    WriteError, WriteErrorKind,
    TextAlignment, Sign, FormatSpec,
    format_debug, format_display,
    format_hex, format_binary, format_octal,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// §A — format_display / format_debug TypeMismatch on closure dispatch
// REGRESSION: `format_display(&n)` for `n: Int` triggers
// `TypeMismatch { expected: "closure", got: "non-pointer", operation:
// "call_closure" }`. The function is generic over `<T: Display>` and
// internally constructs a TextFormatter, then calls
// `T.fmt(formatter)`. The dispatch site appears to interpret the
// fn-pointer as a generic callable; same family as the receiver-kind
// classification issue in char/§A and text/text/§B.
// =============================================================================

// §A closed 2026-05-15: transitively closed via the cumulative
// primitive method dispatch fixes earlier this session.
@test
fn regression_a_format_display_int_pinned() {
    let n: Int = 5;
    let s = format_display(&n);
    assert_eq(s, "5");
}

// §A closed 2026-05-15: transitively closed via the cumulative
// primitive method dispatch fixes earlier this session.
@test
fn regression_a_format_debug_int_pinned() {
    let n: Int = 5;
    let s = format_debug(&n);
    assert_eq(s, "5");
}

// =============================================================================
// Active PASS-GUARDs — the data-shaping and format-string surface is healthy.
// =============================================================================

@test
fn guard_alignment_default_left() {
    let a: TextAlignment = TextAlignment.default();
    assert(a is TextAlignment.Left);
}

@test
fn guard_sign_default_minus() {
    let s: Sign = Sign.default();
    assert(s is Sign.Minus);
}

@test
fn guard_write_error_kind_eq_self() {
    assert(WriteErrorKind.Io == WriteErrorKind.Io);
    assert(WriteErrorKind.BufferFull == WriteErrorKind.BufferFull);
    assert(WriteErrorKind.Encoding == WriteErrorKind.Encoding);
}

@test
fn guard_write_error_factories() {
    assert(WriteError.io().kind is WriteErrorKind.Io);
    assert(WriteError.buffer_full().kind is WriteErrorKind.BufferFull);
}

@test
fn guard_format_spec_default_invariants() {
    let s: FormatSpec = FormatSpec.default();
    assert_eq(s.fill, ' ');
    assert(!s.alternate);
    assert(s.align is TextAlignment.Left);
    assert(s.sign is Sign.Minus);
    assert(s.width is None);
    assert(s.precision is None);
}

@test
fn guard_format_string_int_display() {
    let n: Int = 42;
    assert_eq(f"{n}", "42");
}

@test
fn guard_format_string_text_display() {
    let s: Text = "hello";
    assert_eq(f"{s}", "hello");
}

@test
fn guard_format_string_bool_display() {
    assert_eq(f"{true}", "true");
    assert_eq(f"{false}", "false");
}

// =============================================================================
// §H — PASS-GUARDs for the format_hex / format_binary / format_octal
// wrappers.  The fix in core/text/format.vr uses an explicit `*value`
// dereference; if a reviewer reverts that to the bare `value.to_hex()`
// form, these three guards regress immediately.
// =============================================================================

@test
fn guard_format_hex_dereferences_input() {
    let v: Int = 255;
    assert_eq(format_hex(&v), "ff");
}

@test
fn guard_format_binary_dereferences_input() {
    let v: Int = 10;
    assert_eq(format_binary(&v), "1010");
}

@test
fn guard_format_octal_dereferences_input() {
    let v: Int = 64;
    assert_eq(format_octal(&v), "100");
}

@test
fn guard_format_hex_zero_is_zero_digit() {
    let v: Int = 0;
    assert_eq(format_hex(&v), "0");
}

// =============================================================================
// Underlying defect probe — `(&Int).to_hex()` (reference receiver, value-
// self method on a primitive) should auto-dereference to the pointee
// value.  The current Tier-0 codegen does NOT do this — it passes the
// CBGR pointer bits as the `self: Int` arg, so `format_radix_signed`
// formats the pointer instead.  Pinned `@ignore` because the fix lives
// in `crates/verum_vbc/src/codegen/expressions.rs::compile_method_call`'s
// receiver-handling for primitive value-self methods through `&Primitive`
// references.  When the fix lands, removing `@ignore` flips this green.
// =============================================================================

@ignore
@test
fn regression_h_ref_int_to_hex_auto_deref_pinned() {
    let v: Int = 255;
    let r: &Int = &v;
    // Currently returns the hex of the CBGR pointer bits (e.g.
    // "-6c00000002") because the dispatcher feeds the pointer to
    // `Int.to_hex(self: Int)` without dereferencing.
    assert_eq(r.to_hex(), "ff");
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {}
