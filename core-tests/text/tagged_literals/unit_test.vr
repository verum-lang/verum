// =============================================================================
// core-tests/text/tagged_literals/unit_test.vr
// =============================================================================
//
// Unit tests for `core/text/tagged_literals.vr` — runtime validators for
// tagged string literals (`json#"…"`, `sql#"…"`, `uri#"…"`, `regex#"…"`).
//
// API surface (3 free fns):
//   validate_json(s: Text) -> Bool
//   validate_sql(s: Text)  -> Bool
//   validate_uri(s: Text)  -> Bool
//
// Companion files: property_test.vr, integration_test.vr, regression_test.vr,
// audit.md.
// =============================================================================

mount core.text.{Text};
mount core.text.tagged_literals.{validate_json, validate_sql, validate_uri};

// =============================================================================
// Section 1: validate_json — basic structural shape
// =============================================================================

@test
fn test_json_object_minimal() {
    assert(validate_json("{}"));
}

@test
fn test_json_object_nontrivial() {
    assert(validate_json("{\"key\": \"value\"}"));
}

@test
fn test_json_array_minimal() {
    assert(validate_json("[]"));
}

@test
fn test_json_array_with_items() {
    assert(validate_json("[1, 2, 3]"));
}

@test
fn test_json_string_literal() {
    assert(validate_json("\"hello\""));
}

@test
fn test_json_empty_string_invalid() {
    assert(!validate_json(""));
}

@test
fn test_json_unmatched_open_brace() {
    assert(!validate_json("{"));
}

@test
fn test_json_unmatched_close_brace() {
    assert(!validate_json("}"));
}

@test
fn test_json_object_close_with_array_open_invalid() {
    assert(!validate_json("[}"));
}

@test
fn test_json_naked_word_invalid() {
    assert(!validate_json("hello"));
}

// =============================================================================
// Section 2: validate_sql — leading-keyword check
// =============================================================================

@test
fn test_sql_select() {
    assert(validate_sql("SELECT * FROM users"));
}

@test
fn test_sql_insert() {
    assert(validate_sql("INSERT INTO users (name) VALUES ('alice')"));
}

@test
fn test_sql_update() {
    assert(validate_sql("UPDATE users SET name='alice' WHERE id=1"));
}

@test
fn test_sql_delete() {
    assert(validate_sql("DELETE FROM users WHERE id=1"));
}

@test
fn test_sql_create() {
    assert(validate_sql("CREATE TABLE t (a INT)"));
}

@test
fn test_sql_drop() {
    assert(validate_sql("DROP TABLE t"));
}

@test
fn test_sql_alter() {
    assert(validate_sql("ALTER TABLE t ADD COLUMN b TEXT"));
}

@test
fn test_sql_with_cte() {
    assert(validate_sql("WITH x AS (SELECT 1) SELECT * FROM x"));
}

@test
fn test_sql_lowercase_select_normalised_via_to_upper() {
    assert(validate_sql("select * from users"));
}

@test
fn test_sql_mixed_case_normalised() {
    assert(validate_sql("Select * From users"));
}

@test
fn test_sql_garbage_invalid() {
    assert(!validate_sql("not a sql statement"));
}

@test
fn test_sql_empty_invalid() {
    assert(!validate_sql(""));
}

// =============================================================================
// Section 3: validate_uri — scheme://authority
// =============================================================================

@test
fn test_uri_https() {
    assert(validate_uri("https://example.com"));
}

@test
fn test_uri_http() {
    assert(validate_uri("http://example.com/path"));
}

@test
fn test_uri_ftp() {
    assert(validate_uri("ftp://files.example.com"));
}

@test
fn test_uri_file() {
    assert(validate_uri("file:///etc/hosts"));
}

@test
fn test_uri_no_scheme_invalid() {
    assert(!validate_uri("example.com"));
}

@test
fn test_uri_only_scheme_invalid() {
    assert(!validate_uri("https:"));
}

@test
fn test_uri_empty_invalid() {
    assert(!validate_uri(""));
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {}
