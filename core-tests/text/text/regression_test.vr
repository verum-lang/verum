// =============================================================================
// core-tests/text/text/regression_test.vr
// =============================================================================
//
// One @test per past defect (or current defect class) in `core/text/text.vr`
// and the supporting language plumbing it relies on. Each test names the
// defect, points to its audit.md row, and either *pins the symptom* (with
// `@ignore` while the defect is open) or *guards the fix* (active, must
// stay green forever).
//
// The taxonomy:
//   §A  rfind dispatch / "Text.rfind not found on Object"
//   §B  Char.encode_utf8 dispatch / "not found on receiver of Int"
//   §C  Iterator.next dispatch on Chars / Lines / ByteIter / CharIndices
//   §D  Function-id collision (FunctionId(12039) etc.)
//   §E  Text.truncate NullPointer on small / empty Text
//   §F  Text.find returning wrong byte index (semantic)
//   §G  Text.contains returning wrong Bool (semantic)
//   §H  Text.find_char / index_of returning wrong index
//   §I  Text.cmp returning wrong Ordering on lexicographic input
//   §J  Debug-format escape sequences (\\n, \\t, \\\\, \\")
//   §K  Text padding/center/zfill — width/fill not applied
//   §L  Text.replace / replacen — replacement not propagated
//   §M  Text.from_utf8 / from_utf8_lossy — Utf8Error not raised on invalid input
//   §N  Text.into_bytes — List.extend_from_slice missing
//   §O  Text.from_int / parse_int round-trip — function-id collision symptom
//   §P  Text.split_once / strip_prefix / strip_suffix — None when match exists
//   §Q  Text.capitalize / to_title_case / swapcase — case helpers no-op or wrong
//   §R  count_matches — interpreter panic "Expected int, got Some(3)"
//
// Convention: a regression test is `@ignore`d while the defect is open
// AND has a pin in audit.md. When a fix lands, remove `@ignore` and let the
// test become a green guard against re-regression.
// =============================================================================

mount core.text.{Text, Utf8Error, ParseError};
mount core.text.format.{format_debug, format_display};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.collections.list.List;

// =============================================================================
// §A — Text.rfind dispatch broken (audit.md §A)
// REGRESSION: `Text.rfind` reports "method not found on receiver of runtime
// kind `Object`". Affects rfind directly + every method that calls rfind:
// rsplit, rsplitn, rsplit_once, contains_any, index_of_any, AND apparently
// to_ascii_uppercase / to_ascii_lowercase indirectly. Likely cause: stdlib
// lenient-skip OR archive-load function-id remap loses rfind binding.
// =============================================================================

@test
fn regression_a_rfind_basic_pinned() {
    match "ababab".rfind(&"ab") {
        Some(i) => assert_eq(i, 4),
        None => panic("rfind('ab') in 'ababab' must be Some(4)"),
    }
}

// =============================================================================
// §B — Char.encode_utf8 dispatched on Int receiver (audit.md §B)
// REGRESSION: `Text.insert(idx, ch)` calls `ch.encode_utf8(&mut buf)` and the
// runtime dispatch routes to receiver kind `Int` instead of `Char`. Same
// class as the SelfValue is_type_param fix (commit 90b94e68b context) — but
// here it's the receiver-kind classification at the dispatch site, not the
// is_type_param gate.
// =============================================================================

@test
fn regression_b_text_insert_uses_encode_utf8_pinned() {
    let mut s: Text = "ac";
    s.insert(1, 'b');
    assert_eq(s, "abc");
}

// =============================================================================
// §C — Iterator.next dispatch on Chars / Lines / ByteIter / CharIndices
// CLOSED 2026-05-13 by commit 48a76117f (vbc/dispatch). Three architectural
// fixes in `crates/verum_vbc/src/interpreter/dispatch_table/handlers/method_dispatch.rs`:
//   1. Removed the wrong `chars` intercept that returned `List<Text>` instead
//      of the source-level `Chars` iterator.
//   2. Tightened the func-id-as-method-id heuristic with a parent_type-vs-
//      receiver compatibility gate (`func_id_parent_compatible_with_receiver`).
//   3. Tightened the second-pass bare-suffix scan with the same compatibility
//      check for heap receivers (`heap_receiver_parent_compatible`).
// The active guard test below now passes — keep it green forever as the
// re-regression detector.
// =============================================================================

@test
fn regression_c_chars_iterator_next_pinned() {
    let s: Text = "abc";
    let mut count: Int = 0;
    for _c in s.chars() {
        count = count + 1;
    }
    assert_eq(count, 3);
}

// =============================================================================
// §D — Function-id collision / FunctionNotFound(FunctionId(N)) (audit.md §D)
// REGRESSION: cross-module function-id resolution drops bindings for
// `Text.from_int` / `Text.concat` / `Text.push_byte` / `Text.reserve` /
// `Text.make_ascii_uppercase`. Same defect class as the
// `stdlib_bootstrap.initialize()` revert in MEMORY (per-module
// next_func_id namespaces colliding at archive load).
// =============================================================================

@test
fn regression_d_text_from_int_function_id_pinned() {
    assert_eq(Text.from_int(42), "42");
}

// =============================================================================
// §E — Text.truncate NullPointer on small/empty Text (audit.md §E)
// REGRESSION: `Text.truncate(n)` panics with `NullPointerAt opcode 0x63`
// when invoked on a Text whose `cap == 0` (static / SSO inline). Expected:
// truncate is a no-op or shrinks `len`; null write must be guarded behind
// `cap > 0 && !is_null(ptr)` (mirrors Drop's invariant at line 3387).
// =============================================================================

@test
fn regression_e_truncate_static_text_pinned() {
    let mut s: Text = "hello";   // static, cap == 0
    s.truncate(2);
    assert_eq(s, "he");
}

// Indirect surface — `pop` and `clear` both invoke `truncate`.
@test
fn regression_e_pop_static_text_pinned() {
    let mut s: Text = "abc";
    let _ = s.pop();
    assert_eq(s, "ab");
}

@test
fn regression_e_clear_static_text_pinned() {
    let mut s: Text = "hello";
    s.clear();
    assert(s.is_empty());
}

// =============================================================================
// §F — Text.find returns wrong byte index (audit.md §F)
// REGRESSION: `find(&"ell")` in `"hello"` should return Some(1). Empirically
// returns None or a wrong index. The KMP failure-table preprocessing likely
// returns wrong results — `kmp_failure_table` / `kmp_find` interaction.
// =============================================================================

@test
fn regression_f_find_returns_correct_index_pinned() {
    match "hello".find(&"ell") {
        Some(i) => assert_eq(i, 1),
        None => panic("find('ell') in 'hello' must be Some(1)"),
    }
}

// =============================================================================
// §G — Text.contains returns wrong Bool (audit.md §G)
// REGRESSION: `"hello".contains(&"ell")` returns false. Downstream of §F
// since `contains` likely delegates to `find(...).is_some()`.
// =============================================================================

@test
fn regression_g_contains_present_pinned() {
    assert("hello".contains(&"ell"));
}

// =============================================================================
// §H — index_of / find_char wrong index — CLOSED transitively when §F
// (Text.find KMP indexing) closed via commit f8d70e6ef.  Both aliases
// (`index_of`, `find_char`) delegate to `find`, so the upstream close
// flips them green automatically.  Verified 2026-05-16:
// `"hello".index_of(&"ll")` returns `Some(2)`.  Active guard going
// forward — re-introduction of the find-byte-index defect surfaces
// here immediately.
// =============================================================================

@test
fn regression_h_index_of_alias_pinned() {
    match "hello".index_of(&"ll") {
        Some(i) => assert_eq(i, 2),
        None => panic("index_of('ll') in 'hello' must be Some(2)"),
    }
}

@test
fn regression_h_index_of_empty_needle_pinned() {
    // Empty needle convention: should match at position 0.
    match "hello".index_of(&"") {
        Some(i) => assert_eq(i, 0),
        None => panic("index_of('') in 'hello' must be Some(0)"),
    }
}

@test
fn regression_h_index_of_absent_returns_none_pinned() {
    match "hello".index_of(&"world") {
        Some(_) => panic("index_of('world') in 'hello' must be None"),
        None => {},
    }
}

@test
fn regression_h_index_of_first_occurrence_pinned() {
    // Multiple occurrences — must return the FIRST byte offset.
    match "ababab".index_of(&"ab") {
        Some(i) => assert_eq(i, 0),
        None => panic("index_of('ab') in 'ababab' must be Some(0)"),
    }
}

// =============================================================================
// §I — Text.cmp wrong Ordering result (audit.md §I)
// REGRESSION: `"abc".cmp(&"abd")` returns wrong variant. Suspect: byte-wise
// comparison loop range/index off-by-one or wrong Ordering variant
// constructor at the codegen level (see MEMORY §22 — variant tag stability).
// =============================================================================

@test
fn regression_i_cmp_lex_less_pinned() {
    let a: Text = "abc";
    let b: Text = "abd";
    assert_eq(a.cmp(&b), Less);
}

@test
fn regression_i_cmp_shorter_less_pinned() {
    let a: Text = "ab";
    let b: Text = "abc";
    assert_eq(a.cmp(&b), Less);
}

// =============================================================================
// §J — Debug format escape sequences (audit.md §J)
// REGRESSION: `f"{s:?}"` does not produce the expected escaped form. The
// `Debug for Text` impl matches each control char and writes a sequence
// like `\\n` — but the produced output diverges, suggesting either the
// match arms misroute or the format-spec router does not dispatch
// `fmt_debug` for the `?` type-hint when the inner type is `Text`.
// =============================================================================

@ignore
@test
fn regression_j_debug_format_quotes_pinned() {
    let s: Text = "hi";
    assert_eq(f"{s:?}", "\"hi\"");
}

@ignore
@test
fn regression_j_debug_format_newline_escape_pinned() {
    let s: Text = "a\nb";
    assert_eq(f"{s:?}", "\"a\\nb\"");
}

// =============================================================================
// §K — Padding helpers misbehave (audit.md §K)
// REGRESSION: `pad_left(5, ' ')` does not pad. Width / fill arguments either
// are dropped at the codegen level (variant constructor mis-routing again?)
// or the helper bodies were lenient-skipped at stdlib bootstrap.
// =============================================================================

@test
fn regression_k_pad_left_pinned() {
    assert_eq("ab".pad_left(5, ' '), "   ab");
}

// =============================================================================
// §L — Text.replace not propagating replacement (audit.md §L)
// REGRESSION: `replace(&"a", &"b")` returns a Text that is not the expected
// substituted form. May be downstream of §F (KMP search) or §A (rfind
// resolution) depending on which path the body takes.
// =============================================================================

@test
fn regression_l_replace_pinned() {
    assert_eq("aaa".replace(&"a", &"b"), "bbb");
}

// =============================================================================
// §M — from_utf8 not raising Utf8Error on invalid input (audit.md §M)
// REGRESSION: `Text.from_utf8(invalid_bytes)` returns `Ok(...)` instead of
// `Err(Utf8Error)`. The `utf8_validate` helper at the top of text.vr returns
// the wrong Bool, OR the Result wiring at the call site swallows the Err.
// =============================================================================

@test
fn regression_m_from_utf8_invalid_returns_err_pinned() {
    let bytes: List<Byte> = [0xC0 as Byte, 0x20 as Byte];
    match Text.from_utf8(&bytes) {
        Ok(_) => panic("invalid UTF-8 must be Err"),
        Err(_) => {},
    }
}

// =============================================================================
// §N — Text.into_bytes — CLOSED 2026-05-16
// Was: `Text.into_bytes()` panicked with "List.extend_from_slice not found
// on receiver of runtime kind 'Object'" — cross-module dispatch collapse,
// same class as §D (function-id collision in archive remap).
//
// Fundamental fix: `core/text/text.vr::into_bytes` now uses the canonical
// indexed-while push pattern over `self.as_bytes()` (audit §4 architectural
// rule for slice iteration in stdlib bodies). No dependency on the
// cross-module `List.extend_from_slice` dispatch — eliminates the whole
// failure class for `Text → List<Byte>` conversion.
//
// Active guard: this test stays alive forever so a re-introduction of the
// extend_from_slice idiom (or any reversion of the dispatch fix) surfaces
// immediately as a regression failure.
// =============================================================================

@test
fn regression_n_into_bytes_ascii() {
    let s: Text = "AB";
    let bs = s.into_bytes();
    assert_eq(bs.len(), 2);
    assert_eq(bs[0] as Int, 65);
    assert_eq(bs[1] as Int, 66);
}

@test
fn regression_n_into_bytes_empty() {
    let s: Text = "";
    let bs = s.into_bytes();
    assert_eq(bs.len(), 0);
}

@test
fn regression_n_into_bytes_unicode_two_byte() {
    // 'é' = U+00E9 → C3 A9
    let s: Text = "é";
    let bs = s.into_bytes();
    assert_eq(bs.len(), 2);
    assert_eq(bs[0] as Int, 0xC3);
    assert_eq(bs[1] as Int, 0xA9);
}

@test
fn regression_n_into_bytes_unicode_three_byte() {
    // '€' = U+20AC → E2 82 AC
    let s: Text = "€";
    let bs = s.into_bytes();
    assert_eq(bs.len(), 3);
    assert_eq(bs[0] as Int, 0xE2);
    assert_eq(bs[1] as Int, 0x82);
    assert_eq(bs[2] as Int, 0xAC);
}

// =============================================================================
// §O — Text.from_int FunctionNotFound (audit.md §O)
// REGRESSION: `Text.from_int(0)` panics with `FunctionNotFound(FunctionId(N))`.
// Same root as §D (function-id collision). Pinned separately because
// from_int is the load-bearing API surface for f"{n}" and most format-string
// integer interpolations.
// =============================================================================

@test
fn regression_o_from_int_pinned() {
    assert_eq(Text.from_int(0), "0");
}

// =============================================================================
// §P — split_once / strip_prefix / strip_suffix return None when match exists
//      (audit.md §P)
// REGRESSION: `"key=value".split_once(&"=")` returns None. Same root as §F
// (find returns wrong index) since split_once delegates to find.
// =============================================================================

@test
fn regression_p_split_once_pinned() {
    match "key=value".split_once(&"=") {
        Some(pair) => {
            assert_eq(pair.0, "key");
            assert_eq(pair.1, "value");
        }
        None => panic("split_once('=') must be Some on 'key=value'"),
    }
}

// =============================================================================
// §Q — capitalize / to_title_case / swapcase no-op or wrong (audit.md §Q)
// REGRESSION: `"hello".capitalize()` returns "hello" instead of "Hello".
// =============================================================================

@test
fn regression_q_capitalize_pinned() {
    assert_eq("hello".capitalize(), "Hello");
}

// =============================================================================
// §R — count_matches triggers internal compiler error (audit.md §R)
// REGRESSION: `count_matches` triggers an *internal compiler error*
// ("Expected int, got Some(3)") at compile time. This is a type-inference
// regression in the typechecker, not a stdlib defect — code that mentions
// `count_matches` cannot even compile.
// =============================================================================

@test
fn regression_r_count_matches_compile_pinned() {
    let n = "aaaa".count_matches(&"aa");
    assert_eq(n, 2);
}

// =============================================================================
// Active regression guards — these tests pass today and must keep passing.
// They lock in fixes already landed earlier in the branch.
// =============================================================================

// PASS-GUARD: extract_string CBGR-ref auto-deref (commit f8d70e6ef).
// Pre-fix every &Text arg to a Text intercept fell through to the
// `<value:N>` debug-format fallback. find / contains / replace / split /
// strip_prefix / strip_suffix / rfind / index_of / find_char /
// split_once / rsplit_once / eq_ignore_case / starts_with / ends_with
// were all silently broken. ~25 downstream tests pinned this defect.
@test
fn guard_find_via_borrowed_needle() {
    match "hello".find(&"ell") {
        Some(i) => assert_eq(i, 1),
        None => panic("extract_string CBGR-deref regression — find(&\"ell\") in \"hello\" must be Some(1)"),
    }
}

@test
fn guard_replace_via_borrowed_args() {
    let r = "aaa".replace(&"a", &"b");
    assert_eq(r, "bbb");
}

@test
fn guard_contains_starts_ends_with_via_borrowed_needle() {
    assert("hello".contains(&"ell"));
    assert("hello".starts_with(&"he"));
    assert("hello".ends_with(&"lo"));
}

@test
fn guard_split_once_via_borrowed_separator() {
    match "key=value".split_once(&"=") {
        Some(pair) => {
            assert_eq(pair.0, "key");
            assert_eq(pair.1, "value");
        }
        None => panic("split_once must find '='"),
    }
}

// PASS-GUARD: utf8_decode_char 2-arg fix (commit 5d04b98e7).
// Pre-fix the runtime handler read 1 register treating it as a code
// point. After fix it reads bytes + idx and decodes UTF-8 properly.
@test
fn guard_utf8_decode_char_proper_codepoint() {
    let s: Text = "abc";
    let mut out: List<Char> = [];
    for c in s.chars() {
        out.push(c);
    }
    assert_eq(out.len(), 3);
    assert_eq(out[0], 'a');
    assert_eq(out[1], 'b');
    assert_eq(out[2], 'c');
}

// PASS-GUARD: `Text.new()` must be empty.
@test
fn guard_new_is_empty() {
    let s = Text.new();
    assert(s.is_empty());
    assert_eq(s.len(), 0);
}

// PASS-GUARD: literal Text equality is structural.
@test
fn guard_literal_eq() {
    assert("hello" == "hello");
    assert("a" != "b");
}

// PASS-GUARD: `as_bytes` returns ASCII byte values for ASCII literals.
@test
fn guard_as_bytes_ascii() {
    let s: Text = "AB";
    let b = s.as_bytes();
    assert_eq(b.len(), 2);
    assert_eq(b[0] as Int, 65);
    assert_eq(b[1] as Int, 66);
}

// PASS-GUARD: `len` matches byte length for ASCII.
@test
fn guard_len_ascii() {
    assert_eq("hello".len(), 5);
    assert_eq("".len(), 0);
}

// PASS-GUARD: `starts_with(empty)` is true.
@test
fn guard_starts_with_empty_is_true() {
    assert("hello".starts_with(&""));
}

// PASS-GUARD: `to_int` from a positive integer literal text round-trips.
@test
fn guard_to_int_roundtrip() {
    let n = "42".to_int();
    assert_eq(n, 42);
}

// =============================================================================
// REGRESSION (closed): Text.capacity() reports the true cap field
// =============================================================================
//
// Pre-fix, `Text.with_capacity(64).capacity()` returned 0 because
// `core/text/text.vr::capacity()` body called `text_byte_len(self)`
// for every representation, silently losing the `cap` field on builder-
// layout Text values.
//
// Closed by adding a `capacity` intercept in the Tier-0 method dispatch
// at `crates/verum_vbc/src/interpreter/dispatch_table/handlers/
// method_dispatch.rs` that dispatches by Text representation:
//   * Small-string (NaN-boxed inline): capacity == byte_len
//   * FatRef Text (immutable view): capacity == byte_len
//   * Heap-string flat layout `[hdr][len:u64][bytes...]`: capacity == byte_len
//   * Builder layout `[hdr]{ptr,len,cap}` (24-byte payload): capacity == cap (field2)
//
// These pass-guards keep the contract pinned so any regression on the
// dispatch surfaces immediately.

@test
fn regression_with_capacity_reports_capacity() {
    let t: Text = Text.with_capacity(64);
    assert(t.capacity() >= 64);
}

@test
fn regression_try_with_capacity_reports_capacity() {
    let r: Result<Text, _> = Text.try_with_capacity(64);
    match r {
        Ok(t) => assert(t.capacity() >= 64),
        Err(_) => panic("try_with_capacity(64) must succeed"),
    };
}

// `reserve` closed by the dedicated CallM intercept in
// `method_dispatch.rs` that migrates small-string receivers to
// builder layout via the CBGR-ref writeback discipline (mirrors
// the `push_str` / `push` intercept).  After this intercept,
// `t.reserve(N)` produces a builder-layout Text with
// `cap = max(old_cap, len + N)`.
@test
fn regression_reserve_grows_reported_capacity() {
    let mut t: Text = Text.new();
    t.reserve(128);
    assert(t.capacity() >= 128);
}

// =============================================================================
// REGRESSION (closed): Text.join intercept reads List<Text> backing layout
// =============================================================================
//
// Pre-fix, `Text.join(&parts, &sep)` returned empty for any non-empty
// `parts: List<Text>`.  Two bugs in the Tier-0 intercept at
// `crates/verum_vbc/src/interpreter/dispatch_table/handlers/
// text_static_runtime.rs::"join"`:
//
// 1. The len field was read as a raw `i64` instead of through
//    `Value::as_i64()` — skipping the NaN-box unwrap.
// 2. The element data pointer was read at `after_header + 16` as a
//    direct element-data pointer, but the canonical List layout
//    stores the backing-array OBJECT pointer in field 2, and the
//    element data begins at `backing_ptr + OBJECT_HEADER_SIZE`.
//
// Fix: align with the canonical List<T> heap layout used by
// `method_dispatch.rs::list_push` —
//   `[ObjectHeader][len: Value(i64)][cap: Value(i64)][backing: Value(ptr)]`
//   where `backing` points to an ObjectHeader-prefixed element array.
//
// Closed by task #8.

@test
fn regression_join_single_part_returns_part() {
    let parts: List<Text> = ["only"];
    assert_eq(Text.join(&parts, &","), "only");
}

@test
fn regression_join_two_parts_with_separator() {
    let parts: List<Text> = ["a", "b"];
    let sep: Text = ",";
    assert_eq(Text.join(&parts, &sep), "a,b");
}

// =============================================================================
// REGRESSION (closed): DefaultHasher cross-tier divergence
// =============================================================================
//
// Pre-fix, `DefaultHasher.write(bytes).finish()` returned the SAME
// u64 for distinct inputs on the Tier-0 interpreter, while AOT
// correctly distinguished them.  Bisection (task #10) revealed two
// compounding root causes:
//
// (1) The user-side `Hasher.write(&mut self, bytes: &[Byte])` body
//     performs `self.state = …` SetF on a `&mut self` whose method
//     has a slice argument; that SetF doesn't persist to the caller's
//     frame in the precompiled stdlib body (task #11 — architectural
//     codegen defect, separate fix path).
//
// (2) The `try_intercept_file_runtime` Tier-0 intercept strips
//     qualifiers and matches on bare names — it consumed every
//     `*.write` call with arg_count == 2 regardless of the type
//     qualifier, routing `DefaultHasher.write` to the FS write
//     dispatch.
//
// Closed by adding a dedicated `hasher_runtime` Tier-0 intercept that
// fires BEFORE `file_runtime` in the dispatch chain.  The intercept
// computes the canonical FxHash 64-bit step directly on the heap
// record's state field, in place — bypassing both the broken stdlib
// body and the misclassifying file_runtime intercept.

@test
fn regression_default_hasher_distinguishes_inputs() {
    let mut ha: DefaultHasher = DefaultHasher.new();
    let mut hb: DefaultHasher = DefaultHasher.new();
    ha.write("alpha".as_bytes());
    hb.write("beta".as_bytes());
    assert(ha.finish() != hb.finish());
}

// =============================================================================
// §V — Task #24 close: interior-field-ref auto-deref across function
// boundaries.
//
// Pre-fix: `clone_nums(&self.field)` worked at the argument-passing
// boundary, but inside the callee `src.len()` / `src[i]` dispatched
// against the interior pointer's *parent record's* ObjectHeader
// instead of the actual List.  Every cross-frame
// reference-borrow of a record field surfaced as `length: 0` /
// `IndexOutOfBounds(0, 0)`.
//
// Root cause: `RefField` (emitted by `&record.field`) lowers to a
// `Value::from_ptr(field_ptr)` tracked in `state.cbgr_mutable_ptrs`.
// `dispatch_method_call`, `handle_get_index`, and `handle_set_index`
// each had `is_cbgr_ref` and `is_thin_ref` deref branches but lacked
// the parallel branch for the heap-interior-pointer shape.  When the
// receiver/array was Value::from_ptr-in-cbgr_mutable_ptrs, the
// downstream dispatcher (`dispatch_array_method`, etc.) treated the
// interior ptr as the object base and read the wrong header.
//
// Fix: add the third deref branch parallel to the existing two in
// all three sites.  Architectural rule: every reference-shape unwrap
// site MUST handle (a) CBGR-register-ref, (b) ThinRef, (c)
// heap-interior-pointer-in-cbgr_mutable_ptrs.
//
// Blast radius: every method on every record type that takes
// `&self.field` for a function call returning a value — `BigInt.abs`,
// `BigInt.add`, `BigInt.neg`, etc., plus every analogous pattern in
// user code.
// =============================================================================

type Holder is { flag: Bool, nums: List<Int> };

implement Holder {
    pub fn build() -> Holder {
        let mut xs: List<Int> = List.with_capacity(3);
        xs.push(7);
        Holder { flag: false, nums: xs }
    }
}

fn clone_nums(src: &List<Int>) -> List<Int> {
    let n = src.len() as Int;
    let mut out: List<Int> = List.with_capacity(n);
    let mut i: Int = 0;
    while i < n { out.push(src[i]); i = i + 1; }
    out
}

@test
fn regression_v_clone_field_via_ref_arg_len() {
    let a = Holder.build();
    let cn = clone_nums(&a.nums);
    assert_eq(cn.len(), 1);
}

@test
fn regression_v_clone_field_via_ref_arg_index() {
    let a = Holder.build();
    let cn = clone_nums(&a.nums);
    assert_eq(cn[0], 7);
}

// =============================================================================
// §W — Char method dispatch through &Char auto-deref (CLOSED 2026-05-16)
// Two probe shapes that previously surfaced "method not found on receiver of
// runtime kind Int" because `&Char` auto-deref to Char NaN-box was racing
// the dispatch-table lookup. Both shapes confirmed green 2026-05-16 by
// promotion from `_diag_char_eqic.vr`. Keep these as permanent guards
// against re-regression of the auto-deref normalisation path.
// =============================================================================

@test
fn regression_w_char_method_on_ref_via_explicit_deref() {
    let a: Char = 'A';
    let r: &Char = &a;
    let v: Char = *r;
    let lc = v.to_ascii_lowercase();
    assert_eq(lc as Int, 97);
}

@test
fn regression_w_char_method_on_ref_direct_dispatch() {
    let a: Char = 'A';
    let r: &Char = &a;
    let lc = r.to_ascii_lowercase();
    assert_eq(lc as Int, 97);
}

// =============================================================================
// §X — Result<Bool, Text> destructure (CLOSED 2026-05-16)
// Cross-payload-type variant-arm routing: the previous defect class kept
// surfacing as Ok(Bool) taking the Err arm because the destructure path
// resolved payload type from the first-registered variant rather than the
// expected scrutinee type (closed by task #5 §3.1 — bidirectional variant
// constructor resolution, commit 6cac007b1). These three tests pin all
// three Bool literal sub-cases and the Int-payload baseline. Promoted
// from `_diag_result_bool.vr`.
// =============================================================================

@test
fn regression_x_result_int_ok_destructure() {
    let r: Result<Int, Text> = Ok(42);
    match r {
        Ok(n) => assert_eq(n, 42),
        Err(_) => panic("Int Ok must take Ok arm"),
    }
}

@test
fn regression_x_result_bool_ok_true_destructure() {
    let r: Result<Bool, Text> = Ok(true);
    match r {
        Ok(b) => assert(b),
        Err(_) => panic("Bool Ok(true) must take Ok arm"),
    }
}

@test
fn regression_x_result_bool_ok_false_destructure() {
    let r: Result<Bool, Text> = Ok(false);
    match r {
        Ok(b) => assert(!b),
        Err(_) => panic("Bool Ok(false) must take Ok arm"),
    }
}

