// =============================================================================
// core-tests/text/numeric/bigint/regression_test.vr
// =============================================================================
//
// One @test per past defect (or current defect class) in
// `core/text/numeric/bigint.vr` and the supporting plumbing it relies on.
//
// Defect classes:
//   §A  Method-return loses digits List field (task #24) — every BigInt
//       arithmetic method returns a BigInt record whose `digits` field
//       behaves as if empty downstream.
// =============================================================================

mount core.text.numeric.bigint.{BigInt, parse_bigint};
mount core.base.result.{Result, Ok, Err};

fn bi(n: Int) -> BigInt {
    BigInt.from_int(n)
}

// =============================================================================
// PASS-GUARDs — exercise canonical construction surfaces that MUST stay green.
// These don't return from method bodies, so they're not blocked by §A.
// =============================================================================

@test
fn guard_zero_is_empty_digits() {
    assert(BigInt.zero().digits.len() == 0);
}

@test
fn guard_one_has_single_digit() {
    let one = BigInt.one();
    assert_eq(one.digits.len(), 1);
    assert_eq(one.digits[0], 1);
    assert(!one.sign);
}

@test
fn guard_from_int_zero() {
    let z = BigInt.from_int(0);
    assert(z.is_zero());
}

@test
fn guard_from_int_positive() {
    let a = BigInt.from_int(42);
    assert(!a.is_negative());
    assert(a.is_positive());
    assert_eq(a.digits.len(), 1);
    assert_eq(a.digits[0], 42);
}

@test
fn guard_from_int_negative() {
    let a = BigInt.from_int(-42);
    assert(a.is_negative());
    assert(!a.is_positive());
    assert_eq(a.digits.len(), 1);
    assert_eq(a.digits[0], 42);
}

// `parse_bigint` is gated by the same task #24 defect family —
// returns a Result<BigInt, ...> whose Ok BigInt has the digits
// field destroyed.  Pinned `@ignore` until the codegen-level
// return-record-shape defect closes.
@ignore
@test
fn guard_parse_simple_positive() {
    match parse_bigint(&"42") {
        Ok(b) => {
            assert_eq(b.digits.len(), 1);
            assert_eq(b.digits[0], 42);
        },
        Err(_) => panic("parse_bigint('42') must succeed"),
    };
}

// =============================================================================
// §A — Method-return loses digits List field (task #24 — CLOSED 2026-05-15)
// =============================================================================
//
// Root cause: when `&self.field` is passed across a function boundary
// (`clone_digits(&self.digits)`), the resulting `Value::from_ptr`
// interior pointer was not auto-derefed by `dispatch_method_call`,
// `handle_get_index`, or `handle_set_index`.  Callee dispatchers
// then treated the parent-record header as the receiver — every
// `src.len()` / `src[i]` mis-routed.  Fix: added the same deref
// branch already present for `is_cbgr_ref` and `is_thin_ref` to
// also handle `Value::from_ptr`-in-`cbgr_mutable_ptrs`.
//
// Pins now exercise positive-magnitude paths. Negative-magnitude
// paths are gated on task #20 (`from_int(-N)` returns empty digits
// — separate function-id-collision class on `abs_int#1`).

@test
fn regression_a_abs_preserves_digits() {
    let a = BigInt.from_int(7);
    let b = a.abs();
    assert_eq(b.digits.len(), 1);
    assert_eq(b.digits[0], 7);
}

@test
fn regression_a_neg_preserves_digits() {
    let a = BigInt.from_int(7);
    let b = a.neg();
    assert_eq(b.digits.len(), 1);
    assert_eq(b.digits[0], 7);
    assert(b.sign);
}

@test
fn regression_a_add_preserves_digits() {
    let a = BigInt.from_int(3);
    let b = BigInt.from_int(4);
    let s = a.add(&b);
    assert_eq(s.digits.len(), 1);
    assert_eq(s.digits[0], 7);
}

// Tasks #14/#15/#16 CLOSED 2026-05-15 (commit `f89967176`).  The
// recursion + collision were ALL one defect: `implement Sub for Int`
// (and Add/Mul/Div/Rem/Neg/BitAnd/...) wrappers in primitives.vr
// resolve `sub(self, rhs)` body call to the enclosing `Int.sub`
// method itself (registered under bare `sub` in the function table),
// emitting a self-recursive `Call(Int.sub)` that StackOverflows at
// depth 16384.  Fix: `try_compile_builtin` now intercepts bare
// `add`/`sub`/`mul`/`div`/`rem`/`neg`/`bitand`/`bitor`/`bitxor`/
// `shl`/`shr`/`clamp`/`signum`/`abs_signed` calls with primitive-
// numeric args and routes them directly to the `ArithExtendedOpcode`
// poly-arith intrinsic — mirrors task #20 §A's unary direct-opcode
// rule for binary.
//
// `sub` via explicit binding works; via transient receiver (or via
// internal `add(&other.neg())` chain) currently NullPointers at
// GetF inside `clone_digits` — that's a separate defect class
// (task #17 — interior-field-ref propagation through chained
// method receivers).
@test
fn regression_a_sub_preserves_digits() {
    let a = BigInt.from_int(10);
    let b = BigInt.from_int(3);
    // Note: requires the workaround shape `add(&-b)` via explicit
    // binding instead of `a.sub(&b)` until task #17 closes.
    let nb = b.neg();
    let d = a.add(&nb);
    assert_eq(d.digits.len(), 1);
    assert_eq(d.digits[0], 7);
}

@test
fn regression_a_mul_preserves_digits() {
    let a = BigInt.from_int(3);
    let b = BigInt.from_int(4);
    let p = a.mul(&b);
    assert_eq(p.digits.len(), 1);
    assert_eq(p.digits[0], 12);
}

// Task #16 close-out — from_int(-N) was returning empty digits via
// the `abs_int#1` function-id collision that surfaced as bare
// `sub`/`add`/etc. recursion in the precompiled body.  Same
// fundamental fix as tasks #14/#15: bare poly-arith intrinsic
// emission means `abs_int`'s body's `sub(0, n)` (or `n < 0` check
// followed by negation) no longer recurses.
@test
fn regression_a_from_int_negative_preserves_magnitude() {
    let a = BigInt.from_int(-42);
    assert(a.is_negative());
    assert_eq(a.digits.len(), 1);
    assert_eq(a.digits[0], 42);

    let b = BigInt.from_int(-1);
    assert(b.is_negative());
    assert_eq(b.digits.len(), 1);
    assert_eq(b.digits[0], 1);
}

// Task #17 close-out: `BigInt.sub` body adopts the explicit-binding
// shape (`let neg_other = other.neg(); self.add(&neg_other)`) instead
// of the chained `self.add(&other.neg())` form to sidestep the
// interior-ref-through-chained-method-receiver gap.  The deeper
// language defect — `&MethodCall()` producing an interior pointer
// that the receiving function's `dispatch_method_call` doesn't
// auto-deref correctly across the precompile / cross-frame boundary
// — is tracked as a separate follow-up under the task #24 cascade
// extension (every reference-shape unwrap site must handle ALL
// referent shapes, including interior-ptr-to-fresh-return-value).
// The stdlib-side workaround keeps the user-facing `a.sub(&b)` API
// surface working through both call shapes.
@test
fn regression_a_sub_via_chained_method_receiver() {
    let a = BigInt.from_int(10);
    let b = BigInt.from_int(3);
    let d = a.sub(&b);
    assert_eq(d.digits.len(), 1);
    assert_eq(d.digits[0], 7);
}

fn main() {}
