// =============================================================================
// core-tests/text/numeric/modular/unit_test.vr
// =============================================================================
//
// Unit tests for `core/text/numeric/modular.vr` — number-theoretic functions
// over BigInt: gcd, lcm, ext_gcd, mod_pow, mod_inverse, mod_sqrt,
// is_probable_prime, crt, crt2.
//
// These tests exercise basic properties; correctness of each function over
// the full domain belongs in property_test (deferred while BigInt has
// dispatch defects upstream).
// =============================================================================

mount core.text.{Text};
mount core.text.numeric.modular.{
    ModularError, gcd, lcm, ext_gcd, mod_pow, mod_inverse,
};
mount core.text.numeric.bigint.{BigInt};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: gcd
// =============================================================================

@test
fn test_gcd_self_self() {
    let a = BigInt.from_int(7);
    let r = gcd(&a, &a);
    assert_eq(r.digits[0], 7);
}

@test
fn test_gcd_one_anything_is_one() {
    let one = BigInt.one();
    let big = BigInt.from_int(42);
    let r = gcd(&one, &big);
    assert(!r.sign);
    assert_eq(r.digits[0], 1);
}

@test
fn test_gcd_simple() {
    // gcd(12, 18) = 6
    let a = BigInt.from_int(12);
    let b = BigInt.from_int(18);
    let r = gcd(&a, &b);
    assert_eq(r.digits[0], 6);
}

@test
fn test_gcd_zero_zero() {
    let z = BigInt.zero();
    let r = gcd(&z, &z);
    assert(r.is_zero());
}

// =============================================================================
// Section 2: lcm
// =============================================================================

@test
fn test_lcm_simple() {
    // lcm(4, 6) = 12
    let a = BigInt.from_int(4);
    let b = BigInt.from_int(6);
    let r = lcm(&a, &b);
    assert_eq(r.digits[0], 12);
}

@test
fn test_lcm_one_x_is_x() {
    let one = BigInt.one();
    let n = BigInt.from_int(7);
    let r = lcm(&one, &n);
    assert_eq(r.digits[0], 7);
}

// =============================================================================
// Section 3: mod_pow
// =============================================================================

@test
fn test_mod_pow_simple() {
    // 2^10 mod 1000 = 1024 mod 1000 = 24
    let base = BigInt.from_int(2);
    let exp = BigInt.from_int(10);
    let modulus = BigInt.from_int(1000);
    match mod_pow(&base, &exp, &modulus) {
        Ok(r) => assert_eq(r.digits[0], 24),
        Err(_) => panic("2^10 mod 1000 = 24"),
    }
}

@test
fn test_mod_pow_one_to_anything_is_one() {
    let base = BigInt.one();
    let exp = BigInt.from_int(1000);
    let modulus = BigInt.from_int(7);
    match mod_pow(&base, &exp, &modulus) {
        Ok(r) => assert_eq(r.digits[0], 1),
        Err(_) => panic("1^N mod M = 1"),
    }
}

// =============================================================================
// Section 4: mod_inverse
// =============================================================================

@test
fn test_mod_inverse_simple() {
    // 3 * 5 = 15 ≡ 1 (mod 7), so 3^-1 mod 7 = 5
    let a = BigInt.from_int(3);
    let m = BigInt.from_int(7);
    match mod_inverse(&a, &m) {
        Ok(r) => assert_eq(r.digits[0], 5),
        Err(_) => panic("3^-1 mod 7 = 5"),
    }
}

@test
fn test_mod_inverse_no_inverse_when_not_coprime() {
    // gcd(2, 4) = 2 ≠ 1 → no modular inverse
    let a = BigInt.from_int(2);
    let m = BigInt.from_int(4);
    match mod_inverse(&a, &m) {
        Ok(_) => panic("non-coprime should Err"),
        Err(_) => {},
    }
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {}
