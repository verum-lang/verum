// =============================================================================
// core-tests/text/numeric/decimal/regression_test.vr
// =============================================================================
//
// Defects pinned for `core/text/numeric/decimal.vr`. The Decimal source is
// correct algebraically; failures concentrate in two architectural classes
// inherited from upstream defects:
//
//   §A  Decimal.neg / Decimal.from_parts panic with `Int.neg not found on Int`
//       (same family as Char/§A primitive-mut defect)
//   §B  Decimal.parse + Decimal.add/mul/div trigger FunctionNotFound(N)
//       (function-id collision under archive remap — same as text/text §D)
//   §C  Arithmetic returns wrong coefficient values (downstream of §B —
//       function dispatch reaches the wrong impl body)
// =============================================================================

mount core.text.{Text};
mount core.text.numeric.decimal.{
    Decimal, DecimalError, RoundingMode, MAX_SCALE,
    HalfEven, HalfUp, HalfDown, Truncate,
    parse_decimal,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// §A — Decimal.neg / from_parts(negative scale) panic with `Int.neg not found`
//       — CLOSED 2026-05-15 by task #20 §A fix.
//
// Root cause: `compile_unary` for `UnOp::Neg` checked `has_neg_method`
// FIRST and routed through `CallM("neg")` whenever `<T>.neg` was
// registered — including `Int.neg` from `implement Neg for Int` in
// primitives.vr.  The CallM had no runtime intercept for primitive
// `Int.neg` and panicked with "Int.neg not found on receiver of
// runtime kind 'Int'".
//
// Fix (two layers, defense-in-depth):
//   1. Codegen: for primitive integer / float operands, ALWAYS emit
//      `UnaryI{Neg}` / `UnaryF{Neg}` directly.  Canonical predicate
//      `type_names::is_integer_type` / `is_float_type` covers every
//      spelling (Int / Int8..128 / UInt8..128 / IntSize / USize /
//      Rust-style i8..i128 / f32..f64).  User types with `Neg`
//      protocol impls still route through `CallM("neg")`.
//   2. Runtime intercept (catches LEGACY precompiled bodies): added
//      `neg` / `wrapping_neg` / `checked_neg` / `saturating_neg` /
//      `not` to the Int methods, and `neg` to the Float methods, in
//      `dispatch_primitive_method`.
// =============================================================================

@test
fn regression_a_decimal_neg_panic_pinned() {
    let d = Decimal.from_int(5);
    let n = d.neg();
    assert_eq(n.coefficient, -5);
}

// =============================================================================
// §B — Cross-module record-layout loss in match destructure — CLOSED 2026-05-15
//
// Pre-fix: `archive_ctx_loader::primitive_typeid_name` recognised only
// the 16 numeric/scalar primitive TypeIds. Cross-module generic
// carriers (Maybe, Result, List, …) had `return_type_name = None`
// in their archive FunctionInfo because `type_ref_simple_name`
// scanned only `module.types` (the module-local descriptor list).
// `extract_expr_type_name` couldn't form `Result<X, E>`,
// `compile_match` lost the scrutinee type, and `compile_pattern_bind`
// fell through to the global field-intern fallback for the bound
// variant payload — surfacing as "field access out of bounds: field
// index 4 (offset 32+8=40) exceeds object data size 16" at every
// `match parse_X(...) { Ok(v) => v.field }` site.
//
// Fix: extended `primitive_typeid_name` with the 15 well-known
// generic-carrier TypeIds so cross-module names resolve regardless
// of perspective; `extract_expr_type_name`'s Call arm composes the
// full generic form from `(ret_type, return_type_inner)`.
//
// Architectural rule: every runtime-reserved TypeId that can appear
// as a function return / field / parameter type MUST be recognised
// by `primitive_typeid_name` — cross-module identity does not depend
// on local descriptor tables.
// =============================================================================

@test
fn regression_b_parse_simple_int_pinned() {
    match parse_decimal(&"42") {
        Ok(d) => assert_eq(d.coefficient, 42),
        Err(_) => panic("'42' parses"),
    }
}

@ignore
@test
fn regression_b_add_zero_pinned() {
    let z = Decimal.zero();
    let d = Decimal.from_int(7);
    match z.add(&d) {
        Ok(r) => assert_eq(r.coefficient, 7),
        Err(_) => panic("zero is left identity"),
    }
}

@ignore
@test
fn regression_b_mul_simple_pinned() {
    let a = Decimal.from_int(3);
    let b = Decimal.from_int(4);
    match a.mul(&b) {
        Ok(d) => assert_eq(d.coefficient, 12),
        Err(_) => panic("3 * 4 = 12"),
    }
}

@ignore
@test
fn regression_b_div_simple_exact_pinned() {
    let a = Decimal.from_int(10);
    let b = Decimal.from_int(2);
    match a.div(&b, 0, RoundingMode.HalfEven) {
        Ok(d) => assert_eq(d.coefficient, 5),
        Err(_) => panic("10 / 2 = 5"),
    }
}

// =============================================================================
// Active PASS-GUARDs — basic field access + variant identification works.
// =============================================================================

@test
fn guard_max_scale_constant() {
    assert_eq(MAX_SCALE, 18);
}

@test
fn guard_zero_canonical_shape() {
    let z = Decimal.zero();
    assert_eq(z.coefficient, 0);
    assert_eq(z.scale, 0);
}

@test
fn guard_one_canonical_shape() {
    let o = Decimal.one();
    assert_eq(o.coefficient, 1);
    assert_eq(o.scale, 0);
}

@test
fn guard_from_int_preserves_coefficient() {
    let d = Decimal.from_int(42);
    assert_eq(d.coefficient, 42);
    assert_eq(d.scale, 0);
}

@test
fn guard_is_zero_predicate() {
    assert(Decimal.zero().is_zero());
    assert(!Decimal.from_int(1).is_zero());
}

@test
fn guard_rounding_modes_distinct() {
    assert(RoundingMode.HalfEven is RoundingMode.HalfEven);
    assert(RoundingMode.HalfUp is RoundingMode.HalfUp);
    assert(RoundingMode.HalfDown is RoundingMode.HalfDown);
    assert(RoundingMode.Truncate is RoundingMode.Truncate);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {}
