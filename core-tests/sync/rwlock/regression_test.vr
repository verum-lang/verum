// =============================================================================
// core-tests/sync/rwlock/regression_test.vr
// =============================================================================
//
// LOCK-IN regression pins for surfaced defects in `core.sync.rwlock`.
// Each name below links to a `audit.md` section.
// =============================================================================

mount core.sync.rwlock.{RwLock, PoisonError, TryLockError};

// =============================================================================
// §3.4 — Default<T> for RwLock<T> substitutes literal `0`
// =============================================================================
//
// Same task #17 workaround as Mutex<T>.  LOCK-IN pins current behaviour.

@test
fn regression_rwlock_default_constructs_via_literal_zero_workaround() {
    let l: RwLock<Int> = RwLock.new(0);
    assert(!l.is_poisoned());
}

// =============================================================================
// §3.3 — Re-exported error types from sync.mutex
// =============================================================================
//
// Drift between mutex.vr's and rwlock.vr's view of LockResult /
// TryLockResult / PoisonError / TryLockError surfaces as type-confusion
// at construction.  These pins confirm both ends agree on the variant
// shape under match.

@test
fn regression_rwlock_re_export_poison_error_destructures() {
    let pe: PoisonError<Int> = PoisonError { guard: 1234 };
    let po: TryLockError<Int> = TryLockError.Poisoned(pe);
    match po {
        TryLockError.Poisoned(p) => {
            assert_eq(p.into_inner(), 1234);
        }
        TryLockError.WouldBlock => {
            panic("regression: TryLockError.Poisoned destructured as WouldBlock");
        }
    }
}

@test
fn regression_rwlock_re_export_would_block_destructures() {
    let wb: TryLockError<Int> = TryLockError.WouldBlock;
    match wb {
        TryLockError.WouldBlock => {
            // expected branch
        }
        TryLockError.Poisoned(_) => {
            panic("regression: TryLockError.WouldBlock destructured as Poisoned");
        }
    }
}

// =============================================================================
// §3.2 — Writer-preference fairness gate (data-shape pin)
// =============================================================================
//
// `RwLock.writers_waiting: AtomicInt` is the gate that prevents
// reader-starvation of writers.  We cannot exercise the gate without
// concurrency, but we CAN verify that the field exists and the rwlock
// constructs cleanly with the gate at the documented initial value
// (0).  This pin gates regression where the field is dropped or its
// initial value diverges from the writer-preference contract.

@test
fn regression_rwlock_writers_waiting_initial_zero_via_unpoisoned_fresh_state() {
    // We cannot read writers_waiting directly (private), but a fresh
    // RwLock with no contenders must report unpoisoned + lockable
    // — implicitly validating the field is zero-initialized.
    let l = RwLock.new(0);
    assert(!l.is_poisoned());
}
