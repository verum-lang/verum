// =============================================================================
// core-tests/sync/mod/regression_test.vr
// =============================================================================
//
// LOCK-IN regression pins for the top-level `core.sync.*` re-export
// surface.
//
// Verum's `mount X as Y` alias creates a fresh identifier that does
// NOT carry method-dispatch resolution back to the original record
// type — method lookup is by the original type name.  So we cannot
// directly compare `TopMutex.is_poisoned()` vs `SubMutex.is_poisoned()`
// side-by-side under aliased names; instead we exercise each path
// individually and confirm the resulting value behaves correctly.
//
// Behaviour-only equivalence (constructor + observed state across
// each path) is sufficient for the audit § 3.1 contract — drift in
// the type identity would surface as method-not-found at the
// construction-or-call site, which these tests anchor.
// =============================================================================

mount core.sync.{Mutex, RwLock, MemoryOrdering, OnceState};
mount core.sync.prelude.{
    Mutex as PreludeMutex,
    RwLock as PreludeRwLock,
    AtomicInt as PreludeAtomicInt,
    AtomicBool as PreludeAtomicBool,
};

// =============================================================================
// §3.1 — Top-level re-export resolves identically to submodule-direct
// =============================================================================
//
// Constructing via the top-level path AND via the submodule-direct
// path is exercised in `unit_test.vr` (each name appears under both
// paths in separate test bodies).  These regression pins LOCK the
// behavioural shape: each top-level constructor returns a value whose
// observable accessors agree with the documented invariants — which
// is the contract callers depend on.

@test
fn regression_mod_mutex_top_level_construction_matches_contract() {
    let m = Mutex.new(0);
    // Fresh mutex: not poisoned, not locked.
    assert(!m.is_poisoned());
    assert(!m.is_locked());
}

@test
fn regression_mod_rwlock_top_level_construction_matches_contract() {
    let l = RwLock.new(0);
    assert(!l.is_poisoned());
}

@test
fn regression_mod_memory_ordering_top_level_variants_constructible() {
    let r: MemoryOrdering = MemoryOrdering.Relaxed;
    let a: MemoryOrdering = MemoryOrdering.Acquire;
    let rel: MemoryOrdering = MemoryOrdering.Release;
    let ar: MemoryOrdering = MemoryOrdering.AcqRel;
    let s: MemoryOrdering = MemoryOrdering.SeqCst;

    assert(r is MemoryOrdering.Relaxed);
    assert(a is MemoryOrdering.Acquire);
    assert(rel is MemoryOrdering.Release);
    assert(ar is MemoryOrdering.AcqRel);
    assert(s is MemoryOrdering.SeqCst);
}

@test
fn regression_mod_once_state_top_level_variants_constructible() {
    let n: OnceState = OnceState.New;
    let ip: OnceState = OnceState.InProgress;
    let d: OnceState = OnceState.Done;
    let p: OnceState = OnceState.Poisoned;

    assert(n is OnceState.New);
    assert(ip is OnceState.InProgress);
    assert(d is OnceState.Done);
    assert(p is OnceState.Poisoned);
}

// =============================================================================
// §3.3 — Prelude curated set: Mutex, MutexGuard, RwLock, AtomicInt,
//        AtomicBool, Send, Sync
// =============================================================================
//
// Drift in this set is a public-API change.  LOCK-IN that each
// prelude name resolves and constructs cleanly via the prelude path.
// Verum allows aliasing via `mount X as Y`, but method resolution
// follows the underlying record-type identifier — so the aliased
// `PreludeMutex` is structurally an alias for the prelude's exported
// `Mutex` type, which itself re-exports `core.sync.mutex.Mutex`.

@test
fn regression_mod_prelude_mutex_path_constructs() {
    // Path exists in the prelude; resolution succeeds.
    let _m: PreludeMutex<Int> = PreludeMutex.new(0);
}

@test
fn regression_mod_prelude_rwlock_path_constructs() {
    let _l: PreludeRwLock<Int> = PreludeRwLock.new(0);
}

@test
fn regression_mod_prelude_atomic_int_path_constructs() {
    let _a: PreludeAtomicInt = PreludeAtomicInt.new(99);
}

@test
fn regression_mod_prelude_atomic_bool_path_constructs() {
    let _b: PreludeAtomicBool = PreludeAtomicBool.new(true);
}
