// =============================================================================
// core-tests/sync/mod/unit_test.vr
// =============================================================================
//
// Unit tests for the top-level re-export surface of `core.sync.*`.
//
// Verifies that every name re-exported from mod.vr resolves correctly
// via the top-level path AND that the result is observationally
// equivalent to importing from the submodule directly.
// =============================================================================

// Use the top-level path everywhere — this is the recommended caller
// surface per the docs.
mount core.sync.{
    Mutex, MutexGuard,
    RwLock,
    AtomicInt, AtomicBool, AtomicU8, AtomicU16, AtomicU32, AtomicU64,
    MemoryOrdering,
    Once, OnceState,
    Semaphore, SemaphoreGuard,
    Condvar, CondvarNotifyGuard, producer_consumer_pair,
    Barrier, BarrierWaitResult, Phaser, CountDownLatch,
    WaitGroup,
};

// =============================================================================
// Section 1: Re-export resolution — every name constructs cleanly
// =============================================================================

@test
fn test_mod_re_export_mutex_constructs() {
    let m = Mutex.new(0);
    assert(!m.is_poisoned());
}

@test
fn test_mod_re_export_rwlock_constructs() {
    let l = RwLock.new(0);
    assert(!l.is_poisoned());
}

@test
fn test_mod_re_export_atomic_int_constructs() {
    let a = AtomicInt.new(42);
    assert_eq(a.load(MemoryOrdering.Acquire), 42);
}

@test
fn test_mod_re_export_atomic_bool_constructs() {
    let a = AtomicBool.new(true);
    assert_eq(a.load(MemoryOrdering.Acquire), true);
}

@test
fn test_mod_re_export_atomic_u8_constructs() {
    // AtomicU8.new takes UInt8; we just construct and verify the
    // re-export path resolves.
    let _a = AtomicU8.new(0 as UInt8);
    // Resolution succeeded.
    assert(true);
}

@test
fn test_mod_re_export_atomic_u64_constructs() {
    let _a = AtomicU64.new(0 as UInt64);
    assert(true);
}

@test
fn test_mod_re_export_memory_ordering_variants() {
    let r: MemoryOrdering = MemoryOrdering.Relaxed;
    let s: MemoryOrdering = MemoryOrdering.SeqCst;
    assert(r is MemoryOrdering.Relaxed);
    assert(s is MemoryOrdering.SeqCst);
}

@test
fn test_mod_re_export_once_state_variants() {
    let n: OnceState = OnceState.New;
    let d: OnceState = OnceState.Done;
    assert(n is OnceState.New);
    assert(d is OnceState.Done);
}

@test
fn test_mod_re_export_semaphore_constructs() {
    let s = Semaphore.new(3);
    assert_eq(s.available_permits(), 3);
}

@test
fn test_mod_re_export_condvar_constructs() {
    let c = Condvar.new();
    assert_eq(c.waiter_count(), 0);
}

@test
fn test_mod_re_export_barrier_constructs() {
    let b = Barrier.new(2);
    assert_eq(b.num_threads(), 2);
}

@test
fn test_mod_re_export_barrier_wait_result_constructs() {
    let r: BarrierWaitResult = BarrierWaitResult { is_leader: true };
    assert(r.is_leader());
}

@test
fn test_mod_re_export_phaser_constructs() {
    let p = Phaser.new(1);
    assert_eq(p.get_registered_parties(), 1);
}

@test
fn test_mod_re_export_count_down_latch_constructs() {
    let l = CountDownLatch.new(0);
    assert_eq(l.get_count(), 0);
}

@test
fn test_mod_re_export_waitgroup_constructs() {
    let wg = WaitGroup.new();
    assert(wg.try_wait());
}

@test
fn test_mod_re_export_producer_consumer_pair_factory() {
    let (m, cv) = producer_consumer_pair(0);
    assert(!m.is_poisoned());
    assert_eq(cv.waiter_count(), 0);
}
