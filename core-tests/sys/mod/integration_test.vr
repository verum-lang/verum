// =============================================================================
// core-tests/sys/mod/integration_test.vr
// =============================================================================
//
// Cross-stdlib integration tests for the `core.sys` umbrella surface.
//
// What this file pins:
//
//   * The umbrella re-exports compose with `List<T>` and `Maybe<T>` —
//     the standard `mount core.sys.X;` pattern that user-facing code
//     actually uses survives stdlib refactoring.
//   * Type-identity is preserved across umbrella + direct paths —
//     a `OSError` constructed via `core.sys.OSError` reads back fields
//     identically to one constructed via `core.sys.common.OSError`.
//   * Constants are byte-identical at every reachable path.
// =============================================================================

mount core.prelude.*;
mount core.sys.{
    OSError,
    Fd,
    TimeSpec,
    BarrierKind,
    MemoryFlags,
    PAGE_SIZE,
    USIZE_BITS,
    InitError,
};

// =============================================================================
// Section 1: Umbrella OSError + List composition
// =============================================================================

@test
fn integration_umbrella_os_error_list_iteration() {
    let errors: List<OSError> = [
        OSError { code: 2,  message: "ENOENT".clone() },
        OSError { code: 13, message: "EACCES".clone() },
        OSError { code: 17, message: "EEXIST".clone() },
    ];
    assert_eq(errors.len(), 3);
    let mut total_code: Int = 0;
    for e in errors.iter() {
        total_code = total_code + e.code;
    }
    assert_eq(total_code, 32);
}

// =============================================================================
// Section 2: Umbrella Fd × Maybe — open(2) success/failure funnel
// =============================================================================

@test
fn integration_umbrella_fd_maybe_funnel() {
    fn open_funnel(rv: Fd) -> Maybe<Fd> {
        if rv.0 < (0 as Int32) { None } else { Some(rv) }
    }
    let ok  = open_funnel(Fd(7 as Int32));
    let err = open_funnel(Fd(-1 as Int32));
    match ok {
        Some(fd) => assert_eq(fd.0, 7 as Int32),
        None     => assert(false),
    };
    match err {
        Some(_) => assert(false),
        None    => assert(true),
    };
}

// =============================================================================
// Section 3: Umbrella TimeSpec via Result
// =============================================================================

@test
fn integration_umbrella_timespec_via_result() {
    let r: Result<TimeSpec, OSError> = Ok(TimeSpec {
        tv_sec:  3 as Int64,
        tv_nsec: 500_000_000 as Int64,
    });
    match r {
        Ok(ts) => {
            assert_eq(ts.tv_sec, 3 as Int64);
            assert_eq(ts.tv_nsec, 500_000_000 as Int64);
        }
        Err(_) => assert(false),
    };
}

// =============================================================================
// Section 4: Umbrella BarrierKind + dispatch table
// =============================================================================

@test
fn integration_umbrella_barrier_kind_strength_dispatch() {
    fn strength(b: BarrierKind) -> Int {
        match b {
            BarrierKind.Compiler => 0,
            BarrierKind.Acquire  => 1,
            BarrierKind.Release  => 1,
            BarrierKind.AcqRel   => 2,
            BarrierKind.SeqCst   => 3,
        }
    }
    assert_eq(strength(BarrierKind.Compiler), 0);
    assert_eq(strength(BarrierKind.SeqCst),   3);
}

// =============================================================================
// Section 5: Umbrella MemoryFlags — OR composition
// =============================================================================

@test
fn integration_umbrella_memory_flags_text_segment() {
    // Pin the canonical "text segment" permission combination
    // accessible via the umbrella path.
    let text_perm: UInt32 = MemoryFlags.READ.0 | MemoryFlags.EXEC.0;
    assert_eq(text_perm, 5 as UInt32);
}

// =============================================================================
// Section 6: Umbrella InitError × Maybe lift
// =============================================================================

@test
fn integration_umbrella_init_error_via_maybe_some() {
    let opt: Maybe<InitError> = Some(InitError.AlreadyInitialized);
    match opt {
        Some(e) => {
            match e {
                InitError.AlreadyInitialized => assert(true),
                _ => assert(false),
            }
        }
        None => assert(false),
    };
}

// =============================================================================
// Section 7: Umbrella PAGE_SIZE × computation
// =============================================================================

@test
fn integration_umbrella_page_size_alignment_arithmetic() {
    // The canonical "round up to next page" arithmetic at the umbrella
    // path — pins that PAGE_SIZE is usable in numeric expressions.
    let req: Int = 7;
    let aligned = ((req + PAGE_SIZE - 1) / PAGE_SIZE) * PAGE_SIZE;
    assert_eq(aligned, PAGE_SIZE);
}

@test
fn integration_umbrella_usize_bits_arithmetic() {
    // USIZE_BITS reached via umbrella + used in bit-shift arithmetic.
    let one: USize = 1 as USize;
    let mid_bit = one << (USIZE_BITS / (2 as USize));
    assert(mid_bit > one);
}

fn main() {}
