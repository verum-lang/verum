// =============================================================================
// core-tests/sys/interrupt/integration_test.vr
// =============================================================================
//
// Cross-stdlib integration tests for `core.sys.interrupt`. Touches the
// interrupt-safe constructor surface in combination with other stdlib
// shapes (`List`, `Maybe`, tuples, custom records).
//
// Caveat (mirrored from property_test.vr): the privileged surface
// (`@interrupt`, `with_interrupts_disabled`, exception-frame I/O) is
// kernel-mode-only and lives in `vcs/specs/L0-critical/`. The user-
// space contract here is the safe construction + introspection
// surface every user-mode caller reaches for.
// =============================================================================

mount core.prelude.*;
mount core.sys.interrupt.{
    CriticalSection,
    InterruptCell,
};

// =============================================================================
// Section 1: InterruptCell × List<T> — cells inside collections
// =============================================================================

@test
fn integration_list_of_interrupt_cells_int() {
    // The cells must compose into a List — pinned by walking three
    // elements and reading their type.
    let cells: List<InterruptCell<Int>> = [
        InterruptCell.new(0),
        InterruptCell.new(1),
        InterruptCell.new(2),
    ];
    assert_eq(cells.len(), 3);
}

@test
fn integration_list_of_interrupt_cells_polymorphic_construction() {
    // Three independent monomorphisations (Int / Bool / Text) each
    // produce their own cell — pinned by counting the constructed
    // instances.
    let i_cell: InterruptCell<Int>  = InterruptCell.new(7);
    let b_cell: InterruptCell<Bool> = InterruptCell.new(true);
    let t_cell: InterruptCell<Text> = InterruptCell.new("payload".clone());
    let counts: List<Int> = [1, 1, 1];
    assert_eq(counts.len(), 3);
    // The three locals must be retained — pinning compilation of the
    // monomorphisations.
    let _ = i_cell;
    let _ = b_cell;
    let _ = t_cell;
}

// =============================================================================
// Section 2: CriticalSection.is_active × Maybe + tuple
// =============================================================================

@test
fn integration_is_active_via_maybe_some_branch() {
    let state: Maybe<Bool> = Some(CriticalSection.is_active());
    match state {
        Some(_) => assert(true),
        None    => assert(false),
    };
}

@test
fn integration_is_active_double_read_via_tuple() {
    let pair: (Bool, Bool) = (CriticalSection.is_active(), CriticalSection.is_active());
    let (a, b) = pair;
    assert_eq(a, b);
}

// =============================================================================
// Section 3: InterruptCell × List × iteration
// =============================================================================

@test
fn integration_interrupt_cell_count_constructed() {
    // Count how many InterruptCell<Int> we construct by recording side-
    // effects in a parallel counter. The constructor itself must not
    // observe the counter — every `+1` is from the user-side
    // assignment.
    let mut count: Int = 0;
    let payloads: List<Int> = [10, 20, 30, 40, 50];
    for p in payloads.iter() {
        let _cell: InterruptCell<Int> = InterruptCell.new(*p);
        count = count + 1;
    }
    assert_eq(count, 5);
}

// =============================================================================
// Section 4: Custom-record payloads
// =============================================================================

type IntPair is { a: Int, b: Int };

@test
fn integration_interrupt_cell_with_record_payload() {
    let p = IntPair { a: 3, b: 4 };
    let _cell: InterruptCell<IntPair> = InterruptCell.new(p);
}

fn main() {}
