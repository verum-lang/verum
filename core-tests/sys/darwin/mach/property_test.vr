// =============================================================================
// core-tests/sys/darwin/mach/property_test.vr
// =============================================================================
//
// Algebraic / structural laws for `core.sys.darwin.mach` constants.
// =============================================================================

mount core.prelude.*;
mount core.sys.darwin.mach.{
    KERN_SUCCESS, KERN_INVALID_ADDRESS, KERN_PROTECTION_FAILURE,
    KERN_NO_SPACE, KERN_INVALID_ARGUMENT, KERN_FAILURE,
    KERN_RESOURCE_SHORTAGE, KERN_NOT_RECEIVER, KERN_NO_ACCESS,
    KERN_ABORTED,
    VM_PROT_NONE, VM_PROT_READ, VM_PROT_WRITE, VM_PROT_EXECUTE,
    VM_PROT_DEFAULT, VM_PROT_ALL,
    VM_FLAGS_FIXED, VM_FLAGS_ANYWHERE, VM_FLAGS_PURGABLE,
};

// =============================================================================
// Section 1: KERN_* — canonical Mach return code disjointness
// =============================================================================

@test
fn law_kern_return_codes_consecutive_zero_to_eight() {
    // Pinned 0..=8 + 14: KERN_SUCCESS through KERN_NO_ACCESS, then
    // KERN_ABORTED at 14.
    let codes: List<Int32> = [
        KERN_SUCCESS.0,
        KERN_INVALID_ADDRESS.0,
        KERN_PROTECTION_FAILURE.0,
        KERN_NO_SPACE.0,
        KERN_INVALID_ARGUMENT.0,
        KERN_FAILURE.0,
        KERN_RESOURCE_SHORTAGE.0,
        KERN_NOT_RECEIVER.0,
        KERN_NO_ACCESS.0,
    ];
    let mut i: USize = 0 as USize;
    while i < codes.len() {
        let expected = i as Int32;
        let actual = *codes.get(i).unwrap();
        assert_eq(actual, expected);
        i = i + (1 as USize);
    }
}

@test
fn law_kern_aborted_is_fourteen() {
    assert_eq(KERN_ABORTED.0, 14 as Int32);
}

@test
fn law_kern_success_is_falsy_others_truthy() {
    // The canonical "did the Mach call succeed?" predicate:
    // `kr.0 == 0`.
    assert_eq(KERN_SUCCESS.0, 0 as Int32);
    assert(KERN_INVALID_ADDRESS.0 != (0 as Int32));
    assert(KERN_FAILURE.0 != (0 as Int32));
}

// =============================================================================
// Section 2: VM_PROT_* — 3-bit power-of-two algebra
// =============================================================================

@test
fn law_vm_prot_single_bits_powers_of_two() {
    let bits: List<Int32> = [VM_PROT_READ.0, VM_PROT_WRITE.0, VM_PROT_EXECUTE.0];
    for b in bits.iter() {
        let v: Int32 = *b;
        assert(v != (0 as Int32));
        assert_eq(v & (v - (1 as Int32)), 0 as Int32);
    }
}

@test
fn law_vm_prot_default_is_read_or_write() {
    assert_eq(VM_PROT_DEFAULT.0, VM_PROT_READ.0 | VM_PROT_WRITE.0);
}

@test
fn law_vm_prot_all_is_disjoint_union_of_three() {
    let combined = VM_PROT_READ.0 | VM_PROT_WRITE.0 | VM_PROT_EXECUTE.0;
    assert_eq(VM_PROT_ALL.0, combined);
}

@test
fn law_vm_prot_single_bits_pairwise_disjoint() {
    let bits: List<Int32> = [VM_PROT_READ.0, VM_PROT_WRITE.0, VM_PROT_EXECUTE.0];
    let n = bits.len();
    let mut i: USize = 0 as USize;
    while i < n {
        let mut j: USize = i + (1 as USize);
        while j < n {
            let a = *bits.get(i).unwrap();
            let b = *bits.get(j).unwrap();
            assert_eq(a & b, 0 as Int32);
            j = j + (1 as USize);
        }
        i = i + (1 as USize);
    }
}

@test
fn law_vm_prot_none_is_zero() {
    assert_eq(VM_PROT_NONE.0, 0 as Int32);
}

// =============================================================================
// Section 3: VM_FLAGS_* — distinctness
// =============================================================================

@test
fn law_vm_flags_distinct() {
    assert(VM_FLAGS_FIXED != VM_FLAGS_ANYWHERE);
    assert(VM_FLAGS_FIXED != VM_FLAGS_PURGABLE);
    assert(VM_FLAGS_ANYWHERE != VM_FLAGS_PURGABLE);
}

fn main() {}
