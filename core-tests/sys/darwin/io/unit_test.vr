// =============================================================================
// core-tests/sys/darwin/io/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.darwin.io` — kqueue-based I/O driver
// constants + DarwinIoDriverError + DarwinIoOpKind ADTs.
// =============================================================================

mount core.prelude.*;
mount core.sys.darwin.io.{
    DarwinIoDriverError,
    DarwinIoOpKind,
    DarwinIoToken,
    DarwinIoOp,
    DarwinIoCqe,
    MAX_EVENTS,
    DEFAULT_TIMEOUT_NS,
};

// =============================================================================
// Section 1: Constants
// =============================================================================

@test
fn test_max_events_is_256() {
    assert_eq(MAX_EVENTS, 256);
}

@test
fn test_default_timeout_ns_is_one_second() {
    assert_eq(DEFAULT_TIMEOUT_NS, 1_000_000_000);
}

// =============================================================================
// Section 2: DarwinIoOpKind 9-variant
// =============================================================================

@test
fn test_io_op_kind_read() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Read;
}

@test
fn test_io_op_kind_write() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Write;
}

@test
fn test_io_op_kind_accept() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Accept;
}

@test
fn test_io_op_kind_connect() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Connect;
}

@test
fn test_io_op_kind_send() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Send;
}

@test
fn test_io_op_kind_recv() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Recv;
}

@test
fn test_io_op_kind_timer() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Timer;
}

@test
fn test_io_op_kind_signal() {
    let _: DarwinIoOpKind = DarwinIoOpKind.Signal;
}

@test
fn test_io_op_kind_user() {
    let _: DarwinIoOpKind = DarwinIoOpKind.User;
}

// =============================================================================
