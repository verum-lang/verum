// =============================================================================

@test
fn test_io_error_would_block() {
    let _: DarwinIoDriverError = DarwinIoDriverError.WouldBlock;
}

@test
fn test_io_error_interrupted() {
    let _: DarwinIoDriverError = DarwinIoDriverError.Interrupted;
}

@test
fn test_io_error_already_exists() {
    let _: DarwinIoDriverError = DarwinIoDriverError.AlreadyExists;
}

@test
fn test_io_error_permission_denied() {
    let _: DarwinIoDriverError = DarwinIoDriverError.PermissionDenied;
}

@test
fn test_io_error_connection_refused() {
    let _: DarwinIoDriverError = DarwinIoDriverError.ConnectionRefused;
}

@test
fn test_io_error_broken_pipe() {
    let _: DarwinIoDriverError = DarwinIoDriverError.BrokenPipe;
