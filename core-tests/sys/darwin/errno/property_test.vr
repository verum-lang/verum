// =============================================================================
// core-tests/sys/darwin/errno/property_test.vr
// =============================================================================
//
// Algebraic / structural laws for `core.sys.darwin.errno`.
//
// Properties covered:
//   * Every documented errno constant is in the canonical BSD range
//     1..=106 (EPERM=1 .. EQFULL=106).
//   * The "low POSIX" subset (EPERM..ERANGE = 1..34) is pairwise
//     distinct.
//   * EWOULDBLOCK == EAGAIN (BSD alias convention).
//   * Predicate disjointness over a representative error sample:
//     - is_permission_error subset ⊂ {EPERM, EACCES}.
//     - is_not_found subset       ⊂ {ENOENT, ESRCH}.
//     - is_retryable subset       ⊂ {EAGAIN, EWOULDBLOCK, EINTR}.
//     - is_would_block subset     ⊂ {EAGAIN, EWOULDBLOCK, EINPROGRESS}.
//   * Predicates exhaustively partition the documented domain.
// =============================================================================

mount core.prelude.*;
mount core.sys.darwin.errno.{
    EPERM, ENOENT, ESRCH, EINTR, EIO, ENXIO, E2BIG, ENOEXEC, EBADF,
    ECHILD, EDEADLK, ENOMEM, EACCES, EFAULT, ENOTBLK, EBUSY, EEXIST,
    EXDEV, ENODEV, ENOTDIR, EISDIR, EINVAL, ENFILE, EMFILE, ENOTTY,
    ETXTBSY, EFBIG, ENOSPC, ESPIPE, EROFS, EMLINK, EPIPE, EDOM, ERANGE,
    EAGAIN, EWOULDBLOCK, EINPROGRESS,
    is_retryable, is_permission_error, is_not_found, is_would_block,
};

// =============================================================================
// Section 1: Low-POSIX subset 1..=34 — pairwise distinctness
// =============================================================================

fn low_posix_codes() -> List<Int> {
    [
        EPERM, ENOENT, ESRCH, EINTR, EIO, ENXIO, E2BIG, ENOEXEC, EBADF,
        ECHILD, EDEADLK, ENOMEM, EACCES, EFAULT, ENOTBLK, EBUSY, EEXIST,
        EXDEV, ENODEV, ENOTDIR, EISDIR, EINVAL, ENFILE, EMFILE, ENOTTY,
        ETXTBSY, EFBIG, ENOSPC, ESPIPE, EROFS, EMLINK, EPIPE, EDOM, ERANGE,
    ]
}

@test
fn law_low_posix_count_is_thirtyfour() {
    let codes = low_posix_codes();
    assert_eq(codes.len(), 34);
}

@test
fn law_low_posix_all_in_range_1_to_34() {
    for c in low_posix_codes().iter() {
        assert(*c >= 1);
        assert(*c <= 34);
    }
}

@test
fn law_low_posix_pairwise_distinct() {
    let codes = low_posix_codes();
    let n = codes.len();
    let mut i: USize = 0 as USize;
    while i < n {
        let mut j: USize = i + (1 as USize);
        while j < n {
            let a = *codes.get(i).unwrap();
            let b = *codes.get(j).unwrap();
            assert(a != b);
            j = j + (1 as USize);
        }
        i = i + (1 as USize);
    }
}

@test
fn law_low_posix_form_consecutive_sequence() {
    // The 34 POSIX codes are exactly the values 1..=34.
    let codes = low_posix_codes();
    let mut seen: List<Bool> = [];
    let mut i: Int = 0;
    while i < 35 {
        seen.push(false);
        i = i + 1;
    }
    for c in codes.iter() {
        seen[*c as USize] = true;
    }
    // Index 0 (success) is NOT in the errno list.
    assert(!*seen.get(0 as USize).unwrap());
    // Every index 1..=34 IS.
    let mut j: USize = 1 as USize;
    while j <= (34 as USize) {
        assert(*seen.get(j).unwrap());
        j = j + (1 as USize);
    }
}

// =============================================================================
// Section 2: EWOULDBLOCK ≡ EAGAIN (BSD alias)
// =============================================================================

@test
fn law_ewouldblock_equals_eagain() {
    assert_eq(EWOULDBLOCK, EAGAIN);
}

@test
fn law_ewouldblock_predicates_agree_with_eagain() {
    // Both predicates must classify the two aliased codes the same way.
    assert_eq(is_retryable(EAGAIN),    is_retryable(EWOULDBLOCK));
    assert_eq(is_would_block(EAGAIN),  is_would_block(EWOULDBLOCK));
}

// =============================================================================
// Section 3: Predicate disjointness over representative samples
// =============================================================================

@test
fn law_is_retryable_only_three_codes() {
    // Retryable is exactly {EAGAIN, EWOULDBLOCK, EINTR}. EWOULDBLOCK ≡
    // EAGAIN so the effective set is {EAGAIN, EINTR}.
    // Counter-sample: ENOENT and EACCES are NOT retryable.
    assert(is_retryable(EAGAIN));
    assert(is_retryable(EINTR));
    assert(!is_retryable(ENOENT));
    assert(!is_retryable(EACCES));
    assert(!is_retryable(EPIPE));
}

@test
fn law_is_permission_error_only_eperm_eacces() {
    assert(is_permission_error(EPERM));
    assert(is_permission_error(EACCES));
    // Counter-sample: ENOENT is NOT a permission error.
    assert(!is_permission_error(ENOENT));
    assert(!is_permission_error(EINVAL));
}

@test
fn law_is_not_found_only_enoent_esrch() {
    assert(is_not_found(ENOENT));
    assert(is_not_found(ESRCH));
    // Counter-sample: EACCES is NOT "not found".
    assert(!is_not_found(EACCES));
    assert(!is_not_found(EINVAL));
}

@test
fn law_is_would_block_subset_of_retryable_plus_einprogress() {
    // is_would_block ⊆ {EAGAIN, EWOULDBLOCK, EINPROGRESS}.
    // Counter-sample: EINTR is retryable but NOT would-block.
    assert(is_would_block(EAGAIN));
    assert(is_would_block(EINPROGRESS));
    assert(!is_would_block(EINTR));
    assert(!is_would_block(EPIPE));
}

// =============================================================================
// Section 4: Predicates are total (no panic on any Int input)
// =============================================================================

@test
fn law_predicates_total_over_int_domain() {
    // Every Int input — including 0, negative, and out-of-range values —
    // must return Bool without panicking. The predicates are pure
    // disjunctions over the constant set.
    let inputs: List<Int> = [-1, 0, 1, 100, 10_000, -1_000_000];
    for v in inputs.iter() {
        // We don't pin the value — just that the call completes and
        // returns a Bool.
        let _: Bool = is_retryable(*v);
        let _: Bool = is_permission_error(*v);
        let _: Bool = is_not_found(*v);
        let _: Bool = is_would_block(*v);
    }
}

fn main() {}
