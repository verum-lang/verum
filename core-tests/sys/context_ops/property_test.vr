// =============================================================================
// core-tests/sys/context_ops/property_test.vr
// =============================================================================
//
// Algebraic / structural laws for `core.sys.context_ops`.
//
// The V-LLSI context system is a small per-thread arena; the laws here
// pin the contract end-to-end (independence across slots, idempotence
// of double-end, monotonicity of TLS_SLOT_COUNT).
// =============================================================================

mount core.prelude.*;
mount core.sys.context_ops.{
    TLS_SLOT_COUNT,
    tls_get, tls_set,
    context_provide, context_get, context_end,
};

// =============================================================================
// Section 1: TLS_SLOT_COUNT — structural invariants
// =============================================================================

@test
fn law_tls_slot_count_canonical_value() {
    // The 256-slot ceiling is documented as the V-LLSI per-thread
    // arena width — drift here would silently shrink the arena.
    assert_eq(TLS_SLOT_COUNT, 256);
}

@test
fn law_tls_slot_count_power_of_two() {
    let mask: Int = TLS_SLOT_COUNT - 1;
    assert_eq(TLS_SLOT_COUNT & mask, 0);
}

@test
fn law_tls_slot_count_at_least_eight_bits() {
    // 256 = 2^8. Any future widening must keep at least 8-bit
    // addressability so existing call sites stay valid.
    assert(TLS_SLOT_COUNT >= 256);
}

// =============================================================================
// Section 2: TLS slot independence
// =============================================================================

fn tls_high_slots() -> List<Int> {
    // Reserve the top of the slot range for the property sweep so we
    // never collide with bootstrap-provided slots in low addresses.
    [200, 210, 220, 230, 240, 250]
}

@test
fn law_tls_write_then_read_identity() {
    let slots = tls_high_slots();
    let samples: List<Int> = [0, 1, -1, 42, 1_000_000];
    let mut i: Int = 0;
    let n = slots.len();
    while i < n {
        let s = *slots.get(i as USize);
        for v in samples.iter() {
            tls_set(s, *v);
            let read = tls_get(s);
            assert_eq(read, *v);
        }
        i = i + 1;
    }
}

@test
fn law_tls_distinct_slots_pairwise_independent() {
    // Writing slot a does not bleed into any other slot a' != a.
    let slots = tls_high_slots();
    let n = slots.len();
    let mut i: Int = 0;
    while i < n {
        let mut j: Int = 0;
        while j < n {
            let si = *slots.get(i as USize);
            let sj = *slots.get(j as USize);
            if si != sj {
                tls_set(si, 0);
                tls_set(sj, 0);
                tls_set(si, 9999);
                let vsj = tls_get(sj);
                // sj must remain at the value we last wrote to it (0)
                // — touching si must not bleed.
                assert_eq(vsj, 0);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

@test
fn law_tls_set_is_overwrite_not_accumulate() {
    // The V-LLSI contract is store-overwrite, not append/sum. Pin
    // this so a misread of the spec ("write adds to slot") fails
    // immediately.
    let slot: Int = 245;
    tls_set(slot, 100);
    tls_set(slot, 200);
    tls_set(slot, 300);
    let v = tls_get(slot);
    assert_eq(v, 300);
}

// =============================================================================
// Section 3: Context system — type_id-keyed DI
// =============================================================================

fn ctx_type_ids() -> List<Int> {
    // Reserved unused range for the property tests. Real bootstrap
    // contexts (Allocator, Logger, etc.) live at compile-time-assigned
    // small type_ids; using a high band avoids collision.
    [9001, 9002, 9003, 9004, 9005]
}

@test
fn law_context_provide_then_get_identity() {
    let tids = ctx_type_ids();
    let samples: List<Int> = [1, -1, 0, 42, 999_999];
    let mut i: Int = 0;
    let n = tids.len();
    while i < n {
        let tid = *tids.get(i as USize);
        for v in samples.iter() {
            context_provide(tid, *v);
            let read = context_get(tid);
            assert_eq(read, *v);
            context_end(tid);
        }
        i = i + 1;
    }
}

@test
fn law_context_distinct_type_ids_pairwise_independent() {
    let tids = ctx_type_ids();
    let n = tids.len();
    let mut i: Int = 0;
    while i < n {
        let mut j: Int = 0;
        while j < n {
            let ti = *tids.get(i as USize);
            let tj = *tids.get(j as USize);
            if ti != tj {
                context_provide(ti, 111);
                context_provide(tj, 222);
                let vti = context_get(ti);
                let vtj = context_get(tj);
                assert_eq(vti, 111);
                assert_eq(vtj, 222);
                context_end(ti);
                context_end(tj);
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

@test
fn law_context_end_restores_unprovided_zero() {
    // After `context_end`, `context_get` for the same type_id must
    // observe the V-LLSI "unprovided => 0" contract.
    let tid: Int = 9099;
    context_provide(tid, 1234);
    context_end(tid);
    let v = context_get(tid);
    assert_eq(v, 0);
}

fn main() {}
