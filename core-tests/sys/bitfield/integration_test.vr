@test
fn integration_uint32_bitfield_element_round_trip_max() {
    let bits = (0xFFFFFFFF as UInt32).to_bits();
    let back = UInt32.from_bits(bits);
    assert_eq(back, 0xFFFFFFFF as UInt32);
}

@test
fn integration_uint32_bitfield_element_round_trip_pattern() {
    let v: UInt32 = 0xDEADBEEF as UInt32;
    let back = UInt32.from_bits(v.to_bits());
    assert_eq(back, v);
