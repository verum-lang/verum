// =============================================================================
// core-tests/sys/bitfield/integration_test.vr
// =============================================================================
//
// Cross-stdlib integration tests for `core.sys.bitfield`. Exercises:
//
//   * The `BitfieldElement` protocol implementations for `Bool`, `UInt8`,
//     `UInt16`, `UInt32`, `UInt64` — the canonical bit-storage round-trip
//     for every concrete instance ships in `core/sys/bitfield.vr`.
//   * Free-function bit primitives in combination with `List<USize>`
//     accumulation, `Maybe<USize>` selectors, and pattern matching.
//   * The `Endianness` variant trio — used by the `EndianBitfield`
//     protocol — round-tripped through `Maybe<Endianness>` to confirm
//     pattern matching reaches every arm.
//
// Notes:
//   * All free-function call sites use the `bitfield.<name>(...)`
//     qualified form — that is the working dispatch shape closed by
//     task #121 (see audit.md §3.2).
//   * Constants are accessed through the fully-qualified path
//     (`bitfield.USIZE_BITS`) — the bare-mount selective-const form
//     remains gated on task #15.
//   * The integration suite intentionally avoids hardware
//     `Bitfield`-protocol round-trips: `Bitfield::SIZE_BYTES` and
//     `Bitfield::as_bytes` are produced by the `@bitfield` codegen pass,
//     which is hardware-target-specific. That surface is locked down by
//     `vcs/specs/L3-extended/` integration suites.
// =============================================================================

mount core.prelude.*;
mount core.sys.bitfield.{Endianness, BitfieldElement};
mount core.sys.bitfield;

// =============================================================================
// Section 1: BitfieldElement<Bool> round-trip
// =============================================================================

@test
fn integration_bool_bitfield_element_round_trip_true() {
    let bits = (true as Bool).to_bits();
    let back = Bool.from_bits(bits);
    assert_eq(back, true);
}

@test
fn integration_bool_bitfield_element_round_trip_false() {
    let bits = (false as Bool).to_bits();
    let back = Bool.from_bits(bits);
    assert_eq(back, false);
}

@test
fn integration_bool_bitfield_element_to_bits_is_unit_domain() {
    // Bool.to_bits maps exactly { false → 0, true → 1 }.
    assert_eq(false.to_bits(), 0 as USize);
    assert_eq(true.to_bits(),  1 as USize);
}

@test
fn integration_bool_bitfield_element_from_bits_truthiness() {
    // Every non-zero USize converts to true.
    assert_eq(Bool.from_bits(0 as USize),    false);
    assert_eq(Bool.from_bits(1 as USize),    true);
    assert_eq(Bool.from_bits(0xFF as USize), true);
    assert_eq(Bool.from_bits(!(0 as USize)), true);
}

// =============================================================================
// Section 2: BitfieldElement<UInt8> round-trip
// =============================================================================

@test
fn integration_uint8_bitfield_element_round_trip_zero() {
    let bits = (0 as UInt8).to_bits();
    let back = UInt8.from_bits(bits);
    assert_eq(back, 0 as UInt8);
}

@test
fn integration_uint8_bitfield_element_round_trip_max() {
    let bits = (0xFF as UInt8).to_bits();
    let back = UInt8.from_bits(bits);
    assert_eq(back, 0xFF as UInt8);
}

@test
fn integration_uint8_bitfield_element_round_trip_pattern() {
    let v: UInt8 = 0xA5 as UInt8;
    let back = UInt8.from_bits(v.to_bits());
    assert_eq(back, v);
}

