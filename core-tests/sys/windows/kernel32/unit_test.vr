// =============================================================================
// Section 7 — Wait codes (WaitFor* return values)
// =============================================================================

@test
fn test_wait_object_0_is_zero() {
    assert_eq(WAIT_OBJECT_0, 0_u32);
}

@test
fn test_wait_abandoned_value() {
    assert_eq(WAIT_ABANDONED, 0x80_u32);
}

@test
fn test_wait_timeout_value() {
    assert_eq(WAIT_TIMEOUT, 0x102_u32);
}

@test
fn test_wait_failed_is_all_ones() {
    assert_eq(WAIT_FAILED, 0xFFFFFFFF_u32);
}

@test
fn test_infinite_is_all_ones() {
    assert_eq(INFINITE, 0xFFFFFFFF_u32);
}

