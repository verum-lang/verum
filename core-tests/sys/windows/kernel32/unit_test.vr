@test
fn test_create_new_value() {
    assert_eq(CREATE_NEW, 1_u32);
}

@test
fn test_create_always_value() {
    assert_eq(CREATE_ALWAYS, 2_u32);
}

@test
fn test_open_existing_value() {
    assert_eq(OPEN_EXISTING, 3_u32);
}

@test
fn test_open_always_value() {
    assert_eq(OPEN_ALWAYS, 4_u32);
}

@test
fn test_truncate_existing_value() {
    assert_eq(TRUNCATE_EXISTING, 5_u32);
}

