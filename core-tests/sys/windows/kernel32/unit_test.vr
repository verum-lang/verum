// =============================================================================
// core-tests/sys/windows/kernel32/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.windows.kernel32` — Win32 API constants and the
// `Overlapped` ABI-shape struct. The FFI bindings themselves
// (`CreateFileW`, `ReadFile`, `WaitForSingleObject`, …) cannot be exercised
// on a non-Windows host, so the constant + struct surface is what we pin
// here. Everything tested here is platform-independent at the bytecode level
// — the values come from Microsoft's published API headers and stay stable
// across every Windows 10/11 SKU per the Win32 stability commitment.
//
// API surface tested:
//
//   Constants:
//     * Memory protection: MEM_COMMIT/RESERVE/DECOMMIT/RELEASE/RESET
//                          PAGE_NOACCESS/READONLY/READWRITE/WRITECOPY/
//                          EXECUTE/EXECUTE_READ/EXECUTE_READWRITE/
//                          EXECUTE_WRITECOPY/GUARD
//     * Std handles:       STD_INPUT/OUTPUT/ERROR_HANDLE
//     * File attributes:   FILE_ATTRIBUTE_*
//     * File flags:        FILE_FLAG_*
//     * Creation disposition: CREATE_NEW / CREATE_ALWAYS / OPEN_EXISTING /
//                             OPEN_ALWAYS / TRUNCATE_EXISTING
//     * Win32 error codes: ERROR_*
//     * Wait codes:        WAIT_OBJECT_0 / WAIT_ABANDONED / WAIT_TIMEOUT /
//                          WAIT_FAILED / INFINITE
//   Types:
//     * Overlapped:        new() / with_event() / set_offset() / get_offset()
//
// Reference: Microsoft Win32 API headers (winnt.h, winbase.h, fileapi.h).
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.kernel32.{
    // Memory constants
    MEM_COMMIT, MEM_RESERVE, MEM_DECOMMIT, MEM_RELEASE, MEM_RESET,
    PAGE_NOACCESS, PAGE_READONLY, PAGE_READWRITE, PAGE_WRITECOPY,
    PAGE_EXECUTE, PAGE_EXECUTE_READ, PAGE_EXECUTE_READWRITE,
    PAGE_EXECUTE_WRITECOPY, PAGE_GUARD,
    INVALID_HANDLE_VALUE,

    // Std handles
    STD_INPUT_HANDLE, STD_OUTPUT_HANDLE, STD_ERROR_HANDLE,

    // File attributes
    FILE_ATTRIBUTE_READONLY, FILE_ATTRIBUTE_HIDDEN, FILE_ATTRIBUTE_SYSTEM,
    FILE_ATTRIBUTE_DIRECTORY, FILE_ATTRIBUTE_ARCHIVE, FILE_ATTRIBUTE_DEVICE,
    FILE_ATTRIBUTE_NORMAL, FILE_ATTRIBUTE_TEMPORARY, FILE_ATTRIBUTE_SPARSE_FILE,
    FILE_ATTRIBUTE_REPARSE_POINT, FILE_ATTRIBUTE_COMPRESSED,
    FILE_ATTRIBUTE_OFFLINE, FILE_ATTRIBUTE_NOT_CONTENT_INDEXED,
    FILE_ATTRIBUTE_ENCRYPTED,

    // File flags
    FILE_FLAG_WRITE_THROUGH, FILE_FLAG_OVERLAPPED,
    FILE_FLAG_NO_BUFFERING, FILE_FLAG_RANDOM_ACCESS,
    FILE_FLAG_SEQUENTIAL_SCAN, FILE_FLAG_DELETE_ON_CLOSE,
    FILE_FLAG_BACKUP_SEMANTICS, FILE_FLAG_POSIX_SEMANTICS,
    FILE_FLAG_SESSION_AWARE, FILE_FLAG_OPEN_REPARSE_POINT,
    FILE_FLAG_OPEN_NO_RECALL, FILE_FLAG_FIRST_PIPE_INSTANCE,

    // Creation disposition
    CREATE_NEW, CREATE_ALWAYS, OPEN_EXISTING, OPEN_ALWAYS, TRUNCATE_EXISTING,

    // Win32 error codes
    ERROR_SUCCESS, ERROR_INVALID_FUNCTION, ERROR_FILE_NOT_FOUND,
    ERROR_PATH_NOT_FOUND, ERROR_TOO_MANY_OPEN_FILES, ERROR_ACCESS_DENIED,
    ERROR_INVALID_HANDLE, ERROR_NOT_ENOUGH_MEMORY, ERROR_INVALID_DATA,
    ERROR_OUTOFMEMORY, ERROR_NO_MORE_FILES, ERROR_WRITE_PROTECT,
    ERROR_NOT_READY, ERROR_SHARING_VIOLATION, ERROR_LOCK_VIOLATION,
    ERROR_HANDLE_EOF, ERROR_NOT_SUPPORTED, ERROR_FILE_EXISTS,
    ERROR_INVALID_PARAMETER, ERROR_BROKEN_PIPE, ERROR_DISK_FULL,
    ERROR_INSUFFICIENT_BUFFER, ERROR_INVALID_NAME, ERROR_DIR_NOT_EMPTY,
    ERROR_ALREADY_EXISTS, ERROR_MORE_DATA, ERROR_NO_MORE_ITEMS,
    ERROR_OPERATION_ABORTED, ERROR_IO_INCOMPLETE, ERROR_IO_PENDING,
    ERROR_TIMEOUT,

    // Wait codes
    INFINITE, WAIT_OBJECT_0, WAIT_ABANDONED, WAIT_TIMEOUT, WAIT_FAILED,

    // Notify-change codes
    FILE_NOTIFY_CHANGE_FILE_NAME, FILE_NOTIFY_CHANGE_DIR_NAME,
    FILE_NOTIFY_CHANGE_ATTRIBUTES, FILE_NOTIFY_CHANGE_SIZE,
    FILE_NOTIFY_CHANGE_LAST_WRITE, FILE_NOTIFY_CHANGE_LAST_ACCESS,
    FILE_NOTIFY_CHANGE_CREATION, FILE_NOTIFY_CHANGE_SECURITY,
    FILE_ACTION_ADDED, FILE_ACTION_REMOVED, FILE_ACTION_MODIFIED,
    FILE_ACTION_RENAMED_OLD_NAME, FILE_ACTION_RENAMED_NEW_NAME,

    // Misc
    FILE_BEGIN, FILE_CURRENT, FILE_END,
    LOCKFILE_FAIL_IMMEDIATELY, LOCKFILE_EXCLUSIVE_LOCK,
    STARTF_USESTDHANDLES, CREATE_NO_WINDOW, HANDLE_FLAG_INHERIT,
    STILL_ACTIVE, CREATE_SUSPENDED, TLS_OUT_OF_INDEXES,
};

// =============================================================================
// Section 1 — Memory-protection / allocation constants (winnt.h)
// =============================================================================

@test
fn test_mem_commit_value() {
    assert_eq(MEM_COMMIT, 0x00001000_u32);
}

@test
fn test_mem_reserve_value() {
    assert_eq(MEM_RESERVE, 0x00002000_u32);
}

@test
fn test_mem_decommit_value() {
    assert_eq(MEM_DECOMMIT, 0x00004000_u32);
}

@test
fn test_mem_release_value() {
    assert_eq(MEM_RELEASE, 0x00008000_u32);
}

@test
fn test_mem_reset_value() {
    assert_eq(MEM_RESET, 0x00080000_u32);
}

@test
fn test_page_noaccess_value() {
    assert_eq(PAGE_NOACCESS, 0x01_u32);
}

@test
fn test_page_readonly_value() {
    assert_eq(PAGE_READONLY, 0x02_u32);
}

@test
fn test_page_readwrite_value() {
    assert_eq(PAGE_READWRITE, 0x04_u32);
}

@test
fn test_page_writecopy_value() {
    assert_eq(PAGE_WRITECOPY, 0x08_u32);
}

@test
fn test_page_execute_value() {
    assert_eq(PAGE_EXECUTE, 0x10_u32);
}

@test
fn test_page_execute_read_value() {
    assert_eq(PAGE_EXECUTE_READ, 0x20_u32);
}

@test
fn test_page_execute_readwrite_value() {
    assert_eq(PAGE_EXECUTE_READWRITE, 0x40_u32);
}

@test
fn test_page_execute_writecopy_value() {
    assert_eq(PAGE_EXECUTE_WRITECOPY, 0x80_u32);
}

@test
fn test_page_guard_value() {
    assert_eq(PAGE_GUARD, 0x100_u32);
}

@test
fn test_invalid_handle_value_is_all_ones() {
    assert_eq(INVALID_HANDLE_VALUE, 0xFFFFFFFFFFFFFFFF_u64);
}

// =============================================================================
// Section 2 — Standard handle constants (kernel32 GetStdHandle)
// =============================================================================

@test
fn test_std_input_handle_value() {
    // STD_INPUT_HANDLE = -10 (signed) = 0xFFFFFFF6 (unsigned)
    assert_eq(STD_INPUT_HANDLE, 0xFFFFFFF6_u32);
}

@test
fn test_std_output_handle_value() {
    assert_eq(STD_OUTPUT_HANDLE, 0xFFFFFFF5_u32);
}

@test
fn test_std_error_handle_value() {
    assert_eq(STD_ERROR_HANDLE, 0xFFFFFFF4_u32);
}

