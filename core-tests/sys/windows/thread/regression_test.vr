// =============================================================================
// core-tests/sys/windows/thread/regression_test.vr
// =============================================================================
//
// REGRESSION / LOCK-IN pins for fragile PURE invariants of
// `core.sys.windows.thread`. These guard against silent drift in values
// that the CAS state machine, stack-allocation sizing, and error-payload
// round-tripping all depend on.
//
// HOST-SAFE: no kernel32 FFI. Kernel-facing ops are deferred (audit.md §4).
//
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.thread.{
    WindowsThreadError,
    DEFAULT_THREAD_STACK_SIZE,
    ONCE_INIT, ONCE_RUNNING, ONCE_COMPLETE,
};

// -----------------------------------------------------------------------------
// REGRESSION/LOCK-IN 1 — Once CAS sentinel triple is exactly (0,1,2).
//
// The WindowsOnce state machine uses atomic_cas_u32(state, INIT, RUNNING)
// and a fast-path `== COMPLETE`. If any of these three drift or collide,
// the one-time-initialisation guarantee breaks silently (double-run or
// permanent deadlock). Pin the exact literals AND their distinctness.
// -----------------------------------------------------------------------------

@test
fn wx_thread_lockin_once_sentinels_exact_literals() {
    assert_eq(ONCE_INIT, 0_u32);
    assert_eq(ONCE_RUNNING, 1_u32);
    assert_eq(ONCE_COMPLETE, 2_u32);
}

@test
fn wx_thread_lockin_once_sentinels_distinct() {
    assert(ONCE_INIT != ONCE_RUNNING);
    assert(ONCE_INIT != ONCE_COMPLETE);
    assert(ONCE_RUNNING != ONCE_COMPLETE);
}

// -----------------------------------------------------------------------------
// REGRESSION/LOCK-IN 2 — DEFAULT_THREAD_STACK_SIZE is exactly 1 MiB.
//
// Stack-allocated buffers sized relative to this value would silently
// overflow on shrink. Pin the byte count exactly.
// -----------------------------------------------------------------------------

@test
fn wx_thread_lockin_default_stack_size_exact_bytes() {
    assert_eq(DEFAULT_THREAD_STACK_SIZE, 1048576_usize);
}

// -----------------------------------------------------------------------------
// REGRESSION/LOCK-IN 3 — WindowsThreadError code payload round-trips
// without truncation across the full UInt32 range edges.
//
// The 8 code-bearing variants store a raw GetLastError() code. Pin that a
// boundary value (0xFFFFFFFF) survives a construct -> match -> read cycle,
// guarding against any narrowing of the `code` field width.
// -----------------------------------------------------------------------------

@test
fn wx_thread_lockin_create_failed_code_max_roundtrip() {
    let e = WindowsThreadError.CreateFailed { code: 0xFFFFFFFF_u32 };
    match e {
        WindowsThreadError.CreateFailed { code } => assert_eq(code, 0xFFFFFFFF_u32),
        _ => panic("expected CreateFailed"),
    };
}

@test
fn wx_thread_lockin_cond_wait_failed_error_timeout_code() {
    // 1460 is ERROR_TIMEOUT — the futex_wait timeout path surfaces it as a
    // CondWaitFailed-style code. Pin it survives round-trip intact.
    let e = WindowsThreadError.CondWaitFailed { code: 1460_u32 };
    match e {
        WindowsThreadError.CondWaitFailed { code } => assert_eq(code, 1460_u32),
        _ => panic("expected CondWaitFailed"),
    };
}

// -----------------------------------------------------------------------------
// REGRESSION/LOCK-IN 4 — Eq must not collapse distinct variants that share
// a payload. A naive payload-only Eq would make CreateFailed{8} ==
// JoinFailed{8}; the impl matches on variant tag first. Pin it stays so.
// -----------------------------------------------------------------------------

@test
fn wx_thread_lockin_eq_no_cross_variant_payload_collapse() {
    assert(WindowsThreadError.CreateFailed { code: 8_u32 }
           != WindowsThreadError.JoinFailed { code: 8_u32 });
    assert(WindowsThreadError.MutexInitFailed { code: 8_u32 }
           != WindowsThreadError.CondInitFailed { code: 8_u32 });
}

// -----------------------------------------------------------------------------
// REGRESSION/LOCK-IN 5 — message() text for unit variants is byte-stable.
// These strings are part of the user-facing diagnostic contract.
// -----------------------------------------------------------------------------

@test
fn wx_thread_lockin_message_unit_variant_text() {
    assert_eq(WindowsThreadError.TlsInitFailed.message(),
              "Failed to initialize TLS for new thread");
    assert_eq(WindowsThreadError.AlreadyJoined.message(),
              "WindowsThread has already been joined");
    assert_eq(WindowsThreadError.AlreadyDetached.message(),
              "WindowsThread has already been detached");
}
