// =============================================================================
// core-tests/sys/windows/mod/property_test.vr
// =============================================================================
//
// Algebraic laws over the `core.sys.windows` umbrella re-exports. Every
// value is reached through the umbrella path, so these properties double
// as a re-export-integrity guard: a dropped or mis-wired re-export in
// `core/sys/windows/mod.vr` fails to compile here.
//
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.{
    // kernel32
    INFINITE, WAIT_OBJECT_0,
    STD_INPUT_HANDLE, STD_OUTPUT_HANDLE, STD_ERROR_HANDLE,
    INVALID_HANDLE_VALUE,
    GENERIC_READ, GENERIC_WRITE,
    CREATE_NEW, CREATE_ALWAYS, OPEN_EXISTING,
    TLS_OUT_OF_INDEXES,
    // tls bootstrap
    MAX_CONTEXT_SLOTS, CONTEXT_STACK_DEPTH, GUARD_PAGE_SIZE, DEFAULT_STACK_SIZE,
    // time
    NANOS_PER_SEC, NANOS_PER_MILLI, NANOS_PER_MICRO,
    // winsock2
    AF_INET, AF_INET6, SOCK_STREAM, SOCK_DGRAM, IPPROTO_TCP, IPPROTO_UDP,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
};

// =============================================================================
// Property 1 — kernel32 sentinels
// =============================================================================

@test
fn wx_mod_prop_infinite_is_max_u32() {
    assert_eq(INFINITE, 0xFFFFFFFF_u32);
}

@test
fn wx_mod_prop_wait_object_0_is_zero() {
    assert_eq(WAIT_OBJECT_0, 0_u32);
}

@test
fn wx_mod_prop_std_handles_distinct_and_negative() {
    assert_eq(STD_INPUT_HANDLE, 0xFFFFFFF6_u32);
    assert_eq(STD_OUTPUT_HANDLE, 0xFFFFFFF5_u32);
    assert_eq(STD_ERROR_HANDLE, 0xFFFFFFF4_u32);
    assert(STD_INPUT_HANDLE != STD_OUTPUT_HANDLE);
    assert(STD_INPUT_HANDLE != STD_ERROR_HANDLE);
    assert(STD_OUTPUT_HANDLE != STD_ERROR_HANDLE);
}

@test
fn wx_mod_prop_generic_masks_single_bit() {
    assert(GENERIC_READ != 0 && (GENERIC_READ & (GENERIC_READ - 1)) == 0);
    assert(GENERIC_WRITE != 0 && (GENERIC_WRITE & (GENERIC_WRITE - 1)) == 0);
}

@test
fn wx_mod_prop_creation_disposition_consecutive() {
    assert_eq(CREATE_NEW, 1_u32);
    assert_eq(CREATE_ALWAYS, 2_u32);
    assert_eq(OPEN_EXISTING, 3_u32);
}

// =============================================================================
// Property 2 — TLS bootstrap constants
// =============================================================================

@test
fn wx_mod_prop_tls_constants_powers_of_two() {
    let slots = MAX_CONTEXT_SLOTS;
    let depth = CONTEXT_STACK_DEPTH;
    let guard = GUARD_PAGE_SIZE;
    assert(slots != 0 && (slots & (slots - 1)) == 0);
    assert(depth != 0 && (depth & (depth - 1)) == 0);
    assert(guard != 0 && (guard & (guard - 1)) == 0);
}

@test
fn wx_mod_prop_default_stack_exceeds_guard_page() {
    assert(DEFAULT_STACK_SIZE > GUARD_PAGE_SIZE);
}

@test
fn wx_mod_prop_tls_out_of_indexes_is_max_u32() {
    assert_eq(TLS_OUT_OF_INDEXES, 0xFFFFFFFF_u32);
}

// =============================================================================
// Property 3 — time scaling relations
// =============================================================================

@test
fn wx_mod_prop_nanos_scaling() {
    assert_eq(NANOS_PER_SEC, NANOS_PER_MILLI * 1000_u64);
    assert_eq(NANOS_PER_MILLI, NANOS_PER_MICRO * 1000_u64);
    assert_eq(NANOS_PER_SEC, 1_000_000_000_u64);
}

// =============================================================================
// Property 4 — winsock2 partition laws
// =============================================================================

@test
fn wx_mod_prop_socket_families_and_types_distinct() {
    assert(AF_INET != AF_INET6);
    assert(SOCK_STREAM != SOCK_DGRAM);
    assert(IPPROTO_TCP != IPPROTO_UDP);
}

@test
fn wx_mod_prop_shutdown_modes_partition() {
    assert(SHUT_RD != SHUT_WR);
    assert(SHUT_RD != SHUT_RDWR);
    assert(SHUT_WR != SHUT_RDWR);
    assert_eq(SHUT_RD + SHUT_WR + SHUT_RDWR, 3);
}

// =============================================================================
// Property 5 — INVALID_HANDLE_VALUE is the 64-bit all-ones sentinel
// =============================================================================

@test
fn wx_mod_prop_invalid_handle_value_all_ones() {
    assert_eq(INVALID_HANDLE_VALUE, 0xFFFFFFFFFFFFFFFF_u64);
}
