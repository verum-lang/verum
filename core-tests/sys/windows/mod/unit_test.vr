// =============================================================================
// core-tests/sys/windows/mod/unit_test.vr
// =============================================================================
//
// Unit tests for the `core.sys.windows` umbrella module re-exports.  Pins
// that every documented re-export name resolves at compile time and
// constructs at runtime.  A regression that drops any re-export from
// `core/sys/windows/mod.vr` would cause the corresponding `@test` to fail
// at compile time.
//
// =============================================================================

mount core.prelude.*;

// =============================================================================
// Section 1 — NTSTATUS re-exports
// =============================================================================

mount core.sys.windows.{
    NtStatus,
    STATUS_SUCCESS, STATUS_PENDING, STATUS_TIMEOUT,
    STATUS_INVALID_HANDLE, STATUS_INVALID_PARAMETER, STATUS_NO_MEMORY,
    STATUS_OBJECT_NAME_NOT_FOUND, STATUS_OBJECT_PATH_NOT_FOUND,
    STATUS_END_OF_FILE, STATUS_ACCESS_DENIED, STATUS_BUFFER_OVERFLOW,
    STATUS_BUFFER_TOO_SMALL, STATUS_INSUFFICIENT_RESOURCES,
    STATUS_NOT_SUPPORTED, STATUS_NOT_IMPLEMENTED, STATUS_CANCELLED,
};

@test
fn test_status_success_via_umbrella() {
    assert(STATUS_SUCCESS.is_success());
}

@test
fn test_status_invalid_handle_via_umbrella() {
    assert(STATUS_INVALID_HANDLE.is_error());
}

@test
fn test_nt_status_type_via_umbrella() {
    let s = NtStatus(0_i32);
    assert(s.is_success());
}

// =============================================================================
// Section 2 — Kernel32 re-exports
// =============================================================================

mount core.sys.windows.{
    GetLastError,
    GetStdHandle,
    CloseHandle,
    CreateFileW,
    ReadFile,
    WriteFile,
    VirtualAlloc, VirtualFree, VirtualProtect,
    GetCurrentProcess, GetCurrentProcessId,
    GetCurrentThread, GetCurrentThreadId,
    CreateThread,
    Sleep,
    WaitForSingleObject,
    INFINITE, WAIT_OBJECT_0,
    STD_INPUT_HANDLE, STD_OUTPUT_HANDLE, STD_ERROR_HANDLE,
    INVALID_HANDLE_VALUE,
    CREATE_NEW, CREATE_ALWAYS, OPEN_EXISTING,
    GENERIC_READ, GENERIC_WRITE,
    FILE_ATTRIBUTE_NORMAL, FILE_FLAG_OVERLAPPED,
    TLS_OUT_OF_INDEXES,
};

@test
fn test_infinite_via_umbrella() {
    assert_eq(INFINITE, 0xFFFFFFFF_u32);
}

@test
fn test_wait_object_0_via_umbrella() {
    assert_eq(WAIT_OBJECT_0, 0_u32);
}

@test
fn test_std_handles_via_umbrella() {
    assert_eq(STD_INPUT_HANDLE, 0xFFFFFFF6_u32);
    assert_eq(STD_OUTPUT_HANDLE, 0xFFFFFFF5_u32);
    assert_eq(STD_ERROR_HANDLE, 0xFFFFFFF4_u32);
}

@test
fn test_invalid_handle_value_via_umbrella() {
    assert_eq(INVALID_HANDLE_VALUE, 0xFFFFFFFFFFFFFFFF_u64);
}

@test
fn test_generic_read_write_via_umbrella() {
    assert_eq(GENERIC_READ, 0x80000000_u32);
    assert_eq(GENERIC_WRITE, 0x40000000_u32);
}

@test
fn test_creation_disposition_via_umbrella() {
    assert_eq(CREATE_NEW, 1_u32);
    assert_eq(CREATE_ALWAYS, 2_u32);
    assert_eq(OPEN_EXISTING, 3_u32);
}

@test
fn test_file_attributes_via_umbrella() {
    assert_eq(FILE_ATTRIBUTE_NORMAL, 0x80_u32);
    assert_eq(FILE_FLAG_OVERLAPPED, 0x40000000_u32);
}

@test
fn test_tls_out_of_indexes_via_umbrella() {
    assert_eq(TLS_OUT_OF_INDEXES, 0xFFFFFFFF_u32);
}

// =============================================================================
// Section 3 — TLS re-exports
// =============================================================================

mount core.sys.windows.{
    MAX_CONTEXT_SLOTS, CONTEXT_STACK_DEPTH, TCB_MAGIC,
    DEFAULT_STACK_SIZE, GUARD_PAGE_SIZE,
};

@test
fn test_tls_constants_via_umbrella() {
    assert_eq(MAX_CONTEXT_SLOTS, 256);
    assert_eq(CONTEXT_STACK_DEPTH, 8);
    assert_eq(TCB_MAGIC, 0x5645_5255_4D5F_5443_u64);
    assert_eq(DEFAULT_STACK_SIZE, 1024 * 1024);
    assert_eq(GUARD_PAGE_SIZE, 4096);
}

// =============================================================================
// Section 4 — Time re-exports
// =============================================================================

mount core.sys.windows.{
    NANOS_PER_SEC, NANOS_PER_MILLI, NANOS_PER_MICRO,
};

@test
fn test_time_scale_constants_via_umbrella() {
    assert_eq(NANOS_PER_SEC, 1_000_000_000_u64);
    assert_eq(NANOS_PER_MILLI, 1_000_000_u64);
    assert_eq(NANOS_PER_MICRO, 1_000_u64);
}

// =============================================================================
// Section 5 — Winsock2 re-exports
// =============================================================================

mount core.sys.windows.{
    AF_INET, AF_INET6,
    SOCK_STREAM, SOCK_DGRAM,
    IPPROTO_TCP, IPPROTO_UDP,
    SOL_SOCKET, SO_ERROR,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
    MSG_PEEK,
    INVALID_SOCKET,
};

@test
fn test_winsock_constants_via_umbrella() {
    assert_eq(AF_INET, 2);
    assert_eq(AF_INET6, 23);
    assert_eq(SOCK_STREAM, 1);
    assert_eq(SOCK_DGRAM, 2);
    assert_eq(IPPROTO_TCP, 6);
    assert_eq(IPPROTO_UDP, 17);
    assert_eq(SOL_SOCKET, 0xFFFF);
    assert_eq(INVALID_SOCKET, 0xFFFFFFFFFFFFFFFF_u64);
}

@test
fn test_shutdown_modes_via_umbrella() {
    assert_eq(SHUT_RD, 0);
    assert_eq(SHUT_WR, 1);
    assert_eq(SHUT_RDWR, 2);
}
