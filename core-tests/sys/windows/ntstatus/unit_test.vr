// =============================================================================
// Section 3 — facility / status_code field extraction
// =============================================================================

@test
fn test_facility_of_success_is_zero() {
    assert_eq(STATUS_SUCCESS.facility(), 0_u16);
}

@test
fn test_facility_of_invalid_handle_is_zero() {
    // 0xC0000008 — facility bits 27-16 = 0x000 (NULL/default)
    assert_eq(STATUS_INVALID_HANDLE.facility(), 0_u16);
}

@test
fn test_status_code_of_invalid_handle_is_eight() {
    // 0xC0000008 — low 16 bits = 0x0008
    assert_eq(STATUS_INVALID_HANDLE.status_code(), 8_u16);
}

@test
fn test_status_code_of_object_name_not_found() {
    // 0xC0000034 — low 16 bits = 0x0034 = 52
    assert_eq(STATUS_OBJECT_NAME_NOT_FOUND.status_code(), 0x0034_u16);
}

@test
fn test_status_code_of_pending() {
    // 0x00000103 — low 16 bits = 0x0103 = 259
    assert_eq(STATUS_PENDING.status_code(), 0x0103_u16);
}

// =============================================================================
// Section 4 — to_win32_error conversion
// =============================================================================

@test
fn test_to_win32_error_success_is_zero() {
    assert_eq(STATUS_SUCCESS.to_win32_error(), 0_u32);
}

@test
fn test_to_win32_error_error_keeps_low_16_bits() {
    // 0xC0000008 -> 0x00000008 (low 16 bits, per simplified conversion path)
    assert_eq(STATUS_INVALID_HANDLE.to_win32_error(), 0x0008_u32);
}

@test
fn test_to_win32_error_invalid_parameter_keeps_low_16_bits() {
    // 0xC000000D -> 0x0000000D
    assert_eq(STATUS_INVALID_PARAMETER.to_win32_error(), 0x000D_u32);
}

// =============================================================================
// Section 5 — name() lookup table
// =============================================================================

@test
fn test_name_status_success() {
    assert_eq(STATUS_SUCCESS.name(), "STATUS_SUCCESS");
}

@test
fn test_name_status_pending() {
    assert_eq(STATUS_PENDING.name(), "STATUS_PENDING");
}

@test
fn test_name_status_invalid_handle() {
    assert_eq(STATUS_INVALID_HANDLE.name(), "STATUS_INVALID_HANDLE");
}

@test
fn test_name_status_access_denied() {
    assert_eq(STATUS_ACCESS_DENIED.name(), "STATUS_ACCESS_DENIED");
}

@test
fn test_name_status_no_memory() {
    assert_eq(STATUS_NO_MEMORY.name(), "STATUS_NO_MEMORY");
}

@test
fn test_name_unknown_returns_status_unknown() {
    let unknown_status = NtStatus(0xDEAD_BEEF_u32 as Int32);
    assert_eq(unknown_status.name(), "STATUS_UNKNOWN");
}

@test
fn test_name_status_not_found() {
    assert_eq(STATUS_NOT_FOUND.name(), "STATUS_NOT_FOUND");
}

@test
fn test_name_status_buffer_overflow() {
    assert_eq(STATUS_BUFFER_OVERFLOW.name(), "STATUS_BUFFER_OVERFLOW");
}

// =============================================================================
// Section 6 — Top-level helper predicates (nt_success / nt_error / ...)
// =============================================================================

@test
fn test_nt_success_for_success_arm() {
    assert(nt_success(STATUS_SUCCESS));
    assert(nt_success(STATUS_PENDING));
    assert(nt_success(STATUS_TIMEOUT));
}

@test
fn test_nt_success_for_error_arm_is_false() {
    assert(!nt_success(STATUS_INVALID_HANDLE));
    assert(!nt_success(STATUS_NO_MEMORY));
}

@test
fn test_nt_error_for_error_arms() {
    assert(nt_error(STATUS_INVALID_HANDLE));
    assert(nt_error(STATUS_ACCESS_DENIED));
    assert(nt_error(STATUS_NO_MEMORY));
}

@test
fn test_nt_error_for_success_arm_is_false() {
    assert(!nt_error(STATUS_SUCCESS));
    assert(!nt_error(STATUS_PENDING));
}

@test
fn test_nt_warning_for_warning_arms() {
    assert(nt_warning(STATUS_BUFFER_OVERFLOW));
    assert(nt_warning(STATUS_NO_MORE_FILES));
}

@test
fn test_nt_warning_for_error_arm_is_false() {
    assert(!nt_warning(STATUS_INVALID_HANDLE));
}

@test
fn test_nt_information_for_information_arms() {
    assert(nt_information(STATUS_OBJECT_NAME_EXISTS));
    assert(nt_information(STATUS_THREAD_WAS_SUSPENDED));
}

@test
fn test_nt_information_for_success_arm_is_false() {
    assert(!nt_information(STATUS_SUCCESS));
}

// =============================================================================
// Section 7 — Classifier helpers
// =============================================================================

@test
fn test_is_retryable_only_for_pending() {
    assert(is_retryable(STATUS_PENDING));
    assert(!is_retryable(STATUS_SUCCESS));
    assert(!is_retryable(STATUS_TIMEOUT));
    assert(!is_retryable(STATUS_INVALID_HANDLE));
}

@test
fn test_is_not_found_for_object_name_not_found() {
    assert(is_not_found(STATUS_OBJECT_NAME_NOT_FOUND));
}

@test
fn test_is_not_found_for_no_such_file() {
    assert(is_not_found(STATUS_NO_SUCH_FILE));
}

@test
fn test_is_not_found_for_object_path_not_found() {
    assert(is_not_found(STATUS_OBJECT_PATH_NOT_FOUND));
}

@test
fn test_is_not_found_for_status_not_found() {
    assert(is_not_found(STATUS_NOT_FOUND));
}

@test
fn test_is_not_found_rejects_unrelated_errors() {
    assert(!is_not_found(STATUS_ACCESS_DENIED));
    assert(!is_not_found(STATUS_INVALID_HANDLE));
    assert(!is_not_found(STATUS_NO_MEMORY));
    assert(!is_not_found(STATUS_SUCCESS));
}

@test
fn test_is_access_denied_for_access_denied() {
    assert(is_access_denied(STATUS_ACCESS_DENIED));
}

@test
fn test_is_access_denied_rejects_unrelated_errors() {
    assert(!is_access_denied(STATUS_INVALID_HANDLE));
    assert(!is_access_denied(STATUS_OBJECT_NAME_NOT_FOUND));
    assert(!is_access_denied(STATUS_SUCCESS));
}
