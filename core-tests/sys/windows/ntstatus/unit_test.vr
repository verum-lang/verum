// =============================================================================
// core-tests/sys/windows/ntstatus/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.windows.ntstatus` — NT status codes and severity
// helpers used by every wrapper around `ntdll.dll`. The NTSTATUS layout is
// fixed by the Win32 ABI:
//
//   Bits 31-30 — severity   (0=Success, 1=Info, 2=Warning, 3=Error)
//   Bit  29    — customer
//   Bit  28    — reserved
//   Bits 27-16 — facility
//   Bits 15-0  — code
//
// API surface tested here:
//
//   Types:      NtStatus(Int32)
//   Methods:    is_success / is_information / is_warning / is_error,
//               code / facility / status_code / to_win32_error / name
//   Constants:  ~50 NTSTATUS code constants (success / info / warn / error)
//   Helpers:    nt_success / nt_error / nt_warning / nt_information,
//               is_retryable / is_not_found / is_access_denied
//
// What we DO pin:
//   * Canonical NTSTATUS values — every constant matches its ntstatus.h
//     counterpart at the bit level.
//   * Severity-bit dispatch — `is_*` predicates classify by bits 31-30 only.
//   * `name` lookups for the documented arms; unknown values return
//     `"STATUS_UNKNOWN"`.
//   * Classifier helpers (retryable / not-found / access-denied) match
//     exactly the set the implementation enumerates.
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.ntstatus.{
    NtStatus,
    STATUS_SUCCESS, STATUS_PENDING, STATUS_REPARSE, STATUS_MORE_ENTRIES,
    STATUS_TIMEOUT, STATUS_ALERTED,
    STATUS_OBJECT_NAME_EXISTS, STATUS_THREAD_WAS_SUSPENDED,
    STATUS_BUFFER_OVERFLOW, STATUS_NO_MORE_FILES, STATUS_NO_MORE_ENTRIES,
    STATUS_UNSUCCESSFUL, STATUS_NOT_IMPLEMENTED, STATUS_INVALID_INFO_CLASS,
    STATUS_INFO_LENGTH_MISMATCH, STATUS_ACCESS_VIOLATION,
    STATUS_INVALID_HANDLE, STATUS_INVALID_PARAMETER, STATUS_NO_SUCH_FILE,
    STATUS_END_OF_FILE, STATUS_NO_MEMORY, STATUS_ACCESS_DENIED,
    STATUS_BUFFER_TOO_SMALL, STATUS_OBJECT_NAME_NOT_FOUND,
    STATUS_OBJECT_PATH_NOT_FOUND, STATUS_NOT_SUPPORTED,
    STATUS_NOT_FOUND, STATUS_CANCELLED, STATUS_INTEGER_OVERFLOW,
    STATUS_DISK_FULL, STATUS_DIRECTORY_NOT_EMPTY,
    STATUS_CONNECTION_DISCONNECTED, STATUS_CONNECTION_RESET,
    STATUS_INSUFFICIENT_RESOURCES,
    nt_success, nt_error, nt_warning, nt_information,
    is_retryable, is_not_found, is_access_denied,
};

// =============================================================================
// Section 1 — Severity bit decoding (canonical NTSTATUS layout)
// =============================================================================

@test
fn test_status_success_is_zero() {
    assert_eq(STATUS_SUCCESS.code(), 0_i32);
}

@test
fn test_status_success_is_success() {
    assert(STATUS_SUCCESS.is_success());
}

@test
fn test_status_pending_is_success_severity() {
    // 0x00000103 — severity bits 31-30 = 00 → Success domain
    assert(STATUS_PENDING.is_success());
}

@test
fn test_status_timeout_is_success_severity() {
    // 0x00000102 — severity bits 31-30 = 00 → Success domain
    assert(STATUS_TIMEOUT.is_success());
}

@test
fn test_status_reparse_is_success_severity() {
    assert(STATUS_REPARSE.is_success());
}

@test
fn test_status_more_entries_is_success_severity() {
    assert(STATUS_MORE_ENTRIES.is_success());
}

@test
fn test_status_alerted_is_success_severity() {
    assert(STATUS_ALERTED.is_success());
}

@test
fn test_status_object_name_exists_is_information() {
    // 0x40000000 — severity bits 31-30 = 01 → Information domain
    assert(STATUS_OBJECT_NAME_EXISTS.is_information());
    // NT_SUCCESS convention: NT_SUCCESS(s) := (s >= 0). Information codes
    // are below the sign bit, so they ARE NT_SUCCESS-true. The severity
    // dispatch is the partition into Success / Info / Warn / Error;
    // NT_SUCCESS is the high-bit shortcut covering Success ∪ Information.
    assert(STATUS_OBJECT_NAME_EXISTS.is_success());
    assert(!STATUS_OBJECT_NAME_EXISTS.is_warning());
    assert(!STATUS_OBJECT_NAME_EXISTS.is_error());
}

@test
fn test_status_thread_was_suspended_is_information() {
    assert(STATUS_THREAD_WAS_SUSPENDED.is_information());
    // Same as above — Information is NT_SUCCESS-true.
    assert(STATUS_THREAD_WAS_SUSPENDED.is_success());
}

@test
fn test_status_buffer_overflow_is_warning() {
    // 0x80000005 — severity bits 31-30 = 10 → Warning domain
    assert(STATUS_BUFFER_OVERFLOW.is_warning());
    assert(!STATUS_BUFFER_OVERFLOW.is_success());
    assert(!STATUS_BUFFER_OVERFLOW.is_information());
    assert(!STATUS_BUFFER_OVERFLOW.is_error());
}

@test
fn test_status_no_more_files_is_warning() {
    assert(STATUS_NO_MORE_FILES.is_warning());
}

@test
fn test_status_no_more_entries_is_warning() {
    assert(STATUS_NO_MORE_ENTRIES.is_warning());
}

@test
fn test_status_unsuccessful_is_error() {
    // 0xC0000001 — severity bits 31-30 = 11 → Error domain
    assert(STATUS_UNSUCCESSFUL.is_error());
    assert(!STATUS_UNSUCCESSFUL.is_success());
}

@test
fn test_status_invalid_handle_is_error() {
    assert(STATUS_INVALID_HANDLE.is_error());
}

@test
fn test_status_access_violation_is_error() {
    assert(STATUS_ACCESS_VIOLATION.is_error());
}

@test
fn test_status_access_denied_is_error() {
    assert(STATUS_ACCESS_DENIED.is_error());
}

@test
fn test_status_no_memory_is_error() {
    assert(STATUS_NO_MEMORY.is_error());
}

@test
fn test_status_invalid_parameter_is_error() {
    assert(STATUS_INVALID_PARAMETER.is_error());
}

