// =============================================================================
// core-tests/sys/windows/winsock2/integration_test.vr
// =============================================================================
//
// Cross-stdlib scenarios for `core.sys.windows.winsock2` pure surface.
// sockaddr records + constants flowing through List / Maybe / Map.
// No socket FFI.
//
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.winsock2.{
    AF_INET, AF_INET6,
    SOCK_STREAM, SOCK_DGRAM,
    IPPROTO_TCP, IPPROTO_UDP,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
    WindowsSockaddrIn,
};

// =============================================================================
// Section 1 — Build a table of sockaddr_in and look them up
// =============================================================================

@test
fn wx_winsock2_int_sockaddr_list_round_trip() {
    let mut addrs: List<WindowsSockaddrIn> = List.new();
    addrs.push(WindowsSockaddrIn { family: AF_INET as UInt16, port: 80_u16,  addr: 0x0100007F_u32, zero: 0_u64 });
    addrs.push(WindowsSockaddrIn { family: AF_INET as UInt16, port: 443_u16, addr: 0x0100007F_u32, zero: 0_u64 });

    assert_eq(addrs.len(), 2);
    assert_eq(addrs[0].port, 80_u16);
    assert_eq(addrs[1].port, 443_u16);
}

// =============================================================================
// Section 2 — Protocol selection via a Map keyed by socket type
// =============================================================================

@test
fn wx_winsock2_int_proto_for_socktype_map() {
    let mut m: Map<Int, Int> = Map.new();
    m.insert(SOCK_STREAM, IPPROTO_TCP);
    m.insert(SOCK_DGRAM, IPPROTO_UDP);

    match m.get(&SOCK_STREAM) {
        Maybe.Some(p) => assert_eq(*p, 6),
        Maybe.None => assert(false, "stream proto missing"),
    }
    match m.get(&SOCK_DGRAM) {
        Maybe.Some(p) => assert_eq(*p, 17),
        Maybe.None => assert(false, "dgram proto missing"),
    }
}

// =============================================================================
// Section 3 — Shutdown mode carried through Maybe and matched
// =============================================================================

@test
fn wx_winsock2_int_shutdown_mode_in_maybe() {
    let mode: Maybe<Int> = Maybe.Some(SHUT_RDWR);
    let resolved = match mode {
        Maybe.Some(m) => m,
        Maybe.None => SHUT_RD,
    };
    assert_eq(resolved, 2);
    assert(resolved != SHUT_RD);
    assert(resolved != SHUT_WR);
}

// =============================================================================
// Section 4 — Address-family-tagged dispatch
// =============================================================================

fn family_name(fam: Int) -> Text {
    if fam == AF_INET {
        "v4"
    } else if fam == AF_INET6 {
        "v6"
    } else {
        "?"
    }
}

@test
fn wx_winsock2_int_family_dispatch() {
    assert_eq(family_name(AF_INET), "v4");
    assert_eq(family_name(AF_INET6), "v6");
    assert_eq(family_name(99), "?");
}
