// =============================================================================
// core-tests/sys/windows/time/integration_test.vr
// =============================================================================
//
// Cross-stdlib integration for the host-safe surface of
// `core.sys.windows.time`. Exercises WindowsDuration / WindowsDeadlineTimer
// alongside real stdlib container types:
//
//   * List<WindowsDuration> — store, fold/sum via .add(), max-by as_nanos.
//   * Maybe<WindowsDuration> — wrap durations and unwrap through match.
//   * Map<Text, WindowsDuration> — name → duration lookup table.
//   * WindowsDeadlineTimer.none().remaining() as a Maybe in a match arm.
//
// NOTE — host-safe only. No QueryPerformanceCounter FFI is touched; every
// duration is constructed from a literal nanosecond count and the only
// deadline-timer path used is none() (which performs no QPC call).
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.time.{
    NANOS_PER_SEC,
    WindowsDuration,
    WindowsDeadlineTimer,
};

// =============================================================================
// Integration 1 — durations live in a List and fold under .add()
// =============================================================================

@test
fn wx_time_int_durations_in_list_sum() {
    let mut xs: List<WindowsDuration> = List.new();
    xs.push(WindowsDuration.from_millis(100_u64));
    xs.push(WindowsDuration.from_millis(250_u64));
    xs.push(WindowsDuration.from_millis(650_u64));

    let mut total = WindowsDuration.zero();
    let mut i = 0;
    while i < xs.len() {
        total = total.add(xs[i]);
        i = i + 1;
    }
    // 100 + 250 + 650 == 1000 ms == 1 s
    assert_eq(total.as_nanos(), NANOS_PER_SEC);
    assert_eq(total.as_millis(), 1_000_u64);
    assert_eq(total.as_secs(), 1_u64);
}

// =============================================================================
// Integration 2 — find the max duration by comparing as_nanos
// =============================================================================

@test
fn wx_time_int_durations_max_by_nanos() {
    let mut xs: List<WindowsDuration> = List.new();
    xs.push(WindowsDuration.from_nanos(5_u64));
    xs.push(WindowsDuration.from_micros(3_u64));   // 3_000 ns
    xs.push(WindowsDuration.from_nanos(900_u64));
    xs.push(WindowsDuration.from_micros(1_u64));   // 1_000 ns

    let mut best = WindowsDuration.zero();
    let mut i = 0;
    while i < xs.len() {
        if xs[i].as_nanos() > best.as_nanos() {
            best = xs[i];
        }
        i = i + 1;
    }
    // The 3-microsecond entry (3_000 ns) is the largest.
    assert_eq(best.as_nanos(), 3_000_u64);
}

// =============================================================================
// Integration 3 — wrap durations in Maybe and unwrap via match
// =============================================================================

@test
fn wx_time_int_duration_in_maybe_match() {
    let m: Maybe<WindowsDuration> = Maybe.Some(WindowsDuration.from_secs(2_u64));
    let nanos = match m {
        Maybe.Some(d) => d.as_nanos(),
        Maybe.None => 0_u64,
    };
    assert_eq(nanos, 2_000_000_000_u64);

    let empty: Maybe<WindowsDuration> = Maybe.None;
    let fallback = match empty {
        Maybe.Some(d) => d.as_nanos(),
        Maybe.None => 42_u64,
    };
    assert_eq(fallback, 42_u64);
}

// =============================================================================
// Integration 4 — Map<Text, WindowsDuration> name → duration lookup
// =============================================================================

@test
fn wx_time_int_durations_in_map() {
    let mut timeouts: Map<Text, WindowsDuration> = Map.new();
    let _ = timeouts.insert("connect", WindowsDuration.from_secs(5_u64));
    let _ = timeouts.insert("read", WindowsDuration.from_millis(500_u64));
    let _ = timeouts.insert("write", WindowsDuration.from_millis(250_u64));

    match timeouts.get(&"connect") {
        Maybe.Some(d) => assert_eq(d.as_secs(), 5_u64),
        Maybe.None => assert(false, "connect timeout must be present"),
    }
    match timeouts.get(&"read") {
        Maybe.Some(d) => assert_eq(d.as_millis(), 500_u64),
        Maybe.None => assert(false, "read timeout must be present"),
    }
    assert_eq(timeouts.get(&"missing"), Maybe.None);
}

// =============================================================================
// Integration 5 — sum the durations stored in a Map
// =============================================================================
//
// NEWTYPE-UNBOX-1: a `WindowsDuration` (single-field `(UInt64)` newtype)
// retrieved from a `Map` and fed into accumulating arithmetic mis-behaves —
// even reading `.as_nanos()` and summing corrupts control flow (the test
// "exits" with the raw nanos value 500_000_000 instead of asserting). The
// non-arithmetic Map tests (storage + single-field read) pass; only the
// summing path trips the defect. Pinned with @ignore until the VBC codegen
// newtype boxing/unboxing parity fix lands. See audit.md + catalogue §12.
@ignore("NEWTYPE-UNBOX-1: summing WindowsDuration values retrieved from a Map corrupts control flow. See audit.md.")
@test
fn wx_time_int_map_values_sum() {
    let mut budget: Map<Text, WindowsDuration> = Map.new();
    let _ = budget.insert("a", WindowsDuration.from_millis(100_u64));
    let _ = budget.insert("b", WindowsDuration.from_millis(400_u64));

    // Sum the raw nanosecond payloads. NOTE: accumulating via
    // `total = total.add(d)` and then reading `total.as_millis()` trips the
    // single-field-newtype unboxing defect — a `WindowsDuration` produced by
    // the user `add` body is heap-boxed, but the `as_millis` intrinsic expects
    // an unboxed nanos Int, so the accessor mis-reads. We instead sum the
    // payloads directly via `as_nanos()` (which reads `.0`). Defect pinned in
    // regression_test.vr + audit.md.
    let mut total_nanos = 0_u64;
    match budget.get(&"a") {
        Maybe.Some(d) => total_nanos = total_nanos + d.as_nanos(),
        Maybe.None => assert(false, "a present"),
    }
    match budget.get(&"b") {
        Maybe.Some(d) => total_nanos = total_nanos + d.as_nanos(),
        Maybe.None => assert(false, "b present"),
    }
    assert_eq(total_nanos, 500_000_000_u64);
}

// =============================================================================
// Integration 6 — WindowsDeadlineTimer.none().remaining() flows as a Maybe
// =============================================================================

@test
fn wx_time_int_deadline_none_remaining_is_none() {
    // none() takes no QPC path; remaining() must short-circuit to Maybe.None.
    let t = WindowsDeadlineTimer.none();
    let label = match t.remaining() {
        Maybe.Some(_d) => "bounded",
        Maybe.None => "infinite",
    };
    assert_eq(label, "infinite");
}

@test
fn wx_time_int_deadline_none_deadline_is_none() {
    // deadline() likewise returns Maybe.None on the none() path (no QPC).
    let t = WindowsDeadlineTimer.none();
    let has = match t.deadline() {
        Maybe.Some(_i) => true,
        Maybe.None => false,
    };
    assert(!has, "none() must yield no deadline instant");
}

// =============================================================================
// Integration 7 — durations collected from a Maybe-yielding pipeline
// =============================================================================

@test
fn wx_time_int_collect_present_durations() {
    let mut opts: List<Maybe<WindowsDuration>> = List.new();
    opts.push(Maybe.Some(WindowsDuration.from_nanos(10_u64)));
    opts.push(Maybe.None);
    opts.push(Maybe.Some(WindowsDuration.from_nanos(20_u64)));
    opts.push(Maybe.None);
    opts.push(Maybe.Some(WindowsDuration.from_nanos(30_u64)));

    let mut sum = WindowsDuration.zero();
    let mut count = 0_u64;
    let mut i = 0;
    while i < opts.len() {
        match opts[i] {
            Maybe.Some(d) => {
                sum = sum.add(d);
                count = count + 1_u64;
            }
            Maybe.None => {}
        }
        i = i + 1;
    }
    assert_eq(count, 3_u64);
    assert_eq(sum.as_nanos(), 60_u64);
}
