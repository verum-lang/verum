// =============================================================================
// core-tests/sys/windows/time/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.windows.time` — Windows time module providing
// WindowsDuration / WindowsInstant / WindowsStopwatch / WindowsPerfCounter
// types built on QueryPerformanceCounter + GetSystemTimeAsFileTime.
//
// API surface tested:
//
//   Constants: NANOS_PER_SEC / NANOS_PER_MILLI / NANOS_PER_MICRO,
//              MILLIS_PER_SEC / MICROS_PER_SEC,
//              FILETIME_UNITS_PER_SEC / WINDOWS_EPOCH_OFFSET
//   Type:      WindowsDuration — from_nanos/micros/millis/secs/secs_f64,
//              zero, as_nanos/micros/millis/secs/secs_f64,
//              subsec_nanos/millis, is_zero, add/sub/mul/div
//
// The QueryPerformanceCounter-backed paths (WindowsInstant, sleep, etc.)
// cannot be exercised on a non-Windows host — they're deferred.
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.time.{
    NANOS_PER_SEC, NANOS_PER_MILLI, NANOS_PER_MICRO,
    MILLIS_PER_SEC, MICROS_PER_SEC,
    FILETIME_UNITS_PER_SEC, WINDOWS_EPOCH_OFFSET,
    WindowsDuration,
};

// =============================================================================
// Section 1 — Pinned constants
// =============================================================================

@test
fn test_nanos_per_sec_is_one_billion() {
    assert_eq(NANOS_PER_SEC, 1_000_000_000_u64);
}

@test
fn test_nanos_per_milli_is_one_million() {
    assert_eq(NANOS_PER_MILLI, 1_000_000_u64);
}

@test
fn test_nanos_per_micro_is_one_thousand() {
    assert_eq(NANOS_PER_MICRO, 1_000_u64);
}

@test
fn test_millis_per_sec_is_one_thousand() {
    assert_eq(MILLIS_PER_SEC, 1_000_u64);
}

@test
fn test_micros_per_sec_is_one_million() {
    assert_eq(MICROS_PER_SEC, 1_000_000_u64);
}

@test
fn test_filetime_units_per_sec_is_ten_million() {
    // FILETIME counts 100-nanosecond intervals → 10^7 per second.
    assert_eq(FILETIME_UNITS_PER_SEC, 10_000_000_u64);
}

@test
fn test_windows_epoch_offset_is_documented_value() {
    // Number of 100-nanosecond intervals between 1601-01-01 and 1970-01-01.
    // Documented Microsoft value — used to convert between FILETIME and Unix time.
    assert_eq(WINDOWS_EPOCH_OFFSET, 116444736000000000_u64);
}

@test
fn test_nanos_scaling_relations() {
    // NANOS_PER_SEC == NANOS_PER_MILLI * MILLIS_PER_SEC
    assert_eq(NANOS_PER_SEC, NANOS_PER_MILLI * MILLIS_PER_SEC);
    // NANOS_PER_MILLI == NANOS_PER_MICRO * 1000
    assert_eq(NANOS_PER_MILLI, NANOS_PER_MICRO * 1000_u64);
}

// =============================================================================
// Section 2 — WindowsDuration constructors
// =============================================================================

@test
fn test_duration_from_nanos_round_trip() {
    let d = WindowsDuration.from_nanos(42_u64);
    assert_eq(d.as_nanos(), 42_u64);
}

@test
fn test_duration_from_micros_round_trip() {
    let d = WindowsDuration.from_micros(7_u64);
    assert_eq(d.as_nanos(), 7_000_u64);
    assert_eq(d.as_micros(), 7_u64);
}

@test
fn test_duration_from_millis_round_trip() {
    let d = WindowsDuration.from_millis(5_u64);
    assert_eq(d.as_nanos(), 5_000_000_u64);
    assert_eq(d.as_millis(), 5_u64);
}

@test
fn test_duration_from_secs_round_trip() {
    let d = WindowsDuration.from_secs(3_u64);
    assert_eq(d.as_nanos(), 3_000_000_000_u64);
    assert_eq(d.as_secs(), 3_u64);
}

@test
fn test_duration_zero_is_zero() {
    let d = WindowsDuration.zero();
    assert(d.is_zero());
    assert_eq(d.as_nanos(), 0_u64);
}

// =============================================================================
// Section 3 — Subsecond accessors
// =============================================================================

@test
fn test_duration_subsec_nanos_for_whole_second_is_zero() {
    let d = WindowsDuration.from_secs(7_u64);
    assert_eq(d.subsec_nanos(), 0_u32);
}

@test
fn test_duration_subsec_nanos_for_one_and_a_half_seconds() {
    let d = WindowsDuration.from_nanos(1_500_000_000_u64);
    assert_eq(d.subsec_nanos(), 500_000_000_u32);
    assert_eq(d.as_secs(), 1_u64);
}

@test
fn test_duration_subsec_millis_for_one_and_a_half_seconds() {
    let d = WindowsDuration.from_nanos(1_500_000_000_u64);
    assert_eq(d.subsec_millis(), 500_u32);
}

// =============================================================================
// Section 4 — Arithmetic operators
// =============================================================================

@test
fn test_duration_add_combines_nanos() {
    let a = WindowsDuration.from_nanos(100_u64);
    let b = WindowsDuration.from_nanos(50_u64);
    let c = a.add(b);
    assert_eq(c.as_nanos(), 150_u64);
}

@test
fn test_duration_sub_subtracts_nanos() {
    let a = WindowsDuration.from_nanos(100_u64);
    let b = WindowsDuration.from_nanos(30_u64);
    let c = a.sub(b);
    assert_eq(c.as_nanos(), 70_u64);
}

@test
fn test_duration_sub_saturates_at_zero() {
    let a = WindowsDuration.from_nanos(30_u64);
    let b = WindowsDuration.from_nanos(100_u64);
    let c = a.sub(b);
    assert_eq(c.as_nanos(), 0_u64);
}

@test
fn test_duration_mul_scales_nanos() {
    let a = WindowsDuration.from_nanos(7_u64);
    let c = a.mul(11_u64);
    assert_eq(c.as_nanos(), 77_u64);
}

@test
fn test_duration_div_divides_nanos() {
    let a = WindowsDuration.from_nanos(100_u64);
    let c = a.div(4_u64);
    assert_eq(c.as_nanos(), 25_u64);
}

// =============================================================================
// Section 5 — Cross-scale equivalence
// =============================================================================

@test
fn test_duration_one_second_equals_1000_millis() {
    let a = WindowsDuration.from_secs(1_u64);
    let b = WindowsDuration.from_millis(1000_u64);
    assert_eq(a.as_nanos(), b.as_nanos());
}

@test
fn test_duration_one_milli_equals_1000_micros() {
    let a = WindowsDuration.from_millis(1_u64);
    let b = WindowsDuration.from_micros(1000_u64);
    assert_eq(a.as_nanos(), b.as_nanos());
}

@test
fn test_duration_one_micro_equals_1000_nanos() {
    let a = WindowsDuration.from_micros(1_u64);
    let b = WindowsDuration.from_nanos(1000_u64);
    assert_eq(a.as_nanos(), b.as_nanos());
}

// =============================================================================
// Section 6 — is_zero
// =============================================================================

@test
fn test_duration_is_zero_for_zero() {
    let d = WindowsDuration.from_nanos(0_u64);
    assert(d.is_zero());
}

@test
fn test_duration_is_zero_is_false_for_nonzero() {
    let d = WindowsDuration.from_nanos(1_u64);
    assert(!d.is_zero());
}
