// =============================================================================
// core-tests/sys/windows/io/integration_test.vr
// =============================================================================
//
// Cross-stdlib scenarios for `core.sys.windows.io`. Exercises the IOCP
// error ADT + token newtype against List / Maybe / Map without touching
// any IOCP runtime FFI (host-safe).
//
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.io.{
    MAX_EVENTS, DEFAULT_TIMEOUT_MS,
    WindowsIoToken, WindowsIoDriverError,
};

// =============================================================================
// Section 1 — Error variants flowing through a List
// =============================================================================

@test
fn wx_io_int_classify_codes_into_list() {
    let mut codes: List<UInt32> = List.new();
    codes.push(997_u32);    // WouldBlock
    codes.push(5_u32);      // PermissionDenied
    codes.push(10054_u32);  // ConnectionReset
    codes.push(995_u32);    // Cancelled

    let mut errs: List<WindowsIoDriverError> = List.new();
    for c in codes.iter() {
        errs.push(WindowsIoDriverError.from_error_code(*c));
    }
    assert_eq(errs.len(), 4);
    assert_eq(errs[0], WindowsIoDriverError.WouldBlock);
    assert_eq(errs[1], WindowsIoDriverError.PermissionDenied);
    assert_eq(errs[2], WindowsIoDriverError.ConnectionReset);
    assert_eq(errs[3], WindowsIoDriverError.Cancelled);
}

@test
fn wx_io_int_count_retryable_in_list() {
    let mut errs: List<WindowsIoDriverError> = List.new();
    errs.push(WindowsIoDriverError.WouldBlock);
    errs.push(WindowsIoDriverError.Interrupted);
    errs.push(WindowsIoDriverError.TimedOut);
    errs.push(WindowsIoDriverError.Closed);

    let mut retryable = 0;
    for e in errs.iter() {
        if e.is_retryable() {
            retryable = retryable + 1;
        }
    }
    assert_eq(retryable, 2);
}

// =============================================================================
// Section 2 — Error inside Maybe, matched
// =============================================================================

@test
fn wx_io_int_error_in_maybe_some() {
    let m: Maybe<WindowsIoDriverError> =
        Maybe.Some(WindowsIoDriverError.from_error_code(2_u32));
    match m {
        Maybe.Some(e) => assert_eq(e, WindowsIoDriverError.NotFound { path: "" }),
        Maybe.None => assert(false, "expected Some"),
    }
}

@test
fn wx_io_int_error_in_maybe_none() {
    let m: Maybe<WindowsIoDriverError> = Maybe.None;
    let present = match m {
        Maybe.Some(_) => true,
        Maybe.None => false,
    };
    assert(!present);
}

// =============================================================================
// Section 3 — Tokens as Map keys' values
// =============================================================================

@test
fn wx_io_int_tokens_in_map() {
    let mut m: Map<Int, WindowsIoToken> = Map.new();
    m.insert(1, WindowsIoToken(0xAA_u64));
    m.insert(2, WindowsIoToken(0xBB_u64));
    match m.get(&1) {
        Maybe.Some(t) => assert_eq(t.0, 0xAA_u64),
        Maybe.None => assert(false, "key 1 missing"),
    }
    match m.get(&2) {
        Maybe.Some(t) => assert_eq(t.0, 0xBB_u64),
        Maybe.None => assert(false, "key 2 missing"),
    }
}

// =============================================================================
// Section 4 — Constants composed with stdlib arithmetic
// =============================================================================

@test
fn wx_io_int_max_events_bounds_a_batch() {
    // A submission batch is clamped to MAX_EVENTS — model the clamp purely.
    let requested = 1000;
    let granted = if requested > MAX_EVENTS { MAX_EVENTS } else { requested };
    assert_eq(granted, 256);
}

@test
fn wx_io_int_timeout_ms_used_as_u32_arg() {
    // DEFAULT_TIMEOUT_MS is the value handed to GetQueuedCompletionStatusEx;
    // confirm it survives a UInt32 round-trip unchanged.
    let ms: UInt32 = DEFAULT_TIMEOUT_MS;
    assert_eq(ms, 1000_u32);
}
