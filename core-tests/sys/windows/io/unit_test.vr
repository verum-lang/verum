// =============================================================================
// core-tests/sys/windows/io/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.windows.io` — Windows completion-based I/O
// (IOCP) bootstrap module.  Pins the public constants and lightweight
// type-shape surfaces.  The IOCP runtime operations (create_io_driver /
// async_read / async_write / poll) cannot run on a non-Windows host.
//
// =============================================================================

mount core.prelude.*;
mount core.sys.windows.io.{
    MAX_EVENTS, DEFAULT_TIMEOUT_MS, DEFAULT_TIMEOUT_NS,
    WindowsIoToken,
};

// =============================================================================
// Section 1 — Pinned constants
// =============================================================================

@test
fn test_max_events_is_256() {
    // Maximum events processed in a single GetQueuedCompletionStatusEx call.
    assert_eq(MAX_EVENTS, 256);
}

@test
fn test_default_timeout_ms_is_1000() {
    // 1 second default polling timeout.
    assert_eq(DEFAULT_TIMEOUT_MS, 1000_u32);
}

@test
fn test_default_timeout_ns_is_one_billion() {
    // 1 second in nanoseconds — matches DEFAULT_TIMEOUT_MS × 1_000_000.
    assert_eq(DEFAULT_TIMEOUT_NS, 1_000_000_000);
}

@test
fn test_default_timeout_ms_and_ns_agree_at_1s() {
    // Cross-unit invariant — DEFAULT_TIMEOUT_NS / 1_000_000 == DEFAULT_TIMEOUT_MS.
    assert_eq(DEFAULT_TIMEOUT_NS / 1_000_000, DEFAULT_TIMEOUT_MS as Int);
}

// =============================================================================
// Section 2 — WindowsIoToken newtype shape
// =============================================================================

@test
fn test_io_token_construction_round_trip() {
    let t = WindowsIoToken(0xDEAD_BEEF_u64);
    assert_eq(t.0, 0xDEAD_BEEF_u64);
}

@test
fn test_io_token_distinct_constructions_are_inequal() {
    let a = WindowsIoToken(1_u64);
    let b = WindowsIoToken(2_u64);
    assert(a.0 != b.0);
}

@test
fn test_io_token_zero_is_distinct_from_max() {
    let zero = WindowsIoToken(0_u64);
    let max = WindowsIoToken(0xFFFFFFFFFFFFFFFF_u64);
    assert(zero.0 != max.0);
}
