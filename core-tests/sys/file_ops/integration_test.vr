// =============================================================================
// core-tests/sys/file_ops/integration_test.vr
// =============================================================================
//
// Cross-stdlib integration tests for `core.sys.file_ops` — pairing the
// raw FFI surface with `Maybe`, `Text`, and `List` so the patterns user
// code reaches for are pinned end-to-end.  Includes happy-path
// write→read round-trips through `/tmp` (POSIX-portable across Linux
// and macOS — both have a world-writable `/tmp` per FHS).
// =============================================================================

mount core.prelude.*;
mount core.sys.file_ops.{
    OpenMode,
    read_file, write_file, append_file,
    file_exists, file_size, delete_file,
};

// =============================================================================
// Section 1: Maybe-shaped read_file vs missing path
// =============================================================================

@test
fn integration_read_file_none_branch_is_taken_for_missing() {
    let path: Text = "/tmp/__verum_integration_read_missing_8273645__";
    let observed: Maybe<Text> = read_file(path);
    let tag: Int = match observed {
        Some(_) => 1,
        None => 0,
    };
    assert_eq(tag, 0);
}

// =============================================================================
// Section 2: Open-mode flag-set distinctness via List
// =============================================================================

@test
fn integration_openmode_flag_set_through_list() {
    // The five OpenMode constructors must produce five distinct
    // flag values — collect them into a List and verify pairwise
    // distinctness in O(N²) without relying on a Set type
    // (which Map/Set has its own coverage gaps for cross-tier).
    let flags: List<Int> = [
        OpenMode.read().flags,
        OpenMode.write().flags,
        OpenMode.read_write().flags,
        OpenMode.append().flags,
        OpenMode.create().flags,
    ];
    let n = flags.len();
    let mut i: Int = 0;
    while i < n {
        let mut j: Int = i + 1;
        while j < n {
            let fi = *flags.get(i as USize);
            let fj = *flags.get(j as USize);
            assert(fi != fj);
            j = j + 1;
        }
        i = i + 1;
    }
}

// =============================================================================
// Section 3: Error-sentinel chaining (file_size + delete + exists)
// =============================================================================

@test
fn integration_error_sentinels_chain_consistently() {
    // For a path that demonstrably doesn't exist, all three
    // introspection APIs must agree it doesn't exist:
    //  * file_exists -> false
    //  * file_size   -> negative
    //  * delete_file -> false (unlink ENOENT)
    let p: Text = "/tmp/__verum_integration_chain_consistent_172836__";
    let exists = file_exists(p);
    let sz = file_size(p);
    let deleted = delete_file(p);
    assert_eq(exists, false);
    assert(sz < 0);
    assert_eq(deleted, false);
}

// =============================================================================
// Section 4: Happy-path write → read round-trip via /tmp fixtures
//
// POSIX FHS guarantees `/tmp` is world-writable.  The interpreter's
// real-file-IO implementation (`state.open_files` table backed by
// `std::fs`) writes via `__file_write_string_raw` and reads via
// `__file_read_to_string_raw`.  Cleanup on every code path.
// =============================================================================

@test
fn integration_write_read_round_trip_ascii() {
    let path: Text = "/tmp/__verum_test_write_read_ascii_19271837__";
    let content: Text = "hello verum";
    // Pre-clean so a stale prior run doesn't false-pass.
    let _ = delete_file(path);
    let wrote = write_file(path, content);
    assert(wrote);
    let read_back = read_file(path);
    let observed = match read_back {
        Some(s) => s,
        None => panic("write succeeded but read returned None"),
    };
    assert_eq(observed, content);
    let _ = delete_file(path);
}

@test
fn integration_write_read_round_trip_empty() {
    let path: Text = "/tmp/__verum_test_write_read_empty_293847_19__";
    let _ = delete_file(path);
    let wrote = write_file(path, "");
    assert(wrote);
    // After empty write, the file exists with 0 bytes — file_exists
    // reports true.
    assert(file_exists(path));
    let _ = delete_file(path);
}

@test
fn integration_append_extends_existing_content() {
    // `append_file` post-fix opens with O_APPEND and writes via the
    // fd-based `__file_write_text_raw` (NOT the path-based truncating
    // `__file_write_string_raw`).  Two successive appends should
    // concatenate, not clobber.
    let path: Text = "/tmp/__verum_test_append_extends_92837_44__";
    let _ = delete_file(path);
    let _ = write_file(path, "abc");
    let appended_once = append_file(path, "def");
    assert(appended_once);
    let appended_twice = append_file(path, "ghi");
    assert(appended_twice);
    let observed = match read_file(path) {
        Some(s) => s,
        None => panic("read after append returned None"),
    };
    assert_eq(observed, "abcdefghi");
    let _ = delete_file(path);
}

@test
fn integration_file_size_after_write_equals_byte_length() {
    let path: Text = "/tmp/__verum_test_size_after_write_18273_99__";
    let _ = delete_file(path);
    let _ = write_file(path, "0123456789");
    let sz = file_size(path);
    assert_eq(sz, 10);
    let _ = delete_file(path);
}

@test
fn integration_delete_removes_file() {
    let path: Text = "/tmp/__verum_test_delete_removes_29384_22__";
    let _ = delete_file(path);
    let _ = write_file(path, "x");
    assert(file_exists(path));
    let ok = delete_file(path);
    assert(ok);
    assert_eq(file_exists(path), false);
}

fn main() {}
