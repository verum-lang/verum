// =============================================================================
// core-tests/sys/file_ops/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.file_ops` — POSIX-shaped file primitives
// sitting directly on top of the raw FFI surface
// (`__file_open_raw` / `__file_read_to_string_raw` / `__file_write_string_raw`
// / `__file_close_raw` / `__file_size_raw` / `__file_delete_raw`).
//
// API surface tested here:
//
//   OpenMode                       — newtype + 5 flag constructors
//   OpenMode.read / write / etc.   — POSIX O_* bit-pattern pins
//   read_file / write_file         — Text round-trip
//   append_file                    — additive write
//   file_exists                    — open + close probe
//   file_size                      — byte-length introspection
//   delete_file                    — unlink + idempotent NA on missing
//
// Companion files:
//   property_test.vr     — algebraic laws (flag bit invariants etc.)
//   integration_test.vr  — cross-stdlib (Maybe, Text round-trip)
//   regression_test.vr   — pinned compiler-side defects
//   audit.md             — implementation audit
// =============================================================================

mount core.prelude.*;
mount core.sys.file_ops.{
    OpenMode,
    read_file, write_file, append_file,
    file_exists, file_size, delete_file,
};

// =============================================================================
// Section 1: OpenMode — POSIX O_* bit-pattern pins
// =============================================================================

@test
fn test_openmode_read_flags_zero() {
    // O_RDONLY = 0 (POSIX-canonical).
    let m = OpenMode.read();
    assert_eq(m.flags, 0);
}

@test
fn test_openmode_write_flags_match_create_trunc() {
    // 0x301 = O_WRONLY (1) | O_CREAT (0x40 on Linux) | O_TRUNC (0x200).
    // The exact mask is what file_ops.vr advertises.
    let m = OpenMode.write();
    assert_eq(m.flags, 0x301);
}

@test
fn test_openmode_read_write_flags_two() {
    // O_RDWR = 2 (POSIX-canonical).
    let m = OpenMode.read_write();
    assert_eq(m.flags, 2);
}

@test
fn test_openmode_append_flags_match_create_append() {
    // 0x409 = O_WRONLY (1) | O_CREAT (0x40) | O_APPEND (0x400).
    let m = OpenMode.append();
    assert_eq(m.flags, 0x409);
}

@test
fn test_openmode_create_flags_match_create_excl() {
    // 0x241 = O_WRONLY (1) | O_CREAT (0x40) | O_EXCL (0x200) — the
    // semantics file_ops.vr is asserting (subject to per-platform
    // O_EXCL bit drift, but pinning the constant here at least
    // catches regressions against the documented mask).
    let m = OpenMode.create();
    assert_eq(m.flags, 0x241);
}

@test
fn test_openmode_modes_are_pairwise_distinct() {
    // Five distinct flag-sets must each carry a different bit pattern.
    let r = OpenMode.read().flags;
    let w = OpenMode.write().flags;
    let rw = OpenMode.read_write().flags;
    let app = OpenMode.append().flags;
    let cre = OpenMode.create().flags;
    assert(r != w);
    assert(r != rw);
    assert(r != app);
    assert(r != cre);
    assert(w != rw);
    assert(w != app);
    assert(w != cre);
    assert(rw != app);
    assert(rw != cre);
    assert(app != cre);
}

// =============================================================================
// Section 2: file_exists — open+close probe
// =============================================================================

@test
fn test_file_exists_returns_false_for_unlikely_path() {
    // A path nobody is going to create gives us a deterministic
    // false-negative pin without needing temp-dir setup.
    let p: Text = "/tmp/__verum_test_does_not_exist_92837465__";
    assert_eq(file_exists(p), false);
}

// =============================================================================
// Section 3: delete_file — unlink semantics
// =============================================================================

@test
fn test_delete_file_returns_false_for_missing_path() {
    // POSIX unlink returns -1 for ENOENT. The wrapper maps `>= 0` to
    // success — a missing path must be reported as `false`.
    let p: Text = "/tmp/__verum_test_delete_missing_19283746__";
    assert_eq(delete_file(p), false);
}

// =============================================================================
// Section 4: file_size — error sentinel
// =============================================================================

@test
fn test_file_size_returns_negative_for_missing_path() {
    // The wrapper returns -1 when the open fails (ENOENT).
    let p: Text = "/tmp/__verum_test_size_missing_182734__";
    let sz = file_size(p);
    assert(sz < 0);
}

// =============================================================================
// Section 5: read_file — None on missing
// =============================================================================

@test
fn test_read_file_returns_none_for_missing_path() {
    // The wrapper falls through to the open-probe when
    // `__file_read_to_string_raw` returns "" — for a truly missing
    // path the open then fails, yielding None.
    let p: Text = "/tmp/__verum_test_read_missing_98273645__";
    let r = read_file(p);
    match r {
        Some(_) => panic("missing path must read to None"),
        None => {}
    }
}

fn main() {}
