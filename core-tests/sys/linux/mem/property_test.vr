// =============================================================================
// core-tests/sys/linux/mem/property_test.vr
// =============================================================================
// Algebraic laws for Linux mem PROT_*/MAP_* constants.
// =============================================================================

mount core.prelude.*;
mount core.sys.linux.mem.{
    PROT_NONE, PROT_READ, PROT_WRITE, PROT_EXEC,
    MAP_SHARED, MAP_PRIVATE, MAP_FIXED, MAP_ANON, MAP_ANONYMOUS,
    MAP_GROWSDOWN, MAP_STACK, MAP_HUGETLB, MAP_LOCKED,
};

// =============================================================================
// Section 1: PROT_* invariants
// =============================================================================

@test
fn law_linux_prot_single_bits_power_of_two() {
    let bits: List<Int> = [PROT_READ, PROT_WRITE, PROT_EXEC];
    for b in bits.iter() {
        let v = *b;
        assert(v != 0);
        assert_eq(v & (v - 1), 0);
    }
}

@test
fn law_linux_prot_pairwise_disjoint() {
    let bits: List<Int> = [PROT_READ, PROT_WRITE, PROT_EXEC];
    let n = bits.len();
    let mut i: USize = 0 as USize;
    while i < n {
        let mut j: USize = i + (1 as USize);
        while j < n {
            let a = *bits.get(i).unwrap();
            let b = *bits.get(j).unwrap();
            assert_eq(a & b, 0);
            j = j + (1 as USize);
        }
        i = i + (1 as USize);
    }
}

@test
fn law_linux_prot_or_three_is_seven() {
    assert_eq(PROT_READ | PROT_WRITE | PROT_EXEC, 7);
}

// =============================================================================
// Section 2: MAP_* alias contract
// =============================================================================

@test
fn law_linux_map_anonymous_alias() {
    assert_eq(MAP_ANONYMOUS, MAP_ANON);
}

@test
fn law_linux_map_shared_private_disjoint() {
    assert_eq(MAP_SHARED & MAP_PRIVATE, 0);
}

// =============================================================================
// Section 3: MAP_* flag distinctness
// =============================================================================

@test
fn law_linux_map_flags_pairwise_distinct() {
    let flags: List<Int> = [
        MAP_SHARED, MAP_PRIVATE, MAP_FIXED, MAP_ANON,
        MAP_GROWSDOWN, MAP_STACK, MAP_HUGETLB, MAP_LOCKED,
    ];
    let n = flags.len();
    let mut i: USize = 0 as USize;
    while i < n {
        let mut j: USize = i + (1 as USize);
        while j < n {
            let a = *flags.get(i).unwrap();
            let b = *flags.get(j).unwrap();
            assert(a != b);
            j = j + (1 as USize);
        }
        i = i + (1 as USize);
    }
}

@test
fn law_linux_map_anon_diverges_from_darwin() {
    // Linux MAP_ANON = 0x20, Darwin MAP_ANON = 0x1000.
    assert_eq(MAP_ANON, 0x20);
    assert(MAP_ANON != 0x1000);
}

fn main() {}
