// =============================================================================
// core-tests/sys/linux/bpf/program/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.linux.bpf.program` — eBPF program loader API.
// Pins ProgramType / AttachType ADT surfaces and the
// ProgramBytecode / ProgramDescriptor / Link record shapes.
//
// The kernel-facing operations (`load_program`, `attach_*`) can only run
// on a Linux host with the BPF subsystem; they're deferred.
//
// =============================================================================

mount core.prelude.*;
mount core.sys.linux.bpf.program.{
    ProgramType, AttachType,
    ProgramBytecode, ProgramDescriptor, Link,
};
mount core.sys.common.FileDesc;

// =============================================================================
// Section 1 — ProgramType variant constructors
// =============================================================================

