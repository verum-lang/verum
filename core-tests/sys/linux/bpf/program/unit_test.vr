// =============================================================================
// Section 3 — ProgramBytecode record shape
// =============================================================================

@test
fn test_program_bytecode_construction_field_round_trip() {
    let mut insns: List<Byte> = List.new();
    // BPF_MOV64_IMM(BPF_REG_0, 0) — minimal "return 0" program
    // followed by BPF_EXIT_INSN. Each instruction is 8 bytes.
    let mut i = 0;
    while i < 16 {
        insns.push(0_u8);
        i = i + 1;
    }
    let bc = ProgramBytecode {
        program_type: ProgramType.Xdp,
        insns: insns,
        license: "GPL".to_text(),
        kernel_version: 0_u32,
        name: "drop_all".to_text(),
    };
    assert(bc.program_type is ProgramType.Xdp);
    assert_eq(bc.insns.len(), 16);
    assert_eq(bc.license, "GPL");
    assert_eq(bc.kernel_version, 0_u32);
    assert_eq(bc.name, "drop_all");
}

@test
fn test_program_bytecode_accepts_dual_license() {
    let insns: List<Byte> = List.new();
    let bc = ProgramBytecode {
        program_type: ProgramType.SocketFilter,
        insns: insns,
        license: "dual BSD/GPL".to_text(),
        kernel_version: 0_u32,
        name: "filter".to_text(),
    };
    assert_eq(bc.license, "dual BSD/GPL");
}

// =============================================================================
// Section 4 — ProgramDescriptor record shape
// =============================================================================

@test
fn test_program_descriptor_construction_field_round_trip() {
    let d = ProgramDescriptor {
        fd: FileDesc(99),
        program_type: ProgramType.Tracepoint,
        name: "syscall_enter".to_text(),
    };
    assert_eq(d.fd.raw(), 99);
    assert(d.program_type is ProgramType.Tracepoint);
    assert_eq(d.name, "syscall_enter");
}

// =============================================================================
// Section 5 — Link record shape (attached program handle)
// =============================================================================

@test
fn test_link_construction_field_round_trip() {
    let link = Link {
        fd: FileDesc(101),
        program_fd: FileDesc(99),
        attach_type: AttachType.XdpDevmap,
    };
    assert_eq(link.fd.raw(), 101);
    assert_eq(link.program_fd.raw(), 99);
    assert(link.attach_type is AttachType.XdpDevmap);
}

@test
fn test_link_distinguishes_link_fd_from_program_fd() {
    let link = Link {
        fd: FileDesc(7),
        program_fd: FileDesc(13),
        attach_type: AttachType.CgroupSockOps,
    };
    assert(link.fd.raw() != link.program_fd.raw());
}
