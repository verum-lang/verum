// =============================================================================
// core-tests/sys/linux/bpf/map/unit_test.vr
// =============================================================================
//
// Unit tests for `core.sys.linux.bpf.map` — eBPF map type ADT + descriptor
// shape.  The kernel-facing CRUD operations (`create_map` / `map_lookup` /
// `map_update` / `map_delete` / `map_iterate`) cannot run on a non-Linux
// host — they require the bpf() syscall.  The ADT + descriptor + config
// surface IS portable and is what we pin here.
//
// API surface tested:
//
//   Type:    MapType ADT — 30 variants (Hash, Array, …, BloomFilter)
//            MapConfig record (map_type / key_size / value_size /
//                              max_entries / name / flags)
//            MapDescriptor record (fd / map_type / key_size / value_size /
//                                   max_entries)
// =============================================================================

mount core.prelude.*;
mount core.sys.linux.bpf.map.{MapType, MapConfig, MapDescriptor};
mount core.sys.common.FileDesc;

// =============================================================================
// Section 1 — MapType variant constructors
// =============================================================================

@test
fn test_map_type_hash_constructs() {
    let t = MapType.Hash;
    assert(t is MapType.Hash);
}

@test
fn test_map_type_array_constructs() {
    let t = MapType.Array;
    assert(t is MapType.Array);
}

@test
fn test_map_type_lpm_trie_constructs() {
    let t = MapType.LpmTrie;
    assert(t is MapType.LpmTrie);
}

@test
fn test_map_type_ring_buf_constructs() {
    let t = MapType.RingBuf;
    assert(t is MapType.RingBuf);
}

@test
fn test_map_type_bloom_filter_constructs() {
    let t = MapType.BloomFilter;
    assert(t is MapType.BloomFilter);
}

@test
fn test_map_type_devmap_constructs() {
    let t = MapType.Devmap;
    assert(t is MapType.Devmap);
}

@test
fn test_map_type_sockmap_constructs() {
    let t = MapType.Sockmap;
    assert(t is MapType.Sockmap);
}

@test
fn test_map_type_xskmap_constructs() {
    let t = MapType.Xskmap;
    assert(t is MapType.Xskmap);
}

@test
fn test_map_type_queue_constructs() {
    let t = MapType.Queue;
    assert(t is MapType.Queue);
}

@test
fn test_map_type_stack_constructs() {
    let t = MapType.Stack;
    assert(t is MapType.Stack);
}

@test
fn test_map_type_perf_event_array_constructs() {
    let t = MapType.PerfEventArray;
    assert(t is MapType.PerfEventArray);
}

@test
fn test_map_type_percpu_hash_constructs() {
    let t = MapType.PercpuHash;
    assert(t is MapType.PercpuHash);
}

@test
fn test_map_type_lru_hash_constructs() {
    let t = MapType.LruHash;
    assert(t is MapType.LruHash);
}

@test
fn test_map_type_array_of_maps_constructs() {
    let t = MapType.ArrayOfMaps;
    assert(t is MapType.ArrayOfMaps);
}

@test
fn test_map_type_hash_of_maps_constructs() {
    let t = MapType.HashOfMaps;
    assert(t is MapType.HashOfMaps);
