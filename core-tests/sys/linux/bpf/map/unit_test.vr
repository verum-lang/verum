// =============================================================================
// Section 2 — MapConfig record construction + field round-trip
// =============================================================================

@test
fn test_map_config_construction_field_round_trip() {
    let cfg = MapConfig {
        map_type: MapType.Hash,
        key_size: 4_u32,
        value_size: 8_u32,
        max_entries: 1024_u32,
        name: "test_map".to_text(),
        flags: 0_u32,
    };
    assert(cfg.map_type is MapType.Hash);
    assert_eq(cfg.key_size, 4_u32);
    assert_eq(cfg.value_size, 8_u32);
    assert_eq(cfg.max_entries, 1024_u32);
    assert_eq(cfg.name, "test_map");
    assert_eq(cfg.flags, 0_u32);
}

@test
fn test_map_config_array_with_large_value_size() {
    let cfg = MapConfig {
        map_type: MapType.Array,
        key_size: 4_u32,      // Array maps always use 4-byte index keys
        value_size: 64_u32,
        max_entries: 256_u32,
        name: "perf_counters".to_text(),
        flags: 0_u32,
    };
    assert(cfg.map_type is MapType.Array);
    assert_eq(cfg.key_size, 4_u32);
    assert_eq(cfg.value_size, 64_u32);
}

@test
fn test_map_config_ring_buf_with_flags() {
    // RingBuf maps use power-of-two max_entries for the ringbuffer size.
    let cfg = MapConfig {
        map_type: MapType.RingBuf,
        key_size: 0_u32,
        value_size: 0_u32,
        max_entries: 4096_u32,
        name: "events".to_text(),
        flags: 0x4_u32,       // BPF_F_MMAPABLE
    };
    assert_eq(cfg.max_entries, 4096_u32);
    assert_eq(cfg.flags, 0x4_u32);
}

// =============================================================================
// Section 3 — MapDescriptor record construction + field round-trip
// =============================================================================

@test
fn test_map_descriptor_construction_field_round_trip() {
    let d = MapDescriptor {
        fd: FileDesc(7),
        map_type: MapType.LpmTrie,
        key_size: 8_u32,
        value_size: 4_u32,
        max_entries: 1_000_000_u32,
    };
    assert_eq(d.fd.raw(), 7);
    assert(d.map_type is MapType.LpmTrie);
    assert_eq(d.key_size, 8_u32);
    assert_eq(d.value_size, 4_u32);
    assert_eq(d.max_entries, 1_000_000_u32);
}

@test
fn test_map_descriptor_preserves_map_type_through_field_access() {
    let d = MapDescriptor {
        fd: FileDesc(0),
        map_type: MapType.Sockmap,
        key_size: 4_u32,
        value_size: 4_u32,
        max_entries: 64_u32,
    };
    match d.map_type {
        MapType.Sockmap => (),
        _ => panic("map_type field drifted through record construction"),
    };
}
