@test
fn test_map_type_inode_storage_constructs() {
    let t = MapType.InodeStorage;
    assert(t is MapType.InodeStorage);
}

@test
fn test_map_type_task_storage_constructs() {
    let t = MapType.TaskStorage;
    assert(t is MapType.TaskStorage);
