// =============================================================================
// core-tests/intrinsics/control/integration_test.vr
// =============================================================================
//
// The branch-hint intrinsics are SEMANTICALLY TRANSPARENT: they may steer the
// optimiser but must never change a program's result. These tests drive them
// through realistic control flow and assert the computation is identical to
// the un-hinted form.
// =============================================================================

mount core.intrinsics.control.{ likely, unlikely, expect, nop };

// =============================================================================
// `likely` as a loop-continue hint
// =============================================================================

@test
fn integration_likely_in_hot_loop_sum() {
    let mut sum: Int = 0;
    let mut i: Int = 0;
    // The loop-continue branch is overwhelmingly taken — the canonical
    // `likely` use site. The sum must still be 0+1+…+99 = 4950.
    while likely(i < 100) {
        sum = sum + i;
        i = i + 1;
    }
    assert_eq(sum, 4950);
}

// =============================================================================
// `expect` as a value hint inside arithmetic
// =============================================================================

// CONTROL-EXPECT-GENERIC-ARITH (#30) FIXED: the value `expect<T>` returns is
// correct (native Int) — the bug was that `let x: Int = expect(...)` DROPPED the
// `Int` annotation in compile_let (canonical primitives parse to dedicated
// `TypeKind` variants, not `TypeKind.Path`, and were not matched), so x was
// recorded with expect's Float-inferred type and `acc + x` mis-dispatched to
// float arithmetic (reinterpreting Int NaN-box bits as an f64 NaN). The
// annotation is now honored, so `acc + x` is integer arithmetic.
@test
fn integration_expect_hint_preserves_arithmetic() {
    let mut acc: Int = 0;
    let mut i: Int = 0;
    while i < 10 {
        // Hint "usually 0", real value i*i — the result must use the value.
        let x: Int = expect(i * i, 0);
        acc = acc + x;
        i = i + 1;
    }
    assert_eq(acc, 285); // 0²+1²+…+9²
}

// CONTROL-EXPECT-GENERIC-ARITH (#30) second half FIXED 2026-07-15: the
// UNANNOTATED form.  infer_expr_type_kind's exponential-family Float
// heuristic used name.starts_with("exp") — "expect" matched, so a bare
// `let v = expect(int, int)` recorded v as Float: `v + 1` dispatched
// BinaryF over int-tagged bits (garbage) and f-strings printed 'NaN'.
// Exact names (exp/exp2/exp10/expm1) replaced the prefix; the
// unannotated binding now types from the honest value.
@test
fn integration_expect_unannotated_binding_stays_integer() {
    let v = expect(41, 41);
    assert_eq(v, 41);
    assert_eq(v + 1, 42);
    let m = expect(10, 10) * expect(4, 4);
    assert_eq(m, 40);
}

// =============================================================================
// `unlikely` as a rare-branch hint
// =============================================================================

@test
fn integration_unlikely_error_branch_still_fires() {
    let mut taken: Int = 0;
    let mut i: Int = 0;
    while i < 50 {
        // The "error" branch is rare but MUST still execute when its
        // condition holds.
        if unlikely(i == 25) {
            taken = taken + 1;
        }
        i = i + 1;
    }
    assert_eq(taken, 1);
}

// =============================================================================
// `nop` interspersed has no observable effect
// =============================================================================

@test
fn integration_nop_does_not_perturb_result() {
    let mut p: Int = 1;
    let mut i: Int = 1;
    while i <= 6 {
        nop();
        p = p * i;
        nop();
        i = i + 1;
    }
    assert_eq(p, 720); // 6!
}

// =============================================================================
// Combined: likely + expect together in one kernel
// =============================================================================

@test
fn integration_combined_hints_count_evens() {
    let mut evens: Int = 0;
    let mut i: Int = 0;
    while likely(i < 64) {
        let is_even: Bool = expect((i % 2) == 0, true);
        if is_even {
            evens = evens + 1;
        }
        i = i + 1;
    }
    assert_eq(evens, 32);
}

fn main() {}
