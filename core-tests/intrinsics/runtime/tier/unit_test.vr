// =============================================================================
// core-tests/intrinsics/runtime/tier/unit_test.vr
// =============================================================================
//
// `core/intrinsics/runtime/tier.vr` — VBC tier management intrinsics.
//
// Surface tested:
//   * is_interpreted() — true exactly on Tier 0
//   * get_tier() — canonical tier code: 0=interp, 1=JIT baseline,
//     2=JIT optimized, 3=AOT
//   * tier_promote(func_id) — promotion hint (side-effect only)
//
// CONTRACT NOTE: the same test source runs under BOTH `verum test --interp`
// and `verum test --aot`, so no test here may assert a specific tier — only
// tier-agnostic invariants and the coherence between the two intrinsics.
// (The original revision asserted `is_interpreted() == true`, which is
// unsatisfiable under --aot; pinned in regression_test.vr.)
// =============================================================================

mount core.intrinsics.runtime.tier.{
    is_interpreted, get_tier, tier_promote,
};

// =============================================================================
// Section 1: get_tier returns a canonical tier code
// =============================================================================

@test
fn test_get_tier_returns_canonical_code() {
    // Under `verum test` only the interpreter (0) and AOT (3) tiers exist;
    // JIT tiers (1, 2) never serve test processes.  Anything else is a
    // corrupted tier report.
    let t = get_tier() as Int;
    assert(t == 0 || t == 3);
}

@test
fn test_get_tier_consistent_across_calls() {
    let a = get_tier();
    let b = get_tier();
    assert_eq(a, b);
}

// =============================================================================
// Section 2: is_interpreted coheres with get_tier
// =============================================================================

@test
fn test_is_interpreted_iff_tier_zero() {
    // is_interpreted() == (get_tier() == 0), on every tier.
    let interp = is_interpreted();
    let tier_is_zero = get_tier() == 0 as UInt8;
    assert_eq(interp, tier_is_zero);
}

@test
fn test_is_interpreted_consistent_across_calls() {
    assert_eq(is_interpreted(), is_interpreted());
}

// =============================================================================
// Section 3: tier_promote is a safe no-fail hint
// =============================================================================

@test
fn test_tier_promote_accepts_hint_without_fault() {
    // Promotion is advisory; an unknown function id must be ignored, not
    // fault.  (Observable promotion effects are exercised at the
    // language-level integration suite, not here.)
    tier_promote(0 as UInt32);
    assert(true);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
