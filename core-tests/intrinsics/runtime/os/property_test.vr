// =============================================================================
// core-tests/intrinsics/runtime/os/property_test.vr
// =============================================================================
//
// Laws for the kernel-boundary file-I/O intrinsics of
// `core/intrinsics/runtime/os.vr`.
//
// Sampling rationale: contents cover the byte-level boundary cases — empty,
// single byte, multi-byte UTF-8 (size is BYTES, not chars), newlines, and a
// repeated block (buffer-boundary sweep).  Every test uses a unique /tmp
// path and deletes it — file I/O is process-global; hygiene is contract.
// =============================================================================

mount core.prelude.*;
mount core.intrinsics.runtime.os.{
    __file_write_string_raw, __file_read_to_string_raw, __file_delete_raw,
    __file_open_raw, __file_close_raw, __file_size_raw, __file_seek_raw,
};

fn contents_domain() -> List<Text> {
    ["x",
     "hello verum",
     "line1\nline2\n",
     "мир",
     "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"]
}

// =============================================================================
// Section 1: write → read round-trip identity over the content domain
// =============================================================================

@test
fn law_write_read_identity_over_domain() {
    let mut i = 0;
    for c in contents_domain().iter() {
        let path = f"/tmp/verum_os_prop_rt_{i}.txt";
        let w = __file_write_string_raw(path, *c);
        assert(w >= 0);
        assert_eq(__file_read_to_string_raw(path), *c);
        __file_delete_raw(path);
        i = i + 1;
    }
}

@test
fn law_rewrite_is_idempotent_last_write_wins() {
    let path = "/tmp/verum_os_prop_lww.txt";
    for c in contents_domain().iter() {
        __file_write_string_raw(path, *c);
        assert_eq(__file_read_to_string_raw(path), *c);
    }
    __file_delete_raw(path);
}

// =============================================================================
// Section 2: size reports BYTES (UTF-8 aware sampling)
// =============================================================================

@test
fn law_size_counts_bytes_not_chars() {
    // "мир" is 3 chars / 6 UTF-8 bytes — the honest size is 6.
    let path = "/tmp/verum_os_prop_size_utf8.txt";
    __file_write_string_raw(path, "мир");
    let fd = __file_open_raw(path, 0, 0);
    assert(fd >= 0);
    assert_eq(__file_size_raw(fd), 6);
    __file_close_raw(fd);
    __file_delete_raw(path);
}

@test
fn law_size_zero_for_empty() {
    let path = "/tmp/verum_os_prop_size_zero.txt";
    __file_write_string_raw(path, "");
    let fd = __file_open_raw(path, 0, 0);
    assert(fd >= 0);
    assert_eq(__file_size_raw(fd), 0);
    __file_close_raw(fd);
    __file_delete_raw(path);
}

// =============================================================================
// Section 3: seek algebra (whence 0=SET / 1=CUR / 2=END)
// =============================================================================

@test
fn law_seek_set_returns_target_and_cur_zero_reads_it_back() {
    let path = "/tmp/verum_os_prop_seek1.txt";
    __file_write_string_raw(path, "0123456789");
    let fd = __file_open_raw(path, 0, 0);
    assert(fd >= 0);
    assert_eq(__file_seek_raw(fd, 4, 0), 4);
    assert_eq(__file_seek_raw(fd, 0, 1), 4);
    __file_close_raw(fd);
    __file_delete_raw(path);
}

@test
fn law_seek_end_zero_equals_size() {
    let path = "/tmp/verum_os_prop_seek2.txt";
    __file_write_string_raw(path, "0123456789");
    let fd = __file_open_raw(path, 0, 0);
    assert(fd >= 0);
    let end = __file_seek_raw(fd, 0, 2);
    assert_eq(end, __file_size_raw(fd));
    __file_close_raw(fd);
    __file_delete_raw(path);
}

@test
fn law_seek_set_zero_rewinds() {
    let path = "/tmp/verum_os_prop_seek3.txt";
    __file_write_string_raw(path, "abcdef");
    let fd = __file_open_raw(path, 0, 0);
    assert(fd >= 0);
    let _ = __file_seek_raw(fd, 0, 2);
    assert_eq(__file_seek_raw(fd, 0, 0), 0);
    assert_eq(__file_seek_raw(fd, 0, 1), 0);
    __file_close_raw(fd);
    __file_delete_raw(path);
}

// =============================================================================
// Section 4: lifecycle laws — delete makes open fail; close makes fd stale
// =============================================================================

@test
fn law_open_after_delete_fails() {
    let path = "/tmp/verum_os_prop_del.txt";
    __file_write_string_raw(path, "gone soon");
    assert_eq(__file_delete_raw(path), 0);
    let fd = __file_open_raw(path, 0, 0);
    assert(fd < 0);
}

@test
fn law_delete_missing_reports_error() {
    // Deleting a never-created path must report an error, not success.
    assert(__file_delete_raw("/tmp/verum_os_prop_never_created_xyz.txt") < 0);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
