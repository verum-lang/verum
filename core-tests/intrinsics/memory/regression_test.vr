// =============================================================================
// core-tests/intrinsics/memory/regression_test.vr
// =============================================================================
//
// Pinned regressions for `core/intrinsics/memory.vr` (value-level subset).
// CLOSED defects are PASS-GUARDs; the raw-pointer surface that needs a live
// allocation to test is tracked in `audit.md` §3 (MEM-RAWPTR-HARNESS-1), not
// pinned here (an `@ignore` body would still need a fabricated pointer).
// =============================================================================

mount core.prelude.*;
mount core.intrinsics.runtime.cbgr.{cbgr_allocate, cbgr_deallocate};
mount core.intrinsics.runtime.mem_raw.{load_byte, store_byte};
mount core.intrinsics.memory.{
    null_ptr, null_ptr_mut, ptr_is_null, swap, replace, transmute,
    memset, memcpy, memcmp, ptr_to_ref, ptr_to_mut_ref,
    ptr_read, ptr_write, slice_len, ptr_is_aligned_to,
};

// MEM-NULLPTR-1: null_ptr / ptr_is_null returned nil.  The registry strategies
// were `DirectOpcode(LoadI)` (no immediate to load) and `DirectOpcode(EqI)` (a
// binary compare invoked with a single operand), both of which fell through to
// `LoadNil`.  Now `null_ptr` loads 0 and `ptr_is_null` materialises the `0`
// operand for the compare.
@test
fn regression_null_ptr_is_null_was_nil() {
    let p: *const Int = null_ptr();
    assert(ptr_is_null(p));
}

@test
fn regression_null_ptr_mut_is_null_was_nil() {
    let p: *mut Int = null_ptr_mut();
    assert(ptr_is_null(p));
}

// Sanity: the value-level ops that already worked stay working.
@test
fn regression_swap_replace_transmute_still_work() {
    let mut x = 3;
    let mut y = 7;
    swap(&mut x, &mut y);
    assert_eq(x, 7);
    assert_eq(y, 3);
    let old = replace(&mut x, 100);
    assert_eq(old, 7);
    assert_eq(x, 100);
    let t: Int = transmute(255 as UInt64);
    assert_eq(t, 255);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}

// =============================================================================
// MEM-TRANSMUTE-FLOAT-1 (task #13) — OPEN, pinned
// =============================================================================
// interp `transmute<Float, UInt64>` compiles to identity ("transmute is
// identity at the value level in VBC", expressions.rs) — the NaN-boxed Float
// passes through with its Float tag and NO bit reinterpretation happens;
// f-strings render the result as "1.0".  AOT bitcasts correctly → cross-tier
// divergence.  Root: the destination type of the generic is invisible at the
// @intrinsic arm (VBC-GENERIC-INSTANTIATION-1, task #14).  Portable form
// today: `f64_to_bits` / `bits_to_f64` (core.intrinsics.conversion).

@ignore("MEM-TRANSMUTE-FLOAT-1 (task #13) — interp float↔int transmute is identity, no bit reinterpret; blocked on VBC-GENERIC-INSTANTIATION-1 (task #14).")
@test
fn regression_transmute_float_to_bits_reinterprets() {
    let bits: UInt64 = transmute(1.0);
    assert_eq(bits, 4607182418800017408 as UInt64);
}

@ignore("MEM-TRANSMUTE-FLOAT-1 (task #13) — reverse direction of the same defect.")
@test
fn regression_transmute_bits_to_float_reinterprets() {
    let f: Float = transmute(4607182418800017408 as UInt64);
    assert_eq(f, 1.0);
}

// =============================================================================
// MEM-BULK-ADDR-DUAL-1 (2026-07-15) — CLOSED, pass-guards
// =============================================================================
// THREE stacked legs kept the Tier-0 bulk-memory surface inert while AOT
// executed it (cross-tier divergence):
//   1. The handlers (CMemcpy/CMemset/CSecureZero/CMemmove/CMemcmp in
//      handlers/ffi_extended.rs) extracted buffer addresses with bare
//      `Value::as_ptr()` — an INT-TAGGED address (cbgr bridge, `as *mut T`
//      casts) decoded as NULL and the null-guard skipped the op; memcmp
//      ranked garbage (two equal buffers compared -1).  → canonical
//      `value_as_addr` dual extraction (the PtrAdd/atomic pattern).
//   2. The .vr params are `&[mut] Byte` REFERENCES — a real CBGR reg-ref
//      whose REFERENT holds the address; extraction alone read the ref
//      ENCODING.  → `resolve_arg_value` (three-shape unwrap, contract §6)
//      before extraction.
//   3. `ptr_to_mut_ref` was UNREGISTERED entirely (LoadNil) — every
//      memset/memcpy destination was nil.  → registered with ptr_to_ref's
//      Tier-0 identity strategy.

@test
fn regression_memset_writes_through_int_tagged_address() {
    let a = cbgr_allocate(8, 8);
    memset(ptr_to_mut_ref(a as *mut Byte), 66 as Byte, 8 as USize);
    assert_eq(load_byte(a), 66);
    assert_eq(load_byte(a + 7), 66);
    cbgr_deallocate(a);
}

@test
fn regression_memcpy_copies_through_int_tagged_addresses() {
    let src = cbgr_allocate(8, 8);
    let dst = cbgr_allocate(8, 8);
    store_byte(src, 123);
    memcpy(ptr_to_mut_ref(dst as *mut Byte), ptr_to_ref(src as *const Byte), 1 as USize);
    assert_eq(load_byte(dst), 123);
    cbgr_deallocate(src);
    cbgr_deallocate(dst);
}

@test
fn regression_memcmp_compares_contents_not_addresses() {
    let a = cbgr_allocate(8, 8);
    let b = cbgr_allocate(8, 8);
    memset(ptr_to_mut_ref(a as *mut Byte), 7 as Byte, 8 as USize);
    memset(ptr_to_mut_ref(b as *mut Byte), 7 as Byte, 8 as USize);
    // Pre-fix this ranked the two ALLOCATION ADDRESSES (-1); the contents
    // are equal so the honest verdict is 0.
    assert_eq(memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(b as *const Byte), 8 as USize), 0);
    cbgr_deallocate(a);
    cbgr_deallocate(b);
}

// =============================================================================
// MEM-PTR-DEREF-TIER0-1 (task #16, 2026-07-15) — OPEN, pinned
// =============================================================================
// Registry binds ptr_read → DirectOpcode(Deref 0x72) / ptr_write →
// DirectOpcode(DerefMut 0x73).  A raw Int-tagged address is the FOURTH
// reference shape those CBGR handlers never dereference: handle_deref falls
// to the identity fallback (returns the ADDRESS), handle_deref_mut silently
// does nothing.  AOT lowers both correctly → cross-tier kernel incident.
// Fix design: call-site width channel → SystemSubOpcode::DerefRaw/
// DerefRawSigned/DerefMutRaw {size} (task #16).

@ignore("MEM-PTR-DEREF-TIER0-1 (task #16, 2026-07-15) — interp ptr_write no-op / ptr_read identity; AOT correct. Acceptance pin for the width-channel rerouting.")
@test
fn regression_ptr_write_then_read_round_trips() {
    let a = cbgr_allocate(16, 8);
    let p = a as *mut Int;
    ptr_write(p, 424242);
    assert_eq(ptr_read(p as *const Int), 424242);
    cbgr_deallocate(a);
}

// =============================================================================
// MEM-SLICE-INTRINSIC-FATREF-1 (task #17, 2026-07-15) — OPEN, pinned
// =============================================================================
// slice_len/slice_as_ptr emit `Unpack {count: 2}` treating the slice as a
// 2-tuple heap object — but a slice value is ONE FatRef; Unpack misreads the
// FatRef as a Pack-tuple pointer and SIGSEGVs the interpreter.  slice_get/
// subslice/split_at route to `verum_slice_*` library symbols defined nowhere
// (ghost-symbol drift class).

@test
fn regression_slice_len_reads_fatref_not_tuple() {
    let mut xs: List<Int> = [1, 2, 3];
    let s = &xs[..];
    assert_eq(slice_len(s) as Int, 3);
}

// =============================================================================
// MEM-PTR-ALIGN-NIL-1 (task #18, 2026-07-15) — OPEN, pinned
// =============================================================================

@test
fn regression_ptr_is_aligned_to_returns_bool_not_nil() {
    // MEM-PTR-ALIGN-NIL-1 fixed 2026-07-15: ptr_is_aligned_to was
    // UNREGISTERED (LoadNil, same class as MEM-NULLPTR-1); now a real
    // mask-and-compare.  The generic ptr_is_aligned<T> remains on the
    // task #16 width channel.
    let a = cbgr_allocate(16, 8);
    let aligned = ptr_is_aligned_to(a as *const Int, 8 as USize);
    assert(aligned == true);
    cbgr_deallocate(a);
}
