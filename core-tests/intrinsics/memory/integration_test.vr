// =============================================================================
// core-tests/intrinsics/memory/integration_test.vr
// =============================================================================
//
// Cross-module scenarios for `core/intrinsics/memory.vr`: the bulk ops and
// pointer algebra interoperating with the OTHER raw-memory authorities —
// `core.intrinsics.runtime.cbgr` (allocation bridge) and
// `core.intrinsics.runtime.mem_raw` (Int-address ops).  Two independent
// modules observing the same bytes means a silent stub in either one breaks
// the agreement instead of self-confirming.
// =============================================================================

mount core.prelude.*;
mount core.intrinsics.runtime.cbgr.{cbgr_allocate, cbgr_deallocate};
mount core.intrinsics.runtime.mem_raw.{
    load_byte, store_byte, memset as raw_memset, memcmp as raw_memcmp, strlen,
};
mount core.intrinsics.memory.{
    memset, memcpy, memmove, memcmp, ptr_to_ref, ptr_to_mut_ref,
    ptr_add, null_ptr, ptr_is_null,
};

// =============================================================================
// Section 1: typed-ref bulk ops agree with mem_raw Int-address ops
// =============================================================================

@test
fn integration_memset_agrees_with_raw_memset() {
    let a = cbgr_allocate(16, 8);
    let b = cbgr_allocate(16, 8);
    // Same fill through the two independent front doors.
    memset(ptr_to_mut_ref(a as *mut Byte), 42 as Byte, 12);
    raw_memset(b, 42 as Byte, 12);
    assert_eq(memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(b as *const Byte), 12), 0);
    assert_eq(raw_memcmp(a, b, 12), 0);
    cbgr_deallocate(a);
    cbgr_deallocate(b);
}

@test
fn integration_memcpy_result_readable_via_raw_loads() {
    let src = cbgr_allocate(8, 8);
    let dst = cbgr_allocate(8, 8);
    store_byte(src, 11);
    store_byte(src + 1, 22);
    store_byte(src + 2, 33);
    memcpy(ptr_to_mut_ref(dst as *mut Byte), ptr_to_ref(src as *const Byte), 3);
    assert_eq(load_byte(dst), 11);
    assert_eq(load_byte(dst + 1), 22);
    assert_eq(load_byte(dst + 2), 33);
    cbgr_deallocate(src);
    cbgr_deallocate(dst);
}

@test
fn integration_two_module_memcmp_verdicts_agree() {
    let a = cbgr_allocate(8, 8);
    let b = cbgr_allocate(8, 8);
    store_byte(a, 1);
    store_byte(b, 2);
    let typed = memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(b as *const Byte), 1);
    let raw = raw_memcmp(a, b, 1);
    assert(typed < 0);
    assert(raw < 0);
    cbgr_deallocate(a);
    cbgr_deallocate(b);
}

// =============================================================================
// Section 2: building a C string with intrinsics/memory, measuring with
//            mem_raw strlen
// =============================================================================

@test
fn integration_memset_built_cstring_strlen() {
    let a = cbgr_allocate(16, 8);
    // "AAAA\0" — fill four 0x41 bytes through the typed-ref door, keep the
    // NUL from the zero-initialised bridge allocation.
    memset(ptr_to_mut_ref(a as *mut Byte), 65 as Byte, 4);
    assert_eq(strlen(a), 4);
    cbgr_deallocate(a);
}

@test
fn integration_memmove_shifts_cstring_content() {
    let a = cbgr_allocate(16, 8);
    // "XY\0" → shift to offset 1 → "XXY\0" (overlap-safe), strlen 3.
    store_byte(a, 88);      // 'X'
    store_byte(a + 1, 89);  // 'Y'
    memmove(ptr_to_mut_ref((a + 1) as *mut Byte), ptr_to_ref(a as *const Byte), 2);
    assert_eq(load_byte(a), 88);
    assert_eq(load_byte(a + 1), 88);
    assert_eq(load_byte(a + 2), 89);
    assert_eq(strlen(a), 3);
    cbgr_deallocate(a);
}

// =============================================================================
// Section 3: pointer algebra composed with bulk ops
// =============================================================================

@test
fn integration_interior_pointer_memset_after_ptr_add() {
    let a = cbgr_allocate(32, 8);
    // Advance one Value-slot stride (8 bytes today) into the buffer,
    // fill 4 bytes there; head bytes must stay zero.
    let interior = ptr_add(a as *const Byte, 1);
    memset(ptr_to_mut_ref(interior as Int as *mut Byte), 9 as Byte, 4);
    assert_eq(load_byte(a), 0);
    let off = (interior as Int) - a;
    assert_eq(load_byte(a + off), 9);
    assert_eq(load_byte(a + off + 3), 9);
    assert_eq(load_byte(a + off + 4), 0);
    cbgr_deallocate(a);
}

@test
fn integration_null_ptr_distinct_from_live_allocation() {
    let a = cbgr_allocate(8, 8);
    let n: *const Byte = null_ptr();
    assert(ptr_is_null(n));
    assert(!ptr_is_null(a as *const Byte));
    assert((a as *const Byte as Int) != (n as Int));
    cbgr_deallocate(a);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
