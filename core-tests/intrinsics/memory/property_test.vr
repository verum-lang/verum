// =============================================================================
// core-tests/intrinsics/memory/property_test.vr
// =============================================================================
//
// Algebraic laws for `core/intrinsics/memory.vr`.
//
// Domain strategy: the value ops (swap/replace/transmute) are sampled over the
// signed-64 boundary set {0, 1, -1, MAX, MIN, mixed-bit patterns} — the values
// that break two's-complement/NaN-box handling first.  The raw-pointer laws
// run over LIVE allocations from the `cbgr_allocate` bridge (the proven
// mem_raw harness), never fabricated addresses.
//
// Laws that pin the STILL-OPEN width-channel defects are @ignore'd with their
// defect class; they are the acceptance tests for tasks #16/#17/#18 (session
// 2026-07-15) and flip live when the call-site width channel lands.
// =============================================================================

mount core.prelude.*;
mount core.intrinsics.runtime.cbgr.{cbgr_allocate, cbgr_deallocate};
mount core.intrinsics.runtime.mem_raw.{load_byte, store_byte};
mount core.intrinsics.memory.{
    swap, replace, transmute, null_ptr, null_ptr_mut, ptr_is_null, zeroed,
    ptr_offset, ptr_add, ptr_sub,
    ptr_is_aligned, ptr_is_aligned_to,
    memset, memcpy, memmove, memcmp,
    ptr_to_ref, ptr_to_mut_ref,
    ptr_read, ptr_write,
    slice_len, slice_split_at,
};

fn extremes() -> List<Int> {
    // 0, units, alternating-bit patterns, signed extremes.
    [0, 1, -1, 6148914691236517205, -6148914691236517206,
     9223372036854775807, -9223372036854775807 - 1]
}

// =============================================================================
// Section 1: swap — involution, totality over the boundary set
// =============================================================================

@test
fn law_swap_involution_over_extremes() {
    for a in extremes().iter() {
        for b in extremes().iter() {
            let mut x = *a;
            let mut y = *b;
            swap(&mut x, &mut y);
            swap(&mut x, &mut y);
            assert_eq(x, *a);
            assert_eq(y, *b);
        }
    }
}

@test
fn law_swap_exchanges_over_extremes() {
    for a in extremes().iter() {
        for b in extremes().iter() {
            let mut x = *a;
            let mut y = *b;
            swap(&mut x, &mut y);
            assert_eq(x, *b);
            assert_eq(y, *a);
        }
    }
}

// =============================================================================
// Section 2: replace — returns-old law, chain composition
// =============================================================================

@test
fn law_replace_returns_old_over_extremes() {
    for a in extremes().iter() {
        for b in extremes().iter() {
            let mut cell = *a;
            let old = replace(&mut cell, *b);
            assert_eq(old, *a);
            assert_eq(cell, *b);
        }
    }
}

@test
fn law_replace_chain_returns_previous() {
    let mut cell = 10;
    let o1 = replace(&mut cell, 20);
    let o2 = replace(&mut cell, 30);
    let o3 = replace(&mut cell, 40);
    assert_eq(o1, 10);
    assert_eq(o2, 20);
    assert_eq(o3, 30);
    assert_eq(cell, 40);
}

// =============================================================================
// Section 3: transmute — same-width bit-identity round trip
//
//   Int ↔ UInt64 share the 64-bit pattern; transmute must be an involution.
//   (Float↔Int reinterpret is pinned OPEN in regression_test.vr —
//   MEM-TRANSMUTE-FLOAT-1.)
// =============================================================================

@test
fn law_transmute_int_uint_involution_over_extremes() {
    for a in extremes().iter() {
        let u: UInt64 = transmute(*a);
        let back: Int = transmute(u);
        assert_eq(back, *a);
    }
}

// =============================================================================
// Section 4: null-pointer sentinel laws
// =============================================================================

@test
fn law_null_ptr_is_null_for_distinct_pointee_types() {
    let pi: *const Int = null_ptr();
    let pb: *const Byte = null_ptr();
    let pf: *const Float = null_ptr();
    assert(ptr_is_null(pi));
    assert(ptr_is_null(pb));
    assert(ptr_is_null(pf));
}

@test
fn law_null_ptr_mut_matches_const_null() {
    let p: *mut Int = null_ptr_mut();
    assert(ptr_is_null(p));
    assert_eq(p as Int, 0);
}

@test
fn law_live_allocation_is_not_null() {
    let a = cbgr_allocate(16, 8);
    assert(!ptr_is_null(a as *const Byte));
    cbgr_deallocate(a);
}

// =============================================================================
// Section 5: pointer-arithmetic algebra (over a live allocation)
//
//   NOTE ON STRIDE: ptr arithmetic today advances count × 8 (the Value-slot
//   width) for EVERY pointee type; the honest `count × T.size` law is the
//   @ignore'd byte-stride case below (task #16 MEM-PTR-DEREF-TIER0-1).  The
//   algebra laws (inverse / accumulation / monotonicity) are stride-agnostic
//   and run live.
// =============================================================================

@test
fn law_ptr_add_sub_inverse() {
    let a = cbgr_allocate(64, 8);
    let p = a as *const Int;
    let q = ptr_sub(ptr_add(p, 3), 3);
    assert_eq(q as Int, p as Int);
    cbgr_deallocate(a);
}

@test
fn law_ptr_add_accumulates() {
    let a = cbgr_allocate(64, 8);
    let p = a as *const Int;
    let lhs = ptr_add(ptr_add(p, 2), 3);
    let rhs = ptr_add(p, 5);
    assert_eq(lhs as Int, rhs as Int);
    cbgr_deallocate(a);
}

@test
fn law_ptr_offset_agrees_with_add_for_nonnegative() {
    let a = cbgr_allocate(64, 8);
    let p = a as *const Int;
    assert_eq(ptr_offset(p, 2) as Int, ptr_add(p, 2) as Int);
    cbgr_deallocate(a);
}

@test
fn law_ptr_add_is_strictly_monotonic() {
    let a = cbgr_allocate(64, 8);
    let p = a as *const Int;
    assert((ptr_add(p, 1) as Int) > (p as Int));
    assert((ptr_add(p, 2) as Int) > (ptr_add(p, 1) as Int));
    cbgr_deallocate(a);
}

@ignore("MEM-PTR-DEREF-TIER0-1 (task #16, 2026-07-15) — ptr arithmetic is Value-slot-strided (×8) for every T; the declared contract is count × T.size (Byte stride must be 1). Flips live with the call-site width channel.")
@test
fn law_ptr_add_byte_stride_is_one() {
    let a = cbgr_allocate(16, 8);
    let bp = a as *const Byte;
    let d = (ptr_add(bp, 1) as Int) - (bp as Int);
    assert_eq(d, 1);
    cbgr_deallocate(a);
}

// =============================================================================
// Section 6: bulk memory laws over live buffers (MEM-BULK-ADDR-DUAL-1 fixed)
//
//   Observations go through mem_raw `load_byte` — a second, independently
//   verified path to the same bytes, so a silent no-op in either module
//   cannot self-confirm.
// =============================================================================

@test
fn law_memset_fills_exactly_count_bytes() {
    let a = cbgr_allocate(16, 8);
    memset(ptr_to_mut_ref(a as *mut Byte), 170 as Byte, 8);
    let mut i = 0;
    while i < 8 {
        assert_eq(load_byte(a + i), 170);
        i = i + 1;
    }
    // Byte 8 must stay untouched (zero-initialised bridge allocation).
    assert_eq(load_byte(a + 8), 0);
    cbgr_deallocate(a);
}

@test
fn law_memcpy_preserves_source() {
    let src = cbgr_allocate(8, 8);
    let dst = cbgr_allocate(8, 8);
    let mut i = 0;
    while i < 8 {
        store_byte(src + i, 100 + i);
        i = i + 1;
    }
    memcpy(ptr_to_mut_ref(dst as *mut Byte), ptr_to_ref(src as *const Byte), 8);
    let mut j = 0;
    while j < 8 {
        assert_eq(load_byte(src + j), 100 + j);
        assert_eq(load_byte(dst + j), 100 + j);
        j = j + 1;
    }
    cbgr_deallocate(src);
    cbgr_deallocate(dst);
}

@test
fn law_memcmp_reflexive_equal_is_zero() {
    let a = cbgr_allocate(8, 8);
    let b = cbgr_allocate(8, 8);
    memset(ptr_to_mut_ref(a as *mut Byte), 7 as Byte, 8);
    memset(ptr_to_mut_ref(b as *mut Byte), 7 as Byte, 8);
    assert_eq(memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(b as *const Byte), 8), 0);
    // Reflexivity: a buffer equals itself.
    assert_eq(memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(a as *const Byte), 8), 0);
    cbgr_deallocate(a);
    cbgr_deallocate(b);
}

@test
fn law_memcmp_antisymmetric() {
    let a = cbgr_allocate(8, 8);
    let b = cbgr_allocate(8, 8);
    memset(ptr_to_mut_ref(a as *mut Byte), 1 as Byte, 8);
    memset(ptr_to_mut_ref(b as *mut Byte), 2 as Byte, 8);
    let ab = memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(b as *const Byte), 8);
    let ba = memcmp(ptr_to_ref(b as *const Byte), ptr_to_ref(a as *const Byte), 8);
    assert(ab < 0);
    assert(ba > 0);
    cbgr_deallocate(a);
    cbgr_deallocate(b);
}

@test
fn law_memcmp_first_difference_decides() {
    let a = cbgr_allocate(8, 8);
    let b = cbgr_allocate(8, 8);
    // Equal prefix, differing at index 2, then a REVERSED order suffix —
    // memcmp must rank by the FIRST difference only.
    store_byte(a, 5); store_byte(a + 1, 5); store_byte(a + 2, 1); store_byte(a + 3, 200);
    store_byte(b, 5); store_byte(b + 1, 5); store_byte(b + 2, 2); store_byte(b + 3, 0);
    assert(memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(b as *const Byte), 4) < 0);
    cbgr_deallocate(a);
    cbgr_deallocate(b);
}

@test
fn law_memmove_overlapping_shift_right() {
    let a = cbgr_allocate(16, 8);
    store_byte(a, 10); store_byte(a + 1, 20); store_byte(a + 2, 30);
    // Shift [10,20] right by one: overlap-safe copy must yield [10,10,20].
    memmove(ptr_to_mut_ref((a + 1) as *mut Byte), ptr_to_ref(a as *const Byte), 2);
    assert_eq(load_byte(a), 10);
    assert_eq(load_byte(a + 1), 10);
    assert_eq(load_byte(a + 2), 20);
    cbgr_deallocate(a);
}

@test
fn law_memmove_overlapping_shift_left() {
    let a = cbgr_allocate(16, 8);
    store_byte(a, 1); store_byte(a + 1, 2); store_byte(a + 2, 3);
    // Shift [2,3] left by one: [2,3,3].
    memmove(ptr_to_mut_ref(a as *mut Byte), ptr_to_ref((a + 1) as *const Byte), 2);
    assert_eq(load_byte(a), 2);
    assert_eq(load_byte(a + 1), 3);
    assert_eq(load_byte(a + 2), 3);
    cbgr_deallocate(a);
}

@test
fn law_bulk_zero_count_is_noop() {
    let a = cbgr_allocate(8, 8);
    let b = cbgr_allocate(8, 8);
    memset(ptr_to_mut_ref(a as *mut Byte), 9 as Byte, 8);
    memset(ptr_to_mut_ref(b as *mut Byte), 9 as Byte, 8);
    memcpy(ptr_to_mut_ref(a as *mut Byte), ptr_to_ref(b as *const Byte), 0);
    memmove(ptr_to_mut_ref(a as *mut Byte), ptr_to_ref(b as *const Byte), 0);
    memset(ptr_to_mut_ref(a as *mut Byte), 255 as Byte, 0);
    assert_eq(load_byte(a), 9);
    assert_eq(memcmp(ptr_to_ref(a as *const Byte), ptr_to_ref(b as *const Byte), 0), 0);
    cbgr_deallocate(a);
    cbgr_deallocate(b);
}

// =============================================================================
// Section 7: zeroed determinism
// =============================================================================

@test
fn law_zeroed_int_deterministic() {
    let z1: Int = zeroed();
    let z2: Int = zeroed();
    assert_eq(z1, 0);
    assert_eq(z1, z2);
}

// =============================================================================
// Section 8: OPEN width-channel laws — acceptance tests for task #16/#17
// =============================================================================

@ignore("MEM-PTR-DEREF-TIER0-1 (task #16, 2026-07-15) — interp ptr_write is a silent no-op / ptr_read an identity stub (AOT correct: cross-tier kernel incident). Flips live with the DerefRaw width-channel rerouting.")
@test
fn law_ptr_write_read_round_trip_over_extremes() {
    let a = cbgr_allocate(16, 8);
    let p = a as *mut Int;
    for v in extremes().iter() {
        ptr_write(p, *v);
        assert_eq(ptr_read(p as *const Int), *v);
    }
    cbgr_deallocate(a);
}

@test
fn law_alignment_ladder_downward_closed() {
    // MEM-PTR-ALIGN-NIL-1 fixed 2026-07-15: ptr_is_aligned_to =
    // (ptr & (align-1)) == 0.  An 8-aligned bridge allocation satisfies
    // the whole downward ladder.
    let a = cbgr_allocate(16, 8);
    let p = a as *const Int;
    assert(ptr_is_aligned_to(p, 1));
    assert(ptr_is_aligned_to(p, 2));
    assert(ptr_is_aligned_to(p, 4));
    assert(ptr_is_aligned_to(p, 8));
    // An odd address fails every rung above 1.
    let odd = (a + 1) as *const Byte;
    assert(ptr_is_aligned_to(odd, 1));
    assert(!ptr_is_aligned_to(odd, 2));
    assert(!ptr_is_aligned_to(odd, 8));
    cbgr_deallocate(a);
}

@ignore("MEM-PTR-DEREF-TIER0-1 (task #16, 2026-07-15) — generic ptr_is_aligned<T> derives the alignment from T and needs the call-site width channel; ptr_is_aligned_to (explicit alignment) is live above.")
@test
fn law_ptr_is_aligned_generic_matches_explicit() {
    let a = cbgr_allocate(16, 8);
    let p = a as *const Int;
    assert_eq(ptr_is_aligned(p), ptr_is_aligned_to(p, 8));
    cbgr_deallocate(a);
}

@test
fn law_slice_len_matches_source_and_split_partitions() {
    let mut xs: List<Int> = [10, 20, 30, 40, 50];
    let s = &xs[..];
    assert_eq(slice_len(s) as Int, 5);
    let (l, r) = slice_split_at(s, 2);
    assert_eq((slice_len(l) + slice_len(r)) as Int, 5);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
