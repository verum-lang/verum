// =============================================================================
// core-tests/runtime/cbgr/unit_test.vr
// =============================================================================
//
// `core/runtime/cbgr.vr` — the runtime-facing CBGR shim.  Since
// RUNTIME-DUPLICATE-TREE-1 closed, this module is a thin re-export of
// the canonical, WIRED declarations in `core.intrinsics.runtime.cbgr`
// (one source of truth, both tiers).  The deep bridge behaviour
// (alignment sweeps, realloc preservation, extent exactness) is pinned
// at core-tests/intrinsics/runtime/cbgr/ — this suite pins:
//
//   1. RE-EXPORT COHERENCE — every name in the shim's mount list
//      resolves *through* `core.runtime.cbgr` and dispatches to the
//      live intrinsic (not a dead `verum.runtime.*` key returning the
//      default-zero stub — the original §A defect).
//   2. The handful of semantic laws a runtime-level consumer relies
//      on: allocate → non-zero + usable, epoch reads stable within a
//      synchronous scope, invalidate is per-allocation and defensive
//      on bogus input.
//
// HISTORY: the pre-fix suite mounted `cbgr_generation` / `cbgr_epoch`
// — names that never existed in the canonical module — and assumed a
// `cbgr_check(gen, epoch) -> Bool` signature.  The canonical probe is
// `cbgr_check(thin_ref_ptr) -> Int` (single 64-bit compare on a
// ThinRef header).  Tests are written against the REAL contract now.
// =============================================================================

mount core.prelude.*;
mount core.runtime.cbgr.{
    cbgr_validate,
    cbgr_allocate, cbgr_deallocate, cbgr_realloc,
    cbgr_invalidate,
    cbgr_get_epoch, cbgr_current_epoch,
};

// =============================================================================
// Section 1: re-export coherence — allocation bridge through the shim
// =============================================================================

@test
fn test_shim_allocate_nonzero_and_deallocate() {
    // Through `core.runtime.cbgr`, not `core.intrinsics.runtime.cbgr`:
    // a dead re-export would yield the default-zero stub here.
    let p = cbgr_allocate(64, 8);
    assert(p != 0, "core.runtime.cbgr.cbgr_allocate resolved to a dead stub");
    cbgr_deallocate(p);
}

@test
fn test_shim_realloc_resolves() {
    let p = cbgr_allocate(8, 8);
    let q = cbgr_realloc(p, 32);
    assert(q != 0, "core.runtime.cbgr.cbgr_realloc resolved to a dead stub");
    cbgr_deallocate(q);
}

// =============================================================================
// Section 2: cbgr_validate — live-reference probe through the shim
// =============================================================================

@test
fn test_shim_validate_live_local_ref() {
    let x = 42;
    assert(cbgr_validate(&x), "live local ref must validate true");
}

@test
fn test_shim_validate_live_heap_ref() {
    let xs: List<Int> = [1, 2, 3];
    assert(cbgr_validate(&xs), "live heap ref must validate true");
}

// =============================================================================
// Section 3: epoch reads — stability law
// =============================================================================

@test
fn test_epoch_non_negative() {
    assert(cbgr_get_epoch() >= 0);
}

@test
fn test_epoch_stable_across_adjacent_reads() {
    // No epoch mutator runs between the two reads in a synchronous
    // scope — this is the load-bearing invariant for every caller
    // that grabs the epoch, checks, and uses a reference within the
    // same epoch window.
    assert_eq(cbgr_get_epoch(), cbgr_get_epoch());
}

@test
fn test_current_epoch_reads() {
    let e = cbgr_current_epoch();
    assert(e >= 0 as UInt64);
}

// =============================================================================
// Section 4: cbgr_invalidate — per-allocation revocation, defensive edges
// =============================================================================

@test
fn test_invalidate_null_is_noop() {
    // Defence in depth: revoking the null allocation must not crash —
    // a corrupted call site shouldn't take down the runtime.
    unsafe { cbgr_invalidate(0); }
    assert(true);
}

@test
fn test_invalidate_live_allocation_then_free() {
    // Invalidate bumps the allocation's generation (revoking existing
    // ThinRefs); the allocation itself stays owned and must still be
    // freeable without fault.
    let p = cbgr_allocate(16, 8);
    assert(p != 0);
    unsafe { cbgr_invalidate(p); }
    cbgr_deallocate(p);
    assert(true);
}

@test
fn test_invalidate_is_per_allocation() {
    // Revoking allocation A must not disturb allocation B — pins the
    // isolation between allocation headers (a shared-state defect
    // here would poison every sibling reference on any scope exit).
    let a = cbgr_allocate(16, 8);
    let b = cbgr_allocate(16, 8);
    unsafe { cbgr_invalidate(a); }
    // B is untouched: still a live allocation, freeable.
    cbgr_deallocate(b);
    cbgr_deallocate(a);
    assert(true);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
