// =============================================================================
// Section 6: SpawnConfig public alias
// =============================================================================

@ignore  // §F
@test
fn test_spawn_config_alias_resolves_to_supervisor_spawn_config() {
    let a = SupervisorSpawnConfig.new();
    let b: SpawnConfig = a;
    let _ = b;
    assert(true);
}
