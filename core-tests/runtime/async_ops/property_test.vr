// =============================================================================
// core-tests/runtime/async_ops/property_test.vr
// =============================================================================
//
// Laws for `core.runtime.async_ops` data surface. unit_test.vr pins the 13
// opaque-handle newtypes + AsyncRecoveryError construction/eq; this file pins
// the Eq algebra (reflexive/symmetric/payload-sensitive) + record Display/Debug
// + opaque-handle inner-value preservation.
//
// The @intrinsic free fns (spawn_with_env / executor_spawn / ...) are NOT
// exercised here — they require live executor binding (audit §C).
//
// Tests prefixed `ao_law_`.
// =============================================================================

mount core.prelude.*;
mount core.runtime.async_ops.{
    AsyncRecoveryError,
    JoinHandleOpaque, ExecutorHandle, FutureHandle,
};

// =============================================================================
// §A  AsyncRecoveryError.Eq algebra (message-based)
// =============================================================================

@test
fn ao_law_recovery_error_eq_reflexive() {
    let msgs = ["", "boom", "executor shut down", "task panicked: index oob"];
    for &m in msgs.iter() {
        let e = AsyncRecoveryError { message: m };
        assert(e == e);
    }
}

@test
fn ao_law_recovery_error_eq_symmetric() {
    let a = AsyncRecoveryError { message: "same" };
    let b = AsyncRecoveryError { message: "same" };
    assert(a == b);
    assert(b == a);
}

@test
fn ao_law_recovery_error_eq_payload_sensitive() {
    let a = AsyncRecoveryError { message: "alpha" };
    let b = AsyncRecoveryError { message: "beta" };
    assert(!(a == b));
}

@test
fn ao_law_recovery_error_message_roundtrip() {
    let e = AsyncRecoveryError { message: "deadline exceeded" };
    assert_eq(e.message, "deadline exceeded");
}

// =============================================================================
// §B  AsyncRecoveryError Display / Debug (record — has type_id, not subject to
//     the §H nullary-enum Display gap)
// =============================================================================

@test
fn ao_law_recovery_error_display_is_message() {
    let e = AsyncRecoveryError { message: "circuit open" };
    assert_eq(f"{e}", "circuit open");
}

@test
fn ao_law_recovery_error_debug_wraps_message() {
    let e = AsyncRecoveryError { message: "x" };
    assert_eq(f"{e:?}", "AsyncRecoveryError { message: x }");
}

// =============================================================================
// §C  Opaque-handle newtypes — inner-value extraction (audit §D)
//
// These `type X is (Int)` opaque handles are RUNTIME-TRANSPARENT (audit §A:
// distinctness is typechecker-only). Extracting the inner Int via
// `match h { X(v) => v }` does NOT round-trip under --interp — the same
// `__newtype_inner_*` transparent-wrapper access gap seen in sys/common
// FileDesc. By design these are opaque tokens handed to intrinsics, not
// inspected; the failing extraction is pinned @ignore as a language-level
// finding (audit §D), not a usage the module promises.
// =============================================================================

@ignore  // audit §D — transparent opaque-newtype inner extraction gap
@test
fn ao_law_join_handle_inner_value() {
    let h = JoinHandleOpaque(42);
    // newtype over (Int) — match extracts the inner value
    let inner = match h { JoinHandleOpaque(v) => v };
    assert_eq(inner, 42);
}

@ignore  // audit §D — transparent opaque-newtype inner extraction gap
@test
fn ao_law_executor_handle_inner_value() {
    let h = ExecutorHandle(7);
    let inner = match h { ExecutorHandle(v) => v };
    assert_eq(inner, 7);
}

@ignore  // audit §D — transparent opaque-newtype inner extraction gap
@test
fn ao_law_future_handle_inner_value() {
    let h = FutureHandle(0);
    let inner = match h { FutureHandle(v) => v };
    assert_eq(inner, 0);
}
