fn test_single_thread_executor_opaque_construction() {
    let h: SingleThreadExecutorOpaque = SingleThreadExecutorOpaque(0xBEEF);
    let _ = h;
    assert(true);
}

// =============================================================================
// Section 2: 13-way distinctness — opaque newtypes don't accidentally alias
// =============================================================================
//
// Pin that each opaque type is its OWN type — the type system rejects
// cross-handle assignment.  This is the load-bearing invariant that
// keeps `spawn_with_env(env: ExecutionEnvOpaque, ...)` from silently
// accepting an `AllocHandle`.
//
// The test compiles only if all 13 types are distinct.  Type confusion
// here would surface as a compile error (caught at first build), so
// runtime checks are unnecessary.
//

@test
fn test_opaque_handles_are_distinct_types() {
    // Each newtype wraps an Int but is a distinct type at the type-
    // checker level.  This test compiles iff the typechecker keeps
    // them apart — that's the test.
    let a: JoinHandleOpaque = JoinHandleOpaque(1);
    let b: ExecutorHandle = ExecutorHandle(1);
    let c: FutureHandle = FutureHandle(1);
    let d: SupervisorHandleOpaque = SupervisorHandleOpaque(1);
    let e: ChildSpecOpaque = ChildSpecOpaque(1);
    let f: ExecutionEnvOpaque = ExecutionEnvOpaque(1);
    let g: RecoveryContextOpaque = RecoveryContextOpaque(1);
    let h: CircuitBreakerOpaque = CircuitBreakerOpaque(1);
    let i: AllocHandle = AllocHandle(1);
    let j: IODriverHandle = IODriverHandle(1);
    let k: SharedRegistryOpaque = SharedRegistryOpaque(1);
    let l: MiddlewareChainOpaque = MiddlewareChainOpaque(1);
    let m: SingleThreadExecutorOpaque = SingleThreadExecutorOpaque(1);
    let _ = a; let _ = b; let _ = c; let _ = d;
    let _ = e; let _ = f; let _ = g; let _ = h;
    let _ = i; let _ = j; let _ = k; let _ = l;
    let _ = m;
    assert(true);
}

// =============================================================================
// Section 3: AsyncRecoveryError — record + Display + Debug + Eq
// =============================================================================

@test
fn test_async_recovery_error_construction() {
    let e = AsyncRecoveryError { message: "circuit-open" };
    assert(e.message == "circuit-open");
}

@test
fn test_async_recovery_error_eq_same_message() {
    let a = AsyncRecoveryError { message: "timeout" };
    let b = AsyncRecoveryError { message: "timeout" };
    assert(a == b, "AsyncRecoveryError Eq reflexive on same message");
}

@test
fn test_async_recovery_error_eq_different_message() {
    let a = AsyncRecoveryError { message: "timeout" };
    let b = AsyncRecoveryError { message: "cancelled" };
    assert(!(a == b), "AsyncRecoveryError Eq distinguishes messages");
}

@test
fn test_async_recovery_error_eq_empty_message() {
    let a = AsyncRecoveryError { message: "" };
    let b = AsyncRecoveryError { message: "" };
    assert(a == b, "empty-message AsyncRecoveryError Eq reflexive");
}

@test
fn test_async_recovery_error_clone_preserves_message() {
    // Record-field copy via re-construction.  Clone protocol on this
    // type is auto-derived (single Text field).
    let a = AsyncRecoveryError { message: "kernel-oom" };
    let b = AsyncRecoveryError { message: a.message };
    assert(a == b, "construction copy preserves message");
}
