// =============================================================================
// core-tests/runtime/async_ops/unit_test.vr
// =============================================================================
//
// `core/runtime/async_ops.vr` (136 LOC) — opaque-handle ADTs +
// AsyncRecoveryError + intrinsic forward-declarations for the async-runtime
// surface (spawn / executor / future / supervisor / recovery / allocator
// / IO driver / shared registry / middleware chain / single-thread
// executor / sleep_*).
//
// Strategy: this folder pins the **data-only subset** —
//   * the 13 opaque-handle newtypes (JoinHandleOpaque, ExecutorHandle,
//     FutureHandle, SupervisorHandleOpaque, ChildSpecOpaque,
//     ExecutionEnvOpaque, RecoveryContextOpaque, CircuitBreakerOpaque,
//     AllocHandle, IODriverHandle, SharedRegistryOpaque,
//     MiddlewareChainOpaque, SingleThreadExecutorOpaque)
//   * the AsyncRecoveryError record + Display + Debug + Eq impls
//
// The live intrinsics (spawn_with_env / executor_spawn / future_poll_sync /
// async_sleep_*) require a running executor + spawn surface support
// under --interp.  Spawn is gated on task #28 / task #7 (AOT stdlib
// build); live async tests live at vcs/specs/L2-standard/async/.
// =============================================================================

mount core.runtime.async_ops.{
    JoinHandleOpaque, ExecutorHandle, FutureHandle, SupervisorHandleOpaque,
    ChildSpecOpaque, ExecutionEnvOpaque, RecoveryContextOpaque,
    CircuitBreakerOpaque, AllocHandle, IODriverHandle, SharedRegistryOpaque,
    MiddlewareChainOpaque, SingleThreadExecutorOpaque,
    AsyncRecoveryError,
};

// =============================================================================
// Section 1: Opaque handles — newtype construction + payload-extract
// =============================================================================

@test
fn test_join_handle_opaque_construction() {
    let h: JoinHandleOpaque = JoinHandleOpaque(42);
    let _ = h;
    assert(true);
}

@test
fn test_executor_handle_construction() {
    let h: ExecutorHandle = ExecutorHandle(1);
    let _ = h;
    assert(true);
}

