// =============================================================================
// core-tests/runtime/pool/regression_test.vr
// =============================================================================
//
// One test per past defect.  Never deleted.
// =============================================================================

mount core.runtime.pool.{ThreadPool, PoolTaskHandle};

// Top-level task functions — submitted BY VALUE into the pool.
fn pool_double(x: Int) -> Int { x * 2 }
fn pool_add_ten(x: Int) -> Int { x + 10 }
fn pool_identity(x: Int) -> Int { x }

// REGRESSION: POOL-INTERP-STUB-1 (2026-07-14).  The Tier-0 handlers for
// `__pool_submit_raw` / `__pool_await_raw` / `__pool_global_submit_raw`
// returned constant 0 WITHOUT calling the submitted function —
// `pool.submit(f, x).await()` was a silent constant-zero for every f/x,
// while Tier-1 ran the real native pool (`verum_pool_*`).  Silent-wrong
// + cross-tier divergence.  Fixed by eager synchronous execution via
// `call_function_sync` + a slot-recycling result table
// (`crates/verum_vbc/src/interpreter/task_pool.rs`).
@test
fn regression_pool_submit_await_returns_computed_value() {
    let pool = ThreadPool.new(2);
    let mut h = pool.submit(pool_double, 21);
    let result = h.await();
    assert_eq(result, 42, "submit(double, 21).await() must be 42 — 0 means the task never ran");
}

@test
fn regression_pool_submit_await_not_constant_zero() {
    // Two DIFFERENT tasks must produce two DIFFERENT results — pins
    // against any constant-return stub, whatever the constant.
    let pool = ThreadPool.new(2);
    let mut h1 = pool.submit(pool_double, 100);
    let mut h2 = pool.submit(pool_add_ten, 100);
    let r1 = h1.await();
    let r2 = h2.await();
    assert_eq(r1, 200);
    assert_eq(r2, 110);
    assert(r1 != r2, "distinct tasks collapsed to one value — stub regression");
}

@test
fn regression_pool_await_order_independent_of_submit_order() {
    // Await in reverse submission order — the result table must key by
    // handle, not by a single last-result cell.
    let pool = ThreadPool.new(2);
    let mut h1 = pool.submit(pool_identity, 111);
    let mut h2 = pool.submit(pool_identity, 222);
    let r2 = h2.await();
    let r1 = h1.await();
    assert_eq(r1, 111, "handle 1 must keep ITS result after handle 2 was drained");
    assert_eq(r2, 222);
}

@test
fn regression_pool_global_submit_computes() {
    let mut h = ThreadPool.global_submit(pool_add_ten, 32);
    assert_eq(h.await(), 42, "global_submit must run the task too");
}

@test
fn regression_pool_double_await_is_defensive_zero() {
    // Second await on the same handle: the slot was drained; the
    // defensive contract is 0, never a crash or a stale value replay.
    let pool = ThreadPool.new(1);
    let mut h = pool.submit(pool_identity, 7);
    assert_eq(h.await(), 7);
    assert_eq(h.await(), 0, "drained handle must read defensive 0");
}

fn main() {
    // `verum test` synthesises a per-test main.
}
