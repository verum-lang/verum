// =============================================================================
// core-tests/math/bits/unit_test.vr
// =============================================================================
//
// `core/math/bits.vr` — bit-manipulation intrinsics.
//
// Tested entry points:
//   * clz / clz32 — count leading zeros
//   * ctz / ctz32 — count trailing zeros
//   * popcnt / popcnt32 — population count (set-bit count)
//   * highest_bit / lowest_bit
// =============================================================================

mount core.math.bits.{
    clz, clz32, ctz, ctz32, popcnt, popcnt32,
    highest_bit, lowest_bit,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: clz (count leading zeros) — UInt64
// =============================================================================

@test
fn test_clz_msb_set_returns_zero() {
    // 0x8000000000000000 — MSB set, 0 leading zeros.
    assert_eq(clz(0x8000000000000000_u64), 0_u32);
}

@test
fn test_clz_lsb_set_returns_63() {
    // 0x1 — only LSB, 63 leading zeros.
    assert_eq(clz(1_u64), 63_u32);
}

@test
fn test_clz_all_ones_returns_zero() {
    assert_eq(clz(0xFFFFFFFFFFFFFFFF_u64), 0_u32);
}

// =============================================================================
// Section 2: clz32 — UInt32
// =============================================================================

@test
fn test_clz32_msb_set_returns_zero() {
    assert_eq(clz32(0x80000000_u32), 0_u32);
}

@test
fn test_clz32_lsb_set_returns_31() {
    assert_eq(clz32(1_u32), 31_u32);
}

// =============================================================================
// Section 3: ctz (count trailing zeros) — UInt64
// =============================================================================

@test
fn test_ctz_lsb_set_returns_zero() {
    assert_eq(ctz(1_u64), 0_u32);
}

@test
fn test_ctz_msb_set_returns_63() {
    assert_eq(ctz(0x8000000000000000_u64), 63_u32);
}

@test
fn test_ctz_all_ones_returns_zero() {
    assert_eq(ctz(0xFFFFFFFFFFFFFFFF_u64), 0_u32);
}

// =============================================================================
// Section 4: ctz32 — UInt32
// =============================================================================

@test
fn test_ctz32_lsb_set_returns_zero() {
    assert_eq(ctz32(1_u32), 0_u32);
}

@test
fn test_ctz32_msb_set_returns_31() {
    assert_eq(ctz32(0x80000000_u32), 31_u32);
}

// =============================================================================
// Section 5: popcnt (population count)
// =============================================================================

@test
fn test_popcnt_zero_is_zero() {
    assert_eq(popcnt(0_u64), 0_u32);
}

@test
fn test_popcnt_all_ones_is_64() {
    assert_eq(popcnt(0xFFFFFFFFFFFFFFFF_u64), 64_u32);
}

@test
fn test_popcnt_single_bit_is_one() {
    assert_eq(popcnt(1_u64), 1_u32);
}

@test
fn test_popcnt_alternating_bits_is_32() {
    // 0xAAAAAAAAAAAAAAAA = 10101010... — 32 set bits.
    assert_eq(popcnt(0xAAAAAAAAAAAAAAAA_u64), 32_u32);
}

@test
fn test_popcnt_complement_alternating_bits_is_32() {
    // 0x5555555555555555 = 01010101... — also 32 set bits.
    assert_eq(popcnt(0x5555555555555555_u64), 32_u32);
}

// =============================================================================
// Section 6: popcnt32 — UInt32
// =============================================================================

@test
fn test_popcnt32_zero_is_zero() {
    assert_eq(popcnt32(0_u32), 0_u32);
}

@test
fn test_popcnt32_all_ones_is_32() {
    assert_eq(popcnt32(0xFFFFFFFF_u32), 32_u32);
}

@test
fn test_popcnt32_alternating_is_16() {
    assert_eq(popcnt32(0xAAAAAAAA_u32), 16_u32);
}

// =============================================================================
// Section 7: highest_bit / lowest_bit — UInt64 isolators
// =============================================================================

@test
fn test_highest_bit_msb_set_returns_msb() {
    assert_eq(highest_bit(0x8000000000000000_u64), 0x8000000000000000_u64);
}

@test
fn test_highest_bit_lsb_set_returns_lsb() {
    assert_eq(highest_bit(1_u64), 1_u64);
}

@test
fn test_highest_bit_mixed_returns_msb_only() {
    // 0x80000000_00000001 — MSB + LSB; highest_bit isolates MSB.
    assert_eq(highest_bit(0x8000000000000001_u64), 0x8000000000000000_u64);
}

@test
fn test_lowest_bit_lsb_set_returns_lsb() {
    assert_eq(lowest_bit(1_u64), 1_u64);
}

@test
fn test_lowest_bit_mixed_returns_lsb_only() {
    // 0x80000000_00000001 — lowest_bit isolates LSB.
    assert_eq(lowest_bit(0x8000000000000001_u64), 1_u64);
}

@test
fn test_lowest_bit_msb_only_returns_msb() {
    assert_eq(lowest_bit(0x8000000000000000_u64), 0x8000000000000000_u64);
}

fn main() {}
