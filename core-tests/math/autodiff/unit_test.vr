@test
fn test_op_type_mul_variant() {
    let o: OpType = OpType.Mul;
    assert(o is OpType.Mul);
}

@test
fn test_op_type_div_variant() {
    let o: OpType = OpType.Div;
    assert(o is OpType.Div);
}

@test
fn test_op_type_neg_variant() {
    let o: OpType = OpType.Neg;
    assert(o is OpType.Neg);
}

