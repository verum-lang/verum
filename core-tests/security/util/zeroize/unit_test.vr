// =============================================================================
// core-tests/security/util/zeroize/unit_test.vr
// =============================================================================
//
// `core/security/util/zeroize.vr` —
//   * secure_zero(&mut [Byte])     — volatile memset on slice
//   * secure_zero_text(&mut Text)  — zero backing storage of a Text
// =============================================================================

mount core.security.util.zeroize.{secure_zero, secure_zero_text};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: secure_zero on byte slices
// =============================================================================

// @ignore — secure_zero intrinsic does not propagate writes through the
// Tier-0 interpreter dispatch (NEW defect class: `secure_zero` intrinsic
// stub at `verum_vbc/src/intrinsics` accepts pointer + length but does not
// mutate the buffer slice header observed by the caller). Pin LOCK-IN
// after `secure_zero` intrinsic is wired into the interpreter dispatch.
@test
@ignore
fn test_secure_zero_clears_all_bytes() {
    let mut buf: List<Byte> = [];
    buf.push(0x41_u8);
    buf.push(0x42_u8);
    buf.push(0x43_u8);
    secure_zero(&mut buf);
    assert_eq(buf[0], 0_u8);
    assert_eq(buf[1], 0_u8);
    assert_eq(buf[2], 0_u8);
}

@test
fn test_secure_zero_preserves_length() {
    let mut buf: List<Byte> = [];
    buf.push(0x11_u8);
    buf.push(0x22_u8);
    buf.push(0x33_u8);
    buf.push(0x44_u8);
    let n_before = buf.len();
    secure_zero(&mut buf);
    assert_eq(buf.len(), n_before);
    assert_eq(buf.len(), 4);
}

@test
fn test_secure_zero_empty_buffer_is_no_op() {
    let mut buf: List<Byte> = [];
    secure_zero(&mut buf);
    assert_eq(buf.len(), 0);
}

// @ignore — same defect as test_secure_zero_clears_all_bytes.
@test
@ignore
fn test_secure_zero_single_byte() {
    let mut buf: List<Byte> = [];
    buf.push(0xFF_u8);
    secure_zero(&mut buf);
    assert_eq(buf[0], 0_u8);
}

// @ignore — same defect as test_secure_zero_clears_all_bytes.
@test
@ignore
fn test_secure_zero_max_byte() {
    let mut buf: List<Byte> = [];
    buf.push(0xFF_u8);
    buf.push(0xFF_u8);
    secure_zero(&mut buf);
    assert_eq(buf[0], 0_u8);
    assert_eq(buf[1], 0_u8);
}

@test
fn test_secure_zero_already_zero_idempotent() {
    let mut buf: List<Byte> = [];
    buf.push(0_u8);
    buf.push(0_u8);
    secure_zero(&mut buf);
    assert_eq(buf[0], 0_u8);
    assert_eq(buf[1], 0_u8);
}

// =============================================================================
// Section 2: secure_zero_text
// =============================================================================

// @ignore — Text receiver lost to Int kind in `Text.as_mut_bytes` dispatch
// (known Text codegen 8-byte-scalar receiver-shape regression).
@test
@ignore
fn test_secure_zero_text_clears_backing_storage() {
    let mut t: Text = "secret".to_text();
    secure_zero_text(&mut t);
    let bytes = t.as_bytes();
    let mut i = 0;
    while i < bytes.len() {
        assert_eq(bytes[i], 0_u8);
        i = i + 1;
    }
}

// @ignore — same Text.as_mut_bytes regression.
@test
@ignore
fn test_secure_zero_text_preserves_length() {
    let mut t: Text = "abcdefgh".to_text();
    let n_before = t.as_bytes().len();
    secure_zero_text(&mut t);
    assert_eq(t.as_bytes().len(), n_before);
}

// @ignore — same Text.as_mut_bytes regression.
@test
@ignore
fn test_secure_zero_text_empty_no_op() {
    let mut t: Text = "".to_text();
    secure_zero_text(&mut t);
    assert_eq(t.as_bytes().len(), 0);
}

fn main() {}
