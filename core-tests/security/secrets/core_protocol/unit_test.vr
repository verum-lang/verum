// =============================================================================
// core-tests/security/secrets/core_protocol/unit_test.vr
// =============================================================================
//
// `core/security/secrets/core_protocol.vr` — secret-store version ADT.
// =============================================================================

mount core.security.secrets.core_protocol.SecretVersion;
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: SecretVersion 3-variant ADT
// =============================================================================

@test
fn test_secret_version_latest_variant() {
    let v: SecretVersion = SecretVersion.Latest;
    assert(v is SecretVersion.Latest);
}

@test
fn test_secret_version_number_variant() {
    let v: SecretVersion = SecretVersion.Number(42_u64);
    assert(v is SecretVersion.Number);
}

@test
fn test_secret_version_stage_variant() {
    let v: SecretVersion = SecretVersion.Stage("AWSCURRENT".to_text());
    assert(v is SecretVersion.Stage);
}

// =============================================================================
// Section 2: Pairwise disjointness
// =============================================================================

@test
fn test_secret_version_latest_disjoint() {
    let v: SecretVersion = SecretVersion.Latest;
    assert(!(v is SecretVersion.Number));
    assert(!(v is SecretVersion.Stage));
}

@test
fn test_secret_version_number_disjoint() {
    let v: SecretVersion = SecretVersion.Number(1_u64);
    assert(!(v is SecretVersion.Latest));
    assert(!(v is SecretVersion.Stage));
}

@test
fn test_secret_version_stage_disjoint() {
    let v: SecretVersion = SecretVersion.Stage("AWSPREVIOUS".to_text());
    assert(!(v is SecretVersion.Latest));
    assert(!(v is SecretVersion.Number));
}

// =============================================================================
// Section 3: Payload preservation
// =============================================================================

@test
fn test_secret_version_number_payload_round_trip() {
    let v: SecretVersion = SecretVersion.Number(255_u64);
    match v {
        SecretVersion.Number(n) => assert_eq(n, 255_u64),
        _ => panic("expected Number"),
    }
}

@test
fn test_secret_version_stage_payload_round_trip() {
    let v: SecretVersion = SecretVersion.Stage("v2".to_text());
    match v {
        SecretVersion.Stage(s) => assert_eq(s, "v2"),
        _ => panic("expected Stage"),
    }
}

// =============================================================================
// Section 4: Canonical AWS / Vault / GCP version aliases
// =============================================================================

@test
fn test_secret_version_aws_current_stage() {
    let v: SecretVersion = SecretVersion.Stage("AWSCURRENT".to_text());
    match v {
        SecretVersion.Stage(s) => assert_eq(s, "AWSCURRENT"),
        _ => panic("expected Stage"),
    }
}

@test
fn test_secret_version_aws_previous_stage() {
    let v: SecretVersion = SecretVersion.Stage("AWSPREVIOUS".to_text());
    match v {
        SecretVersion.Stage(s) => assert_eq(s, "AWSPREVIOUS"),
        _ => panic("expected Stage"),
    }
}

@test
fn test_secret_version_aws_pending_stage() {
    let v: SecretVersion = SecretVersion.Stage("AWSPENDING".to_text());
    match v {
        SecretVersion.Stage(s) => assert_eq(s, "AWSPENDING"),
        _ => panic("expected Stage"),
    }
}

fn main() {}
