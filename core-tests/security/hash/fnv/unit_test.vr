// =============================================================================
// core-tests/security/hash/fnv/unit_test.vr
// =============================================================================
//
// `core/security/hash/fnv.vr` — Fowler–Noll–Vo non-cryptographic hash
// (32-bit and 64-bit variants).
//
// Pure-data + arithmetic surface tested:
//   * FNV_OFFSET_32 / FNV_PRIME_32 / FNV_OFFSET_64 / FNV_PRIME_64
//   * Fnv1a32 / Fnv1a64 streaming state records
//   * Empty-input → offset basis identity
//
// Note: FNV is a deterministic hash; the offset-basis values are
// reserved by the FNV spec and form the canonical reference point
// for any incremental hash trace.
// =============================================================================

mount core.security.hash.fnv.{
    FNV_OFFSET_32, FNV_PRIME_32, FNV_OFFSET_64, FNV_PRIME_64,
    Fnv1a32, Fnv1a64,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: FNV canonical constants
// =============================================================================

@test
fn test_fnv_offset_32_canonical_value() {
    // FNV-1a 32-bit offset basis (Fowler–Noll–Vo §3)
    assert_eq(FNV_OFFSET_32, 0x811C9DC5_u32);
}

@test
fn test_fnv_prime_32_canonical_value() {
    // FNV-1a 32-bit prime (Fowler–Noll–Vo §3)
    assert_eq(FNV_PRIME_32, 0x01000193_u32);
}

@test
fn test_fnv_offset_64_canonical_value() {
    // FNV-1a 64-bit offset basis (Fowler–Noll–Vo §3)
    assert_eq(FNV_OFFSET_64, 0xCBF29CE484222325_u64);
}

@test
fn test_fnv_prime_64_canonical_value() {
    // FNV-1a 64-bit prime: 2^40 + 2^8 + 0xB3 = 0x100000001B3
    assert_eq(FNV_PRIME_64, 0x100000001B3_u64);
}

// =============================================================================
// Section 2: Fnv1a32 streaming state
//
//   The streaming wrapper starts at FNV_OFFSET_32 and updates by
//   XOR-multiply. After zero updates, .finalize() must return the
//   unmodified offset basis.
// =============================================================================

@test
fn test_fnv1a32_new_initial_state_is_offset_basis() {
    let h: Fnv1a32 = Fnv1a32.new();
    assert_eq(h.finalize(), FNV_OFFSET_32);
}

@test
fn test_fnv1a32_finalize_idempotent_on_empty() {
    let h: Fnv1a32 = Fnv1a32.new();
    assert_eq(h.finalize(), 0x811C9DC5_u32);
}

// =============================================================================
// Section 3: Fnv1a64 streaming state
// =============================================================================

@test
fn test_fnv1a64_new_initial_state_is_offset_basis() {
    let h: Fnv1a64 = Fnv1a64.new();
    assert_eq(h.finalize(), FNV_OFFSET_64);
}

@test
fn test_fnv1a64_finalize_idempotent_on_empty() {
    let h: Fnv1a64 = Fnv1a64.new();
    assert_eq(h.finalize(), 0xCBF29CE484222325_u64);
}

// =============================================================================
// Section 4: State direct construction
//
//   Tests that the public Fnv1a32 / Fnv1a64 record types are
//   directly constructible (useful for test fixtures that seed a
//   non-canonical state).
// =============================================================================

@test
fn test_fnv1a32_direct_construction_preserves_state() {
    let h: Fnv1a32 = Fnv1a32 { state: 0xDEADBEEF_u32 };
    assert_eq(h.finalize(), 0xDEADBEEF_u32);
}

@test
fn test_fnv1a64_direct_construction_preserves_state() {
    let h: Fnv1a64 = Fnv1a64 { state: 0xDEADBEEFCAFEBABE_u64 };
    assert_eq(h.finalize(), 0xDEADBEEFCAFEBABE_u64);
}

// =============================================================================
// Section 5: Constant disjointness
//
//   Offset and prime constants must be pairwise distinct within their
//   bit-width — a same-value constant would collapse the hash to
//   identity transforms.
// =============================================================================

@test
fn test_fnv32_offset_distinct_from_prime() {
    assert(FNV_OFFSET_32 != FNV_PRIME_32);
}

@test
fn test_fnv64_offset_distinct_from_prime() {
    assert(FNV_OFFSET_64 != FNV_PRIME_64);
}

fn main() {}
