// =============================================================================
// core-tests/security/password_hash/unit_test.vr
// =============================================================================
//
// `core/security/password_hash.vr` — password-hashing surface
// (PBKDF2-SHA256 baseline).
// =============================================================================

mount core.security.password_hash.{
    DEFAULT_PBKDF2_ITERATIONS, DEFAULT_SALT_BYTES, DEFAULT_OUTPUT_BYTES,
    MIN_PBKDF2_ITERATIONS, MAX_PBKDF2_ITERATIONS,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: PBKDF2-SHA256 canonical baseline
//
//   OWASP 2025 minimum: 600,000 iterations.
// =============================================================================

@test
fn test_default_pbkdf2_iterations_canonical_value() {
    // OWASP 2025 password-storage cheatsheet: 600,000 SHA-256 iterations.
    assert_eq(DEFAULT_PBKDF2_ITERATIONS, 600_000_u32);
}

@test
fn test_default_salt_bytes_canonical_value() {
    // 128-bit (16-byte) salt — standard recommendation.
    assert_eq(DEFAULT_SALT_BYTES, 16);
}

@test
fn test_default_output_bytes_canonical_value() {
    // 256-bit (32-byte) output — matches SHA-256 digest width.
    assert_eq(DEFAULT_OUTPUT_BYTES, 32);
}

// =============================================================================
// Section 2: Iteration bounds
// =============================================================================

@test
fn test_min_pbkdf2_iterations_canonical_value() {
    // Floor at 100,000 (NIST SP 800-63B minimum).
    assert_eq(MIN_PBKDF2_ITERATIONS, 100_000_u32);
}

@test
fn test_max_pbkdf2_iterations_canonical_value() {
    // Cap at 10M to prevent DoS via huge iteration counts.
    assert_eq(MAX_PBKDF2_ITERATIONS, 10_000_000_u32);
}

@test
fn test_pbkdf2_default_within_bounds() {
    // 600,000 is in [100,000, 10,000,000].
    assert(DEFAULT_PBKDF2_ITERATIONS >= MIN_PBKDF2_ITERATIONS);
    assert(DEFAULT_PBKDF2_ITERATIONS <= MAX_PBKDF2_ITERATIONS);
}

@test
fn test_pbkdf2_min_lt_max() {
    assert(MIN_PBKDF2_ITERATIONS < MAX_PBKDF2_ITERATIONS);
}

// =============================================================================
// Section 3: Width invariants
// =============================================================================

@test
fn test_output_bytes_is_twice_salt_bytes() {
    // 32 == 2 * 16 — output is SHA-256 width, salt is half-width.
    assert_eq(DEFAULT_OUTPUT_BYTES, DEFAULT_SALT_BYTES * 2);
}

@test
fn test_size_constants_positive() {
    assert(DEFAULT_SALT_BYTES > 0);
    assert(DEFAULT_OUTPUT_BYTES > 0);
}

fn main() {}
