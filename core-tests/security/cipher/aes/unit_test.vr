// =============================================================================
// core-tests/security/cipher/aes/unit_test.vr
// =============================================================================
//
// `core/security/cipher/aes.vr` — AES-128 / AES-256 block cipher
// (FIPS 197).
//
// Pure-data constant surface tested:
//   * BLOCK_SIZE
//   * AES128_KEY_SIZE / AES128_NR / AES128_NK / AES128_RK_WORDS
//   * AES256_KEY_SIZE / AES256_NR / AES256_NK
//   * Width invariants
//
// Round-key expansion, encryption, and decryption surfaces deferred
// behind byte-array compile-time class.
// =============================================================================

mount core.security.cipher.aes.{
    BLOCK_SIZE, AES128_KEY_SIZE, AES128_NR, AES128_NK, AES128_RK_WORDS,
    AES256_KEY_SIZE, AES256_NR, AES256_NK,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: AES block size
//
//   AES is a 128-bit (16-byte) block cipher regardless of key size
//   (FIPS 197 §3).
// =============================================================================

@test
fn test_aes_block_size_canonical_value() {
    assert_eq(BLOCK_SIZE, 16);
}

// =============================================================================
// Section 2: AES-128 parameters
//
//   FIPS 197 §6.1 — AES-128 uses a 128-bit (16-byte) key, 10 rounds,
//   and 4 × UInt32 key words, giving 44 round-key words total
//   (4 × 11 = 44).
// =============================================================================

@test
fn test_aes128_key_size_canonical_value() {
    assert_eq(AES128_KEY_SIZE, 16);
}

@test
fn test_aes128_nr_canonical_value() {
    assert_eq(AES128_NR, 10);
}

@test
fn test_aes128_nk_canonical_value() {
    assert_eq(AES128_NK, 4);
}

@test
fn test_aes128_rk_words_canonical_value() {
    // 4 × (10 + 1) = 44.
    assert_eq(AES128_RK_WORDS, 44);
}

@test
fn test_aes128_rk_words_matches_formula() {
    assert_eq(AES128_RK_WORDS, AES128_NK * (AES128_NR + 1));
}

// =============================================================================
// Section 3: AES-256 parameters
//
//   FIPS 197 §6.1 — AES-256 uses a 256-bit (32-byte) key, 14 rounds,
//   and 8 × UInt32 key words.
// =============================================================================

@test
fn test_aes256_key_size_canonical_value() {
    assert_eq(AES256_KEY_SIZE, 32);
}

@test
fn test_aes256_nr_canonical_value() {
    assert_eq(AES256_NR, 14);
}

@test
fn test_aes256_nk_canonical_value() {
    assert_eq(AES256_NK, 8);
}

// =============================================================================
// Section 4: Width invariants
// =============================================================================

@test
fn test_aes128_key_size_equals_block_size() {
    // AES-128's key happens to equal the block size — both 128-bit.
    assert_eq(AES128_KEY_SIZE, BLOCK_SIZE);
}

@test
fn test_aes256_key_size_is_twice_block_size() {
    // AES-256's key is 256-bit = 2 × 128-bit block.
    assert_eq(AES256_KEY_SIZE, BLOCK_SIZE * 2);
}

@test
fn test_aes256_has_more_rounds_than_aes128() {
    // 14 > 10 — AES-256 must have more rounds to resist key-schedule attacks.
    assert(AES256_NR > AES128_NR);
}

@test
fn test_aes256_nk_is_twice_aes128_nk() {
    // 8 = 2 × 4. AES-256 key fills 8 UInt32 words.
    assert_eq(AES256_NK, AES128_NK * 2);
}

@test
fn test_aes_block_is_four_words() {
    // 4 × UInt32 = 16 bytes. The cipher state is a 4×4 byte matrix
    // (FIPS 197 §3.4).
    assert_eq(BLOCK_SIZE, 4 * 4);
}

fn main() {}
