// =============================================================================
// core-tests/concurrency/process/unit_test.vr
// =============================================================================
//
// `core/concurrency/process.vr` — π-calculus process algebra.
//
// Surface:
//   * Process 6-variant (Zero / Par / Restrict / Send / Recv / Replicate)
//   * Smart ctors + substitute + alpha_eq
// =============================================================================

mount core.concurrency.process.{
    Process,
    proc_zero, proc_par, proc_restrict, proc_send, proc_recv, proc_replicate,
    substitute, alpha_eq,
};

// =============================================================================
// Section 1: Process 6-variant construction
// =============================================================================

@test
fn test_proc_zero_construction() {
    let p = proc_zero();
    assert(p is Process.Zero);
}

@test
fn test_proc_par_construction() {
    let p = proc_par(proc_zero(), proc_zero());
    assert(p is Process.Par);
}

@test
fn test_proc_restrict_construction() {
    let p = proc_restrict(Text.from("x"), proc_zero());
    assert(p is Process.Restrict);
}

@test
fn test_proc_send_construction() {
    let p = proc_send(Text.from("x"), Text.from("msg"), proc_zero());
    assert(p is Process.Send);
}

@test
fn test_proc_recv_construction() {
    let p = proc_recv(Text.from("x"), Text.from("y"), proc_zero());
    assert(p is Process.Recv);
}

@test
fn test_proc_replicate_construction() {
    let p = proc_replicate(proc_zero());
    assert(p is Process.Replicate);
}

@test
fn test_proc_variants_pairwise_disjoint() {
    let z = proc_zero();
    let p = proc_par(proc_zero(), proc_zero());
    let r = proc_restrict(Text.from("x"), proc_zero());
    assert(z is Process.Zero && !(z is Process.Par));
    assert(p is Process.Par && !(p is Process.Restrict));
    assert(r is Process.Restrict && !(r is Process.Zero));
}

// =============================================================================
// Section 2: substitute — basic rules
// =============================================================================

@test
fn test_substitute_zero_unchanged() {
    let p = substitute(proc_zero(), Text.from("x"), Text.from("y"));
    assert(p is Process.Zero);
}

@test
fn test_substitute_send_channel() {
    let p = substitute(
        proc_send(Text.from("x"), Text.from("m"), proc_zero()),
        Text.from("x"),
        Text.from("z"),
    );
    assert(p is Process.Send);
}

@test
fn test_substitute_recv_channel() {
    let p = substitute(
        proc_recv(Text.from("x"), Text.from("y"), proc_zero()),
        Text.from("x"),
        Text.from("z"),
    );
    assert(p is Process.Recv);
}

@test
fn test_substitute_restrict_shadows() {
    let inner = proc_send(Text.from("x"), Text.from("m"), proc_zero());
    let p = substitute(
        proc_restrict(Text.from("x"), inner),
        Text.from("x"),
        Text.from("z"),
    );
    assert(p is Process.Restrict);
}

@test
fn test_substitute_par_descends() {
    let p = substitute(
        proc_par(
            proc_send(Text.from("a"), Text.from("m"), proc_zero()),
            proc_recv(Text.from("b"), Text.from("y"), proc_zero()),
        ),
        Text.from("a"),
        Text.from("z"),
    );
    assert(p is Process.Par);
}

@test
fn test_substitute_replicate_descends() {
    let p = substitute(
        proc_replicate(proc_send(Text.from("x"), Text.from("m"), proc_zero())),
        Text.from("x"),
        Text.from("z"),
    );
    assert(p is Process.Replicate);
}

// =============================================================================
// Section 3: alpha_eq — basic cases
// =============================================================================

@test
fn test_alpha_eq_zero_self() {
    assert(alpha_eq(&proc_zero(), &proc_zero()));
}

@test
fn test_alpha_eq_send_same() {
    let p = proc_send(Text.from("x"), Text.from("m"), proc_zero());
    let q = proc_send(Text.from("x"), Text.from("m"), proc_zero());
    assert(alpha_eq(&p, &q));
}

@test
fn test_alpha_eq_send_different_channel() {
    let p = proc_send(Text.from("x"), Text.from("m"), proc_zero());
    let q = proc_send(Text.from("y"), Text.from("m"), proc_zero());
    assert(!alpha_eq(&p, &q));
}

@test
fn test_alpha_eq_restrict_rename_bound() {
    // (νx) x⟨m⟩.0  =α=  (νy) y⟨m⟩.0
    let p = proc_restrict(
        Text.from("x"),
        proc_send(Text.from("x"), Text.from("m"), proc_zero()),
    );
    let q = proc_restrict(
        Text.from("y"),
        proc_send(Text.from("y"), Text.from("m"), proc_zero()),
    );
    assert(alpha_eq(&p, &q));
}

// SURFACED DEFECT: alpha_eq on (νx) free1.0 vs (νy) free2.0 returns
// true when it should return false. The free names `free1` / `free2`
// fall to `(None, None) => a == b` which should yield false but the
// outer Restrict-binder env-extend may be incorrectly treating them
// as bound. Same task #17/#39 root suspected on `name_eq_under_env`
// resolution. Pinned for investigation.
@ignore
@test
fn test_alpha_eq_restrict_different_free_name_distinct() {
    let p = proc_restrict(
        Text.from("x"),
        proc_send(Text.from("free1"), Text.from("m"), proc_zero()),
    );
    let q = proc_restrict(
        Text.from("y"),
        proc_send(Text.from("free2"), Text.from("m"), proc_zero()),
    );
    assert(!alpha_eq(&p, &q));
}

@test
fn test_alpha_eq_recv_rename_binder() {
    // x(y).y⟨m⟩.0  =α=  x(z).z⟨m⟩.0
    let p = proc_recv(
        Text.from("x"),
        Text.from("y"),
        proc_send(Text.from("y"), Text.from("m"), proc_zero()),
    );
    let q = proc_recv(
        Text.from("x"),
        Text.from("z"),
        proc_send(Text.from("z"), Text.from("m"), proc_zero()),
    );
    assert(alpha_eq(&p, &q));
}

@test
fn test_alpha_eq_different_variants_distinct() {
    assert(!alpha_eq(&proc_zero(), &proc_replicate(proc_zero())));
}

@test
fn test_alpha_eq_replicate_recurses() {
    let p = proc_replicate(proc_send(Text.from("x"), Text.from("m"), proc_zero()));
    let q = proc_replicate(proc_send(Text.from("x"), Text.from("m"), proc_zero()));
    assert(alpha_eq(&p, &q));
}
