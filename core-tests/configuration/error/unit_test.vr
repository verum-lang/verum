    assert(c is ConfigErrorCategory.EcClient);
}

@test
fn test_category_upstream_construction() {
    let c: ConfigErrorCategory = ConfigErrorCategory.EcUpstream;
    assert(c is ConfigErrorCategory.EcUpstream);
