// =============================================================================
// Section 4: category() — variant → category routing
// =============================================================================

@test
fn test_category_unexpected_eof_is_client() {
    let k = ConfigErrorKind.UnexpectedEof;
    assert(category(&k) is ConfigErrorCategory.EcClient);
}

@test
fn test_category_duplicate_key_is_client() {
    let k = ConfigErrorKind.DuplicateKey;
    assert(category(&k) is ConfigErrorCategory.EcClient);
}

@test
fn test_category_schema_violation_is_client() {
    let k = ConfigErrorKind.SchemaViolation;
    assert(category(&k) is ConfigErrorCategory.EcClient);
}

@test
fn test_category_depth_limit_is_resource() {
    let k = ConfigErrorKind.DepthLimit;
    assert(category(&k) is ConfigErrorCategory.EcResource);
}

@test
fn test_category_table_too_large_is_resource() {
    let k = ConfigErrorKind.TableTooLarge;
    assert(category(&k) is ConfigErrorCategory.EcResource);
}

@test
fn test_category_lossy_conversion_is_conversion() {
    let k = ConfigErrorKind.LossyConversion;
    assert(category(&k) is ConfigErrorCategory.EcConversion);
}

@test
fn test_category_unsupported_feature_is_conversion() {
    let k = ConfigErrorKind.UnsupportedFeature;
    assert(category(&k) is ConfigErrorCategory.EcConversion);
}

@test
fn test_category_io_file_not_found_is_upstream() {
    let k = ConfigErrorKind.IoFileNotFound;
    assert(category(&k) is ConfigErrorCategory.EcUpstream);
}

@test
fn test_category_io_permission_denied_is_upstream() {
    let k = ConfigErrorKind.IoPermissionDenied;
    assert(category(&k) is ConfigErrorCategory.EcUpstream);
}

@test
fn test_category_io_other_is_upstream() {
    let k = ConfigErrorKind.IoOther;
    assert(category(&k) is ConfigErrorCategory.EcUpstream);
}

// =============================================================================
// Section 5: config_error_kind_name — fixed typo regressions
// =============================================================================
//
// Three typos in pre-fix source (commit 793269375 in branch):
// "UnexpectedCha" / "InvalidNumbe" / "IoOthe". Pin the correct
// canonical names.

@test
fn test_kind_name_unexpected_char_no_typo() {
    let k = ConfigErrorKind.UnexpectedChar;
    assert_eq(config_error_kind_name(&k), "UnexpectedChar");
}

@test
fn test_kind_name_invalid_number_no_typo() {
    let k = ConfigErrorKind.InvalidNumber;
    assert_eq(config_error_kind_name(&k), "InvalidNumber");
}

@test
fn test_kind_name_io_other_no_typo() {
    let k = ConfigErrorKind.IoOther;
    assert_eq(config_error_kind_name(&k), "IoOther");
}

@test
fn test_kind_name_unexpected_eof() {
    let k = ConfigErrorKind.UnexpectedEof;
    assert_eq(config_error_kind_name(&k), "UnexpectedEof");
}

@test
fn test_kind_name_schema_violation() {
    let k = ConfigErrorKind.SchemaViolation;
    assert_eq(config_error_kind_name(&k), "SchemaViolation");
}

// =============================================================================
// Section 6: config_err constructor + with_path
// =============================================================================

@test
fn test_config_err_basic_construction() {
    let e = config_err(
        format_id_toml(),
        ConfigErrorKind.UnexpectedEof,
        10,
        5,
        100,
        "EOF in string".clone(),
    );
    assert_eq(e.line, 10);
    assert_eq(e.column, 5);
    assert_eq(e.byte_offset, 100);
    assert_eq(e.message, "EOF in string");
    assert_eq(e.format_id, "toml");
}

@test
fn test_config_err_default_path_is_none() {
    let e = config_err(
        format_id_yaml(),
        ConfigErrorKind.InvalidIndent,
        1,
        1,
        0,
        "bad indent".clone(),
    );
    match e.path {
        Maybe.Some(_) => panic("expected default path = None"),
        Maybe.None => assert(true),
    }
}

@test
fn test_with_path_attaches_path_string() {
    let base = config_err(
        format_id_jsonc(),
        ConfigErrorKind.UnknownField,
        3,
        9,
        42,
        "unknown".clone(),
    );
    let with_p = with_path(base, "server.host".clone());
    match with_p.path {
        Maybe.Some(p) => assert_eq(p, "server.host"),
        Maybe.None => panic("expected Some(path)"),
    }
}

@test
fn test_with_path_preserves_other_fields() {
    let base = config_err(
        format_id_hcl(),
        ConfigErrorKind.InvalidReference,
        20,
        7,
        200,
        "bad ref".clone(),
    );
    let with_p = with_path(base.clone(), "module.network".clone());
    assert_eq(with_p.format_id, "hcl");
    assert_eq(with_p.line, 20);
    assert_eq(with_p.column, 7);
    assert_eq(with_p.byte_offset, 200);
    assert_eq(with_p.message, "bad ref");
}
