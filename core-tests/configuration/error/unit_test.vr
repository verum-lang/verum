// =============================================================================
// core-tests/configuration/error/unit_test.vr
// =============================================================================
//
// `core/configuration/error.vr` defines:
//   * `FormatId` — refined Text matching `^[a-z][a-z0-9_-]{0,31}$`
//   * `ConfigError` — record with format_id/kind/line/column/byte_offset/
//                     message/path
//   * `ConfigErrorKind` — 32-variant tag
//   * `ConfigErrorCategory` — 5-variant (EcClient / EcUpstream /
//                              EcResource / EcConversion / EcInternal)
//   * `category()` — routes ConfigErrorKind → ConfigErrorCategory
//   * `config_err()` / `with_path()` — constructors
//
// 12 canonical FormatId factories: toml/yaml/jsonc/json5/ini/properties/
// hcl/hocon/nestedtext/kdl/cue/dhall.
// =============================================================================

mount core.configuration.error.{
    FormatId, ConfigError, ConfigErrorKind, ConfigErrorCategory,
    config_err, with_path, category, config_error_kind_name,
    format_id_toml, format_id_yaml, format_id_jsonc, format_id_json5,
    format_id_ini, format_id_properties, format_id_hcl, format_id_hocon,
    format_id_nestedtext, format_id_kdl, format_id_cue, format_id_dhall,
};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: format_id_* canonical IDs
// =============================================================================

@test
fn test_format_id_toml() { assert_eq(format_id_toml(), "toml"); }

@test
fn test_format_id_yaml() { assert_eq(format_id_yaml(), "yaml"); }

@test
fn test_format_id_jsonc() { assert_eq(format_id_jsonc(), "jsonc"); }

@test
fn test_format_id_json5() { assert_eq(format_id_json5(), "json5"); }

@test
fn test_format_id_ini() { assert_eq(format_id_ini(), "ini"); }

@test
fn test_format_id_properties() { assert_eq(format_id_properties(), "properties"); }

@test
fn test_format_id_hcl() { assert_eq(format_id_hcl(), "hcl"); }

@test
fn test_format_id_hocon() { assert_eq(format_id_hocon(), "hocon"); }

@test
fn test_format_id_nestedtext() { assert_eq(format_id_nestedtext(), "nestedtext"); }

@test
fn test_format_id_kdl() { assert_eq(format_id_kdl(), "kdl"); }

@test
fn test_format_id_cue() { assert_eq(format_id_cue(), "cue"); }

@test
fn test_format_id_dhall() { assert_eq(format_id_dhall(), "dhall"); }

