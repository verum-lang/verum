// =============================================================================
// core-tests/money/currency/unit_test.vr
// =============================================================================
//
// Companion files:
//   property_test.vr — eq reflexivity/symmetry, code uniqueness across
//                      predefined currencies, minor-unit consistency.
//   audit.md         — module audit + deferred items.
//
// `Currency` carries ISO 4217 code + minor-unit precision (decimal
// places in the smallest transactable subunit). The `core.money.currency`
// module ships 25 predefined currency factories spanning 0/2/3-minor-unit
// classes. `Currency.eq` is code-only comparison (per ISO contract that
// minor-unit precision is fixed by code).
// =============================================================================

mount core.money.currency.{Currency,
    jpy, krw, vnd, clp, isk,
    usd, eur, gbp, cad, aud, nzd, chf, cny, inr, brl, mxn, zar, sek, nok, dkk,
    bhd, kwd, omr, jod, tnd
};

// =============================================================================
// Section 1: Currency.new constructor
// =============================================================================

@test
fn test_currency_new_preserves_code() {
    let c = Currency.new("USD".clone(), 2);
    assert_eq(c.code, "USD");
}

@test
fn test_currency_new_preserves_minor_units() {
    let c = Currency.new("JPY".clone(), 0);
    assert_eq(c.minor_units, 0);
}

@test
fn test_currency_new_custom_test_currency() {
    let c = Currency.new("XTC".clone(), 4);
    assert_eq(c.code, "XTC");
    assert_eq(c.minor_units, 4);
}

// =============================================================================
// Section 2: Currency.eq — code-only comparison
// =============================================================================

@test
fn test_currency_eq_same_code() {
    let a = Currency.new("USD".clone(), 2);
    let b = Currency.new("USD".clone(), 2);
    assert(a.eq(&b));
}

@test
fn test_currency_eq_differs_on_code() {
    let a = Currency.new("USD".clone(), 2);
    let b = Currency.new("EUR".clone(), 2);
    assert(!a.eq(&b));
}

@test
fn test_currency_eq_ignores_minor_units() {
    // Doc-stated contract: code-only comparison.
    // Two currencies with same code but different minor units
    // SHOULD compare equal (the minor-unit drift would be a bug).
    let a = Currency.new("USD".clone(), 2);
    let b = Currency.new("USD".clone(), 3); // hypothetical inconsistency
    assert(a.eq(&b));
}

// =============================================================================
// Section 3: Zero-minor-unit currencies (no fractional subunit)
// =============================================================================

@test
fn test_jpy_code() {
    assert_eq(jpy().code, "JPY");
}

@test
fn test_jpy_minor_units_zero() {
    assert_eq(jpy().minor_units, 0);
}

@test
fn test_krw_code_and_minor_units() {
    let c = krw();
    assert_eq(c.code, "KRW");
    assert_eq(c.minor_units, 0);
}

@test
fn test_vnd_code_and_minor_units() {
    let c = vnd();
    assert_eq(c.code, "VND");
    assert_eq(c.minor_units, 0);
}

@test
fn test_clp_code_and_minor_units() {
    let c = clp();
    assert_eq(c.code, "CLP");
    assert_eq(c.minor_units, 0);
}

@test
fn test_isk_code_and_minor_units() {
    let c = isk();
    assert_eq(c.code, "ISK");
    assert_eq(c.minor_units, 0);
}

