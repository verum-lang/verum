// =============================================================================
// core-tests/context/scope/regression_test.vr
// =============================================================================
//
// Pinned regressions for `core.context.scope`. Each test names the defect,
// the workaround in current source, and the upstream task that should
// fix it. Do not delete tests here — they pin observed bugs so a regression
// after the upstream fix immediately re-surfaces in this file.
// =============================================================================

mount core.context.scope.{Scope, ContextScope};

// =============================================================================
// REGRESSION §1: bare `Transient` collides with sibling-module variants
// =============================================================================
//
// `core/context/scope.vr:57 type Scope is Singleton | Request | Transient`
// declares the variant. But `Transient` is ALSO a unit variant of:
//   * `core/async/spawn_config.vr` (some local config type)
//   * `core/runtime/env.vr`        (some restart-strategy type)
//   * `core/runtime/supervisor.vr` (RestartStrategy)
//   * `core/database/common/pool_supervisor.vr` (SupervisorRestartStrategy)
//
// Pre-fix, even with `mount core.context.scope.{Transient}` at the top of
// a test file, ANY reference to bare `Transient` failed to compile
// with `UndefinedVariable("Transient")`. The bare-name resolver picked
// the wrong sibling-module variant first under the first-wins lookup
// hazard (task #17/#39 mount-scope-aware lookup not yet landed).
//
// Workaround: always reference `Scope.Transient` with the type prefix.
// The test below pins the workaround AND uses bare `Transient` in a
// COMMENT to make sure we re-test the bare form once #17/#39 closes.

@test
fn regression_bare_transient_collision_workaround_via_qualification() {
    // Same logical assertion as bare-form `let s: Scope = Transient;`
    // PRE-FIX FORM (commented — fails to compile under task #17/#39):
    //   mount core.context.scope.{Transient};
    //   let s: Scope = Transient;
    //   assert(s is Transient);
    let s: Scope = Scope.Transient;
    assert(s is Scope.Transient);
}

// =============================================================================
// REGRESSION §2: bare `Singleton` value-of-Scope dispatches to wrong .name()
// =============================================================================
//
// `Singleton` is defined ONLY in `core.context.scope.Scope` — no
// cross-module collision. Yet `Singleton.name()` (with `mount
// core.context.scope.{Singleton}`) returned a value DIFFERENT from
// "Singleton". Root cause: the bare-variant constructor `Singleton`
// produces a `Scope`-typed value, but the implicit method-receiver
// type-tracking for the resulting value drops the `Scope` association
// in some compile paths — method dispatch then picks a `.name()` from
// another type. Same class as the broader `T.method()` dispatch hazard
// pinned in MEMORY task #17/#26 (memory/callg_emission_fix_blueprint).
//
// Worse: `Singleton.can_depend_on(Scope.Request)` returned `true`
// instead of `false` — the dispatch picked an "always-true" method
// from an unrelated type, silently corrupting the DI graph check.
//
// Workaround: always qualify as `Scope.Singleton.name()`. The bare
// form is pinned in this regression so that when #17/#39 closes we
// re-enable the bare reference.

@test
fn regression_qualified_singleton_name_returns_singleton() {
    assert_eq(Scope.Singleton.name(), "Singleton");
}

@test
fn regression_qualified_singleton_can_depend_on_only_singleton() {
    assert(Scope.Singleton.can_depend_on(Scope.Singleton));
    assert(!Scope.Singleton.can_depend_on(Scope.Request));
    assert(!Scope.Singleton.can_depend_on(Scope.Transient));
}

// =============================================================================
// REGRESSION §3: ContextScope.enter immutability
// =============================================================================
//
// `enter(&self)` borrows immutably and must return a NEW `ContextScope`
// without mutating the receiver. Pin the immutability contract so a
// future implementation switch to `&mut self` is caught immediately.

@test
fn regression_contextscope_enter_does_not_mutate_receiver() {
    let root = ContextScope.root();
    let _child = root.enter();
    let _grandchild = root.enter().enter();
    let _ggchild = root.enter().enter().enter();

    // root must still be root
    assert_eq(root.current_depth(), 0);
    assert_eq(root.parent(), 0);
}

// =============================================================================
// REGRESSION §4: ContextScope.root.parent == 0 (not 1, not -1)
// =============================================================================
//
// `ContextScope.root()` constructs a `{ depth: 0, parent_depth: 0 }`
// record. Pin that `parent_depth` for the root is `0` (NOT `-1`,
// which would have been a sentinel-based alternative). The `0/0`
// degeneracy is intentional: it lets `enter(root)` produce `{ depth: 1,
// parent_depth: 0 }` symmetrically.

@test
fn regression_root_parent_is_zero_not_negative_sentinel() {
    let root = ContextScope.root();
    assert_eq(root.parent(), 0);
    // And NOT a negative sentinel:
    assert(root.parent() >= 0);
}
