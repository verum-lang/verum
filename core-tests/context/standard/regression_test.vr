// =============================================================================
// core-tests/context/standard/regression_test.vr
// =============================================================================
//
// One @test per defect surfaced while building the standard-context
// data-type suite. Kept forever as re-regression guardrails.
//
// The dominant defect class here is the cross-module variant-name
// collision: `ContextLogLevel`'s variants (Trace / Debug / Info / Warn /
// Error) are ALSO variants of `core.base.log.LogLevel`. Bare-name
// first-wins resolution (task #17/#39) routes a bare `Trace` to whichever
// type registered first, so `severity()` / `name()` / Display / Eq / Ord
// silently dispatched to the wrong type's method. The source fix qualifies
// every arm as `ContextLogLevel.<Variant>`; these tests pin that the
// qualified dispatch returns the right answer DESPITE the collision.
// =============================================================================

mount core.context.standard.{ContextLogLevel, Row, QueryResult, AuthUser};
mount core.collections.list.List;
mount core.base.maybe.{Maybe};

// =============================================================================
// REGRESSION: `severity()` mis-dispatched on bare-variant receivers
// (audit.md §3.2 class). The ordinal must be the ContextLogLevel ordinal
// (0..5), not a sibling LogLevel's (which has no Fatal → different layout).
// =============================================================================

@test
fn regression_severity_full_ordinal_ladder() {
    assert_eq(ContextLogLevel.Trace.severity(), 0);
    assert_eq(ContextLogLevel.Debug.severity(), 1);
    assert_eq(ContextLogLevel.Info.severity(),  2);
    assert_eq(ContextLogLevel.Warn.severity(),  3);
    assert_eq(ContextLogLevel.Error.severity(), 4);
    assert_eq(ContextLogLevel.Fatal.severity(), 5);
}

// =============================================================================
// REGRESSION ([[fstring_direct_variant_ctor_display_dispatch]] — CLOSED
// 2026-06-01 by commit 19bb51b3a `fix(vbc/codegen): … qualified-variant
// Display`): `f"{<Type>.<Variant>}"` — a DIRECT variant-constructor in an
// interpolation placeholder — now DISPATCHES the user `Display` impl.
//
// Pre-fix it fell back to the default rendering (the variant name, e.g.
// "Info") instead of `Display`'s output ("INFO"); only the bound-var form
// (`let l = ContextLogLevel.Info; f"{l}"`) dispatched. The codegen fix
// threads the variant-constructor's type through `infer_expr_type_name`
// (`Field{Path(Type), Variant}` → `<Type>` when `<Type>` declares that
// variant), so the interpolation routes through `<Type>.fmt`.
//
// Un-@ignore'd 2026-06-01 after validating on a clean worktree build of
// HEAD (f64d7e4fc, which includes 19bb51b3a): `f"{ContextLogLevel.Trace}"`
// → "TRACE" etc. all GREEN. Kept forever as a re-regression guard.
// Note: the SEPARATE record-variant case (`f"{err}"` for ContextError, a
// bound var) is NOT closed by this fix — pinned still in error/.
// =============================================================================

@test
fn regression_display_direct_ctor_renders_uppercase_name() {
    assert_eq(f"{ContextLogLevel.Trace}", "TRACE");
    assert_eq(f"{ContextLogLevel.Info}",  "INFO");
    assert_eq(f"{ContextLogLevel.Fatal}", "FATAL");
}

// LIVE companion: Display DOES dispatch via a bound variable — pin the
// working idiom so the coverage survives while the direct-ctor form above
// is @ignore'd.
@test
fn regression_display_via_bound_var_dispatches() {
    let t = ContextLogLevel.Trace;
    let i = ContextLogLevel.Info;
    let f = ContextLogLevel.Fatal;
    assert_eq(f"{t}", "TRACE");
    assert_eq(f"{i}", "INFO");
    assert_eq(f"{f}", "FATAL");
    // Display ≡ name() via the bound-var path.
    let w = ContextLogLevel.Warn;
    assert_eq(f"{w}", w.name());
}

@test
fn regression_debug_renders_name_for_every_level() {
    // Debug (`:?`) dispatches correctly even in direct-ctor form.
    assert_eq(f"{ContextLogLevel.Trace:?}", "TRACE");
    assert_eq(f"{ContextLogLevel.Fatal:?}", "FATAL");
}

// =============================================================================
// REGRESSION: Eq is defined via `severity() == severity()`. Bare-variant
// dispatch corruption made same-variant comparisons return false. Pin
// reflexivity for every variant + cross-variant inequality.
// =============================================================================

@test
fn regression_eq_reflexive_every_variant() {
    assert(ContextLogLevel.Trace == ContextLogLevel.Trace);
    assert(ContextLogLevel.Debug == ContextLogLevel.Debug);
    assert(ContextLogLevel.Info  == ContextLogLevel.Info);
    assert(ContextLogLevel.Warn  == ContextLogLevel.Warn);
    assert(ContextLogLevel.Error == ContextLogLevel.Error);
    assert(ContextLogLevel.Fatal == ContextLogLevel.Fatal);
}

@test
fn regression_eq_distinguishes_adjacent_levels() {
    assert(ContextLogLevel.Trace != ContextLogLevel.Debug);
    assert(ContextLogLevel.Error != ContextLogLevel.Fatal);
}

// =============================================================================
// REGRESSION: Ord is defined via severity().cmp(). Pin that `<` / `>`
// cohere with the severity ladder (catches a cmp mis-dispatch that would
// invert or flatten the ordering).
// =============================================================================

@test
fn regression_ord_coheres_with_severity_ladder() {
    assert(ContextLogLevel.Trace < ContextLogLevel.Fatal);
    assert(ContextLogLevel.Fatal > ContextLogLevel.Trace);
    assert(ContextLogLevel.Info < ContextLogLevel.Warn);
    // Not strictly less than itself.
    assert(!(ContextLogLevel.Info < ContextLogLevel.Info));
}

// =============================================================================
// REGRESSION: is_enabled compares severities; pin the boundary (self is
// always enabled; one step below the floor is not).
// =============================================================================

@test
fn regression_is_enabled_boundary() {
    assert(ContextLogLevel.Info.is_enabled(ContextLogLevel.Info));
    assert(ContextLogLevel.Error.is_enabled(ContextLogLevel.Info));
    assert(!ContextLogLevel.Debug.is_enabled(ContextLogLevel.Info));
}

// =============================================================================
// REGRESSION: AuthUser.has_role delegates to List.contains over the roles
// list. Pin present/absent so a List.contains dispatch regression on
// List<Text> is caught at the AuthUser boundary.
// =============================================================================

@test
fn regression_auth_user_has_role_contains_dispatch() {
    let u = AuthUser {
        id: "u1".clone(),
        name: "alice".clone(),
        roles: ["admin".clone(), "editor".clone()],
    };
    let admin = "admin".clone();
    let viewer = "viewer".clone();
    assert(u.has_role(&admin));
    assert(!u.has_role(&viewer));
}

// =============================================================================
// REGRESSION (archive-loaded `Row`, two facets — BOTH CLOSED, see audit §3.5):
//
// Facet #1: `Row.get_index(n)` / `Row.get(&name)` return `Maybe<&Text>`
// borrowed from `self.values[i].as_ref()`. Calling + consuming them used to
// SIGSEGV the compiler at execution-compile. Closed by codegen between
// 2026-06-01 and a1293ff52 (record-alloc / Self-literal / transparent-ref).
//
// Facet #2: reading `Row`'s OWN fields (`r.columns` / `r.values`) panicked
// field-OOB. ROOT CAUSE: the bare name `Row` collides with the variant
// `StepResult.Row(reg_start, n_cols)` (core.database.sqlite). The let binding
// was typed `StepResult` (the variant's parent — matched by arg COUNT in
// `find_variant_parent_type_by_args`), shifting every later `r.<field>` read
// to a global field-intern index. CLOSED 2026-06-03: that resolver now
// field-NAME-verifies the variant match (`columns,values` ≠ `reg_start,n_cols`
// → the literal is the record, not the variant).
// =============================================================================

@test
fn regression_row_get_index_bounds_guarded() {
    let r = Row {
        columns: ["c".clone()],
        values: [Maybe.Some("v".clone())],
    };
    assert(r.get_index(0) is Maybe.Some);
    assert(r.get_index(1) is Maybe.None);
    assert(r.get_index(-1) is Maybe.None);
}

// Facet #2 pin: a bare `Row { .. }` literal whose head collides with the
// `StepResult.Row` variant must be typed as the RECORD, so direct field reads
// resolve to the record's own layout (columns@0, values@1) — not a global
// field-intern index. Regresses the field-OOB panic if the collision returns.
@test
fn regression_row_direct_field_read_after_collision() {
    let r = Row {
        columns: ["name".clone(), "email".clone()],
        values: [Maybe.Some("alice".clone())],
    };
    assert_eq(r.columns.len(), 2);
    assert_eq(r.values.len(), 1);
}

// =============================================================================
// REGRESSION: QueryResult Display reads `rows.len()` + `rows_affected`.
// Pin that an empty result renders both counts without an iterator
// dispatch fault on the empty rows list.
// =============================================================================

@test
fn regression_query_result_display_empty_rows() {
    let qr = QueryResult { rows: [], rows_affected: 0 };
    let s = f"{qr}";
    assert(s.contains("QueryResult"));
    assert(s.contains("0"));
}

fn main() {
    // Tests run via @test discovery.
}
