// =============================================================================
// core-tests/base/glob/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.glob` — POSIX shell glob patterns
// against List<Text> path collections.
//
// API surface used:
//   • `matches(pattern: &Text, path: &Text) -> Bool` (free fn — simplest)
//   • `compile(pattern: &Text) -> Result<GlobPattern, GlobError>` +
//     `pattern.matches_path(path: &Text) -> Bool` (reusable form)
//   • `compile_with(pattern: &Text, case_sensitive: Bool)
//     -> Result<GlobPattern, GlobError>`
//
// Pre-fix tests called a hallucinated `GlobOptions.new()` /
// `compile_with(pattern, opts)` API (the real signature takes a Bool,
// not an opaque options record) and `pattern.matches(path)` on a
// `Result<GlobPattern, _>` (the real method is `.matches_path` and
// the Result must be unwrapped first). All sites rewritten.
// =============================================================================

mount core.prelude.*;
mount core.base.glob.{
    GlobPattern, GlobError,
    compile, compile_with, matches,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: Filtering List<Text> paths through a glob
// =============================================================================

@test
fn integration_filter_paths_with_star_pattern() {
    let paths: List<Text> = [
        "src/main.vr".to_text(),
        "src/lib.vr".to_text(),
        "tests/unit.vr".to_text(),
        "README.md".to_text(),
    ];
    let mut matched_count: Int = 0;
    let mut i: Int = 0;
    while i < paths.len() {
        let p = paths[i].clone();
        if matches(&"src/*.vr".to_text(), &p) {
            matched_count = matched_count + 1;
        }
        i = i + 1;
    }
    assert_eq(matched_count, 2);
}

@test
fn integration_filter_paths_with_globstar() {
    let paths: List<Text> = [
        "a/b/c.vr".to_text(),
        "a/c.vr".to_text(),
        "b/c.vr".to_text(),
        "c.vr".to_text(),
    ];
    let mut matched_count: Int = 0;
    let mut i: Int = 0;
    while i < paths.len() {
        let p = paths[i].clone();
        if matches(&"a/**/*.vr".to_text(), &p) {
            matched_count = matched_count + 1;
        }
        i = i + 1;
    }
    // "a/b/c.vr" and "a/c.vr" both under a/ — 2 paths match.
    assert_eq(matched_count, 2);
}

@test
fn integration_no_paths_match_impossible_pattern() {
    let paths: List<Text> = [
        "foo.rs".to_text(),
        "bar.rs".to_text(),
        "baz.rs".to_text(),
    ];
    let mut matched_count: Int = 0;
    let mut i: Int = 0;
    while i < paths.len() {
        let p = paths[i].clone();
        if matches(&"*.vr".to_text(), &p) {
            matched_count = matched_count + 1;
        }
        i = i + 1;
    }
    assert_eq(matched_count, 0);
}

// =============================================================================
// Section 2: Negated character classes [!...]
// =============================================================================

@test
fn integration_negated_char_class_excludes_listed_chars() {
    assert(matches(&"[!abc].txt".to_text(), &"d.txt".to_text()));
    assert(matches(&"[!abc].txt".to_text(), &"z.txt".to_text()));
    assert(!matches(&"[!abc].txt".to_text(), &"a.txt".to_text()));
    assert(!matches(&"[!abc].txt".to_text(), &"b.txt".to_text()));
    assert(!matches(&"[!abc].txt".to_text(), &"c.txt".to_text()));
}

@test
fn integration_negated_char_class_with_digit_range() {
    assert(matches(&"[!0-9]oo".to_text(), &"foo".to_text()));
    assert(matches(&"[!0-9]oo".to_text(), &"zoo".to_text()));
    assert(!matches(&"[!0-9]oo".to_text(), &"1oo".to_text()));
    assert(!matches(&"[!0-9]oo".to_text(), &"9oo".to_text()));
}

// =============================================================================
// Section 3: Escape sequences via the reusable compile path
// =============================================================================

@test
fn integration_escape_star_via_compile() {
    let r = compile(&"file\\*.txt".to_text());
    assert(r.is_ok());
    let pat: GlobPattern = r.unwrap();
    assert(pat.matches_path(&"file*.txt".to_text()));
    assert(!pat.matches_path(&"fileX.txt".to_text()));
}

@test
fn integration_escape_question_via_compile() {
    let r = compile(&"item\\?.txt".to_text());
    assert(r.is_ok());
    let pat: GlobPattern = r.unwrap();
    assert(pat.matches_path(&"item?.txt".to_text()));
    assert(!pat.matches_path(&"itemX.txt".to_text()));
}

// =============================================================================
// Section 4: compile_with — case-sensitivity option
// =============================================================================

@test
fn integration_case_insensitive_compile() {
    let r = compile_with(&"*.TXT".to_text(), false);   // false = case-insensitive
    assert(r.is_ok());
    let pat: GlobPattern = r.unwrap();
    assert(pat.matches_path(&"foo.txt".to_text()));
    assert(pat.matches_path(&"foo.TXT".to_text()));
    assert(pat.matches_path(&"foo.Txt".to_text()));
}

@test
fn integration_case_sensitive_compile() {
    let r = compile_with(&"*.TXT".to_text(), true);    // true = case-sensitive
    assert(r.is_ok());
    let pat: GlobPattern = r.unwrap();
    assert(pat.matches_path(&"foo.TXT".to_text()));
    assert(!pat.matches_path(&"foo.txt".to_text()));
}

// =============================================================================
// Section 5: Literal-only patterns (no metacharacters)
// =============================================================================

@test
fn integration_literal_pattern_exact_match() {
    assert(matches(&"Cargo.toml".to_text(), &"Cargo.toml".to_text()));
    assert(!matches(&"Cargo.toml".to_text(), &"Cargo.tomx".to_text()));
    assert(!matches(&"Cargo.toml".to_text(), &"cargo.toml".to_text()));
}

// =============================================================================
// Section 6: Compiled-pattern reuse across multiple paths
// =============================================================================

@test
fn integration_compiled_pattern_reuse_across_paths() {
    let r = compile(&"*.vr".to_text());
    assert(r.is_ok());
    let pat: GlobPattern = r.unwrap();
    // Reuse the compiled pattern against three pre-bound paths —
    // confirms pat is not consumed by .matches_path. Inline subscript
    // chained with `&candidates[i]` can hit a Text-element-type-loss
    // through List<Text>[i] (same class as [[btree_pattern_match_ref_generic_class]]),
    // so we destructure into typed locals first.
    let p_main: Text = "main.vr".to_text();
    let p_lib:  Text = "lib.vr".to_text();
    let p_rs:   Text = "test.rs".to_text();
    let p_md:   Text = "other.md".to_text();
    assert(pat.matches_path(&p_main));
    assert(pat.matches_path(&p_lib));
    assert(!pat.matches_path(&p_rs));
    assert(!pat.matches_path(&p_md));
}

fn main() {}
