// =============================================================================
// core-tests/base/nanoid/property_test.vr
// =============================================================================
//
// Algebraic-law verification for `core.base.nanoid` — alphabet-level
// invariants and length-entropy properties.
//
// Live `generate()` properties are pinned `@ignore`'d at
// `regression_test.vr §A/§B` (precompiled stdlib has `Text.from("")`
// + private `Text.from_utf8_unchecked` — both fixed in this branch,
// gate on next stdlib refresh).
// =============================================================================

mount core.prelude.*;
mount core.base.nanoid.{NANOID_ALPHABET, NANOID_DEFAULT_LENGTH, DEFAULT_LEN};
mount core.collections.list.List;

// =============================================================================
// §A  Alphabet — every char in URL-safe printable range, no duplicates.
// =============================================================================

@test
fn law_alphabet_size_is_64() {
    assert_eq(NANOID_ALPHABET.len(), 64);
}

@test
fn law_alphabet_chars_in_ascii_printable_range() {
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let b = NANOID_ALPHABET[i];
        assert(b >= 0x20_u8);   // space — printable lower bound
        assert(b <= 0x7E_u8);   // tilde — printable upper bound
        i = i + 1;
    }
}

@test
fn law_alphabet_pairwise_distinct() {
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let mut j: Int = i + 1;
        while j < NANOID_ALPHABET.len() {
            assert(NANOID_ALPHABET[i] != NANOID_ALPHABET[j]);
            j = j + 1;
        }
        i = i + 1;
    }
}

@test
fn law_alphabet_no_url_reserved_chars() {
    // RFC 3986 §2.2 reserved chars that MUST NOT appear in a
    // URL-safe alphabet: ':' '/' '?' '#' '[' ']' '@' '!' '$' '&'
    // ''' '(' ')' '*' '+' ',' ';' '=' '%' ' '
    let reserved: List<Byte> = [
        0x3A_u8, 0x2F_u8, 0x3F_u8, 0x23_u8, 0x5B_u8, 0x5D_u8, 0x40_u8,
        0x21_u8, 0x24_u8, 0x26_u8, 0x27_u8, 0x28_u8, 0x29_u8, 0x2A_u8,
        0x2B_u8, 0x2C_u8, 0x3B_u8, 0x3D_u8, 0x25_u8, 0x20_u8,
    ];
    let mut ri: Int = 0;
    while ri < reserved.len() {
        let bad = reserved[ri];
        let mut ai: Int = 0;
        while ai < NANOID_ALPHABET.len() {
            assert(NANOID_ALPHABET[ai] != bad);
            ai = ai + 1;
        }
        ri = ri + 1;
    }
}

// =============================================================================
// §B  Alphabet composition — 26 upper + 26 lower + 10 digit + 2 special.
// =============================================================================

@test
fn law_alphabet_has_26_uppercase() {
    let mut count: Int = 0;
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let b = NANOID_ALPHABET[i];
        if b >= 0x41_u8 && b <= 0x5A_u8 { count = count + 1; }
        i = i + 1;
    }
    assert_eq(count, 26);
}

@test
fn law_alphabet_has_26_lowercase() {
    let mut count: Int = 0;
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let b = NANOID_ALPHABET[i];
        if b >= 0x61_u8 && b <= 0x7A_u8 { count = count + 1; }
        i = i + 1;
    }
    assert_eq(count, 26);
}

@test
fn law_alphabet_has_10_digits() {
    let mut count: Int = 0;
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let b = NANOID_ALPHABET[i];
        if b >= 0x30_u8 && b <= 0x39_u8 { count = count + 1; }
        i = i + 1;
    }
    assert_eq(count, 10);
}

@test
fn law_alphabet_has_exactly_two_special_chars() {
    // The two special chars must be '_' (0x5F) and '-' (0x2D).
    let mut count_under: Int = 0;
    let mut count_hyphen: Int = 0;
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let b = NANOID_ALPHABET[i];
        if b == 0x5F_u8 { count_under = count_under + 1; }
        if b == 0x2D_u8 { count_hyphen = count_hyphen + 1; }
        i = i + 1;
    }
    assert_eq(count_under, 1);
    assert_eq(count_hyphen, 1);
}

@test
fn law_alphabet_composition_sums_to_64() {
    // 26 upper + 26 lower + 10 digits + 2 special = 64.
    assert_eq(26 + 26 + 10 + 2, 64);
    assert_eq(NANOID_ALPHABET.len(), 64);
}

// =============================================================================
// §C  Entropy invariants — 21 chars × 6 bits = 126 bits.
// =============================================================================

@test
fn law_default_length_is_21() {
    assert_eq(NANOID_DEFAULT_LENGTH, 21);
}

@test
fn law_default_total_entropy_is_126_bits() {
    let alpha_bits: Int = 6;                 // log2(64)
    let total_bits = NANOID_DEFAULT_LENGTH * alpha_bits;
    assert_eq(total_bits, 126);
}

@test
fn law_default_len_alias_consistent() {
    assert_eq(DEFAULT_LEN, NANOID_DEFAULT_LENGTH);
}

@test
fn law_alphabet_is_power_of_two() {
    // n is power of two iff n & (n-1) == 0
    let n = NANOID_ALPHABET.len();
    assert_eq(n & (n - 1), 0);
}

fn main() {}
