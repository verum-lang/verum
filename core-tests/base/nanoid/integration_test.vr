// =============================================================================
// core-tests/base/nanoid/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.nanoid` — alphabet-level invariants
// exercised against List<Byte> / Set<Byte> / cross-position layout.
//
// Live generation surface (`generate` / `generate_len` /
// `generate_with_alphabet`) is gated on two stdlib defects fixed in
// this branch but pending precompiled-stdlib refresh — pinned at
// `regression_test.vr §A/§B`. All integration tests here exercise
// the data-only alphabet surface.
// =============================================================================

mount core.prelude.*;
mount core.base.nanoid.{
    NANOID_ALPHABET, NANOID_DEFAULT_LENGTH, DEFAULT_LEN,
};
mount core.collections.list.List;
mount core.collections.set.Set;

// =============================================================================
// Section 1: Alphabet membership via Set<Byte> insertion
// =============================================================================

@test
fn integration_alphabet_distinct_set_has_64_members() {
    let mut s: Set<Byte> = Set.new();
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        s.insert(NANOID_ALPHABET[i]);
        i = i + 1;
    }
    assert_eq(s.len(), 64);
}

@test
fn integration_alphabet_disjoint_from_url_reserved_set() {
    let mut alpha_set: Set<Byte> = Set.new();
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        alpha_set.insert(NANOID_ALPHABET[i]);
        i = i + 1;
    }
    // Insert each reserved char and confirm Set.contains returns false.
    let reserved: List<Byte> = [
        0x3A_u8, 0x2F_u8, 0x3F_u8, 0x23_u8, 0x40_u8, 0x21_u8,
        0x2B_u8, 0x2C_u8, 0x3B_u8, 0x3D_u8, 0x25_u8, 0x20_u8,
    ];
    let mut ri: Int = 0;
    while ri < reserved.len() {
        assert(!alpha_set.contains(&reserved[ri]));
        ri = ri + 1;
    }
}

// =============================================================================
// Section 2: Alphabet positions — uppercase / lowercase / digit / special
// =============================================================================

@test
fn integration_alphabet_uppercase_block_positions_0_to_25() {
    let mut i: Int = 0;
    while i < 26 {
        let b = NANOID_ALPHABET[i];
        assert(b >= 0x41_u8);
        assert(b <= 0x5A_u8);
        i = i + 1;
    }
}

@test
fn integration_alphabet_lowercase_block_positions_26_to_51() {
    let mut i: Int = 26;
    while i < 52 {
        let b = NANOID_ALPHABET[i];
        assert(b >= 0x61_u8);
        assert(b <= 0x7A_u8);
        i = i + 1;
    }
}

@test
fn integration_alphabet_digit_block_positions_52_to_61() {
    let mut i: Int = 52;
    while i < 62 {
        let b = NANOID_ALPHABET[i];
        assert(b >= 0x30_u8);
        assert(b <= 0x39_u8);
        i = i + 1;
    }
}

@test
fn integration_alphabet_special_block_positions_62_63() {
    // Position 62: '_'. Position 63: '-'.
    assert_eq(NANOID_ALPHABET[62], 0x5F_u8);
    assert_eq(NANOID_ALPHABET[63], 0x2D_u8);
}

// =============================================================================
// Section 3: Entropy bookkeeping
// =============================================================================

@test
fn integration_default_entropy_is_126_bits_at_21_chars() {
    let alpha_bits: Int = 6;
    let total = NANOID_DEFAULT_LENGTH * alpha_bits;
    assert_eq(total, 126);
}

@test
fn integration_entropy_at_various_lengths() {
    // For Nano ID's 64-char alphabet (6 bits / char):
    let cases: List<(Int, Int)> = [
        (1,    6),
        (8,   48),
        (16,  96),
        (21, 126),
        (32, 192),
        (64, 384),
    ];
    let alpha_bits: Int = 6;
    let mut i: Int = 0;
    while i < cases.len() {
        let p = cases[i].clone();
        let len = p.0;
        let exp = p.1;
        assert_eq(len * alpha_bits, exp);
        i = i + 1;
    }
}

@test
fn integration_alphabet_size_log2_is_six() {
    // log2(64) = 6. A defect that resized the alphabet (e.g. to 32
    // for a hypothetical "smaller" variant) would change the bits-
    // per-char and break the entropy contract.
    let n = NANOID_ALPHABET.len();
    let mut bits: Int = 0;
    let mut x = n;
    while x > 1 {
        x = x / 2;
        bits = bits + 1;
    }
    assert_eq(bits, 6);
}

fn main() {}
