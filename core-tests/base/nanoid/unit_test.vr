// =============================================================================
// core-tests/base/nanoid/unit_test.vr
// =============================================================================
//
// Tests for `core.base.nanoid` — URL-safe short-ID generator (Nano ID
// spec). Default length 21 chars ≈ 126 bits of entropy.
//
// The full generation surface (`generate` / `generate_len` /
// `generate_with_alphabet`) is currently gated on two distinct
// fundamental defects:
//
//   §A `Text.from("")` referenced at `core/base/nanoid.vr:138` does
//      not exist on `Text` (only `Text.from_utf8` / `.from_char` /
//      `.from_int` / `.from_float` / `.from_bool` / `.new()`).
//      Lenient-stubbed at precompile; every `generate_with_alphabet`
//      call panics with:
//        [lenient] generate_with_alphabet compiled to panic-stub:
//        undefined function: Text.from
//      Fix landed in this branch (`Text.from("")` → `Text.new()`).
//      Activates after next precompiled-stdlib refresh.
//
//   §B `Text.from_utf8_unchecked` was private in `core/text/text.vr:455`.
//      The final line of `generate_with_alphabet` calls it; the
//      visibility fix landed in `core-tests/base/ulid` work
//      (`unsafe fn` → `public unsafe fn`). Also activates on the
//      same stdlib refresh.
//
// All live generation tests are pinned `@ignore`'d at
// `regression_test.vr §A/§B`. This file exercises the data-only
// surface: alphabet constants, default-length constant, alphabet
// composition rules.
// =============================================================================

mount core.prelude.*;
mount core.base.nanoid.{
    NANOID_ALPHABET, NANOID_DEFAULT_LENGTH, DEFAULT_LEN,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: NANOID_DEFAULT_LENGTH constant — 21 chars per spec
// =============================================================================

@test
fn test_default_length_is_21() {
    assert_eq(NANOID_DEFAULT_LENGTH, 21);
}

@test
fn test_default_len_alias_matches_default_length() {
    assert_eq(DEFAULT_LEN, NANOID_DEFAULT_LENGTH);
    assert_eq(DEFAULT_LEN, 21);
}

// =============================================================================
// Section 2: NANOID_ALPHABET — URL-safe Base64 variant (A-Za-z0-9_-)
// =============================================================================

@test
fn test_alphabet_length_is_64() {
    assert_eq(NANOID_ALPHABET.len(), 64);
}

@test
fn test_alphabet_starts_with_uppercase_a() {
    assert_eq(NANOID_ALPHABET[0], 0x41_u8);   // 'A'
}

@test
fn test_alphabet_ends_with_hyphen() {
    assert_eq(NANOID_ALPHABET[63], 0x2D_u8);   // '-'
}

@test
fn test_alphabet_position_62_is_underscore() {
    assert_eq(NANOID_ALPHABET[62], 0x5F_u8);   // '_'
}

@test
fn test_alphabet_first_26_are_uppercase_letters() {
    let mut i: Int = 0;
    while i < 26 {
        let expected: Byte = 0x41_u8 + (i as Byte);   // 'A' + i
        assert_eq(NANOID_ALPHABET[i], expected);
        i = i + 1;
    }
}

@test
fn test_alphabet_chars_26_to_52_are_lowercase_letters() {
    let mut i: Int = 0;
    while i < 26 {
        let expected: Byte = 0x61_u8 + (i as Byte);   // 'a' + i
        assert_eq(NANOID_ALPHABET[26 + i], expected);
        i = i + 1;
    }
}

@test
fn test_alphabet_chars_52_to_62_are_decimal_digits() {
    let mut i: Int = 0;
    while i < 10 {
        let expected: Byte = 0x30_u8 + (i as Byte);   // '0' + i
        assert_eq(NANOID_ALPHABET[52 + i], expected);
        i = i + 1;
    }
}

// =============================================================================
// Section 3: Alphabet composition — uniqueness + URL-safety
// =============================================================================

@test
fn test_alphabet_chars_pairwise_distinct() {
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let mut j: Int = i + 1;
        while j < NANOID_ALPHABET.len() {
            assert(NANOID_ALPHABET[i] != NANOID_ALPHABET[j]);
            j = j + 1;
        }
        i = i + 1;
    }
}

@test
fn test_alphabet_excludes_url_unsafe_chars() {
    // URL-unsafe chars per RFC 3986 §2.3 that nanoid's URL-safe
    // alphabet must NOT contain: '+' '/' '=' '?' '#' '&' ' '
    let unsafe_chars: List<Byte> = [
        0x2B_u8,   // '+'
        0x2F_u8,   // '/'
        0x3D_u8,   // '='
        0x3F_u8,   // '?'
        0x23_u8,   // '#'
        0x26_u8,   // '&'
        0x20_u8,   // ' '
    ];
    let mut ui: Int = 0;
    while ui < unsafe_chars.len() {
        let bad = unsafe_chars[ui];
        let mut ai: Int = 0;
        while ai < NANOID_ALPHABET.len() {
            assert(NANOID_ALPHABET[ai] != bad);
            ai = ai + 1;
        }
        ui = ui + 1;
    }
}

@test
fn test_alphabet_all_chars_in_url_safe_range() {
    // Every byte must be an alphanumeric or one of '_' / '-'.
    let mut i: Int = 0;
    while i < NANOID_ALPHABET.len() {
        let b = NANOID_ALPHABET[i];
        let is_upper  = b >= 0x41_u8 && b <= 0x5A_u8;
        let is_lower  = b >= 0x61_u8 && b <= 0x7A_u8;
        let is_digit  = b >= 0x30_u8 && b <= 0x39_u8;
        let is_under  = b == 0x5F_u8;
        let is_hyphen = b == 0x2D_u8;
        assert(is_upper || is_lower || is_digit || is_under || is_hyphen);
        i = i + 1;
    }
}

@test
fn test_alphabet_is_64_power_of_two() {
    // Nano ID's URL-safe alphabet is exactly 64 chars (6 bits per
    // sample), enabling mask-based rejection sampling without
    // discards. A defect that changed the length would change the
    // entropy-per-character.
    let n = NANOID_ALPHABET.len();
    // n must be a positive power of two.
    assert(n > 0);
    assert_eq(n & (n - 1), 0);   // n is power of two iff n & (n-1) == 0
}

// =============================================================================
// Section 4: 126-bit entropy invariant
// =============================================================================

@test
fn test_default_length_times_alphabet_bits_is_126() {
    // 21 chars × log2(64) bits = 21 × 6 = 126 bits of entropy.
    let alpha_bits: Int = 6;                 // log2(64)
    let total_bits: Int = NANOID_DEFAULT_LENGTH * alpha_bits;
    assert_eq(total_bits, 126);
}

fn main() {}
