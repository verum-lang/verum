// =============================================================================
// core-tests/base/mod/unit_test.vr
// =============================================================================
//
// Tests for `core/base/mod.vr` — the core module manifest. This file is
// itself a re-export hub and type-alias declaration site, so its tests
// verify:
//   - Re-exported names are accessible (Maybe, Result, Ordering, …)
//   - Type aliases resolve (Byte, Bytes, TextResult, StdResult)
//   - VERSION constants exist and have expected values
//   - Submodule declarations are reachable
//
// Companion files:
//   prelude_test.vr      — minimal prelude-types test (migrated)
//   property_test.vr     — invariants on the manifest contents
//   integration_test.vr  — exercising the prelude across stdlib boundaries
//   audit.md             — re-export drift surfaces
// =============================================================================

mount core.prelude.*;
mount core.collections.list.List;

// =============================================================================
// Section 1: Prelude re-exports — all canonical names accessible
// =============================================================================

@test
fn test_prelude_reexports_maybe() {
    let m: Maybe<Int> = Some(42);
    assert(m.is_some());
}

@test
fn test_prelude_reexports_result() {
    let r: Result<Int, Text> = Ok(7);
    assert(r.is_ok());
}

@test
fn test_prelude_reexports_ordering() {
    let o: Ordering = Less;
    assert(o is Less);
}

@test
fn test_prelude_reexports_collections() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.len(), 3);

    let _m: Map<Text, Int> = Map.new();
    let _s: Set<Int> = Set.new();
}

// =============================================================================
// Section 2: Type aliases
// =============================================================================

@test
fn test_byte_alias_is_uint8_compatible() {
    let b: Byte = 42 as Byte;
    let n: Int = b as Int;
    assert_eq(n, 42);
}

@test
fn test_bytes_alias_is_list_byte_compatible() {
    let bs: Bytes = [1 as Byte, 2 as Byte, 3 as Byte];
    assert_eq(bs.len(), 3);
}

@test
fn test_text_result_alias() {
    let r: TextResult<Int> = Ok(42);
    assert(r.is_ok());

    let e: TextResult<Int> = Err("error message");
    assert(e.is_err());
}

// =============================================================================
// Section 3: VERSION constants
// =============================================================================

@test
fn test_version_constant_format() {
    // Just verify the constants exist with expected types.
    // Actual values may evolve; we pin only the shape.
    assert(VERSION.len() > 0);
    assert(VERSION_MAJOR >= 0);
    assert(VERSION_MINOR >= 0);
    assert(VERSION_PATCH >= 0);
}

@test
fn test_version_string_is_dotted() {
    // Format: "major.minor.patch"
    let v = VERSION;
    assert(v.contains("."));
}

// =============================================================================
// Section 4: Common operator protocols accessible
// =============================================================================

@test
fn test_eq_protocol_via_prelude() {
    let a: Int = 1;
    let b: Int = 1;
    assert(a == b);
}

@test
fn test_ord_protocol_via_prelude() {
    let cmp_result = (1 as Int).cmp(&(2 as Int));
    assert_eq(cmp_result, Less);
}

@test
fn test_clone_protocol_via_prelude() {
    let a: Int = 7;
    let b = a.clone();
    assert_eq(a, b);
}

// =============================================================================
// Section 5: Memory primitives via prelude
// =============================================================================

@test
fn test_heap_via_prelude() {
    let h: Heap<Int> = Heap.new(99);
    assert_eq(*h, 99);
}

@test
fn test_drop_take_via_prelude_returns_value() {
    // `take(&mut x)` must at minimum RETURN the captured value.
    // The post-take reset to T::default() is gated on a stdlib
    // defect (see regression_test.vr §B); the value-extraction
    // half of the contract is what's exercised here.
    let mut x: Int = 42;
    let taken = take(&mut x);
    assert_eq(taken, 42);
}

// =============================================================================
// Section 6: Iterator primitives via prelude
// =============================================================================

@test
fn test_range_via_prelude() {
    let n = (0..5).count();
    assert_eq(n, 5);
}

@test
fn test_range_inclusive_via_prelude_is_constructible() {
    // The inclusive `..=` range syntax must construct cleanly via the
    // prelude. The actual count / sum semantics hit a stdlib defect —
    // pinned at regression_test.vr §A. Here we only verify the
    // syntax binds.
    let _r = 1..=10;
}

// =============================================================================
// Section 7: Panic primitives via prelude
// =============================================================================

@test
fn test_assert_via_prelude() {
    assert(true);
    assert(true, "always true");
}

@test
fn test_assert_eq_via_prelude() {
    assert_eq(1, 1);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
