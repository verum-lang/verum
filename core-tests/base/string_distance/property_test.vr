// =============================================================================
// core-tests/base/string_distance/property_test.vr
// =============================================================================
//
// Algebraic-law verification for string-distance functions:
// metric axioms — d(a, a) = 0, d(a, b) >= 0, d(a, b) = d(b, a),
// triangle inequality — plus the Jaro [0, 1] range and the
// Jaro-Winkler >= Jaro prefix-bonus invariant.
//
// All byte-slice forms use `Text.as_bytes()` rather than the
// hand-rolled `&str.chars()` builder used by the pre-fix file —
// `&str` is not a public type in Verum, and `chars().map(as Byte)`
// loses information on multi-byte codepoints.
// =============================================================================

mount core.prelude.*;
mount core.base.string_distance.{levenshtein, jaro, jaro_winkler};
mount core.collections.list.List;

// =============================================================================
// §A  Levenshtein metric axioms.
// =============================================================================

@test
fn law_levenshtein_zero_iff_equal() {
    let cases: List<Text> = [
        "".to_text(),
        "a".to_text(),
        "abc".to_text(),
        "kitten".to_text(),
    ];
    let mut i: Int = 0;
    while i < cases.len() {
        let s = cases[i].clone();
        assert_eq(levenshtein(s.as_bytes(), s.as_bytes()), 0);
        i = i + 1;
    }
}

@test
fn law_levenshtein_non_negative() {
    let pairs: List<(Text, Text)> = [
        ("kitten".to_text(),  "sitting".to_text()),
        ("".to_text(),         "abc".to_text()),
        ("hello".to_text(),   "world".to_text()),
        ("abc".to_text(),     "xyz".to_text()),
    ];
    let mut i: Int = 0;
    while i < pairs.len() {
        let p = pairs[i].clone();
        let d = levenshtein(p.0.as_bytes(), p.1.as_bytes());
        assert(d >= 0);
        i = i + 1;
    }
}

@test
fn law_levenshtein_symmetric() {
    let pairs: List<(Text, Text)> = [
        ("kitten".to_text(), "sitting".to_text()),
        ("abc".to_text(),    "xyz".to_text()),
        ("a".to_text(),      "ab".to_text()),
        ("hello".to_text(),  "world".to_text()),
    ];
    let mut i: Int = 0;
    while i < pairs.len() {
        let p = pairs[i].clone();
        let ab = levenshtein(p.0.as_bytes(), p.1.as_bytes());
        let ba = levenshtein(p.1.as_bytes(), p.0.as_bytes());
        assert_eq(ab, ba);
        i = i + 1;
    }
}

@test
fn law_levenshtein_triangle_inequality() {
    let triples: List<(Text, Text, Text)> = [
        ("kitten".to_text(), "sitting".to_text(), "fitting".to_text()),
        ("abc".to_text(),    "xyz".to_text(),     "qwe".to_text()),
        ("hello".to_text(),  "help".to_text(),    "world".to_text()),
    ];
    let mut i: Int = 0;
    while i < triples.len() {
        let t = triples[i].clone();
        let ac = levenshtein(t.0.as_bytes(), t.2.as_bytes());
        let ab = levenshtein(t.0.as_bytes(), t.1.as_bytes());
        let bc = levenshtein(t.1.as_bytes(), t.2.as_bytes());
        // d(a, c) <= d(a, b) + d(b, c)
        assert(ac <= ab + bc);
        i = i + 1;
    }
}

@test
fn law_levenshtein_distance_bounded_by_max_length() {
    // d(a, b) <= max(|a|, |b|) — the distance can never exceed the
    // length of the longer string.
    let pairs: List<(Text, Text)> = [
        ("kitten".to_text(),  "sitting".to_text()),
        ("".to_text(),         "x".to_text()),
        ("abc".to_text(),     "xyz".to_text()),
    ];
    let mut i: Int = 0;
    while i < pairs.len() {
        let p = pairs[i].clone();
        let d = levenshtein(p.0.as_bytes(), p.1.as_bytes());
        let la = p.0.as_bytes().len();
        let lb = p.1.as_bytes().len();
        let max_len = if la > lb { la } else { lb };
        assert(d <= max_len);
        i = i + 1;
    }
}

// =============================================================================
// §B  Jaro — range [0, 1] + symmetry.
// =============================================================================

@test
fn law_jaro_in_unit_interval() {
    let pairs: List<(Text, Text)> = [
        ("MARTHA".to_text(),    "MARHTA".to_text()),
        ("DIXON".to_text(),     "DICKSONX".to_text()),
        ("JELLYFISH".to_text(), "SMELLYFISH".to_text()),
        ("abc".to_text(),       "xyz".to_text()),
    ];
    let mut i: Int = 0;
    while i < pairs.len() {
        let p = pairs[i].clone();
        let v = jaro(p.0.as_bytes(), p.1.as_bytes());
        assert(v >= -0.001);
        assert(v <= 1.001);
        i = i + 1;
    }
}

@test
fn law_jaro_symmetric() {
    let pairs: List<(Text, Text)> = [
        ("MARTHA".to_text(), "MARHTA".to_text()),
        ("abc".to_text(),    "abd".to_text()),
        ("DIXON".to_text(),  "DICKSONX".to_text()),
    ];
    let mut i: Int = 0;
    while i < pairs.len() {
        let p = pairs[i].clone();
        let ab = jaro(p.0.as_bytes(), p.1.as_bytes());
        let ba = jaro(p.1.as_bytes(), p.0.as_bytes());
        let diff = if ab > ba { ab - ba } else { ba - ab };
        assert(diff < 0.001);
        i = i + 1;
    }
}

@test
fn law_jaro_reflexive_returns_one() {
    let cases: List<Text> = [
        "x".to_text(),
        "abc".to_text(),
        "kitten".to_text(),
        "MARTHA".to_text(),
    ];
    let mut i: Int = 0;
    while i < cases.len() {
        let s = cases[i].clone();
        let v = jaro(s.as_bytes(), s.as_bytes());
        assert(v >= 0.999 && v <= 1.001);
        i = i + 1;
    }
}

// =============================================================================
// §C  Jaro-Winkler >= Jaro (the prefix bonus is non-negative).
// =============================================================================

@test
fn law_jaro_winkler_at_least_jaro() {
    let pairs: List<(Text, Text)> = [
        ("MARTHA".to_text(), "MARHTA".to_text()),
        ("DIXON".to_text(),  "DICKSONX".to_text()),
        ("DWAYNE".to_text(), "DUANE".to_text()),
    ];
    let mut i: Int = 0;
    while i < pairs.len() {
        let p = pairs[i].clone();
        let j  = jaro(p.0.as_bytes(), p.1.as_bytes());
        let jw = jaro_winkler(p.0.as_bytes(), p.1.as_bytes());
        assert(jw >= j - 0.001);   // tolerance for float precision
        i = i + 1;
    }
}

@test
fn law_jaro_winkler_in_unit_interval() {
    let pairs: List<(Text, Text)> = [
        ("MARTHA".to_text(),    "MARHTA".to_text()),
        ("DIXON".to_text(),     "DICKSONX".to_text()),
        ("JELLYFISH".to_text(), "SMELLYFISH".to_text()),
    ];
    let mut i: Int = 0;
    while i < pairs.len() {
        let p = pairs[i].clone();
        let jw = jaro_winkler(p.0.as_bytes(), p.1.as_bytes());
        assert(jw >= -0.001);
        assert(jw <= 1.001);
        i = i + 1;
    }
}

fn main() {}
