// =============================================================================
// core-tests/base/string_distance/unit_test.vr
// =============================================================================
//
// Tests for `core.base.string_distance` — Levenshtein, Jaro,
// Jaro-Winkler distance functions for fuzzy string matching.
// =============================================================================

mount core.prelude.*;
mount core.base.string_distance.{levenshtein, levenshtein_bounded, jaro, jaro_winkler, closest};
mount core.collections.list.List;

fn bytes(s: &str) -> List<Byte> {
    let mut bs: List<Byte> = [];
    for c in s.chars() { bs.push(c as Byte); }
    bs
}

// =============================================================================
// Section 1: Levenshtein known fixtures
// =============================================================================

@test
fn test_levenshtein_kitten_sitting_is_3() {
    let a = bytes("kitten");
    let b = bytes("sitting");
    assert_eq(levenshtein(&a, &b), 3);
}

@test
fn test_levenshtein_saturday_sunday_is_3() {
    let a = bytes("saturday");
    let b = bytes("sunday");
    assert_eq(levenshtein(&a, &b), 3);
}

@test
fn test_levenshtein_identical_strings_is_zero() {
    let a = bytes("hello");
    assert_eq(levenshtein(&a, &a), 0);
}

@test
fn test_levenshtein_empty_string_to_self_is_zero() {
    let a = bytes("");
    assert_eq(levenshtein(&a, &a), 0);
}

@test
fn test_levenshtein_empty_to_nonempty_is_length() {
    let a = bytes("");
    let b = bytes("abc");
    assert_eq(levenshtein(&a, &b), 3);
    assert_eq(levenshtein(&b, &a), 3);
}

// =============================================================================
// Section 2: Levenshtein bounded — early termination at threshold
// =============================================================================

@test
fn test_levenshtein_bounded_within_max() {
    let a = bytes("kitten");
    let b = bytes("sitting");
    let r = levenshtein_bounded(&a, &b, 5);
    assert_eq(r.unwrap(), 3);
}

@test
fn test_levenshtein_bounded_exceeds_max_returns_none() {
    let a = bytes("kitten");
    let b = bytes("sitting");
    let r = levenshtein_bounded(&a, &b, 1);
    assert(r.is_none());
}

// =============================================================================
// Section 3: Jaro — symmetric similarity in [0, 1]
// =============================================================================

@test
fn test_jaro_identical_returns_one() {
    let a = bytes("hello");
    let v = jaro(&a, &a);
    assert(v >= 0.999 && v <= 1.001);
}

@test
fn test_jaro_completely_different_returns_zero() {
    let a = bytes("abc");
    let b = bytes("xyz");
    let v = jaro(&a, &b);
    assert(v >= -0.001 && v <= 0.001);
}

// =============================================================================
// Section 4: Jaro-Winkler — Jaro + prefix bonus
// =============================================================================

@test
fn test_jaro_winkler_identical_returns_one() {
    let a = bytes("hello");
    let v = jaro_winkler(&a, &a);
    assert(v >= 0.999 && v <= 1.001);
}

// =============================================================================
// Section 5: `closest` autocorrect API
// =============================================================================

@test
fn test_closest_returns_exact_match() {
    let dict: List<Text> = ["cat", "car", "bar"].map(|s| s.to_text()).collect();
    assert_eq(closest("car".to_text(), &dict), Some("car".to_text()));
}

@test
fn test_closest_finds_nearest_by_levenshtein() {
    let dict: List<Text> = ["hello", "world", "help"].map(|s| s.to_text()).collect();
    let result = closest("helo".to_text(), &dict);
    assert(result.is_some());
    // distance("helo","hello")=1, distance("helo","world")=4, distance("helo","help")=1
    let best = result.unwrap();
    assert(best == "hello".to_text() || best == "help".to_text());
}

@test
fn test_closest_empty_candidates_returns_none() {
    let dict: List<Text> = [];
    assert(closest("query".to_text(), &dict).is_none());
}

// =============================================================================
// Section 6: Unicode byte-distance contract
// =============================================================================

@test
fn test_ascii_byte_distance_equals_char_distance() {
    // For pure ASCII, byte-level distance = character-level distance
    let a: Bytes = "abc".bytes();
    let b: Bytes = "abd".bytes();
    assert_eq(levenshtein(&a, &b), 1);
}

@test
fn test_empty_vs_nonempty_distance_is_length() {
    let empty: Bytes = [].to_bytes();
    let s: Bytes = "hello".bytes();
    assert_eq(levenshtein(&empty, &s), 5);
    assert_eq(levenshtein(&s, &empty), 5);
}

fn main() {}
