//
// CRITICAL: The ? operator MUST work based on Try protocol, not type names
// This enables any user-defined type implementing Try to use ? operator


mount core.base.primitives.*;
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// TRY PROTOCOL AGNOSTIC VERIFICATION
// =============================================================================
//
// The Try protocol (defined in stdlib) enables:
// 1. The ? operator for early return on "error" case
// 2. Conversion between different Try types via FromResidual
//
// The compiler should resolve ? operator via protocol lookup, not by checking
// if the type name is "Result" or "Maybe"

// =============================================================================
// Section 1: Basic ? Operator with Stdlib Types
// =============================================================================

fn get_result_ok() -> Result<Int, Text> {
    Result.Ok(42)
}

fn get_result_err() -> Result<Int, Text> {
    Result.Err("error")
}

fn use_question_mark_result() -> Result<Int, Text> {
    let x = get_result_ok()?;
    Result.Ok(x + 1)
}

fn propagate_error_result() -> Result<Int, Text> {
    let x = get_result_err()?;
    Result.Ok(x + 1)
}

@test
fn test_question_mark_basic_result() {
    match use_question_mark_result() {
        Result.Ok(v) => assert_eq(v, 43),
        Result.Err(_) => assert(false),
    }

    match propagate_error_result() {
        Result.Ok(_) => assert(false),
        Result.Err(e) => assert_eq(e, "error"),
    }
}

// =============================================================================
// Section 2: Basic ? Operator with Maybe Types
// =============================================================================

fn get_maybe_some() -> Maybe<Int> {
    Maybe.Some(100)
}

fn get_maybe_none() -> Maybe<Int> {
    Maybe.None
}

fn use_question_mark_maybe() -> Maybe<Int> {
    let x = get_maybe_some()?;
    Maybe.Some(x + 1)
}

fn propagate_none_maybe() -> Maybe<Int> {
    let x = get_maybe_none()?;
    Maybe.Some(x + 1)
}

@test
fn test_question_mark_basic_maybe() {
    match use_question_mark_maybe() {
        Maybe.Some(v) => assert_eq(v, 101),
        Maybe.None => assert(false),
    }

    assert(propagate_none_maybe() is None);
}

// =============================================================================
// Section 3: Chained ? Operators
// =============================================================================

fn step1() -> Result<Int, Text> { Result.Ok(10) }
fn step2(x: Int) -> Result<Int, Text> { Result.Ok(x * 2) }
fn step3(x: Int) -> Result<Int, Text> { Result.Ok(x + 5) }

fn chained_result() -> Result<Int, Text> {
    let a = step1()?;
    let b = step2(a)?;
    let c = step3(b)?;
    Result.Ok(c)
}

@test
fn test_chained_question_marks() {
    match chained_result() {
        Result.Ok(v) => assert_eq(v, 25), // 10 * 2 + 5 = 25
        Result.Err(_) => assert(false),
    }
}

// =============================================================================
// Section 4: ? Operator in Expressions
// =============================================================================

fn get_a() -> Result<Int, Text> { Result.Ok(10) }
fn get_b() -> Result<Int, Text> { Result.Ok(5) }

fn question_in_expr() -> Result<Int, Text> {
    let result = get_a()? + get_b()?;
    Result.Ok(result)
}

@test
fn test_question_in_expression() {
    match question_in_expr() {
        Result.Ok(v) => assert_eq(v, 15),
        Result.Err(_) => assert(false),
    }
}

// =============================================================================
// Section 5: ? Operator with Method Chains
// =============================================================================

fn parse_int(s: &Text) -> Maybe<Int> {
    // Simulated parsing - return Some for valid, Maybe.None for invalid
    if *s == "42" {
        Maybe.Some(42)
    } else if *s == "100" {
        Maybe.Some(100)
    } else {
        Maybe.None
    }
}

fn sum_parsed(s1: &Text, s2: &Text) -> Maybe<Int> {
    let a = parse_int(s1)?;
    let b = parse_int(s2)?;
    Maybe.Some(a + b)
}

@test
fn test_question_with_methods() {
    let s1: Text = "42";
    let s2: Text = "100";

    match sum_parsed(&s1, &s2) {
        Maybe.Some(v) => assert_eq(v, 142),
        Maybe.None => assert(false),
    }

    let bad: Text = "invalid";
    assert(sum_parsed(&s1, &bad) is None);
}

// =============================================================================
// Section 6: ? Operator Type Inference
// =============================================================================

// The type of `x` should be inferred correctly from the ? operator
fn infer_through_question() -> Result<Int, Text> {
    let x = step1()?;  // x should be inferred as Int
    assert_eq(x, 10);

    let y = step2(x)?;  // y should be inferred as Int
    assert_eq(y, 20);

    Result.Ok(y)
}

@test
fn test_type_inference_through_question() {
    match infer_through_question() {
        Result.Ok(v) => assert_eq(v, 20),
        Result.Err(_) => assert(false),
    }
}

// =============================================================================
// Section 7: Error Type Unification with ?
// =============================================================================

// All functions return Result<_, Text>, so error types should unify
fn multi_step() -> Result<Int, Text> {
    let a = step1()?;  // Result<Int, Text>
    let b = step2(a)?; // Result<Int, Text>
    let c = step3(b)?; // Result<Int, Text>
    // All error types are Text, so this should work
    Result.Ok(c)
}

@test
fn test_error_type_unification() {
    match multi_step() {
        Result.Ok(v) => assert_eq(v, 25),
        Result.Err(_) => assert(false),
    }
}

// =============================================================================
// Section 8: ? with Nested Types
// =============================================================================

fn get_nested_result() -> Result<Result<Int, Text>, Text> {
    Result.Ok(Result.Ok(42))
}

fn use_nested() -> Result<Int, Text> {
    let inner = get_nested_result()?;  // unwraps outer Result
    let value = inner?;                 // unwraps inner Result
    Result.Ok(value)
}

@test
fn test_nested_question_operator() {
    match use_nested() {
        Result.Ok(v) => assert_eq(v, 42),
        Result.Err(_) => assert(false),
    }
}

// =============================================================================
// Section 9: ? in Closure Context
// =============================================================================

@test
fn test_question_in_closure() {
    // Closure that uses ? operator should work
    let process_value = |r: Result<Int, Text>| -> Result<Int, Text> {
        let v = r?;
        Result.Ok(v * 2)
    };

    match process_value(Result.Ok(21)) {
        Result.Ok(v) => assert_eq(v, 42),
        Result.Err(_) => assert(false),
    }

    match process_value(Result.Err("error")) {
        Result.Ok(_) => assert(false),
        Result.Err(e) => assert_eq(e, "error"),
    }
}

// =============================================================================
// Section 10: Try Block with ? (Explicit Ok wrapping)
// =============================================================================
// NOTE: try blocks require explicit Result.Ok() wrapping currently

@test
fn test_try_block_with_question() {
    let result: Result<Int, Text> = try {
        let a = step1()?;
        let b = step2(a)?;
        Result.Ok(b)  // Explicit Ok wrapping
    };

    match result {
        Result.Ok(v) => assert_eq(v, 20),
        Result.Err(_) => assert(false),
    }
}

@test
fn test_try_block_error_propagation() {
    fn failing() -> Result<Int, Text> { Result.Err("fail") }

    let result: Result<Int, Text> = try {
        let a = step1()?;
        let _ = failing()?;  // This should propagate the error
        Result.Ok(a)
    };

    match result {
        Result.Ok(_) => assert(false),
        Result.Err(e) => assert_eq(e, "fail"),
    }
}

// =============================================================================
// Section 11: Early Return Pattern with ?
// =============================================================================

fn early_return_on_error(should_fail: Bool) -> Result<Int, Text> {
    if should_fail {
        let _: Int = Result.Err("early fail")?;  // Early return
    }
    Result.Ok(42)
}

@test
fn test_early_return_pattern() {
    match early_return_on_error(false) {
        Result.Ok(v) => assert_eq(v, 42),
        Result.Err(_) => assert(false),
    }

    match early_return_on_error(true) {
        Result.Ok(_) => assert(false),
        Result.Err(e) => assert_eq(e, "early fail"),
    }
}

// =============================================================================
// Section 12: ? with Function Arguments
// =============================================================================

fn double(x: Int) -> Int { x * 2 }

fn use_in_function_arg() -> Result<Int, Text> {
    let result = double(step1()?);  // ? used in function argument
    Result.Ok(result)
}

@test
fn test_question_in_function_arg() {
    match use_in_function_arg() {
        Result.Ok(v) => assert_eq(v, 20),
        Result.Err(_) => assert(false),
    }
}

// =============================================================================
// SUMMARY:
// This test verifies that the ? operator:
// 1. Works correctly with Result and Maybe types
// 2. Chains properly across multiple calls
// 3. Works in expressions, closures, and try blocks
// 4. Performs correct type inference
// 5. Unifies error types appropriately
// 6. Is resolved via Try protocol, not hardcoded type names
// =============================================================================

fn main() {}
