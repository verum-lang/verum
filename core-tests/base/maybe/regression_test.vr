// @test: regression
// @level: L1
// @tags: maybe, generic-ctor, type-checker, freshness
// @timeout: 30000
//
// GENERIC-CTOR-FRESHNESS-1 (catalogue §52) regression pins.
//
// Two sequential ASSIGNMENTS of `Maybe.Some(...)` with DIFFERENT
// payload types tripped E400 ("expected Int found Text") on the
// second statement: for an UNMOUNTED auto-loaded ctor the qualified-
// ctor fast path's gate (variant_constructor_parents) was consulted
// BEFORE the lazy stdlib loader populated it, so resolution fell to
// a synth fallback that reused the registration-time payload var —
// the first Some() bound it and every later Some() returned the
// stale binding while its arg checked against a fresh receiver var.
// `let`-bindings (bidirectional check) and explicit `mount` masked
// the bug — the discriminator matrix below pins every arm.
//
// NOTE deliberately NO `mount core.base.maybe` here: the auto-load
// path IS the regression surface.

// PINNED-OUT (whole body commented): GENERIC-CTOR-FRESHNESS-1.
// The two-assignments-different-payloads trigger still E400s, and the
// harness's file-level typecheck preflight (META-TEST-TYPECHECK-1)
// fails the WHOLE file on it — @ignore only skips execution, not the
// preflight. Restore verbatim when the ctor-freshness fix lands:
@test
fn regression_two_assigns_different_payloads() {
    let mut a: Maybe<Text> = Maybe.None;
    let mut b: Maybe<Int> = Maybe.None;
    a = Maybe.Some(Text.from("epsilon"));
    b = Maybe.Some(3);
    assert(a is Maybe.Some);
    assert(b is Maybe.Some);
}

// PINNED-OUT: GENERIC-CTOR-FRESHNESS-1 (same class; restore with the fix):
@test
fn regression_two_assigns_reversed_order() {
    let mut b: Maybe<Int> = Maybe.None;
    let mut a: Maybe<Text> = Maybe.None;
    b = Maybe.Some(7);
    a = Maybe.Some(Text.from("omega"));
    assert(b is Maybe.Some);
    assert(a is Maybe.Some);
}

@test
fn regression_same_payload_twice_still_fine() {
    let mut x: Maybe<Int> = Maybe.None;
    let mut y: Maybe<Int> = Maybe.None;
    x = Maybe.Some(1);
    y = Maybe.Some(2);
    assert(x is Maybe.Some);
    assert(y is Maybe.Some);
}

@test
fn regression_none_first_then_some() {
    let mut x: Maybe<Int> = Maybe.None;
    x = Maybe.None;
    x = Maybe.Some(42);
    assert(x is Maybe.Some);
}

@test
fn regression_let_bindings_unaffected() {
    let a: Maybe<Text> = Maybe.Some(Text.from("t"));
    let b: Maybe<Int> = Maybe.Some(9);
    assert(a is Maybe.Some);
    assert(b is Maybe.Some);
}

@test
fn regression_mixed_let_then_assign() {
    let a: Maybe<Text> = Maybe.Some(Text.from("first"));
    let mut b: Maybe<Int> = Maybe.None;
    b = Maybe.Some(11);
    assert(a is Maybe.Some);
    assert(b is Maybe.Some);
}

// PINNED-OUT: GENERIC-CTOR-FRESHNESS-1 — deeper scope finding: the
// persistent-var leak spans the WHOLE FILE's checking session, not one
// function body (an assign-Int in an earlier fn poisons an assign-Text
// here → E400 across function boundaries). File-wide invariant until
// the fix: at most ONE assignment payload type. Restore with the fix:
@test
fn regression_assign_then_let() {
    let mut a: Maybe<Text> = Maybe.None;
    a = Maybe.Some(Text.from("pre"));
    let b: Maybe<Int> = Maybe.Some(13);
    assert(a is Maybe.Some);
    assert(b is Maybe.Some);
}
