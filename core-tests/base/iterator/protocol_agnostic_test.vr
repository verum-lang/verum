// =============================================================================
// Section 7: Enumerate
// =============================================================================

@test
fn test_enumerate() {
    let list = List.from(["a", "b", "c"]);
    let mut index_sum = 0;

    for (idx, _) in list.iter().enumerate() {
        index_sum = index_sum + idx;
    }

    assert_eq(index_sum, 3);  // 0 + 1 + 2
}

// =============================================================================
// Section 8: Zip
// =============================================================================

@test
fn test_zip_iteration() {
    let a = [1, 2, 3];
    let b = [10, 20, 30];
    let mut sum = 0;

    for (x, y) in a.iter().zip(b.iter()) {
        sum = sum + *x + *y;
    }

    assert_eq(sum, 66);  // (1+10) + (2+20) + (3+30)
}

// =============================================================================
// Section 9: Collect
// =============================================================================

@test
fn test_collect_to_list() {
    let arr = [1, 2, 3, 4, 5];

    // Map and collect should work
    let doubled: List<Int> = arr.iter().map(|x| *x * 2).collect();

    let mut sum = 0;
    for x in doubled.iter() {
        sum = sum + *x;
    }

    assert_eq(sum, 30);  // 2 + 4 + 6 + 8 + 10
}

// =============================================================================
// Section 10: Fold/Reduce
// =============================================================================

@test
fn test_fold() {
    let list = List.from([1, 2, 3, 4, 5]);

    let sum = list.iter().fold(0, |acc, x| acc + *x);
    assert_eq(sum, 15);
}

@test
fn test_fold_with_initial() {
    let list = List.from([1, 2, 3]);

    let product = list.iter().fold(1, |acc, x| acc * *x);
    assert_eq(product, 6);  // 1 * 2 * 3
}

// =============================================================================
// Section 11: Find and Position
// =============================================================================

@test
fn test_find() {
    let list = List.from([1, 2, 3, 4, 5]);

    match list.iter().find(|x| **x > 3) {
        Some(v) => assert_eq(*v, 4),
        None => assert(false),
    }

    let not_found = list.iter().find(|x| **x > 10);
    assert(not_found is None);
}

// =============================================================================
// Section 12: Any and All
// =============================================================================

@test
fn test_any() {
    let list = List.from([1, 2, 3, 4, 5]);

    let has_even = list.iter().any(|x| *x % 2 == 0);
    assert(has_even);

    let has_negative = list.iter().any(|x| *x < 0);
    assert(!has_negative);
}

@test
fn test_all() {
    let list = List.from([2, 4, 6, 8]);

    let all_even = list.iter().all(|x| *x % 2 == 0);
    assert(all_even);

    let all_less_than_5 = list.iter().all(|x| *x < 5);
    assert(!all_less_than_5);
}

// =============================================================================
// Section 13: Count
// =============================================================================

@test
fn test_count() {
    let list = List.from([1, 2, 3, 4, 5]);

    let count = list.iter().count();
    assert_eq(count, 5);
}

// =============================================================================
// Section 14: Chain
// =============================================================================

@test
fn test_chain() {
    let a = [1, 2, 3];
    let b = [4, 5, 6];
    let mut sum = 0;

    for x in a.iter().chain(b.iter()) {
        sum = sum + *x;
    }

    assert_eq(sum, 21);  // 1 + 2 + 3 + 4 + 5 + 6
}

