// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: iterator, protocol, stdlib-agnostic, for-loop
// @description: Tests Iterator protocol is stdlib-agnostic (no hardcoded List/Array names)

module specs.stdlib.core.iterator_protocol_agnostic_test;

mount core.prelude.*;
mount core.collections.list.List;

// =============================================================================
// ITERATOR PROTOCOL AGNOSTIC VERIFICATION
// =============================================================================
//
// The Iterator protocol should work with any type that implements it,
// not just hardcoded List, Array, etc.
//
// Key Protocol Definition:
// protocol Iterator {
//     type Item;
//     fn next(&mut self) -> Maybe<Self.Item>;
// }

// =============================================================================
// Section 1: Built-in Collection Iteration
// =============================================================================

@test
fn test_list_iteration() {
    let list = List.from([1, 2, 3, 4, 5]);
    let mut sum = 0;

    for x in list.iter() {
        sum = sum + *x;
    }

    assert_eq(sum, 15);
}

@test
fn test_array_iteration() {
    let arr = [10, 20, 30, 40, 50];
    let mut sum = 0;

    for x in arr.iter() {
        sum = sum + *x;
    }

    assert_eq(sum, 150);
}

// =============================================================================
// Section 2: Range Iteration
// =============================================================================

@test
fn test_range_iteration() {
    let mut sum = 0;

    // 0..5 produces 0, 1, 2, 3, 4
    for i in 0..5 {
        sum = sum + i;
    }

    assert_eq(sum, 10);  // 0 + 1 + 2 + 3 + 4
}

@test
fn test_inclusive_range_iteration() {
    let mut sum = 0;

    // 1..=5 produces 1, 2, 3, 4, 5
    for i in 1..=5 {
        sum = sum + i;
    }

    assert_eq(sum, 15);  // 1 + 2 + 3 + 4 + 5
}

// =============================================================================
// Section 3: Iterator Methods
// =============================================================================

@test
fn test_iterator_map() {
    let list = List.from([1, 2, 3]);
    let mut doubled_sum = 0;

    // Map should work on any iterator
    for x in list.iter().map(|n| *n * 2) {
        doubled_sum = doubled_sum + x;
    }

    assert_eq(doubled_sum, 12);  // 2 + 4 + 6
}

@test
fn test_iterator_filter() {
    let list = List.from([1, 2, 3, 4, 5, 6]);
    let mut even_sum = 0;

    // Filter should work on any iterator
    for x in list.iter().filter(|n| *n % 2 == 0) {
        even_sum = even_sum + *x;
    }

    assert_eq(even_sum, 12);  // 2 + 4 + 6
}

@test
fn test_iterator_take() {
    let mut sum = 0;

    // Take first 3 elements from infinite range
    for i in (0..).take(3) {
        sum = sum + i;
    }

    assert_eq(sum, 3);  // 0 + 1 + 2
}

@test
fn test_iterator_skip() {
    let list = List.from([1, 2, 3, 4, 5]);
    let mut sum = 0;

    // Skip first 2 elements
    for x in list.iter().skip(2) {
        sum = sum + *x;
    }

    assert_eq(sum, 12);  // 3 + 4 + 5
}

// =============================================================================
// Section 4: Nested Iteration
// =============================================================================

@test
fn test_nested_iteration() {
    let mut count = 0;

    for i in 0..3 {
        for j in 0..3 {
            count = count + 1;
        }
    }

    assert_eq(count, 9);  // 3 * 3
}

@test
fn test_nested_list_iteration() {
    let outer = List.from([1, 2]);
    let inner = List.from([10, 20, 30]);
    let mut sum = 0;

    for x in outer.iter() {
        for y in inner.iter() {
            sum = sum + *x * *y;
        }
    }

    // (1*10 + 1*20 + 1*30) + (2*10 + 2*20 + 2*30) = 60 + 120 = 180
    assert_eq(sum, 180);
}

// =============================================================================
// Section 5: Early Break and Continue
// =============================================================================

@test
fn test_break_in_iteration() {
    let mut sum = 0;

    for i in 0..100 {
        if i >= 5 {
            break;
        }
        sum = sum + i;
    }

    assert_eq(sum, 10);  // 0 + 1 + 2 + 3 + 4
}

@test
fn test_continue_in_iteration() {
    let mut sum = 0;

    for i in 0..10 {
        if i % 2 != 0 {
            continue;  // Skip odd numbers
        }
        sum = sum + i;
    }

    assert_eq(sum, 20);  // 0 + 2 + 4 + 6 + 8
}

// =============================================================================
// Section 6: Iterator with Pattern Matching
// =============================================================================

