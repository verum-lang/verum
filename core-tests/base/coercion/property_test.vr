// =============================================================================
// core-tests/base/coercion/property_test.vr
// =============================================================================
//
// Algebraic-law verification for `core/base/coercion.vr`. The protocols
// are markers, so the "laws" here are about the *coercion rules* the
// markers gate, not about methods on the markers themselves.
//
// Laws verified (each via observable typechecking + runtime behaviour):
//   §A  Reflexive coercion        Int → Int is always identity
//   §B  IntCoercible round-trip   Type → Int → Type preserves canonical
//                                 representation when conversion is lossless
//   §C  TensorLike scalar absorb  Float operates as Tensor<Float>(scalar)
//   §D  Indexable produces Int    `t[i]` typechecks where `i: Int`
//   §E  RangeLike preserves bounds  range.lo ≤ range.hi for valid ranges
// =============================================================================

mount core.prelude.*;
mount core.base.coercion.{IntCoercible, TensorLike, Indexable, RangeLike};
mount core.collections.list.List;

// =============================================================================
// §A  Reflexive identity coercion: Int ↔ Int via IntCoercible.
// =============================================================================

@test
fn law_int_coercible_reflexive_identity() {
    // Plain Int trivially "coerces" to Int via the identity. No
    // marker required; this is the unification-level no-op that
    // every marker rule must respect.
    let n: Int = 42;
    let m: Int = n;
    assert_eq(n, m);
}

// =============================================================================
// §B  IntCoercible round-trip preservation.
//
// Pattern: a type that wraps an Int can be reconstituted from its
// integer representation via From<Int> + the IntCoercible marker.
// Without the marker, the unifier would refuse the implicit
// conversion at any use site that mixes the wrapper and Int.
// =============================================================================

type Port is { number: Int };

implement IntCoercible for Port {}

implement From<Int> for Port {
    fn from(n: Int) -> Port {
        Port { number: n }
    }
}

@test
fn law_int_coercible_round_trip_preserves_value() {
    let cases: List<Int> = [0, 1, 80, 443, 65535];
    for n in cases.iter() {
        let p: Port = Port.from(*n);
        assert_eq(p.number, *n);
    }
}

// =============================================================================
// §C  TensorLike marker is reflexive over a scalar.
// =============================================================================

type Scalar is { value: Float };

implement TensorLike for Scalar {}

@test
fn law_tensor_like_round_trip_scalar() {
    let s: Scalar = Scalar { value: 3.14 };
    assert(s.value > 3.0 && s.value < 4.0);
}

// =============================================================================
// §D  Indexable preserves index validity over typical ranges.
// =============================================================================

type FixedArray is { data: List<Int> };

implement Indexable for FixedArray {}

@test
fn law_indexable_index_in_bounds() {
    let arr = FixedArray { data: [10, 20, 30, 40, 50] };
    let n = arr.data.len();
    let mut i = 0;
    while i < n {
        let v = arr.data[i];
        assert(v >= 10 && v <= 50);
        i = i + 1;
    }
}

// =============================================================================
// §E  RangeLike: range bounds are preserved under construction.
// =============================================================================

type Bounds is { lo: Int, hi: Int };

implement RangeLike for Bounds {}

@test
fn law_range_like_bounds_preserved() {
    let cases: List<(Int, Int)> = [(0, 10), (-5, 5), (100, 100), (Int.MIN, Int.MAX)];
    for c in cases.iter() {
        let (lo, hi) = *c;
        let b = Bounds { lo: lo, hi: hi };
        assert_eq(b.lo, lo);
        assert_eq(b.hi, hi);
        // Either lo ≤ hi (non-empty range) or lo == hi+1 etc.
        // The marker doesn't enforce non-emptiness — it only marks
        // the shape.
    }
}

// =============================================================================
// §F  @property — round-trip via From<Int> over the full Int axis.
// =============================================================================

@property
fn prop_port_round_trip_int(n: Int) {
    let p: Port = Port.from(n);
    assert_eq(p.number, n);
}

@property
fn prop_bounds_preserve_int_pair(lo: Int, hi: Int) {
    let b = Bounds { lo: lo, hi: hi };
    assert_eq(b.lo, lo);
    assert_eq(b.hi, hi);
}

// =============================================================================
// §G  Parametrised — concrete (input, expected) pairs for marker round-trips.
// =============================================================================

@test_case(0)
@test_case(80)
@test_case(443)
@test_case(8080)
@test_case(65535)
@test_case(-1)        // negative is allowed at the type level
@test_case(Int.MAX)
@test_case(Int.MIN)
fn parametrised_port_round_trip(n: Int) {
    let p: Port = Port.from(n);
    assert_eq(p.number, n);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
