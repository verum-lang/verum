// =============================================================================
// core-tests/base/serde/unit_test.vr
// =============================================================================
//
// Tests for `core.base.serde` — Serialize / Deserialize protocol surface,
// SerdeError variants, helper Serializer / Deserializer types.
// Concrete backends (json, binary) live in `core.encoding.*` — those are
// tested in their own folders.
// =============================================================================

mount core.prelude.*;
mount core.base.serde.{
    SerdeError, Serialize, Deserialize, Serializer, Deserializer,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: SerdeError construction
// =============================================================================

@test
fn test_serde_error_new_preserves_message() {
    let e = SerdeError.new("custom message".to_text());
    assert(e.message.contains("custom message"));
}

@test
fn test_serde_error_unexpected_type() {
    let e = SerdeError.unexpected_type(&"Int".to_text(), &"Text".to_text());
    assert(e.message.contains("Int"));
    assert(e.message.contains("Text"));
}

@test
fn test_serde_error_missing_field() {
    let e = SerdeError.missing_field(&"username".to_text());
    assert(e.message.contains("username"));
}

@test
fn test_serde_error_unknown_field() {
    let e = SerdeError.unknown_field(&"xyzzy".to_text());
    assert(e.message.contains("xyzzy"));
}

// =============================================================================
// Section 2: Custom Serialize / Deserialize impl
// =============================================================================

type Point is { x: Int, y: Int };

// Note: Concrete Serializer/Deserializer impls require backend-specific
// types (verum_codegen::serde_helpers etc.). These tests verify the
// PROTOCOL SHAPE compiles cleanly — actual serialization round-trips are
// in core-tests/encoding/<backend>.

@test
fn test_serialize_protocol_signature_compiles() {
    // Just verify the protocol can be implemented in user code.
    // We don't construct a Serializer here — that requires a backend.
    let _: Point = Point { x: 1, y: 2 };
}

fn main() {}
