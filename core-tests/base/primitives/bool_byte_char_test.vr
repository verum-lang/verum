@test
fn test_unit_eq_protocol() {
    assert(() == ());
    assert(!((() != ())));
}

@test
fn test_unit_ord_protocol() {
    // All units are equal
    assert_eq(().cmp(&()), Equal);
    assert(() <= ());
    assert(() >= ());
    assert(!(() < ()));
    assert(!(() > ()));
}

@test
fn test_unit_default() {
    assert_eq(().default(), ());
}

@test
fn test_unit_clone_copy() {
    let x = ();
    let y = x.clone();
    assert_eq(x, y);

    let z = x;
    assert_eq(x, ());
    assert_eq(z, ());
}

// =============================================================================
// ASCII TABLE COMPLETENESS TEST
// =============================================================================

@test
fn test_ascii_table_coverage() {
    // Verify classification for entire ASCII range
    let mut i = 0;
    while i < 128 {
        let b = i as Byte;

        // At least one classification should apply or be false
        let is_alpha = b.is_ascii_alphabetic();
        let is_digit = b.is_ascii_digit();
        let is_space = b.is_ascii_whitespace();

        // Alphanumeric should be union of alpha and digit
        assert_eq(b.is_ascii_alphanumeric(), is_alpha || is_digit);
        i = i + 1;
    }
}

@test
fn test_byte_char_consistency() {
    // For ASCII range, Byte and Char classifications should agree
    let mut i = 0;
    while i < 128 {
        let b = i as Byte;
        let c = i as Char;

        // is_ascii should always be true
        assert(c.is_ascii());

        // ASCII-specific checks match
        assert_eq(b.is_ascii_alphabetic(), c.is_alphabetic() && c.is_ascii());
        assert_eq(b.is_ascii_digit(), c.is_numeric() && c.is_ascii());
        i = i + 1;
    }
}

fn main() {
    print("Bool, Byte, Char, Unit primitive tests loaded successfully");
}
