// =============================================================================
// regression_test.vr — primitives regression pins (one @test per past defect)
// =============================================================================
//
// Contract: every defect we have ever seen in primitive-type behaviour gets a
// one-test-per-bug entry here.  Tests are kept forever even after the
// underlying issue is fixed — they become guardrails against re-regression.
//
// Naming: `regression_<short-description>_pinned` so the test name carries the
// bug shape.  Each test starts with a `// REGRESSION:` comment naming the
// defect, its surface site, and the closing commit / task reference.

mount core.prelude.*;
mount core.base.ordering.{Less, Equal, Greater};

// =============================================================================
// Char.from_digit — canonical lowercase contract
// =============================================================================

// REGRESSION: pre-fix two `Char.from_digit` definitions existed in the stdlib
// — `core/base/primitives.vr` returned UPPERCASE letters (`A`..=`Z`) and
// `core/text/char.vr` returned LOWERCASE (`a`..=`z`).  archive_ctx_loader
// registered bare `Char.from_digit` first-wins, picking whichever loaded
// first.  Closed in task #22 §C (commit 24c4e0155) by aligning primitives.vr
// to lowercase, matching the standard convention shared with Rust / Swift /
// Python.  Architectural rule pinned in the stdlib docstrings: there must be
// EXACTLY ONE `Char.from_digit` definition; the canonical home is
// `core/text/char.vr`.  Callers that need uppercase output should chain
// `.to_ascii_uppercase()`.
@test
fn regression_char_from_digit_returns_lowercase_pinned() {
    assert_eq(Char.from_digit(10, 16), Some('a'));
    assert_eq(Char.from_digit(15, 16), Some('f'));
    assert_eq(Char.from_digit(35, 36), Some('z'));
    assert_eq(Char.from_digit(11, 16).unwrap().to_ascii_uppercase(), 'B');
}

// =============================================================================
// `as Byte` cast carries target type to method dispatch
// =============================================================================

// REGRESSION: pre-fix `(N as Byte).<method>(M as Byte)` collapsed every
// primitive-sized-int cast receiver to the Int handler because the codegen's
// `effective_method_name` cascade had no `ExprKind::Cast` arm — receivers
// fell through to the final bare-`method.name` else arm, and the runtime
// CallM dispatcher resolved by the receiver's NaN-boxed Int kind alone.
//
// Three-site codegen fix:
//   * Cast arm in `extract_expr_type_name` so the cast's target type
//     propagates to every downstream type-name extraction.
//   * Cast arm in `infer_expr_type_name` paired with the above so the two
//     type-extraction functions agree on cast semantics.
//   * Cast arm in `effective_method_name`'s cascade (Case 6c) emitting the
//     same width-suffixed form Case 1a uses for typed-let receivers
//     (`byte$method` / `int32$method` / `uint64$method` for sized-int
//     targets).
//
// Defense-in-depth: width-prefix normalisation in the runtime
// `dispatch_primitive_method` rewrites `Byte.method` / `UInt8.method` etc.
// to `byte$method` before the prefix-strip-and-dispatch step.
//
// Architectural rule pinned: `as TargetType` MUST propagate `TargetType` to
// every type-extraction site AND the runtime dispatcher MUST honour
// qualified-prefix width information for sized-int primitives that share
// the NaN-boxed Int runtime kind.

// Cast-as-receiver, `wrapping_add` — must wrap modulo 256 (u8 semantics).
// Pre-fix returned 300 (Int.wrapping_add no-op = regular add).
@test
fn regression_as_byte_cast_wrapping_add_uses_u8_modulo_pinned() {
    assert_eq((255 as Byte).wrapping_add(1 as Byte), 0 as Byte);
    assert_eq((200 as Byte).wrapping_add(100 as Byte), 44 as Byte);
    assert_eq((255 as Byte).wrapping_add(255 as Byte), 254 as Byte);
}

// Cast-as-receiver, `checked_add` — must overflow at u8::MAX.
// Pre-fix returned Some(256) (Int.checked_add no overflow until i64::MAX).
@test
fn regression_as_byte_cast_checked_add_overflows_at_u8_max_pinned() {
    assert_eq((100 as Byte).checked_add(50 as Byte), Some(150 as Byte));
    assert_eq((255 as Byte).checked_add(1 as Byte), None);
    assert_eq((200 as Byte).checked_add(100 as Byte), None);
}

// Cast-as-receiver, `saturating_add` — must saturate at u8::MAX.
// Pre-fix returned 256 / 260 / 510 etc. (Int.saturating_add saturates at
// i64::MAX, not u8::MAX).
//
// STILL OPEN: `saturating_add` is emitted as a direct
// `ArithExtendedOpcode(SaturatingAdd)` bytecode opcode (not a CallM), so
// it bypasses both the codegen Cast arm AND the runtime prefix-rewrite.
// The bytecode opcode reads a width byte from the stream, which the
// codegen currently sets from the bare `saturating_add` intrinsic
// definition (width=0 → i64) rather than from the cast-target width
// (width=8 → u8).  The fix requires width propagation through the
// intrinsic-emission path in `compile_intrinsic_call` or equivalent.
// Tracked as §A residual in `core-tests/base/primitives/audit.md`.
@ignore
@test
fn regression_as_byte_cast_saturating_add_saturates_at_u8_max_pinned() {
    assert_eq((100 as Byte).saturating_add(50 as Byte), 150 as Byte);
    assert_eq((255 as Byte).saturating_add(1 as Byte), 255 as Byte);
    assert_eq((200 as Byte).saturating_add(100 as Byte), 255 as Byte);
    assert_eq((255 as Byte).saturating_add(255 as Byte), 255 as Byte);
}

// =============================================================================
// Byte alias dispatch — UInt8.<method> normalises to byte$<method>
// =============================================================================

// REGRESSION: pre-fix `UInt8.<method>` qualified-name CallM dispatch
// short-circuited at the early `is_builtin_prefix` gate in
// `dispatch_primitive_method` because UInt8 (and its aliases U8/u8/I8/i8/
// UInt16/U16/u16/Int16/I16/i16/I32/i32/U64/u64/Int64/I64/i64/UInt128/U128/
// u128/Int128/I128/i128/USize/UIntSize/Usize/usize/ISize/IntSize/Isize/
// isize) was missing from the allowlist.  The gate returned `Ok(None)`
// before the width-prefix normaliser at the same function could rewrite
// `UInt8.<method>` to `byte$<method>`.
//
// Surface site: `let lower = (b as Byte); lower.to_ascii_uppercase()`
// — typechecker stamps `UInt8.to_ascii_uppercase` as the resolved
// static call (UInt8 is Byte's canonical name in `NUMERIC_ALIAS_MATRIX`),
// but the runtime dispatcher rejected `UInt8.<method>` and panicked
// with `method 'UInt8.to_ascii_lowercase' not found on receiver of
// runtime kind Int`.
//
// Closed by extending the `is_builtin_prefix` allowlist with every
// sized-int alias spelling (canonical + uppercase-short + Rust-style
// lowercase, for both signed and unsigned widths 8/16/32/64/128 +
// pointer-width USize/ISize).  Now every qualified-prefix sized-int
// CallM reaches the width-prefix normaliser and routes to the correct
// byte$/int32$/uint64$ arm.
//
// Architectural rule pinned: every sized-int alias the
// `NUMERIC_ALIAS_MATRIX` recognises as a Byte/Int32/UInt64 alias MUST
// be in `dispatch_primitive_method`'s `is_builtin_prefix` allowlist so
// the runtime dispatcher honours qualified CallM forms regardless of
// which alias spelling the codegen / typechecker resolved.
@test
fn regression_byte_alias_dispatch_through_normaliser_pinned() {
    // Round-trip via UInt8 canonical name (the form the typechecker
    // resolves to when the receiver carries the `Byte` alias).
    let lower: Byte = 97;
    let upper = lower.to_ascii_uppercase();
    assert_eq(upper, 65 as Byte);

    let round_trip = upper.to_ascii_lowercase();
    assert_eq(round_trip, 97 as Byte);

    // Cast-receiver form — exercises both my Cast arm (Case 6c) AND the
    // runtime prefix-normaliser path.
    let r = (98 as Byte).to_ascii_uppercase();
    assert_eq(r, 66 as Byte);
}

// =============================================================================
// Unit `()` receiver — protocol-default dispatch
// =============================================================================

// REGRESSION: pre-fix `().cmp(&())` panicked with `method 'Once.next' not
// found on receiver of runtime kind ()` because the dispatcher's
// bare-method suffix-scan picked the `Iterator.cmp` default body
// (monomorphised onto `Once<T>`) over the inherent `implement Ord for ()
// { fn cmp(...) }` impl.  Iterator.cmp's body executes `self.next()`
// → `CallM { method_id: "Once.next" }` (because the body was
// monomorphised with `self_type = Once`), and Unit has no `.next` method.
//
// Same defect class affected every protocol method on `()`: Eq.eq /
// Ord.cmp / Hash.hash_value / Clone.clone / Default.default / Display.fmt
// were all reachable but routed unpredictably depending on
// HashMap-iteration-order of the function table.
//
// Closed by a Unit-receiver intercept in
// `dispatch_primitive_method` that returns the mathematical identity
// for each protocol method.  `()` has exactly one value, so every method
// reduces to a constant:
//
//   * `().cmp(&())  == Equal`, `() == ()`, `() <= ()`, etc.
//   * `().hash_value() == fxhash_bytes(0, &[])` (seed-0 unchanged).
//   * `().clone() == ()`, `Unit.default() == ()`.
//   * `f"{()}" == "()"` (Display.fmt).
//
// Architectural rule pinned: every primitive's protocol-default surface
// MUST be reachable through `dispatch_primitive_method` so the
// function-table-side suffix-scan never wins over the canonical
// primitive intercept.
@test
fn regression_unit_receiver_dispatch_pinned() {
    // Ord — closed by Unit-receiver intercept (`cmp` arm).
    assert_eq(().cmp(&()), Equal);
    assert(() <= ());
    assert(() >= ());
    assert(!(() < ()));
    assert(!(() > ()));

    // Eq — closed by Unit-receiver intercept (`eq`/`ne` arms).
    assert(() == ());
    assert(!(() != ()));

    // Default — `Unit.default()` returns `()`.
    assert_eq(().default(), ());

    // Clone — identity.
    let u = ();
    let cloned = u.clone();
    assert_eq(cloned, ());
}

// REGRESSION: same defect class on let-binding form — `let a = 255 as Byte;`
// then `a.method(b)` also routed through Int's handler because the cast's
// target type wasn't propagated when the binding's RHS expression type was
// extracted.  The let-binding RHS type-inference (`compile_let::expr_type`)
// folds primitive integer widths to `VarTypeKind::Int`, losing the Byte
// specificity even with my Cast arm in `extract_expr_type_name`.
//
// PARTIAL FIX: `let c: Byte = 255 as Byte` (explicit annotation) works
// correctly because `annotation_type` at `compile_let:314` recognises
// `Byte`/`UInt8`/`U8`/`u8` and emits `VarTypeKind::Byte`.  Unannotated
// `let a = 255 as Byte` still drops to `VarTypeKind::Int` per the existing
// `infer_expr_type_kind` Cast arm folding to `TypeKind::Int`.
//
// STILL OPEN for unannotated form — needs a width-preserving
// `VarTypeKind`-from-cast-target step in `compile_let`.  Tracked as §A
// residual in `core-tests/base/primitives/audit.md`.
@ignore
@test
fn regression_let_bound_as_cast_propagates_type_pinned() {
    let a = 255 as Byte;
    let b = 1 as Byte;
    assert_eq(a.wrapping_add(b), 0 as Byte);

    let c = 200 as Byte;
    let d = 100 as Byte;
    assert_eq(c.wrapping_add(d), 44 as Byte);
}
