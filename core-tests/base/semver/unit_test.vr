// =============================================================================
// core-tests/base/semver/unit_test.vr
// =============================================================================
//
// Tests for `core.base.semver` — SemVer 2.0.0 parser, comparator,
// and formatter (https://semver.org/spec/v2.0.0.html).
//
// **Important dispatch defect surfaced in this branch**: bare-name
// `parse` mis-dispatches via task #17/#39's first-suffix-wins root
// — both `core.base.semver.parse` (returning `Result<SemVer, SemVerError>`)
// and another stdlib module's bare `parse` (returning `ParsedType`)
// resolve through the same `lookup_function` call. The dispatcher
// picks the wrong sibling; `parse(&"1.2.3")` returns a `ParsedType`
// and `.unwrap()` panics with:
//   method 'ParsedType.unwrap' not found on receiver of runtime kind
//   `ParsedType` ... 5 candidate(s) end with `.unwrap` (Maybe / Result /
//   CheckedResult / Poll / ReduceResult)
//
// Workaround in this file: construct SemVer records directly via the
// record-literal `SemVer { ... }` factory instead of going through
// `parse`. Live parsing is pinned `@ignore`'d in `regression_test.vr §A`.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{
    SemVer, SemVerError,
    cmp, format, format_semver,
};
mount core.collections.list.List;

fn mk_semver(major: UInt64, minor: UInt64, patch: UInt64) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: List.new(),
        build_meta:  List.new(),
    }
}

fn mk_semver_pre(major: UInt64, minor: UInt64, patch: UInt64, pre: List<Text>) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: pre,
        build_meta:  List.new(),
    }
}

// =============================================================================
// Section 1: SemVer record construction
// =============================================================================

@test
fn test_construct_zero_version() {
    let v = mk_semver(0_u64, 0_u64, 0_u64);
    assert_eq(v.major, 0_u64);
    assert_eq(v.minor, 0_u64);
    assert_eq(v.patch, 0_u64);
}

@test
fn test_construct_canonical_major_minor_patch() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    assert_eq(v.major, 1_u64);
    assert_eq(v.minor, 2_u64);
    assert_eq(v.patch, 3_u64);
}

@test
fn test_construct_high_major_number() {
    let v = mk_semver(100_u64, 0_u64, 0_u64);
    assert_eq(v.major, 100_u64);
}

@test
fn test_construct_no_prerelease_no_build() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    assert_eq(v.pre_release.len(), 0);
    assert_eq(v.build_meta.len(), 0);
}

@test
fn test_construct_with_prerelease_list() {
    let pre: List<Text> = ["alpha".to_text(), "1".to_text()];
    let v = mk_semver_pre(1_u64, 0_u64, 0_u64, pre);
    assert_eq(v.pre_release.len(), 2);
}

// =============================================================================
// Section 2: cmp ordering
// =============================================================================

@test
fn test_cmp_equal_versions_returns_equal() {
    let a = mk_semver(1_u64, 2_u64, 3_u64);
    let b = mk_semver(1_u64, 2_u64, 3_u64);
    match cmp(&a, &b) {
        Ordering.Equal => {},
        _ => panic("expected Equal for 1.2.3 == 1.2.3"),
    }
}

@test
fn test_cmp_major_difference() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(2_u64, 0_u64, 0_u64);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected Less for 1.0.0 < 2.0.0"),
    }
    match cmp(&b, &a) {
        Ordering.Greater => {},
        _ => panic("expected Greater for 2.0.0 > 1.0.0"),
    }
}

@test
fn test_cmp_minor_difference() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(1_u64, 1_u64, 0_u64);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected Less for 1.0.0 < 1.1.0"),
    }
}

@test
fn test_cmp_patch_difference() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(1_u64, 0_u64, 1_u64);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected Less for 1.0.0 < 1.0.1"),
    }
}

@test
fn test_cmp_prerelease_lower_than_release() {
    // SemVer §11.3: 1.0.0-alpha < 1.0.0 (prerelease < release).
    let a = mk_semver_pre(1_u64, 0_u64, 0_u64, ["alpha".to_text()]);
    let b = mk_semver(1_u64, 0_u64, 0_u64);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected 1.0.0-alpha < 1.0.0"),
    }
}

@test
fn test_cmp_two_prereleases_alphabetic() {
    let a = mk_semver_pre(1_u64, 0_u64, 0_u64, ["alpha".to_text()]);
    let b = mk_semver_pre(1_u64, 0_u64, 0_u64, ["beta".to_text()]);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected alpha < beta"),
    }
}

@test
fn test_cmp_two_prereleases_longer_wins() {
    // §11.4.4: longer pre-release set > shorter when common prefix equal.
    let a = mk_semver_pre(1_u64, 0_u64, 0_u64, ["alpha".to_text()]);
    let b = mk_semver_pre(1_u64, 0_u64, 0_u64, [
        "alpha".to_text(), "1".to_text(),
    ]);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected [alpha] < [alpha.1]"),
    }
}

// =============================================================================
// Section 3: SemVerError variants
// =============================================================================

@test
fn test_error_variants_construction() {
    let _ = SemVerError.Malformed("test".to_text());
    let _ = SemVerError.LeadingZero("major".to_text());
    let _ = SemVerError.InvalidIdentifier("foo".to_text());
    let _ = SemVerError.Overflow("minor".to_text());
}

@test
fn test_error_variants_eq_reflexive() {
    let a = SemVerError.Malformed("test".to_text());
    let b = SemVerError.Malformed("test".to_text());
    assert(a == b);
}

@test
fn test_error_variants_eq_distinct_unequal() {
    let a = SemVerError.Malformed("x".to_text());
    let b = SemVerError.LeadingZero("x".to_text());
    assert(!(a == b));
}

@test
fn test_error_variants_eq_same_variant_different_payload_unequal() {
    let a = SemVerError.Malformed("foo".to_text());
    let b = SemVerError.Malformed("bar".to_text());
    assert(!(a == b));
}

// =============================================================================
// Section 4: format / format_semver aliases
// =============================================================================

@ignore("`format` calls Text.from_utf8_unchecked which was private; visibility fix landed in this branch, activates on next precompiled-stdlib refresh.")
@test
fn test_format_aliases_match() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    // `format_semver` is the backward-compat alias for `format`.
    assert_eq(format(&v), format_semver(&v));
}

@ignore("Same Text.from_utf8_unchecked visibility defect — gated on stdlib refresh.")
@test
fn test_format_zero_version() {
    let v = mk_semver(0_u64, 0_u64, 0_u64);
    let s = format(&v);
    // The canonical zero-version formats to "0.0.0".
    assert_eq(s.len(), 5);   // "0.0.0" has 5 chars
}

fn main() {}
