// =============================================================================
// core-tests/base/semver/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.semver` — cross-type Sort<SemVer>
// ordering, cmp chain composition, and Eq-disjointness scenarios.
//
// All construction uses the direct record-literal `mk_semver` helper
// to bypass the `parse` bare-name dispatch defect (task #17/#39 —
// `regression_test.vr §A`). Live parse + format integration tests
// flip green when the dispatcher closes task #17/#39 AND the
// precompiled stdlib refreshes against the visibility fix to
// `Text.from_utf8_unchecked`.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer, SemVerError, cmp};
mount core.collections.list.List;

fn mk_semver(major: UInt64, minor: UInt64, patch: UInt64) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: List.new(),
        build_meta:  List.new(),
    }
}

// =============================================================================
// Section 1: RFC 2.0.0 §11 precedence — entire ordered chain
// =============================================================================

@test
fn integration_full_rfc_precedence_chain() {
    // RFC 2.0.0 §11 example ordering (release versions only, since
    // bare-cmp on parsed prereleases hits the §A defect):
    //   1.0.0 < 2.0.0 < 2.1.0 < 2.1.1
    let versions: List<SemVer> = [
        mk_semver(1_u64, 0_u64, 0_u64),
        mk_semver(2_u64, 0_u64, 0_u64),
        mk_semver(2_u64, 1_u64, 0_u64),
        mk_semver(2_u64, 1_u64, 1_u64),
    ];
    let mut i: Int = 0;
    while i + 1 < versions.len() {
        let a = versions[i].clone();
        let b = versions[i + 1].clone();
        match cmp(&a, &b) {
            Ordering.Less => {},
            _ => panic("RFC §11 precedence chain broken at position"),
        }
        i = i + 1;
    }
}

// =============================================================================
// Section 2: Sorting List<SemVer> via cmp
// =============================================================================

@test
fn integration_sort_versions_ascending() {
    // The list is built shuffled; after sort, must equal the
    // chronologically-ordered triple.
    let shuffled: List<SemVer> = [
        mk_semver(2_u64, 0_u64, 0_u64),
        mk_semver(1_u64, 0_u64, 0_u64),
        mk_semver(1_u64, 2_u64, 0_u64),
        mk_semver(1_u64, 1_u64, 0_u64),
        mk_semver(2_u64, 1_u64, 0_u64),
    ];
    // Manually bubble-sort using cmp — avoids any List.sort_by
    // closure-dispatch gotcha in the current codegen.
    let mut sorted = shuffled.clone();
    let n = sorted.len();
    let mut i: Int = 0;
    while i < n {
        let mut j: Int = 0;
        while j + 1 < n - i {
            let a = sorted[j].clone();
            let b = sorted[j + 1].clone();
            match cmp(&a, &b) {
                Ordering.Greater => {
                    sorted.set(j,     b);
                    sorted.set(j + 1, a);
                },
                _ => {},
            }
            j = j + 1;
        }
        i = i + 1;
    }
    // sorted[0] must be 1.0.0
    assert_eq(sorted[0].major, 1_u64);
    assert_eq(sorted[0].minor, 0_u64);
    // sorted[4] must be 2.1.0
    assert_eq(sorted[4].major, 2_u64);
    assert_eq(sorted[4].minor, 1_u64);
}

// =============================================================================
// Section 3: cmp chain composition — strict ordering across triples
// =============================================================================

@test
fn integration_cmp_chain_strict_less() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(1_u64, 0_u64, 1_u64);
    let c = mk_semver(1_u64, 1_u64, 0_u64);
    let d = mk_semver(2_u64, 0_u64, 0_u64);
    let ab = match cmp(&a, &b) { Ordering.Less => true, _ => false };
    let bc = match cmp(&b, &c) { Ordering.Less => true, _ => false };
    let cd = match cmp(&c, &d) { Ordering.Less => true, _ => false };
    let ad = match cmp(&a, &d) { Ordering.Less => true, _ => false };
    assert(ab);
    assert(bc);
    assert(cd);
    assert(ad);
}

// =============================================================================
// Section 4: SemVerError in collections
// =============================================================================

@test
fn integration_error_variants_in_list() {
    let errors: List<SemVerError> = [
        SemVerError.Malformed("malformed".to_text()),
        SemVerError.LeadingZero("major".to_text()),
        SemVerError.InvalidIdentifier("pre".to_text()),
        SemVerError.Overflow("minor".to_text()),
    ];
    assert_eq(errors.len(), 4);
}

@test
fn integration_error_variants_eq_within_list() {
    let errors: List<SemVerError> = [
        SemVerError.Malformed("x".to_text()),
        SemVerError.Malformed("x".to_text()),
        SemVerError.Malformed("y".to_text()),
    ];
    assert(errors[0].clone() == errors[1].clone());
    assert(!(errors[0].clone() == errors[2].clone()));
}

// =============================================================================
// Section 5: SemVer record clone preserves all 5 fields
// =============================================================================

@test
fn integration_semver_clone_preserves_record() {
    let v = SemVer {
        major: 1_u64,
        minor: 2_u64,
        patch: 3_u64,
        pre_release: ["rc".to_text(), "1".to_text()],
        build_meta:  ["build".to_text()],
    };
    let c = v.clone();
    assert_eq(c.major, 1_u64);
    assert_eq(c.minor, 2_u64);
    assert_eq(c.patch, 3_u64);
    assert_eq(c.pre_release.len(), 2);
    assert_eq(c.build_meta.len(), 1);
}

fn main() {}
