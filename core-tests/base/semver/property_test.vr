// =============================================================================
// core-tests/base/semver/property_test.vr
// =============================================================================
//
// Algebraic-law verification for SemVer.
// Laws: parse round-trip, total-order axioms, monotonicity by component.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer, parse, cmp, format_semver};
mount core.collections.list.List;

// =============================================================================
// §A  parse ∘ format round-trip on canonical witnesses.
// =============================================================================

@test
fn law_parse_format_round_trip() {
    let cases: List<Text> = [
        "0.0.0".to_text(),
        "1.0.0".to_text(),
        "1.2.3".to_text(),
        "10.20.30".to_text(),
        "1.0.0-alpha".to_text(),
        "1.0.0-alpha.1".to_text(),
        "1.0.0-rc.1+build.abc".to_text(),
    ];
    for s in cases.iter() {
        let v = parse(s).unwrap();
        assert_eq(format_semver(&v), *s);
    }
}

// =============================================================================
// §B  cmp reflexivity.
// =============================================================================

@test
fn law_cmp_reflexive() {
    let cases: List<Text> = [
        "0.0.0".to_text(),
        "1.2.3".to_text(),
        "1.0.0-rc.1".to_text(),
    ];
    for s in cases.iter() {
        let v = parse(s).unwrap();
        assert(cmp(&v, &v).is_equal());
    }
}

// =============================================================================
// §C  cmp anti-symmetry.
// =============================================================================

@test
fn law_cmp_anti_symmetric() {
    let pairs: List<(Text, Text)> = [
        ("1.0.0".to_text(), "2.0.0".to_text()),
        ("1.0.0".to_text(), "1.0.1".to_text()),
        ("1.0.0".to_text(), "1.1.0".to_text()),
        ("1.0.0-alpha".to_text(), "1.0.0".to_text()),
    ];
    for p in pairs.iter() {
        let (a_s, b_s) = (*p);
        let a = parse(&a_s).unwrap();
        let b = parse(&b_s).unwrap();
        let ab = cmp(&a, &b);
        let ba = cmp(&b, &a);
        // sign(ab) == -sign(ba)
        if ab.is_less() { assert(ba.is_greater()); }
        if ab.is_greater() { assert(ba.is_less()); }
        if ab.is_equal() { assert(ba.is_equal()); }
    }
}

// =============================================================================
// §D  cmp transitivity.
// =============================================================================

@test
fn law_cmp_transitive() {
    let a = parse(&"1.0.0".to_text()).unwrap();
    let b = parse(&"1.0.1".to_text()).unwrap();
    let c = parse(&"1.0.2".to_text()).unwrap();
    if cmp(&a, &b).is_less() && cmp(&b, &c).is_less() { assert(cmp(&a, &c).is_less()); }
}

// =============================================================================
// §E  Component monotonicity.
// =============================================================================

@test
fn law_major_dominates_minor() {
    let a = parse(&"2.0.0".to_text()).unwrap();
    let b = parse(&"1.99.99".to_text()).unwrap();
    assert(cmp(&a, &b).is_greater());
}

@test
fn law_minor_dominates_patch() {
    let a = parse(&"1.2.0".to_text()).unwrap();
    let b = parse(&"1.1.99".to_text()).unwrap();
    assert(cmp(&a, &b).is_greater());
}

// =============================================================================
// §F  @test_case — known SemVer comparison fixtures from semver.org spec.
// =============================================================================

@test_case("1.0.0-alpha".to_text(),     "1.0.0-alpha.1".to_text(), -1)
@test_case("1.0.0-alpha.1".to_text(),   "1.0.0-alpha.beta".to_text(), -1)
@test_case("1.0.0-alpha.beta".to_text(), "1.0.0-beta".to_text(), -1)
@test_case("1.0.0-beta".to_text(),      "1.0.0-beta.2".to_text(), -1)
@test_case("1.0.0-beta.2".to_text(),    "1.0.0-beta.11".to_text(), -1)
@test_case("1.0.0-beta.11".to_text(),   "1.0.0-rc.1".to_text(), -1)
@test_case("1.0.0-rc.1".to_text(),      "1.0.0".to_text(), -1)
fn parametrised_prerelease_ordering(a_s: Text, b_s: Text, expected_sign: Int) {
    let a = parse(&a_s).unwrap();
    let b = parse(&b_s).unwrap();
    let n = cmp(&a, &b);
    if expected_sign < 0 { assert(n.is_less()); }
    else if expected_sign > 0 { assert(n.is_greater()); }
    else { assert(n.is_equal()); }
}

// =============================================================================
// §G  Build-metadata MUST be ignored for precedence (RFC §10)
// =============================================================================

@test
fn law_build_metadata_ignored_in_comparison() {
    let a = parse(&"1.0.0+build.1".to_text()).unwrap();
    let b = parse(&"1.0.0+build.2".to_text()).unwrap();
    assert(cmp(&a, &b).is_equal());
}

@test
fn law_prerelease_with_build_lt_release_with_build() {
    let pre = parse(&"1.0.0-alpha+001".to_text()).unwrap();
    let release = parse(&"1.0.0+build.1".to_text()).unwrap();
    assert(cmp(&pre, &release).is_less());
}

@test
fn law_two_releases_with_different_build_metadata_equal() {
    let a = parse(&"2.3.4+sha.aabbcc".to_text()).unwrap();
    let b = parse(&"2.3.4+sha.ddeeff".to_text()).unwrap();
    assert(cmp(&a, &b).is_equal());
}

// =============================================================================
// §H  Remaining RFC §11 ordered list (items 8-11)
// =============================================================================

@test_case("2.0.0".to_text(), "2.1.0".to_text(), -1)
@test_case("2.1.0".to_text(), "2.1.1".to_text(), -1)
@test_case("0.0.1".to_text(), "0.0.2".to_text(), -1)
@test_case("1.0.0".to_text(), "1.0.0".to_text(), 0)
fn parametrised_additional_fixtures(a_s: Text, b_s: Text, expected_sign: Int) {
    let a = parse(&a_s).unwrap();
    let b = parse(&b_s).unwrap();
    let n = cmp(&a, &b);
    if expected_sign < 0 { assert(n.is_less()); }
    else if expected_sign > 0 { assert(n.is_greater()); }
    else { assert(n.is_equal()); }
}

fn main() {}
