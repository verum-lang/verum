// =============================================================================
// core-tests/base/semver/property_test.vr
// =============================================================================
//
// Algebraic-law verification for `core.base.semver` — total-order
// axioms, component monotonicity, SemVer §11 ordering precedence.
//
// All laws use direct record-literal construction via `mk_semver` to
// bypass the `parse` bare-name dispatch defect (task #17/#39 — see
// `regression_test.vr §A`). Live parse/format round-trip is gated on
// task #17/#39 close + Text.from_utf8_unchecked stdlib refresh.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer, cmp};
mount core.collections.list.List;

fn mk_semver(major: UInt64, minor: UInt64, patch: UInt64) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: List.new(),
        build_meta:  List.new(),
    }
}

fn mk_semver_pre(major: UInt64, minor: UInt64, patch: UInt64, pre: List<Text>) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: pre,
        build_meta:  List.new(),
    }
}

// =============================================================================
// §A  cmp reflexivity — every version equals itself.
// =============================================================================

@test
fn law_cmp_reflexive_on_simple_versions() {
    let cases: List<SemVer> = [
        mk_semver(0_u64, 0_u64, 0_u64),
        mk_semver(1_u64, 2_u64, 3_u64),
        mk_semver(100_u64, 200_u64, 300_u64),
    ];
    let mut i: Int = 0;
    while i < cases.len() {
        let v = cases[i].clone();
        match cmp(&v, &v) {
            Ordering.Equal => {},
            _ => panic("cmp must be reflexive"),
        }
        i = i + 1;
    }
}

@test
fn law_cmp_reflexive_on_prerelease_versions() {
    let v = mk_semver_pre(1_u64, 0_u64, 0_u64, ["alpha".to_text()]);
    match cmp(&v, &v) {
        Ordering.Equal => {},
        _ => panic("cmp must be reflexive on prerelease"),
    }
}

// =============================================================================
// §B  cmp anti-symmetry — cmp(a,b) flips when args swapped.
// =============================================================================

@test
fn law_cmp_anti_symmetric_major() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(2_u64, 0_u64, 0_u64);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected Less for 1.0.0 < 2.0.0"),
    }
    match cmp(&b, &a) {
        Ordering.Greater => {},
        _ => panic("expected Greater for 2.0.0 > 1.0.0"),
    }
}

@test
fn law_cmp_anti_symmetric_patch() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(1_u64, 0_u64, 1_u64);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected Less for 1.0.0 < 1.0.1"),
    }
    match cmp(&b, &a) {
        Ordering.Greater => {},
        _ => panic("expected Greater for 1.0.1 > 1.0.0"),
    }
}

// =============================================================================
// §C  Component monotonicity — major dominates minor dominates patch.
// =============================================================================

@test
fn law_major_dominates_minor() {
    let a = mk_semver(2_u64, 0_u64, 0_u64);
    let b = mk_semver(1_u64, 99_u64, 99_u64);
    match cmp(&a, &b) {
        Ordering.Greater => {},
        _ => panic("expected 2.0.0 > 1.99.99"),
    }
}

@test
fn law_minor_dominates_patch() {
    let a = mk_semver(1_u64, 2_u64, 0_u64);
    let b = mk_semver(1_u64, 1_u64, 99_u64);
    match cmp(&a, &b) {
        Ordering.Greater => {},
        _ => panic("expected 1.2.0 > 1.1.99"),
    }
}

@test
fn law_patch_strictly_orders_within_minor() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(1_u64, 0_u64, 1_u64);
    match cmp(&a, &b) {
        Ordering.Less => {},
        _ => panic("expected 1.0.0 < 1.0.1"),
    }
}

// =============================================================================
// §D  SemVer §11.3 — pre-release < release.
// =============================================================================

@test
fn law_prerelease_strictly_less_than_release() {
    let pre = mk_semver_pre(1_u64, 0_u64, 0_u64, ["alpha".to_text()]);
    let rel = mk_semver(1_u64, 0_u64, 0_u64);
    match cmp(&pre, &rel) {
        Ordering.Less => {},
        _ => panic("expected 1.0.0-alpha < 1.0.0"),
    }
}

@test
fn law_prerelease_versions_ordered_alphabetically() {
    let alpha = mk_semver_pre(1_u64, 0_u64, 0_u64, ["alpha".to_text()]);
    let beta  = mk_semver_pre(1_u64, 0_u64, 0_u64, ["beta".to_text()]);
    let rc    = mk_semver_pre(1_u64, 0_u64, 0_u64, ["rc".to_text()]);
    match cmp(&alpha, &beta) {
        Ordering.Less => {},
        _ => panic("expected alpha < beta"),
    }
    match cmp(&beta, &rc) {
        Ordering.Less => {},
        _ => panic("expected beta < rc"),
    }
}

@test
fn law_prerelease_longer_set_greater_than_shorter() {
    // SemVer §11.4.4 — longer pre-release set > shorter when common
    // prefix equal.
    let alpha     = mk_semver_pre(1_u64, 0_u64, 0_u64, ["alpha".to_text()]);
    let alpha_one = mk_semver_pre(1_u64, 0_u64, 0_u64, [
        "alpha".to_text(),
        "1".to_text(),
    ]);
    match cmp(&alpha, &alpha_one) {
        Ordering.Less => {},
        _ => panic("expected [alpha] < [alpha.1]"),
    }
}

// =============================================================================
// §E  Equality preserved by component equality.
// =============================================================================

@test
fn law_cmp_equal_for_same_triple() {
    let a = mk_semver(1_u64, 2_u64, 3_u64);
    let b = mk_semver(1_u64, 2_u64, 3_u64);
    match cmp(&a, &b) {
        Ordering.Equal => {},
        _ => panic("expected Equal for same triple"),
    }
}

@test
fn law_cmp_equal_for_same_prerelease() {
    let a = mk_semver_pre(1_u64, 0_u64, 0_u64, ["rc".to_text()]);
    let b = mk_semver_pre(1_u64, 0_u64, 0_u64, ["rc".to_text()]);
    match cmp(&a, &b) {
        Ordering.Equal => {},
        _ => panic("expected Equal for same prerelease tuple"),
    }
}

// =============================================================================
// §F  Transitivity — cmp(a,b)==Less ∧ cmp(b,c)==Less ⇒ cmp(a,c)==Less.
// =============================================================================

@test
fn law_cmp_transitive_on_patches() {
    let a = mk_semver(1_u64, 0_u64, 0_u64);
    let b = mk_semver(1_u64, 0_u64, 1_u64);
    let c = mk_semver(1_u64, 0_u64, 2_u64);
    let ab_less = match cmp(&a, &b) { Ordering.Less => true, _ => false };
    let bc_less = match cmp(&b, &c) { Ordering.Less => true, _ => false };
    let ac_less = match cmp(&a, &c) { Ordering.Less => true, _ => false };
    if ab_less && bc_less { assert(ac_less); }
}

fn main() {}
