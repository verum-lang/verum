// =============================================================================
// core-tests/base/ulid/property_test.vr
// =============================================================================
//
// Algebraic-law verification for `core.base.ulid` — parse validation,
// alphabet membership, timestamp round-trip via `from_parts`.
//
// Live `Ulid.new()` properties (uniqueness, lex order, length) are
// gated on the `SystemTime.now()` static-method dispatch defect
// (task #17/#39, same as snowflake §D). The `to_text` round-trip
// (and any property depending on the canonical string form) is
// additionally gated on the `Text.from_utf8_unchecked` visibility
// fix landed in this branch (text.vr:455 now `public unsafe fn`)
// activating after the next precompiled-stdlib refresh.
//
// All laws here use deterministic `from_parts(int, int)` inputs and
// the validation surface of `parse`.
// =============================================================================

mount core.prelude.*;
mount core.base.ulid.{Ulid, UlidError, parse, from_parts, ULID_ALPHABET};
mount core.collections.list.List;
mount core.collections.set.Set;

// =============================================================================
// §A  from_parts: pinned timestamp round-trips for representative values.
// =============================================================================

@test
fn law_from_parts_timestamp_round_trips() {
    let ts_cases: List<Int> = [
        0, 1, 1_000, 1_000_000, 1_000_000_000,
        281_474_976_710_655,   // 2^48 - 1 (max 48-bit)
    ];
    let mut i: Int = 0;
    while i < ts_cases.len() {
        let ts = ts_cases[i].clone();
        let u = from_parts(ts, 0);
        assert_eq(u.timestamp_ms(), ts as UInt64);
        i = i + 1;
    }
}

@test
fn law_from_parts_timestamp_independent_of_seed() {
    let ts_cases: List<Int> = [0, 100, 1_000_000];
    let seed_cases: List<Int> = [0, 1, 42, 999_999];
    let mut i: Int = 0;
    while i < ts_cases.len() {
        let ts = ts_cases[i].clone();
        let mut j: Int = 0;
        while j < seed_cases.len() {
            let seed = seed_cases[j].clone();
            let u = from_parts(ts, seed);
            assert_eq(u.timestamp_ms(), ts as UInt64);
            j = j + 1;
        }
        i = i + 1;
    }
}

@property
fn prop_from_parts_timestamp_round_trip(ts: Int) {
    if ts >= 0 && ts <= 281_474_976_710_655 {
        let u = from_parts(ts, 0);
        assert_eq(u.timestamp_ms(), ts as UInt64);
    }
}

// =============================================================================
// §B  parse rejects every wrong-length input.
// =============================================================================

@test
fn law_parse_rejects_wrong_length() {
    let bad_lengths: List<Text> = [
        "".to_text(),
        "0".to_text(),
        "0123456789".to_text(),                       // 10 chars
        "0123456789ABCDEFGHJKLMNPQR".to_text() + "X".to_text(), // 27 chars
    ];
    let mut i: Int = 0;
    while i < bad_lengths.len() {
        let s = bad_lengths[i].clone();
        let r = parse(&s);
        if s.len() != 26 {
            assert(r.is_err());
        }
        i = i + 1;
    }
}

@test
fn law_parse_accepts_all_zero_canonical() {
    // 26 '0' characters = the canonical all-zero ULID.
    let s = "00000000000000000000000000".to_text();
    let r = parse(&s);
    assert(r.is_ok());
    assert_eq(r.unwrap().timestamp_ms(), 0_u64);
}

// =============================================================================
// §C  Alphabet membership — every Crockford char accepted, every banned
//     non-alias rejected.
// =============================================================================

@test
fn law_alphabet_has_canonical_size() {
    assert_eq(ULID_ALPHABET.len(), 32);
}

@test
fn law_alphabet_no_duplicate_chars() {
    let mut i: Int = 0;
    while i < ULID_ALPHABET.len() {
        let mut j: Int = i + 1;
        while j < ULID_ALPHABET.len() {
            assert(ULID_ALPHABET[i] != ULID_ALPHABET[j]);
            j = j + 1;
        }
        i = i + 1;
    }
}

@test
fn law_alphabet_chars_in_ascii_printable_range() {
    let mut i: Int = 0;
    while i < ULID_ALPHABET.len() {
        let b = ULID_ALPHABET[i];
        assert(b >= 0x30_u8);   // '0'
        assert(b <= 0x5A_u8);   // 'Z'
        i = i + 1;
    }
}

// =============================================================================
// §D  UlidError variants disjoint under Eq.
// =============================================================================

@test
fn law_error_variants_pairwise_distinct() {
    let a = UlidError.InvalidLength(0);
    let b = UlidError.InvalidLength(15);
    let c = UlidError.InvalidCharacter(0_u8);
    let d = UlidError.InvalidCharacter(0x49_u8);
    assert(!(a == b));         // same variant, different payload
    assert(!(c == d));         // same variant, different payload
    assert(!(a == c));         // different variant
    assert(!(b == d));         // different variant
}

@test
fn law_error_eq_reflexive() {
    let lengths: List<Int> = [0, 15, 26, 100];
    let mut i: Int = 0;
    while i < lengths.len() {
        let a = UlidError.InvalidLength(lengths[i].clone());
        let b = UlidError.InvalidLength(lengths[i].clone());
        assert(a == b);
        i = i + 1;
    }
}

// =============================================================================
// §E  Parametrised: invalid lengths rejected.
// =============================================================================

@test_case("".to_text())
@test_case("0".to_text())
@test_case("0123456789".to_text())
fn parametrised_parse_rejects_short_input(s: Text) {
    let r = parse(&s);
    assert(r.is_err());
}

fn main() {}
