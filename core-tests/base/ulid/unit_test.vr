// =============================================================================
// core-tests/base/ulid/unit_test.vr
// =============================================================================
//
// Tests for `core.base.ulid` — 128-bit time-ordered IDs encoded in
// 26-char Crockford Base32 (no I/L/O/U).
//
// Two distinct test groups:
//   • Pure-data surface — `from_parts` factory, `parse` validation,
//     `timestamp_ms` extractor, `UlidError` 2-variant ADT,
//     `ULID_ALPHABET` constant pinning.
//   • Round-trip / encoding surface — gated on
//     **`Ulid.to_text()` lenient panic-stub**: the function references
//     `Text.from_utf8_unchecked` which was declared private (`unsafe fn`
//     instead of `public unsafe fn`) in `core/text/text.vr`. The
//     visibility fix is staged in this branch (text.vr:455 now
//     `public unsafe fn`); it activates after the next precompiled-
//     stdlib refresh. Pinned at `regression_test.vr §A`.
//
// All comparisons use `to_text()` ONLY in §3 / §6 (gated on the
// to_text refresh). The bulk of the suite exercises the pure-data
// surface that bypasses to_text entirely.
// =============================================================================

mount core.prelude.*;
mount core.base.ulid.{
    Ulid, UlidError, parse, from_parts,
    ULID_ALPHABET,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: from_parts factory — deterministic ULIDs
// =============================================================================

@test
fn test_from_parts_all_zero_yields_zero_timestamp() {
    let u = from_parts(0, 0);
    assert_eq(u.timestamp_ms(), 0_u64);
}

@test
fn test_from_parts_pinned_timestamp_recoverable() {
    let ts: Int = 1_234_567_890;
    let u = from_parts(ts, 0);
    assert_eq(u.timestamp_ms(), ts as UInt64);
}

@test
fn test_from_parts_negative_timestamp_clamped_to_zero() {
    // The free-fn `from_parts` clamps negative ts/seed to 0 (source
    // line 239-241). A defect that wrapped negatives into UInt64 (so
    // `-1` → `UInt64.MAX`) would surface here as a non-zero ts.
    let u = from_parts(-100, -50);
    assert_eq(u.timestamp_ms(), 0_u64);
}

@test
fn test_from_parts_max_48_bit_timestamp() {
    // 2^48 - 1 = max representable ULID timestamp.
    let max_ts: Int = 281_474_976_710_655;
    let u = from_parts(max_ts, 0);
    assert_eq(u.timestamp_ms(), max_ts as UInt64);
}

@test
fn test_from_parts_seeded_method_form_with_uint64() {
    // Static-method form takes UInt64 + UInt64 (vs free fn Int + Int).
    let u = Ulid.from_parts_seeded(1000_u64, 42_u64);
    assert_eq(u.timestamp_ms(), 1000_u64);
}

@test
fn test_from_parts_seed_does_not_affect_timestamp() {
    let ts: Int = 12345;
    let u1 = from_parts(ts, 0);
    let u2 = from_parts(ts, 9_999_999);
    let u3 = from_parts(ts, 1);
    // Different seeds, same timestamp.
    assert_eq(u1.timestamp_ms(), u2.timestamp_ms());
    assert_eq(u2.timestamp_ms(), u3.timestamp_ms());
    assert_eq(u1.timestamp_ms(), ts as UInt64);
}

// =============================================================================
// Section 2: parse — validation paths
// =============================================================================

@test
fn test_parse_invalid_length_returns_err() {
    let s = "not-a-ulid".to_text();   // 10 chars
    let r = parse(&s);
    assert(r.is_err());
}

@test
fn test_parse_wrong_length_15_returns_err() {
    let s = "01H8XGJWBWBAQ4M".to_text();   // 15 chars, should be 26
    let r = parse(&s);
    assert(r.is_err());
}

@test
fn test_parse_empty_returns_err() {
    let s = "".to_text();
    let r = parse(&s);
    assert(r.is_err());
}

@test
fn test_parse_invalid_character_returns_err() {
    // 26 characters but contains '!' (not in Crockford alphabet,
    // not a Crockford I/L/O alias either).
    let s = "000000000000000000000000!0".to_text();
    let r = parse(&s);
    assert(r.is_err());
}

@test
fn test_parse_all_zero_string_returns_zero_ulid() {
    // The all-zero 26-char Crockford string MUST parse to the
    // all-zero ULID (alphabet[0] == '0').
    let s = "00000000000000000000000000".to_text();
    let r = parse(&s);
    assert(r.is_ok());
    assert_eq(r.unwrap().timestamp_ms(), 0_u64);
}

@test
fn test_parse_known_timestamp_string() {
    // Hand-encoded ULID: timestamp = 1, rest = 0.
    // Crockford encodes ts=1 across 10 chars as 9 '0's + '1'.
    let s = "00000000010000000000000000".to_text();
    let r = parse(&s);
    assert(r.is_ok());
    assert_eq(r.unwrap().timestamp_ms(), 1_u64);
}

// =============================================================================
// Section 3: UlidError variants
// =============================================================================

@test
fn test_error_invalid_length_payload() {
    let s = "abc".to_text();
    let r = parse(&s);
    assert(r.is_err());
    match r {
        Err(e) => match e {
            UlidError.InvalidLength(n) => assert_eq(n, 3),
            UlidError.InvalidCharacter(_) => panic("expected InvalidLength"),
        },
        Ok(_) => panic("expected Err"),
    }
}

@test
fn test_error_invalid_character_payload_is_offending_byte() {
    // 26 chars; position 24 is '!' (0x21) which is not in the
    // Crockford alphabet AND not a Crockford I/L/O alias.
    // The ULID decoder accepts I/L → 1 and O → 0 as aliases, so
    // 'I' / 'L' / 'O' do NOT trigger InvalidCharacter.
    let s = "000000000000000000000000!0".to_text();
    let r = parse(&s);
    assert(r.is_err());
    match r {
        Err(e) => match e {
            UlidError.InvalidCharacter(b) => assert_eq(b, 0x21_u8),   // '!'
            UlidError.InvalidLength(_) => panic("expected InvalidCharacter"),
        },
        Ok(_) => panic("expected Err"),
    }
}

@test
fn test_error_eq_reflexive_for_invalid_length() {
    let a = UlidError.InvalidLength(15);
    let b = UlidError.InvalidLength(15);
    assert(a == b);
}

@test
fn test_error_eq_reflexive_for_invalid_character() {
    let a = UlidError.InvalidCharacter(0x49_u8);
    let b = UlidError.InvalidCharacter(0x49_u8);
    assert(a == b);
}

@test
fn test_error_eq_distinct_variants_unequal() {
    let a = UlidError.InvalidLength(15);
    let b = UlidError.InvalidCharacter(0x49_u8);
    assert(!(a == b));
}

@test
fn test_error_eq_same_variant_different_payload_unequal() {
    let a = UlidError.InvalidLength(10);
    let b = UlidError.InvalidLength(15);
    assert(!(a == b));
}

// =============================================================================
// Section 4: ULID_ALPHABET constant — Crockford Base32 (RFC §4)
// =============================================================================

@test
fn test_alphabet_length_is_32() {
    assert_eq(ULID_ALPHABET.len(), 32);
}

@test
fn test_alphabet_starts_with_digit_zero() {
    assert_eq(ULID_ALPHABET[0], 0x30_u8);   // '0'
}

@test
fn test_alphabet_excludes_i_l_o_u() {
    let banned: List<Byte> = [0x49_u8, 0x4C_u8, 0x4F_u8, 0x55_u8];
    let mut bi: Int = 0;
    while bi < banned.len() {
        let bad = banned[bi];
        let mut ai: Int = 0;
        while ai < ULID_ALPHABET.len() {
            assert(ULID_ALPHABET[ai] != bad);
            ai = ai + 1;
        }
        bi = bi + 1;
    }
}

@test
fn test_alphabet_first_10_are_decimal_digits() {
    let mut i: Int = 0;
    while i < 10 {
        assert_eq(ULID_ALPHABET[i], (0x30_u8 + i as Byte));
        i = i + 1;
    }
}

@test
fn test_alphabet_last_position_is_z() {
    assert_eq(ULID_ALPHABET[31], 0x5A_u8);   // 'Z'
}

// =============================================================================
// Section 5: timestamp_ms extractor — 48-bit field semantics
// =============================================================================

@test
fn test_timestamp_ms_extracts_high_48_bits() {
    let ts: Int = 42;
    let u = from_parts(ts, 0);
    assert_eq(u.timestamp_ms(), 42_u64);
}

@test
fn test_timestamp_ms_zero_for_zero_ulid() {
    let u = from_parts(0, 0);
    assert_eq(u.timestamp_ms(), 0_u64);
}

@test
fn test_timestamp_ms_at_48_bit_boundary() {
    // The 48-bit max value.
    let max_ts: Int = 281_474_976_710_655;
    let u = from_parts(max_ts, 0);
    assert_eq(u.timestamp_ms(), max_ts as UInt64);
}

fn main() {}
