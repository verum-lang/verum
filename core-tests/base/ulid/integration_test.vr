// =============================================================================
// core-tests/base/ulid/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.ulid` — deterministic ULID corpora
// in List<Ulid> / Set<Text> / Map<Text, Text>, parse-validation paths,
// and 48-bit timestamp-boundary exercises.
//
// Live `generate()` / `Ulid.new()` integration is gated on the
// `SystemTime.now()` static-method dispatch defect (task #17/#39 — see
// `regression_test.vr §C`). The `Ulid.to_text()` round-trip is
// additionally gated on the `Text.from_utf8_unchecked` visibility fix
// landed in this branch (text.vr:455 now `public unsafe fn`) — pinned
// in `regression_test.vr §B`. All integration tests here use
// deterministic `from_parts(int, int)` constructors and parse-only
// validation paths.
// =============================================================================

mount core.prelude.*;
mount core.base.ulid.{Ulid, UlidError, parse, from_parts};
mount core.collections.list.List;
mount core.collections.set.Set;

// =============================================================================
// Section 1: Deterministic ULID corpus — distinct timestamps
// =============================================================================

@test
fn integration_distinct_timestamps_yield_distinct_ulids_via_timestamp_ms() {
    // 10 ULIDs at distinct ts values — every one must be recoverable.
    let mut ts_set: Set<UInt64> = Set.new();
    let mut i: Int = 0;
    while i < 10 {
        let u = from_parts(1_000_000 + i, 0);
        ts_set.insert(u.timestamp_ms());
        i = i + 1;
    }
    assert_eq(ts_set.len(), 10);
}

@test
fn integration_same_timestamp_different_seed_yields_same_ts() {
    let u1 = from_parts(5_000_000, 1);
    let u2 = from_parts(5_000_000, 2);
    let u3 = from_parts(5_000_000, 999);
    assert_eq(u1.timestamp_ms(), u2.timestamp_ms());
    assert_eq(u2.timestamp_ms(), u3.timestamp_ms());
    assert_eq(u1.timestamp_ms(), 5_000_000_u64);
}

// =============================================================================
// Section 2: Timestamp 48-bit boundary
// =============================================================================

@test
fn integration_from_parts_epoch_zero() {
    let u = from_parts(0, 0);
    assert_eq(u.timestamp_ms(), 0_u64);
}

@test
fn integration_from_parts_max_48_bit_timestamp() {
    let max_ts: Int = 281_474_976_710_655;   // 2^48 - 1
    let u = from_parts(max_ts, 0);
    assert_eq(u.timestamp_ms(), max_ts as UInt64);
}

@test
fn integration_from_parts_at_year_2055_approximate() {
    // Year 2055 ≈ 2_700_000_000_000 ms since Unix epoch.
    let ts: Int = 2_700_000_000_000;
    let u = from_parts(ts, 0);
    assert_eq(u.timestamp_ms(), ts as UInt64);
}

// =============================================================================
// Section 3: parse — error paths exercised over List inputs
// =============================================================================

@test
fn integration_parse_rejects_short_inputs() {
    let bad_lengths: List<Text> = [
        "".to_text(),
        "0".to_text(),
        "01ARZ3NDEKTSV4RRFFQ69G5FA".to_text(),   // 25 chars (one short)
    ];
    let mut i: Int = 0;
    while i < bad_lengths.len() {
        let s = bad_lengths[i].clone();
        let r = parse(&s);
        assert(r.is_err());
        i = i + 1;
    }
}

@test
fn integration_parse_rejects_invalid_non_alias_chars() {
    // ULID decoder treats I/L → 1 and O → 0 as aliases (Crockford
    // strict mode does not, but the impl does — source line 376-378).
    // To trigger InvalidCharacter we must use a char NOT in the
    // alphabet AND NOT an alias.
    let bad: List<Text> = [
        // 26 chars, position 24 is '!' (0x21):
        "000000000000000000000000!0".to_text(),
        // 26 chars, position 0 is '@' (0x40, between '?' and 'A'):
        "@0000000000000000000000000".to_text(),
        // 26 chars, position 13 is '~' (0x7E, after 'Z'):
        "0000000000000~0000000000000".to_text()[0..26].to_text(),
    ];
    let mut i: Int = 0;
    while i < bad.len() - 1 {   // skip the slice-construct one
        let s = bad[i].clone();
        let r = parse(&s);
        assert(r.is_err());
        i = i + 1;
    }
}

@test
fn integration_parse_accepts_io_aliases_as_canonical() {
    // The Crockford spec allows I/L → 1 and O → 0 as aliases. The
    // decoder explicitly implements this (source line 376-378). A
    // ULID built from a synthetic 26-char string with 'I' / 'L' / 'O'
    // at any position should still parse.
    let mut s = "00000000000000000000000000".to_text();
    let r1 = parse(&s);
    assert(r1.is_ok());
    // Replace one '0' with 'I' — should still parse (alias for '1').
    let s2 = "00000000000000000000000I00".to_text();
    let r2 = parse(&s2);
    assert(r2.is_ok());
}

// =============================================================================
// Section 4: ULID corpora in Set<UInt64> — uniqueness by timestamp
// =============================================================================

@test
fn integration_100_distinct_timestamp_ulids_all_unique() {
    let mut ts_set: Set<UInt64> = Set.new();
    let mut i: Int = 0;
    while i < 100 {
        let u = from_parts(i, 0);
        ts_set.insert(u.timestamp_ms());
        i = i + 1;
    }
    assert_eq(ts_set.len(), 100);
}

// =============================================================================
// Section 5: UlidError variants in a List<UlidError>
// =============================================================================

@test
fn integration_error_variants_in_collection() {
    let errors: List<UlidError> = [
        UlidError.InvalidLength(0),
        UlidError.InvalidLength(15),
        UlidError.InvalidCharacter(0x21_u8),
        UlidError.InvalidCharacter(0x40_u8),
    ];
    assert_eq(errors.len(), 4);
}

@test
fn integration_error_variants_disjoint_across_collection() {
    let errors: List<UlidError> = [
        UlidError.InvalidLength(15),
        UlidError.InvalidCharacter(0x21_u8),
    ];
    // The two errors must compare unequal.
    let a = errors[0].clone();
    let b = errors[1].clone();
    assert(!(a == b));
}

fn main() {}
