// =============================================================================
// core-tests/base/retry/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.retry` — RetryBackoff in
// List<RetryBackoff>, RetryOptions builder chain composition, and
// first-attempt success across all four retry helpers
// (`retry` / `retry_linear` / `retry_immediate` / `retry_jittered`).
//
// Multi-attempt retry integration tests (abort-on-permanent-error,
// transient-then-permanent, counter-overflow) are pinned `@ignore`'d
// at `regression_test.vr §A` — the closure mutable-state defect
// (every `counter = counter + 1` inside the closure trips a
// `.next` not-found on Int) gates all of those scenarios.
// =============================================================================

mount core.prelude.*;
mount core.base.retry.{
    RetryBackoff, RetryOptions,
    retry, retry_linear, retry_immediate, retry_jittered, retry_with_strategy,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: Builder chain composition
// =============================================================================

@test
fn integration_retry_options_simple_chain_with_should_retry() {
    let opts: RetryOptions<Text> = RetryOptions.simple(5)
        .with_should_retry(|e: &Text| { *e == "transient".to_text() });
    assert_eq(opts.max_attempts, 5);
}

@test
fn integration_retry_options_exponential_chain_with_should_retry() {
    let opts: RetryOptions<Text> = RetryOptions
        .exponential(7, 100, 10_000)
        .with_should_retry(|e: &Text| { *e == "transient".to_text() });
    assert_eq(opts.max_attempts, 7);
}

@test
fn integration_retry_options_linear_chain_with_should_retry() {
    let opts: RetryOptions<Text> = RetryOptions
        .linear(4, 200)
        .with_should_retry(|e: &Text| { *e == "transient".to_text() });
    assert_eq(opts.max_attempts, 4);
}

// =============================================================================
// Section 2: RetryBackoff variants in List<RetryBackoff>
// =============================================================================

@test
fn integration_retry_backoff_variants_in_list() {
    let strategies: List<RetryBackoff> = [
        RetryBackoff.None,
        RetryBackoff.Linear { delay_ms: 50 },
        RetryBackoff.Linear { delay_ms: 200 },
        RetryBackoff.Exponential {
            initial_ms: 10,
            max_ms:     1_000,
            multiplier: 2.0,
        },
    ];
    assert_eq(strategies.len(), 4);
}

@test
fn integration_retry_backoff_iterate_and_match() {
    let strategies: List<RetryBackoff> = [
        RetryBackoff.None,
        RetryBackoff.Linear { delay_ms: 100 },
        RetryBackoff.Exponential {
            initial_ms: 50,
            max_ms:     5_000,
            multiplier: 1.5,
        },
    ];
    let mut none_count: Int    = 0;
    let mut linear_count: Int  = 0;
    let mut expo_count: Int    = 0;
    let mut i: Int = 0;
    while i < strategies.len() {
        let s = strategies[i].clone();
        match s {
            RetryBackoff.None              => none_count   = none_count + 1,
            RetryBackoff.Linear { delay_ms: _ }       => linear_count = linear_count + 1,
            RetryBackoff.Exponential { initial_ms: _, max_ms: _, multiplier: _ } => expo_count   = expo_count + 1,
            _ => {},
        }
        i = i + 1;
    }
    assert_eq(none_count,   1);
    assert_eq(linear_count, 1);
    assert_eq(expo_count,   1);
}

// =============================================================================
// Section 3: First-attempt success across all four retry helpers
// =============================================================================

@test
fn integration_retry_first_attempt_success() {
    let r: Result<Int, Text> = retry(3, || { Ok(42) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 42);
}

@test
fn integration_retry_immediate_first_attempt_success() {
    let r: Result<Int, Text> = retry_immediate(3, || { Ok(99) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 99);
}

@test
fn integration_retry_jittered_first_attempt_success() {
    let r: Result<Int, Text> = retry_jittered(3, 50, || { Ok(7) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 7);
}

@test
fn integration_retry_linear_first_attempt_success() {
    let r: Result<Int, Text> = retry_linear(3, 50, || { Ok(13) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 13);
}

@test
fn integration_retry_with_strategy_first_attempt_success() {
    let opts: RetryOptions<Text> = RetryOptions.simple(3);
    let r: Result<Int, Text> = retry_with_strategy(|| { Ok(100) }, opts);
    assert(r.is_ok());
    assert_eq(r.unwrap(), 100);
}

// =============================================================================
// Section 4: Result<T, RetryError> composition with stdlib types
// =============================================================================

@test
fn integration_retry_returns_first_attempt_text_value() {
    let r: Result<Text, Text> = retry(3, || { Ok("done".to_text()) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), "done".to_text());
}

@test
fn integration_retry_returns_first_attempt_list_value() {
    let r: Result<List<Int>, Text> = retry(3, || { Ok([1, 2, 3]) });
    assert(r.is_ok());
    assert_eq(r.unwrap().len(), 3);
}

fn main() {}
