// =============================================================================
// core-tests/base/retry/property_test.vr
// =============================================================================
//
// Algebraic-law verification for `core.base.retry` — RetryBackoff
// variant disjointness, RetryOptions builder invariants, and
// first-attempt success paths.
//
// Multi-attempt retry properties (max_attempts cap, exponential
// backoff monotonicity) are pinned `@ignore`'d at
// `regression_test.vr §A` — the closure mutable-state defect
// makes any closure that increments an outer counter mis-dispatch
// through the `.next` iterator method on Int.
// =============================================================================

mount core.prelude.*;
mount core.base.retry.{
    RetryBackoff, RetryOptions,
    retry, retry_immediate, retry_jittered, retry_linear,
};
mount core.collections.list.List;

// =============================================================================
// §A  RetryBackoff variants — pairwise disjoint construction.
// =============================================================================

@test
fn law_retry_backoff_variants_are_distinct_shapes() {
    let none_v = RetryBackoff.None;
    let linear_v = RetryBackoff.Linear { delay_ms: 100 };
    let expo_v = RetryBackoff.Exponential {
        initial_ms: 10,
        max_ms:     1_000,
        multiplier: 2.0,
    };
    // Each variant must reach its own arm in a match (variant tags
    // are pairwise distinct).
    let mut counts: List<Int> = [0, 0, 0];
    let inputs: List<RetryBackoff> = [none_v, linear_v, expo_v];
    let mut i: Int = 0;
    while i < inputs.len() {
        match inputs[i].clone() {
            RetryBackoff.None             => counts.set(0, counts[0] + 1),
            RetryBackoff.Linear { delay_ms: _ } => counts.set(1, counts[1] + 1),
            RetryBackoff.Exponential { initial_ms: _, max_ms: _, multiplier: _ } => counts.set(2, counts[2] + 1),
            _ => {},
        }
        i = i + 1;
    }
    assert_eq(counts[0], 1);
    assert_eq(counts[1], 1);
    assert_eq(counts[2], 1);
}

// =============================================================================
// §B  RetryOptions.simple preserves max_attempts argument exactly.
// =============================================================================

@test_case(1)
@test_case(2)
@test_case(5)
@test_case(10)
@test_case(100)
fn law_retry_options_simple_round_trip(n: Int) {
    let opts: RetryOptions<Text> = RetryOptions.simple(n);
    assert_eq(opts.max_attempts, n);
}

// =============================================================================
// §C  RetryOptions.exponential / .linear preserve max_attempts.
// =============================================================================

@test
fn law_retry_options_exponential_preserves_max_attempts() {
    let cases: List<Int> = [1, 3, 7, 100];
    let mut i: Int = 0;
    while i < cases.len() {
        let n = cases[i].clone();
        let opts: RetryOptions<Text> = RetryOptions.exponential(n, 100, 10_000);
        assert_eq(opts.max_attempts, n);
        i = i + 1;
    }
}

@test
fn law_retry_options_linear_preserves_max_attempts() {
    let cases: List<Int> = [1, 5, 25];
    let mut i: Int = 0;
    while i < cases.len() {
        let n = cases[i].clone();
        let opts: RetryOptions<Text> = RetryOptions.linear(n, 200);
        assert_eq(opts.max_attempts, n);
        i = i + 1;
    }
}

// =============================================================================
// §D  First-attempt success — every retry variant returns the value
//     unchanged when the closure succeeds on the first call.
// =============================================================================

@test
fn law_retry_first_attempt_success_returns_value() {
    let r: Result<Int, Text> = retry(5, || { Ok(42) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 42);
}

@test
fn law_retry_immediate_first_attempt_success() {
    let r: Result<Int, Text> = retry_immediate(5, || { Ok(99) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 99);
}

@test
fn law_retry_jittered_first_attempt_success() {
    let r: Result<Int, Text> = retry_jittered(3, 100, || { Ok(7) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 7);
}

@test
fn law_retry_linear_first_attempt_success() {
    let r: Result<Int, Text> = retry_linear(3, 50, || { Ok(13) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 13);
}

// =============================================================================
// §E  RetryBackoff record-payload pin — Exponential carries 3 fields,
//     Linear carries 1.
// =============================================================================

@test
fn law_retry_backoff_exponential_carries_three_fields() {
    let b = RetryBackoff.Exponential {
        initial_ms: 100,
        max_ms:     10_000,
        multiplier: 2.5,
    };
    match b {
        RetryBackoff.Exponential { initial_ms, max_ms, multiplier: _ } => {
            assert_eq(initial_ms, 100);
            assert_eq(max_ms, 10_000);
        },
        _ => panic("expected Exponential variant with 3 fields"),
    }
}

@test
fn law_retry_backoff_linear_carries_one_field() {
    let b = RetryBackoff.Linear { delay_ms: 500 };
    match b {
        RetryBackoff.Linear { delay_ms } => assert_eq(delay_ms, 500),
        _ => panic("expected Linear variant with delay_ms"),
    }
}

fn main() {}
