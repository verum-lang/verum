// =============================================================================
// core-tests/base/retry/unit_test.vr
// =============================================================================
//
// Tests for `core.base.retry` — RetryBackoff strategy ADT, RetryOptions<E>
// configuration record + builders, and retry combinators.
//
// **Closure mutable-state defect surfaced in this branch**: the `retry`
// / `retry_immediate` / `retry_with_strategy` closure bodies that
// mutate an outer-scope counter (`let mut counter = 0; retry(N, || {
// counter = counter + 1; ... })`) trigger a closure-state-mutation
// defect that surfaces as:
//   method 'next' not found on receiver of runtime kind `Int` ...
//   8 candidate(s) end with `.next` (SignalStream / Args / Rev / MappedIter / ...)
// The closure's `counter = counter + 1` mutation interacts with the
// iterator-method dispatch on `Int` (since `counter` is mutated under
// a `while attempt < max_attempts` loop in retry_with_strategy). The
// dispatcher misroutes some downstream operation. Multi-day VBC
// codegen fix; pinned at `regression_test.vr §A`.
//
// Workaround: tests that succeed on the FIRST attempt (counter never
// increments above 1) don't hit the defect. Multi-attempt retry tests
// are pinned `@ignore`'d.
// =============================================================================

mount core.prelude.*;
mount core.base.retry.{
    RetryBackoff, RetryOptions,
    retry, retry_linear, retry_immediate, retry_jittered,
    retry_with_strategy,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: RetryOptions construction — `simple` factory
// =============================================================================

@test
fn test_retry_options_simple_max_attempts() {
    let opts: RetryOptions<Text> = RetryOptions.simple(5);
    assert_eq(opts.max_attempts, 5);
}

@test
fn test_retry_options_simple_with_zero_max_attempts() {
    let opts: RetryOptions<Text> = RetryOptions.simple(0);
    assert_eq(opts.max_attempts, 0);
}

@test
fn test_retry_options_simple_high_max_attempts() {
    let opts: RetryOptions<Text> = RetryOptions.simple(1000);
    assert_eq(opts.max_attempts, 1000);
}

// =============================================================================
// Section 2: RetryOptions.exponential builder
// =============================================================================

@test
fn test_retry_options_exponential_preserves_max_attempts() {
    let opts: RetryOptions<Text> = RetryOptions.exponential(7, 100, 10_000);
    assert_eq(opts.max_attempts, 7);
}

// =============================================================================
// Section 3: RetryOptions.linear builder
// =============================================================================

@test
fn test_retry_options_linear_preserves_max_attempts() {
    let opts: RetryOptions<Text> = RetryOptions.linear(4, 500);
    assert_eq(opts.max_attempts, 4);
}

// =============================================================================
// Section 4: with_should_retry — builder chain preserves shape
// =============================================================================

@test
fn test_retry_options_with_should_retry_preserves_max_attempts() {
    let opts: RetryOptions<Text> = RetryOptions.simple(3)
        .with_should_retry(|e: &Text| { *e == "transient".to_text() });
    assert_eq(opts.max_attempts, 3);
}

// =============================================================================
// Section 5: retry — succeeds first attempt (no closure mutation)
// =============================================================================

@test
fn test_retry_succeeds_on_first_attempt_returns_value() {
    let r: Result<Int, Text> = retry(3, || { Ok(42) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 42);
}

@test
fn test_retry_succeeds_on_first_attempt_with_one_max() {
    let r: Result<Int, Text> = retry(1, || { Ok(7) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 7);
}

@test
fn test_retry_immediate_succeeds_on_first_attempt() {
    let r: Result<Int, Text> = retry_immediate(3, || { Ok(99) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 99);
}

@test
fn test_retry_jittered_succeeds_on_first_attempt() {
    let r: Result<Int, Text> = retry_jittered(2, 100, || { Ok(11) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 11);
}

@test
fn test_retry_linear_succeeds_on_first_attempt() {
    let r: Result<Int, Text> = retry_linear(3, 50, || { Ok(13) });
    assert(r.is_ok());
    assert_eq(r.unwrap(), 13);
}

// =============================================================================
// Section 6: RetryBackoff variants — construction + payload
// =============================================================================

@test
fn test_retry_backoff_none_variant_constructible() {
    let _ = RetryBackoff.None;
}

@test
fn test_retry_backoff_linear_variant_carries_delay_ms() {
    let b = RetryBackoff.Linear { delay_ms: 500 };
    match b {
        RetryBackoff.Linear { delay_ms } => assert_eq(delay_ms, 500),
        _ => panic("expected Linear variant"),
    }
}

@test
fn test_retry_backoff_exponential_carries_full_payload() {
    let b = RetryBackoff.Exponential {
        initial_ms: 100,
        max_ms:     10_000,
        multiplier: 2.0,
    };
    match b {
        RetryBackoff.Exponential { initial_ms, max_ms, multiplier: _ } => {
            assert_eq(initial_ms, 100);
            assert_eq(max_ms, 10_000);
        },
        _ => panic("expected Exponential variant"),
    }
}

fn main() {}
