// =============================================================================
// core-tests/base/ordering/regression_test.vr
// =============================================================================
//
// Known limitation pinned by `test_iterator_deref_reverse`: in
//   for ord in orderings.iter() { ord.reverse() }
// iterator-item type is inferred too late for method lookup — work-around is
// `(*ord).reverse()`. This is a TYPE-INFERENCE defect at the language level,
// not an Ordering-API defect. Tracked in audit.md §3.

mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.collections.list.List;

// Direct call - should work
@test
fn test_direct_reverse() {
    let result = Less.reverse();
    assert_eq(result, Greater);
}

// Direct call on variable
@test
fn test_variable_reverse() {
    let ord: Ordering = Less;
    let result = ord.reverse();
    assert_eq(result, Greater);
}

// Call on reference - WORKS (auto-deref for explicit reference types)
@test
fn test_reference_reverse() {
    let ord: Ordering = Less;
    let ord_ref: &Ordering = &ord;
    // This auto-derefs because ord_ref has known type &Ordering
    let result = ord_ref.reverse();
    assert_eq(result, Greater);
}

// Call through function taking &Ordering - WORKS
@test
fn test_ref_param_reverse() {
    fn do_reverse(ord: &Ordering) -> Ordering {
        ord.reverse()
    }

    let result = do_reverse(&Less);
    assert_eq(result, Greater);
}

// Test with explicit dereference - WORKS
// This is the workaround for iterator items
@test
fn test_iterator_deref_reverse() {
    let orderings: List<Ordering> = [Less, Equal, Greater];
    for ord in orderings.iter() {
        // Explicitly dereference since auto-deref doesn't work for iterator items
        let reversed = (*ord).reverse();
        let back = reversed.reverse();
        assert_eq(*ord, back);
    }
}

// Test: bind iterator item to explicitly typed variable
@test
fn test_iterator_rebind_reverse() {
    let orderings: List<Ordering> = [Less, Equal, Greater];
    for ord in orderings.iter() {
        // Rebind to explicitly typed variable
        let o: &Ordering = ord;
        let reversed = o.reverse();
        assert(reversed is Less || reversed is Equal || reversed is Greater);
    }
}

// NOTE: The following pattern FAILS:
// for ord in orderings.iter() { ord.reverse(); }
// The type of 'ord' is inferred but not resolved early enough for method lookup.
// This is a known type inference ordering issue.
// Workaround: Use explicit dereference (*ord).reverse()

// =============================================================================
// REGRESSION (task #8, 2026-05-14): every primitive-method intercept on
// the interpreter side (Int.cmp/eq/ne/lt/le/gt/ge, Bool.* mirrors, Float.*,
// Byte.*, Char.*, Int32.*, UInt64.*) handled CBGR REGISTER refs but missed
// HEAP-INTERIOR refs produced by `RefListElement` / `RefField`.
//
// Symptom: `xs[0].cmp(&xs[1])` for `xs = [5, 2]` returned `Less` instead of
// `Greater` because the intercept fell through to `other_val.as_i64()` on a
// `Value::from_ptr(elem_ptr)` and ended up comparing the receiver `5`
// against the pointer ADDRESS (a large positive Int).
//
// Blast radius: bubble-sort on indexed lists, every `for byte in bytes`
// comparison, every `cmp` over field-borrowed primitives. Closed by a
// single canonical helper `resolve_arg_value(state, val)` in
// `crates/verum_vbc/src/interpreter/dispatch_table/handlers/cbgr_helpers.rs`
// that unifies all three ref shapes (CBGR register-ref, heap-interior ptr,
// thin-ref) — replaces 24+ inline duplicated `if is_cbgr_ref(...) { ... }`
// sites across the primitive intercepts in `method_dispatch.rs`.
// =============================================================================

@test
fn regression_cmp_on_two_indexed_int_arguments() {
    // The minimal repro: `xs[0].cmp(&xs[1])` where xs[0]=5, xs[1]=2.
    let xs: List<Int> = [5, 2];
    let ord = xs[0].cmp(&xs[1]);
    assert(ord is Greater);
}

@test
fn regression_bubble_sort_via_indexed_cmp_chain() {
    fn bubble_sort_int(xs: &mut List<Int>) {
        let n = xs.len();
        let mut i = 0;
        while i < n {
            let mut j = 0;
            while j + 1 < n - i {
                // Inline-indexed-receiver + inline-indexed-arg dispatch —
                // pre-fix this swap was unreachable because
                // `xs[j].cmp(&xs[j+1]).is_greater()` returned false on
                // every adjacent pair.
                if xs[j].cmp(&xs[j + 1]).is_greater() {
                    let tmp = xs[j];
                    xs[j] = xs[j + 1];
                    xs[j + 1] = tmp;
                }
                j = j + 1;
            }
            i = i + 1;
        }
    }
    let mut xs: List<Int> = [5, 2, 8, 1, 9, 3];
    bubble_sort_int(&mut xs);
    assert_eq(xs, [1, 2, 3, 5, 8, 9]);
}

@test
fn regression_eq_on_two_indexed_int_arguments() {
    let xs: List<Int> = [7, 7, 3];
    assert(xs[0].eq(&xs[1]));   // 7 == 7
    assert(!xs[0].eq(&xs[2]));  // 7 != 3
}

@test
fn regression_lt_le_gt_ge_on_indexed_arguments() {
    let xs: List<Int> = [2, 5];
    assert(xs[0].lt(&xs[1]));   //  2 <  5
    assert(xs[0].le(&xs[1]));   //  2 <= 5
    assert(!xs[1].lt(&xs[0]));  // !(5 <  2)
    assert(xs[1].gt(&xs[0]));   //  5 >  2
    assert(xs[1].ge(&xs[0]));   //  5 >= 2
    assert(xs[0].le(&xs[0]));   //  2 <= 2
}

// =============================================================================
// REGRESSION (task #9, 2026-05-14): `f"{x}"` interpolation lowered
// unconditionally to the `ToString` opcode, which routes through the
// runtime `format_value_for_print` Debug-style formatter — every
// user-defined `implement Display for T` impl across `core/` (Ordering,
// Maybe, Result, error variants, every domain-specific glyph) was
// silently bypassed.  Closed by introducing a codegen-side dispatch in
// `compile_interpolated_string` (`try_emit_display_dispatch`) that
// detects `<TypeName>.fmt` registration at compile time and emits the
// canonical Formatter wiring (`buf := ""; formatter := Formatter.new
// (&mut buf); _ := value.fmt(&mut formatter); buf`) inline.  Primitives
// (Int / Float / Bool / Byte / Char / Int32 / UInt64 / …) keep the
// inline `ToString` fast path — their runtime formatter matches the
// stdlib Display impl bit-for-bit.
// =============================================================================

@test
fn regression_display_ordering_via_f_string() {
    // The original repro: `f"{Less}"` must produce `<`, not `Less`.
    let l = Less;
    let e = Equal;
    let g = Greater;
    assert_eq(f"{l}", "<");
    assert_eq(f"{e}", "=");
    assert_eq(f"{g}", ">");
}

@test
fn regression_display_ordering_in_interpolated_text() {
    let ord = Less;
    assert_eq(f"ordering={ord}", "ordering=<");
}

@test
fn regression_display_ordering_inline_constructor() {
    // Direct constructor in placeholder — exercises the codegen path
    // where `expr_reg` is the variant value itself, not a bound var.
    assert_eq(f"{Equal}", "=");
}

@test
fn regression_display_does_not_break_primitives() {
    // Int / Bool / Char must continue to use the ToString fast path —
    // verify the primitive bypass is intact.  (Float formatting is
    // exercised in float_test.vr; here we keep the assertion exact.)
    let n: Int = 42;
    let b: Bool = true;
    let c: Char = 'A';
    assert_eq(f"{n}", "42");
    assert_eq(f"{b}", "true");
    assert_eq(f"{c}", "A");
}

// =============================================================================
// REGRESSION (task #11, 2026-05-15): protocol default-method monomorphisation
// `Self → concrete-type` substitution.  `extract_type_name` /
// `extract_type_name_from_ast` mis-handled `PathSegment::SelfValue`:
// the first returned `None` (only matched `PathSegment::Name`), the
// second fell through to `format!("{}", path)` which renders Self as
// lowercase "self" (the Path Display impl).  `substitute_self_in_type_name`
// then never matched — every `register_impl_function` for a default
// method materialised onto a user type recorded `param_type_names =
// ["self"]` (literal lowercase) and `return_type_name = None`.
// Downstream `let m = a.max(b); m.<field>` lost the receiver type at
// `extract_expr_type_name`'s MethodCall arm and fell through to
// `resolve_field_index`'s scan-all-types path, picking the wrong
// type's same-named field index — surfaced as "field index N exceeds
// object data size M" panics.
//
// Closed by canonicalising `PathSegment::SelfValue` → `"Self"` (Pascal-
// case canonical) in both extractors so `substitute_self_in_type_name`'s
// word-boundary substitution fires correctly at registration time.
// =============================================================================

type OrdRegA is { value: Int };

implement Ord for OrdRegA {
    fn cmp(&self, other: &OrdRegA) -> Ordering {
        self.value.cmp(&other.value)
    }
}

@test
fn regression_ord_max_user_type_inferred_binding() {
    let a = OrdRegA { value: 100 };
    let b = OrdRegA { value: 200 };
    let m = a.max(b);
    assert_eq(m.value, 200);
}

@test
fn regression_ord_min_user_type_inferred_binding() {
    let a = OrdRegA { value: 100 };
    let b = OrdRegA { value: 200 };
    let m = a.min(b);
    assert_eq(m.value, 100);
}

@test
fn regression_ord_clamp_user_type_inferred_binding() {
    let v = OrdRegA { value: 150 };
    let lo = OrdRegA { value: 0 };
    let hi = OrdRegA { value: 100 };
    let c = v.clamp(lo, hi);
    assert_eq(c.value, 100);
}

@test
fn regression_ord_default_comparisons_user_type() {
    let a = OrdRegA { value: 100 };
    let b = OrdRegA { value: 200 };
    assert(a.lt(&b));
    assert(a.le(&b));
    assert(b.gt(&a));
    assert(b.ge(&a));
    assert(a.le(&a));
    assert(a.ge(&a));
}

fn main() {
    // Tests run via @test annotations
}
