// =============================================================================
// core-tests/base/semver_constraint/property_test.vr
// =============================================================================
//
// Algebraic-law verification for SemVer constraints:
//   - exact(v).matches(v) is always true
//   - caret(v).matches(v) is always true
//   - tilde(v).matches(v) is always true
//   - matching is downward-stable in patch (within tilde / caret bounds)
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer, parse as parse_ver};
mount core.base.semver_constraint.{
    SemVerConstraint, exact, caret, tilde,
    matches_default,
};
mount core.collections.list.List;

fn ver(s: Text) -> SemVer { parse_ver(&s).unwrap() }

// =============================================================================
// §A  Reflexivity — every constraint matches its base version.
// =============================================================================

@test
fn law_exact_self_matches() {
    let cases: List<Text> = ["0.0.0".to_text(), "1.2.3".to_text(), "10.20.30".to_text()];
    for s in cases.iter() {
        let v = ver((*s).clone());
        assert(matches_default(&exact(v.clone()), &v));
    }
}

@test
fn law_caret_self_matches() {
    let cases: List<Text> = ["0.1.0".to_text(), "1.2.3".to_text(), "5.0.0".to_text()];
    for s in cases.iter() {
        let v = ver((*s).clone());
        assert(matches_default(&caret(v.clone()), &v));
    }
}

@test
fn law_tilde_self_matches() {
    let cases: List<Text> = ["1.2.3".to_text(), "1.99.0".to_text()];
    for s in cases.iter() {
        let v = ver((*s).clone());
        assert(matches_default(&tilde(v.clone()), &v));
    }
}

// =============================================================================
// §B  caret window — [v, next-major).
// =============================================================================

@test
fn law_caret_excludes_next_major() {
    let pairs: List<(Text, Text)> = [
        ("1.0.0".to_text(), "2.0.0".to_text()),
        ("1.5.0".to_text(), "2.0.0".to_text()),
        ("3.2.1".to_text(), "4.0.0".to_text()),
    ];
    for p in pairs.iter() {
        let (lo, hi) = (*p);
        let c = caret(ver(lo.clone()));
        assert(!matches_default(&c, &ver(hi.clone())));
    }
}

// =============================================================================
// §C  tilde window — [v, next-minor).
// =============================================================================

@test
fn law_tilde_excludes_next_minor() {
    let pairs: List<(Text, Text)> = [
        ("1.2.0".to_text(), "1.3.0".to_text()),
        ("0.5.7".to_text(), "0.6.0".to_text()),
    ];
    for p in pairs.iter() {
        let (lo, hi) = (*p);
        let c = tilde(ver(lo.clone()));
        assert(!matches_default(&c, &ver(hi.clone())));
    }
}

// =============================================================================
// §D  @test_case — exact-match truth table.
// =============================================================================

@test_case("1.2.3".to_text(), "1.2.3".to_text(), true)
@test_case("1.2.3".to_text(), "1.2.4".to_text(), false)
@test_case("1.2.3".to_text(), "1.2.2".to_text(), false)
@test_case("1.2.3".to_text(), "0.0.0".to_text(), false)
@test_case("0.0.0".to_text(), "0.0.0".to_text(), true)
fn parametrised_exact_match(a: Text, b: Text, expected: Bool) {
    let c = exact(ver(a));
    assert_eq(matches_default(&c, &ver(b)), expected);
}

// =============================================================================
// §E  Pre-release matching mode — allow_prerelease flag.
// =============================================================================

@test
fn test_caret_default_excludes_prerelease_of_higher_minor() {
    let c = caret(ver("1.2.3".to_text()));
    let pre = ver("1.3.0-beta".to_text());
    assert(!matches_default(&c, &pre));
}

@test
fn test_caret_allow_prerelease_includes_beta() {
    let c = caret(ver("1.2.3".to_text()));
    let pre = ver("1.3.0-beta".to_text());
    assert(matches_allow_prerelease(&c, &pre));
}

@test
fn test_exact_default_excludes_prerelease() {
    let c = exact(ver("1.0.0".to_text()));
    let pre = ver("1.0.0-rc.1".to_text());
    assert(!matches_default(&c, &pre));
}

// =============================================================================
// §F  X-ranges — wildcard expansions.
// =============================================================================

@test_case("*",    "1.0.0",  true)
@test_case("*",    "99.9.9", true)
@test_case("1.x",  "1.5.0",  true)
@test_case("1.x",  "2.0.0",  false)
@test_case("1.2.x","1.2.5",  true)
@test_case("1.2.x","1.3.0",  false)
fn parametrised_x_range(constraint: Text, version: Text, expected: Bool) {
    let c = parse_constraint(&constraint).unwrap();
    let v = ver(version.to_text());
    assert_eq(c.matches(&v), expected,
        f"x-range '{constraint}'.matches('{version}') expected {expected}");
}

fn main() {}
