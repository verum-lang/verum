// =============================================================================
// core-tests/base/semver_constraint/property_test.vr
// =============================================================================
//
// Algebraic-law verification for `core.base.semver_constraint` —
// `exact` reflexivity, `caret` / `tilde` monotonicity boundaries,
// `Any` / `Empty` lattice laws, and convenience-constructor identity.
//
// All construction uses direct record/sum variants to bypass the
// `parse` bare-name dispatch defect (task #17/#39) and the
// `MatchAst` type-confusion downstream (see `regression_test.vr §A`).
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer};
mount core.base.semver_constraint.{
    SemVerConstraint, MatchOptions,
    matches_default, matches,
    match_options_default,
    exact, caret, tilde, tilde_minor, tilde_major,
    x_range_major, x_range_minor,
    and, or,
};
mount core.collections.list.List;

fn mk_semver(major: UInt64, minor: UInt64, patch: UInt64) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: List.new(),
        build_meta:  List.new(),
    }
}

// =============================================================================
// §A  exact is reflexive on the anchor version.
// =============================================================================

@test
fn law_exact_reflexive_on_anchor() {
    let cases: List<(UInt64, UInt64, UInt64)> = [
        (0_u64, 0_u64, 0_u64),
        (1_u64, 0_u64, 0_u64),
        (1_u64, 2_u64, 3_u64),
        (10_u64, 20_u64, 30_u64),
    ];
    let mut i: Int = 0;
    while i < cases.len() {
        let p = cases[i].clone();
        let v = mk_semver(p.0, p.1, p.2);
        let c = exact(v.clone());
        assert(matches_default(&c, &v));
        i = i + 1;
    }
}

// =============================================================================
// §B  Any matches every release version.
// =============================================================================

@test
fn law_any_matches_every_release_version() {
    let c = SemVerConstraint.Any;
    let versions: List<SemVer> = [
        mk_semver(0_u64, 0_u64, 0_u64),
        mk_semver(1_u64, 0_u64, 0_u64),
        mk_semver(99_u64, 99_u64, 99_u64),
    ];
    let mut i: Int = 0;
    while i < versions.len() {
        assert(matches_default(&c, &versions[i]));
        i = i + 1;
    }
}

// =============================================================================
// §C  Empty matches no version.
// =============================================================================

@test
fn law_empty_matches_no_release_version() {
    let c = SemVerConstraint.Empty;
    let versions: List<SemVer> = [
        mk_semver(0_u64, 0_u64, 0_u64),
        mk_semver(1_u64, 2_u64, 3_u64),
        mk_semver(99_u64, 99_u64, 99_u64),
    ];
    let mut i: Int = 0;
    while i < versions.len() {
        assert(!matches_default(&c, &versions[i]));
        i = i + 1;
    }
}

// =============================================================================
// §D  caret(v) accepts v and v.patch+N within the same minor.
// =============================================================================

@test
fn law_caret_accepts_higher_patch_within_same_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = caret(v);
    let patches: List<UInt64> = [3_u64, 4_u64, 5_u64, 10_u64, 99_u64];
    let mut i: Int = 0;
    while i < patches.len() {
        let candidate = mk_semver(1_u64, 2_u64, patches[i].clone());
        assert(matches_default(&c, &candidate));
        i = i + 1;
    }
}

@test
fn law_caret_rejects_lower_patch_within_same_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = caret(v);
    let v_lower = mk_semver(1_u64, 2_u64, 2_u64);
    assert(!matches_default(&c, &v_lower));
}

@test
fn law_caret_rejects_next_major_for_any_minor_patch() {
    let v = mk_semver(1_u64, 0_u64, 0_u64);
    let c = caret(v);
    let bad: List<SemVer> = [
        mk_semver(2_u64, 0_u64, 0_u64),
        mk_semver(2_u64, 1_u64, 0_u64),
        mk_semver(2_u64, 99_u64, 99_u64),
        mk_semver(3_u64, 0_u64, 0_u64),
    ];
    let mut i: Int = 0;
    while i < bad.len() {
        assert(!matches_default(&c, &bad[i]));
        i = i + 1;
    }
}

// =============================================================================
// §E  tilde(v) accepts higher patch but rejects next minor.
// =============================================================================

@test
fn law_tilde_accepts_higher_patch_within_same_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = tilde(v);
    let v_high = mk_semver(1_u64, 2_u64, 99_u64);
    assert(matches_default(&c, &v_high));
}

@test
fn law_tilde_rejects_higher_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = tilde(v);
    let v_next_minor = mk_semver(1_u64, 3_u64, 0_u64);
    assert(!matches_default(&c, &v_next_minor));
}

// =============================================================================
// §F  tilde_major / x_range_major aliases match every minor.patch in
//     major and reject any next-major version.
// =============================================================================

@test
fn law_tilde_major_full_minor_patch_coverage() {
    let c = tilde_major(1_u64);
    let cases: List<SemVer> = [
        mk_semver(1_u64, 0_u64, 0_u64),
        mk_semver(1_u64, 5_u64, 0_u64),
        mk_semver(1_u64, 99_u64, 99_u64),
    ];
    let mut i: Int = 0;
    while i < cases.len() {
        assert(matches_default(&c, &cases[i]));
        i = i + 1;
    }
}

@test
fn law_tilde_major_rejects_next_major() {
    let c = tilde_major(1_u64);
    let next = mk_semver(2_u64, 0_u64, 0_u64);
    assert(!matches_default(&c, &next));
}

@test
fn law_x_range_major_aliases_tilde_major() {
    let c1 = tilde_major(1_u64);
    let c2 = x_range_major(1_u64);
    let v = mk_semver(1_u64, 5_u64, 7_u64);
    assert_eq(matches_default(&c1, &v), matches_default(&c2, &v));
}

@test
fn law_x_range_minor_aliases_tilde_minor() {
    let c1 = tilde_minor(1_u64, 2_u64);
    let c2 = x_range_minor(1_u64, 2_u64);
    let v = mk_semver(1_u64, 2_u64, 99_u64);
    assert_eq(matches_default(&c1, &v), matches_default(&c2, &v));
}

// =============================================================================
// §G  and/or — basic identity laws over Any / Empty.
// =============================================================================

@test
fn law_and_with_any_collapses_to_other() {
    // and(Any, x) and and(x, Any) both reduce to x (the source
    // line 236-243 implements this absorption).
    let target = mk_semver(1_u64, 0_u64, 0_u64);
    let c_x = exact(target.clone());
    let r = and(SemVerConstraint.Any, c_x);
    assert(matches_default(&r, &target));
}

@test
fn law_and_with_empty_collapses_to_empty() {
    // and(Empty, x) and and(x, Empty) both reduce to Empty.
    let target = mk_semver(1_u64, 0_u64, 0_u64);
    let c_x = exact(target.clone());
    let r = and(SemVerConstraint.Empty, c_x);
    assert(!matches_default(&r, &target));
}

@test
fn law_or_with_any_collapses_to_any() {
    let v = mk_semver(99_u64, 99_u64, 99_u64);
    let c_x = exact(mk_semver(1_u64, 0_u64, 0_u64));
    let r = or(SemVerConstraint.Any, c_x);
    // Anything matches.
    assert(matches_default(&r, &v));
}

@test
fn law_or_with_empty_collapses_to_other() {
    let target = mk_semver(1_u64, 0_u64, 0_u64);
    let c_x = exact(target.clone());
    let r = or(SemVerConstraint.Empty, c_x);
    assert(matches_default(&r, &target));
}

fn main() {}
