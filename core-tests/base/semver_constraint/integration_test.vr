// =============================================================================
// core-tests/base/semver_constraint/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.semver_constraint` — constraints
// in List<SemVerConstraint>, multi-version filtering against a
// constraint, MatchOptions strict vs allow-prerelease modes.
//
// All construction uses direct record/sum-variant constructors. Live
// `parse_constraint(s)` is gated on task #17/#39 — pinned at
// `regression_test.vr §A`.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer};
mount core.base.semver_constraint.{
    SemVerConstraint, MatchOptions,
    matches_default, matches, matches_allow_prerelease,
    match_options_default, match_options_allow_prerelease,
    exact, caret, tilde, tilde_major, tilde_minor,
    and, or,
};
mount core.collections.list.List;

fn mk_semver(major: UInt64, minor: UInt64, patch: UInt64) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: List.new(),
        build_meta:  List.new(),
    }
}

fn mk_prerelease(major: UInt64, minor: UInt64, patch: UInt64, tag: Text) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: [tag],
        build_meta:  List.new(),
    }
}

// =============================================================================
// Section 1: MatchOptions — strict default rejects prereleases
// =============================================================================

@test
fn integration_default_options_reject_prerelease_when_constraint_is_release() {
    let c = caret(mk_semver(1_u64, 0_u64, 0_u64));
    let pre = mk_prerelease(1_u64, 5_u64, 0_u64, "alpha".to_text());
    // Default mode: prerelease NOT eligible for release-constraint.
    assert(!matches_default(&c, &pre));
}

@test
fn integration_allow_prerelease_options_admit_prerelease() {
    // allow_prerelease allows prerelease input ONLY when an operand
    // is itself a prerelease at the same triple. Two-sided release
    // constraint still excludes a different-triple prerelease.
    let c = exact(mk_prerelease(1_u64, 0_u64, 0_u64, "alpha".to_text()));
    let v = mk_prerelease(1_u64, 0_u64, 0_u64, "alpha".to_text());
    let opts = match_options_allow_prerelease();
    assert(matches(&c, &v, &opts));
}

// =============================================================================
// Section 2: Filtering a List<SemVer> through a constraint
// =============================================================================

@test
fn integration_filter_versions_through_caret_constraint() {
    let c = caret(mk_semver(1_u64, 0_u64, 0_u64));
    let candidates: List<SemVer> = [
        mk_semver(0_u64, 9_u64, 9_u64),   // below 1.0
        mk_semver(1_u64, 0_u64, 0_u64),   // exact anchor
        mk_semver(1_u64, 5_u64, 0_u64),   // higher minor in same major
        mk_semver(1_u64, 99_u64, 99_u64), // highest within same major
        mk_semver(2_u64, 0_u64, 0_u64),   // next major
        mk_semver(2_u64, 5_u64, 0_u64),   // far above
    ];
    let mut matched_count: Int = 0;
    let mut i: Int = 0;
    while i < candidates.len() {
        if matches_default(&c, &candidates[i]) {
            matched_count = matched_count + 1;
        }
        i = i + 1;
    }
    // 1.0.0, 1.5.0, 1.99.99 all match — 3 versions.
    assert_eq(matched_count, 3);
}

@test
fn integration_filter_versions_through_tilde_constraint() {
    let c = tilde(mk_semver(1_u64, 2_u64, 0_u64));
    let candidates: List<SemVer> = [
        mk_semver(1_u64, 1_u64, 99_u64),  // below same-minor
        mk_semver(1_u64, 2_u64, 0_u64),   // exact anchor
        mk_semver(1_u64, 2_u64, 5_u64),   // higher patch
        mk_semver(1_u64, 2_u64, 99_u64),  // highest within same-minor
        mk_semver(1_u64, 3_u64, 0_u64),   // next minor
    ];
    let mut matched_count: Int = 0;
    let mut i: Int = 0;
    while i < candidates.len() {
        if matches_default(&c, &candidates[i]) {
            matched_count = matched_count + 1;
        }
        i = i + 1;
    }
    // 1.2.0, 1.2.5, 1.2.99 — 3 versions.
    assert_eq(matched_count, 3);
}

// =============================================================================
// Section 3: Compound constraints — and/or composition
// =============================================================================

@test
fn integration_compound_and_intersects_two_bounds() {
    // Constraint: >=1.0.0 AND <2.0.0
    let lower = SemVerConstraint.Gte(mk_semver(1_u64, 0_u64, 0_u64));
    let upper = SemVerConstraint.Lt(mk_semver(2_u64, 0_u64, 0_u64));
    let c = and(lower, upper);

    let inside  = mk_semver(1_u64, 5_u64, 0_u64);
    let below   = mk_semver(0_u64, 9_u64, 0_u64);
    let on_low  = mk_semver(1_u64, 0_u64, 0_u64);
    let on_high = mk_semver(2_u64, 0_u64, 0_u64);

    assert(matches_default(&c, &inside));
    assert(!matches_default(&c, &below));
    assert(matches_default(&c, &on_low));   // Gte includes equal
    assert(!matches_default(&c, &on_high)); // Lt excludes equal
}

@test
fn integration_compound_or_unions_two_branches() {
    // Constraint: ^1.0.0 OR ^3.0.0
    let c = or(
        caret(mk_semver(1_u64, 0_u64, 0_u64)),
        caret(mk_semver(3_u64, 0_u64, 0_u64)),
    );

    let in_first  = mk_semver(1_u64, 5_u64, 0_u64);
    let in_second = mk_semver(3_u64, 9_u64, 9_u64);
    let in_gap    = mk_semver(2_u64, 0_u64, 0_u64);

    assert(matches_default(&c, &in_first));
    assert(matches_default(&c, &in_second));
    assert(!matches_default(&c, &in_gap));
}

// =============================================================================
// Section 4: x-range semantics
// =============================================================================

@test
fn integration_tilde_major_full_coverage() {
    let c = tilde_major(2_u64);
    let in_range: List<SemVer> = [
        mk_semver(2_u64, 0_u64, 0_u64),
        mk_semver(2_u64, 1_u64, 0_u64),
        mk_semver(2_u64, 99_u64, 99_u64),
    ];
    let out_of_range: List<SemVer> = [
        mk_semver(1_u64, 99_u64, 99_u64),
        mk_semver(3_u64, 0_u64, 0_u64),
    ];
    let mut i: Int = 0;
    while i < in_range.len() {
        assert(matches_default(&c, &in_range[i]));
        i = i + 1;
    }
    let mut j: Int = 0;
    while j < out_of_range.len() {
        assert(!matches_default(&c, &out_of_range[j]));
        j = j + 1;
    }
}

// =============================================================================
// Section 5: SemVerConstraint variants in List<SemVerConstraint>
// =============================================================================

@test
fn integration_constraint_variants_in_list() {
    let v = mk_semver(1_u64, 0_u64, 0_u64);
    let constraints: List<SemVerConstraint> = [
        SemVerConstraint.Any,
        SemVerConstraint.Empty,
        SemVerConstraint.Eq(v.clone()),
        SemVerConstraint.Gte(v.clone()),
        SemVerConstraint.Lt(v.clone()),
    ];
    assert_eq(constraints.len(), 5);
}

fn main() {}
