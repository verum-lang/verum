// =============================================================================
// core-tests/base/semver_constraint/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.semver_constraint` — prerelease matching
// modes, X-range equivalences, compound constraint parsing, and real-world
// dependency resolution scenarios.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer, parse as parse_version, cmp};
mount core.base.semver_constraint.{
    SemVerConstraint, parse as parse_constraint,
    MatchOptions,
    match_options_default, match_options_allow_prerelease,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: Prerelease matching — default mode excludes prereleases
// =============================================================================

@test
fn test_caret_default_excludes_prerelease() {
    let c = parse_constraint("^1.2.3").unwrap();
    let pre = parse_version("1.3.0-beta.1").unwrap();
    // Default mode: prerelease of same range excluded
    assert(!c.matches_with(&pre, match_options_default()));
}

@test
fn test_caret_allow_prerelease_includes_beta() {
    let c = parse_constraint("^1.2.3").unwrap();
    let pre = parse_version("1.3.0-beta.1").unwrap();
    assert(c.matches_with(&pre, match_options_allow_prerelease()));
}

@test
fn test_tilde_default_excludes_prerelease() {
    let c = parse_constraint("~1.2.3").unwrap();
    let pre = parse_version("1.2.5-alpha").unwrap();
    assert(!c.matches_with(&pre, match_options_default()));
}

@test
fn test_tilde_allow_prerelease_includes_alpha() {
    let c = parse_constraint("~1.2.3").unwrap();
    let pre = parse_version("1.2.5-alpha").unwrap();
    assert(c.matches_with(&pre, match_options_allow_prerelease()));
}

// =============================================================================
// Section 2: X-ranges
// =============================================================================

@test
fn test_x_range_major_wildcard_matches_any_version() {
    let c = parse_constraint("*").unwrap();
    let v1 = parse_version("1.0.0").unwrap();
    let v2 = parse_version("99.99.99").unwrap();
    assert(c.matches(&v1));
    assert(c.matches(&v2));
}

@test
fn test_x_range_minor_wildcard_matches_same_major() {
    let c = parse_constraint("1.x").unwrap();
    let v_match = parse_version("1.5.0").unwrap();
    let v_no_match = parse_version("2.0.0").unwrap();
    assert(c.matches(&v_match));
    assert(!c.matches(&v_no_match));
}

@test
fn test_x_range_patch_wildcard_equivalent_to_tilde() {
    // 1.2.x == ~1.2.0 (same-minor, any patch)
    let c_x = parse_constraint("1.2.x").unwrap();
    let c_tilde = parse_constraint("~1.2.0").unwrap();
    let versions: List<Text> = ["1.2.0", "1.2.5", "1.2.99", "1.3.0", "2.0.0"];
    for v_str in versions {
        let v = parse_version(v_str).unwrap();
        assert_eq(c_x.matches(&v), c_tilde.matches(&v),
            f"1.2.x vs ~1.2.0 disagreed on {v_str}");
    }
}

// =============================================================================
// Section 3: Dependency resolution scenario
// =============================================================================

@test
fn test_resolve_compatible_versions_from_list() {
    let constraint = parse_constraint("^2.0.0").unwrap();
    let candidates: List<Text> = [
        "1.9.9", "2.0.0", "2.1.0", "2.9.9", "3.0.0",
    ];
    let compatible: List<Text> = candidates.filter(|v_str| {
        parse_version(v_str)
            .map(|v| constraint.matches(&v))
            .unwrap_or(false)
    }).collect();
    assert_eq(compatible, ["2.0.0", "2.1.0", "2.9.9"]);
}

@test
fn test_resolve_latest_compatible() {
    let constraint = parse_constraint("^1.0.0").unwrap();
    let candidates: List<SemVer> = [
        "1.0.0", "1.1.0", "1.2.5", "2.0.0",
    ].map(|s| parse_version(s).unwrap()).collect();
    let compatible: List<SemVer> = candidates.filter(|v| constraint.matches(v)).collect();
    assert_eq(compatible.len(), 3);
    // Sort and pick highest
    let mut sorted = compatible.clone();
    sorted.sort_by(|a, b| cmp(b, a));  // descending
    let latest = sorted.get(0).unwrap();
    assert_eq(latest.minor, 2);
}

fn main() {}
