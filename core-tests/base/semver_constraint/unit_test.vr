// =============================================================================
// core-tests/base/semver_constraint/unit_test.vr
// =============================================================================
//
// Tests for `core.base.semver_constraint` — constraint parser/matcher.
// Operators: ^1.2 (caret), ~1.2 (tilde), >=1.0 <2.0, exact, x-ranges.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer, parse as parse_ver};
mount core.base.semver_constraint.{
    SemVerConstraint, parse, matches_default, matches,
    exact, caret, tilde, tilde_minor, tilde_major,
    match_options_default, match_options_allow_prerelease,
    format_constraint,
};
mount core.collections.list.List;

fn ver(s: Text) -> SemVer { parse_ver(&s).unwrap() }

// =============================================================================
// Section 1: caret semantics — ^1.2.3 means >=1.2.3 <2.0.0
// =============================================================================

@test
fn test_caret_matches_within_major() {
    let c = caret(ver("1.2.3".to_text()));
    assert(matches_default(&c, &ver("1.2.3".to_text())));
    assert(matches_default(&c, &ver("1.2.4".to_text())));
    assert(matches_default(&c, &ver("1.5.0".to_text())));
    assert(matches_default(&c, &ver("1.99.99".to_text())));
}

@test
fn test_caret_rejects_next_major() {
    let c = caret(ver("1.2.3".to_text()));
    assert(!matches_default(&c, &ver("2.0.0".to_text())));
}

@test
fn test_caret_rejects_below_lower() {
    let c = caret(ver("1.2.3".to_text()));
    assert(!matches_default(&c, &ver("1.2.2".to_text())));
    assert(!matches_default(&c, &ver("0.9.9".to_text())));
}

// =============================================================================
// Section 2: tilde semantics — ~1.2.3 means >=1.2.3 <1.3.0
// =============================================================================

@test
fn test_tilde_matches_within_minor() {
    let c = tilde(ver("1.2.3".to_text()));
    assert(matches_default(&c, &ver("1.2.3".to_text())));
    assert(matches_default(&c, &ver("1.2.99".to_text())));
}

@test
fn test_tilde_rejects_next_minor() {
    let c = tilde(ver("1.2.3".to_text()));
    assert(!matches_default(&c, &ver("1.3.0".to_text())));
}

// =============================================================================
// Section 3: exact match
// =============================================================================

@test
fn test_exact_matches_only_self() {
    let c = exact(ver("1.2.3".to_text()));
    assert(matches_default(&c, &ver("1.2.3".to_text())));
    assert(!matches_default(&c, &ver("1.2.4".to_text())));
    assert(!matches_default(&c, &ver("1.2.2".to_text())));
}

// =============================================================================
// Section 4: parse common constraint syntaxes
// =============================================================================

@test
fn test_parse_caret_syntax() {
    let r = parse(&"^1.2.3".to_text());
    assert(r.is_ok());
}

@test
fn test_parse_tilde_syntax() {
    let r = parse(&"~1.2.3".to_text());
    assert(r.is_ok());
}

@test
fn test_parse_exact_syntax() {
    let r = parse(&"1.2.3".to_text());
    assert(r.is_ok());
}

@test
fn test_parse_invalid_returns_err() {
    let r = parse(&"not-a-constraint".to_text());
    assert(r.is_err());
}

// =============================================================================
// Section 5: format round-trip (where deterministic)
// =============================================================================

@test
fn test_format_caret_round_trip() {
    let c = parse(&"^1.2.3".to_text()).unwrap();
    let formatted = format_constraint(&c);
    let reparsed = parse(&formatted).unwrap();
    assert_eq(format_constraint(&reparsed), formatted);
}

fn main() {}
