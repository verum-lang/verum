// =============================================================================
// core-tests/base/semver_constraint/unit_test.vr
// =============================================================================
//
// Tests for `core.base.semver_constraint` — constraint parser/matcher
// over Cargo / npm-style semver expressions
//   (^1.2 caret, ~1.2 tilde, >=1.0 <2.0, exact, x-ranges, alternation).
//
// Field-access through `parse(s).unwrap()` and through `parse_ver(...)`
// hits the same task #17/#39 bare-name dispatch defect as `base/semver`
// (`parse(&"1.2.3").unwrap()` mis-routes via the `MatchAst`-returning
// regex `parse` sibling). Symptom — every match-test that goes through
// `parse_ver(s)` ultimately panics at `core.base.semver.cmp`:
//
//   field access out of bounds: field index 2 (offset 16+8 = 24)
//   exceeds object data size 16 type_id=... type='MatchAst'
//
// Workaround in this file: construct `SemVer` via direct record literal
// AND construct `SemVerConstraint` either via direct sum-variant
// `SemVerConstraint.Eq(v)` / `SemVerConstraint.Gte(v)` / ... or via the
// convenience constructors `exact` / `caret` / `tilde` / `tilde_major` /
// `tilde_minor`. Live `parse` is pinned `@ignore`'d at
// `regression_test.vr §A`.
// =============================================================================

mount core.prelude.*;
mount core.base.semver.{SemVer};
mount core.base.semver_constraint.{
    SemVerConstraint, SemVerConstraintError, MatchOptions,
    matches_default, matches, matches_allow_prerelease,
    match_options_default, match_options_allow_prerelease,
    exact, caret, tilde, tilde_minor, tilde_major,
    x_range_major, x_range_minor,
    and, or,
};
mount core.collections.list.List;

fn mk_semver(major: UInt64, minor: UInt64, patch: UInt64) -> SemVer {
    SemVer {
        major: major,
        minor: minor,
        patch: patch,
        pre_release: List.new(),
        build_meta:  List.new(),
    }
}

// =============================================================================
// Section 1: exact — `=v` matches only that exact triple
// =============================================================================

@test
fn test_exact_matches_only_self() {
    let target = mk_semver(1_u64, 2_u64, 3_u64);
    let c = exact(target);
    let v_match  = mk_semver(1_u64, 2_u64, 3_u64);
    let v_higher = mk_semver(1_u64, 2_u64, 4_u64);
    let v_lower  = mk_semver(1_u64, 2_u64, 2_u64);
    assert(matches_default(&c, &v_match));
    assert(!matches_default(&c, &v_higher));
    assert(!matches_default(&c, &v_lower));
}

@test
fn test_exact_construction_returns_eq_variant() {
    let v = mk_semver(1_u64, 0_u64, 0_u64);
    let c = exact(v);
    match c {
        SemVerConstraint.Eq(_) => {},
        _ => panic("expected Eq variant from exact"),
    }
}

// =============================================================================
// Section 2: caret — Cargo-style major-stable
// =============================================================================

@test
fn test_caret_matches_anchor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = caret(v);
    let v_self = mk_semver(1_u64, 2_u64, 3_u64);
    assert(matches_default(&c, &v_self));
}

@test
fn test_caret_matches_higher_minor_within_same_major() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = caret(v);
    let v_higher = mk_semver(1_u64, 5_u64, 0_u64);
    assert(matches_default(&c, &v_higher));
}

@test
fn test_caret_matches_higher_patch_within_same_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = caret(v);
    let v_higher = mk_semver(1_u64, 2_u64, 4_u64);
    assert(matches_default(&c, &v_higher));
}

@test
fn test_caret_rejects_lower_patch_within_same_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = caret(v);
    let v_lower = mk_semver(1_u64, 2_u64, 2_u64);
    assert(!matches_default(&c, &v_lower));
}

@test
fn test_caret_rejects_next_major() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = caret(v);
    let v_next_major = mk_semver(2_u64, 0_u64, 0_u64);
    assert(!matches_default(&c, &v_next_major));
}

// =============================================================================
// Section 3: tilde — npm-style minor-stable
// =============================================================================

@test
fn test_tilde_matches_anchor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = tilde(v);
    let v_self = mk_semver(1_u64, 2_u64, 3_u64);
    assert(matches_default(&c, &v_self));
}

@test
fn test_tilde_matches_higher_patch_within_same_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = tilde(v);
    let v_higher = mk_semver(1_u64, 2_u64, 99_u64);
    assert(matches_default(&c, &v_higher));
}

@test
fn test_tilde_rejects_next_minor() {
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    let c = tilde(v);
    let v_next_minor = mk_semver(1_u64, 3_u64, 0_u64);
    assert(!matches_default(&c, &v_next_minor));
}

// =============================================================================
// Section 4: tilde_major / tilde_minor / x_range_* convenience ctors
// =============================================================================

@test
fn test_tilde_major_matches_any_minor_within_major() {
    let c = tilde_major(1_u64);
    let v = mk_semver(1_u64, 5_u64, 99_u64);
    assert(matches_default(&c, &v));
}

@test
fn test_tilde_major_rejects_next_major() {
    let c = tilde_major(1_u64);
    let v_next = mk_semver(2_u64, 0_u64, 0_u64);
    assert(!matches_default(&c, &v_next));
}

@test
fn test_tilde_minor_matches_higher_patch_within_minor() {
    let c = tilde_minor(1_u64, 2_u64);
    let v_higher = mk_semver(1_u64, 2_u64, 99_u64);
    assert(matches_default(&c, &v_higher));
}

@test
fn test_tilde_minor_rejects_next_minor() {
    let c = tilde_minor(1_u64, 2_u64);
    let v_next = mk_semver(1_u64, 3_u64, 0_u64);
    assert(!matches_default(&c, &v_next));
}

@test
fn test_x_range_major_aliases_tilde_major() {
    // x_range_major(1) == tilde_major(1) per source line 230.
    let c_x = x_range_major(1_u64);
    let v = mk_semver(1_u64, 5_u64, 0_u64);
    assert(matches_default(&c_x, &v));
}

@test
fn test_x_range_minor_aliases_tilde_minor() {
    // x_range_minor(1, 2) == tilde_minor(1, 2) per source line 233.
    let c_x = x_range_minor(1_u64, 2_u64);
    let v = mk_semver(1_u64, 2_u64, 99_u64);
    assert(matches_default(&c_x, &v));
}

// =============================================================================
// Section 5: MatchOptions factories
// =============================================================================

@test
fn test_match_options_default_disallows_prerelease() {
    let o = match_options_default();
    assert(!o.allow_prerelease);
}

@test
fn test_match_options_allow_prerelease_enables_flag() {
    let o = match_options_allow_prerelease();
    assert(o.allow_prerelease);
}

// =============================================================================
// Section 6: matches (with explicit MatchOptions)
// =============================================================================

@test
fn test_matches_default_via_explicit_options() {
    let v = mk_semver(1_u64, 0_u64, 0_u64);
    let c = exact(v.clone());
    let opts = match_options_default();
    assert(matches(&c, &v, &opts));
}

@test
fn test_matches_allow_prerelease_admits_prerelease() {
    let target = mk_semver(1_u64, 0_u64, 0_u64);
    let c = exact(target.clone());
    // allow_prerelease mode allows pre-release input only when the
    // CONSTRAINT operand is at the same triple. Here both sides are
    // non-prerelease, so allow_prerelease has no effect — simple
    // smoke test.
    assert(matches_allow_prerelease(&c, &target));
}

// =============================================================================
// Section 7: SemVerConstraint sum variants — direct construction
// =============================================================================

@test
fn test_constraint_any_matches_anything_release() {
    let c = SemVerConstraint.Any;
    let v = mk_semver(1_u64, 2_u64, 3_u64);
    assert(matches_default(&c, &v));
}

@test
fn test_constraint_empty_matches_nothing() {
    let c = SemVerConstraint.Empty;
    let v = mk_semver(0_u64, 0_u64, 0_u64);
    assert(!matches_default(&c, &v));
}

@test
fn test_constraint_gte_admits_equal_and_higher() {
    let target = mk_semver(1_u64, 0_u64, 0_u64);
    let c = SemVerConstraint.Gte(target.clone());
    assert(matches_default(&c, &target));
    let higher = mk_semver(2_u64, 0_u64, 0_u64);
    assert(matches_default(&c, &higher));
}

@test
fn test_constraint_lt_rejects_equal_and_higher() {
    let target = mk_semver(1_u64, 0_u64, 0_u64);
    let c = SemVerConstraint.Lt(target.clone());
    assert(!matches_default(&c, &target));
    let lower = mk_semver(0_u64, 9_u64, 0_u64);
    assert(matches_default(&c, &lower));
}

// =============================================================================
// Section 8: SemVerConstraintError variants
// =============================================================================

@test
fn test_error_invalid_constraint_eq_reflexive() {
    let a = SemVerConstraintError.InvalidConstraint("test".to_text());
    let b = SemVerConstraintError.InvalidConstraint("test".to_text());
    assert(a == b);
}

@test
fn test_error_invalid_constraint_same_variant_different_payload_unequal() {
    let a = SemVerConstraintError.InvalidConstraint("x".to_text());
    let b = SemVerConstraintError.InvalidConstraint("y".to_text());
    assert(!(a == b));
}

fn main() {}
