// =============================================================================
// core-tests/base/snowflake/unit_test.vr
// =============================================================================
//
// Tests for `core.base.snowflake` — Twitter-style 64-bit time-ordered
// IDs: 41-bit timestamp + 10-bit worker + 12-bit sequence.
//
// Two distinct test groups:
//   • Pure-data surface — Snowflake.new validation, SnowflakeError
//     variants, parse round-trip with synthetic IDs, layout constants.
//   • Live next_id surface — gated on `SystemTime.now()` dispatching
//     correctly. Currently `SystemTime.now()` mis-dispatches to
//     `SysTimeOpsInstant.now()` (task #17/#39 bare-name collision in
//     static-method dispatch), so every `next_id()` call panics with
//     `field access out of bounds: ... type='SysTimeOpsInstant'`.
//     Pinned as @ignore'd; flips green when the dispatcher is mount-
//     scope-aware.
// =============================================================================

mount core.prelude.*;
mount core.base.snowflake.{
    Snowflake, SnowflakeError, SnowflakeParts, parse,
    MAX_WORKER, MAX_SEQUENCE, DEFAULT_EPOCH_MS,
    WORKER_BITS, SEQUENCE_BITS, WORKER_SHIFT, TIMESTAMP_SHIFT,
};
mount core.collections.list.List;

// =============================================================================
// Section 1: Snowflake.new — validation
// =============================================================================

@test
fn test_snowflake_new_with_valid_worker() {
    let r = Snowflake.new(0_u64, 1_u64);
    assert(r.is_ok());
}

@test
fn test_snowflake_new_with_default_epoch_via_helper() {
    let r = Snowflake.using_default_epoch(1_u64);
    assert(r.is_ok());
}

@test
fn test_snowflake_new_worker_id_zero() {
    // 0 is the minimum legal worker_id.
    let r = Snowflake.new(0_u64, 0_u64);
    assert(r.is_ok());
}

@test
fn test_snowflake_new_worker_id_at_max() {
    // MAX_WORKER == 1023 is the maximum legal worker_id.
    let r = Snowflake.new(0_u64, MAX_WORKER);
    assert(r.is_ok());
}

@test
fn test_snowflake_new_rejects_worker_above_max() {
    let r = Snowflake.new(0_u64, MAX_WORKER + 1_u64);
    assert(r.is_err());
}

@test
fn test_snowflake_new_rejects_worker_far_above_max() {
    let r = Snowflake.new(0_u64, 9999_u64);
    assert(r.is_err());
}

// =============================================================================
// Section 2: Layout constants
// =============================================================================

@test
fn test_worker_bits_constant() {
    assert_eq(WORKER_BITS, 10);
}

@test
fn test_sequence_bits_constant() {
    assert_eq(SEQUENCE_BITS, 12);
}

@test
fn test_max_worker_constant() {
    assert_eq(MAX_WORKER, 1023_u64);
}

@test
fn test_max_sequence_constant() {
    assert_eq(MAX_SEQUENCE, 4095_u64);
}

@test
fn test_worker_shift_constant() {
    assert_eq(WORKER_SHIFT, 12_u64);
}

@test
fn test_timestamp_shift_constant() {
    assert_eq(TIMESTAMP_SHIFT, 22_u64);
}

@test
fn test_default_epoch_ms_twitter_2010() {
    // Twitter's original epoch: 2010-11-04 01:42:54.657 UTC.
    assert_eq(DEFAULT_EPOCH_MS, 1_288_834_974_657_u64);
}

@test
fn test_max_worker_equals_one_less_than_two_to_bits() {
    // MAX_WORKER == (1 << WORKER_BITS) - 1
    let expected: UInt64 = (1_u64 << 10_u64) - 1_u64;
    assert_eq(MAX_WORKER, expected);
}

@test
fn test_max_sequence_equals_one_less_than_two_to_bits() {
    // MAX_SEQUENCE == (1 << SEQUENCE_BITS) - 1
    let expected: UInt64 = (1_u64 << 12_u64) - 1_u64;
    assert_eq(MAX_SEQUENCE, expected);
}

// =============================================================================
// Section 3: SnowflakeError variants — disjoint construction
// =============================================================================

@test
fn test_snowflake_error_worker_id_out_of_range_payload() {
    let err = SnowflakeError.WorkerIdOutOfRange(9999_u64);
    match err {
        SnowflakeError.WorkerIdOutOfRange(id) => assert_eq(id, 9999_u64),
        SnowflakeError.ClockRegressed(_)     => panic("expected WorkerIdOutOfRange"),
        SnowflakeError.ClockBeforeEpoch(_)   => panic("expected WorkerIdOutOfRange"),
    }
}

@test
fn test_snowflake_error_clock_regressed_payload() {
    let err = SnowflakeError.ClockRegressed(500_u64);
    match err {
        SnowflakeError.ClockRegressed(ms) => assert_eq(ms, 500_u64),
        _ => panic("expected ClockRegressed"),
    }
}

@test
fn test_snowflake_error_clock_before_epoch_payload() {
    let err = SnowflakeError.ClockBeforeEpoch(123_u64);
    match err {
        SnowflakeError.ClockBeforeEpoch(ms) => assert_eq(ms, 123_u64),
        _ => panic("expected ClockBeforeEpoch"),
    }
}

@test
fn test_snowflake_error_eq_reflexive_for_each_variant() {
    let a = SnowflakeError.WorkerIdOutOfRange(7_u64);
    let b = SnowflakeError.WorkerIdOutOfRange(7_u64);
    assert(a == b);
    let c = SnowflakeError.ClockRegressed(99_u64);
    let d = SnowflakeError.ClockRegressed(99_u64);
    assert(c == d);
}

@test
fn test_snowflake_error_eq_distinct_variants_unequal() {
    let a = SnowflakeError.WorkerIdOutOfRange(7_u64);
    let b = SnowflakeError.ClockRegressed(7_u64);
    assert(!(a == b));
}

@test
fn test_snowflake_error_eq_same_variant_different_payload_unequal() {
    let a = SnowflakeError.ClockRegressed(100_u64);
    let b = SnowflakeError.ClockRegressed(200_u64);
    assert(!(a == b));
}

// =============================================================================
// Section 4: parse — decompose a synthetic ID back into its parts
// =============================================================================

@test
fn test_parse_synthetic_id_recovers_worker_id() {
    // Hand-build an ID: timestamp_offset = 100, worker = 5, sequence = 9.
    let ts_offset: UInt64 = 100_u64;
    let worker:    UInt64 = 5_u64;
    let sequence:  UInt64 = 9_u64;
    let id: UInt64 = (ts_offset << TIMESTAMP_SHIFT)
                   | (worker    << WORKER_SHIFT)
                   | sequence;
    let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.worker_id, worker);
}

@test
fn test_parse_synthetic_id_recovers_sequence() {
    let ts_offset: UInt64 = 0_u64;
    let worker:    UInt64 = 0_u64;
    let sequence:  UInt64 = 2048_u64;
    let id: UInt64 = (ts_offset << TIMESTAMP_SHIFT)
                   | (worker    << WORKER_SHIFT)
                   | sequence;
    let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.sequence, sequence);
}

@test
fn test_parse_synthetic_id_recovers_timestamp_via_offset() {
    // timestamp_ms == epoch_ms + (id >> TIMESTAMP_SHIFT)
    let ts_offset: UInt64 = 12_345_u64;
    let id: UInt64 = ts_offset << TIMESTAMP_SHIFT;
    let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.timestamp_ms, DEFAULT_EPOCH_MS + ts_offset);
}

@test
fn test_parse_zero_id() {
    let parts: SnowflakeParts = parse(0_u64, DEFAULT_EPOCH_MS);
    assert_eq(parts.worker_id, 0_u64);
    assert_eq(parts.sequence, 0_u64);
    assert_eq(parts.timestamp_ms, DEFAULT_EPOCH_MS);
}

@test
fn test_parse_max_worker_and_sequence_packed_correctly() {
    let id: UInt64 = (MAX_WORKER << WORKER_SHIFT) | MAX_SEQUENCE;
    let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.worker_id, MAX_WORKER);
    assert_eq(parts.sequence,  MAX_SEQUENCE);
}

// =============================================================================
// Section 5: SnowflakeParts — direct construction
// =============================================================================

@test
fn test_snowflake_parts_direct_construction() {
    let p = SnowflakeParts {
        timestamp_ms: 1_000_u64,
        worker_id:    5_u64,
        sequence:     42_u64,
    };
    assert_eq(p.timestamp_ms, 1_000_u64);
    assert_eq(p.worker_id, 5_u64);
    assert_eq(p.sequence, 42_u64);
}

// =============================================================================
// Section 6: Snowflake accessors after construction
// =============================================================================

@test
fn test_snowflake_worker_id_accessor() {
    let sf = Snowflake.new(0_u64, 42_u64).unwrap();
    assert_eq(sf.worker_id(), 42_u64);
}

@test
fn test_snowflake_epoch_ms_accessor() {
    let sf = Snowflake.new(1_234_567_u64, 0_u64).unwrap();
    assert_eq(sf.epoch_ms(), 1_234_567_u64);
}

@test
fn test_snowflake_using_default_epoch_carries_default() {
    let sf = Snowflake.using_default_epoch(1_u64).unwrap();
    assert_eq(sf.epoch_ms(), DEFAULT_EPOCH_MS);
}

fn main() {}
