// =============================================================================
// core-tests/base/snowflake/property_test.vr
// =============================================================================
//
// Algebraic-law verification for `core.base.snowflake` — bit-packing
// invariants, parse round-trip across worker / sequence / timestamp
// dimensions, and worker-id range validation.
//
// Live `next_id()` properties (monotonicity within a burst) are pinned
// in `regression_test.vr §D` as `@ignore`'d — they require the
// `SystemTime.now()` static-method dispatch defect (task #17/#39) to
// close. The pure-bit-layout properties here use synthetic IDs that
// bypass the live-clock path entirely.
// =============================================================================

mount core.prelude.*;
mount core.base.snowflake.{
    Snowflake, SnowflakeParts, parse,
    MAX_WORKER, MAX_SEQUENCE, DEFAULT_EPOCH_MS,
    WORKER_SHIFT, TIMESTAMP_SHIFT,
};
mount core.collections.list.List;

fn build_synthetic_id(ts_offset: UInt64, worker: UInt64, sequence: UInt64) -> UInt64 {
    (ts_offset << TIMESTAMP_SHIFT)
        | (worker << WORKER_SHIFT)
        | sequence
}

// =============================================================================
// §A  parse · build is the identity on each field.
// =============================================================================

@test
fn law_worker_id_round_trip_via_synthetic_id() {
    let workers: List<UInt64> = [
        0_u64, 1_u64, 7_u64, 127_u64, 511_u64, 1_023_u64,
    ];
    let mut i: Int = 0;
    while i < workers.len() {
        let w = workers[i].clone();
        let id = build_synthetic_id(0_u64, w, 0_u64);
        let parts = parse(id, DEFAULT_EPOCH_MS);
        assert_eq(parts.worker_id, w);
        i = i + 1;
    }
}

@test
fn law_sequence_round_trip_via_synthetic_id() {
    let seqs: List<UInt64> = [
        0_u64, 1_u64, 4_u64, 256_u64, 1_023_u64, 2_048_u64, 4_095_u64,
    ];
    let mut i: Int = 0;
    while i < seqs.len() {
        let s = seqs[i].clone();
        let id = build_synthetic_id(0_u64, 0_u64, s);
        let parts = parse(id, DEFAULT_EPOCH_MS);
        assert_eq(parts.sequence, s);
        i = i + 1;
    }
}

@test
fn law_timestamp_offset_round_trip_via_synthetic_id() {
    let offsets: List<UInt64> = [
        0_u64, 1_u64, 1_000_u64, 1_000_000_u64, 1_000_000_000_u64,
    ];
    let mut i: Int = 0;
    while i < offsets.len() {
        let off = offsets[i].clone();
        let id = build_synthetic_id(off, 0_u64, 0_u64);
        let parts = parse(id, DEFAULT_EPOCH_MS);
        assert_eq(parts.timestamp_ms, DEFAULT_EPOCH_MS + off);
        i = i + 1;
    }
}

// =============================================================================
// §B  Bit-field independence: setting one field at a time leaves the
//     others at their zero default.
// =============================================================================

@test
fn law_worker_field_does_not_leak_into_sequence() {
    let id = build_synthetic_id(0_u64, MAX_WORKER, 0_u64);
    let parts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.sequence, 0_u64);
}

@test
fn law_sequence_field_does_not_leak_into_worker() {
    let id = build_synthetic_id(0_u64, 0_u64, MAX_SEQUENCE);
    let parts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.worker_id, 0_u64);
}

@test
fn law_timestamp_does_not_leak_into_worker_or_sequence() {
    let id = build_synthetic_id(9_999_u64, 0_u64, 0_u64);
    let parts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.worker_id, 0_u64);
    assert_eq(parts.sequence,  0_u64);
}

// =============================================================================
// §C  Monotonicity of synthetic IDs across increasing timestamp.
// =============================================================================

@test
fn law_synthetic_id_monotone_in_timestamp() {
    let mut prev: UInt64 = 0_u64;
    let mut off: UInt64 = 0_u64;
    while off < 20_u64 {
        let id = build_synthetic_id(off, 0_u64, 0_u64);
        if off > 0_u64 {
            assert(id > prev);
        }
        prev = id;
        off = off + 1_u64;
    }
}

@test
fn law_synthetic_id_monotone_in_sequence_within_same_ms() {
    let mut prev: UInt64 = 0_u64;
    let mut seq: UInt64 = 0_u64;
    while seq < 20_u64 {
        let id = build_synthetic_id(100_u64, 5_u64, seq);
        if seq > 0_u64 {
            assert(id > prev);
        }
        prev = id;
        seq = seq + 1_u64;
    }
}

// =============================================================================
// §D  Worker-ID validation — parametrised over invalid range.
// =============================================================================

@test_case(2048_u64)
@test_case(4095_u64)
@test_case(99999_u64)
fn parametrised_invalid_worker_id_returns_err(worker: UInt64) {
    let r = Snowflake.using_default_epoch(worker);
    assert(r.is_err());
}

@test_case(0_u64)
@test_case(1_u64)
@test_case(7_u64)
@test_case(MAX_WORKER)
fn parametrised_valid_worker_id_returns_ok(worker: UInt64) {
    let r = Snowflake.using_default_epoch(worker);
    assert(r.is_ok());
}

// =============================================================================
// §E  Bit-layout: 41 + 10 + 12 = 63 bits used (bit 63 reserved sign).
//     The combined mask of (worker | sequence) must fit in the lower
//     22 bits (TIMESTAMP_SHIFT).
// =============================================================================

@test
fn law_max_worker_and_sequence_fit_in_lower_22_bits() {
    let combined: UInt64 = (MAX_WORKER << WORKER_SHIFT) | MAX_SEQUENCE;
    let limit: UInt64 = 1_u64 << TIMESTAMP_SHIFT;
    assert(combined < limit);
}

fn main() {}
