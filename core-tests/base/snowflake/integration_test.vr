// =============================================================================
// core-tests/base/snowflake/integration_test.vr
// =============================================================================
//
// Integration tests for `core.base.snowflake` — multi-worker ID space
// composition, parse + List<UInt64> + Set<UInt64> interaction, and
// bit-layout extraction via synthetic IDs that bypass the live-clock
// dispatch defect.
//
// Live `next_id()` integration is gated on the `SystemTime.now()`
// static-method dispatch defect (task #17/#39 — see
// `regression_test.vr §D`). Until that closes, these tests use
// hand-built synthetic Snowflake IDs to exercise the bit-packing
// contract end-to-end with `parse`.
// =============================================================================

mount core.prelude.*;
mount core.base.snowflake.{
    Snowflake, SnowflakeError, SnowflakeParts, parse,
    using_default_epoch, with_epoch,
    MAX_WORKER, MAX_SEQUENCE, DEFAULT_EPOCH_MS,
    WORKER_SHIFT, TIMESTAMP_SHIFT,
};
mount core.collections.list.List;
mount core.collections.set.Set;

// =============================================================================
// Section 1: Multi-worker generators — construction only
// =============================================================================

@test
fn integration_two_generators_with_distinct_worker_ids() {
    let g1 = using_default_epoch(1_u64).unwrap();
    let g2 = using_default_epoch(2_u64).unwrap();
    assert_eq(g1.worker_id(), 1_u64);
    assert_eq(g2.worker_id(), 2_u64);
    // Both share the canonical Twitter 2010-11-04 epoch.
    assert_eq(g1.epoch_ms(), DEFAULT_EPOCH_MS);
    assert_eq(g2.epoch_ms(), DEFAULT_EPOCH_MS);
}

@test
fn integration_worker_id_boundary_construction() {
    // Worker ID range: 0..=1023 (10-bit field).
    let g_zero = using_default_epoch(0_u64);
    let g_max  = using_default_epoch(1023_u64);
    let g_over = using_default_epoch(1024_u64);
    assert(g_zero.is_ok());
    assert(g_max.is_ok());
    assert(g_over.is_err());
}

@test
fn integration_with_epoch_helper_carries_custom_epoch() {
    let custom_epoch: UInt64 = 1_500_000_000_000_u64;
    let g = with_epoch(custom_epoch, 5_u64).unwrap();
    assert_eq(g.epoch_ms(), custom_epoch);
    assert_eq(g.worker_id(), 5_u64);
}

// =============================================================================
// Section 2: parse + synthetic IDs — bit-layout extraction at scale
// =============================================================================

fn build_synthetic_id(ts_offset: UInt64, worker: UInt64, sequence: UInt64) -> UInt64 {
    (ts_offset << TIMESTAMP_SHIFT)
        | (worker << WORKER_SHIFT)
        | sequence
}

@test
fn integration_parse_recovers_worker_across_full_range() {
    let mut w: UInt64 = 0_u64;
    while w <= 5_u64 {
        let id = build_synthetic_id(100_u64, w, 0_u64);
        let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
        assert_eq(parts.worker_id, w);
        w = w + 1_u64;
    }
}

@test
fn integration_parse_recovers_sequence_at_each_boundary() {
    let cases: List<UInt64> = [
        0_u64, 1_u64, 4_u64, 16_u64, 256_u64,
        1_024_u64, 4_095_u64, MAX_SEQUENCE,
    ];
    let mut i: Int = 0;
    while i < cases.len() {
        let seq: UInt64 = cases[i].clone();
        let id = build_synthetic_id(0_u64, 0_u64, seq);
        let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
        assert_eq(parts.sequence, seq);
        i = i + 1;
    }
}

@test
fn integration_parse_recovers_timestamp_across_offsets() {
    let offsets: List<UInt64> = [
        0_u64, 1_u64, 1_000_u64, 1_000_000_u64, 9_999_999_u64,
    ];
    let mut i: Int = 0;
    while i < offsets.len() {
        let off: UInt64 = offsets[i].clone();
        let id = build_synthetic_id(off, 0_u64, 0_u64);
        let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
        assert_eq(parts.timestamp_ms, DEFAULT_EPOCH_MS + off);
        i = i + 1;
    }
}

@test
fn integration_parse_independent_fields_no_cross_contamination() {
    // Set each field to a distinctive value and confirm `parse`
    // doesn't mix them up — a defect that OR'd the worker bits into
    // the sequence (or vice versa) would surface here.
    let ts_offset: UInt64 = 9_999_u64;
    let worker:    UInt64 = 511_u64;       // bit pattern 0011_1111_1111 (mid-range)
    let sequence:  UInt64 = 2_730_u64;     // bit pattern 1010_1010_1010 (alternating)
    let id = build_synthetic_id(ts_offset, worker, sequence);
    let parts: SnowflakeParts = parse(id, DEFAULT_EPOCH_MS);
    assert_eq(parts.timestamp_ms, DEFAULT_EPOCH_MS + ts_offset);
    assert_eq(parts.worker_id, worker);
    assert_eq(parts.sequence, sequence);
}

// =============================================================================
// Section 3: Synthetic ID corpus inserted into Set<UInt64>
// =============================================================================

@test
fn integration_synthetic_ids_with_distinct_sequences_all_unique() {
    let mut ids: Set<UInt64> = Set.new();
    let mut seq: UInt64 = 0_u64;
    while seq < 100_u64 {
        ids.insert(build_synthetic_id(0_u64, 0_u64, seq));
        seq = seq + 1_u64;
    }
    assert_eq(ids.len(), 100);
}

@test
fn integration_synthetic_ids_two_workers_no_collision_within_same_ms() {
    let mut ids: Set<UInt64> = Set.new();
    let mut seq: UInt64 = 0_u64;
    while seq < 50_u64 {
        ids.insert(build_synthetic_id(0_u64, 1_u64, seq));
        ids.insert(build_synthetic_id(0_u64, 2_u64, seq));
        seq = seq + 1_u64;
    }
    // Worker bits separate the two streams: 50 + 50 = 100 unique.
    assert_eq(ids.len(), 100);
}

@test
fn integration_synthetic_ids_byte_lexicographic_order_matches_chronological() {
    // The promise: byte-lex order of big-endian IDs == chronological
    // order. Within one worker / one sequence-base, monotonically
    // increasing timestamp_offset must produce monotonically
    // increasing UInt64 IDs.
    let mut prev: UInt64 = 0_u64;
    let mut off: UInt64 = 1_u64;
    while off <= 10_u64 {
        let id = build_synthetic_id(off, 5_u64, 0_u64);
        assert(id > prev);
        prev = id;
        off = off + 1_u64;
    }
}

// =============================================================================
// Section 4: SnowflakeError variants in a List<SnowflakeError>
// =============================================================================

@test
fn integration_snowflake_error_variants_in_collection() {
    let errors: List<SnowflakeError> = [
        SnowflakeError.WorkerIdOutOfRange(2000_u64),
        SnowflakeError.ClockRegressed(50_u64),
        SnowflakeError.ClockBeforeEpoch(123_u64),
    ];
    assert_eq(errors.len(), 3);
}

fn main() {}
