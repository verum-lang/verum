// =============================================================================
// core-tests/async/timer/regression_test.vr
// =============================================================================
//
// Defect pins for `core.async.timer`.
//
//   §A — task #15 — Duration.from_millis / from_nanos / from_micros
//                  dispatch routes to an Int receiver from user code
//   §B — task #17 — TimerInterval.period() field-vs-method-name
//                  shadowing causes infinite recursion
//   §C — task #16 — Timeout<F> field-layout write out of bounds
//   §D — task #14 — timeout_ms cross-module name collision
//
// All @ignored pending architectural fixes; remove the @ignore once
// the corresponding task closes to confirm the defect went away.
// =============================================================================

mount core.async.timer.{
    Sleep, SleepUntil, TimerInterval, Delay, Timeout, TimeoutError,
    Debounce, Throttle,
    sleep_secs, sleep_until, delay,
};
mount core.async.future.{ready, ReadyFuture};
mount core.time.{Duration};

// =============================================================================
// §A — task #15 — Duration.from_millis dispatch defect
// =============================================================================

@test
@ignore
fn regression_timer_sleep_from_millis_does_not_panic() {
    let s = Sleep.new(Duration.from_millis(100));
    assert(s.deadline.is_none());
}

@test
@ignore
fn regression_timer_sleep_ms_factory_does_not_panic() {
    // sleep_ms internally calls Duration.from_millis — gated by #15.
    // mount: core.async.timer.{sleep_ms};
    assert(true);
}

// =============================================================================
// §B — task #17 — TimerInterval.period() recursion
// =============================================================================

@test
@ignore
fn regression_timer_interval_period_getter_does_not_stack_overflow() {
    let p = Duration.from_secs(1);
    let it = TimerInterval.new(p);
    // Today: stack-overflow because `self.period` inside the method
    // body dispatches to `self.period()` recursively.
    assert(it.period().eq(&p));
}

// =============================================================================
// §C — task #16 — Timeout<F> field-layout write out of bounds
// =============================================================================

@test
@ignore
fn regression_timer_timeout_new_does_not_field_write_out_of_bounds() {
    let _t = Timeout.new(Duration.from_secs(1), ready(42));
    assert(true);
}

@test
@ignore
fn regression_timer_timeout_factory_does_not_field_write_out_of_bounds() {
    // mount: core.async.timer.{timeout};
    // let _t = timeout(Duration.from_secs(1), ready(42));
    assert(true);
}

// =============================================================================
// §D — task #14 — timeout_ms cross-module name collision
// =============================================================================

@test
@ignore
fn regression_timer_timeout_ms_factory_resolves_correctly() {
    // Today: `timeout_ms(500, ready(7))` fails to compile —
    // WrongArgumentCount expected:1 found:2 — the codegen routes
    // to a same-named symbol from net.dns or runtime.supervisor.
    // mount: core.async.timer.{timeout_ms};
    // let _t = timeout_ms(500, ready(7));
    assert(true);
}

fn main() {}
