// =============================================================================
// core-tests/async/channel/property_test.vr
// =============================================================================

mount core.async.channel.{TrySendError, TryRecvError};
mount core.collections.list.List;

// =============================================================================
// Section A: TrySendError<T> partition (Full / Disconnected)
// =============================================================================

@test
fn property_channel_try_send_error_partition() {
    fn flag_count(e: TrySendError<Int>) -> Int {
        let mut n: Int = 0;
        if e is TrySendError.Full { n = n + 1; }
        if e is TrySendError.Disconnected { n = n + 1; }
        n
    }
    assert_eq(flag_count(TrySendError.Full(0)), 1);
    assert_eq(flag_count(TrySendError.Disconnected(0)), 1);
    assert_eq(flag_count(TrySendError.Full(42)), 1);
    assert_eq(flag_count(TrySendError.Disconnected(99)), 1);
}

@test
fn property_channel_try_send_error_payload_round_trip() {
    fn extract_full(e: TrySendError<Int>) -> Int {
        match e {
            TrySendError.Full(p) => p,
            TrySendError.Disconnected(_) => -999_999,
        }
    }
    fn extract_disc(e: TrySendError<Int>) -> Int {
        match e {
            TrySendError.Full(_) => -999_999,
            TrySendError.Disconnected(p) => p,
        }
    }
    assert_eq(extract_full(TrySendError.Full(-1)), -1);
    assert_eq(extract_full(TrySendError.Full(0)), 0);
    assert_eq(extract_full(TrySendError.Full(42)), 42);
    assert_eq(extract_full(TrySendError.Full(1_000_000)), 1_000_000);
    assert_eq(extract_disc(TrySendError.Disconnected(-1)), -1);
    assert_eq(extract_disc(TrySendError.Disconnected(0)), 0);
    assert_eq(extract_disc(TrySendError.Disconnected(42)), 42);
}

// =============================================================================
// Section B: TryRecvError partition (Empty / Disconnected)
// =============================================================================

@test
fn property_channel_try_recv_error_partition() {
    fn flag_count(e: TryRecvError) -> Int {
        let mut n: Int = 0;
        if e is TryRecvError.Empty { n = n + 1; }
        if e is TryRecvError.Disconnected { n = n + 1; }
        n
    }
    assert_eq(flag_count(TryRecvError.Empty), 1);
    assert_eq(flag_count(TryRecvError.Disconnected), 1);
}

fn main() {}
