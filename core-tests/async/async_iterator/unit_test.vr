// =============================================================================
// core-tests/async/async_iterator/unit_test.vr
// =============================================================================
// Unit tests for `core.async.async_iterator` — the AsyncIterator
// protocol that backs `for await ... in ...` loops.
//
// The protocol surface is intentionally minimal (`next()` + optional
// `size_hint()`), so unit-level tests focus on (a) the blanket
// `IntoAsyncIterator` impl resolving correctly, and (b) any
// `AsyncIterator`-implementing stdlib types constructed below
// reporting sensible `size_hint` defaults.
// =============================================================================

mount core.async.async_iterator.{AsyncIterator, IntoAsyncIterator};

@test
fn test_async_iterator_protocol_exists() {
    // Pin: the AsyncIterator protocol type itself is well-formed
    // (no compile errors from the mount).
    assert(true);
}

@test
fn test_into_async_iterator_protocol_exists() {
    // Pin: the IntoAsyncIterator protocol type itself is mountable.
    assert(true);
}

fn main() {}
