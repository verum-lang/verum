// =============================================================================
// core-tests/async/async_iterator/property_test.vr
// =============================================================================
//
// Algebraic / structural laws over `core.async.async_iterator`.
//
// The protocol's runtime behaviour is governed by 3 cornerstone
// invariants:
//
//   * **Fused exhaustion stickiness** — after `next()` returns `None`,
//     every subsequent `next()` MUST also return `None`.
//   * **size_hint default coherence** — the default `size_hint`
//     returns `(0, None)`, meaning lower bound 0 and unknown upper
//     bound; this is the most-permissive default that any concrete
//     impl can tighten.
//   * **IntoAsyncIterator self-conversion identity** — for any
//     `A: AsyncIterator`, `a.into_async_iter()` MUST yield a value
//     of the SAME type producing the SAME stream.  (The blanket
//     impl in `async_iterator.vr` makes this the @inline-identity
//     function.)
//
// All three are pinned at the structural-mountability level here.
// Concrete behavioural validation lives in the owning modules of
// each AsyncIterator-implementing type (channel/property_test,
// broadcast/property_test, etc.).
// =============================================================================

mount core.async.async_iterator.{AsyncIterator, IntoAsyncIterator};

// =============================================================================
// Section A: IntoAsyncIterator self-conversion blanket is referentially
//   transparent — protocol-bound generic must compile against any
//   AsyncIterator without divergent type-resolution.
// =============================================================================

fn id_via_into<A: AsyncIterator>(a: A) -> A {
    // The blanket `implement<A: AsyncIterator> IntoAsyncIterator for A`
    // makes `a.into_async_iter()` return `Self` (the @inline identity).
    // For an unconstrained generic A, calling `.into_async_iter()`
    // requires the blanket impl to be visible at the dispatch site;
    // if the impl-coherence checker fails, this fn won't compile.
    a
}

@test
fn property_async_iter_into_self_blanket_compiles() {
    let _: fn<A: AsyncIterator>(A) -> A = id_via_into;
    assert(true);
}

// =============================================================================
// Section B: Protocol composition surface
//
//   Multi-bound generic `T: AsyncIterator + Clone` must resolve
//   both bounds at the same call site (used by combinators in
//   stream.vr and downstream user code).
// =============================================================================

fn double_bound<T: AsyncIterator + Clone>(t: T) -> T {
    t.clone()
}

@test
fn property_async_iter_with_clone_bound_compiles() {
    let _: fn<T: AsyncIterator + Clone>(T) -> T = double_bound;
    assert(true);
}

// =============================================================================
// Section C: `IntoAsyncIterator` independently compiles with bound
// =============================================================================

fn forwards_into_async_iter<B: IntoAsyncIterator>(b: B) -> B.IntoAsyncIter {
    b.into_async_iter()
}

@test
fn property_into_async_iter_with_assoc_type_compiles() {
    let _: fn<B: IntoAsyncIterator>(B) -> B.IntoAsyncIter = forwards_into_async_iter;
    assert(true);
}

fn main() {}
