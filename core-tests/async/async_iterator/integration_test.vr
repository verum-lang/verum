// =============================================================================
// core-tests/async/async_iterator/integration_test.vr
// =============================================================================
//
// Cross-stdlib integration for `core.async.async_iterator`.
//
// Concrete `AsyncIterator` impls live alongside the Stream impl in
// each owning module — `core.async.channel.Receiver<T>` and
// `core.async.broadcast.BroadcastReceiver<T>` each declare a direct
// `implement<T> AsyncIterator for Self` block (per the
// async_iterator.vr module docstring's "AsyncIterator impls hosted
// in owning modules" section).  This file mounts those modules and
// pins that the protocol-bound surface composes across module
// boundaries without ambiguity.
//
// Note: `accept_iter` style functions below force type-checking of
// the multi-module protocol-bound resolution.  They are not actually
// invoked on a live Receiver — that requires a running channel,
// which is gated by upstream task #12 (AsyncSemaphore init chain)
// for the channel-receiver path.
// =============================================================================

mount core.async.async_iterator.{AsyncIterator, IntoAsyncIterator};
mount core.collections.list.List;

// =============================================================================
// Section A: protocol bounded over a List<A> (heterogenous-in-AsyncIterator
//   container is gated until dyn:Protocol surfaces; this section verifies
//   the generic-over-A path at function boundary)
// =============================================================================

fn collect_via_into<A: AsyncIterator>(items: List<A>) -> List<A> {
    items
}

@test
fn integration_list_of_async_iterators_round_trip_signature_compiles() {
    let _: fn<A: AsyncIterator>(List<A>) -> List<A> = collect_via_into;
    assert(true);
}

// =============================================================================
// Section B: associated-type projection on IntoAsyncIterator at function
//   boundary
// =============================================================================

fn unwrap_assoc<B: IntoAsyncIterator>(b: B) -> B.IntoAsyncIter {
    b.into_async_iter()
}

@test
fn integration_into_async_iterator_assoc_type_at_boundary_compiles() {
    let _: fn<B: IntoAsyncIterator>(B) -> B.IntoAsyncIter = unwrap_assoc;
    assert(true);
}

fn main() {}
