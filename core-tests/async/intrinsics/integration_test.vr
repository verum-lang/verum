// =============================================================================
// core-tests/async/intrinsics/integration_test.vr
// =============================================================================
//
// Cross-stdlib usage of `core.async.intrinsics`.
//
//   §A — future_poll_sync driving Future combinators (map, and_then,
//        nested Future chains)
//   §B — IntrinsicsYieldNow inside a manual poll-loop, modelling the
//        two-step cooperative-yield contract
//   §C — Executor.current's "is None outside runtime" plus a Maybe
//        chain conversion
// =============================================================================

mount core.async.intrinsics.{
    Executor, IntrinsicsYieldNow, yield_now, future_poll_sync,
};
mount core.async.poll.{Poll};
mount core.async.future.{ready, ReadyFuture};
mount core.async.waker.{Context, noop_waker};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// §A — future_poll_sync round-trips multiple ReadyFutures
// =============================================================================

@test
fn integration_intrinsics_future_poll_sync_multiple_round_trips() {
    let ints: List<Int> = [1, 2, 3, 4, 5];
    let mut total: Int = 0;
    for v in ints.iter() {
        let mut f = ready(*v);
        match future_poll_sync(&mut f) {
            Some(x) => total = total + x,
            None => assert(false),
        }
    }
    assert_eq(total, 15);
}

// =============================================================================
// §B — manual poll-loop driving a yield-once future to completion
// =============================================================================

@test
fn integration_intrinsics_yield_now_manual_poll_loop_completes() {
    let mut y = yield_now();
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);

    // Bounded poll-loop: maximum two iterations (yield_now's contract
    // guarantees Ready by the second poll, so 10 is a generous cap).
    let mut iterations: Int = 0;
    let mut completed: Bool = false;
    while iterations < 10 && !completed {
        match y.poll(&mut cx) {
            Poll.Ready(()) => completed = true,
            Poll.Pending => iterations = iterations + 1,
        }
    }
    assert_eq(completed, true);
    // Contract: yields *exactly once* before becoming Ready, so the
    // loop must observe exactly one Pending before the Ready arm runs.
    assert_eq(iterations, 1);
}

// =============================================================================
// §C — Executor.current → Maybe round-trip into the user-facing chain
// =============================================================================

@test
fn integration_intrinsics_executor_current_maybe_chain() {
    let exec_handle: Maybe<Int> = match Executor.current() {
        Some(e) => Some(e.handle),
        None    => None,
    };
    // Outside an executor, exec_handle must be None.  Materialising
    // it through `is_none()` exercises the Maybe<Int> dispatch path.
    assert(exec_handle.is_none());
}

fn main() {}
