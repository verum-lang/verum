// =============================================================================
// core-tests/async/semaphore/property_test.vr
// =============================================================================
//
// Properties for `core.async.semaphore` that exercise the
// variant-algebra surface only.  Construction-side properties live
// pinned in regression_test.vr §A pending task #12.
// =============================================================================

mount core.async.semaphore.{SemaphoreError};
mount core.collections.list.List;

// =============================================================================
// §A — SemaphoreError partition: Closed is the unique variant
// =============================================================================

@test
fn property_semaphore_error_is_closed_partition() {
    // SemaphoreError today has exactly one variant, `Closed`.  Pin
    // the partition so that future additions are forced to update
    // this test and the public-API audit.  Task #13 CLOSED
    // 2026-05-15 — single-variant `is`-operator now works
    // correctly, so the natural `e is SemaphoreError.Closed`
    // classifier replaces the match-arm workaround.
    fn is_closed(e: SemaphoreError) -> Bool {
        e is SemaphoreError.Closed
    }
    let xs: List<SemaphoreError> = [
        SemaphoreError.Closed,
    ];
    for e in xs.iter() {
        assert(is_closed(*e));
    }
}

@test
fn property_semaphore_error_closed_eq_reflexive() {
    let a: SemaphoreError = SemaphoreError.Closed;
    assert(a.eq(&a));
}

fn main() {}
