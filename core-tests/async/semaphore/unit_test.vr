// =============================================================================
// core-tests/async/semaphore/unit_test.vr
// =============================================================================
//
// Unit tests for `core.async.semaphore` — the async-task counting
// semaphore.  Today the constructor `AsyncSemaphore.new` panics
// inside Mutex/AtomicBool initialisation (tracked as task #12);
// the variant-algebra surface still tests cleanly:
//
//   §1 SemaphoreError variant algebra (Closed)
//
// All AsyncSemaphore lifecycle tests (new / try_acquire / add_permits /
// close / available_permits) are pinned in regression_test.vr §A
// pending task #12.
// =============================================================================

mount core.async.semaphore.{SemaphoreError};

// =============================================================================
// Section 1: SemaphoreError variant algebra
// =============================================================================

@test
fn test_semaphore_error_closed_construction() {
    // Task #13 CLOSED 2026-05-15 — `is`-operator on a single-variant
    // sum now resolves correctly.  See regression_test.vr §B for the
    // architectural rationale (parser distinguishes `is`-form sum
    // declarations from `=`-form aliases per grammar/verum.ebnf §2.4).
    let e: SemaphoreError = SemaphoreError.Closed;
    assert(e is SemaphoreError.Closed);
    // Also confirm the match-arm path still routes (it always did).
    let routed = match e {
        SemaphoreError.Closed => true,
    };
    assert(routed);
}

@test
fn test_semaphore_error_closed_eq_to_self() {
    let a: SemaphoreError = SemaphoreError.Closed;
    let b: SemaphoreError = SemaphoreError.Closed;
    assert(a.eq(&b));
}

@test
fn test_semaphore_error_closed_match_arm() {
    fn classify(e: SemaphoreError) -> Text {
        match e {
            SemaphoreError.Closed => "closed",
        }
    }
    assert_eq(classify(SemaphoreError.Closed), "closed");
}

fn main() {}
