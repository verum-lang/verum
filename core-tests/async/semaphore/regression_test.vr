// =============================================================================
// core-tests/async/semaphore/regression_test.vr
// =============================================================================
//
// Defect pins for `core.async.semaphore`.
//
// §A — task #12 — `AsyncSemaphore.new(N)` panics with
// `NullPointerAt { op: "opcode 0xe5", site: "AtomicInt.swap", pc: 34 }`
// for every N.  Construction chain: AsyncSemaphore.new →
// Shared.new(Mutex.new(SemaphoreInner{...})) → AtomicBool.new(false)
// → AtomicInt.swap NULL.  Until #12 is closed, no test that
// constructs an AsyncSemaphore can run.
// =============================================================================

mount core.async.semaphore.{AsyncSemaphore, SemaphoreError};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// §A — task #12 — AsyncSemaphore.new null-derefs through AtomicInt.swap
// =============================================================================

// §B — task #13 CLOSED — `is`-operator on single-variant sum
//
// CLOSED 2026-05-15 by an architectural fix in the parser
// (`crates/verum_fast_parser/src/decl.rs::parse_type_decl_body`).
//
// **Root cause (architectural)**: per `grammar/verum.ebnf` §2.4,
// the `type X = Y;` form (with the `=` sigil) is a TYPE ALIAS, and
// the `type X is Y;` form (with the `is` sigil) is a SUM-TYPE
// declaration whose `variant_list` production accepts a single
// variant without the leading `|`:
//
//     variant_list = [ '|' ] , variant , { '|' , variant } ;
//     type_alias   = 'type' , identifier , [ generics ]
//                  , [ ':' , bounds ] , '=' , type_expr , ';' ;
//
// Pre-fix the parser collapsed `type X is OnlyVariant;` (bare
// identifier, no payload, no leading `|`) into
// `TypeDeclBody::Alias(OnlyVariant)` — silently turning a
// single-variant sum into an alias to a (typically non-existent)
// type.  The downstream typechecker / codegen / runtime then saw
// `SemaphoreError` as an alias, NOT as a variant type:
//   - `match e { SemaphoreError.Closed => … }` still worked
//     because the destructure-tag path tolerated alias resolution.
//   - `e.eq(&other)` worked because Eq was an inherent impl.
//   - `e is SemaphoreError.Closed` returned `false` because the
//     `is`-operator path strictly required a Type::Variant.
//
// The fix changes the single-bare-name `is`-form arm at
// `decl.rs:3384` to emit `TypeDeclBody::Variant(vec![variant])`
// instead of `TypeDeclBody::Alias`.  Both forms produce identical
// AST:
//
//     type X is | Closed;     -- explicit leading pipe
//     type X is Closed;       -- now equivalent to the leading-pipe form
//
// Closes the SemaphoreError / ChannelError / Closed-marker idiom
// across the entire stdlib without a stdlib-source change.
//
// **Architectural rule pinned**: the `is` / `=` sigils in type
// declarations are NEVER interchangeable.  `is` introduces a
// structural type body (record / variant / quotient / sigma);
// `=` introduces a name alias.  The parser MUST honour that
// invariant — any future "is-form right-hand side looks like a
// type alias" optimisation MUST go through `=`, not `is`.

@test
fn regression_semaphore_error_is_closed_single_variant() {
    let e: SemaphoreError = SemaphoreError.Closed;
    assert(e is SemaphoreError.Closed);
}

// =============================================================================

@test
fn regression_semaphore_new_zero_permits_does_not_panic() {
    // Today: panics with AtomicInt.swap NULL during Mutex init.
    let s = AsyncSemaphore.new(0);
    assert_eq(s.available_permits(), 0);
}

@test
fn regression_semaphore_new_positive_permits_does_not_panic() {
    let s = AsyncSemaphore.new(5);
    assert_eq(s.available_permits(), 5);
}

@test
fn regression_semaphore_new_negative_clamps_to_zero() {
    let s = AsyncSemaphore.new(-3);
    assert_eq(s.available_permits(), 0);
}

@test
fn regression_semaphore_try_acquire_when_available_returns_some() {
    let s = AsyncSemaphore.new(1);
    match s.try_acquire() {
        Some(_) => assert(true),
        None => assert(false),
    }
}

@test
fn regression_semaphore_try_acquire_when_saturated_returns_none() {
    let s = AsyncSemaphore.new(0);
    match s.try_acquire() {
        Some(_) => assert(false),
        None => assert(true),
    }
}

@test
@ignore
fn regression_semaphore_add_permits_widens_capacity() {
    let s = AsyncSemaphore.new(1);
    s.add_permits(4);
    assert_eq(s.available_permits(), 5);
}

@test
fn regression_semaphore_add_permits_zero_is_noop() {
    let s = AsyncSemaphore.new(3);
    s.add_permits(0);
    assert_eq(s.available_permits(), 3);
}

@test
@ignore
fn regression_semaphore_close_makes_try_acquire_return_none() {
    let s = AsyncSemaphore.new(10);
    s.close();
    match s.try_acquire() {
        Some(_) => assert(false),
        None => assert(true),
    }
}

@test
@ignore
fn regression_semaphore_close_is_idempotent() {
    let s = AsyncSemaphore.new(2);
    s.close();
    s.close();
    s.close();
    assert(s.try_acquire().is_none());
}

fn main() {}
