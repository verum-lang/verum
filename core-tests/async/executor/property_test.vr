// =============================================================================
// core-tests/async/executor/property_test.vr
// =============================================================================
//
// Algebraic laws over the `core.async.executor` configuration surface.
// Properties stay on the builder / config layer since live runtime
// invocation is gated by tasks #10 / #12.
//
// Laws:
//   * Builder chain is COMMUTATIVE on independent knobs — invoking
//     `.max_tasks(N).stack_size(M)` produces the same downstream
//     state as `.stack_size(M).max_tasks(N)`.  (Pinned at the
//     no-panic level; structural equality of the produced state is
//     gated by user-defined Eq for AsyncRuntimeConfig.)
//   * `RuntimeBuilder.new()` is idempotent — repeated calls produce
//     structurally-independent builders that all chain cleanly.
//   * Builder chain is ASSOCIATIVE on n-fold composition — calling
//     N setters in any chain order produces a configurable builder.
//   * Config presets (`default`/`cpu_bound`/`io_bound`) are
//     non-interfering — building one does not corrupt subsequent
//     constructions of another.
// =============================================================================

mount core.async.executor.{RuntimeBuilder, AsyncRuntimeConfig};

// =============================================================================
// Section A: Builder chain commutativity on independent knobs
// =============================================================================

@test
fn property_executor_builder_max_tasks_stack_size_commute() {
    let _a = RuntimeBuilder.new().max_tasks(64).stack_size(8192);
    let _b = RuntimeBuilder.new().stack_size(8192).max_tasks(64);
    assert(true);
}

@test
fn property_executor_builder_enable_flags_commute() {
    let _a = RuntimeBuilder.new().enable_io().enable_time();
    let _b = RuntimeBuilder.new().enable_time().enable_io();
    assert(true);
}

// =============================================================================
// Section B: Builder construction independence
// =============================================================================

@test
fn property_executor_builder_new_independent_across_5_constructions() {
    let mut i = 0;
    while i < 5 {
        let _b = RuntimeBuilder.new().max_tasks(i * 100 + 1);
        i = i + 1;
    }
    assert_eq(i, 5);
}

// =============================================================================
// Section C: N-fold associative composition over the setter surface
// =============================================================================

@test
fn property_executor_builder_associates_over_full_setter_set() {
    // Order 1
    let _b1 = RuntimeBuilder.new()
        .max_tasks(10)
        .stack_size(1024)
        .enable_work_stealing()
        .enable_io()
        .enable_time();
    // Order 2 — flag setters interspersed
    let _b2 = RuntimeBuilder.new()
        .enable_work_stealing()
        .max_tasks(10)
        .enable_io()
        .stack_size(1024)
        .enable_time();
    // Order 3 — reverse-ish
    let _b3 = RuntimeBuilder.new()
        .enable_time()
        .enable_io()
        .enable_work_stealing()
        .stack_size(1024)
        .max_tasks(10);
    assert(true);
}

// =============================================================================
// Section D: Preset non-interference
//
//   Building `cpu_bound` then `io_bound` then `default` must not
//   produce stale state — each call is referentially transparent
//   and returns a fresh config.
// =============================================================================

@test
fn property_executor_config_presets_independent() {
    let _c1 = AsyncRuntimeConfig.cpu_bound();
    let _c2 = AsyncRuntimeConfig.io_bound();
    let _c3 = AsyncRuntimeConfig.default();
    let _c4 = AsyncRuntimeConfig.cpu_bound();
    let _c5 = AsyncRuntimeConfig.io_bound();
    assert(true);
}

@test
fn property_executor_config_default_idempotent_under_repeated_construction() {
    let mut i = 0;
    while i < 10 {
        let _c = AsyncRuntimeConfig.default();
        i = i + 1;
    }
    assert_eq(i, 10);
}

fn main() {}
