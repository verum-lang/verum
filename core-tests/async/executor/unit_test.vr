// =============================================================================
// core-tests/async/executor/unit_test.vr
// =============================================================================
//
// Unit tests for `core.async.executor` — the production-grade async
// runtime built on V-LLSI primitives.  The executor's full surface
// (`AsyncRuntime.block_on`, `LocalExecutor.run_until_complete`,
// work-stealing scheduler, timer-driver wakeups) is gated by upstream
// task #10 (LLVM AOT SmallVector hang on `generate_native`) and
// task #12 (`AsyncSemaphore.new` null-deref).
//
// This file pins the **configuration / builder surface** that does NOT
// require live executor instantiation.  Tests cover:
//   * `RuntimeBuilder.new()` default state
//   * Each builder mutator (`max_tasks`, `stack_size`, `enable_*`)
//     produces a builder that still composes
//   * `AsyncRuntimeConfig.default()` / `.cpu_bound()` / `.io_bound()`
//     are non-panicking constructors and produce coherent state
//   * The fluent chain across every public setter is structurally
//     valid (re-pin of the regression-test scenario, expanded)
//
// Live `.build() → AsyncRuntime` round-trips and `block_on(future)`
// are deferred to integration tests in `tests/` once the executor
// dispatcher gap closes.
//
// **Task #8 + #9 CLOSED 2026-05-24** — the runtime-bridge FFI
// intercept was previously gated by an empty-getter-name lookup
// (FfiSymbolId(1) → empty string) AND task #47's stage-3 stub
// cascade was breaking global_ctors at the same time.  Both
// resolved by task #9 fix in `crates/verum_vbc/src/codegen/mod.rs`
// — the external_function_names skip-gate at line ~15074 now
// distinguishes stage-1/2/3 stub IDs from variant-ctor / FFI
// extern sentinels, so cross-module stub references get proper
// name-based resolution at archive merge.
// =============================================================================

mount core.async.executor.{
    RuntimeBuilder, AsyncRuntimeConfig, RuntimeConfig,
};

// =============================================================================
// Section 1: RuntimeBuilder.new() default state
// =============================================================================

@test
fn test_executor_runtime_builder_new_constructs() {
    let _b = RuntimeBuilder.new();
    assert(true);
}

@test
fn test_executor_runtime_builder_independent_constructions() {
    let _b1 = RuntimeBuilder.new();
    let _b2 = RuntimeBuilder.new();
    let _b3 = RuntimeBuilder.new();
    assert(true);
}

// =============================================================================
// Section 2: AsyncRuntimeConfig.default() / cpu_bound() / io_bound()
// =============================================================================

@test
fn test_executor_async_runtime_config_default_constructs() {
    let _c = AsyncRuntimeConfig.default();
    assert(true);
}

@test
fn test_executor_async_runtime_config_cpu_bound_constructs() {
    let _c = AsyncRuntimeConfig.cpu_bound();
    assert(true);
}

@test
fn test_executor_async_runtime_config_io_bound_constructs() {
    let _c = AsyncRuntimeConfig.io_bound();
    assert(true);
}

@test
fn test_executor_runtime_config_alias_mounts() {
    // RuntimeConfig is the canonical short-name alias for
    // AsyncRuntimeConfig — pinned here so the alias stays stable
    // across stdlib re-export reshuffles.
    let _c: RuntimeConfig = AsyncRuntimeConfig.default();
    assert(true);
}

// =============================================================================
// Section 3: Builder setters — single-knob composition
// =============================================================================

@test
fn test_executor_runtime_builder_max_tasks_chains() {
    let _b = RuntimeBuilder.new().max_tasks(128);
    assert(true);
}

@test
fn test_executor_runtime_builder_stack_size_chains() {
    let _b = RuntimeBuilder.new().stack_size(8192);
    assert(true);
}

@test
fn test_executor_runtime_builder_enable_work_stealing_chains() {
    let _b = RuntimeBuilder.new().enable_work_stealing();
    assert(true);
}

@test
fn test_executor_runtime_builder_enable_io_chains() {
    let _b = RuntimeBuilder.new().enable_io();
    assert(true);
}

@test
fn test_executor_runtime_builder_enable_time_chains() {
    let _b = RuntimeBuilder.new().enable_time();
    assert(true);
}

// =============================================================================
// Section 4: Builder fluent chain — multi-knob composition
// =============================================================================

@test
fn test_executor_runtime_builder_full_chain() {
    let _b = RuntimeBuilder.new()
        .max_tasks(1024)
        .stack_size(65536)
        .enable_work_stealing()
        .enable_io()
        .enable_time();
    assert(true);
}

@test
fn test_executor_runtime_builder_partial_chains_compose_independently() {
    let _b1 = RuntimeBuilder.new().max_tasks(8);
    let _b2 = RuntimeBuilder.new().stack_size(32768).enable_io();
    let _b3 = RuntimeBuilder.new().enable_time().enable_work_stealing().max_tasks(4096);
    assert(true);
}

// =============================================================================
// Section 5: AsyncRuntimeConfig setter fluents
// =============================================================================

@test
fn test_executor_async_runtime_config_max_tasks_chains() {
    let _c = AsyncRuntimeConfig.default().max_tasks(256);
    assert(true);
}

@test
fn test_executor_async_runtime_config_task_stack_size_chains() {
    let _c = AsyncRuntimeConfig.default().task_stack_size(4096);
    assert(true);
}

@test
fn test_executor_async_runtime_config_work_stealing_chains() {
    let _c_off = AsyncRuntimeConfig.default().work_stealing(false);
    let _c_on = AsyncRuntimeConfig.default().work_stealing(true);
    assert(true);
}

@test
fn test_executor_async_runtime_config_poll_budget_chains() {
    let _c = AsyncRuntimeConfig.default().poll_budget(512);
    assert(true);
}

fn main() {}
