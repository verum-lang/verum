// =============================================================================
// core-tests/async/poll/property_test.vr
// =============================================================================
//
// Algebraic laws for `core.async.poll.Poll<T>`. The Poll type is a
// 2-state algebra (Ready(T) | Pending) that, restricted to its
// observable surface, is structurally identical to `Maybe<T>` —
// `Ready ↔ Some`, `Pending ↔ None`. Every law below is proved
// exhaustively over a representative `Int` payload domain when the
// law involves an `Int` carrier, and over a small sample of payloads
// otherwise. The `Pending` case is the absorbing element for
// every fmap-style operation.
// =============================================================================

mount core.async.poll.{Poll};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;

// -----------------------------------------------------------------------------
// Domain helpers
// -----------------------------------------------------------------------------

fn int_domain() -> List<Int> {
    // Boundary, mid, signed-extreme samples — enough to expose any
    // payload-dependent failures (sign, wrap-around, off-by-one).
    [-1_000_000, -1, 0, 1, 42, 1_000_000]
}

fn poll_int_domain() -> List<Poll<Int>> {
    let mut out: List<Poll<Int>> = [];
    out.push(Poll.Pending);
    for v in int_domain().iter() {
        out.push(Poll.Ready(*v));
    }
    out
}

// =============================================================================
// Section A: Two-state partition (`is_ready` ⊕ `is_pending` exact equality)
// =============================================================================

@test
fn property_poll_two_state_partition_exhaustive() {
    for p in poll_int_domain().iter() {
        let r = (*p).is_ready();
        let n = (*p).is_pending();
        // Disjoint and exhaustive — exactly one is true for every Poll value.
        assert(r != n);
        assert(r || n);
    }
}

@test
fn property_poll_ready_iff_payload_present_exhaustive() {
    for p in poll_int_domain().iter() {
        let r = (*p).is_ready();
        match *p {
            Poll.Ready(_) => assert(r),
            Poll.Pending => assert(!r),
        }
    }
}

// =============================================================================
// Section B: Functor laws on `map`
//
//   F1.  Identity:        p.map(|x| x) == p
//   F2.  Composition:     p.map(g).map(f) == p.map(|x| f(g(x)))
//   F3.  Pending absorbs: Pending.map(f) == Pending
// =============================================================================

@test
fn property_poll_map_identity_exhaustive() {
    for p in poll_int_domain().iter() {
        let mapped = (*p).map(|x| x);
        assert_eq(mapped, *p);
    }
}

@test
fn property_poll_map_composition_exhaustive() {
    for p in poll_int_domain().iter() {
        let lhs = (*p).map(|x| x + 1).map(|x| x * 2);
        let rhs = (*p).map(|x| (x + 1) * 2);
        assert_eq(lhs, rhs);
    }
}

@test
fn property_poll_map_pending_is_absorbing() {
    let p: Poll<Int> = Poll.Pending;
    let q = p.map(|x| x + 9999);
    assert(q.is_pending());
}

// =============================================================================
// Section C: `unwrap_or` laws
//
//   U1.  Ready(v).unwrap_or(d) == v          (for any d)
//   U2.  Pending.unwrap_or(d)  == d
//   U3.  default never observed when Ready
// =============================================================================

@test
fn property_poll_unwrap_or_ready_returns_value_exhaustive() {
    for v in int_domain().iter() {
        let p: Poll<Int> = Poll.Ready(*v);
        assert_eq(p.unwrap_or(-99), *v);
    }
}

@test
fn property_poll_unwrap_or_pending_returns_default_exhaustive() {
    for d in int_domain().iter() {
        let p: Poll<Int> = Poll.Pending;
        assert_eq(p.unwrap_or(*d), *d);
    }
}

// =============================================================================
// Section D: `ready()` ↔ Maybe isomorphism
//
//   M1.  Ready(v).ready() == Some(v)
//   M2.  Pending.ready()  == None
//   M3.  Poll.from(p.ready()) == p     (round-trip via Maybe)
// =============================================================================

@test
fn property_poll_ready_maybe_isomorphism_exhaustive() {
    for p in poll_int_domain().iter() {
        let m: Maybe<Int> = (*p).ready();
        match *p {
            Poll.Ready(v) => assert_eq(m, Some(v)),
            Poll.Pending => assert_eq(m, None),
        }
    }
}

@test
fn property_poll_roundtrip_via_maybe_exhaustive() {
    // p -> Maybe -> Poll round-trip preserves identity.
    for p in poll_int_domain().iter() {
        let m: Maybe<Int> = (*p).ready();
        let back: Poll<Int> = Poll.from(m);
        assert_eq(back, *p);
    }
}

// =============================================================================
// Section E: Eq protocol laws
//
//   E1.  Reflexive:    p == p
//   E2.  Symmetric:    p == q  ⇒  q == p
//   E3.  Pending == Pending across construction sites
// =============================================================================

@test
fn property_poll_eq_reflexive_exhaustive() {
    for p in poll_int_domain().iter() {
        assert(*p == *p);
    }
}

@test
fn property_poll_eq_symmetric_exhaustive() {
    let dom = poll_int_domain();
    for a in dom.iter() {
        for b in dom.iter() {
            assert((*a == *b) == (*b == *a));
        }
    }
}

@test
fn property_poll_eq_transitive_exhaustive() {
    let dom = poll_int_domain();
    for a in dom.iter() {
        for b in dom.iter() {
            for c in dom.iter() {
                if *a == *b && *b == *c {
                    assert(*a == *c);
                }
            }
        }
    }
}

@test
fn property_poll_pending_eq_pending() {
    let p1: Poll<Int> = Poll.Pending;
    let p2: Poll<Int> = Poll.Pending;
    // Construct a Pending via map-on-Pending — Pending is the
    // absorbing element under the Functor map, so the closure is
    // never invoked.  Asserts the absorbing property and that any
    // pair of Pending values is equal regardless of construction
    // history.
    let p3: Poll<Int> = (Poll.Pending).map(|_x| panic("absorbing-element law violated"));
    assert(p1 == p2);
    assert(p2 == p3);
    assert(p1 == p3);
}

// =============================================================================
// Section F: Clone laws
//
//   C1.  Clone preserves equality:  p.clone() == p
//   C2.  Clone independence:        mutating an original-binding does
//        not change the clone (Poll<T> is a value type — exhaustive
//        over the int payload domain).
// =============================================================================

@test
fn property_poll_clone_preserves_equality_exhaustive() {
    for p in poll_int_domain().iter() {
        let cloned = (*p).clone();
        assert_eq(*p, cloned);
    }
}

// =============================================================================
// Section G: From<T> for Poll<T> — Ready constructor identity
//
//   FT1. Poll.Ready(v) == Poll.from(v)   for non-Maybe payloads.
//
//   NB. This law is gated on regression_test.vr §B (From<T> vs
//   From<Maybe<T>> impl-resolution) until that defect is closed.
//   For now we document the law as a property; reactivate when the
//   regression flips green.
// =============================================================================

// Section G is currently pinned by regression_test.vr §B; tests
// belong there in @ignore form until impl-resolution is fixed.

// =============================================================================
// Section H: `map_ok` / `map_err` on Poll<Result<T, E>>
//
//   R1.  Ready(Ok(t)).map_ok(f)  == Ready(Ok(f(t)))
//   R2.  Ready(Err(e)).map_ok(f) == Ready(Err(e))
//   R3.  Pending.map_ok(f)       == Pending
//   R4.  Symmetric set for map_err.
// =============================================================================

@test
fn property_poll_map_ok_only_affects_ok_branch_exhaustive() {
    for v in int_domain().iter() {
        let p: Poll<Result<Int, Text>> = Poll.Ready(Ok(*v));
        let q = p.map_ok(|x| x * 3);
        assert_eq(q, Poll.Ready(Ok(*v * 3)));
    }
}

@test
fn property_poll_map_ok_preserves_err_exhaustive() {
    let errs: List<Text> = ["", "x", "long error message"];
    for e in errs.iter() {
        let p: Poll<Result<Int, Text>> = Poll.Ready(Err((*e).clone()));
        let q = p.map_ok(|x| x + 1);
        assert_eq(q, Poll.Ready(Err((*e).clone())));
    }
}

@test
fn property_poll_map_err_only_affects_err_branch_exhaustive() {
    let errs: List<Text> = ["", "x", "fail"];
    for e in errs.iter() {
        let p: Poll<Result<Int, Text>> = Poll.Ready(Err((*e).clone()));
        let q = p.map_err(|s: Text| s.len());
        assert_eq(q, Poll.Ready(Err((*e).len())));
    }
}

@test
fn property_poll_map_err_preserves_ok_exhaustive() {
    for v in int_domain().iter() {
        let p: Poll<Result<Int, Text>> = Poll.Ready(Ok(*v));
        let q = p.map_err(|s: Text| s.len());
        assert_eq(q, Poll.Ready(Ok(*v)));
    }
}

@test
fn property_poll_map_ok_pending_is_absorbing() {
    let p: Poll<Result<Int, Text>> = Poll.Pending;
    let q = p.map_ok(|x| x + 1);
    assert(q.is_pending());
}

@test
fn property_poll_map_err_pending_is_absorbing() {
    let p: Poll<Result<Int, Text>> = Poll.Pending;
    let q = p.map_err(|s: Text| s.len());
    assert(q.is_pending());
}

// =============================================================================
// Section I: Default protocol
//
//   D1.  Poll.default() is Pending, independent of payload type.
// =============================================================================

@test
fn property_poll_default_is_pending_payload_invariant() {
    let d_int: Poll<Int> = Poll.default();
    let d_text: Poll<Text> = Poll.default();
    let d_bool: Poll<Bool> = Poll.default();
    let d_list: Poll<List<Int>> = Poll.default();
    assert(d_int.is_pending());
    assert(d_text.is_pending());
    assert(d_bool.is_pending());
    assert(d_list.is_pending());
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {}
