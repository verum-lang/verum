// =============================================================================
// core-tests/async/backoff/regression_test.vr
// =============================================================================
//
// Pinned regressions surfaced while building the `core.async.backoff`
// conformance suite. Each `@ignore`d test reproduces a specific
// language / stdlib defect in the minimum form possible — kept here
// forever as a guardrail against re-regression once the underlying
// defect closes.
// =============================================================================

mount core.async.backoff.{Backoff, BackoffStrategy};
mount core.time.duration.{Duration};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// §A  `core.sys.common.random_bytes` not registered in VBC dispatch
//     table — module-load of `core.async.backoff` fails
//
//   `core/async/backoff.vr:71` declares
//     `mount core.sys.common.random_bytes as sys_random_bytes;`
//   so the CSPRNG fn must be reachable at module-load.  The function
//   IS defined in `core/sys/common.vr:1162` (`public fn random_bytes`)
//   with per-OS implementations (Linux getrandom, macOS getentropy,
//   Windows BCryptGenRandom), but the VBC interpreter's dispatch
//   table doesn't carry the registration, so every reference to
//   `Backoff.<any>` from a downstream consumer panics with
//   `FunctionNotFound(FunctionId(N))` at the first call.
//
//   Same upstream defect that gates the
//   `core-tests/collections/reservoir` replacement-phase suite.
//
//   Tracking task: "VBC interpreter: register
//   `core.sys.common.random_bytes` in the dispatch table; gates
//   every consumer that depends on the canonical CSPRNG surface
//   (backoff, reservoir, every BloomFilter/HyperLogLog key
//   construction)".
// =============================================================================

@ignore
@test
fn regression_backoff_exponential_no_jitter_constructs() {
    let _b = Backoff.exponential_no_jitter(
        Duration.from_millis(100),
        Duration.from_secs(30),
    );
}

@ignore
@test
fn regression_backoff_next_delay_returns_base_on_first_call() {
    let mut b = Backoff.exponential_no_jitter(
        Duration.from_millis(100),
        Duration.from_secs(30),
    );
    let d = b.next_delay();
    match d {
        Some(dur) => assert_eq(dur.as_millis(), 100),
        None => assert(false),
    }
}

@ignore
@test
fn regression_backoff_next_delay_doubles_each_call() {
    let mut b = Backoff.exponential_no_jitter(
        Duration.from_millis(100),
        Duration.from_secs(30),
    );
    let d1 = b.next_delay();
    let d2 = b.next_delay();
    let d3 = b.next_delay();
    match d1 { Some(d) => assert_eq(d.as_millis(), 100), None => assert(false) }
    match d2 { Some(d) => assert_eq(d.as_millis(), 200), None => assert(false) }
    match d3 { Some(d) => assert_eq(d.as_millis(), 400), None => assert(false) }
}

@ignore
@test
fn regression_backoff_caps_at_ceiling() {
    let mut b = Backoff.exponential_no_jitter(
        Duration.from_millis(100),
        Duration.from_secs(1),
    );
    let _ = b.next_delay();
    let _ = b.next_delay();
    let _ = b.next_delay();
    let _ = b.next_delay();
    let d = b.next_delay();
    match d {
        Some(dur) => assert_eq(dur.as_millis(), 1000),
        None => assert(false),
    }
}

@ignore
@test
fn regression_backoff_attempt_counter_advances() {
    let mut b = Backoff.exponential_no_jitter(
        Duration.from_millis(10),
        Duration.from_secs(1),
    );
    assert_eq(b.attempt(), 0);
    let _ = b.next_delay();
    assert_eq(b.attempt(), 1);
    let _ = b.next_delay();
    assert_eq(b.attempt(), 2);
}

@ignore
@test
fn regression_backoff_max_attempts_bounds_retries() {
    let mut b = Backoff.exponential_no_jitter(
        Duration.from_millis(10),
        Duration.from_secs(1),
    ).with_max_attempts(3);
    let _ = b.next_delay();
    let _ = b.next_delay();
    let _ = b.next_delay();
    assert(b.next_delay() is Maybe.None);
}

@ignore
@test
fn regression_backoff_reset_zeros_counter() {
    let mut b = Backoff.exponential_no_jitter(
        Duration.from_millis(10),
        Duration.from_secs(1),
    );
    let _ = b.next_delay();
    let _ = b.next_delay();
    b.reset();
    assert_eq(b.attempt(), 0);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {}
