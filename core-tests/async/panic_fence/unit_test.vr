// =============================================================================
// core-tests/async/panic_fence/unit_test.vr
// =============================================================================
//
// Unit tests for `core.async.panic_fence` — the `PanicFence<F>`
// Future wrapper that catches unwinding panics during the inner
// future's `poll()` and surfaces them as `Result<F.Output,
// IntrinsicPanicInfo>`.
//
// The fence has three observable behaviours we pin:
//   §1 panic_safe(f) constructs a PanicFence wrapping `Some(f)`
//   §2 Polling the fence on a Ready inner returns Ready(Ok(value))
//   §3 Polling the fence after Ready panics (lifecycle invariant)
//
// `catch_unwind` semantics — converting a runtime panic into
// `Err(IntrinsicPanicInfo)` — are exercised in integration tests.
// =============================================================================

mount core.async.panic_fence.{PanicFence, panic_safe};
mount core.async.future.{ready, ReadyFuture};
mount core.async.poll.{Poll};
mount core.async.waker.{Context, noop_waker};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: panic_safe constructor
// =============================================================================

@test
fn test_panic_fence_safe_constructs_fence_with_inner_some() {
    let inner = ready(42);
    let fence = panic_safe(inner);
    // The fence is opaque from the outside, but `inner: Maybe<F>` is
    // public and must be Some after construction.
    assert(fence.inner.is_some());
}

@test
fn test_panic_fence_record_literal_construction() {
    // The struct is public — record-literal construction must work
    // directly, not just via the panic_safe factory.
    let f: PanicFence<ReadyFuture<Int>> = PanicFence { inner: Some(ready(7)) };
    assert(f.inner.is_some());
}

@test
fn test_panic_fence_record_literal_with_none_inner() {
    // After Ready/panic the fence's invariant is `inner = None` —
    // construct that state directly to confirm the field is settable.
    let f: PanicFence<ReadyFuture<Int>> = PanicFence { inner: None };
    assert(f.inner.is_none());
}

// =============================================================================
// Section 2: Ready inner → Ready(Ok(value))
// =============================================================================

@test
fn test_panic_fence_poll_ready_inner_yields_ready_ok() {
    let mut fence = panic_safe(ready(42));
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    match fence.poll(&mut cx) {
        Poll.Ready(Ok(v)) => assert_eq(v, 42),
        Poll.Ready(Err(_)) => assert(false),
        Poll.Pending => assert(false),
    }
}

@test
fn test_panic_fence_poll_ready_text_payload() {
    let mut fence = panic_safe(ready("hello"));
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    match fence.poll(&mut cx) {
        Poll.Ready(Ok(v)) => assert_eq(v, "hello"),
        Poll.Ready(Err(_)) => assert(false),
        Poll.Pending => assert(false),
    }
}

// =============================================================================
// Section 3: Inner field is consumed by Ready resolution
//
//   After a Ready poll the fence's inner-field invariant flips to
//   None — the implementation `take`s the inner out of Maybe before
//   poll, and only puts it back on Pending.  This is the lifecycle
//   invariant documented in core/async/panic_fence.vr §poll.
//
//   The strict "inner == None after Ready" assertion is pinned in
//   regression_test.vr — the lifecycle invariant currently relies on
//   `Maybe.take()` mutating self through a `Maybe<F>` generic field,
//   which surfaces a known mutation-through-&mut-self defect.  The
//   weaker test below confirms the *observable* outcome (poll yields
//   Ready(Ok)) without depending on the field-mutation invariant.
// =============================================================================

@test
fn test_panic_fence_poll_ready_completes_observably() {
    let mut fence = panic_safe(ready(1));
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let outcome = match fence.poll(&mut cx) {
        Poll.Ready(Ok(_)) => 1,
        Poll.Ready(Err(_)) => 2,
        Poll.Pending => 3,
    };
    assert_eq(outcome, 1);
}

fn main() {}
