// =============================================================================
// Section 7: ParseErrorKind.to_exit() — clig.dev mapping
// =============================================================================

@test
fn test_kind_to_exit_unknown_flag_is_usage() {
    assert(ParseErrorKind.UnknownFlag.to_exit().code() == 2);
}

@test
fn test_kind_to_exit_unknown_subcommand_is_usage() {
    assert(ParseErrorKind.UnknownSubcommand.to_exit().code() == 2);
}

@test
fn test_kind_to_exit_missing_required_is_usage() {
    assert(ParseErrorKind.MissingRequired.to_exit().code() == 2);
}

@test
fn test_kind_to_exit_invalid_value_is_data_err() {
    assert(ParseErrorKind.InvalidValue.to_exit().code() == 65);
}

@test
fn test_kind_to_exit_refinement_failed_is_data_err() {
    assert(ParseErrorKind.RefinementFailed.to_exit().code() == 65);
}

@test
fn test_kind_to_exit_not_a_tty_is_generic() {
    assert(ParseErrorKind.NotATty.to_exit().code() == 1);
}

@test
fn test_kind_to_exit_internal_error_is_software() {
    assert(ParseErrorKind.InternalError.to_exit().code() == 70);
}

// =============================================================================
// Section 8: ParseErrorKind.tag() — stable JSON output string
// =============================================================================

@test
fn test_kind_tag_unknown_flag() {
    assert(ParseErrorKind.UnknownFlag.tag() == Text.from("UnknownFlag"));
}

@test
fn test_kind_tag_missing_required() {
    assert(ParseErrorKind.MissingRequired.tag() == Text.from("MissingRequired"));
}

@test
fn test_kind_tag_refinement_failed() {
    assert(ParseErrorKind.RefinementFailed.tag() == Text.from("RefinementFailed"));
}

@test
fn test_kind_tag_internal_error() {
    assert(ParseErrorKind.InternalError.tag() == Text.from("InternalError"));
}

@test
fn test_kind_tag_all_distinct() {
    let tags: List<Text> = [
        ParseErrorKind.UnknownFlag.tag(),
        ParseErrorKind.UnknownSubcommand.tag(),
        ParseErrorKind.MissingRequired.tag(),
        ParseErrorKind.MissingValue.tag(),
        ParseErrorKind.InvalidValue.tag(),
        ParseErrorKind.DuplicateFlag.tag(),
        ParseErrorKind.TooFewValues.tag(),
        ParseErrorKind.TooManyValues.tag(),
        ParseErrorKind.RefinementFailed.tag(),
        ParseErrorKind.MutexConflict.tag(),
        ParseErrorKind.RequiresMissing.tag(),
        ParseErrorKind.NotATty.tag(),
        ParseErrorKind.InternalError.tag(),
    ];
    // 13 entries, all distinct
    let mut i: Int = 0;
    while i < tags.len() {
        let mut j: Int = i + 1;
        while j < tags.len() {
            assert(tags[i] != tags[j]);
            j = j + 1;
        }
        i = i + 1;
    }
}
