// =============================================================================
// core-tests/cli/spec/unit_test.vr
// =============================================================================
//
// `core/cli/spec.vr` —
//   * Arity 5-variant ADT (Exactly(N) / AtMost(N) / AtLeast(N) /
//                          Range(M, N) / Unlimited)
//   * Arity.one() / .optional() / .is_switch() / .lower_bound() /
//     .is_required()
// =============================================================================

mount core.cli.spec.Arity;
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: Arity 5-variant construction
// =============================================================================

@test
fn test_arity_exactly_variant() {
    let a: Arity = Arity.Exactly(2);
    assert(a is Arity.Exactly);
}

@test
fn test_arity_at_most_variant() {
    let a: Arity = Arity.AtMost(5);
    assert(a is Arity.AtMost);
}

@test
fn test_arity_at_least_variant() {
    let a: Arity = Arity.AtLeast(1);
    assert(a is Arity.AtLeast);
}

@test
fn test_arity_range_variant() {
    let a: Arity = Arity.Range(1, 3);
    assert(a is Arity.Range);
}

@test
fn test_arity_unlimited_variant() {
    let a: Arity = Arity.Unlimited;
    assert(a is Arity.Unlimited);
}

// =============================================================================
// Section 2: Pairwise disjointness
// =============================================================================

@test
fn test_arity_exactly_disjoint() {
    let a: Arity = Arity.Exactly(0);
    assert(!(a is Arity.AtMost));
    assert(!(a is Arity.AtLeast));
    assert(!(a is Arity.Range));
    assert(!(a is Arity.Unlimited));
}

@test
fn test_arity_unlimited_disjoint() {
    let a: Arity = Arity.Unlimited;
    assert(!(a is Arity.Exactly));
    assert(!(a is Arity.AtMost));
    assert(!(a is Arity.AtLeast));
    assert(!(a is Arity.Range));
}

// =============================================================================
// Section 3: Arity static constructors
// =============================================================================

@test
fn test_arity_one_returns_exactly_one() {
    let a: Arity = Arity.one();
    assert(a is Arity.Exactly);
    match a {
        Arity.Exactly(n) => assert_eq(n, 1),
        _ => panic("expected Exactly"),
    }
}

@test
fn test_arity_optional_returns_at_most_one() {
    let a: Arity = Arity.optional();
    assert(a is Arity.AtMost);
    match a {
        Arity.AtMost(n) => assert_eq(n, 1),
        _ => panic("expected AtMost"),
    }
}

// =============================================================================
// Section 4: Arity.is_switch() — Exactly(0) iff switch
// =============================================================================

@test
fn test_arity_exactly_zero_is_switch() {
    let a: Arity = Arity.Exactly(0);
    assert(a.is_switch());
}

@test
fn test_arity_exactly_one_not_switch() {
    let a: Arity = Arity.Exactly(1);
    assert(!a.is_switch());
}

@test
fn test_arity_at_most_zero_not_switch() {
    let a: Arity = Arity.AtMost(0);
    assert(!a.is_switch());
}

@test
fn test_arity_unlimited_not_switch() {
    let a: Arity = Arity.Unlimited;
    assert(!a.is_switch());
}

// =============================================================================
// Section 5: Arity.lower_bound()
// =============================================================================

@test
fn test_arity_lower_bound_exactly() {
    let a: Arity = Arity.Exactly(3);
    assert_eq(a.lower_bound(), 3);
}

@test
fn test_arity_lower_bound_at_most_is_zero() {
    let a: Arity = Arity.AtMost(5);
    assert_eq(a.lower_bound(), 0);
}

@test
fn test_arity_lower_bound_at_least() {
    let a: Arity = Arity.AtLeast(2);
    assert_eq(a.lower_bound(), 2);
}

@test
fn test_arity_lower_bound_range() {
    let a: Arity = Arity.Range(1, 4);
    assert_eq(a.lower_bound(), 1);
}

@test
fn test_arity_lower_bound_unlimited_is_zero() {
    let a: Arity = Arity.Unlimited;
    assert_eq(a.lower_bound(), 0);
}

// =============================================================================
// Section 6: Arity.is_required() — true iff lower_bound > 0
// =============================================================================

@test
fn test_arity_is_required_at_least_one() {
    let a: Arity = Arity.AtLeast(1);
    assert(a.is_required());
}

@test
fn test_arity_is_required_exactly_one() {
    let a: Arity = Arity.Exactly(1);
    assert(a.is_required());
}

@test
fn test_arity_is_required_at_most_one_not_required() {
    let a: Arity = Arity.AtMost(1);
    assert(!a.is_required());
}

@test
fn test_arity_is_required_unlimited_not_required() {
    let a: Arity = Arity.Unlimited;
    assert(!a.is_required());
}

fn main() {}
