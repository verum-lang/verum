// =============================================================================
// core-tests/collections/hyperloglog/integration_test.vr
// =============================================================================

mount core.prelude.*;
mount core.collections.hyperloglog.{MIN_PRECISION, MAX_PRECISION, DEFAULT_PRECISION};

@test
fn int_hll_precision_range_spans_at_least_one() {
    assert(MAX_PRECISION - MIN_PRECISION >= 1);
}

@test
fn int_hll_default_precision_strictly_inside_or_at_boundary() {
    assert(DEFAULT_PRECISION >= MIN_PRECISION);
    assert(DEFAULT_PRECISION <= MAX_PRECISION);
}
