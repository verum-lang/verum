// =============================================================================
// core-tests/collections/heap/unit_test.vr
// =============================================================================
//
// Tests for `core.collections.heap` — BinaryHeap<T: Ord>, the canonical
// max-heap priority queue.
//
// Stdlib decl: `type BinaryHeap<T: Ord> is { data: List<T> }`. No direct
// runtime intercept — every method delegates through `self.data.<method>`
// on the inner List, which is itself runtime-intercepted. The wrapper-
// record indirection is safe IFF `self.data` resolves to the inner List
// pointer at the right slot.
//
// Construction goes through `BinaryHeap.new()` which the stdlib body
// builds as `BinaryHeap { data: List.new() }`. The runtime executes the
// stdlib body, calling intercepted `List.new()`, and wraps the resulting
// List in a 1-slot heap record. Codegen-side field access on `self.data`
// then resolves to the inner List, and downstream method dispatch is on
// a real List object.
// =============================================================================

mount core.prelude.*;
mount core.collections.heap.BinaryHeap;

// =============================================================================
// Section 1: BinaryHeap.new — construction
// =============================================================================

@test
fn test_heap_new_is_empty() {
    let h: BinaryHeap<Int> = BinaryHeap.new();
    assert_eq(h.len(), 0);
    assert(h.is_empty());
}

@test
fn test_heap_new_peek_is_none() {
    let h: BinaryHeap<Int> = BinaryHeap.new();
    assert_eq(h.peek(), None);
}

// =============================================================================
// Section 2: push / peek — basic heap-property
// =============================================================================

@test
fn test_heap_push_one_element_peek_returns_it() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(42);
    assert_eq(h.len(), 1);
    assert_eq(h.peek(), Some(42));
}

@test
fn test_heap_push_ascending_yields_max_on_top() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(2);
    h.push(3);
    h.push(4);
    h.push(5);
    // Max-heap: top is the largest pushed.
    assert_eq(h.peek(), Some(5));
}

@test
fn test_heap_push_descending_yields_max_on_top() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(5);
    h.push(4);
    h.push(3);
    h.push(2);
    h.push(1);
    assert_eq(h.peek(), Some(5));
}

@test
fn test_heap_push_mixed_yields_max_on_top() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(3);
    h.push(1);
    h.push(4);
    h.push(1);
    h.push(5);
    h.push(9);
    h.push(2);
    h.push(6);
    assert_eq(h.peek(), Some(9));
}

// =============================================================================
// Section 3: pop — drain in descending order
// =============================================================================

@test
fn test_heap_pop_returns_max_first() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(3);
    h.push(1);
    h.push(4);
    h.push(1);
    h.push(5);
    assert_eq(h.pop(), Some(5));
    assert_eq(h.pop(), Some(4));
    assert_eq(h.pop(), Some(3));
    assert_eq(h.pop(), Some(1));
    assert_eq(h.pop(), Some(1));
    assert_eq(h.pop(), None);
}

@test
fn test_heap_pop_decrements_len() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);
    h.push(30);
    let _ = h.pop();
    assert_eq(h.len(), 2);
}

@test
fn test_heap_pop_from_empty_is_none() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    assert_eq(h.pop(), None);
}

// =============================================================================
// Section 4: clear / is_empty — reset
// =============================================================================

@test
fn test_heap_clear_empties_heap() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(2);
    h.push(3);
    h.clear();
    assert(h.is_empty());
    assert_eq(h.len(), 0);
}

@test
fn test_heap_clear_then_push_starts_fresh() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(2);
    h.clear();
    h.push(99);
    assert_eq(h.len(), 1);
    assert_eq(h.peek(), Some(99));
}

// =============================================================================
// Section 5: into_sorted_list — full drain in ascending order
// =============================================================================

@test
fn test_heap_into_sorted_list_ascending() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(3);
    h.push(1);
    h.push(4);
    h.push(1);
    h.push(5);
    h.push(9);
    h.push(2);
    h.push(6);
    let sorted = h.into_sorted_list();
    assert_eq(sorted.len(), 8);
    assert_eq(sorted.get(0), Some(1));
    assert_eq(sorted.get(1), Some(1));
    assert_eq(sorted.get(2), Some(2));
    assert_eq(sorted.get(7), Some(9));
}

// =============================================================================
// Section 6: with_capacity — explicit preallocation
// =============================================================================

@test
fn test_heap_with_capacity_starts_empty() {
    let h: BinaryHeap<Int> = BinaryHeap.with_capacity(64);
    assert_eq(h.len(), 0);
    assert(h.is_empty());
}

@test
fn test_heap_with_capacity_then_fill_preserves_max_invariant() {
    let mut h: BinaryHeap<Int> = BinaryHeap.with_capacity(8);
    h.push(5);
    h.push(1);
    h.push(9);
    h.push(3);
    // Max-heap → peek returns greatest.
    assert_eq(h.peek(), Some(9));
}

// =============================================================================
// Section 7: push_pop — atomic push-then-pop convenience
//
//   `push_pop(v)` is equivalent to push then pop. When v ≥ current max, it
//   returns v (heap unchanged); otherwise it pops the current max and the
//   new v sits inside.
// =============================================================================

@test
fn test_heap_push_pop_returns_value_when_value_is_largest() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(2);
    h.push(3);
    // Pushing 100 → it's the new max → pop returns it; heap stays {1,2,3}.
    let out = h.push_pop(100);
    assert_eq(out, 100);
    assert_eq(h.peek(), Some(3));
    assert_eq(h.len(), 3);
}

@test
fn test_heap_push_pop_returns_current_max_when_value_is_smaller() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);
    h.push(30);
    // Pushing 5 → current max 30 is popped; heap becomes {10, 20, 5}.
    let out = h.push_pop(5);
    assert_eq(out, 30);
    assert_eq(h.len(), 3);
    assert_eq(h.peek(), Some(20));
}

@test
fn test_heap_push_pop_on_empty_returns_value() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    let out = h.push_pop(42);
    // Empty heap → pushed value is itself the max → popped.
    assert_eq(out, 42);
    assert(h.is_empty());
}

// =============================================================================
// Section 8: replace — pop-then-push compound
//
//   `replace(v)` pops the current max (returns it as Maybe) and pushes v.
//   On an empty heap returns None and v is still pushed.
// =============================================================================

@test
fn test_heap_replace_returns_previous_max() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);
    let old: Maybe<Int> = h.replace(99);
    assert_eq(old, Some(20));
    // New max is 99.
    assert_eq(h.peek(), Some(99));
    assert_eq(h.len(), 2);
}

@test
fn test_heap_replace_on_empty_returns_none() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    let old: Maybe<Int> = h.replace(7);
    assert_eq(old, None);
    assert_eq(h.peek(), Some(7));
    assert_eq(h.len(), 1);
}

// =============================================================================
// Section 9: try_push — fallible push
// =============================================================================

@test
fn test_heap_try_push_succeeds() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    let r = h.try_push(42);
    assert(r.is_ok());
    assert_eq(h.peek(), Some(42));
}

// =============================================================================
// Section 10: Singleton heap — edge cases
// =============================================================================

@test
fn test_heap_singleton_pop_then_empty() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(99);
    assert_eq(h.pop(), Some(99));
    assert(h.is_empty());
    assert_eq(h.pop(), None);
}

@test
fn test_heap_singleton_peek_returns_value() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(42);
    assert_eq(h.peek(), Some(42));
}

// =============================================================================
// Section 11: Reverse / in-order insert both yield descending drain
// =============================================================================

@test
fn test_heap_inserted_in_increasing_order_drains_descending() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    let mut i = 1;
    while i <= 5 {
        h.push(i);
        i = i + 1;
    }
    // Drain — should be 5, 4, 3, 2, 1.
    assert_eq(h.pop(), Some(5));
    assert_eq(h.pop(), Some(4));
    assert_eq(h.pop(), Some(3));
    assert_eq(h.pop(), Some(2));
    assert_eq(h.pop(), Some(1));
    assert_eq(h.pop(), None);
}

@test
fn test_heap_inserted_in_decreasing_order_drains_descending() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    let mut i = 5;
    while i >= 1 {
        h.push(i);
        i = i - 1;
    }
    assert_eq(h.pop(), Some(5));
    assert_eq(h.pop(), Some(4));
    assert_eq(h.pop(), Some(3));
    assert_eq(h.pop(), Some(2));
    assert_eq(h.pop(), Some(1));
}

@test
fn test_heap_duplicates_preserved_in_drain() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(3);
    h.push(3);
    h.push(3);
    assert_eq(h.len(), 3);
    assert_eq(h.pop(), Some(3));
    assert_eq(h.pop(), Some(3));
    assert_eq(h.pop(), Some(3));
    assert(h.is_empty());
}

fn main() {}
