// =============================================================================
// core-tests/collections/list/regression_test.vr
// =============================================================================
//
// Pinned regressions surfaced while building the list conformance suite.
// Each `@ignore`d test reproduces a specific stdlib / language-level defect
// in the minimum form possible. Tests stay forever — even after the
// underlying defect closes — to guard against re-regression.
// =============================================================================

mount core.prelude.*;

// =============================================================================
// §A  Static-constructor name resolution for non-intercepted constructors.
//
//   The codegen function-table only resolves `List.new` and
//   `List.with_capacity` because both are intercepted at the
//   `method_dispatch.rs` static-constructor block (canonical
//   `[len, cap, backing_ptr]` runtime layout). The remaining stdlib
//   constructors — `List.from(array)`, `List.from_elem(value, n)`,
//   `List.of(value)` — are real public `impl<T> List<T>` static methods
//   with bodies. They register correctly during stdlib precompile and
//   work in stdlib-internal code (`core/net/weft/metrics.vr`,
//   `core/verify/kernel_soundness/rules.vr`), but FAIL with
//   `CodegenError::UndefinedFunction("List.from")` at every user-side
//   call site because the cross-module function-name table propagated
//   to user-side bytecode misses these IDs.
//
//   Same defect class as Tasks #24/#25/#26 close-out: cross-module Call
//   name-table coverage is incomplete for stdlib types whose static
//   methods aren't intercepted at dispatch time. The fix is structural —
//   either fold every constructor into the same intercept block (low
//   complexity, expensive to maintain across every stdlib type), OR fix
//   the user-side function-id remap to cover constructor IDs that don't
//   appear in any user-side body's Call instruction.
//
//   Tracking: this regression suite + audit.md §1.
// =============================================================================

@ignore
@test
fn regression_list_from_array_literal_undefined_function() {
    // Expected: List.from([1, 2, 3]) builds a 3-element List<Int>.
    // Actual: codegen raises UndefinedFunction("List.from").
    let xs: List<Int> = List.from([1, 2, 3]);
    assert_eq(xs.len(), 3);
}

@ignore
@test
fn regression_list_of_undefined_function() {
    // Expected: List.of(42) builds a 1-element List<Int>.
    // Actual: codegen raises UndefinedFunction("List.of").
    let xs: List<Int> = List.of(42);
    assert_eq(xs.len(), 1);
    assert_eq(xs.get(0), Some(42));
}

@ignore
@test
fn regression_list_from_elem_undefined_function() {
    // Expected: List.from_elem(7, 4) builds [7, 7, 7, 7].
    // Actual: codegen raises UndefinedFunction("List.from_elem").
    let xs: List<Int> = List.from_elem(7, 4);
    assert_eq(xs.len(), 4);
    assert_eq(xs.get(0), Some(7));
}

// =============================================================================
// §B  Runtime memory-layout drift between stdlib type decl and runtime
//     intercept allocation shape.
//
//   The runtime `List.new()` / `List.with_capacity()` intercepts at
//   `crates/verum_vbc/src/interpreter/dispatch_table/handlers/method_dispatch.rs`
//   allocate the canonical heap object as `[len@0, cap@1, backing_ptr@2]`
//   after the heap header. The stdlib declares
//   `type List<T> is { ptr: &unsafe T, len: Int, cap: Int }` — ptr at
//   slot 0 in the type decl order, but at slot 2 in the runtime
//   intercept order.
//
//   Codegen resolves `self.<field>` via the type declaration's field
//   order, so when an unintercepted stdlib method falls through to its
//   body (e.g. `swap_remove`, `truncate`, `retain`, `fill`, every
//   `&mut self` family method without an explicit intercept), the body's
//   `self.ptr` reads slot 0 (= the runtime's `len` Int) and the body's
//   `self.len` reads slot 1 (= the runtime's `cap`).
//
//   Consequence:
//     * `self.ptr.offset(idx)` reads from a bogus address derived from
//       an Int reinterpreted as a pointer — SIGSEGV (e.g. truncate-
//       internal pop chain, retain, fill).
//     * `while self.len > new_len { self.pop() }` reads `cap` instead
//       of `len` — infinite loop.
//     * `let val = ptr_read(self.ptr.offset(idx))` returns the wrong
//       bit pattern — silent data corruption.
//
//   The fundamental fix is one of:
//     1. Re-declare the stdlib type as `{ len, cap, ptr }` so the
//        type-decl field order matches the runtime intercept layout.
//     2. Add a Rust-side runtime intercept for every `&mut self` /
//        `&self` method that reads internal fields.
//     3. Lift the runtime intercept allocation into a stdlib code path
//        that uses the same field-init constructor (`List { ptr, len,
//        cap }`) — the codegen would then assign field offsets in the
//        same order as the type decl.
//
//   Methods landed as intercepts in this branch to unblock unit tests
//   without a full re-layout: set, get_or, swap_remove, truncate.
//
//   Tracking: audit.md §2. Remaining unblocked-by-intercept methods
//   pinned below.
// =============================================================================

@ignore
@test
fn regression_list_retain_layout_drift() {
    // Expected: retain(|x| *x % 2 == 0) leaves evens.
    // Actual: pre-intercept, retain falls through to stdlib body which
    // reads self.ptr (slot 0 = len in runtime) as a pointer and SIGSEGVs.
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.retain(|x| *x % 2 == 0);
    assert_eq(xs.len(), 2);
}

@ignore
@test
fn regression_list_fill_layout_drift() {
    // Expected: fill(value) overwrites every slot with `value`.
    // Actual: writes go through ptr_write on a misaligned address.
    let mut xs: List<Int> = [1, 2, 3, 4];
    xs.fill(0);
    assert_eq(xs.get(0), Some(0));
    assert_eq(xs.get(3), Some(0));
}

@ignore
@test
fn regression_list_resize_layout_drift() {
    // Expected: resize(5, 0) extends [1, 2] to [1, 2, 0, 0, 0].
    // Actual: stdlib body uses self.ptr / self.len arithmetic against
    // wrong slots; outcome is undefined data and/or len corruption.
    let mut xs: List<Int> = [1, 2];
    xs.resize(5, 0);
    assert_eq(xs.len(), 5);
    assert_eq(xs.get(4), Some(0));
}

@ignore
@test
fn regression_list_sort_via_user_callback() {
    // Expected: sort_by(custom_cmp) sorts via the callback.
    // Actual: closure dispatch on List elements goes through a path
    // that hits the layout drift; pinned for parity with sort default
    // (which is intercepted and works).
    let mut xs: List<Int> = [3, 1, 2];
    xs.sort_by(|a, b| (*b).cmp(a));
    assert_eq(xs.get(0), Some(3));
    assert_eq(xs.get(2), Some(1));
}

// =============================================================================
// §C  contains needle CBGR-ref bit-comparison (CLOSED in this branch).
//
//   Pre-fix, `xs.contains(&value)` for primitive `value` always returned
//   false because the runtime intercept compared the ref-encoded bits
//   directly against each NaN-boxed element. Closed by auto-derefing the
//   needle through `decode_cbgr_ref` before the bit-equality compare.
//   Pinned here as a permanent guardrail.
// =============================================================================

@test
fn regression_list_contains_primitive_needle_via_ref() {
    // Pre-fix: returned false. Post-fix: returns true.
    let xs: List<Int> = [10, 20, 30];
    assert(xs.contains(&20));
    assert(xs.contains(&30));
    assert(!xs.contains(&99));
}

fn main() {}
