// =============================================================================
// core-tests/collections/list/regression_test.vr
// =============================================================================
//
// Pinned regressions surfaced while building the list conformance suite.
// Each `@ignore`d test reproduces a specific stdlib / language-level defect
// in the minimum form possible. Tests stay forever — even after the
// underlying defect closes — to guard against re-regression.
// =============================================================================

mount core.prelude.*;

// =============================================================================
// §A  Static-constructor name resolution for non-intercepted constructors.
//
//   The codegen function-table only resolves `List.new` and
//   `List.with_capacity` because both are intercepted at the
//   `method_dispatch.rs` static-constructor block (canonical
//   `[len, cap, backing_ptr]` runtime layout). The remaining stdlib
//   constructors — `List.from(array)`, `List.from_elem(value, n)`,
//   `List.of(value)` — are real public `impl<T> List<T>` static methods
//   with bodies. They register correctly during stdlib precompile and
//   work in stdlib-internal code (`core/net/weft/metrics.vr`,
//   `core/verify/kernel_soundness/rules.vr`), but FAIL with
//   `CodegenError::UndefinedFunction("List.from")` at every user-side
//   call site because the cross-module function-name table propagated
//   to user-side bytecode misses these IDs.
//
//   Same defect class as Tasks #24/#25/#26 close-out: cross-module Call
//   name-table coverage is incomplete for stdlib types whose static
//   methods aren't intercepted at dispatch time. The fix is structural —
//   either fold every constructor into the same intercept block (low
//   complexity, expensive to maintain across every stdlib type), OR fix
//   the user-side function-id remap to cover constructor IDs that don't
//   appear in any user-side body's Call instruction.
//
//   Tracking: this regression suite + audit.md §1.
// =============================================================================

// CLOSED 2026-05-24 (commit 0360a343e) — List.from rewritten to use
// index-based iteration; `for item in [T; N]` silently no-op'd
// (returned empty list).  Test now active as a guardrail.
@test
fn regression_list_from_array_literal_undefined_function() {
    let xs: List<Int> = List.from([1, 2, 3]);
    assert_eq(xs.len(), 3);
}

// CLOSED 2026-05-24 (commit 0360a343e cohort) — same as above,
// already worked but kept as guardrail.
@test
fn regression_list_of_undefined_function() {
    let xs: List<Int> = List.of(42);
    assert_eq(xs.len(), 1);
    assert_eq(xs.get(0), Some(42));
}

// CLOSED 2026-05-24 — same as above.
@test
fn regression_list_from_elem_undefined_function() {
    let xs: List<Int> = List.from_elem(7, 4);
    assert_eq(xs.len(), 4);
    assert_eq(xs.get(0), Some(7));
}

// =============================================================================
// §B  Runtime memory-layout drift between stdlib type decl and runtime
//     intercept allocation shape — CLOSED.
//
//   Pre-fix history: the runtime `List.new()` / `List.with_capacity()`
//   intercepts at `crates/verum_vbc/src/interpreter/dispatch_table/handlers/
//   method_dispatch.rs` allocate the canonical heap object as
//   `[len@0, cap@1, backing_ptr@2]` after the heap header. The stdlib
//   declared `type List<T> is { ptr, len, cap }` — ptr at slot 0 in the
//   type decl order, but at slot 2 in the runtime intercept order.
//
//   Codegen resolved `self.<field>` via the type-declaration field
//   order, so every unintercepted stdlib method that read internal
//   fields misrouted (retain SIGSEGV, fill silent no-op, resize
//   undefined data, sort_by reference corruption, …).
//
//   Fundamental fix in this branch: reorder the stdlib type decl to
//   `{ len, cap, ptr }` so codegen field-index = runtime slot index.
//   Re-aligned methods are now covered in unit_test.vr §10 (retain /
//   resize / rotate_left / dedup) — they ALL pass through the stdlib
//   body now, no Rust-side intercept required.
//
//   The Rust-side intercepts for `set`, `get_or`, `swap_remove`,
//   `truncate` remain as defense-in-depth (cheaper than crossing into
//   the stdlib body) and as a guarantee that the runtime is independent
//   of any stdlib regression.
//
//   The guardrail tests below stay non-`@ignore`d so any future re-drift
//   of the type-decl field order fails CI immediately.
// =============================================================================

@test
fn regression_list_retain_through_stdlib_body() {
    // Pre-fix: SIGSEGV. Post-fix: stdlib body's self.ptr.offset(i)
    // correctly reads from slot 2 (the backing pointer).
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.retain(|x| *x % 2 == 0);
    assert_eq(xs.len(), 2);
    assert_eq(xs.get(0), Some(2));
    assert_eq(xs.get(1), Some(4));
}

@test
fn regression_list_resize_through_stdlib_body() {
    // Pre-fix: silent data corruption. Post-fix: tail extension works.
    let mut xs: List<Int> = [1, 2];
    xs.resize(5, 0);
    assert_eq(xs.len(), 5);
    assert_eq(xs.get(4), Some(0));
}

@test
fn regression_list_dedup_through_stdlib_body() {
    let mut xs: List<Int> = [1, 1, 2, 2, 3, 3, 3];
    xs.dedup();
    assert_eq(xs.len(), 3);
}

@test
fn regression_list_rotate_left_through_stdlib_body() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.rotate_left(2);
    assert_eq(xs.get(0), Some(3));
    assert_eq(xs.get(4), Some(2));
}

// =============================================================================
// §D  Residual cross-class defects exposed AFTER the layout fix landed
//     (the fix unblocked the code path to reach them).
//
//   These are NOT layout-drift defects — they live in adjacent layers
//   (Clone-dispatch, ref-deref equality) that the now-reachable code
//   paths exercise. Tracked separately.
// =============================================================================

@ignore
@test
fn regression_list_fill_value_clone_dispatch() {
    // Expected: fill(0) writes 0 into every slot.
    // Actual: `value.clone()` dispatch for Int returns a wrong NaN-
    // boxed Value — the resulting writes are uniform but not equal to
    // the source value. Not a layout issue.
    let mut xs: List<Int> = [1, 2, 3, 4];
    xs.fill(0);
    assert_eq(xs.get(0), Some(0));
    assert_eq(xs.get(3), Some(0));
}

@ignore
@test
fn regression_list_is_sorted_ref_deref_compare() {
    // Expected: is_sorted on a sorted List<Int> returns true.
    // Actual: stdlib uses `&*self.ptr.offset(i)` then compares `a > b`
    // — comparing references-to-Int rather than the Int values
    // themselves. Not a layout issue (the deref reaches the right
    // pointer); the comparison operator picks address-comparison.
    let xs: List<Int> = [1, 2, 3, 4, 5];
    assert(xs.is_sorted());
}

@ignore
@test
fn regression_list_sort_by_closure_via_deref_compare() {
    // Same defect class as is_sorted — the closure is invoked with
    // `&T` references that compare addresses, not values.
    let mut xs: List<Int> = [3, 1, 2];
    xs.sort_by(|a, b| (*b).cmp(a));
    assert_eq(xs.get(0), Some(3));
    assert_eq(xs.get(2), Some(1));
}

// =============================================================================
// §C  contains needle CBGR-ref bit-comparison (CLOSED in this branch).
//
//   Pre-fix, `xs.contains(&value)` for primitive `value` always returned
//   false because the runtime intercept compared the ref-encoded bits
//   directly against each NaN-boxed element. Closed by auto-derefing the
//   needle through `decode_cbgr_ref` before the bit-equality compare.
//   Pinned here as a permanent guardrail.
// =============================================================================

@test
fn regression_list_contains_primitive_needle_via_ref() {
    // Pre-fix: returned false. Post-fix: returns true.
    let xs: List<Int> = [10, 20, 30];
    assert(xs.contains(&20));
    assert(xs.contains(&30));
    assert(!xs.contains(&99));
}

fn main() {}
