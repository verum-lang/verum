// =============================================================================
// core-tests/collections/list/unit_test.vr
// =============================================================================
//
// Tests for `core.collections.list` — the canonical dynamic array primitive
// (`List<T>`). One axis of behaviour per `@test`; section banners group tests
// by the public method or method-family under test.
//
// Construction: every test goes through one of the two `List<T>` builders
// that the codegen + runtime cleanly resolve today —
//   * `List.new()` / `List.with_capacity(n)` — runtime-intercepted in
//     `method_dispatch.rs` (handles the canonical 3-Value heap layout).
//   * `let xs: List<Int> = [1, 2, 3]` — the array-literal coercion path
//     through `ArrayCoercible for List<T>` (`core/collections/list.vr:86`).
//
// `List.from`, `List.from_elem`, `List.of` are pinned in regression_test.vr
// §A — they fail the codegen function-table lookup despite being defined as
// public `impl<T> List<T>` static methods. That is a fundamental cross-
// module name-resolution defect, not a per-call-site bug. The remaining unit-
// API surface stays fully testable through the two builders above.
// =============================================================================

mount core.prelude.*;

// =============================================================================
// Section 1: List.new / List.with_capacity / array-literal — construction
// =============================================================================

@test
fn test_list_new_is_empty() {
    let xs: List<Int> = List.new();
    assert_eq(xs.len(), 0);
    assert(xs.is_empty());
}

@test
fn test_list_with_capacity_reserves_but_keeps_len_zero() {
    let xs: List<Int> = List.with_capacity(16);
    assert_eq(xs.len(), 0);
    assert(xs.capacity() >= 16);
}

@test
fn test_list_with_capacity_zero_falls_back_to_default() {
    // Internal default is 16 to keep the first push allocation-free.
    let xs: List<Int> = List.with_capacity(0);
    assert_eq(xs.len(), 0);
    assert(xs.is_empty());
}

@test
fn test_list_array_literal_preserves_length() {
    let xs: List<Int> = [10, 20, 30];
    assert_eq(xs.len(), 3);
    assert(!xs.is_empty());
}

@test
fn test_list_array_literal_preserves_order() {
    let xs: List<Int> = [10, 20, 30];
    assert_eq(xs.get(0), Some(10));
    assert_eq(xs.get(1), Some(20));
    assert_eq(xs.get(2), Some(30));
}

@test
fn test_list_empty_array_literal() {
    let xs: List<Int> = [];
    assert(xs.is_empty());
    assert_eq(xs.len(), 0);
}

// =============================================================================
// Section 2: push / pop — back-end mutation
// =============================================================================

@test
fn test_list_push_increments_len() {
    let mut xs: List<Int> = List.new();
    xs.push(1);
    assert_eq(xs.len(), 1);
    xs.push(2);
    assert_eq(xs.len(), 2);
    xs.push(3);
    assert_eq(xs.len(), 3);
}

@test
fn test_list_push_preserves_order() {
    let mut xs: List<Int> = List.new();
    xs.push(10);
    xs.push(20);
    xs.push(30);
    assert_eq(xs.get(0), Some(10));
    assert_eq(xs.get(1), Some(20));
    assert_eq(xs.get(2), Some(30));
}

@test
fn test_list_push_grows_capacity() {
    let mut xs: List<Int> = List.new();
    let mut i = 0;
    while i < 32 {
        xs.push(i);
        i = i + 1;
    }
    assert_eq(xs.len(), 32);
    assert(xs.capacity() >= 32);
}

@test
fn test_list_pop_from_empty_returns_none() {
    let mut xs: List<Int> = List.new();
    assert_eq(xs.pop(), None);
}

@test
fn test_list_pop_returns_last_pushed() {
    let mut xs: List<Int> = [10, 20, 30];
    assert_eq(xs.pop(), Some(30));
    assert_eq(xs.pop(), Some(20));
    assert_eq(xs.pop(), Some(10));
    assert_eq(xs.pop(), None);
}

@test
fn test_list_pop_decrements_len() {
    let mut xs: List<Int> = [1, 2, 3];
    let _ = xs.pop();
    assert_eq(xs.len(), 2);
}

// =============================================================================
// Section 3: get / first / last / is_empty / is_not_empty — read-only access
// =============================================================================

@test
fn test_list_get_in_bounds_returns_some() {
    let xs: List<Int> = [100, 200, 300];
    assert_eq(xs.get(0), Some(100));
    assert_eq(xs.get(1), Some(200));
    assert_eq(xs.get(2), Some(300));
}

@test
fn test_list_get_out_of_bounds_returns_none() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.get(3), None);
    assert_eq(xs.get(100), None);
}

@test
fn test_list_get_negative_index_returns_none() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.get(-1), None);
}

@test
fn test_list_first_of_non_empty() {
    let xs: List<Int> = [7, 8, 9];
    assert_eq(xs.first(), Some(7));
}

@test
fn test_list_first_of_empty_is_none() {
    let xs: List<Int> = List.new();
    assert_eq(xs.first(), None);
}

@test
fn test_list_last_of_non_empty() {
    let xs: List<Int> = [7, 8, 9];
    assert_eq(xs.last(), Some(9));
}

@test
fn test_list_last_of_empty_is_none() {
    let xs: List<Int> = List.new();
    assert_eq(xs.last(), None);
}

@test
fn test_list_is_empty_after_new() {
    let xs: List<Int> = List.new();
    assert(xs.is_empty());
}

@test
fn test_list_is_not_empty_after_push() {
    let mut xs: List<Int> = List.new();
    xs.push(1);
    assert(!xs.is_empty());
}

// =============================================================================
// Section 4: set / swap / clear / truncate — in-place mutation
// =============================================================================

@test
fn test_list_set_overwrites_in_place() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.set(1, 42);
    assert_eq(xs.get(1), Some(42));
    assert_eq(xs.len(), 3);
}

@test
fn test_list_swap_exchanges_two_indices() {
    let mut xs: List<Int> = [10, 20, 30];
    xs.swap(0, 2);
    assert_eq(xs.get(0), Some(30));
    assert_eq(xs.get(2), Some(10));
    assert_eq(xs.get(1), Some(20));
}

@test
fn test_list_swap_same_index_is_noop() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.swap(1, 1);
    assert_eq(xs.get(1), Some(2));
}

@test
fn test_list_clear_empties_list() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.clear();
    assert_eq(xs.len(), 0);
    assert(xs.is_empty());
}

@test
fn test_list_truncate_shorter_than_len_drops_tail() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.truncate(3);
    assert_eq(xs.len(), 3);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(2), Some(3));
    assert_eq(xs.get(3), None);
}

@test
fn test_list_truncate_longer_than_len_is_noop() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.truncate(10);
    assert_eq(xs.len(), 3);
}

@test
fn test_list_truncate_to_zero_clears() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.truncate(0);
    assert_eq(xs.len(), 0);
}

// =============================================================================
// Section 5: reverse / insert / remove / swap_remove — order & shape mutation
// =============================================================================

@test
fn test_list_reverse_odd_length() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.reverse();
    assert_eq(xs.get(0), Some(5));
    assert_eq(xs.get(1), Some(4));
    assert_eq(xs.get(2), Some(3));
    assert_eq(xs.get(3), Some(2));
    assert_eq(xs.get(4), Some(1));
}

@test
fn test_list_reverse_even_length() {
    let mut xs: List<Int> = [1, 2, 3, 4];
    xs.reverse();
    assert_eq(xs.get(0), Some(4));
    assert_eq(xs.get(3), Some(1));
}

@test
fn test_list_reverse_empty_is_noop() {
    let mut xs: List<Int> = List.new();
    xs.reverse();
    assert_eq(xs.len(), 0);
}

@test
fn test_list_reverse_involution() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.reverse();
    xs.reverse();
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(4), Some(5));
}

@test
fn test_list_insert_at_start_shifts_right() {
    let mut xs: List<Int> = [2, 3, 4];
    xs.insert(0, 1);
    assert_eq(xs.len(), 4);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(1), Some(2));
    assert_eq(xs.get(3), Some(4));
}

@test
fn test_list_insert_at_end_is_push() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.insert(3, 4);
    assert_eq(xs.len(), 4);
    assert_eq(xs.get(3), Some(4));
}

@test
fn test_list_insert_in_middle_preserves_order() {
    let mut xs: List<Int> = [10, 30, 40];
    xs.insert(1, 20);
    assert_eq(xs.get(0), Some(10));
    assert_eq(xs.get(1), Some(20));
    assert_eq(xs.get(2), Some(30));
    assert_eq(xs.get(3), Some(40));
}

@test
fn test_list_remove_first_shifts_left() {
    let mut xs: List<Int> = [1, 2, 3, 4];
    let removed = xs.remove(0);
    assert_eq(removed, 1);
    assert_eq(xs.len(), 3);
    assert_eq(xs.get(0), Some(2));
    assert_eq(xs.get(2), Some(4));
}

@test
fn test_list_remove_middle_shifts_left() {
    let mut xs: List<Int> = [1, 2, 3, 4];
    let removed = xs.remove(2);
    assert_eq(removed, 3);
    assert_eq(xs.len(), 3);
    assert_eq(xs.get(2), Some(4));
}

@test
fn test_list_swap_remove_returns_and_replaces_with_last() {
    let mut xs: List<Int> = [1, 2, 3, 4];
    let removed = xs.swap_remove(1);
    assert_eq(removed, 2);
    assert_eq(xs.len(), 3);
    // Slot 1 now holds what was the last element.
    assert_eq(xs.get(1), Some(4));
}

// =============================================================================
// Section 6: contains — value search (post-fix for CBGR-ref needle deref)
// =============================================================================

@test
fn test_list_contains_existing_value() {
    let xs: List<Int> = [1, 2, 3, 4];
    assert(xs.contains(&2));
    assert(xs.contains(&4));
}

@test
fn test_list_contains_absent_value() {
    let xs: List<Int> = [1, 2, 3, 4];
    assert(!xs.contains(&99));
}

@test
fn test_list_contains_in_empty_is_false() {
    let xs: List<Int> = List.new();
    assert(!xs.contains(&0));
}

// =============================================================================
// Section 7: sort / is_sorted — ordering
// =============================================================================

@test
fn test_list_sort_ascending() {
    let mut xs: List<Int> = [3, 1, 4, 1, 5, 9, 2, 6];
    xs.sort();
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(1), Some(1));
    assert_eq(xs.get(2), Some(2));
    assert_eq(xs.get(7), Some(9));
}

@test
fn test_list_sort_empty_is_noop() {
    let mut xs: List<Int> = List.new();
    xs.sort();
    assert_eq(xs.len(), 0);
}

@test
fn test_list_sort_singleton_is_noop() {
    let mut xs: List<Int> = [42];
    xs.sort();
    assert_eq(xs.get(0), Some(42));
}

@test
fn test_list_sort_already_sorted_is_idempotent() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.sort();
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(4), Some(5));
}

@test
fn test_list_sort_reverse_input() {
    let mut xs: List<Int> = [5, 4, 3, 2, 1];
    xs.sort();
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(4), Some(5));
}

// =============================================================================
// Section 8: clear preserves capacity
// =============================================================================

@test
fn test_list_clear_preserves_capacity() {
    let mut xs: List<Int> = List.with_capacity(64);
    xs.push(1);
    xs.push(2);
    let cap_before = xs.capacity();
    xs.clear();
    assert_eq(xs.len(), 0);
    assert_eq(xs.capacity(), cap_before);
}

// =============================================================================
// Section 9: get_or — default-return read
// =============================================================================

@test
fn test_list_get_or_in_bounds_returns_value() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.get_or(0, -1), 1);
    assert_eq(xs.get_or(2, -1), 3);
}

@test
fn test_list_get_or_out_of_bounds_returns_default() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.get_or(99, -1), -1);
    assert_eq(xs.get_or(-5, 42), 42);
}

// =============================================================================
// Section 10: retain / resize / rotate_left / dedup — methods that go
// through the stdlib body's `self.ptr.offset(idx)` direct-pointer access.
//
// Before the layout-alignment fix in the stdlib `type List<T> is { len,
// cap, ptr }` decl, every one of these SIGSEGV'd because `self.ptr`
// resolved to the runtime intercept's `len` slot and was dereferenced
// as a pointer. The reorder makes `self.ptr` resolve to slot 2 — the
// actual backing pointer — and the stdlib-body fast paths now run
// correctly.
// =============================================================================

@test
fn test_list_retain_drops_non_matching() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.retain(|x| *x % 2 == 0);
    assert_eq(xs.len(), 2);
    assert_eq(xs.get(0), Some(2));
    assert_eq(xs.get(1), Some(4));
}

@test
fn test_list_retain_all_matching_is_noop() {
    let mut xs: List<Int> = [2, 4, 6];
    xs.retain(|x| *x % 2 == 0);
    assert_eq(xs.len(), 3);
}

@test
fn test_list_retain_none_matching_drops_all() {
    let mut xs: List<Int> = [1, 3, 5];
    xs.retain(|x| *x % 2 == 0);
    assert_eq(xs.len(), 0);
}

@test
fn test_list_resize_grow_pads_with_value() {
    let mut xs: List<Int> = [1, 2];
    xs.resize(5, 0);
    assert_eq(xs.len(), 5);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(2), Some(0));
    assert_eq(xs.get(4), Some(0));
}

@test
fn test_list_resize_shrink_truncates() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.resize(2, 0);
    assert_eq(xs.len(), 2);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(1), Some(2));
}

@test
fn test_list_resize_same_len_is_noop() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.resize(3, 0);
    assert_eq(xs.len(), 3);
    assert_eq(xs.get(2), Some(3));
}

@test
fn test_list_rotate_left_basic() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.rotate_left(2);
    assert_eq(xs.get(0), Some(3));
    assert_eq(xs.get(4), Some(2));
}

@test
fn test_list_rotate_left_zero_is_noop() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.rotate_left(0);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(2), Some(3));
}

@test
fn test_list_dedup_consecutive_duplicates() {
    let mut xs: List<Int> = [1, 1, 2, 2, 2, 3, 1, 1];
    xs.dedup();
    // Dedup keeps the first of each consecutive run.
    assert_eq(xs.len(), 4);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(1), Some(2));
    assert_eq(xs.get(2), Some(3));
    assert_eq(xs.get(3), Some(1));
}

@test
fn test_list_dedup_no_duplicates_is_noop() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.dedup();
    assert_eq(xs.len(), 5);
}

@test
fn test_list_dedup_all_same_collapses_to_one() {
    let mut xs: List<Int> = [7, 7, 7, 7, 7];
    xs.dedup();
    assert_eq(xs.len(), 1);
    assert_eq(xs.get(0), Some(7));
}

// =============================================================================
// Section 11: position / index_of / rposition — value search
// =============================================================================

@test
fn test_list_position_returns_first_match() {
    let xs: List<Int> = [10, 20, 30, 20, 10];
    assert_eq(xs.position(&20), Some(1));
    assert_eq(xs.position(&10), Some(0));
    assert_eq(xs.position(&30), Some(2));
}

@test
fn test_list_position_missing_returns_none() {
    let xs: List<Int> = [10, 20, 30];
    assert_eq(xs.position(&99), None);
}

@test
fn test_list_position_in_empty_is_none() {
    let xs: List<Int> = [];
    assert_eq(xs.position(&1), None);
}

@test
fn test_list_index_of_returns_first_match() {
    let xs: List<Int> = [5, 10, 15, 10, 5];
    assert_eq(xs.index_of(&10), Some(1));
    assert_eq(xs.index_of(&5), Some(0));
    assert_eq(xs.index_of(&15), Some(2));
}

@test
fn test_list_index_of_missing_returns_none() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.index_of(&42), None);
}

@test
fn test_list_rposition_returns_last_match() {
    let xs: List<Int> = [10, 20, 30, 20, 10];
    assert_eq(xs.rposition(&20), Some(3));
    assert_eq(xs.rposition(&10), Some(4));
    assert_eq(xs.rposition(&30), Some(2));
}

@test
fn test_list_rposition_missing_returns_none() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.rposition(&7), None);
}

// =============================================================================
// Section 12: pop_front — O(n) front-end removal
// =============================================================================

@test
fn test_list_pop_front_returns_first_element() {
    let mut xs: List<Int> = [10, 20, 30];
    assert_eq(xs.pop_front(), Some(10));
    assert_eq(xs.len(), 2);
}

@test
fn test_list_pop_front_shifts_remaining_left() {
    let mut xs: List<Int> = [1, 2, 3, 4];
    xs.pop_front();
    assert_eq(xs.get(0), Some(2));
    assert_eq(xs.get(1), Some(3));
    assert_eq(xs.get(2), Some(4));
}

@test
fn test_list_pop_front_on_empty_returns_none() {
    let mut xs: List<Int> = [];
    assert_eq(xs.pop_front(), None);
    assert_eq(xs.len(), 0);
}

@test
fn test_list_pop_front_singleton_empties() {
    let mut xs: List<Int> = [42];
    assert_eq(xs.pop_front(), Some(42));
    assert(xs.is_empty());
}

// =============================================================================
// Section 13: extend / extend_from_slice / append — bulk insertion
// =============================================================================

@test
fn test_list_extend_from_slice_appends_in_order() {
    let mut xs: List<Int> = [1, 2];
    let src: List<Int> = [3, 4, 5];
    xs.extend_from_slice(src.as_slice());
    assert_eq(xs.len(), 5);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(2), Some(3));
    assert_eq(xs.get(4), Some(5));
}

@test
fn test_list_extend_from_empty_slice_is_noop() {
    let mut xs: List<Int> = [1, 2, 3];
    let src: List<Int> = [];
    xs.extend_from_slice(src.as_slice());
    assert_eq(xs.len(), 3);
}

@test
fn test_list_append_moves_other_to_self() {
    let mut xs: List<Int> = [1, 2];
    let mut ys: List<Int> = [3, 4, 5];
    xs.append(&mut ys);
    assert_eq(xs.len(), 5);
    assert_eq(xs.get(4), Some(5));
    // Per std contract, `other` is emptied after append.
    assert_eq(ys.len(), 0);
}

@test
fn test_list_append_empty_to_self_is_noop() {
    let mut xs: List<Int> = [1, 2, 3];
    let mut ys: List<Int> = [];
    xs.append(&mut ys);
    assert_eq(xs.len(), 3);
}

// =============================================================================
// Section 14: split_at / split_off — partitioning
// =============================================================================

@test
fn test_list_split_off_at_zero_moves_all() {
    let mut xs: List<Int> = [1, 2, 3];
    let tail = xs.split_off(0);
    assert_eq(xs.len(), 0);
    assert_eq(tail.len(), 3);
    assert_eq(tail.get(0), Some(1));
    assert_eq(tail.get(2), Some(3));
}

@test
fn test_list_split_off_at_len_returns_empty_tail() {
    let mut xs: List<Int> = [1, 2, 3];
    let tail = xs.split_off(3);
    assert_eq(xs.len(), 3);
    assert_eq(tail.len(), 0);
}

@test
fn test_list_split_off_middle_partitions() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    let tail = xs.split_off(2);
    assert_eq(xs.len(), 2);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(1), Some(2));
    assert_eq(tail.len(), 3);
    assert_eq(tail.get(0), Some(3));
    assert_eq(tail.get(2), Some(5));
}

// =============================================================================
// Section 15: rotate_right — symmetric to rotate_left
// =============================================================================

@test
fn test_list_rotate_right_basic() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.rotate_right(2);
    // Last 2 elements move to front: [4, 5, 1, 2, 3]
    assert_eq(xs.get(0), Some(4));
    assert_eq(xs.get(1), Some(5));
    assert_eq(xs.get(2), Some(1));
    assert_eq(xs.get(4), Some(3));
}

@test
fn test_list_rotate_right_zero_is_noop() {
    let mut xs: List<Int> = [1, 2, 3];
    xs.rotate_right(0);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(2), Some(3));
}

@test
fn test_list_rotate_right_then_left_is_identity() {
    let mut xs: List<Int> = [1, 2, 3, 4, 5];
    xs.rotate_right(2);
    xs.rotate_left(2);
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(4), Some(5));
}

// =============================================================================
// Section 16: any / all — boolean predicates
// =============================================================================

@test
fn test_list_any_returns_true_when_one_matches() {
    let xs: List<Int> = [1, 2, 3, 4];
    assert(xs.any(|x| *x == 3));
}

@test
fn test_list_any_returns_false_when_none_match() {
    let xs: List<Int> = [1, 2, 3];
    assert(!xs.any(|x| *x > 10));
}

@test
fn test_list_any_on_empty_is_false() {
    let xs: List<Int> = [];
    assert(!xs.any(|x| *x > 0));
}

@test
fn test_list_all_returns_true_when_all_match() {
    let xs: List<Int> = [2, 4, 6];
    assert(xs.all(|x| *x % 2 == 0));
}

@test
fn test_list_all_returns_false_when_one_violates() {
    let xs: List<Int> = [2, 4, 5];
    assert(!xs.all(|x| *x % 2 == 0));
}

@test
fn test_list_all_on_empty_is_true() {
    // Vacuous truth.
    let xs: List<Int> = [];
    assert(xs.all(|x| *x > 0));
}

// =============================================================================
// Section 17: starts_with / ends_with
//
// stdlib body migrated from `for i in range(...)` to `while +
// self.get(i)` pattern (commits this round); tests now active.
// =============================================================================

@test
fn test_list_starts_with_proper_prefix() {
    let xs: List<Int> = [1, 2, 3, 4, 5];
    let prefix: List<Int> = [1, 2];
    assert(xs.starts_with(&prefix));
}

@test
fn test_list_starts_with_empty_is_true() {
    let xs: List<Int> = [1, 2, 3];
    let empty: List<Int> = [];
    assert(xs.starts_with(&empty));
}

@test
fn test_list_starts_with_self_is_true() {
    let xs: List<Int> = [1, 2, 3];
    assert(xs.starts_with(&xs));
}

@test
fn test_list_starts_with_longer_than_self_is_false() {
    let xs: List<Int> = [1, 2];
    let longer: List<Int> = [1, 2, 3];
    assert(!xs.starts_with(&longer));
}

@test
fn test_list_ends_with_proper_suffix() {
    let xs: List<Int> = [1, 2, 3, 4, 5];
    let suffix: List<Int> = [4, 5];
    assert(xs.ends_with(&suffix));
}

@test
fn test_list_ends_with_empty_is_true() {
    let xs: List<Int> = [1, 2, 3];
    let empty: List<Int> = [];
    assert(xs.ends_with(&empty));
}

@test
fn test_list_ends_with_longer_than_self_is_false() {
    let xs: List<Int> = [4, 5];
    let longer: List<Int> = [1, 4, 5];
    assert(!xs.ends_with(&longer));
}

// =============================================================================
// Section 18: find_by / position_by — predicate-driven search
//
// position_by migrated to `while + self.get(i)`; tests now active.
// =============================================================================

@test
fn test_list_position_by_returns_first_index() {
    let xs: List<Int> = [1, 2, 3, 4];
    assert_eq(xs.position_by(|x| *x >= 3), Some(2));
}

@test
fn test_list_position_by_no_match_returns_none() {
    let xs: List<Int> = [1, 2, 3];
    assert_eq(xs.position_by(|x| *x > 100), None);
}

@test
fn test_list_position_by_on_empty_is_none() {
    let xs: List<Int> = [];
    assert_eq(xs.position_by(|x| *x > 0), None);
}

// =============================================================================
// Section 19: binary_search / partition_point — sorted-list queries
// =============================================================================

@test
fn test_list_binary_search_finds_element() {
    let xs: List<Int> = [1, 3, 5, 7, 9];
    let r: Result<Int, Int> = xs.binary_search(&5);
    assert(r.is_ok());
    assert_eq(r.unwrap_or(-1), 2);
}

@test
fn test_list_binary_search_finds_first_and_last() {
    let xs: List<Int> = [1, 3, 5, 7, 9];
    let r0: Result<Int, Int> = xs.binary_search(&1);
    let r1: Result<Int, Int> = xs.binary_search(&9);
    assert(r0.is_ok());
    assert(r1.is_ok());
    assert_eq(r0.unwrap_or(-1), 0);
    assert_eq(r1.unwrap_or(-1), 4);
}

@test
fn test_list_binary_search_missing_returns_insertion_point() {
    let xs: List<Int> = [1, 3, 5, 7, 9];
    // 4 would be inserted between 3 and 5 → idx 2
    let r4: Result<Int, Int> = xs.binary_search(&4);
    assert(r4.is_err());
    // 0 inserts at front
    let r0: Result<Int, Int> = xs.binary_search(&0);
    assert(r0.is_err());
    // 10 inserts at end
    let r10: Result<Int, Int> = xs.binary_search(&10);
    assert(r10.is_err());
}

@test
fn test_list_partition_point_returns_split_index() {
    let xs: List<Int> = [1, 2, 3, 4, 5, 6];
    // Stdlib semantics (`core/collections/list.vr`): assumes false-then-true
    // monotone partition; returns the index of the first true. For
    // pred=|x| *x >= 4 the partition is F,F,F,T,T,T → first true at idx 3.
    let i = xs.partition_point(|x| *x >= 4);
    assert_eq(i, 3);
}

@test
fn test_list_partition_point_all_true_returns_zero() {
    // All-true means first-true is index 0 (the very first element).
    let xs: List<Int> = [1, 2, 3];
    let i = xs.partition_point(|x| *x < 100);
    assert_eq(i, 0);
}

@test
fn test_list_partition_point_all_false_returns_len() {
    // All-false means no true element exists; returns len() (= 3).
    let xs: List<Int> = [1, 2, 3];
    let i = xs.partition_point(|x| *x < 0);
    assert_eq(i, 3);
}

// =============================================================================
// Section 20: dedup_by — generalised consecutive deduplication
//
// stdlib body migrated to `while + self.get(i) / self.set(write, v)`
// pattern (this round); tests now active.
// =============================================================================

@test
fn test_list_dedup_by_same_predicate_keeps_first() {
    let mut xs: List<Int> = [1, 11, 2, 22, 3];
    // Treat values as "same" if they share div-10.
    // dedup_by passes consecutive pairs — semantics depend on order;
    // conservative property: result is shorter or equal in length.
    xs.dedup_by(|a, b| (*a / 10) == (*b / 10));
    assert(xs.len() <= 5);
    assert(xs.len() >= 1);
}

@test
fn test_list_dedup_by_no_collapse_keeps_all() {
    let mut xs: List<Int> = [1, 2, 3, 4];
    xs.dedup_by(|a, b| *a == *b);
    assert_eq(xs.len(), 4);
}

// =============================================================================
// Section 21: capacity-management API — reserve / shrink_to_fit
//
// NOTE: reserve / reserve_exact / shrink_to_fit / shrink_to all route
// through `resize_buffer` which calls `realloc(self.ptr, ...)`. Because
// `self.ptr` in stdlib resolves to the backing heap object's start
// (including its ObjectHeader), the realloc operation triggers a
// runtime SIGABRT in the allocator. Same defect class as audit.md §E,
// but with a destructive write side-effect — pinned @ignore until the
// `self.ptr` resolution is corrected at codegen / runtime layer, or
// until reserve / shrink delegate to a runtime-intercepted operation.
// =============================================================================

@ignore
@test
fn test_list_reserve_grows_capacity() {
    let mut xs: List<Int> = List.new();
    xs.reserve(64);
    assert(xs.capacity() >= 64);
    assert_eq(xs.len(), 0);
}

@ignore
@test
fn test_list_reserve_zero_is_noop_when_fits() {
    let mut xs: List<Int> = List.with_capacity(16);
    let cap_before = xs.capacity();
    xs.reserve(0);
    assert_eq(xs.capacity(), cap_before);
}

@ignore
@test
fn test_list_reserve_exact_grows_capacity() {
    let mut xs: List<Int> = List.new();
    xs.reserve_exact(32);
    assert(xs.capacity() >= 32);
}

@ignore
@test
fn test_list_shrink_to_fit_reduces_capacity_to_len() {
    let mut xs: List<Int> = List.with_capacity(64);
    xs.push(1);
    xs.push(2);
    xs.push(3);
    xs.shrink_to_fit();
    // After shrink: capacity may still be implementation-defined
    // floor, but should be reduced.
    assert(xs.capacity() <= 64);
    assert_eq(xs.len(), 3);
    // Values preserved.
    assert_eq(xs.get(0), Some(1));
    assert_eq(xs.get(2), Some(3));
}

@ignore
@test
fn test_list_shrink_to_min_capacity() {
    let mut xs: List<Int> = List.with_capacity(64);
    xs.push(1);
    xs.shrink_to(16);
    assert(xs.capacity() <= 64);
    assert_eq(xs.get(0), Some(1));
}

// =============================================================================
// Section 22: as_slice / as_mut_slice — view conversion
// =============================================================================

@test
fn test_list_as_slice_returns_view_with_same_len() {
    let xs: List<Int> = [10, 20, 30];
    let s = xs.as_slice();
    assert_eq(s.len(), 3);
}

@test
fn test_list_as_slice_on_empty_is_empty_slice() {
    let xs: List<Int> = [];
    let s = xs.as_slice();
    assert_eq(s.len(), 0);
}

// =============================================================================
// Section 23: iter — basic iteration entry point
// =============================================================================

@test
fn test_list_iter_count_matches_len() {
    let xs: List<Int> = [10, 20, 30, 40];
    let mut count = 0;
    for _x in xs.iter() {
        count = count + 1;
    }
    assert_eq(count, 4);
}

@test
fn test_list_iter_on_empty_yields_zero() {
    let xs: List<Int> = [];
    let mut count = 0;
    for _x in xs.iter() {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_list_iter_sum_in_loop() {
    let xs: List<Int> = [1, 2, 3, 4, 5];
    let mut sum = 0;
    for x in xs.iter() {
        sum = sum + *x;
    }
    assert_eq(sum, 15);
}

// =============================================================================
// Section 24: try_push / try_with_capacity — fallible allocation surface
//
// NOTE: `List.try_with_capacity` is a static constructor — under the
// current cross-module name-table, bare-suffix dispatch routes the call
// to `AdjacencyList.add_vertex` (`NullPointerAt opcode 0x62 site=
// AdjacencyList.add_vertex pc:0`). Same defect class as the historical
// `List.from` / `List.of` / `List.from_elem` collision (task #28/#47);
// pinned @ignore until that closes or this constructor is folded into
// the dispatch-table intercept block. `try_push` is a method — works
// post-migration to push-delegate body (commit pending).
// =============================================================================

@ignore
@test
fn test_list_try_with_capacity_small_succeeds() {
    let r: Result<List<Int>, AllocError> = List.try_with_capacity(16);
    assert(r.is_ok());
}

@test
fn test_list_try_push_succeeds_under_normal_growth() {
    let mut xs: List<Int> = List.new();
    let r = xs.try_push(42);
    assert(r.is_ok());
    assert_eq(xs.len(), 1);
    assert_eq(xs.get(0), Some(42));
}

