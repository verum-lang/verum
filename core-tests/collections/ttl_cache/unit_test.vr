// =============================================================================
// core-tests/collections/ttl_cache/unit_test.vr
// =============================================================================
//
// Tests for `core.collections.ttl_cache` — `TtlCache<K, V>`, hybrid LRU +
// per-entry TTL cache.  Hot-path expiry is checked lazily on `get`; idle
// reclamation goes through `purge_expired`.
//
// Architectural caveat: every insert path routes through
// `Instant.checked_add(Duration)`.  Until 2026-05-16T16:42 the stdlib
// source called the non-existent `Instant.add_duration(Duration)`;
// the source fix landed in this branch but the precompiled stdlib
// embedded in the `verum` binary still carries the old CallM operand
// until a fresh `cargo build --release`.  See regression_test.vr §A
// for pinned coverage; this file holds only the time-independent
// surface that doesn't traverse the insert path.
// =============================================================================

mount core.prelude.*;
mount core.collections.ttl_cache.{TtlCache, TtlCacheConfig};
mount core.time.duration.{Duration};

// =============================================================================
// Section 1: Construction — pre-insert state
// =============================================================================

@test
fn test_ttl_new_with_config_is_empty() {
    let cfg = TtlCacheConfig {
        capacity: 8,
        default_ttl: Duration.from_secs(3600),
    };
    let c: TtlCache<Int, Int> = TtlCache.new(cfg);
    assert(c.is_empty());
    assert_eq(c.len(), 0);
}

@test
fn test_ttl_with_defaults_is_empty() {
    let c: TtlCache<Int, Int> = TtlCache.with_defaults();
    assert(c.is_empty());
    assert_eq(c.len(), 0);
}

// =============================================================================
// Section 2: get / remove on empty cache
// =============================================================================

@test
fn test_ttl_get_absent_returns_none() {
    let mut c: TtlCache<Int, Int> = TtlCache.with_defaults();
    let v: Maybe<&Int> = c.get(&999);
    assert(v is None);
}

@test
fn test_ttl_remove_absent_returns_false() {
    let mut c: TtlCache<Int, Int> = TtlCache.with_defaults();
    let r = c.remove(&999);
    assert(!r);
}

// =============================================================================
// Section 3: stats on empty cache
// =============================================================================

@test
fn test_ttl_stats_misses_on_get_miss() {
    let mut c: TtlCache<Int, Int> = TtlCache.with_defaults();
    let _ = c.get(&1);
    let _ = c.get(&2);
    let s = c.stats();
    assert_eq(s.misses, 2_u64);
}

@test
fn test_ttl_stats_zero_initial() {
    let c: TtlCache<Int, Int> = TtlCache.with_defaults();
    let s = c.stats();
    assert_eq(s.size, 0);
    assert_eq(s.hits, 0_u64);
    assert_eq(s.misses, 0_u64);
    assert_eq(s.evicted, 0_u64);
    assert_eq(s.expired, 0_u64);
}

// =============================================================================
// Section 4: purge_expired on empty
// =============================================================================

@test
fn test_ttl_purge_on_empty_returns_zero() {
    let mut c: TtlCache<Int, Int> = TtlCache.with_defaults();
    let r = c.purge_expired();
    assert_eq(r, 0);
}
