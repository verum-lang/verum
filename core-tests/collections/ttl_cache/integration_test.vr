// =============================================================================
// core-tests/collections/ttl_cache/integration_test.vr
// =============================================================================
//
// Cross-type scenarios — TtlCache composed with Duration without
// traversing the insert path (which awaits the precompiled-stdlib
// rebuild — see regression_test.vr §A).
// =============================================================================

mount core.prelude.*;
mount core.collections.ttl_cache.{TtlCache, TtlCacheConfig};
mount core.time.duration.{Duration};

// =============================================================================
// Integration: TtlCacheConfig + Duration interop
// =============================================================================

@test
fn int_ttl_config_duration_from_secs() {
    let cfg = TtlCacheConfig {
        capacity: 100,
        default_ttl: Duration.from_secs(60),
    };
    assert_eq(cfg.capacity, 100);
}

@test
fn int_ttl_config_duration_from_millis() {
    let cfg = TtlCacheConfig {
        capacity: 50,
        default_ttl: Duration.from_millis(500),
    };
    assert_eq(cfg.capacity, 50);
}

// =============================================================================
// Integration: with_defaults round-trip + read-only operations
// =============================================================================

@test
fn int_ttl_defaults_read_only_round_trip() {
    let mut c: TtlCache<Int, Int> = TtlCache.with_defaults();

    // Read-only ops on an empty cache must be no-ops.
    let v: Maybe<&Int> = c.get(&1);
    assert(v is None);

    let r = c.remove(&1);
    assert(!r);

    let p = c.purge_expired();
    assert_eq(p, 0);

    assert(c.is_empty());
    assert_eq(c.len(), 0);
}

// =============================================================================
// Integration: multiple cache instances independent
// =============================================================================

@test
fn int_ttl_independent_instances() {
    let cfg_a = TtlCacheConfig { capacity: 4, default_ttl: Duration.from_secs(60) };
    let cfg_b = TtlCacheConfig { capacity: 8, default_ttl: Duration.from_secs(120) };
    let mut a: TtlCache<Int, Int> = TtlCache.new(cfg_a);
    let mut b: TtlCache<Int, Int> = TtlCache.new(cfg_b);

    // Operations on one must not leak into the other.
    let _ = a.get(&1);
    let _ = a.get(&2);
    let sa = a.stats();
    let sb = b.stats();
    assert_eq(sa.misses, 2_u64);
    assert_eq(sb.misses, 0_u64);
}
