// =============================================================================
// core-tests/collections/trie/regression_test.vr
// =============================================================================

mount core.prelude.*;
mount core.collections.trie.{Trie};

// =============================================================================
// §A — Trie populated-state surface gated on Map.get_mut dispatch
//
// `Trie.remove` calls `Map.get_mut(...)` which raises
//   "method 'Map.get_mut' not found on receiver of runtime kind `Map`"
// — same dispatch class as the multiset §B / slice §D wrapper-iter
// defect.  Cascades into `Trie.insert`'s mutator path.
// =============================================================================

@ignore
@test
fn regression_trie_insert_get_round_trip() {
    let mut t: Trie<Int> = Trie.new();
    let k: [Byte; 3] = [1, 2, 3];
    let _ = t.insert(&k, 100);
    assert_eq(t.get(&k), Some(100));
}

@ignore
@test
fn regression_trie_remove_present_returns_value() {
    let mut t: Trie<Int> = Trie.new();
    let k: [Byte; 3] = [1, 2, 3];
    let _ = t.insert(&k, 100);
    let r = t.remove(&k);
    assert_eq(r, Some(100));
}

// CLOSED 2026-05-26 (Map.get_mut added in commit 997f53352)
@test
fn regression_trie_remove_absent_returns_none_via_map_get_mut() {
    let mut t: Trie<Int> = Trie.new();
    let k: [Byte; 3] = [1, 2, 3];
    let r: Maybe<Int> = t.remove(&k);
    assert(r is None);
}

// =============================================================================
// §F — PASS-GUARD pins for the empty-state surface
// =============================================================================

@test
fn pass_guard_trie_new_is_empty() {
    let t: Trie<Int> = Trie.new();
    assert(t.is_empty());
    assert_eq(t.len(), 0);
}

@test
fn pass_guard_trie_empty_get_returns_none() {
    let t: Trie<Int> = Trie.new();
    let k: [Byte; 1] = [42];
    let v: Maybe<Int> = t.get(&k);
    assert(v is None);
}

@test
fn pass_guard_trie_empty_contains_returns_false() {
    let t: Trie<Int> = Trie.new();
    let k: [Byte; 1] = [42];
    assert(!t.contains(&k));
}
