// =============================================================================
// core-tests/collections/multiset/unit_test.vr
// =============================================================================
//
// Tests for `core.collections.multiset` — Multiset<T: Hash + Eq>, the
// canonical "hash bag" with strictly-positive multiplicities backed by
// `Map<T, Int>`.  One axis of behaviour per `@test`.
//
// Construction: every test goes through `Multiset.new()` (canonical) or
// `Multiset.with_capacity(n)`.  `Multiset.from([...])` and
// `Multiset.from_counts([...])` exercise the array-literal coercion
// paths and are tested behind the cross-module function-id resolution
// gate; failures are pinned in `regression_test.vr` §A.
// =============================================================================

mount core.prelude.*;
mount core.collections.multiset.Multiset;

// =============================================================================
// Section 1: Construction
// =============================================================================

@test
fn test_multiset_new_is_empty() {
    let m: Multiset<Int> = Multiset.new();
    assert(m.is_empty());
    assert_eq(m.distinct_len(), 0);
    assert_eq(m.cardinality(), 0);
}

@test
fn test_multiset_with_capacity_is_empty() {
    let m: Multiset<Int> = Multiset.with_capacity(16);
    assert(m.is_empty());
    assert_eq(m.distinct_len(), 0);
    assert_eq(m.cardinality(), 0);
}

// =============================================================================
// Section 2: insert / count / contains
// =============================================================================

@test
fn test_multiset_insert_single_returns_one() {
    let mut m: Multiset<Int> = Multiset.new();
    let n = m.insert(42);
    assert_eq(n, 1);
    assert_eq(m.count(&42), 1);
    assert(m.contains(&42));
}

@test
fn test_multiset_insert_duplicate_increments() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert(42);
    let n = m.insert(42);
    assert_eq(n, 2);
    assert_eq(m.count(&42), 2);
}

@test
fn test_multiset_insert_distinct_len_one_after_duplicates() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert(42);
    m.insert(42);
    m.insert(42);
    assert_eq(m.distinct_len(), 1);
    assert_eq(m.cardinality(), 3);
}

@test
fn test_multiset_insert_n_positive() {
    let mut m: Multiset<Int> = Multiset.new();
    let r = m.insert_n(7, 5);
    assert_eq(r, 5);
    assert_eq(m.count(&7), 5);
    assert_eq(m.cardinality(), 5);
}

@test
fn test_multiset_insert_n_zero_is_noop() {
    let mut m: Multiset<Int> = Multiset.new();
    let r = m.insert_n(7, 0);
    assert_eq(r, 0);
    assert_eq(m.count(&7), 0);
    assert(m.is_empty());
}

@test
fn test_multiset_insert_n_negative_is_noop() {
    let mut m: Multiset<Int> = Multiset.new();
    let r = m.insert_n(7, -3);
    assert_eq(r, 0);
    assert(m.is_empty());
}

@test
fn test_multiset_count_absent_returns_zero() {
    let m: Multiset<Int> = Multiset.new();
    assert_eq(m.count(&99), 0);
}

@test
fn test_multiset_contains_absent_returns_false() {
    let m: Multiset<Int> = Multiset.new();
    assert(!m.contains(&99));
}

// =============================================================================
// Section 3: remove / remove_n / remove_all
// =============================================================================

@test
fn test_multiset_remove_decrements() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert_n(7, 3);
    let r = m.remove(&7);
    assert_eq(r, 2);
    assert_eq(m.count(&7), 2);
}

@test
fn test_multiset_remove_evicts_when_count_hits_zero() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert(7);
    let r = m.remove(&7);
    assert_eq(r, 0);
    assert(!m.contains(&7));
    assert_eq(m.distinct_len(), 0);
}

@test
fn test_multiset_remove_absent_returns_zero() {
    let mut m: Multiset<Int> = Multiset.new();
    let r = m.remove(&99);
    assert_eq(r, 0);
}

@test
fn test_multiset_remove_n_saturates_at_zero() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert_n(7, 3);
    let r = m.remove_n(&7, 99);
    assert_eq(r, 0);
    assert(!m.contains(&7));
}

@test
fn test_multiset_remove_all_returns_evicted_count() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert_n(7, 5);
    let r = m.remove_all(&7);
    assert_eq(r, 5);
    assert(!m.contains(&7));
    assert_eq(m.cardinality(), 0);
}

@test
fn test_multiset_remove_all_absent_returns_zero() {
    let mut m: Multiset<Int> = Multiset.new();
    let r = m.remove_all(&99);
    assert_eq(r, 0);
}

// =============================================================================
// Section 4: clear
// =============================================================================

@test
fn test_multiset_clear_zeroes_all_counters() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert_n(1, 3);
    m.insert_n(2, 4);
    m.clear();
    assert(m.is_empty());
    assert_eq(m.distinct_len(), 0);
    assert_eq(m.cardinality(), 0);
    assert_eq(m.count(&1), 0);
}

// =============================================================================
// Section 5: cardinality bookkeeping
// =============================================================================

@test
fn test_multiset_cardinality_tracks_insertions() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert(1);
    m.insert(2);
    m.insert(2);
    m.insert(3);
    m.insert(3);
    m.insert(3);
    assert_eq(m.cardinality(), 6);
    assert_eq(m.distinct_len(), 3);
}

@test
fn test_multiset_cardinality_tracks_removals() {
    let mut m: Multiset<Int> = Multiset.new();
    m.insert_n(1, 5);
    m.insert_n(2, 3);
    assert_eq(m.cardinality(), 8);
    m.remove(&1);
    m.remove(&2);
    assert_eq(m.cardinality(), 6);
}

// =============================================================================
// Section 6: union / intersection / sum / difference — with-empty
//
// Per-element-correct algebraic ops are gated on `Multiset.iter()`
// reaching the loop body — see regression_test.vr §B. With an empty
// other-multiset, the iter loop is a no-op, so these reduce to
// `self.clone()` / `Multiset.new()` and exercise the surface
// reachable today.
// =============================================================================

@test
fn test_multiset_union_with_empty_is_self() {
    let mut a: Multiset<Int> = Multiset.new();
    a.insert_n(1, 3);
    let empty: Multiset<Int> = Multiset.new();
    let u: Multiset<Int> = a.union(&empty);
    assert_eq(u.count(&1), 3);
    assert_eq(u.cardinality(), 3);
}

@test
fn test_multiset_intersection_with_empty_is_empty() {
    let mut a: Multiset<Int> = Multiset.new();
    a.insert_n(1, 3);
    let empty: Multiset<Int> = Multiset.new();
    let i: Multiset<Int> = a.intersection(&empty);
    assert(i.is_empty());
}

// =============================================================================
// Section 7: is_subset / is_superset — early-exit + empty cases
// =============================================================================

@test
fn test_multiset_is_subset_false_on_overcount() {
    let mut a: Multiset<Int> = Multiset.new();
    a.insert_n(1, 4);

    let mut b: Multiset<Int> = Multiset.new();
    b.insert_n(1, 2);

    assert(!a.is_subset(&b));
}

@test
fn test_multiset_empty_is_subset_of_anything() {
    let empty: Multiset<Int> = Multiset.new();
    let mut a: Multiset<Int> = Multiset.new();
    a.insert(1);
    assert(empty.is_subset(&a));
    assert(empty.is_subset(&empty));
}
