// =============================================================================
// core-tests/collections/btree/regression_test.vr
// =============================================================================

mount core.prelude.*;
mount core.collections.btree.{BTreeMap};

// =============================================================================
// §A — BTreeMap multi-insert + populated-state field-access defect
//
// Triage 2026-05-17: `BTreeMap.new() + single insert + len/get-absent`
// now works (verified in triage_test.vr).  But ANY operation that
// traverses a populated tree past one entry — second insert
// (replace_value_in_node path), get on an existing key
// (search_node), contains_key, remove, clear, len after 3 inserts,
// pop_first/last, first_key_value, last_key_value, get_or_default —
// panics at runtime with:
//   "field access out of bounds: field index 0 (offset 0+8 = 8)
//    exceeds object data size 0"
//
// Hypothesis: the failure is in `Maybe.as_mut()` / `Maybe.as_ref()`
// on a `Some(Heap<BTreeNode<K,V>>)` payload, OR in the BTreeNode
// generic-K-V substitution during tree traversal.  The 0-data
// object is likely the Heap<BTreeNode> auto-deref reading from a
// receiver whose monomorphised TypeDescriptor has 0 fields (generic
// param substitution failed).
//
// Architectural fix path: investigate `extract_expr_type_name`'s
// MethodCall arm for `self.root.as_mut()` to verify the return type
// gets correctly substituted with concrete K=Int, V=Int.
// =============================================================================

@ignore
@test
fn regression_btreemap_insert_returns_prior_on_replacement() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    let prev = m.insert(1, 200);
    assert_eq(prev, Some(100));
}

@ignore
@test
fn regression_btreemap_get_present_returns_some() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    assert_eq(m.get(&1), Some(100));
}

@ignore
@test
fn regression_btreemap_contains_key_present_returns_true() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    assert(m.contains_key(&1));
}

@ignore
@test
fn regression_btreemap_remove_present_returns_value() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    let r = m.remove(&1);
    assert_eq(r, Some(100));
}

@ignore
@test
fn regression_btreemap_clear_after_population() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    m.insert(2, 200);
    m.clear();
    assert(m.is_empty());
}

@ignore
@test
fn regression_btreemap_first_key_value_returns_min() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(5, 50);
    m.insert(1, 10);
    m.insert(3, 30);
    match m.first_key_value() {
        Some((k, _)) => { assert_eq(*k, 1); },
        None         => { panic("first_key_value None"); },
    }
}

@ignore
@test
fn regression_btreemap_last_key_value_returns_max() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(5, 50);
    m.insert(1, 10);
    match m.last_key_value() {
        Some((k, _)) => { assert_eq(*k, 5); },
        None         => { panic("last_key_value None"); },
    }
}

@ignore
@test
fn regression_btreemap_pop_first_yields_min() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(5, 50);
    m.insert(1, 10);
    match m.pop_first() {
        Some((k, v)) => {
            assert_eq(k, 1);
            assert_eq(v, 10);
        },
        None => { panic("pop_first None"); },
    }
}

@ignore
@test
fn regression_btreemap_pop_last_yields_max() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(5, 50);
    m.insert(1, 10);
    match m.pop_last() {
        Some((k, v)) => {
            assert_eq(k, 5);
            assert_eq(v, 50);
        },
        None => { panic("pop_last None"); },
    }
}

@ignore
@test
fn regression_btreemap_len_tracks_insertions() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    m.insert(2, 200);
    m.insert(3, 300);
    assert_eq(m.len(), 3);
}

@ignore
@test
fn regression_btreemap_get_or_default_present() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    let v = m.get_or_default(&1, -1);
    assert_eq(v, 100);
}

// =============================================================================
// §B — Empty-state pop_first_on_empty / first_last_none_on_empty
// CLOSED 2026-05-18 via BTreeMap.root refactor from
// `Maybe<Heap<BTreeNode<K,V>>>` to direct `Heap<BTreeNode<K,V>>` with
// a sentinel empty leaf — bypasses the variant-payload-extract defect
// in the codegen.  Active PASS-GUARDs against re-regression.
// =============================================================================

@test
fn regression_btreemap_pop_first_on_empty_returns_none() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    let r: Maybe<(Int, Int)> = m.pop_first();
    assert(r is None);
}

@test
fn regression_btreemap_first_last_none_on_empty() {
    let m: BTreeMap<Int, Int> = BTreeMap.new();
    let f: Maybe<(&Int, &Int)> = m.first_key_value();
    let l: Maybe<(&Int, &Int)> = m.last_key_value();
    assert(f is None);
    assert(l is None);
}

// =============================================================================
// §F — PASS-GUARD pins for the working empty-state surface
//
// Plus the recently-verified `BTreeMap.new() + single insert + len`
// chain (validated 2026-05-17 in triage_test.vr; promoted here as a
// PASS-GUARD against re-regression).
// =============================================================================

@test
fn pass_guard_btreemap_new_is_empty() {
    let m: BTreeMap<Int, Int> = BTreeMap.new();
    assert(m.is_empty());
    assert_eq(m.len(), 0);
}

@test
fn pass_guard_btreemap_get_absent_returns_none() {
    let m: BTreeMap<Int, Int> = BTreeMap.new();
    let v: Maybe<Int> = m.get(&1);
    assert(v is None);
}

@test
fn pass_guard_btreemap_contains_key_absent_returns_false() {
    let m: BTreeMap<Int, Int> = BTreeMap.new();
    assert(!m.contains_key(&1));
}

@test
fn pass_guard_btreemap_remove_absent_returns_none() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    let r: Maybe<Int> = m.remove(&1);
    assert(r is None);
}

@test
fn pass_guard_btreemap_single_insert_then_len() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    assert_eq(m.len(), 1);
}
