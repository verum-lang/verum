// =============================================================================
// core-tests/collections/deque/property_test.vr
// =============================================================================
//
// Algebraic + structural laws for `core.collections.deque`. Domain choice
// follows the conformance suite convention: bounded representative-sample
// sweeps since the input space is too large to exhaust.
// =============================================================================

mount core.prelude.*;
mount core.collections.deque.Deque;

// =============================================================================
// §1  push_back / pop_front round-trip: FIFO discipline
// =============================================================================

@test
fn property_push_back_pop_front_is_fifo() {
    let mut d: Deque<Int> = Deque.new();
    let mut i = 1;
    while i <= 10 {
        d.push_back(i);
        i = i + 1;
    }
    let mut expected = 1;
    while expected <= 10 {
        assert_eq(d.pop_front(), Some(expected));
        expected = expected + 1;
    }
    assert_eq(d.pop_front(), None);
}

// =============================================================================
// §2  push_back / pop_back round-trip: LIFO discipline (stack mode)
// =============================================================================

@test
fn property_push_back_pop_back_is_lifo() {
    let mut d: Deque<Int> = Deque.new();
    let mut i = 1;
    while i <= 10 {
        d.push_back(i);
        i = i + 1;
    }
    let mut expected = 10;
    while expected >= 1 {
        assert_eq(d.pop_back(), Some(expected));
        expected = expected - 1;
    }
    assert_eq(d.pop_back(), None);
}

// =============================================================================
// §3  push_front / pop_front round-trip: LIFO discipline (stack from front)
// =============================================================================

@test
fn property_push_front_pop_front_is_lifo() {
    let mut d: Deque<Int> = Deque.new();
    let mut i = 1;
    while i <= 10 {
        d.push_front(i);
        i = i + 1;
    }
    let mut expected = 10;
    while expected >= 1 {
        assert_eq(d.pop_front(), Some(expected));
        expected = expected - 1;
    }
    assert_eq(d.pop_front(), None);
}

// =============================================================================
// §4  push_front / pop_back round-trip: FIFO discipline (front-fed queue)
// =============================================================================

@test
fn property_push_front_pop_back_is_fifo() {
    let mut d: Deque<Int> = Deque.new();
    let mut i = 1;
    while i <= 10 {
        d.push_front(i);
        i = i + 1;
    }
    // Pushed 1, 2, ..., 10 to front: logical sequence is [10, 9, ..., 1].
    // pop_back yields the original first-pushed = 1, then 2, then 3, ...
    let mut expected = 1;
    while expected <= 10 {
        assert_eq(d.pop_back(), Some(expected));
        expected = expected + 1;
    }
}

// =============================================================================
// §5  len monotone-decreasing on pop_*, lower-bounded by zero
// =============================================================================

@test
fn property_pop_front_decreases_len_or_returns_none() {
    let mut d: Deque<Int> = Deque.new();
    let mut i = 0;
    while i < 8 {
        d.push_back(i);
        i = i + 1;
    }
    let mut prev_len = d.len();
    while !d.is_empty() {
        let _ = d.pop_front();
        assert(d.len() < prev_len);
        prev_len = d.len();
    }
    assert_eq(d.len(), 0);
    assert_eq(d.pop_front(), None);
    assert_eq(d.pop_front(), None);
}

@test
fn property_pop_back_decreases_len_or_returns_none() {
    let mut d: Deque<Int> = Deque.new();
    let mut i = 0;
    while i < 8 {
        d.push_back(i);
        i = i + 1;
    }
    let mut prev_len = d.len();
    while !d.is_empty() {
        let _ = d.pop_back();
        assert(d.len() < prev_len);
        prev_len = d.len();
    }
    assert_eq(d.len(), 0);
}

// =============================================================================
// §6  front and back of a 1-element deque coincide
// =============================================================================

@test
fn property_front_eq_back_when_len_one() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(42);
    assert_eq(d.front(), Some(42));
    assert_eq(d.back(), Some(42));
    assert_eq(d.front(), d.back());
}

// =============================================================================
// §7  Capacity is non-decreasing across push sequences
// =============================================================================

@test
fn property_capacity_monotone_non_decreasing_under_push_back() {
    let mut d: Deque<Int> = Deque.new();
    let mut prev_cap = d.capacity();
    let mut i = 0;
    while i < 20 {
        d.push_back(i);
        assert(d.capacity() >= prev_cap);
        prev_cap = d.capacity();
        i = i + 1;
    }
}

// =============================================================================
// §8  clear is idempotent
// =============================================================================

@test
fn property_clear_is_idempotent() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.clear();
    let len_first = d.len();
    d.clear();
    let len_second = d.len();
    assert_eq(len_first, 0);
    assert_eq(len_second, 0);
}

fn main() {}
