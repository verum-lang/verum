// =============================================================================
// core-tests/time/julian/property_test.vr
// =============================================================================
//
// Algebraic laws for Julian Day conversions.
// =============================================================================

mount core.prelude.*;
mount core.time.julian.{
    JD_UNIX_EPOCH, JD_MJD_EPOCH,
    julian_from_unix_ms, unix_ms_from_julian,
    julian_from_unix_secs, unix_secs_from_julian,
    julian_from_ymd, ymd_from_julian,
    time_fraction_from_hms, hms_from_julian,
    julian_from_gregorian, gregorian_from_julian,
    mjd_from_julian, julian_from_mjd,
};
mount core.collections.list.List;

// =============================================================================
// §A  unix_ms round-trip: unix_ms_from_julian ∘ julian_from_unix_ms ≈ id
// =============================================================================

@test
fn law_unix_ms_round_trip() {
    let cases: List<Int64> = [0, 86400000, 1_000_000_000_000, 1_700_000_000_000];
    for &ms in cases.iter() {
        let jd = julian_from_unix_ms(ms);
        let recovered = unix_ms_from_julian(jd);
        assert((recovered - ms).abs() <= 1,
            f"round-trip failed for ms={ms}: got {recovered}");
    }
}

// =============================================================================
// §B  unix_secs round-trip: unix_secs_from_julian ∘ julian_from_unix_secs ≈ id
// =============================================================================

@test
fn law_unix_secs_round_trip() {
    let cases: List<Int64> = [0, 86400, 1_000_000_000, 1_700_000_000];
    for &s in cases.iter() {
        let jd = julian_from_unix_secs(s);
        let recovered = unix_secs_from_julian(jd);
        assert((recovered - s).abs() <= 1);
    }
}

// =============================================================================
// §C  ymd_from_julian ∘ julian_from_ymd = id
// =============================================================================

@test
fn law_ymd_round_trip() {
    let cases: List<(Int, Int, Int)> = [
        (1970, 1, 1),
        (2000, 1, 1),
        (2000, 2, 29), // leap year
        (2026, 5, 9),
        (2100, 12, 31),
    ];
    for &(y, m, d) in cases.iter() {
        let jd = julian_from_ymd(y, m, d);
        let (y2, m2, d2) = ymd_from_julian(jd);
        assert_eq(y2, y, f"year mismatch for {y}-{m}-{d}");
        assert_eq(m2, m, f"month mismatch for {y}-{m}-{d}");
        assert_eq(d2, d, f"day mismatch for {y}-{m}-{d}");
    }
}

// =============================================================================
// §D  gregorian round-trip
// =============================================================================

@test
fn law_gregorian_round_trip() {
    let cases: List<(Int, Int, Int, Int, Int, Int)> = [
        (2000, 1, 1, 0, 0, 0),
        (2026, 6, 15, 12, 30, 0),
        (1970, 1, 1, 0, 0, 0),
    ];
    for &(y, mo, d, h, mi, s) in cases.iter() {
        let jd = julian_from_gregorian(y, mo, d, h, mi, s, 0);
        let (y2, mo2, d2, h2, mi2, s2, _) = gregorian_from_julian(jd);
        assert_eq(y2, y);
        assert_eq(mo2, mo);
        assert_eq(d2, d);
        assert_eq(h2, h);
        assert_eq(mi2, mi);
        assert_eq(s2, s);
    }
}

// =============================================================================
// §E  mjd_from_julian ∘ julian_from_mjd = id
// =============================================================================

@test
fn law_mjd_round_trip() {
    let jd_values: List<Float64> = [
        JD_UNIX_EPOCH, 2451545.0, 2400000.5, 2440000.0,
    ];
    let eps: Float64 = 1e-9;
    for &jd in jd_values.iter() {
        let mjd = mjd_from_julian(jd);
        let recovered = julian_from_mjd(mjd);
        assert((recovered - jd).abs() < eps);
    }
}

// =============================================================================
// §F  Consecutive days: julian_from_ymd(y,m,d+1) - julian_from_ymd(y,m,d) = 1
// =============================================================================

@test
fn law_consecutive_days_differ_by_one() {
    let cases: List<(Int, Int, Int)> = [
        (2000, 1, 1), (2026, 2, 28), (2000, 2, 28), // day before or after Feb 29
    ];
    let eps: Float64 = 1e-9;
    for &(y, m, d) in cases.iter() {
        let jd1 = julian_from_ymd(y, m, d);
        let jd2 = julian_from_ymd(y, m, d + 1);
        assert((jd2 - jd1 - 1.0).abs() < eps);
    }
}

// =============================================================================
// §G  @test_case — known Julian Day numbers
// =============================================================================

@test_case(1970, 1, 1,    2440587.5)
@test_case(2000, 1, 1,    2451544.5)
@test_case(1858, 11, 17,  2400000.5) // MJD epoch
fn parametrised_known_jd(year: Int, month: Int, day: Int, expected_jd: Float64) {
    let jd = julian_from_ymd(year, month, day);
    let eps: Float64 = 1e-9;
    assert((jd - expected_jd).abs() < eps,
        f"julian_from_ymd({year},{month},{day}) = {jd}, expected {expected_jd}");
}

fn main() {}
