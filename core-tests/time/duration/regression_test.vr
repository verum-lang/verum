// =============================================================================
// core-tests/time/duration/regression_test.vr
// =============================================================================
//
// Regression pins for surfaced defects in `core.time.duration`.
//
// Every regression name here links to an entry in `audit.md`.
// =============================================================================

mount core.prelude.*;
mount core.time.duration.{Duration};

// =============================================================================
// §A  CONSTRUCTOR-CLAMPING INCONSISTENCY — CLOSED 2026-05-27 via Option B
// =============================================================================
//
// PRE-CLOSE STATE (round 13 surface): `Duration.nanos(n)` ran the Verum body
// `Duration { nanos: n.max(0) }` (clamped negatives to zero) while
// `Duration.from_nanos(n)` was intercepted by the runtime intrinsic
// `time_duration_from_nanos` (pure identity — preserved negative).  Same
// split existed for (micros / from_micros), (millis / from_millis),
// (secs / from_secs).
//
// CLOSED via Option B (signed Duration refactor) — drop `.max(0)` from
// every Verum-body constructor + Sub/Mul operator impls + from_secs_f64
// early-return.  Duration is now signed (matches `Go time.Duration` /
// `Java Duration` / `C++ chrono::duration` semantics; aligns with the
// runtime intrinsic identity surface; preserves the duration_parse
// "-15m" negative-input contract).  See [duration/audit.md §A].
//
// These pins now LOCK the POST-CLOSE behaviour: short-form and long-form
// constructors AGREE on signed semantics.  Resurrected divergence would
// re-open §A.

@test
fn regression_a_nanos_short_form_preserves_via_signed_body() {
    // Post-fix: short-form constructor IS now signed (matches intrinsic).
    assert_eq(Duration.nanos(-1).as_nanos(), -1,
        "Duration.nanos(-1) preserves sign post Option B");
}

@test
fn regression_a_from_nanos_long_form_preserves_via_intrinsic() {
    // Long-form constructor remains intrinsic-identity (unchanged).
    assert_eq(Duration.from_nanos(-1).as_nanos(), -1,
        "Duration.from_nanos(-1) preserves via intrinsic identity");
}

@test
fn regression_a_constructor_surface_consistent() {
    // The two surfaces produce IDENTICAL Duration values for the
    // SAME input — §A is closed.
    assert_eq(Duration.nanos(-1), Duration.from_nanos(-1),
        "constructor surface is consistent — §A closed via Option B");
    assert_eq(Duration.millis(-100), Duration.from_millis(-100));
    assert_eq(Duration.secs(-5), Duration.from_secs(-5));
}

@test
fn regression_a_from_secs_large_negative_preserves() {
    // Confirms large-negative arithmetic round-trips correctly.
    let d = Duration.from_secs(-15 * 60);
    assert_eq(d.as_nanos(), -900_000_000_000,
        "Duration.from_secs preserves large negative");
}

@test
fn regression_a_short_form_secs_large_negative_preserves() {
    // Post-fix: short-form preserves negatives the same way long-form does.
    let d = Duration.secs(-15 * 60);
    assert_eq(d.as_nanos(), -900_000_000_000,
        "Duration.secs preserves large negative post Option B");
}

// =============================================================================
// §B  duration_parse NEGATIVE-INPUT contract — preserved under §A close
// =============================================================================
//
// The parser's negative-input contract (`parse("-15m")` → negative
// Duration) continues to hold after §A close because Option B
// preserves the intrinsic-identity surface that the parser depends on.

@test
fn regression_b_parse_negative_carries_through_signed_constructor() {
    let r = core.time.duration_parse.parse(&"-15m".to_text());
    assert(r.is_ok(), "parse('-15m') accepts negative");
    let d = r.unwrap();
    assert(d.as_nanos() < 0,
        "negative parse preserves sign via signed Duration.from_nanos");
    assert_eq(d.as_secs(), -900,  // -15 * 60 seconds
        "negative parse magnitude exact");
}

// =============================================================================
// §C  Signed-arithmetic operators (Sub / Mul) — Option B post-close pins
// =============================================================================
//
// Pre-fix: `Duration - Duration` had `.max(0)` clamp; `Duration * Int`
// clamped `rhs.max(0)`.  Post-fix: both are signed.

@test
fn regression_c_sub_operator_returns_signed_result() {
    // Read raw `nanos` field rather than `.as_secs()` accessor — the
    // accessor is intercepted by `time_duration_as_secs` intrinsic
    // which expects an unboxed-Int receiver under the tier-0
    // single-field-record optimisation; Durations returned from a
    // user-defined Sub.sub body stay heap-boxed, breaking the intrinsic
    // dispatch in the unboxing-inconsistency surface (tracked
    // separately at `time/duration §F`).  Reading `.nanos` directly
    // exercises the layered field-access path which IS consistent
    // post-§D operator-dispatch fix.
    let diff = Duration.secs(1) - Duration.secs(3);
    let n: Int = diff.nanos;
    assert_eq(n, -2_000_000_000,
        "signed subtraction preserves negative result");
}

@test
fn regression_c_mul_operator_negative_scalar_flips_sign() {
    let d = Duration.secs(5) * (-2);
    let n: Int = d.nanos;
    assert_eq(n, -10_000_000_000,
        "signed multiplication: negative scalar produces past-relative span");
}

@test
fn regression_c_saturating_sub_still_floors_at_zero() {
    // saturating_sub retains the timer-friendly floor-at-zero
    // convention even under signed Duration.
    let diff = Duration.secs(1).saturating_sub(Duration.secs(5));
    assert(diff.is_zero(),
        "saturating_sub floors at zero (timer-friendly convention)");
}

// =============================================================================
// §D  Operator-method-dispatch shadow — CLOSED 2026-05-27 via VBC runtime fix
// =============================================================================
//
// SURFACE (pre-fix): the runtime intercept for pointer-arithmetic methods
// (`sub` / `byte_sub` / `add` / `byte_add` / `offset` in
// `crates/verum_vbc/src/interpreter/dispatch_table/handlers/method_dispatch.rs:7252`)
// fired indiscriminately on `receiver.is_ptr() && !is_nil()` — catching
// heap-allocated records like Duration whose user-defined `Sub.sub` body
// was silently bypassed.  The result was a garbage pointer value
// masquerading as a Duration; `.nanos` reads of that value returned
// NaN-boxed Float pattern.
//
// The pre-fix test `test_sub_operator_floors_at_zero` happened to pass
// only because `.max(0)` clamped the garbage value to zero by accident
// (the runtime path for `max(NaN, 0)` returns 0).  Removing the
// `.max(0)` clamp under Option B exposed the underlying defect, which
// surfaced as NaN-rendered output for `Duration - Duration`.
//
// RESOLUTION 2026-05-27 — `method_dispatch.rs` line 7249 extended with
// a `is_cbgr_heap_object` guard: pointer arithmetic methods now skip
// CBGR-allocated heap objects (Duration / Instant / SystemTime / any
// user-defined record), letting the protocol dispatch resolve to the
// user-defined `Sub.sub` / `Add.add` / `Offset.offset` body instead.
//
// Closes the operator-method-dispatch shadow defect class for ALL
// heap-allocated records that define `sub` / `add` / `offset` methods
// via Sub / Add / Offset protocol impls.

@test
fn regression_d_op_minus_dispatches_to_user_sub_not_ptr_arith() {
    // The `-` operator on two Duration values MUST dispatch to the
    // user-defined `Sub.sub` body, NOT the runtime's pointer-arithmetic
    // intercept.  Pre-fix this returned a garbage pointer Value; post-fix
    // it returns the signed Int difference.
    let a = Duration.secs(1);
    let b = Duration.secs(3);
    let diff = a - b;
    let n: Int = diff.nanos;
    assert_eq(n, -2_000_000_000,
        "Duration - Duration dispatches to user Sub.sub (not ptr arith)");
}

@test
fn regression_d_dot_sub_dispatches_to_user_method() {
    // Same defect class, exercised via explicit method call.
    let a = Duration.secs(7);
    let b = Duration.secs(2);
    let diff = a.sub(b);
    assert_eq(diff.as_secs(), 5,
        "Duration.sub() method-call dispatches to user impl (not ptr arith)");
}

fn main() {}
