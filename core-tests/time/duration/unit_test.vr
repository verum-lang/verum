// =============================================================================
// core-tests/time/duration/unit_test.vr
// =============================================================================
//
// Unit tests for `core.time.duration.Duration`.
// =============================================================================

mount core.prelude.*;
mount core.time.duration.{Duration};

// =============================================================================
// Section 1: Constructors — accuracy of stored nanoseconds
// =============================================================================

@test
fn test_zero_is_zero_nanos() {
    assert_eq(Duration.zero().as_nanos(), 0);
}

@test
fn test_nanos_constructor() {
    assert_eq(Duration.nanos(42).as_nanos(), 42);
}

@test
fn test_micros_constructor() {
    assert_eq(Duration.micros(3).as_nanos(), 3000);
}

@test
fn test_millis_constructor() {
    assert_eq(Duration.millis(5).as_nanos(), 5_000_000);
}

@test
fn test_secs_constructor() {
    assert_eq(Duration.secs(2).as_nanos(), 2_000_000_000);
}

@test
fn test_mins_constructor() {
    assert_eq(Duration.mins(1).as_nanos(), 60_000_000_000);
}

@test
fn test_hours_constructor() {
    assert_eq(Duration.hours(1).as_nanos(), 3_600_000_000_000);
}

@test
fn test_from_days_constructor() {
    assert_eq(Duration.from_days(1).as_nanos(), 86_400_000_000_000);
}

@test
fn test_from_weeks_constructor() {
    assert_eq(Duration.from_weeks(1).as_nanos(), 604_800_000_000_000);
}

@test
fn test_new_constructor_secs_and_nanos() {
    // Duration.new(secs, nanos) should sum both parts
    let d = Duration.new(1, 500_000_000);
    assert_eq(d.as_nanos(), 1_500_000_000);
}

@test
fn test_from_nanos_alias() {
    assert_eq(Duration.from_nanos(99).as_nanos(), 99);
}

@test
fn test_from_millis_alias() {
    assert_eq(Duration.from_millis(10).as_millis(), 10);
}

@test
fn test_from_secs_alias() {
    assert_eq(Duration.from_secs(3).as_secs(), 3);
}

// =============================================================================
// Section 2: Negative input clamped to zero
// =============================================================================

@test
fn test_nanos_negative_clamped_to_zero() {
    assert_eq(Duration.nanos(-1).as_nanos(), 0);
}

@test
fn test_millis_negative_clamped_to_zero() {
    assert_eq(Duration.millis(-100).as_nanos(), 0);
}

@test
fn test_secs_negative_clamped_to_zero() {
    assert_eq(Duration.secs(-5).as_nanos(), 0);
}

// =============================================================================
// Section 3: Accessors — truncation behaviour
// =============================================================================

@test
fn test_as_micros_truncates() {
    // 1001 µs → 1001 (exact)
    assert_eq(Duration.micros(1001).as_micros(), 1001);
    // 1001ns → 1µs (truncated)
    assert_eq(Duration.nanos(1001).as_micros(), 1);
}

@test
fn test_as_millis_truncates() {
    // 1500ms → 1500; 1_500_001ns → 1ms
    assert_eq(Duration.millis(1500).as_millis(), 1500);
    assert_eq(Duration.nanos(1_500_001).as_millis(), 1);
}

@test
fn test_as_secs_truncates() {
    // 90 seconds → 90; 90_500_000_000ns → 90s
    assert_eq(Duration.secs(90).as_secs(), 90);
    assert_eq(Duration.nanos(90_500_000_000).as_secs(), 90);
}

// =============================================================================
// Section 4: Subsec accessors
// =============================================================================

@test
fn test_subsec_nanos_range() {
    // 1.5 seconds → subsec_nanos = 500_000_000
    let d = Duration.nanos(1_500_000_000);
    assert_eq(d.subsec_nanos(), 500_000_000);
}

@test
fn test_subsec_nanos_zero_for_whole_seconds() {
    assert_eq(Duration.secs(3).subsec_nanos(), 0);
}

@test
fn test_subsec_micros_derives_from_subsec_nanos() {
    // 1_500_700 nanos = 1s + 500_700ns → subsec_micros = 500
    let d = Duration.nanos(1_000_500_700);
    assert_eq(d.subsec_micros(), 500);
}

@test
fn test_subsec_millis_derives_correctly() {
    let d = Duration.nanos(1_750_000_000); // 1.75s
    assert_eq(d.subsec_millis(), 750);
}

// =============================================================================
// Section 5: is_zero predicate
// =============================================================================

@test
fn test_is_zero_for_zero() {
    assert(Duration.zero().is_zero());
}

@test
fn test_is_zero_false_for_one_nano() {
    assert(!Duration.nanos(1).is_zero());
}

// =============================================================================
// Section 6: from_secs_f64
// =============================================================================

@test
fn test_from_secs_f64_whole() {
    let d = Duration.from_secs_f64(2.0);
    assert_eq(d.as_secs(), 2);
    assert_eq(d.subsec_nanos(), 0);
}

@test
fn test_from_secs_f64_fractional() {
    let d = Duration.from_secs_f64(1.5);
    assert_eq(d.as_secs(), 1);
    // 0.5s = 500_000_000ns, allow ±1 for float rounding
    let sub = d.subsec_nanos();
    assert(sub >= 499_999_999 && sub <= 500_000_001);
}

@test
fn test_from_secs_f64_negative_gives_zero() {
    assert(Duration.from_secs_f64(-1.0).is_zero());
}

// =============================================================================
// Section 7: Checked arithmetic
// =============================================================================

@test
fn test_checked_add_returns_some() {
    let a = Duration.secs(1);
    let b = Duration.secs(2);
    let r = a.checked_add(b);
    assert(r.is_some());
    assert_eq(r.unwrap().as_secs(), 3);
}

@test
fn test_checked_sub_exact() {
    let a = Duration.secs(5);
    let b = Duration.secs(3);
    let r = a.checked_sub(b);
    assert_eq(r.unwrap().as_secs(), 2);
}

@test
fn test_checked_sub_underflow_returns_none() {
    let a = Duration.secs(1);
    let b = Duration.secs(5);
    assert(a.checked_sub(b).is_none());
}

@test
fn test_checked_mul_returns_some() {
    let d = Duration.millis(100);
    let r = d.checked_mul(4);
    assert_eq(r.unwrap().as_millis(), 400);
}

@test
fn test_checked_mul_by_zero_returns_zero() {
    let d = Duration.secs(10);
    let r = d.checked_mul(0);
    assert(r.is_some());
    assert(r.unwrap().is_zero());
}

@test
fn test_checked_mul_negative_returns_none() {
    let d = Duration.secs(5);
    assert(d.checked_mul(-1).is_none());
}

@test
fn test_checked_div_exact() {
    let d = Duration.secs(10);
    let r = d.checked_div(2);
    assert_eq(r.unwrap().as_secs(), 5);
}

@test
fn test_checked_div_by_zero_returns_none() {
    let d = Duration.secs(5);
    assert(d.checked_div(0).is_none());
}

// =============================================================================
// Section 8: Saturating arithmetic
// =============================================================================

@test
fn test_saturating_add_normal() {
    let d = Duration.secs(3).saturating_add(Duration.secs(2));
    assert_eq(d.as_secs(), 5);
}

@test
fn test_saturating_sub_floors_at_zero() {
    let d = Duration.secs(1).saturating_sub(Duration.secs(5));
    assert(d.is_zero());
}

@test
fn test_saturating_mul_normal() {
    let d = Duration.millis(50).saturating_mul(3);
    assert_eq(d.as_millis(), 150);
}

// =============================================================================
// Section 9: Operator arithmetic
// =============================================================================

@test
fn test_add_operator() {
    let sum = Duration.secs(1) + Duration.millis(500);
    assert_eq(sum.as_millis(), 1500);
}

@test
fn test_sub_operator_floors_at_zero() {
    let diff = Duration.secs(1) - Duration.secs(3);
    assert(diff.is_zero());
}

@test
fn test_mul_operator() {
    let d = Duration.millis(100) * 5;
    assert_eq(d.as_millis(), 500);
}

@test
fn test_div_operator() {
    let d = Duration.secs(10) / 4;
    assert_eq(d.as_millis(), 2500);
}

// =============================================================================
// Section 10: Comparison
// =============================================================================

@test
fn test_duration_eq() {
    assert_eq(Duration.millis(42), Duration.millis(42));
}

@test
fn test_duration_lt() {
    assert(Duration.millis(1) < Duration.secs(1));
}

@test
fn test_duration_zero_eq_to_self() {
    assert_eq(Duration.zero(), Duration.zero());
}

fn main() {}
