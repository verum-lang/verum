// =============================================================================
// core-tests/encoding/hex/property_test.vr
// =============================================================================
//
// Algebraic laws over `core.encoding.hex`:
//
//   §1  Round-trip: ∀b. decode(encode(b)) == Ok(b)
//   §2  Output length: ∀b. encode(b).len() == 2 * b.len()
//   §3  encode is canonical-lowercase (no uppercase digits)
//   §4  encode_upper is canonical-uppercase (no lowercase digits)
//   §5  decode is case-insensitive: decode(encode(b)) == decode(encode_upper(b))
//   §6  decode rejects odd-length input
//   §7  decode is a left-inverse of encode but NOT a right-inverse
//       (uppercase and lowercase produce same bytes; canonical form is lowercase)
// =============================================================================

mount core.encoding.hex.{encode, encode_upper, decode, HexErrorKind};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// §1 Round-trip: decode(encode(b)) == Ok(b)
// =============================================================================

@test
fn property_round_trip_empty() {
    let input: [Byte; 0] = [];
    let encoded = encode(&input);
    match decode(&encoded) {
        Ok(decoded) => assert_eq(decoded.len(), 0),
        Err(_) => panic("round trip should succeed"),
    }
}

@test
fn property_round_trip_single_byte() {
    let input: [Byte; 1] = [0x42_u8];
    let encoded = encode(&input);
    match decode(&encoded) {
        Ok(decoded) => {
            assert_eq(decoded.len(), 1);
            assert_eq(decoded[0], 0x42_u8);
        },
        Err(_) => panic("round trip should succeed"),
    }
}

@test
fn property_round_trip_all_zeros() {
    let input: [Byte; 4] = [0_u8; 4];
    let encoded = encode(&input);
    match decode(&encoded) {
        Ok(decoded) => {
            assert_eq(decoded.len(), 4);
            let mut i = 0;
            while i < 4 {
                assert_eq(decoded[i], 0_u8);
                i = i + 1;
            }
        },
        Err(_) => panic("round trip should succeed"),
    }
}

@test
fn property_round_trip_all_ones() {
    let input: [Byte; 4] = [0xFF_u8; 4];
    let encoded = encode(&input);
    match decode(&encoded) {
        Ok(decoded) => {
            assert_eq(decoded.len(), 4);
            let mut i = 0;
            while i < 4 {
                assert_eq(decoded[i], 0xFF_u8);
                i = i + 1;
            }
        },
        Err(_) => panic("round trip should succeed"),
    }
}

@test
fn property_round_trip_mixed_values() {
    let input: [Byte; 6] = [0x00_u8, 0x7F_u8, 0x80_u8, 0xCA_u8, 0xFE_u8, 0xBA_u8];
    let encoded = encode(&input);
    match decode(&encoded) {
        Ok(decoded) => {
            assert_eq(decoded.len(), 6);
            assert_eq(decoded[0], 0x00_u8);
            assert_eq(decoded[1], 0x7F_u8);
            assert_eq(decoded[2], 0x80_u8);
            assert_eq(decoded[3], 0xCA_u8);
            assert_eq(decoded[4], 0xFE_u8);
            assert_eq(decoded[5], 0xBA_u8);
        },
        Err(_) => panic("round trip should succeed"),
    }
}

// =============================================================================
// §2 Output length: encode(b).len() == 2 * b.len()
// =============================================================================

@test
fn property_output_length_doubles_input() {
    let i0: [Byte; 0] = [];
    let i1: [Byte; 1] = [0_u8];
    let i3: [Byte; 3] = [0_u8, 1_u8, 2_u8];
    let i8: [Byte; 8] = [0_u8; 8];

    assert_eq(encode(&i0).len(), 0);
    assert_eq(encode(&i1).len(), 2);
    assert_eq(encode(&i3).len(), 6);
    assert_eq(encode(&i8).len(), 16);
}

// =============================================================================
// §3 Lowercase canonical for encode
// =============================================================================

@test
fn property_encode_lowercase_only_no_uppercase() {
    let input: [Byte; 1] = [0xFF_u8];
    let out = encode(&input);
    // "ff" — no uppercase characters
    assert(!out.contains("F"));
    assert(!out.contains("E"));
    assert(!out.contains("D"));
    assert(!out.contains("C"));
    assert(!out.contains("B"));
    assert(!out.contains("A"));
}

// =============================================================================
// §4 Uppercase canonical for encode_upper
// =============================================================================

@test
fn property_encode_upper_uppercase_only_no_lowercase() {
    let input: [Byte; 1] = [0xFF_u8];
    let out = encode_upper(&input);
    // "FF" — no lowercase characters
    assert(!out.contains("f"));
    assert(!out.contains("e"));
    assert(!out.contains("d"));
    assert(!out.contains("c"));
    assert(!out.contains("b"));
    assert(!out.contains("a"));
}

// =============================================================================
// §5 decode case-insensitive: lowercase and uppercase produce same bytes
// =============================================================================

@test
fn property_decode_case_insensitive() {
    let input: [Byte; 4] = [0xDE_u8, 0xAD_u8, 0xBE_u8, 0xEF_u8];
    let lower = encode(&input);
    let upper = encode_upper(&input);
    let dec_lower = decode(&lower);
    let dec_upper = decode(&upper);
    match (dec_lower, dec_upper) {
        (Ok(a), Ok(b)) => {
            assert_eq(a.len(), b.len());
            let mut i = 0;
            while i < a.len() {
                assert_eq(a[i], b[i]);
                i = i + 1;
            }
        },
        _ => panic("both should decode successfully"),
    }
}

// =============================================================================
// §6 decode rejects odd-length input
// =============================================================================

@test
fn property_decode_rejects_odd_length_one() {
    let s = "a".clone();
    match decode(&s) {
        Ok(_) => panic("1-char hex should fail"),
        Err(e) => assert(e.kind is HexErrorKind.InvalidLength),
    }
}

@test
fn property_decode_rejects_odd_length_three() {
    let s = "abc".clone();
    match decode(&s) {
        Ok(_) => panic("3-char hex should fail"),
        Err(e) => assert(e.kind is HexErrorKind.InvalidLength),
    }
}

@test
fn property_decode_rejects_odd_length_seven() {
    let s = "0123456".clone();
    match decode(&s) {
        Ok(_) => panic("7-char hex should fail"),
        Err(e) => assert(e.kind is HexErrorKind.InvalidLength),
    }
}
