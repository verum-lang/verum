// =============================================================================
// core-tests/mem/cap_audit/regression_test.vr
// =============================================================================
//
// Pinned regressions for `core.mem.cap_audit`.
//
// Pinned regressions:
//   §A  CapEvent.new returns seq=0.  Pre-fix some drafts assigned a
//       fresh seq at construction time, but the architectural design
//       requires the ring buffer (not the constructor) to assign seq
//       on commit.  Pin seq=0 on construction.
//   §B  bumped_generation is true ONLY for Revoke and GenBump variants.
//       Pre-fix some drafts also returned true for Attenuate (which
//       narrows caps but does NOT bump generation).
//   §C  CapEventKind variant tag stability — Revoke=0, Attenuate=1,
//       RefIncr=2, RefDecr=3, GenBump=4, EpochAdvance=5.  The tag
//       assignment is observable via `cap_event_kind_tag` (private)
//       through the Eq impl.  Pin the variant order so a future
//       reorder doesn't silently drift.
// =============================================================================

mount core.prelude.*;
mount core.mem.cap_audit.{
    CapEventKind, CapEvent,
    Revoke, Attenuate, RefIncr, RefDecr, GenBump, EpochAdvance,
};

// -----------------------------------------------------------------------------
// §A — CapEvent.new sets seq=0
// -----------------------------------------------------------------------------

@test
fn regression_cap_event_new_seq_zero() {
    let event = CapEvent.new(
        Revoke,
        100 as UInt64,
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.seq, 0 as UInt64);
}

// -----------------------------------------------------------------------------
// §B — bumped_generation matrix
// -----------------------------------------------------------------------------

@test
fn regression_bumped_generation_matrix() {
    let cases: List<(CapEventKind, Bool)> = [
        (Revoke, true),
        (Attenuate, false),
        (RefIncr, false),
        (RefDecr, false),
        (GenBump, true),
        (EpochAdvance, false),
    ];
    for case in cases.iter() {
        let event = CapEvent.new(
            case.0,
            100 as UInt64,
            1 as UInt32, 2 as UInt32,
            0 as UInt16, 0 as UInt16,
            0 as UInt64,
        );
        assert_eq(event.bumped_generation(), case.1);
    }
}

// -----------------------------------------------------------------------------
// §C — CapEventKind Eq variant identity is stable
// -----------------------------------------------------------------------------

@test
fn regression_cap_event_kind_eq_variant_identity() {
    // Reflexivity of all 6 variants.  This pins the tag-comparison
    // behaviour of the Eq impl — if a future reorder shifted tags
    // silently, this would still pass (Eq is identity-of-tag).
    // The variant order is pinned in unit_test by checking each is's
    // own variant marker via `is`-pattern.
    let r1: CapEventKind = Revoke;
    let r2: CapEventKind = Revoke;
    assert(r1.eq(&r2));
    let a1: CapEventKind = Attenuate;
    let a2: CapEventKind = Attenuate;
    assert(a1.eq(&a2));
    assert(!r1.eq(&a1));
}

// -----------------------------------------------------------------------------
// §D — CapEvent field count is 8 (compile-time pin via field reads)
// -----------------------------------------------------------------------------

@test
fn regression_cap_event_field_count_eight() {
    // The CapEvent record has exactly 8 fields.  This test fails to
    // compile if a field is removed; it passes value reads on each so
    // a field rename or type change surfaces.
    let event = CapEvent.new(
        EpochAdvance,
        1 as UInt64, 2 as UInt32, 3 as UInt32,
        4 as UInt16, 5 as UInt16, 6 as UInt64,
    );
    // 8 field reads — kind, seq, ptr_id, gen_before, gen_after,
    // caps_before, caps_after, timestamp_ns.
    assert(event.kind is EpochAdvance);
    assert_eq(event.seq, 0 as UInt64);
    assert_eq(event.ptr_id, 1 as UInt64);
    assert_eq(event.generation_before, 2 as UInt32);
    assert_eq(event.generation_after, 3 as UInt32);
    assert_eq(event.capabilities_before, 4 as UInt16);
    assert_eq(event.capabilities_after, 5 as UInt16);
    assert_eq(event.timestamp_ns, 6 as UInt64);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
