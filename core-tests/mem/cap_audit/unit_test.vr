// =============================================================================
// core-tests/mem/cap_audit/unit_test.vr
// =============================================================================
//
// Per-API tests for `core.mem.cap_audit` — the CapEvent record type
// for forensic reconstruction of CBGR capability state changes.
//
// This file pins:
//   * CapEventKind variants (6-way sum type)
//   * CapEvent constructor + field round-trip
//   * Eq, Debug, Display impls on CapEventKind
//   * `bumped_generation` predicate
//
// Companion files:
//   property_test.vr     — variant disjointness, predicate consistency
//   integration_test.vr  — composition with cap_audit_ring + writers
//   regression_test.vr   — pinned defects
//   audit.md             — drift surfaces & action items
// =============================================================================

mount core.prelude.*;
mount core.mem.cap_audit.{
    CapEventKind, CapEvent,
    Revoke, Attenuate, RefIncr, RefDecr, GenBump, EpochAdvance,
};

// =============================================================================
// Section 1: CapEventKind variant construction
// =============================================================================

@test
fn test_cap_event_kind_revoke_construction() {
    let k: CapEventKind = Revoke;
    assert(k is Revoke);
}

@test
fn test_cap_event_kind_attenuate_construction() {
    let k: CapEventKind = Attenuate;
    assert(k is Attenuate);
}

@test
fn test_cap_event_kind_ref_incr_construction() {
    let k: CapEventKind = RefIncr;
    assert(k is RefIncr);
}

@test
fn test_cap_event_kind_ref_decr_construction() {
    let k: CapEventKind = RefDecr;
    assert(k is RefDecr);
}

@test
fn test_cap_event_kind_gen_bump_construction() {
    let k: CapEventKind = GenBump;
    assert(k is GenBump);
}

@test
fn test_cap_event_kind_epoch_advance_construction() {
    let k: CapEventKind = EpochAdvance;
    assert(k is EpochAdvance);
}

@test
fn test_cap_event_kind_variants_pairwise_distinct() {
    let revoke: CapEventKind = Revoke;
    let attenuate: CapEventKind = Attenuate;
    let ref_incr: CapEventKind = RefIncr;
    let ref_decr: CapEventKind = RefDecr;
    let gen_bump: CapEventKind = GenBump;
    let epoch_adv: CapEventKind = EpochAdvance;
    // Each variant matches only itself
    assert(!(revoke is Attenuate));
    assert(!(attenuate is Revoke));
    assert(!(ref_incr is RefDecr));
    assert(!(ref_decr is RefIncr));
    assert(!(gen_bump is EpochAdvance));
    assert(!(epoch_adv is GenBump));
}

// =============================================================================
// Section 2: CapEventKind Eq
// =============================================================================

@test
fn test_cap_event_kind_eq_same_variant_returns_true() {
    let a: CapEventKind = Revoke;
    let b: CapEventKind = Revoke;
    assert(a.eq(&b));
}

@test
fn test_cap_event_kind_eq_different_variants_returns_false() {
    let a: CapEventKind = Revoke;
    let b: CapEventKind = Attenuate;
    assert(!a.eq(&b));
}

// =============================================================================
// Section 3: CapEvent construction via CapEvent.new
// =============================================================================

@test
fn test_cap_event_new_records_kind() {
    let event = CapEvent.new(
        Revoke,
        100 as UInt64,    // ptr_id
        5 as UInt32,      // gen_before
        6 as UInt32,      // gen_after
        0xFF as UInt16,   // caps_before
        0 as UInt16,      // caps_after
        0 as UInt64,      // timestamp_ns
    );
    assert(event.kind is Revoke);
}

@test
fn test_cap_event_new_records_ptr_id() {
    let event = CapEvent.new(
        Revoke,
        0xABCDEF as UInt64,
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.ptr_id, 0xABCDEF as UInt64);
}

@test
fn test_cap_event_new_records_generation_range() {
    let event = CapEvent.new(
        GenBump,
        100 as UInt64,
        42 as UInt32, 43 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.generation_before, 42 as UInt32);
    assert_eq(event.generation_after, 43 as UInt32);
}

@test
fn test_cap_event_new_records_capability_range() {
    let event = CapEvent.new(
        Attenuate,
        100 as UInt64,
        1 as UInt32, 1 as UInt32,
        0xFF as UInt16, 0x01 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.capabilities_before, 0xFF as UInt16);
    assert_eq(event.capabilities_after, 0x01 as UInt16);
}

@test
fn test_cap_event_new_seq_is_zero_for_uncommitted() {
    let event = CapEvent.new(
        Revoke,
        100 as UInt64,
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    // seq = 0 marks an un-committed event.
    assert_eq(event.seq, 0 as UInt64);
}

// =============================================================================
// Section 4: bumped_generation predicate
// =============================================================================

@test
fn test_bumped_generation_true_for_revoke() {
    let event = CapEvent.new(
        Revoke,
        100 as UInt64,
        5 as UInt32, 6 as UInt32,
        0xFF as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(event.bumped_generation());
}

@test
fn test_bumped_generation_true_for_gen_bump() {
    let event = CapEvent.new(
        GenBump,
        100 as UInt64,
        5 as UInt32, 6 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(event.bumped_generation());
}

@test
fn test_bumped_generation_false_for_attenuate() {
    let event = CapEvent.new(
        Attenuate,
        100 as UInt64,
        5 as UInt32, 5 as UInt32,     // gen unchanged
        0xFF as UInt16, 0x01 as UInt16,
        0 as UInt64,
    );
    assert(!event.bumped_generation());
}

@test
fn test_bumped_generation_false_for_ref_incr() {
    let event = CapEvent.new(
        RefIncr,
        100 as UInt64,
        5 as UInt32, 5 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(!event.bumped_generation());
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
