// =============================================================================
// core-tests/mem/cap_audit/unit_test.vr
// =============================================================================
//
// Per-API tests for `core.mem.cap_audit` — the CapEvent record type
// for forensic reconstruction of CBGR capability state changes.
//
// This file pins:
//   * CapEventKind variants (6-way sum type)
//   * CapEvent constructor + field round-trip
//   * Eq, Debug, Display impls on CapEventKind
//   * `bumped_generation` predicate
//
// Companion files:
//   property_test.vr     — variant disjointness, predicate consistency
//   integration_test.vr  — composition with cap_audit_ring + writers
//   regression_test.vr   — pinned defects
//   audit.md             — drift surfaces & action items
// =============================================================================

mount core.prelude.*;
mount core.mem.cap_audit.{
    CapEventKind, CapEvent,
};
// `Revoke`/`Attenuate`/`RefIncr`/`RefDecr`/`GenBump`/`EpochAdvance`
// are NOT imported by bare name because `Revoke` collides with
// `core.mem.capability.Capability.Revoke` (a separate single-bit
// capability flag — same variant name, different type).  Use the
// qualified `CapEventKind.Variant` form throughout the test body.

// =============================================================================
// Section 1: CapEventKind variant construction
// =============================================================================

@test
fn test_cap_event_kind_revoke_construction() {
    let k: CapEventKind = CapEventKind.Revoke;
    assert(k is CapEventKind.Revoke);
}

@test
fn test_cap_event_kind_attenuate_construction() {
    let k: CapEventKind = CapEventKind.Attenuate;
    assert(k is CapEventKind.Attenuate);
}

@test
fn test_cap_event_kind_ref_incr_construction() {
    let k: CapEventKind = CapEventKind.RefIncr;
    assert(k is CapEventKind.RefIncr);
}

@test
fn test_cap_event_kind_ref_decr_construction() {
    let k: CapEventKind = CapEventKind.RefDecr;
    assert(k is CapEventKind.RefDecr);
}

@test
fn test_cap_event_kind_gen_bump_construction() {
    let k: CapEventKind = CapEventKind.GenBump;
    assert(k is CapEventKind.GenBump);
}

@test
fn test_cap_event_kind_epoch_advance_construction() {
    let k: CapEventKind = CapEventKind.EpochAdvance;
    assert(k is CapEventKind.EpochAdvance);
}

@test
fn test_cap_event_kind_variants_pairwise_distinct() {
    let revoke: CapEventKind = CapEventKind.Revoke;
    let attenuate: CapEventKind = CapEventKind.Attenuate;
    let ref_incr: CapEventKind = CapEventKind.RefIncr;
    let ref_decr: CapEventKind = CapEventKind.RefDecr;
    let gen_bump: CapEventKind = CapEventKind.GenBump;
    let epoch_adv: CapEventKind = CapEventKind.EpochAdvance;
    // Each variant matches only itself
    assert(!(revoke is CapEventKind.Attenuate));
    assert(!(attenuate is CapEventKind.Revoke));
    assert(!(ref_incr is CapEventKind.RefDecr));
    assert(!(ref_decr is CapEventKind.RefIncr));
    assert(!(gen_bump is CapEventKind.EpochAdvance));
    assert(!(epoch_adv is CapEventKind.GenBump));
}

// =============================================================================
// Section 2: CapEventKind Eq
// =============================================================================

@test
fn test_cap_event_kind_eq_same_variant_returns_true() {
    let a: CapEventKind = CapEventKind.Revoke;
    let b: CapEventKind = CapEventKind.Revoke;
    assert(a.eq(&b));
}

@test
fn test_cap_event_kind_eq_different_variants_returns_false() {
    let a: CapEventKind = CapEventKind.Revoke;
    let b: CapEventKind = CapEventKind.Attenuate;
    assert(!a.eq(&b));
}

// =============================================================================
// Section 3: CapEvent construction via CapEvent.new
// =============================================================================

@test
fn test_cap_event_new_records_kind() {
    let event = CapEvent.new(
        CapEventKind.Revoke,
        100 as UInt64,    // ptr_id
        5 as UInt32,      // gen_before
        6 as UInt32,      // gen_after
        0xFF as UInt16,   // caps_before
        0 as UInt16,      // caps_after
        0 as UInt64,      // timestamp_ns
    );
    assert(event.kind is CapEventKind.Revoke);
}

@test
fn test_cap_event_new_records_ptr_id() {
    let event = CapEvent.new(
        CapEventKind.Revoke,
        0xABCDEF as UInt64,
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.ptr_id, 0xABCDEF as UInt64);
}

@test
fn test_cap_event_new_records_generation_range() {
    let event = CapEvent.new(
        CapEventKind.GenBump,
        100 as UInt64,
        42 as UInt32, 43 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.generation_before, 42 as UInt32);
    assert_eq(event.generation_after, 43 as UInt32);
}

@test
fn test_cap_event_new_records_capability_range() {
    let event = CapEvent.new(
        CapEventKind.Attenuate,
        100 as UInt64,
        1 as UInt32, 1 as UInt32,
        0xFF as UInt16, 0x01 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.capabilities_before, 0xFF as UInt16);
    assert_eq(event.capabilities_after, 0x01 as UInt16);
}

@test
fn test_cap_event_new_seq_is_zero_for_uncommitted() {
    let event = CapEvent.new(
        CapEventKind.Revoke,
        100 as UInt64,
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    // seq = 0 marks an un-committed event.
    assert_eq(event.seq, 0 as UInt64);
}

// =============================================================================
// Section 4: bumped_generation predicate
// =============================================================================

@test
fn test_bumped_generation_true_for_revoke() {
    let event = CapEvent.new(
        CapEventKind.Revoke,
        100 as UInt64,
        5 as UInt32, 6 as UInt32,
        0xFF as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(event.bumped_generation());
}

@test
fn test_bumped_generation_true_for_gen_bump() {
    let event = CapEvent.new(
        CapEventKind.GenBump,
        100 as UInt64,
        5 as UInt32, 6 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(event.bumped_generation());
}

@test
fn test_bumped_generation_false_for_attenuate() {
    let event = CapEvent.new(
        CapEventKind.Attenuate,
        100 as UInt64,
        5 as UInt32, 5 as UInt32,     // gen unchanged
        0xFF as UInt16, 0x01 as UInt16,
        0 as UInt64,
    );
    assert(!event.bumped_generation());
}

@test
fn test_bumped_generation_false_for_ref_incr() {
    let event = CapEvent.new(
        CapEventKind.RefIncr,
        100 as UInt64,
        5 as UInt32, 5 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(!event.bumped_generation());
}

@test
fn test_bumped_generation_false_for_ref_decr() {
    // RefDecr does NOT touch generation — predicate must be false
    // even if generation_before != generation_after (the predicate
    // is kind-driven, not diff-driven; see task #24 close-out).
    let event = CapEvent.new(
        CapEventKind.RefDecr,
        100 as UInt64,
        5 as UInt32, 5 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(!event.bumped_generation());
}

@test
fn test_bumped_generation_false_for_epoch_advance() {
    // EpochAdvance bumps the epoch field, NOT the generation —
    // predicate must be false regardless of generation values.
    let event = CapEvent.new(
        CapEventKind.EpochAdvance,
        100 as UInt64,
        5 as UInt32, 5 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(!event.bumped_generation());
}

@test
fn test_bumped_generation_kind_driven_not_diff_driven() {
    // Critical: even when gen_before != gen_after, the predicate
    // must return false for variants that semantically don't bump
    // (Attenuate, RefIncr, RefDecr, EpochAdvance).  This is the
    // intent-vs-diff contract pinned in task #24 close-out.
    let attenuate = CapEvent.new(
        CapEventKind.Attenuate,
        100 as UInt64,
        1 as UInt32, 2 as UInt32,            // gen DIFFERS, but kind is Attenuate
        0xFF as UInt16, 0x01 as UInt16,
        0 as UInt64,
    );
    assert(!attenuate.bumped_generation());

    let ref_incr = CapEvent.new(
        CapEventKind.RefIncr,
        100 as UInt64,
        1 as UInt32, 2 as UInt32,            // gen DIFFERS, but kind is RefIncr
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert(!ref_incr.bumped_generation());
}

// =============================================================================
// Section 5: CapEvent epoch_at_event field independence
// =============================================================================

@test
fn test_cap_event_new_records_epoch_at_event() {
    // The 7th argument to .new() is the timestamp_ns / epoch-at-event
    // value — fully independent of generation / capabilities.
    let event = CapEvent.new(
        CapEventKind.GenBump,
        100 as UInt64,
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0xDEAD_BEEF as UInt64,
    );
    assert_eq(event.epoch_at_event, 0xDEAD_BEEF as UInt64);
}

@test
fn test_cap_event_new_independent_fields_no_cross_contamination() {
    // Construct two events with the SAME kind but DIFFERENT payloads.
    // The fields must not bleed across — pin field-independence.
    let a = CapEvent.new(
        CapEventKind.Revoke,
        0x1111 as UInt64,
        10 as UInt32, 11 as UInt32,
        0x00FF as UInt16, 0 as UInt16,
        100 as UInt64,
    );
    let b = CapEvent.new(
        CapEventKind.Revoke,
        0x2222 as UInt64,
        20 as UInt32, 21 as UInt32,
        0xFF00 as UInt16, 0 as UInt16,
        200 as UInt64,
    );
    assert_eq(a.ptr_id, 0x1111 as UInt64);
    assert_eq(b.ptr_id, 0x2222 as UInt64);
    assert_eq(a.generation_before, 10 as UInt32);
    assert_eq(b.generation_before, 20 as UInt32);
    assert_eq(a.capabilities_before, 0x00FF as UInt16);
    assert_eq(b.capabilities_before, 0xFF00 as UInt16);
    assert_eq(a.epoch_at_event, 100 as UInt64);
    assert_eq(b.epoch_at_event, 200 as UInt64);
}

// =============================================================================
// Section 6: CapEvent ptr_id full UInt64 range
// =============================================================================

@test
fn test_cap_event_ptr_id_supports_max_uint64() {
    let event = CapEvent.new(
        CapEventKind.Revoke,
        0xFFFFFFFFFFFFFFFF as UInt64,    // max 64-bit
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.ptr_id, 0xFFFFFFFFFFFFFFFF as UInt64);
}

@test
fn test_cap_event_ptr_id_supports_zero() {
    // Zero ptr_id is a valid (but unusual) input — pin the
    // contract that the constructor does not reject it.
    let event = CapEvent.new(
        CapEventKind.Revoke,
        0 as UInt64,
        1 as UInt32, 2 as UInt32,
        0 as UInt16, 0 as UInt16,
        0 as UInt64,
    );
    assert_eq(event.ptr_id, 0 as UInt64);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
