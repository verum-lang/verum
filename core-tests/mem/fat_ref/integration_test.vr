// =============================================================================
// core-tests/mem/fat_ref/integration_test.vr
// =============================================================================
//
// Integration tests: FatRef composed with ThinRef, header, and capability.
// FatRef extends ThinRef with a metadata field (slice length or vtable
// pointer) plus offset_from_base for subslice views.  These tests pin
// the cross-module invariants.
// =============================================================================

mount core.prelude.*;
mount core.mem.header.{HEADER_SIZE, GEN_UNALLOCATED, GEN_INITIAL};
mount core.mem.capability.{
    CAP_READ, CAP_WRITE, CAP_OWNED, CAP_READ_ONLY,
    attenuate, has_capability,
    pack_epoch_caps, unpack_epoch, unpack_caps,
};

// -----------------------------------------------------------------------------
// §1  Header recovery via offset arithmetic.  For a fat ref pointing
//     at offset O from the base allocation, the header is at:
//        ptr - offset_from_base - HEADER_SIZE
// -----------------------------------------------------------------------------

@test
fn integration_subslice_header_offset_zero() {
    // Non-subslice fat ref: offset = 0, header at ptr - 32.
    let ptr: Int = 1000;
    let offset: Int = 0;
    let header_addr: Int = ptr - offset - HEADER_SIZE;
    assert_eq(header_addr, 1000 - 32);
    assert_eq(header_addr, 968);
}

@test
fn integration_subslice_header_offset_nonzero() {
    // Subslice fat ref at offset 16 from a base allocation at ptr 1000.
    // Sub-ptr = 1016; header recovery reads 1016 - 16 - 32 = 968.
    let base_ptr: Int = 1000;
    let offset: Int = 16;
    let sub_ptr: Int = base_ptr + offset;
    let header_addr: Int = sub_ptr - offset - HEADER_SIZE;
    assert_eq(header_addr, 968);
}

// -----------------------------------------------------------------------------
// §2  Packed-field semantics — FatRef and ThinRef share the same
//     pack_epoch_caps layout.
// -----------------------------------------------------------------------------

@test
fn integration_fat_ref_packed_field_matches_thin_ref() {
    // The (epoch, caps) packing is bijective for both reference types.
    let packed_a = pack_epoch_caps(7 as UInt16, CAP_OWNED);
    let packed_b = pack_epoch_caps(7 as UInt16, CAP_OWNED);
    assert_eq(packed_a, packed_b);
    assert_eq(unpack_epoch(packed_a), 7 as UInt16);
    assert_eq(unpack_caps(packed_a), CAP_OWNED);
}

// -----------------------------------------------------------------------------
// §3  Attenuate caps on a fat-ref-style packed field.
// -----------------------------------------------------------------------------

@test
fn integration_attenuate_fat_ref_caps_to_read_only() {
    let initial = pack_epoch_caps(1 as UInt16, CAP_OWNED);
    let attenuated_caps = attenuate(unpack_caps(initial), CAP_READ_ONLY);
    let final_packed = pack_epoch_caps(unpack_epoch(initial), attenuated_caps);
    assert(!has_capability(unpack_caps(final_packed), CAP_WRITE));
    assert(has_capability(unpack_caps(final_packed), CAP_READ));
    assert_eq(unpack_epoch(final_packed), 1 as UInt16);
}

// -----------------------------------------------------------------------------
// §4  Null fat-ref shape — generation = GEN_UNALLOCATED, packed = 0.
// -----------------------------------------------------------------------------

@test
fn integration_null_fat_ref_shape() {
    let null_gen: UInt32 = GEN_UNALLOCATED;
    let null_packed: UInt32 = 0 as UInt32;
    let null_offset: UInt32 = 0 as UInt32;
    let null_metadata: Int = 0;
    assert_eq(null_gen, 0 as UInt32);
    assert_eq(unpack_epoch(null_packed), 0 as UInt16);
    assert_eq(unpack_caps(null_packed), 0 as UInt16);
    assert_eq(null_offset, 0 as UInt32);
    assert_eq(null_metadata, 0);
}

// -----------------------------------------------------------------------------
// §5  Metadata field semantics — length for slices, vtable for dyn.
// -----------------------------------------------------------------------------

@test
fn integration_slice_length_in_metadata() {
    // For a FatRef<[Int]> over a 5-element slice, metadata = 5.
    let slice_len: Int = 5;
    assert(slice_len >= 0);
    assert(slice_len < 1000000);   // Realistic upper bound for slice length
}

// -----------------------------------------------------------------------------
// §6  Subslice-of-subslice: offsets add.
// -----------------------------------------------------------------------------

@test
fn integration_subslice_of_subslice_offset_adds() {
    // Initial base at 1000.  Sub-A at offset 16 → ptr 1016.
    // Sub-B from Sub-A at offset 8 → ptr 1024.  Sub-B's
    // offset_from_base should be 24 (cumulative).
    let base_ptr: Int = 1000;
    let sub_a_offset: Int = 16;
    let sub_b_offset_from_a: Int = 8;
    let sub_b_ptr: Int = base_ptr + sub_a_offset + sub_b_offset_from_a;
    let sub_b_offset_from_base: Int = sub_b_ptr - base_ptr;
    assert_eq(sub_b_offset_from_base, 24);
    // Header recovery from sub-B
    let header_addr: Int = sub_b_ptr - sub_b_offset_from_base - HEADER_SIZE;
    assert_eq(header_addr, 1000 - 32);
}

// -----------------------------------------------------------------------------
// §7  32-byte layout invariant — FatRef MUST occupy exactly 32 bytes
//     for @repr(C, size(32), align(8)).  Pin the per-field byte
//     breakdown that LLVM lowering depends on.
// -----------------------------------------------------------------------------

@test
fn integration_fat_ref_field_byte_breakdown_sums_to_32() {
    // ptr      8 bytes (NaN-boxed pointer)
    // gen      4 bytes (UInt32 generation)
    // caps     4 bytes (UInt32 epoch_and_caps packed form)
    // meta     8 bytes (Int signed for slice-length / -1 sentinel / vtable ptr)
    // offset   4 bytes (UInt32 offset_from_base)
    // reserved 4 bytes (zero-init forward-compat slot)
    // ----     -------
    //          32 bytes total
    let ptr_bytes: Int = 8;
    let gen_bytes: Int = 4;
    let caps_bytes: Int = 4;
    let meta_bytes: Int = 8;
    let offset_bytes: Int = 4;
    let reserved_bytes: Int = 4;
    let total = ptr_bytes + gen_bytes + caps_bytes
              + meta_bytes + offset_bytes + reserved_bytes;
    assert_eq(total, 32);
}

@test
fn integration_fat_ref_alignment_divides_size() {
    // The FatRef @repr declares align(8) and size(32). For C ABI
    // compatibility, alignment must divide size — pinned here.
    let size: Int = 32;
    let alignment: Int = 8;
    assert_eq(size % alignment, 0);
}

// -----------------------------------------------------------------------------
// §8  Metadata signed-sentinel semantics — the metadata field is
//     declared signed (Int) NOT unsigned, so it can carry -1 as a
//     sentinel for "no metadata yet" + arbitrary positive lengths up
//     to Int.MAX.
// -----------------------------------------------------------------------------

@test
fn integration_fat_ref_metadata_minus_one_sentinel_distinct_from_zero() {
    // -1 is the "no metadata yet" sentinel; 0 is "empty slice".
    // The two MUST be distinguishable — pin via direct comparison.
    let no_meta: Int = -1;
    let empty_slice: Int = 0;
    assert(no_meta != empty_slice);
    assert(no_meta < 0);
    assert(empty_slice >= 0);
}

@test
fn integration_fat_ref_metadata_supports_large_positive_lengths() {
    // The metadata field is Int (signed 64-bit), so it supports
    // slice lengths up to 2^63 - 1 (Int.MAX).  Pin a few canonical
    // large values that downstream slice operations use.
    let small: Int = 16;
    let mid: Int = 4096;
    let large: Int = 1048576;       // 2^20
    let huge: Int = 1073741824;     // 2^30
    assert(small > 0);
    assert(mid > small);
    assert(large > mid);
    assert(huge > large);
    // All fit within Int.MAX range.
    assert(huge < (1 << 62));
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
