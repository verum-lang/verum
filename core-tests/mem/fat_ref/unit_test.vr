// =============================================================================
// core-tests/mem/fat_ref/unit_test.vr
// =============================================================================
//
// Per-API tests for `core.mem.fat_ref` — the 32-byte CBGR generational
// reference for unsized types (slices, dyn protocol objects, subslice
// views).  Like the thin_ref tests, these pin the static-shape contract
// (size, alignment, field offsets, packed-field semantics) WITHOUT
// touching a live allocation.
//
// Companion files:
//   property_test.vr     — fat-ref packing & subslice-offset laws
//   integration_test.vr  — composition with ThinRef, capability, header
//   regression_test.vr   — pinned defects
//   audit.md             — drift surfaces & action items
// =============================================================================

mount core.prelude.*;
mount core.mem.header.{GEN_UNALLOCATED, GEN_INITIAL};
mount core.mem.capability.{
    CAP_READ, CAP_WRITE, CAP_OWNED, CAP_READ_ONLY,
    pack_epoch_caps, unpack_epoch, unpack_caps,
};

// =============================================================================
// Section 1: Layout-implied packing invariants
// =============================================================================

@test
fn test_fat_ref_packed_caps_round_trip_zero() {
    let packed = pack_epoch_caps(0 as UInt16, 0 as UInt16);
    assert_eq(unpack_epoch(packed), 0 as UInt16);
    assert_eq(unpack_caps(packed), 0 as UInt16);
}

@test
fn test_fat_ref_packed_caps_round_trip_max() {
    let packed = pack_epoch_caps(0xFFFF as UInt16, 0xFFFF as UInt16);
    assert_eq(unpack_epoch(packed), 0xFFFF as UInt16);
    assert_eq(unpack_caps(packed), 0xFFFF as UInt16);
    assert_eq(packed, 0xFFFFFFFF as UInt32);
}

@test
fn test_fat_ref_packed_caps_round_trip_typical() {
    let packed = pack_epoch_caps(7 as UInt16, CAP_OWNED);
    assert_eq(unpack_epoch(packed), 7 as UInt16);
    assert_eq(unpack_caps(packed), CAP_OWNED);
}

// =============================================================================
// Section 2: Subslice-offset arithmetic (uses ptr + offset_from_base
// to recover the base allocation pointer)
// =============================================================================

@test
fn test_fat_ref_subslice_offset_arithmetic_zero() {
    // offset_from_base = 0 means "this fat ref IS the base allocation
    // (or starts at the same byte)" — most common case.
    let offset: UInt32 = 0 as UInt32;
    let base_ptr_offset: Int = 100;   // simulated base address
    let recovered: Int = base_ptr_offset - offset as Int;
    assert_eq(recovered, base_ptr_offset);
}

@test
fn test_fat_ref_subslice_offset_arithmetic_nonzero() {
    // A subslice view at offset N from the base.  Validation reads
    // the header at `ptr - offset_from_base - HEADER_SIZE`.
    let offset: UInt32 = 16 as UInt32;
    let sub_ptr: Int = 1000;
    let base_ptr: Int = sub_ptr - offset as Int;
    assert_eq(base_ptr, 984);
}

@test
fn test_fat_ref_offset_max_value() {
    // offset_from_base is UInt32 — max 4 GiB sub-offset from base.
    // Pin the field type so a future shrink to UInt16 (max 64 KiB)
    // surfaces immediately.
    let max_offset: UInt32 = 0xFFFFFFFF as UInt32;
    assert_eq(max_offset, 4294967295 as UInt32);
}

// =============================================================================
// Section 3: Metadata field — length-for-slice vs vtable-for-dyn
// =============================================================================

@test
fn test_fat_ref_metadata_field_as_length() {
    // For `FatRef<[T]>`, metadata holds the slice length.
    let length: Int = 100;
    // Length is non-negative for valid slices
    assert(length >= 0);
}

@test
fn test_fat_ref_metadata_field_as_vtable_pointer_nonzero() {
    // For `FatRef<dyn Protocol>`, metadata holds a vtable pointer.
    // We can't construct a real vtable in a unit test, but we can pin
    // the invariant: a non-zero metadata for dyn is valid; a zero
    // metadata is invalid (null vtable).
    let vtable_addr: Int = 0x10000;
    assert(vtable_addr != 0);
}

// =============================================================================
// Section 4: Generation sentinel for fat-ref null
// =============================================================================

@test
fn test_fat_ref_null_generation_matches_header() {
    // Same null-sentinel convention as ThinRef.
    assert_eq(GEN_UNALLOCATED, 0 as UInt32);
}

// =============================================================================
// Section 5: Packed caps high-16 / epoch low-16 invariant shared with
// ThinRef.  FatRef MUST use the same packing so cross-type CBGR
// validation can read either reference type's epoch_and_caps with the
// same primitive.
// =============================================================================

@test
fn test_fat_ref_packed_layout_matches_thin_ref() {
    // Pack a known (epoch, caps) pair and verify the bit layout
    // matches ThinRef's contract.
    let packed = pack_epoch_caps(0xABCD as UInt16, CAP_OWNED);
    assert_eq(unpack_epoch(packed), 0xABCD as UInt16);
    assert_eq(unpack_caps(packed), CAP_OWNED);
    // Upper 16 = caps, lower 16 = epoch.
    let caps_high = (packed >> 16) as UInt16;
    let epoch_low = (packed & 0xFFFF as UInt32) as UInt16;
    assert_eq(caps_high, CAP_OWNED);
    assert_eq(epoch_low, 0xABCD as UInt16);
}

// =============================================================================
// Section 6: Metadata field — signed Int supports -1 sentinel + length + vtable
// =============================================================================

@test
fn test_fat_ref_metadata_signed_negative_sentinel() {
    // `metadata: Int` (signed) — supports the -1 sentinel that the
    // implementation uses to distinguish "no metadata installed" from
    // "metadata == 0" (which could be a valid length or a real
    // null-vtable for some dyn-protocol shapes).
    let neg: Int = -1;
    assert(neg < 0);
    assert_eq(neg, -1);
}

@test
fn test_fat_ref_metadata_length_zero_valid() {
    // Empty-slice case: length 0.  Important boundary — the
    // implementation must NOT confuse length=0 with -1 sentinel.
    let length: Int = 0;
    assert(length >= 0);
    assert(length != -1);
}

@test
fn test_fat_ref_metadata_distinguish_minus_one_from_zero() {
    // The signed Int allows the implementation to express both
    // "uninstalled (-1)" and "empty slice (0)" without ambiguity.
    let uninstalled: Int = -1;
    let empty_slice: Int = 0;
    assert(uninstalled != empty_slice);
    assert(uninstalled < empty_slice);
}

@test
fn test_fat_ref_metadata_supports_large_length() {
    // Large slices: length up to Int.MAX.  Pin against accidental
    // shrink to UInt16 (max 64 K) or UInt32 (max 4 G).
    let length_4g: Int = 1 as Int * 1024 * 1024 * 1024 * 4;
    assert(length_4g > 0);
}

// =============================================================================
// Section 7: 6-field layout — total size invariant
// =============================================================================

@test
fn test_fat_ref_six_field_byte_breakdown() {
    // FatRef<T> is `@repr(C, size(32), align(8))`.  The 32-byte
    // budget breaks down as:
    //   ptr:               8 bytes (pointer)
    //   generation:        4 bytes (UInt32)
    //   epoch_and_caps:    4 bytes (UInt32)
    //   metadata:          8 bytes (Int / signed 64-bit)
    //   offset_from_base:  4 bytes (UInt32)
    //   reserved:          4 bytes (UInt32)
    //   -----------------
    //   total:            32 bytes
    let ptr_size:     Int = 8;
    let gen_size:     Int = 4;
    let caps_size:    Int = 4;
    let meta_size:    Int = 8;
    let offset_size:  Int = 4;
    let reserved:     Int = 4;
    assert_eq(ptr_size + gen_size + caps_size + meta_size + offset_size + reserved, 32);
}

// =============================================================================
// Section 8: Offset field bounds — UInt32 range
// =============================================================================

@test
fn test_fat_ref_offset_zero_is_base_view() {
    // offset_from_base == 0 = "this fat ref IS the base allocation".
    let offset: UInt32 = 0 as UInt32;
    assert_eq(offset, 0 as UInt32);
}

@test
fn test_fat_ref_offset_one_is_byte_subslice() {
    // Minimal non-zero offset: one byte into the allocation.
    let offset: UInt32 = 1 as UInt32;
    assert(offset > 0 as UInt32);
}

@test
fn test_fat_ref_reserved_field_zero_init() {
    // The `reserved` field is reserved for future use — current
    // implementations must initialise it to zero so future layout
    // extensions can detect uninitialised consumers.
    let reserved: UInt32 = 0 as UInt32;
    assert_eq(reserved, 0 as UInt32);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
