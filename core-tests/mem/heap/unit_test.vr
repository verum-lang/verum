// =============================================================================
// core-tests/mem/heap/unit_test.vr
// =============================================================================
//
// Per-API tests for `core.mem.heap` — thread-local heap with lock-free
// fast path.  Tests pin constants + the read-only `get_heap_stats`
// surface; live `heap_alloc` / `heap_free` round-trip is covered in
// `core-tests/base/memory/cbgr_test.vr`.
//
// Companion files:
//   property_test.vr     — constant relationships
//   integration_test.vr  — composition with allocator constants
//   regression_test.vr   — pinned defects
//   audit.md             — drift surfaces & action items
// =============================================================================

mount core.prelude.*;
mount core.mem.heap.{
    DIRECT_LOOKUP_SIZE, PAGE_HEADER_SIZE,
    PAGE_FLAG_IN_FULL_QUEUE, PAGE_FLAG_HAS_ALIGNED, PAGE_FLAG_ZERO_INIT,
    HeapStats, HeapError,
    get_heap_stats,
};
mount core.mem.segment.{SegmentError};

// =============================================================================
// Section 1: Heap constants
// =============================================================================

@test
fn test_direct_lookup_size_is_129() {
    // Direct lookup covers wsize 0..128 (129 entries).
    assert_eq(DIRECT_LOOKUP_SIZE, 129);
}

@test
fn test_page_header_size_is_128() {
    // 128-byte page header — cache line aligned for the heap.vr
    // `HeapPageHeader` record.
    assert_eq(PAGE_HEADER_SIZE, 128);
}

@test
fn test_page_flag_in_full_queue() {
    assert_eq(PAGE_FLAG_IN_FULL_QUEUE, 0x0001 as UInt16);
}

@test
fn test_page_flag_has_aligned() {
    assert_eq(PAGE_FLAG_HAS_ALIGNED, 0x0002 as UInt16);
}

@test
fn test_page_flag_zero_init() {
    assert_eq(PAGE_FLAG_ZERO_INIT, 0x0004 as UInt16);
}

@test
fn test_page_flags_pairwise_distinct() {
    let flags: List<UInt16> = [
        PAGE_FLAG_IN_FULL_QUEUE,
        PAGE_FLAG_HAS_ALIGNED,
        PAGE_FLAG_ZERO_INIT,
    ];
    for i in 0..flags.len() {
        for j in 0..flags.len() {
            if i != j {
                assert((flags[i] & flags[j]) == 0 as UInt16);
            }
        }
    }
}

// =============================================================================
// Section 2: get_heap_stats — read-only stats surface
// =============================================================================

@test
fn test_get_heap_stats_returns_value() {
    let _stats: HeapStats = get_heap_stats();
    assert(true);
}

@test
fn test_heap_stats_record_construction() {
    let s = HeapStats {
        alloc_count: 100 as UInt64,
        dealloc_count: 50 as UInt64,
        bytes_allocated: 4096 as UInt64,
        bytes_freed: 1024 as UInt64,
        live_count: 50 as UInt64,
        live_bytes: 3072 as UInt64,
        pages_in_use: 2 as UInt32,
        segments_owned: 1 as UInt32,
    };
    assert_eq(s.alloc_count, 100 as UInt64);
    assert_eq(s.dealloc_count, 50 as UInt64);
    assert_eq(s.bytes_allocated, 4096 as UInt64);
    assert_eq(s.bytes_freed, 1024 as UInt64);
    assert_eq(s.live_count, 50 as UInt64);
    assert_eq(s.live_bytes, 3072 as UInt64);
    assert_eq(s.pages_in_use, 2 as UInt32);
    assert_eq(s.segments_owned, 1 as UInt32);
}

@test
fn test_heap_stats_new_zero_initial() {
    // HeapStats.new() is the zero-initialiser called from LocalHeap.new()
    // during thread-heap bootstrap.  Every counter — including the
    // page / segment book-keeping fields — must start at zero to
    // prevent leakage across thread recycling.
    let s = HeapStats.new();
    assert_eq(s.alloc_count, 0 as UInt64);
    assert_eq(s.dealloc_count, 0 as UInt64);
    assert_eq(s.bytes_allocated, 0 as UInt64);
    assert_eq(s.bytes_freed, 0 as UInt64);
    assert_eq(s.live_count, 0 as UInt64);
    assert_eq(s.live_bytes, 0 as UInt64);
    assert_eq(s.pages_in_use, 0 as UInt32);
    assert_eq(s.segments_owned, 0 as UInt32);
}

// =============================================================================
// Section 3: HeapError variants
// =============================================================================

@test
fn test_heap_error_out_of_memory_construction() {
    let e: HeapError = HeapError.OutOfMemory;
    assert(e is HeapError.OutOfMemory);
}

@test
fn test_heap_error_page_exhausted_construction() {
    let e: HeapError = HeapError.PageExhausted;
    assert(e is HeapError.PageExhausted);
}

@test
fn test_heap_error_invalid_pointer_construction() {
    let e: HeapError = HeapError.InvalidPointer;
    assert(e is HeapError.InvalidPointer);
}

@test
fn test_heap_error_use_after_free_construction() {
    let e: HeapError = HeapError.UseAfterFree;
    assert(e is HeapError.UseAfterFree);
}

@test
fn test_heap_error_invalid_size_construction() {
    let e: HeapError = HeapError.InvalidSize { size: -1 };
    match e {
        HeapError.InvalidSize { size } => assert_eq(size, -1),
        _ => panic("expected InvalidSize variant"),
    }
}

@test
fn test_heap_error_invalid_alignment_construction() {
    let e: HeapError = HeapError.InvalidAlignment { alignment: 7 };
    match e {
        HeapError.InvalidAlignment { alignment } => assert_eq(alignment, 7),
        _ => panic("expected InvalidAlignment variant"),
    }
}

@test
fn test_heap_error_eq_reflexive_oom() {
    let a: HeapError = HeapError.OutOfMemory;
    let b: HeapError = HeapError.OutOfMemory;
    assert(a == b);
}

@test
fn test_heap_error_eq_invalid_size_payload_compared() {
    let a: HeapError = HeapError.InvalidSize { size: 100 };
    let b: HeapError = HeapError.InvalidSize { size: 100 };
    let c: HeapError = HeapError.InvalidSize { size: 200 };
    assert(a == b);
    assert(!(a == c));
    assert(a != c);
}

@test
fn test_heap_error_eq_distinct_variants() {
    let a: HeapError = HeapError.OutOfMemory;
    let b: HeapError = HeapError.PageExhausted;
    assert(!(a == b));
    assert(a != b);
}

@test
fn test_heap_error_message_per_variant() {
    let e1: HeapError = HeapError.OutOfMemory;
    let e2: HeapError = HeapError.PageExhausted;
    let e3: HeapError = HeapError.InvalidPointer;
    let e4: HeapError = HeapError.UseAfterFree;
    assert_eq(e1.message(), "out of memory");
    assert_eq(e2.message(), "page exhausted");
    assert_eq(e3.message(), "invalid pointer");
    assert_eq(e4.message(), "use after free detected");
}

@test
fn test_heap_error_invalid_size_message_carries_payload() {
    // `.message()` formats the payload — required for post-mortem
    // diagnostic output to be actionable.
    let e: HeapError = HeapError.InvalidSize { size: 999_888 };
    assert(e.message().contains("999888"));
}

@test
fn test_heap_error_invalid_alignment_message_carries_payload() {
    let e: HeapError = HeapError.InvalidAlignment { alignment: 33 };
    assert(e.message().contains("33"));
}

@test
fn test_heap_error_segment_error_wrapping() {
    // HeapError.SegmentError wraps a SegmentError — exercise the
    // wrapping path and `.message()` cascade.
    let inner: SegmentError = SegmentError.OutOfMemory;
    let e: HeapError = HeapError.SegmentError { inner: inner };
    assert(e is HeapError.SegmentError);
    let msg = e.message();
    assert(msg.contains("segment error"));
}

@test
fn test_heap_error_from_segment_error_conversion() {
    // `impl From<SegmentError> for HeapError` makes `?` work across
    // the segment->heap boundary — exercise the lift via the
    // variant-payload form which is structurally identical to what
    // the `from` impl emits.  We avoid the bare `HeapError.from(e)`
    // call form because under AOT typechecker the `from` symbol
    // resolves to the variant-payload constructor (taking a record
    // `{ inner: SegmentError }`) rather than the `impl From::from`
    // method — a separate dispatch divergence tracked under #17/#39.
    let inner: SegmentError = SegmentError.OutOfMemory;
    let lifted: HeapError = HeapError.SegmentError { inner: inner };
    assert(lifted is HeapError.SegmentError);
}

// DEFERRED: `HeapError.from(e: SegmentError)` cross-tier dispatch
// divergence — under `--interp`, the bare call resolves to the
// `impl From<SegmentError>` method and round-trips correctly; under
// `--aot`, the typechecker resolves the same expression to the
// `HeapError.SegmentError` variant-payload constructor (expecting
// `{ inner: SegmentError }`, getting bare `SegmentError`) and
// rejects with E400.  Same root as #17/#39 mount-scope-aware
// function lookup.  An `@ignore`'d regression test would still
// trigger the typecheck error and break the whole module, so the
// pin is documented as a comment here until #17/#39 closes.

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
