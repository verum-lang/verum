// =============================================================================
// core-tests/mem/heap/integration_test.vr
// =============================================================================
//
// Integration tests for `core.mem.heap` — the thread-local LocalHeap
// fast-path layer over `cbgr_alloc`.
//
//   §1  Static-shape composition — heap constants line up with sibling
//       allocator / size_class constants.
//   §2  Live heap_alloc round-trip via the public `Heap<T>` surface —
//       `Heap.new(value)` lands in `LocalHeap::alloc` for sizes ≤
//       LARGE_THRESHOLD, exercising the thread-local fast path.
//   §3  Free-list churn — repeated alloc/drop cycles must recycle pages
//       and not exhaust process memory.
// =============================================================================

mount core.prelude.*;
mount core.mem.heap.{DIRECT_LOOKUP_SIZE, PAGE_HEADER_SIZE, HeapStats, HeapError};
mount core.mem.size_class.{SMALL_SIZE_MAX, WORD_SIZE};

// -----------------------------------------------------------------------------
// §1  Static-shape composition
// -----------------------------------------------------------------------------

@test
fn integration_direct_lookup_covers_small_range() {
    // DIRECT_LOOKUP_SIZE = 129 → covers wsize 0..128 → byte range 0..1024.
    // SMALL_SIZE_MAX = 8 KiB → bytes 0..8192 → wsize 0..1024.
    // The direct-lookup window is the FAST PATH for sizes ≤ 1024 bytes;
    // sizes 1025..SMALL_SIZE_MAX still classify as "small" but use the
    // bit-arithmetic slow path.
    let direct_max_bytes = (DIRECT_LOOKUP_SIZE - 1) * WORD_SIZE;
    assert_eq(direct_max_bytes, 1024);
    assert(direct_max_bytes < SMALL_SIZE_MAX);
}

@test
fn integration_page_header_leaves_room() {
    // A 64 KiB page minus a 128-byte header = 65408 usable bytes.
    let page_size: Int = 65536;
    let usable: Int = page_size - PAGE_HEADER_SIZE;
    assert(usable > 65000);
    assert_eq(usable, 65408);
}

// -----------------------------------------------------------------------------
// §2  Live heap_alloc round-trip via Heap<T>
//
// `Heap.new(small_value)` → `cbgr_alloc(layout)` → `LocalHeap::alloc`
// (for sizes ≤ LARGE_THRESHOLD).  The thread-local heap services the
// allocation from its direct-lookup table when wsize ≤ 128.
// -----------------------------------------------------------------------------

@test
fn integration_heap_alloc_via_public_api() {
    let boxed = Heap.new(0xC0FFEE);
    assert_eq(*boxed, 0xC0FFEE);
    assert(boxed.is_valid());
}

@test
fn integration_heap_repeated_alloc_recycles_pages() {
    // 100 alloc/drop cycles — the freelist must recycle slots; if it
    // didn't, repeated allocation would exhaust the page and trip
    // either OOM or a slow path.  We can only observe "no panic", but
    // that's enough to detect a broken freelist.
    for i in 0..100 {
        let _scratch = Heap.new(i);
    }
}

// -----------------------------------------------------------------------------
// §3  Free-list churn across multiple live allocations
// -----------------------------------------------------------------------------

@test
fn integration_multiple_concurrent_heap_allocations() {
    // 8 simultaneously-live Heap allocations.  Each one must come from
    // its own slot — if the allocator returned overlapping pointers, the
    // `*a == 1`, `*b == 2`, etc. assertions would fail.
    let a = Heap.new(1);
    let b = Heap.new(2);
    let c = Heap.new(3);
    let d = Heap.new(4);
    let e = Heap.new(5);
    let f = Heap.new(6);
    let g = Heap.new(7);
    let h = Heap.new(8);

    assert_eq(*a, 1);
    assert_eq(*b, 2);
    assert_eq(*c, 3);
    assert_eq(*d, 4);
    assert_eq(*e, 5);
    assert_eq(*f, 6);
    assert_eq(*g, 7);
    assert_eq(*h, 8);
}

// -----------------------------------------------------------------------------
// §4  HeapStats record algebra — zero-init shape + non-negative-counters
//     pin.  The HeapStats record carries the per-thread observability
//     surface; downstream tools (verum profile, debugger) read these
//     8 fields and depend on the zero-init contract.
// -----------------------------------------------------------------------------

@test
fn integration_heap_stats_new_yields_zero_state() {
    // HeapStats.new() must produce an all-zero record — pin the
    // baseline state that every per-thread heap reports BEFORE the
    // first allocation.
    let s: HeapStats = HeapStats.new();
    assert_eq(s.allocated, 0);
    assert_eq(s.deallocated, 0);
    assert_eq(s.bytes_allocated, 0);
    assert_eq(s.bytes_deallocated, 0);
    assert_eq(s.peak_bytes, 0);
    assert_eq(s.pages_allocated, 0);
    assert_eq(s.pages_freed, 0);
    assert_eq(s.cache_hits, 0);
}

@test
fn integration_heap_stats_zero_state_live_count_zero() {
    // At zero state, the live-allocation count is zero. This is the
    // load-bearing invariant for any per-thread heap observer: when
    // there have been no allocations, there are no live allocations.
    let s: HeapStats = HeapStats.new();
    assert_eq(s.allocated - s.deallocated, 0);
}

@test
fn integration_heap_stats_zero_state_bytes_outstanding_zero() {
    // At zero state, outstanding bytes (bytes_allocated -
    // bytes_deallocated) is zero. Pinned for parity with the
    // live-count zero invariant.
    let s: HeapStats = HeapStats.new();
    assert_eq(s.bytes_allocated - s.bytes_deallocated, 0);
    assert_eq(s.peak_bytes, 0);
}

@test
fn integration_heap_stats_zero_state_no_pages_or_cache_activity() {
    // At zero state, no pages have been allocated or freed, no cache
    // hits accrued. Pins the full 8-field zero baseline (4 of the 8
    // fields exercised here; the other 4 are in the _zero_state test).
    let s: HeapStats = HeapStats.new();
    assert_eq(s.pages_allocated, 0);
    assert_eq(s.pages_freed, 0);
    assert_eq(s.cache_hits, 0);
}

// -----------------------------------------------------------------------------
// §5  Constants drift surface — DIRECT_LOOKUP_SIZE and PAGE_HEADER_SIZE
//     are load-bearing primitives; pin them against unintended drift.
// -----------------------------------------------------------------------------

@test
fn integration_direct_lookup_size_positive_and_bounded() {
    // DIRECT_LOOKUP_SIZE must be in a sane range: > 0 (otherwise no
    // fast-path table) and <= 256 (otherwise the table consumes too
    // much L1 cache for the small-alloc hot path).
    assert(DIRECT_LOOKUP_SIZE > 0);
    assert(DIRECT_LOOKUP_SIZE <= 256);
    // Current pinned value is 129.
    assert_eq(DIRECT_LOOKUP_SIZE, 129);
}

@test
fn integration_page_header_size_aligned_to_cache_line() {
    // PAGE_HEADER_SIZE must be a multiple of 64 bytes (typical L1 cache
    // line size on modern CPUs) so the page payload starts on a
    // cache-aligned boundary.  Current pinned value is 128 (= 2 cache lines).
    assert(PAGE_HEADER_SIZE > 0);
    assert(PAGE_HEADER_SIZE % 64 == 0);
    assert_eq(PAGE_HEADER_SIZE, 128);
}

fn main() {
    // `verum test` synthesises a per-test main.
}
