// =============================================================================
// core-tests/mem/size_class/integration_test.vr
// =============================================================================
//
// Integration tests: size_class composed with header/allocator sizing,
// PageKind dispatch, and the standard allocator request shapes coming
// out of the rest of the stdlib.
// =============================================================================

mount core.prelude.*;
mount core.mem.size_class.{
    BIN_COUNT, BIN_HUGE, SIZE_CLASSES,
    SMALL_SIZE_MAX, MEDIUM_SIZE_MAX,
    size_to_bin, bin_to_size,
    is_small_size, is_medium_size,
    page_kind_for_bin, page_size_for_bin,
    blocks_per_page,
    aligned_size,
    Small, Medium, Large, Huge,
};

// -----------------------------------------------------------------------------
// §1  Allocator request shape: every allocation comes in as
//     (size, align) and ends up dispatched through size_to_bin.
// -----------------------------------------------------------------------------

@test
fn integration_alloc_request_dispatch_consistent() {
    // Probe the common "small object" sizes — headers, list nodes, etc.
    let common_sizes: List<Int> = [
        8,    // single i64
        16,   // pair of i64 / ThinRef body
        24,   // header sub-slot
        32,   // CBGR AllocationHeader
        40, 48, 56, 64,    // exact small bins
        80, 96, 128,
        256, 512, 1024,
    ];
    for s in common_sizes.iter() {
        let bin = size_to_bin(*s);
        let bsize = bin_to_size(bin);
        // The chosen bin can fit the requested size.
        assert(bsize >= *s);
        // The bin size class is small.
        assert(is_small_size(bsize));
        // The page-kind is Small.
        assert(page_kind_for_bin(bin) is Small);
    }
}

// -----------------------------------------------------------------------------
// §2  CBGR header (32 bytes) lands in bin 3.
// -----------------------------------------------------------------------------

@test
fn integration_cbgr_header_size_lands_in_bin_three() {
    // AllocationHeader is documented as 32 bytes.  bin 3 = 32-byte slot.
    assert_eq(size_to_bin(32), 3);
    assert_eq(bin_to_size(3), 32);
}

// -----------------------------------------------------------------------------
// §3  ThinRef (16 bytes) lands in bin 1.
// -----------------------------------------------------------------------------

@test
fn integration_thin_ref_size_lands_in_bin_one() {
    assert_eq(size_to_bin(16), 1);
    assert_eq(bin_to_size(1), 16);
}

// -----------------------------------------------------------------------------
// §4  FatRef (32 bytes) lands in bin 3 — same as the header.
// -----------------------------------------------------------------------------

@test
fn integration_fat_ref_size_lands_in_bin_three() {
    assert_eq(size_to_bin(32), 3);
}

// -----------------------------------------------------------------------------
// §5  blocks_per_page × bin_size is page-bounded.
// -----------------------------------------------------------------------------

@test
fn integration_blocks_per_page_bounded_by_page_size() {
    // For every bin, blocks_per_page * bin_size + page_header ≤ page_size.
    let header_size: Int = 64;
    let mut b: Int = 0;
    while b < BIN_COUNT {
        let bsize = bin_to_size(b);
        let bcount = blocks_per_page(b);
        let psize = page_size_for_bin(b);
        let total_used = bcount * bsize + header_size;
        assert(total_used <= psize);
        b = b + 1;
    }
}

// -----------------------------------------------------------------------------
// §6  aligned_size + size_to_bin composition.
// -----------------------------------------------------------------------------

@test
fn integration_aligned_size_then_size_to_bin_consistent() {
    // For align ≤ MAX_ALIGN_SIZE (16), aligned_size is identity, so the
    // bin choice is identical to that of the raw size.
    let aligned = aligned_size(100, 16);
    assert_eq(aligned, 100);
    assert_eq(size_to_bin(aligned), size_to_bin(100));
}

@test
fn integration_aligned_size_large_align_pushes_bin_up() {
    // For align > MAX_ALIGN_SIZE, aligned_size adds padding which can
    // bump the size into a larger bin.
    let raw: Int = 100;
    let padded = aligned_size(raw, 64);    // 100 + 63 = 163 bytes
    let bin_raw = size_to_bin(raw);
    let bin_padded = size_to_bin(padded);
    // Padded version must use the same or a larger bin.
    assert(bin_padded >= bin_raw);
}

// -----------------------------------------------------------------------------
// §7  Probe ranges: small/medium/large each map to distinct page tiers.
// -----------------------------------------------------------------------------

@test
fn integration_tier_disjoint_for_distinct_size_classes() {
    // Pick three sizes — one in each tier — and verify they land in
    // distinct page-kind buckets.
    let small_size: Int = 100;        // → Small
    let medium_size: Int = 10240;     // → Medium
    let large_size: Int = 100000;     // → Large

    let small_bin = size_to_bin(small_size);
    let medium_bin = size_to_bin(medium_size);
    let large_bin = size_to_bin(large_size);

    assert(page_kind_for_bin(small_bin) is Small);
    assert(page_kind_for_bin(medium_bin) is Medium);
    assert(page_kind_for_bin(large_bin) is Large);
}

// -----------------------------------------------------------------------------
// §8  Huge allocations route to BIN_HUGE and Huge page kind.
// -----------------------------------------------------------------------------

@test
fn integration_huge_size_routes_to_huge_bin() {
    let huge: Int = 8 * 1024 * 1024;   // 8 MiB → above 5 MiB threshold
    let bin = size_to_bin(huge);
    // Either BIN_HUGE or out-of-table — either way is "huge".
    assert(bin >= BIN_HUGE - 1);   // tolerate 72 (top regular) or 73 (huge)
}

// -----------------------------------------------------------------------------
// §9  Aligned-size monotonicity — `aligned_size(s, a) >= s` for every
//     (s, a) where a is a power of 2. The aligned size is the smallest
//     multiple of a that is >= s.
// -----------------------------------------------------------------------------

@test
fn integration_aligned_size_passthrough_for_standard_alignment() {
    // For alignments <= MAX_ALIGN_SIZE (16, the standard 16-byte
    // boundary), aligned_size returns size unchanged because the
    // size class itself already satisfies alignment.  Pins the
    // mimalloc-style invariant that small-alignment allocations
    // never pay an alignment-overhead cost.
    let pairs: List<(Int, Int)> = [
        (8, 1), (8, 2), (8, 4), (8, 8), (8, 16),
        (9, 8), (15, 8), (16, 8), (17, 8), (24, 8),
        (32, 16), (64, 16), (256, 16),
    ];
    for pair in pairs.iter() {
        let s: Int = pair.0;
        let a: Int = pair.1;
        let aligned = aligned_size(s, a);
        // For align <= MAX_ALIGN_SIZE=16, returns size unchanged.
        assert_eq(aligned, s);
    }
}

@test
fn integration_aligned_size_overhead_for_oversized_alignment() {
    // For alignments > MAX_ALIGN_SIZE=16, aligned_size adds (align - 1)
    // bytes of slack — pin the "size + align - 1" upper bound that
    // the allocator uses to over-reserve and then align the returned
    // pointer.
    let pairs: List<(Int, Int)> = [
        (8, 32), (16, 32), (64, 32),
        (8, 64), (16, 64), (256, 64),
        (8, 256), (256, 256), (4096, 256),
    ];
    for pair in pairs.iter() {
        let s: Int = pair.0;
        let a: Int = pair.1;
        let aligned = aligned_size(s, a);
        assert_eq(aligned, s + a - 1);
    }
}

// -----------------------------------------------------------------------------
// §10  Round-trip law: size_to_bin · bin_to_size is monotonic and
//      idempotent on bin domain.
// -----------------------------------------------------------------------------

@test
fn integration_round_trip_idempotent_on_canonical_bin_sizes() {
    // Every canonical bin's size, when re-mapped to a bin, must yield
    // the same bin id. This pins the bin-to-size table's lossless
    // round-trip on its canonical entries.
    let probe_sizes: List<Int> = [8, 16, 32, 64, 128, 256, 512, 1024, 2048];
    for s in probe_sizes.iter() {
        let bin = size_to_bin(*s);
        let bin_size = bin_to_size(bin);
        let bin2 = size_to_bin(bin_size);
        // bin2 == bin: the round-trip lands at the same bin id.
        assert_eq(bin2, bin);
    }
}

@test
fn integration_size_to_bin_monotonic_over_doubling() {
    // For increasing sizes 1, 2, 4, 8, ..., 1024, size_to_bin must be
    // non-decreasing. This is a consequence of the bin table's
    // monotonic structure (~12.5% spacing).
    let doublings: List<Int> = [1, 2, 4, 8, 16, 32, 64, 128, 256, 512, 1024];
    let mut prev_bin: Int = -1;
    for s in doublings.iter() {
        let bin = size_to_bin(*s);
        assert(bin >= prev_bin);
        prev_bin = bin;
    }
}

// -----------------------------------------------------------------------------
// §11  Page-layout consistency: blocks_per_page is at least 1 for
//      small bins (every page must hold at least one block of the
//      bin's size class). This is the load-bearing minimum invariant
//      for the free-list allocator.
// -----------------------------------------------------------------------------

@test
fn integration_blocks_per_page_at_least_one_for_small_bins() {
    // For the first 30 bins (covering small-size class — bins 0..30
    // are all sub-1024-byte blocks), every page must hold at least one
    // block of the bin's size class.
    let probe_bins: List<Int> = [0, 1, 2, 5, 10, 15, 20, 25, 30];
    for b in probe_bins.iter() {
        let blocks = blocks_per_page(*b);
        assert(blocks >= 1);
    }
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
