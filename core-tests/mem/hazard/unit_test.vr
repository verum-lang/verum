// =============================================================================
// core-tests/mem/hazard/unit_test.vr
// =============================================================================
//
// Per-API tests for `core.mem.hazard` — hazard pointer system for
// concurrent-safe dereferences.  Tests pin constants + the read-only
// `hazard_stats` and `cleanup_thread_hazards` surface; live
// acquire_hazard / retire_hazard round-trip is covered in
// `core-tests/base/memory/cbgr_test.vr`.
//
// Companion files:
//   property_test.vr     — constant relationships
//   integration_test.vr  — composition with capability
//   regression_test.vr   — pinned defects
//   audit.md             — drift surfaces & action items
// =============================================================================

mount core.prelude.*;
mount core.mem.hazard.{
    HAZARD_POINTERS_PER_THREAD, RETIRED_THRESHOLD, MAX_THREADS,
    HazardStats,
    hazard_stats, force_reclaim_all, cleanup_thread_hazards,
};

// =============================================================================
// Section 1: Hazard constants
// =============================================================================

@test
fn test_hazard_pointers_per_thread_is_8() {
    // Each thread reserves 8 hazard slots — sufficient for typical
    // concurrent-deref patterns.
    assert_eq(HAZARD_POINTERS_PER_THREAD, 8);
}

@test
fn test_retired_threshold_is_64() {
    // Reclamation triggers when a thread accumulates 64 retired refs.
    assert_eq(RETIRED_THRESHOLD, 64);
}

@test
fn test_max_threads_is_256() {
    // Hazard domain supports up to 256 threads.
    assert_eq(MAX_THREADS, 256);
}

// =============================================================================
// Section 2: hazard_stats — read-only stats surface
// =============================================================================

// REGRESSION: `hazard_stats()` reaches into the static-mut record
// `GLOBAL_HAZARD_DOMAIN` via a method-receiver implicit-self load
// (`GLOBAL_HAZARD_DOMAIN.scan_hazards()`).  The current static-mut
// backing (`InterpreterState::static_mut_cell_addr`, Task #26 [E2])
// allocates an 8-byte cell only for scalar `static mut`s, not for
// record-typed ones, so `&self` materialises as a null pointer and
// the first GetF (opcode 0x62) inside scan_hazards null-derefs at
// pc=144 with `NullPointerAt { op: "opcode 0x62", site:
// "HazardDomain.scan_hazards" }`.  Fundamental fix tracked in
// `audit.md` §3.3 — extend the cell allocator to handle record-typed
// `static mut` with per-field offset materialisation, OR refactor
// the access pattern in hazard.vr to use scalar field-by-field
// reads through individual `StaticMutAddr` ops.
@test
@ignore
fn test_hazard_stats_returns_value() {
    let _stats: HazardStats = hazard_stats();
    assert(true);
}

@test
@ignore
fn test_hazard_stats_initial_state_is_zero() {
    let s: HazardStats = hazard_stats();
    assert(s.protected_count >= 0);
    assert(s.retired_count >= 0);
    assert(s.thread_count >= 0);
}

@test
fn test_hazard_stats_record_construction() {
    // Pin the 3-field shape via direct record-literal round-trip so
    // any future layout reshuffle (e.g. adding a fourth counter) is
    // caught as a compile-time break here.
    let s: HazardStats = HazardStats {
        protected_count: 3,
        retired_count:   7,
        thread_count:    2,
    };
    assert_eq(s.protected_count, 3);
    assert_eq(s.retired_count, 7);
    assert_eq(s.thread_count, 2);
}

// =============================================================================
// Section 3: HazardStats.needs_reclaim — RETIRED_THRESHOLD boundary
// =============================================================================

@test
fn test_hazard_stats_needs_reclaim_below_threshold_is_false() {
    let s: HazardStats = HazardStats {
        protected_count: 0,
        retired_count:   RETIRED_THRESHOLD - 1,
        thread_count:    1,
    };
    assert(!s.needs_reclaim());
}

@test
fn test_hazard_stats_needs_reclaim_at_threshold_is_true() {
    // The predicate uses `>=`, so reaching exactly the threshold
    // must trigger reclamation.
    let s: HazardStats = HazardStats {
        protected_count: 0,
        retired_count:   RETIRED_THRESHOLD,
        thread_count:    1,
    };
    assert(s.needs_reclaim());
}

@test
fn test_hazard_stats_needs_reclaim_above_threshold_is_true() {
    let s: HazardStats = HazardStats {
        protected_count: 0,
        retired_count:   RETIRED_THRESHOLD + 16,
        thread_count:    1,
    };
    assert(s.needs_reclaim());
}

@test
fn test_hazard_stats_needs_reclaim_zero_is_false() {
    let s: HazardStats = HazardStats {
        protected_count: 0,
        retired_count:   0,
        thread_count:    0,
    };
    assert(!s.needs_reclaim());
}

// =============================================================================
// Section 4: HazardStats.estimated_retired_bytes — product invariant
// =============================================================================

@test
fn test_hazard_stats_estimated_retired_bytes_is_product() {
    // The estimator returns `retired_count * avg_size`, a pure
    // multiplication — pin a small representative product.
    let s: HazardStats = HazardStats {
        protected_count: 0,
        retired_count:   10,
        thread_count:    1,
    };
    assert_eq(s.estimated_retired_bytes(64),   10 * 64);
    assert_eq(s.estimated_retired_bytes(128),  10 * 128);
    assert_eq(s.estimated_retired_bytes(4096), 10 * 4096);
}

@test
fn test_hazard_stats_estimated_retired_bytes_zero_inputs() {
    // Either factor being zero yields zero — important for the
    // empty-state diagnostic dump.
    let s_zero_count: HazardStats = HazardStats {
        protected_count: 0,
        retired_count:   0,
        thread_count:    0,
    };
    assert_eq(s_zero_count.estimated_retired_bytes(128), 0);

    let s_zero_avg: HazardStats = HazardStats {
        protected_count: 0,
        retired_count:   16,
        thread_count:    1,
    };
    assert_eq(s_zero_avg.estimated_retired_bytes(0), 0);
}

// =============================================================================
// Section 3: force_reclaim_all — fire-and-forget
// =============================================================================
//
// Pre-fix `force_reclaim_all()` panicked with
//   `NullPointerAt { op: "opcode 0x62", site: "HazardDomain.scan_hazards", pc: 120 }`
// on a fresh process — the global `HazardDomain.head` was null before
// any thread registered, and `scan_hazards` did `List.with_capacity(0)`
// + `sort`/`dedup` on the resulting empty list which triggered the
// null-deref.  Fixed by E1: empty-state early-return in scan_hazards
// when `thread_count == 0`.

@test
fn test_force_reclaim_all_returns_unit() {
    force_reclaim_all();
    assert(true);
}

// =============================================================================
// Section 4: cleanup_thread_hazards — fire-and-forget
// =============================================================================

@test
fn test_cleanup_thread_hazards_returns_unit() {
    cleanup_thread_hazards();
    assert(true);
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
