// =============================================================================
// core-tests/mem/arena/integration_test.vr
// =============================================================================
//
// Integration tests for `core.mem.arena` — the generational bump-pointer
// arena allocator with O(1) mass invalidation.
//
//   §1  Static-shape composition — arena constants line up with the CBGR
//       generation lattice.
//   §2  Live arena lifecycle — `new` → `alloc` → `reset` → `alloc again`
//       → `destroy`.  Exercises bump-pointer allocation, generation
//       bump on reset, and is_destroyed flag on destroy.
//
// Live arena lifecycle tests run unconditionally as of task #8 close
// (2026-05-24).  The fundamental fix lives at
// `crates/verum_vbc/src/interpreter/dispatch_table/handlers/log_extended.rs::handle_mem_extended`
// where `_operand_len` is now authoritative — the handler force-aligns
// PC to `operand_start + operand_len` after the sub-op handler returns,
// tolerating short-operand emissions from intrinsic calls whose Verum
// signature binds a subset of the registry's declared params (the
// canonical example is `__alloc_zeroed_raw(size)` against the
// 2-param `alloc_zeroed(size, align)` registry intrinsic).
// =============================================================================

mount core.prelude.*;
mount core.mem.arena.{
    DEFAULT_ARENA_CAPACITY, MAX_ARENA_CAPACITY, ARENA_ALIGNMENT,
    ArenaConfig, GenerationalArena,
};
mount core.mem.header.{GEN_INITIAL, GEN_MAX};

// -----------------------------------------------------------------------------
// §0  Probe — does cross-module constructor + field access work for the
//     sibling ArenaConfig record?  This diagnostic narrows down whether
//     the GenerationalArena GetF NullPointer is a record-allocation
//     issue or a method-dispatch issue.
// -----------------------------------------------------------------------------

@test
fn probe_arenaconfig_default_field_access() {
    let cfg = ArenaConfig.default();
    // Direct field read on a record returned from a cross-module
    // constructor.  If this fails, the defect is in record-return
    // path.  If this passes but GenerationalArena fails, the defect
    // is specific to GenerationalArena's 7-field layout or its
    // method dispatch.
    assert_eq(cfg.initial_capacity, DEFAULT_ARENA_CAPACITY);
    assert(cfg.max_capacity >= cfg.initial_capacity);
    assert(cfg.growth_factor > 100);
}

@test
fn probe_arenaconfig_fixed_field_access() {
    let cfg = ArenaConfig.fixed(2048);
    assert_eq(cfg.initial_capacity, 2048);
    assert_eq(cfg.max_capacity, 2048);
    assert_eq(cfg.growth_factor, 100);
}

// Probe: bypass the method, read the field directly.  Closed by
// task #8 fundamental fix (commit forthcoming) — handler-side
// `_operand_len`-bounded PC advancement in
// `interpreter/dispatch_table/handlers/log_extended.rs::handle_mem_extended`
// realigns past `__alloc_zeroed_raw(size)`'s short-operand emission,
// which was desynchronising the PC for the rest of the
// `GenerationalArena.new` body and surfacing as a downstream
// `NullPointer` at the first `SetF`.
@test
fn probe_generationalarena_direct_field_read() {
    let arena = GenerationalArena.new(1024);
    let c = arena.capacity;
    assert(c >= 1024);
}

// Probe: a USER-DEFINED 7-field record with the same shape as
// GenerationalArena (Int fields + nested record).  If this works,
// the defect is specific to the precompiled-stdlib representation
// of GenerationalArena (function-id remap or field-layout
// registration drift).  If this also fails, the defect is in the
// 7-field MakeRecord path itself.
type ProbeArenaShape is {
    buffer: Int,
    capacity: Int,
    used: Int,
    generation: Int,
    alloc_count: Int,
    reset_count: Int,
    config: Int,    // simplified: nested-record stand-in
};

@test
fn probe_user_seven_field_record_field_access() {
    let r = ProbeArenaShape {
        buffer: 100,
        capacity: 1024,
        used: 0,
        generation: 1,
        alloc_count: 0,
        reset_count: 0,
        config: 42,
    };
    assert_eq(r.capacity, 1024);
    assert_eq(r.config, 42);
}

// Probe: replicate GenerationalArena's pattern of including a nested
// stdlib record field initialised via cross-module constructor.  This
// pinpoints whether the defect lives in record-literal construction
// where one of the slots is itself a fresh cross-module-built record.
type ProbeWithNestedConstructor is {
    a: Int,
    b: Int,
    cfg: ArenaConfig,
};

@test
fn probe_user_record_with_nested_constructor_field() {
    let r = ProbeWithNestedConstructor {
        a: 11,
        b: 22,
        cfg: ArenaConfig.default(),
    };
    assert_eq(r.a, 11);
    assert_eq(r.b, 22);
    assert(r.cfg.initial_capacity > 0);
}

// Probe: alternative constructor `with_config` builds the same
// GenerationalArena from an explicit ArenaConfig.  If it ALSO
// fails, the defect is in EVERY GenerationalArena constructor (i.e.
// in the precompiled stdlib's representation of the type itself).
// If it WORKS, the defect is specific to `new(capacity: Int)` —
// most likely because its body contains `__alloc_zeroed_raw` AND
// `ArenaConfig.fixed(...)` inside the record-literal initializer.
@test
fn probe_arena_with_config_constructor() {
    // Closed by task #8 fundamental fix — same `__alloc_zeroed_raw`-
    // induced PC desync as `probe_generationalarena_direct_field_read`
    // above.  `with_config` historically failed at SetF (opcode 0x63)
    // PC 88 inside the body; the handler-side `operand_end`-forcing
    // PC fix-up in `handle_mem_extended` realigns the stream and the
    // record allocation succeeds.
    let arena = GenerationalArena.with_config(ArenaConfig.default());
    let c = arena.capacity();
    assert(c > 0);
}

// -----------------------------------------------------------------------------
// §1  Static-shape composition (always-green)
// -----------------------------------------------------------------------------

@test
fn integration_default_arena_config_valid() {
    let config: ArenaConfig = ArenaConfig {
        initial_capacity: DEFAULT_ARENA_CAPACITY,
        max_capacity: MAX_ARENA_CAPACITY,
        growth_factor: 200,
    };
    assert(config.initial_capacity <= config.max_capacity);
    assert(config.growth_factor > 100);   // > 1x growth
    // Alignment is a module constant, not a config field — pin separately.
    assert(ARENA_ALIGNMENT > 0);
}

@test
fn integration_arena_uses_same_generation_lattice() {
    // The arena's generation counter shares the same GEN_INITIAL → GEN_MAX
    // → wraparound semantics as individual allocations.  Pin the constants.
    assert_eq(GEN_INITIAL, 1 as UInt32);
    assert(GEN_INITIAL < GEN_MAX);
}

@test
fn integration_arena_alignment_matches_word_size() {
    // 8-byte alignment = 64-bit word alignment, matching all CBGR
    // pointer-sized fields.
    assert_eq(ARENA_ALIGNMENT, 8);
}

// -----------------------------------------------------------------------------
// §2  Live arena lifecycle — CLOSED by task #8 (2026-05-24)
//
// Pre-close failure: every `&self` method on a fresh
// `GenerationalArena.new(N)` panicked with `NullPointerAt opcode 0x62
// (GetF)` at PC 0 of the method — the receiver materialised as a null
// pointer because the `New { type_id, field_count }` allocation inside
// the constructor's body never completed.  The root cause was a
// PC-desync in `handle_mem_extended` (logged at
// `interpreter/dispatch_table/handlers/log_extended.rs`): the AllocZeroed
// sub-op read THREE register operands while the codegen for the
// 1-arg `__alloc_zeroed_raw(size)` Verum signature emitted only TWO
// — handler read one byte past the instruction boundary, the next
// `New` opcode decoded from a misaligned offset, the resulting object
// pointer was non-pointer garbage, and the first `SetF` on it
// null-derefed.
//
// Fundamental fix: `handle_mem_extended` now treats `_operand_len`
// as authoritative and force-realigns PC to `operand_start +
// operand_len` after the sub-op handler returns.  Tolerates any
// short-operand emission from intrinsics whose Verum signature
// binds a subset of the registry's declared params.
// -----------------------------------------------------------------------------

@test
fn integration_arena_new_initial_state() {
    let arena = GenerationalArena.new(1024);
    // Fresh arena: 0 bytes used, 0 allocations.
    assert_eq(arena.used(), 0);
    assert_eq(arena.alloc_count(), 0);
    assert_eq(arena.reset_count(), 0);
    assert(arena.capacity() >= 1024);
    assert(!arena.is_destroyed());
}

@test
fn integration_arena_new_capacity_only() {
    let arena = GenerationalArena.new(1024);
    let c = arena.capacity();
    assert(c >= 1024);
}

@test
fn integration_arena_alloc_advances_used() {
    let mut arena = GenerationalArena.new(1024);
    let ptr = arena.alloc(64);
    // Successful allocation returns a non-zero pointer.
    assert(ptr != 0);
    // bump-pointer arithmetic: used is at least 64 bytes (more after
    // alignment rounding).
    assert(arena.used() >= 64);
    assert_eq(arena.alloc_count(), 1);
}

@test
fn integration_arena_reset_bumps_generation() {
    let mut arena = GenerationalArena.new(1024);
    let gen_before = arena.generation();
    let _p1 = arena.alloc(32);
    let _p2 = arena.alloc(32);
    arena.reset();
    // reset bumps the generation counter — every ref allocated pre-reset
    // is now invalidated.
    assert(arena.generation() > gen_before);
    // used counter is rewound for memory reuse.
    assert_eq(arena.used(), 0);
    assert_eq(arena.reset_count(), 1);
}

@test
fn integration_arena_reset_does_not_decrease_capacity() {
    let mut arena = GenerationalArena.new(1024);
    let cap_before = arena.capacity();
    let _p = arena.alloc(64);
    arena.reset();
    // Memory is NOT freed on reset — only on destroy.  Capacity holds.
    assert_eq(arena.capacity(), cap_before);
}

@test
fn integration_arena_destroy_marks_arena_dead() {
    let mut arena = GenerationalArena.new(1024);
    let _p = arena.alloc(64);
    arena.destroy();
    assert(arena.is_destroyed());
    // Post-destroy alloc is a no-op returning 0.
    let p2 = arena.alloc(32);
    assert_eq(p2, 0);
}

@test
fn integration_arena_repeated_alloc_increments_counter() {
    let mut arena = GenerationalArena.new(2048);
    for _i in 0..16 {
        let _p = arena.alloc(64);
    }
    assert_eq(arena.alloc_count(), 16);
    assert(arena.used() >= 1024);
}

@test
fn integration_arena_reset_reuses_memory() {
    let mut arena = GenerationalArena.new(1024);
    let p_before = arena.alloc(32);
    arena.reset();
    let p_after = arena.alloc(32);
    // After reset, the next alloc must start at the buffer base —
    // identical raw pointer.
    assert_eq(p_before, p_after);
}

@test
fn integration_arena_snapshot_captures_state() {
    let mut arena = GenerationalArena.new(1024);
    let _p1 = arena.alloc(64);
    let _p2 = arena.alloc(64);
    let snap = arena.snapshot();
    let used_at_snap = arena.used();
    let gen_at_snap = arena.generation();
    let _p3 = arena.alloc(64);
    assert(arena.used() > used_at_snap);
    let ok = arena.restore(snap);
    assert(ok);
    assert_eq(arena.used(), used_at_snap);
    assert_eq(arena.generation(), gen_at_snap);
}

fn main() {
    // `verum test` synthesises a per-test main.
}
