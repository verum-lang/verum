// =============================================================================
// core-tests/mem/arena/regression_test.vr
// =============================================================================
//
// Pinned regressions for `core.mem.arena`.
//
//   §A  DEFAULT_ARENA_CAPACITY = 64 KiB.  Pre-fix some drafts used
//       4 KiB (single page) which made the default arena too small
//       for typical AST / per-request scenarios.
//   §B  MAX_ARENA_CAPACITY = 256 MiB.  Hard cap to prevent unbounded
//       memory growth.
//   §C  ARENA_ALIGNMENT = 8 (64-bit word).  Pre-fix some drafts used
//       4 (32-bit) which broke alignment for u64 / pointer fields.
//   §D  Task #8 — `GenerationalArena.new(N)` returns a non-pointer
//       Value; every subsequent `&self` method (capacity / used /
//       generation / is_destroyed / …) AND every direct field access
//       fails at `GetF` (opcode 0x62) with `NullPointerAt`.  Diagnostic
//       evidence in `integration_test.vr` §0:
//         (a) sibling `ArenaConfig.default()` / `.fixed(N)` cross-
//             module constructors work fine (3-field record, no
//             nested record).
//         (b) a user-defined 7-Int-field record works fine.
//         (c) `GenerationalArena.new(N)` (7-field record with a
//             nested `ArenaConfig` field built via cross-module
//             constructor `ArenaConfig.fixed(N)`) is the failing
//             shape.
//       Hypothesis: when a record literal's slot is itself a fresh
//       cross-module constructor call AND the enclosing record was
//       loaded from the precompiled stdlib archive, the resulting
//       Value is mis-encoded.  Pinned `@ignore`'d below until #8
//       closes; the moment it does, both pins flip active.
// =============================================================================

mount core.prelude.*;
mount core.mem.arena.{
    DEFAULT_ARENA_CAPACITY, MAX_ARENA_CAPACITY, ARENA_ALIGNMENT,
    GenerationalArena,
};

@test
fn regression_default_capacity_is_64_kib() {
    assert_eq(DEFAULT_ARENA_CAPACITY, 65536);
}

@test
fn regression_max_capacity_is_256_mib() {
    assert_eq(MAX_ARENA_CAPACITY, 268435456);
}

@test
fn regression_alignment_is_8_bytes() {
    assert_eq(ARENA_ALIGNMENT, 8);
}

// REGRESSION: task #8 — CLOSED 2026-05-24.  Pre-close failure was
// `NullPointer` at the first `SetF` inside `GenerationalArena.new`'s
// body, caused by a PC-desync in `handle_mem_extended` AllocZeroed
// sub-op which read 3 register operands while the 1-arg
// `__alloc_zeroed_raw(size)` codegen emitted only 2.  Fix:
// `interpreter/dispatch_table/handlers/log_extended.rs::handle_mem_extended`
// now treats `_operand_len` as authoritative and force-realigns PC
// to `operand_start + operand_len` after the sub-op handler returns.
// Both round-trip and direct-field tests pin the closed contract.
@test
fn regression_task_8_generational_arena_constructor_round_trip() {
    let arena = GenerationalArena.new(1024);
    let c = arena.capacity();
    assert(c >= 1024);
}

@test
fn regression_task_8_generational_arena_direct_field() {
    let arena = GenerationalArena.new(1024);
    let c = arena.capacity;
    assert(c >= 1024);
}

fn main() {
    // `verum test` synthesises a per-test main.
}
