// =============================================================================
// core-tests/mem/cap_audit_ring/unit_test.vr
// =============================================================================
//
// Per-API tests for `core.mem.cap_audit_ring` — the lock-free SPMC ring
// buffer that stores CapEvent records for forensic observers.
//
// Companion files:
//   property_test.vr     — ring-buffer monotonicity & ordering laws
//   integration_test.vr  — composition with the record_* writers
//   regression_test.vr   — pinned defects
//   audit.md             — drift surfaces & action items
// =============================================================================

mount core.prelude.*;
mount core.mem.cap_audit_ring.{
    CAP_AUDIT_RING_CAPACITY,
    commit, recent, count, enable, disable, is_enabled,
    reset_for_tests,
    record_revoke, record_attenuate, record_ref_incr, record_ref_decr,
    record_gen_bump, record_epoch_advance,
};
mount core.mem.cap_audit.{CapEventKind, CapEvent};

// =============================================================================
// Section 1: Module constants
// =============================================================================

@test
fn test_cap_audit_ring_capacity_is_256() {
    // 256 slots × ~64-byte CapEvent ≈ 16 KiB ring.  Pin the size so
    // observers and forensic tools that hardcode the window-size
    // assumption cannot drift.
    assert_eq(CAP_AUDIT_RING_CAPACITY, 256);
}

// =============================================================================
// Section 2: enable / disable / is_enabled state machine
// =============================================================================
//
// E2 CLOSED 2026-05-16 — `static mut` no longer dereferences a bogus
// CBGR-Ref bit-pattern on `&STATIC_MUT as *mut T`.  Fix lands in three
// sites:
//   (1) New `SystemSubOpcode::StaticMutAddr` (0x52) in
//       `crates/verum_vbc/src/instruction.rs`.
//   (2) `InterpreterState::static_mut_cells:
//       HashMap<u16, Box<UnsafeCell<u64>>>` with lazy cell allocation
//       on first `handle_static_mut_addr` dispatch.
//   (3) Codegen helper `try_compile_static_mut_addr` in
//       `crates/verum_vbc/src/codegen/expressions.rs::compile_cast`,
//       sibling of `try_compile_struct_field_addr`, detects
//       `&IDENT as *T` where IDENT is in `thread_local_vars`.
//
// Pre-fix `enable()` / `disable()` / `is_enabled()` SIGSEGV'd the
// interpreter dereferencing 0xfffffffdfffffffd (the CBGR-Ref
// bit-pattern decoded as a raw pointer in `handle_atomic_store`).

@test
fn test_audit_enable_disable_toggles_state() {
    let initial = is_enabled();
    enable();
    assert(is_enabled());
    disable();
    assert(!is_enabled());
    if initial { enable(); } else { disable(); }
}

@test
fn test_audit_disable_after_enable_is_disabled() {
    enable();
    disable();
    assert(!is_enabled());
}

@test
fn test_audit_enable_after_disable_is_enabled() {
    disable();
    enable();
    assert(is_enabled());
    disable();
}

// =============================================================================
// Section 3: reset_for_tests — test-isolation primitive
// =============================================================================

@test
fn test_reset_for_tests_returns_unit() {
    // Fire-and-forget — verify no panic.
    reset_for_tests();
    assert(true);
}

// =============================================================================
// Section 4: count — monotonic event counter
// =============================================================================

@test
fn test_count_returns_uint64() {
    let c: UInt64 = count();
    assert(c >= 0 as UInt64);
}

// =============================================================================
// Section 5: recent(n) — returns at most n events
// =============================================================================

@test
fn test_recent_returns_at_most_n_events() {
    let events = recent(10);
    assert(events.len() <= 10);
}

@test
fn test_recent_zero_returns_empty_list() {
    let events = recent(0);
    assert_eq(events.len(), 0);
}

@test
fn test_recent_negative_returns_empty_list() {
    // Defensive: negative n must not panic.
    let events = recent(-1);
    assert_eq(events.len(), 0);
}

// =============================================================================
// Section 6: record_* writers — accept arguments and return Unit
// =============================================================================

@test
fn test_record_revoke_accepts_full_args() {
    reset_for_tests();
    enable();
    record_revoke(
        0x10000000 as UInt64,    // ptr_id
        5 as UInt32,             // gen_before
        6 as UInt32,             // gen_after
        0xFF as UInt16,          // capabilities (cleared on revoke)
        0 as UInt64,             // timestamp_ns (zero = unsupported)
    );
    disable();
    // No assertion on count() because record_* may short-circuit
    // depending on enabled-state at call time; the test verifies the
    // call returns without panic.
    assert(true);
}

@test
fn test_record_attenuate_accepts_full_args() {
    reset_for_tests();
    enable();
    record_attenuate(
        0x10000000 as UInt64,
        5 as UInt32,
        0xFF as UInt16,
        0x01 as UInt16,
        0 as UInt64,
    );
    disable();
    assert(true);
}

@test
fn test_record_ref_incr_accepts_full_args() {
    reset_for_tests();
    enable();
    record_ref_incr(
        0x10000000 as UInt64,
        5 as UInt32,
        0xFF as UInt16,
        0 as UInt64,
    );
    disable();
    assert(true);
}

@test
fn test_record_gen_bump_accepts_full_args() {
    reset_for_tests();
    enable();
    record_gen_bump(
        0x10000000 as UInt64,
        5 as UInt32,
        6 as UInt32,
        0xFF as UInt16,          // capabilities
        0 as UInt64,
    );
    disable();
    assert(true);
}

// =============================================================================
// Section 7: enable / disable idempotence across multiple cycles
// =============================================================================

@test
fn test_audit_enable_is_idempotent_across_three_calls() {
    // Calling enable() multiple times must leave the ring in the
    // enabled state — no internal counter increments, no error.
    disable();
    enable();
    enable();
    enable();
    assert(is_enabled());
    disable();
}

@test
fn test_audit_disable_is_idempotent_across_three_calls() {
    enable();
    disable();
    disable();
    disable();
    assert(!is_enabled());
}

@test
fn test_audit_toggle_cycle_four_round_trips() {
    // Four enable/disable cycles must not drift away from the
    // expected state at any point.
    disable();
    for _ in 0..4 {
        enable();
        assert(is_enabled());
        disable();
        assert(!is_enabled());
    }
}

// =============================================================================
// Section 8: recent(n) — bounded by ring capacity, single-event lower bound
// =============================================================================

@test
fn test_recent_beyond_capacity_bounded_by_capacity() {
    // recent(n) MUST NOT return more than the ring capacity — even
    // when n > CAP_AUDIT_RING_CAPACITY, the result is bounded.  This
    // is a "no buffer overflow" guarantee for forensic readers.
    let events = recent(CAP_AUDIT_RING_CAPACITY * 4);
    assert(events.len() <= CAP_AUDIT_RING_CAPACITY);
}

@test
fn test_recent_with_exact_capacity_request_is_bounded() {
    let events = recent(CAP_AUDIT_RING_CAPACITY);
    assert(events.len() <= CAP_AUDIT_RING_CAPACITY);
}

@test
fn test_recent_one_returns_at_most_one() {
    let events = recent(1);
    assert(events.len() <= 1);
}

// Note on disabled-state record_* short-circuit + reset-after-recent
// tests: those rely on `reset_for_tests()` which currently null-derefs
// at `pc=49 opcode 0x78` (CbgrExtended on a static-mut array element
// field-addr `&mut (*slot_ptr).state as *mut UInt64`).  Same defect
// class as task #9 (epoch `&mut static_mut.scalar_field` cell-backing)
// and §3.3 (mem/hazard fundamental).  The shape is already pinned in
// `regression_test.vr §C` — adding duplicates here would just multiply
// the same red signal.

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
