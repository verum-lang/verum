// =============================================================================
// core-tests/mem/allocator/unit_test.vr
// =============================================================================
//
// Per-API tests for `core.mem.allocator` — the CBGR-aware allocator
// stack.  Tests pin constants + `Layout` record + `AllocError` variants
// + `align_up` / `align_down` arithmetic.  Live `cbgr_alloc` /
// `cbgr_dealloc` / `cbgr_realloc` round-trip tests live in
// `core-tests/base/memory/cbgr_test.vr` because they require a
// complete CBGR header lifecycle.
//
// Companion files:
//   property_test.vr     — alignment laws
//   integration_test.vr  — composition with size_class
//   regression_test.vr   — pinned defects
//   audit.md             — drift surfaces & action items
// =============================================================================

mount core.prelude.*;
mount core.mem.allocator.{
    SIZE_CLASSES, SIZE_CLASS_COUNT,
    PAGE_SIZE, CHUNK_SIZE, LARGE_THRESHOLD,
    MAX_SLOTS_PER_PAGE, GUARD_PAGE_SIZE,
    Layout, AllocError,
    align_up, align_down,
    size_class_index, size_class_to_size,
    AllocStats,
};

// =============================================================================
// Section 1: Allocator constants
// =============================================================================

@test
fn test_size_class_count_is_11() {
    // 11 size classes (mimalloc-style basic tier).
    assert_eq(SIZE_CLASS_COUNT, 11);
}

@test
fn test_size_classes_table_strictly_monotonic() {
    for i in 1..SIZE_CLASS_COUNT {
        assert(SIZE_CLASSES[i] > SIZE_CLASSES[i - 1]);
    }
}

@test
fn test_size_classes_first_is_16() {
    assert_eq(SIZE_CLASSES[0], 16);
}

@test
fn test_size_classes_last_is_2048() {
    assert_eq(SIZE_CLASSES[10], 2048);
}

@test
fn test_page_size_is_64_kib() {
    assert_eq(PAGE_SIZE, 65536);
}

@test
fn test_chunk_size_is_2_mib() {
    assert_eq(CHUNK_SIZE, 2 * 1024 * 1024);
}

@test
fn test_large_threshold_is_2048() {
    assert_eq(LARGE_THRESHOLD, 2048);
}

@test
fn test_max_slots_per_page_is_512() {
    assert_eq(MAX_SLOTS_PER_PAGE, 512);
}

@test
fn test_guard_page_size_is_4_kib() {
    // 4 KiB guard pages between large allocations.
    assert_eq(GUARD_PAGE_SIZE, 4096);
}

// =============================================================================
// Section 2: align_up / align_down
// =============================================================================

@test
fn test_align_up_already_aligned_identity() {
    assert_eq(align_up(0, 8), 0);
    assert_eq(align_up(8, 8), 8);
    assert_eq(align_up(16, 8), 16);
}

@test
fn test_align_up_below_boundary_rounds_up() {
    assert_eq(align_up(1, 8), 8);
    assert_eq(align_up(7, 8), 8);
    assert_eq(align_up(9, 8), 16);
}

@test
fn test_align_down_already_aligned_identity() {
    assert_eq(align_down(0, 8), 0);
    assert_eq(align_down(8, 8), 8);
    assert_eq(align_down(16, 8), 16);
}

@test
fn test_align_down_below_boundary_rounds_down() {
    assert_eq(align_down(7, 8), 0);
    assert_eq(align_down(15, 8), 8);
    assert_eq(align_down(17, 8), 16);
}

// =============================================================================
// Section 3: Layout record
// =============================================================================

@test
fn test_layout_record_construction() {
    let layout: Layout = Layout {
        size: 100,
        align: 8,
    };
    assert_eq(layout.size, 100);
    assert_eq(layout.align, 8);
}

// =============================================================================
// Section 4: size_class_index round-trip
// =============================================================================

@test
fn test_size_class_index_for_first_class() {
    // sizes ≤ 16 → class 0
    let r = size_class_index(16);
    assert(r.is_some());
    assert_eq(r.unwrap(), 0);
}

@test
fn test_size_class_index_above_max_returns_none() {
    // Anything > LARGE_THRESHOLD has no size class index.
    let r = size_class_index(LARGE_THRESHOLD + 1);
    assert(r.is_none());
}

@test
fn test_size_class_to_size_round_trip() {
    // For each class index, size_class_to_size(i) returns
    // SIZE_CLASSES[i].
    for i in 0..SIZE_CLASS_COUNT {
        assert_eq(size_class_to_size(i), SIZE_CLASSES[i]);
    }
}

// =============================================================================
// Section 5: AllocError — 9-variant surface + .message() routing
// =============================================================================

@test
fn test_alloc_error_out_of_memory_carries_requested() {
    let e: AllocError = AllocError.OutOfMemory { requested: 4096 };
    assert(e is AllocError.OutOfMemory);
    assert(e.message().contains("4096"));
    assert(e.message().contains("out of memory"));
}

@test
fn test_alloc_error_invalid_size_carries_size() {
    let e: AllocError = AllocError.InvalidSize { size: -1 };
    assert(e is AllocError.InvalidSize);
    assert(e.message().contains("-1"));
    assert(e.message().contains("invalid"));
}

@test
fn test_alloc_error_invalid_alignment_carries_alignment() {
    let e: AllocError = AllocError.InvalidAlignment { alignment: 7 };
    assert(e is AllocError.InvalidAlignment);
    assert(e.message().contains("7"));
}

@test
fn test_alloc_error_mmap_failed_carries_code() {
    let e: AllocError = AllocError.MmapFailed { code: 12 };
    assert(e is AllocError.MmapFailed);
    assert(e.message().contains("mmap"));
    assert(e.message().contains("12"));
}

@test
fn test_alloc_error_munmap_failed_carries_code() {
    let e: AllocError = AllocError.MunmapFailed { code: 22 };
    assert(e is AllocError.MunmapFailed);
    assert(e.message().contains("munmap"));
    assert(e.message().contains("22"));
}

@test
fn test_alloc_error_page_exhausted_message() {
    let e: AllocError = AllocError.PageExhausted;
    assert(e is AllocError.PageExhausted);
    assert(e.message().contains("page"));
}

@test
fn test_alloc_error_invalid_pointer_message() {
    let e: AllocError = AllocError.InvalidPointer;
    assert(e is AllocError.InvalidPointer);
    assert(e.message().contains("pointer"));
}

@test
fn test_alloc_error_capacity_overflow_carries_requested() {
    let e: AllocError = AllocError.CapacityOverflow { requested: 9_000_000_000 };
    assert(e is AllocError.CapacityOverflow);
    assert(e.message().contains("overflow"));
}

@test
fn test_alloc_error_unsupported_os_carries_op_text() {
    let e: AllocError = AllocError.UnsupportedOs { op: "cbgr_alloc".to_text() };
    assert(e is AllocError.UnsupportedOs);
    assert(e.message().contains("cbgr_alloc"));
}

@test
fn test_alloc_error_variants_pairwise_distinct_via_is() {
    // Pin disjoint-variant invariant: every variant matches itself only.
    let oom: AllocError = AllocError.OutOfMemory { requested: 0 };
    let isz: AllocError = AllocError.InvalidSize { size: 0 };
    let ial: AllocError = AllocError.InvalidAlignment { alignment: 0 };
    let mmf: AllocError = AllocError.MmapFailed { code: 0 };
    let mun: AllocError = AllocError.MunmapFailed { code: 0 };
    let pgx: AllocError = AllocError.PageExhausted;
    let inp: AllocError = AllocError.InvalidPointer;
    let cap: AllocError = AllocError.CapacityOverflow { requested: 0 };
    let uos: AllocError = AllocError.UnsupportedOs { op: "x".to_text() };
    assert(oom is AllocError.OutOfMemory);
    assert(isz is AllocError.InvalidSize);
    assert(ial is AllocError.InvalidAlignment);
    assert(mmf is AllocError.MmapFailed);
    assert(mun is AllocError.MunmapFailed);
    assert(pgx is AllocError.PageExhausted);
    assert(inp is AllocError.InvalidPointer);
    assert(cap is AllocError.CapacityOverflow);
    assert(uos is AllocError.UnsupportedOs);
    // Cross-checks: a unit variant must NOT match a payload-bearing
    // variant's tag.
    assert(!(pgx is AllocError.OutOfMemory));
    assert(!(inp is AllocError.MmapFailed));
    assert(!(oom is AllocError.InvalidSize));
}

@test
fn test_alloc_error_eq_reflexive_unit_variants() {
    let a: AllocError = AllocError.PageExhausted;
    let b: AllocError = AllocError.PageExhausted;
    assert(a == b);
    let c: AllocError = AllocError.InvalidPointer;
    let d: AllocError = AllocError.InvalidPointer;
    assert(c == d);
}

@test
fn test_alloc_error_eq_distinct_unit_variants() {
    let a: AllocError = AllocError.PageExhausted;
    let b: AllocError = AllocError.InvalidPointer;
    assert(!(a == b));
    assert(a != b);
}

// =============================================================================
// Section 6: Layout — accessors + ctor
// =============================================================================

@test
fn test_layout_from_size_align_pins_fields() {
    // The canonical ctor — verifies that the resulting Layout carries
    // the exact (size, align) passed in.
    let l: Layout = Layout.from_size_align(128, 16);
    assert_eq(l.size(), 128);
    assert_eq(l.align(), 16);
}

@test
fn test_layout_try_from_size_align_success() {
    // try_from_size_align returns Ok for valid power-of-2 alignments
    // and non-negative sizes.
    let r: Result<Layout, AllocError> = Layout.try_from_size_align(64, 8);
    assert(r.is_ok());
    let l = r.unwrap();
    assert_eq(l.size(), 64);
    assert_eq(l.align(), 8);
}

@test
fn test_layout_try_from_size_align_negative_size_rejects() {
    let r: Result<Layout, AllocError> = Layout.try_from_size_align(-1, 8);
    assert(r.is_err());
}

@test
fn test_layout_try_from_size_align_non_power_of_two_rejects() {
    let r: Result<Layout, AllocError> = Layout.try_from_size_align(64, 7);
    assert(r.is_err());
}

@test
fn test_layout_try_from_size_align_zero_align_rejects() {
    let r: Result<Layout, AllocError> = Layout.try_from_size_align(64, 0);
    assert(r.is_err());
}

@test
fn test_layout_try_repeat_zero_count_yields_zero_size() {
    let l: Layout = Layout.from_size_align(16, 8);
    let r = l.try_repeat(0);
    assert(r.is_ok());
    let r2 = r.unwrap();
    assert_eq(r2.size(), 0);
    assert_eq(r2.align(), 8);          // alignment preserved
}

@test
fn test_layout_try_repeat_normal_case() {
    let l: Layout = Layout.from_size_align(16, 8);
    let r = l.try_repeat(10).unwrap();
    assert_eq(r.size(), 160);
    assert_eq(r.align(), 8);
}

@test
fn test_layout_try_repeat_negative_count_rejects() {
    let l: Layout = Layout.from_size_align(16, 8);
    let r = l.try_repeat(-3);
    assert(r.is_err());
}

// =============================================================================
// Section 7: align_up / align_down — power-of-2 sweep
// =============================================================================

@test
fn test_align_up_with_various_powers_of_two() {
    // 1-aligned: identity (every value already aligned to 1).
    assert_eq(align_up(0, 1),  0);
    assert_eq(align_up(7, 1),  7);
    assert_eq(align_up(99, 1), 99);

    // 4-aligned.
    assert_eq(align_up(0, 4),  0);
    assert_eq(align_up(1, 4),  4);
    assert_eq(align_up(4, 4),  4);
    assert_eq(align_up(5, 4),  8);

    // 64-aligned.
    assert_eq(align_up(0, 64),  0);
    assert_eq(align_up(63, 64), 64);
    assert_eq(align_up(64, 64), 64);
    assert_eq(align_up(65, 64), 128);

    // 4096-aligned (page).
    assert_eq(align_up(0, 4096),     0);
    assert_eq(align_up(1, 4096),     4096);
    assert_eq(align_up(4095, 4096),  4096);
    assert_eq(align_up(4097, 4096),  8192);
}

@test
fn test_align_down_with_various_powers_of_two() {
    // align_down floors toward zero.
    assert_eq(align_down(0, 4),  0);
    assert_eq(align_down(3, 4),  0);
    assert_eq(align_down(4, 4),  4);
    assert_eq(align_down(7, 4),  4);
    assert_eq(align_down(8, 4),  8);

    assert_eq(align_down(0, 4096),    0);
    assert_eq(align_down(4095, 4096), 0);
    assert_eq(align_down(4096, 4096), 4096);
    assert_eq(align_down(8191, 4096), 4096);
}

@test
fn test_align_up_is_idempotent() {
    // align_up(align_up(x, a), a) == align_up(x, a)
    let x = 13;
    let a = 8;
    let once = align_up(x, a);
    let twice = align_up(once, a);
    assert_eq(once, twice);
}

@test
fn test_align_down_is_idempotent() {
    let x = 13;
    let a = 8;
    let once = align_down(x, a);
    let twice = align_down(once, a);
    assert_eq(once, twice);
}

@test
fn test_align_up_never_decreases() {
    // For any non-negative x and power-of-2 a, align_up(x, a) >= x.
    for x in 0..100 {
        for a in [1, 2, 4, 8, 16, 32, 64].iter() {
            assert(align_up(x, *a) >= x);
        }
    }
}

@test
fn test_align_down_never_increases() {
    // For any non-negative x and power-of-2 a, align_down(x, a) <= x.
    for x in 0..100 {
        for a in [1, 2, 4, 8, 16, 32, 64].iter() {
            assert(align_down(x, *a) <= x);
        }
    }
}

// =============================================================================
// Entry point
// =============================================================================

fn main() {
    // `verum test` synthesises a per-test main.
}
