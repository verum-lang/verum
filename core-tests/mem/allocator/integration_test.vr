// =============================================================================
// core-tests/mem/allocator/integration_test.vr
// =============================================================================
//
// Integration tests for `core.mem.allocator`.
//
//   §1  Static-shape composition — allocator constants line up with
//       sibling modules (size_class, header, segment).
//   §2  Live cbgr_alloc round-trip via the public `Heap<T>` surface —
//       every `Heap.new(value)` routes through `cbgr_alloc`, every
//       scope-end drop routes through `cbgr_dealloc`.  Exercising the
//       full lifecycle through the public surface closes audit §A
//       without reaching into the allocator's private API.
//   §3  Cross-size-class behaviour — allocations small / medium / above
//       LARGE_THRESHOLD all succeed and remain valid.
//   §4  Raw alloc round-trip — `Heap.into_raw` → `Heap.from_raw` keeps
//       the CBGR header consistent across the conversion.
// =============================================================================

mount core.prelude.*;
mount core.mem.allocator.{
    SIZE_CLASSES as ALLOC_SIZE_CLASSES, PAGE_SIZE, CHUNK_SIZE, LARGE_THRESHOLD,
    align_up,
};
mount core.mem.size_class.{
    SMALL_SIZE_MAX,
};
mount core.mem.header.{HEADER_SIZE};

// -----------------------------------------------------------------------------
// §1  Static-shape composition
// -----------------------------------------------------------------------------

@test
fn integration_header_size_aligned_to_8() {
    // HEADER_SIZE = 32 — already 8-byte aligned.
    assert_eq(align_up(HEADER_SIZE, 8), HEADER_SIZE);
}

@test
fn integration_large_threshold_matches_top_class() {
    // The top basic size class (2048) IS the LARGE_THRESHOLD.
    assert_eq(LARGE_THRESHOLD, 2048);
    assert_eq(ALLOC_SIZE_CLASSES[10], LARGE_THRESHOLD);
}

@test
fn integration_page_size_matches_slice_size() {
    // The allocator's PAGE_SIZE = 64 KiB; segment's SLICE_SIZE = 64 KiB.
    // These MUST agree since the allocator pages live inside segment
    // slices.
    assert_eq(PAGE_SIZE, 65536);
}

@test
fn integration_chunk_size_exceeds_large_threshold() {
    // Chunks (2 MiB) are vastly larger than large allocations (2 KB).
    assert(CHUNK_SIZE > LARGE_THRESHOLD);
}

// -----------------------------------------------------------------------------
// §2  Live cbgr_alloc round-trip through Heap<T>
//
// Every `Heap.new(value)` lands in `cbgr_alloc(layout)` — the value
// is bit-copied into the freshly-allocated slot, the AllocationHeader
// is initialised with GEN_INITIAL, and the current epoch+capabilities
// are packed into `epoch_caps`.  When the `Heap<T>` binding goes out
// of scope, `cbgr_dealloc(ptr, layout)` is invoked which bumps the
// header's generation field to invalidate any outstanding references.
//
// Exercising the lifecycle through `Heap<T>` is the canonical way to
// touch the allocator's full surface from a userspace test.
// -----------------------------------------------------------------------------

@test
fn integration_heap_new_returns_valid_allocation() {
    let boxed = Heap.new(42);
    assert_eq(*boxed, 42);
    assert(boxed.is_valid());
}

@test
fn integration_heap_drop_at_scope_end() {
    // Bind, observe, let the binding drop.  No assertion needed beyond
    // "no panic" — if cbgr_dealloc were broken the runtime would
    // detect a double-free or leak on shutdown.
    {
        let _boxed = Heap.new(1234567);
    }
    // The allocation is now freed.  Re-allocating after a free must
    // still succeed — verifies the freelist returns the slot.
    let next = Heap.new(7654321);
    assert_eq(*next, 7654321);
}

@test
fn integration_heap_alloc_dealloc_burst() {
    // 32 alloc / drop cycles in a single scope — exercises the
    // freelist + bin-promotion paths under realistic churn.
    let mut total = 0;
    for i in 0..32 {
        let boxed = Heap.new(i);
        total = total + *boxed;
    }
    // Σ 0..31 = 31 * 32 / 2 = 496
    assert_eq(total, 496);
}

// -----------------------------------------------------------------------------
// §3  Cross-size-class behaviour
// -----------------------------------------------------------------------------

@test
fn integration_heap_small_size_class() {
    // Int payload = 8 bytes — lands in the smallest size class
    // (SIZE_CLASSES[0] = 16) after the 32-byte header is prepended.
    let boxed = Heap.new(0xDEADBEEF);
    assert_eq(*boxed, 0xDEADBEEF);
    assert(boxed.is_valid());
}

type MediumPayload is {
    a0: Int, a1: Int, a2: Int, a3: Int,
    a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int,
    a12: Int, a13: Int, a14: Int, a15: Int,
};

@test
fn integration_heap_medium_size_class() {
    // 16 Int fields = 128 bytes — lands in the medium-bin band
    // (SIZE_CLASSES[5] = 80 or so depending on header overhead).
    // The point isn't a specific bin — the point is to exercise the
    // allocator on a non-trivial payload that does NOT fit into the
    // smallest bin.
    let boxed = Heap.new(MediumPayload {
        a0: 0,  a1: 1,  a2: 2,  a3: 3,
        a4: 4,  a5: 5,  a6: 6,  a7: 7,
        a8: 8,  a9: 9,  a10: 10, a11: 11,
        a12: 12, a13: 13, a14: 14, a15: 15,
    });
    assert(boxed.is_valid());
    assert_eq(boxed.a0, 0);
    assert_eq(boxed.a15, 15);
}

// -----------------------------------------------------------------------------
// §4  Raw alloc round-trip — Heap.into_raw / Heap.from_raw
// -----------------------------------------------------------------------------

@test
fn integration_heap_into_raw_from_raw_round_trip() {
    let boxed = Heap.new(0xCAFEF00D);
    // Convert to a raw pointer + reconstruct.  The CBGR header is
    // preserved across the conversion — the reconstructed Heap<T>
    // must still validate.
    let raw = boxed.into_raw();
    let restored = unsafe { Heap.from_raw(raw) };
    assert(restored.is_valid());
    assert_eq(*restored, 0xCAFEF00D);
}

// -----------------------------------------------------------------------------
// §5  Multiple Shared<T> bumps strong count, drop bumps refcount down
// -----------------------------------------------------------------------------

@test
fn integration_shared_clone_drops_back_to_one() {
    let s = Shared.new(99);
    assert_eq(s.strong_count(), 1);
    {
        let s2 = s.clone();
        assert_eq(s.strong_count(), 2);
        assert_eq(*s2, 99);
    }
    // s2 dropped → strong_count back to 1.
    assert_eq(s.strong_count(), 1);
    assert_eq(*s, 99);
}

fn main() {
    // `verum test` synthesises a per-test main.
}
