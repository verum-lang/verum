// =============================================================================
// core-tests/io/path/regression_test.vr
// =============================================================================
//
// Pinned regressions surfaced while building the `core.io.path` conformance
// suite.
// =============================================================================

mount core.io.path.{Path, PathBuf, Component, normalize};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// §A — `PathBuf.push` of relative component: Text-equality drift after
//      separator+suffix concatenation through nested struct field
//
// EVIDENCE: After
//   `let mut buf = PathBuf.from(&Text.from("/home/user"));
//    buf.push(&Path.new(&Text.from("docs")));`
// `buf.len()` is correctly 15 ("/home/user/docs"), and byte-by-byte the
// content matches `Text.from("/home/user/docs").as_bytes()`. But
// `assert_eq(buf.to_text(), Text.from("/home/user/docs"))` fails: the
// Text.eq compares the two non-equal.
//
// ROOT CAUSE: The push body chains
//   self.path.inner.push(MAIN_SEPARATOR);
//   self.path.inner.push_str(&inner_text);
// where `self.path.inner` is a nested struct field (PathBuf → Path → Text).
// Each call routes through GetF/SetF on the nested record. Earlier (before
// the surgical fix), the inner_text reference was being misread by ~13
// bytes, producing len=28 after a single push. The clone() workaround
// brought len back to the correct 15, but a residual "Text invariant"
// (likely the small-string-inline state or hash cache) differs between
// `Text.from(literal)` and `Text.from(literal).clone().push(c).push_str(other)`,
// so direct `Text.eq` fails despite byte-equal content.
//
// FUNDAMENTAL FIX: Either (a) deepen `Text.eq` to ignore non-byte
// invariants, or (b) close the codegen GetF/SetF chain through nested
// fields. The latter is the same root as the BTreeMap pattern-match-
// ref-generic defect class pinned in
// `[[btree_pattern_match_ref_generic_class]]`.
// =============================================================================

// PARTIAL CLOSE 2026-05-24 — surgical fix in `core/io/path.vr::push`
// (single-level Path assignment + clone-extract) closes the LENGTH
// defect (pre-fix: 28 bytes garbage instead of 15-byte correct
// "/home/user/docs").  Residual Text.eq drift remains: byte-by-byte
// content matches but direct Text.eq returns false.  Root cause
// suspected at a deeper VBC layer — possibly `Text.as_bytes()`
// returning a different view depending on the Text's construction
// shape (push-built vs literal-built).  Multi-day investigation
// required.
@ignore
@test
fn regression_pathbuf_push_text_equality_drift() {
    let mut buf = PathBuf.from(&Text.from("/home/user"));
    buf.push(&Path.new(&Text.from("docs")));
    assert_eq(buf.to_text(), Text.from("/home/user/docs"));
}

@ignore
@test
fn regression_pathbuf_push_when_already_has_trailing_separator() {
    let mut buf = PathBuf.from(&Text.from("/home/user/"));
    buf.push(&Path.new(&Text.from("file.txt")));
    assert_eq(buf.to_text(), Text.from("/home/user/file.txt"));
}

@ignore
@test
fn regression_pathbuf_pop_after_push_returns_to_base() {
    let base = Text.from("/home/user");
    let mut buf = PathBuf.from(&base);
    buf.push(&Path.new(&Text.from("docs")));
    assert(buf.pop());
    assert_eq(buf.to_text(), base);
}

@ignore
@test
fn regression_pathbuf_set_extension_text_equality() {
    let mut buf = PathBuf.from(&Text.from("/home/file.txt"));
    let changed = buf.set_extension(&Text.from("md"));
    assert(changed);
    assert_eq(buf.to_text(), Text.from("/home/file.md"));
}

// =============================================================================
// §B — `Text.ends_with_char` / `starts_with_char` was missing from stdlib
//
// CLOSED 2026-05-24 by adding `ends_with_char` and `starts_with_char` to
// `core/text/text.vr`. The `PathBuf.push` body called `ends_with_char` to
// check for a trailing separator before joining; without the method,
// every non-empty PathBuf.push() panicked with
// `method 'Text.ends_with_char' not found on receiver of runtime kind Object`.
// =============================================================================

@test
fn regression_text_ends_with_char_method_exists() {
    let t = Text.from("hello/");
    assert(t.ends_with_char('/'));
    assert(!t.ends_with_char('x'));
}

@test
fn regression_text_ends_with_char_empty_text() {
    let t = Text.from("");
    assert(!t.ends_with_char('/'));
}

@test
fn regression_text_ends_with_char_single_byte_char() {
    let t = Text.from("abc");
    assert(t.ends_with_char('c'));
    assert(!t.ends_with_char('a'));
}

@test
fn regression_text_starts_with_char_method_exists() {
    let t = Text.from("/path");
    assert(t.starts_with_char('/'));
    assert(!t.starts_with_char('a'));
}

@test
fn regression_text_starts_with_char_empty_text() {
    let t = Text.from("");
    assert(!t.starts_with_char('a'));
}

// =============================================================================
// §C — `file_name()` on path ending with trailing separator
// =============================================================================

@ignore
@test
fn regression_path_file_name_with_trailing_separator() {
    let p = Path.new(&Text.from("/home/user/"));
    match p.file_name() {
        Some(name) => assert_eq(name, Text.from("user")),
        None => assert(false),
    }
}

// =============================================================================
// §D — `normalize` lexical path resolution. Gated by §A.
// =============================================================================

@ignore
@test
fn regression_normalize_resolves_dot_dot() {
    let p = Path.new(&Text.from("/home/user/../docs/./file.txt"));
    let n = normalize(&p);
    assert_eq(n.to_text(), Text.from("/home/docs/file.txt"));
}

@ignore
@test
fn regression_normalize_preserves_root() {
    let p = Path.new(&Text.from("/"));
    let n = normalize(&p);
    assert_eq(n.to_text(), Text.from("/"));
}

@ignore
@test
fn regression_normalize_empty_becomes_dot() {
    let p = Path.new(&Text.from(""));
    let n = normalize(&p);
    assert_eq(n.to_text(), Text.from("."));
}

fn main() {}
