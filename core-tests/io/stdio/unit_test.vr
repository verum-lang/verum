// =============================================================================
// core-tests/io/stdio/unit_test.vr
// =============================================================================
//
// Unit tests for `core.io.stdio`. Most stdio operations need a real
// process and a TTY-ish stdin — those are exercised in regression_test.vr
// with @ignore until #io-1 closes (most surface uses sys_read/sys_write
// bare-name calls).
// =============================================================================

mount core.io.stdio.{
    Stdin, Stdout, Stderr,
    StdinLock, StdoutLock, StderrLock,
    stdin, stdout, stderr,
};

// =============================================================================
// Section 1: Stdin / Stdout / Stderr factory construction
// =============================================================================

@test
fn test_stdin_factory_constructs() {
    let _s: Stdin = stdin();
}

@test
fn test_stdout_factory_constructs() {
    let _s: Stdout = stdout();
}

@test
fn test_stderr_factory_constructs() {
    let _s: Stderr = stderr();
}

// =============================================================================
// Section 2: Stdout / Stderr are unit-shaped types
// =============================================================================

@test
fn test_stdout_is_unit_typed() {
    let s: Stdout = stdout();
    let _: Stdout = s;  // type assignment
}

@test
fn test_stderr_is_unit_typed() {
    let s: Stderr = stderr();
    let _: Stderr = s;
}

// =============================================================================
// Section 3: Stdin.lock returns a StdinLock
// =============================================================================
//
// `.lock()` returns a StdinLock; this exercises only the construction
// path (no kernel I/O).
//

@test
fn test_stdin_lock_returns_stdinlock() {
    let s = stdin();
    let _lock: StdinLock = s.lock();
}

@test
fn test_stdout_lock_returns_stdoutlock() {
    let s = stdout();
    let _lock: StdoutLock = s.lock();
}

@test
fn test_stderr_lock_returns_stderrlock() {
    let s = stderr();
    let _lock: StderrLock = s.lock();
}

fn main() {}
