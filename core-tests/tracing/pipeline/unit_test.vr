// =============================================================================
// Section 3: parent linkage
// =============================================================================

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_child_span_inherits_trace_and_links_parent() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let tracer = provider.tracer(&"suite".into(), &"1".into());
    let links1: List<SpanLink> = List.new();
    let parent = tracer.start_span(
        &"parent".into(), SpanKind.KindServer, AttributeSet.new(), links1, &SpanContext.invalid(),
    );
    let parent_ctx = parent.context();
    let links2: List<SpanLink> = List.new();
    let child = tracer.start_span(
        &"child".into(), SpanKind.KindInternal, AttributeSet.new(), links2, &parent_ctx,
    );
    let child_ctx = child.context();
    assert(child_ctx.trace_id().eq(&parent_ctx.trace_id()));
    assert(!child_ctx.span_id().eq(&parent_ctx.span_id()));
    child.end();
    parent.end();
    assert_eq(sink.line_count(), 2);
    let blob = sink.read_blob();
    // Child line carries the parent's span id + the shared trace id.
    let parent_sid = parent_ctx.span_id().to_hex();
    let expect = f"parent={parent_sid}";
    assert(blob.contains(&expect));
    assert(blob.contains(&parent_ctx.trace_id().to_hex()));
}

// =============================================================================
// Section 4: sampling — Drop keeps a valid context, exports nothing;
// recording-but-unsampled spans are never exported
// =============================================================================

@test
fn test_dropped_span_keeps_valid_context_and_exports_nothing() {
    let sink = FileSink.fresh();
    let provider = TracerProvider.builder()
        .with_sampler(always_off())
        .with_processor(ProcessorHandle.simple(sink.exporter()))
        .build();
    let span = start_simple_span(&provider, &"dropped".into());
    // Traceparent continuity: the context MUST stay valid and unsampled.
    let ctx = span.context();
    assert(ctx.is_valid());
    assert(!ctx.is_sampled());
    assert(!span.is_recording());
    span.set_attribute("ignored".into(), AttributeValue.Int(1));
    span.end();
    assert_eq(sink.line_count(), 0);
}

@test
fn test_record_only_span_records_but_never_exports() {
    // A recording span whose context is NOT sampled models the
    // RecordOnly decision: the processor receives it on end(), but the
    // exporter must never see it.
    let sink = FileSink.fresh();
    let unsampled_ctx = SpanContext.new(
        generate_trace_id(), generate_span_id(),
        TraceFlags.default(), TraceState.empty(), false,
    );
    let inner = SpanInner {
        name: "record-only".into(),
        parent_span_id: Maybe.None,
        kind: SpanKind.KindInternal,
        start_time: Instant.now(),
        start_system_time: SystemTime.now(),
        end_time: Maybe.None,
        attributes: AttributeSet.new(),
        events: List.new(),
        links: List.new(),
        status: SpanStatus.unset(),
        resource: Shared.new(Resource.empty()),
        instrumentation_scope: "suite".into(),
        instrumentation_version: "1".into(),
    };
    let span = Span.recording(
        unsampled_ctx,
        inner,
        ProcessorHandle.simple(sink.exporter()),
    );
    assert(span.is_recording());
    assert(!span.context().is_sampled());
    span.set_attribute("recorded".into(), AttributeValue.Int(1));
    span.end();
    // Recording but unsampled: processor received it, exporter must not.
    assert_eq(sink.line_count(), 0);
}

// =============================================================================
// Section 5: TraceIdRatio — deterministic on the low-63-bit key
// =============================================================================

fn trace_id_with_low_byte(b: UInt8) -> TraceId {
    let mut bytes: [UInt8; 16] = [0; 16];
    bytes[0] = 1;      // keep the id valid regardless of the low half
    bytes[15] = b;
    TraceId.from_bytes(bytes)
}

@test
fn test_ratio_zero_drops_everything() {
    let s = TraceIdRatio.new(0.0);
    let parent = SpanContext.invalid();
    let attrs = AttributeSet.new();
    let r = s.should_sample(&parent, &trace_id_with_low_byte(0), &"n".into(), SpanKind.KindInternal, &attrs);
    assert(r.decision() is SamplingDecision.Drop);
}

@test
fn test_ratio_one_samples_everything() {
    let s = TraceIdRatio.new(1.0);
    let parent = SpanContext.invalid();
    let attrs = AttributeSet.new();
    // Even the maximal 63-bit key is strictly below the 2^63 bound.
    let mut bytes: [UInt8; 16] = [0; 16];
    let mut i = 8;
    while i < 16 {
        bytes[i] = 0xFF;
        i = i + 1;
    }
    let max_key_id = TraceId.from_bytes(bytes);
    let r = s.should_sample(&parent, &max_key_id, &"n".into(), SpanKind.KindInternal, &attrs);
    assert(r.decision() is SamplingDecision.RecordAndSample);
}

@test
fn test_ratio_low_key_sampled_at_small_ratio() {
    let s = TraceIdRatio.new(0.01);
    let parent = SpanContext.invalid();
    let attrs = AttributeSet.new();
    // Key 0 is below every non-zero bound.
    let r = s.should_sample(&parent, &trace_id_with_low_byte(0), &"n".into(), SpanKind.KindInternal, &attrs);
    assert(r.decision() is SamplingDecision.RecordAndSample);
}

@test
fn test_ratio_is_deterministic_per_trace_id() {
    let s = TraceIdRatio.new(0.5);
    let parent = SpanContext.invalid();
    let attrs = AttributeSet.new();
    let id = generate_trace_id();
    let a = s.should_sample(&parent, &id, &"n".into(), SpanKind.KindInternal, &attrs);
    let b = s.should_sample(&parent, &id, &"n".into(), SpanKind.KindInternal, &attrs);
    let both_sampled = (a.decision() is SamplingDecision.RecordAndSample)
        && (b.decision() is SamplingDecision.RecordAndSample);
    let both_dropped = (a.decision() is SamplingDecision.Drop)
        && (b.decision() is SamplingDecision.Drop);
    assert(both_sampled || both_dropped);
}

// =============================================================================
// Section 6: generated ids — validity, uniqueness, low-bit spread
// =============================================================================

fn low_key_of(id: &TraceId) -> UInt64 {
    let b = id.as_bytes();
    let mut n: UInt64 = 0;
    let mut i = 8;
    while i < 16 {
        n = (n << 8) | (b[i] as UInt64);
        i = i + 1;
    }
    n
}

@test
fn test_generated_trace_ids_valid_and_unique() {
    let mut ids: List<TraceId> = List.new();
    let mut i = 0;
    while i < 64 {
        let id = generate_trace_id();
        assert(!id.is_invalid());
        let mut j = 0;
        while j < ids.len() {
            assert(!ids[j].eq(&id));
            j = j + 1;
        }
        ids.push(id);
        i = i + 1;
    }
}

@test
fn test_generated_span_ids_valid_and_unique() {
    let mut ids: List<SpanId> = List.new();
    let mut i = 0;
    while i < 64 {
        let id = generate_span_id();
        assert(!id.is_invalid());
        let mut j = 0;
        while j < ids.len() {
            assert(!ids[j].eq(&id));
            j = j + 1;
        }
        ids.push(id);
        i = i + 1;
    }
}

@test
fn test_generated_trace_ids_spread_across_ratio_key() {
    // Regression pin for the constant-low-word defect class: the ratio
    // key (low 8 bytes) must differ across generated ids, otherwise
    // TraceIdRatio degenerates to all-or-nothing per process.
    let ka = low_key_of(&generate_trace_id());
    let kb = low_key_of(&generate_trace_id());
    assert(ka != kb);
}

// =============================================================================
// Section 7: NoopTracer propagates the parent context
// =============================================================================

@test
fn test_noop_tracer_passes_parent_context_through() {
    let tracer = NoopTracer.new("noop".into(), "1".into());
    let parent = SpanContext.new(
        generate_trace_id(), generate_span_id(),
        TraceFlags.sampled(), TraceState.empty(), true,
    );
    let links: List<SpanLink> = List.new();
    let span = tracer.start_span(&"x".into(), SpanKind.KindInternal, AttributeSet.new(), links, &parent);
    let ctx = span.context();
    assert(ctx.is_valid());
    assert(ctx.trace_id().eq(&parent.trace_id()));
    assert(ctx.span_id().eq(&parent.span_id()));
    assert(!span.is_recording());
}

// =============================================================================
// Section 8: provider lifecycle — flush / shutdown over the handles
// =============================================================================

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_provider_force_flush_and_shutdown_succeed() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"lifecycle".into());
    span.end();
    let flushed = provider.force_flush(Duration.from_secs(1));
    assert(flushed.is_success());
    let down = provider.shutdown(Duration.from_secs(1));
    assert(down.is_success());
    assert_eq(sink.line_count(), 1);
}

fn main() {}
