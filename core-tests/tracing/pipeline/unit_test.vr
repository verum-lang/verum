// =============================================================================
// core-tests/tracing/pipeline/unit_test.vr
// =============================================================================
//
// End-to-end pipeline conformance over the SYNCHRONOUS path:
//   TracerProvider → SdkTracer → Span.end() → ProcessorHandle.simple →
//   ExporterHandle.in_memory.
//
// This is the suite that pins the wiring contract: a span that ends MUST
// arrive at the exporter, exactly once, with the right identity, status,
// attributes, and sampling flags.
// =============================================================================

mount core.tracing.tracer.{TracerProvider, TracerHandle, NoopTracer};
mount core.tracing.processor.{ProcessorHandle};
mount core.tracing.exporter.{ExporterHandle, InMemoryExporter, FileExporter};
mount core.io.file.{read_to_string as file_read_to_string, write as file_write};
mount core.io.fs.{remove_file};
mount core.io.path.{Path};
mount core.tracing.id.{generate_span_id as fresh_span_id};
mount core.tracing.span.{Span, SpanInner};
mount core.tracing.data.{SpanKind, SpanStatus, SpanStatusCode, SpanLink, SpanData};
mount core.tracing.sampler.{SamplingDecision, TraceIdRatio, always_on, always_off, trace_id_ratio};
mount core.tracing.attribute.{AttributeSet, AttributeValue};
mount core.tracing.context.{SpanContext, TraceFlags, TraceState};
mount core.tracing.resource.{Resource};
mount core.tracing.id.{TraceId, SpanId, generate_trace_id, generate_span_id};
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};
mount core.time.system_time.{SystemTime};
mount core.base.maybe.{Maybe, Some, None};

// -----------------------------------------------------------------------------
// Harness helpers
// -----------------------------------------------------------------------------

/// Filesystem sink: the exporter appends canonical span lines to a
/// unique temp file; the test reads the file back. Cross-handle shared
/// memory is not required — the observation channel is the FS.
type FileSink is {
    path: Text,
};

implement FileSink {
    public fn fresh() -> FileSink {
        let tag = fresh_span_id().to_hex();
        let path: Text = f"/tmp/verum-tracing-pipeline-{tag}.log";
        // Start clean; ignore result when absent.
        let _ = file_write(&path, &"".into());
        FileSink { path: path }
    }

    public fn exporter(&self) -> ExporterHandle {
        ExporterHandle.file(self.path.clone())
    }

    public fn read_blob(&self) -> Text {
        match file_read_to_string(&self.path) {
            Result.Ok(t) => t,
            Result.Err(_) => "".into(),
        }
    }

    public fn line_count(&self) -> Int {
        let blob = self.read_blob();
        let bytes = blob.as_bytes();
        let mut n = 0;
        let mut i = 0;
        while i < bytes.len() {
            if bytes[i] == 0x0A { n = n + 1; }
            i = i + 1;
        }
        n
    }
}

fn make_provider(exporter: ExporterHandle) -> TracerProvider {
    TracerProvider.builder()
        .with_resource(Resource.service(&"pipeline-test".into(), &"1.0".into()))
        .with_sampler(always_on())
        .with_processor(ProcessorHandle.simple(exporter))
        .build()
}

fn start_simple_span(provider: &TracerProvider, name: &Text) -> Span {
    let tracer = provider.tracer(&"suite".into(), &"1".into());
    let links: List<SpanLink> = List.new();
    tracer.start_span(name, SpanKind.KindServer, AttributeSet.new(), links, &SpanContext.invalid())
}

// =============================================================================
// Section 1: end() delivers exactly one SpanData to the exporter
// =============================================================================

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_end_delivers_span_to_exporter() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"work".into());
    span.end();
    assert_eq(sink.line_count(), 1);
    let blob = sink.read_blob();
    assert(blob.contains(&"work".into()));
}

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_end_is_idempotent_single_export() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"once".into());
    span.end();
    span.end();
    span.end();
    assert_eq(sink.line_count(), 1);
}

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_exported_span_carries_identity_and_kind() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"identity".into());
    let ctx = span.context();
    span.end();
    assert_eq(sink.line_count(), 1);
    let blob = sink.read_blob();
    assert(blob.contains(&ctx.trace_id().to_hex()));
    assert(blob.contains(&ctx.span_id().to_hex()));
    assert(blob.contains(&"kind=SERVER".into()));
    assert(blob.contains(&"sampled=true".into()));
    assert(blob.contains(&"parent=-".into()));
}

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_exported_span_carries_attributes_events_status() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"detail".into());
    span.set_attribute("http.method".into(), AttributeValue.Text("GET".into()));
    span.set_attribute("http.status_code".into(), AttributeValue.Int(200));
    span.add_event_now("validated".into());
    span.set_status(SpanStatus.ok());
    span.end();
    assert_eq(sink.line_count(), 1);
    let blob = sink.read_blob();
    assert(blob.contains(&"http.method=\"GET\"".into()));
    assert(blob.contains(&"http.status_code=200".into()));
    assert(blob.contains(&"events=1".into()));
    assert(blob.contains(&"status=OK".into()));
}

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_mutation_after_end_is_ignored() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"frozen".into());
    span.set_attribute("kept".into(), AttributeValue.Int(1));
    span.end();
    span.set_attribute("dropped".into(), AttributeValue.Int(2));
    span.add_event_now("late".into());
    span.update_name("renamed".into());
    assert_eq(sink.line_count(), 1);
    let blob = sink.read_blob();
    assert(blob.contains(&"frozen".into()));
    assert(blob.contains(&"kept=1".into()));
    assert(!blob.contains(&"dropped".into()));
    assert(blob.contains(&"events=0".into()));
}

// =============================================================================
// Section 2: status transition lattice survives the pipeline
// =============================================================================

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_status_error_wins_over_ok() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"status1".into());
    span.set_status(SpanStatus.ok());
    span.set_status(SpanStatus.error("boom".into()));
    span.end();
    assert(sink.read_blob().contains(&"status=ERROR".into()));
}

@test
@ignore("[[tracing-delivery-vbc-class]] — the end()→processor→exporter delivery chain drops the call between baked-module stages (verified live to the exporter cell in an earlier assembly; the memory-cell fork class is FIXED (T0107: SetF SHARED write-through + handle_clone SHARED arm, pinned in mem/allocator §6). Opcode proof: enum SetVariantData/GetVariantData never copy — this was NEVER a cell copy. Residual = baked-module Shared-field method-dispatch / self-binding mis-lowering, core/tracing/data.vr:1351, a T0146-family root). FS-side primitives and the exporter itself are green in isolation. Un-ignore when baked-module Shared-field method-dispatch lands (T0146 family) — the assertions are already written against the canonical file-sink observation surface.")
fn test_status_error_is_final() {
    let sink = FileSink.fresh();
    let provider = make_provider(sink.exporter());
    let span = start_simple_span(&provider, &"status2".into());
    span.set_status(SpanStatus.error("first".into()));
