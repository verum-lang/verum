@test
fn test_type_kind_pointer() {
    let k: TypeKind = TypeKind.Pointer;
    assert(k is TypeKind.Pointer);
}

@test
fn test_type_kind_function() {
    let k: TypeKind = TypeKind.Function;
    assert(k is TypeKind.Function);
}

@test
fn test_type_kind_type_param() {
    let k: TypeKind = TypeKind.TypeParam;
    assert(k is TypeKind.TypeParam);
}

@test
fn test_type_kind_associated() {
    let k: TypeKind = TypeKind.Associated;
    assert(k is TypeKind.Associated);
}

@test
fn test_type_kind_primitive() {
    let k: TypeKind = TypeKind.Primitive;
    assert(k is TypeKind.Primitive);
}

@test
fn test_type_kind_never() {
    let k: TypeKind = TypeKind.Never;
    assert(k is TypeKind.Never);
}

@test
fn test_type_kind_infer() {
    let k: TypeKind = TypeKind.Infer;
    assert(k is TypeKind.Infer);
}

@test
fn test_type_kind_unknown() {
    let k: TypeKind = TypeKind.Unknown;
    assert(k is TypeKind.Unknown);
}

@test
fn test_type_kind_pairwise_disjoint_compound() {
    let s: TypeKind = TypeKind.Struct;
    let e: TypeKind = TypeKind.Enum;
    let t: TypeKind = TypeKind.Tuple;
    assert(s is TypeKind.Struct && !(s is TypeKind.Enum));
    assert(e is TypeKind.Enum && !(e is TypeKind.Tuple));
    assert(t is TypeKind.Tuple && !(t is TypeKind.Struct));
}

@test
fn test_type_kind_pairwise_disjoint_reference() {
    let r: TypeKind = TypeKind.Reference;
    let p: TypeKind = TypeKind.Pointer;
    let n: TypeKind = TypeKind.Never;
    assert(r is TypeKind.Reference && !(r is TypeKind.Pointer));
    assert(p is TypeKind.Pointer && !(p is TypeKind.Never));
    assert(n is TypeKind.Never && !(n is TypeKind.Reference));
}

