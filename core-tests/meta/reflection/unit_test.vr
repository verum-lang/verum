@test
fn test_self_kind_value() {
    let k: SelfKind = SelfKind.Value;
    assert(k is SelfKind.Value);
}

@test
fn test_self_kind_ref() {
    let k: SelfKind = SelfKind.Ref;
    assert(k is SelfKind.Ref);
}

@test
fn test_self_kind_ref_mut() {
    let k: SelfKind = SelfKind.RefMut;
    assert(k is SelfKind.RefMut);
}

@test
fn test_self_kind_pairwise_disjoint() {
    let v: SelfKind = SelfKind.Value;
    let r: SelfKind = SelfKind.Ref;
    let m: SelfKind = SelfKind.RefMut;
    assert(v is SelfKind.Value && !(v is SelfKind.Ref));
    assert(r is SelfKind.Ref && !(r is SelfKind.RefMut));
    assert(m is SelfKind.RefMut && !(m is SelfKind.Value));
}

// =============================================================================
// Section 9: MethodSource 4-variant
// =============================================================================

@test
fn test_method_source_inherent() {
    let s: MethodSource = MethodSource.Inherent;
    assert(s is MethodSource.Inherent);
}

@test
fn test_method_source_protocol() {
    let s: MethodSource = MethodSource.Protocol;
    assert(s is MethodSource.Protocol);
}

@test
fn test_method_source_derived() {
    let s: MethodSource = MethodSource.Derived;
    assert(s is MethodSource.Derived);
}

@test
fn test_method_source_generated() {
    let s: MethodSource = MethodSource.Generated;
    assert(s is MethodSource.Generated);
}

@test
fn test_method_source_pairwise_disjoint() {
    let i: MethodSource = MethodSource.Inherent;
    let p: MethodSource = MethodSource.Protocol;
    let d: MethodSource = MethodSource.Derived;
    let g: MethodSource = MethodSource.Generated;
    assert(i is MethodSource.Inherent && !(i is MethodSource.Protocol));
    assert(p is MethodSource.Protocol && !(p is MethodSource.Derived));
    assert(d is MethodSource.Derived && !(d is MethodSource.Generated));
    assert(g is MethodSource.Generated && !(g is MethodSource.Inherent));
}

