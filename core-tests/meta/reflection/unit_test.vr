// =============================================================================
// Section 11: PrimitiveType.is_signed / .is_unsigned / .is_float / .is_numeric
// =============================================================================

@test
fn test_primitive_is_signed_int8() {
    let p: PrimitiveType = PrimitiveType.Int8;
    assert(p.is_signed());
    assert(!p.is_unsigned());
}

@test
fn test_primitive_is_unsigned_uint8() {
    let p: PrimitiveType = PrimitiveType.UInt8;
    assert(p.is_unsigned());
    assert(!p.is_signed());
}

@test
fn test_primitive_is_float_f32() {
    let p: PrimitiveType = PrimitiveType.Float32;
    assert(p.is_float());
    assert(!p.is_signed());
    assert(!p.is_unsigned());
}

@test
fn test_primitive_is_float_f64() {
    let p: PrimitiveType = PrimitiveType.Float64;
    assert(p.is_float());
}

@test
fn test_primitive_bool_not_numeric() {
    let p: PrimitiveType = PrimitiveType.Bool;
    assert(!p.is_numeric());
    assert(!p.is_signed());
    assert(!p.is_unsigned());
    assert(!p.is_float());
}

@test
fn test_primitive_char_not_numeric() {
    let p: PrimitiveType = PrimitiveType.Char;
    assert(!p.is_numeric());
}

@test
fn test_primitive_text_not_numeric() {
    let p: PrimitiveType = PrimitiveType.Text;
    assert(!p.is_numeric());
}

@test
fn test_primitive_unit_not_numeric() {
    let p: PrimitiveType = PrimitiveType.Unit;
    assert(!p.is_numeric());
}

@test
fn test_primitive_int_is_numeric() {
    let p: PrimitiveType = PrimitiveType.Int;
    assert(p.is_numeric());
}

// =============================================================================
// Section 12: FieldOffset record + accessors
// =============================================================================

@test
fn test_field_offset_direct_construction() {
    let f = FieldOffset {
        name: Text.from("x"),
        offset: 8,
        size: 8,
        align: 8,
        padding_before: 0,
    };
    assert(f.offset == 8);
    assert(f.size == 8);
    assert(!f.has_padding());
}

@test
fn test_field_offset_has_padding_true() {
    let f = FieldOffset {
        name: Text.from("y"),
        offset: 16,
        size: 4,
        align: 4,
        padding_before: 4,
    };
    assert(f.has_padding());
}

@test
fn test_field_offset_end_position() {
    let f = FieldOffset {
        name: Text.from("z"),
        offset: 24,
        size: 8,
        align: 8,
        padding_before: 0,
    };
    assert(f.end() == 32);
}

// =============================================================================
// Section 13: OwnershipInfo record + composed predicates
// =============================================================================

@test
fn test_ownership_info_thread_safe() {
    let o = OwnershipInfo {
        is_copy: true,
        is_clone: true,
        is_send: true,
        is_sync: true,
        has_drop: false,
        needs_drop: false,
        is_unpin: true,
        has_interior_mutability: false,
        blocking_fields: List.new(),
    };
    assert(o.is_thread_safe());
}

@test
fn test_ownership_info_not_thread_safe_when_not_send() {
    let o = OwnershipInfo {
        is_copy: false,
        is_clone: true,
        is_send: false,
        is_sync: true,
        has_drop: false,
        needs_drop: false,
        is_unpin: true,
        has_interior_mutability: false,
        blocking_fields: List.new(),
    };
    assert(!o.is_thread_safe());
}

@test
fn test_ownership_info_trivially_copyable_when_copy_no_drop() {
    let o = OwnershipInfo {
        is_copy: true,
        is_clone: true,
        is_send: true,
        is_sync: true,
        has_drop: false,
        needs_drop: false,
        is_unpin: true,
        has_interior_mutability: false,
        blocking_fields: List.new(),
    };
    assert(o.is_trivially_copyable());
}

@test
fn test_ownership_info_not_trivially_copyable_with_drop() {
    let o = OwnershipInfo {
        is_copy: true,
        is_clone: true,
        is_send: true,
        is_sync: true,
        has_drop: false,
        needs_drop: true,
        is_unpin: true,
        has_interior_mutability: false,
        blocking_fields: List.new(),
    };
    assert(!o.is_trivially_copyable());
}

@test
fn test_ownership_info_requires_cleanup_with_drop() {
    let o = OwnershipInfo {
        is_copy: false,
        is_clone: false,
        is_send: false,
        is_sync: false,
        has_drop: true,
        needs_drop: true,
        is_unpin: true,
        has_interior_mutability: false,
        blocking_fields: List.new(),
    };
    assert(o.requires_cleanup());
}
