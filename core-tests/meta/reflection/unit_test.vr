// =============================================================================
// core-tests/meta/reflection/unit_test.vr
// =============================================================================
//
// `core/meta/reflection.vr` — compile-time type introspection data
// shapes. The `TypeInfo` context's accessors are @compiler_intrinsic
// and require a live compile-time registry; this test layer covers
// the **pure-data** types that those accessors return.
//
// Surface tested here:
//   * TypeKind 17-variant + .is_compound / .is_reference /
//     .is_primitive / .name
//   * Visibility 5-variant + .is_public + .keyword
//   * GenericParamKind 3-variant
//   * VariantKind 3-variant
//   * SelfKind 3-variant
//   * MethodSource 4-variant
//   * PrimitiveType 18-variant + .name / .size / .is_numeric /
//     .is_signed / .is_unsigned / .is_float
//
// Records (FieldInfo, VariantInfo, GenericParam, ProtocolInfo,
// FunctionInfo, ParamInfo, TraitBound, LifetimeParam,
// OwnershipInfo, FieldOffset, MethodResolution,
// AssociatedTypeInfo) require Span/Attribute construction and are
// covered at the integration layer once the cross-module record
// return defect (audit §3.1) is fixed.
// =============================================================================

mount core.meta.reflection.{
    TypeKind, VariantKind, GenericParamKind, SelfKind, MethodSource,
    Visibility, PrimitiveType,
    FieldOffset, OwnershipInfo,
};

// =============================================================================
// Section 1: TypeKind 17-variant
// =============================================================================

@test
fn test_type_kind_struct() {
    let k: TypeKind = TypeKind.Struct;
    assert(k is TypeKind.Struct);
}

@test
fn test_type_kind_enum() {
    let k: TypeKind = TypeKind.Enum;
    assert(k is TypeKind.Enum);
}

