@test
fn test_generic_param_kind_lifetime() {
    let k: GenericParamKind = GenericParamKind.Lifetime;
    assert(k is GenericParamKind.Lifetime);
}

@test
fn test_generic_param_kind_const() {
    let k: GenericParamKind = GenericParamKind.Const;
    assert(k is GenericParamKind.Const);
}

@test
fn test_generic_param_kind_pairwise_disjoint() {
    let t: GenericParamKind = GenericParamKind.Type;
    let l: GenericParamKind = GenericParamKind.Lifetime;
    let c: GenericParamKind = GenericParamKind.Const;
    assert(t is GenericParamKind.Type && !(t is GenericParamKind.Lifetime));
    assert(l is GenericParamKind.Lifetime && !(l is GenericParamKind.Const));
    assert(c is GenericParamKind.Const && !(c is GenericParamKind.Type));
}

