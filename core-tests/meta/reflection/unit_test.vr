@test
fn test_type_kind_is_compound_struct() {
    let k: TypeKind = TypeKind.Struct;
    assert(k.is_compound());
}

@test
fn test_type_kind_is_compound_enum() {
    let k: TypeKind = TypeKind.Enum;
    assert(k.is_compound());
}

@test
fn test_type_kind_is_compound_tuple() {
    let k: TypeKind = TypeKind.Tuple;
    assert(k.is_compound());
}

@test
fn test_type_kind_is_compound_false_newtype() {
    let k: TypeKind = TypeKind.Newtype;
    assert(!k.is_compound());
}

@test
fn test_type_kind_is_compound_false_unit() {
    let k: TypeKind = TypeKind.Unit;
    assert(!k.is_compound());
}

@test
fn test_type_kind_is_compound_false_array() {
    let k: TypeKind = TypeKind.Array;
    assert(!k.is_compound());
}

@test
fn test_type_kind_is_compound_false_protocol() {
    let k: TypeKind = TypeKind.Protocol;
    assert(!k.is_compound());
}

@test
fn test_type_kind_is_compound_false_primitive() {
    let k: TypeKind = TypeKind.Primitive;
    assert(!k.is_compound());
}

