// =============================================================================
// Section 5: Visibility 5-variant
// =============================================================================

@test
fn test_visibility_public() {
    let v: Visibility = Visibility.Public;
    assert(v is Visibility.Public);
}

@test
fn test_visibility_private() {
    let v: Visibility = Visibility.Private;
    assert(v is Visibility.Private);
}

@test
fn test_visibility_crate() {
    let v: Visibility = Visibility.Crate;
    assert(v is Visibility.Crate);
}

@test
fn test_visibility_super() {
    let v: Visibility = Visibility.Super;
    assert(v is Visibility.Super);
}

@test
fn test_visibility_in_path() {
    let v: Visibility = Visibility.In(Text.from("mod.submod"));
    assert(v is Visibility.In);
}

@test
fn test_visibility_pairwise_disjoint() {
    let p: Visibility = Visibility.Public;
    let pr: Visibility = Visibility.Private;
    let c: Visibility = Visibility.Crate;
    let s: Visibility = Visibility.Super;
    assert(p is Visibility.Public && !(p is Visibility.Private));
    assert(pr is Visibility.Private && !(pr is Visibility.Crate));
    assert(c is Visibility.Crate && !(c is Visibility.Super));
    assert(s is Visibility.Super && !(s is Visibility.Public));
}

