// =============================================================================
// core-tests/meta/contexts/unit_test.vr
// =============================================================================
//
// `core/meta/contexts.vr` — 14 capability-context declarations + their
// payload data types. ~3700 LOC.  The contexts themselves
// (`BuildAssets`, `TypeInfo`, `AstAccess`, `CompileDiag`,
// `MetaRuntime`, `MacroState`, `StageInfo`, `Hygiene`, `CodeSearch`,
// `ProjectInfo`, `SourceMap`, `Schema`, `DepGraph`, `MetaBench`) are
// compiler-provided — their methods are `@compiler_provided` /
// `@compiler_intrinsic` and require a live build context. They are
// covered at the verum_compiler test layer.
//
// **This test layer** covers the pure-data payload types that those
// methods accept and return:
//
//   Enums:
//   * DiagnosticSeverity 4-variant, SuggestionKind 3-variant,
//     UsageContext 6-variant, ItemKind 7-variant,
//     SchemaErrorSeverity 3-variant (+ Display/Eq impls),
//     BraceStyle 3-variant
//
//   Records (construction + field readback + pure methods):
//   * AssetMetadata, SpanLabel, Suggestion, DiagnosticBuilder (pure
//     fluent setters; `.emit()` is @compiler_intrinsic — NOT called),
//     CacheStats, FunctionSearchResult, TypeSearchResult, UsageInfo,
//     PatternMatch, ItemInfo, DependencyInfo, SpanMapping,
//     SchemaError (+ Display/Eq), BenchTimer (fields only —
//     `.stop()`/`.elapsed()` are bodyless compiler fns), BenchResult,
//     BenchStats, StageRecord, TraceMarker, InvocationId (+ to_text),
//     ParseResult<Int> (+ is_ok/has_errors/ok/to_result),
//     MetaParseError (+ format + Display), FormatOptions
//     (+ default/compact)
//
//   NOT tested here (no runtime surface):
//   * MetaExpr / Type / Item / Pattern / Statement / MetaBlock —
//     @compiler_type unit-type opaque tokens
//   * FunctionSchemaBuilder / TypeSchemaBuilder / ExprSchemaBuilder /
//     ModuleSchemaBuilder / CodeSchema — `_inner: ()` opaque handles
//     whose methods are all bodyless compiler declarations
//   * ToTokens protocol — meta fn only
//
// Construction discipline: Spans are built by direct MetaSpan record
// construction (`Span.call_site()` is @compiler_intrinsic); alias
// types (Span, MetaResult<T>) are only ever named in fn signatures,
// never in `let` annotations (META-SPAN-ALIAS class).
//
// Locals pulled OUT of a cross-module record (list elements, nested
// records) are always explicitly annotated (`let l: SpanLabel = …`) —
// the unannotated form falls back to dynamic field lookup and misreads
// (META-CTX-ELEM-INFER-1, audit.md §3.2).
// =============================================================================

mount core.meta.contexts.{
    DiagnosticSeverity, SuggestionKind,
    UsageContext, ItemKind,
    SchemaErrorSeverity, BraceStyle,
    AssetMetadata,
    DiagnosticBuilder, SpanLabel, Suggestion,
    CacheStats,
    FunctionSearchResult, TypeSearchResult, UsageInfo, PatternMatch, ItemInfo,
    DependencyInfo, SpanMapping, SchemaError,
    BenchTimer, BenchResult, BenchStats,
    StageRecord, TraceMarker, InvocationId,
    ParseResult, MetaParseError, FormatOptions,
};
mount core.meta.span.{MetaSpan, Span, SpanFlags};
mount core.meta.token.{TokenStream};
mount core.meta.reflection.{TypeKind};
mount core.base.maybe.{Maybe};

// ---- builders ---------------------------------------------------------------

fn ssp() -> Span {
    MetaSpan {
        id: 0,
        hygiene: 0,
        flags: SpanFlags { is_expansion: false, is_synthetic: true, is_hidden: false },
    }
}

fn sp(id: UInt64) -> Span {
    MetaSpan {
        id,
        hygiene: 0,
        flags: SpanFlags { is_expansion: false, is_synthetic: false, is_hidden: false },
    }
}

fn ets() -> TokenStream {
    TokenStream { tokens: List.new(), span: ssp() }
}

fn fresh_builder() -> DiagnosticBuilder {
    DiagnosticBuilder {
        severity: DiagnosticSeverity.Note,
        code: Maybe.None,
        message: Maybe.None,
        spans: List.new(),
        suggestions: List.new(),
    }
}

fn mk_parse_error(msg: Text) -> MetaParseError {
    MetaParseError {
        message: msg,
        code: Maybe.None,
        span: ssp(),
        expected: List.new(),
        found: Maybe.None,
    }
}

// =============================================================================
// Section 1: DiagnosticSeverity 4-variant
// =============================================================================

@test
fn test_diagnostic_severity_error() {
    let s: DiagnosticSeverity = DiagnosticSeverity.Error;
    assert(s is DiagnosticSeverity.Error);
}

@test
fn test_diagnostic_severity_warning() {
    let s: DiagnosticSeverity = DiagnosticSeverity.Warning;
    assert(s is DiagnosticSeverity.Warning);
}

@test
fn test_diagnostic_severity_note() {
    let s: DiagnosticSeverity = DiagnosticSeverity.Note;
    assert(s is DiagnosticSeverity.Note);
}

@test
fn test_diagnostic_severity_help() {
    let s: DiagnosticSeverity = DiagnosticSeverity.Help;
    assert(s is DiagnosticSeverity.Help);
}

@test
fn test_diagnostic_severity_pairwise_disjoint() {
    let e: DiagnosticSeverity = DiagnosticSeverity.Error;
    let w: DiagnosticSeverity = DiagnosticSeverity.Warning;
    let n: DiagnosticSeverity = DiagnosticSeverity.Note;
    let h: DiagnosticSeverity = DiagnosticSeverity.Help;
    assert(e is DiagnosticSeverity.Error && !(e is DiagnosticSeverity.Warning));
    assert(w is DiagnosticSeverity.Warning && !(w is DiagnosticSeverity.Note));
    assert(n is DiagnosticSeverity.Note && !(n is DiagnosticSeverity.Help));
    assert(h is DiagnosticSeverity.Help && !(h is DiagnosticSeverity.Error));
}

