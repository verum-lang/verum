// =============================================================================
// Section 17: DependencyInfo record (ProjectInfo payload)
// =============================================================================

@test
fn test_dependency_info_plain() {
    let d = DependencyInfo {
        name: Text.from("serde"),
        version: Text.from("1.0"),
        is_optional: false,
        features: List.new(),
    };
    assert(d.name == "serde");
    assert(d.version == "1.0");
    assert(!d.is_optional);
    assert(d.features.len() == 0);
}

@test
fn test_dependency_info_optional_with_features() {
    let d = DependencyInfo {
        name: Text.from("tokio"),
        version: Text.from(">=1.2"),
        is_optional: true,
        features: [Text.from("rt"), Text.from("net")],
    };
    assert(d.is_optional);
    assert(d.features.len() == 2);
    assert(d.features[0] == "rt");
    assert(d.features[1] == "net");
}

// =============================================================================
// Section 18: SpanMapping record (SourceMap payload)
// =============================================================================

@test
fn test_span_mapping_construction_readback() {
    let m = SpanMapping {
        generated: sp(100),
        source: sp(200),
        scope: Text.from("derive_clone"),
    };
    assert(m.generated == sp(100));
    assert(m.source == sp(200));
    assert(m.scope == "derive_clone");
}

@test
fn test_span_mapping_generated_and_source_distinct() {
    let m = SpanMapping {
        generated: sp(1),
        source: sp(2),
        scope: Text.from("g"),
    };
    assert(!(m.generated == m.source));
}

