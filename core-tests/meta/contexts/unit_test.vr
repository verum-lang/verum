// =============================================================================
// Section 7: AssetMetadata record (BuildAssets payload)
// =============================================================================

@test
fn test_asset_metadata_file_shape() {
    let m = AssetMetadata {
        size: 2048,
        modified_ns: 1700000000000000000,
        is_directory: false,
        is_file: true,
        is_symlink: false,
    };
    assert(m.size == 2048);
    assert(m.modified_ns == 1700000000000000000);
    assert(!m.is_directory);
    assert(m.is_file);
    assert(!m.is_symlink);
}

@test
fn test_asset_metadata_directory_shape() {
    let m = AssetMetadata {
        size: 0,
        modified_ns: 0,
        is_directory: true,
        is_file: false,
        is_symlink: false,
    };
    assert(m.size == 0);
    assert(m.is_directory);
    assert(!m.is_file);
}

@test
fn test_asset_metadata_symlink_shape() {
    let m = AssetMetadata {
        size: 12,
        modified_ns: 5,
        is_directory: false,
        is_file: false,
        is_symlink: true,
    };
    assert(m.is_symlink);
    assert(!m.is_directory && !m.is_file);
}

// =============================================================================
// Section 8: SpanLabel record (CompileDiag payload)
// =============================================================================

@test
fn test_span_label_primary_construction() {
    let l = SpanLabel { span: sp(7), label: Text.from("expected here"), is_primary: true };
    assert(l.label == "expected here");
    assert(l.is_primary);
    assert(l.span == sp(7));
}

@test
fn test_span_label_secondary_construction() {
    let l = SpanLabel { span: sp(9), label: Text.from("defined here"), is_primary: false };
    assert(l.label == "defined here");
    assert(!l.is_primary);
}

// =============================================================================
// Section 9: Suggestion record (CompileDiag payload)
// =============================================================================

@test
fn test_suggestion_note_shape_no_span_no_replacement() {
    let s = Suggestion {
        kind: SuggestionKind.Note,
        message: Text.from("consider this"),
        span: Maybe.None,
        replacement: Maybe.None,
    };
    assert(s.kind is SuggestionKind.Note);
    assert(s.message == "consider this");
    assert(s.span is None);
    assert(s.replacement is None);
}

@test
fn test_suggestion_fix_shape_with_span_and_replacement() {
    let s = Suggestion {
        kind: SuggestionKind.Fix,
        message: Text.from("use .into()"),
        span: Maybe.Some(sp(3)),
        replacement: Maybe.Some(Text.from(".into()")),
    };
    assert(s.kind is SuggestionKind.Fix);
    assert(s.span is Some);
    assert(s.replacement is Some);
}

// =============================================================================
// Section 10: DiagnosticBuilder — pure fluent setters
// (`.emit()` is @compiler_intrinsic and is NOT called here)
// =============================================================================

@test
fn test_diagnostic_builder_fresh_state() {
    let b = fresh_builder();
    assert(b.severity is DiagnosticSeverity.Note);
    assert(b.code is None);
    assert(b.message is None);
    assert(b.spans.len() == 0);
    assert(b.suggestions.len() == 0);
}

@test
fn test_diagnostic_builder_error_sets_severity_and_message() {
    let b = fresh_builder().error(Text.from("mismatched types"));
    assert(b.severity is DiagnosticSeverity.Error);
    assert(b.message is Some);
}

@test
fn test_diagnostic_builder_warning_sets_severity_and_message() {
    let b = fresh_builder().warning(Text.from("unused variable"));
    assert(b.severity is DiagnosticSeverity.Warning);
    assert(b.message is Some);
}

// DEFECT META-CTX-BUILDER-CODE-METHODFIELD-1 (audit.md §3.3): the
// stdlib `DiagnosticBuilder.code(Text)` method shares its name with the
// `code` field; called cross-module at Tier-0 the invocation returns a
// corrupt value (subsequent field reads null-deref, opcode 0x62).  An
// identically-shaped method/field collision on a LOCALLY-declared type
// works fine — archive-dispatch-specific.  `.error()`/`.warning()` etc.
// (non-colliding names) work.
// @ignore: META-CTX-BUILDER-CODE-METHODFIELD-1
@ignore
@test
fn test_diagnostic_builder_code_sets_code_only() {
    let b = fresh_builder().code(Text.from("E0308"));
    assert(b.code is Some);
    assert(b.message is None);
}

@test
fn test_diagnostic_builder_code_field_direct_assignment() {
    // Data-surface counterpart of the @ignored method test above.
    let mut b = fresh_builder();
    b.code = Maybe.Some(Text.from("E0308"));
    assert(b.code is Some);
    assert(b.message is None);
}

@test
fn test_diagnostic_builder_primary_span_pushes_primary_label() {
    let b = fresh_builder().primary_span(sp(11), Text.from("found here"));
    assert(b.spans.len() == 1);
    let l: SpanLabel = b.spans[0];
    assert(l.is_primary);
    assert(l.label == "found here");
    assert(l.span == sp(11));
}

@test
fn test_diagnostic_builder_secondary_span_pushes_secondary_label() {
    let b = fresh_builder().secondary_span(sp(12), Text.from("expected here"));
    assert(b.spans.len() == 1);
    let l: SpanLabel = b.spans[0];
    assert(!l.is_primary);
    assert(l.label == "expected here");
}

@test
fn test_diagnostic_builder_note_pushes_note_suggestion() {
    let b = fresh_builder().note(Text.from("types must match"));
    assert(b.suggestions.len() == 1);
    let s: Suggestion = b.suggestions[0];
    assert(s.kind is SuggestionKind.Note);
    assert(s.message == "types must match");
    assert(s.span is None);
    assert(s.replacement is None);
}

@test
fn test_diagnostic_builder_help_pushes_help_suggestion() {
    let b = fresh_builder().help(Text.from("try .into()"));
    assert(b.suggestions.len() == 1);
    let s: Suggestion = b.suggestions[0];
    assert(s.kind is SuggestionKind.Help);
    assert(s.span is None);
}

@test
fn test_diagnostic_builder_suggest_pushes_fix_with_span_and_replacement() {
    let b = fresh_builder().suggest(Text.from("convert"), sp(4), Text.from("x.into()"));
    assert(b.suggestions.len() == 1);
    let s: Suggestion = b.suggestions[0];
    assert(s.kind is SuggestionKind.Fix);
    assert(s.span is Some);
    assert(s.replacement is Some);
}

@test
fn test_diagnostic_builder_full_chain() {
    // `.code(...)` is deliberately absent from the chain — the method is
    // defective cross-module (META-CTX-BUILDER-CODE-METHODFIELD-1, see
    // the @ignored test above) and corrupts every later link.
    let b = fresh_builder()
        .error(Text.from("mismatched types"))
        .primary_span(sp(1), Text.from("found Int"))
        .secondary_span(sp(2), Text.from("expected Text"))
        .help(Text.from("consider using .into()"));
    assert(b.severity is DiagnosticSeverity.Error);
    assert(b.message is Some);
    assert(b.code is None);
    assert(b.spans.len() == 2);
    assert(b.suggestions.len() == 1);
}

// =============================================================================
// Section 11: CacheStats record (MacroState payload)
// =============================================================================

@test
fn test_cache_stats_construction_readback() {
    let s = CacheStats { entry_count: 12, hits: 90, misses: 10, memory_bytes: 4096 };
    assert(s.entry_count == 12);
    assert(s.hits == 90);
    assert(s.misses == 10);
    assert(s.memory_bytes == 4096);
}

@test
fn test_cache_stats_zero_state() {
    let s = CacheStats { entry_count: 0, hits: 0, misses: 0, memory_bytes: 0 };
    assert(s.entry_count == 0);
    assert(s.hits + s.misses == 0);
}

// =============================================================================
// Section 12: FunctionSearchResult record (CodeSearch payload)
// =============================================================================

@test
fn test_function_search_result_construction_readback() {
    let r = FunctionSearchResult {
        name: Text.from("app.handlers.on_get"),
        module: Text.from("app.handlers"),
        is_public: true,
        span: sp(21),
        attributes: List.new(),
        signature: Text.from("fn on_get(req: Request) -> Response"),
    };
    assert(r.name == "app.handlers.on_get");
    assert(r.module == "app.handlers");
    assert(r.is_public);
    assert(r.span == sp(21));
    assert(r.attributes.len() == 0);
    assert(r.signature == "fn on_get(req: Request) -> Response");
}

@test
fn test_function_search_result_private_function() {
    let r = FunctionSearchResult {
        name: Text.from("helper"),
        module: Text.from("app"),
        is_public: false,
        span: ssp(),
        attributes: List.new(),
        signature: Text.from("fn helper()"),
    };
    assert(!r.is_public);
}

// =============================================================================
// Section 13: TypeSearchResult record (CodeSearch payload)
// =============================================================================

@test
fn test_type_search_result_struct_kind() {
    let r = TypeSearchResult {
        name: Text.from("app.User"),
        module: Text.from("app"),
        is_public: true,
        span: sp(31),
        attributes: List.new(),
        kind: TypeKind.Struct,
    };
    assert(r.name == "app.User");
    assert(r.is_public);
    assert(r.kind is TypeKind.Struct);
}

@test
fn test_type_search_result_enum_kind() {
    let r = TypeSearchResult {
        name: Text.from("app.Color"),
        module: Text.from("app"),
        is_public: false,
        span: ssp(),
        attributes: List.new(),
        kind: TypeKind.Enum,
    };
    assert(r.kind is TypeKind.Enum);
    assert(!(r.kind is TypeKind.Struct));
}

// =============================================================================
// Section 14: UsageInfo record (CodeSearch payload)
// =============================================================================

@test
fn test_usage_info_inside_function() {
    let u = UsageInfo {
        span: sp(41),
        module: Text.from("app.main"),
        containing_function: Maybe.Some(Text.from("main")),
        context: UsageContext.Call,
    };
    assert(u.module == "app.main");
    assert(u.containing_function is Some);
    assert(u.context is UsageContext.Call);
}

@test
fn test_usage_info_top_level() {
    let u = UsageInfo {
        span: ssp(),
        module: Text.from("app.types"),
        containing_function: Maybe.None,
        context: UsageContext.TypeAnnotation,
    };
    assert(u.containing_function is None);
    assert(u.context is UsageContext.TypeAnnotation);
}

@test
fn test_usage_info_other_context_payload() {
    let u = UsageInfo {
        span: ssp(),
        module: Text.from("app"),
        containing_function: Maybe.None,
        context: UsageContext.Other(Text.from("doc-link")),
    };
    assert(u.context is UsageContext.Other);
}

// =============================================================================
// Section 15: PatternMatch record (CodeSearch payload)
// =============================================================================

@test
fn test_pattern_match_empty_captures() {
    let m = PatternMatch {
        span: sp(51),
        captures: Map.new(),
        module: Text.from("app.core"),
    };
    assert(m.module == "app.core");
    assert(m.captures.len() == 0);
    assert(m.span == sp(51));
}

@test
fn test_pattern_match_with_one_capture() {
    let mut caps: Map<Text, TokenStream> = Map.new();
    caps.insert(Text.from("x"), ets());
    let m = PatternMatch {
        span: ssp(),
        captures: caps,
        module: Text.from("app"),
    };
    assert(m.captures.len() == 1);
}

