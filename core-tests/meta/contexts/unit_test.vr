// =============================================================================
// Section 26: ParseResult<Int> (AstAccess recovery-parse payload) —
// generic record + pure predicate/accessor methods
// =============================================================================

fn pr_clean_success(v: Int) -> ParseResult<Int> {
    ParseResult {
        value: Maybe.Some(v),
        errors: List.new(),
        remaining: ets(),
        success: true,
    }
}

fn pr_failed() -> ParseResult<Int> {
    let e = mk_parse_error(Text.from("unexpected token"));
    ParseResult {
        value: Maybe.None,
        errors: [e],
        remaining: ets(),
        success: false,
    }
}

fn pr_partial(v: Int) -> ParseResult<Int> {
    // Recovered: has a value AND errors; success=true (parser recovered).
    let e = mk_parse_error(Text.from("recovered"));
    ParseResult {
        value: Maybe.Some(v),
        errors: [e],
        remaining: ets(),
        success: true,
    }
}

@test
fn test_parse_result_construction_readback() {
    let r = pr_clean_success(7);
    assert(r.value is Some);
    assert(r.errors.len() == 0);
    assert(r.success);
    // Nested cross-module record reads need an annotated hop
    // (META-CTX-ELEM-INFER-1): `r.remaining.tokens` direct chain
    // misresolves the field index at Tier-0.
    let rem: TokenStream = r.remaining;
    assert(rem.tokens.len() == 0);
}

@test
fn test_parse_result_is_ok_clean_success() {
    let r = pr_clean_success(7);
    assert(r.is_ok());
}

@test
fn test_parse_result_is_ok_false_on_failure() {
    let r = pr_failed();
    assert(!r.is_ok());
}

@test
fn test_parse_result_is_ok_false_when_recovered_with_errors() {
    // success=true but errors non-empty → NOT ok.
    let r = pr_partial(3);
    assert(!r.is_ok());
}

@test
fn test_parse_result_has_errors_true() {
    let r = pr_failed();
    assert(r.has_errors());
}

@test
fn test_parse_result_has_errors_false() {
    let r = pr_clean_success(1);
    assert(!r.has_errors());
}

@test
fn test_parse_result_ok_returns_value_on_success() {
    let r = pr_clean_success(9);
    let v = r.ok();
    assert(v is Some);
}

@test
fn test_parse_result_ok_returns_none_on_failure() {
    let r = pr_failed();
    let v = r.ok();
    assert(v is None);
}

@test
fn test_parse_result_ok_returns_value_even_with_errors_when_success() {
    // `ok()` keys off `success` alone (unlike is_ok) — pinned behavior.
    let r = pr_partial(5);
    let v = r.ok();
    assert(v is Some);
}

@test
fn test_parse_result_to_result_ok_on_clean_success() {
    let r = pr_clean_success(11);
    let res = r.to_result();
    assert(res is Ok);
}

@test
fn test_parse_result_to_result_err_on_failure() {
    let r = pr_failed();
    let res = r.to_result();
    assert(res is Err);
}

// =============================================================================
// Section 27: MetaParseError record + format() + Display
// =============================================================================

@test
fn test_meta_parse_error_construction_readback() {
    let e = MetaParseError {
        message: Text.from("expected expression"),
        code: Maybe.Some(Text.from("E0101")),
        span: sp(91),
        expected: [Text.from("Int"), Text.from("Ident")],
        found: Maybe.Some(Text.from(".")),
    };
    assert(e.message == "expected expression");
    assert(e.code is Some);
    assert(e.span == sp(91));
    assert(e.expected.len() == 2);
    assert(e.found is Some);
}

@test
fn test_meta_parse_error_format_message_only() {
    let e = mk_parse_error(Text.from("boom"));
    assert(e.format() == "boom");
}

// DEFECT META-CTX-FSTRING-NEWLINE-1 (audit.md §3.4): `\n` inside an
// f-string is emitted as the LITERAL two characters `\` `n` while the
// same escape in a plain string literal produces a real newline
// (`f"x\ny".len() == 4` but `"x\ny".len() == 3`).  `format()` is built
// from f-strings, so its multi-line output currently carries literal
// `\n` sequences and these exact-equality pins fail.  The composition
// tests below cover the pure logic escape-agnostically.
// @ignore: META-CTX-FSTRING-NEWLINE-1
@ignore
@test
fn test_meta_parse_error_format_with_expected() {
    let e = MetaParseError {
        message: Text.from("boom"),
        code: Maybe.None,
        span: ssp(),
        expected: [Text.from("Int"), Text.from("Bool")],
        found: Maybe.None,
    };
    assert(e.format() == "boom\nExpected: Int, Bool");
}

// @ignore: META-CTX-FSTRING-NEWLINE-1
@ignore
@test
fn test_meta_parse_error_format_with_found() {
    let e = MetaParseError {
        message: Text.from("boom"),
        code: Maybe.None,
        span: ssp(),
        expected: List.new(),
        found: Maybe.Some(Text.from("Ident")),
    };
    assert(e.format() == "boom\nFound: Ident");
}

// @ignore: META-CTX-FSTRING-NEWLINE-1
@ignore
@test
fn test_meta_parse_error_format_with_expected_and_found() {
    let e = MetaParseError {
        message: Text.from("boom"),
        code: Maybe.None,
        span: ssp(),
        expected: [Text.from("Int")],
        found: Maybe.Some(Text.from("Text")),
    };
    assert(e.format() == "boom\nExpected: Int\nFound: Text");
}

@test
fn test_meta_parse_error_format_expected_line_composition() {
    // Escape-agnostic: message prefix + joined expected list are present.
    let e = MetaParseError {
        message: Text.from("boom"),
        code: Maybe.None,
        span: ssp(),
        expected: [Text.from("Int"), Text.from("Bool")],
        found: Maybe.None,
    };
    let out = e.format();
    let prefix = Text.from("boom");
    let exp_line = Text.from("Expected: Int, Bool");
    let found_marker = Text.from("Found:");
    assert(out.starts_with(&prefix));
    assert(out.contains(&exp_line));
    assert(!out.contains(&found_marker));
}

@test
fn test_meta_parse_error_format_found_line_composition() {
    let e = MetaParseError {
        message: Text.from("boom"),
        code: Maybe.None,
        span: ssp(),
        expected: List.new(),
        found: Maybe.Some(Text.from("Ident")),
    };
    let out = e.format();
    let prefix = Text.from("boom");
    let found_line = Text.from("Found: Ident");
    let exp_marker = Text.from("Expected:");
    assert(out.starts_with(&prefix));
    assert(out.contains(&found_line));
    assert(!out.contains(&exp_marker));
}

@test
fn test_meta_parse_error_format_both_lines_composition() {
    let e = MetaParseError {
        message: Text.from("boom"),
        code: Maybe.None,
        span: ssp(),
        expected: [Text.from("Int")],
        found: Maybe.Some(Text.from("Text")),
    };
    let out = e.format();
    let exp_line = Text.from("Expected: Int");
    let found_line = Text.from("Found: Text");
    assert(out.contains(&exp_line));
    assert(out.contains(&found_line));
}

@test
fn test_meta_parse_error_display_delegates_to_format() {
    let e = MetaParseError {
        message: Text.from("boom"),
        code: Maybe.None,
        span: ssp(),
        expected: [Text.from("Int")],
        found: Maybe.None,
    };
    assert(f"{e}" == e.format());
}

// =============================================================================
// Section 28: FormatOptions record + default() / compact()
// =============================================================================

@test
fn test_format_options_custom_construction_readback() {
    let o = FormatOptions {
        indent_width: 2,
        max_width: 80,
        use_tabs: true,
        trailing_commas: false,
        preserve_blank_lines: true,
        brace_style: BraceStyle.NextLine,
    };
    assert(o.indent_width == 2);
    assert(o.max_width == 80);
    assert(o.use_tabs);
    assert(!o.trailing_commas);
    assert(o.preserve_blank_lines);
    assert(o.brace_style is BraceStyle.NextLine);
}

@test
fn test_format_options_default_pinned_values() {
    let o = FormatOptions.default();
    assert(o.indent_width == 4);
    assert(o.max_width == 100);
    assert(!o.use_tabs);
    assert(o.trailing_commas);
    assert(o.preserve_blank_lines);
    assert(o.brace_style is BraceStyle.SameLine);
}

@test
fn test_format_options_compact_pinned_values() {
    let o = FormatOptions.compact();
    assert(o.indent_width == 0);
    assert(o.max_width == 1000);
    assert(!o.use_tabs);
    assert(!o.trailing_commas);
    assert(!o.preserve_blank_lines);
    assert(o.brace_style is BraceStyle.SameLine);
}
