@test
fn test_schema_error_construction_with_suggestion() {
    let e = SchemaError {
        message: Text.from("missing @handler attribute"),
        span: sp(71),
        severity: SchemaErrorSeverity.Error,
        suggestion: Maybe.Some(Text.from("add @handler")),
    };
    assert(e.message == "missing @handler attribute");
    assert(e.severity is SchemaErrorSeverity.Error);
    assert(e.suggestion is Some);
}

@test
fn test_schema_error_construction_without_suggestion() {
    let e = SchemaError {
        message: Text.from("odd shape"),
        span: ssp(),
        severity: SchemaErrorSeverity.Info,
        suggestion: Maybe.None,
    };
    assert(e.severity is SchemaErrorSeverity.Info);
    assert(e.suggestion is None);
}

@test
fn test_schema_error_eq_same_fields() {
    let a = SchemaError {
        message: Text.from("m"),
        span: sp(1),
        severity: SchemaErrorSeverity.Warning,
        suggestion: Maybe.None,
    };
    let b = SchemaError {
        message: Text.from("m"),
        span: sp(1),
        severity: SchemaErrorSeverity.Warning,
        suggestion: Maybe.None,
    };
    assert(a == b);
}

@test
fn test_schema_error_severity_display_error() {
    let s: SchemaErrorSeverity = SchemaErrorSeverity.Error;
    assert(f"{s}" == "error");
}

@test
fn test_schema_error_severity_display_warning() {
    let s: SchemaErrorSeverity = SchemaErrorSeverity.Warning;
    assert(f"{s}" == "warning");
}

@test
fn test_schema_error_severity_display_info() {
    let s: SchemaErrorSeverity = SchemaErrorSeverity.Info;
    assert(f"{s}" == "info");
}

@test
fn test_schema_error_display_format() {
    let e = SchemaError {
        message: Text.from("boom"),
        span: ssp(),
        severity: SchemaErrorSeverity.Error,
        suggestion: Maybe.None,
    };
    assert(f"{e}" == "schema error: boom");
}

