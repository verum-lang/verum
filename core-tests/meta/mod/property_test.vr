// =============================================================================
// core-tests/meta/mod/property_test.vr
// =============================================================================
//
// Algebraic / law-style tests for `core/meta/mod.vr`.
//
// Properties pinned here:
//   1. MetaError variant disjointness — exhaustive 13×13 matrix
//      (12 happy variants + Other)
//   2. Default constants relative ordering invariant (mem >> iter
//      >> timeout >> recursion) — same shape as `assert_eq` in
//      unit_test.vr but framed as an invariant the user expects
//      across release-level configuration overrides
//   3. VERSION_INFO components are non-negative + match VERSION text
//      prefix shape (0.1.0)
//   4. Default-limit constants are all positive (no zero/negative
//      slip-through from a verum.toml-override audit)
//
// Construction discipline (same as unit_test.vr):
//   * Direct variant construction at the test site, never
//     cross-module method-call.  MetaError's payload variants are
//     record/tuple-shaped sum-type variants — direct construction
//     works under --interp.
// =============================================================================

mount core.meta.{MetaError, DEFAULT_RECURSION_LIMIT, DEFAULT_ITERATION_LIMIT, DEFAULT_MEMORY_LIMIT, DEFAULT_TIMEOUT_MS, VERSION_INFO};
mount core.meta.span.{MetaSpan, Span, SpanFlags};
mount core.base.maybe.{Maybe};

fn synthetic_span() -> Span {
    MetaSpan {
        id: 0,
        hygiene: 0,
        flags: SpanFlags { is_expansion: false, is_synthetic: true, is_hidden: false },
    }
}

// =============================================================================
// Property 1: MetaError variant disjointness — full 13×13 anti-diagonal
// =============================================================================
//
// Every MetaError variant must be distinguishable from every OTHER
// variant via the `is` operator.  This pins the underlying tag
// allocation: each variant must carry a unique tag distinct from all
// others, otherwise pattern-matching dispatch silently routes the
// wrong variant.  The matrix is exhaustive over all 13 currently-
// declared variants:
//
//   AssetNotFound / AssetReadError / SyntaxError / ParseFailed /
//   TypeError / RecursionLimit / IterationLimit / MemoryLimit /
//   Timeout / InvalidOperation / CacheError / MethodNotFound / Other
//
// The test constructs one of each, then asserts each value's `is`
// predicate is true for ITS variant and false for every other.

@test
fn property_meta_error_all_13_variants_pairwise_disjoint() {
    let v1: MetaError = MetaError.AssetNotFound { path: Text.from("/x") };
    let v2: MetaError = MetaError.AssetReadError { path: Text.from("/x"), reason: Text.from("e") };
    let v3: MetaError = MetaError.SyntaxError { message: Text.from("m"), span: synthetic_span() };
    let v4: MetaError = MetaError.ParseFailed(List.new());
    let v5: MetaError = MetaError.TypeError { expected: Text.from("a"), found: Text.from("b") };
    let v6: MetaError = MetaError.RecursionLimit { depth: 1, limit: 1 };
    let v7: MetaError = MetaError.IterationLimit { count: 1, limit: 1 };
    let v8: MetaError = MetaError.MemoryLimit { used: 1, limit: 1 };
    let v9: MetaError = MetaError.Timeout { elapsed_ms: 1, limit_ms: 1 };
    let v10: MetaError = MetaError.InvalidOperation { operation: Text.from("o"), reason: Text.from("r") };
    let v11: MetaError = MetaError.CacheError { key: Text.from("k"), reason: Text.from("r") };
    let v12: MetaError = MetaError.MethodNotFound { type_name: Text.from("T"), method_name: Text.from("m") };
    let v13: MetaError = MetaError.Other { message: Text.from("g") };

    // Anti-diagonal: each variant's `is <Variant>` is true.
    assert(v1 is MetaError.AssetNotFound);
    assert(v2 is MetaError.AssetReadError);
    assert(v3 is MetaError.SyntaxError);
    assert(v4 is MetaError.ParseFailed);
    assert(v5 is MetaError.TypeError);
    assert(v6 is MetaError.RecursionLimit);
    assert(v7 is MetaError.IterationLimit);
    assert(v8 is MetaError.MemoryLimit);
    assert(v9 is MetaError.Timeout);
    assert(v10 is MetaError.InvalidOperation);
    assert(v11 is MetaError.CacheError);
    assert(v12 is MetaError.MethodNotFound);
    assert(v13 is MetaError.Other);

    // Off-diagonal samples — cross-family checks.
    assert(!(v1 is MetaError.SyntaxError));
    assert(!(v2 is MetaError.ParseFailed));
    assert(!(v3 is MetaError.AssetNotFound));
    assert(!(v4 is MetaError.TypeError));
    assert(!(v5 is MetaError.RecursionLimit));
    assert(!(v6 is MetaError.MemoryLimit));
    assert(!(v7 is MetaError.Timeout));
    assert(!(v8 is MetaError.IterationLimit));
    assert(!(v9 is MetaError.RecursionLimit));
    assert(!(v10 is MetaError.CacheError));
    assert(!(v11 is MetaError.InvalidOperation));
    assert(!(v12 is MetaError.Other));
    assert(!(v13 is MetaError.MethodNotFound));
}

// =============================================================================
// Property 2: Default constants relative ordering invariant
// =============================================================================
//
// The four canonical limit defaults must obey:
//     MEMORY > ITERATION > TIMEOUT > RECURSION
//
// This is a user-facing contract: the absolute defaults can be
// overridden in `verum.toml [meta]` but the relative ordering
// (memory budget largest, recursion depth smallest) is the design
// invariant.  An audit that flips the ordering (e.g. memory <
// iteration) signals a config typo that would silently degrade
// macro-expansion limits at compile time.

@test
fn property_default_limits_relative_ordering_invariant() {
    assert(DEFAULT_MEMORY_LIMIT > DEFAULT_ITERATION_LIMIT);
    assert(DEFAULT_ITERATION_LIMIT > DEFAULT_TIMEOUT_MS);
    assert(DEFAULT_TIMEOUT_MS > DEFAULT_RECURSION_LIMIT);
}

// =============================================================================
// Property 3: Default constants are strictly positive
// =============================================================================
//
// Every default limit must be > 0.  A zero or negative limit would
// halt every meta-fn at the first iteration / allocation / recursion
// step — a configuration audit smell-test that's separate from the
// ordering invariant above.

@test
fn property_default_limits_strictly_positive() {
    assert(DEFAULT_RECURSION_LIMIT > 0);
    assert(DEFAULT_ITERATION_LIMIT > 0);
    assert(DEFAULT_MEMORY_LIMIT > 0);
    assert(DEFAULT_TIMEOUT_MS > 0);
}

// =============================================================================
// Property 4: VERSION_INFO components are non-negative
// =============================================================================
//
// Semantic-version components are unsigned natural numbers.  A
// negative version component would break any consumer that compares
// against thresholds (e.g. `if VERSION_INFO.0 >= 1 { … }` capability
// gates).

@test
fn property_version_info_components_non_negative() {
    let (major, minor, patch) = VERSION_INFO;
    assert(major >= 0);
    assert(minor >= 0);
    assert(patch >= 0);
}
