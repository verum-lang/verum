// =============================================================================
// core-tests/meta/attribute/unit_test.vr
// =============================================================================
//
// `core/meta/attribute.vr` — typed attribute representation for macros / @cfg /
// @derive / @repr.
//
// Surface tested here (pure-data subset):
//   * AttributeStyle 3-variant (Word / Value / Call)
//   * MetaAttributeValue 8-variant (Ident / String / Int / Float / Bool /
//     Nested / Eq / Tokens) + ctors + as_string / as_ident / is_ident
//   * AttributeArg + .positional / .named / .is_named / accessors
//   * CfgPredicate 5-variant (Simple / KeyValue / All / Any / Not)
//   * ReprKind 4-variant (Verum / C / Transparent / Int)
//
// Live attribute parsing + evaluate() requires @compiler_intrinsic and is
// covered at the compiler-level test layer.
// =============================================================================

mount core.meta.attribute.{
    AttributeStyle, MetaAttributeValue, AttributeValue, AttributeArg,
    CfgPredicate, ReprKind,
};

// =============================================================================
// Section 1: AttributeStyle 3-variant
// =============================================================================

@test
fn test_attribute_style_word() {
    let s: AttributeStyle = AttributeStyle.Word;
    assert(s is AttributeStyle.Word);
}

@test
fn test_attribute_style_value() {
    let s: AttributeStyle = AttributeStyle.Value;
    assert(s is AttributeStyle.Value);
}

@test
fn test_attribute_style_call() {
    let s: AttributeStyle = AttributeStyle.Call;
    assert(s is AttributeStyle.Call);
}

@test
fn test_attribute_style_pairwise_disjoint() {
    let w: AttributeStyle = AttributeStyle.Word;
    let v: AttributeStyle = AttributeStyle.Value;
    let c: AttributeStyle = AttributeStyle.Call;
    assert(w is AttributeStyle.Word && !(w is AttributeStyle.Value));
    assert(v is AttributeStyle.Value && !(v is AttributeStyle.Call));
    assert(c is AttributeStyle.Call && !(c is AttributeStyle.Word));
}

// =============================================================================
// Section 2: MetaAttributeValue 8-variant
// =============================================================================

@test
fn test_meta_attribute_value_ident() {
    let v: MetaAttributeValue = MetaAttributeValue.Ident(Text.from("Clone"));
    assert(v is MetaAttributeValue.Ident);
}

@test
fn test_meta_attribute_value_string() {
    let v: MetaAttributeValue = MetaAttributeValue.String(Text.from("linux"));
    assert(v is MetaAttributeValue.String);
}

@test
fn test_meta_attribute_value_int() {
    let v: MetaAttributeValue = MetaAttributeValue.Int(42);
    assert(v is MetaAttributeValue.Int);
}

@test
fn test_meta_attribute_value_float() {
    let v: MetaAttributeValue = MetaAttributeValue.Float(3.14);
    assert(v is MetaAttributeValue.Float);
}

@test
fn test_meta_attribute_value_bool() {
    let v: MetaAttributeValue = MetaAttributeValue.Bool(true);
    assert(v is MetaAttributeValue.Bool);
}

@test
fn test_meta_attribute_value_variants_disjoint() {
    let i: MetaAttributeValue = MetaAttributeValue.Ident(Text.from("a"));
    let s: MetaAttributeValue = MetaAttributeValue.String(Text.from("a"));
    let n: MetaAttributeValue = MetaAttributeValue.Int(1);
    let b: MetaAttributeValue = MetaAttributeValue.Bool(true);
    assert(i is MetaAttributeValue.Ident && !(i is MetaAttributeValue.String));
    assert(s is MetaAttributeValue.String && !(s is MetaAttributeValue.Int));
    assert(n is MetaAttributeValue.Int && !(n is MetaAttributeValue.Bool));
    assert(b is MetaAttributeValue.Bool && !(b is MetaAttributeValue.Ident));
}

// =============================================================================
// Section 3: MetaAttributeValue ctors + accessors
// =============================================================================

@test
fn test_meta_attribute_value_ident_ctor() {
    let v = MetaAttributeValue.ident(Text.from("Eq"));
    assert(v is MetaAttributeValue.Ident);
}

@test
fn test_meta_attribute_value_string_ctor() {
    let v = MetaAttributeValue.string(Text.from("unix"));
    assert(v is MetaAttributeValue.String);
}

@test
fn test_meta_attribute_value_int_ctor() {
    let v = MetaAttributeValue.int(99);
    assert(v is MetaAttributeValue.Int);
}

@test
fn test_meta_attribute_value_bool_ctor() {
    let v = MetaAttributeValue.bool(false);
    assert(v is MetaAttributeValue.Bool);
}

@test
fn test_meta_attribute_value_is_ident_yes() {
    let v = MetaAttributeValue.ident(Text.from("X"));
    assert(v.is_ident());
}

@test
fn test_meta_attribute_value_is_ident_no() {
    let v = MetaAttributeValue.string(Text.from("X"));
    assert(!v.is_ident());
}

@test
fn test_meta_attribute_value_as_ident_match() {
    let v = MetaAttributeValue.ident(Text.from("Y"));
    let r = v.as_ident();
    assert(r is Maybe.Some);
}

@test
fn test_meta_attribute_value_as_ident_miss() {
    let v = MetaAttributeValue.int(1);
    let r = v.as_ident();
    assert(r is Maybe.None);
}

@test
fn test_meta_attribute_value_as_string_match() {
    let v = MetaAttributeValue.string(Text.from("Z"));
    let r = v.as_string();
    assert(r is Maybe.Some);
}

@test
fn test_meta_attribute_value_as_string_miss() {
    let v = MetaAttributeValue.int(1);
    let r = v.as_string();
    assert(r is Maybe.None);
}

// =============================================================================
// Section 4: AttributeArg .positional / .named / .is_named
// =============================================================================
//
// task #17/#39: `AttributeArg.positional` static method collides with a
// same-named sibling that takes a wider record (15 fields vs 3), so codegen
// writes past the AttributeArg.data size and panics. AttributeArg.named
// works because `named` is uniquely-named. @ignore until #28 closes.
//

@ignore
@test
fn test_attribute_arg_positional_not_named() {
    let a = AttributeArg.positional(MetaAttributeValue.string(Text.from("x")));
    assert(!a.is_named());
}

@ignore
@test
fn test_attribute_arg_named_is_named() {
    let a = AttributeArg.named(
        Text.from("align"),
        MetaAttributeValue.int(8),
    );
    assert(a.is_named());
}

@ignore
@test
fn test_attribute_arg_as_string_pulls_string() {
    let a = AttributeArg.positional(MetaAttributeValue.string(Text.from("linux")));
    let s = a.as_string();
    assert(s is Maybe.Some);
}

@ignore
@test
fn test_attribute_arg_as_string_miss() {
    let a = AttributeArg.positional(MetaAttributeValue.int(1));
    let s = a.as_string();
    assert(s is Maybe.None);
}

@ignore
@test
fn test_attribute_arg_as_int_pulls_int() {
    let a = AttributeArg.positional(MetaAttributeValue.int(42));
    let r = a.as_int();
    assert(r is Maybe.Some);
}

@ignore
@test
fn test_attribute_arg_as_int_miss() {
    let a = AttributeArg.positional(MetaAttributeValue.string(Text.from("x")));
    let r = a.as_int();
    assert(r is Maybe.None);
}

@ignore
@test
fn test_attribute_arg_as_bool_pulls_bool() {
    let a = AttributeArg.positional(MetaAttributeValue.bool(true));
    let r = a.as_bool();
    assert(r is Maybe.Some);
}

@ignore
@test
fn test_attribute_arg_as_ident_pulls_ident() {
    let a = AttributeArg.positional(MetaAttributeValue.ident(Text.from("X")));
    let r = a.as_ident();
    assert(r is Maybe.Some);
}

// =============================================================================
// Section 5: CfgPredicate 5-variant
// =============================================================================

@test
fn test_cfg_predicate_simple() {
    let p: CfgPredicate = CfgPredicate.Simple(Text.from("unix"));
    assert(p is CfgPredicate.Simple);
}

@test
fn test_cfg_predicate_key_value() {
    let p: CfgPredicate = CfgPredicate.KeyValue {
        key:   Text.from("target_os"),
        value: Text.from("linux"),
    };
    assert(p is CfgPredicate.KeyValue);
}

@test
fn test_cfg_predicate_all() {
    let p: CfgPredicate = CfgPredicate.All([
        CfgPredicate.Simple(Text.from("unix")),
        CfgPredicate.Simple(Text.from("debug")),
    ]);
    assert(p is CfgPredicate.All);
}

@test
fn test_cfg_predicate_any() {
    let p: CfgPredicate = CfgPredicate.Any([
        CfgPredicate.Simple(Text.from("a")),
        CfgPredicate.Simple(Text.from("b")),
    ]);
    assert(p is CfgPredicate.Any);
}

@test
fn test_cfg_predicate_not() {
    let p: CfgPredicate = CfgPredicate.Not(Heap(CfgPredicate.Simple(Text.from("windows"))));
    assert(p is CfgPredicate.Not);
}

@test
fn test_cfg_predicate_variants_pairwise_disjoint() {
    let s: CfgPredicate = CfgPredicate.Simple(Text.from("unix"));
    let kv: CfgPredicate = CfgPredicate.KeyValue {
        key: Text.from("k"), value: Text.from("v"),
    };
    let n: CfgPredicate = CfgPredicate.Not(Heap(CfgPredicate.Simple(Text.from("x"))));
    assert(s is CfgPredicate.Simple && !(s is CfgPredicate.KeyValue));
    assert(kv is CfgPredicate.KeyValue && !(kv is CfgPredicate.Not));
    assert(n is CfgPredicate.Not && !(n is CfgPredicate.Simple));
}

// =============================================================================
// Section 6: ReprKind 4-variant
// =============================================================================

@test
fn test_repr_kind_verum() {
    let k: ReprKind = ReprKind.Verum;
    assert(k is ReprKind.Verum);
}

@test
fn test_repr_kind_c() {
    let k: ReprKind = ReprKind.C;
    assert(k is ReprKind.C);
}

@test
fn test_repr_kind_transparent() {
    let k: ReprKind = ReprKind.Transparent;
    assert(k is ReprKind.Transparent);
}

@test
fn test_repr_kind_int_payload() {
    let k: ReprKind = ReprKind.Int(Text.from("Int32"));
    assert(k is ReprKind.Int);
}

@test
fn test_repr_kind_variants_pairwise_disjoint() {
    let v: ReprKind = ReprKind.Verum;
    let c: ReprKind = ReprKind.C;
    let t: ReprKind = ReprKind.Transparent;
    let i: ReprKind = ReprKind.Int(Text.from("UInt8"));
    assert(v is ReprKind.Verum && !(v is ReprKind.C));
    assert(c is ReprKind.C && !(c is ReprKind.Transparent));
    assert(t is ReprKind.Transparent && !(t is ReprKind.Int));
    assert(i is ReprKind.Int && !(i is ReprKind.Verum));
}
