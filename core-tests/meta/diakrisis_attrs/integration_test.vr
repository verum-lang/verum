// =============================================================================
// Section 4: parse_autopoietic — named-args, order-independent
// =============================================================================

@test
fn test_parse_autopoietic_both_present() {
    let attr = attr_with(
        Text.from("autopoietic"),
        List.of(named_arg(Text.from("epsilon"), MetaAttributeValue.String(Text.from("ε_math"))))
            .append(List.of(named_arg(Text.from("depth"), MetaAttributeValue.Int(3)))),
    );
    assert(parse_autopoietic(&attr) is Maybe.Some);
}

@test
fn test_parse_autopoietic_order_independent() {
    // depth first, epsilon second — same result.
    let attr = attr_with(
        Text.from("autopoietic"),
        List.of(named_arg(Text.from("depth"), MetaAttributeValue.Int(5)))
            .append(List.of(named_arg(Text.from("epsilon"), MetaAttributeValue.String(Text.from("ε_compute"))))),
    );
    assert(parse_autopoietic(&attr) is Maybe.Some);
}

@test
fn test_parse_autopoietic_missing_epsilon_rejected() {
    let attr = attr_with(
        Text.from("autopoietic"),
        List.of(named_arg(Text.from("depth"), MetaAttributeValue.Int(2))),
    );
    assert(parse_autopoietic(&attr) is Maybe.None);
}

@test
fn test_parse_autopoietic_missing_depth_rejected() {
    let attr = attr_with(
        Text.from("autopoietic"),
        List.of(named_arg(Text.from("epsilon"), MetaAttributeValue.String(Text.from("ε_math")))),
    );
    assert(parse_autopoietic(&attr) is Maybe.None);
}

@test
fn test_parse_autopoietic_negative_depth_rejected() {
    let attr = attr_with(
        Text.from("autopoietic"),
        List.of(named_arg(Text.from("epsilon"), MetaAttributeValue.String(Text.from("ε_math"))))
            .append(List.of(named_arg(Text.from("depth"), MetaAttributeValue.Int(-1)))),
    );
    assert(parse_autopoietic(&attr) is Maybe.None);
}

@test
fn test_parse_autopoietic_wrong_name_rejected() {
    let attr = attr_with(
        Text.from("not_autopoietic"),
        List.of(named_arg(Text.from("epsilon"), MetaAttributeValue.String(Text.from("x"))))
            .append(List.of(named_arg(Text.from("depth"), MetaAttributeValue.Int(1)))),
    );
    assert(parse_autopoietic(&attr) is Maybe.None);
}

@test
fn test_parse_autopoietic_epsilon_int_value_rejected() {
    // Wrong value type for epsilon: needs String, given Int.
    let attr = attr_with(
        Text.from("autopoietic"),
        List.of(named_arg(Text.from("epsilon"), MetaAttributeValue.Int(42)))
            .append(List.of(named_arg(Text.from("depth"), MetaAttributeValue.Int(1)))),
    );
    assert(parse_autopoietic(&attr) is Maybe.None);
}

// =============================================================================
// Section 5: parse_ludic_design — zero args
// =============================================================================

@test
fn test_parse_ludic_design_zero_args() {
    let attr = simple_attr(Text.from("ludic_design"));
    assert(parse_ludic_design(&attr) is Maybe.Some);
}

@test
fn test_parse_ludic_design_with_args_rejected() {
    let attr = attr_with(
        Text.from("ludic_design"),
        List.of(positional_arg(MetaAttributeValue.Int(1))),
    );
    assert(parse_ludic_design(&attr) is Maybe.None);
}

@test
fn test_parse_ludic_design_wrong_name_rejected() {
    let attr = simple_attr(Text.from("ludic"));
    assert(parse_ludic_design(&attr) is Maybe.None);
}

