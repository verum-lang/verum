// =============================================================================
// Section 2: parse_effect_attr — rejections
// =============================================================================

@test
fn test_parse_effect_attr_wrong_name_rejected() {
    let attr = attr_with(
        Text.from("not_effect"),
        List.of(positional_arg(MetaAttributeValue.Ident(Text.from("pure")))),
    );
    assert(parse_effect_attr(&attr) is Maybe.None);
}

@test
fn test_parse_effect_attr_no_args_rejected() {
    let attr = attr_with(Text.from("effect"), List.new());
    assert(parse_effect_attr(&attr) is Maybe.None);
}

@test
fn test_parse_effect_attr_string_arg_rejected() {
    let attr = attr_with(
        Text.from("effect"),
        List.of(positional_arg(MetaAttributeValue.String(Text.from("pure")))),
    );
    assert(parse_effect_attr(&attr) is Maybe.None);
}

@test
fn test_parse_effect_attr_unknown_ident_rejected() {
    let attr = attr_with(
        Text.from("effect"),
        List.of(positional_arg(MetaAttributeValue.Ident(Text.from("frobnicate")))),
    );
    assert(parse_effect_attr(&attr) is Maybe.None);
}

@test
fn test_parse_effect_attr_named_arg_rejected() {
    // Positional-only contract; named-form must be rejected.
    let attr = attr_with(
        Text.from("effect"),
        List.of(named_arg(
            Text.from("kind"),
            MetaAttributeValue.Ident(Text.from("pure")),
        )),
    );
    assert(parse_effect_attr(&attr) is Maybe.None);
}

