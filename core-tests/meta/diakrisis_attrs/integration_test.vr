// =============================================================================
// core-tests/meta/diakrisis_attrs/integration_test.vr
// =============================================================================
//
// Integration tests for the five `parse_*` functions in
// `core/meta/diakrisis_attrs.vr` — now that the `AttributeArg` schema
// drift (audit §3.1) is closed and the parsers actually match the
// record-form `AttributeArg`.
//
// Construction discipline: direct record literal at the test site for
// `Attribute` / `AttributeArg` / `TokenStream` / `Span` — avoids the
// cross-module record-return field-access OOB defect (see
// meta/span audit §3.1).
// =============================================================================

mount core.meta.diakrisis_attrs.{
    DiakrisisEffectKind, EffectAttr,
    InfinityLevel, InfinityCategoryAttr,
    AutopoieticAttr, LudicDesignAttr, CutEliminationAttr,
    CUT_ELIMINATION_DEFAULT_BOUND,
    parse_effect_attr, parse_infinity_category, parse_autopoietic,
    parse_ludic_design, parse_cut_elimination,
};
mount core.meta.attribute.{Attribute, AttributeStyle, AttributeArg, MetaAttributeValue};
mount core.meta.token.{TokenStream};
mount core.meta.span.{MetaSpan, Span, SpanFlags};
mount core.base.maybe.{Maybe};

// =============================================================================
// Helpers (direct record construction — sidesteps cross-module .new ctors)
// =============================================================================

fn syn_span() -> Span {
    MetaSpan {
        id: 0,
        hygiene: 0,
        flags: SpanFlags { is_expansion: false, is_synthetic: true, is_hidden: false },
    }
}

fn empty_tokens() -> TokenStream {
    TokenStream { tokens: List.new(), span: syn_span() }
}

fn positional_arg(value: MetaAttributeValue) -> AttributeArg {
    AttributeArg { name: Maybe.None, value, span: syn_span() }
}

fn named_arg(name: Text, value: MetaAttributeValue) -> AttributeArg {
    AttributeArg { name: Maybe.Some(name), value, span: syn_span() }
}

fn attr_with(name: Text, args: List<AttributeArg>) -> Attribute {
    Attribute {
        name,
        style: AttributeStyle.Call,
        args,
        tokens: empty_tokens(),
        span: syn_span(),
    }
}

fn simple_attr(name: Text) -> Attribute {
    Attribute {
        name,
        style: AttributeStyle.Word,
        args: List.new(),
        tokens: empty_tokens(),
        span: syn_span(),
    }
}

// =============================================================================
// Section 1: parse_effect_attr — 7 canonical kinds + 2 aliases
// =============================================================================

@test
fn test_parse_effect_attr_pure() {
    let attr = attr_with(
        Text.from("effect"),
        List.of(positional_arg(MetaAttributeValue.Ident(Text.from("pure")))),
    );
    let r = parse_effect_attr(&attr);
    assert(r is Maybe.Some);
}

@test
fn test_parse_effect_attr_io() {
    let attr = attr_with(
        Text.from("effect"),
        List.of(positional_arg(MetaAttributeValue.Ident(Text.from("io")))),
    );
    assert(parse_effect_attr(&attr) is Maybe.Some);
}

