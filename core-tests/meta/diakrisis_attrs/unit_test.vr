@test
fn test_effect_kind_as_str_pure() {
    let k: DiakrisisEffectKind = DiakrisisEffectKind.Pure;
    assert(k.as_str() == "pure");
}

@test
fn test_effect_kind_as_str_io() {
    let k: DiakrisisEffectKind = DiakrisisEffectKind.Io;
    assert(k.as_str() == "io");
}

@test
fn test_effect_kind_as_str_exception() {
    let k: DiakrisisEffectKind = DiakrisisEffectKind.Exception;
    assert(k.as_str() == "exception");
}

@test
fn test_effect_kind_as_str_nondet() {
    let k: DiakrisisEffectKind = DiakrisisEffectKind.Nondet;
    assert(k.as_str() == "nondet");
}

@test
fn test_effect_kind_as_str_quantum() {
    let k: DiakrisisEffectKind = DiakrisisEffectKind.Quantum;
    assert(k.as_str() == "quantum");
}

// =============================================================================
// Section 4: EffectKind public alias
// =============================================================================

@test
fn test_effect_kind_public_alias_resolves() {
    let k: EffectKind = DiakrisisEffectKind.State;
    assert(k is DiakrisisEffectKind.State);
}

// =============================================================================
// Section 5: InfinityLevel 3-variant
// =============================================================================

@test
fn test_infinity_level_finite_zero() {
    let l: InfinityLevel = InfinityLevel.Finite(0);
    assert(l is InfinityLevel.Finite);
}

@test
fn test_infinity_level_finite_two() {
    let l: InfinityLevel = InfinityLevel.Finite(2);
    assert(l is InfinityLevel.Finite);
}

@test
fn test_infinity_level_omega() {
    let l: InfinityLevel = InfinityLevel.Omega;
    assert(l is InfinityLevel.Omega);
}

@test
fn test_infinity_level_omega_omega() {
    let l: InfinityLevel = InfinityLevel.OmegaOmega;
    assert(l is InfinityLevel.OmegaOmega);
}

@test
fn test_infinity_level_variants_pairwise_disjoint() {
    let f: InfinityLevel = InfinityLevel.Finite(1);
    let o: InfinityLevel = InfinityLevel.Omega;
    let oo: InfinityLevel = InfinityLevel.OmegaOmega;
    assert(f is InfinityLevel.Finite && !(f is InfinityLevel.Omega));
    assert(o is InfinityLevel.Omega && !(o is InfinityLevel.OmegaOmega));
    assert(oo is InfinityLevel.OmegaOmega && !(oo is InfinityLevel.Finite));
}

// =============================================================================
// Section 6: InfinityLevel.as_str
// =============================================================================

@test
fn test_infinity_level_as_str_omega() {
    let l: InfinityLevel = InfinityLevel.Omega;
    assert(l.as_str() == "omega");
}

@test
fn test_infinity_level_as_str_omega_omega() {
    let l: InfinityLevel = InfinityLevel.OmegaOmega;
    assert(l.as_str() == "omega_omega");
}

// =============================================================================
// Section 7: EffectAttr / InfinityCategoryAttr / AutopoieticAttr /
//            LudicDesignAttr / CutEliminationAttr — record construction
// =============================================================================

@test
fn test_effect_attr_record_construction() {
    let a = EffectAttr { kind: DiakrisisEffectKind.Io, span: synthetic_span() };
    assert(a.kind is DiakrisisEffectKind.Io);
}

@test
fn test_infinity_category_attr_record_construction() {
    let a = InfinityCategoryAttr { level: InfinityLevel.Omega, span: synthetic_span() };
    assert(a.level is InfinityLevel.Omega);
}

@test
fn test_autopoietic_attr_record_construction() {
    let a = AutopoieticAttr {
        epsilon: Text.from("ε_math"),
        depth: 3,
        span: synthetic_span(),
    };
    assert(a.epsilon == "ε_math");
    assert(a.depth == 3);
}

@test
fn test_ludic_design_attr_record_construction() {
    let a = LudicDesignAttr { span: synthetic_span() };
    // No payload — construction is the assertion.
    let _ = a;
}

@test
fn test_cut_elimination_attr_record_construction() {
    let a = CutEliminationAttr { bound: 500, span: synthetic_span() };
    assert(a.bound == 500);
}

// =============================================================================
// Section 8: CUT_ELIMINATION_DEFAULT_BOUND constant
// =============================================================================

@test
fn test_cut_elimination_default_bound_value() {
    assert(CUT_ELIMINATION_DEFAULT_BOUND == 1000);
}
