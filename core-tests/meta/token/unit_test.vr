// =============================================================================
// core-tests/meta/token/unit_test.vr
// =============================================================================
//
// `core/meta/token.vr` — Token streams + tokens + delimited groups.
// Pure-data subset that does NOT call @compiler_intrinsic ctors at
// runtime (`Span.call_site`, `TokenStream.from_str`,
// `keyword_from_str`).
//
// Surface tested here:
//   * Delimiter 4-variant (Parenthesis / Brace / Bracket / Invisible)
//     + .open / .close
//   * Spacing 2-variant (Joint / Alone)
//   * Keyword 38-variant (sample of representative members)
//   * StringKind 4-variant (Normal / Format / Raw / RawFormat)
//   * TokenKind 6-variant (Ident / Kw / Lit / Punct / DocComment / Eof)
//   * Literal 6-variant (Int / Float / String / Char / Bool / ByteString)
//     + Literal ctors (.int / .float / .string / .char / .bool /
//                      .format_string / .raw_string)
//   * Token record direct construction + .is_ident / .as_ident /
//     .is_keyword / .is_literal / .is_punct / .as_punct
//   * TokenTree.Leaf / TokenTree.Grouped variant disjointness +
//     .is_token / .is_group / .as_token / .as_group
//   * TokenStream record direct construction + .is_empty / .len /
//     .span / .first / .last / .trees / .to_trees
//   * Group record + .delimiter / .tokens
//   * LexError record + .new + Eq derived
// =============================================================================

mount core.meta.token.{
    TokenStream, Token, TokenTree, TokenKind, Token as TokenStruct,
    Delimiter, Spacing, Keyword, Literal, StringKind, Group, LexError,
};
mount core.meta.span.{MetaSpan, Span, SpanFlags};
mount core.base.maybe.{Maybe};

fn synthetic_span() -> Span {
    MetaSpan {
        id: 0,
        hygiene: 0,
        flags: SpanFlags { is_expansion: false, is_synthetic: true, is_hidden: false },
    }
}

fn span_with_id(id: UInt64) -> Span {
    MetaSpan {
        id,
        hygiene: 0,
        flags: SpanFlags { is_expansion: false, is_synthetic: false, is_hidden: false },
    }
}

// =============================================================================
// Section 1: Delimiter 4-variant
// =============================================================================

@test
fn test_delimiter_parenthesis() {
    let d: Delimiter = Delimiter.Parenthesis;
    assert(d is Delimiter.Parenthesis);
}

@test
fn test_delimiter_brace() {
    let d: Delimiter = Delimiter.Brace;
    assert(d is Delimiter.Brace);
}

@test
fn test_delimiter_bracket() {
    let d: Delimiter = Delimiter.Bracket;
    assert(d is Delimiter.Bracket);
}

@test
fn test_delimiter_invisible() {
    let d: Delimiter = Delimiter.Invisible;
    assert(d is Delimiter.Invisible);
}

@test
fn test_delimiter_pairwise_disjoint() {
    let p: Delimiter = Delimiter.Parenthesis;
    let br: Delimiter = Delimiter.Brace;
    let bk: Delimiter = Delimiter.Bracket;
    let iv: Delimiter = Delimiter.Invisible;
    assert(p is Delimiter.Parenthesis && !(p is Delimiter.Brace));
    assert(br is Delimiter.Brace && !(br is Delimiter.Bracket));
    assert(bk is Delimiter.Bracket && !(bk is Delimiter.Invisible));
    assert(iv is Delimiter.Invisible && !(iv is Delimiter.Parenthesis));
}

// =============================================================================
// Section 2: Delimiter.open / .close
// =============================================================================

@test
fn test_delimiter_open_parenthesis() {
    let d: Delimiter = Delimiter.Parenthesis;
    let r = d.open();
    assert(r is Maybe.Some);
}

@test
fn test_delimiter_close_brace() {
    let d: Delimiter = Delimiter.Brace;
    let r = d.close();
    assert(r is Maybe.Some);
}

@test
fn test_delimiter_open_invisible_is_none() {
    let d: Delimiter = Delimiter.Invisible;
    let r = d.open();
    assert(r is Maybe.None);
}

@test
fn test_delimiter_close_invisible_is_none() {
    let d: Delimiter = Delimiter.Invisible;
    let r = d.close();
    assert(r is Maybe.None);
}

// =============================================================================
// Section 3: Spacing 2-variant
// =============================================================================

@test
fn test_spacing_joint() {
    let s: Spacing = Spacing.Joint;
    assert(s is Spacing.Joint);
}

@test
fn test_spacing_alone() {
    let s: Spacing = Spacing.Alone;
    assert(s is Spacing.Alone);
}

@test
fn test_spacing_variants_disjoint() {
    let j: Spacing = Spacing.Joint;
    let a: Spacing = Spacing.Alone;
    assert(j is Spacing.Joint && !(j is Spacing.Alone));
    assert(a is Spacing.Alone && !(a is Spacing.Joint));
}

