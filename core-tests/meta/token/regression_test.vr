// =============================================================================
// core-tests/meta/token/regression_test.vr
// =============================================================================
//
// Pinned regressions for `core/meta/token.vr`.
// =============================================================================

mount core.meta.token.{Group, Delimiter, TokenStream, TokenTree, Token, TokenKind};
mount core.meta.span.{MetaSpan, SpanFlags};
mount core.base.maybe.{Maybe};

fn syn() -> MetaSpan {
    MetaSpan { id: 0, hygiene: 0, flags: SpanFlags { is_expansion: false, is_synthetic: true, is_hidden: false } }
}

fn empty_stream() -> TokenStream {
    TokenStream { tokens: List.new(), span: syn() }
}

// =============================================================================
// META-GROUP-XMODULE-1 — cross-module simple-type-name collision → Group
//                        field-write out of bounds
// =============================================================================
//
// DEFECT CLASS: archive type-name collision across modules.
//
// Constructing `meta.token.Group { delimiter, tokens, span }` died with:
//
//   Panic: field write out of bounds: field index 3 (offset 24+8 = 32)
//          exceeds object data size 24  type_id=1240 type='Group'
//          backtrace=[…@pc=46]
//
// ROOT CAUSE: the archive loader keyed types by their **simple** name in
// a first-wins registry.  Three unrelated `Group`s exist in the stdlib:
//
//   * `core.meta.token.Group`   — the 3-field record { delimiter, tokens, span }
//   * `core.math.algebra.Group` — an algebraic-structure *protocol*
//   * `core.cli.spec.Group`     — a CLI argument-group record
//
// Whichever `Group` was registered first won the bare name `Group`, so
// `meta.token.Group`'s field writes resolved against the *wrong* type's
// layout — a 3-field (24-byte) object was addressed as if it had the
// colliding type's shape, and the write of field index 3 (the `span`
// field, at byte offset 24) ran off the end of the 24-byte allocation.
//
// INTENDED FIX: module-qualified type registration + mount-aware re-key,
// so `meta.token.Group` retains its own 3-field layout regardless of
// which same-named type loaded first.
//
// ORDER-SENSITIVITY (observed 2026-07-06).  Because the collision lives
// in a *global* first-wins registry, the manifestation is nondeterministic
// with respect to the set + order of modules compiled in a single
// `verum test` run — NOT reproducible from any one file in isolation:
//
//   * `verum test --interp --filter meta/token/` with ONLY `unit_test.vr`
//     present in the folder → the `test_group_record_construction_*`
//     tests hit the OOB above (meta.token.Group LOST the bare name).
//   * The same filter with `property_test.vr` + this file also present
//     → all Group constructions resolve correctly (meta.token.Group WON
//     the bare name); the folder is green.
//
// The four tests below therefore act as a CANARY, not a deterministic
// red-until-fixed pin: they exercise the Group construct + `.delimiter()`
// / `.tokens()` read-back path (field 0 and field 1 reads, plus the
// trailing `span` field-2 write that overran the allocation).  On the
// current binary + suite composition they PASS; a proper module-qualified
// registration fix makes them pass deterministically under EVERY load
// order.  Any future run that turns these (or the `unit_test.vr` Group
// tests) red is the collision resurfacing — re-open META-GROUP-XMODULE-1
// and validate the fix across multiple suite compositions, not one filter.
// =============================================================================

@test
fn regression_meta_group_xmodule_parenthesis() {
    let g = Group { delimiter: Delimiter.Parenthesis, tokens: empty_stream(), span: syn() };
    assert(g.delimiter() is Delimiter.Parenthesis);
    assert(g.tokens().is_empty());
}

@test
fn regression_meta_group_xmodule_brace() {
    let g = Group { delimiter: Delimiter.Brace, tokens: empty_stream(), span: syn() };
    assert(g.delimiter() is Delimiter.Brace);
    assert(g.tokens().is_empty());
}

@test
fn regression_meta_group_xmodule_bracket() {
    let g = Group { delimiter: Delimiter.Bracket, tokens: empty_stream(), span: syn() };
    assert(g.delimiter() is Delimiter.Bracket);
    assert(g.tokens().is_empty());
}

@test
fn regression_meta_group_xmodule_nonempty_tokens_readback() {
    // Group carrying a real token — exercises the `tokens` (field 1)
    // read as well as the `delimiter` (field 0) read after the layout
    // fix, so a partial fix that only corrected the trailing `span`
    // field would still be caught.
    let leaf = TokenTree.Leaf(Token { kind: TokenKind.Ident(Text.from("x")), span: syn() });
    let inner = TokenStream { tokens: List.of(leaf), span: syn() };
    let g = Group { delimiter: Delimiter.Bracket, tokens: inner, span: syn() };
    assert(g.delimiter() is Delimiter.Bracket);
    assert_eq(g.tokens().len(), 1);
}

fn main() {}
