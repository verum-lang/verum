// =============================================================================
// core-tests/meta/token/regression_test.vr
// =============================================================================
//
// Pinned regressions for `core/meta/token.vr`.
// =============================================================================

mount core.meta.token.{TokenGroup, Delimiter, TokenStream, TokenTree, Token, TokenKind};
mount core.meta.span.{MetaSpan, SpanFlags};
mount core.base.maybe.{Maybe};

fn syn() -> MetaSpan {
    MetaSpan { id: 0, hygiene: 0, flags: SpanFlags { is_expansion: false, is_synthetic: true, is_hidden: false } }
}

fn empty_stream() -> TokenStream {
    TokenStream { tokens: List.new(), span: syn() }
}

// =============================================================================
// META-GROUP-XMODULE-1 — cross-module simple-type-name collision (historical)
// =============================================================================
//
// DEFECT CLASS: archive type-name collision across modules (first-wins on
// the *simple* name).  These tests were born from it; the record has since
// been renamed to a unique simple name, so the history is recorded here.
//
// ORIGINAL SYMPTOM.  Constructing the meta.token group record died with:
//
//   Panic: field write out of bounds: field index 3 (offset 24+8 = 32)
//          exceeds object data size 24  type_id=1240 type='Group'
//
// ROOT CAUSE: the codegen layout registry keyed types by their **simple**
// name in a first-wins map.  Three unrelated `Group`s existed in the stdlib:
//
//   * `core.meta.token.Group`   — a 3-field record { delimiter, tokens, span }
//   * `core.math.algebra.Group` — an algebraic-structure *protocol*
//   * `core.cli.spec.Group`     — a CLI argument-group record
//
// Whichever `Group` registered first won the bare name, so the meta.token
// record's field writes resolved against the *wrong* type's layout — the
// 3-field (24-byte) object was addressed with the colliding type's shape and
// the field-index-3 write (`span`, byte offset 24) ran off the 24-byte
// allocation.
//
// RESOLUTION (current tree).  The two colliding *records* were given unique
// simple names so no two record layouts contend for one bare key:
// `meta.token.Group` -> `TokenGroup` (this suite) and `cli.spec.Group` ->
// `ArgGroup`.  Only the `math.algebra.Group` *protocol* keeps the bare name,
// and protocols carry no record layout, so the collision is structurally gone
// for these types.
//
// The DEEPER root — a layout registry that is first-wins on the simple name —
// is NOT closed by the renames; it is tracked as T0408
// (SIMPLE-KEY-LAYOUT-SQUAT-CONSUMER-1: `type_field_layouts` simple-key is a
// first-wins global namespace).  T0408's charter is the module-qualified /
// mount-aware re-key that lets same-simple-name types coexist safely; a
// genuine cross-module same-simple-name collision regression belongs there.
//
// The four tests below now construct `TokenGroup` and guard its 3-field
// layout + `.delimiter()` / `.tokens()` read-back (field 0 and field 1 reads
// plus the trailing `span` field-2 write that historically overran).  They no
// longer exercise the collision itself (TokenGroup's name is unique) — that
// guard moves to T0408.
// =============================================================================

@test
fn regression_meta_group_xmodule_parenthesis() {
    let g = TokenGroup { delimiter: Delimiter.Parenthesis, tokens: empty_stream(), span: syn() };
    assert(g.delimiter() is Delimiter.Parenthesis);
    assert(g.tokens().is_empty());
}

@test
fn regression_meta_group_xmodule_brace() {
    let g = TokenGroup { delimiter: Delimiter.Brace, tokens: empty_stream(), span: syn() };
    assert(g.delimiter() is Delimiter.Brace);
    assert(g.tokens().is_empty());
}

@test
fn regression_meta_group_xmodule_bracket() {
    let g = TokenGroup { delimiter: Delimiter.Bracket, tokens: empty_stream(), span: syn() };
    assert(g.delimiter() is Delimiter.Bracket);
    assert(g.tokens().is_empty());
}

@test
fn regression_meta_group_xmodule_nonempty_tokens_readback() {
    // Group carrying a real token — exercises the `tokens` (field 1)
    // read as well as the `delimiter` (field 0) read after the layout
    // fix, so a partial fix that only corrected the trailing `span`
    // field would still be caught.
    let leaf = TokenTree.Leaf(Token { kind: TokenKind.Ident(Text.from("x")), span: syn() });
    let inner = TokenStream { tokens: List.of(leaf), span: syn() };
    let g = TokenGroup { delimiter: Delimiter.Bracket, tokens: inner, span: syn() };
    assert(g.delimiter() is Delimiter.Bracket);
    assert_eq(g.tokens().len(), 1);
}

fn main() {}
