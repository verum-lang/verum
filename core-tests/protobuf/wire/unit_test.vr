// =============================================================================
// core-tests/protobuf/wire/unit_test.vr
// =============================================================================
//
// `core/protobuf/wire.vr` — Protocol Buffers wire format (proto3 v3
// canonical encoding).  Tag (field_number, wire_type) coding + varint
// encode/decode + ProtobufCursor for reader state.
//
// Surface tested here (pure-data subset):
//   * WireType 4-variant (Varint / Fixed64 / LengthDelim / Fixed32)
//   * .to_u8 canonical wire-tag values (proto3 spec table)
//   * tag_value (field_number << 3 | wire_type)
//   * MAX_LENGTH_DELIM constant (32 MiB DoS guard)
//
// from_u8 / write_varint / read_varint / write_tag tests would require
// either a Result chain or a List<Byte> buffer round-trip — both hit
// cross-module record-return defects. Integration tests deferred.
// =============================================================================

mount core.protobuf.wire.{WireType, MAX_LENGTH_DELIM, tag_value};

// =============================================================================
// Section 1: WireType 4-variant
// =============================================================================

@test
fn test_wire_type_varint() {
    let t: WireType = WireType.Varint;
    assert(t is WireType.Varint);
}

@test
fn test_wire_type_fixed64() {
    let t: WireType = WireType.Fixed64;
    assert(t is WireType.Fixed64);
}

@test
fn test_wire_type_length_delim() {
    let t: WireType = WireType.LengthDelim;
    assert(t is WireType.LengthDelim);
}

@test
fn test_wire_type_fixed32() {
    let t: WireType = WireType.Fixed32;
    assert(t is WireType.Fixed32);
}

@test
fn test_wire_type_pairwise_disjoint() {
    let v: WireType = WireType.Varint;
    let f64: WireType = WireType.Fixed64;
    let ld: WireType = WireType.LengthDelim;
    let f32: WireType = WireType.Fixed32;
    assert(v is WireType.Varint && !(v is WireType.Fixed64));
    assert(f64 is WireType.Fixed64 && !(f64 is WireType.LengthDelim));
    assert(ld is WireType.LengthDelim && !(ld is WireType.Fixed32));
    assert(f32 is WireType.Fixed32 && !(f32 is WireType.Varint));
}

// =============================================================================
// Section 2: WireType.to_u8 — canonical proto3 wire-tag values
// =============================================================================
//
// Per https://protobuf.dev/programming-guides/encoding/#structure
//   0 = VARINT          (int32, int64, uint32, uint64, sint32, sint64, bool, enum)
//   1 = I64             (fixed64, sfixed64, double)
//   2 = LEN             (string, bytes, embedded messages, packed repeated)
//   3 = SGROUP          (deprecated, removed from proto3)
//   4 = EGROUP          (deprecated, removed from proto3)
//   5 = I32             (fixed32, sfixed32, float)

@test
fn test_wire_type_varint_canonical_value_0() {
    let v: WireType = WireType.Varint;
    assert(v.to_u8() == 0);
}

@test
fn test_wire_type_fixed64_canonical_value_1() {
    let v: WireType = WireType.Fixed64;
    assert(v.to_u8() == 1);
}

@test
fn test_wire_type_length_delim_canonical_value_2() {
    let v: WireType = WireType.LengthDelim;
    assert(v.to_u8() == 2);
}

@test
fn test_wire_type_fixed32_canonical_value_5() {
    let v: WireType = WireType.Fixed32;
    assert(v.to_u8() == 5);
}

@test
fn test_wire_type_to_u8_all_distinct() {
    assert(WireType.Varint.to_u8() != WireType.Fixed64.to_u8());
    assert(WireType.Fixed64.to_u8() != WireType.LengthDelim.to_u8());
    assert(WireType.LengthDelim.to_u8() != WireType.Fixed32.to_u8());
    assert(WireType.Fixed32.to_u8() != WireType.Varint.to_u8());
}

@test
fn test_wire_type_no_group_codes_in_canonical_set() {
    // SGROUP (3) and EGROUP (4) are deprecated and MUST not be in
    // the canonical set per proto3 spec.
    assert(WireType.Varint.to_u8() != 3);
    assert(WireType.Fixed64.to_u8() != 3);
    assert(WireType.LengthDelim.to_u8() != 3);
    assert(WireType.Fixed32.to_u8() != 3);
    assert(WireType.Varint.to_u8() != 4);
    assert(WireType.Fixed64.to_u8() != 4);
    assert(WireType.LengthDelim.to_u8() != 4);
    assert(WireType.Fixed32.to_u8() != 4);
}

// =============================================================================
// Section 3: tag_value — (field_number << 3) | wire_type
// =============================================================================

@test
fn test_tag_value_field_1_varint() {
    // field_number=1, wire_type=Varint(0) → tag = (1 << 3) | 0 = 8
    let t = tag_value(1, WireType.Varint);
    assert(t == 8);
}

@test
fn test_tag_value_field_1_fixed64() {
    // field_number=1, wire_type=Fixed64(1) → tag = (1 << 3) | 1 = 9
    let t = tag_value(1, WireType.Fixed64);
    assert(t == 9);
}

@test
fn test_tag_value_field_1_length_delim() {
    // field_number=1, wire_type=LengthDelim(2) → tag = (1 << 3) | 2 = 10
    let t = tag_value(1, WireType.LengthDelim);
    assert(t == 10);
}

@test
fn test_tag_value_field_1_fixed32() {
    // field_number=1, wire_type=Fixed32(5) → tag = (1 << 3) | 5 = 13
    let t = tag_value(1, WireType.Fixed32);
    assert(t == 13);
}

@test
fn test_tag_value_field_2_varint() {
    // (2 << 3) | 0 = 16
    let t = tag_value(2, WireType.Varint);
    assert(t == 16);
}

@test
fn test_tag_value_field_15_varint_single_byte_boundary() {
    // field_number=15 is the largest single-byte-encoded field tag
    // for Varint wire type. (15 << 3) | 0 = 120 (fits in 1 varint byte).
    let t = tag_value(15, WireType.Varint);
    assert(t == 120);
}

@test
fn test_tag_value_field_16_varint_two_byte_boundary() {
    // field_number=16 is the first 2-byte-encoded field tag.
    // (16 << 3) | 0 = 128 (requires 2 varint bytes).
    let t = tag_value(16, WireType.Varint);
    assert(t == 128);
}

@test
fn test_tag_value_field_2047_max_two_byte_varint() {
    // field_number=2047 is the largest 2-byte-encoded field tag.
    // (2047 << 3) | 0 = 16376 (< 16384 = 2^14, fits in 2 varint bytes).
    let t = tag_value(2047, WireType.Varint);
    assert(t == 16376);
}

@test
fn test_tag_value_high_field_with_wire_type() {
    // (536870911 << 3) | 5 = max field-number * 8 + Fixed32 wire-type
    // 2^29-1 is the max proto3 field number.
    let t = tag_value(536870911, WireType.Fixed32);
    assert(t == ((536870911 * 8) + 5));
}

// =============================================================================
// Section 4: MAX_LENGTH_DELIM — DoS guard
// =============================================================================

@test
fn test_max_length_delim_is_32mib() {
    // 32 * 1024 * 1024 = 33,554,432
    assert(MAX_LENGTH_DELIM == 33554432);
}

@test
fn test_max_length_delim_positive() {
    // DoS-guard MUST be positive (a zero or negative cap would
    // reject all messages OR accept all messages).
    assert(MAX_LENGTH_DELIM > 0);
}

@test
fn test_max_length_delim_under_int_max() {
    // Sanity: 32 MiB is well under Int32 max (2 GiB) — no overflow risk.
    assert(MAX_LENGTH_DELIM < 2147483647);
}
