fn encode(data: Int{>= 0, < 16}) -> Int {
    let d0 = data & 1;
    let d1 = (data >> 1) & 1;
    let d2 = (data >> 2) & 1;
    let d3 = (data >> 3) & 1;
    let p1 = d0 ^ d1 ^ d3;
    let p2 = d0 ^ d2 ^ d3;
    let p4 = d1 ^ d2 ^ d3;
    p1 | (p2 << 1) | (d0 << 2) | (p4 << 3) | (d1 << 4) | (d2 << 5) | (d3 << 6)
}

fn extract(w: Int{>= 0, < 128}) -> Int {
    ((w >> 2) & 1) | (((w >> 4) & 1) << 1) | (((w >> 5) & 1) << 2) | (((w >> 6) & 1) << 3)
}

fn main() {
    let nested = extract(encode(5));
    let e5 = encode(5);
    let x5 = extract(e5);
    print(f"nested={nested} two-step: e5={e5} x5={x5}");
}
