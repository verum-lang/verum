fn main() {
    let t: Text = "abcd";
    let bs = t.as_bytes();
    print(f"blen={bs.len()}");
    print(f"b1={bs[1]}");
    let mut acc = 0;
    for b in bs { acc += *b; }
    print(f"bsum={acc}");
    let sub = bs.slice(1, 3);
    print(f"slen={sub.len()}");
    print(f"s0={sub[0]}");
    let mut acc2 = 0;
    for b in sub { acc2 += *b; }
    print(f"ssum={acc2}");
}
// SUBSLICE-AOT-LEN0 pinned repro (task #56).
// Expected BOTH tiers: blen=4 b1=98 bsum=394 slen=2 s0=98 ssum=197.
// Regressed AOT-only: slen=0 (interp perfect). Bisect: green at the
// ded20ea4a-era binaries (fix82), red after the 2026-07-15 peer window
// (10 commits touching llvm/instruction.rs: MONO-DEFAULT-ON-1,
// MEM-SLICE-INTRINSIC-FATREF-1, stamps ac0ad45c9, ...). Mono
// kill-switch (VERUM_DISABLE_MONO_AOT=1) does NOT change it. The VBC
// route is correct ([slice-route] receiver_type=Some("[Byte]") →
// typed [T].slice intercept → SliceSubslice opcode; the interpreter
// executes the same bytecode correctly) — the defect is in the AOT
// SliceSubslice lowering's handling of this input shape.
