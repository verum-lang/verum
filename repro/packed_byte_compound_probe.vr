// T0172 extra probe — COMPOUND (op-assign) index mutation on a packed [Byte; N].
// Exercises compile_compound_assignment's Index arm (buf[i] ^= v / += v / <<= v),
// a read-modify-write the explicit-assign repro does NOT cover. Both the
// read-back and the store-back must route through ByteArrayLoad/ByteArrayStore
// at Tier-1 (generic GetE/SetE crash on a packed byte buffer). Green BOTH tiers.

fn main() {
    let mut buf: [Byte; 8] = [0; 8];
    buf[2] = 5 as Byte;
    buf[2] ^= 3 as Byte;          // 5 ^ 3 = 6
    assert_eq(buf[2] as Int, 6);
    buf[2] += 4 as Byte;          // 6 + 4 = 10
    assert_eq(buf[2] as Int, 10);
    buf[5] = 1 as Byte;
    buf[5] <<= 3 as Byte;         // 1 << 3 = 8
    assert_eq(buf[5] as Int, 8);
    print("COMPOUND_OK");
}
