const TK_DOT: Int = 171;
const TK_HASH: Int = 172;
const TK_AT: Int = 173;
const TK_DOLLAR: Int = 174;

// --- Lifetime ---
const TK_LIFETIME: Int = 175;

// =============================================================================
// Token Name (for error messages)
// =============================================================================

fn token_name(kind: Int) -> Text {
    if kind == TK_EOF { return "end of file"; }
    if kind == TK_ERROR { return "error"; }
    if kind == TK_IDENT { return "identifier"; }
    if kind == TK_INTEGER { return "integer literal"; }
    if kind == TK_FLOAT { return "float literal"; }
    if kind == TK_STRING { return "string literal"; }
    if kind == TK_FSTRING { return "format string"; }
    if kind == TK_CHAR { return "char literal"; }
    // Reserved keywords
    if kind == TK_LET { return "let"; }
    if kind == TK_FN { return "fn"; }
    if kind == TK_IS { return "is"; }
    // Primary keywords
    if kind == TK_TYPE { return "type"; }
    if kind == TK_MATCH { return "match"; }
    if kind == TK_MOUNT { return "mount"; }
    if kind == TK_WHERE { return "where"; }
    // Control flow
    if kind == TK_IF { return "if"; }
    if kind == TK_ELSE { return "else"; }
    if kind == TK_WHILE { return "while"; }
    if kind == TK_FOR { return "for"; }
    if kind == TK_LOOP { return "loop"; }
    if kind == TK_BREAK { return "break"; }
    if kind == TK_CONTINUE { return "continue"; }
    if kind == TK_RETURN { return "return"; }
    if kind == TK_YIELD { return "yield"; }
    // Async
    if kind == TK_ASYNC { return "async"; }
    if kind == TK_AWAIT { return "await"; }
    if kind == TK_SPAWN { return "spawn"; }
    if kind == TK_SELECT { return "select"; }
    if kind == TK_NURSERY { return "nursery"; }
    // Modifiers
    if kind == TK_MUT { return "mut"; }
    if kind == TK_CONST { return "const"; }
    if kind == TK_STATIC { return "static"; }
    if kind == TK_PURE { return "pure"; }
    if kind == TK_UNSAFE { return "unsafe"; }
    if kind == TK_REF { return "ref"; }
    if kind == TK_MOVE { return "move"; }
    if kind == TK_CHECKED { return "checked"; }
    // Type/implementation
    if kind == TK_IMPLEMENT { return "implement"; }
    if kind == TK_PROTOCOL { return "protocol"; }
    if kind == TK_EXTENDS { return "extends"; }
    if kind == TK_MODULE { return "module"; }
    // Context
    if kind == TK_USING { return "using"; }
    if kind == TK_CONTEXT { return "context"; }
    if kind == TK_PROVIDE { return "provide"; }
    // Error handling
    if kind == TK_DEFER { return "defer"; }
    if kind == TK_TRY { return "try"; }
    if kind == TK_THROW { return "throw"; }
    // Variant constructors
    if kind == TK_TRUE { return "true"; }
    if kind == TK_FALSE { return "false"; }
    if kind == TK_NONE { return "None"; }
    if kind == TK_SOME { return "Some"; }
    if kind == TK_OK { return "Ok"; }
    if kind == TK_ERR { return "Err"; }
    // Self
    if kind == TK_SELF_VALUE { return "self"; }
    if kind == TK_SELF_TYPE { return "Self"; }
    // Type ops
    if kind == TK_AS { return "as"; }
    if kind == TK_IN { return "in"; }
    // Visibility
    if kind == TK_PUB { return "pub"; }
    if kind == TK_PUBLIC { return "public"; }
    if kind == TK_INTERNAL { return "internal"; }
    if kind == TK_PROTECTED { return "protected"; }
    if kind == TK_PRIVATE { return "private"; }
    // Operators
    if kind == TK_PLUS { return "+"; }
    if kind == TK_MINUS { return "-"; }
    if kind == TK_STAR { return "*"; }
    if kind == TK_SLASH { return "/"; }
    if kind == TK_PERCENT { return "%"; }
    if kind == TK_STAR_STAR { return "**"; }
    if kind == TK_EQ_EQ { return "=="; }
    if kind == TK_BANG_EQ { return "!="; }
    if kind == TK_LT { return "<"; }
    if kind == TK_GT { return ">"; }
    if kind == TK_LT_EQ { return "<="; }
    if kind == TK_GT_EQ { return ">="; }
    if kind == TK_AMP_AMP { return "&&"; }
    if kind == TK_PIPE_PIPE { return "||"; }
    if kind == TK_BANG { return "!"; }
    if kind == TK_AMP { return "&"; }
    if kind == TK_PIPE { return "|"; }
    if kind == TK_CARET { return "^"; }
    if kind == TK_TILDE { return "~"; }
    if kind == TK_EQ { return "="; }
    if kind == TK_R_ARROW { return "->"; }
    if kind == TK_FAT_ARROW { return "=>"; }
    if kind == TK_QUESTION { return "?"; }
    if kind == TK_PIPE_GT { return "|>"; }
    if kind == TK_DOT_DOT { return ".."; }
    if kind == TK_DOT_DOT_EQ { return "..="; }
    // Delimiters
    if kind == TK_LPAREN { return "("; }
    if kind == TK_RPAREN { return ")"; }
    if kind == TK_LBRACKET { return "["; }
    if kind == TK_RBRACKET { return "]"; }
    if kind == TK_LBRACE { return "{"; }
    if kind == TK_RBRACE { return "}"; }
    // Punctuation
    if kind == TK_COMMA { return ","; }
    if kind == TK_SEMI { return ";"; }
    if kind == TK_COLON { return ":"; }
    if kind == TK_COLON_COLON { return "::"; }
    if kind == TK_DOT { return "."; }
    if kind == TK_HASH { return "#"; }
    if kind == TK_AT { return "@"; }
    if kind == TK_DOLLAR { return "$"; }
    "unknown"
}

// =============================================================================
// Precedence table for binary operators
// =============================================================================

fn operator_precedence(kind: Int) -> Int {
    // Higher number = higher precedence
    if kind == TK_PIPE_PIPE { return 1; }
    if kind == TK_AMP_AMP { return 2; }
    if kind == TK_PIPE { return 3; }
    if kind == TK_CARET { return 4; }
    if kind == TK_AMP { return 5; }
    if kind == TK_EQ_EQ || kind == TK_BANG_EQ { return 6; }
    if kind == TK_LT || kind == TK_GT || kind == TK_LT_EQ || kind == TK_GT_EQ { return 7; }
    if kind == TK_LT_LT || kind == TK_GT_GT { return 8; }
    if kind == TK_PLUS || kind == TK_MINUS { return 9; }
    if kind == TK_STAR || kind == TK_SLASH || kind == TK_PERCENT { return 10; }
    if kind == TK_STAR_STAR { return 11; }
    if kind == TK_AS { return 12; }
    0
}

fn is_binary_op(kind: Int) -> Bool {
    operator_precedence(kind) > 0
}

fn is_assignment_op(kind: Int) -> Bool {
    kind >= TK_EQ && kind <= TK_GT_GT_EQ
}

fn is_right_assoc(kind: Int) -> Bool {
    kind == TK_STAR_STAR
}
