// =============================================================================
// token.vr - Token definitions for the Verum bootstrap compiler
// =============================================================================
// All token kinds as integer constants for efficient comparison.
// Matches the full Verum grammar (grammar/verum.ebnf).
// =============================================================================

mount core.*;

// =============================================================================
// Source Location
// =============================================================================

type Span is {
    start: Int,
    end: Int,
    line: Int,
    col: Int,
};

// =============================================================================
// Token
// =============================================================================

type Token is {
    kind: Int,
    span: Span,
    value: Text,
};

implement Token {
    fn new(kind: Int, start: Int, end: Int, line: Int, col: Int) -> Token {
        Token {
            kind: kind,
            span: Span { start: start, end: end, line: line, col: col },
            value: "",
        }
    }

    fn with_value(kind: Int, start: Int, end: Int, line: Int, col: Int, val: Text) -> Token {
        Token {
            kind: kind,
            span: Span { start: start, end: end, line: line, col: col },
            value: val,
        }
    }

    fn is_eof(&self) -> Bool {
        self.kind == TK_EOF
    }

    fn is_error(&self) -> Bool {
        self.kind == TK_ERROR
    }
}

// =============================================================================
// Token Kind Constants
// =============================================================================

// --- Special ---
const TK_EOF: Int = 0;
const TK_ERROR: Int = 1;

// --- Literals ---
const TK_IDENT: Int = 2;
const TK_INTEGER: Int = 3;
const TK_FLOAT: Int = 4;
const TK_STRING: Int = 5;
const TK_FSTRING: Int = 6;
const TK_CHAR: Int = 7;
const TK_BYTE_CHAR: Int = 8;
const TK_BYTE_STRING: Int = 9;

// --- Reserved Keywords (3) ---
const TK_LET: Int = 10;
const TK_FN: Int = 11;
const TK_IS: Int = 12;

// --- Primary Keywords ---
const TK_TYPE: Int = 13;
const TK_MATCH: Int = 14;
const TK_MOUNT: Int = 15;
const TK_WHERE: Int = 16;

// --- Control Flow ---
const TK_IF: Int = 17;
const TK_ELSE: Int = 18;
const TK_WHILE: Int = 19;
const TK_FOR: Int = 20;
const TK_LOOP: Int = 21;
const TK_BREAK: Int = 22;
const TK_CONTINUE: Int = 23;
const TK_RETURN: Int = 24;
const TK_YIELD: Int = 25;

// --- Async/Concurrency ---
const TK_ASYNC: Int = 26;
const TK_AWAIT: Int = 27;
const TK_SPAWN: Int = 28;
const TK_SELECT: Int = 29;
const TK_NURSERY: Int = 30;

// --- Modifiers ---
const TK_MUT: Int = 31;
const TK_CONST: Int = 32;
const TK_VOLATILE: Int = 33;
const TK_STATIC: Int = 34;
const TK_PURE: Int = 35;
const TK_UNSAFE: Int = 36;
const TK_REF: Int = 37;
const TK_MOVE: Int = 38;
const TK_CHECKED: Int = 39;

// --- Type/Implementation ---
const TK_IMPLEMENT: Int = 40;
const TK_PROTOCOL: Int = 41;
const TK_EXTENDS: Int = 42;
const TK_MODULE: Int = 43;

// --- Context System ---
const TK_USING: Int = 44;
const TK_CONTEXT: Int = 45;
const TK_PROVIDE: Int = 46;

// --- Error Handling ---
const TK_DEFER: Int = 47;
const TK_ERRDEFER: Int = 48;
const TK_THROW: Int = 49;
const TK_THROWS: Int = 50;
const TK_TRY: Int = 51;

// --- Variant Constructors ---
const TK_TRUE: Int = 52;
const TK_FALSE: Int = 53;
const TK_NONE: Int = 54;
const TK_SOME: Int = 55;
const TK_OK: Int = 56;
const TK_ERR: Int = 57;

// --- Self ---
const TK_SELF_VALUE: Int = 58;
const TK_SELF_TYPE: Int = 59;

// --- Type Operators ---
const TK_AS: Int = 60;
const TK_IN: Int = 61;

// --- Visibility ---
const TK_PUB: Int = 62;
const TK_PUBLIC: Int = 63;
const TK_INTERNAL: Int = 64;
const TK_PROTECTED: Int = 65;
const TK_PRIVATE: Int = 66;

// --- Collection/Generator ---
const TK_STREAM: Int = 67;
const TK_SET: Int = 68;
const TK_GEN: Int = 69;

// --- FFI ---
const TK_FFI: Int = 70;
const TK_EXTERN: Int = 71;

// --- Additional Contextual ---
const TK_SUPER: Int = 72;
const TK_COG: Int = 73;
const TK_INVARIANT: Int = 74;
const TK_DECREASES: Int = 75;
const TK_TENSOR: Int = 76;
const TK_AFFINE: Int = 77;
const TK_LINEAR: Int = 78;
const TK_COFIX: Int = 79;
const TK_FINALLY: Int = 80;
const TK_RECOVER: Int = 81;
const TK_ENSURES: Int = 82;
const TK_REQUIRES: Int = 83;
const TK_RESULT: Int = 84;
const TK_VIEW: Int = 85;
const TK_PATTERN: Int = 86;
const TK_WITH: Int = 87;
const TK_UNKNOWN: Int = 88;
const TK_TYPEOF: Int = 89;

// --- Metaprogramming ---
const TK_QUOTE: Int = 90;
const TK_STAGE: Int = 91;
const TK_LIFT: Int = 92;

// --- Proof Keywords ---
const TK_THEOREM: Int = 93;
const TK_AXIOM: Int = 94;
const TK_LEMMA: Int = 95;
const TK_COROLLARY: Int = 96;
const TK_PROOF: Int = 97;
const TK_CALC: Int = 98;
const TK_HAVE: Int = 99;
const TK_SHOW: Int = 100;
const TK_SUFFICES: Int = 101;
const TK_OBTAIN: Int = 102;
const TK_BY: Int = 103;
const TK_INDUCTION: Int = 104;
const TK_CASES: Int = 105;
const TK_CONTRADICTION: Int = 106;
const TK_TRIVIAL: Int = 107;
const TK_ASSUMPTION: Int = 108;
const TK_SIMP: Int = 109;
const TK_RING_TACTIC: Int = 110;
const TK_FIELD_TACTIC: Int = 111;
const TK_OMEGA: Int = 112;
const TK_AUTO: Int = 113;
const TK_BLAST: Int = 114;
const TK_SMT: Int = 115;
const TK_QED: Int = 116;
const TK_FORALL: Int = 117;
