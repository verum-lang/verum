const TK_EQ_EQ: Int = 126;
const TK_BANG_EQ: Int = 127;
const TK_LT: Int = 128;
const TK_GT: Int = 129;
const TK_LT_EQ: Int = 130;
const TK_GT_EQ: Int = 131;

const TK_AMP_AMP: Int = 132;
const TK_PIPE_PIPE: Int = 133;
const TK_BANG: Int = 134;

const TK_AMP: Int = 135;
const TK_PIPE: Int = 136;
const TK_CARET: Int = 137;
const TK_LT_LT: Int = 138;
const TK_GT_GT: Int = 139;
const TK_TILDE: Int = 140;

const TK_EQ: Int = 141;
const TK_PLUS_EQ: Int = 142;
const TK_MINUS_EQ: Int = 143;
const TK_STAR_EQ: Int = 144;
const TK_SLASH_EQ: Int = 145;
const TK_PERCENT_EQ: Int = 146;
const TK_AMP_EQ: Int = 147;
const TK_PIPE_EQ: Int = 148;
const TK_CARET_EQ: Int = 149;
const TK_LT_LT_EQ: Int = 150;
const TK_GT_GT_EQ: Int = 151;

const TK_DOT_DOT: Int = 152;
const TK_DOT_DOT_EQ: Int = 153;
const TK_DOT_DOT_DOT: Int = 154;
const TK_PIPE_GT: Int = 155;
const TK_R_ARROW: Int = 156;
const TK_FAT_ARROW: Int = 157;
const TK_QUESTION_DOT: Int = 158;
const TK_QUESTION_QUESTION: Int = 159;
