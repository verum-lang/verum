# External-prover replay (Coq 9.x / Rocq) for `kernel_soundness.v`.
#
# Generates a Makefile from `_CoqProject` and drives `coqc`.  The
# soundness corpus is regenerated by `verum audit --kernel-soundness`
# from the Verum side; this Makefile only runs the external re-check.
#
# Usage:
#   make             — build (re-elaborate via coqc)
#   make clean       — remove build artefacts (.vo / .vok / .vos / .glob)

ROCQ_BIN ?= /opt/homebrew/Cellar/rocq/9.1.1_1/bin
COQ_MAKEFILE ?= $(ROCQ_BIN)/coq_makefile

all: Makefile.coq
	$(MAKE) -f Makefile.coq

Makefile.coq: _CoqProject
	$(COQ_MAKEFILE) -f _CoqProject -o Makefile.coq

clean:
	-$(MAKE) -f Makefile.coq clean 2>/dev/null
	$(RM) Makefile.coq Makefile.coq.conf

.PHONY: all clean
