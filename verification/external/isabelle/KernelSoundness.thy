lemma K_Pi_Form_sound:
  assumes "\<Gamma> \<turnstile> A : Universe i"
      and "((x, A) # \<Gamma>) \<turnstile> B : Universe i"
  shows "\<Gamma> \<turnstile> Pi x A B : Universe i"
  using assms by (rule T_pi)

