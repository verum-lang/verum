// docs/by-example/05-collections/main.vr
// List<T>, Map<K, V>, iteration patterns, and the `mount` system.

mount core.collections.{List, Map};

fn main() {
    // Build a list.
    let mut nums: List<Int> = List.new();
    nums.push(1);
    nums.push(2);
    nums.push(3);
    nums.push(4);

    // Iterate.
    let mut total = 0;
    for n in nums {
        total = total + n;
    }
    print(f"sum = {total}");

    // Build a map of word -> count.
    let words = ["apple", "banana", "apple", "cherry", "banana", "apple"];
    let mut counts: Map<Text, Int> = Map.new();
    for w in words {
        let prev = match counts.get(&w.clone()) {
            Some(n) => *n,
            None    => 0,
        };
        counts.insert(w.clone(), prev + 1);
    }

    print("word counts:");
    for (word, n) in &counts {
        print(f"  {word} -> {n}");
    }

    // List comprehension via map + collect.
    let doubled: List<Int> = nums.iter().map(|n| n * 2).collect();
    print(f"doubled = {doubled}");
}
