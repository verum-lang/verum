// @test: benchmark
// @tier: all
// @level: L4
// @expected-performance: <= 20 µs per cert
// @tags: x509, der, performance

/// DER parse latency — single certificate.
///
/// Spec §11 target: ≤ 20 µs on server-grade x86_64.
/// Reference: rustls-webpki ~15 µs (AMD Zen 4).
///
/// Measurement: instantiate a DerReader over a ~1000-byte synthetic
/// SEQUENCE + run `read_tag_length` on every TLV in a Let's-Encrypt-
/// sized 3-cert chain's leaf-cert structure.

module vcs.benchmarks.net.x509.der_parse_single;

mount core.*;
mount core.collections.List;
mount core.encoding.der.{DerReader};

const BENCHMARK_ITERATIONS: Int = 100_000;

@bench
public fn x509_der_parse_single() {
    // Build a representative DER blob (SEQUENCE of 8 sub-SEQUENCES).
    let mut blob: List<Byte> = [];
    blob.push(0x30_u8);          // outer SEQUENCE
    blob.push(0x81_u8);          // long-form length byte
    blob.push(0x80_u8);          // length = 128
    let mut filler: Int = 0;
    while filler < 128 {
        blob.push(0x02_u8);
        blob.push(0x01_u8);
        blob.push(filler as Byte);
        filler = filler + 3;
    }

    let mut n: Int = 0;
    while n < BENCHMARK_ITERATIONS {
        let mut r = DerReader::new(&blob);
        let _ = r.read_tag_length();
        n = n + 1;
    }
}
