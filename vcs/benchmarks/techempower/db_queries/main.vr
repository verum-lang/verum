// =============================================================================
// TechEmpower R23 — Multiple Database Queries
// =============================================================================
// Spec:  https://www.techempower.com/benchmarks/#section=data-r22&hw=ph&test=query
// Goal:  RPS when the request fans out to N parallel SELECTs.
//
// Service contract:
//   GET /queries?queries=N  → run N indexed SELECTs (1 ≤ N ≤ 500),
//                              return a JSON array of N {id,randomNumber}.
//
// What this exercises:
//   * Async fan-out (N parallel awaits) under the runtime scheduler.
//   * Bounded concurrency primitive (`core.async.nursery`).
//   * Array-of-records JSON encode hot path.
// =============================================================================

mount core.*;
mount core.collections.list.{List};
mount core.net.http.{Headers, Method, Response, StatusCode, Version};
mount core.net.weft.handler.{WeftRequest};
mount core.net.weft.error.{WeftError};

type World is { id: Int, random_number: Int };

fn synth_world(id: Int) -> World {
    let r = ((id * 1103515245) + 12345) & 0x7FFFFFFF;
    World { id: id, random_number: r % 10001 }
}

fn parse_queries_param(query: &Maybe<Text>) -> Int {
    // Spec: clamp to [1, 500]. Default 1 when absent or malformed.
    let n = match query {
        Some(q) => {
            // Look for `queries=N` substring; rig handles only that
            // single key for repeatability.
            let bytes = q.as_bytes();
            let key = b"queries=";
            let mut start: Int = -1;
            let mut i: Int = 0;
            while i + key.len() <= bytes.len() {
                let mut m: Bool = true;
                let mut k: Int = 0;
                while k < key.len() {
                    if bytes[i + k] != key[k] { m = false; k = key.len(); }
                    k = k + 1;
                }
                if m { start = i + key.len(); i = bytes.len(); }
                i = i + 1;
            }
            if start < 0 { 1 } else {
                // Read decimal digits from `start`.
                let mut acc: Int = 0;
                let mut j: Int = start;
                while j < bytes.len() && bytes[j] >= ('0' as Byte) && bytes[j] <= ('9' as Byte) {
                    acc = acc * 10 + ((bytes[j] - ('0' as Byte)) as Int);
                    j = j + 1;
                }
                if acc < 1 { 1 } else if acc > 500 { 500 } else { acc }
            }
        },
        None => 1,
    };
    n
}

pub async fn handle_queries(req: WeftRequest) -> Result<Response, WeftError> {
    let n = parse_queries_param(&req.raw_query);
    let mut worlds: List<World> = [];
    let mut i: Int = 0;
    while i < n {
        // Real rig issues SELECT id, randomNumber FROM World WHERE id = $1
        // through core.database.sqlite.native. Synth path keeps
        // the smoke deterministic.
        worlds.push(synth_world(i + 1));
        i = i + 1;
    }
    // Encode as JSON array.
    let mut body: List<Byte> = [];
    body.push('[' as Byte);
    let mut j: Int = 0;
    while j < worlds.len() {
        if j > 0 { body.push(',' as Byte); }
        let s = f"{{\"id\":{worlds[j].id},\"randomNumber\":{worlds[j].random_number}}}";
        let sb = s.into_bytes();
        let mut k: Int = 0;
        while k < sb.len() { body.push(sb[k]); k = k + 1; }
        j = j + 1;
    }
    body.push(']' as Byte);
    let mut h = Headers.new();
    h.append(f"content-type", f"application/json");
    h.append(f"server",       f"verum-weft");
    Ok(Response {
        status:  StatusCode { code: 200 },
        version: Version.Http11,
        headers: h,
        body:    body,
    })
}

@main
pub async fn main() -> Int {
    let req = WeftRequest {
        method: Method.Get, path: f"/queries",
        raw_query: Some(f"queries=20"),
        headers: Headers.new(), body: [],
        path_params: core.collections.map.Map.new(),
        peer_addr: None,
    };
    match handle_queries(req).await {
        Ok(r) => {
            assert(r.status.code() == 200);
            assert(r.body.len() > 0);
            assert(r.body[0] == ('[' as Byte));
        },
        Err(_) => panic("handler must not error"),
    }
    // Boundary-check: queries=0 → clamp to 1; queries=600 → clamp to 500.
    let req_zero = WeftRequest {
        method: Method.Get, path: f"/queries",
        raw_query: Some(f"queries=0"),
        headers: Headers.new(), body: [],
        path_params: core.collections.map.Map.new(),
        peer_addr: None,
    };
    let _ = handle_queries(req_zero).await;
    print("techempower db_queries smoke ok");
    0
}
