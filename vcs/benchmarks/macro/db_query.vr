// @test: benchmark
// @tier: macro
// @level: L4
// @expected-performance: > 10K queries/sec (simple), > 1K queries/sec (complex)
// @tags: database, query, async, performance

/// Database Query Benchmark
///
/// Simulates realistic database operations:
/// - Simple SELECT queries
/// - Complex JOINs
/// - Aggregations
/// - Transactions
/// - Connection pooling

module benchmarks.macro.db_query;

using [Benchmark, Database, Async]

/// Setup test database
fn setup_test_db() -> Database {
    let db = Database.in_memory();

    // Create tables
    db.execute("
        CREATE TABLE users (
            id INTEGER PRIMARY KEY,
            name TEXT NOT NULL,
            email TEXT UNIQUE,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ");

    db.execute("
        CREATE TABLE orders (
            id INTEGER PRIMARY KEY,
            user_id INTEGER REFERENCES users(id),
            total DECIMAL(10,2),
            status TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ");

    db.execute("
        CREATE TABLE order_items (
            id INTEGER PRIMARY KEY,
            order_id INTEGER REFERENCES orders(id),
            product_name TEXT,
            quantity INTEGER,
            price DECIMAL(10,2)
        )
    ");

    // Create indexes
    db.execute("CREATE INDEX idx_orders_user_id ON orders(user_id)");
    db.execute("CREATE INDEX idx_order_items_order_id ON order_items(order_id)");

    // Insert test data
    for i in 0..10_000 {
        db.execute(&text(
            "INSERT INTO users (id, name, email) VALUES ({}, 'User {}', 'user{}@example.com')",
            i, i, i
        ));
    }

    for i in 0..50_000 {
        let user_id = i % 10_000;
        db.execute(&text(
            "INSERT INTO orders (id, user_id, total, status) VALUES ({}, {}, {:.2}, '{}')",
            i, user_id, (i as Float) * 10.5, if i % 3 == 0 { "completed" } else { "pending" }
        ));
    }

    for i in 0..200_000 {
        let order_id = i % 50_000;
        db.execute(&text(
            "INSERT INTO order_items (id, order_id, product_name, quantity, price) VALUES ({}, {}, 'Product {}', {}, {:.2})",
            i, order_id, i % 100, (i % 10) + 1, ((i % 50) as Float) * 9.99
        ));
    }

    db
}

/// Simple SELECT by primary key
fn benchmark_db_select_by_id() {
    let db = setup_test_db();

    for i in 0..100_000 {
        let id = i % 10_000;
        let result = db.query_one(&text(
            "SELECT * FROM users WHERE id = {}", id
        ));
        assert(result.is_some());
    }
}

/// SELECT with index scan
fn benchmark_db_select_indexed() {
    let db = setup_test_db();

    for i in 0..50_000 {
        let user_id = i % 10_000;
        let results = db.query(&text(
            "SELECT * FROM orders WHERE user_id = {}", user_id
        ));
        let _ = results.len();
    }
}

/// SELECT with LIKE pattern
fn benchmark_db_select_like() {
    let db = setup_test_db();

    for i in 0..10_000 {
        let pattern = text("User {}%", i % 100);
        let results = db.query(&text(
            "SELECT * FROM users WHERE name LIKE '{}'", pattern
        ));
        let _ = results.len();
    }
}

/// Simple JOIN
fn benchmark_db_simple_join() {
    let db = setup_test_db();

    for _ in 0..10_000 {
        let results = db.query("
            SELECT u.name, o.total
            FROM users u
            JOIN orders o ON u.id = o.user_id
            WHERE u.id = 42
        ");
        let _ = results.len();
    }
}

/// Complex JOIN with multiple tables
fn benchmark_db_complex_join() {
    let db = setup_test_db();

    for _ in 0..5_000 {
        let results = db.query("
            SELECT u.name, o.total, oi.product_name, oi.quantity
            FROM users u
            JOIN orders o ON u.id = o.user_id
            JOIN order_items oi ON o.id = oi.order_id
            WHERE u.id = 42
            ORDER BY o.created_at DESC
            LIMIT 100
        ");
        let _ = results.len();
    }
}

/// Aggregation - COUNT
fn benchmark_db_count() {
    let db = setup_test_db();

    for _ in 0..50_000 {
        let result = db.query_one("SELECT COUNT(*) as count FROM orders");
        let _ = result["count"];
    }
}

/// Aggregation - GROUP BY
fn benchmark_db_group_by() {
    let db = setup_test_db();

    for _ in 0..5_000 {
        let results = db.query("
            SELECT user_id, COUNT(*) as order_count, SUM(total) as total_spent
            FROM orders
            GROUP BY user_id
            HAVING COUNT(*) > 3
            ORDER BY total_spent DESC
            LIMIT 100
        ");
        let _ = results.len();
    }
}

/// Aggregation with JOIN
fn benchmark_db_aggregate_join() {
    let db = setup_test_db();

    for _ in 0..2_000 {
        let results = db.query("
            SELECT u.name, COUNT(o.id) as orders, SUM(o.total) as revenue
            FROM users u
            LEFT JOIN orders o ON u.id = o.user_id
            GROUP BY u.id, u.name
            ORDER BY revenue DESC
            LIMIT 50
        ");
        let _ = results.len();
    }
}

/// INSERT single row
fn benchmark_db_insert_single() {
    let db = setup_test_db();

    for i in 0..10_000 {
        db.execute(&text(
            "INSERT INTO users (id, name, email) VALUES ({}, 'New User {}', 'new{}@example.com')",
            100_000 + i, i, i
        ));
    }
}

/// INSERT batch (transaction)
fn benchmark_db_insert_batch() {
    let db = setup_test_db();

    for batch in 0..100 {
        db.transaction(|tx| {
            for i in 0..100 {
                let id = 200_000 + batch * 100 + i;
                tx.execute(&text(
                    "INSERT INTO users (id, name, email) VALUES ({}, 'Batch User {}', 'batch{}@example.com')",
                    id, id, id
                ));
            }
            Ok(())
        });
    }
}

/// UPDATE by primary key
fn benchmark_db_update_by_id() {
    let db = setup_test_db();

    for i in 0..50_000 {
        let id = i % 10_000;
        db.execute(&text(
            "UPDATE users SET name = 'Updated User {}' WHERE id = {}",
            i, id
        ));
    }
}

/// DELETE by primary key
fn benchmark_db_delete_by_id() {
    let db = setup_test_db();

    for i in 0..5_000 {
        let id = i % 1000 + 5000;  // Delete subset
        db.execute(&text(
            "DELETE FROM users WHERE id = {}",
            id
        ));
    }
}

/// Prepared statements
fn benchmark_db_prepared() {
    let db = setup_test_db();
    let stmt = db.prepare("SELECT * FROM users WHERE id = ?");

    for i in 0..100_000 {
        let id = i % 10_000;
        let result = stmt.query_one(&[id]);
        assert(result.is_some());
    }
}

/// Connection pooling
async fn benchmark_db_connection_pool() {
    let pool = ConnectionPool.new("sqlite.memory:")
        .min_connections(5)
        .max_connections(20);

    let handles: List<_> = (0..100).map(|_| {
        let pool = pool.clone();
        spawn async move {
            for _ in 0..1_000 {
                let conn = pool.acquire().await;
                let _ = conn.query("SELECT 1");
            }
        }
    }).collect();

    for h in handles {
        h.await;
    }
}

/// Async queries
async fn benchmark_db_async_query() {
    let db = AsyncDatabase.in_memory().await;
    setup_async_db(&db).await;

    for _ in 0..50_000 {
        let result = db.query_one("SELECT * FROM users WHERE id = 42").await;
        assert(result.is_some());
    }
}

/// Concurrent async queries
async fn benchmark_db_concurrent_async() {
    let db = AsyncDatabase.in_memory().await;
    setup_async_db(&db).await;

    let handles: List<_> = (0..100).map(|i| {
        let db = db.clone();
        spawn async move {
            for j in 0..500 {
                let id = (i * 500 + j) % 10_000;
                let _ = db.query_one(&text(
                    "SELECT * FROM users WHERE id = {}", id
                )).await;
            }
        }
    }).collect();

    for h in handles {
        h.await;
    }
}

/// Transaction with rollback
fn benchmark_db_transaction_rollback() {
    let db = setup_test_db();

    for _ in 0..10_000 {
        let result = db.transaction(|tx| {
            tx.execute("INSERT INTO users (id, name, email) VALUES (999999, 'Test', 'test@example.com')");
            Err("Rollback")  // Force rollback
        });
        assert(result.is_err());
    }
}

/// Subquery
fn benchmark_db_subquery() {
    let db = setup_test_db();

    for _ in 0..5_000 {
        let results = db.query("
            SELECT * FROM users
            WHERE id IN (
                SELECT user_id FROM orders
                WHERE total > 1000
                GROUP BY user_id
                HAVING COUNT(*) > 2
            )
        ");
        let _ = results.len();
    }
}

async fn setup_async_db(db: &AsyncDatabase) {
    db.execute("CREATE TABLE users (id INTEGER PRIMARY KEY, name TEXT, email TEXT)").await;
    for i in 0..10_000 {
        db.execute(&text(
            "INSERT INTO users (id, name, email) VALUES ({}, 'User {}', 'user{}@example.com')",
            i, i, i
        )).await;
    }
}
