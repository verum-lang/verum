/// Benchmark sorting 1 million elements
fn benchmark_sort_1000000() -> BenchmarkResult {
    let size = 1_000_000;
    let iterations = 10;

    let timer = Timer.new();
    timer.start();

    for i in 0..iterations {
        let mut arr = generate_random_array(size, i as u64);
        arr.sort();
        black_box(&arr);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ms = (elapsed_ns as Float / 1_000_000.0) / iterations as Float;

    // Compare to expected C qsort (~70ms for 1M elements)
    let c_baseline_ms = 70.0;
    let ratio = per_sort_ms / c_baseline_ms;

    BenchmarkResult {
        name: "sort_1000000",
        metric: "ratio to C",
        value: ratio,
        target: 1.15,  // Within 15% of C
        passed: ratio < 1.15,
    }
}

