/// Benchmark explicit quicksort
fn benchmark_quicksort() -> BenchmarkResult {
    let size = 100_000;
    let iterations = 50;

    let timer = Timer.new();
    timer.start();

    for i in 0..iterations {
        let mut arr = generate_random_array(size, i as u64);
        quicksort(&mut arr);
        black_box(&arr);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ms = (elapsed_ns as Float / 1_000_000.0) / iterations as Float;

    // Compare to C qsort baseline
    let c_baseline_ms = 5.0;
    let ratio = per_sort_ms / c_baseline_ms;

    BenchmarkResult {
        name: "quicksort_100k",
        metric: "ratio to C",
        value: ratio,
        target: 1.10,  // Within 10% of C
        passed: ratio < 1.10,
    }
}

/// Benchmark explicit mergesort
fn benchmark_mergesort() -> BenchmarkResult {
    let size = 100_000;
    let iterations = 50;

    let timer = Timer.new();
    timer.start();

    for i in 0..iterations {
        let mut arr = generate_random_array(size, i as u64);
