// @test: benchmark
// @tier: baseline
// @level: L4
// @expected-performance: within 15% of C qsort
// @tags: sorting, baseline, comparison, performance

/// Sorting Algorithm Benchmark - Verum Implementation
///
/// Compares Verum's sorting performance against C, Rust, and Go
/// using various sorting algorithms and data patterns.
///
/// Targets:
/// - Quicksort: within 10% of C
/// - Mergesort: within 15% of C
/// - Standard sort: within 10% of Rust

module vcs.benchmarks.baselines.sort_comparison

const WARMUP_ITERATIONS: Int = 5;

fn main() {
    let results = BenchmarkResults.new("Sorting - Verum vs Other Languages");

    // Small array sorting
    results.add(benchmark_sort_100());
    results.add(benchmark_sort_1000());

    // Large array sorting
    results.add(benchmark_sort_10000());
    results.add(benchmark_sort_100000());
    results.add(benchmark_sort_1000000());

    // Different data patterns
    results.add(benchmark_sort_random());
    results.add(benchmark_sort_sorted());
    results.add(benchmark_sort_reverse());
    results.add(benchmark_sort_nearly_sorted());
    results.add(benchmark_sort_few_unique());

    // Algorithm comparison
    results.add(benchmark_quicksort());
    results.add(benchmark_mergesort());
    results.add(benchmark_heapsort());

    // Stable vs unstable
    results.add(benchmark_stable_sort());
    results.add(benchmark_unstable_sort());

    results.report();
    assert(results.all_pass(), "Sorting performance below target");
}

/// Generate random array
fn generate_random_array(size: Int, seed: u64) -> List<Int> {
    let mut rng = Rng.seed(seed);
    (0..size).map(|_| rng.next_int()).collect()
}

/// Generate sorted array
fn generate_sorted_array(size: Int) -> List<Int> {
    (0..size).collect()
}

/// Generate reverse-sorted array
fn generate_reverse_array(size: Int) -> List<Int> {
    (0..size).rev().collect()
}

/// Generate nearly sorted array (10% swapped)
fn generate_nearly_sorted_array(size: Int, seed: u64) -> List<Int> {
    let mut arr: List<Int> = (0..size).collect();
    let mut rng = Rng.seed(seed);
    let swaps = size / 10;

    for _ in 0..swaps {
        let i = rng.next_int() % size;
        let j = rng.next_int() % size;
        arr.swap(i, j);
    }

    arr
}

/// Generate array with few unique values
fn generate_few_unique_array(size: Int, unique_count: Int, seed: u64) -> List<Int> {
    let mut rng = Rng.seed(seed);
    (0..size).map(|_| rng.next_int() % unique_count).collect()
}

/// Quicksort implementation
fn quicksort<T: Ord>(arr: &mut [T]) {
    if arr.len() <= 1 {
        return;
    }

    let pivot_idx = partition(arr);

    if pivot_idx > 0 {
        quicksort(&mut arr[..pivot_idx]);
    }
    quicksort(&mut arr[pivot_idx + 1..]);
}

fn partition<T: Ord>(arr: &mut [T]) -> Int {
    let len = arr.len();
    let pivot_idx = len / 2;
    arr.swap(pivot_idx, len - 1);

    let mut i = 0;
    for j in 0..(len - 1) {
        if arr[j] < arr[len - 1] {
            arr.swap(i, j);
            i += 1;
        }
    }
    arr.swap(i, len - 1);
    i
}

/// Mergesort implementation
fn mergesort<T: Ord + Clone>(arr: &mut [T]) {
    if arr.len() <= 1 {
        return;
    }

    let mid = arr.len() / 2;
    let left = arr[..mid].to_vec();
    let right = arr[mid..].to_vec();

    mergesort(&mut left);
    mergesort(&mut right);

    merge(arr, &left, &right);
}

fn merge<T: Ord + Clone>(arr: &mut [T], left: &[T], right: &[T]) {
    let (mut i, mut j, mut k) = (0, 0, 0);

    while i < left.len() && j < right.len() {
        if left[i] <= right[j] {
            arr[k] = left[i].clone();
            i += 1;
        } else {
            arr[k] = right[j].clone();
            j += 1;
        }
        k += 1;
    }

    while i < left.len() {
        arr[k] = left[i].clone();
        i += 1;
        k += 1;
    }

    while j < right.len() {
        arr[k] = right[j].clone();
        j += 1;
        k += 1;
    }
}

/// Heapsort implementation
fn heapsort<T: Ord>(arr: &mut [T]) {
    let len = arr.len();

    // Build max heap
    for i in (0..len / 2).rev() {
        heapify(arr, len, i);
    }

    // Extract elements from heap
    for i in (1..len).rev() {
        arr.swap(0, i);
        heapify(arr, i, 0);
    }
}

fn heapify<T: Ord>(arr: &mut [T], n: Int, i: Int) {
    let mut largest = i;
    let left = 2 * i + 1;
    let right = 2 * i + 2;

    if left < n && arr[left] > arr[largest] {
        largest = left;
    }

    if right < n && arr[right] > arr[largest] {
        largest = right;
    }

    if largest != i {
        arr.swap(i, largest);
        heapify(arr, n, largest);
    }
}

/// Benchmark sorting 100 elements
fn benchmark_sort_100() -> BenchmarkResult {
    let size = 100;
    let iterations = 100_000;

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        let mut arr = generate_random_array(size, 42);
        arr.sort();
    }

    let timer = Timer.new();
    timer.start();

    for i in 0..iterations {
        let mut arr = generate_random_array(size, i as u64);
        arr.sort();
        black_box(&arr);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ns = elapsed_ns as Float / iterations as Float;

    // Expected: ~1us for 100 elements
    BenchmarkResult {
        name: "sort_100",
        metric: "us/sort",
        value: per_sort_ns / 1000.0,
        target: 2.0,
        passed: per_sort_ns < 2000.0,
    }
}

