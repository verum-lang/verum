        black_box(&arr);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ms = (elapsed_ns as Float / 1_000_000.0) / iterations as Float;

    // Mergesort has more allocations, expect slightly worse than quicksort
    let c_baseline_ms = 6.0;
    let ratio = per_sort_ms / c_baseline_ms;

    BenchmarkResult {
        name: "mergesort_100k",
        metric: "ratio to C",
        value: ratio,
        target: 1.15,  // Within 15% of C
        passed: ratio < 1.15,
    }
}

/// Benchmark explicit heapsort
fn benchmark_heapsort() -> BenchmarkResult {
    let size = 100_000;
    let iterations = 50;

    let timer = Timer.new();
    timer.start();

    for i in 0..iterations {
        let mut arr = generate_random_array(size, i as u64);
        heapsort(&mut arr);
        black_box(&arr);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ms = (elapsed_ns as Float / 1_000_000.0) / iterations as Float;

    BenchmarkResult {
