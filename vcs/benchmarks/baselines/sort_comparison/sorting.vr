/// Benchmark stable sort
fn benchmark_stable_sort() -> BenchmarkResult {
    let size = 100_000;
    let iterations = 50;

    let timer = Timer.new();
    timer.start();

    for i in 0..iterations {
        let mut arr = generate_random_array(size, i as u64);
        arr.sort_stable();  // Stable sort preserves equal element order
        black_box(&arr);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ms = (elapsed_ns as Float / 1_000_000.0) / iterations as Float;

    BenchmarkResult {
        name: "stable_sort_100k",
        metric: "ms/sort",
        value: per_sort_ms,
        target: 6.0,
        passed: per_sort_ms < 6.0,
    }
}

/// Benchmark unstable sort
fn benchmark_unstable_sort() -> BenchmarkResult {
    let size = 100_000;
    let iterations = 50;

    let timer = Timer.new();
    timer.start();

    for i in 0..iterations {
        let mut arr = generate_random_array(size, i as u64);
        arr.sort_unstable();  // May be faster, doesn't preserve equal element order
        black_box(&arr);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ms = (elapsed_ns as Float / 1_000_000.0) / iterations as Float;

    // Compare to Rust's sort_unstable baseline
    let rust_baseline_ms = 4.0;
    let ratio = per_sort_ms / rust_baseline_ms;

    BenchmarkResult {
        name: "unstable_sort_100k",
        metric: "ratio to Rust",
        value: ratio,
        target: 1.10,  // Within 10% of Rust
        passed: ratio < 1.10,
    }
}

// Benchmark infrastructure
type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(&self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results.iter() {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.3} {} (target: {:.3})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}

@extern("verum_bench")
fn black_box<T>(value: T) -> T;

type Timer is { start_time: u64 };

implement Timer {
    fn new() -> Self { Self { start_time: 0 } }
    fn start(&mut self) { self.start_time = clock_ns(); }
    fn elapsed_ns(&self) -> u64 { clock_ns() - self.start_time }
}

type Rng is { state: u64 };

implement Rng {
    fn seed(s: u64) -> Self { Self { state: s } }

    fn next_int(&mut self) -> Int {
        // xorshift64
        self.state ^= self.state << 13;
        self.state ^= self.state >> 7;
        self.state ^= self.state << 17;
        self.state as Int
    }
}

@extern("verum_time")
fn clock_ns() -> u64;
