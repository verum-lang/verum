// @test: benchmark
// @tier: all
// @level: L4
// @expected-performance: < 2ns direct call, < 5ns indirect call
// @tags: function, call, performance, micro

/// Function Call Overhead Benchmark
///
/// Measures the overhead of various function call patterns in Verum:
/// - Direct function calls
/// - Indirect calls through function pointers
/// - Virtual dispatch (protocol methods)
/// - Generic function calls
/// - Recursive function calls
///
/// Targets:
/// - Direct call: < 2ns
/// - Indirect call: < 5ns
/// - Virtual dispatch: < 10ns
/// - Generic monomorphized: = direct call
/// - Recursive: < 3ns per call + stack overhead

module vcs.benchmarks.micro.function_call

const WARMUP_ITERATIONS: Int = 100_000;
const BENCHMARK_ITERATIONS: Int = 10_000_000;

/// Simple function for direct call testing
fn simple_add(a: Int, b: Int) -> Int {
    a + b
}

/// Function with more parameters
fn multi_param(a: Int, b: Int, c: Int, d: Int, e: Int, f: Int) -> Int {
    a + b + c + d + e + f
}

/// Generic function (should be monomorphized)
fn generic_add<T: Add>(a: T, b: T) -> T {
    a + b
}

/// Inline-hinted function
@inline
fn inline_add(a: Int, b: Int) -> Int {
    a + b
}

/// No-inline function
@no_inline
fn noinline_add(a: Int, b: Int) -> Int {
    a + b
}

/// Recursive function
fn recursive_sum(n: Int) -> Int {
    if n <= 0 {
        0
    } else {
        n + recursive_sum(n - 1)
    }
}

/// Tail-recursive function
fn tail_recursive_sum(n: Int, acc: Int) -> Int {
    if n <= 0 {
        acc
    } else {
        tail_recursive_sum(n - 1, acc + n)
    }
}

/// Protocol for virtual dispatch testing
type Addable is protocol {
    fn add(&self, other: Int) -> Int;
};

/// Implementation type for protocol
type IntWrapper is {
    value: Int,
};

implement Addable for IntWrapper {
    fn add(&self, other: Int) -> Int {
        self.value + other
    }
}

/// Another implementation for polymorphism testing
type DoubleWrapper is {
    value: Int,
};

implement Addable for DoubleWrapper {
    fn add(&self, other: Int) -> Int {
        self.value * 2 + other
    }
}

fn main() {
    let results = BenchmarkResults.new("Function Call Overhead");

    // Direct call benchmarks
    results.add(benchmark_direct_call());
    results.add(benchmark_direct_call_2params());
    results.add(benchmark_direct_call_6params());

    // Inline benchmarks
    results.add(benchmark_inline_call());
    results.add(benchmark_noinline_call());

    // Generic function benchmarks
    results.add(benchmark_generic_call());
    results.add(benchmark_generic_call_float());

    // Indirect call benchmarks
    results.add(benchmark_function_pointer());
    results.add(benchmark_closure_call());
    results.add(benchmark_closure_with_capture());

    // Virtual dispatch benchmarks
    results.add(benchmark_virtual_dispatch());
    results.add(benchmark_virtual_dispatch_polymorphic());

    // Recursive call benchmarks
    results.add(benchmark_recursive_call());
    results.add(benchmark_tail_recursive_call());

    // Call chain benchmarks
    results.add(benchmark_call_chain());
    results.add(benchmark_deep_call_chain());

    results.report();
    assert(results.all_pass(), "Function call performance below target");
}

/// Benchmark direct function call
fn benchmark_direct_call() -> BenchmarkResult {
    let mut sum: Int = 0;

    // Warmup
    for i in 0..WARMUP_ITERATIONS {
        sum += simple_add(i, i + 1);
    }
    black_box(sum);

    sum = 0;
    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += simple_add(i, i + 1);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "direct_call",
        metric: "ns/call",
        value: per_call_ns,
        target: 2.0,
        passed: per_call_ns < 2.0,
    }
}

/// Benchmark 2-parameter direct call
fn benchmark_direct_call_2params() -> BenchmarkResult {
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += simple_add(i, 1);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "direct_call_2params",
        metric: "ns/call",
        value: per_call_ns,
        target: 2.0,
        passed: per_call_ns < 2.0,
    }
}

/// Benchmark 6-parameter direct call
fn benchmark_direct_call_6params() -> BenchmarkResult {
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += multi_param(i, 1, 2, 3, 4, 5);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "direct_call_6params",
        metric: "ns/call",
        value: per_call_ns,
        target: 3.0,  // Slightly higher due to more params
        passed: per_call_ns < 3.0,
    }
}

/// Benchmark inline function call
fn benchmark_inline_call() -> BenchmarkResult {
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += inline_add(i, 1);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "inline_call",
        metric: "ns/call",
        value: per_call_ns,
        target: 1.0,  // Should be nearly zero due to inlining
        passed: per_call_ns < 1.0,
    }
}

