/// Set remove (O(1) average)
fn benchmark_set_remove() -> BenchmarkResult {
    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let mut set: Set<Int> = Set.new();
        for i in 0..SMALL_SIZE {
            set.insert(i);
        }

        for i in 0..SMALL_SIZE {
            set.remove(&i);
        }
