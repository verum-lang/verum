// @test: benchmark
// @tier: all
// @level: L4
// @expected-performance: Competitive with Rust std collections
// @tags: collections, list, map, set, performance, micro

/// Collection Operations Benchmark
///
/// Measures the performance of Verum's semantic collection types:
/// - List<T> (semantic Vec)
/// - Map<K, V> (semantic HashMap)
/// - Set<T> (semantic HashSet)
///
/// These benchmarks verify that semantic type wrappers add
/// negligible overhead compared to raw implementations.
///
/// Spec reference: docs/detailed/03-type-system.md

module vcs.benchmarks.micro.collection_ops;

const SMALL_SIZE: Int = 100;
const MEDIUM_SIZE: Int = 10_000;
const LARGE_SIZE: Int = 1_000_000;
const BENCHMARK_ITERATIONS: Int = 1_000;

fn main() {
    let results = BenchmarkResults.new("Collection Operations");

    // List benchmarks
    results.add(benchmark_list_push());
    results.add(benchmark_list_pop());
    results.add(benchmark_list_get());
    results.add(benchmark_list_set());
    results.add(benchmark_list_iterate());
    results.add(benchmark_list_sort());
    results.add(benchmark_list_filter());
    results.add(benchmark_list_map());

    // Map benchmarks
    results.add(benchmark_map_insert());
    results.add(benchmark_map_get());
    results.add(benchmark_map_remove());
    results.add(benchmark_map_iterate());
    results.add(benchmark_map_contains());

    // Set benchmarks
    results.add(benchmark_set_insert());
    results.add(benchmark_set_contains());
    results.add(benchmark_set_remove());
    results.add(benchmark_set_union());
    results.add(benchmark_set_intersection());

    results.report();
    assert(results.all_pass(), "Collection operation performance below target");
}

// ============================================================================
// List Benchmarks
// ============================================================================

/// List push (amortized O(1))
fn benchmark_list_push() -> BenchmarkResult {
    let mut list: List<Int> = List.new();

    let timer = Timer.new();
    timer.start();

    for i in 0..LARGE_SIZE {
        list.push(i);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_op_ns = elapsed_ns as Float / LARGE_SIZE as Float;

    BenchmarkResult {
        name: "list_push",
        metric: "ns/push",
        value: per_op_ns,
        target: 50.0,  // Amortized with occasional reallocation
        passed: per_op_ns < 50.0,
    }
}

/// List pop (O(1))
fn benchmark_list_pop() -> BenchmarkResult {
    let mut list: List<Int> = List.with_capacity(LARGE_SIZE);
    for i in 0..LARGE_SIZE {
        list.push(i);
    }

    let timer = Timer.new();
    timer.start();

    while !list.is_empty() {
        black_box(list.pop());
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_op_ns = elapsed_ns as Float / LARGE_SIZE as Float;

    BenchmarkResult {
        name: "list_pop",
        metric: "ns/pop",
        value: per_op_ns,
        target: 10.0,
        passed: per_op_ns < 10.0,
    }
}

/// List indexed access (O(1))
fn benchmark_list_get() -> BenchmarkResult {
    let list: List<Int> = (0..MEDIUM_SIZE).collect();
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        for i in 0..MEDIUM_SIZE {
            sum += list[i];
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "list_get",
        metric: "ns/get",
        value: per_op_ns,
        target: 5.0,
        passed: per_op_ns < 5.0,
    }
}

/// List indexed set (O(1))
fn benchmark_list_set() -> BenchmarkResult {
    let mut list: List<Int> = (0..MEDIUM_SIZE).collect();

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        for i in 0..MEDIUM_SIZE {
            list[i] = i * 2;
        }
    }

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "list_set",
        metric: "ns/set",
        value: per_op_ns,
        target: 5.0,
        passed: per_op_ns < 5.0,
    }
}

/// List iteration
fn benchmark_list_iterate() -> BenchmarkResult {
    let list: List<Int> = (0..MEDIUM_SIZE).collect();
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        for elem in list.iter() {
            sum += *elem;
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "list_iterate",
        metric: "ns/element",
        value: per_op_ns,
        target: 3.0,
        passed: per_op_ns < 3.0,
    }
}

/// List sort (O(n log n))
fn benchmark_list_sort() -> BenchmarkResult {
    let mut rng = Rng.with_seed(12345);

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let mut list: List<Int> = List.with_capacity(MEDIUM_SIZE);
        for _ in 0..MEDIUM_SIZE {
            list.push(rng.next_int());
        }
        list.sort();
        black_box(list);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_sort_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;
    let per_element_ns = per_sort_ns / (MEDIUM_SIZE as Float * (MEDIUM_SIZE as Float).log2());

    BenchmarkResult {
        name: "list_sort",
        metric: "ns/(n log n)",
        value: per_element_ns,
        target: 50.0,
        passed: per_element_ns < 50.0,
    }
}

/// List filter
fn benchmark_list_filter() -> BenchmarkResult {
    let list: List<Int> = (0..MEDIUM_SIZE).collect();

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let filtered: List<Int> = list.iter()
            .filter(|x| *x % 2 == 0)
            .cloned()
            .collect();
        black_box(filtered);
    }

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "list_filter",
        metric: "ns/element",
        value: per_op_ns,
        target: 10.0,
        passed: per_op_ns < 10.0,
    }
}

/// List map transformation
fn benchmark_list_map() -> BenchmarkResult {
    let list: List<Int> = (0..MEDIUM_SIZE).collect();

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let mapped: List<Int> = list.iter()
            .map(|x| *x * 2)
            .collect();
        black_box(mapped);
    }

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "list_map",
        metric: "ns/element",
        value: per_op_ns,
        target: 10.0,
        passed: per_op_ns < 10.0,
    }
}

// ============================================================================
// Map Benchmarks
// ============================================================================

/// Map insert (amortized O(1))
fn benchmark_map_insert() -> BenchmarkResult {
    let mut map: Map<Int, Int> = Map.new();

    let timer = Timer.new();
    timer.start();

    for i in 0..MEDIUM_SIZE {
        map.insert(i, i * 2);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_op_ns = elapsed_ns as Float / MEDIUM_SIZE as Float;

    BenchmarkResult {
        name: "map_insert",
        metric: "ns/insert",
        value: per_op_ns,
        target: 100.0,  // Includes hashing
        passed: per_op_ns < 100.0,
    }
}

/// Map get (O(1) average)
fn benchmark_map_get() -> BenchmarkResult {
    let mut map: Map<Int, Int> = Map.new();
    for i in 0..MEDIUM_SIZE {
        map.insert(i, i * 2);
    }

    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        for i in 0..MEDIUM_SIZE {
            if let Some(v) = map.get(&i) {
                sum += *v;
            }
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "map_get",
        metric: "ns/get",
        value: per_op_ns,
        target: 50.0,
        passed: per_op_ns < 50.0,
    }
}

/// Map remove (O(1) average)
fn benchmark_map_remove() -> BenchmarkResult {
    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let mut map: Map<Int, Int> = Map.new();
        for i in 0..SMALL_SIZE {
            map.insert(i, i);
        }

        for i in 0..SMALL_SIZE {
            map.remove(&i);
        }
    }

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * SMALL_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "map_remove",
        metric: "ns/remove",
        value: per_op_ns,
        target: 80.0,
        passed: per_op_ns < 80.0,
    }
}

/// Map iteration
fn benchmark_map_iterate() -> BenchmarkResult {
    let mut map: Map<Int, Int> = Map.new();
    for i in 0..MEDIUM_SIZE {
        map.insert(i, i * 2);
    }

    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        for (k, v) in map.iter() {
            sum += *k + *v;
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "map_iterate",
        metric: "ns/entry",
        value: per_op_ns,
        target: 15.0,
        passed: per_op_ns < 15.0,
    }
}

/// Map contains_key
fn benchmark_map_contains() -> BenchmarkResult {
    let mut map: Map<Int, Int> = Map.new();
    for i in 0..MEDIUM_SIZE {
        map.insert(i, i);
    }

    let mut count: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        for i in 0..MEDIUM_SIZE {
            if map.contains_key(&i) {
                count += 1;
            }
        }
    }
    black_box(count);

    let elapsed_ns = timer.elapsed_ns();
    let total_ops = BENCHMARK_ITERATIONS * MEDIUM_SIZE;
    let per_op_ns = elapsed_ns as Float / total_ops as Float;

    BenchmarkResult {
        name: "map_contains",
        metric: "ns/lookup",
        value: per_op_ns,
        target: 40.0,
        passed: per_op_ns < 40.0,
    }
}

