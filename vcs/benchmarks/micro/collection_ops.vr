/// Set union
fn benchmark_set_union() -> BenchmarkResult {
    let mut set_a: Set<Int> = Set.new();
    let mut set_b: Set<Int> = Set.new();

    for i in 0..SMALL_SIZE {
        set_a.insert(i);
    }
    for i in (SMALL_SIZE / 2)..(SMALL_SIZE + SMALL_SIZE / 2) {
        set_b.insert(i);
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let union = set_a.union(&set_b);
        black_box(union.len());
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_op_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "set_union",
        metric: "ns/union",
        value: per_op_ns,
        target: 5000.0,  // O(n) operation
        passed: per_op_ns < 5000.0,
    }
}

/// Set intersection
fn benchmark_set_intersection() -> BenchmarkResult {
    let mut set_a: Set<Int> = Set.new();
    let mut set_b: Set<Int> = Set.new();

    for i in 0..SMALL_SIZE {
        set_a.insert(i);
    }
    for i in (SMALL_SIZE / 2)..(SMALL_SIZE + SMALL_SIZE / 2) {
        set_b.insert(i);
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let intersection = set_a.intersection(&set_b);
        black_box(intersection.len());
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_op_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "set_intersection",
        metric: "ns/intersection",
        value: per_op_ns,
        target: 3000.0,  // O(min(n,m)) operation
        passed: per_op_ns < 3000.0,
    }
}

// Benchmark infrastructure
type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(&self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results.iter() {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}

@extern("verum_bench")
fn black_box<T>(value: T) -> T;

type Timer is {
    start_time: u64,
};

implement Timer {
    fn new() -> Self {
        Self { start_time: 0 }
    }

    fn start(&mut self) {
        self.start_time = clock_ns();
    }

    fn elapsed_ns(&self) -> u64 {
        clock_ns() - self.start_time
    }
}

@extern("verum_time")
fn clock_ns() -> u64;

type Rng is {
    state: u64,
};

implement Rng {
    fn with_seed(seed: u64) -> Self {
        Self { state: seed }
    }

    fn next_int(&mut self) -> Int {
        self.state = self.state * 6364136223846793005 + 1442695040888963407;
        (self.state >> 32) as Int
    }
}
