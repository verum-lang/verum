// @test: benchmark
// @tier: 0
// @level: L4
// @tags: strings, text, f-string, performance, micro
// @timeout: 30000

/// String Operations Benchmark
/// Construction, interpolation, comparison.

module vcs.benchmarks.micro.string_benchmark;

const ITERATIONS: Int = 10_000;

fn benchmark_fstring() -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < ITERATIONS {
        let s = f"item_{i}";
        if s.len() > 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

fn benchmark_comparison() -> Int {
    let mut matches = 0;
    let target = "hello";
    let mut i = 0;
    while i < ITERATIONS {
        let s = if i % 100 == 0 { "hello" } else { "world" };
        if s == target {
            matches = matches + 1;
        }
        i = i + 1;
    }
    matches
}

fn main() {
    let fstr = benchmark_fstring();
    assert_eq(fstr, ITERATIONS);

    let cmp = benchmark_comparison();
    assert_eq(cmp, 100);

    print(f"fstring constructions: {fstr}");
    print(f"string comparisons matched: {cmp}");
}
