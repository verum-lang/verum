// @test: benchmark
// @tier: all
// @level: L4
// @expected-performance: < 3ns single capture, < 10ns multi capture
// @tags: closure, capture, performance, micro

/// Closure Capture Performance Benchmark
///
/// Measures the overhead of closure capture patterns in Verum:
/// - No capture (pure function-like closures)
/// - Single value capture
/// - Multiple value capture
/// - Reference capture
/// - Mutable capture
/// - Move capture
/// - Nested closures
///
/// Targets:
/// - No capture: < 2ns
/// - Single capture: < 3ns
/// - Multi capture: < 10ns (varies by size)
/// - Reference capture: < 4ns
/// - Mutable capture: < 5ns

module vcs.benchmarks.micro.closure_capture

const WARMUP_ITERATIONS: Int = 100_000;
const BENCHMARK_ITERATIONS: Int = 10_000_000;

/// Large struct for testing capture overhead
type LargeStruct is {
    a: Int, b: Int, c: Int, d: Int,
    e: Int, f: Int, g: Int, h: Int,
};

implement LargeStruct {
    fn new() -> Self {
        LargeStruct {
            a: 1, b: 2, c: 3, d: 4,
            e: 5, f: 6, g: 7, h: 8,
        }
    }

    fn sum(&self) -> Int {
        self.a + self.b + self.c + self.d + self.e + self.f + self.g + self.h
    }
}

fn main() {
    let results = BenchmarkResults.new("Closure Capture Performance");

    // No capture benchmarks
    results.add(benchmark_no_capture());
    results.add(benchmark_no_capture_multiline());

    // Single capture benchmarks
    results.add(benchmark_capture_single_int());
    results.add(benchmark_capture_single_float());
    results.add(benchmark_capture_single_text());

    // Multiple capture benchmarks
    results.add(benchmark_capture_two_ints());
    results.add(benchmark_capture_four_ints());
    results.add(benchmark_capture_eight_ints());

    // Reference capture benchmarks
    results.add(benchmark_capture_ref());
    results.add(benchmark_capture_ref_large());

    // Mutable capture benchmarks
    results.add(benchmark_capture_mut_single());
    results.add(benchmark_capture_mut_multiple());

    // Move capture benchmarks
    results.add(benchmark_move_capture_small());
    results.add(benchmark_move_capture_large());

    // Nested closure benchmarks
    results.add(benchmark_nested_closure());
    results.add(benchmark_deeply_nested_closure());

    // Closure in loop benchmarks
    results.add(benchmark_closure_in_loop());
    results.add(benchmark_closure_reuse());

    // Higher-order function benchmarks
    results.add(benchmark_map_closure());
    results.add(benchmark_filter_closure());
    results.add(benchmark_fold_closure());

    results.report();
    assert(results.all_pass(), "Closure capture performance below target");
}

/// Benchmark closure with no capture
fn benchmark_no_capture() -> BenchmarkResult {
    let closure = |x: Int| -> Int { x + 1 };
    let mut sum: Int = 0;

    // Warmup
    for i in 0..WARMUP_ITERATIONS {
        sum += closure(i);
    }
    black_box(sum);

    sum = 0;
    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += closure(i);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "no_capture",
        metric: "ns/call",
        value: per_call_ns,
        target: 2.0,
        passed: per_call_ns < 2.0,
    }
}

/// Benchmark multiline closure with no capture
fn benchmark_no_capture_multiline() -> BenchmarkResult {
    let closure = |x: Int| -> Int {
        let a = x + 1;
        let b = a * 2;
        let c = b - 1;
        c
    };
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += closure(i);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "no_capture_multiline",
        metric: "ns/call",
        value: per_call_ns,
        target: 3.0,
        passed: per_call_ns < 3.0,
    }
}

