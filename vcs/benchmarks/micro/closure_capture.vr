/// Benchmark reference capture
fn benchmark_capture_ref() -> BenchmarkResult {
    let value = 42;
    let closure = |x: Int| -> Int { x + *(&value) };
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += closure(i);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "capture_ref",
        metric: "ns/call",
        value: per_call_ns,
        target: 4.0,
        passed: per_call_ns < 4.0,
    }
}

/// Benchmark reference capture of large struct
fn benchmark_capture_ref_large() -> BenchmarkResult {
    let large = LargeStruct.new();
    let closure = |x: Int| -> Int { x + (&large).sum() };
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..(BENCHMARK_ITERATIONS / 10) {
        sum += closure(i);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / (BENCHMARK_ITERATIONS / 10) as Float;

    BenchmarkResult {
        name: "capture_ref_large",
        metric: "ns/call",
        value: per_call_ns,
        target: 15.0,
        passed: per_call_ns < 15.0,
    }
}

/// Benchmark mutable single capture
fn benchmark_capture_mut_single() -> BenchmarkResult {
    let mut counter = 0;
    let mut closure = || { counter += 1; counter };

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let _ = closure();
    }
    black_box(counter);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "capture_mut_single",
        metric: "ns/call",
        value: per_call_ns,
        target: 5.0,
        passed: per_call_ns < 5.0,
    }
}

/// Benchmark mutable multiple capture
fn benchmark_capture_mut_multiple() -> BenchmarkResult {
    let mut a = 0;
    let mut b = 0;
    let mut c = 0;
    let mut closure = |x: Int| {
        a += x;
        b += x * 2;
        c += x * 3;
        a + b + c
    };
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += closure(i % 100);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "capture_mut_multiple",
        metric: "ns/call",
        value: per_call_ns,
        target: 8.0,
        passed: per_call_ns < 8.0,
    }
}

/// Benchmark move capture of small type
fn benchmark_move_capture_small() -> BenchmarkResult {
    let iterations = BENCHMARK_ITERATIONS / 1000;
    let mut total_sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        let value = 42;
        let closure = move || { value };
        total_sum += closure();
    }
    black_box(total_sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / iterations as Float;

    BenchmarkResult {
        name: "move_capture_small",
        metric: "ns/create+call",
        value: per_call_ns,
        target: 20.0,
        passed: per_call_ns < 20.0,
    }
}

/// Benchmark move capture of large type
fn benchmark_move_capture_large() -> BenchmarkResult {
    let iterations = BENCHMARK_ITERATIONS / 10000;
    let mut total_sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        let large = LargeStruct.new();
        let closure = move || { large.sum() };
        total_sum += closure();
    }
    black_box(total_sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / iterations as Float;

    BenchmarkResult {
        name: "move_capture_large",
        metric: "ns/create+call",
        value: per_call_ns,
        target: 100.0,
        passed: per_call_ns < 100.0,
    }
}

/// Benchmark nested closure
fn benchmark_nested_closure() -> BenchmarkResult {
    let outer_val = 10;
    let outer = |x: Int| -> Int {
        let inner_val = 20;
        let inner = |y: Int| -> Int { y + outer_val + inner_val };
        inner(x)
    };
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += outer(i);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "nested_closure",
        metric: "ns/call",
        value: per_call_ns,
        target: 8.0,
        passed: per_call_ns < 8.0,
    }
}

/// Benchmark deeply nested closures
fn benchmark_deeply_nested_closure() -> BenchmarkResult {
    let v1 = 1;
    let level1 = |x: Int| -> Int {
        let v2 = 2;
        let level2 = |y: Int| -> Int {
            let v3 = 3;
            let level3 = |z: Int| -> Int {
                z + v1 + v2 + v3
            };
            level3(y)
        };
        level2(x)
    };
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..(BENCHMARK_ITERATIONS / 2) {
        sum += level1(i);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / (BENCHMARK_ITERATIONS / 2) as Float;

    BenchmarkResult {
        name: "deeply_nested_closure",
        metric: "ns/call",
        value: per_call_ns,
        target: 15.0,
        passed: per_call_ns < 15.0,
    }
}

/// Benchmark closure creation in loop
fn benchmark_closure_in_loop() -> BenchmarkResult {
    let mut sum: Int = 0;
    let captured = 100;

    let timer = Timer.new();
    timer.start();

    for i in 0..(BENCHMARK_ITERATIONS / 100) {
        let closure = |x: Int| -> Int { x + captured };
        for j in 0..100 {
            sum += closure(j);
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "closure_in_loop",
        metric: "ns/call",
        value: per_call_ns,
        target: 4.0,
        passed: per_call_ns < 4.0,
    }
}

/// Benchmark reusing same closure
fn benchmark_closure_reuse() -> BenchmarkResult {
    let captured = 100;
    let closure = |x: Int| -> Int { x + captured };
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        sum += closure(i);
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "closure_reuse",
        metric: "ns/call",
        value: per_call_ns,
        target: 3.0,
        passed: per_call_ns < 3.0,
    }
}

/// Benchmark map with closure
fn benchmark_map_closure() -> BenchmarkResult {
    let data: List<Int> = (0..1000).collect();
    let multiplier = 2;
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..(BENCHMARK_ITERATIONS / 1000) {
        let mapped: List<Int> = data.iter().map(|x| x * multiplier).collect();
        sum += mapped.len();
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_elem_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "map_closure",
        metric: "ns/element",
        value: per_elem_ns,
        target: 5.0,
        passed: per_elem_ns < 5.0,
    }
}

/// Benchmark filter with closure
fn benchmark_filter_closure() -> BenchmarkResult {
    let data: List<Int> = (0..1000).collect();
    let threshold = 500;
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..(BENCHMARK_ITERATIONS / 1000) {
        let filtered: List<Int> = data.iter().filter(|x| *x > threshold).cloned().collect();
        sum += filtered.len();
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_elem_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "filter_closure",
        metric: "ns/element",
        value: per_elem_ns,
        target: 5.0,
        passed: per_elem_ns < 5.0,
    }
}

/// Benchmark fold with closure
fn benchmark_fold_closure() -> BenchmarkResult {
    let data: List<Int> = (0..1000).collect();
    let initial = 0;
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..(BENCHMARK_ITERATIONS / 1000) {
        let result = data.iter().fold(initial, |acc, x| acc + x);
        sum += result;
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_elem_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "fold_closure",
        metric: "ns/element",
        value: per_elem_ns,
        target: 4.0,
        passed: per_elem_ns < 4.0,
    }
}

// Benchmark infrastructure types
type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(&self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results.iter() {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}

@extern("verum_bench")
fn black_box<T>(value: T) -> T;

type Timer is {
    start_time: u64,
};

implement Timer {
    fn new() -> Self {
        Self { start_time: 0 }
    }

    fn start(&mut self) {
        self.start_time = clock_ns();
    }

    fn elapsed_ns(&self) -> u64 {
        clock_ns() - self.start_time
    }
}

@extern("verum_time")
fn clock_ns() -> u64;
