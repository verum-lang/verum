    for i in 0..BENCHMARK_ITERATIONS {
        let value = i % 101;
        if let Some(pct) = Percentage.try_from(value) {
            success_count += 1;
        }
    }
    black_box(success_count);

    let elapsed_ns = timer.elapsed_ns();
    let per_check_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "percentage_check",
        metric: "ns/check",
        value: per_check_ns,
        target: 25.0,
        passed: per_check_ns < 25.0,
    }
}

