/// Generic range check
fn benchmark_range_check() -> BenchmarkResult {
    type InRange is Int { value: it >= 10 && it <= 1000 };

    let mut success_count: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        let value = (i % 1100) + 1;
        if let Some(_) = InRange.try_from(value) {
            success_count += 1;
        }
    }
    black_box(success_count);

    let elapsed_ns = timer.elapsed_ns();
    let per_check_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "range_check",
        metric: "ns/check",
        value: per_check_ns,
        target: 30.0,
        passed: per_check_ns < 30.0,
    }
}

/// Compound refinement (positive AND even)
fn benchmark_positive_even_check() -> BenchmarkResult {
    let mut success_count: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 1..=BENCHMARK_ITERATIONS {
        if let Some(_) = PositiveEven.try_from(i * 2) {
            success_count += 1;
        }
    }
    black_box(success_count);

    let elapsed_ns = timer.elapsed_ns();
    let per_check_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "positive_even_check",
        metric: "ns/check",
        value: per_check_ns,
        target: 35.0,
        passed: per_check_ns < 35.0,
    }
}

/// Multiple independent constraints
fn benchmark_multiple_constraints() -> BenchmarkResult {
    type Constrained is Int {
        value: it > 0 && it < 1000 && it % 3 == 0 && it % 5 != 0
    };

    let mut success_count: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 1..=BENCHMARK_ITERATIONS {
        let value = (i % 999) + 1;
        if let Some(_) = Constrained.try_from(value) {
            success_count += 1;
        }
    }
    black_box(success_count);

    let elapsed_ns = timer.elapsed_ns();
    let per_check_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "multiple_constraints",
        metric: "ns/check",
        value: per_check_ns,
        target: 50.0,
        passed: per_check_ns < 50.0,
    }
}

/// Refinement as function parameter
fn benchmark_refinement_parameter() -> BenchmarkResult {
    fn process_positive(x: Positive) -> Int {
        x.value() * 2
    }

    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 1..=BENCHMARK_ITERATIONS {
        if let Some(pos) = Positive.try_from(i) {
            sum += process_positive(pos);
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "refinement_parameter",
        metric: "ns/call",
        value: per_call_ns,
        target: 25.0,
        passed: per_call_ns < 25.0,
    }
}

/// Refinement as function return
fn benchmark_refinement_return() -> BenchmarkResult {
    fn make_positive(x: Int) -> Maybe<Positive> {
        Positive.try_from(x)
    }

    let mut success_count: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 1..=BENCHMARK_ITERATIONS {
        if let Some(_) = make_positive(i) {
            success_count += 1;
        }
    }
    black_box(success_count);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "refinement_return",
        metric: "ns/call",
        value: per_call_ns,
        target: 25.0,
        passed: per_call_ns < 25.0,
    }
}

/// Bounded index (dependent on array length)
fn benchmark_bounded_index() -> BenchmarkResult {
    const ARRAY_SIZE: Int = 100;

    let array: [Int; ARRAY_SIZE] = [0; ARRAY_SIZE];
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        let idx = i % ARRAY_SIZE;
        if let Some(bounded) = BoundedIndex<ARRAY_SIZE>.try_from(idx) {
            sum += array[bounded.value()];
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_check_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "bounded_index",
        metric: "ns/check",
        value: per_check_ns,
        target: 30.0,
        passed: per_check_ns < 30.0,
    }
}

/// Length-dependent refinement
fn benchmark_length_dependent() -> BenchmarkResult {
    type ValidIndex is Int where value { 0 <= value && value < len };

    fn get_element<T>(list: &List<T>, idx: ValidIndex) -> &T {
        &list[idx.value()]
    }

    let list: List<Int> = (0..100).collect();
    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        let idx = i % 100;
        // Bounds check is part of ValidIndex construction
        sum += list[idx];
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_access_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "length_dependent",
        metric: "ns/access",
        value: per_access_ns,
        target: 25.0,
        passed: per_access_ns < 25.0,
    }
}

/// Static refinement elimination
fn benchmark_static_elimination() -> BenchmarkResult {
    // Compiler should prove this is always positive
    fn always_positive() -> Positive {
        // 42 is a constant, compiler knows it's > 0
        Positive.from_unchecked(42)
    }

    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        sum += always_positive().value();
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    // Static elimination should result in near-zero overhead
    BenchmarkResult {
        name: "static_elimination",
        metric: "ns/call",
        value: per_call_ns,
        target: 5.0,
        passed: per_call_ns < 5.0,
    }
}

/// Dynamic refinement check (user input simulation)
fn benchmark_dynamic_check() -> BenchmarkResult {
    fn validate_user_input(input: Int) -> Result<Positive, Text> {
        Positive.try_from(input)
            .ok_or("Input must be positive".to_text())
    }

    let mut rng = Rng.with_seed(12345);
    let mut success_count: Int = 0;

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        let input = rng.next_int() % 200 - 100;  // Range: -100 to 99
        if let Ok(_) = validate_user_input(input) {
            success_count += 1;
        }
    }
    black_box(success_count);

    let elapsed_ns = timer.elapsed_ns();
    let per_check_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "dynamic_check",
        metric: "ns/check",
        value: per_check_ns,
        target: 50.0,
        passed: per_check_ns < 50.0,
    }
}

/// Division safety with refinement
fn benchmark_division_safety() -> BenchmarkResult {
    fn safe_divide(numerator: Int, denominator: NonZero) -> Int {
        numerator / denominator.value()
    }

    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 1..=BENCHMARK_ITERATIONS {
        if let Some(nz) = NonZero.try_from(i) {
            sum += safe_divide(100, nz);
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_op_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "division_safety",
        metric: "ns/op",
        value: per_op_ns,
        target: 30.0,
        passed: per_op_ns < 30.0,
    }
}

/// Array bounds with refinement
fn benchmark_array_bounds_refinement() -> BenchmarkResult {
    const SIZE: Int = 1000;
    let array: [Int; SIZE] = [0; SIZE];

    let mut sum: Int = 0;

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        let idx = i % SIZE;
        if let Some(bounded) = BoundedIndex<SIZE>.try_from(idx) {
            // No bounds check needed - refinement guarantees safety
            sum += unsafe { array.get_unchecked(bounded.value()) };
        }
    }
    black_box(sum);

    let elapsed_ns = timer.elapsed_ns();
    let per_access_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "array_bounds_refinement",
        metric: "ns/access",
        value: per_access_ns,
        target: 25.0,
        passed: per_access_ns < 25.0,
    }
}

// Refinement type implementations
implement NonZero {
    fn try_from(value: Int) -> Maybe<Self> {
        if value != 0 {
            Some(unsafe { Self.from_unchecked(value) })
        } else {
            None
        }
    }

    fn from_unchecked(value: Int) -> Self {
        // SAFETY: Caller guarantees value != 0
        unsafe { transmute(value) }
    }

    fn value(&self) -> Int {
        *self as Int
    }
}

implement Positive {
    fn try_from(value: Int) -> Maybe<Self> {
        if value > 0 {
            Some(unsafe { Self.from_unchecked(value) })
        } else {
            None
        }
    }

    fn from_unchecked(value: Int) -> Self {
        unsafe { transmute(value) }
    }

    fn value(&self) -> Int {
        *self as Int
    }
}

implement Percentage {
    fn try_from(value: Int) -> Maybe<Self> {
        if value >= 0 && value <= 100 {
            Some(unsafe { transmute(value) })
        } else {
            None
        }
    }
}

implement ValidAge {
    fn try_from(value: Int) -> Maybe<Self> {
        if value >= 0 && value <= 150 {
            Some(unsafe { transmute(value) })
        } else {
            None
        }
    }
}

implement Even {
    fn try_from(value: Int) -> Maybe<Self> {
        if value % 2 == 0 {
            Some(unsafe { transmute(value) })
        } else {
            None
        }
    }
}

implement PositiveEven {
    fn try_from(value: Int) -> Maybe<Self> {
        if value > 0 && value % 2 == 0 {
            Some(unsafe { transmute(value) })
        } else {
            None
        }
    }
}

implement<N: meta Int> BoundedIndex<N> {
    fn try_from(value: Int) -> Maybe<Self> {
        if value >= 0 && value < N {
            Some(unsafe { transmute(value) })
        } else {
            None
        }
    }

    fn value(&self) -> Int {
        *self as Int
    }
}

// Benchmark infrastructure
type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(&self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results.iter() {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}

@extern("verum_bench")
fn black_box<T>(value: T) -> T;

@extern("verum_intrinsics")
unsafe fn transmute<T, U>(value: T) -> U;

type Timer is {
    start_time: u64,
};

implement Timer {
    fn new() -> Self {
        Self { start_time: 0 }
    }

    fn start(&mut self) {
        self.start_time = clock_ns();
    }

    fn elapsed_ns(&self) -> u64 {
        clock_ns() - self.start_time
    }
}

@extern("verum_time")
fn clock_ns() -> u64;

type Rng is {
    state: u64,
};

implement Rng {
    fn with_seed(seed: u64) -> Self {
        Self { state: seed }
    }

    fn next_int(&mut self) -> Int {
        self.state = self.state * 6364136223846793005 + 1442695040888963407;
        (self.state >> 32) as Int
    }
}
