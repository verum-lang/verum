// =============================================================================
// t02_simple_query.vr — text-protocol round-trip against live Postgres
// =============================================================================
// Spec: internal/specs/database.md §6.1.3 (Simple-Query Protocol).
// =============================================================================
//
// Exercises the text-protocol path that every other test depends
// on. After this test passes, subsequent tests can rely on
// `simple_query` for setup / teardown DDL.
//
// Scenarios:
//   1. SELECT-class — multiple rows, multiple columns; verify
//      command_tag, row count, column metadata.
//   2. INSERT-class — affected_rows visible via command_tag
//      `INSERT 0 N`.
//   3. UPDATE / DELETE — same pattern.
//   4. Empty result — `SELECT WHERE FALSE` returns zero rows but
//      still completes cleanly (no error, command_tag present).
//   5. Multi-statement — Postgres simple-query allows ';'-separated
//      statements; the wire returns one result per statement and
//      Spindle currently exposes the LAST one. Verify no crash.
// =============================================================================

mount conn_config.{
    connect_app, expect, expect_ok, expect_eq_int, pass,
};

fn main() {
    let mut conn = expect_ok(
        connect_app(),
        &"connect_app() failed".clone(),
    );

    // -------------------------------------------------------------------------
    // 1. SELECT — generate_series produces 5 rows, 2 columns.
    // -------------------------------------------------------------------------
    let r1 = expect_ok(
        conn.simple_query(&
            "SELECT n AS num, n * 10 AS scaled FROM generate_series(1, 5) AS n".clone()
        ),
        &"SELECT generate_series failed".clone(),
    );
    expect_eq_int(r1.rows.len() as Int, 5, &"generate_series row count".clone());
    match &r1.row_description {
        Some(rd) => expect_eq_int(rd.fields.len() as Int, 2, &"col count".clone()),
        None     => expect(false, &"row_description missing".clone()),
    }

    // -------------------------------------------------------------------------
    // 2. INSERT — clean a known table, insert a row, verify count.
    // -------------------------------------------------------------------------
    let _ = conn.simple_query(&"DELETE FROM accounts".clone());
    let r2 = expect_ok(
        conn.simple_query(&
            "INSERT INTO accounts (email, age, balance) VALUES ('a@b.co', 30, 100.0)"
                .clone()
        ),
        &"INSERT failed".clone(),
    );
    // command_tag for INSERT is `INSERT 0 N`. We check it ends with `1`.
    let tag = &r2.command_tag;
    let tag_bytes = tag.as_bytes();
    expect(
        tag_bytes.len() > 0 && tag_bytes[(tag_bytes.len() - 1) as Int] == ('1' as Byte),
        &f"unexpected INSERT command_tag: {tag}",
    );

    // -------------------------------------------------------------------------
    // 3. UPDATE — touch the row, verify command_tag `UPDATE 1`.
    // -------------------------------------------------------------------------
    let r3 = expect_ok(
        conn.simple_query(&
            "UPDATE accounts SET age = 31 WHERE email = 'a@b.co'".clone()
        ),
        &"UPDATE failed".clone(),
    );
    let tag3 = &r3.command_tag;
    let tag3_bytes = tag3.as_bytes();
    expect(
        tag3_bytes.len() > 0 && tag3_bytes[(tag3_bytes.len() - 1) as Int] == ('1' as Byte),
        &f"unexpected UPDATE command_tag: {tag3}",
    );

    // -------------------------------------------------------------------------
    // 4. SELECT WHERE FALSE — empty result, no crash, command_tag present.
    // -------------------------------------------------------------------------
    let r4 = expect_ok(
        conn.simple_query(&
            "SELECT id FROM accounts WHERE id = -1".clone()
        ),
        &"empty SELECT failed".clone(),
    );
    expect_eq_int(r4.rows.len() as Int, 0, &"empty result row count".clone());

    // -------------------------------------------------------------------------
    // 5. DELETE — clean up; tag ends with `1`.
    // -------------------------------------------------------------------------
    let r5 = expect_ok(
        conn.simple_query(&
            "DELETE FROM accounts WHERE email = 'a@b.co'".clone()
        ),
        &"DELETE failed".clone(),
    );
    let tag5 = &r5.command_tag;
    let tag5_bytes = tag5.as_bytes();
    expect(
        tag5_bytes.len() > 0 && tag5_bytes[(tag5_bytes.len() - 1) as Int] == ('1' as Byte),
        &f"unexpected DELETE command_tag: {tag5}",
    );

    pass(&"t02_simple_query".clone());
}
