// =============================================================================
// vcs/integration/postgres/tests/conn_config.vr — shared test fixtures
// =============================================================================
// Mounted by every t*.vr file. Centralises the connection
// parameters so the docker-compose.yml port / role / db / password
// values are defined once.
// =============================================================================

module conn_config;

mount core.*;
mount base.{Result, Ok, Err, Text};
mount core.database.postgres.{
    PgConfig, PgConnection, PgTlsMode, PtmDisable, PtmVerifyFull,
    connect,
};

/// Container endpoint per docker-compose.yml.
public const TEST_HOST: Text = "127.0.0.1";
public const TEST_PORT: Int = 55432;
public const TEST_DB:   Text = "spindle_test";

/// App-tier role — has SELECT/INSERT/UPDATE/DELETE on the test
/// schema. Use for the typical handler path.
public const APP_USER: Text = "spindle_app";
public const APP_PW:   Text = "spindle_app_pw";

/// Read-only role — capability narrowing tests. SELECT-only.
public const RO_USER:  Text = "spindle_ro";
public const RO_PW:    Text = "spindle_ro_pw";

/// Admin role — schema mutation / cleanup paths.
public const ADMIN_USER: Text = "spindle_admin";
public const ADMIN_PW:   Text = "spindle_admin_pw";

/// Build a fresh connection as the app role. Tests typically
/// open one connection per scenario for isolation.
public fn connect_app() -> Result<PgConnection, core.database.common.error.DbError> {
    let cfg = PgConfig {
        host: TEST_HOST.clone(),
        port: TEST_PORT,
        user: APP_USER.clone(),
        password: APP_PW.clone(),
        database: TEST_DB.clone(),
        application_name: "spindle-itest".clone(),
        tls_mode: PtmDisable,           // loopback — TLS layer is a separate workstream
        connect_timeout_ms: 10_000,
    };
    connect(&cfg)
}

/// Build a fresh connection as the read-only role.
public fn connect_ro() -> Result<PgConnection, core.database.common.error.DbError> {
    let cfg = PgConfig {
        host: TEST_HOST.clone(),
        port: TEST_PORT,
        user: RO_USER.clone(),
        password: RO_PW.clone(),
        database: TEST_DB.clone(),
        application_name: "spindle-itest-ro".clone(),
        tls_mode: PtmDisable,
        connect_timeout_ms: 10_000,
    };
    connect(&cfg)
}

/// Build a fresh connection as the admin role.
public fn connect_admin() -> Result<PgConnection, core.database.common.error.DbError> {
    let cfg = PgConfig {
        host: TEST_HOST.clone(),
        port: TEST_PORT,
        user: ADMIN_USER.clone(),
        password: ADMIN_PW.clone(),
        database: TEST_DB.clone(),
        application_name: "spindle-itest-admin".clone(),
        tls_mode: PtmDisable,
        connect_timeout_ms: 10_000,
    };
    connect(&cfg)
}

// -----------------------------------------------------------------------------
// Tiny assertion helpers — every test prefers `expect_eq` /
// `expect` over panic'ing inline so the runner sees a clean
// non-zero exit + a one-line failure message. Tests print
// "FAIL: ..." to stderr and `exit(1)` on the first violated
// expectation; success-path tests fall through to `exit(0)`.
// -----------------------------------------------------------------------------

public fn expect(condition: Bool, message: &Text) {
    if !condition {
        eprint(f"FAIL: {message}");
        sys.exit(1);
    }
}

public fn expect_eq_int(actual: Int, expected: Int, message: &Text) {
    if actual != expected {
        eprint(f"FAIL: {message} — expected {expected}, got {actual}");
        sys.exit(1);
    }
}

public fn expect_ok<T, E: Display>(r: Result<T, E>, message: &Text) -> T {
    match r {
        Ok(v) => v,
        Err(e) => {
            eprint(f"FAIL: {message} — {e}");
            sys.exit(1);
        }
    }
}

public fn pass(name: &Text) {
    print(f"PASS: {name}");
}
