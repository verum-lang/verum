// =============================================================================
// t18_async_prepared.vr — async prepared statements + PreparedSession LRU
// =============================================================================
// Spec: internal/specs/database.md §6.3.4 (binary protocol prepared cache).
// =============================================================================
//
// V0:
//   1. Async prepare/execute/close round-trip via direct
//      AsyncMysqlConnection.prepare → execute_prepared → close.
//   2. AsyncMysqlPreparedSession.prepare_cached double-call
//      hits cache (cache.len stays 1, total_hits ≥ 1).
//   3. query_cached round-trip returns affected_rows == 1.
//   4. drain_cache_on_close releases the slot.
// =============================================================================

mount conn_config.{
    expect, expect_ok, expect_eq_int, pass,
    TEST_HOST, TEST_PORT, TEST_DB, APP_USER, APP_PW,
};
mount core.database.mysql.{
    MysqlConfig, MtmDisable,
    AsyncMysqlConnection, AsyncMysqlPreparedStatement,
    AsyncMysqlPreparedSession,
    async_mysql_connect,
    StmtParam, param_int, param_text,
};
mount core.async.executor.block_on;

fn main() {
    block_on(async move {
        let cfg = MysqlConfig {
            host: TEST_HOST.clone(),
            port: TEST_PORT,
            user: APP_USER.clone(),
            password: APP_PW.clone(),
            database: TEST_DB.clone(),
            character_set: 255,
            tls_mode: MtmDisable,
            connect_timeout_ms: 10_000,
        };
        let conn = expect_ok(
            async_mysql_connect(&cfg, 8).await,
            &"async_mysql_connect failed".clone(),
        );

        // Setup smoke table.
        let _ = conn.execute(&"DROP TABLE IF EXISTS async_prep_smoke".clone()).await;
        expect_ok(
            conn.execute(&
                "CREATE TABLE async_prep_smoke ( \
                    id INT AUTO_INCREMENT PRIMARY KEY, \
                    payload VARCHAR(255) NOT NULL \
                 ) ENGINE=InnoDB".clone()
            ).await,
            &"CREATE TABLE failed".clone(),
        );

        // -------------------------------------------------------------------
        // 1. Direct prepare → execute → close round-trip.
        // -------------------------------------------------------------------
        let stmt = expect_ok(
            conn.prepare(&"INSERT INTO async_prep_smoke (payload) VALUES (?)".clone()).await,
            &"prepare INSERT failed".clone(),
        );
        expect_eq_int(stmt.num_params(), 1, &"INSERT num_params".clone());

        let mut params: List<StmtParam> = List.new();
        params.push(param_text("hello".clone()));
        let r = expect_ok(
            conn.execute_prepared(&stmt, params).await,
            &"execute_prepared failed".clone(),
        );
        expect_eq_int(r.affected_rows, 1, &"INSERT affected_rows".clone());

        expect_ok(
            conn.close_prepared(stmt).await,
            &"close_prepared failed".clone(),
        );

        // -------------------------------------------------------------------
        // 2 + 3. PreparedSession LRU + query_cached.
        // -------------------------------------------------------------------
        let mut session = AsyncMysqlPreparedSession.new();

        let upsert_sql = "INSERT INTO async_prep_smoke (payload) VALUES (?)".clone();
        let _ = expect_ok(
            session.prepare_cached(&conn, &upsert_sql).await,
            &"session prepare_cached A failed".clone(),
        );
        let _ = expect_ok(
            session.prepare_cached(&conn, &upsert_sql).await,
            &"session prepare_cached B failed".clone(),
        );
        let metrics = session.cache_metrics();
        expect(
            metrics.total_hits >= 1,
            &f"session expected ≥1 cache hit, got {metrics.total_hits}",
        );
        expect_eq_int(session.cache_len(), 1,
            &"cache.len stays 1 after second prepare".clone());

        let mut p2: List<StmtParam> = List.new();
        p2.push(param_text("via-session".clone()));
        let r2 = expect_ok(
            session.query_cached(&conn, &upsert_sql, p2).await,
            &"session.query_cached failed".clone(),
        );
        expect_eq_int(r2.affected_rows, 1,
            &"session INSERT affected_rows".clone());

        // -------------------------------------------------------------------
        // 4. Drain.
        // -------------------------------------------------------------------
        let drained = session.drain_cache_on_close(&conn).await;
        expect_eq_int(drained, 1,
            &"drain closed 1 statement".clone());
        expect_eq_int(session.cache_len(), 0,
            &"cache empty after drain".clone());

        let _ = conn.execute(&"DROP TABLE async_prep_smoke".clone()).await;
        let _ = conn.close().await;

        pass(&"t18_async_prepared".clone());
    });
}
