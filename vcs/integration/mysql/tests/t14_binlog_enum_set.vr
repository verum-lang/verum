// =============================================================================
// t14_binlog_enum_set.vr — TABLE_MAP optional metadata + ENUM/SET decoders
// =============================================================================
// Spec: internal/specs/database.md §6.3.7 (binlog row decode), §6.3.7.1
//       (TABLE_MAP optional metadata, MySQL 8.0+ binlog_row_metadata=FULL).
// =============================================================================
//
// V0:
//   * INSERT a row into a table with ENUM + SET columns.
//   * Open binlog stream from earliest GTID.
//   * Drain WRITE_ROWS_V2 → decode_with_table_map.
//   * Assert TABLE_MAP carries column_names + ENUM/SET string
//     tables (binlog_row_metadata=FULL is enabled in
//     docker-compose).
//   * Assert decoded ENUM column == "small" (enum value text)
//     and SET column == "alpha,gamma" (comma-separated bits).
// =============================================================================

mount conn_config.{
    expect, expect_ok, expect_eq_int, pass,
    TEST_HOST, TEST_PORT, TEST_DB, ADMIN_USER, ADMIN_PW,
    connect_app,
};
mount core.database.mysql.{
    MysqlConfig, MtmDisable,
    BinlogConfig, BinlogStream,
    BinlogEvent, BeFormatDescription, BeQuery, BeXid, BeRotate,
    BeGtid, BeHeartbeat, BeOther,
    BeTableMap, BeWriteRows,
    TableMapEvent, TableMapCache, RowsEvent,
    RowValue, RvText, RvInt,
    DecodedRows, DrSimple, DrPairs,
    decode_with_table_map,
    connect_binlog,
};

const SERVER_ID: Int = 16777221;

fn admin_mysql_cfg() -> MysqlConfig {
    MysqlConfig {
        host: TEST_HOST.clone(),
        port: TEST_PORT,
        user: ADMIN_USER.clone(),
        password: ADMIN_PW.clone(),
        database: TEST_DB.clone(),
        character_set: 255,
        tls_mode: MtmDisable,
        connect_timeout_ms: 10_000,
    }
}

fn write_enum_set_row() {
    let mut side = expect_ok(
        connect_app(),
        &"side-channel connect_app() failed".clone(),
    );
    let _ = side.simple_query(
        &"CREATE TABLE IF NOT EXISTS binlog_enum_set_smoke ( \
            id INT PRIMARY KEY, \
            sz ENUM('small','medium','large') NOT NULL, \
            tags SET('alpha','beta','gamma','delta') NOT NULL \
          ) ENGINE=InnoDB".clone()
    );
    let _ = side.simple_query(&"DELETE FROM binlog_enum_set_smoke".clone());
    expect_ok(
        side.simple_query(&
            "INSERT INTO binlog_enum_set_smoke (id, sz, tags) \
             VALUES (1, 'small', 'alpha,gamma')".clone()
        ),
        &"INSERT enum/set row failed".clone(),
    );
}

fn main() {
    write_enum_set_row();

    let bcfg = BinlogConfig.from_gtid(SERVER_ID, "".clone());
    let mut stream = expect_ok(
        connect_binlog(&admin_mysql_cfg(), bcfg),
        &"connect_binlog failed".clone(),
    );

    let mut cache = TableMapCache.new();
    let mut decoded_enum: Maybe<Text> = None;
    let mut decoded_set: Maybe<Text> = None;
    let mut saw_column_names: Bool = false;
    let mut saw_enum_table: Bool = false;
    let mut saw_set_table: Bool = false;
    let mut i: Int = 0;
    while i < 200 {
        let r = expect_ok(
            stream.next_event(),
            &f"next_event #{i} failed",
        );
        match r {
            Some(ev) => {
                match ev {
                    BeTableMap { body: tm, .. } => {
                        if &tm.name == &"binlog_enum_set_smoke".clone() {
                            // Optional metadata sanity checks.
                            if (tm.column_names.len() as Int) >= 3 {
                                if &tm.column_names[0] == &"id".clone() {
                                    saw_column_names = true;
                                }
                            }
                            // ENUM column is index 1; SET is index 2.
                            if (tm.enum_values.len() as Int) > 1 {
                                if (tm.enum_values[1].len() as Int) == 3 {
                                    saw_enum_table = true;
                                }
                            }
                            if (tm.set_values.len() as Int) > 2 {
                                if (tm.set_values[2].len() as Int) == 4 {
                                    saw_set_table = true;
                                }
                            }
                        }
                        cache.record(tm);
                    }
                    BeWriteRows { body: rev, .. } => {
                        match cache.lookup(rev.table_id) {
                            Some(tm) => {
                                if &tm.name == &"binlog_enum_set_smoke".clone() {
                                    let dr = expect_ok(
                                        decode_with_table_map(&rev, tm),
                                        &"decode_with_table_map failed".clone(),
                                    );
                                    match dr {
                                        DrSimple(rows) => {
                                            if rows.len() > 0 {
                                                let row = &rows[0];
                                                if row.columns.len() >= 3 {
                                                    match &row.columns[1] {
                                                        RvText(s) => { decoded_enum = Some(s.clone()); }
                                                        _ => {}
                                                    }
                                                    match &row.columns[2] {
                                                        RvText(s) => { decoded_set = Some(s.clone()); }
                                                        _ => {}
                                                    }
                                                }
                                            }
                                        }
                                        DrPairs(_) => {}
                                    }
                                }
                            }
                            None => {}
                        }
                    }
                    BeFormatDescription { .. } | BeQuery { .. } | BeXid { .. }
                    | BeGtid { .. } | BeRotate { .. } | BeHeartbeat { .. }
                    | BeOther { .. } => {}
                }
                if decoded_enum.is_some() && decoded_set.is_some() { break; }
            }
            None => { break; }
        }
        i = i + 1;
    }

    expect(saw_column_names, &"TABLE_MAP COLUMN_NAME metadata missing".clone());
    expect(saw_enum_table,   &"TABLE_MAP ENUM_STR_VALUE metadata missing".clone());
    expect(saw_set_table,    &"TABLE_MAP SET_STR_VALUE metadata missing".clone());

    let enum_text = expect_ok(
        decoded_enum.ok_or(core.database.common.error.DbError.Adapter(
            core.database.common.error.AdapterSpecific {
                adapter: core.database.common.error.AdMysql,
                code: "TEST".clone(),
                message: "no ENUM value decoded".clone(),
                retryable: false,
            }
        )),
        &"ENUM decoded".clone(),
    );
    expect(
        &enum_text == &"small".clone(),
        &f"ENUM value: expected 'small', got '{enum_text}'",
    );

    let set_text = expect_ok(
        decoded_set.ok_or(core.database.common.error.DbError.Adapter(
            core.database.common.error.AdapterSpecific {
                adapter: core.database.common.error.AdMysql,
                code: "TEST".clone(),
                message: "no SET value decoded".clone(),
                retryable: false,
            }
        )),
        &"SET decoded".clone(),
    );
    expect(
        &set_text == &"alpha,gamma".clone(),
        &f"SET value: expected 'alpha,gamma', got '{set_text}'",
    );

    let _ = stream.close();

    pass(&"t14_binlog_enum_set".clone());
}
