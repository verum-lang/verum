// =============================================================================
// t02_simple_query.vr — text-protocol round-trip against live MySQL
// =============================================================================
// Spec: internal/specs/database.md §6.3.3 (COM_QUERY text resultset).
// =============================================================================
//
// Exercises the text-protocol path that every other test depends
// on. After this passes, follow-up tests can rely on
// `simple_query` for setup / teardown DDL.
//
// Scenarios:
//   1. SELECT-class — multiple rows, multiple columns; verify
//      column metadata + row count.
//   2. INSERT-class — `affected_rows` reflects 1.
//   3. UPDATE — `affected_rows` reflects 1.
//   4. Empty result — `SELECT … WHERE id = -1` returns 0 rows
//      cleanly.
//   5. DELETE — clean up; `affected_rows` reflects 1.
// =============================================================================

mount conn_config.{
    connect_app, expect, expect_ok, expect_eq_int, pass,
};

fn main() {
    let mut conn = expect_ok(
        connect_app(),
        &"connect_app() failed".clone(),
    );

    // -------------------------------------------------------------------------
    // 1. SELECT — pull 5 rows from a generated table-valued query.
    // MySQL has no generate_series; we emulate via UNION ALL.
    // -------------------------------------------------------------------------
    let r1 = expect_ok(
        conn.simple_query(&
            "SELECT n AS num, n * 10 AS scaled FROM (\
              SELECT 1 AS n UNION ALL SELECT 2 UNION ALL SELECT 3 \
              UNION ALL SELECT 4 UNION ALL SELECT 5\
            ) t".clone()
        ),
        &"SELECT UNION ALL failed".clone(),
    );
    expect_eq_int(r1.rows.len() as Int, 5, &"SELECT row count".clone());
    expect_eq_int(r1.columns.len() as Int, 2, &"SELECT col count".clone());

    // -------------------------------------------------------------------------
    // 2. INSERT — clean a known table, insert a row.
    // -------------------------------------------------------------------------
    let _ = conn.simple_query(&"DELETE FROM accounts".clone());
    let r2 = expect_ok(
        conn.simple_query(&
            "INSERT INTO accounts (email, age, balance) VALUES ('a@b.co', 30, 100.0)"
                .clone()
        ),
        &"INSERT failed".clone(),
    );
    expect_eq_int(r2.affected_rows, 1, &"INSERT affected_rows".clone());
    expect(
        r2.last_insert_id > 0,
        &"INSERT last_insert_id should be > 0 for AUTO_INCREMENT".clone(),
    );

    // -------------------------------------------------------------------------
    // 3. UPDATE — touch the row.
    // -------------------------------------------------------------------------
    let r3 = expect_ok(
        conn.simple_query(&
            "UPDATE accounts SET age = 31 WHERE email = 'a@b.co'".clone()
        ),
        &"UPDATE failed".clone(),
    );
    expect_eq_int(r3.affected_rows, 1, &"UPDATE affected_rows".clone());

    // -------------------------------------------------------------------------
    // 4. SELECT WHERE FALSE — empty result, no error.
    // -------------------------------------------------------------------------
    let r4 = expect_ok(
        conn.simple_query(&
            "SELECT id FROM accounts WHERE id = -1".clone()
        ),
        &"empty SELECT failed".clone(),
    );
    expect_eq_int(r4.rows.len() as Int, 0, &"empty result row count".clone());

    // -------------------------------------------------------------------------
    // 5. DELETE — clean up; affected_rows == 1.
    // -------------------------------------------------------------------------
    let r5 = expect_ok(
        conn.simple_query(&
            "DELETE FROM accounts WHERE email = 'a@b.co'".clone()
        ),
        &"DELETE failed".clone(),
    );
    expect_eq_int(r5.affected_rows, 1, &"DELETE affected_rows".clone());

    pass(&"t02_simple_query".clone());
}
