// =============================================================================
// t06_pool.vr — pool acquire/release accounting
// =============================================================================
// Spec: internal/specs/database.md §4.3 (pool), §4.2 (arena reset).
// =============================================================================
//
// Single-threaded for v1 — concurrency-fan-out variant lands once
// the test runner pipes core.async.spawn through.
//
// Asserts:
//   1. Pool launches with min=2 connections eagerly opened.
//   2. 20 sequential acquire/release cycles succeed.
//   3. total_arena_resets bumps per healthy release (≥20).
//   4. Pool drains cleanly without leaked connections.
// =============================================================================

mount conn_config.{
    expect, expect_ok, expect_eq_int, pass,
    TEST_HOST, TEST_PORT, TEST_DB, APP_USER, APP_PW,
};
mount core.database.mysql.{
    MysqlConfig, MysqlPool, MtmDisable,
};
mount core.database.common.pool_impl.{PoolConfig};
mount core.database.common.error.{AdMysql};

fn main() {
    let cfg = MysqlConfig {
        host: TEST_HOST.clone(),
        port: TEST_PORT,
        user: APP_USER.clone(),
        password: APP_PW.clone(),
        database: TEST_DB.clone(),
        character_set: 255,
        tls_mode: MtmDisable,
        connect_timeout_ms: 10_000,
    };
    let pool_cfg = PoolConfig.default(AdMysql)
        .with_min(2)
        .with_max(8)
        .with_acquire_timeout_ms(5_000);

    let pool = expect_ok(
        MysqlPool.launch(cfg, pool_cfg),
        &"pool launch failed".clone(),
    );

    let s0 = pool.stats();
    expect(
        s0.idle >= 2,
        &f"expected ≥2 idle after launch, got {s0.idle}",
    );

    let mut i: Int = 0;
    while i < 20 {
        let mut handle = expect_ok(
            pool.acquire(),
            &f"acquire iteration {i} failed",
        );
        let _ = expect_ok(
            handle.conn_mut().simple_query(&"SELECT 1".clone()),
            &f"SELECT 1 on iteration {i} failed",
        );
        handle.release_healthy();
        i = i + 1;
    }

    let s1 = pool.stats();
    expect(
        s1.total_acquired >= 20,
        &f"total_acquired = {s1.total_acquired}, expected ≥20",
    );
    expect(
        s1.total_arena_resets >= 20,
        &f"total_arena_resets = {s1.total_arena_resets}, expected ≥20".to_owned(),
    );
    expect_eq_int(
        s1.total_timeouts,
        0,
        &"no acquires should have timed out".clone(),
    );

    expect_ok(
        pool.drain(5_000),
        &"pool drain failed".clone(),
    );

    pass(&"t06_pool".clone());
}
