// =============================================================================
// t19_typed_prepared.vr — typed prepared-row decoder + MysqlTypedRow
// =============================================================================
// Spec: internal/specs/database.md §6.3.4 (binary protocol prepared cache).
// =============================================================================
//
// V0:
//   1. INSERT a row with INT + TEXT + BIGINT cells.
//   2. PREPARE + EXECUTE a SELECT pulling those columns back.
//   3. typed_prepared_rows decodes raw cell bytes into List<List<RowValue>>.
//   4. rows_typed_my::<(Int, Text, Int)> lifts each row into the typed
//      tuple shape; assert exact values round-trip.
// =============================================================================

mount conn_config.{
    expect, expect_ok, expect_eq_int, pass,
    TEST_HOST, TEST_PORT, TEST_DB, APP_USER, APP_PW,
};
mount core.database.mysql.{
    MysqlConfig, MtmDisable,
    AsyncMysqlConnection, AsyncMysqlPreparedStatement,
    AsyncMysqlPreparedSession,
    async_mysql_connect,
    StmtParam, param_int, param_text,
    typed_prepared_row, typed_prepared_rows,
    MysqlTypedRow, rows_typed_my,
    DecodedRow,
    RowValue, RvNull, RvInt, RvText,
};
mount core.async.executor.block_on;

fn main() {
    block_on(async move {
        let cfg = MysqlConfig {
            host: TEST_HOST.clone(),
            port: TEST_PORT,
            user: APP_USER.clone(),
            password: APP_PW.clone(),
            database: TEST_DB.clone(),
            character_set: 255,
            tls_mode: MtmDisable,
            connect_timeout_ms: 10_000,
        };
        let conn = expect_ok(
            async_mysql_connect(&cfg, 8).await,
            &"async_mysql_connect failed".clone(),
        );

        // Setup table.
        let _ = conn.execute(&"DROP TABLE IF EXISTS typed_prep_smoke".clone()).await;
        expect_ok(
            conn.execute(&
                "CREATE TABLE typed_prep_smoke ( \
                    id INT PRIMARY KEY, \
                    payload VARCHAR(255) NOT NULL, \
                    big BIGINT NOT NULL \
                 ) ENGINE=InnoDB".clone()
            ).await,
            &"CREATE TABLE failed".clone(),
        );

        // Insert via simple_query so we don't need typed-params here.
        let _ = expect_ok(
            conn.simple_query(&
                "INSERT INTO typed_prep_smoke (id, payload, big) VALUES \
                 (1, 'first', 1000000000), \
                 (2, 'second', 2000000000)".clone()
            ).await,
            &"INSERT failed".clone(),
        );

        // -------------------------------------------------------------------
        // Prepare + execute a SELECT.
        // -------------------------------------------------------------------
        let stmt = expect_ok(
            conn.prepare(&"SELECT id, payload, big FROM typed_prep_smoke ORDER BY id".clone()).await,
            &"prepare SELECT failed".clone(),
        );
        let no_params: List<StmtParam> = List.new();
        let result = expect_ok(
            conn.execute_prepared(&stmt, no_params).await,
            &"execute_prepared failed".clone(),
        );
        expect_eq_int(result.rows.len() as Int, 2,
            &"prepared SELECT row count".clone());

        // -------------------------------------------------------------------
        // typed_prepared_rows lifts raw bytes → List<List<RowValue>>.
        // -------------------------------------------------------------------
        let rv_rows = expect_ok(
            typed_prepared_rows(&result, stmt.inner()),
            &"typed_prepared_rows failed".clone(),
        );
        expect_eq_int(rv_rows.len() as Int, 2,
            &"typed rows count".clone());
        expect_eq_int(rv_rows[0].len() as Int, 3,
            &"typed row arity".clone());

        // Spot-check first row's values via the RowValue ADT.
        match &rv_rows[0][0] {
            RvInt(n) => expect_eq_int(*n, 1, &"row[0].id".clone()),
            _ => expect(false, &"row[0].id not RvInt".clone()),
        }
        match &rv_rows[0][1] {
            RvText(s) => expect_eq_int(s.len() as Int, 5, &"row[0].payload len".clone()),
            _ => expect(false, &"row[0].payload not RvText".clone()),
        }
        match &rv_rows[0][2] {
            RvInt(n) => expect_eq_int(*n, 1000000000, &"row[0].big".clone()),
            _ => expect(false, &"row[0].big not RvInt".clone()),
        }

        // -------------------------------------------------------------------
        // MysqlTypedRow tuple lift: (Int, Text, Int).
        // -------------------------------------------------------------------
        let mut decoded: List<DecodedRow> = List.with_capacity(rv_rows.len());
        let mut k: Int = 0;
        while k < (rv_rows.len() as Int) {
            decoded.push(DecodedRow { columns: rv_rows[k].clone() });
            k = k + 1;
        }
        let lifted: List<(Int, Text, Int)> = expect_ok(
            rows_typed_my::<(Int, Text, Int)>(&decoded),
            &"rows_typed_my::<(Int, Text, Int)> failed".clone(),
        );
        expect_eq_int(lifted.len() as Int, 2, &"lifted len".clone());

        let r0 = &lifted[0];
        expect_eq_int(r0.0, 1, &"lifted[0].id".clone());
        expect(&r0.1 == &"first".clone(), &"lifted[0].payload".clone());
        expect_eq_int(r0.2, 1000000000, &"lifted[0].big".clone());

        let r1 = &lifted[1];
        expect_eq_int(r1.0, 2, &"lifted[1].id".clone());
        expect(&r1.1 == &"second".clone(), &"lifted[1].payload".clone());
        expect_eq_int(r1.2, 2000000000, &"lifted[1].big".clone());

        let _ = conn.close_prepared(stmt).await;
        let _ = conn.execute(&"DROP TABLE typed_prep_smoke".clone()).await;
        let _ = conn.close().await;

        pass(&"t19_typed_prepared".clone());
    });
}
