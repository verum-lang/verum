// =============================================================================
// t16_binlog_geometry.vr — WKB → GeoJSON decoder for binlog GEOMETRY columns
// =============================================================================
// Spec: internal/specs/database.md §6.3.7 (binlog row / GEOMETRY).
// =============================================================================
//
// V0:
//   * INSERT a row with a POINT(1 2) GEOMETRY column.
//   * Drain binlog → decode_with_table_map → assert column 1
//     arrives as RvText carrying GeoJSON
//     `{"type":"Point","coordinates":[1,2]}` (substring scan
//     because float formatting may vary across runtimes).
// =============================================================================

mount conn_config.{
    expect, expect_ok, expect_eq_int, pass,
    TEST_HOST, TEST_PORT, TEST_DB, ADMIN_USER, ADMIN_PW,
    connect_app,
};
mount core.database.mysql.{
    MysqlConfig, MtmDisable,
    BinlogConfig, BinlogStream,
    BinlogEvent, BeFormatDescription, BeQuery, BeXid, BeRotate,
    BeGtid, BeHeartbeat, BeOther,
    BeTableMap, BeWriteRows,
    TableMapEvent, TableMapCache, RowsEvent,
    RowValue, RvText,
    DecodedRows, DrSimple, DrPairs,
    decode_with_table_map,
    connect_binlog,
};

const SERVER_ID: Int = 16777222;

fn admin_mysql_cfg() -> MysqlConfig {
    MysqlConfig {
        host: TEST_HOST.clone(),
        port: TEST_PORT,
        user: ADMIN_USER.clone(),
        password: ADMIN_PW.clone(),
        database: TEST_DB.clone(),
        character_set: 255,
        tls_mode: MtmDisable,
        connect_timeout_ms: 10_000,
    }
}

fn write_geometry_row() {
    let mut side = expect_ok(
        connect_app(),
        &"side-channel connect_app() failed".clone(),
    );
    let _ = side.simple_query(
        &"CREATE TABLE IF NOT EXISTS binlog_geo_smoke ( \
            id INT PRIMARY KEY, \
            shape GEOMETRY NOT NULL \
          ) ENGINE=InnoDB".clone()
    );
    let _ = side.simple_query(&"DELETE FROM binlog_geo_smoke".clone());
    expect_ok(
        side.simple_query(&
            "INSERT INTO binlog_geo_smoke (id, shape) VALUES \
             (1, ST_GeomFromText('POINT(1 2)'))".clone()
        ),
        &"INSERT geometry row failed".clone(),
    );
}

fn text_contains(haystack: &Text, needle: &str) -> Bool {
    let h = haystack.as_bytes();
    let n_text = needle.as_bytes();
    let hlen = h.len() as Int;
    let nlen = n_text.len() as Int;
    if nlen == 0 { return true; }
    if nlen > hlen { return false; }
    let mut i: Int = 0;
    while i <= hlen - nlen {
        let mut match_ok: Bool = true;
        let mut k: Int = 0;
        while k < nlen {
            if h[i + k] != n_text[k] { match_ok = false; break; }
            k = k + 1;
        }
        if match_ok { return true; }
        i = i + 1;
    }
    false
}

fn main() {
    write_geometry_row();

    let bcfg = BinlogConfig.from_gtid(SERVER_ID, "".clone());
    let mut stream = expect_ok(
        connect_binlog(&admin_mysql_cfg(), bcfg),
        &"connect_binlog failed".clone(),
    );

    let mut cache = TableMapCache.new();
    let mut decoded_geo: Maybe<Text> = None;
    let mut i: Int = 0;
    while i < 200 {
        let r = expect_ok(
            stream.next_event(),
            &f"next_event #{i} failed",
        );
        match r {
            Some(ev) => {
                match ev {
                    BeTableMap { body: tm, .. } => { cache.record(tm); }
                    BeWriteRows { body: rev, .. } => {
                        match cache.lookup(rev.table_id) {
                            Some(tm) => {
                                if &tm.name == &"binlog_geo_smoke".clone() {
                                    let dr = expect_ok(
                                        decode_with_table_map(&rev, tm),
                                        &"decode_with_table_map failed".clone(),
                                    );
                                    match dr {
                                        DrSimple(rows) => {
                                            if rows.len() > 0 {
                                                let row = &rows[0];
                                                if row.columns.len() >= 2 {
                                                    match &row.columns[1] {
                                                        RvText(s) => {
                                                            decoded_geo = Some(s.clone());
                                                        }
                                                        _ => {
                                                            expect(false,
                                                                &"col[1] not RvText (geo decode failed)".clone());
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                        DrPairs(_) => {}
                                    }
                                }
                            }
                            None => {}
                        }
                    }
                    BeFormatDescription { .. } | BeQuery { .. } | BeXid { .. }
                    | BeGtid { .. } | BeRotate { .. } | BeHeartbeat { .. }
                    | BeOther { .. } => {}
                }
                if decoded_geo.is_some() { break; }
            }
            None => { break; }
        }
        i = i + 1;
    }

    let geo_text = expect_ok(
        decoded_geo.ok_or(core.database.common.error.DbError.Adapter(
            core.database.common.error.AdapterSpecific {
                adapter: core.database.common.error.AdMysql,
                code: "TEST".clone(),
                message: "no GEOMETRY value decoded".clone(),
                retryable: false,
            }
        )),
        &"GEOMETRY decoded".clone(),
    );

    // Substring checks — float formatting may differ across
    // runtimes ("1" vs "1.0") so we look for the canonical
    // structural tokens.
    expect(text_contains(&geo_text, "\"type\""),
        &"GeoJSON has key \"type\"".clone());
    expect(text_contains(&geo_text, "\"Point\""),
        &"GeoJSON Point type".clone());
    expect(text_contains(&geo_text, "\"coordinates\""),
        &"GeoJSON has key \"coordinates\"".clone());

    let _ = stream.close();

    pass(&"t16_binlog_geometry".clone());
}
