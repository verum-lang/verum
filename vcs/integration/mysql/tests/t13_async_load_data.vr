// =============================================================================
// t13_async_load_data.vr — async LOAD DATA LOCAL INFILE V0
// =============================================================================
// Spec: internal/specs/database.md §6.3.6 (async surface),
//       §6.3.8 (LOAD DATA LOCAL INFILE).
// =============================================================================
//
// V0:
//   1. AsyncMysqlConnection.execute creates / clears a target table.
//   2. load_data_local_async opens the streaming session
//      (LOAD DATA LOCAL INFILE 'spindle.tsv' INTO TABLE …
//       FIELDS TERMINATED BY '\t' LINES TERMINATED BY '\n').
//   3. Writer streams 1000 TSV-formatted rows in 10 chunks of 100.
//   4. .finish().await returns affected_rows == 1000.
//   5. Round-trip SELECT count(*) confirms persistence.
// =============================================================================

mount conn_config.{
    expect, expect_ok, expect_eq_int, pass,
    TEST_HOST, TEST_PORT, TEST_DB, APP_USER, APP_PW,
};
mount core.database.mysql.{
    MysqlConfig, MtmDisable,
    AsyncMysqlConnection,
    async_mysql_connect,
    AsyncMysqlInfileWriter,
    load_data_local_async,
};
mount core.async.executor.block_on;

const N_ROWS: Int = 1000;
const ROWS_PER_CHUNK: Int = 100;

fn main() {
    block_on(async move {
        let cfg = MysqlConfig {
            host: TEST_HOST.clone(),
            port: TEST_PORT,
            user: APP_USER.clone(),
            password: APP_PW.clone(),
            database: TEST_DB.clone(),
            character_set: 255,
            tls_mode: MtmDisable,
            connect_timeout_ms: 10_000,
        };
        let conn = expect_ok(
            async_mysql_connect(&cfg, 8).await,
            &"async_mysql_connect failed".clone(),
        );

        let _ = conn.execute(&"DROP TABLE IF EXISTS async_load_smoke".clone()).await;
        expect_ok(
            conn.execute(&
                "CREATE TABLE async_load_smoke ( \
                    id INT PRIMARY KEY, \
                    payload VARCHAR(255) NOT NULL \
                 ) ENGINE=InnoDB".clone()
            ).await,
            &"CREATE TABLE failed".clone(),
        );

        let writer = expect_ok(
            load_data_local_async(
                &conn,
                &"LOAD DATA LOCAL INFILE 'spindle.tsv' INTO TABLE async_load_smoke \
                  FIELDS TERMINATED BY '\\t' LINES TERMINATED BY '\\n' \
                  (id, payload)".clone(),
                4,
            ).await,
            &"load_data_local_async failed".clone(),
        );

        let mut row_id: Int = 0;
        let mut chunk_idx: Int = 0;
        while chunk_idx < (N_ROWS / ROWS_PER_CHUNK) {
            let mut buf: List<Byte> = List.with_capacity(ROWS_PER_CHUNK * 32);
            let mut k: Int = 0;
            while k < ROWS_PER_CHUNK {
                let row_text = f"{row_id}\tpayload-{row_id}\n";
                let bytes = row_text.as_bytes();
                let mut i: Int = 0;
                while i < (bytes.len() as Int) {
                    buf.push(bytes[i]);
                    i = i + 1;
                }
                row_id = row_id + 1;
                k = k + 1;
            }
            expect_ok(
                writer.write(buf).await,
                &f"writer.write chunk {chunk_idx} failed",
            );
            chunk_idx = chunk_idx + 1;
        }

        let written = expect_ok(
            writer.finish().await,
            &"writer.finish failed".clone(),
        );
        expect_eq_int(written, N_ROWS, &"LOAD DATA affected_rows".clone());

        // Verify persistence via simple SELECT count(*).
        let cnt = expect_ok(
            conn.simple_query(&"SELECT COUNT(*) FROM async_load_smoke".clone()).await,
            &"COUNT(*) failed".clone(),
        );
        expect_eq_int(cnt.rows.len() as Int, 1, &"COUNT(*) row count".clone());

        let _ = conn.execute(&"DROP TABLE async_load_smoke".clone()).await;
        let _ = conn.close().await;

        pass(&"t13_async_load_data".clone());
    });
}
