// =============================================================================
// t11_typed_row.vr — MysqlTypedRow + NEWDECIMAL binlog row decode
// =============================================================================
// Spec: internal/specs/database.md §6.3.7 (binlog row decode / typed lift).
// =============================================================================
//
// V0 covers two pieces in one round trip:
//   1. NEWDECIMAL decoder produces canonical "1234.5678" Text.
//   2. MysqlTypedRow lifts each DecodedRow into a typed tuple
//      (Int, Text, Text) — id / payload / decimal as canonical text.
//
// Steps:
//   * INSERT 2 rows on side-channel into a table with INT PK +
//     VARCHAR + DECIMAL(12, 4).
//   * Open binlog stream from earliest GTID.
//   * Cache TABLE_MAP for the affected table.
//   * On WRITE_ROWS_V2, decode_with_table_map → DrSimple(rows).
//   * Lift via rows_typed_my::<(Int, Text, Text)>.
//   * Assert tuple values.
// =============================================================================

mount conn_config.{
    expect, expect_ok, expect_eq_int, pass,
    TEST_HOST, TEST_PORT, TEST_DB, ADMIN_USER, ADMIN_PW,
    connect_app,
};
mount core.database.mysql.{
    MysqlConfig, MtmDisable,
    BinlogConfig, BinlogStream,
    BinlogEvent, BeFormatDescription, BeQuery, BeXid, BeRotate,
    BeGtid, BeHeartbeat, BeOther,
    BeTableMap, BeWriteRows,
    TableMapEvent, TableMapCache, RowsEvent,
    RowValue, RvInt, RvText,
    DecodedRows, DrSimple, DrPairs,
    decode_with_table_map,
    connect_binlog,
    MysqlTypedRow, rows_typed_my,
};

const SERVER_ID: Int = 16777219;

fn admin_mysql_cfg() -> MysqlConfig {
    MysqlConfig {
        host: TEST_HOST.clone(),
        port: TEST_PORT,
        user: ADMIN_USER.clone(),
        password: ADMIN_PW.clone(),
        database: TEST_DB.clone(),
        character_set: 255,
        tls_mode: MtmDisable,
        connect_timeout_ms: 10_000,
    }
}

fn write_rows_on_side_channel() {
    let mut side = expect_ok(
        connect_app(),
        &"side-channel connect_app() failed".clone(),
    );
    let _ = side.simple_query(
        &"CREATE TABLE IF NOT EXISTS binlog_typed_smoke ( \
            id INT PRIMARY KEY, \
            payload VARCHAR(255) NOT NULL, \
            amount DECIMAL(12, 4) NOT NULL \
          ) ENGINE=InnoDB".clone()
    );
    let _ = side.simple_query(&"DELETE FROM binlog_typed_smoke".clone());
    let _ = expect_ok(
        side.simple_query(&
            "INSERT INTO binlog_typed_smoke (id, payload, amount) \
             VALUES (1, 'first', '1234.5678')".clone()
        ),
        &"side-channel INSERT 1 failed".clone(),
    );
    let _ = expect_ok(
        side.simple_query(&
            "INSERT INTO binlog_typed_smoke (id, payload, amount) \
             VALUES (2, 'second', '-9.0001')".clone()
        ),
        &"side-channel INSERT 2 failed".clone(),
    );
}

fn main() {
    write_rows_on_side_channel();

    let bcfg = BinlogConfig.from_gtid(SERVER_ID, "".clone());
    let mut stream = expect_ok(
        connect_binlog(&admin_mysql_cfg(), bcfg),
        &"connect_binlog failed".clone(),
    );

    let mut cache = TableMapCache.new();
    let mut typed_results: List<(Int, Text, Text)> = List.new();
    let mut i: Int = 0;
    while i < 200 {
        let r = expect_ok(
            stream.next_event(),
            &f"next_event #{i} failed",
        );
        match r {
            Some(ev) => {
                match ev {
                    BeTableMap { body: tm, .. } => {
                        cache.record(tm);
                    }
                    BeWriteRows { body: rev, .. } => {
                        match cache.lookup(rev.table_id) {
                            Some(tm) => {
                                if &tm.name == &"binlog_typed_smoke".clone() {
                                    let dr = expect_ok(
                                        decode_with_table_map(&rev, tm),
                                        &"decode_with_table_map failed".clone(),
                                    );
                                    match dr {
                                        DrSimple(rows) => {
                                            // Lift each row into (Int, Text, Text).
                                            let lifted = expect_ok(
                                                rows_typed_my::<(Int, Text, Text)>(&rows),
                                                &"rows_typed_my failed".clone(),
                                            );
                                            let mut k: Int = 0;
                                            while k < (lifted.len() as Int) {
                                                typed_results.push(lifted[k].clone());
                                                k = k + 1;
                                            }
                                        }
                                        DrPairs(_) => {}
                                    }
                                }
                            }
                            None => {}
                        }
                    }
                    BeFormatDescription { .. } | BeQuery { .. } | BeXid { .. }
                    | BeGtid { .. } | BeRotate { .. } | BeHeartbeat { .. }
                    | BeOther { .. } => {}
                }
                if (typed_results.len() as Int) >= 2 { break; }
            }
            None => { break; }
        }
        i = i + 1;
    }

    expect_eq_int(
        typed_results.len() as Int, 2,
        &f"expected 2 typed rows, got {typed_results.len() as Int}",
    );

    // Row 1: (1, "first", "1234.5678")
    let r0 = &typed_results[0];
    expect_eq_int(r0.0, 1, &"row[0].id".clone());
    expect_eq_int(r0.1.len() as Int, 5, &"row[0].payload length".clone());
    expect(
        &r0.2 == &"1234.5678".clone(),
        &f"row[0].amount: expected 1234.5678, got {r0.2}",
    );

    // Row 2: (2, "second", "-9.0001")
    let r1 = &typed_results[1];
    expect_eq_int(r1.0, 2, &"row[1].id".clone());
    expect_eq_int(r1.1.len() as Int, 6, &"row[1].payload length".clone());
    expect(
        &r1.2 == &"-9.0001".clone(),
        &f"row[1].amount: expected -9.0001, got {r1.2}",
    );

    let _ = stream.close();

    pass(&"t11_typed_row".clone());
}
