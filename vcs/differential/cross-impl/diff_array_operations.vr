// @test: differential
// @tier: 0,1
// @level: L0
// @tags: differential, array, indexing
// @timeout: 10000
// @expected-exit: 0
// @description: Array operations: literal creation, indexing, mutation, search

fn linear_search(arr: List<Int>, target: Int) -> Int {
    let mut i = 0;
    while i < arr.len() {
        if arr[i] == target {
            return i;
        }
        i = i + 1;
    }
    -1
}

fn reverse_list(arr: List<Int>) -> List<Int> {
    let mut result = List.new();
    let mut i = arr.len();
    while i > 0 {
        i = i - 1;
        result.push(arr[i]);
    }
    result
}

fn main() -> Int {
    // Array literal
    let nums = [10, 20, 30, 40, 50];
    assert_eq(nums[0], 10);
    assert_eq(nums[4], 50);

    // Build and mutate
    let mut arr = List.new();
    let mut i = 0;
    while i < 10 {
        arr.push(i * 10);
        i = i + 1;
    }
    assert_eq(arr.len(), 10);
    assert_eq(arr[0], 0);
    assert_eq(arr[5], 50);
    assert_eq(arr[9], 90);

    // Mutate element
    arr[3] = 999;
    assert_eq(arr[3], 999);

    // Search
    assert_eq(linear_search(arr, 999), 3);
    assert_eq(linear_search(arr, 50), 5);
    assert_eq(linear_search(arr, 42), -1);

    // Reverse
    let mut small = List.new();
    small.push(1);
    small.push(2);
    small.push(3);
    small.push(4);
    small.push(5);
    let rev = reverse_list(small);
    assert_eq(rev[0], 5);
    assert_eq(rev[1], 4);
    assert_eq(rev[2], 3);
    assert_eq(rev[3], 2);
    assert_eq(rev[4], 1);

    // Sum via index
    let mut total = 0;
    let mut j = 0;
    while j < rev.len() {
        total = total + rev[j];
        j = j + 1;
    }
    assert_eq(total, 15);

    print("diff_array_operations: ok");
    0
}
