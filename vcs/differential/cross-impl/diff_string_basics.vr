// @test: differential

// @tier: 0,1
// @level: L0
// @tags: differential, text, string, format
// @timeout: 10000
// @expected-exit: 0
// @description: Text operations: concatenation, f-strings, comparison, empty strings

fn main() -> Int {
    // Literals
    let hello = "Hello";
    let world = "World";
    assert_eq(hello, "Hello");

    // Concatenation
    let combined = hello + ", " + world + "!";
    assert_eq(combined, "Hello, World!");

    // Empty string
    let empty = "";
    assert_eq(empty, "");
    assert_eq("abc" + "" + "def", "abcdef");

    // Format strings
    let x = 42;
    assert_eq(f"x={x}", "x=42");

    let a = 10;
    let b = 20;
    assert_eq(f"{a}+{b}={a+b}", "10+20=30");

    // Negative in f-string
    let neg = -7;
    assert_eq(f"n={neg}", "n=-7");

    // Build string in loop
    let mut s = "";
    let mut i = 0;
    while i < 5 {
        s = s + f"{i}";
        i = i + 1;
    }
    assert_eq(s, "01234");

    // Multi-expression format
    let p = 3;
    let q = 4;
    assert_eq(f"{p}*{q}={p*q}", "3*4=12");

    print("diff_string_basics: ok");
    0
}
