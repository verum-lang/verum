// @test: differential

// @tier: 0,1
// @level: L0
// @tags: differential, functions, call
// @timeout: 10000
// @expected-exit: 0
// @description: Function calls: parameters, return values, multiple args, early return

fn add(a: Int, b: Int) -> Int {
    a + b
}

fn multiply(a: Int, b: Int) -> Int {
    a * b
}

fn power(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < exp {
        result = result * base;
        i = i + 1;
    }
    result
}

fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y > 0 {
        let tmp = y;
        y = x % y;
        x = tmp;
    }
    x
}

fn is_prime(n: Int) -> Bool {
    if n < 2 { return false; }
    if n < 4 { return true; }
    if n % 2 == 0 { return false; }
    let mut d = 3;
    while d * d <= n {
        if n % d == 0 { return false; }
        d = d + 2;
    }
    true
}

fn main() -> Int {
    assert_eq(add(3, 4), 7);
    assert_eq(add(-10, 10), 0);
    assert_eq(multiply(6, 7), 42);
    assert_eq(multiply(0, 999), 0);

    assert_eq(power(2, 10), 1024);
    assert_eq(power(3, 5), 243);
    assert_eq(power(10, 0), 1);

    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(252, 105), 21);
    assert_eq(gcd(100, 1), 1);

    assert_eq(is_prime(2), true);
    assert_eq(is_prime(3), true);
    assert_eq(is_prime(4), false);
    assert_eq(is_prime(17), true);
    assert_eq(is_prime(49), false);
    assert_eq(is_prime(97), true);

    // Count primes up to 50
    let mut prime_count = 0;
    let mut n = 2;
    while n <= 50 {
        if is_prime(n) {
            prime_count = prime_count + 1;
        }
        n = n + 1;
    }
    assert_eq(prime_count, 15);

    print("diff_functions_basic: ok");
    0
}
