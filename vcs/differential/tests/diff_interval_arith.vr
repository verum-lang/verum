// @test: differential

// @level: L0
// @tags: differential, interval, arithmetic
// @timeout: 30000

// Interval arithmetic: operations on [lo, hi] intervals

type Ivl is { lo: Int, hi: Int };

fn ivl_add(a: Ivl, b: Ivl) -> Ivl {
    Ivl { lo: a.lo + b.lo, hi: a.hi + b.hi }
}

fn ivl_sub(a: Ivl, b: Ivl) -> Ivl {
    Ivl { lo: a.lo - b.hi, hi: a.hi - b.lo }
}

fn min4(a: Int, b: Int, c: Int, d: Int) -> Int {
    let mut m = a;
    if b < m { m = b; }
    if c < m { m = c; }
    if d < m { m = d; }
    m
}

fn max4(a: Int, b: Int, c: Int, d: Int) -> Int {
    let mut m = a;
    if b > m { m = b; }
    if c > m { m = c; }
    if d > m { m = d; }
    m
}

fn ivl_mul(a: Ivl, b: Ivl) -> Ivl {
    let p1 = a.lo * b.lo;
    let p2 = a.lo * b.hi;
    let p3 = a.hi * b.lo;
    let p4 = a.hi * b.hi;
    Ivl { lo: min4(p1, p2, p3, p4), hi: max4(p1, p2, p3, p4) }
}

fn ivl_contains(a: Ivl, x: Int) -> Int {
    if x >= a.lo {
        if x <= a.hi { 1 } else { 0 }
    } else { 0 }
}

fn ivl_width(a: Ivl) -> Int { a.hi - a.lo }

fn ivl_overlaps(a: Ivl, b: Ivl) -> Int {
    if a.hi < b.lo { 0 }
    else if b.hi < a.lo { 0 }
    else { 1 }
}

fn ivl_intersect(a: Ivl, b: Ivl) -> Ivl {
    let lo = if a.lo > b.lo { a.lo } else { b.lo };
    let hi = if a.hi < b.hi { a.hi } else { b.hi };
    Ivl { lo: lo, hi: hi }
}

fn ivl_union(a: Ivl, b: Ivl) -> Ivl {
    let lo = if a.lo < b.lo { a.lo } else { b.lo };
    let hi = if a.hi > b.hi { a.hi } else { b.hi };
    Ivl { lo: lo, hi: hi }
}

// Interval midpoint (integer division)
fn ivl_mid(a: Ivl) -> Int { (a.lo + a.hi) / 2 }

fn test_add_sub() -> Int {
    let a = Ivl { lo: 1, hi: 3 };
    let b = Ivl { lo: 2, hi: 5 };
    let sum = ivl_add(a, b);
    assert_eq(sum.lo, 3);
    assert_eq(sum.hi, 8);

    let diff = ivl_sub(a, b);
    assert_eq(diff.lo, -4); // 1 - 5
    assert_eq(diff.hi, 1);  // 3 - 2
    1
}

fn test_mul() -> Int {
    let a = Ivl { lo: 1, hi: 3 };
    let b = Ivl { lo: 2, hi: 4 };
    let prod = ivl_mul(a, b);
    assert_eq(prod.lo, 2);   // 1*2
    assert_eq(prod.hi, 12);  // 3*4

    // Negative interval
    let c = Ivl { lo: -2, hi: 3 };
    let d = Ivl { lo: 1, hi: 4 };
    let prod2 = ivl_mul(c, d);
    assert_eq(prod2.lo, -8);  // -2*4
    assert_eq(prod2.hi, 12);  // 3*4
    1
}

fn test_contains_overlap() -> Int {
    let a = Ivl { lo: 1, hi: 5 };
    assert_eq(ivl_contains(a, 3), 1);
    assert_eq(ivl_contains(a, 0), 0);
    assert_eq(ivl_contains(a, 6), 0);
    assert_eq(ivl_contains(a, 1), 1);
    assert_eq(ivl_contains(a, 5), 1);

    let b = Ivl { lo: 3, hi: 7 };
    assert_eq(ivl_overlaps(a, b), 1);

    let c = Ivl { lo: 6, hi: 8 };
    assert_eq(ivl_overlaps(a, c), 0);
    1
}

fn test_intersect_union() -> Int {
    let a = Ivl { lo: 1, hi: 5 };
    let b = Ivl { lo: 3, hi: 7 };

    let isect = ivl_intersect(a, b);
    assert_eq(isect.lo, 3);
    assert_eq(isect.hi, 5);

    let un = ivl_union(a, b);
    assert_eq(un.lo, 1);
    assert_eq(un.hi, 7);

    assert_eq(ivl_width(a), 4);
    assert_eq(ivl_mid(a), 3);
    1
}

fn main() -> Int {
    test_add_sub();
    test_mul();
    test_contains_overlap();
    test_intersect_union();
    print("[OK] diff_interval_arith");
    0
}
