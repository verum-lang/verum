// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, polynomial, math
// @timeout: 10000

// Polynomial eval using Horner's method
// p(x) = c0 + c1*x + c2*x^2 + c3*x^3
fn poly_eval(c0: Int, c1: Int, c2: Int, c3: Int, x: Int) -> Int {
    ((c3 * x + c2) * x + c1) * x + c0
}

fn main() -> Int {
    // p(x) = 2 + 3x + x^2
    assert_eq(poly_eval(2, 3, 1, 0, 0), 2);
    assert_eq(poly_eval(2, 3, 1, 0, 1), 6);
    assert_eq(poly_eval(2, 3, 1, 0, 2), 12);
    assert_eq(poly_eval(2, 3, 1, 0, -1), 0);

    // p(x) = x^3
    assert_eq(poly_eval(0, 0, 0, 1, 3), 27);
    assert_eq(poly_eval(0, 0, 0, 1, -2), -8);

    // (x+1)^2 = 1 + 2x + x^2
    assert_eq(poly_eval(1, 2, 1, 0, 5), 36);

    print("DIFF_OK: polynomial");
    0
}
