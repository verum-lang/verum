// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, stack-machine, virtual-machine, interpreter
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Stack machine with 8-element stack
// Opcodes: 0=PUSH(val_in_next), 1=ADD, 2=SUB, 3=MUL, 4=DUP, 5=SWAP, 6=NEG, 7=HALT
type StackMachine is { stack: Arr8, sp: Int };

fn sm_new() -> StackMachine { StackMachine { stack: zeros(), sp: 0 } }

fn sm_push(sm: StackMachine, val: Int) -> StackMachine {
    StackMachine { stack: set(sm.stack, sm.sp, val), sp: sm.sp + 1 }
}

fn sm_pop(sm: StackMachine) -> Int {
    get(sm.stack, sm.sp - 1)
}

fn sm_pop_machine(sm: StackMachine) -> StackMachine {
    StackMachine { stack: sm.stack, sp: sm.sp - 1 }
}

fn sm_top(sm: StackMachine) -> Int {
    get(sm.stack, sm.sp - 1)
}

// Execute a program (opcodes in code array, length n)
// Operand for PUSH follows immediately
fn sm_execute(code: Arr8, n: Int) -> StackMachine {
    let mut sm = sm_new();
    let mut pc = 0;
    while pc < n {
        let op = get(code, pc);
        if op == 0 {
            // PUSH: next code element is the value
            pc = pc + 1;
            sm = sm_push(sm, get(code, pc));
        } else if op == 1 {
            // ADD
            let b = sm_pop(sm);
            sm = sm_pop_machine(sm);
            let a = sm_pop(sm);
            sm = sm_pop_machine(sm);
            sm = sm_push(sm, a + b);
        } else if op == 2 {
            // SUB
            let b = sm_pop(sm);
            sm = sm_pop_machine(sm);
            let a = sm_pop(sm);
            sm = sm_pop_machine(sm);
            sm = sm_push(sm, a - b);
        } else if op == 3 {
            // MUL
            let b = sm_pop(sm);
            sm = sm_pop_machine(sm);
            let a = sm_pop(sm);
            sm = sm_pop_machine(sm);
            sm = sm_push(sm, a * b);
        } else if op == 4 {
            // DUP
            let v = sm_top(sm);
            sm = sm_push(sm, v);
        } else if op == 5 {
            // SWAP
            let b = sm_pop(sm);
            sm = sm_pop_machine(sm);
            let a = sm_pop(sm);
            sm = sm_pop_machine(sm);
            sm = sm_push(sm, b);
            sm = sm_push(sm, a);
        } else if op == 6 {
            // NEG
            let v = sm_pop(sm);
            sm = sm_pop_machine(sm);
            sm = sm_push(sm, 0 - v);
        } else {
            // HALT (op == 7) or unknown
            pc = n; // break
        }
        pc = pc + 1;
    }
    sm
}

fn main() -> Int {
    // Program: PUSH 3, PUSH 4, ADD → 7
    let p1 = Arr8 { d0: 0, d1: 3, d2: 0, d3: 4, d4: 1, d5: 0, d6: 0, d7: 0 };
    let r1 = sm_execute(p1, 5);
    assert_eq(sm_top(r1), 7);
    assert_eq(r1.sp, 1);

    // Program: PUSH 10, PUSH 3, SUB → 7
    let p2 = Arr8 { d0: 0, d1: 10, d2: 0, d3: 3, d4: 2, d5: 0, d6: 0, d7: 0 };
    let r2 = sm_execute(p2, 5);
    assert_eq(sm_top(r2), 7);

    // Program: PUSH 5, PUSH 6, MUL → 30
    let p3 = Arr8 { d0: 0, d1: 5, d2: 0, d3: 6, d4: 3, d5: 0, d6: 0, d7: 0 };
    let r3 = sm_execute(p3, 5);
    assert_eq(sm_top(r3), 30);

    // DUP: PUSH 42, DUP → stack [42, 42]
    let p4 = Arr8 { d0: 0, d1: 42, d2: 4, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let r4 = sm_execute(p4, 3);
    assert_eq(r4.sp, 2);
    assert_eq(get(r4.stack, 0), 42);
    assert_eq(get(r4.stack, 1), 42);

    // SWAP: PUSH 1, PUSH 2, SWAP → stack [2, 1]
    let p5 = Arr8 { d0: 0, d1: 1, d2: 0, d3: 2, d4: 5, d5: 0, d6: 0, d7: 0 };
    let r5 = sm_execute(p5, 5);
    assert_eq(get(r5.stack, 0), 2);
    assert_eq(get(r5.stack, 1), 1);

    // NEG: PUSH 7, NEG → -7
    let p6 = Arr8 { d0: 0, d1: 7, d2: 6, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let r6 = sm_execute(p6, 3);
    assert_eq(sm_top(r6), -7);

    // Complex: (3 + 4) * 2 = 14
    // PUSH 3, PUSH 4, ADD, PUSH 2, MUL
    let p7 = Arr8 { d0: 0, d1: 3, d2: 0, d3: 4, d4: 1, d5: 0, d6: 2, d7: 3 };
    let r7 = sm_execute(p7, 8);
    assert_eq(sm_top(r7), 14);

    // DUP + MUL = square: PUSH 5, DUP, MUL → 25
    let p8 = Arr8 { d0: 0, d1: 5, d2: 4, d3: 3, d4: 0, d5: 0, d6: 0, d7: 0 };
    let r8 = sm_execute(p8, 4);
    assert_eq(sm_top(r8), 25);

    print("DIFF_OK: stack_machine");
    0
}
