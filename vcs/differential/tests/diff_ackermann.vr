// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, ackermann, recursion
// @timeout: 10000

// Iterative Ackermann using explicit stack
type Stack16 is {
    d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int,
    d8: Int, d9: Int, d10: Int, d11: Int, d12: Int, d13: Int, d14: Int, d15: Int,
    top: Int
};

fn stack_new() -> Stack16 {
    Stack16 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0,
              d8: 0, d9: 0, d10: 0, d11: 0, d12: 0, d13: 0, d14: 0, d15: 0, top: 0 }
}

fn stack_get(s: Stack16, i: Int) -> Int {
    if i == 0 { s.d0 } else if i == 1 { s.d1 } else if i == 2 { s.d2 }
    else if i == 3 { s.d3 } else if i == 4 { s.d4 } else if i == 5 { s.d5 }
    else if i == 6 { s.d6 } else if i == 7 { s.d7 } else if i == 8 { s.d8 }
    else if i == 9 { s.d9 } else if i == 10 { s.d10 } else if i == 11 { s.d11 }
    else if i == 12 { s.d12 } else if i == 13 { s.d13 } else if i == 14 { s.d14 }
    else { s.d15 }
}

fn stack_set(s: Stack16, i: Int, v: Int) -> Stack16 {
    Stack16 {
        d0: if i == 0 { v } else { s.d0 }, d1: if i == 1 { v } else { s.d1 },
        d2: if i == 2 { v } else { s.d2 }, d3: if i == 3 { v } else { s.d3 },
        d4: if i == 4 { v } else { s.d4 }, d5: if i == 5 { v } else { s.d5 },
        d6: if i == 6 { v } else { s.d6 }, d7: if i == 7 { v } else { s.d7 },
        d8: if i == 8 { v } else { s.d8 }, d9: if i == 9 { v } else { s.d9 },
        d10: if i == 10 { v } else { s.d10 }, d11: if i == 11 { v } else { s.d11 },
        d12: if i == 12 { v } else { s.d12 }, d13: if i == 13 { v } else { s.d13 },
        d14: if i == 14 { v } else { s.d14 }, d15: if i == 15 { v } else { s.d15 },
        top: s.top
    }
}

fn stack_push(s: Stack16, v: Int) -> Stack16 {
    let s2 = stack_set(s, s.top, v);
    Stack16 {
        d0: s2.d0, d1: s2.d1, d2: s2.d2, d3: s2.d3, d4: s2.d4, d5: s2.d5, d6: s2.d6, d7: s2.d7,
        d8: s2.d8, d9: s2.d9, d10: s2.d10, d11: s2.d11, d12: s2.d12, d13: s2.d13, d14: s2.d14, d15: s2.d15,
        top: s.top + 1
    }
}

fn stack_pop(s: Stack16) -> Stack16 {
    Stack16 {
        d0: s.d0, d1: s.d1, d2: s.d2, d3: s.d3, d4: s.d4, d5: s.d5, d6: s.d6, d7: s.d7,
        d8: s.d8, d9: s.d9, d10: s.d10, d11: s.d11, d12: s.d12, d13: s.d13, d14: s.d14, d15: s.d15,
        top: s.top - 1
    }
}

fn stack_peek(s: Stack16) -> Int {
    stack_get(s, s.top - 1)
}

// Iterative Ackermann: maintains stack of pending m values
fn ackermann(m: Int, n: Int) -> Int {
    let mut stk = stack_new();
    stk = stack_push(stk, m);
    let mut result = n;
    while stk.top > 0 {
        let cur_m = stack_peek(stk);
        stk = stack_pop(stk);
        if cur_m == 0 {
            result = result + 1;
        } else if result == 0 {
            stk = stack_push(stk, cur_m - 1);
            result = 1;
        } else {
            stk = stack_push(stk, cur_m - 1);
            stk = stack_push(stk, cur_m);
            result = result - 1;
        }
    }
    result
}

fn main() -> Int {
    // A(0, n) = n + 1
    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(0, 1), 2);
    assert_eq(ackermann(0, 5), 6);

    // A(1, n) = n + 2
    assert_eq(ackermann(1, 0), 2);
    assert_eq(ackermann(1, 1), 3);
    assert_eq(ackermann(1, 5), 7);

    // A(2, n) = 2n + 3
    assert_eq(ackermann(2, 0), 3);
    assert_eq(ackermann(2, 1), 5);
    assert_eq(ackermann(2, 2), 7);
    assert_eq(ackermann(2, 3), 9);

    // A(3, 0) = 5
    assert_eq(ackermann(3, 0), 5);
    // A(3, 1) = 13
    assert_eq(ackermann(3, 1), 13);

    print("DIFF_OK: ackermann");
    0
}
