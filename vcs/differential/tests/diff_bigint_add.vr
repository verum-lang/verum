// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, bigint, addition, multiplication, arbitrary-precision
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// BigInt: digits stored in base 100, LSB first
// Length stored separately

fn bigint_add(a: Arr8, a_len: Int, b: Arr8, b_len: Int, out: Arr8) -> Arr8 {
    let mut result = out;
    let mut carry = 0;
    let max_len = if a_len > b_len { a_len } else { b_len };
    let mut i = 0;
    while i < max_len {
        let da = if i < a_len { get(a, i) } else { 0 };
        let db = if i < b_len { get(b, i) } else { 0 };
        let sum = da + db + carry;
        result = set(result, i, sum % 100);
        carry = sum / 100;
        i = i + 1;
    }
    if carry > 0 {
        result = set(result, max_len, carry);
    }
    result
}

fn bigint_add_len(a_len: Int, b_len: Int) -> Int {
    let max_len = if a_len > b_len { a_len } else { b_len };
    max_len + 1
}

// Convert bigint to regular int (for small values)
fn bigint_to_int(a: Arr8, a_len: Int) -> Int {
    let mut result = 0;
    let mut place = 1;
    let mut i = 0;
    while i < a_len {
        result = result + get(a, i) * place;
        place = place * 100;
        i = i + 1;
    }
    result
}

// Convert int to bigint
fn int_to_bigint(n: Int) -> Arr8 {
    let mut result = zeros();
    let mut val = n;
    let mut i = 0;
    while val > 0 {
        result = set(result, i, val % 100);
        val = val / 100;
        i = i + 1;
    }
    result
}

fn int_to_bigint_len(n: Int) -> Int {
    if n == 0 { return 1; }
    let mut len = 0;
    let mut val = n;
    while val > 0 { val = val / 100; len = len + 1; }
    len
}

// BigInt multiply (school method)
fn bigint_mul(a: Arr8, a_len: Int, b: Arr8, b_len: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i < a_len {
        let mut carry = 0;
        let mut j = 0;
        while j < b_len {
            let pos = i + j;
            if pos < 8 {
                let prod = get(a, i) * get(b, j) + get(result, pos) + carry;
                result = set(result, pos, prod % 100);
                carry = prod / 100;
            }
            j = j + 1;
        }
        if i + b_len < 8 {
            result = set(result, i + b_len, get(result, i + b_len) + carry);
        }
        i = i + 1;
    }
    result
}

fn main() -> Int {
    // Simple addition: 99 + 1 = 100
    let a1 = Arr8 { d0: 99, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let b1 = Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let sum1 = bigint_add(a1, 1, b1, 1, zeros());
    assert_eq(bigint_to_int(sum1, 2), 100);

    // 9999 + 1 = 10000 (base 100: [99,99] + [1] = [0,0,1])
    let a2 = Arr8 { d0: 99, d1: 99, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let b2 = Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let sum2 = bigint_add(a2, 2, b2, 1, zeros());
    assert_eq(bigint_to_int(sum2, 3), 10000);

    // Round-trip: int_to_bigint and back
    assert_eq(bigint_to_int(int_to_bigint(12345), int_to_bigint_len(12345)), 12345);
    assert_eq(bigint_to_int(int_to_bigint(9999), int_to_bigint_len(9999)), 9999);

    // Addition cross-check with native int
    let mut i = 0;
    while i < 100 {
        let val = i * 101; // 0, 101, 202, ...
        let a = int_to_bigint(val);
        let al = int_to_bigint_len(val);
        let b = int_to_bigint(val);
        let sum = bigint_add(a, al, b, al, zeros());
        assert_eq(bigint_to_int(sum, bigint_add_len(al, al)), val * 2);
        i = i + 1;
    }

    // Multiplication: 12 * 34 = 408
    let m1 = int_to_bigint(12);
    let m2 = int_to_bigint(34);
    let prod = bigint_mul(m1, int_to_bigint_len(12), m2, int_to_bigint_len(34));
    assert_eq(bigint_to_int(prod, 2), 408);

    // 99 * 99 = 9801
    let m3 = int_to_bigint(99);
    let m4 = int_to_bigint(99);
    let prod2 = bigint_mul(m3, 1, m4, 1);
    assert_eq(bigint_to_int(prod2, 2), 9801);

    // 100 * 100 = 10000 (base 100: [0,1] * [0,1] = [0,0,1])
    let m5 = int_to_bigint(100);
    let m6 = int_to_bigint(100);
    let prod3 = bigint_mul(m5, int_to_bigint_len(100), m6, int_to_bigint_len(100));
    assert_eq(bigint_to_int(prod3, 3), 10000);

    // Commutativity: a*b = b*a
    let ma = int_to_bigint(123);
    let mb = int_to_bigint(45);
    let p1 = bigint_mul(ma, int_to_bigint_len(123), mb, int_to_bigint_len(45));
    let p2 = bigint_mul(mb, int_to_bigint_len(45), ma, int_to_bigint_len(123));
    assert_eq(bigint_to_int(p1, 3), bigint_to_int(p2, 3));
    assert_eq(bigint_to_int(p1, 3), 5535);

    print("DIFF_OK: bigint_add");
    0
}
