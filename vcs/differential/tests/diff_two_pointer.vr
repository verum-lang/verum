// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, two-pointer, sliding-window, array
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

// Two sum on sorted array: find if two elements sum to target
fn two_sum_sorted(a: Arr8, n: Int, target: Int) -> Int {
    let mut lo = 0;
    let mut hi = n - 1;
    while lo < hi {
        let s = get(a, lo) + get(a, hi);
        if s == target { return 1; }
        if s < target { lo = lo + 1; }
        else { hi = hi - 1; }
    }
    0
}

// Remove duplicates from sorted array, return new length
fn remove_dups(a: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut unique = 1;
    let mut i = 1;
    while i < n {
        if get(a, i) != get(a, i - 1) { unique = unique + 1; }
        i = i + 1;
    }
    unique
}

// Max subarray sum of length k (sliding window)
fn max_subarray_sum_k(a: Arr8, n: Int, k: Int) -> Int {
    // Initial window sum
    let mut window = 0;
    let mut i = 0;
    while i < k { window = window + get(a, i); i = i + 1; }
    let mut best = window;
    i = k;
    while i < n {
        window = window + get(a, i) - get(a, i - k);
        if window > best { best = window; }
        i = i + 1;
    }
    best
}

// Longest subarray with sum <= target
fn longest_subarray_sum_le(a: Arr8, n: Int, target: Int) -> Int {
    let mut lo = 0;
    let mut sum = 0;
    let mut best = 0;
    let mut hi = 0;
    while hi < n {
        sum = sum + get(a, hi);
        while sum > target {
            sum = sum - get(a, lo);
            lo = lo + 1;
        }
        let len = hi - lo + 1;
        if len > best { best = len; }
        hi = hi + 1;
    }
    best
}

fn test_two_sum() -> Int {
    let a = Arr8 { d0: 1, d1: 2, d2: 4, d3: 6, d4: 8, d5: 0, d6: 0, d7: 0 };
    assert_eq(two_sum_sorted(a, 5, 10), 1);  // 2+8 or 4+6
    assert_eq(two_sum_sorted(a, 5, 3), 1);   // 1+2
    assert_eq(two_sum_sorted(a, 5, 15), 0);  // no pair
    assert_eq(two_sum_sorted(a, 5, 5), 1);   // 1+4
    1
}

fn test_remove_dups() -> Int {
    let a = Arr8 { d0: 1, d1: 1, d2: 2, d3: 3, d4: 3, d5: 3, d6: 4, d7: 0 };
    assert_eq(remove_dups(a, 7), 4);
    let b = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 0, d6: 0, d7: 0 };
    assert_eq(remove_dups(b, 5), 5);
    let c = Arr8 { d0: 7, d1: 7, d2: 7, d3: 7, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(remove_dups(c, 4), 1);
    1
}

fn test_sliding_window() -> Int {
    let a = Arr8 { d0: 1, d1: 3, d2: 2, d3: 6, d4: 1, d5: 4, d6: 0, d7: 0 };
    assert_eq(max_subarray_sum_k(a, 6, 2), 8);   // [2,6]
    assert_eq(max_subarray_sum_k(a, 6, 3), 11);  // [2,6,1] nope, [3,2,6]=11
    assert_eq(max_subarray_sum_k(a, 6, 1), 6);   // just 6
    1
}

fn test_longest_sum() -> Int {
    let a = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 0, d6: 0, d7: 0 };
    assert_eq(longest_subarray_sum_le(a, 5, 6), 3);   // [1,2,3]
    assert_eq(longest_subarray_sum_le(a, 5, 10), 4);  // [1,2,3,4]
    assert_eq(longest_subarray_sum_le(a, 5, 15), 5);  // entire array
    assert_eq(longest_subarray_sum_le(a, 5, 1), 1);   // just [1]
    1
}

fn main() -> Int {
    test_two_sum();
    test_remove_dups();
    test_sliding_window();
    test_longest_sum();
    print("DIFF_OK: two_pointer");
    0
}
