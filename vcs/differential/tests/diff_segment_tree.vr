// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, segment-tree, range-query, data-structure
// @timeout: 10000

// Segment tree for range-sum and range-min queries on 8 elements
// Tree stored in array of size 32 (4*8 is enough)

type Arr32 is {
    d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int,
    d8: Int, d9: Int, d10: Int, d11: Int, d12: Int, d13: Int, d14: Int, d15: Int,
    d16: Int, d17: Int, d18: Int, d19: Int, d20: Int, d21: Int, d22: Int, d23: Int,
    d24: Int, d25: Int, d26: Int, d27: Int, d28: Int, d29: Int, d30: Int, d31: Int
};

fn get32(a: Arr32, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else if i == 7 { a.d7 } else if i == 8 { a.d8 }
    else if i == 9 { a.d9 } else if i == 10 { a.d10 } else if i == 11 { a.d11 }
    else if i == 12 { a.d12 } else if i == 13 { a.d13 } else if i == 14 { a.d14 }
    else if i == 15 { a.d15 } else if i == 16 { a.d16 } else if i == 17 { a.d17 }
    else if i == 18 { a.d18 } else if i == 19 { a.d19 } else if i == 20 { a.d20 }
    else if i == 21 { a.d21 } else if i == 22 { a.d22 } else if i == 23 { a.d23 }
    else if i == 24 { a.d24 } else if i == 25 { a.d25 } else if i == 26 { a.d26 }
    else if i == 27 { a.d27 } else if i == 28 { a.d28 } else if i == 29 { a.d29 }
    else if i == 30 { a.d30 } else { a.d31 }
}

fn set32(a: Arr32, i: Int, v: Int) -> Arr32 {
    Arr32 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 },
        d8: if i == 8 { v } else { a.d8 }, d9: if i == 9 { v } else { a.d9 },
        d10: if i == 10 { v } else { a.d10 }, d11: if i == 11 { v } else { a.d11 },
        d12: if i == 12 { v } else { a.d12 }, d13: if i == 13 { v } else { a.d13 },
        d14: if i == 14 { v } else { a.d14 }, d15: if i == 15 { v } else { a.d15 },
        d16: if i == 16 { v } else { a.d16 }, d17: if i == 17 { v } else { a.d17 },
        d18: if i == 18 { v } else { a.d18 }, d19: if i == 19 { v } else { a.d19 },
        d20: if i == 20 { v } else { a.d20 }, d21: if i == 21 { v } else { a.d21 },
        d22: if i == 22 { v } else { a.d22 }, d23: if i == 23 { v } else { a.d23 },
        d24: if i == 24 { v } else { a.d24 }, d25: if i == 25 { v } else { a.d25 },
        d26: if i == 26 { v } else { a.d26 }, d27: if i == 27 { v } else { a.d27 },
        d28: if i == 28 { v } else { a.d28 }, d29: if i == 29 { v } else { a.d29 },
        d30: if i == 30 { v } else { a.d30 }, d31: if i == 31 { v } else { a.d31 }
    }
}

fn zeros32() -> Arr32 {
    Arr32 {
        d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0,
        d8: 0, d9: 0, d10: 0, d11: 0, d12: 0, d13: 0, d14: 0, d15: 0,
        d16: 0, d17: 0, d18: 0, d19: 0, d20: 0, d21: 0, d22: 0, d23: 0,
        d24: 0, d25: 0, d26: 0, d27: 0, d28: 0, d29: 0, d30: 0, d31: 0
    }
}

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn min2(a: Int, b_val: Int) -> Int { if a < b_val { a } else { b_val } }
fn max2(a: Int, b_val: Int) -> Int { if a > b_val { a } else { b_val } }

// Build sum segment tree iteratively (bottom-up)
// Leaves at positions n..2n-1, internal at 1..n-1
fn build_sum_tree(data: Arr8, n: Int) -> Arr32 {
    let mut tree = zeros32();
    // Place leaves
    let mut i = 0;
    while i < n {
        tree = set32(tree, n + i, get8(data, i));
        i = i + 1;
    }
    // Build internal nodes bottom-up
    let mut i2 = n - 1;
    while i2 >= 1 {
        tree = set32(tree, i2, get32(tree, 2 * i2) + get32(tree, 2 * i2 + 1));
        i2 = i2 - 1;
    }
    tree
}

// Range sum query [l, r) (0-indexed on original array)
fn range_sum(tree: Arr32, n: Int, l: Int, r: Int) -> Int {
    let mut lo = l + n;
    let mut hi = r + n;
    let mut sum = 0;
    while lo < hi {
        if lo % 2 == 1 { sum = sum + get32(tree, lo); lo = lo + 1; }
        if hi % 2 == 1 { hi = hi - 1; sum = sum + get32(tree, hi); }
        lo = lo / 2;
        hi = hi / 2;
    }
    sum
}

// Point update: set data[pos] = val
fn point_update(tree: Arr32, n: Int, pos: Int, val: Int) -> Arr32 {
    let mut t = tree;
    let mut i = pos + n;
    t = set32(t, i, val);
    i = i / 2;
    while i >= 1 {
        t = set32(t, i, get32(t, 2 * i) + get32(t, 2 * i + 1));
        i = i / 2;
    }
    t
}

// Build min segment tree
fn build_min_tree(data: Arr8, n: Int) -> Arr32 {
    let mut tree = zeros32();
    let mut i = 0;
    while i < n {
        tree = set32(tree, n + i, get8(data, i));
        i = i + 1;
    }
    // Fill unused leaves with large value
    let mut i2 = n;
    while i2 < n {
        tree = set32(tree, n + i2, 999999);
        i2 = i2 + 1;
    }
    let mut i3 = n - 1;
    while i3 >= 1 {
        tree = set32(tree, i3, min2(get32(tree, 2 * i3), get32(tree, 2 * i3 + 1)));
        i3 = i3 - 1;
    }
    tree
}

fn range_min(tree: Arr32, n: Int, l: Int, r: Int) -> Int {
    let mut lo = l + n;
    let mut hi = r + n;
    let mut mn = 999999;
    while lo < hi {
        if lo % 2 == 1 { mn = min2(mn, get32(tree, lo)); lo = lo + 1; }
        if hi % 2 == 1 { hi = hi - 1; mn = min2(mn, get32(tree, hi)); }
        lo = lo / 2;
        hi = hi / 2;
    }
    mn
}

// Brute-force sum for verification
fn brute_sum(data: Arr8, l: Int, r: Int) -> Int {
    let mut s = 0;
    let mut i = l;
    while i < r { s = s + get8(data, i); i = i + 1; }
    s
}

fn brute_min(data: Arr8, l: Int, r: Int) -> Int {
    let mut m = get8(data, l);
    let mut i = l + 1;
    while i < r { m = min2(m, get8(data, i)); i = i + 1; }
    m
}

fn main() -> Int {
    let data = Arr8 { d0: 5, d1: 3, d2: 8, d3: 1, d4: 7, d5: 2, d6: 9, d7: 4 };
    let n = 8;
    let tree = build_sum_tree(data, n);

    // Full range
    assert_eq(range_sum(tree, n, 0, 8), 39);
    assert_eq(brute_sum(data, 0, 8), 39);

    // Single elements
    assert_eq(range_sum(tree, n, 0, 1), 5);
    assert_eq(range_sum(tree, n, 2, 3), 8);
    assert_eq(range_sum(tree, n, 7, 8), 4);

    // Subranges
    assert_eq(range_sum(tree, n, 0, 4), 17); // 5+3+8+1
    assert_eq(range_sum(tree, n, 4, 8), 22); // 7+2+9+4
    assert_eq(range_sum(tree, n, 2, 6), 18); // 8+1+7+2
    assert_eq(range_sum(tree, n, 1, 3), 11); // 3+8

    // Verify against brute force
    assert_eq(range_sum(tree, n, 2, 6), brute_sum(data, 2, 6));
    assert_eq(range_sum(tree, n, 0, 5), brute_sum(data, 0, 5));

    // Point update: set index 3 to 10 (was 1)
    let tree2 = point_update(tree, n, 3, 10);
    assert_eq(range_sum(tree2, n, 0, 8), 48); // 39 - 1 + 10
    assert_eq(range_sum(tree2, n, 3, 4), 10);
    assert_eq(range_sum(tree2, n, 0, 4), 26); // 5+3+8+10

    // Min segment tree
    let mtree = build_min_tree(data, n);
    assert_eq(range_min(mtree, n, 0, 8), 1);
    assert_eq(range_min(mtree, n, 0, 4), 1);
    assert_eq(range_min(mtree, n, 4, 8), 2);
    assert_eq(range_min(mtree, n, 0, 2), 3);
    assert_eq(range_min(mtree, n, 5, 7), 2);
    assert_eq(range_min(mtree, n, 2, 3), 8); // single

    // Verify min against brute force
    assert_eq(range_min(mtree, n, 1, 5), brute_min(data, 1, 5));
    assert_eq(range_min(mtree, n, 3, 7), brute_min(data, 3, 7));

    print("DIFF_OK: segment_tree");
    0
}
