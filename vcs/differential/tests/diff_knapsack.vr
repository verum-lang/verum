// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, knapsack, dynamic-programming
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn max2(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// 0/1 knapsack with rolling DP
// weights and values are Arr8, capacity <= 7
fn knapsack(weights: Arr8, values: Arr8, n: Int, capacity: Int) -> Int {
    // dp[w] = max value with capacity w
    let mut dp = Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };

    let mut item = 0;
    while item < n {
        let w = get(weights, item);
        let v = get(values, item);
        // Process capacity in reverse to avoid double-counting
        let mut c = capacity;
        while c >= w {
            let without_item = get(dp, c);
            let with_item = get(dp, c - w) + v;
            dp = set(dp, c, max2(without_item, with_item));
            c = c - 1;
        }
        item = item + 1;
    }
    get(dp, capacity)
}

fn main() -> Int {
    // Classic knapsack: items (weight, value)
    // (2, 3), (3, 4), (4, 5), (5, 8)
    let weights = Arr8 { d0: 2, d1: 3, d2: 4, d3: 5, d4: 0, d5: 0, d6: 0, d7: 0 };
    let values = Arr8 { d0: 3, d1: 4, d2: 5, d3: 8, d4: 0, d5: 0, d6: 0, d7: 0 };

    // Capacity 5: best is items 0+1 (w=5, v=7) or item 3 (w=5, v=8)
    assert_eq(knapsack(weights, values, 4, 5), 8);

    // Capacity 7: items 0+3 (w=7, v=11) or 0+1+2 impossible (w=9), 1+2 (w=7, v=9)
    // Actually: item 0(w=2,v=3) + item 3(w=5,v=8) = w=7, v=11
    assert_eq(knapsack(weights, values, 4, 7), 11);

    // Capacity 0: nothing fits
    assert_eq(knapsack(weights, values, 4, 0), 0);

    // Capacity 2: only item 0 fits (w=2, v=3)
    assert_eq(knapsack(weights, values, 4, 2), 3);

    // Single item test
    let w1 = Arr8 { d0: 3, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let v1 = Arr8 { d0: 10, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(knapsack(w1, v1, 1, 3), 10);
    assert_eq(knapsack(w1, v1, 1, 2), 0);  // doesn't fit

    // All weight 1
    let w_unit = Arr8 { d0: 1, d1: 1, d2: 1, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 };
    let v_unit = Arr8 { d0: 5, d1: 3, d2: 4, d3: 2, d4: 0, d5: 0, d6: 0, d7: 0 };
    // Capacity 2: pick top 2 values: 5+4=9
    assert_eq(knapsack(w_unit, v_unit, 4, 2), 9);
    // Capacity 4: all fit: 5+3+4+2=14
    assert_eq(knapsack(w_unit, v_unit, 4, 4), 14);

    print("DIFF_OK: knapsack");
    0
}
