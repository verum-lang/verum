// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, lis, longest-increasing-subsequence, dp
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// LIS length via O(n^2) DP
fn lis_length(a: Arr8, n: Int) -> Int {
    let mut dp = zeros();
    let mut i = 0;
    while i < n {
        dp = set(dp, i, 1);
        i = i + 1;
    }

    let mut i2 = 1;
    while i2 < n {
        let mut j = 0;
        while j < i2 {
            if get(a, j) < get(a, i2) {
                if get(dp, j) + 1 > get(dp, i2) {
                    dp = set(dp, i2, get(dp, j) + 1);
                }
            }
            j = j + 1;
        }
        i2 = i2 + 1;
    }

    let mut max_len = 0;
    let mut k = 0;
    while k < n {
        if get(dp, k) > max_len { max_len = get(dp, k); }
        k = k + 1;
    }
    max_len
}

// Longest non-decreasing subsequence
fn lnds_length(a: Arr8, n: Int) -> Int {
    let mut dp = zeros();
    let mut i = 0;
    while i < n { dp = set(dp, i, 1); i = i + 1; }

    let mut i2 = 1;
    while i2 < n {
        let mut j = 0;
        while j < i2 {
            if get(a, j) <= get(a, i2) {
                if get(dp, j) + 1 > get(dp, i2) {
                    dp = set(dp, i2, get(dp, j) + 1);
                }
            }
            j = j + 1;
        }
        i2 = i2 + 1;
    }

    let mut max_len = 0;
    let mut k = 0;
    while k < n { if get(dp, k) > max_len { max_len = get(dp, k); } k = k + 1; }
    max_len
}

// Longest decreasing subsequence = LIS of reversed array
fn lds_length(a: Arr8, n: Int) -> Int {
    let mut rev = zeros();
    let mut i = 0;
    while i < n {
        rev = set(rev, i, get(a, n - 1 - i));
        i = i + 1;
    }
    lis_length(rev, n)
}

// Count number of LIS (brute force via DP)
fn count_lis(a: Arr8, n: Int) -> Int {
    let mut dp_len = zeros();
    let mut dp_cnt = zeros();
    let mut i = 0;
    while i < n {
        dp_len = set(dp_len, i, 1);
        dp_cnt = set(dp_cnt, i, 1);
        i = i + 1;
    }

    let mut i2 = 1;
    while i2 < n {
        let mut j = 0;
        while j < i2 {
            if get(a, j) < get(a, i2) {
                if get(dp_len, j) + 1 > get(dp_len, i2) {
                    dp_len = set(dp_len, i2, get(dp_len, j) + 1);
                    dp_cnt = set(dp_cnt, i2, get(dp_cnt, j));
                } else if get(dp_len, j) + 1 == get(dp_len, i2) {
                    dp_cnt = set(dp_cnt, i2, get(dp_cnt, i2) + get(dp_cnt, j));
                }
            }
            j = j + 1;
        }
        i2 = i2 + 1;
    }

    let lis_len = lis_length(a, n);
    let mut total = 0;
    let mut k = 0;
    while k < n {
        if get(dp_len, k) == lis_len { total = total + get(dp_cnt, k); }
        k = k + 1;
    }
    total
}

fn main() -> Int {
    // [10, 9, 2, 5, 3, 7, 101, 18] — LIS = [2,3,7,101] or [2,5,7,101] = length 4
    let a1 = Arr8 { d0: 10, d1: 9, d2: 2, d3: 5, d4: 3, d5: 7, d6: 101, d7: 18 };
    assert_eq(lis_length(a1, 8), 4);

    // Strictly increasing
    let a2 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 6, d6: 7, d7: 8 };
    assert_eq(lis_length(a2, 8), 8);

    // Strictly decreasing
    let a3 = Arr8 { d0: 8, d1: 7, d2: 6, d3: 5, d4: 4, d5: 3, d6: 2, d7: 1 };
    assert_eq(lis_length(a3, 8), 1);

    // All same — LIS=1 but LNDS=n
    let a4 = Arr8 { d0: 5, d1: 5, d2: 5, d3: 5, d4: 5, d5: 0, d6: 0, d7: 0 };
    assert_eq(lis_length(a4, 5), 1);
    assert_eq(lnds_length(a4, 5), 5);

    // Single element
    let a5 = Arr8 { d0: 42, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(lis_length(a5, 1), 1);

    // LDS: decreasing subsequence length
    assert_eq(lds_length(a2, 8), 1);  // increasing → LDS = 1
    assert_eq(lds_length(a3, 8), 8);  // decreasing → LDS = 8

    // [3, 1, 2, 1, 4] — LIS = [1,2,4] length 3
    let a6 = Arr8 { d0: 3, d1: 1, d2: 2, d3: 1, d4: 4, d5: 0, d6: 0, d7: 0 };
    assert_eq(lis_length(a6, 5), 3);

    // Count LIS: [1,3,5,4,7] — LIS length 4: [1,3,5,7] and [1,3,4,7] → 2
    let a7 = Arr8 { d0: 1, d1: 3, d2: 5, d3: 4, d4: 7, d5: 0, d6: 0, d7: 0 };
    assert_eq(lis_length(a7, 5), 4);
    assert_eq(count_lis(a7, 5), 2);

    // Dilworth's theorem: min chains to cover = max antichain = LIS length
    // (for a sequence, LDS length = min number of increasing subsequences needed)
    // Erdos-Szekeres: sequence of length > r*s has increasing subseq > r or decreasing > s
    // For a2 (1..8): LIS=8, LDS=1, 8*1=8 = length — tight

    print("DIFF_OK: lis");
    0
}
