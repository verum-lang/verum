// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, insertion-sort, sorting, stable
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn is_sorted(a: Arr8, n: Int) -> Int {
    let mut i = 1;
    while i < n {
        if get(a, i) < get(a, i - 1) { return 0; }
        i = i + 1;
    }
    1
}

fn insertion_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 1;
    while i < n {
        let key = get(arr, i);
        let mut j = i - 1;
        let mut done = 0;
        let mut insert_pos = i;
        while done == 0 {
            if j < 0 {
                insert_pos = 0;
                done = 1;
            } else if get(arr, j) > key {
                arr = set(arr, j + 1, get(arr, j));
                insert_pos = j;
                j = j - 1;
            } else {
                insert_pos = j + 1;
                done = 1;
            }
        }
        arr = set(arr, insert_pos, key);
        i = i + 1;
    }
    arr
}

// Bubble sort for cross-check
fn bubble_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n {
        let mut j = 0;
        while j < n - 1 - i {
            if get(arr, j) > get(arr, j + 1) {
                let tmp = get(arr, j);
                arr = set(arr, j, get(arr, j + 1));
                arr = set(arr, j + 1, tmp);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

// Count inversions
fn count_inversions(a: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if get(a, i) > get(a, j) { count = count + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

fn main() -> Int {
    // Basic sort
    let a1 = Arr8 { d0: 5, d1: 3, d2: 8, d3: 1, d4: 7, d5: 2, d6: 9, d7: 4 };
    let s1 = insertion_sort(a1, 8);
    assert_eq(is_sorted(s1, 8), 1);
    assert_eq(get(s1, 0), 1);
    assert_eq(get(s1, 7), 9);

    // Cross-check with bubble sort
    let b1 = bubble_sort(a1, 8);
    let mut i = 0;
    while i < 8 {
        assert_eq(get(s1, i), get(b1, i));
        i = i + 1;
    }

    // Already sorted
    let a2 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 6, d6: 7, d7: 8 };
    let s2 = insertion_sort(a2, 8);
    assert_eq(is_sorted(s2, 8), 1);

    // Reverse sorted
    let a3 = Arr8 { d0: 8, d1: 7, d2: 6, d3: 5, d4: 4, d5: 3, d6: 2, d7: 1 };
    let s3 = insertion_sort(a3, 8);
    assert_eq(is_sorted(s3, 8), 1);
    assert_eq(get(s3, 0), 1);

    // All same
    let a4 = Arr8 { d0: 5, d1: 5, d2: 5, d3: 5, d4: 0, d5: 0, d6: 0, d7: 0 };
    let s4 = insertion_sort(a4, 4);
    assert_eq(is_sorted(s4, 4), 1);

    // Single element
    let a5 = Arr8 { d0: 42, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let s5 = insertion_sort(a5, 1);
    assert_eq(get(s5, 0), 42);

    // Inversions
    assert_eq(count_inversions(a2, 8), 0); // sorted = 0
    assert_eq(count_inversions(a3, 8), 28); // reverse = n*(n-1)/2 = 28
    // Sorting should produce 0 inversions
    assert_eq(count_inversions(s1, 8), 0);

    // With duplicates
    let a6 = Arr8 { d0: 3, d1: 1, d2: 4, d3: 1, d4: 5, d5: 9, d6: 2, d7: 6 };
    let s6 = insertion_sort(a6, 8);
    assert_eq(is_sorted(s6, 8), 1);
    assert_eq(get(s6, 0), 1);
    assert_eq(get(s6, 1), 1); // two 1s together

    print("DIFF_OK: insertion_sort");
    0
}
