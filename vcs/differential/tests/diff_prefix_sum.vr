// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, prefix-sum, range-query, accumulation
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

// Build prefix sum array: ps[i] = a[0] + ... + a[i-1], ps[0] = 0
fn build_prefix(a: Arr8, n: Int) -> Arr8 {
    let mut ps = Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let mut i = 0;
    let mut sum = 0;
    while i < n {
        sum = sum + get(a, i);
        ps = set(ps, i + 1, sum);
        i = i + 1;
    }
    ps
}

// Range sum query: sum of a[l..r] (inclusive)
fn range_sum(ps: Arr8, l: Int, r: Int) -> Int {
    get(ps, r + 1) - get(ps, l)
}

// Product of range (naive)
fn range_product(a: Arr8, l: Int, r: Int) -> Int {
    let mut prod = 1;
    let mut i = l;
    while i <= r {
        prod = prod * get(a, i);
        i = i + 1;
    }
    prod
}

// Max in range (naive)
fn range_max(a: Arr8, l: Int, r: Int) -> Int {
    let mut mx = get(a, l);
    let mut i = l + 1;
    while i <= r {
        let v = get(a, i);
        if v > mx { mx = v; }
        i = i + 1;
    }
    mx
}

// Min in range (naive)
fn range_min(a: Arr8, l: Int, r: Int) -> Int {
    let mut mn = get(a, l);
    let mut i = l + 1;
    while i <= r {
        let v = get(a, i);
        if v < mn { mn = v; }
        i = i + 1;
    }
    mn
}

fn test_prefix_sum() -> Int {
    let a = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 0, d6: 0, d7: 0 };
    let ps = build_prefix(a, 5);
    assert_eq(get(ps, 0), 0);
    assert_eq(get(ps, 1), 1);
    assert_eq(get(ps, 5), 15);
    assert_eq(range_sum(ps, 0, 4), 15);
    assert_eq(range_sum(ps, 1, 3), 9);
    assert_eq(range_sum(ps, 2, 2), 3);
    1
}

fn test_product() -> Int {
    let a = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 0, d6: 0, d7: 0 };
    assert_eq(range_product(a, 0, 4), 120);
    assert_eq(range_product(a, 1, 3), 24);
    assert_eq(range_product(a, 2, 2), 3);
    assert_eq(range_product(a, 0, 0), 1);
    1
}

fn test_min_max() -> Int {
    let a = Arr8 { d0: 3, d1: 1, d2: 4, d3: 1, d4: 5, d5: 9, d6: 2, d7: 6 };
    assert_eq(range_max(a, 0, 7), 9);
    assert_eq(range_min(a, 0, 7), 1);
    assert_eq(range_max(a, 4, 7), 9);
    assert_eq(range_min(a, 4, 7), 2);
    assert_eq(range_max(a, 0, 0), 3);
    assert_eq(range_min(a, 0, 0), 3);
    1
}

fn main() -> Int {
    test_prefix_sum();
    test_product();
    test_min_max();
    print("DIFF_OK: prefix_sum");
    0
}
