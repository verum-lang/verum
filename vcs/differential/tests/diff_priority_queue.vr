// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, priority-queue, heap, scheduling
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Max-heap priority queue (1-indexed, data[0] unused)
type MaxPQ is { data: Arr8, size: Int };

fn pq_new() -> MaxPQ { MaxPQ { data: zeros(), size: 0 } }

fn pq_parent(i: Int) -> Int { i / 2 }
fn pq_left(i: Int) -> Int { i * 2 }
fn pq_right(i: Int) -> Int { i * 2 + 1 }

fn pq_insert(pq: MaxPQ, val: Int) -> MaxPQ {
    let new_size = pq.size + 1;
    let mut data = set(pq.data, new_size, val);
    // Sift up
    let mut i = new_size;
    let mut done = 0;
    while i > 1 {
        if done == 0 {
            let p = pq_parent(i);
            if get(data, i) > get(data, p) {
                let tmp = get(data, i);
                data = set(data, i, get(data, p));
                data = set(data, p, tmp);
                i = p;
            } else {
                done = 1;
            }
        } else { i = 0; }
    }
    MaxPQ { data: data, size: new_size }
}

fn pq_peek(pq: MaxPQ) -> Int { get(pq.data, 1) }

fn pq_extract_max(pq: MaxPQ) -> MaxPQ {
    let mut data = set(pq.data, 1, get(pq.data, pq.size));
    let new_size = pq.size - 1;
    // Sift down
    let mut i = 1;
    let mut done = 0;
    while done == 0 {
        let l = pq_left(i);
        let r = pq_right(i);
        let mut largest = i;
        if l <= new_size {
            if get(data, l) > get(data, largest) { largest = l; }
        }
        if r <= new_size {
            if get(data, r) > get(data, largest) { largest = r; }
        }
        if largest != i {
            let tmp = get(data, i);
            data = set(data, i, get(data, largest));
            data = set(data, largest, tmp);
            i = largest;
        } else {
            done = 1;
        }
    }
    MaxPQ { data: data, size: new_size }
}

fn is_max_heap(pq: MaxPQ) -> Int {
    let mut i = 1;
    while i <= pq.size {
        let l = pq_left(i);
        let r = pq_right(i);
        if l <= pq.size {
            if get(pq.data, l) > get(pq.data, i) { return 0; }
        }
        if r <= pq.size {
            if get(pq.data, r) > get(pq.data, i) { return 0; }
        }
        i = i + 1;
    }
    1
}

fn main() -> Int {
    let mut pq = pq_new();
    assert_eq(pq.size, 0);

    // Insert elements
    pq = pq_insert(pq, 3);
    assert_eq(pq_peek(pq), 3);
    assert_eq(is_max_heap(pq), 1);

    pq = pq_insert(pq, 7);
    assert_eq(pq_peek(pq), 7);
    assert_eq(is_max_heap(pq), 1);

    pq = pq_insert(pq, 1);
    assert_eq(pq_peek(pq), 7);
    assert_eq(is_max_heap(pq), 1);

    pq = pq_insert(pq, 5);
    assert_eq(pq_peek(pq), 7);
    pq = pq_insert(pq, 9);
    assert_eq(pq_peek(pq), 9);
    pq = pq_insert(pq, 2);
    assert_eq(pq.size, 6);
    assert_eq(is_max_heap(pq), 1);

    // Extract in descending order
    let max1 = pq_peek(pq);
    pq = pq_extract_max(pq);
    assert_eq(max1, 9);
    assert_eq(is_max_heap(pq), 1);

    let max2 = pq_peek(pq);
    pq = pq_extract_max(pq);
    assert_eq(max2, 7);

    let max3 = pq_peek(pq);
    pq = pq_extract_max(pq);
    assert_eq(max3, 5);

    let max4 = pq_peek(pq);
    pq = pq_extract_max(pq);
    assert_eq(max4, 3);

    let max5 = pq_peek(pq);
    pq = pq_extract_max(pq);
    assert_eq(max5, 2);

    let max6 = pq_peek(pq);
    pq = pq_extract_max(pq);
    assert_eq(max6, 1);

    assert_eq(pq.size, 0);

    // Heap sort test: insert 5,3,8,1,4 then extract
    let mut pq2 = pq_new();
    pq2 = pq_insert(pq2, 5);
    pq2 = pq_insert(pq2, 3);
    pq2 = pq_insert(pq2, 8);
    pq2 = pq_insert(pq2, 1);
    pq2 = pq_insert(pq2, 4);

    let mut sorted = zeros();
    let mut idx = 0;
    while pq2.size > 0 {
        sorted = set(sorted, idx, pq_peek(pq2));
        pq2 = pq_extract_max(pq2);
        idx = idx + 1;
    }
    // Sorted descending: 8,5,4,3,1
    assert_eq(get(sorted, 0), 8);
    assert_eq(get(sorted, 1), 5);
    assert_eq(get(sorted, 2), 4);
    assert_eq(get(sorted, 3), 3);
    assert_eq(get(sorted, 4), 1);

    print("DIFF_OK: priority_queue");
    0
}
