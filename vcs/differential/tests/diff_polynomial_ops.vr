// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, polynomial, math, horner, calculus
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Evaluate polynomial at x using Horner's method
// coeffs[0] + coeffs[1]*x + coeffs[2]*x^2 + ... + coeffs[n-1]*x^(n-1)
fn poly_eval(coeffs: Arr8, n: Int, x: Int) -> Int {
    if n == 0 { return 0; }
    let mut result = get(coeffs, n - 1);
    let mut i = n - 2;
    while i >= 0 {
        result = result * x + get(coeffs, i);
        i = i - 1;
    }
    result
}

// Compute derivative coefficients: d/dx of a0 + a1*x + a2*x^2 + ...
// = a1 + 2*a2*x + 3*a3*x^2 + ...
fn poly_derivative(coeffs: Arr8, n: Int) -> Arr8 {
    let mut der = zeros();
    if n <= 1 { return der; }
    let mut i = 1;
    while i < n {
        der = set(der, i - 1, i * get(coeffs, i));
        i = i + 1;
    }
    der
}

// Evaluate derivative at x
fn poly_deriv_eval(coeffs: Arr8, n: Int, x: Int) -> Int {
    let der = poly_derivative(coeffs, n);
    let dn = if n <= 1 { 0 } else { n - 1 };
    poly_eval(der, dn, x)
}

// Evaluate definite integral from 0 to x (integer approximation)
// integral of a0 + a1*x + a2*x^2 = a0*x + a1*x^2/2 + a2*x^3/3
// We compute sum(coeffs[i] * x^(i+1) / (i+1)) using integer division
fn poly_integral_eval(coeffs: Arr8, n: Int, x: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        // coeffs[i] * x^(i+1) / (i+1)
        let mut power = 1;
        let mut j = 0;
        while j <= i {
            power = power * x;
            j = j + 1;
        }
        total = total + get(coeffs, i) * power / (i + 1);
        i = i + 1;
    }
    total
}

// Add two polynomials
fn poly_add(a: Arr8, na: Int, b_arr: Arr8, nb: Int) -> Arr8 {
    let mut result = zeros();
    let n = if na > nb { na } else { nb };
    let mut i = 0;
    while i < n {
        let av = if i < na { get(a, i) } else { 0 };
        let bv = if i < nb { get(b_arr, i) } else { 0 };
        result = set(result, i, av + bv);
        i = i + 1;
    }
    result
}

// Polynomial degree (highest non-zero coefficient index + 1, 0 for zero poly)
fn poly_degree(coeffs: Arr8, n: Int) -> Int {
    let mut deg = 0;
    let mut i = 0;
    while i < n {
        if get(coeffs, i) != 0 { deg = i + 1; }
        i = i + 1;
    }
    deg
}

// Multiply two polynomials (result up to 8 coefficients)
fn poly_mul(a: Arr8, na: Int, b_arr: Arr8, nb: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i < na {
        let mut j = 0;
        while j < nb {
            if i + j < 8 {
                let cur = get(result, i + j);
                result = set(result, i + j, cur + get(a, i) * get(b_arr, j));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

fn test_eval_linear() -> Int {
    // p(x) = 3 + 2x
    let p = Arr8 { d0: 3, d1: 2, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(poly_eval(p, 2, 0), 3);
    assert_eq(poly_eval(p, 2, 1), 5);
    assert_eq(poly_eval(p, 2, 5), 13);
    assert_eq(poly_eval(p, 2, -1), 1);
    assert_eq(poly_degree(p, 2), 2);
    0
}

fn test_eval_quadratic() -> Int {
    // p(x) = 1 + 0x + 1x^2 = 1 + x^2
    let p = Arr8 { d0: 1, d1: 0, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(poly_eval(p, 3, 0), 1);
    assert_eq(poly_eval(p, 3, 1), 2);
    assert_eq(poly_eval(p, 3, 2), 5);
    assert_eq(poly_eval(p, 3, 3), 10);
    assert_eq(poly_eval(p, 3, -2), 5);
    0
}

fn test_eval_cubic() -> Int {
    // p(x) = x^3 - 6x^2 + 11x - 6 = (x-1)(x-2)(x-3)
    let p = Arr8 { d0: -6, d1: 11, d2: -6, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(poly_eval(p, 4, 1), 0);
    assert_eq(poly_eval(p, 4, 2), 0);
    assert_eq(poly_eval(p, 4, 3), 0);
    assert_eq(poly_eval(p, 4, 0), -6);
    assert_eq(poly_eval(p, 4, 4), 6);
    0
}

fn test_derivative() -> Int {
    // p(x) = 3 + 2x + 5x^2 => p'(x) = 2 + 10x
    let p = Arr8 { d0: 3, d1: 2, d2: 5, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let der = poly_derivative(p, 3);
    assert_eq(get(der, 0), 2);
    assert_eq(get(der, 1), 10);

    assert_eq(poly_deriv_eval(p, 3, 0), 2);
    assert_eq(poly_deriv_eval(p, 3, 1), 12);
    assert_eq(poly_deriv_eval(p, 3, 3), 32);

    // p(x) = x^3 => p'(x) = 3x^2
    let p2 = Arr8 { d0: 0, d1: 0, d2: 0, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(poly_deriv_eval(p2, 4, 2), 12);
    assert_eq(poly_deriv_eval(p2, 4, 3), 27);
    0
}

fn test_integral() -> Int {
    // integral(2) from 0 to x = 2x => at x=5 => 10
    let c = Arr8 { d0: 2, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(poly_integral_eval(c, 1, 5), 10);

    // integral(3x) from 0 to x = 3x^2/2 => at x=4 => 3*16/2 = 24
    let c2 = Arr8 { d0: 0, d1: 3, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(poly_integral_eval(c2, 2, 4), 24);

    // integral(1 + x) from 0 to 4 = 4 + 16/2 = 4 + 8 = 12
    let c3 = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(poly_integral_eval(c3, 2, 4), 12);
    0
}

fn test_add_and_mul() -> Int {
    // (1 + x) + (2 + 3x) = 3 + 4x
    let a = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let b_arr = Arr8 { d0: 2, d1: 3, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let sum = poly_add(a, 2, b_arr, 2);
    assert_eq(get(sum, 0), 3);
    assert_eq(get(sum, 1), 4);

    // (1 + x) * (1 + x) = 1 + 2x + x^2
    let prod = poly_mul(a, 2, a, 2);
    assert_eq(get(prod, 0), 1);
    assert_eq(get(prod, 1), 2);
    assert_eq(get(prod, 2), 1);
    assert_eq(poly_eval(prod, 3, 5), 36); // (1+5)^2 = 36
    0
}

fn test_mul_verify() -> Int {
    // (1 + x) * (1 - x) = 1 - x^2
    let a = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let b_arr = Arr8 { d0: 1, d1: -1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let prod = poly_mul(a, 2, b_arr, 2);
    assert_eq(get(prod, 0), 1);
    assert_eq(get(prod, 1), 0);
    assert_eq(get(prod, 2), -1);
    assert_eq(poly_eval(prod, 3, 3), -8); // 1 - 9 = -8

    // Zero polynomial
    assert_eq(poly_eval(zeros(), 0, 5), 0);
    assert_eq(poly_degree(zeros(), 4), 0);
    0
}

fn main() -> Int {
    test_eval_linear();
    test_eval_quadratic();
    test_eval_cubic();
    test_derivative();
    test_integral();
    test_add_and_mul();
    test_mul_verify();
    print("DIFF_OK: polynomial_ops");
    0
}
