// @test: differential

// @tier: 0, 3
// @level: L0
// @tags: differential, math, rational, gcd
// @timeout: 10000
// @expected-exit: 0
// @description: Rational number arithmetic with GCD simplification, verify sums and products

fn main() -> Int {
    test_gcd();
    test_rational_add();
    test_rational_mul();
    test_rational_chain();
    0
}

/// Euclidean GCD
fn gcd_val(a: Int, b: Int) -> Int {
    let mut x = if a < 0 { -a } else { a };
    let mut y = if b < 0 { -b } else { b };
    while y != 0 {
        let tmp = y;
        y = x % y;
        x = tmp;
    }
    x
}

/// Verify GCD for known pairs
fn test_gcd() {
    assert_eq(gcd_val(12, 8), 4);
    assert_eq(gcd_val(15, 10), 5);
    assert_eq(gcd_val(7, 13), 1);
    assert_eq(gcd_val(100, 75), 25);
    assert_eq(gcd_val(0, 5), 5);
    assert_eq(gcd_val(17, 17), 17);
    println("gcd: pass");
}

/// Rational add: a/b + c/d = (a*d + c*b) / (b*d), then simplify
fn rat_add_num(an: Int, ad: Int, bn: Int, bd: Int) -> Int {
    let num = an * bd + bn * ad;
    let den = ad * bd;
    let g = gcd_val(num, den);
    num / g
}

fn rat_add_den(an: Int, ad: Int, bn: Int, bd: Int) -> Int {
    let num = an * bd + bn * ad;
    let den = ad * bd;
    let g = gcd_val(num, den);
    den / g
}

/// Test rational addition
fn test_rational_add() {
    // 1/2 + 1/3 = 5/6
    assert_eq(rat_add_num(1, 2, 1, 3), 5);
    assert_eq(rat_add_den(1, 2, 1, 3), 6);

    // 1/4 + 1/4 = 1/2
    assert_eq(rat_add_num(1, 4, 1, 4), 1);
    assert_eq(rat_add_den(1, 4, 1, 4), 2);

    // 2/3 + 1/6 = 5/6
    assert_eq(rat_add_num(2, 3, 1, 6), 5);
    assert_eq(rat_add_den(2, 3, 1, 6), 6);

    // 3/7 + 2/7 = 5/7
    assert_eq(rat_add_num(3, 7, 2, 7), 5);
    assert_eq(rat_add_den(3, 7, 2, 7), 7);
    println("rational_add: pass");
}

/// Rational multiply: a/b * c/d = (a*c) / (b*d), then simplify
fn rat_mul_num(an: Int, ad: Int, bn: Int, bd: Int) -> Int {
    let num = an * bn;
    let den = ad * bd;
    let g = gcd_val(num, den);
    num / g
}

fn rat_mul_den(an: Int, ad: Int, bn: Int, bd: Int) -> Int {
    let num = an * bn;
    let den = ad * bd;
    let g = gcd_val(num, den);
    den / g
}

/// Test rational multiplication
fn test_rational_mul() {
    // 1/2 * 1/3 = 1/6
    assert_eq(rat_mul_num(1, 2, 1, 3), 1);
    assert_eq(rat_mul_den(1, 2, 1, 3), 6);

    // 2/3 * 3/4 = 1/2
    assert_eq(rat_mul_num(2, 3, 3, 4), 1);
    assert_eq(rat_mul_den(2, 3, 3, 4), 2);

    // 5/6 * 3/10 = 1/4
    assert_eq(rat_mul_num(5, 6, 3, 10), 1);
    assert_eq(rat_mul_den(5, 6, 3, 10), 4);
    println("rational_mul: pass");
}

/// Chain of additions: 1/2 + 1/3 + 1/6 = 1/1
fn test_rational_chain() {
    // First: 1/2 + 1/3 = 5/6
    let n1 = rat_add_num(1, 2, 1, 3);
    let d1 = rat_add_den(1, 2, 1, 3);
    assert_eq(n1, 5);
    assert_eq(d1, 6);

    // Then: 5/6 + 1/6 = 1/1
    let n2 = rat_add_num(n1, d1, 1, 6);
    let d2 = rat_add_den(n1, d1, 1, 6);
    assert_eq(n2, 1);
    assert_eq(d2, 1);
    println("rational_chain: pass");
}
