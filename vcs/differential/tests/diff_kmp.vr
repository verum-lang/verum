// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, kmp, string-matching, pattern
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Compute KMP failure function for pattern
fn compute_failure(pat: Arr8, m: Int) -> Arr8 {
    let mut fail = zeros();
    // fail[0] = 0
    let mut i = 1;
    let mut j = 0;
    while i < m {
        if get(pat, i) == get(pat, j) {
            j = j + 1;
            fail = set(fail, i, j);
            i = i + 1;
        } else {
            if j > 0 {
                j = get(fail, j - 1);
            } else {
                fail = set(fail, i, 0);
                i = i + 1;
            }
        }
    }
    fail
}

// KMP search: count occurrences of pattern in text
fn kmp_count(text: Arr8, n: Int, pat: Arr8, m: Int) -> Int {
    if m == 0 { return 0; }
    let fail = compute_failure(pat, m);
    let mut count = 0;
    let mut i = 0;
    let mut j = 0;
    while i < n {
        if get(text, i) == get(pat, j) {
            i = i + 1;
            j = j + 1;
            if j == m {
                count = count + 1;
                j = get(fail, j - 1);
            }
        } else {
            if j > 0 {
                j = get(fail, j - 1);
            } else {
                i = i + 1;
            }
        }
    }
    count
}

// KMP search: first occurrence index (-1 if not found)
fn kmp_find(text: Arr8, n: Int, pat: Arr8, m: Int) -> Int {
    if m == 0 { return -1; }
    let fail = compute_failure(pat, m);
    let mut i = 0;
    let mut j = 0;
    while i < n {
        if get(text, i) == get(pat, j) {
            i = i + 1;
            j = j + 1;
            if j == m { return i - m; }
        } else {
            if j > 0 {
                j = get(fail, j - 1);
            } else {
                i = i + 1;
            }
        }
    }
    -1
}

// Brute force search for cross-check
fn brute_find(text: Arr8, n: Int, pat: Arr8, m: Int) -> Int {
    let mut i = 0;
    while i <= n - m {
        let mut j = 0;
        let mut ok = 1;
        while j < m {
            if get(text, i + j) != get(pat, j) { ok = 0; j = m; }
            else { j = j + 1; }
        }
        if ok == 1 { return i; }
        i = i + 1;
    }
    -1
}

fn brute_count(text: Arr8, n: Int, pat: Arr8, m: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i <= n - m {
        let mut j = 0;
        let mut ok = 1;
        while j < m {
            if get(text, i + j) != get(pat, j) { ok = 0; j = m; }
            else { j = j + 1; }
        }
        if ok == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn main() -> Int {
    // Text: [1,2,1,2,1,3,1,2], Pattern: [1,2,1]
    let text = Arr8 { d0: 1, d1: 2, d2: 1, d3: 2, d4: 1, d5: 3, d6: 1, d7: 2 };
    let pat1 = Arr8 { d0: 1, d1: 2, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };

    assert_eq(kmp_find(text, 8, pat1, 3), 0);
    assert_eq(kmp_count(text, 8, pat1, 3), 2); // at 0 and 2
    // Cross-check with brute force
    assert_eq(brute_find(text, 8, pat1, 3), 0);
    assert_eq(brute_count(text, 8, pat1, 3), 2);

    // Pattern not found
    let pat2 = Arr8 { d0: 9, d1: 9, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(kmp_find(text, 8, pat2, 2), -1);
    assert_eq(brute_find(text, 8, pat2, 2), -1);

    // Pattern = single element
    let pat3 = Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(kmp_count(text, 8, pat3, 1), 4); // positions 0,2,4,6
    assert_eq(brute_count(text, 8, pat3, 1), 4);

    // Failure function for "AABAAB" = [1,1,2,1,1,2]: fail = [0,1,0,1,2,3]
    // Encoded as: A=1, B=2, "AABAA B" = [1,1,2,1,1,2]
    let pat4 = Arr8 { d0: 1, d1: 1, d2: 2, d3: 1, d4: 1, d5: 2, d6: 0, d7: 0 };
    let f4 = compute_failure(pat4, 6);
    assert_eq(get(f4, 0), 0);
    assert_eq(get(f4, 1), 1);
    assert_eq(get(f4, 2), 0);
    assert_eq(get(f4, 3), 1);
    assert_eq(get(f4, 4), 2);
    assert_eq(get(f4, 5), 3);

    // Pattern same as text
    assert_eq(kmp_find(text, 8, text, 8), 0);
    assert_eq(kmp_count(text, 8, text, 8), 1);

    // All same: [1,1,1,1,1], pattern [1,1]
    let all1 = Arr8 { d0: 1, d1: 1, d2: 1, d3: 1, d4: 1, d5: 0, d6: 0, d7: 0 };
    let p11 = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(kmp_count(all1, 5, p11, 2), 4);
    assert_eq(brute_count(all1, 5, p11, 2), 4);

    print("DIFF_OK: kmp");
    0
}
