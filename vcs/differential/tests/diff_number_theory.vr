// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, number-theory, prime, euler
// @timeout: 10000

fn is_prime(n: Int) -> Int {
    if n < 2 { return 0; }
    if n == 2 { return 1; }
    if n % 2 == 0 { return 0; }
    let mut i = 3;
    while i * i <= n {
        if n % i == 0 { return 0; }
        i = i + 2;
    }
    1
}

fn gcd(a: Int, b: Int) -> Int {
    let mut va = a;
    let mut vb = b;
    while vb != 0 {
        let t = vb;
        vb = va % vb;
        va = t;
    }
    va
}

fn lcm(a: Int, b: Int) -> Int {
    (a / gcd(a, b)) * b
}

fn euler_phi(n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i <= n {
        if gcd(i, n) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn count_prime_factors(n: Int) -> Int {
    let mut count = 0;
    let mut v = n;
    let mut d = 2;
    while d * d <= v {
        while v % d == 0 {
            count = count + 1;
            v = v / d;
        }
        d = d + 1;
    }
    if v > 1 { count = count + 1; }
    count
}

fn count_distinct_primes(n: Int) -> Int {
    let mut count = 0;
    let mut v = n;
    let mut d = 2;
    while d * d <= v {
        if v % d == 0 {
            count = count + 1;
            while v % d == 0 { v = v / d; }
        }
        d = d + 1;
    }
    if v > 1 { count = count + 1; }
    count
}

fn sum_divisors(n: Int) -> Int {
    let mut s = 0;
    let mut i = 1;
    while i * i <= n {
        if n % i == 0 {
            s = s + i;
            if i != n / i { s = s + n / i; }
        }
        i = i + 1;
    }
    s
}

fn test_primes() -> Int {
    assert_eq(is_prime(2), 1);
    assert_eq(is_prime(3), 1);
    assert_eq(is_prime(4), 0);
    assert_eq(is_prime(17), 1);
    assert_eq(is_prime(25), 0);
    assert_eq(is_prime(97), 1);
    1
}

fn test_gcd_lcm() -> Int {
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(7, 13), 1);
    assert_eq(gcd(100, 75), 25);
    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(3, 5), 15);
    assert_eq(lcm(12, 8), 24);
    1
}

fn test_euler_phi() -> Int {
    assert_eq(euler_phi(1), 1);
    assert_eq(euler_phi(2), 1);
    assert_eq(euler_phi(6), 2);
    assert_eq(euler_phi(12), 4);
    assert_eq(euler_phi(7), 6);
    assert_eq(euler_phi(13), 12);
    1
}

fn test_factorization() -> Int {
    assert_eq(count_prime_factors(12), 3);
    assert_eq(count_distinct_primes(12), 2);
    assert_eq(count_prime_factors(30), 3);
    assert_eq(count_distinct_primes(30), 3);
    assert_eq(count_prime_factors(64), 6);
    assert_eq(count_distinct_primes(64), 1);
    1
}

fn test_divisor_sum() -> Int {
    assert_eq(sum_divisors(1), 1);
    assert_eq(sum_divisors(6), 12);
    assert_eq(sum_divisors(12), 28);
    assert_eq(sum_divisors(28), 56);
    1
}

fn main() -> Int {
    test_primes();
    test_gcd_lcm();
    test_euler_phi();
    test_factorization();
    test_divisor_sum();
    print("DIFF_OK: number_theory");
    0
}
