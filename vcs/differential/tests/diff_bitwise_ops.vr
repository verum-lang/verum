// @test: differential

// @tier: 0
// @level: L0
// @tags: vbc, differential, bitwise, shift, and, or, xor, not
// @timeout: 10000
// @expected-exit: 0
//
// Differential test: bitwise operations must produce identical results
// in interpreter and AOT

fn bnot(x: Int) -> Int { !x }

fn test_and() {
    assert_eq(0xFF & 0x0F, 0x0F);
    assert_eq(0xAA & 0x55, 0x00);
    assert_eq(12 & 10, 8);
    assert_eq(7 & 3, 3);
}

fn test_or() {
    assert_eq(0xF0 | 0x0F, 0xFF);
    assert_eq(0xAA | 0x55, 0xFF);
    assert_eq(12 | 10, 14);
}

fn test_xor() {
    assert_eq(0xFF ^ 0xFF, 0x00);
    assert_eq(12 ^ 10, 6);
    let x = 42;
    assert_eq(x ^ x, 0);
}

fn test_shifts() {
    assert_eq(1 << 0, 1);
    assert_eq(1 << 4, 16);
    assert_eq(1 << 10, 1024);
    assert_eq(16 >> 2, 4);
    assert_eq(255 >> 4, 15);
}

fn test_bitwise_not() {
    assert_eq(bnot(0), -1);
    assert_eq(bnot(-1), 0);
    assert_eq(bnot(1), -2);
    assert_eq(bnot(42), -43);
    assert_eq(bnot(bnot(12345)), 12345);
}

fn test_combined() {
    let val = 0xABCD;
    assert_eq(val & 0xFF, 0xCD);
    assert_eq((val >> 8) & 0xFF, 0xAB);
    // Set bit 3
    assert_eq(0 | (1 << 3), 8);
    // XOR swap
    let mut a = 42;
    let mut b = 99;
    a = a ^ b;
    b = a ^ b;
    a = a ^ b;
    assert_eq(a, 99);
    assert_eq(b, 42);
}

fn main() -> Int {
    test_and();
    test_or();
    test_xor();
    test_shifts();
    test_bitwise_not();
    test_combined();
    print("differential bitwise ops ok");
    0
}
