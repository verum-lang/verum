// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, diophantine, number-theory
// @timeout: 10000

fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }

fn gcd(a: Int, b: Int) -> Int {
    let mut x = abs_val(a);
    let mut y = abs_val(b);
    while y != 0 { let t = y; y = x % y; x = t; }
    x
}

// Extended Euclidean: returns (g, x, y) where a*x + b*y = g
// We return g, x, y packed as separate return values via helper
type ExtGcd is { g: Int, x: Int, y: Int };

fn ext_gcd_helper(a: Int, b: Int, g_out: Int, x_out: Int, y_out: Int) -> Int {
    // Returns g, sets x_out, y_out via the ExtGcd record
    0
}

// Iterative extended GCD
fn ext_gcd(a: Int, b: Int) -> ExtGcd {
    let mut old_r = a; let mut r = b;
    let mut old_s = 1; let mut s = 0;
    let mut old_t = 0; let mut t = 1;
    while r != 0 {
        let q = old_r / r;
        let temp_r = r; r = old_r - q * r; old_r = temp_r;
        let temp_s = s; s = old_s - q * s; old_s = temp_s;
        let temp_t = t; t = old_t - q * t; old_t = temp_t;
    }
    ExtGcd { g: old_r, x: old_s, y: old_t }
}

fn ext_gcd_g(a: Int, b: Int) -> Int {
    let r = ext_gcd(a, b);
    r.g
}

fn ext_gcd_x(a: Int, b: Int) -> Int {
    let r = ext_gcd(a, b);
    r.x
}

fn ext_gcd_y(a: Int, b: Int) -> Int {
    let r = ext_gcd(a, b);
    r.y
}

// Solve a*x + b*y = c (has solution iff gcd(a,b) | c)
fn has_solution(a: Int, b: Int, c: Int) -> Int {
    let g = gcd(a, b);
    if c % g == 0 { 1 } else { 0 }
}

// Count lattice points in circle x^2 + y^2 <= r^2
fn lattice_points_in_circle(r: Int) -> Int {
    let r2 = r * r;
    let mut count = 0;
    let mut x = -r;
    while x <= r {
        let mut y = -r;
        while y <= r {
            if x * x + y * y <= r2 {
                count = count + 1;
            }
            y = y + 1;
        }
        x = x + 1;
    }
    count
}

fn main() -> Int {
    // Extended GCD: gcd(12, 18) = 6
    assert_eq(ext_gcd_g(12, 18), 6);
    // Verify: 12*x + 18*y = 6
    let x1 = ext_gcd_x(12, 18);
    let y1 = ext_gcd_y(12, 18);
    assert_eq(12 * x1 + 18 * y1, 6);

    // gcd(35, 15) = 5
    assert_eq(ext_gcd_g(35, 15), 5);
    let x2 = ext_gcd_x(35, 15);
    let y2 = ext_gcd_y(35, 15);
    assert_eq(35 * x2 + 15 * y2, 5);

    // gcd(17, 13) = 1 (coprime)
    assert_eq(ext_gcd_g(17, 13), 1);
    let x3 = ext_gcd_x(17, 13);
    let y3 = ext_gcd_y(17, 13);
    assert_eq(17 * x3 + 13 * y3, 1);

    // Diophantine solvability
    assert_eq(has_solution(6, 9, 3), 1);   // gcd=3, 3|3
    assert_eq(has_solution(6, 9, 4), 0);   // gcd=3, 3∤4
    assert_eq(has_solution(6, 9, 12), 1);  // gcd=3, 3|12
    assert_eq(has_solution(1, 1, 100), 1); // gcd=1, always solvable

    // Lattice points: circle of radius 0 → 1 point
    assert_eq(lattice_points_in_circle(0), 1);
    // Radius 1: (0,0), (±1,0), (0,±1) = 5
    assert_eq(lattice_points_in_circle(1), 5);
    // Radius 2: known = 13
    assert_eq(lattice_points_in_circle(2), 13);
    // Radius 3: known = 29
    assert_eq(lattice_points_in_circle(3), 29);
    // Radius 5: known = 81
    assert_eq(lattice_points_in_circle(5), 81);

    print("DIFF_OK: diophantine");
    0
}
