// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, collatz, sequence
// @timeout: 10000

fn collatz_length(n: Int) -> Int {
    let mut x = n;
    let mut steps = 0;
    while x != 1 {
        if x % 2 == 0 { x = x / 2; }
        else { x = 3 * x + 1; }
        steps = steps + 1;
    }
    steps
}

fn main() -> Int {
    assert_eq(collatz_length(1), 0);
    assert_eq(collatz_length(2), 1);
    assert_eq(collatz_length(3), 7);
    assert_eq(collatz_length(27), 111);

    // Total steps for 1..20
    let mut total = 0;
    let mut i = 1;
    while i <= 20 {
        total = total + collatz_length(i);
        i = i + 1;
    }
    assert_eq(total > 0, true);
    print("DIFF_OK: collatz");
    0
}
