// @test: differential

// @level: L0
// @tags: differential, heap, sort, priority-queue
// @timeout: 30000

// Differential test: Min-heap operations and heap sort

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn swap8(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = get8(a, i);
    let vj = get8(a, j);
    set8(set8(a, i, vj), j, vi)
}

fn sift_down(arr: Arr8, i: Int, size: Int) -> Arr8 {
    let mut a = arr;
    let mut idx = i;
    let mut cont = 1;
    while cont == 1 {
        let left = 2 * idx + 1;
        let right = 2 * idx + 2;
        let mut smallest = idx;
        if left < size {
            if get8(a, left) < get8(a, smallest) { smallest = left; }
        }
        if right < size {
            if get8(a, right) < get8(a, smallest) { smallest = right; }
        }
        if smallest != idx {
            a = swap8(a, idx, smallest);
            idx = smallest;
        } else {
            cont = 0;
        }
    }
    a
}

fn heapify(arr: Arr8, size: Int) -> Arr8 {
    let mut a = arr;
    let mut i = size / 2 - 1;
    while i >= 0 {
        a = sift_down(a, i, size);
        i = i - 1;
    }
    a
}

fn is_min_heap(arr: Arr8, size: Int) -> Int {
    let mut i = 0;
    while i < size {
        let left = 2 * i + 1;
        let right = 2 * i + 2;
        if left < size {
            if get8(arr, left) < get8(arr, i) { return 0; }
        }
        if right < size {
            if get8(arr, right) < get8(arr, i) { return 0; }
        }
        i = i + 1;
    }
    1
}

fn heap_extract_arr(arr: Arr8, size: Int) -> Arr8 {
    let a = set8(arr, 0, get8(arr, size - 1));
    sift_down(a, 0, size - 1)
}

fn heap_sort(arr: Arr8, size: Int) -> Arr8 {
    let mut a = heapify(arr, size);
    let mut result = zeros();
    let mut s = size;
    let mut ri = 0;
    while s > 0 {
        result = set8(result, ri, get8(a, 0));
        a = heap_extract_arr(a, s);
        s = s - 1;
        ri = ri + 1;
    }
    result
}

fn main() -> Int {
    // Heapify
    let arr = Arr8 { v0: 9, v1: 4, v2: 7, v3: 1, v4: 3, v5: 6, v6: 2, v7: 8 };
    let h = heapify(arr, 8);
    assert_eq(is_min_heap(h, 8), 1);
    assert_eq(get8(h, 0), 1); // min at root

    // Heap sort
    let sorted = heap_sort(arr, 8);
    // arr = {9,4,7,1,3,6,2,8}, sorted = {1,2,3,4,6,7,8,9}
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 1), 2);
    assert_eq(get8(sorted, 2), 3);
    assert_eq(get8(sorted, 3), 4);
    assert_eq(get8(sorted, 4), 6);
    assert_eq(get8(sorted, 5), 7);
    assert_eq(get8(sorted, 6), 8);
    assert_eq(get8(sorted, 7), 9);

    // Sort already sorted
    let sorted2 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let res2 = heap_sort(sorted2, 8);
    assert_eq(get8(res2, 0), 1);
    assert_eq(get8(res2, 7), 8);

    // Sort reverse
    let rev = Arr8 { v0: 8, v1: 7, v2: 6, v3: 5, v4: 4, v5: 3, v6: 2, v7: 1 };
    let res3 = heap_sort(rev, 8);
    assert_eq(get8(res3, 0), 1);
    assert_eq(get8(res3, 7), 8);

    // Sort with duplicates
    let dup = Arr8 { v0: 3, v1: 1, v2: 3, v3: 1, v4: 2, v5: 2, v6: 4, v7: 4 };
    let res4 = heap_sort(dup, 8);
    assert_eq(get8(res4, 0), 1);
    assert_eq(get8(res4, 1), 1);
    assert_eq(get8(res4, 2), 2);
    assert_eq(get8(res4, 3), 2);
    assert_eq(get8(res4, 4), 3);
    assert_eq(get8(res4, 5), 3);

    print("[OK] diff_heap_sort");
    0
}
