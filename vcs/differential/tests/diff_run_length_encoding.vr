// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, rle, compression, encoding
// @timeout: 10000

type Arr16 is {
    d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int,
    d8: Int, d9: Int, d10: Int, d11: Int, d12: Int, d13: Int, d14: Int, d15: Int
};

fn get16(a: Arr16, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else if i == 7 { a.d7 } else if i == 8 { a.d8 }
    else if i == 9 { a.d9 } else if i == 10 { a.d10 } else if i == 11 { a.d11 }
    else if i == 12 { a.d12 } else if i == 13 { a.d13 } else if i == 14 { a.d14 }
    else { a.d15 }
}

fn set16(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 },
        d8: if i == 8 { v } else { a.d8 }, d9: if i == 9 { v } else { a.d9 },
        d10: if i == 10 { v } else { a.d10 }, d11: if i == 11 { v } else { a.d11 },
        d12: if i == 12 { v } else { a.d12 }, d13: if i == 13 { v } else { a.d13 },
        d14: if i == 14 { v } else { a.d14 }, d15: if i == 15 { v } else { a.d15 }
    }
}

fn zeros16() -> Arr16 {
    Arr16 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0,
            d8: 0, d9: 0, d10: 0, d11: 0, d12: 0, d13: 0, d14: 0, d15: 0 }
}

// RLE encode: input is data[0..n-1], output is pairs (value, count) in encoded[0..2*k-1]
// Returns number of runs
type RleResult is { encoded: Arr16, num_runs: Int };

fn rle_encode(data: Arr16, n: Int) -> RleResult {
    if n == 0 { return RleResult { encoded: zeros16(), num_runs: 0 }; }
    let mut encoded = zeros16();
    let mut runs = 0;
    let mut current = get16(data, 0);
    let mut count = 1;
    let mut i = 1;
    while i < n {
        let v = get16(data, i);
        if v == current {
            count = count + 1;
        } else {
            encoded = set16(encoded, runs * 2, current);
            encoded = set16(encoded, runs * 2 + 1, count);
            runs = runs + 1;
            current = v;
            count = 1;
        }
        i = i + 1;
    }
    // Last run
    encoded = set16(encoded, runs * 2, current);
    encoded = set16(encoded, runs * 2 + 1, count);
    runs = runs + 1;
    RleResult { encoded: encoded, num_runs: runs }
}

// RLE decode: from encoded pairs to original array
// Returns decoded length
fn rle_decode(encoded: Arr16, num_runs: Int) -> Arr16 {
    let mut decoded = zeros16();
    let mut pos = 0;
    let mut r = 0;
    while r < num_runs {
        let val = get16(encoded, r * 2);
        let cnt = get16(encoded, r * 2 + 1);
        let mut c = 0;
        while c < cnt {
            decoded = set16(decoded, pos, val);
            pos = pos + 1;
            c = c + 1;
        }
        r = r + 1;
    }
    decoded
}

fn rle_decoded_length(encoded: Arr16, num_runs: Int) -> Int {
    let mut total = 0;
    let mut r = 0;
    while r < num_runs {
        total = total + get16(encoded, r * 2 + 1);
        r = r + 1;
    }
    total
}

// Compression ratio: encoded_size / original_size (as percentage * 100)
fn compression_pct(num_runs: Int, original_len: Int) -> Int {
    if original_len == 0 { return 0; }
    (num_runs * 2 * 100) / original_len
}

fn main() -> Int {
    // All same: [5,5,5,5,5] → 1 run: (5,5)
    let data1 = set16(set16(set16(set16(set16(zeros16(), 0, 5), 1, 5), 2, 5), 3, 5), 4, 5);
    let r1 = rle_encode(data1, 5);
    assert_eq(r1.num_runs, 1);
    assert_eq(get16(r1.encoded, 0), 5);  // value
    assert_eq(get16(r1.encoded, 1), 5);  // count
    assert_eq(rle_decoded_length(r1.encoded, r1.num_runs), 5);
    assert_eq(compression_pct(r1.num_runs, 5), 40); // 2/5 = 40%

    // All different: [1,2,3,4] → 4 runs
    let mut data2 = zeros16();
    data2 = set16(data2, 0, 1);
    data2 = set16(data2, 1, 2);
    data2 = set16(data2, 2, 3);
    data2 = set16(data2, 3, 4);
    let r2 = rle_encode(data2, 4);
    assert_eq(r2.num_runs, 4);
    assert_eq(compression_pct(r2.num_runs, 4), 200); // worse than original

    // Mixed: [1,1,2,2,2,3] → 3 runs: (1,2),(2,3),(3,1)
    let mut data3 = zeros16();
    data3 = set16(data3, 0, 1);
    data3 = set16(data3, 1, 1);
    data3 = set16(data3, 2, 2);
    data3 = set16(data3, 3, 2);
    data3 = set16(data3, 4, 2);
    data3 = set16(data3, 5, 3);
    let r3 = rle_encode(data3, 6);
    assert_eq(r3.num_runs, 3);
    assert_eq(get16(r3.encoded, 0), 1); assert_eq(get16(r3.encoded, 1), 2);
    assert_eq(get16(r3.encoded, 2), 2); assert_eq(get16(r3.encoded, 3), 3);
    assert_eq(get16(r3.encoded, 4), 3); assert_eq(get16(r3.encoded, 5), 1);

    // Round-trip: decode should match original
    let decoded3 = rle_decode(r3.encoded, r3.num_runs);
    let mut i = 0;
    while i < 6 {
        assert_eq(get16(decoded3, i), get16(data3, i));
        i = i + 1;
    }

    // Single element
    let data4 = set16(zeros16(), 0, 42);
    let r4 = rle_encode(data4, 1);
    assert_eq(r4.num_runs, 1);
    assert_eq(get16(r4.encoded, 0), 42);
    assert_eq(get16(r4.encoded, 1), 1);

    // Empty
    let r5 = rle_encode(zeros16(), 0);
    assert_eq(r5.num_runs, 0);

    print("DIFF_OK: run_length_encoding");
    0
}
