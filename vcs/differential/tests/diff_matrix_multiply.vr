// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, matrix-multiply, linear-algebra
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// 2x2 matrix stored as [a,b,c,d] meaning [[a,b],[c,d]]
fn mat2_get(m: Arr8, row: Int, col: Int) -> Int { get(m, row * 2 + col) }

fn mat2_mul(a: Arr8, b: Arr8) -> Arr8 {
    let r00 = mat2_get(a, 0, 0) * mat2_get(b, 0, 0) + mat2_get(a, 0, 1) * mat2_get(b, 1, 0);
    let r01 = mat2_get(a, 0, 0) * mat2_get(b, 0, 1) + mat2_get(a, 0, 1) * mat2_get(b, 1, 1);
    let r10 = mat2_get(a, 1, 0) * mat2_get(b, 0, 0) + mat2_get(a, 1, 1) * mat2_get(b, 1, 0);
    let r11 = mat2_get(a, 1, 0) * mat2_get(b, 0, 1) + mat2_get(a, 1, 1) * mat2_get(b, 1, 1);
    Arr8 { d0: r00, d1: r01, d2: r10, d3: r11, d4: 0, d5: 0, d6: 0, d7: 0 }
}

fn mat2_add(a: Arr8, b: Arr8) -> Arr8 {
    Arr8 {
        d0: get(a, 0) + get(b, 0), d1: get(a, 1) + get(b, 1),
        d2: get(a, 2) + get(b, 2), d3: get(a, 3) + get(b, 3),
        d4: 0, d5: 0, d6: 0, d7: 0
    }
}

fn mat2_det(m: Arr8) -> Int {
    mat2_get(m, 0, 0) * mat2_get(m, 1, 1) - mat2_get(m, 0, 1) * mat2_get(m, 1, 0)
}

fn mat2_trace(m: Arr8) -> Int {
    mat2_get(m, 0, 0) + mat2_get(m, 1, 1)
}

fn mat2_transpose(m: Arr8) -> Arr8 {
    Arr8 { d0: get(m, 0), d1: get(m, 2), d2: get(m, 1), d3: get(m, 3), d4: 0, d5: 0, d6: 0, d7: 0 }
}

// Identity matrix
fn mat2_id() -> Arr8 {
    Arr8 { d0: 1, d1: 0, d2: 0, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 }
}

// Matrix power
fn mat2_pow(m: Arr8, n: Int) -> Arr8 {
    let mut result = mat2_id();
    let mut base = m;
    let mut exp = n;
    while exp > 0 {
        if exp % 2 == 1 { result = mat2_mul(result, base); }
        base = mat2_mul(base, base);
        exp = exp / 2;
    }
    result
}

fn main() -> Int {
    let id = mat2_id();

    // A = [[1,2],[3,4]]
    let a = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 0, d5: 0, d6: 0, d7: 0 };
    // B = [[5,6],[7,8]]
    let b = Arr8 { d0: 5, d1: 6, d2: 7, d3: 8, d4: 0, d5: 0, d6: 0, d7: 0 };

    // A * I = A
    let ai = mat2_mul(a, id);
    assert_eq(get(ai, 0), 1);
    assert_eq(get(ai, 1), 2);
    assert_eq(get(ai, 2), 3);
    assert_eq(get(ai, 3), 4);

    // A * B = [[1*5+2*7, 1*6+2*8], [3*5+4*7, 3*6+4*8]] = [[19,22],[43,50]]
    let ab = mat2_mul(a, b);
    assert_eq(get(ab, 0), 19);
    assert_eq(get(ab, 1), 22);
    assert_eq(get(ab, 2), 43);
    assert_eq(get(ab, 3), 50);

    // det(A) = 1*4-2*3 = -2
    assert_eq(mat2_det(a), -2);

    // det(AB) = det(A)*det(B) = (-2)*(-2) = 4
    assert_eq(mat2_det(b), -2);
    assert_eq(mat2_det(ab), 4);
    assert_eq(mat2_det(a) * mat2_det(b), mat2_det(ab));

    // Trace
    assert_eq(mat2_trace(a), 5);
    assert_eq(mat2_trace(id), 2);

    // tr(A+B) = tr(A) + tr(B)
    let apb = mat2_add(a, b);
    assert_eq(mat2_trace(apb), mat2_trace(a) + mat2_trace(b));

    // Transpose
    let at = mat2_transpose(a);
    assert_eq(get(at, 0), 1);
    assert_eq(get(at, 1), 3);
    assert_eq(get(at, 2), 2);
    assert_eq(get(at, 3), 4);

    // det(A^T) = det(A)
    assert_eq(mat2_det(at), mat2_det(a));

    // Matrix power: Fibonacci via [[1,1],[1,0]]^n
    let fib_mat = Arr8 { d0: 1, d1: 1, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let f5 = mat2_pow(fib_mat, 5);
    assert_eq(get(f5, 0), 8);  // F(6)
    assert_eq(get(f5, 1), 5);  // F(5)

    let f10 = mat2_pow(fib_mat, 10);
    assert_eq(get(f10, 1), 55); // F(10)

    // A^0 = I
    let a0 = mat2_pow(a, 0);
    assert_eq(get(a0, 0), 1);
    assert_eq(get(a0, 3), 1);

    print("DIFF_OK: matrix_multiply");
    0
}
