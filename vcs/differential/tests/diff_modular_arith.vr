// @test: differential

// @level: L0
// @tags: differential, modular, arithmetic, number-theory
// @timeout: 30000

// Modular arithmetic operations

fn mod_add(a: Int, b: Int, m: Int) -> Int { (a % m + b % m) % m }
fn mod_sub(a: Int, b: Int, m: Int) -> Int { ((a % m - b % m) + m) % m }
fn mod_mul(a: Int, b: Int, m: Int) -> Int { (a % m) * (b % m) % m }

fn mod_pow(base: Int, exp: Int, m: Int) -> Int {
    let mut result = 1;
    let mut b = base % m;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 { result = result * b % m; }
        b = b * b % m;
        e = e / 2;
    }
    result
}

fn mod_inverse(a: Int, m: Int) -> Int {
    let mut old_r = a;
    let mut r = m;
    let mut old_s = 1;
    let mut s = 0;
    while r != 0 {
        let q = old_r / r;
        let tmp_r = r;
        r = old_r - q * r;
        old_r = tmp_r;
        let tmp_s = s;
        s = old_s - q * s;
        old_s = tmp_s;
    }
    if old_r != 1 { return -1; }
    (old_s % m + m) % m
}

fn fermat_check(a: Int, p: Int) -> Int { mod_pow(a, p - 1, p) }

fn euler_phi(n: Int) -> Int {
    let mut result = n;
    let mut p = 2;
    let mut tmp = n;
    while p * p <= tmp {
        if tmp % p == 0 {
            while tmp % p == 0 { tmp = tmp / p; }
            result = result / p * (p - 1);
        }
        p = p + 1;
    }
    if tmp > 1 { result = result / tmp * (tmp - 1); }
    result
}

fn euler_check(a: Int, n: Int) -> Int {
    let phi = euler_phi(n);
    mod_pow(a, phi, n)
}

fn test_mod_arith() -> Int {
    assert_eq(mod_add(7, 8, 10), 5);
    assert_eq(mod_sub(3, 7, 10), 6);
    assert_eq(mod_mul(6, 7, 10), 2);
    assert_eq(mod_pow(2, 10, 1000), 24);
    assert_eq(mod_pow(3, 5, 100), 43);
    1
}

fn test_mod_inverse() -> Int {
    assert_eq(mod_inverse(3, 10), 7);
    assert_eq(mod_inverse(2, 7), 4);
    assert_eq(mod_inverse(5, 10), -1);
    1
}

fn test_fermat() -> Int {
    assert_eq(fermat_check(2, 7), 1);
    assert_eq(fermat_check(3, 7), 1);
    assert_eq(fermat_check(5, 7), 1);
    assert_eq(fermat_check(2, 13), 1);
    assert_eq(fermat_check(7, 13), 1);
    1
}

fn test_euler() -> Int {
    assert_eq(euler_phi(1), 1);
    assert_eq(euler_phi(7), 6);
    assert_eq(euler_phi(10), 4);
    assert_eq(euler_phi(12), 4);
    assert_eq(euler_check(3, 10), 1);
    assert_eq(euler_check(7, 10), 1);
    assert_eq(euler_check(7, 12), 1);
    1
}

fn main() -> Int {
    test_mod_arith();
    test_mod_inverse();
    test_fermat();
    test_euler();
    print("[OK] diff_modular_arith");
    0
}
