// @test: differential

// @level: L0
// @tags: differential, dynamic-programming, dp
// @timeout: 30000

// Classic DP problems: stairs, coin change, rod cutting, LIS

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 {
    Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
}

fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Climbing stairs: ways to climb n stairs taking 1 or 2 steps
fn climb_stairs(n: Int) -> Int {
    if n <= 1 { return 1; }
    let mut a = 1;
    let mut b = 1;
    let mut i = 2;
    while i <= n {
        let c = a + b;
        a = b;
        b = c;
        i = i + 1;
    }
    b
}

// Minimum coin change: min coins to make amount using coins[0..n]
fn min_coins(coins: Arr8, n: Int, amount: Int) -> Int {
    // dp[i] = min coins for amount i
    let mut dp = Arr8 { v0: 0, v1: 999, v2: 999, v3: 999, v4: 999, v5: 999, v6: 999, v7: 999 };
    let mut amt = 1;
    while amt <= amount {
        let mut best = 999;
        let mut c = 0;
        while c < n {
            let coin = get8(coins, c);
            if coin <= amt {
                let prev = get8(dp, amt - coin);
                if prev + 1 < best { best = prev + 1; }
            }
            c = c + 1;
        }
        dp = set8(dp, amt, best);
        amt = amt + 1;
    }
    get8(dp, amount)
}

// Rod cutting: maximize revenue from rod of length n
// prices[i] = price for rod of length i+1
fn rod_cutting(prices: Arr8, n: Int) -> Int {
    let mut dp = zeros();
    let mut i = 1;
    while i <= n {
        let mut best = 0;
        let mut j = 0;
        while j < i {
            let val = get8(prices, j) + get8(dp, i - j - 1);
            if val > best { best = val; }
            j = j + 1;
        }
        dp = set8(dp, i, best);
        i = i + 1;
    }
    get8(dp, n)
}

// LIS length (O(n^2))
fn lis_length(arr: Arr8, n: Int) -> Int {
    let mut dp = Arr8 { v0: 1, v1: 1, v2: 1, v3: 1, v4: 1, v5: 1, v6: 1, v7: 1 };
    let mut best = 1;
    let mut i = 1;
    while i < n {
        let mut j = 0;
        while j < i {
            if get8(arr, j) < get8(arr, i) {
                let val = get8(dp, j) + 1;
                if val > get8(dp, i) { dp = set8(dp, i, val); }
            }
            j = j + 1;
        }
        if get8(dp, i) > best { best = get8(dp, i); }
        i = i + 1;
    }
    best
}

// Maximum non-adjacent sum (house robber)
fn max_non_adjacent(arr: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    if n == 1 { return get8(arr, 0); }
    let mut prev2 = get8(arr, 0);
    let mut prev1 = max_val(get8(arr, 0), get8(arr, 1));
    let mut i = 2;
    while i < n {
        let curr = max_val(prev1, prev2 + get8(arr, i));
        prev2 = prev1;
        prev1 = curr;
        i = i + 1;
    }
    prev1
}

fn main() -> Int {
    // Climbing stairs (Fibonacci-like)
    assert_eq(climb_stairs(1), 1);
    assert_eq(climb_stairs(2), 2);
    assert_eq(climb_stairs(3), 3);
    assert_eq(climb_stairs(4), 5);
    assert_eq(climb_stairs(5), 8);
    assert_eq(climb_stairs(6), 13);

    // Min coins: coins = [1, 3, 4]
    let coins = Arr8 { v0: 1, v1: 3, v2: 4, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(min_coins(coins, 3, 6), 2);  // 3+3
    assert_eq(min_coins(coins, 3, 7), 2);  // 3+4
    assert_eq(min_coins(coins, 3, 1), 1);  // 1

    // Coins = [1, 5, 6]
    let coins2 = Arr8 { v0: 1, v1: 5, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(min_coins(coins2, 3, 7), 2);  // 1+6

    // Rod cutting: prices = [1, 5, 8, 9, 10, 17, 17, 20]
    let prices = Arr8 { v0: 1, v1: 5, v2: 8, v3: 9, v4: 10, v5: 17, v6: 17, v7: 20 };
    assert_eq(rod_cutting(prices, 1), 1);
    assert_eq(rod_cutting(prices, 2), 5);   // cut into 2 pieces of 1 each? No, price[1]=5
    assert_eq(rod_cutting(prices, 4), 10);  // two pieces of length 2: 5+5=10
    assert_eq(rod_cutting(prices, 7), 18);  // dp[7]: best is 18 (multiple options)
    assert_eq(rod_cutting(prices, 6), 17);  // length 6: price=17

    // LIS
    let arr = Arr8 { v0: 10, v1: 9, v2: 2, v3: 5, v4: 3, v5: 7, v6: 101, v7: 18 };
    assert_eq(lis_length(arr, 8), 4); // [2,5,7,101] or [2,3,7,101] or [2,5,7,18]

    let arr2 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    assert_eq(lis_length(arr2, 8), 8); // already sorted

    let arr3 = Arr8 { v0: 8, v1: 7, v2: 6, v3: 5, v4: 4, v5: 3, v6: 2, v7: 1 };
    assert_eq(lis_length(arr3, 8), 1); // decreasing

    // House robber
    let houses = Arr8 { v0: 2, v1: 7, v2: 9, v3: 3, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_non_adjacent(houses, 5), 12); // 2+9+1=12
    let houses2 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_non_adjacent(houses2, 4), 4); // 1+3=4

    print("[OK] diff_dp_classic");
    0
}
