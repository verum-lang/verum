// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, sequences, arithmetic, geometric, harmonic
// @timeout: 10000

// Mathematical sequences: arithmetic sums, geometric series,
// alternating series, triangular/pentagonal numbers.

// Sum of first n natural numbers: n*(n+1)/2
fn sum_naturals(n: Int) -> Int {
    n * (n + 1) / 2
}

// Iterative verification of sum of first n naturals
fn sum_naturals_iter(n: Int) -> Int {
    let mut s = 0;
    let mut i = 1;
    while i <= n {
        s = s + i;
        i = i + 1;
    }
    s
}

// Sum of squares: n*(n+1)*(2n+1)/6
fn sum_squares(n: Int) -> Int {
    n * (n + 1) * (2 * n + 1) / 6
}

fn sum_squares_iter(n: Int) -> Int {
    let mut s = 0;
    let mut i = 1;
    while i <= n {
        s = s + i * i;
        i = i + 1;
    }
    s
}

// Sum of cubes: (n*(n+1)/2)^2
fn sum_cubes(n: Int) -> Int {
    let half = n * (n + 1) / 2;
    half * half
}

fn sum_cubes_iter(n: Int) -> Int {
    let mut s = 0;
    let mut i = 1;
    while i <= n {
        s = s + i * i * i;
        i = i + 1;
    }
    s
}

// Geometric series sum: a * (r^n - 1) / (r - 1) for r != 1
// We compute iteratively to avoid needing pow and handle integer division
fn geometric_sum(a: Int, r: Int, n: Int) -> Int {
    let mut s = 0;
    let mut term = a;
    let mut i = 0;
    while i < n {
        s = s + term;
        term = term * r;
        i = i + 1;
    }
    s
}

// Alternating series: a0 - a1 + a2 - a3 + ...
// Using natural numbers: 1 - 2 + 3 - 4 + ... + (-1)^(n-1) * n
fn alternating_naturals(n: Int) -> Int {
    let mut s = 0;
    let mut i = 1;
    let mut sign = 1;
    while i <= n {
        s = s + sign * i;
        sign = 0 - sign;
        i = i + 1;
    }
    s
}

// Triangular number: T(n) = n*(n+1)/2
fn triangular(n: Int) -> Int {
    n * (n + 1) / 2
}

// Pentagonal number: P(n) = n*(3n-1)/2
fn pentagonal(n: Int) -> Int {
    n * (3 * n - 1) / 2
}

// Arithmetic progression sum: n terms, first=a, common diff=d
// S = n*(2a + (n-1)*d)/2
fn arith_prog_sum(a: Int, d: Int, n: Int) -> Int {
    n * (2 * a + (n - 1) * d) / 2
}

fn arith_prog_sum_iter(a: Int, d: Int, n: Int) -> Int {
    let mut s = 0;
    let mut term = a;
    let mut i = 0;
    while i < n {
        s = s + term;
        term = term + d;
        i = i + 1;
    }
    s
}

// n-th term of arithmetic progression
fn arith_nth(a: Int, d: Int, n: Int) -> Int {
    a + (n - 1) * d
}

fn test_natural_sums() -> Int {
    assert_eq(sum_naturals(1), 1);
    assert_eq(sum_naturals(10), 55);
    assert_eq(sum_naturals(100), 5050);
    assert_eq(sum_naturals_iter(10), 55);
    assert_eq(sum_naturals_iter(100), 5050);
    assert_eq(sum_naturals(10), sum_naturals_iter(10));
    1
}

fn test_sum_squares() -> Int {
    assert_eq(sum_squares(1), 1);
    assert_eq(sum_squares(3), 14);
    assert_eq(sum_squares(5), 55);
    assert_eq(sum_squares(10), 385);
    assert_eq(sum_squares_iter(10), 385);
    assert_eq(sum_squares(10), sum_squares_iter(10));
    1
}

fn test_sum_cubes() -> Int {
    assert_eq(sum_cubes(1), 1);
    assert_eq(sum_cubes(3), 36);
    assert_eq(sum_cubes(5), 225);
    assert_eq(sum_cubes(10), 3025);
    assert_eq(sum_cubes_iter(10), 3025);
    assert_eq(sum_cubes(10), sum_cubes_iter(10));
    1
}

fn test_geometric() -> Int {
    // 1 + 2 + 4 + 8 = 15
    assert_eq(geometric_sum(1, 2, 4), 15);
    // 1 + 3 + 9 + 27 = 40
    assert_eq(geometric_sum(1, 3, 4), 40);
    // 2 + 6 + 18 = 26
    assert_eq(geometric_sum(2, 3, 3), 26);
    // Single term
    assert_eq(geometric_sum(5, 10, 1), 5);
    1
}

fn test_alternating() -> Int {
    // 1 = 1
    assert_eq(alternating_naturals(1), 1);
    // 1 - 2 = -1
    assert_eq(alternating_naturals(2), -1);
    // 1 - 2 + 3 = 2
    assert_eq(alternating_naturals(3), 2);
    // 1 - 2 + 3 - 4 = -2
    assert_eq(alternating_naturals(4), -2);
    // 1 - 2 + 3 - 4 + 5 = 3
    assert_eq(alternating_naturals(5), 3);
    // For even n, result = -n/2; for odd n, result = (n+1)/2
    assert_eq(alternating_naturals(10), -5);
    1
}

fn test_figurate() -> Int {
    // Triangular: 1, 3, 6, 10, 15, 21
    assert_eq(triangular(1), 1);
    assert_eq(triangular(2), 3);
    assert_eq(triangular(3), 6);
    assert_eq(triangular(4), 10);
    assert_eq(triangular(6), 21);
    1
}

fn test_pentagonal() -> Int {
    // Pentagonal: 1, 5, 12, 22, 35, 51
    assert_eq(pentagonal(1), 1);
    assert_eq(pentagonal(2), 5);
    assert_eq(pentagonal(3), 12);
    assert_eq(pentagonal(4), 22);
    assert_eq(pentagonal(5), 35);
    assert_eq(pentagonal(6), 51);
    1
}

fn test_arith_prog() -> Int {
    // AP: 1,3,5,7,9 (a=1, d=2, n=5) sum = 25
    assert_eq(arith_prog_sum(1, 2, 5), 25);
    assert_eq(arith_prog_sum_iter(1, 2, 5), 25);
    assert_eq(arith_nth(1, 2, 5), 9);
    // AP: 10,7,4,1 (a=10, d=-3, n=4) sum = 22
    assert_eq(arith_prog_sum(10, -3, 4), 22);
    assert_eq(arith_prog_sum_iter(10, -3, 4), 22);
    1
}

fn main() -> Int {
    test_natural_sums();
    test_sum_squares();
    test_sum_cubes();
    test_geometric();
    test_alternating();
    test_figurate();
    test_pentagonal();
    test_arith_prog();
    print("DIFF_OK: sequence_math");
    0
}
