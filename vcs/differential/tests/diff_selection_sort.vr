// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, selection-sort, algorithm
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn selection_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if get(arr, j) < get(arr, min_idx) {
                min_idx = j;
            }
            j = j + 1;
        }
        if min_idx != i {
            let tmp = get(arr, i);
            arr = set(arr, i, get(arr, min_idx));
            arr = set(arr, min_idx, tmp);
        }
        i = i + 1;
    }
    arr
}

fn find_median(a: Arr8, n: Int) -> Int {
    let sorted = selection_sort(a, n);
    if n % 2 == 1 {
        get(sorted, n / 2)
    } else {
        (get(sorted, n / 2 - 1) + get(sorted, n / 2)) / 2
    }
}

fn find_kth_smallest(a: Arr8, n: Int, k: Int) -> Int {
    let sorted = selection_sort(a, n);
    get(sorted, k)
}

fn main() -> Int {
    let data = Arr8 { d0: 64, d1: 25, d2: 12, d3: 22, d4: 11, d5: 90, d6: 34, d7: 55 };

    let sorted = selection_sort(data, 8);
    assert_eq(get(sorted, 0), 11);
    assert_eq(get(sorted, 1), 12);
    assert_eq(get(sorted, 2), 22);
    assert_eq(get(sorted, 3), 25);
    assert_eq(get(sorted, 4), 34);
    assert_eq(get(sorted, 5), 55);
    assert_eq(get(sorted, 6), 64);
    assert_eq(get(sorted, 7), 90);

    // Median of 8 elements (average of 4th and 5th)
    let med = find_median(data, 8);
    assert_eq(med, (25 + 34) / 2);  // 29

    // kth smallest (0-indexed)
    assert_eq(find_kth_smallest(data, 8, 0), 11);
    assert_eq(find_kth_smallest(data, 8, 3), 25);
    assert_eq(find_kth_smallest(data, 8, 7), 90);

    // All same elements
    let same = Arr8 { d0: 5, d1: 5, d2: 5, d3: 5, d4: 5, d5: 5, d6: 5, d7: 5 };
    let sorted2 = selection_sort(same, 8);
    assert_eq(get(sorted2, 0), 5);
    assert_eq(get(sorted2, 7), 5);

    // Already sorted
    let asc = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 6, d6: 7, d7: 8 };
    let sorted3 = selection_sort(asc, 8);
    assert_eq(get(sorted3, 0), 1);
    assert_eq(get(sorted3, 7), 8);

    print("DIFF_OK: selection_sort");
    0
}
