// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, permutation, cycle, inversion
// @timeout: 10000

// Permutation operations using Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// Check if array is a valid permutation of [0..n)
fn is_valid_perm(p: Arr8, n: Int) -> Int {
    let mut i = 0;
    while i < n {
        let val = get8(p, i);
        if val < 0 { return 0; }
        if val >= n { return 0; }
        // Check no duplicates
        let mut j = i + 1;
        while j < n {
            if get8(p, j) == val { return 0; }
            j = j + 1;
        }
        i = i + 1;
    }
    1
}

// Compose two permutations: result[i] = q[p[i]]
fn compose(p: Arr8, q: Arr8, n: Int) -> Arr8 {
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 0;
    while i < n {
        result = set8(result, i, get8(q, get8(p, i)));
        i = i + 1;
    }
    result
}

// Inverse permutation
fn inverse(p: Arr8, n: Int) -> Arr8 {
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 0;
    while i < n {
        result = set8(result, get8(p, i), i);
        i = i + 1;
    }
    result
}

// Count inversions: pairs (i,j) where i < j but p[i] > p[j]
fn count_inversions(p: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if get8(p, i) > get8(p, j) { count = count + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Count fixed points: p[i] == i
fn fixed_points(p: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(p, i) == i { count = count + 1; }
        i = i + 1;
    }
    count
}

// Count cycles in permutation
fn count_cycles(p: Arr8, n: Int) -> Int {
    let mut visited = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut cycles = 0;
    let mut i = 0;
    while i < n {
        if get8(visited, i) == 0 {
            cycles = cycles + 1;
            let mut j = i;
            while get8(visited, j) == 0 {
                visited = set8(visited, j, 1);
                j = get8(p, j);
            }
        }
        i = i + 1;
    }
    cycles
}

// Permutation is even (even number of inversions)
fn is_even_perm(p: Arr8, n: Int) -> Int {
    if count_inversions(p, n) % 2 == 0 { 1 } else { 0 }
}

fn test_identity() -> Int {
    let id = Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_valid_perm(id, 4), 1);
    assert_eq(count_inversions(id, 4), 0);
    assert_eq(fixed_points(id, 4), 4);
    assert_eq(count_cycles(id, 4), 4);
    1
}

fn test_compose_inverse() -> Int {
    // p = [2, 0, 3, 1]
    let p = Arr8 { v0: 2, v1: 0, v2: 3, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let inv = inverse(p, 4);
    // p^(-1) composed with p should give identity
    let comp = compose(p, inv, 4);
    assert_eq(get8(comp, 0), 0);
    assert_eq(get8(comp, 1), 1);
    assert_eq(get8(comp, 2), 2);
    assert_eq(get8(comp, 3), 3);
    1
}

fn test_inversions() -> Int {
    // [3, 1, 2, 0]: inversions = (3,1),(3,2),(3,0),(1,0),(2,0) = 5
    let p = Arr8 { v0: 3, v1: 1, v2: 2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_inversions(p, 4), 5);
    assert_eq(is_even_perm(p, 4), 0); // odd
    1
}

fn test_cycles() -> Int {
    // [1, 0, 3, 2]: two 2-cycles (0,1) and (2,3)
    let p = Arr8 { v0: 1, v1: 0, v2: 3, v3: 2, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_cycles(p, 4), 2);
    assert_eq(fixed_points(p, 4), 0);
    1
}

fn main() -> Int {
    test_identity();
    test_compose_inverse();
    test_inversions();
    test_cycles();
    print("DIFF_OK: permutation");
    0
}
