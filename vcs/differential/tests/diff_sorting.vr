// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, sorting, algorithms
// @timeout: 10000
// @expected-exit: 0
//
// Differential test: sorting algorithms (interpreter vs AOT)

type Arr5 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int };

fn arr5_get(a: Arr5, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 }
    else if i == 2 { a.v2 } else if i == 3 { a.v3 }
    else { a.v4 }
}

fn arr5_set(a: Arr5, i: Int, v: Int) -> Arr5 {
    Arr5 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 }
    }
}

fn bubble_sort5(a: Arr5) -> Arr5 {
    let mut arr = a;
    let mut i = 0;
    while i < 5 {
        let mut j = 0;
        while j < 4 - i {
            let curr = arr5_get(arr, j);
            let next = arr5_get(arr, j + 1);
            if curr > next {
                arr = arr5_set(arr, j, next);
                arr = arr5_set(arr, j + 1, curr);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

fn is_sorted5(a: Arr5) -> Bool {
    arr5_get(a, 0) <= arr5_get(a, 1) &&
    arr5_get(a, 1) <= arr5_get(a, 2) &&
    arr5_get(a, 2) <= arr5_get(a, 3) &&
    arr5_get(a, 3) <= arr5_get(a, 4)
}

fn main() -> Int {
    let a = Arr5 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 4 };
    let sorted = bubble_sort5(a);
    assert_eq(arr5_get(sorted, 0), 1);
    assert_eq(arr5_get(sorted, 1), 3);
    assert_eq(arr5_get(sorted, 2), 4);
    assert_eq(arr5_get(sorted, 3), 5);
    assert_eq(arr5_get(sorted, 4), 8);
    assert_eq(is_sorted5(sorted), true);

    // Already sorted
    let b = Arr5 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5 };
    assert_eq(is_sorted5(bubble_sort5(b)), true);

    // Reverse sorted
    let c = Arr5 { v0: 5, v1: 4, v2: 3, v3: 2, v4: 1 };
    let sc = bubble_sort5(c);
    assert_eq(arr5_get(sc, 0), 1);
    assert_eq(arr5_get(sc, 4), 5);

    print("DIFF_OK: sorting");
    0
}
