// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, collatz, sequence, stopping-time
// @timeout: 10000

// Collatz sequence length (stopping time)
fn collatz_len(n: Int) -> Int {
    let mut v = n;
    let mut count = 0;
    while v != 1 {
        if v % 2 == 0 { v = v / 2; }
        else { v = 3 * v + 1; }
        count = count + 1;
    }
    count
}

// Max value reached in Collatz sequence
fn collatz_max(n: Int) -> Int {
    let mut v = n;
    let mut mx = n;
    while v != 1 {
        if v % 2 == 0 { v = v / 2; }
        else { v = 3 * v + 1; }
        if v > mx { mx = v; }
    }
    mx
}

// Count even steps in Collatz sequence
fn collatz_even_steps(n: Int) -> Int {
    let mut v = n;
    let mut count = 0;
    while v != 1 {
        if v % 2 == 0 { v = v / 2; count = count + 1; }
        else { v = 3 * v + 1; }
    }
    count
}

// Find number in [1..limit] with longest Collatz sequence
fn longest_collatz(limit: Int) -> Int {
    let mut best_n = 1;
    let mut best_len = 0;
    let mut i = 1;
    while i <= limit {
        let len = collatz_len(i);
        if len > best_len {
            best_len = len;
            best_n = i;
        }
        i = i + 1;
    }
    best_n
}

fn test_collatz_len() -> Int {
    assert_eq(collatz_len(1), 0);
    assert_eq(collatz_len(2), 1);
    assert_eq(collatz_len(3), 7);  // 3->10->5->16->8->4->2->1
    assert_eq(collatz_len(6), 8);
    assert_eq(collatz_len(27), 111);
    1
}

fn test_collatz_max() -> Int {
    assert_eq(collatz_max(1), 1);
    assert_eq(collatz_max(3), 16);
    assert_eq(collatz_max(7), 52);  // 7->22->11->34->17->52->...
    1
}

fn test_collatz_even() -> Int {
    // 3->10->5->16->8->4->2->1: even steps at 10,16,8,4,2 = 5
    assert_eq(collatz_even_steps(3), 5);
    assert_eq(collatz_even_steps(2), 1);
    assert_eq(collatz_even_steps(4), 2);
    1
}

fn test_longest() -> Int {
    // In [1..10], 9 has longest sequence (19 steps)
    assert_eq(longest_collatz(10), 9);
    1
}

fn main() -> Int {
    test_collatz_len();
    test_collatz_max();
    test_collatz_even();
    test_longest();
    print("DIFF_OK: collatz_ext");
    0
}
