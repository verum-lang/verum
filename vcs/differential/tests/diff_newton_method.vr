// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, newton, numerical, sqrt, integer
// @timeout: 10000

// Integer square root using Newton's method
fn isqrt(n: Int) -> Int {
    if n <= 1 { return n; }
    let mut x = n;
    let mut y = (x + 1) / 2;
    while y < x {
        x = y;
        y = (x + n / x) / 2;
    }
    x
}

// Integer cube root (Newton's method)
fn icbrt(n: Int) -> Int {
    if n <= 0 { return 0; }
    if n <= 1 { return 1; }
    let mut x = n;
    let mut y = (2 * x + n / (x * x)) / 3;
    // Prevent y from being 0
    if y == 0 { y = 1; }
    while y < x {
        x = y;
        if x == 0 { return 0; }
        y = (2 * x + n / (x * x)) / 3;
        if y == 0 { y = 1; }
    }
    x
}

// Check if perfect square
fn is_perfect_square(n: Int) -> Int {
    let s = isqrt(n);
    if s * s == n { 1 } else { 0 }
}

// Binary search for integer square root (alternative)
fn isqrt_binary(n: Int) -> Int {
    if n <= 1 { return n; }
    let mut lo = 1;
    let mut hi = n;
    if hi > 46340 { hi = 46340; } // prevent overflow
    while lo <= hi {
        let mid = (lo + hi) / 2;
        if mid * mid == n { return mid; }
        if mid * mid < n { lo = mid + 1; }
        else { hi = mid - 1; }
    }
    hi
}

fn test_isqrt() -> Int {
    assert_eq(isqrt(0), 0);
    assert_eq(isqrt(1), 1);
    assert_eq(isqrt(4), 2);
    assert_eq(isqrt(9), 3);
    assert_eq(isqrt(100), 10);
    assert_eq(isqrt(101), 10);
    1
}

fn test_isqrt_large() -> Int {
    assert_eq(isqrt(10000), 100);
    assert_eq(isqrt(144), 12);
    assert_eq(isqrt(169), 13);
    assert_eq(isqrt(170), 13);
    1
}

fn test_icbrt() -> Int {
    assert_eq(icbrt(0), 0);
    assert_eq(icbrt(1), 1);
    assert_eq(icbrt(8), 2);
    assert_eq(icbrt(27), 3);
    assert_eq(icbrt(64), 4);
    assert_eq(icbrt(125), 5);
    1
}

fn test_perfect_square() -> Int {
    assert_eq(is_perfect_square(0), 1);
    assert_eq(is_perfect_square(1), 1);
    assert_eq(is_perfect_square(4), 1);
    assert_eq(is_perfect_square(5), 0);
    assert_eq(is_perfect_square(25), 1);
    assert_eq(is_perfect_square(26), 0);
    1
}

fn test_binary_sqrt() -> Int {
    assert_eq(isqrt_binary(100), 10);
    assert_eq(isqrt_binary(81), 9);
    assert_eq(isqrt_binary(50), 7);
    // Both methods agree
    assert_eq(isqrt(144), isqrt_binary(144));
    1
}

fn main() -> Int {
    test_isqrt();
    test_isqrt_large();
    test_icbrt();
    test_perfect_square();
    test_binary_sqrt();
    print("DIFF_OK: newton_method");
    0
}
