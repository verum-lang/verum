// @test: differential

// @level: L0
// @tags: differential, permutations, combinatorics
// @timeout: 30000

// Permutation operations: next permutation, inversion count, cycle detection

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn swap8(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = get8(a, i);
    let vj = get8(a, j);
    let tmp = set8(a, i, vj);
    set8(tmp, j, vi)
}

// Reverse elements in [l, r]
fn reverse8(a: Arr8, l: Int, r: Int) -> Arr8 {
    let mut arr = a;
    let mut lo = l;
    let mut hi = r;
    while lo < hi {
        arr = swap8(arr, lo, hi);
        lo = lo + 1;
        hi = hi - 1;
    }
    arr
}

// Next permutation (returns the permutation, or reversed if at last)
fn next_perm(a: Arr8, n: Int) -> Arr8 {
    // Find largest i such that a[i] < a[i+1]
    let mut i = n - 2;
    let mut found = 0;
    while i >= 0 {
        if get8(a, i) < get8(a, i + 1) {
            found = 1;
            i = i; // break - use the found flag
            let mut dummy = -1;
            while dummy < 0 { dummy = 0; } // break out
            // Actually we need to stop the loop
        }
        if found == 1 { i = -1; } // exit loop keeping i
        else { i = i - 1; }
    }
    if found == 0 {
        // Last permutation, return sorted (first permutation)
        return reverse8(a, 0, n - 1);
    }
    // Recover the actual i value
    let mut idx = n - 2;
    while idx >= 0 {
        if get8(a, idx) < get8(a, idx + 1) {
            // Found it
            idx = idx;
            // Find largest j > idx where a[j] > a[idx]
            let mut j = n - 1;
            while get8(a, j) <= get8(a, idx) { j = j - 1; }
            let mut arr = swap8(a, idx, j);
            arr = reverse8(arr, idx + 1, n - 1);
            return arr;
        }
        idx = idx - 1;
    }
    a // unreachable
}

// Count inversions in permutation (O(n^2))
fn count_inversions(a: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if get8(a, i) > get8(a, j) { count = count + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Check if permutation is identity
fn is_identity(a: Arr8, n: Int) -> Int {
    let mut i = 0;
    while i < n {
        if get8(a, i) != i { return 0; }
        i = i + 1;
    }
    1
}

// Compose two permutations: result[i] = b[a[i]]
fn compose(a: Arr8, b: Arr8, n: Int) -> Arr8 {
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 0;
    while i < n {
        result = set8(result, i, get8(b, get8(a, i)));
        i = i + 1;
    }
    result
}

// Inverse permutation
fn inverse_perm(a: Arr8, n: Int) -> Arr8 {
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 0;
    while i < n {
        result = set8(result, get8(a, i), i);
        i = i + 1;
    }
    result
}

// Count cycles in permutation
fn count_cycles(a: Arr8, n: Int) -> Int {
    let mut visited = 0; // bitmask
    let mut cycles = 0;
    let mut i = 0;
    while i < n {
        let mut mask = 1;
        let mut m = 0;
        while m < i { mask = mask * 2; m = m + 1; }
        if (visited / mask) % 2 == 0 {
            cycles = cycles + 1;
            let mut j = i;
            let mut keep_going = 1;
            while keep_going == 1 {
                let mut jmask = 1;
                let mut jm = 0;
                while jm < j { jmask = jmask * 2; jm = jm + 1; }
                visited = visited + jmask;
                j = get8(a, j);
                // Check if j is visited
                let mut jmask2 = 1;
                let mut jm2 = 0;
                while jm2 < j { jmask2 = jmask2 * 2; jm2 = jm2 + 1; }
                if (visited / jmask2) % 2 == 1 { keep_going = 0; }
            }
        }
        i = i + 1;
    }
    cycles
}

fn main() -> Int {
    // Inversions
    let sorted = Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_inversions(sorted, 4), 0);

    let rev = Arr8 { v0: 3, v1: 2, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_inversions(rev, 4), 6); // C(4,2) = 6

    let perm = Arr8 { v0: 2, v1: 0, v2: 3, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_inversions(perm, 4), 3); // (2,0), (2,1), (3,1)

    // Identity check
    assert_eq(is_identity(sorted, 4), 1);
    assert_eq(is_identity(perm, 4), 0);

    // Compose with identity = self
    let id = Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    let comp = compose(perm, id, 4);
    assert_eq(get8(comp, 0), 2);
    assert_eq(get8(comp, 1), 0);
    assert_eq(get8(comp, 2), 3);
    assert_eq(get8(comp, 3), 1);

    // Inverse: p * p^{-1} = identity
    let inv = inverse_perm(perm, 4);
    let should_be_id = compose(perm, inv, 4);
    assert_eq(is_identity(should_be_id, 4), 1);

    // Also p^{-1} * p = identity
    let should_be_id2 = compose(inv, perm, 4);
    assert_eq(is_identity(should_be_id2, 4), 1);

    // Cycles
    // Identity has 4 cycles (4 fixed points)
    assert_eq(count_cycles(id, 4), 4);
    // (0 2 3 1) is one 4-cycle → wait, perm = [2,0,3,1]
    // 0->2->3->1->0 is a single 4-cycle
    assert_eq(count_cycles(perm, 4), 1);

    // Two 2-cycles: (0 1)(2 3) = [1,0,3,2]
    let two_swaps = Arr8 { v0: 1, v1: 0, v2: 3, v3: 2, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_cycles(two_swaps, 4), 2);

    // Next permutation
    let p1 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let p2 = next_perm(p1, 3);
    // next of [1,2,3] = [1,3,2]
    assert_eq(get8(p2, 0), 1);
    assert_eq(get8(p2, 1), 3);
    assert_eq(get8(p2, 2), 2);

    let p3 = next_perm(p2, 3);
    // next of [1,3,2] = [2,1,3]
    assert_eq(get8(p3, 0), 2);
    assert_eq(get8(p3, 1), 1);
    assert_eq(get8(p3, 2), 3);

    print("[OK] diff_permutations");
    0
}
