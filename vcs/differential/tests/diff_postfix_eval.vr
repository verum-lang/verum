// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, postfix, stack, expression-evaluation
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Encode: positive values = operands, negative = operators
// -1 = add, -2 = subtract, -3 = multiply, -4 = divide

// Evaluate postfix expression
fn eval_postfix(expr: Arr8, n: Int) -> Int {
    let mut stack = zeros();
    let mut top = 0;
    let mut i = 0;
    while i < n {
        let token = get(expr, i);
        if token >= 0 {
            // Push operand
            stack = set(stack, top, token);
            top = top + 1;
        } else {
            // Pop two operands, apply op, push result
            let b = get(stack, top - 1);
            let a = get(stack, top - 2);
            top = top - 2;
            let result = if token == -1 { a + b }
                        else if token == -2 { a - b }
                        else if token == -3 { a * b }
                        else { a / b }; // -4 = divide
            stack = set(stack, top, result);
            top = top + 1;
        }
        i = i + 1;
    }
    get(stack, 0)
}

// Infix evaluation of a simple left-to-right expression (no precedence)
// encoded as: val op val op val ... (alternating)
fn eval_infix_lr(expr: Arr8, n: Int) -> Int {
    let mut result = get(expr, 0);
    let mut i = 1;
    while i < n {
        let op = get(expr, i);
        let val = get(expr, i + 1);
        if op == -1 { result = result + val; }
        else if op == -2 { result = result - val; }
        else if op == -3 { result = result * val; }
        else { result = result / val; }
        i = i + 2;
    }
    result
}

// Convert simple infix (with only + and *) respecting precedence to postfix and evaluate
// a + b * c = a + (b*c)
// We handle a limited case: sequence of values with + and * operators
fn eval_with_precedence(vals: Arr8, ops: Arr8, n_vals: Int) -> Int {
    // First pass: handle all multiplications
    let mut vs = vals;
    let mut os = ops;
    let n_ops = n_vals - 1;

    // Process * first by collapsing adjacent values
    let mut changed = 1;
    while changed == 1 {
        changed = 0;
        let mut i = 0;
        while i < n_ops {
            if get(os, i) == -3 {
                // Multiply vals[i] * vals[i+1], shift remaining left
                let product = get(vs, i) * get(vs, i + 1);
                vs = set(vs, i, product);
                // Shift values
                let mut j = i + 1;
                while j < n_vals - 1 {
                    vs = set(vs, j, get(vs, j + 1));
                    j = j + 1;
                }
                // Shift ops
                let mut k = i;
                while k < n_ops - 1 {
                    os = set(os, k, get(os, k + 1));
                    k = k + 1;
                }
                changed = 1;
                i = n_ops; // restart
            } else {
                i = i + 1;
            }
        }
    }

    // Second pass: sum remaining (all ops should be +)
    let mut result = get(vs, 0);
    let mut i = 0;
    while i < n_ops {
        if get(os, i) == -1 { result = result + get(vs, i + 1); }
        i = i + 1;
    }
    result
}

// Stack-based bracket matcher: returns 1 if balanced
// Encode: 1='(', 2='[', 3='{', -1=')', -2=']', -3='}'
fn brackets_match(expr: Arr8, n: Int) -> Int {
    let mut stack = zeros();
    let mut top = 0;
    let mut i = 0;
    while i < n {
        let c = get(expr, i);
        if c > 0 {
            stack = set(stack, top, c);
            top = top + 1;
        } else {
            if top == 0 { return 0; }
            top = top - 1;
            let open = get(stack, top);
            // Check matching: open + close should == 0 if matching
            if open + c != 0 { return 0; }
        }
        i = i + 1;
    }
    if top == 0 { 1 } else { 0 }
}

fn main() -> Int {
    // "3 4 + 2 *" = (3+4)*2 = 14
    let e1 = Arr8 { d0: 3, d1: 4, d2: -1, d3: 2, d4: -3, d5: 0, d6: 0, d7: 0 };
    assert_eq(eval_postfix(e1, 5), 14);

    // "5 1 2 + 4 * + 3 -" = 5+((1+2)*4)-3 = 5+12-3 = 14
    let e2 = Arr8 { d0: 5, d1: 1, d2: 2, d3: -1, d4: 4, d5: -3, d6: -1, d7: 3 };
    // Actually need 8 tokens: 5 1 2 + 4 * + 3, then - at position 8... too many
    // Simpler: "2 3 + 5 *" = (2+3)*5 = 25
    let e2b = Arr8 { d0: 2, d1: 3, d2: -1, d3: 5, d4: -3, d5: 0, d6: 0, d7: 0 };
    assert_eq(eval_postfix(e2b, 5), 25);

    // "10 3 -" = 10-3 = 7
    let e3 = Arr8 { d0: 10, d1: 3, d2: -2, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(eval_postfix(e3, 3), 7);

    // "20 4 /" = 20/4 = 5
    let e4 = Arr8 { d0: 20, d1: 4, d2: -4, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(eval_postfix(e4, 3), 5);

    // Single operand
    let e5 = Arr8 { d0: 42, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(eval_postfix(e5, 1), 42);

    // "2 3 * 4 5 * +" = 6 + 20 = 26
    let e6 = Arr8 { d0: 2, d1: 3, d2: -3, d3: 4, d4: 5, d5: -3, d6: -1, d7: 0 };
    assert_eq(eval_postfix(e6, 7), 26);

    // Precedence test: 2 + 3 * 4 = 14 (not 20)
    let vals = Arr8 { d0: 2, d1: 3, d2: 4, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let ops = Arr8 { d0: -1, d1: -3, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(eval_with_precedence(vals, ops, 3), 14);

    // Bracket matching
    // "( [ ] )" = balanced
    let b1 = Arr8 { d0: 1, d1: 2, d2: -2, d3: -1, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(brackets_match(b1, 4), 1);

    // "( [ ) ]" = not balanced
    let b2 = Arr8 { d0: 1, d1: 2, d2: -1, d3: -2, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(brackets_match(b2, 4), 0);

    // "{ { } }" = balanced
    let b3 = Arr8 { d0: 3, d1: 3, d2: -3, d3: -3, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(brackets_match(b3, 4), 1);

    // "(" = unbalanced
    let b4 = Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(brackets_match(b4, 1), 0);

    // Empty = balanced
    assert_eq(brackets_match(b4, 0), 1);

    print("DIFF_OK: postfix_eval");
    0
}
