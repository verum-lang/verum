// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, rle, encoding, compression
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// RLE encoded as pairs: (value, count) stored interleaved in Arr8
// encoded[0]=val0, encoded[1]=count0, encoded[2]=val1, encoded[3]=count1, ...

// Count number of runs in data
fn rle_num_runs(data: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut runs = 1;
    let mut i = 1;
    while i < n {
        if get(data, i) != get(data, i - 1) {
            runs = runs + 1;
        }
        i = i + 1;
    }
    runs
}

// Encode data into (value, count) pairs, return encoded array
// n_runs is output from rle_num_runs
fn rle_encode(data: Arr8, n: Int) -> Arr8 {
    let mut enc = zeros();
    if n == 0 { return enc; }
    let mut run_idx = 0;
    let mut cur_val = get(data, 0);
    let mut cur_count = 1;
    let mut i = 1;
    while i < n {
        if get(data, i) == cur_val {
            cur_count = cur_count + 1;
        } else {
            enc = set(enc, run_idx * 2, cur_val);
            enc = set(enc, run_idx * 2 + 1, cur_count);
            run_idx = run_idx + 1;
            cur_val = get(data, i);
            cur_count = 1;
        }
        i = i + 1;
    }
    // Write last run
    enc = set(enc, run_idx * 2, cur_val);
    enc = set(enc, run_idx * 2 + 1, cur_count);
    enc
}

// Decode RLE back to original data, return decoded array
fn rle_decode(encoded: Arr8, n_runs: Int) -> Arr8 {
    let mut dec = zeros();
    let mut pos = 0;
    let mut r = 0;
    while r < n_runs {
        let val = get(encoded, r * 2);
        let cnt = get(encoded, r * 2 + 1);
        let mut c = 0;
        while c < cnt {
            dec = set(dec, pos, val);
            pos = pos + 1;
            c = c + 1;
        }
        r = r + 1;
    }
    dec
}

// Decoded length from RLE
fn rle_decoded_len(encoded: Arr8, n_runs: Int) -> Int {
    let mut total = 0;
    let mut r = 0;
    while r < n_runs {
        total = total + get(encoded, r * 2 + 1);
        r = r + 1;
    }
    total
}

// First run value
fn rle_first_run_val(encoded: Arr8) -> Int {
    get(encoded, 0)
}

// First run length
fn rle_first_run_len(encoded: Arr8) -> Int {
    get(encoded, 1)
}

// Check if two arrays are equal for first n elements
fn arrays_equal(a: Arr8, b_arr: Arr8, n: Int) -> Int {
    let mut i = 0;
    while i < n {
        if get(a, i) != get(b_arr, i) { return 0; }
        i = i + 1;
    }
    1
}

fn test_all_same() -> Int {
    // All same: [5, 5, 5, 5, 5]
    let data = Arr8 { d0: 5, d1: 5, d2: 5, d3: 5, d4: 5, d5: 0, d6: 0, d7: 0 };
    let n = 5;
    assert_eq(rle_num_runs(data, n), 1);

    let enc = rle_encode(data, n);
    assert_eq(rle_first_run_val(enc), 5);
    assert_eq(rle_first_run_len(enc), 5);
    assert_eq(rle_decoded_len(enc, 1), 5);

    let dec = rle_decode(enc, 1);
    assert_eq(arrays_equal(data, dec, n), 1);
    0
}

fn test_alternating() -> Int {
    // Alternating: [1, 2, 1, 2, 1, 2]
    let data = Arr8 { d0: 1, d1: 2, d2: 1, d3: 2, d4: 1, d5: 2, d6: 0, d7: 0 };
    let n = 6;
    assert_eq(rle_num_runs(data, n), 6);

    let enc = rle_encode(data, n);
    assert_eq(rle_first_run_val(enc), 1);
    assert_eq(rle_first_run_len(enc), 1);
    assert_eq(rle_decoded_len(enc, 6), 6);

    // Each run has count 1
    let mut r = 0;
    while r < 6 {
        assert_eq(get(enc, r * 2 + 1), 1);
        r = r + 1;
    }
    0
}

fn test_groups() -> Int {
    // Groups: [1, 1, 2, 2, 2, 3, 3, 1]
    let data = Arr8 { d0: 1, d1: 1, d2: 2, d3: 2, d4: 2, d5: 3, d6: 3, d7: 1 };
    let n = 8;
    assert_eq(rle_num_runs(data, n), 4);

    let enc = rle_encode(data, n);
    // Run 0: (1, 2)
    assert_eq(get(enc, 0), 1);
    assert_eq(get(enc, 1), 2);
    // Run 1: (2, 3)
    assert_eq(get(enc, 2), 2);
    assert_eq(get(enc, 3), 3);
    // Run 2: (3, 2)
    assert_eq(get(enc, 4), 3);
    assert_eq(get(enc, 5), 2);
    0
}

fn test_groups_roundtrip() -> Int {
    let data = Arr8 { d0: 1, d1: 1, d2: 2, d3: 2, d4: 2, d5: 3, d6: 3, d7: 1 };
    let n = 8;
    let enc = rle_encode(data, n);
    // Run 3: (1, 1)
    assert_eq(get(enc, 6), 1);
    assert_eq(get(enc, 7), 1);

    assert_eq(rle_decoded_len(enc, 4), 8);

    let dec = rle_decode(enc, 4);
    assert_eq(arrays_equal(data, dec, n), 1);
    0
}

fn test_single_and_empty() -> Int {
    // Single element
    let data = Arr8 { d0: 7, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(rle_num_runs(data, 1), 1);
    let enc = rle_encode(data, 1);
    assert_eq(rle_first_run_val(enc), 7);
    assert_eq(rle_first_run_len(enc), 1);

    let dec = rle_decode(enc, 1);
    assert_eq(get(dec, 0), 7);

    // Empty
    assert_eq(rle_num_runs(zeros(), 0), 0);
    0
}

fn test_compression_ratio() -> Int {
    // Best case: all same = 1 run from 8 elements
    let same = Arr8 { d0: 3, d1: 3, d2: 3, d3: 3, d4: 3, d5: 3, d6: 3, d7: 3 };
    assert_eq(rle_num_runs(same, 8), 1);

    // Worst case: all different = 8 runs from 8 elements
    let diff = Arr8 { d0: 0, d1: 1, d2: 2, d3: 3, d4: 4, d5: 5, d6: 6, d7: 7 };
    assert_eq(rle_num_runs(diff, 8), 8);

    // Two blocks
    let two = Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 1, d5: 1, d6: 1, d7: 1 };
    assert_eq(rle_num_runs(two, 8), 2);
    let enc = rle_encode(two, 8);
    assert_eq(get(enc, 0), 0);
    assert_eq(get(enc, 1), 4);
    assert_eq(get(enc, 2), 1);
    assert_eq(get(enc, 3), 4);
    0
}

fn main() -> Int {
    test_all_same();
    test_alternating();
    test_groups();
    test_groups_roundtrip();
    test_single_and_empty();
    test_compression_ratio();
    print("DIFF_OK: rle_encoding");
    0
}
