// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, gray, code, bitwise, encoding
// @timeout: 10000

// Gray code encoding and decoding

// Convert binary to Gray code
fn to_gray(n: Int) -> Int {
    n ^ (n / 2)
}

// Convert Gray code back to binary
fn from_gray(g: Int) -> Int {
    let mut n = g;
    let mut mask = n / 2;
    while mask > 0 {
        n = n ^ mask;
        mask = mask / 2;
    }
    n
}

// Check if two adjacent Gray codes differ by exactly one bit
fn differs_one_bit(a: Int, b: Int) -> Int {
    let diff = a ^ b;
    // Check if diff is a power of 2 (exactly one bit set)
    if diff == 0 { return 0; }
    if (diff & (diff - 1)) == 0 { 1 } else { 0 }
}

// Count bits set in a number
fn popcount(n: Int) -> Int {
    let mut count = 0;
    let mut val = n;
    while val > 0 {
        count = count + (val & 1);
        val = val / 2;
    }
    count
}

// Generate n-bit Gray code sequence and return sum of all codes
fn gray_sequence_sum(bits: Int) -> Int {
    let count = 1;
    let mut total_count = count;
    let mut i = 0;
    while i < bits {
        total_count = total_count * 2;
        i = i + 1;
    }
    let mut sum_val = 0;
    let mut j = 0;
    while j < total_count {
        sum_val = sum_val + to_gray(j);
        j = j + 1;
    }
    sum_val
}

// Verify round-trip: binary -> gray -> binary
fn test_roundtrip() -> Int {
    let mut i = 0;
    while i < 64 {
        let g = to_gray(i);
        let b = from_gray(g);
        assert_eq(b, i);
        i = i + 1;
    }
    1
}

// Verify adjacent Gray codes differ by one bit
fn test_adjacent() -> Int {
    let mut i = 0;
    while i < 63 {
        let g1 = to_gray(i);
        let g2 = to_gray(i + 1);
        assert_eq(differs_one_bit(g1, g2), 1);
        i = i + 1;
    }
    1
}

fn test_specific_values() -> Int {
    // 0=000->000=0, 1=001->001=1, 2=010->011=3, 3=011->010=2
    // 4=100->110=6, 5=101->111=7, 6=110->101=5, 7=111->100=4
    assert_eq(to_gray(0), 0);
    assert_eq(to_gray(1), 1);
    assert_eq(to_gray(2), 3);
    assert_eq(to_gray(3), 2);
    assert_eq(to_gray(4), 6);
    assert_eq(to_gray(5), 7);
    assert_eq(to_gray(6), 5);
    assert_eq(to_gray(7), 4);
    1
}

fn test_gray_sequence() -> Int {
    // 2-bit Gray codes: 0,1,3,2 -> sum = 6
    assert_eq(gray_sequence_sum(2), 6);
    // 3-bit Gray codes: 0,1,3,2,6,7,5,4 -> sum = 28
    assert_eq(gray_sequence_sum(3), 28);
    1
}

fn main() -> Int {
    test_roundtrip();
    test_adjacent();
    test_specific_values();
    test_gray_sequence();
    print("DIFF_OK: gray_code");
    0
}
