// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, parentheses, balanced, catalan
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Encode: 1 = '(', 0 = ')'
// Check if parenthesis sequence is balanced
fn is_balanced(seq: Arr8, n: Int) -> Int {
    let mut depth = 0;
    let mut i = 0;
    while i < n {
        if get(seq, i) == 1 { depth = depth + 1; }
        else { depth = depth - 1; }
        if depth < 0 { return 0; }
        i = i + 1;
    }
    if depth == 0 { 1 } else { 0 }
}

// Maximum nesting depth
fn max_depth(seq: Arr8, n: Int) -> Int {
    let mut depth = 0;
    let mut max_d = 0;
    let mut i = 0;
    while i < n {
        if get(seq, i) == 1 { depth = depth + 1; }
        else { depth = depth - 1; }
        if depth > max_d { max_d = depth; }
        i = i + 1;
    }
    max_d
}

// Count balanced subsequences of length 2n via Catalan number
// C(n) = C(2n, n) / (n+1)
fn catalan(n: Int) -> Int {
    if n <= 0 { return 1; }
    // Use recurrence: C(n) = C(n-1) * 2(2n-1) / (n+1)
    let mut c = 1;
    let mut i = 1;
    while i <= n {
        c = c * (4 * i - 2) / (i + 1);
        i = i + 1;
    }
    c
}

// Count valid parenthesizations via brute force (for small n)
// Enumerate all 2^(2n) sequences of length 2n
fn count_balanced_brute(half_n: Int) -> Int {
    let n = half_n * 2;
    let mut total_seqs = 1;
    let mut i = 0;
    while i < n { total_seqs = total_seqs * 2; i = i + 1; }

    let mut count = 0;
    let mut mask = 0;
    while mask < total_seqs {
        // Convert mask to sequence
        let mut seq = zeros();
        let mut j = 0;
        let mut m = mask;
        while j < n {
            seq = set(seq, j, m % 2);
            m = m / 2;
            j = j + 1;
        }
        if is_balanced(seq, n) == 1 { count = count + 1; }
        mask = mask + 1;
    }
    count
}

// Minimum additions to make balanced
fn min_additions(seq: Arr8, n: Int) -> Int {
    let mut open = 0;  // unmatched opens
    let mut close = 0; // unmatched closes
    let mut i = 0;
    while i < n {
        if get(seq, i) == 1 { open = open + 1; }
        else {
            if open > 0 { open = open - 1; }
            else { close = close + 1; }
        }
        i = i + 1;
    }
    open + close
}

fn main() -> Int {
    // Balanced: "(())" = [1,1,0,0]
    let b1 = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(is_balanced(b1, 4), 1);
    assert_eq(max_depth(b1, 4), 2);

    // Balanced: "()()" = [1,0,1,0]
    let b2 = Arr8 { d0: 1, d1: 0, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(is_balanced(b2, 4), 1);
    assert_eq(max_depth(b2, 4), 1);

    // Unbalanced: "(()" = [1,1,0]
    let u1 = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(is_balanced(u1, 3), 0);

    // Unbalanced: ")(" = [0,1]
    let u2 = Arr8 { d0: 0, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(is_balanced(u2, 2), 0);

    // Empty is balanced
    assert_eq(is_balanced(b1, 0), 1);

    // "()" = [1,0]
    let b3 = Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(is_balanced(b3, 2), 1);

    // Catalan numbers
    assert_eq(catalan(0), 1);
    assert_eq(catalan(1), 1);
    assert_eq(catalan(2), 2);
    assert_eq(catalan(3), 5);
    assert_eq(catalan(4), 14);

    // Cross-check: brute force vs Catalan for small n
    assert_eq(count_balanced_brute(1), catalan(1)); // 1
    assert_eq(count_balanced_brute(2), catalan(2)); // 2
    assert_eq(count_balanced_brute(3), catalan(3)); // 5

    // Min additions
    assert_eq(min_additions(b1, 4), 0); // already balanced
    assert_eq(min_additions(u2, 2), 2); // need (() and ())
    // "(((" = [1,1,1] needs 3 closes
    let u3 = Arr8 { d0: 1, d1: 1, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(min_additions(u3, 3), 3);
    // "))" = [0,0] needs 2 opens
    let u4 = Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(min_additions(u4, 2), 2);

    print("DIFF_OK: parentheses");
    0
}
