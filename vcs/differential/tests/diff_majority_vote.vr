// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, majority, vote, frequency, consensus, n-over-3
// @timeout: 10000

// Extended majority voting: n/3 majority (elements appearing > n/3 times),
// frequency histogram, consensus detection, and vote tallying.

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Count occurrences of val in array
fn count_val(a: Arr8, n: Int, val: Int) -> Int {
    let mut c = 0;
    let mut i = 0;
    while i < n {
        if get(a, i) == val { c = c + 1; }
        i = i + 1;
    }
    c
}

// Boyer-Moore n/3 majority: find up to 2 candidates appearing > n/3 times
// Returns number of such elements found (0, 1, or 2)
// Candidates stored in cand1, cand2
type TwoResult is { cand1: Int, cand2: Int, found: Int };

fn find_third_majority(a: Arr8, n: Int) -> TwoResult {
    // Phase 1: find at most 2 candidates
    let mut c1 = 0;
    let mut c2 = 0;
    let mut cnt1 = 0;
    let mut cnt2 = 0;
    let mut i = 0;
    while i < n {
        let v = get(a, i);
        if cnt1 > 0 {
            if v == c1 {
                cnt1 = cnt1 + 1;
                i = i + 1;
            } else if cnt2 > 0 {
                if v == c2 {
                    cnt2 = cnt2 + 1;
                    i = i + 1;
                } else {
                    cnt1 = cnt1 - 1;
                    cnt2 = cnt2 - 1;
                    i = i + 1;
                }
            } else {
                c2 = v;
                cnt2 = 1;
                i = i + 1;
            }
        } else if cnt2 > 0 {
            if v == c2 {
                cnt2 = cnt2 + 1;
                i = i + 1;
            } else {
                c1 = v;
                cnt1 = 1;
                i = i + 1;
            }
        } else {
            c1 = v;
            cnt1 = 1;
            i = i + 1;
        }
    }

    // Phase 2: verify candidates
    let threshold = n / 3;
    let mut found = 0;
    let mut r1 = -1;
    let mut r2 = -1;
    if cnt1 > 0 {
        let actual = count_val(a, n, c1);
        if actual > threshold {
            r1 = c1;
            found = found + 1;
        }
    }
    if cnt2 > 0 {
        let actual = count_val(a, n, c2);
        if actual > threshold {
            if found == 0 { r1 = c2; }
            else { r2 = c2; }
            found = found + 1;
        }
    }
    TwoResult { cand1: r1, cand2: r2, found: found }
}

// Count distinct elements (brute force, values 0..7 only)
fn count_distinct(a: Arr8, n: Int) -> Int {
    let mut seen = zeros();
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let v = get(a, i);
        if get(seen, v) == 0 {
            seen = set(seen, v, 1);
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

// Check if array has perfect consensus (all same value)
fn is_unanimous(a: Arr8, n: Int) -> Int {
    if n <= 1 { return 1; }
    let first = get(a, 0);
    let mut i = 1;
    while i < n {
        if get(a, i) != first { return 0; }
        i = i + 1;
    }
    1
}

// Find most frequent element among values 0..7 (brute force histogram)
fn most_frequent(a: Arr8, n: Int) -> Int {
    let mut best_val = get(a, 0);
    let mut best_cnt = 0;
    let mut v = 0;
    while v < 8 {
        let cnt = count_val(a, n, v);
        if cnt > best_cnt {
            best_cnt = cnt;
            best_val = v;
        }
        v = v + 1;
    }
    best_val
}

// Weighted majority vote: each element has a weight
fn weighted_majority(vals: Arr8, weights: Arr8, n: Int) -> Int {
    // Sum weights for each candidate (values 0..7)
    let mut totals = zeros();
    let mut i = 0;
    while i < n {
        let v = get(vals, i);
        let w = get(weights, i);
        let cur = get(totals, v);
        totals = set(totals, v, cur + w);
        i = i + 1;
    }
    // Find max weight candidate
    let mut best_val = 0;
    let mut best_w = 0;
    let mut v = 0;
    while v < 8 {
        let tw = get(totals, v);
        if tw > best_w {
            best_w = tw;
            best_val = v;
        }
        v = v + 1;
    }
    best_val
}

fn test_third_majority() -> Int {
    // [1,1,1,2,2,2,3] n=7, threshold=2
    // 1 appears 3 > 2, 2 appears 3 > 2 => 2 found
    let a1 = Arr8 { d0: 1, d1: 1, d2: 1, d3: 2, d4: 2, d5: 2, d6: 3, d7: 0 };
    let r1 = find_third_majority(a1, 7);
    assert_eq(r1.found, 2);

    // [1,2,3,4,5,6] n=6, threshold=2 => none appear > 2 times
    let a2 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 6, d6: 0, d7: 0 };
    let r2 = find_third_majority(a2, 6);
    assert_eq(r2.found, 0);

    // [3,3,3,3,1,2] n=6, threshold=2 => 3 appears 4 > 2
    let a3 = Arr8 { d0: 3, d1: 3, d2: 3, d3: 3, d4: 1, d5: 2, d6: 0, d7: 0 };
    let r3 = find_third_majority(a3, 6);
    assert_eq(r3.found, 1);
    assert_eq(r3.cand1, 3);
    1
}

fn test_distinct() -> Int {
    let a1 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 0, d6: 0, d7: 0 };
    assert_eq(count_distinct(a1, 5), 5);

    let a2 = Arr8 { d0: 3, d1: 3, d2: 3, d3: 3, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(count_distinct(a2, 4), 1);

    let a3 = Arr8 { d0: 0, d1: 1, d2: 0, d3: 1, d4: 2, d5: 2, d6: 0, d7: 0 };
    assert_eq(count_distinct(a3, 6), 3);
    1
}

fn test_unanimous() -> Int {
    let a1 = Arr8 { d0: 5, d1: 5, d2: 5, d3: 5, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(is_unanimous(a1, 4), 1);

    let a2 = Arr8 { d0: 5, d1: 5, d2: 4, d3: 5, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(is_unanimous(a2, 4), 0);

    // Single element is unanimous
    assert_eq(is_unanimous(a1, 1), 1);
    // Empty is unanimous
    assert_eq(is_unanimous(a1, 0), 1);
    1
}

fn test_most_frequent() -> Int {
    let a1 = Arr8 { d0: 1, d1: 2, d2: 2, d3: 3, d4: 3, d5: 3, d6: 0, d7: 0 };
    assert_eq(most_frequent(a1, 6), 3);

    let a2 = Arr8 { d0: 0, d1: 0, d2: 0, d3: 1, d4: 1, d5: 0, d6: 0, d7: 0 };
    assert_eq(most_frequent(a2, 5), 0);
    1
}

fn test_weighted_vote() -> Int {
    // vals=[1,2,1], weights=[10,100,10] => 2 wins with weight 100 vs 1 with 20
    let vals = Arr8 { d0: 1, d1: 2, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let wts = Arr8 { d0: 10, d1: 100, d2: 10, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(weighted_majority(vals, wts, 3), 2);

    // vals=[3,3,3,1], weights=[1,1,1,100] => 1 wins with weight 100 vs 3 with 3
    let v2 = Arr8 { d0: 3, d1: 3, d2: 3, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 };
    let w2 = Arr8 { d0: 1, d1: 1, d2: 1, d3: 100, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(weighted_majority(v2, w2, 4), 1);

    // Equal weights => most frequent wins
    let v3 = Arr8 { d0: 2, d1: 2, d2: 2, d3: 1, d4: 1, d5: 0, d6: 0, d7: 0 };
    let w3 = Arr8 { d0: 1, d1: 1, d2: 1, d3: 1, d4: 1, d5: 0, d6: 0, d7: 0 };
    assert_eq(weighted_majority(v3, w3, 5), 2);
    1
}

fn main() -> Int {
    test_third_majority();
    test_distinct();
    test_unanimous();
    test_most_frequent();
    test_weighted_vote();
    print("DIFF_OK: majority_vote");
    0
}
