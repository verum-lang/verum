// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, bloom-filter, probabilistic, hashing
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }

// Bit array of 64 bits stored as 8 bytes
// Bit positions 0-63

fn get_bit(bits: Arr8, pos: Int) -> Int {
    let byte_idx = pos / 8;
    let bit_idx = pos % 8;
    let byte_val = get(bits, byte_idx);
    let mut shifted = byte_val;
    let mut i = 0;
    while i < bit_idx {
        shifted = shifted / 2;
        i = i + 1;
    }
    shifted % 2
}

fn set_bit(bits: Arr8, pos: Int) -> Arr8 {
    let byte_idx = pos / 8;
    let bit_idx = pos % 8;
    let byte_val = get(bits, byte_idx);
    // Check if already set
    if get_bit(bits, pos) == 1 { return bits; }
    // Set the bit by adding 2^bit_idx
    let mut power = 1;
    let mut i = 0;
    while i < bit_idx {
        power = power * 2;
        i = i + 1;
    }
    set(bits, byte_idx, byte_val + power)
}

// Three hash functions for the bloom filter
fn hash1(val: Int) -> Int { abs_val((val * 7 + 3) % 64) }
fn hash2(val: Int) -> Int { abs_val((val * 13 + 17) % 64) }
fn hash3(val: Int) -> Int { abs_val((val * 31 + 5) % 64) }

// Insert value into bloom filter
fn bloom_insert(bits: Arr8, val: Int) -> Arr8 {
    let b1 = set_bit(bits, hash1(val));
    let b2 = set_bit(b1, hash2(val));
    set_bit(b2, hash3(val))
}

// Query: might-contain (1) or definitely-not (0)
fn bloom_query(bits: Arr8, val: Int) -> Int {
    if get_bit(bits, hash1(val)) == 0 { return 0; }
    if get_bit(bits, hash2(val)) == 0 { return 0; }
    if get_bit(bits, hash3(val)) == 0 { return 0; }
    1
}

// Count bits set
fn popcount(bits: Arr8) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 64 {
        count = count + get_bit(bits, i);
        i = i + 1;
    }
    count
}

fn main() -> Int {
    // Empty filter: nothing found
    let mut bf = zeros();
    assert_eq(bloom_query(bf, 42), 0);
    assert_eq(bloom_query(bf, 0), 0);
    assert_eq(popcount(bf), 0);

    // Insert and query
    bf = bloom_insert(bf, 42);
    assert_eq(bloom_query(bf, 42), 1); // definitely present

    // Other values probably not found (no false positive guarantee, but likely)
    // After inserting only 42, most values should not match all 3 hashes

    // Insert more
    bf = bloom_insert(bf, 100);
    bf = bloom_insert(bf, 7);
    assert_eq(bloom_query(bf, 42), 1);
    assert_eq(bloom_query(bf, 100), 1);
    assert_eq(bloom_query(bf, 7), 1);

    // Bits set should be at most 9 (3 hashes * 3 values, some may overlap)
    let pc = popcount(bf);
    assert_eq(pc > 0, true);
    assert_eq(pc <= 9, true);

    // No false negatives: inserted values always found
    bf = bloom_insert(bf, 1);
    bf = bloom_insert(bf, 2);
    bf = bloom_insert(bf, 3);
    assert_eq(bloom_query(bf, 1), 1);
    assert_eq(bloom_query(bf, 2), 1);
    assert_eq(bloom_query(bf, 3), 1);
    assert_eq(bloom_query(bf, 42), 1);
    assert_eq(bloom_query(bf, 100), 1);
    assert_eq(bloom_query(bf, 7), 1);

    // Bit operations tests
    let mut test_bits = zeros();
    test_bits = set_bit(test_bits, 0);
    assert_eq(get_bit(test_bits, 0), 1);
    assert_eq(get_bit(test_bits, 1), 0);

    test_bits = set_bit(test_bits, 7);
    assert_eq(get_bit(test_bits, 7), 1);

    test_bits = set_bit(test_bits, 8);
    assert_eq(get_bit(test_bits, 8), 1);
    assert_eq(get_bit(test_bits, 9), 0);

    // Setting same bit twice is idempotent
    let bits_before = popcount(test_bits);
    test_bits = set_bit(test_bits, 0);
    assert_eq(popcount(test_bits), bits_before);

    // Hash functions produce different values for different inputs
    assert_eq(hash1(0) == hash1(1), false);
    assert_eq(hash2(0) == hash2(1), false);

    // Hash values in range [0, 63]
    assert_eq(hash1(99) >= 0, true);
    assert_eq(hash1(99) < 64, true);
    assert_eq(hash2(99) >= 0, true);
    assert_eq(hash2(99) < 64, true);
    assert_eq(hash3(99) >= 0, true);
    assert_eq(hash3(99) < 64, true);

    print("DIFF_OK: bloom_filter");
    0
}
