// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, fibonacci, dynamic-programming, sequences
// @timeout: 10000

// Standard Fibonacci
fn fib(n: Int) -> Int {
    if n <= 1 { return n; }
    let mut a = 0;
    let mut b = 1;
    let mut i = 2;
    while i <= n {
        let c = a + b;
        a = b;
        b = c;
        i = i + 1;
    }
    b
}

// Tribonacci: T(n) = T(n-1) + T(n-2) + T(n-3), T(0)=0, T(1)=0, T(2)=1
fn tribonacci(n: Int) -> Int {
    if n == 0 { return 0; }
    if n == 1 { return 0; }
    if n == 2 { return 1; }
    let mut a = 0;
    let mut b = 0;
    let mut c = 1;
    let mut i = 3;
    while i <= n {
        let d = a + b + c;
        a = b;
        b = c;
        c = d;
        i = i + 1;
    }
    c
}

// Lucas numbers: L(0)=2, L(1)=1, L(n) = L(n-1) + L(n-2)
fn lucas(n: Int) -> Int {
    if n == 0 { return 2; }
    if n == 1 { return 1; }
    let mut a = 2;
    let mut b = 1;
    let mut i = 2;
    while i <= n {
        let c = a + b;
        a = b;
        b = c;
        i = i + 1;
    }
    b
}

// Pell numbers: P(0)=0, P(1)=1, P(n) = 2*P(n-1) + P(n-2)
fn pell(n: Int) -> Int {
    if n == 0 { return 0; }
    if n == 1 { return 1; }
    let mut a = 0;
    let mut b = 1;
    let mut i = 2;
    while i <= n {
        let c = 2 * b + a;
        a = b;
        b = c;
        i = i + 1;
    }
    b
}

fn test_fib() -> Int {
    assert_eq(fib(0), 0);
    assert_eq(fib(1), 1);
    assert_eq(fib(5), 5);
    assert_eq(fib(10), 55);
    assert_eq(fib(15), 610);
    assert_eq(fib(20), 6765);
    1
}

fn test_tribonacci() -> Int {
    assert_eq(tribonacci(0), 0);
    assert_eq(tribonacci(2), 1);
    assert_eq(tribonacci(4), 2);  // 0,0,1,1,2
    assert_eq(tribonacci(5), 4);  // 0,0,1,1,2,4
    assert_eq(tribonacci(7), 13); // 0,0,1,1,2,4,7,13
    1
}

fn test_lucas() -> Int {
    assert_eq(lucas(0), 2);
    assert_eq(lucas(1), 1);
    assert_eq(lucas(2), 3);
    assert_eq(lucas(5), 11);  // 2,1,3,4,7,11
    // L(n) = F(n-1) + F(n+1)
    assert_eq(lucas(6), fib(5) + fib(7));
    1
}

fn test_pell() -> Int {
    assert_eq(pell(0), 0);
    assert_eq(pell(1), 1);
    assert_eq(pell(2), 2);   // 2*1+0
    assert_eq(pell(3), 5);   // 2*2+1
    assert_eq(pell(4), 12);  // 2*5+2
    assert_eq(pell(5), 29);  // 2*12+5
    1
}

fn main() -> Int {
    test_fib();
    test_tribonacci();
    test_lucas();
    test_pell();
    print("DIFF_OK: fibonacci_variants");
    0
}
