// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, dutch, flag, partition, sorting
// @timeout: 10000

// Dutch National Flag problem and partitioning algorithms

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn swap_arr(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = get8(a, i);
    let vj = get8(a, j);
    let tmp = set8(a, i, vj);
    set8(tmp, j, vi)
}

// Dutch National Flag: sort array with values 0, 1, 2
// 3-way partition
fn dutch_flag(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut lo = 0;
    let mut mid = 0;
    let mut hi = n - 1;
    while mid <= hi {
        let v = get8(a, mid);
        if v == 0 {
            a = swap_arr(a, lo, mid);
            lo = lo + 1;
            mid = mid + 1;
        } else if v == 1 {
            mid = mid + 1;
        } else {
            a = swap_arr(a, mid, hi);
            hi = hi - 1;
        }
    }
    a
}

// Lomuto partition: partition around pivot
fn lomuto_partition(arr: Arr8, n: Int, pivot: Int) -> Int {
    // Returns count of elements <= pivot
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) <= pivot { count = count + 1; }
        i = i + 1;
    }
    count
}

// Stable partition: separate elements by predicate (keep relative order)
// predicate: value < threshold
fn stable_partition_count(arr: Arr8, n: Int, threshold: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) < threshold { count = count + 1; }
        i = i + 1;
    }
    count
}

// Three-way count: count 0s, 1s, 2s
fn count_values(arr: Arr8, n: Int, target: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) == target { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_dutch_flag() -> Int {
    let arr = Arr8 { v0: 2, v1: 0, v2: 1, v3: 2, v4: 0, v5: 1, v6: 0, v7: 2 };
    let sorted = dutch_flag(arr, 8);
    // Should be [0,0,0,1,1,2,2,2]
    assert_eq(get8(sorted, 0), 0);
    assert_eq(get8(sorted, 1), 0);
    assert_eq(get8(sorted, 2), 0);
    assert_eq(get8(sorted, 3), 1);
    assert_eq(get8(sorted, 4), 1);
    assert_eq(get8(sorted, 5), 2);
    assert_eq(get8(sorted, 6), 2);
    assert_eq(get8(sorted, 7), 2);
    1
}

fn test_count_preserved() -> Int {
    let arr = Arr8 { v0: 2, v1: 0, v2: 1, v3: 2, v4: 0, v5: 1, v6: 0, v7: 2 };
    let sorted = dutch_flag(arr, 8);
    // Counts should be preserved
    assert_eq(count_values(sorted, 8, 0), 3);
    assert_eq(count_values(sorted, 8, 1), 2);
    assert_eq(count_values(sorted, 8, 2), 3);
    1
}

fn test_lomuto() -> Int {
    let arr = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 2, v7: 6 };
    assert_eq(lomuto_partition(arr, 8, 4), 5); // 3,1,4,1,2 <= 4
    assert_eq(lomuto_partition(arr, 8, 1), 2); // 1,1 <= 1
    1
}

fn test_all_same() -> Int {
    let arr = Arr8 { v0: 1, v1: 1, v2: 1, v3: 1, v4: 1, v5: 1, v6: 1, v7: 1 };
    let sorted = dutch_flag(arr, 8);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 7), 1);
    1
}

fn main() -> Int {
    test_dutch_flag();
    test_count_preserved();
    test_lomuto();
    test_all_same();
    print("DIFF_OK: dutch_flag");
    0
}
