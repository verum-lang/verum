// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, stack, operations, simulation
// @timeout: 10000

// Stack-based operations

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn new_arr8() -> Arr8 {
    Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
}

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

type Stack is { data: Arr8, sp: Int };

fn stack_new() -> Stack {
    Stack { data: new_arr8(), sp: 0 }
}

fn stack_push(s: Stack, v: Int) -> Stack {
    Stack { data: set8(s.data, s.sp, v), sp: s.sp + 1 }
}

fn stack_pop(s: Stack) -> Stack {
    Stack { data: s.data, sp: s.sp - 1 }
}

fn stack_top(s: Stack) -> Int {
    get8(s.data, s.sp - 1)
}

fn stack_empty(s: Stack) -> Int {
    if s.sp == 0 { 1 } else { 0 }
}

// Check balanced brackets: 1=open, 2=close
fn check_balanced(seq: Arr8, n: Int) -> Int {
    let mut s = stack_new();
    let mut i = 0;
    while i < n {
        let v = get8(seq, i);
        if v == 1 {
            s = stack_push(s, 1);
        } else if v == 2 {
            if stack_empty(s) == 1 { return 0; }
            s = stack_pop(s);
        }
        i = i + 1;
    }
    stack_empty(s)
}

// Evaluate postfix with just ADD and MUL
fn eval_postfix(tokens: Arr8, n: Int) -> Int {
    // Positive = number, -1 = ADD, -2 = MUL
    let mut s = stack_new();
    let mut i = 0;
    while i < n {
        let t = get8(tokens, i);
        if t >= 0 {
            s = stack_push(s, t);
        } else {
            let b = stack_top(s);
            s = stack_pop(s);
            let a = stack_top(s);
            s = stack_pop(s);
            if t == -1 {
                s = stack_push(s, a + b);
            } else {
                s = stack_push(s, a * b);
            }
        }
        i = i + 1;
    }
    stack_top(s)
}

// Min stack: track minimum alongside regular stack
// Use two stacks: main and min-tracker
fn min_stack_test() -> Int {
    let mut main_s = stack_new();
    let mut min_s = stack_new();

    // Push 5
    main_s = stack_push(main_s, 5);
    min_s = stack_push(min_s, 5);

    // Push 3 (new min)
    main_s = stack_push(main_s, 3);
    min_s = stack_push(min_s, 3);

    // Push 7 (min stays 3)
    main_s = stack_push(main_s, 7);
    min_s = stack_push(min_s, 3);

    // Push 1 (new min)
    main_s = stack_push(main_s, 1);
    min_s = stack_push(min_s, 1);

    assert_eq(stack_top(min_s), 1);

    // Pop 1
    main_s = stack_pop(main_s);
    min_s = stack_pop(min_s);
    assert_eq(stack_top(min_s), 3);

    // Pop 7
    main_s = stack_pop(main_s);
    min_s = stack_pop(min_s);
    assert_eq(stack_top(min_s), 3);

    // Pop 3
    main_s = stack_pop(main_s);
    min_s = stack_pop(min_s);
    assert_eq(stack_top(min_s), 5);

    1
}

fn test_balanced() -> Int {
    // (()) = 1,1,2,2 -> balanced
    let b1 = Arr8 { v0: 1, v1: 1, v2: 2, v3: 2, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(check_balanced(b1, 4), 1);

    // ())( = 1,2,2,1 -> not balanced
    let b2 = Arr8 { v0: 1, v1: 2, v2: 2, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(check_balanced(b2, 4), 0);

    // ()() = 1,2,1,2 -> balanced
    let b3 = Arr8 { v0: 1, v1: 2, v2: 1, v3: 2, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(check_balanced(b3, 4), 1);
    1
}

fn test_postfix() -> Int {
    // 3 4 ADD 2 MUL = (3+4)*2 = 14
    let tokens = Arr8 { v0: 3, v1: 4, v2: -1, v3: 2, v4: -2, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval_postfix(tokens, 5), 14);

    // 2 3 MUL 4 5 MUL ADD = 6+20 = 26
    let t2 = Arr8 { v0: 2, v1: 3, v2: -2, v3: 4, v4: 5, v5: -2, v6: -1, v7: 0 };
    assert_eq(eval_postfix(t2, 7), 26);
    1
}

fn main() -> Int {
    test_balanced();
    test_postfix();
    min_stack_test();
    print("DIFF_OK: stack_ops");
    0
}
