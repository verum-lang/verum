// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, plateau, sequence, array
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// Longest plateau: longest run of equal consecutive elements
fn longest_plateau(a: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut best = 1;
    let mut cur = 1;
    let mut i = 1;
    while i < n {
        if get(a, i) == get(a, i - 1) {
            cur = cur + 1;
            best = max_val(best, cur);
        } else {
            cur = 1;
        }
        i = i + 1;
    }
    best
}

// Longest increasing run
fn longest_increasing_run(a: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut best = 1;
    let mut cur = 1;
    let mut i = 1;
    while i < n {
        if get(a, i) > get(a, i - 1) {
            cur = cur + 1;
            best = max_val(best, cur);
        } else {
            cur = 1;
        }
        i = i + 1;
    }
    best
}

// Longest decreasing run
fn longest_decreasing_run(a: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut best = 1;
    let mut cur = 1;
    let mut i = 1;
    while i < n {
        if get(a, i) < get(a, i - 1) {
            cur = cur + 1;
            best = max_val(best, cur);
        } else {
            cur = 1;
        }
        i = i + 1;
    }
    best
}

// Count peaks (a[i] > a[i-1] and a[i] > a[i+1])
fn count_peaks(a: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i < n - 1 {
        if get(a, i) > get(a, i - 1) {
            if get(a, i) > get(a, i + 1) {
                count = count + 1;
            }
        }
        i = i + 1;
    }
    count
}

// Count valleys (a[i] < a[i-1] and a[i] < a[i+1])
fn count_valleys(a: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i < n - 1 {
        if get(a, i) < get(a, i - 1) {
            if get(a, i) < get(a, i + 1) {
                count = count + 1;
            }
        }
        i = i + 1;
    }
    count
}

// Check if sorted (non-decreasing)
fn is_sorted(a: Arr8, n: Int) -> Int {
    let mut i = 1;
    while i < n {
        if get(a, i) < get(a, i - 1) { return 0; }
        i = i + 1;
    }
    1
}

fn main() -> Int {
    // [1,2,2,2,3,1,1,4]
    let a1 = Arr8 { d0: 1, d1: 2, d2: 2, d3: 2, d4: 3, d5: 1, d6: 1, d7: 4 };
    assert_eq(longest_plateau(a1, 8), 3);    // three 2s
    assert_eq(longest_increasing_run(a1, 8), 2); // 1→2 or 1→4
    assert_eq(longest_decreasing_run(a1, 8), 2); // 3→1

    // All same: [5,5,5,5,5]
    let a2 = Arr8 { d0: 5, d1: 5, d2: 5, d3: 5, d4: 5, d5: 0, d6: 0, d7: 0 };
    assert_eq(longest_plateau(a2, 5), 5);
    assert_eq(longest_increasing_run(a2, 5), 1);
    assert_eq(longest_decreasing_run(a2, 5), 1);

    // Strictly increasing: [1,2,3,4,5,6,7,8]
    let a3 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 5, d5: 6, d6: 7, d7: 8 };
    assert_eq(longest_plateau(a3, 8), 1);
    assert_eq(longest_increasing_run(a3, 8), 8);
    assert_eq(longest_decreasing_run(a3, 8), 1);
    assert_eq(is_sorted(a3, 8), 1);

    // Peaks and valleys: [1,3,2,4,1,5,2,3]
    let a4 = Arr8 { d0: 1, d1: 3, d2: 2, d3: 4, d4: 1, d5: 5, d6: 2, d7: 3 };
    assert_eq(count_peaks(a4, 8), 3);   // 3, 4, 5 are peaks
    assert_eq(count_valleys(a4, 8), 3); // 2, 1, 2 are valleys (positions 2, 4, 6)

    // No peaks or valleys in sorted array
    assert_eq(count_peaks(a3, 8), 0);
    assert_eq(count_valleys(a3, 8), 0);

    // Single element
    let a5 = Arr8 { d0: 42, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(longest_plateau(a5, 1), 1);

    // Two elements
    let a6 = Arr8 { d0: 3, d1: 3, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(longest_plateau(a6, 2), 2);

    // V-shape [5,3,1,3,5]
    let a7 = Arr8 { d0: 5, d1: 3, d2: 1, d3: 3, d4: 5, d5: 0, d6: 0, d7: 0 };
    assert_eq(count_valleys(a7, 5), 1);
    assert_eq(count_peaks(a7, 5), 0);
    assert_eq(longest_decreasing_run(a7, 5), 3); // 5,3,1
    assert_eq(longest_increasing_run(a7, 5), 3); // 1,3,5

    print("DIFF_OK: longest_plateau");
    0
}
