// @test: differential

// @level: L0
// @tags: differential, fsm, automaton, state-machine
// @timeout: 30000

// Differential test: Finite state machine simulation

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

// FSM for matching "ab" pattern (a=0, b=1)
// States: 0=start, 1=seen_a, 2=accept, 3=dead
fn fsm_ab(state: Int, sym: Int) -> Int {
    if state == 0 {
        if sym == 0 { 1 } else { 3 }
    } else if state == 1 {
        if sym == 1 { 2 } else { 3 }
    } else { 3 }
}

fn run_fsm_ab(input: Arr8, len: Int) -> Int {
    let mut state = 0;
    let mut i = 0;
    while i < len {
        state = fsm_ab(state, get8(input, i));
        i = i + 1;
    }
    state
}

// FSM for even number of 1s in binary
fn fsm_even(state: Int, sym: Int) -> Int {
    if sym == 1 {
        if state == 0 { 1 } else { 0 }
    } else { state }
}

fn run_fsm_even(input: Arr8, len: Int) -> Int {
    let mut state = 0;
    let mut i = 0;
    while i < len {
        state = fsm_even(state, get8(input, i));
        i = i + 1;
    }
    state
}

// FSM for divisibility by 3 (reading binary MSB-first)
fn fsm_div3(state: Int, bit: Int) -> Int {
    (state * 2 + bit) % 3
}

fn run_fsm_div3(input: Arr8, len: Int) -> Int {
    let mut state = 0;
    let mut i = 0;
    while i < len {
        state = fsm_div3(state, get8(input, i));
        i = i + 1;
    }
    state
}

fn main() -> Int {
    // "ab" FSM tests
    let ab = Arr8 { v0: 0, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_ab(ab, 2), 2); // "ab" → accept

    let a_only = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_ab(a_only, 1), 1); // "a" → seen_a
    assert_eq(run_fsm_ab(a_only, 2), 3); // "aa" → dead

    let b_only = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_ab(b_only, 1), 3); // "b" → dead

    assert_eq(run_fsm_ab(ab, 0), 0); // empty → start

    // Even ones FSM
    let ones2 = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_even(ones2, 0), 0); // 0 ones = even
    assert_eq(run_fsm_even(ones2, 1), 1); // 1 one = odd
    assert_eq(run_fsm_even(ones2, 2), 0); // 2 ones = even

    let ones4 = Arr8 { v0: 1, v1: 1, v2: 1, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_even(ones4, 3), 1); // 3 ones = odd
    assert_eq(run_fsm_even(ones4, 4), 0); // 4 ones = even

    let mixed = Arr8 { v0: 1, v1: 0, v2: 1, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_even(mixed, 6), 1); // 3 ones = odd

    // Divisibility by 3 FSM
    // Binary "110" = 6, div by 3 → state 0
    let six = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_div3(six, 3), 0);

    // Binary "111" = 7, 7%3=1 → state 1
    let seven = Arr8 { v0: 1, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_div3(seven, 3), 1);

    // Binary "1001" = 9, div by 3 → state 0
    let nine = Arr8 { v0: 1, v1: 0, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_div3(nine, 4), 0);

    // Binary "101" = 5, 5%3=2 → state 2
    let five = Arr8 { v0: 1, v1: 0, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_div3(five, 3), 2);

    // Binary "1100" = 12, div by 3 → state 0
    let twelve = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(run_fsm_div3(twelve, 4), 0);

    print("[OK] diff_fsm_automaton");
    0
}
