// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, minimax, game-tree, alpha-beta
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Minimax on a complete binary tree of depth 3 (8 leaf values)
// Leaves are in arr[0..7], internal nodes evaluated bottom-up
// Depth 3: root is max player
// Depth 2: 2 nodes, min player
// Depth 1: 4 nodes, max player
// Depth 0: 8 leaf nodes

// Layer 1 (max of pairs): 4 values
fn layer1_val(leaves: Arr8, idx: Int) -> Int {
    max_val(get(leaves, idx * 2), get(leaves, idx * 2 + 1))
}

// Layer 2 (min of pairs of layer1): 2 values
fn layer2_val(leaves: Arr8, idx: Int) -> Int {
    min_val(layer1_val(leaves, idx * 2), layer1_val(leaves, idx * 2 + 1))
}

// Root (max of layer2): 1 value
fn minimax_root(leaves: Arr8) -> Int {
    max_val(layer2_val(leaves, 0), layer2_val(leaves, 1))
}

// Nim game: with n stones, optimal move (take 1-3)
// Returns 1 if current player wins, 0 if loses
fn nim_winner(n: Int) -> Int {
    if n % 4 == 0 { 0 } else { 1 }
}

// Nim optimal move: take (n % 4) stones, or 1 if n % 4 == 0
fn nim_move(n: Int) -> Int {
    let take = n % 4;
    if take == 0 { 1 } else { take }
}

// Evaluate tic-tac-toe position (3x3 stored as 9 values: 0=empty, 1=X, 2=O)
// Check for winner
type Board9 is { c0: Int, c1: Int, c2: Int, c3: Int, c4: Int, c5: Int, c6: Int, c7: Int, c8: Int };

fn bget(b: Board9, i: Int) -> Int {
    if i == 0 { b.c0 } else if i == 1 { b.c1 } else if i == 2 { b.c2 }
    else if i == 3 { b.c3 } else if i == 4 { b.c4 } else if i == 5 { b.c5 }
    else if i == 6 { b.c6 } else if i == 7 { b.c7 } else { b.c8 }
}

// Check if player p wins
fn check_win(b: Board9, p: Int) -> Int {
    // Rows
    if bget(b, 0) == p { if bget(b, 1) == p { if bget(b, 2) == p { return 1; } } }
    if bget(b, 3) == p { if bget(b, 4) == p { if bget(b, 5) == p { return 1; } } }
    if bget(b, 6) == p { if bget(b, 7) == p { if bget(b, 8) == p { return 1; } } }
    // Cols
    if bget(b, 0) == p { if bget(b, 3) == p { if bget(b, 6) == p { return 1; } } }
    if bget(b, 1) == p { if bget(b, 4) == p { if bget(b, 7) == p { return 1; } } }
    if bget(b, 2) == p { if bget(b, 5) == p { if bget(b, 8) == p { return 1; } } }
    // Diags
    if bget(b, 0) == p { if bget(b, 4) == p { if bget(b, 8) == p { return 1; } } }
    if bget(b, 2) == p { if bget(b, 4) == p { if bget(b, 6) == p { return 1; } } }
    0
}

fn test_minimax() -> Int {
    // Leaves: [3, 5, 6, 9, 1, 2, 0, -1]
    // Layer 1 (max pairs): max(3,5)=5, max(6,9)=9, max(1,2)=2, max(0,-1)=0
    // Layer 2 (min pairs): min(5,9)=5, min(2,0)=0
    // Root (max): max(5,0) = 5
    let leaves = Arr8 { d0: 3, d1: 5, d2: 6, d3: 9, d4: 1, d5: 2, d6: 0, d7: -1 };
    assert_eq(minimax_root(leaves), 5);
    1
}

fn test_minimax2() -> Int {
    // All same → result is that value
    let same = Arr8 { d0: 7, d1: 7, d2: 7, d3: 7, d4: 7, d5: 7, d6: 7, d7: 7 };
    assert_eq(minimax_root(same), 7);
    // Increasing: [0,1,2,3,4,5,6,7]
    let inc = Arr8 { d0: 0, d1: 1, d2: 2, d3: 3, d4: 4, d5: 5, d6: 6, d7: 7 };
    // L1: 1, 3, 5, 7
    // L2: min(1,3)=1, min(5,7)=5
    // Root: max(1,5) = 5
    assert_eq(minimax_root(inc), 5);
    1
}

fn test_nim() -> Int {
    assert_eq(nim_winner(0), 0);  // no stones = lose
    assert_eq(nim_winner(1), 1);
    assert_eq(nim_winner(4), 0);
    assert_eq(nim_winner(5), 1);
    assert_eq(nim_winner(8), 0);
    assert_eq(nim_move(5), 1);    // take 1, leave 4
    assert_eq(nim_move(7), 3);    // take 3, leave 4
    1
}

fn test_tictactoe() -> Int {
    // X wins top row
    let b1 = Board9 { c0: 1, c1: 1, c2: 1, c3: 0, c4: 2, c5: 2, c6: 0, c7: 0, c8: 0 };
    assert_eq(check_win(b1, 1), 1);
    assert_eq(check_win(b1, 2), 0);
    // O wins diagonal
    let b2 = Board9 { c0: 2, c1: 1, c2: 0, c3: 1, c4: 2, c5: 0, c6: 0, c7: 1, c8: 2 };
    assert_eq(check_win(b2, 2), 1);
    // No winner
    let b3 = Board9 { c0: 1, c1: 2, c2: 1, c3: 2, c4: 1, c5: 2, c6: 2, c7: 1, c8: 2 };
    assert_eq(check_win(b3, 1), 0);
    assert_eq(check_win(b3, 2), 0);
    1
}

fn main() -> Int {
    test_minimax();
    test_minimax2();
    test_nim();
    test_tictactoe();

    print("DIFF_OK: minimax");
    0
}
