// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, dp, matrix, chain, optimization
// @timeout: 10000

// Matrix chain multiplication order optimization (small instances)
// Using flat arrays for DP table

type Arr6 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int };

fn new_arr6() -> Arr6 {
    Arr6 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0 }
}

fn get6(a: Arr6, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else { a.v5 }
}

fn set6(a: Arr6, i: Int, v: Int) -> Arr6 {
    Arr6 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 }
    }
}

// Matrix chain for 3 matrices: dimensions d0 x d1, d1 x d2, d2 x d3
// Two possible orderings: (AB)C or A(BC)
fn chain_3(d0: Int, d1: Int, d2: Int, d3: Int) -> Int {
    let cost1 = d0 * d1 * d2 + d0 * d2 * d3;  // (AB)C
    let cost2 = d1 * d2 * d3 + d0 * d1 * d3;  // A(BC)
    if cost1 < cost2 { cost1 } else { cost2 }
}

// Matrix chain for 4 matrices: d0xd1, d1xd2, d2xd3, d3xd4
// Five possible orderings
fn chain_4(d0: Int, d1: Int, d2: Int, d3: Int, d4: Int) -> Int {
    // Split at k=1: A * (BCD)
    let bc_d = chain_3(d1, d2, d3, d4);
    let c1 = d0 * d1 * d4 + bc_d;

    // Split at k=2: (AB) * (CD)
    let ab = d0 * d1 * d2;
    let cd = d2 * d3 * d4;
    let c2 = ab + cd + d0 * d2 * d4;

    // Split at k=3: (ABC) * D
    let abc = chain_3(d0, d1, d2, d3);
    let c3 = abc + d0 * d3 * d4;

    let m12 = if c1 < c2 { c1 } else { c2 };
    if m12 < c3 { m12 } else { c3 }
}

// Minimum scalar multiplications for matrix product
fn test_chain_3() -> Int {
    // A: 10x30, B: 30x5, C: 5x60
    // (AB)C = 10*30*5 + 10*5*60 = 1500 + 3000 = 4500
    // A(BC) = 30*5*60 + 10*30*60 = 9000 + 18000 = 27000
    assert_eq(chain_3(10, 30, 5, 60), 4500);

    // A: 40x20, B: 20x30, C: 30x10
    // (AB)C = 40*20*30 + 40*30*10 = 24000 + 12000 = 36000
    // A(BC) = 20*30*10 + 40*20*10 = 6000 + 8000 = 14000
    assert_eq(chain_3(40, 20, 30, 10), 14000);
    1
}

fn test_chain_4() -> Int {
    // Classic example: dimensions 1x2, 2x3, 3x4, 4x3
    let result = chain_4(1, 2, 3, 4, 3);
    // Optimal: ((AB)C)D
    // AB: 1*2*3=6, (AB)C: 1*3*4=12, ((AB)C)D: 1*4*3=12
    // Total: 6+12+12=30
    assert_eq(result, 30);
    1
}

// Rod cutting problem (similar DP structure)
// Prices for lengths 1..5, rod length n
fn rod_cut_5(n: Int) -> Int {
    // prices: length 1->2, 2->5, 3->7, 4->8, 5->10
    let prices = Arr6 { v0: 0, v1: 2, v2: 5, v3: 7, v4: 8, v5: 10 };
    // dp[i] = max revenue for rod of length i
    let mut dp = new_arr6();
    // dp[0] = 0

    let mut i = 1;
    while i <= n {
        let mut best = 0;
        let mut j = 1;
        while j <= i {
            let candidate = get6(prices, j) + get6(dp, i - j);
            if candidate > best { best = candidate; }
            j = j + 1;
        }
        dp = set6(dp, i, best);
        i = i + 1;
    }
    get6(dp, n)
}

fn test_rod_cutting() -> Int {
    assert_eq(rod_cut_5(1), 2);
    assert_eq(rod_cut_5(2), 5);
    assert_eq(rod_cut_5(3), 7);
    assert_eq(rod_cut_5(4), 10);  // cut into 2+2: 5+5=10
    assert_eq(rod_cut_5(5), 12);  // cut into 2+3: 5+7=12
    1
}

fn main() -> Int {
    test_chain_3();
    test_chain_4();
    test_rod_cutting();
    print("DIFF_OK: matrix_chain");
    0
}
