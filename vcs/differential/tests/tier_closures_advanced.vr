// @test: differential

// @tier: 0, 3
// @level: L0
// @tags: differential, closures, higher-order
// @timeout: 10000
// @expected-exit: 0
// @description: Higher-order functions (apply_twice, compose), verify results

fn main() -> Int {
    test_apply_twice();
    test_compose();
    test_accumulator();
    0
}

/// Apply a transformation function twice
fn double_val(x: Int) -> Int {
    x * 2
}

fn add_three(x: Int) -> Int {
    x + 3
}

fn square_val(x: Int) -> Int {
    x * x
}

fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int {
    f(f(x))
}

/// Test apply_twice with various functions
fn test_apply_twice() {
    // double(double(5)) = double(10) = 20
    let r1 = apply_twice(double_val, 5);
    assert_eq(r1, 20);

    // add_three(add_three(10)) = add_three(13) = 16
    let r2 = apply_twice(add_three, 10);
    assert_eq(r2, 16);

    // square(square(3)) = square(9) = 81
    let r3 = apply_twice(square_val, 3);
    assert_eq(r3, 81);

    // double(double(0)) = 0
    let r4 = apply_twice(double_val, 0);
    assert_eq(r4, 0);
    print("apply_twice: pass\n");
}

/// Compose two functions: compose(f, g)(x) = f(g(x))
fn compose_fns(f: fn(Int) -> Int, g: fn(Int) -> Int, x: Int) -> Int {
    f(g(x))
}

/// Test function composition
fn test_compose() {
    // double(add_three(5)) = double(8) = 16
    let r1 = compose_fns(double_val, add_three, 5);
    assert_eq(r1, 16);

    // add_three(double(5)) = add_three(10) = 13
    let r2 = compose_fns(add_three, double_val, 5);
    assert_eq(r2, 13);

    // square(add_three(2)) = square(5) = 25
    let r3 = compose_fns(square_val, add_three, 2);
    assert_eq(r3, 25);

    // add_three(square(4)) = add_three(16) = 19
    let r4 = compose_fns(add_three, square_val, 4);
    assert_eq(r4, 19);

    // Triple compose: double(square(add_three(1)))
    // add_three(1)=4, square(4)=16, double(16)=32
    let inner = compose_fns(square_val, add_three, 1);
    let r5 = double_val(inner);
    assert_eq(r5, 32);
    print("compose: pass\n");
}

/// Simulate accumulator pattern with explicit operation dispatch
fn test_accumulator() {
    // Apply a series of operations to a running value
    // ops: 1=double, 2=add_three, 3=square
    let mut ops = [0, 0, 0, 0, 0];
    ops[0] = 1;
    ops[1] = 2;
    ops[2] = 1;
    ops[3] = 3;
    ops[4] = 2;
    let n = 5;
    let mut val = 2;

    let mut i = 0;
    while i < n {
        if ops[i] == 1 {
            val = double_val(val);
        } else if ops[i] == 2 {
            val = add_three(val);
        } else {
            val = square_val(val);
        }
        i = i + 1;
    }

    // 2 -> double -> 4 -> add3 -> 7 -> double -> 14 -> square -> 196 -> add3 -> 199
    assert_eq(val, 199);

    // Apply all three in sequence from 1
    let mut v2 = 1;
    v2 = double_val(v2);   // 2
    v2 = add_three(v2);    // 5
    v2 = square_val(v2);   // 25
    assert_eq(v2, 25);
    print("accumulator: pass\n");
}
