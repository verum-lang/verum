// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, dp, lcs, edit, distance
// @timeout: 10000

// Longest Common Subsequence and Edit Distance (small inputs)

type Arr6 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int };

fn new_arr6() -> Arr6 {
    Arr6 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0 }
}

fn get6(a: Arr6, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else { a.v5 }
}

fn set6(a: Arr6, i: Int, v: Int) -> Arr6 {
    Arr6 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 }
    }
}

// LCS of two sequences of length <= 5
// Uses a 6x6 DP table stored as 6 rows of Arr6
fn lcs_len(a: Arr6, alen: Int, b: Arr6, blen: Int) -> Int {
    // dp[i] stores previous row, dp_cur stores current row
    let mut prev = new_arr6();

    let mut i = 1;
    while i <= alen {
        let mut cur = new_arr6();
        // cur[0] = 0
        let mut j = 1;
        while j <= blen {
            let val = if get6(a, i - 1) == get6(b, j - 1) {
                get6(prev, j - 1) + 1
            } else {
                let up = get6(prev, j);
                let left = get6(cur, j - 1);
                if up > left { up } else { left }
            };
            cur = set6(cur, j, val);
            j = j + 1;
        }
        prev = cur;
        i = i + 1;
    }
    get6(prev, blen)
}

// Edit distance (Levenshtein) for sequences <= 5
fn edit_dist(a: Arr6, alen: Int, b: Arr6, blen: Int) -> Int {
    // Initialize prev row: [0, 1, 2, ..., blen]
    let mut prev = new_arr6();
    let mut j = 0;
    while j <= blen {
        prev = set6(prev, j, j);
        j = j + 1;
    }

    let mut i = 1;
    while i <= alen {
        let mut cur = set6(new_arr6(), 0, i);
        let mut k = 1;
        while k <= blen {
            let cost = if get6(a, i - 1) == get6(b, k - 1) { 0 } else { 1 };
            let replace_cost = get6(prev, k - 1) + cost;
            let delete_cost = get6(prev, k) + 1;
            let insert_cost = get6(cur, k - 1) + 1;
            let mut best = replace_cost;
            if delete_cost < best { best = delete_cost; }
            if insert_cost < best { best = insert_cost; }
            cur = set6(cur, k, best);
            k = k + 1;
        }
        prev = cur;
        i = i + 1;
    }
    get6(prev, blen)
}

// Longest Increasing Subsequence length (O(n^2))
fn lis_len(a: Arr6, n: Int) -> Int {
    // dp[i] = length of LIS ending at index i
    let mut dp = new_arr6();
    let mut i = 0;
    while i < n {
        dp = set6(dp, i, 1);
        i = i + 1;
    }

    let mut i2 = 1;
    while i2 < n {
        let mut j2 = 0;
        while j2 < i2 {
            if get6(a, j2) < get6(a, i2) {
                let candidate = get6(dp, j2) + 1;
                if candidate > get6(dp, i2) {
                    dp = set6(dp, i2, candidate);
                }
            }
            j2 = j2 + 1;
        }
        i2 = i2 + 1;
    }

    let mut best = 0;
    let mut k = 0;
    while k < n {
        if get6(dp, k) > best { best = get6(dp, k); }
        k = k + 1;
    }
    best
}

fn test_lcs() -> Int {
    // LCS of [1,3,4,2,5] and [1,2,4,3,5]
    let a = Arr6 { v0: 1, v1: 3, v2: 4, v3: 2, v4: 5, v5: 0 };
    let b = Arr6 { v0: 1, v1: 2, v2: 4, v3: 3, v4: 5, v5: 0 };
    // LCS: 1,4,5 or 1,3,5 = length 3
    assert_eq(lcs_len(a, 5, b, 5), 3);

    // Identical sequences
    let c = Arr6 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0 };
    assert_eq(lcs_len(c, 3, c, 3), 3);

    // No common elements
    let d = Arr6 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0 };
    let e = Arr6 { v0: 4, v1: 5, v2: 6, v3: 0, v4: 0, v5: 0 };
    assert_eq(lcs_len(d, 3, e, 3), 0);
    1
}

fn test_edit() -> Int {
    // Same strings -> 0
    let a = Arr6 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0 };
    assert_eq(edit_dist(a, 3, a, 3), 0);

    // [1,2,3] -> [1,2,4]: one substitution
    let b = Arr6 { v0: 1, v1: 2, v2: 4, v3: 0, v4: 0, v5: 0 };
    assert_eq(edit_dist(a, 3, b, 3), 1);

    // [1,2,3] -> [1,2]: one deletion
    let c = Arr6 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0 };
    assert_eq(edit_dist(a, 3, c, 2), 1);

    // [1,2,3] -> [4,5,6]: three substitutions
    let d = Arr6 { v0: 4, v1: 5, v2: 6, v3: 0, v4: 0, v5: 0 };
    assert_eq(edit_dist(a, 3, d, 3), 3);
    1
}

fn test_lis() -> Int {
    // [3, 1, 4, 1, 5, 2] -> LIS: 1,4,5 = 3
    let a = Arr6 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 2 };
    assert_eq(lis_len(a, 6), 3);

    // Already sorted [1,2,3,4,5] -> LIS = 5
    let b = Arr6 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0 };
    assert_eq(lis_len(b, 5), 5);

    // Decreasing [5,4,3,2,1] -> LIS = 1
    let c = Arr6 { v0: 5, v1: 4, v2: 3, v3: 2, v4: 1, v5: 0 };
    assert_eq(lis_len(c, 5), 1);
    1
}

fn main() -> Int {
    test_lcs();
    test_edit();
    test_lis();
    print("DIFF_OK: lcs_edit");
    0
}
