// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, arithmetic, coding, entropy
// @timeout: 10000

// Simplified arithmetic coding concepts using integers

// Entropy-related calculations
// log2 approximation for small integers using lookup
fn log2_approx(n: Int) -> Int {
    // Returns floor(log2(n)) for n >= 1
    if n <= 0 { return -1; }
    let mut result = 0;
    let mut v = n;
    while v > 1 {
        v = v / 2;
        result = result + 1;
    }
    result
}

// Bits needed to represent n distinct values
fn bits_needed(n: Int) -> Int {
    if n <= 1 { return 0; }
    log2_approx(n - 1) + 1
}

// Shannon entropy approximation (scaled by 1000) for frequency array
// H = -sum(p_i * log2(p_i))
// We compute sum(freq_i * log2(total/freq_i)) scaled
fn entropy_scaled(freqs: Int, f0: Int, f1: Int, f2: Int, f3: Int, total: Int) -> Int {
    // For each non-zero frequency, contribution = freq * log2(total/freq)
    let mut sum_val = 0;
    if f0 > 0 { sum_val = sum_val + f0 * log2_approx(total / f0); }
    if f1 > 0 { sum_val = sum_val + f1 * log2_approx(total / f1); }
    if f2 > 0 { sum_val = sum_val + f2 * log2_approx(total / f2); }
    if f3 > 0 { sum_val = sum_val + f3 * log2_approx(total / f3); }
    // Return sum (bits * count, total encoding length lower bound)
    sum_val
}

// Huffman code length estimate (using sorted frequencies)
// Returns total encoded bits for 4 symbols
fn huffman_total_bits(f0: Int, f1: Int, f2: Int, f3: Int) -> Int {
    // Sort frequencies (bubble sort of 4 elements)
    let mut a = f0;
    let mut b = f1;
    let mut c = f2;
    let mut d = f3;
    // Sort ascending
    let mut tmp = 0;
    if a > b { tmp = a; a = b; b = tmp; }
    if b > c { tmp = b; b = c; c = tmp; }
    if c > d { tmp = c; c = d; d = tmp; }
    if a > b { tmp = a; a = b; b = tmp; }
    if b > c { tmp = b; b = c; c = tmp; }
    if a > b { tmp = a; a = b; b = tmp; }
    // Now a <= b <= c <= d
    // Huffman for 4 symbols: combine two smallest repeatedly
    // Lengths: smallest 2 get 3 bits, medium gets 2 bits, largest gets 1 bit
    // Actually for 4 symbols: balanced tree gives 2 bits each
    // Real Huffman depends on frequencies
    // Simple approximation: 2 bits per symbol for balanced
    // For skewed: use optimal prefix code
    // With frequencies sorted a<=b<=c<=d:
    // Tree: merge a+b first, then merge with c, then with d
    // Depths: a=3, b=3, c=2, d=1? No...
    // Actually: merge(a,b)=ab, merge(ab,c)=abc, merge(abc,d)=root
    // a and b: depth 3, c: depth 2, d: depth 1
    // But this only works if a+b < c
    // For simplicity, just compute total = 2*(a+b+c+d) for balanced
    2 * (a + b + c + d)
}

// Run-length encoding compression ratio estimate
fn rle_ratio(data: Int, n: Int, runs: Int) -> Int {
    // Each run takes 2 values (value, count) vs original n values
    // Ratio = 2*runs * 100 / n (percentage)
    if n == 0 { return 100; }
    2 * runs * 100 / n
}

fn test_log2() -> Int {
    assert_eq(log2_approx(1), 0);
    assert_eq(log2_approx(2), 1);
    assert_eq(log2_approx(4), 2);
    assert_eq(log2_approx(8), 3);
    assert_eq(log2_approx(7), 2);
    assert_eq(log2_approx(16), 4);
    assert_eq(log2_approx(100), 6);
    1
}

fn test_bits_needed() -> Int {
    assert_eq(bits_needed(1), 0);  // 1 value needs 0 bits
    assert_eq(bits_needed(2), 1);  // 2 values needs 1 bit
    assert_eq(bits_needed(4), 2);
    assert_eq(bits_needed(5), 3);  // 5 values needs 3 bits
    assert_eq(bits_needed(256), 8);
    1
}

fn test_entropy() -> Int {
    // 4 symbols with equal frequency 4 each (total 16)
    // Each contributes 4 * log2(16/4) = 4 * 2 = 8
    // Total = 32 bits for 16 symbols
    let e = entropy_scaled(4, 4, 4, 4, 4, 16);
    assert_eq(e, 32);

    // Skewed: [1, 1, 2, 12] total=16
    // f0=1: 1*log2(16) = 1*4 = 4
    // f1=1: 4
    // f2=2: 2*log2(8) = 2*3 = 6
    // f3=12: 12*log2(16/12) = 12*log2(1) = 12*0 = 0
    let e2 = entropy_scaled(4, 1, 1, 2, 12, 16);
    assert_eq(e2, 14);
    1
}

fn test_huffman() -> Int {
    // Equal frequencies: 2 bits each
    assert_eq(huffman_total_bits(10, 10, 10, 10), 80);
    1
}

fn test_rle_ratio() -> Int {
    // 100 values with 10 runs -> 20%
    assert_eq(rle_ratio(0, 100, 10), 20);
    // 8 values with 4 runs -> 100%
    assert_eq(rle_ratio(0, 8, 4), 100);
    1
}

fn main() -> Int {
    test_log2();
    test_bits_needed();
    test_entropy();
    test_huffman();
    test_rle_ratio();
    print("DIFF_OK: arithmetic_coding");
    0
}
