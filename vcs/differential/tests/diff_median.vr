// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, median, selection, quickselect, statistics
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Sort via insertion sort (needed for median computation)
fn sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 1;
    while i < n {
        let key = get(arr, i);
        let mut j = i - 1;
        let mut insert_pos = i;
        let mut found = 0;
        while j >= 0 {
            if found == 0 {
                if get(arr, j) > key {
                    arr = set(arr, j + 1, get(arr, j));
                    insert_pos = j;
                    j = j - 1;
                } else {
                    insert_pos = j + 1;
                    found = 1;
                    j = -1;
                }
            } else { j = -1; }
        }
        if found == 0 { insert_pos = 0; }
        arr = set(arr, insert_pos, key);
        i = i + 1;
    }
    arr
}

// Median (lower median for even-length arrays)
fn median(a: Arr8, n: Int) -> Int {
    let sorted = sort(a, n);
    get(sorted, (n - 1) / 2)
}

// Kth smallest element (0-indexed) via sort
fn kth_smallest(a: Arr8, n: Int, k: Int) -> Int {
    let sorted = sort(a, n);
    get(sorted, k)
}

// QuickSelect: find kth smallest using Lomuto partition
fn quickselect(a: Arr8, n: Int, k: Int) -> Int {
    let mut arr = a;
    let mut lo = 0;
    let mut hi = n - 1;
    let mut result = 0;
    let mut done = 0;

    while done == 0 {
        if lo == hi { result = get(arr, lo); done = 1; }
        else {
            // Lomuto partition around arr[hi]
            let pivot = get(arr, hi);
            let mut store = lo;
            let mut j = lo;
            while j < hi {
                if get(arr, j) <= pivot {
                    // Swap arr[store] and arr[j]
                    let tmp = get(arr, store);
                    arr = set(arr, store, get(arr, j));
                    arr = set(arr, j, tmp);
                    store = store + 1;
                }
                j = j + 1;
            }
            // Swap pivot into position
            let tmp2 = get(arr, store);
            arr = set(arr, store, get(arr, hi));
            arr = set(arr, hi, tmp2);

            if k == store { result = get(arr, store); done = 1; }
            else if k < store { hi = store - 1; }
            else { lo = store + 1; }
        }
    }
    result
}

// Mean * n (to avoid division)
fn sum(a: Arr8, n: Int) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < n { s = s + get(a, i); i = i + 1; }
    s
}

// Min and max
fn arr_min(a: Arr8, n: Int) -> Int {
    let mut m = get(a, 0);
    let mut i = 1;
    while i < n { if get(a, i) < m { m = get(a, i); } i = i + 1; }
    m
}

fn arr_max(a: Arr8, n: Int) -> Int {
    let mut m = get(a, 0);
    let mut i = 1;
    while i < n { if get(a, i) > m { m = get(a, i); } i = i + 1; }
    m
}

// Variance * n (sum of (x - mean*n/n)^2... approximate via sum of (x*n - sum)^2 / n)
// Actually: n * variance = sum((x_i - mean)^2)
// = sum(x_i^2) - n * mean^2 = sum(x_i^2) - (sum(x_i))^2 / n
// We compute n * sum(x_i^2) - (sum(x_i))^2 to avoid division
fn variance_numerator(a: Arr8, n: Int) -> Int {
    let mut sq_sum = 0;
    let s = sum(a, n);
    let mut i = 0;
    while i < n {
        let v = get(a, i);
        sq_sum = sq_sum + v * v;
        i = i + 1;
    }
    n * sq_sum - s * s
}

fn main() -> Int {
    // [3, 1, 4, 1, 5, 9, 2, 6]
    let a1 = Arr8 { d0: 3, d1: 1, d2: 4, d3: 1, d4: 5, d5: 9, d6: 2, d7: 6 };

    // Sorted: [1, 1, 2, 3, 4, 5, 6, 9]
    assert_eq(arr_min(a1, 8), 1);
    assert_eq(arr_max(a1, 8), 9);
    assert_eq(sum(a1, 8), 31);

    // Median of 8 elements: index (8-1)/2 = 3 → sorted[3] = 3
    assert_eq(median(a1, 8), 3);

    // Kth smallest
    assert_eq(kth_smallest(a1, 8, 0), 1);  // min
    assert_eq(kth_smallest(a1, 8, 7), 9);  // max
    assert_eq(kth_smallest(a1, 8, 3), 3);  // median

    // QuickSelect cross-check
    assert_eq(quickselect(a1, 8, 0), 1);
    assert_eq(quickselect(a1, 8, 7), 9);
    assert_eq(quickselect(a1, 8, 3), 3);

    // Odd length: [5, 2, 8, 1, 7] → sorted [1,2,5,7,8], median = sorted[2] = 5
    let a2 = Arr8 { d0: 5, d1: 2, d2: 8, d3: 1, d4: 7, d5: 0, d6: 0, d7: 0 };
    assert_eq(median(a2, 5), 5);
    assert_eq(quickselect(a2, 5, 2), 5);

    // All same: [4,4,4,4]
    let a3 = Arr8 { d0: 4, d1: 4, d2: 4, d3: 4, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(median(a3, 4), 4);
    assert_eq(quickselect(a3, 4, 0), 4);
    assert_eq(quickselect(a3, 4, 3), 4);

    // Single element
    let a4 = Arr8 { d0: 42, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(median(a4, 1), 42);

    // Variance: [2, 4, 4, 4, 5, 5, 7, 9] → sum=40, mean=5
    // Var = ((2-5)^2+(4-5)^2+(4-5)^2+(4-5)^2+(5-5)^2+(5-5)^2+(7-5)^2+(9-5)^2)/8
    //     = (9+1+1+1+0+0+4+16)/8 = 32/8 = 4
    // variance_numerator = 8*32 = 256... no: n*sum(x^2) - sum(x)^2
    // sum(x^2) = 4+16+16+16+25+25+49+81 = 232
    // n*sum(x^2) = 8*232 = 1856
    // sum(x)^2 = 40^2 = 1600
    // numerator = 256
    let a5 = Arr8 { d0: 2, d1: 4, d2: 4, d3: 4, d4: 5, d5: 5, d6: 7, d7: 9 };
    assert_eq(sum(a5, 8), 40);
    assert_eq(variance_numerator(a5, 8), 256);  // = 8 * variance * 8 / 8 = n^2 * var / n = n * var * n ... hmm
    // Actually: variance_numerator = n * sum(x^2) - sum(x)^2 = n^2 * variance
    // So variance = 256 / 64 = 4. ✓

    // Range = max - min
    assert_eq(arr_max(a5, 8) - arr_min(a5, 8), 7);

    print("DIFF_OK: median");
    0
}
