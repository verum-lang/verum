// @test: differential

// @tier: 0
// @level: L0
// @tags: vbc, differential, closures, higher-order, functional
// @timeout: 10000
// @expected-exit: 0
//
// Differential test: higher-order functions and closures must match across tiers

fn apply(f: fn(Int) -> Int, x: Int) -> Int { f(x) }
fn apply2(f: fn(Int, Int) -> Int, a: Int, b: Int) -> Int { f(a, b) }
fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int, x: Int) -> Int { f(g(x)) }

fn fold(start: Int, end: Int, init: Int, f: fn(Int, Int) -> Int) -> Int {
    let mut acc = init;
    let mut i = start;
    while i < end {
        acc = f(acc, i);
        i = i + 1;
    }
    acc
}

fn count_if(start: Int, end: Int, pred: fn(Int) -> Bool) -> Int {
    let mut count = 0;
    let mut i = start;
    while i < end {
        if pred(i) { count = count + 1; }
        i = i + 1;
    }
    count
}

fn find_first(start: Int, end: Int, pred: fn(Int) -> Bool) -> Int {
    let mut i = start;
    while i < end {
        if pred(i) { return i; }
        i = i + 1;
    }
    -1
}

fn test_apply() {
    let double = |x: Int| -> Int { x * 2 };
    let square = |x: Int| -> Int { x * x };
    let inc = |x: Int| -> Int { x + 1 };

    assert_eq(apply(double, 5), 10);
    assert_eq(apply(square, 4), 16);
    assert_eq(apply(inc, 99), 100);
}

fn test_compose() {
    let double = |x: Int| -> Int { x * 2 };
    let inc = |x: Int| -> Int { x + 1 };

    // double(inc(5)) = double(6) = 12
    assert_eq(compose(double, inc, 5), 12);
    // inc(double(5)) = inc(10) = 11
    assert_eq(compose(inc, double, 5), 11);
}

fn test_fold() {
    let add = |a: Int, b: Int| -> Int { a + b };
    let mul = |a: Int, b: Int| -> Int { a * b };

    // Sum 0..10 = 45
    assert_eq(fold(0, 10, 0, add), 45);
    // Product 1..6 = 120
    assert_eq(fold(1, 6, 1, mul), 120);
}

fn test_count_find() {
    let is_even = |x: Int| -> Bool { x % 2 == 0 };
    let is_gt_5 = |x: Int| -> Bool { x > 5 };

    assert_eq(count_if(0, 10, is_even), 5);
    assert_eq(count_if(0, 10, is_gt_5), 4);
    assert_eq(find_first(0, 10, is_even), 0);
    assert_eq(find_first(1, 10, is_even), 2);
    assert_eq(find_first(0, 5, is_gt_5), -1);
}

fn main() -> Int {
    test_apply();
    test_compose();
    test_fold();
    test_count_find();
    print("differential higher order ok");
    0
}
