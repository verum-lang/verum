// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, sliding-window, max-subarray
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// Sum of window [i, i+k-1]
fn window_sum(a: Arr8, n: Int, i: Int, k: Int) -> Int {
    let mut sum = 0;
    let mut j = i;
    while j < i + k {
        if j < n { sum = sum + get(a, j); }
        j = j + 1;
    }
    sum
}

// Max window sum of size k
fn max_window_sum(a: Arr8, n: Int, k: Int) -> Int {
    let mut best = window_sum(a, n, 0, k);
    let mut i = 1;
    while i + k <= n {
        let s = window_sum(a, n, i, k);
        if s > best { best = s; }
        i = i + 1;
    }
    best
}

// Sliding window max element for each window of size k (brute force)
// Returns array of max values for each window position
fn sliding_max(a: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i + k <= n {
        let mut mx = get(a, i);
        let mut j = i + 1;
        while j < i + k {
            mx = max_val(mx, get(a, j));
            j = j + 1;
        }
        result = set(result, i, mx);
        i = i + 1;
    }
    result
}

// Sliding window min element
fn sliding_min(a: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i + k <= n {
        let mut mn = get(a, i);
        let mut j = i + 1;
        while j < i + k {
            mn = min_val(mn, get(a, j));
            j = j + 1;
        }
        result = set(result, i, mn);
        i = i + 1;
    }
    result
}

// Max element minus min element in window = window "spread"
fn window_spread(a: Arr8, n: Int, k: Int) -> Arr8 {
    let maxes = sliding_max(a, n, k);
    let mins = sliding_min(a, n, k);
    let mut result = zeros();
    let mut i = 0;
    while i + k <= n {
        result = set(result, i, get(maxes, i) - get(mins, i));
        i = i + 1;
    }
    result
}

// Moving average * k (to avoid division)
fn moving_avg_times_k(a: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i + k <= n {
        result = set(result, i, window_sum(a, n, i, k));
        i = i + 1;
    }
    result
}

fn main() -> Int {
    let data = Arr8 { d0: 1, d1: 3, d2: 5, d3: 2, d4: 8, d5: 4, d6: 7, d7: 6 };

    // Window sum k=3: [9, 10, 15, 14, 19, 17]
    assert_eq(window_sum(data, 8, 0, 3), 9);   // 1+3+5
    assert_eq(window_sum(data, 8, 1, 3), 10);  // 3+5+2
    assert_eq(window_sum(data, 8, 4, 3), 19);  // 8+4+7

    // Max window sum k=3 = 19 (at position 4: 8+4+7)
    assert_eq(max_window_sum(data, 8, 3), 19);

    // Max window sum k=1 = 8 (just the max element)
    assert_eq(max_window_sum(data, 8, 1), 8);

    // Max window sum k=8 = total sum = 36
    assert_eq(max_window_sum(data, 8, 8), 36);

    // Sliding max k=3: max of [1,3,5]=5, [3,5,2]=5, [5,2,8]=8, [2,8,4]=8, [8,4,7]=8, [4,7,6]=7
    let maxes = sliding_max(data, 8, 3);
    assert_eq(get(maxes, 0), 5);
    assert_eq(get(maxes, 1), 5);
    assert_eq(get(maxes, 2), 8);
    assert_eq(get(maxes, 3), 8);
    assert_eq(get(maxes, 4), 8);
    assert_eq(get(maxes, 5), 7);

    // Sliding min k=3: min of [1,3,5]=1, [3,5,2]=2, [5,2,8]=2, [2,8,4]=2, [8,4,7]=4, [4,7,6]=4
    let mins = sliding_min(data, 8, 3);
    assert_eq(get(mins, 0), 1);
    assert_eq(get(mins, 1), 2);
    assert_eq(get(mins, 2), 2);
    assert_eq(get(mins, 3), 2);
    assert_eq(get(mins, 4), 4);
    assert_eq(get(mins, 5), 4);

    // Window spread k=3: [4, 3, 6, 6, 4, 3]
    let spreads = window_spread(data, 8, 3);
    assert_eq(get(spreads, 0), 4);
    assert_eq(get(spreads, 1), 3);
    assert_eq(get(spreads, 2), 6);
    assert_eq(get(spreads, 3), 6);

    // Property: sliding max >= sliding min for all windows
    let mut i = 0;
    while i + 3 <= 8 {
        assert(get(maxes, i) >= get(mins, i));
        i = i + 1;
    }

    print("DIFF_OK: sliding_window");
    0
}
