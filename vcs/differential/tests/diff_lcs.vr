// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, lcs, longest-common-subsequence, dp
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// 8x8 DP table stored as 8 Arr8 rows
type Grid8 is { r0: Arr8, r1: Arr8, r2: Arr8, r3: Arr8, r4: Arr8, r5: Arr8, r6: Arr8, r7: Arr8 };

fn get_row(g: Grid8, r: Int) -> Arr8 {
    if r == 0 { g.r0 } else if r == 1 { g.r1 } else if r == 2 { g.r2 }
    else if r == 3 { g.r3 } else if r == 4 { g.r4 } else if r == 5 { g.r5 }
    else if r == 6 { g.r6 } else { g.r7 }
}

fn set_row(g: Grid8, r: Int, row: Arr8) -> Grid8 {
    Grid8 {
        r0: if r == 0 { row } else { g.r0 },
        r1: if r == 1 { row } else { g.r1 },
        r2: if r == 2 { row } else { g.r2 },
        r3: if r == 3 { row } else { g.r3 },
        r4: if r == 4 { row } else { g.r4 },
        r5: if r == 5 { row } else { g.r5 },
        r6: if r == 6 { row } else { g.r6 },
        r7: if r == 7 { row } else { g.r7 }
    }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn grid_get(g: Grid8, r: Int, c: Int) -> Int { get(get_row(g, r), c) }
fn grid_set(g: Grid8, r: Int, c: Int, v: Int) -> Grid8 {
    set_row(g, r, set(get_row(g, r), c, v))
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }
fn grid_zeros() -> Grid8 {
    let z = zeros();
    Grid8 { r0: z, r1: z, r2: z, r3: z, r4: z, r5: z, r6: z, r7: z }
}

// LCS length using DP, sequences a[0..m] and b[0..n]
// dp[i][j] = LCS of a[0..i-1] and b[0..j-1], stored with 1-offset
fn lcs_length(a: Arr8, m: Int, b: Arr8, n: Int) -> Int {
    let mut dp = grid_zeros();
    let mut i = 1;
    while i <= m {
        let mut j = 1;
        while j <= n {
            if get(a, i - 1) == get(b, j - 1) {
                dp = grid_set(dp, i, j, grid_get(dp, i - 1, j - 1) + 1);
            } else {
                dp = grid_set(dp, i, j, max_val(grid_get(dp, i - 1, j), grid_get(dp, i, j - 1)));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    grid_get(dp, m, n)
}

// Edit distance (Levenshtein) between a[0..m] and b[0..n]
fn edit_distance(a: Arr8, m: Int, b: Arr8, n: Int) -> Int {
    let mut dp = grid_zeros();
    // Base cases
    let mut i = 0;
    while i <= m { dp = grid_set(dp, i, 0, i); i = i + 1; }
    let mut j = 0;
    while j <= n { dp = grid_set(dp, 0, j, j); j = j + 1; }
    // Fill
    i = 1;
    while i <= m {
        j = 1;
        while j <= n {
            if get(a, i - 1) == get(b, j - 1) {
                dp = grid_set(dp, i, j, grid_get(dp, i - 1, j - 1));
            } else {
                let ins = grid_get(dp, i, j - 1) + 1;
                let del = grid_get(dp, i - 1, j) + 1;
                let rep = grid_get(dp, i - 1, j - 1) + 1;
                dp = grid_set(dp, i, j, min_val(ins, min_val(del, rep)));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    grid_get(dp, m, n)
}

fn main() -> Int {
    // LCS of [1,3,2,4,1] and [3,4,1,2,1] = [3,2,1] or [3,4,1] = length 3
    let a1 = Arr8 { d0: 1, d1: 3, d2: 2, d3: 4, d4: 1, d5: 0, d6: 0, d7: 0 };
    let b1 = Arr8 { d0: 3, d1: 4, d2: 1, d3: 2, d4: 1, d5: 0, d6: 0, d7: 0 };
    assert_eq(lcs_length(a1, 5, b1, 5), 3);

    // LCS of identical sequences
    let a2 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(lcs_length(a2, 4, a2, 4), 4);

    // LCS of disjoint sequences
    let a3 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let b3 = Arr8 { d0: 4, d1: 5, d2: 6, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(lcs_length(a3, 3, b3, 3), 0);

    // LCS with empty
    let empty = zeros();
    assert_eq(lcs_length(a3, 3, empty, 0), 0);

    // LCS symmetry: lcs(a,b) == lcs(b,a)
    assert_eq(lcs_length(a1, 5, b1, 5), lcs_length(b1, 5, a1, 5));

    // Property: lcs(a,b) <= min(|a|, |b|)
    let lcs_len = lcs_length(a1, 5, b1, 5);
    assert(lcs_len <= 5);

    // Edit distance
    // [1,2,3] vs [1,3,3] → 1 substitution (2→3) → distance 1
    let e1 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let e2 = Arr8 { d0: 1, d1: 3, d2: 3, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(edit_distance(e1, 3, e2, 3), 1);

    // Edit distance of identical = 0
    assert_eq(edit_distance(e1, 3, e1, 3), 0);

    // Edit distance with empty = length
    assert_eq(edit_distance(e1, 3, empty, 0), 3);
    assert_eq(edit_distance(empty, 0, e1, 3), 3);

    // Symmetry
    assert_eq(edit_distance(e1, 3, e2, 3), edit_distance(e2, 3, e1, 3));

    // Triangle inequality: d(a,c) <= d(a,b) + d(b,c)
    let e3 = Arr8 { d0: 2, d1: 3, d2: 4, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let d_ac = edit_distance(e1, 3, e3, 3);
    let d_ab = edit_distance(e1, 3, e2, 3);
    let d_bc = edit_distance(e2, 3, e3, 3);
    assert(d_ac <= d_ab + d_bc);

    // Relation: edit_distance >= |m - n| (length difference)
    let short = Arr8 { d0: 1, d1: 2, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let ed = edit_distance(e1, 3, short, 2);
    assert(ed >= 1);

    print("DIFF_OK: lcs");
    0
}
