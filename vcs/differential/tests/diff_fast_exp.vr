// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, fast-exponentiation, modular-arithmetic, binary-exp
// @timeout: 10000

// Fast exponentiation by squaring
fn fast_pow(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut b = base;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 { result = result * b; }
        b = b * b;
        e = e / 2;
    }
    result
}

// Modular exponentiation
fn mod_pow(base: Int, exp: Int, modulus: Int) -> Int {
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 { result = (result * b) % modulus; }
        b = (b * b) % modulus;
        e = e / 2;
    }
    result
}

// Naive exponentiation for cross-check
fn naive_pow(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < exp {
        result = result * base;
        i = i + 1;
    }
    result
}

// GCD via Euclidean algorithm
fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y != 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

// Modular multiplicative inverse (when gcd(a,m)=1)
// Uses extended Euclidean algorithm
fn mod_inverse(a: Int, m: Int) -> Int {
    let mut old_r = a;
    let mut r = m;
    let mut old_s = 1;
    let mut s = 0;
    while r != 0 {
        let q = old_r / r;
        let temp_r = r;
        r = old_r - q * r;
        old_r = temp_r;
        let temp_s = s;
        s = old_s - q * s;
        old_s = temp_s;
    }
    // Make positive
    let mut result = old_s % m;
    if result < 0 { result = result + m; }
    result
}

// Fermat primality test: a^(p-1) ≡ 1 (mod p) for prime p
fn fermat_test(p: Int, a: Int) -> Int {
    if p <= 1 { return 0; }
    if p == 2 { return 1; }
    if p % 2 == 0 { return 0; }
    if mod_pow(a, p - 1, p) == 1 { 1 } else { 0 }
}

fn main() -> Int {
    // Basic powers
    assert_eq(fast_pow(2, 0), 1);
    assert_eq(fast_pow(2, 1), 2);
    assert_eq(fast_pow(2, 10), 1024);
    assert_eq(fast_pow(3, 5), 243);
    assert_eq(fast_pow(5, 3), 125);

    // Cross-check with naive
    assert_eq(fast_pow(2, 10), naive_pow(2, 10));
    assert_eq(fast_pow(3, 7), naive_pow(3, 7));
    assert_eq(fast_pow(7, 4), naive_pow(7, 4));

    // Modular exponentiation
    assert_eq(mod_pow(2, 10, 1000), 24);  // 1024 % 1000 = 24
    assert_eq(mod_pow(3, 5, 100), 43);    // 243 % 100 = 43
    assert_eq(mod_pow(2, 20, 1000), 576); // 1048576 % 1000 = 576

    // Fermat's little theorem: a^p ≡ a (mod p)
    assert_eq(mod_pow(2, 7, 7), 2);   // 2^7 mod 7 = 2
    assert_eq(mod_pow(3, 11, 11), 3);  // 3^11 mod 11 = 3

    // Fermat primality test
    assert_eq(fermat_test(7, 2), 1);
    assert_eq(fermat_test(11, 2), 1);
    assert_eq(fermat_test(13, 2), 1);
    assert_eq(fermat_test(4, 2), 0);   // 4 is even, not prime
    assert_eq(fermat_test(9, 2), 0);   // 2^8 mod 9 = 256 mod 9 = 4 ≠ 1

    // Modular inverse
    assert_eq(mod_inverse(3, 7), 5);   // 3*5 = 15 ≡ 1 (mod 7)
    assert_eq((3 * mod_inverse(3, 7)) % 7, 1);
    assert_eq(mod_inverse(2, 11), 6);  // 2*6 = 12 ≡ 1 (mod 11)
    assert_eq((2 * mod_inverse(2, 11)) % 11, 1);

    // GCD
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(17, 13), 1);
    assert_eq(gcd(100, 75), 25);

    // Power of power: (a^b)^c = a^(b*c)
    assert_eq(fast_pow(fast_pow(2, 3), 4), fast_pow(2, 12)); // (2^3)^4 = 2^12 = 4096

    // Edge cases
    assert_eq(fast_pow(1, 100), 1);
    assert_eq(fast_pow(0, 5), 0);
    assert_eq(mod_pow(0, 0, 7), 1);  // 0^0 = 1 by convention

    print("DIFF_OK: fast_exp");
    0
}
