// @test: differential
// @tier: 0
// @level: L0
// @tags: differential, graph-coloring, chromatic, greedy
// @timeout: 10000

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn zeros() -> Arr8 { Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 } }

// Adjacency matrix stored in Arr8 rows (one Arr8 per row, max 8 nodes)
type Graph6 is { r0: Arr8, r1: Arr8, r2: Arr8, r3: Arr8, r4: Arr8, r5: Arr8 };

fn g6_get_row(g: Graph6, r: Int) -> Arr8 {
    if r == 0 { g.r0 } else if r == 1 { g.r1 } else if r == 2 { g.r2 }
    else if r == 3 { g.r3 } else if r == 4 { g.r4 } else { g.r5 }
}

fn edge(g: Graph6, u: Int, v: Int) -> Int {
    get(g6_get_row(g, u), v)
}

// Greedy coloring: assign smallest available color to each vertex in order
fn greedy_color(g: Graph6, n: Int) -> Arr8 {
    let mut colors = zeros();
    // Initialize all to -1 (uncolored)
    let mut i = 0;
    while i < n { colors = set(colors, i, -1); i = i + 1; }

    let mut v = 0;
    while v < n {
        // Find colors used by neighbors
        let mut used = zeros();
        let mut u = 0;
        while u < n {
            if edge(g, v, u) == 1 {
                let c = get(colors, u);
                if c >= 0 { used = set(used, c, 1); }
            }
            u = u + 1;
        }
        // Find smallest unused color
        let mut c = 0;
        while get(used, c) == 1 { c = c + 1; }
        colors = set(colors, v, c);
        v = v + 1;
    }
    colors
}

// Check if coloring is valid
fn is_valid_coloring(g: Graph6, colors: Arr8, n: Int) -> Int {
    let mut u = 0;
    while u < n {
        let mut v = u + 1;
        while v < n {
            if edge(g, u, v) == 1 {
                if get(colors, u) == get(colors, v) { return 0; }
            }
            v = v + 1;
        }
        u = u + 1;
    }
    1
}

// Number of colors used
fn num_colors(colors: Arr8, n: Int) -> Int {
    let mut max_c = 0;
    let mut i = 0;
    while i < n {
        if get(colors, i) > max_c { max_c = get(colors, i); }
        i = i + 1;
    }
    max_c + 1
}

// Brute force chromatic number: try k=1,2,3... until valid coloring found
fn chromatic_number(g: Graph6, n: Int) -> Int {
    let mut k = 1;
    while k <= n {
        if can_color_k(g, n, k, zeros(), 0) == 1 { return k; }
        k = k + 1;
    }
    n
}

fn can_color_k(g: Graph6, n: Int, k: Int, colors: Arr8, v: Int) -> Int {
    if v == n { return 1; }
    let mut c = 0;
    while c < k {
        // Check if color c is safe for vertex v
        let mut safe = 1;
        let mut u = 0;
        while u < v {
            if edge(g, v, u) == 1 {
                if get(colors, u) == c { safe = 0; u = v; }
            }
            u = u + 1;
        }
        if safe == 1 {
            let new_colors = set(colors, v, c);
            if can_color_k(g, n, k, new_colors, v + 1) == 1 { return 1; }
        }
        c = c + 1;
    }
    0
}

// Count edges
fn edge_count(g: Graph6, n: Int) -> Int {
    let mut count = 0;
    let mut u = 0;
    while u < n {
        let mut v = u + 1;
        while v < n {
            if edge(g, u, v) == 1 { count = count + 1; }
            v = v + 1;
        }
        u = u + 1;
    }
    count
}

fn main() -> Int {
    let z = zeros();

    // Complete graph K4: 0-1, 0-2, 0-3, 1-2, 1-3, 2-3
    let k4 = Graph6 {
        r0: Arr8 { d0: 0, d1: 1, d2: 1, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 },
        r1: Arr8 { d0: 1, d1: 0, d2: 1, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 },
        r2: Arr8 { d0: 1, d1: 1, d2: 0, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 },
        r3: Arr8 { d0: 1, d1: 1, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r4: z, r5: z
    };
    assert_eq(chromatic_number(k4, 4), 4);
    assert_eq(edge_count(k4, 4), 6);

    let col_k4 = greedy_color(k4, 4);
    assert_eq(is_valid_coloring(k4, col_k4, 4), 1);

    // Cycle C4: 0-1-2-3-0 (bipartite, chromatic = 2)
    let c4 = Graph6 {
        r0: Arr8 { d0: 0, d1: 1, d2: 0, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 },
        r1: Arr8 { d0: 1, d1: 0, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r2: Arr8 { d0: 0, d1: 1, d2: 0, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 },
        r3: Arr8 { d0: 1, d1: 0, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r4: z, r5: z
    };
    assert_eq(chromatic_number(c4, 4), 2);
    let col_c4 = greedy_color(c4, 4);
    assert_eq(is_valid_coloring(c4, col_c4, 4), 1);

    // Odd cycle C5: 0-1-2-3-4-0 (chromatic = 3)
    let c5 = Graph6 {
        r0: Arr8 { d0: 0, d1: 1, d2: 0, d3: 0, d4: 1, d5: 0, d6: 0, d7: 0 },
        r1: Arr8 { d0: 1, d1: 0, d2: 1, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r2: Arr8 { d0: 0, d1: 1, d2: 0, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 },
        r3: Arr8 { d0: 0, d1: 0, d2: 1, d3: 0, d4: 1, d5: 0, d6: 0, d7: 0 },
        r4: Arr8 { d0: 1, d1: 0, d2: 0, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 },
        r5: z
    };
    assert_eq(chromatic_number(c5, 5), 3);
    let col_c5 = greedy_color(c5, 5);
    assert_eq(is_valid_coloring(c5, col_c5, 5), 1);

    // Empty graph E4 (no edges): chromatic = 1
    let e4 = Graph6 { r0: z, r1: z, r2: z, r3: z, r4: z, r5: z };
    assert_eq(chromatic_number(e4, 4), 1);
    assert_eq(edge_count(e4, 4), 0);

    // Star graph: center 0 connected to 1,2,3,4 (bipartite, chromatic = 2)
    let star = Graph6 {
        r0: Arr8 { d0: 0, d1: 1, d2: 1, d3: 1, d4: 1, d5: 0, d6: 0, d7: 0 },
        r1: Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r2: Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r3: Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r4: Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 },
        r5: z
    };
    assert_eq(chromatic_number(star, 5), 2);

    print("DIFF_OK: graph_coloring");
    0
}
