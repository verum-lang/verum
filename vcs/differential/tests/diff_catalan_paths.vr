// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, catalan, dp, counting, paths
// @timeout: 10000

// Count Catalan-number related combinatorial objects

// Binomial coefficient C(n,k)
fn binom(n: Int, k: Int) -> Int {
    if k < 0 { return 0; }
    if k > n { return 0; }
    if k == 0 { return 1; }
    if k == n { return 1; }
    let mut result = 1;
    let mut i = 0;
    while i < k {
        result = result * (n - i) / (i + 1);
        i = i + 1;
    }
    result
}

// Catalan number C_n = C(2n,n)/(n+1)
fn catalan(n: Int) -> Int {
    binom(2 * n, n) / (n + 1)
}

// Number of valid parenthesizations of n pairs
fn valid_parens(n: Int) -> Int {
    catalan(n)
}

// Number of rooted binary trees with n internal nodes
fn binary_trees(n: Int) -> Int {
    catalan(n)
}

// Number of paths from (0,0) to (n,n) that don't cross diagonal
fn monotone_paths(n: Int) -> Int {
    catalan(n)
}

// Ballot problem: ways A beats B in all partial counts
// A gets 'a' votes, B gets 'b' votes, a > b
fn ballot_count(a: Int, b: Int) -> Int {
    if a <= b { return 0; }
    // Bertrand ballot: (a-b)/(a+b) * C(a+b, a)
    (a - b) * binom(a + b, a) / (a + b)
}

// Number of non-crossing partitions of n elements
fn non_crossing_partitions(n: Int) -> Int {
    catalan(n)
}

// Motzkin number M_n (lattice paths with flat steps)
fn motzkin(n: Int) -> Int {
    let mut m0 = 1;
    let mut m1 = 1;
    let mut i = 2;
    while i <= n {
        let m2 = ((2 * i + 1) * m1 + 3 * (i - 1) * m0) / (i + 2);
        // Use the summation formula instead for small n
        m0 = m1;
        m1 = m2;
        i = i + 1;
    }
    if n == 0 { return 1; }
    if n == 1 { return 1; }
    m1
}

// Direct computation of Motzkin via sum of Catalan
fn motzkin_direct(n: Int) -> Int {
    let mut total = 0;
    let mut k = 0;
    while k <= n / 2 {
        total = total + binom(n, 2 * k) * catalan(k);
        k = k + 1;
    }
    total
}

fn test_catalan() -> Int {
    assert_eq(catalan(0), 1);
    assert_eq(catalan(1), 1);
    assert_eq(catalan(2), 2);
    assert_eq(catalan(3), 5);
    assert_eq(catalan(4), 14);
    assert_eq(catalan(5), 42);
    1
}

fn test_ballot() -> Int {
    // ballot_count(3,1) = (3-1)/(3+1) * C(4,3) = 2/4 * 4 = 2
    assert_eq(ballot_count(3, 1), 2);
    // ballot_count(4,2) = (4-2)/(4+2) * C(6,4) = 2/6 * 15 = 5
    assert_eq(ballot_count(4, 2), 5);
    assert_eq(ballot_count(2, 2), 0);
    1
}

fn test_motzkin_direct() -> Int {
    assert_eq(motzkin_direct(0), 1);
    assert_eq(motzkin_direct(1), 1);
    assert_eq(motzkin_direct(2), 2);
    assert_eq(motzkin_direct(3), 4);
    assert_eq(motzkin_direct(4), 9);
    1
}

fn test_binom() -> Int {
    assert_eq(binom(5, 0), 1);
    assert_eq(binom(5, 1), 5);
    assert_eq(binom(5, 2), 10);
    assert_eq(binom(5, 3), 10);
    assert_eq(binom(10, 5), 252);
    1
}

fn main() -> Int {
    test_catalan();
    test_ballot();
    test_motzkin_direct();
    test_binom();
    print("DIFF_OK: catalan_paths");
    0
}
