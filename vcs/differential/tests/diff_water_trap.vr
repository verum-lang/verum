// @test: differential

// @tier: 0
// @level: L0
// @tags: differential, water-trap, two-pointer, array, classic
// @timeout: 10000

// Trapping rain water problem: given elevation heights, compute how much
// water can be trapped after raining. Two-pointer approach and brute force
// cross-verification.

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn max_of(a: Int, b_val: Int) -> Int { if a > b_val { a } else { b_val } }
fn min_of(a: Int, b_val: Int) -> Int { if a < b_val { a } else { b_val } }

// Brute force: for each position, find max height to its left and right,
// water at position = min(left_max, right_max) - height[i]
fn trap_brute(h: Arr8, n: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        // Find max height to the left of i (inclusive)
        let mut left_max = 0;
        let mut j = 0;
        while j <= i {
            left_max = max_of(left_max, get(h, j));
            j = j + 1;
        }
        // Find max height to the right of i (inclusive)
        let mut right_max = 0;
        j = i;
        while j < n {
            right_max = max_of(right_max, get(h, j));
            j = j + 1;
        }
        let water = min_of(left_max, right_max) - get(h, i);
        if water > 0 {
            total = total + water;
        }
        i = i + 1;
    }
    total
}

// Two-pointer approach: O(n) time, O(1) space
fn trap_two_ptr(h: Arr8, n: Int) -> Int {
    if n < 3 { return 0; }
    let mut left = 0;
    let mut right = n - 1;
    let mut left_max = get(h, 0);
    let mut right_max = get(h, n - 1);
    let mut total = 0;
    while left < right {
        if left_max <= right_max {
            left = left + 1;
            left_max = max_of(left_max, get(h, left));
            let water = left_max - get(h, left);
            if water > 0 { total = total + water; }
        } else {
            right = right - 1;
            right_max = max_of(right_max, get(h, right));
            let water = right_max - get(h, right);
            if water > 0 { total = total + water; }
        }
    }
    total
}

// Container with most water (different problem): find max area between two lines
fn max_container(h: Arr8, n: Int) -> Int {
    let mut left = 0;
    let mut right = n - 1;
    let mut best = 0;
    while left < right {
        let width = right - left;
        let height = min_of(get(h, left), get(h, right));
        let area = width * height;
        if area > best { best = area; }
        if get(h, left) < get(h, right) {
            left = left + 1;
        } else {
            right = right - 1;
        }
    }
    best
}

// Total volume including bars (sum of max_height * n)
fn total_volume(h: Arr8, n: Int) -> Int {
    let mut mx = 0;
    let mut i = 0;
    while i < n {
        mx = max_of(mx, get(h, i));
        i = i + 1;
    }
    mx * n
}

// Sum of heights
fn sum_heights(h: Arr8, n: Int) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < n { s = s + get(h, i); i = i + 1; }
    s
}

fn test_classic() -> Int {
    // Classic example: [0,1,0,2,1,0,1,3] => 5
    // Water fills: position 2 gets 1, position 4 gets 1, position 5 gets 2, position 6 gets 1 = 5...
    // Actually: [0,1,0,2,1,0,1,3]
    //   pos 0: left_max=0, right_max=3, min=0, water=0-0=0
    //   pos 1: left_max=1, right_max=3, min=1, water=1-1=0
    //   pos 2: left_max=1, right_max=3, min=1, water=1-0=1
    //   pos 3: left_max=2, right_max=3, min=2, water=2-2=0
    //   pos 4: left_max=2, right_max=3, min=2, water=2-1=1
    //   pos 5: left_max=2, right_max=3, min=2, water=2-0=2
    //   pos 6: left_max=2, right_max=3, min=2, water=2-1=1
    //   pos 7: left_max=3, right_max=3, min=3, water=3-3=0
    //   total = 0+0+1+0+1+2+1+0 = 5
    let h1 = Arr8 { d0: 0, d1: 1, d2: 0, d3: 2, d4: 1, d5: 0, d6: 1, d7: 3 };
    assert_eq(trap_brute(h1, 8), 5);
    assert_eq(trap_two_ptr(h1, 8), 5);
    1
}

fn test_valley() -> Int {
    // Simple valley: [3,0,3] => 3
    let h2 = Arr8 { d0: 3, d1: 0, d2: 3, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h2, 3), 3);
    assert_eq(trap_two_ptr(h2, 3), 3);

    // Asymmetric valley: [5,0,2] => 2 (bounded by shorter wall)
    let h3 = Arr8 { d0: 5, d1: 0, d2: 2, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h3, 3), 2);
    assert_eq(trap_two_ptr(h3, 3), 2);
    1
}

fn test_flat_and_ascending() -> Int {
    // Flat: [2,2,2,2] => 0
    let h4 = Arr8 { d0: 2, d1: 2, d2: 2, d3: 2, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h4, 4), 0);
    assert_eq(trap_two_ptr(h4, 4), 0);

    // Ascending: [1,2,3,4] => 0
    let h5 = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h5, 4), 0);
    assert_eq(trap_two_ptr(h5, 4), 0);

    // Descending: [4,3,2,1] => 0
    let h6 = Arr8 { d0: 4, d1: 3, d2: 2, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h6, 4), 0);
    assert_eq(trap_two_ptr(h6, 4), 0);
    1
}

fn test_double_valley() -> Int {
    // Two valleys: [4,1,3,1,4] => 3+1+3 wait...
    // pos 0: lm=4, rm=4, min=4, w=4-4=0
    // pos 1: lm=4, rm=4, min=4, w=4-1=3
    // pos 2: lm=4, rm=4, min=4, w=4-3=1
    // pos 3: lm=4, rm=4, min=4, w=4-1=3
    // pos 4: lm=4, rm=4, min=4, w=4-4=0
    // total = 0+3+1+3+0 = 7
    let h7 = Arr8 { d0: 4, d1: 1, d2: 3, d3: 1, d4: 4, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h7, 5), 7);
    assert_eq(trap_two_ptr(h7, 5), 7);
    1
}

fn test_single_and_pair() -> Int {
    // Single element: no water
    let h8 = Arr8 { d0: 5, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h8, 1), 0);
    assert_eq(trap_two_ptr(h8, 1), 0);

    // Two elements: no water
    let h9 = Arr8 { d0: 5, d1: 3, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h9, 2), 0);
    assert_eq(trap_two_ptr(h9, 2), 0);

    // All zeros: no water
    let h10 = Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(trap_brute(h10, 4), 0);
    assert_eq(trap_two_ptr(h10, 4), 0);
    1
}

fn test_container() -> Int {
    // [1,8,6,2,5,4,8,3] => max container between index 1 (h=8) and index 6 (h=8), width=5, area=40
    // Actually: indices 1 and 6: width=5, height=min(8,8)=8, area=40
    let c1 = Arr8 { d0: 1, d1: 8, d2: 6, d3: 2, d4: 5, d5: 4, d6: 8, d7: 3 };
    assert_eq(max_container(c1, 8), 40);

    // [1,1] => area = 1 * 1 = 1
    let c2 = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(max_container(c2, 2), 1);

    // [4,3,2,1,4] => max container between 0 and 4: width=4, height=min(4,4)=4, area=16
    let c3 = Arr8 { d0: 4, d1: 3, d2: 2, d3: 1, d4: 4, d5: 0, d6: 0, d7: 0 };
    assert_eq(max_container(c3, 5), 16);
    1
}

fn test_cross_check() -> Int {
    // Verify brute and two-ptr give same answer on various inputs
    let a = Arr8 { d0: 2, d1: 0, d2: 4, d3: 0, d4: 3, d5: 0, d6: 5, d7: 0 };
    assert_eq(trap_brute(a, 8), trap_two_ptr(a, 8));

    let b = Arr8 { d0: 1, d1: 3, d2: 2, d3: 4, d4: 1, d5: 3, d6: 1, d7: 4 };
    assert_eq(trap_brute(b, 8), trap_two_ptr(b, 8));

    let c = Arr8 { d0: 5, d1: 2, d2: 1, d3: 2, d4: 1, d5: 5, d6: 0, d7: 0 };
    assert_eq(trap_brute(c, 6), trap_two_ptr(c, 6));
    1
}

fn main() -> Int {
    test_classic();
    test_valley();
    test_flat_and_ascending();
    test_double_valley();
    test_single_and_pair();
    test_container();
    test_cross_check();
    print("DIFF_OK: water_trap");
    0
}
