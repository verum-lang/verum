// @test: differential
// @tier: 0, 3
// @level: L1
// @tags: differential, recursion

/// Recursive functions must produce identical results
/// across interpreter (Tier 0) and AOT (Tier 3)

/// Classic factorial
fn factorial(n: Int) -> Int {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

/// Tail-recursive factorial
fn factorial_tail(n: Int, acc: Int) -> Int {
    if n <= 1 {
        acc
    } else {
        factorial_tail(n - 1, n * acc)
    }
}

/// Fibonacci (exponential)
fn fib(n: Int) -> Int {
    if n <= 1 {
        n
    } else {
        fib(n - 1) + fib(n - 2)
    }
}

/// Tail-recursive Fibonacci
fn fib_tail(n: Int, a: Int, b: Int) -> Int {
    if n == 0 {
        a
    } else if n == 1 {
        b
    } else {
        fib_tail(n - 1, b, a + b)
    }
}

/// Greatest common divisor (Euclidean algorithm)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 {
        a
    } else {
        gcd(b, a % b)
    }
}

/// Ackermann function (tests deep recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 {
        n + 1
    } else if n == 0 {
        ackermann(m - 1, 1)
    } else {
        ackermann(m - 1, ackermann(m, n - 1))
    }
}

/// Sum of list using recursion
fn sum_list(list: List<Int>, index: Int) -> Int {
    if index >= list.len() {
        0
    } else {
        list[index] + sum_list(list, index + 1)
    }
}

/// Binary search (recursive)
fn binary_search(list: List<Int>, target: Int, low: Int, high: Int) -> Maybe<Int> {
    if low > high {
        None
    } else {
        let mid = (low + high) / 2;
        let midVal = list[mid];
        if midVal == target {
            Some(mid)
        } else if midVal < target {
            binary_search(list, target, mid + 1, high)
        } else {
            binary_search(list, target, low, mid - 1)
        }
    }
}

/// Mutual recursion: is_even / is_odd
fn is_even(n: Int) -> Bool {
    if n == 0 {
        true
    } else {
        is_odd(n - 1)
    }
}

fn is_odd(n: Int) -> Bool {
    if n == 0 {
        false
    } else {
        is_even(n - 1)
    }
}

fn main() {
    // Factorial tests
    println(f"factorial(0) = {factorial(0)}");
    println(f"factorial(5) = {factorial(5)}");
    println(f"factorial(10) = {factorial(10)}");
    println(f"factorial_tail(10, 1) = {factorial_tail(10, 1)}");

    // Fibonacci tests
    println(f"fib(0) = {fib(0)}");
    println(f"fib(1) = {fib(1)}");
    println(f"fib(10) = {fib(10)}");
    println(f"fib_tail(10, 0, 1) = {fib_tail(10, 0, 1)}");
    println(f"fib(20) = {fib(20)}");

    // GCD tests
    println(f"gcd(48, 18) = {gcd(48, 18)}");
    println(f"gcd(100, 35) = {gcd(100, 35)}");
    println(f"gcd(17, 13) = {gcd(17, 13)}");

    // Ackermann (small values only - grows extremely fast)
    println(f"ackermann(0, 0) = {ackermann(0, 0)}");
    println(f"ackermann(1, 1) = {ackermann(1, 1)}");
    println(f"ackermann(2, 2) = {ackermann(2, 2)}");
    println(f"ackermann(3, 3) = {ackermann(3, 3)}");

    // List sum
    let nums = [1, 2, 3, 4, 5];
    println(f"sum_list = {sum_list(nums, 0)}");

    // Binary search
    let sorted = [1, 3, 5, 7, 9, 11, 13, 15];
    println(f"binary_search(7) = {binary_search(sorted, 7, 0, 7)}");
    println(f"binary_search(6) = {binary_search(sorted, 6, 0, 7)}");

    // Mutual recursion
    println(f"is_even(10) = {is_even(10)}");
    println(f"is_odd(10) = {is_odd(10)}");
    println(f"is_even(7) = {is_even(7)}");
    println(f"is_odd(7) = {is_odd(7)}");
}
