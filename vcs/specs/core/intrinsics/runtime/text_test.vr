// =============================================================================
// vcs/specs/core/intrinsics/runtime/text_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: core, intrinsics, runtime, text, char, utf8, parsing, formatting
// @description: Tests for text/string intrinsics including text creation,
//               parsing, formatting, UTF-8 operations, and character
//               classification/conversion functions.
//
// Coverage:
// - Text creation: text_from_static
// - Parsing: text_parse_int, text_parse_float
// - Formatting: int_to_text, float_to_text
// - UTF-8: utf8_decode_char, utf8_decode_char_len, char_encode_utf8
// - Character classification: is_alphabetic, is_numeric, is_alphanumeric,
//   is_whitespace, is_control, is_uppercase, is_lowercase
// - Character conversion: to_uppercase, to_lowercase, general_category,
//   escape_debug
// - Panic/debug: panic, debug_assert
//
// Test Strategy:
// - Verify function imports resolve
// - Verify function type signatures
// =============================================================================

module specs.core.intrinsics.runtime.text_test;

mount core.intrinsics.runtime.text.{
    text_parse_int,
    text_parse_float,
    int_to_text,
    float_to_text,
