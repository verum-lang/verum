module specs.core.intrinsics.runtime.async_ops_test;

mount core.intrinsics.runtime.async_ops.{
    JoinHandleOpaque,
    ExecutorHandle,
    FutureHandle,
    SupervisorHandleOpaque,
    ChildSpecOpaque,
    ExecutionEnvOpaque,
    RecoveryContextOpaque,
    CircuitBreakerOpaque,
    AllocHandle,
    IODriverHandle,
    SharedRegistryOpaque,
    MiddlewareChainOpaque,
    SingleThreadExecutorOpaque,
    RecoveryError,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// RecoveryError Variant Tests
// =============================================================================

@test
fn test_recovery_error_max_retries() {
    let err = RecoveryError.MaxRetriesExceeded;
    match err {
        RecoveryError.MaxRetriesExceeded => { /* expected */ }
        _ => assert(false, "Should be MaxRetriesExceeded"),
    }
}

@test
fn test_recovery_error_circuit_open() {
    let err = RecoveryError.CircuitOpen;
    match err {
        RecoveryError.CircuitOpen => { /* expected */ }
        _ => assert(false, "Should be CircuitOpen"),
    }
}

@test
fn test_recovery_error_timeout() {
    let err = RecoveryError.Timeout;
    match err {
        RecoveryError.Timeout => { /* expected */ }
        _ => assert(false, "Should be Timeout"),
    }
}

@test
fn test_recovery_error_inner_error() {
    // InnerError wraps an Error value
    let _: RecoveryError = RecoveryError.Timeout;
    // Verify InnerError variant exists as a type
    let _ = RecoveryError.Timeout; // type check
}

