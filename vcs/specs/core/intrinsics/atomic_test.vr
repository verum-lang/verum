// =============================================================================
// vcs/specs/core/intrinsics/atomic_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L0
// @tags: stdlib, intrinsics, atomic, concurrency, memory-ordering, fence
// @description: Comprehensive tests for atomic operation intrinsics.
//
// Coverage:
// - Memory ordering enum: Relaxed, Acquire, Release, AcqRel, SeqCst
// - Ordering constants: ORDERING_RELAXED through ORDERING_SEQ_CST
// - Fence operations: atomic_fence, compiler_fence with all orderings
// - VBC-specific function import verification
// - Generic function import verification
// - Compatibility alias verification
//
// Test Strategy:
// - Test ordering enum values are distinct
// - Test ordering constants have correct values
// - Test fence operations don't crash
// - Verify all function imports resolve correctly
// =============================================================================

module test.stdlib.intrinsics.atomic_test;

mount core.intrinsics.atomic.{
    // Memory ordering
    MemoryOrder, Relaxed, Acquire, Release, AcqRel, SeqCst,
    // Ordering constants
    ORDERING_RELAXED, ORDERING_ACQUIRE, ORDERING_RELEASE, ORDERING_ACQ_REL, ORDERING_SEQ_CST,
    // Generic atomics
    atomic_load, atomic_store, atomic_xchg,
    atomic_cmpxchg, atomic_cmpxchg_weak,
    atomic_add, atomic_sub, atomic_max, atomic_min,
    atomic_umax, atomic_umin,
    atomic_and, atomic_nand, atomic_or, atomic_xor,
    // VBC-specific atomics
    atomic_load_u32, atomic_store_u32, atomic_cas_u32,
    atomic_load_u64, atomic_store_u64, atomic_cas_u64,
    atomic_load_u8, atomic_load_u16,
    atomic_store_u8, atomic_store_u16,
    atomic_load_i32, atomic_store_i32, atomic_cas_i32,
    atomic_fetch_add_u32, atomic_fetch_sub_u32,
    atomic_fetch_add_u64, atomic_fetch_sub_u64,
    atomic_fetch_add_u16,
    atomic_fetch_and_u64, atomic_fetch_and_u16,
    atomic_fetch_or_u64, atomic_fetch_xor_u64,
    atomic_exchange_u32, atomic_exchange_u64, atomic_exchange_i32,
    // Int helpers
    atomic_load_int, atomic_store_int, atomic_cmpxchg_int, atomic_fetch_add_int,
    // Compatibility aliases
    atomic_compare_exchange_u32, atomic_compare_exchange_u64, atomic_compare_exchange_i32,
    // Fences
    atomic_fence, compiler_fence,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// Memory Ordering Constants
// =============================================================================

@test
fn test_ordering_constant_values() {
    assert(ORDERING_RELAXED == (0 as UInt8));
    assert(ORDERING_ACQUIRE == (1 as UInt8));
    assert(ORDERING_RELEASE == (2 as UInt8));
    assert(ORDERING_ACQ_REL == (3 as UInt8));
    assert(ORDERING_SEQ_CST == (4 as UInt8));
}

@test
fn test_ordering_constants_distinct() {
    assert(ORDERING_RELAXED != ORDERING_ACQUIRE);
    assert(ORDERING_ACQUIRE != ORDERING_RELEASE);
    assert(ORDERING_RELEASE != ORDERING_ACQ_REL);
    assert(ORDERING_ACQ_REL != ORDERING_SEQ_CST);
    assert(ORDERING_RELAXED != ORDERING_SEQ_CST);
}

@test
fn test_ordering_constants_type() {
    let _: UInt8 = ORDERING_RELAXED;
    let _: UInt8 = ORDERING_ACQUIRE;
    let _: UInt8 = ORDERING_RELEASE;
    let _: UInt8 = ORDERING_ACQ_REL;
    let _: UInt8 = ORDERING_SEQ_CST;
}

// =============================================================================
// Memory Ordering Enum — Variant Existence
// =============================================================================

@test
fn test_ordering_enum_relaxed() {
    let o: MemoryOrder = Relaxed;
    match o {
        Relaxed => {},
        _ => panic("Expected Relaxed"),
    }
}

@test
fn test_ordering_enum_acquire() {
    let o: MemoryOrder = Acquire;
    match o {
        Acquire => {},
        _ => panic("Expected Acquire"),
    }
}

@test
fn test_ordering_enum_release() {
    let o: MemoryOrder = Release;
    match o {
        Release => {},
        _ => panic("Expected Release"),
    }
}

@test
fn test_ordering_enum_acqrel() {
    let o: MemoryOrder = AcqRel;
    match o {
        AcqRel => {},
        _ => panic("Expected AcqRel"),
    }
}

@test
fn test_ordering_enum_seqcst() {
    let o: MemoryOrder = SeqCst;
    match o {
        SeqCst => {},
        _ => panic("Expected SeqCst"),
    }
}

@test
fn test_ordering_enum_all_variants() {
    let _: MemoryOrder = Relaxed;
    let _: MemoryOrder = Acquire;
    let _: MemoryOrder = Release;
    let _: MemoryOrder = AcqRel;
    let _: MemoryOrder = SeqCst;
}

// =============================================================================
// Fences — atomic_fence
// =============================================================================

@test
fn test_atomic_fence_acquire() {
    atomic_fence(Acquire);
}

@test
fn test_atomic_fence_release() {
    atomic_fence(Release);
}

@test
fn test_atomic_fence_acqrel() {
    atomic_fence(AcqRel);
}

@test
fn test_atomic_fence_seqcst() {
    atomic_fence(SeqCst);
}

@test
fn test_atomic_fence_loop() {
    let mut i = 0;
    while i < 5 {
        atomic_fence(SeqCst);
        i = i + 1;
    }
    assert(i == 5);
}

