@test
fn test_compiler_fence_acquire() {
    compiler_fence(Acquire);
}

@test
fn test_compiler_fence_release() {
    compiler_fence(Release);
}

@test
fn test_compiler_fence_acqrel() {
    compiler_fence(AcqRel);
}

@test
fn test_compiler_fence_seqcst() {
    compiler_fence(SeqCst);
}

@test
fn test_compiler_fence_loop() {
    let mut i = 0;
    while i < 5 {
        compiler_fence(SeqCst);
        i = i + 1;
    }
    assert(i == 5);
}

