// =============================================================================
// Mixed Fence Sequences
// =============================================================================

@test
fn test_mixed_fence_sequence() {
    atomic_fence(Acquire);
    compiler_fence(Release);
    atomic_fence(SeqCst);
    compiler_fence(AcqRel);
    atomic_fence(Release);
    compiler_fence(Acquire);
}

// =============================================================================
// Memory Ordering Enum — Distinctness
// =============================================================================

@test
fn test_ordering_enum_relaxed_not_others() {
    let o: MemoryOrder = Relaxed;
    assert(o is Relaxed);
    assert(!(o is Acquire));
    assert(!(o is Release));
    assert(!(o is AcqRel));
    assert(!(o is SeqCst));
}

@test
fn test_ordering_enum_acquire_not_others() {
    let o: MemoryOrder = Acquire;
    assert(o is Acquire);
    assert(!(o is Relaxed));
    assert(!(o is Release));
    assert(!(o is AcqRel));
    assert(!(o is SeqCst));
}

@test
fn test_ordering_enum_seqcst_not_others() {
    let o: MemoryOrder = SeqCst;
    assert(o is SeqCst);
    assert(!(o is Relaxed));
    assert(!(o is Acquire));
    assert(!(o is Release));
    assert(!(o is AcqRel));
}

// =============================================================================
// Memory Ordering Constants — Ordering
// =============================================================================

@test
fn test_ordering_constants_monotonic() {
    assert(ORDERING_RELAXED < ORDERING_ACQUIRE);
    assert(ORDERING_ACQUIRE < ORDERING_RELEASE);
    assert(ORDERING_RELEASE < ORDERING_ACQ_REL);
    assert(ORDERING_ACQ_REL < ORDERING_SEQ_CST);
}

// =============================================================================
// Memory Ordering Enum — Match Exhaustive
// =============================================================================

@test
fn test_ordering_enum_match_exhaustive() {
    let o: MemoryOrder = AcqRel;
    let val = match o {
        Relaxed => 0,
        Acquire => 1,
        Release => 2,
        AcqRel => 3,
        SeqCst => 4,
    };
    assert_eq(val, 3);
}

@test
fn test_ordering_enum_match_all_branches() {
    let orders: List<MemoryOrder> = List.from([Relaxed, Acquire, Release, AcqRel, SeqCst]);
    let mut sum = 0;
    for o in orders.iter() {
        let val = match o {
            Relaxed => 1,
            Acquire => 2,
            Release => 4,
            AcqRel => 8,
            SeqCst => 16,
        };
        sum = sum + val;
    }
    assert_eq(sum, 31); // 1+2+4+8+16
}

// =============================================================================
// Alternating Fences
// =============================================================================

@test
fn test_alternating_atomic_compiler_fences() {
    for _ in 0..5 {
        atomic_fence(Acquire);
        compiler_fence(Release);
    }
}

@test
fn test_all_orderings_atomic_fence() {
    let orders: List<MemoryOrder> = List.from([Acquire, Release, AcqRel, SeqCst]);
    for o in orders.iter() {
        atomic_fence(*o);
    }
}

@test
fn test_all_orderings_compiler_fence() {
    let orders: List<MemoryOrder> = List.from([Acquire, Release, AcqRel, SeqCst]);
    for o in orders.iter() {
        compiler_fence(*o);
    }
}

// =============================================================================
// Additional Memory Ordering Enum Tests
// =============================================================================

@test
fn test_ordering_enum_release_not_others() {
    let o: MemoryOrder = Release;
    assert(o is Release);
    assert(!(o is Relaxed));
    assert(!(o is Acquire));
    assert(!(o is AcqRel));
    assert(!(o is SeqCst));
}

@test
fn test_ordering_enum_acqrel_not_others() {
    let o: MemoryOrder = AcqRel;
    assert(o is AcqRel);
    assert(!(o is Relaxed));
    assert(!(o is Acquire));
    assert(!(o is Release));
    assert(!(o is SeqCst));
}

@test
fn test_ordering_enum_five_variants_count() {
    let orders: List<MemoryOrder> = List.from([Relaxed, Acquire, Release, AcqRel, SeqCst]);
    assert_eq(orders.len(), 5);
}

// =============================================================================
// Additional Fence Tests
// =============================================================================

@test
fn test_fence_interleaved_with_computation() {
    let mut sum = 0;
    atomic_fence(Acquire);
    sum = sum + 1;
    compiler_fence(Release);
    sum = sum + 2;
    atomic_fence(SeqCst);
    sum = sum + 3;
    compiler_fence(AcqRel);
    assert_eq(sum, 6);
}

@test
fn test_compiler_fence_does_not_affect_state() {
    let mut x = 42;
    compiler_fence(SeqCst);
    assert_eq(x, 42);
    compiler_fence(Acquire);
    x = x + 1;
    compiler_fence(Release);
    assert_eq(x, 43);
}

@test
fn test_ordering_constant_range() {
    // All constants should be in 0..=4
    assert(ORDERING_RELAXED <= (4 as UInt8));
    assert(ORDERING_ACQUIRE <= (4 as UInt8));
    assert(ORDERING_RELEASE <= (4 as UInt8));
    assert(ORDERING_ACQ_REL <= (4 as UInt8));
    assert(ORDERING_SEQ_CST <= (4 as UInt8));
}

@test
fn test_multiple_fence_types_in_sequence() {
    atomic_fence(Acquire);
    atomic_fence(Release);
    atomic_fence(AcqRel);
    atomic_fence(SeqCst);
    compiler_fence(Acquire);
    compiler_fence(Release);
    compiler_fence(AcqRel);
    compiler_fence(SeqCst);
}

@test
fn test_ordering_match_returns_value() {
    let o: MemoryOrder = Release;
    let val = match o {
        Relaxed => 0,
        Acquire => 1,
        Release => 2,
        AcqRel => 3,
        SeqCst => 4,
    };
    assert_eq(val, 2);
}
