// =============================================================================
// vcs/specs/core/intrinsics/lowlevel/x86_64_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: core, intrinsics, lowlevel, x86_64, cpu-features, sse, avx, crypto
// @note: x86_64 module loads fine for typecheck-pass regardless of target arch
// @description: Tests for x86_64-specific low-level intrinsics including
//               CPU feature detection (CpuFeatures record), SSE/AVX operations,
//               bit manipulation, cryptographic instructions, system registers,
//               timing, and port I/O.
//
// Coverage:
// - CpuFeatures: record construction and field access
// - cpu_features(): runtime CPU detection
// - SSE/SSE2: sqrtps, rcpps, rsqrtps, dpps
// - AVX/AVX2: haddps_256, fmadd_ps_256
// - Bit manipulation: tzcnt, lzcnt, popcnt, bextr, pdep, pext
// - Timing: rdtsc, rdtscp, mfence, lfence
//
// Test Strategy:
// - CpuFeatures type construction
// - Function existence verification
// =============================================================================

module specs.core.intrinsics.lowlevel.x86_64_test;

mount core.intrinsics.lowlevel.x86_64.{
    CpuFeatures,
    cpu_features,
    cpuid,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// CpuFeatures Type Tests
// =============================================================================

@test
fn test_cpu_features_type_exists() {
    let _: CpuFeatures;
}

@test
fn test_cpu_features_construction() {
    let features = CpuFeatures {
        has_sse3: true,
        has_ssse3: true,
        has_sse41: true,
        has_sse42: true,
        has_avx: true,
        has_avx2: false,
        has_avx512f: false,
        has_avx512dq: false,
        has_avx512bw: false,
        has_avx512vl: false,
        has_fma: true,
        has_bmi1: true,
        has_bmi2: true,
        has_popcnt: true,
        has_lzcnt: true,
        has_aes: true,
        has_pclmulqdq: true,
        has_sha: false,
        has_cx16: true,
    };
    assert(features.has_sse3, "SSE3 should be available");
    assert(!features.has_avx512f, "AVX-512F should not be available");
}

@test
fn test_cpu_features_field_access() {
    let features = CpuFeatures {
        has_sse3: false, has_ssse3: false, has_sse41: false, has_sse42: false,
        has_avx: false, has_avx2: false, has_avx512f: false, has_avx512dq: false,
        has_avx512bw: false, has_avx512vl: false, has_fma: false, has_bmi1: false,
        has_bmi2: false, has_popcnt: false, has_lzcnt: false, has_aes: false,
        has_pclmulqdq: false, has_sha: false, has_cx16: false,
    };
    assert(!features.has_avx, "All features should be false");
}

// =============================================================================
// Function Existence Tests
// =============================================================================

@test
fn test_cpu_features_fn_exists() {
    let _ = cpu_features;
}

@test
fn test_cpuid_fn_exists() {
    let _ = cpuid;
}
