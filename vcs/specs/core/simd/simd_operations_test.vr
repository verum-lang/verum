// =============================================================================
// Section 21: Shuffle and Rotate Deeper Tests
// =============================================================================

@test
fn test_vec4i_reverse() {
    let v = Vec4i.from_array([100, 200, 300, 400]);
    let reversed = v.reverse();
    let arr = reversed.to_array();
    assert_eq(arr[0], 400);
    assert_eq(arr[1], 300);
    assert_eq(arr[2], 200);
    assert_eq(arr[3], 100);
    print("Vec4i reverse test passed (dup)");
}

@test
fn test_vec4i_rotate_left_1() {
    let v = Vec4i.from_array([10, 20, 30, 40]);
    let rotated = v.rotate_left<1>();
    let arr = rotated.to_array();
    assert_eq(arr[0], 20);
    assert_eq(arr[1], 30);
    assert_eq(arr[2], 40);
    assert_eq(arr[3], 10);
    print("Vec4i rotate_left<1> test passed");
}

@test
fn test_vec4f_rotate_left_3() {
    let v = Vec4f.from_array([1.0, 2.0, 3.0, 4.0]);
    let rotated = v.rotate_left<3>();
    let arr = rotated.to_array();
    // Rotate left by 3: [4.0, 1.0, 2.0, 3.0]
    assert_eq(arr[0], 4.0);
    assert_eq(arr[1], 1.0);
    assert_eq(arr[2], 2.0);
    assert_eq(arr[3], 3.0);
    print("Vec4f rotate_left<3> test passed");
}

@test
fn test_vec2d_reverse() {
    let v = Vec2d.from_array([1.0, 2.0]);
    let reversed = v.reverse();
    let arr = reversed.to_array();
    assert_eq(arr[0], 2.0);
    assert_eq(arr[1], 1.0);
    print("Vec2d reverse test passed");
}

// =============================================================================
// Section 22: Chained Operations
// =============================================================================

@test
fn test_vec4f_add_sub_chain() {
    let a = Vec4f.from_array([10.0, 20.0, 30.0, 40.0]);
    let b = Vec4f.from_array([5.0, 5.0, 5.0, 5.0]);
    // (a + b) - b should equal a
    let result = a.add(b).sub(b).to_array();
    assert_eq(result[0], 10.0);
    assert_eq(result[1], 20.0);
    assert_eq(result[2], 30.0);
    assert_eq(result[3], 40.0);
    print("Vec4f add-sub chain test passed");
}

@test
fn test_vec4i_chain_mul_add() {
    let v = Vec4i.from_array([1, 2, 3, 4]);
    let two = Vec4i.splat(2);
    let ten = Vec4i.splat(10);
    // (v * 2) + 10
    let result = v.mul(two).add(ten).to_array();
    assert_eq(result[0], 12);
    assert_eq(result[1], 14);
    assert_eq(result[2], 16);
    assert_eq(result[3], 18);
    print("Vec4i chain mul-add test passed");
}

@test
fn test_vec4f_abs_after_sub() {
    let a = Vec4f.from_array([1.0, 5.0, 3.0, 8.0]);
    let b = Vec4f.from_array([3.0, 2.0, 7.0, 4.0]);
    let result = a.sub(b).abs().to_array();
    assert_eq(result[0], 2.0);   // |1-3| = 2
    assert_eq(result[1], 3.0);   // |5-2| = 3
    assert_eq(result[2], 4.0);   // |3-7| = 4
    assert_eq(result[3], 4.0);   // |8-4| = 4
    print("Vec4f abs after sub test passed");
}

// =============================================================================
// Section 23: Construction Patterns
// =============================================================================

@test
fn test_vec4f_splat_negative() {
    let v = Vec4f.splat(-5.0);
    let arr = v.to_array();
    assert_eq(arr[0], -5.0);
    assert_eq(arr[1], -5.0);
    assert_eq(arr[2], -5.0);
    assert_eq(arr[3], -5.0);
    print("Vec4f splat negative test passed");
}

@test
fn test_vec4i_splat_negative() {
    let v = Vec4i.splat(-42);
    let arr = v.to_array();
    assert_eq(arr[0], -42);
    assert_eq(arr[3], -42);
    print("Vec4i splat negative test passed");
}

@test
fn test_vec4f_splat_zero() {
    let v = Vec4f.splat(0.0);
    let arr = v.to_array();
    assert_eq(arr[0], 0.0);
    assert_eq(arr[3], 0.0);
    print("Vec4f splat zero test passed");
}

@test
fn test_vec4i_from_array_with_negatives() {
    let v = Vec4i.from_array([-100, 0, 100, -200]);
    let arr = v.to_array();
    assert_eq(arr[0], -100);
    assert_eq(arr[1], 0);
    assert_eq(arr[2], 100);
    assert_eq(arr[3], -200);
    print("Vec4i from_array with negatives test passed");
}

@test
fn test_vec2l_splat() {
    let v = Vec2l.splat(999);
    let arr = v.to_array();
    assert_eq(arr[0], 999);
    assert_eq(arr[1], 999);
    print("Vec2l splat test passed");
}

@test
fn test_vec2l_from_array() {
    let v = Vec2l.from_array([100, 200]);
    let arr = v.to_array();
    assert_eq(arr[0], 100);
    assert_eq(arr[1], 200);
    print("Vec2l from_array test passed");
}

