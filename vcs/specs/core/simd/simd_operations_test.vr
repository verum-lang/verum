// =============================================================================
// Section 17: Comparison Deeper Tests
// =============================================================================

@test
fn test_vec4f_cmp_eq_all_equal() {
    let v = Vec4f.splat(5.0);
    let mask = v.cmp_eq(v);
    assert_eq(mask.count(), 4);
    assert(mask.all_active());
    print("Vec4f cmp_eq all equal test passed");
}

@test
fn test_vec4f_cmp_ne_all_equal() {
    let v = Vec4f.splat(5.0);
    let mask = v.cmp_ne(v);
    assert_eq(mask.count(), 0);
    assert(!mask.any());
    print("Vec4f cmp_ne all equal test passed");
}

@test
fn test_vec4i_cmp_le() {
    let a = Vec4i.from_array([1, 3, 3, 5]);
    let b = Vec4i.from_array([2, 3, 4, 4]);
    let mask = a.cmp_le(b);
    // 1<=2=true, 3<=3=true, 3<=4=true, 5<=4=false
    assert_eq(mask.count(), 3);
    print("Vec4i cmp_le test passed");
}

@test
fn test_vec4i_cmp_gt() {
    let a = Vec4i.from_array([5, 3, 7, 1]);
    let b = Vec4i.from_array([2, 4, 6, 8]);
    let mask = a.cmp_gt(b);
    // 5>2=true, 3>4=false, 7>6=true, 1>8=false
    assert_eq(mask.count(), 2);
    print("Vec4i cmp_gt test passed");
}

@test
fn test_vec4i_cmp_ge() {
    let a = Vec4i.from_array([2, 3, 4, 5]);
    let b = Vec4i.from_array([2, 4, 3, 5]);
    let mask = a.cmp_ge(b);
    // 2>=2=true, 3>=4=false, 4>=3=true, 5>=5=true
    assert_eq(mask.count(), 3);
    print("Vec4i cmp_ge test passed");
}

@test
fn test_vec4i_cmp_eq() {
    let a = Vec4i.from_array([1, 2, 3, 4]);
    let b = Vec4i.from_array([1, 3, 3, 5]);
    let mask = a.cmp_eq(b);
    // 1==1=true, 2==3=false, 3==3=true, 4==5=false
    assert_eq(mask.count(), 2);
    print("Vec4i cmp_eq test passed");
}

@test
fn test_vec4i_cmp_ne() {
    let a = Vec4i.from_array([1, 2, 3, 4]);
    let b = Vec4i.from_array([1, 3, 3, 5]);
    let mask = a.cmp_ne(b);
    // 1!=1=false, 2!=3=true, 3!=3=false, 4!=5=true
    assert_eq(mask.count(), 2);
    print("Vec4i cmp_ne test passed");
}

// =============================================================================
// Section 18: FMA Edge Cases
// =============================================================================

@test
fn test_vec4f_fma_zero_mul() {
    // fma(a, 0, c) = a * 0 + c = c
    let a = Vec4f.from_array([1.0, 2.0, 3.0, 4.0]);
    let zero = Vec4f.splat(0.0);
    let c = Vec4f.from_array([10.0, 20.0, 30.0, 40.0]);
    let result = a.fma(zero, c).to_array();
    assert_eq(result[0], 10.0);
    assert_eq(result[1], 20.0);
    assert_eq(result[2], 30.0);
    assert_eq(result[3], 40.0);
    print("Vec4f fma zero mul test passed");
}

@test
fn test_vec4f_fma_zero_add() {
    // fma(a, b, 0) = a * b
    let a = Vec4f.from_array([2.0, 3.0, 4.0, 5.0]);
    let b = Vec4f.from_array([3.0, 4.0, 5.0, 6.0]);
    let zero = Vec4f.splat(0.0);
    let result = a.fma(b, zero).to_array();
    assert_eq(result[0], 6.0);
    assert_eq(result[1], 12.0);
    assert_eq(result[2], 20.0);
    assert_eq(result[3], 30.0);
    print("Vec4f fma zero add test passed");
}

@test
fn test_vec4f_fma_identity() {
    // fma(a, 1, 0) = a
    let a = Vec4f.from_array([7.0, 8.0, 9.0, 10.0]);
    let one = Vec4f.splat(1.0);
    let zero = Vec4f.splat(0.0);
    let result = a.fma(one, zero).to_array();
    assert_eq(result[0], 7.0);
    assert_eq(result[1], 8.0);
    assert_eq(result[2], 9.0);
    assert_eq(result[3], 10.0);
    print("Vec4f fma identity test passed");
}

// =============================================================================
// Section 19: Select Edge Cases
// =============================================================================

@test
fn test_vec4f_select_all_true() {
    let a = Vec4f.from_array([1.0, 2.0, 3.0, 4.0]);
    let b = Vec4f.from_array([10.0, 20.0, 30.0, 40.0]);
    let mask = Mask4.all();
    let result = Vec4f.select(mask, a, b).to_array();
    assert_eq(result[0], 1.0);
    assert_eq(result[1], 2.0);
    assert_eq(result[2], 3.0);
    assert_eq(result[3], 4.0);
    print("Vec4f select all true test passed");
}

@test
fn test_vec4f_select_all_false() {
    let a = Vec4f.from_array([1.0, 2.0, 3.0, 4.0]);
    let b = Vec4f.from_array([10.0, 20.0, 30.0, 40.0]);
    let mask = Mask4.none();
    let result = Vec4f.select(mask, a, b).to_array();
    assert_eq(result[0], 10.0);
    assert_eq(result[1], 20.0);
    assert_eq(result[2], 30.0);
    assert_eq(result[3], 40.0);
    print("Vec4f select all false test passed");
}

