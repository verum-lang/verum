@test
fn test_static_mask16_all() {
    let m = Mask16.all();
    assert(m.all_active());
    assert_eq(m.count(), 16);
}

@test
fn test_static_mask16_and_all_all() {
    let a = Mask16.all();
    let b = Mask16.all();
    let result = a.and(b);
    assert_eq(result.count(), 16);
    assert(result.all_active());
}

