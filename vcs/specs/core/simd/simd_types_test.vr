// =============================================================================
// simd_types_test.vr - Tests for SIMD type definitions
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: simd, types, vectors, portable, core
// @description: Tests for SIMD type imports and basic type checking
// =============================================================================

// Import basic types - these should resolve successfully
mount core.simd.SimdElement;
mount core.simd.Vec;
mount core.simd.Mask;

// Import type aliases
mount core.simd.{
    Vec4f, Vec2d, Vec4i, Vec2l, Vec16b, Vec8s,
    Vec8f, Vec4d, Vec8i, Vec4l, Vec32b, Vec16s,
    Vec16f, Vec8d, Vec16i, Vec8l, Vec64b, Vec32s,
    Mask4, Mask8, Mask16,
};

// Import platform constants
mount core.simd.{HAS_SSE42, HAS_AVX, HAS_AVX2, HAS_AVX512, HAS_NEON};

// =============================================================================
// SECTION 1: Basic Import Verification
// =============================================================================

// Test that SimdElement protocol can be imported
@test
fn test_simd_element_import() {
    // SimdElement protocol import verified — compilation is the test
    fn accept_element(v: &Vec4f) -> Bool { true }
    let _ = accept_element;
}

