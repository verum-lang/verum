// =============================================================================
// format_traits_test.vr - Tests for LowerHex, UpperHex, Binary, Octal,
//                         LowerExp, UpperExp protocols
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: text, format, hex, binary, octal, exponential
// @description: Tests for specialized format protocols: LowerHex, UpperHex,
//               Binary, Octal, LowerExp, UpperExp. Verifies protocol
//               definitions, Int implementations, Float implementations,
//               and formatting functions.
// =============================================================================

mount core.text.format.{
    TextFormatter, FormatSpec,
    LowerHex, UpperHex, Binary, Octal, LowerExp, UpperExp,
    format_hex, format_binary, format_octal,
    format_lower_exp, format_upper_exp,
};
mount core.base.result.{Result, Ok, Err};
mount core.base.protocols.{FormatError};

// =============================================================================
// Section 1: LowerHex protocol
// =============================================================================

@test
fn test_lower_hex_zero() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 0;
    let result = val.fmt_lower_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "0");
}

@test
fn test_lower_hex_ten() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 10;
    let result = val.fmt_lower_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "a");
}

@test
fn test_lower_hex_255() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 255;
    let result = val.fmt_lower_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "ff");
}

@test
fn test_lower_hex_256() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 256;
    let result = val.fmt_lower_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "100");
}

@test
fn test_lower_hex_one() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 1;
    let result = val.fmt_lower_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "1");
}

@test
fn test_lower_hex_sixteen() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 16;
    let result = val.fmt_lower_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "10");
}

// =============================================================================
// Section 2: UpperHex protocol
// =============================================================================

@test
fn test_upper_hex_zero() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 0;
    let result = val.fmt_upper_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "0");
}

@test
fn test_upper_hex_255() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 255;
    let result = val.fmt_upper_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "FF");
}

@test
fn test_upper_hex_171() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 171;  // 0xAB
    let result = val.fmt_upper_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "AB");
}

@test
fn test_upper_hex_large() {
    let mut buf = "";
    let mut fmt = TextFormatter.new(&mut buf);
    let val: Int = 4096; // 0x1000
    let result = val.fmt_upper_hex(&mut fmt);
    assert(result is Ok);
    assert_eq(buf, "1000");
}

