// =============================================================================
// text_utf16_test.vr - UTF-16 encoding/decoding for Text
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: text, utf16, encoding, decoding
// @description: Tests for Text.encode_utf16(), Text.from_utf16(),
//               and Text.from_utf16_lossy(). Covers ASCII, BMP,
//               supplementary characters, surrogate pairs, and error cases.
// =============================================================================

mount core.text.{Text};

// =============================================================================
// Section 1: encode_utf16 — ASCII
// =============================================================================

@test
fn test_encode_utf16_empty() {
    let s: Text = "";
    let units = s.encode_utf16();
    assert_eq(units.len(), 0);
}

@test
fn test_encode_utf16_ascii() {
    let s: Text = "hello";
    let units = s.encode_utf16();
    assert_eq(units.len(), 5);
    assert_eq(units[0], 104);  // 'h'
    assert_eq(units[1], 101);  // 'e'
    assert_eq(units[2], 108);  // 'l'
    assert_eq(units[3], 108);  // 'l'
    assert_eq(units[4], 111);  // 'o'
}

@test
fn test_encode_utf16_single_char() {
    let s: Text = "A";
    let units = s.encode_utf16();
    assert_eq(units.len(), 1);
    assert_eq(units[0], 65);
}

// =============================================================================
// Section 2: encode_utf16 — BMP (non-ASCII)
// =============================================================================

@test
fn test_encode_utf16_bmp_chars() {
    // Euro sign U+20AC → single code unit 0x20AC (8364)
    let s: Text = "\u{20AC}";
    let units = s.encode_utf16();
    assert_eq(units.len(), 1);
    assert_eq(units[0], 8364);
}

@test
fn test_encode_utf16_mixed_bmp() {
    // "A" + euro sign: 2 BMP code units
    let mut s: Text = "A";
    s.push('\u{20AC}');
    let units = s.encode_utf16();
    assert_eq(units.len(), 2);
    assert_eq(units[0], 65);     // 'A'
    assert_eq(units[1], 8364);   // U+20AC
}

// =============================================================================
// Section 3: encode_utf16 — Supplementary (surrogate pairs)
// =============================================================================

@test
fn test_encode_utf16_supplementary() {
    // U+1F600 (Grinning Face) → surrogate pair 0xD83D, 0xDE00
    let mut s: Text = "";
    s.push('\u{1F600}');
    let units = s.encode_utf16();
    assert_eq(units.len(), 2);
    assert_eq(units[0], 0xD83D);
    assert_eq(units[1], 0xDE00);
}

// =============================================================================
// Section 4: from_utf16 — valid input
// =============================================================================

@test
fn test_from_utf16_empty() {
    let units: [Int; 0] = [];
    let result = Text.from_utf16(&units);
    assert(result is Ok);
}

@test
fn test_from_utf16_ascii() {
    let units: [Int; 5] = [104, 101, 108, 108, 111];
    let result = Text.from_utf16(&units);
    assert(result is Ok);
}

@test
fn test_from_utf16_bmp() {
    // Euro sign U+20AC
    let units: [Int; 1] = [8364];
    let result = Text.from_utf16(&units);
    assert(result is Ok);
}

@test
fn test_from_utf16_surrogate_pair() {
    // U+1F600 → 0xD83D 0xDE00
    let units: [Int; 2] = [0xD83D, 0xDE00];
    let result = Text.from_utf16(&units);
    assert(result is Ok);
}

// =============================================================================
// Section 5: from_utf16 — invalid input
// =============================================================================

@test
fn test_from_utf16_lone_high_surrogate() {
    let units: [Int; 1] = [0xD800];
    let result = Text.from_utf16(&units);
    assert(result is Err);
}

@test
fn test_from_utf16_lone_low_surrogate() {
    let units: [Int; 1] = [0xDC00];
    let result = Text.from_utf16(&units);
    assert(result is Err);
}

@test
fn test_from_utf16_reversed_surrogates() {
    // Low before high is invalid
    let units: [Int; 2] = [0xDC00, 0xD800];
    let result = Text.from_utf16(&units);
    assert(result is Err);
}

@test
fn test_from_utf16_high_surrogate_followed_by_non_surrogate() {
    // High surrogate followed by BMP char
    let units: [Int; 2] = [0xD800, 65];
    let result = Text.from_utf16(&units);
    assert(result is Err);
}

// =============================================================================
// Section 6: from_utf16_lossy
// =============================================================================

@test
fn test_from_utf16_lossy_valid() {
    let units: [Int; 5] = [104, 101, 108, 108, 111];
    let s = Text.from_utf16_lossy(&units);
    assert_eq(s, "hello");
}

@test
fn test_from_utf16_lossy_lone_surrogate() {
    // Lone high surrogate should produce U+FFFD
    let units: [Int; 3] = [65, 0xD800, 66];
    let s = Text.from_utf16_lossy(&units);
    // Result should be "A" + replacement + "B"
    assert_eq(s.len(), 6);  // 1 + 3 (U+FFFD is 3 bytes in UTF-8) + 1
}

@test
fn test_from_utf16_lossy_empty() {
    let units: [Int; 0] = [];
    let s = Text.from_utf16_lossy(&units);
    assert_eq(s, "");
}

// =============================================================================
// Section 7: roundtrip — encode then decode
// =============================================================================

@test
fn test_utf16_roundtrip_ascii() {
    let original: Text = "hello world";
    let encoded = original.encode_utf16();
    let decoded = Text.from_utf16(&encoded);
    assert(decoded is Ok);
}

@test
fn test_utf16_roundtrip_mixed() {
    // ASCII + BMP
    let mut original: Text = "A";
    original.push('\u{20AC}');
    original.push('Z');
    let encoded = original.encode_utf16();
    let decoded = Text.from_utf16(&encoded);
    assert(decoded is Ok);
}

// =============================================================================
// Section 8: Utf16Error type
// =============================================================================

@test
fn test_utf16_error_index() {
    let units: [Int; 3] = [65, 0xDC00, 66];
    let result = Text.from_utf16(&units);
    assert(result is Err);
}

fn main() {
    // Tests run via @test annotations
}
