// =============================================================================
// char_test.vr - Comprehensive tests for Char utilities
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: text, char, unicode, core
// @description: Comprehensive tests for Char type methods and utilities
// =============================================================================

mount core.text.{GeneralCategory, CharPattern, AnyChar, CharRange, any_of, char_range};
mount core.base.maybe.{Maybe};

// =============================================================================
// Section 1: ASCII Classification Tests
// =============================================================================

@test
fn test_char_is_ascii() {
    assert('a'.is_ascii());
    assert('Z'.is_ascii());
    assert('0'.is_ascii());
    assert(' '.is_ascii());
    assert('\n'.is_ascii());
    // Non-ASCII should return false (but we can't easily test without Unicode chars)
}

@test
fn test_char_is_ascii_alphabetic() {
    assert('a'.is_ascii_alphabetic());
    assert('z'.is_ascii_alphabetic());
    assert('A'.is_ascii_alphabetic());
    assert('Z'.is_ascii_alphabetic());
    assert('m'.is_ascii_alphabetic());
    assert('M'.is_ascii_alphabetic());

    assert(!('0'.is_ascii_alphabetic()));
    assert(!(' '.is_ascii_alphabetic()));
    assert(!('!'.is_ascii_alphabetic()));
}

@test
fn test_char_is_ascii_uppercase() {
    assert('A'.is_ascii_uppercase());
    assert('Z'.is_ascii_uppercase());
    assert('M'.is_ascii_uppercase());

    assert(!('a'.is_ascii_uppercase()));
    assert(!('z'.is_ascii_uppercase()));
    assert(!('0'.is_ascii_uppercase()));
}

@test
fn test_char_is_ascii_lowercase() {
    assert('a'.is_ascii_lowercase());
    assert('z'.is_ascii_lowercase());
    assert('m'.is_ascii_lowercase());

    assert(!('A'.is_ascii_lowercase()));
    assert(!('Z'.is_ascii_lowercase()));
    assert(!('0'.is_ascii_lowercase()));
}

@test
fn test_char_is_ascii_digit() {
    assert('0'.is_ascii_digit());
    assert('5'.is_ascii_digit());
    assert('9'.is_ascii_digit());

    assert(!('a'.is_ascii_digit()));
    assert(!(' '.is_ascii_digit()));
    assert(!('!'.is_ascii_digit()));
}

@test
fn test_char_is_ascii_hexdigit() {
    // Decimal digits
    assert('0'.is_ascii_hexdigit());
    assert('9'.is_ascii_hexdigit());

    // Lowercase hex
    assert('a'.is_ascii_hexdigit());
    assert('f'.is_ascii_hexdigit());

    // Uppercase hex
    assert('A'.is_ascii_hexdigit());
    assert('F'.is_ascii_hexdigit());

    // Not hex
    assert(!('g'.is_ascii_hexdigit()));
    assert(!('G'.is_ascii_hexdigit()));
    assert(!(' '.is_ascii_hexdigit()));
}

@test
fn test_char_is_ascii_alphanumeric() {
    assert('a'.is_ascii_alphanumeric());
    assert('Z'.is_ascii_alphanumeric());
    assert('0'.is_ascii_alphanumeric());
    assert('9'.is_ascii_alphanumeric());

    assert(!(' '.is_ascii_alphanumeric()));
    assert(!('!'.is_ascii_alphanumeric()));
}

@test
fn test_char_is_ascii_whitespace() {
    assert(' '.is_ascii_whitespace());   // space
    assert('\t'.is_ascii_whitespace());  // tab
    assert('\n'.is_ascii_whitespace());  // newline
    assert('\r'.is_ascii_whitespace());  // carriage return

    assert(!('a'.is_ascii_whitespace()));
    assert(!('0'.is_ascii_whitespace()));
}

@test
fn test_char_is_ascii_control() {
    assert('\0'.is_ascii_control());     // NUL
    assert('\t'.is_ascii_control());     // TAB
    assert('\n'.is_ascii_control());     // LF
    assert('\r'.is_ascii_control());     // CR

    assert(!(' '.is_ascii_control()));    // space is not control
    assert(!('a'.is_ascii_control()));
}

@test
fn test_char_is_ascii_punctuation() {
    assert('!'.is_ascii_punctuation());
    assert('.'.is_ascii_punctuation());
    assert(','.is_ascii_punctuation());
    assert(';'.is_ascii_punctuation());
    assert(':'.is_ascii_punctuation());
    assert('?'.is_ascii_punctuation());
    assert('@'.is_ascii_punctuation());
    assert('['.is_ascii_punctuation());
    assert('{'.is_ascii_punctuation());
    assert('~'.is_ascii_punctuation());

    assert(!('a'.is_ascii_punctuation()));
    assert(!('0'.is_ascii_punctuation()));
    assert(!(' '.is_ascii_punctuation()));
}

@test
fn test_char_is_ascii_graphic() {
    assert('!'.is_ascii_graphic());
    assert('~'.is_ascii_graphic());
    assert('a'.is_ascii_graphic());
    assert('0'.is_ascii_graphic());

    assert(!(' '.is_ascii_graphic()));   // space is not graphic
    assert(!('\t'.is_ascii_graphic()));
}

// =============================================================================
// Section 2: ASCII Case Conversion Tests
// =============================================================================

@test
fn test_char_to_ascii_uppercase() {
    assert_eq('a'.to_ascii_uppercase(), 'A');
    assert_eq('z'.to_ascii_uppercase(), 'Z');
    assert_eq('m'.to_ascii_uppercase(), 'M');

    // Already uppercase - unchanged
    assert_eq('A'.to_ascii_uppercase(), 'A');
    assert_eq('Z'.to_ascii_uppercase(), 'Z');

    // Non-letters - unchanged
    assert_eq('0'.to_ascii_uppercase(), '0');
    assert_eq('!'.to_ascii_uppercase(), '!');
    assert_eq(' '.to_ascii_uppercase(), ' ');
}

@test
fn test_char_to_ascii_lowercase() {
    assert_eq('A'.to_ascii_lowercase(), 'a');
    assert_eq('Z'.to_ascii_lowercase(), 'z');
    assert_eq('M'.to_ascii_lowercase(), 'm');

    // Already lowercase - unchanged
    assert_eq('a'.to_ascii_lowercase(), 'a');
    assert_eq('z'.to_ascii_lowercase(), 'z');

    // Non-letters - unchanged
    assert_eq('0'.to_ascii_lowercase(), '0');
    assert_eq('!'.to_ascii_lowercase(), '!');
    assert_eq(' '.to_ascii_lowercase(), ' ');
}

@test
fn test_char_eq_ignore_ascii_case() {
    assert('a'.eq_ignore_ascii_case(&'a'));
    assert('a'.eq_ignore_ascii_case(&'A'));
    assert('A'.eq_ignore_ascii_case(&'a'));
    assert('A'.eq_ignore_ascii_case(&'A'));

    assert('z'.eq_ignore_ascii_case(&'Z'));

    assert(!('a'.eq_ignore_ascii_case(&'b')));
    assert(!('A'.eq_ignore_ascii_case(&'B')));
}

// =============================================================================
// Section 3: Digit Conversion Tests
// =============================================================================

@test
fn test_char_is_digit() {
    // Base 10
    assert('0'.is_digit(10));
    assert('9'.is_digit(10));
    assert(!('a'.is_digit(10)));

    // Base 16
    assert('0'.is_digit(16));
    assert('9'.is_digit(16));
    assert('a'.is_digit(16));
    assert('f'.is_digit(16));
    assert('A'.is_digit(16));
    assert('F'.is_digit(16));
    assert(!('g'.is_digit(16)));

    // Base 2
    assert('0'.is_digit(2));
    assert('1'.is_digit(2));
    assert(!('2'.is_digit(2)));

    // Base 36
    assert('0'.is_digit(36));
    assert('9'.is_digit(36));
    assert('z'.is_digit(36));
    assert('Z'.is_digit(36));
}

@test
fn test_char_to_digit_base10() {
    match '0'.to_digit(10) {
        Maybe.Some(d) => assert_eq(d, 0),
        Maybe.None => panic("Expected Some"),
    }

    match '5'.to_digit(10) {
        Maybe.Some(d) => assert_eq(d, 5),
        Maybe.None => panic("Expected Some"),
    }

    match '9'.to_digit(10) {
        Maybe.Some(d) => assert_eq(d, 9),
        Maybe.None => panic("Expected Some"),
    }

    match 'a'.to_digit(10) {
        Maybe.None => {} // Expected
        Maybe.Some(_) => panic("Expected None"),
    }
}

@test
fn test_char_to_digit_base16() {
    match '0'.to_digit(16) {
        Maybe.Some(d) => assert_eq(d, 0),
        Maybe.None => panic("Expected Some"),
    }

    match '9'.to_digit(16) {
        Maybe.Some(d) => assert_eq(d, 9),
        Maybe.None => panic("Expected Some"),
    }

    match 'a'.to_digit(16) {
        Maybe.Some(d) => assert_eq(d, 10),
        Maybe.None => panic("Expected Some"),
    }

    match 'f'.to_digit(16) {
        Maybe.Some(d) => assert_eq(d, 15),
        Maybe.None => panic("Expected Some"),
    }

    match 'A'.to_digit(16) {
        Maybe.Some(d) => assert_eq(d, 10),
        Maybe.None => panic("Expected Some"),
    }

    match 'F'.to_digit(16) {
        Maybe.Some(d) => assert_eq(d, 15),
        Maybe.None => panic("Expected Some"),
    }
}

@test
fn test_char_from_digit() {
    match Char.from_digit(0, 10) {
        Maybe.Some(c) => assert_eq(c, '0'),
        Maybe.None => panic("Expected Some"),
    }

    match Char.from_digit(5, 10) {
        Maybe.Some(c) => assert_eq(c, '5'),
        Maybe.None => panic("Expected Some"),
    }

    match Char.from_digit(9, 10) {
        Maybe.Some(c) => assert_eq(c, '9'),
        Maybe.None => panic("Expected Some"),
    }

    match Char.from_digit(10, 16) {
        Maybe.Some(c) => assert_eq(c, 'a'),
        Maybe.None => panic("Expected Some"),
    }

    match Char.from_digit(15, 16) {
        Maybe.Some(c) => assert_eq(c, 'f'),
        Maybe.None => panic("Expected Some"),
    }

    // Invalid digit for radix
    match Char.from_digit(10, 10) {
        Maybe.None => {} // Expected
        Maybe.Some(_) => panic("Expected None"),
    }

    match Char.from_digit(-1, 10) {
        Maybe.None => {} // Expected
        Maybe.Some(_) => panic("Expected None for negative"),
    }
}

// =============================================================================
// Section 4: UTF-8/UTF-16 Length Tests
// =============================================================================

@test
fn test_char_len_utf8() {
    // ASCII - 1 byte
    assert_eq('a'.len_utf8(), 1);
    assert_eq('0'.len_utf8(), 1);
    assert_eq(' '.len_utf8(), 1);
    assert_eq('\0'.len_utf8(), 1);
}

@test
fn test_char_len_utf16() {
    // BMP characters - 1 code unit
    assert_eq('a'.len_utf16(), 1);
    assert_eq('0'.len_utf16(), 1);
}

