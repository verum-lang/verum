// =============================================================================
// Section 10: Unicode Case Conversion Tests
// =============================================================================

@test
fn test_char_to_uppercase() {
    assert_eq('a'.to_uppercase(), 'A');
    assert_eq('z'.to_uppercase(), 'Z');
    assert_eq('m'.to_uppercase(), 'M');

    // Already uppercase
    assert_eq('A'.to_uppercase(), 'A');
    assert_eq('Z'.to_uppercase(), 'Z');

    // Non-letter unchanged
    assert_eq('0'.to_uppercase(), '0');
    assert_eq('!'.to_uppercase(), '!');
}

@test
fn test_char_to_lowercase() {
    assert_eq('A'.to_lowercase(), 'a');
    assert_eq('Z'.to_lowercase(), 'z');
    assert_eq('M'.to_lowercase(), 'm');

    // Already lowercase
    assert_eq('a'.to_lowercase(), 'a');
    assert_eq('z'.to_lowercase(), 'z');

    // Non-letter unchanged
    assert_eq('0'.to_lowercase(), '0');
    assert_eq('!'.to_lowercase(), '!');
}

// =============================================================================
// Section 11: In-Place Mutation Tests
// =============================================================================

@test
fn test_char_make_ascii_uppercase() {
    let mut c = 'a';
    c.make_ascii_uppercase();
    assert_eq(c, 'A');

    let mut d = 'z';
    d.make_ascii_uppercase();
    assert_eq(d, 'Z');

    // Already uppercase - unchanged
    let mut e = 'A';
    e.make_ascii_uppercase();
    assert_eq(e, 'A');

    // Non-letter - unchanged
    let mut f = '0';
    f.make_ascii_uppercase();
    assert_eq(f, '0');
}

@test
fn test_char_make_ascii_lowercase() {
    let mut c = 'A';
    c.make_ascii_lowercase();
    assert_eq(c, 'a');

    let mut d = 'Z';
    d.make_ascii_lowercase();
    assert_eq(d, 'z');

    // Already lowercase - unchanged
    let mut e = 'a';
    e.make_ascii_lowercase();
    assert_eq(e, 'a');

    // Non-letter - unchanged
    let mut f = '0';
    f.make_ascii_lowercase();
    assert_eq(f, '0');
}

// =============================================================================
// Section 12: Escape Sequence Tests
// =============================================================================

@test
fn test_char_escape_debug() {
    // Normal printable chars should be themselves
    let a_escaped: Text = 'a'.escape_debug();
    assert_eq(a_escaped, "a");

    let zero_escaped: Text = '0'.escape_debug();
    assert_eq(zero_escaped, "0");
}

@test
fn test_char_escape_debug_special() {
    // Special chars should be escaped
    let newline_escaped: Text = '\n'.escape_debug();
    assert_eq(newline_escaped, "\\n");

    let tab_escaped: Text = '\t'.escape_debug();
    assert_eq(tab_escaped, "\\t");

    let cr_escaped: Text = '\r'.escape_debug();
    assert_eq(cr_escaped, "\\r");

    let null_escaped: Text = '\0'.escape_debug();
    assert_eq(null_escaped, "\\0");

    let backslash_escaped: Text = '\\'.escape_debug();
    assert_eq(backslash_escaped, "\\\\");

    let quote_escaped: Text = '\''.escape_debug();
    assert_eq(quote_escaped, "\\'");
}

@test
fn test_char_escape_unicode() {
    let a_escaped: Text = 'a'.escape_unicode();
    // 'a' is U+0061
    assert_eq(a_escaped, "\\u{61}");

    let zero_escaped: Text = '0'.escape_unicode();
    // '0' is U+0030
    assert_eq(zero_escaped, "\\u{30}");
}

@test
fn test_char_escape_default() {
    // Printable ASCII should be unchanged
    let a_escaped: Text = 'a'.escape_default();
    assert_eq(a_escaped, "a");

    let zero_escaped: Text = '0'.escape_default();
    assert_eq(zero_escaped, "0");
}

@test
fn test_char_escape_default_special() {
    // Special chars should use symbolic escapes
    let newline_escaped: Text = '\n'.escape_default();
    assert_eq(newline_escaped, "\\n");

    let tab_escaped: Text = '\t'.escape_default();
    assert_eq(tab_escaped, "\\t");
}

// =============================================================================
// Section 13: UTF Encoding Tests
// =============================================================================

@test
fn test_char_encode_utf8_ascii() {
    let mut buf: List<Byte> = List.new();
    buf.push(0 as Byte);
    buf.push(0 as Byte);
    buf.push(0 as Byte);
    buf.push(0 as Byte);

    let len: Int = 'a'.encode_utf8(&mut buf);
    assert_eq(len, 1);
}

@test
fn test_char_encode_utf16_ascii() {
    let mut buf: List<Int> = List.new();
    buf.push(0);
    buf.push(0);

    let len: Int = 'a'.encode_utf16(&mut buf);
    assert_eq(len, 1);
}

