// =============================================================================

@test
fn test_general_category_is_letter() {
    assert(GeneralCategory.Lu.is_letter());
    assert(GeneralCategory.Ll.is_letter());
    assert(GeneralCategory.Lt.is_letter());
    assert(GeneralCategory.Lm.is_letter());
    assert(GeneralCategory.Lo.is_letter());

    assert(!GeneralCategory.Nd.is_letter());
    assert(!GeneralCategory.Sm.is_letter());
}

@test
fn test_general_category_is_number() {
    assert(GeneralCategory.Nd.is_number());
    assert(GeneralCategory.Nl.is_number());
    assert(GeneralCategory.No.is_number());

    assert(!GeneralCategory.Lu.is_number());
    assert(!GeneralCategory.Sm.is_number());
}

@test
fn test_general_category_is_punctuation() {
    assert(GeneralCategory.Pc.is_punctuation());
    assert(GeneralCategory.Pd.is_punctuation());
    assert(GeneralCategory.Ps.is_punctuation());
    assert(GeneralCategory.Pe.is_punctuation());
    assert(GeneralCategory.Po.is_punctuation());

    assert(!GeneralCategory.Lu.is_punctuation());
    assert(!GeneralCategory.Nd.is_punctuation());
}

@test
fn test_general_category_is_symbol() {
    assert(GeneralCategory.Sm.is_symbol());
    assert(GeneralCategory.Sc.is_symbol());
    assert(GeneralCategory.Sk.is_symbol());
    assert(GeneralCategory.So.is_symbol());

    assert(!GeneralCategory.Lu.is_symbol());
    assert(!GeneralCategory.Nd.is_symbol());
}

@test
fn test_general_category_is_separator() {
    assert(GeneralCategory.Zs.is_separator());
    assert(GeneralCategory.Zl.is_separator());
    assert(GeneralCategory.Zp.is_separator());

    assert(!GeneralCategory.Lu.is_separator());
    assert(!GeneralCategory.Nd.is_separator());
}

@test
fn test_general_category_is_other() {
    assert(GeneralCategory.Cc.is_other());
    assert(GeneralCategory.Cf.is_other());
    assert(GeneralCategory.Cs.is_other());
    assert(GeneralCategory.Co.is_other());
    assert(GeneralCategory.Cn.is_other());

    assert(!GeneralCategory.Lu.is_other());
    assert(!GeneralCategory.Nd.is_other());
}

// =============================================================================
// Section 6: CharPattern Tests
// =============================================================================

@test
fn test_char_pattern_char() {
    let pattern = 'a';
    assert(pattern.matches('a'));
    assert(!pattern.matches('b'));
    assert(!pattern.matches('A'));
}

@test
fn test_char_pattern_any_of() {
    let vowels = ['a', 'e', 'i', 'o', 'u'];
    let pattern = any_of(&vowels);

    assert(pattern.matches('a'));
    assert(pattern.matches('e'));
    assert(pattern.matches('u'));
    assert(!pattern.matches('b'));
    assert(!pattern.matches('x'));
}

@test
fn test_char_pattern_range() {
    let digits = char_range('0', '9');

    assert(digits.matches('0'));
    assert(digits.matches('5'));
    assert(digits.matches('9'));
    assert(!digits.matches('a'));
    assert(!digits.matches('!'));

    let lowercase = char_range('a', 'z');
    assert(lowercase.matches('a'));
    assert(lowercase.matches('m'));
    assert(lowercase.matches('z'));
    assert(!lowercase.matches('A'));
    assert(!lowercase.matches('0'));
}

// =============================================================================
// Section 7: Valid Unicode Test
// =============================================================================

@test
fn test_char_is_valid_unicode() {
    assert('a'.is_valid_unicode());
    assert('0'.is_valid_unicode());
    assert(' '.is_valid_unicode());
    // Surrogate code points are invalid, but we can't easily construct them
}

// =============================================================================
// Section 8: Edge Cases
// =============================================================================

@test
fn test_char_null() {
    assert('\0'.is_ascii());
    assert('\0'.is_ascii_control());
    assert(!'\0'.is_ascii_graphic());
    assert_eq('\0'.len_utf8(), 1);
}

@test
fn test_char_newline() {
    assert('\n'.is_ascii());
    assert('\n'.is_ascii_whitespace());
    assert('\n'.is_ascii_control());
    assert(!'\n'.is_ascii_graphic());
}

@test
fn test_char_space() {
    assert(' '.is_ascii());
    assert(' '.is_ascii_whitespace());
    assert(!(' '.is_ascii_control()));
    assert(!(' '.is_ascii_graphic()));
    assert(!(' '.is_ascii_punctuation()));
}

@test
fn test_char_boundary_values() {
    // Test boundary ASCII values
    let exclaim = '!';  // First printable (33)
    let tilde = '~';    // Last printable before DEL (126)

    assert(exclaim.is_ascii_graphic());
    assert(exclaim.is_ascii_punctuation());

    assert(tilde.is_ascii_graphic());
    assert(tilde.is_ascii_punctuation());
}

