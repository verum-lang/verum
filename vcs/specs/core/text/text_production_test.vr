// =============================================================================
// Section: Text Conversion Functions
// =============================================================================

@test
fn test_text_from_int_positive() {
    let t = Text.from_int(42);
    assert_eq(t, "42");
}

@test
fn test_text_from_int_negative() {
    let t = Text.from_int(-123);
    assert_eq(t, "-123");
}

@test
fn test_text_from_int_zero() {
    let t = Text.from_int(0);
    assert_eq(t, "0");
}

@test
fn test_text_from_int_large() {
    let t = Text.from_int(1000000);
    assert_eq(t, "1000000");
}

@test
fn test_text_from_float_basic() {
    let t = Text.from_float(3.14);
    // Float formatting may vary, just verify it contains expected digits
    assert(t.contains("3"));
    assert(t.contains("14"));
}

@test
fn test_text_from_float_zero() {
    let t = Text.from_float(0.0);
    assert(t.contains("0"));
}

@test
fn test_text_from_float_negative() {
    let t = Text.from_float(-2.5);
    assert(t.starts_with("-"));
    assert(t.contains("2"));
}

@test
fn test_text_from_float_integer() {
    let t = Text.from_float(100.0);
    assert(t.contains("100"));
}

@test
fn test_text_from_bool_true() {
    let t = Text.from_bool(true);
    assert_eq(t, "true");
}

@test
fn test_text_from_bool_false() {
    let t = Text.from_bool(false);
    assert_eq(t, "false");
}

// =============================================================================
// Section: Unicode Multi-byte Tests
// =============================================================================

@test
fn test_text_unicode_2byte_len() {
    // é is 2 bytes in UTF-8
    let t = "café";
    assert(t.len() >= 4); // At least 4 bytes (c=1, a=1, f=1, é=2 = 5)
}

@test
fn test_text_unicode_contains() {
    let t = "hello wörld";
    assert(t.contains("wörld"));
    assert(t.contains("hello"));
    assert(!t.contains("world")); // ASCII 'o' != 'ö'
}

@test
fn test_text_unicode_starts_ends_with() {
    let t = "über cool";
    assert(t.starts_with("über"));
    assert(t.ends_with("cool"));
}

@test
fn test_text_unicode_split() {
    let t = "a,ö,ü";
    let parts = t.split(",");
    assert_eq(parts.len(), 3);
    assert_eq(parts[0], "a");
    assert_eq(parts[1], "ö");
    assert_eq(parts[2], "ü");
}

@test
fn test_text_unicode_eq() {
    let a = "naïve";
    let b = "naïve";
    assert_eq(a, b);
}

@test
fn test_text_unicode_trim() {
    let t = "  héllo  ";
    let trimmed = t.trim();
    assert_eq(trimmed, "héllo");
}

@test
fn test_text_unicode_replace() {
    let t = "café latte";
    let replaced = t.replace("café", "espresso");
    assert_eq(replaced, "espresso latte");
}

@test
fn test_text_unicode_to_uppercase() {
    let t = "hello";
    assert_eq(t.to_uppercase(), "HELLO");
}

@test
fn test_text_unicode_to_lowercase() {
    let t = "HELLO";
    assert_eq(t.to_lowercase(), "hello");
}

// =============================================================================
// Section: SSO Boundary Edge Cases
// =============================================================================

@test
fn test_text_sso_boundary_22() {
    // 22 bytes = within SSO inline storage
    let t = "1234567890123456789012"; // 22 chars
    assert_eq(t.len(), 22);
    assert(!t.is_empty());
}

@test
fn test_text_sso_boundary_23() {
    // 23 bytes = SSO maximum capacity
    let t = "12345678901234567890123"; // 23 chars
    assert_eq(t.len(), 23);
}

@test
fn test_text_sso_boundary_24() {
    // 24 bytes = exceeds SSO, moves to heap
    let t = "123456789012345678901234"; // 24 chars
    assert_eq(t.len(), 24);
    assert(t.starts_with("1234"));
    assert(t.ends_with("1234"));
}

@test
fn test_text_sso_push_transition() {
    // Build up a string that crosses the SSO boundary
    let mut t = "";
    let mut i = 0;
    while i < 30 {
        t = t + "a";
        i = i + 1;
    }
    assert_eq(t.len(), 30);
    // Verify content is correct after SSO-to-heap transition
    assert(t.starts_with("aaa"));
    assert(t.ends_with("aaa"));
}

// =============================================================================
// Section: trim_start_matches / trim_end_matches
// =============================================================================

@test
fn test_trim_start_matches_basic() {
    let s = "---hello";
    assert_eq(s.trim_start_matches("-"), "hello");
}

@test
fn test_trim_start_matches_repeated() {
    let s = "aaabbb";
    assert_eq(s.trim_start_matches("a"), "bbb");
}

@test
fn test_trim_start_matches_not_found() {
    let s = "hello";
    assert_eq(s.trim_start_matches("x"), "hello");
}

@test
fn test_trim_start_matches_empty_pattern() {
    let s = "hello";
    assert_eq(s.trim_start_matches(""), "hello");
}

@test
fn test_trim_start_matches_multi_char() {
    let s = "abcabcdef";
    assert_eq(s.trim_start_matches("abc"), "def");
}

@test
fn test_trim_end_matches_basic() {
    let s = "hello---";
    assert_eq(s.trim_end_matches("-"), "hello");
}

@test
fn test_trim_end_matches_repeated() {
    let s = "bbbccc";
    assert_eq(s.trim_end_matches("c"), "bbb");
}

@test
fn test_trim_end_matches_not_found() {
    let s = "hello";
    assert_eq(s.trim_end_matches("x"), "hello");
}

@test
fn test_trim_end_matches_empty_pattern() {
    let s = "hello";
    assert_eq(s.trim_end_matches(""), "hello");
}

@test
fn test_trim_end_matches_multi_char() {
    let s = "defabcabc";
    assert_eq(s.trim_end_matches("abc"), "def");
}

// =============================================================================
// Section: pad_left / pad_right
// =============================================================================

@test
fn test_pad_left_basic() {
    let s = "42";
    assert_eq(s.pad_left(5, '0'), "00042");
}

@test
fn test_pad_left_no_padding_needed() {
    let s = "hello";
    assert_eq(s.pad_left(3, ' '), "hello");
}

@test
fn test_pad_left_exact_width() {
    let s = "abc";
    assert_eq(s.pad_left(3, ' '), "abc");
}

@test
fn test_pad_left_single_char() {
    let s = "x";
    assert_eq(s.pad_left(4, '.'), "...x");
}

@test
fn test_pad_left_empty_string() {
    let s = "";
    assert_eq(s.pad_left(3, '*'), "***");
}

@test
fn test_pad_right_basic() {
    let s = "hi";
    assert_eq(s.pad_right(5, '-'), "hi---");
}

@test
fn test_pad_right_no_padding_needed() {
    let s = "hello";
    assert_eq(s.pad_right(3, ' '), "hello");
}

@test
fn test_pad_right_exact_width() {
    let s = "abc";
    assert_eq(s.pad_right(3, ' '), "abc");
}

@test
fn test_pad_right_single_char() {
    let s = "x";
    assert_eq(s.pad_right(4, '.'), "x...");
}

@test
fn test_pad_right_empty_string() {
    let s = "";
    assert_eq(s.pad_right(3, '#'), "###");
}

// =============================================================================
// Section: splitn / rsplitn
// =============================================================================

@test
fn test_splitn_basic() {
    let s = "a:b:c:d";
    let parts = s.splitn(3, ":");
    assert_eq(parts.len(), 3);
    assert_eq(parts[0], "a");
    assert_eq(parts[1], "b");
    assert_eq(parts[2], "c:d"); // Remainder
}

@test
fn test_splitn_no_separator() {
    let s = "hello world";
    let parts = s.splitn(3, ":");
    assert_eq(parts.len(), 1);
    assert_eq(parts[0], "hello world");
}

@test
fn test_splitn_one() {
    let s = "a:b:c";
    let parts = s.splitn(1, ":");
    assert_eq(parts.len(), 1);
    assert_eq(parts[0], "a:b:c");
}

@test
fn test_splitn_exact() {
    let s = "a:b:c";
    let parts = s.splitn(3, ":");
    assert_eq(parts.len(), 3);
    assert_eq(parts[0], "a");
    assert_eq(parts[1], "b");
    assert_eq(parts[2], "c");
}

@test
fn test_splitn_more_than_parts() {
    let s = "a:b";
    let parts = s.splitn(5, ":");
    assert_eq(parts.len(), 2);
    assert_eq(parts[0], "a");
    assert_eq(parts[1], "b");
}

@test
fn test_rsplitn_basic() {
    let s = "a:b:c:d";
    let parts = s.rsplitn(3, ":");
    assert_eq(parts.len(), 3);
    assert_eq(parts[0], "a:b");   // Remainder (from left)
    assert_eq(parts[1], "c");
    assert_eq(parts[2], "d");
}

@test
fn test_rsplitn_no_separator() {
    let s = "hello world";
    let parts = s.rsplitn(3, ":");
    assert_eq(parts.len(), 1);
    assert_eq(parts[0], "hello world");
}

@test
fn test_rsplitn_one() {
    let s = "a:b:c";
    let parts = s.rsplitn(1, ":");
    assert_eq(parts.len(), 1);
    assert_eq(parts[0], "a:b:c");
}

@test
fn test_rsplitn_exact() {
    let s = "a:b:c";
    let parts = s.rsplitn(3, ":");
    assert_eq(parts.len(), 3);
    assert_eq(parts[0], "a");
    assert_eq(parts[1], "b");
    assert_eq(parts[2], "c");
}

@test
fn test_rsplitn_more_than_parts() {
    let s = "a:b";
    let parts = s.rsplitn(5, ":");
    assert_eq(parts.len(), 2);
    assert_eq(parts[0], "a");
    assert_eq(parts[1], "b");
}

fn main() {
    // Tests run via @test annotations
}
