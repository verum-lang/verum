fn test_format_display_empty_text() {
    let empty: Text = "";
    let result = format_display(&empty);
    assert_eq(result, "");
}

@test
fn test_formatter_write_str_multiple() {
    let mut buffer: Text = "";
    let mut fmt = Formatter.new(&mut buffer);
    fmt.write_str(&"abc");
    fmt.write_str(&"def");
    fmt.write_str(&"ghi");
    assert_eq(buffer, "abcdefghi");
}

@test
fn test_formatter_write_int_zero() {
    let mut buffer: Text = "";
    let mut fmt = Formatter.new(&mut buffer);
    fmt.write_int(0);
    assert_eq(buffer, "0");
}

@test
fn test_debug_struct_single_field() {
    let mut buffer: Text = "";
    let mut fmt = Formatter.new(&mut buffer);
    let mut ds = fmt.debug_struct(&"Wrapper");
    ds.field(&"value", &42);
    ds.finish();
    assert(buffer.contains(&"Wrapper"));
    assert(buffer.contains(&"value"));
    assert(buffer.contains(&"42"));
}

@test
fn test_format_string_zero() {
    let x = 0;
    let result = f"value: {x}";
    assert_eq(result, "value: 0");
}

@test
fn test_format_debug_empty_text() {
    let empty: Text = "";
    let result = format_debug(&empty);
    assert_eq(result, "\"\"");
}

