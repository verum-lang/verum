// =============================================================================
// Section 12: StreamError Convenience Constructors
// =============================================================================

@test
fn test_stream_error_from_errno() {
    // from_errno is an alias for from_raw_os_error
    let err = StreamError.from_errno(2);
    assert(err.kind() is NotFound);
}

@test
fn test_stream_error_from_errno_permission() {
    let err = StreamError.from_errno(13);
    assert(err.kind() is PermissionDenied);
}

@test
fn test_stream_error_other_constructor() {
    let err = StreamError.Other("custom error message");
    assert(err.kind() is Other);
    match err.message() {
        Some(msg) => assert_eq(*msg, "custom error message"),
        None => panic("Expected message"),
    }
}

@test
fn test_stream_error_other_empty_message() {
    let err = StreamError.Other("");
    assert(err.kind() is Other);
    match err.message() {
        Some(msg) => assert_eq(*msg, ""),
        None => panic("Expected message"),
    }
}

// =============================================================================
// Section 13: StreamError from_raw_os_error Extended
// =============================================================================

@test
fn test_stream_error_from_raw_os_error_would_block() {
    // EAGAIN = 11
    let err = StreamError.from_raw_os_error(11);
    assert(err.kind() is WouldBlock);
}

@test
fn test_stream_error_from_raw_os_error_broken_pipe() {
    // EPIPE = 32
    let err = StreamError.from_raw_os_error(32);
    assert(err.kind() is BrokenPipe);
}

@test
fn test_stream_error_from_raw_os_error_timed_out() {
    // ETIMEDOUT = 110
    let err = StreamError.from_raw_os_error(110);
    assert(err.kind() is TimedOut);
}

@test
fn test_stream_error_from_raw_os_error_connection_refused() {
    // ECONNREFUSED = 111
    let err = StreamError.from_raw_os_error(111);
    assert(err.kind() is ConnectionRefused);
}

@test
fn test_stream_error_from_raw_os_error_connection_reset() {
    // ECONNRESET = 104
    let err = StreamError.from_raw_os_error(104);
    assert(err.kind() is ConnectionReset);
}

// =============================================================================
// Section 14: IoErrorKind Distinctness
// =============================================================================

@test
fn test_error_kind_all_distinct() {
    // Verify each kind is distinct from others
    let nf: IoErrorKind = NotFound;
    assert(nf is NotFound);
    assert(!(nf is PermissionDenied));
    assert(!(nf is ConnectionRefused));
    assert(!(nf is BrokenPipe));
    assert(!(nf is Other));
}

@test
fn test_error_kind_network_errors_distinct() {
    let cr: IoErrorKind = ConnectionRefused;
    let creset: IoErrorKind = ConnectionReset;
    let ca: IoErrorKind = ConnectionAborted;
    let nc: IoErrorKind = NotConnected;

    assert(cr is ConnectionRefused);
    assert(!(cr is ConnectionReset));
    assert(creset is ConnectionReset);
    assert(!(creset is ConnectionAborted));
    assert(ca is ConnectionAborted);
    assert(!(ca is NotConnected));
    assert(nc is NotConnected);
    assert(!(nc is ConnectionRefused));
}

// =============================================================================
// Section 15: SeekFrom Edge Cases
// =============================================================================

@test
fn test_seek_from_start_large_offset() {
    let pos = Start(1073741824); // 1GB
    match pos {
        Start(n) => assert_eq(n, 1073741824),
        _ => panic("Expected Start"),
    }
}

@test
fn test_seek_from_end_large_negative() {
    let pos = End(-1048576); // -1MB
    match pos {
        End(n) => assert_eq(n, -1048576),
        _ => panic("Expected End"),
    }
}

@test
fn test_seek_from_current_large_positive() {
    let pos = Current(4096);
    match pos {
        Current(n) => assert_eq(n, 4096),
        _ => panic("Expected Current"),
    }
}

// =============================================================================
// Section 16: IoResult with Different Types
// =============================================================================

@test
fn test_io_result_ok_text() {
    let result: IoResult<Text> = Ok("hello");
    match result {
        Ok(s) => assert_eq(s, "hello"),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_io_result_ok_bool() {
    let result: IoResult<Bool> = Ok(true);
    match result {
        Ok(b) => assert(b),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_io_result_err_with_message() {
    let result: IoResult<Int> = Err(StreamError.with_message(TimedOut, "connection timed out after 30s"));
    match result {
        Ok(_) => panic("Expected Err"),
        Err(e) => {
            assert(e.kind() is TimedOut);
            match e.message() {
                Some(msg) => assert(msg.contains("30s")),
                None => panic("Expected message"),
            }
        }
    }
}

fn main() {
    // Tests run via @test annotations
}
