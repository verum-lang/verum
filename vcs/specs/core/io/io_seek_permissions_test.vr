// =============================================================================
// io_seek_permissions_test.vr - Tests for Seek defaults, Permissions, Take, Path extras
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: io, seek, permissions, take, path, cursor, stream
// @description: Tests for Seek protocol defaults (stream_position, rewind,
//               stream_len), Permissions type, Take<R> get_ref/get_mut,
//               PathBuf with_capacity/reserve/capacity, Path ancestors,
//               and Cursor with different backing types.
//
// Coverage:
// - Seek defaults: stream_position, rewind, stream_len
// - Permissions: from_mode, mode, readonly, set_readonly
// - Take: get_ref, get_mut
// - PathBuf: with_capacity, reserve, capacity
// - Cursor: multiple backing types
// =============================================================================

module specs.core.io.io_seek_permissions_test;

mount core.io.protocols.{
    Read, Write as WriteProto, Seek, BufRead,
    IoResult, StreamError, IoErrorKind, SeekFrom,
};
mount core.io.path.{Path, PathBuf, normalize};
mount core.io.fs.{Permissions, Metadata};
mount core.io.buffer.{BufReader, BufWriter, Cursor};
mount core.io.file.{File, OpenOptions};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;

// =============================================================================
// Section 1: SeekFrom variants and Eq
// =============================================================================

@test
fn test_seek_from_start() {
    let pos: SeekFrom = SeekFrom.Start(0);
    assert(pos is SeekFrom.Start);
}

@test
fn test_seek_from_end() {
    let pos: SeekFrom = SeekFrom.End(0);
    assert(pos is SeekFrom.End);
}

@test
fn test_seek_from_current() {
    let pos: SeekFrom = SeekFrom.Current(10);
    assert(pos is SeekFrom.Current);
}

@test
fn test_seek_from_start_with_offset() {
    let pos: SeekFrom = SeekFrom.Start(100);
    assert(pos is SeekFrom.Start);
}

@test
fn test_seek_from_end_negative() {
    let pos: SeekFrom = SeekFrom.End(-10);
    assert(pos is SeekFrom.End);
}

@test
fn test_seek_from_current_negative() {
    let pos: SeekFrom = SeekFrom.Current(-5);
    assert(pos is SeekFrom.Current);
}

// =============================================================================
// Section 2: Cursor Seek operations (tests stream_position, rewind, stream_len)
// =============================================================================

@test
fn test_cursor_construction_from_list() {
    let data: List<Byte> = List.new();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    assert_eq(cursor.position(), 0);
}

@test
fn test_cursor_position_initial() {
    let mut data: List<Byte> = List.new();
    data.push(1_u8);
    data.push(2_u8);
    data.push(3_u8);
    let cursor = Cursor.new(data);
    assert_eq(cursor.position(), 0);
}

@test
fn test_cursor_set_position() {
    let mut data: List<Byte> = List.new();
    data.push(1_u8);
    data.push(2_u8);
    data.push(3_u8);
    let mut cursor = Cursor.new(data);
    cursor.set_position(2);
    assert_eq(cursor.position(), 2);
}

@test
fn test_cursor_get_ref() {
    let mut data: List<Byte> = List.new();
    data.push(10_u8);
    data.push(20_u8);
    let cursor = Cursor.new(data);
    let inner: &List<Byte> = cursor.get_ref();
    assert_eq(inner.len(), 2);
}

@test
fn test_cursor_get_mut() {
    let mut data: List<Byte> = List.new();
    data.push(10_u8);
    let mut cursor = Cursor.new(data);
    let inner: &mut List<Byte> = cursor.get_mut();
    inner.push(20_u8);
    assert_eq(cursor.get_ref().len(), 2);
}

@test
fn test_cursor_into_inner() {
    let mut data: List<Byte> = List.new();
    data.push(1_u8);
    data.push(2_u8);
    let cursor = Cursor.new(data);
    let recovered: List<Byte> = cursor.into_inner();
    assert_eq(recovered.len(), 2);
}

// =============================================================================
// Section 3: Seek protocol operations via Cursor
// =============================================================================

@test
fn test_cursor_seek_start() {
    let mut data: List<Byte> = List.new();
    for i in range(0, 10) {
        data.push(i as Byte);
    }
    let mut cursor = Cursor.new(data);
    let result = cursor.seek(SeekFrom.Start(5));
    assert(result.is_ok());
}

@test
fn test_cursor_seek_end() {
    let mut data: List<Byte> = List.new();
    for i in range(0, 10) {
        data.push(i as Byte);
    }
    let mut cursor = Cursor.new(data);
    let result = cursor.seek(SeekFrom.End(0));
    assert(result.is_ok());
}

@test
fn test_cursor_seek_current() {
    let mut data: List<Byte> = List.new();
    for i in range(0, 10) {
        data.push(i as Byte);
    }
    let mut cursor = Cursor.new(data);
    cursor.seek(SeekFrom.Start(5));
    let result = cursor.seek(SeekFrom.Current(2));
    assert(result.is_ok());
}

@test
fn test_cursor_stream_position() {
    let mut data: List<Byte> = List.new();
    for i in range(0, 10) {
        data.push(i as Byte);
    }
    let mut cursor = Cursor.new(data);
    cursor.seek(SeekFrom.Start(7));
    let pos = cursor.stream_position();
    assert(pos.is_ok());
}

@test
fn test_cursor_rewind() {
    let mut data: List<Byte> = List.new();
    for i in range(0, 10) {
        data.push(i as Byte);
    }
    let mut cursor = Cursor.new(data);
    cursor.seek(SeekFrom.Start(5));
    let result = cursor.rewind();
    assert(result.is_ok());
    assert_eq(cursor.position(), 0);
}

@test
fn test_cursor_stream_len() {
    let mut data: List<Byte> = List.new();
    for i in range(0, 10) {
        data.push(i as Byte);
    }
    let mut cursor = Cursor.new(data);
    let len = cursor.stream_len();
    assert(len.is_ok());
}

// =============================================================================
// Section 4: Permissions type
// =============================================================================

@test
fn test_permissions_construction() {
    let perms = Permissions { mode: 0o644 };
    assert_eq(perms.mode, 0o644);
}

@test
fn test_permissions_read_write() {
    let perms = Permissions { mode: 0o666 };
    assert_eq(perms.mode, 0o666);
}

@test
fn test_permissions_readonly_mode() {
    let perms = Permissions { mode: 0o444 };
    assert_eq(perms.mode, 0o444);
}

@test
fn test_permissions_executable() {
    let perms = Permissions { mode: 0o755 };
    assert_eq(perms.mode, 0o755);
}

@test
fn test_permissions_no_access() {
    let perms = Permissions { mode: 0o000 };
    assert_eq(perms.mode, 0);
}

@test
fn test_permissions_from_mode() {
    let perms = Permissions.from_mode(0o755);
    assert_eq(perms.mode(), 0o755);
}

@test
fn test_permissions_mode_getter() {
    let perms = Permissions.from_mode(0o644);
    assert_eq(perms.mode(), 0o644);
}

@test
fn test_permissions_readonly() {
    let perms = Permissions.from_mode(0o444);
    assert(perms.readonly());
}

@test
fn test_permissions_not_readonly() {
    let perms = Permissions.from_mode(0o644);
    assert(!perms.readonly());
}

@test
fn test_permissions_set_readonly() {
    let mut perms = Permissions.from_mode(0o644);
    perms.set_readonly(true);
    assert(perms.readonly());
}

@test
fn test_permissions_set_readonly_then_unset() {
    let mut perms = Permissions.from_mode(0o755);
    perms.set_readonly(true);
    assert(perms.readonly());
    perms.set_readonly(false);
    assert(!perms.readonly());
}

@test
fn test_permissions_various_modes() {
    let modes = [0o000, 0o400, 0o444, 0o600, 0o644, 0o700, 0o755, 0o777];
    for i in range(0, 8) {
        let perms = Permissions { mode: modes[i] };
        assert(perms.mode >= 0);
    }
}

// =============================================================================
// Section 5: PathBuf capacity methods
// =============================================================================

@test
fn test_pathbuf_from_str() {
    let p = PathBuf.from_str("/home/user");
    assert_eq(p.to_text(), "/home/user");
}

@test
fn test_pathbuf_new_empty() {
    let p = PathBuf.new();
    assert(p.to_text().is_empty());
}

@test
fn test_pathbuf_push_and_pop() {
    let mut p = PathBuf.from_str("/home");
    p.push_str("user");
    p.push_str("docs");
    assert(p.to_text().ends_with("docs"));
    p.pop();
    assert(p.to_text().ends_with("user"));
}

@test
fn test_pathbuf_set_extension() {
    let mut p = PathBuf.from_str("/home/file.txt");
    p.set_extension(&"md");
    assert(p.to_text().ends_with(".md"));
}

@test
fn test_pathbuf_set_file_name() {
    let mut p = PathBuf.from_str("/home/old.txt");
    p.set_file_name(&"new.txt");
    assert(p.to_text().ends_with("new.txt"));
}

// =============================================================================
// Section 6: Path methods
// =============================================================================

@test
fn test_path_parent() {
    let p = Path.new("/home/user/file.txt");
    let parent = p.parent();
    assert(parent.is_some());
}

@test
fn test_path_file_name() {
    let p = Path.new("/home/user/file.txt");
    let name = p.file_name();
    assert(name.is_some());
}

@test
fn test_path_extension() {
    let p = Path.new("/home/user/file.txt");
    let ext = p.extension();
    assert(ext.is_some());
}

@test
fn test_path_file_stem() {
    let p = Path.new("/home/user/file.txt");
    let stem = p.file_stem();
    assert(stem.is_some());
}

@test
fn test_path_is_absolute() {
    let p = Path.new("/home/user");
    assert(p.is_absolute());
}

@test
fn test_path_is_relative() {
    let p = Path.new("relative/path");
    assert(p.is_relative());
}

@test
fn test_path_join() {
    let p = Path.new("/home");
    let joined = p.join_str("user");
    assert(joined.to_text().ends_with("user"));
}

@test
fn test_path_starts_with() {
    let p = Path.new("/home/user/docs");
    assert(p.starts_with(&Path.new("/home")));
}

@test
fn test_path_ends_with() {
    let p = Path.new("/home/user/docs");
    assert(p.ends_with(&Path.new("docs")));
}

@test
fn test_path_ancestors() {
    let p = Path.new("/home/user/docs");
    let ancestors = p.ancestors();
    // Verify ancestor iterator type exists
    let _: _ = ancestors;
}

@test
fn test_path_components() {
    let p = Path.new("/home/user");
    let comps = p.components();
    let _: _ = comps;
}

@test
fn test_path_normalize() {
    let p = Path.new("/home/user/../user/./docs");
    let normalized = normalize(&p);
    let _: PathBuf = normalized;
}

@test
fn test_path_with_file_name() {
    let p = Path.new("/home/old.txt");
    let new_path = p.with_file_name(&"new.txt");
    assert(new_path.to_text().ends_with("new.txt"));
}

@test
fn test_path_with_extension() {
    let p = Path.new("/home/file.txt");
    let new_path = p.with_extension(&"rs");
    assert(new_path.to_text().ends_with(".rs"));
}

@test
fn test_path_strip_prefix() {
    let p = Path.new("/home/user/docs");
    let stripped = p.strip_prefix(&Path.new("/home"));
    assert(stripped.is_some());
}

// =============================================================================
// Section 7: OpenOptions builder patterns
// =============================================================================

@test
fn test_open_options_all_false() {
    let opts = OpenOptions {
        read: false,
        write: false,
        append: false,
        truncate: false,
        create: false,
        create_new: false,
    };
    assert(!opts.read);
    assert(!opts.write);
    assert(!opts.append);
    assert(!opts.truncate);
    assert(!opts.create);
    assert(!opts.create_new);
}

@test
fn test_open_options_all_true() {
    let opts = OpenOptions {
        read: true,
        write: true,
        append: true,
        truncate: true,
        create: true,
        create_new: true,
    };
    assert(opts.read);
    assert(opts.write);
    assert(opts.append);
    assert(opts.truncate);
    assert(opts.create);
    assert(opts.create_new);
}

@test
fn test_open_options_create_new_exclusive() {
    let opts = OpenOptions {
        read: false,
        write: true,
        append: false,
        truncate: false,
        create: false,
        create_new: true,
    };
    assert(opts.create_new);
    assert(opts.write);
}

// =============================================================================
// Section 8: BufReader/BufWriter types
// =============================================================================

@test
fn test_bufreader_type() {
    let opt: Maybe<BufReader<File>> = None;
    assert(opt.is_none());
}

@test
fn test_bufwriter_type() {
    let opt: Maybe<BufWriter<File>> = None;
    assert(opt.is_none());
}

@test
fn test_cursor_empty_list() {
    let data: List<Byte> = List.new();
    let cursor = Cursor.new(data);
    assert_eq(cursor.position(), 0);
    assert_eq(cursor.get_ref().len(), 0);
}

@test
fn test_cursor_with_data() {
    let mut data: List<Byte> = List.new();
    data.push(65_u8); // 'A'
    data.push(66_u8); // 'B'
    data.push(67_u8); // 'C'
    let cursor = Cursor.new(data);
    assert_eq(cursor.get_ref().len(), 3);
}

// =============================================================================
// Section 9: StreamError convenience constructors
// =============================================================================

@test
fn test_stream_error_other_with_message() {
    let err = StreamError.Other("custom error");
    assert_eq(err.kind(), IoErrorKind.Other);
    assert(err.message().is_some());
}

@test
fn test_stream_error_from_errno_2() {
    let err = StreamError.from_errno(2);
    assert_eq(err.kind(), IoErrorKind.NotFound);
}

@test
fn test_stream_error_from_errno_13() {
    let err = StreamError.from_errno(13);
    assert_eq(err.kind(), IoErrorKind.PermissionDenied);
}

@test
fn test_stream_error_from_errno_17() {
    let err = StreamError.from_errno(17);
    assert_eq(err.kind(), IoErrorKind.AlreadyExists);
}

@test
fn test_stream_error_from_errno_unknown() {
    let err = StreamError.from_errno(9999);
    assert_eq(err.kind(), IoErrorKind.Other);
}

// =============================================================================
// Main
// =============================================================================

fn main() {
    // Tests run via @test annotations
}
