// =============================================================================
// io_protocols_extended_test.vr - Tests for I/O protocol improvements
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: io, protocols, error, seek, chain, take, core
// @description: Tests for IoErrorKind Eq, SeekFrom Eq/Clone/Debug, StreamError
//               Display/Eq, Chain/Take adapters
// =============================================================================

mount core.io.protocols.{
    StreamError, IoErrorKind, IoResult, SeekFrom,
    Read, Write, Seek, BufRead,
    Chain, Take,
    empty_reader, repeat_byte, sink,
    Cursor,
};
mount core.base.result.{Result, Ok, Err};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.protocols.{Eq, Clone, Debug, Display, Formatter, FormatError};

// =============================================================================
// Section 1: IoErrorKind Eq
// =============================================================================

@test
fn test_io_error_kind_eq_same() {
    let a = IoErrorKind.NotFound;
    let b = IoErrorKind.NotFound;
    assert_eq(a, b);
}

@test
fn test_io_error_kind_eq_different() {
    let a = IoErrorKind.NotFound;
    let b = IoErrorKind.PermissionDenied;
    assert(a != b);
}

@test
fn test_io_error_kind_eq_all_variants() {
    assert_eq(IoErrorKind.NotFound, IoErrorKind.NotFound);
    assert_eq(IoErrorKind.PermissionDenied, IoErrorKind.PermissionDenied);
    assert_eq(IoErrorKind.ConnectionRefused, IoErrorKind.ConnectionRefused);
    assert_eq(IoErrorKind.ConnectionReset, IoErrorKind.ConnectionReset);
    assert_eq(IoErrorKind.BrokenPipe, IoErrorKind.BrokenPipe);
    assert_eq(IoErrorKind.AlreadyExists, IoErrorKind.AlreadyExists);
    assert_eq(IoErrorKind.WouldBlock, IoErrorKind.WouldBlock);
    assert_eq(IoErrorKind.InvalidInput, IoErrorKind.InvalidInput);
    assert_eq(IoErrorKind.InvalidData, IoErrorKind.InvalidData);
    assert_eq(IoErrorKind.TimedOut, IoErrorKind.TimedOut);
    assert_eq(IoErrorKind.WriteZero, IoErrorKind.WriteZero);
    assert_eq(IoErrorKind.Interrupted, IoErrorKind.Interrupted);
    assert_eq(IoErrorKind.UnexpectedEof, IoErrorKind.UnexpectedEof);
    assert_eq(IoErrorKind.OutOfMemory, IoErrorKind.OutOfMemory);
    assert_eq(IoErrorKind.Other, IoErrorKind.Other);
}

@test
fn test_io_error_kind_neq_cross() {
    assert(IoErrorKind.NotFound != IoErrorKind.Other);
    assert(IoErrorKind.TimedOut != IoErrorKind.WouldBlock);
    assert(IoErrorKind.Interrupted != IoErrorKind.UnexpectedEof);
}

// =============================================================================
// Section 2: StreamError Eq
// =============================================================================

@test
fn test_stream_error_eq_same_kind() {
    let a = StreamError.new(IoErrorKind.NotFound);
    let b = StreamError.new(IoErrorKind.NotFound);
    assert_eq(a, b);
}

@test
fn test_stream_error_eq_different_kind() {
    let a = StreamError.new(IoErrorKind.NotFound);
    let b = StreamError.new(IoErrorKind.PermissionDenied);
    assert(a != b);
}

@test
fn test_stream_error_eq_with_message() {
    let a = StreamError.with_message(IoErrorKind.Other, "test");
    let b = StreamError.with_message(IoErrorKind.Other, "test");
    assert_eq(a, b);
}

@test
fn test_stream_error_neq_different_message() {
    let a = StreamError.with_message(IoErrorKind.Other, "foo");
    let b = StreamError.with_message(IoErrorKind.Other, "bar");
    assert(a != b);
}

@test
fn test_stream_error_neq_message_vs_none() {
    let a = StreamError.with_message(IoErrorKind.Other, "foo");
    let b = StreamError.new(IoErrorKind.Other);
    assert(a != b);
}

// =============================================================================
// Section 3: SeekFrom Eq, Clone, Debug
// =============================================================================

@test
fn test_seekfrom_eq_start() {
    assert_eq(SeekFrom.Start(0), SeekFrom.Start(0));
    assert_eq(SeekFrom.Start(100), SeekFrom.Start(100));
    assert(SeekFrom.Start(0) != SeekFrom.Start(1));
}

@test
fn test_seekfrom_eq_end() {
    assert_eq(SeekFrom.End(0), SeekFrom.End(0));
    assert(SeekFrom.End(0) != SeekFrom.End(-1));
}

@test
fn test_seekfrom_eq_current() {
    assert_eq(SeekFrom.Current(0), SeekFrom.Current(0));
    assert(SeekFrom.Current(5) != SeekFrom.Current(-5));
}

@test
fn test_seekfrom_neq_different_variants() {
    assert(SeekFrom.Start(0) != SeekFrom.End(0));
    assert(SeekFrom.Start(0) != SeekFrom.Current(0));
    assert(SeekFrom.End(0) != SeekFrom.Current(0));
}

@test
fn test_seekfrom_clone() {
    let original = SeekFrom.Start(42);
    let cloned = original.clone();
    assert_eq(original, cloned);
}

// =============================================================================
// Section 4: StreamError from_raw_os_error
// =============================================================================

@test
fn test_stream_error_from_raw_os_enoent() {
    let err = StreamError.from_raw_os_error(2);
    assert_eq(err.kind(), IoErrorKind.NotFound);
}

@test
fn test_stream_error_from_raw_os_eacces() {
    let err = StreamError.from_raw_os_error(13);
    assert_eq(err.kind(), IoErrorKind.PermissionDenied);
}

@test
fn test_stream_error_from_raw_os_eexist() {
    let err = StreamError.from_raw_os_error(17);
    assert_eq(err.kind(), IoErrorKind.AlreadyExists);
}

@test
fn test_stream_error_from_raw_os_unknown() {
    let err = StreamError.from_raw_os_error(999);
    assert_eq(err.kind(), IoErrorKind.Other);
}

// =============================================================================
// Section 5: StreamError convenience constructors
// =============================================================================

@test
fn test_stream_error_other() {
    let err = StreamError.Other("something went wrong");
    assert_eq(err.kind(), IoErrorKind.Other);
    assert(err.message().is_some());
}

@test
fn test_stream_error_clone() {
    let err = StreamError.with_message(IoErrorKind.NotFound, "file.txt");
    let cloned = err.clone();
    assert_eq(err, cloned);
}

