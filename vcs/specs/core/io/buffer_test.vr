@test
fn test_bufreader_get_mut() {
    let data: List<Byte> = make_byte_list_5();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let mut reader: BufReader<Cursor<List<Byte>>> = BufReader.new(cursor);
    let inner: &mut Cursor<List<Byte>> = reader.get_mut();
    inner.set_position(2);
    assert_eq(inner.position(), 2);
}

@test
fn test_bufreader_capacity_default() {
    let data: List<Byte> = List.new();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let reader: BufReader<Cursor<List<Byte>>> = BufReader.new(cursor);
    assert_eq(reader.capacity(), DEFAULT_BUF_CAPACITY);
}

@test
fn test_bufreader_capacity_custom() {
    let data: List<Byte> = List.new();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let reader: BufReader<Cursor<List<Byte>>> = BufReader.with_capacity(1024, cursor);
    assert_eq(reader.capacity(), 1024);
}

// =============================================================================
// Section 14: BufWriter Extended Tests
// =============================================================================

@test
fn test_bufwriter_get_mut() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: BufWriter<Cursor<List<Byte>>> = BufWriter.new(cursor);
    let inner: &mut Cursor<List<Byte>> = writer.get_mut();
    inner.set_position(10);
    assert_eq(inner.position(), 10);
}

@test
fn test_bufwriter_write_increases_buffer_len() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: BufWriter<Cursor<List<Byte>>> = BufWriter.new(cursor);
    assert_eq(writer.buffer_len(), 0);
    let buf: [Byte; 3] = [1 as Byte, 2 as Byte, 3 as Byte];
    let _ = writer.write(&buf);
    assert_eq(writer.buffer_len(), 3);
}

@test
fn test_bufwriter_flush_clears_buffer() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: BufWriter<Cursor<List<Byte>>> = BufWriter.new(cursor);
    let buf: [Byte; 3] = [1 as Byte, 2 as Byte, 3 as Byte];
    let _ = writer.write(&buf);
    assert_eq(writer.buffer_len(), 3);
    let _ = writer.flush();
    assert_eq(writer.buffer_len(), 0);
}

@test
fn test_bufwriter_into_inner_success() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: BufWriter<Cursor<List<Byte>>> = BufWriter.new(cursor);
    let buf: [Byte; 3] = [1 as Byte, 2 as Byte, 3 as Byte];
    let _ = writer.write(&buf);
    let result = writer.into_inner();
    assert(result is Ok);
}

@test
fn test_bufwriter_capacity_custom() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let writer: BufWriter<Cursor<List<Byte>>> = BufWriter.with_capacity(4096, cursor);
    assert_eq(writer.capacity(), 4096);
}

// =============================================================================
// Section 15: Cursor Extended Tests
// =============================================================================

@test
fn test_cursor_get_mut() {
    let data: List<Byte> = make_byte_list_3();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let inner: &mut List<Byte> = cursor.get_mut();
    inner.push(4 as Byte);
    assert_eq(cursor.get_ref().len(), 4);
}

@test
fn test_cursor_write_then_read() {
    let mut cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    // Write some data
    let write_buf: [Byte; 4] = [10 as Byte, 20 as Byte, 30 as Byte, 40 as Byte];
    let _ = cursor.write(&write_buf);
    assert_eq(cursor.position(), 4);
    // Seek to start
    let _ = cursor.seek(SeekFrom.Start(0));
    assert_eq(cursor.position(), 0);
    // Read it back
    let mut read_buf: [Byte; 2] = [0 as Byte, 0 as Byte];
    let result = cursor.read(&mut read_buf);
    match result {
        Ok(n) => assert_eq(n, 2),
        Err(_) => panic("Read should succeed"),
    }
    assert_eq(cursor.position(), 2);
}

@test
fn test_cursor_seek_current_backward() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    cursor.set_position(4);
    let pos = cursor.seek(SeekFrom.Current(-2));
    match pos {
        Ok(p) => assert_eq(p, 2),
        Err(_) => panic("Seek should succeed"),
    }
}

@test
fn test_cursor_seek_negative_error() {
    let data: List<Byte> = make_byte_list_3();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let result = cursor.seek(SeekFrom.Current(-5)); // Would go below 0
    assert(result is Err);
}

@test
fn test_cursor_consume_zero() {
    let data: List<Byte> = make_byte_list_3();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    cursor.consume(0);
    assert_eq(cursor.position(), 0);
}

// =============================================================================
// Section 16: Utility Function Type Tests
// =============================================================================

@test
fn test_copy_function_type() {
    let src_data: List<Byte> = make_byte_list_5();
    let mut reader: Cursor<List<Byte>> = Cursor.new(src_data);
    let mut writer: Cursor<List<Byte>> = Cursor.new(List.new());
    let _result: IoResult<Int> = buf_copy(&mut reader, &mut writer);
}

@test
fn test_read_all_function_type() {
    let data: List<Byte> = make_byte_list_3();
    let mut reader: Cursor<List<Byte>> = Cursor.new(data);
    let _result: IoResult<List<Byte>> = read_all(&mut reader);
}

