// =============================================================================
// Section 10: SeekFrom Variants
// =============================================================================

@test
fn test_seekfrom_start() {
    let pos: SeekFrom = SeekFrom.Start(100);
    assert(pos is SeekFrom.Start);
}

@test
fn test_seekfrom_end() {
    let pos: SeekFrom = SeekFrom.End(-50);
    assert(pos is SeekFrom.End);
}

@test
fn test_seekfrom_current() {
    let pos: SeekFrom = SeekFrom.Current(25);
    assert(pos is SeekFrom.Current);
}

@test
fn test_seekfrom_match_start() {
    let pos: SeekFrom = SeekFrom.Start(42);
    match pos {
        SeekFrom.Start(n) => assert_eq(n, 42),
        _ => panic("Expected Start"),
    }
}

@test
fn test_seekfrom_match_end() {
    let pos: SeekFrom = SeekFrom.End(-10);
    match pos {
        SeekFrom.End(n) => assert_eq(n, -10),
        _ => panic("Expected End"),
    }
}

@test
fn test_seekfrom_match_current() {
    let pos: SeekFrom = SeekFrom.Current(5);
    match pos {
        SeekFrom.Current(n) => assert_eq(n, 5),
        _ => panic("Expected Current"),
    }
}

// =============================================================================
// Section 11: LineWriter Extended Tests
// =============================================================================

@test
fn test_linewriter_get_ref() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let writer: LineWriter<Cursor<List<Byte>>> = LineWriter.new(cursor);
    let inner: &Cursor<List<Byte>> = writer.get_ref();
    assert_eq(inner.position(), 0);
}

@test
fn test_linewriter_get_mut() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: LineWriter<Cursor<List<Byte>>> = LineWriter.new(cursor);
    let inner: &mut Cursor<List<Byte>> = writer.get_mut();
    inner.set_position(5);
    assert_eq(inner.position(), 5);
}

@test
fn test_linewriter_write_no_newline() {
    // Writing without newline should buffer
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: LineWriter<Cursor<List<Byte>>> = LineWriter.new(cursor);
    let data: [Byte; 3] = [65 as Byte, 66 as Byte, 67 as Byte]; // "ABC"
    let result = writer.write(&data);
    assert(result is Ok);
}

@test
fn test_linewriter_write_with_newline() {
    // Writing with newline should flush
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: LineWriter<Cursor<List<Byte>>> = LineWriter.new(cursor);
    let data: [Byte; 4] = [65 as Byte, 66 as Byte, 10 as Byte, 67 as Byte]; // "AB\nC"
    let result = writer.write(&data);
    assert(result is Ok);
}

@test
fn test_linewriter_flush() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let mut writer: LineWriter<Cursor<List<Byte>>> = LineWriter.new(cursor);
    let result = writer.flush();
    assert(result is Ok);
}

@test
fn test_linewriter_with_capacity_custom() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let writer: LineWriter<Cursor<List<Byte>>> = LineWriter.with_capacity(2048, cursor);
    // Verify it constructed successfully
    let inner: &Cursor<List<Byte>> = writer.get_ref();
    assert_eq(inner.position(), 0);
}

// =============================================================================
// Section 12: IntoInnerError Type Existence
// =============================================================================

@test
fn test_into_inner_error_type_exists() {
    // IntoInnerError wraps a write error during into_inner
    let val: Maybe<IntoInnerError<Cursor<List<Byte>>>> = None;
    assert(val is None);
}

