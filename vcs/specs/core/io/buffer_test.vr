fn test_linewriter_new() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let writer: LineWriter<Cursor<List<Byte>>> = LineWriter.new(cursor);
    let inner: &Cursor<List<Byte>> = writer.get_ref();
