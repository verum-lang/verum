@test
fn test_bufwriter_buffer_len_initial() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let writer: BufWriter<Cursor<List<Byte>>> = BufWriter.new(cursor);
    assert_eq(writer.buffer_len(), 0);
}

@test
fn test_bufwriter_get_ref() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let writer: BufWriter<Cursor<List<Byte>>> = BufWriter.new(cursor);
    let inner: &Cursor<List<Byte>> = writer.get_ref();
    assert_eq(inner.position(), 0);
