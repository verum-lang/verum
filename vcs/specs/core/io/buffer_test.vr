@test
fn test_bufwriter_with_capacity_below_minimum() {
    let cursor: Cursor<List<Byte>> = Cursor.new(List.new());
    let writer: BufWriter<Cursor<List<Byte>>> = BufWriter.with_capacity(32, cursor);
    // Should use minimum capacity
    assert_eq(writer.capacity(), MIN_BUF_CAPACITY);
