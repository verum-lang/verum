// =============================================================================
// buffer_test.vr - Tests for buffered I/O operations
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: io, buffer, bufreader, bufwriter, cursor, core
// @description: Tests for BufReader, BufWriter, LineWriter, Cursor, and buffer constants
// =============================================================================

mount core.io.buffer.{
    DEFAULT_BUF_CAPACITY,
    MIN_BUF_CAPACITY,
    BufReader,
    BufWriter,
    LineWriter,
    Cursor,
    IntoInnerError,
    copy as buf_copy,
    read_all,
};
mount core.io.protocols.{Read, Write, Seek, BufRead, SeekFrom, IoResult};
mount core.{List, Byte};
mount core.result.{Result, Ok, Err};
mount core.base.maybe.{Maybe, None};

// Helper to create a byte list from values
fn make_byte_list_3() -> List<Byte> {
    let mut data: List<Byte> = List.new();
    data.push(1 as Byte);
    data.push(2 as Byte);
    data.push(3 as Byte);
    data
}

fn make_byte_list_5() -> List<Byte> {
    let mut data: List<Byte> = List.new();
    data.push(1 as Byte);
    data.push(2 as Byte);
    data.push(3 as Byte);
    data.push(4 as Byte);
    data.push(5 as Byte);
    data
}

// =============================================================================
// Section 1: Buffer Constants
// =============================================================================

@test
fn test_default_buf_capacity() {
    // Default buffer should be 8KB
    assert_eq(DEFAULT_BUF_CAPACITY, 8192);
}

@test
fn test_min_buf_capacity() {
    // Minimum buffer should be 64 bytes
    assert_eq(MIN_BUF_CAPACITY, 64);
}

@test
fn test_buffer_capacity_relationship() {
    // Default should be greater than minimum
    assert(DEFAULT_BUF_CAPACITY > MIN_BUF_CAPACITY);
}

// =============================================================================
// Section 2: Cursor - Basic Operations
// =============================================================================

@test
fn test_cursor_new() {
    let data: List<Byte> = List.new();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    assert_eq(cursor.position(), 0);
}

@test
fn test_cursor_new_with_data() {
    let data: List<Byte> = make_byte_list_5();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    assert_eq(cursor.position(), 0);
}

@test
fn test_cursor_position() {
    let data: List<Byte> = make_byte_list_3();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    assert_eq(cursor.position(), 0);
}

@test
fn test_cursor_set_position() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    cursor.set_position(3);
    assert_eq(cursor.position(), 3);
}

@test
fn test_cursor_get_ref() {
    let data: List<Byte> = make_byte_list_3();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let inner: &List<Byte> = cursor.get_ref();
    assert_eq(inner.len(), 3);
}

@test
fn test_cursor_into_inner() {
    let data: List<Byte> = make_byte_list_3();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let recovered: List<Byte> = cursor.into_inner();
    assert_eq(recovered.len(), 3);
}

// =============================================================================
// Section 3: Cursor - Seek Operations
// =============================================================================

@test
fn test_cursor_seek_start() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let pos = cursor.seek(SeekFrom.Start(2));
    match pos {
        Ok(p) => assert_eq(p, 2),
        Err(_) => panic("Seek should succeed"),
    }
    assert_eq(cursor.position(), 2);
}

@test
fn test_cursor_seek_current_forward() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    cursor.set_position(2);
    let pos = cursor.seek(SeekFrom.Current(1));
    match pos {
        Ok(p) => assert_eq(p, 3),
        Err(_) => panic("Seek should succeed"),
    }
}

@test
fn test_cursor_seek_end() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let pos = cursor.seek(SeekFrom.End(-1));
    match pos {
        Ok(p) => assert_eq(p, 4),
        Err(_) => panic("Seek should succeed"),
    }
}

@test
fn test_cursor_seek_to_end() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let pos = cursor.seek(SeekFrom.End(0));
    match pos {
        Ok(p) => assert_eq(p, 5),
        Err(_) => panic("Seek should succeed"),
    }
}

// =============================================================================
// Section 4: Cursor - Read Operations
// =============================================================================

@test
fn test_cursor_read_advances_position() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let mut buf: [Byte; 2] = [0 as Byte, 0 as Byte];
    let _ = cursor.read(&mut buf);
    assert_eq(cursor.position(), 2);
}

@test
fn test_cursor_read_at_end() {
    let data: List<Byte> = make_byte_list_3();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    cursor.set_position(3);  // At end
    let mut buf: [Byte; 2] = [0 as Byte, 0 as Byte];
    let result = cursor.read(&mut buf);
    match result {
        Ok(n) => assert_eq(n, 0),  // EOF
        Err(_) => panic("Read should succeed (return 0)"),
    }
}

// =============================================================================
// Section 5: Cursor - Write Operations
// =============================================================================

@test
fn test_cursor_write_advances_position() {
    let data: List<Byte> = List.new();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let buf: [Byte; 4] = [1 as Byte, 2 as Byte, 3 as Byte, 4 as Byte];
    let _ = cursor.write(&buf);
    assert_eq(cursor.position(), 4);
}

@test
fn test_cursor_write_extends_buffer() {
    let data: List<Byte> = List.new();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let buf: [Byte; 5] = [1 as Byte, 2 as Byte, 3 as Byte, 4 as Byte, 5 as Byte];
    let _ = cursor.write(&buf);
    let inner = cursor.get_ref();
    assert_eq(inner.len(), 5);
}

@test
fn test_cursor_flush() {
    let data: List<Byte> = List.new();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    let result = cursor.flush();
    assert(result is Ok);
}

// =============================================================================
// Section 6: Cursor - BufRead Operations
// =============================================================================

@test
fn test_cursor_consume() {
    let data: List<Byte> = make_byte_list_5();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    cursor.consume(2);
    assert_eq(cursor.position(), 2);
}

@test
fn test_cursor_consume_clamped() {
    let data: List<Byte> = make_byte_list_3();
    let mut cursor: Cursor<List<Byte>> = Cursor.new(data);
    cursor.consume(10);  // More than available
    assert_eq(cursor.position(), 3);  // Clamped to end
}

// =============================================================================
// Section 7: BufReader - Basic Construction
// =============================================================================

@test
fn test_bufreader_new() {
    let data: List<Byte> = make_byte_list_5();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let reader: BufReader<Cursor<List<Byte>>> = BufReader.new(cursor);
    assert_eq(reader.capacity(), DEFAULT_BUF_CAPACITY);
}

@test
fn test_bufreader_with_capacity() {
    let data: List<Byte> = make_byte_list_3();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let reader: BufReader<Cursor<List<Byte>>> = BufReader.with_capacity(256, cursor);
    assert_eq(reader.capacity(), 256);
}

@test
fn test_bufreader_with_capacity_below_minimum() {
    let data: List<Byte> = make_byte_list_3();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let reader: BufReader<Cursor<List<Byte>>> = BufReader.with_capacity(10, cursor);
    // Should use minimum capacity
    assert_eq(reader.capacity(), MIN_BUF_CAPACITY);
}

@test
fn test_bufreader_get_ref() {
    let data: List<Byte> = make_byte_list_3();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let reader: BufReader<Cursor<List<Byte>>> = BufReader.new(cursor);
    let inner: &Cursor<List<Byte>> = reader.get_ref();
    assert_eq(inner.position(), 0);
}

@test
fn test_bufreader_into_inner() {
    let data: List<Byte> = make_byte_list_3();
    let cursor: Cursor<List<Byte>> = Cursor.new(data);
    let reader: BufReader<Cursor<List<Byte>>> = BufReader.new(cursor);
    let recovered: Cursor<List<Byte>> = reader.into_inner();
    assert_eq(recovered.position(), 0);
}

