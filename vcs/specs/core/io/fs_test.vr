@test
fn test_dir_entry_construction() {
    let entry = DirEntry {
        path: PathBuf.from("/tmp/test.txt"),
        file_name: "test.txt",
        file_type: FileType.File,
    };
    assert_eq(entry.file_name, "test.txt");
}

@test
fn test_dir_entry_file_type_file() {
    let entry = DirEntry {
        path: PathBuf.from("/home/user/doc.pdf"),
        file_name: "doc.pdf",
        file_type: FileType.File,
    };
    assert_eq(entry.file_type(), FileType.File);
}

@test
fn test_dir_entry_file_type_dir() {
    let entry = DirEntry {
        path: PathBuf.from("/home/user/projects"),
        file_name: "projects",
        file_type: FileType.Dir,
    };
    assert_eq(entry.file_type(), FileType.Dir);
}

@test
fn test_dir_entry_file_type_symlink() {
    let entry = DirEntry {
        path: PathBuf.from("/usr/bin/python"),
        file_name: "python",
        file_type: FileType.Symlink,
    };
    assert_eq(entry.file_type(), FileType.Symlink);
}

@test
fn test_dir_entry_file_name_method() {
    let entry = DirEntry {
        path: PathBuf.from("/var/log/syslog"),
        file_name: "syslog",
        file_type: FileType.File,
    };
    assert_eq(*entry.file_name(), "syslog");
}

