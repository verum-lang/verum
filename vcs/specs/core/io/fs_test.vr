// =============================================================================
// Section 14: Metadata Method Tests
// =============================================================================
// NOTE: Metadata wraps FsMetadataRaw. We construct FsMetadataRaw directly
// to test Metadata methods without needing filesystem access.

@test
fn test_metadata_len() {
    let raw = FsMetadataRaw {
        size: 1024,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o644, is_dir: 0, is_file: 1, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert_eq(meta.len(), 1024);
}

@test
fn test_metadata_is_file() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o644, is_dir: 0, is_file: 1, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert(meta.is_file());
    assert(!meta.is_dir());
    assert(!meta.is_symlink());
}

@test
fn test_metadata_is_dir() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o755, is_dir: 1, is_file: 0, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert(meta.is_dir());
    assert(!meta.is_file());
}

@test
fn test_metadata_is_symlink() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o777, is_dir: 0, is_file: 0, is_symlink: 1,
    };
    let meta = Metadata { raw: raw };
    assert(meta.is_symlink());
}

@test
fn test_metadata_file_type_file() {
    let raw = FsMetadataRaw {
        size: 100,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o644, is_dir: 0, is_file: 1, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert_eq(meta.file_type(), FileType.File);
}

@test
fn test_metadata_file_type_dir() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o755, is_dir: 1, is_file: 0, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert_eq(meta.file_type(), FileType.Dir);
}

@test
fn test_metadata_file_type_symlink() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o777, is_dir: 0, is_file: 0, is_symlink: 1,
    };
    let meta = Metadata { raw: raw };
    assert_eq(meta.file_type(), FileType.Symlink);
}

@test
fn test_metadata_file_type_unknown() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0, is_dir: 0, is_file: 0, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert_eq(meta.file_type(), FileType.Unknown);
}

@test
fn test_metadata_timestamps() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 1700000000, modified_nanos: 123456,
        accessed_secs: 1700000100, accessed_nanos: 0,
        created_secs: 1699999000, created_nanos: 0,
        mode: 0o644, is_dir: 0, is_file: 1, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert_eq(meta.modified_secs(), 1700000000);
    assert_eq(meta.accessed_secs(), 1700000100);
    assert_eq(meta.created_secs(), 1699999000);
}

@test
fn test_metadata_is_readonly_true() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o444, is_dir: 0, is_file: 1, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert(meta.is_readonly());
}

@test
fn test_metadata_is_readonly_false() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o644, is_dir: 0, is_file: 1, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert(!meta.is_readonly());
}

@test
fn test_metadata_len_zero_for_dir() {
    let raw = FsMetadataRaw {
        size: 0,
        modified_secs: 0, modified_nanos: 0,
        accessed_secs: 0, accessed_nanos: 0,
        created_secs: 0, created_nanos: 0,
        mode: 0o755, is_dir: 1, is_file: 0, is_symlink: 0,
    };
    let meta = Metadata { raw: raw };
    assert_eq(meta.len(), 0);
}

