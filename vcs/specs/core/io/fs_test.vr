    // metadata() returns IoResult<Metadata>
    let _result: IoResult<Metadata> = entry.metadata();
}

// =============================================================================
// Section 18: FileType Pattern Matching
// =============================================================================

@test
fn test_file_type_comprehensive_match() {
    // Test each variant individually (iter() returns &FileType, can't match on reference)
    let ft1 = FileType.File;
    match ft1 {
        FileType.File => { assert(ft1.is_file()); }
        _ => { assert(false); }
    }
    let ft2 = FileType.Dir;
    match ft2 {
        FileType.Dir => { assert(ft2.is_dir()); }
        _ => { assert(false); }
    }
    let ft3 = FileType.Symlink;
    match ft3 {
        FileType.Symlink => { assert(ft3.is_symlink()); }
        _ => { assert(false); }
    }
    let ft4 = FileType.Unknown;
    match ft4 {
        FileType.Unknown => { assert(ft4 is FileType.Unknown); }
        _ => { assert(false); }
    }
}

// =============================================================================
// Section 19: Permissions Extended Tests
// =============================================================================

@test
fn test_permissions_set_readonly_toggle() {
    let mut perm = Permissions { mode: 0o644 };
    assert(!perm.readonly());
    perm.set_readonly(true);
    assert(perm.readonly());
    perm.set_readonly(false);
    assert(!perm.readonly());
}

@test
fn test_permissions_from_mode_zero() {
    let perm = Permissions.from_mode(0);
    assert_eq(perm.mode(), 0);
    assert(perm.readonly());
}

@test
fn test_permissions_from_mode_full() {
    let perm = Permissions.from_mode(0o7777);
    assert_eq(perm.mode(), 0o7777);
    assert(!perm.readonly());
}

fn main() {
    // Tests run via @test annotations
}
