@test
fn test_temp_dir() {
    let tmp: PathBuf = temp_dir();
    // temp_dir returns a valid PathBuf
    assert(tmp.to_text().len() >= 0);
}

@test
fn test_is_file_type() {
    let path = PathBuf.from("/tmp");
    let p: Path = path.as_path();
    let result: Bool = is_file(&p);
    // Result is a Bool (true or false)
    assert(result || !result);
}

@test
fn test_is_dir_type() {
    let path = PathBuf.from("/tmp");
    let p: Path = path.as_path();
    let result: Bool = is_dir(&p);
    assert(result || !result);
}

@test
fn test_is_symlink_type() {
    let path = PathBuf.from("/tmp");
    let p: Path = path.as_path();
    let result: Bool = is_symlink(&p);
    assert(result || !result);
}

// =============================================================================
// Section 8: FileType Equality
// =============================================================================

@test
fn test_file_type_eq_same() {
    assert_eq(FileType.File, FileType.File);
    assert_eq(FileType.Dir, FileType.Dir);
    assert_eq(FileType.Symlink, FileType.Symlink);
    assert_eq(FileType.Unknown, FileType.Unknown);
}

@test
fn test_file_type_neq_different() {
    assert(FileType.File != FileType.Dir);
    assert(FileType.File != FileType.Symlink);
    assert(FileType.Dir != FileType.Symlink);
    assert(FileType.File != FileType.Unknown);
}

// =============================================================================
// Section 9: FileType Match Exhaustive
// =============================================================================

@test
fn test_file_type_match_all_variants() {
    let types = [FileType.File, FileType.Dir, FileType.Symlink, FileType.Unknown];
    let mut file_count = 0;
    let mut dir_count = 0;
    let mut symlink_count = 0;
    let mut unknown_count = 0;

    // Verify each variant matches exactly one arm
    let ft1 = FileType.File;
    match ft1 {
        FileType.File => file_count = file_count + 1,
        FileType.Dir => dir_count = dir_count + 1,
        FileType.Symlink => symlink_count = symlink_count + 1,
        FileType.Unknown => unknown_count = unknown_count + 1,
    }
    assert_eq(file_count, 1);

    let ft2 = FileType.Dir;
    match ft2 {
        FileType.File => file_count = file_count + 1,
        FileType.Dir => dir_count = dir_count + 1,
        FileType.Symlink => symlink_count = symlink_count + 1,
        FileType.Unknown => unknown_count = unknown_count + 1,
    }
    assert_eq(dir_count, 1);
}

// =============================================================================
// Section 10: Permissions Edge Cases
// =============================================================================

@test
fn test_permissions_setuid_setgid() {
    // Setuid (4000) + setgid (2000) + sticky (1000)
    let perm = Permissions.from_mode(0o7755);
    assert_eq(perm.mode(), 0o7755);
}

@test
fn test_permissions_sticky_bit() {
    let perm = Permissions.from_mode(0o1755);
    assert_eq(perm.mode(), 0o1755);
}

@test
fn test_permissions_write_only() {
    let perm = Permissions { mode: 0o200 };
    assert(!perm.readonly());
}

@test
fn test_permissions_group_write_no_owner_write() {
    // Owner has no write, group does - still "readonly" by owner check
    let perm = Permissions { mode: 0o464 };
    assert(perm.readonly());
}

