// =============================================================================
// fs_test.vr - Comprehensive tests for filesystem types and operations
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: io, filesystem, metadata, permissions, directory, filetype
// @description: Tests for FileType variants and methods, Permissions construction
//               and methods, DirEntry construction and field access, Metadata
//               construction and methods, WalkDir type, and filesystem operation
//               type signatures (temp_dir, current_dir, is_file, is_dir, etc.)
// =============================================================================

mount core.io.fs.{
    Metadata, FileType, Permissions, DirEntry,
    WalkDir, ReadDir,
    is_file, is_dir, is_symlink,
    temp_dir, current_dir, set_current_dir,
    metadata, symlink_metadata,
    create_dir, create_dir_all, remove_dir, remove_dir_all,
    read_dir, walk_dir,
    remove_file, rename,
    copy as fs_copy,
    hard_link, read_link, canonicalize,
    read as fs_read, write as fs_write,
    read_to_string as fs_read_to_string,
    write_str as fs_write_str,
    FsMetadataRaw,
};
// Note: fs.exists() cannot be imported directly because `exists`
// is a reserved keyword (quantifier). Must use qualified: core.io.fs.exists().
mount core.io.path.{Path, PathBuf};
mount core.io.protocols.{IoResult, IoErrorKind};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;

// =============================================================================
// Section 1: FileType Variant Construction
// =============================================================================

@test
fn test_file_type_file() {
    let ft: FileType = FileType.File;
    assert(ft is FileType.File);
    assert(ft.is_file());
}

@test
fn test_file_type_directory() {
    let ft: FileType = FileType.Dir;
    assert(ft is FileType.Dir);
    assert(ft.is_dir());
}

@test
fn test_file_type_symlink() {
    let ft: FileType = FileType.Symlink;
    assert(ft is FileType.Symlink);
    assert(ft.is_symlink());
}

@test
fn test_file_type_unknown() {
    let ft: FileType = FileType.Unknown;
    assert(ft is FileType.Unknown);
    assert(!ft.is_file());
    assert(!ft.is_dir());
    assert(!ft.is_symlink());
}

// =============================================================================
// Section 2: FileType Method Tests
// =============================================================================

@test
fn test_file_type_is_file_true() {
    let ft = FileType.File;
    assert(ft.is_file());
}

@test
fn test_file_type_is_file_false_dir() {
    let ft = FileType.Dir;
    assert(!ft.is_file());
}

@test
fn test_file_type_is_file_false_symlink() {
    let ft = FileType.Symlink;
    assert(!ft.is_file());
}

@test
fn test_file_type_is_file_false_unknown() {
    let ft = FileType.Unknown;
    assert(!ft.is_file());
}

@test
fn test_file_type_is_dir_true() {
    let ft = FileType.Dir;
    assert(ft.is_dir());
}

@test
fn test_file_type_is_dir_false_file() {
    let ft = FileType.File;
    assert(!ft.is_dir());
}

@test
fn test_file_type_is_dir_false_symlink() {
    let ft = FileType.Symlink;
    assert(!ft.is_dir());
}

@test
fn test_file_type_is_symlink_true() {
    let ft = FileType.Symlink;
    assert(ft.is_symlink());
}

@test
fn test_file_type_is_symlink_false_file() {
    let ft = FileType.File;
    assert(!ft.is_symlink());
}

@test
fn test_file_type_is_symlink_false_dir() {
    let ft = FileType.Dir;
    assert(!ft.is_symlink());
}

// =============================================================================
// Section 3: Permissions Construction
// =============================================================================

@test
fn test_permissions_readonly() {
    let perm = Permissions { mode: 0o444 };
    assert_eq(perm.mode, 0o444);
}

@test
fn test_permissions_readwrite() {
    let perm = Permissions { mode: 0o644 };
    assert_eq(perm.mode, 0o644);
}

@test
fn test_permissions_executable() {
    let perm = Permissions { mode: 0o755 };
    assert_eq(perm.mode, 0o755);
}

@test
fn test_permissions_all_access() {
    let perm = Permissions { mode: 0o777 };
    assert_eq(perm.mode, 0o777);
}

@test
fn test_permissions_no_access() {
    let perm = Permissions { mode: 0o000 };
    assert_eq(perm.mode, 0o000);
}

// =============================================================================
// Section 4: Permissions Method Tests
// =============================================================================

@test
fn test_permissions_from_mode() {
    let perm = Permissions.from_mode(0o755);
    assert_eq(perm.mode(), 0o755);
}

@test
fn test_permissions_from_mode_masks() {
    // from_mode masks with 0o7777
    let perm = Permissions.from_mode(0o100755);
    assert_eq(perm.mode(), 0o755);
}

@test
fn test_permissions_mode_method() {
    let perm = Permissions { mode: 0o644 };
    assert_eq(perm.mode(), 0o644);
}

@test
fn test_permissions_readonly_true() {
    // No write permission for owner (0o444)
    let perm = Permissions { mode: 0o444 };
    assert(perm.readonly());
}

@test
fn test_permissions_readonly_false() {
    // Has write permission for owner (0o644)
    let perm = Permissions { mode: 0o644 };
    assert(!perm.readonly());
}

@test
fn test_permissions_readonly_no_perms() {
    let perm = Permissions { mode: 0o000 };
    assert(perm.readonly());
}

@test
fn test_permissions_set_readonly_true() {
    let mut perm = Permissions { mode: 0o644 };
    perm.set_readonly(true);
    assert(perm.readonly());
}

@test
fn test_permissions_set_readonly_false() {
    let mut perm = Permissions { mode: 0o444 };
    perm.set_readonly(false);
    assert(!perm.readonly());
}

