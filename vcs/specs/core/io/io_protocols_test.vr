// =============================================================================
// io_protocols_test.vr - Tests for IoErrorKind Clone and Component Display
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: io, error, path, clone, display, protocols, core
// @description: Tests Clone for IoErrorKind and Display for path Component
// =============================================================================

mount core.io.protocols.{StreamError, IoErrorKind, io_error_kind_from_os_code};
mount core.io.path.{Component};
mount core.base.protocols.{Display, Debug, Clone, Eq};
mount core.text.format.{Formatter, FormatError, format_display, format_debug};
mount core.base.result.{Result, Ok, Err};
mount core.base.maybe.{Maybe, None};

// =============================================================================
// Section 1: IoErrorKind Clone
// =============================================================================

@test
fn test_io_error_kind_clone_not_found() {
    let kind = IoErrorKind.NotFound;
    let cloned = kind.clone();
    assert(cloned == IoErrorKind.NotFound);
}

@test
fn test_io_error_kind_clone_permission_denied() {
    let kind = IoErrorKind.PermissionDenied;
    let cloned = kind.clone();
    assert(cloned == IoErrorKind.PermissionDenied);
}

@test
fn test_io_error_kind_clone_timed_out() {
    let kind = IoErrorKind.TimedOut;
    let cloned = kind.clone();
    assert(cloned == IoErrorKind.TimedOut);
}

@test
fn test_io_error_kind_clone_other() {
    let kind = IoErrorKind.Other;
    let cloned = kind.clone();
    assert(cloned == IoErrorKind.Other);
}

@test
fn test_io_error_kind_clone_display_matches() {
    let kind = IoErrorKind.ConnectionRefused;
    let cloned = kind.clone();
    assert_eq(format_display(&kind), format_display(&cloned));
}

@test
fn test_io_error_kind_clone_fn_exists() {
    fn clone_kind(k: &IoErrorKind) -> IoErrorKind {
        k.clone()
    }
    let _ = clone_kind;
}

// =============================================================================
// Section 2: Component Display
// =============================================================================

@test
fn test_component_root_dir_display() {
    let c = Component.RootDir;
    let text = format_display(&c);
    assert_eq(text, "/");
}

@test
fn test_component_cur_dir_display() {
    let c = Component.CurDir;
    let text = format_display(&c);
    assert_eq(text, ".");
}

@test
fn test_component_parent_dir_display() {
    let c = Component.ParentDir;
    let text = format_display(&c);
    assert_eq(text, "..");
}

@test
fn test_component_normal_display() {
    let c = Component.Normal("hello");
    let text = format_display(&c);
    assert_eq(text, "hello");
}

@test
fn test_component_prefix_display() {
    let c = Component.Prefix("C:");
    let text = format_display(&c);
    assert_eq(text, "C:");
}

@test
fn test_component_display_vs_debug_differ() {
    let c = Component.Normal("file.txt");
    let display_text = format_display(&c);
    let debug_text = format_debug(&c);
    // Display is just "file.txt", Debug is "Normal(file.txt)"
    assert(display_text != debug_text);
    assert_eq(display_text, "file.txt");
    assert(debug_text.contains("Normal"));
}

@test
fn test_component_display_fn_exists() {
    fn display_component(c: &Component) -> Text {
        format_display(c)
    }
    let _ = display_component;
}

// =============================================================================
// Section 3: Type Existence
// =============================================================================

@test
fn test_io_error_kind_type_exists() {
    let _: Maybe<IoErrorKind> = None;
}

@test
fn test_component_type_exists() {
    let _: Maybe<Component> = None;
}

// =============================================================================
// Section 4: Typed errno mapping (#102) — `io_error_kind_from_os_code`
// =============================================================================
//
// Pins the POSIX-stable errno → IoErrorKind mappings that core/io/fs.vr
// uses to surface specific error kinds instead of collapsing every
// syscall failure into IoErrorKind.Other.  ENOENT/EACCES/EEXIST/EPIPE/
// EINTR/EINVAL/ENOMEM are POSIX-stable across all three supported
// platforms (Linux/macOS/Windows ucrt) so those can be tested
// platform-independently.  Network / time errno codes diverge between
// Linux and macOS — those tests live behind @cfg-gated companion files
// when added.

@test
fn test_errno_2_maps_to_not_found() {
    // ENOENT = 2 — POSIX-stable.
    assert(io_error_kind_from_os_code(2) == IoErrorKind.NotFound);
}

@test
fn test_errno_13_maps_to_permission_denied() {
    // EACCES = 13 — POSIX-stable.
    assert(io_error_kind_from_os_code(13) == IoErrorKind.PermissionDenied);
}

@test
fn test_errno_17_maps_to_already_exists() {
    // EEXIST = 17 — POSIX-stable.
    assert(io_error_kind_from_os_code(17) == IoErrorKind.AlreadyExists);
}

@test
fn test_errno_32_maps_to_broken_pipe() {
    // EPIPE = 32 — POSIX-stable.
    assert(io_error_kind_from_os_code(32) == IoErrorKind.BrokenPipe);
}

@test
fn test_errno_4_maps_to_interrupted() {
    // EINTR = 4 — POSIX-stable.
    assert(io_error_kind_from_os_code(4) == IoErrorKind.Interrupted);
}

@test
fn test_errno_22_maps_to_invalid_input() {
    // EINVAL = 22 — POSIX-stable.
    assert(io_error_kind_from_os_code(22) == IoErrorKind.InvalidInput);
}

@test
fn test_errno_12_maps_to_out_of_memory() {
    // ENOMEM = 12 — POSIX-stable.
    assert(io_error_kind_from_os_code(12) == IoErrorKind.OutOfMemory);
}

@test
fn test_unknown_errno_falls_through_to_other() {
    // Any errno outside the per-platform table collapses to
    // Other — defensive catch-all so unrecognised codes still
    // surface with the original message instead of crashing
    // the dispatch.
    assert(io_error_kind_from_os_code(9999) == IoErrorKind.Other);
}

@test
fn test_zero_errno_collapses_to_other() {
    // 0 is not a valid errno (success); if it surfaces here
    // something upstream is mishandling success vs failure —
    // collapse to Other rather than misclassify.
    assert(io_error_kind_from_os_code(0) == IoErrorKind.Other);
}

@test
fn test_negative_errno_collapses_to_other() {
    // Some platforms use negative codes (return -EINVAL) in
    // raw syscall returns; the high-level wrappers should
    // negate before passing here, but defensively the
    // mapping must not crash.
    assert(io_error_kind_from_os_code(-22) == IoErrorKind.Other);
}

fn main() {
    // Tests run via @test annotations
}
