// =============================================================================
// Section 10: Additional Conversion Edge Cases and Boundary Tests
// =============================================================================

@test
fn test_from_wrapper_identity() {
    // Test that converting the same value multiple times produces equal results
    let w1 = Wrapper.from(777);
    let w2 = Wrapper.from(777);
    assert_eq(w1.inner, w2.inner);
    assert(w1 == w2);
}

@test
fn test_from_temperature_scale_negative_extremes() {
    // Test near absolute zero in Celsius
    let c = Celsius { value: -273.0 };
    let f = Fahrenheit.from(c);
    let back = Celsius.from(f);
    let diff = (back.value - (-273.0)).abs();
    assert(diff < 0.1);
}

@test
fn test_from_distance_conversion_precision() {
    // Test that small distances convert accurately
    let km = Kilometers { value: 0.000001 };
    let m = Meters.from(km);
    assert_eq(m.value, 0.001);
    let mm = Millimeters.from(m);
    assert_eq(mm.value, 1.0);
}

@test
fn test_tryfrom_percentage_boundary_edge() {
    // Test exact boundaries of valid percentage range
    let zero_result = Percentage.try_from(0);
    let hundred_result = Percentage.try_from(100);
    let minus_one_result = Percentage.try_from(-1);
    let hundred_one_result = Percentage.try_from(101);

    assert(zero_result.is_ok());
    assert(hundred_result.is_ok());
    assert(minus_one_result.is_err());
    assert(hundred_one_result.is_err());
}

@test
fn test_tryfrom_positive_int_sequential() {
    // Test sequential positive integers
    let r1 = PositiveInt.try_from(1);
    let r2 = PositiveInt.try_from(2);
    let r3 = PositiveInt.try_from(3);

    assert(r1.is_ok());
    assert(r2.is_ok());
    assert(r3.is_ok());

    match (r1, r2, r3) {
        (Ok(p1), Ok(p2), Ok(p3)) => {
            assert_eq(p1.value + p2.value + p3.value, 6);
        },
        _ => assert(false),
    }
}

@test
fn test_from_celsius_boiling_point_round_trip() {
    // Verify round-trip at boiling point of water
    let boiling = Celsius { value: 100.0 };
    let f = Fahrenheit.from(boiling);
    assert_eq(f.value, 212.0);
    let back = Celsius.from(f);
    let diff = (back.value - 100.0).abs();
    assert(diff < 0.001);
}

@test
fn test_from_multi_step_distance_conversions() {
    // Test multiple consecutive conversions maintain accuracy
    let km1 = Kilometers { value: 5.0 };
    let m1 = Meters.from(km1);
    assert_eq(m1.value, 5000.0);

    let km2 = Kilometers { value: 2.5 };
    let m2 = Meters.from(km2);
    let mm2 = Millimeters.from(m2);
    assert_eq(mm2.value, 2500000.0);
}

@test
fn test_percentage_error_type_discrimination() {
    // Verify error types are correctly discriminated
    let neg_result = Percentage.try_from(-50);
    let over_result = Percentage.try_from(150);

    match neg_result {
        Ok(_) => assert(false),
        Err(e) => {
            assert(e is Negative);
            assert(!(e is OutOfRange));
        },
    }

    match over_result {
        Ok(_) => assert(false),
        Err(e) => {
            assert(e is OutOfRange);
            assert(!(e is Negative));
        },
    }
}

