fn test_from_zero_meters_to_mm() {
    let m = Meters { value: 0.0 };
    let mm = Millimeters.from(m);
    assert_eq(mm.value, 0.0);
}

@test
fn test_from_negative_km() {
    // Negative distances may be meaningful (displacement)
    let km = Kilometers { value: -5.0 };
    let m = Meters.from(km);
    assert_eq(m.value, -5000.0);
}

@test
fn test_from_multiple_wrapper_conversions() {
    let w1 = Wrapper.from(1);
    let w2 = Wrapper.from(2);
