}

@test
fn test_from_absolute_zero() {
    let c = Celsius { value: -273.15 };
    let f = Fahrenheit.from(c);
    // -273.15 * 1.8 + 32 = -459.67
    let diff = (f.value - (-459.67)).abs();
    assert(diff < 0.01);
}

@test
fn test_from_zero_km() {
    let km = Kilometers { value: 0.0 };
    let m = Meters.from(km);
    assert_eq(m.value, 0.0);
}

