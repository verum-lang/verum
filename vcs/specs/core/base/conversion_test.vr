// =============================================================================
// conversion_test.vr - Tests for From, Into, TryFrom conversion protocols
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: core, base, protocols, from, into, tryfrom, conversions
// @description: Comprehensive tests for type conversion protocols.
//
// Coverage:
// - From protocol: custom type conversions
// - Into protocol: blanket impl from From
// - TryFrom protocol: fallible conversions
// - Conversion chains and composability
// =============================================================================

module specs.core.base.conversion_test;

mount core.base.protocols.{From, Into, TryFrom, TryInto, Eq, Clone};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Test Types
// =============================================================================

/// Celsius temperature
type Celsius is {
    value: Float,
};

implement Eq for Celsius {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

/// Fahrenheit temperature
type Fahrenheit is {
    value: Float,
};

implement Eq for Fahrenheit {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

/// Implement From<Celsius> for Fahrenheit
implement From<Celsius> for Fahrenheit {
    fn from(c: Celsius) -> Fahrenheit {
        Fahrenheit { value: c.value * 1.8 + 32.0 }
    }
}

/// Implement From<Fahrenheit> for Celsius
implement From<Fahrenheit> for Celsius {
    fn from(f: Fahrenheit) -> Celsius {
        Celsius { value: (f.value - 32.0) / 1.8 }
    }
}

/// A wrapper for positive integers only
type PositiveInt is {
    value: Int,
};

implement Eq for PositiveInt {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

/// TryFrom Int: only accepts positive values
implement TryFrom<Int> for PositiveInt {
    type Error = Text;

    fn try_from(n: Int) -> Result<PositiveInt, Text> {
        if n > 0 {
            Ok(PositiveInt { value: n })
        } else {
            Err("value must be positive")
        }
    }
}

/// Newtype wrappers for From/Into testing
type Meters is { value: Float };
type Kilometers is { value: Float };

implement Eq for Meters {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

implement Eq for Kilometers {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

implement From<Kilometers> for Meters {
    fn from(km: Kilometers) -> Meters {
        Meters { value: km.value * 1000.0 }
    }
}

/// Wrapper type to test From<Int>
type Wrapper is { inner: Int };

implement Eq for Wrapper {
    fn eq(&self, other: &Self) -> Bool {
        self.inner == other.inner
    }
}

implement From<Int> for Wrapper {
    fn from(n: Int) -> Wrapper {
        Wrapper { inner: n }
    }
}

// =============================================================================
// Section 1: From Protocol - Basic Conversions
// =============================================================================

@test
fn test_from_celsius_to_fahrenheit() {
    let boiling = Celsius { value: 100.0 };
    let f = Fahrenheit.from(boiling);
    assert_eq(f.value, 212.0);
}

@test
fn test_from_fahrenheit_to_celsius() {
    let f = Fahrenheit { value: 32.0 };
    let c = Celsius.from(f);
    assert_eq(c.value, 0.0);
}

@test
fn test_from_freezing_point() {
    let freezing = Celsius { value: 0.0 };
    let f = Fahrenheit.from(freezing);
    assert_eq(f.value, 32.0);
}

@test
fn test_from_kilometers_to_meters() {
    let km = Kilometers { value: 1.0 };
    let m = Meters.from(km);
    assert_eq(m.value, 1000.0);
}

@test
fn test_from_kilometers_to_meters_fractional() {
    let km = Kilometers { value: 2.5 };
    let m = Meters.from(km);
    assert_eq(m.value, 2500.0);
}

@test
fn test_from_int_to_wrapper() {
    let w = Wrapper.from(42);
    assert_eq(w.inner, 42);
}

@test
fn test_from_int_to_wrapper_zero() {
    let w = Wrapper.from(0);
    assert_eq(w.inner, 0);
}

@test
fn test_from_int_to_wrapper_negative() {
    let w = Wrapper.from(-99);
    assert_eq(w.inner, -99);
}

// =============================================================================
// Section 2: From Protocol - Additional Conversions
// =============================================================================

@test
fn test_from_multiple_conversions() {
    // Convert same source to different targets
    let c1 = Celsius { value: 100.0 };
    let c2 = Celsius { value: 100.0 };
    let f = Fahrenheit.from(c1);
    assert_eq(f.value, 212.0);

    // And the reverse
    let c3 = Celsius.from(f);
    assert_eq(c3.value, 100.0);
}

@test
fn test_from_round_trip() {
    // Celsius -> Fahrenheit -> Celsius should be identity
    let original = Celsius { value: 37.0 };
    let f = Fahrenheit.from(original);
    let back = Celsius.from(f);
    // Floating point round trip
    let diff = (back.value - 37.0).abs();
    assert(diff < 0.001);
}

@test
fn test_from_negative_temperature() {
    let c = Celsius { value: -40.0 };
    let f = Fahrenheit.from(c);
    // -40 is the same in both scales
    assert_eq(f.value, -40.0);
}

@test
fn test_from_wrapper_preserves_value() {
    let w1 = Wrapper.from(Int.MAX);
    assert_eq(w1.inner, Int.MAX);

    let w2 = Wrapper.from(Int.MIN);
    assert_eq(w2.inner, Int.MIN);
}

// =============================================================================
// Section 3: TryFrom Protocol - Fallible Conversions
// =============================================================================

@test
fn test_tryfrom_positive_success() {
    let result = PositiveInt.try_from(42);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 42),
        Err(_) => assert(false),
    }
}

@test
fn test_tryfrom_positive_one() {
    let result = PositiveInt.try_from(1);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 1),
        Err(_) => assert(false),
    }
}

@test
fn test_tryfrom_zero_fails() {
    let result = PositiveInt.try_from(0);
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(msg) => assert_eq(msg, "value must be positive"),
    }
}

@test
fn test_tryfrom_negative_fails() {
    let result = PositiveInt.try_from(-10);
    assert(result.is_err());
}

@test
fn test_tryfrom_large_positive() {
    let result = PositiveInt.try_from(1000000);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 1000000),
        Err(_) => assert(false),
    }
}

// =============================================================================
// Section 4: TryFrom with Different Error Types
// =============================================================================

/// Percentage type (0-100 only)
type Percentage is {
    value: Int,
};

implement Eq for Percentage {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

type PercentageError is OutOfRange | Negative;

implement Eq for PercentageError {
    fn eq(&self, other: &Self) -> Bool {
        match (self, other) {
            (OutOfRange, OutOfRange) => true,
            (Negative, Negative) => true,
            _ => false,
        }
    }
}

implement TryFrom<Int> for Percentage {
    type Error = PercentageError;

    fn try_from(n: Int) -> Result<Percentage, PercentageError> {
        if n < 0 {
            Err(Negative)
        } else if n > 100 {
            Err(OutOfRange)
        } else {
            Ok(Percentage { value: n })
        }
    }
}

@test
fn test_percentage_valid() {
    let result = Percentage.try_from(50);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 50),
        Err(_) => assert(false),
    }
}

@test
fn test_percentage_zero() {
    let result = Percentage.try_from(0);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 0),
        Err(_) => assert(false),
    }
}

@test
fn test_percentage_hundred() {
    let result = Percentage.try_from(100);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 100),
        Err(_) => assert(false),
    }
}

@test
fn test_percentage_negative() {
    let result = Percentage.try_from(-1);
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e is Negative),
    }
}

@test
fn test_percentage_over_hundred() {
    let result = Percentage.try_from(101);
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e is OutOfRange),
    }
}

@test
fn test_percentage_large_over() {
    let result = Percentage.try_from(999);
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e is OutOfRange),
    }
}

// =============================================================================
// Section 5: From/Into with Identity and Composability
// =============================================================================

/// Test that From is composable through multiple conversions
type Millimeters is { value: Float };

implement Eq for Millimeters {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

implement From<Meters> for Millimeters {
    fn from(m: Meters) -> Millimeters {
        Millimeters { value: m.value * 1000.0 }
    }
}

@test
fn test_from_chain_km_to_m_to_mm() {
    // Kilometers -> Meters -> Millimeters (two-step conversion)
    let km = Kilometers { value: 1.0 };
    let m = Meters.from(km);
    let mm = Millimeters.from(m);
    assert_eq(mm.value, 1000000.0);
}

@test
fn test_from_chain_small_values() {
    let km = Kilometers { value: 0.001 };
    let m = Meters.from(km);
    assert_eq(m.value, 1.0);
    let mm = Millimeters.from(m);
    assert_eq(mm.value, 1000.0);
}

