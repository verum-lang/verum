@test
fn test_tryfrom_positive_large_boundary() {
    let result = PositiveInt.try_from(Int.MAX);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, Int.MAX),
        Err(_) => assert(false),
    }
}

@test
fn test_tryfrom_negative_large() {
    let result = PositiveInt.try_from(-999999);
    assert(result.is_err());
}

@test
fn test_percentage_one() {
    let result = Percentage.try_from(1);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 1),
        Err(_) => assert(false),
    }
}

@test
fn test_percentage_ninety_nine() {
    let result = Percentage.try_from(99);
    assert(result.is_ok());
    match result {
        Ok(p) => assert_eq(p.value, 99),
        Err(_) => assert(false),
    }
}

@test
fn test_percentage_large_negative() {
    let result = Percentage.try_from(-1000);
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e is Negative),
    }
}

@test
fn test_percentage_error_equality() {
    assert(OutOfRange == OutOfRange);
    assert(Negative == Negative);
    assert(OutOfRange != Negative);
    assert(Negative != OutOfRange);
}

