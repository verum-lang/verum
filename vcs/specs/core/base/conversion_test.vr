// =============================================================================
// Section 12: TryInto Protocol - Blanket Implementation Tests
// =============================================================================
// NOTE: When a source type has multiple TryFrom implementations (e.g. Int has
// TryFrom<Int> for both PositiveInt and Percentage), the type checker cannot
// disambiguate using the target type annotation alone. To test TryInto cleanly,
// we use unique source types with only one TryFrom target.

/// Score type: valid range 0.0..=100.0 (Float source — unique TryFrom target)
type Score is { value: Float };

implement Eq for Score {
    fn eq(&self, other: &Self) -> Bool {
        self.value == other.value
    }
}

type ScoreError is TooLow | TooHigh;

implement Eq for ScoreError {
    fn eq(&self, other: &Self) -> Bool {
        match (self, other) {
            (TooLow, TooLow) => true,
            (TooHigh, TooHigh) => true,
            _ => false,
        }
    }
}

implement TryFrom<Float> for Score {
    type Error = ScoreError;

    fn try_from(f: Float) -> Result<Score, ScoreError> {
        if f < 0.0 {
            Err(TooLow)
        } else if f > 100.0 {
            Err(TooHigh)
        } else {
            Ok(Score { value: f })
        }
    }
}

@test
fn test_tryinto_score_valid() {
    let f: Float = 85.5;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_ok());
    match result {
        Ok(s) => assert_eq(s.value, 85.5),
        Err(_) => assert(false),
    }
}

@test
fn test_tryinto_score_zero() {
    let f: Float = 0.0;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_ok());
    match result {
        Ok(s) => assert_eq(s.value, 0.0),
        Err(_) => assert(false),
    }
}

@test
fn test_tryinto_score_hundred() {
    let f: Float = 100.0;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_ok());
    match result {
        Ok(s) => assert_eq(s.value, 100.0),
        Err(_) => assert(false),
    }
}

@test
fn test_tryinto_score_negative_fails() {
    let f: Float = -1.0;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e is TooLow),
    }
}

@test
fn test_tryinto_score_over_fails() {
    let f: Float = 100.1;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e is TooHigh),
    }
}

@test
fn test_tryinto_score_boundary_precision() {
    let f: Float = 99.999;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_ok());
    match result {
        Ok(s) => assert(s.value > 99.0),
        Err(_) => assert(false),
    }
}

@test
fn test_tryinto_error_type_preserved() {
    let low: Float = -50.0;
    let high: Float = 200.0;

    let low_result: Result<Score, ScoreError> = low.try_into();
    let high_result: Result<Score, ScoreError> = high.try_into();

    match low_result {
        Err(e) => {
            assert(e is TooLow);
            assert(!(e is TooHigh));
        },
        Ok(_) => assert(false),
    }

    match high_result {
        Err(e) => {
            assert(e is TooHigh);
            assert(!(e is TooLow));
        },
        Ok(_) => assert(false),
    }
}

@test
fn test_tryinto_mirrors_tryfrom() {
    // Verify TryInto and TryFrom produce identical results
    let f: Float = 42.0;
    let from_result = Score.try_from(42.0);
    let into_result: Result<Score, ScoreError> = f.try_into();

    assert(from_result.is_ok());
    assert(into_result.is_ok());

    match (from_result, into_result) {
        (Ok(fr), Ok(ir)) => assert_eq(fr.value, ir.value),
        _ => assert(false),
    }
}

@test
fn test_tryinto_mirrors_tryfrom_failure() {
    let f: Float = -10.0;
    let from_result = Score.try_from(-10.0);
    let into_result: Result<Score, ScoreError> = f.try_into();

    assert(from_result.is_err());
    assert(into_result.is_err());
}

@test
fn test_tryinto_score_midpoint() {
    let f: Float = 50.0;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_ok());
    match result {
        Ok(s) => assert_eq(s.value, 50.0),
        Err(_) => assert(false),
    }
}

@test
fn test_tryinto_score_large_negative() {
    let f: Float = -1000.0;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_err());
}

@test
fn test_tryinto_score_large_positive() {
    let f: Float = 999.0;
    let result: Result<Score, ScoreError> = f.try_into();
    assert(result.is_err());
    match result {
        Ok(_) => assert(false),
        Err(e) => assert(e is TooHigh),
    }
}

fn main() {
    // Tests run via @test annotations
}
