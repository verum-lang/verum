// =============================================================================
// USize - all new methods
// =============================================================================

@test
fn test_usize_checked_rem() {
    let a = 100 as USize;
    assert(a.checked_rem(7 as USize) is Some);
    assert(a.checked_rem(0 as USize) is None);
}

@test
fn test_usize_wrapping_neg() {
    let zero = 0 as USize;
    assert_eq(zero.wrapping_neg().to_int(), 0);
    let one = 1 as USize;
    assert(one.wrapping_neg().to_int() != 0);
}

@test
fn test_usize_abs_diff() {
    let a = 100 as USize;
    let b = 40 as USize;
    assert_eq(a.abs_diff(b), 60);
    assert_eq(b.abs_diff(a), 60);
}

@test
fn test_usize_ilog2_ilog10() {
    let a = 512 as USize;
    assert_eq(a.ilog2(), 9);
    let b = 99999 as USize;
    assert_eq(b.ilog10(), 4);
}

@test
fn test_usize_is_power_of_two() {
    assert((1 as USize).is_power_of_two());
    assert((65536 as USize).is_power_of_two());
    assert(!(65535 as USize).is_power_of_two());
}

// =============================================================================
// Cross-type consistency: verify all types have consistent methods
// =============================================================================

@test
fn test_all_signed_have_checked_rem() {
    // Verify checked_rem exists and returns Maybe for all signed types
    assert((10 as Int8).checked_rem(3 as Int8) is Some);
    assert((10 as Int16).checked_rem(3 as Int16) is Some);
    assert((10 as Int32).checked_rem(3 as Int32) is Some);
    assert((10 as Int64).checked_rem(3 as Int64) is Some);
    assert((10 as Int128).checked_rem(3 as Int128) is Some);
    assert((10 as ISize).checked_rem(3 as ISize) is Some);
}

@test
fn test_all_unsigned_have_checked_rem() {
    assert((10 as UInt8).checked_rem(3 as UInt8) is Some);
    assert((10 as UInt16).checked_rem(3 as UInt16) is Some);
    assert((10 as UInt32).checked_rem(3 as UInt32) is Some);
    assert((10 as UInt64).checked_rem(3 as UInt64) is Some);
    assert((10 as UInt128).checked_rem(3 as UInt128) is Some);
    assert((10 as USize).checked_rem(3 as USize) is Some);
}

@test
fn test_all_have_wrapping_neg() {
    let _a = (5 as Int8).wrapping_neg();
    let _b = (5 as Int16).wrapping_neg();
    let _c = (5 as Int32).wrapping_neg();
    let _d = (5 as Int64).wrapping_neg();
    let _e = (5 as Int128).wrapping_neg();
    let _f = (5 as ISize).wrapping_neg();
    let _g = (5 as UInt8).wrapping_neg();
    let _h = (5 as UInt16).wrapping_neg();
    let _i = (5 as UInt32).wrapping_neg();
    let _j = (5 as UInt64).wrapping_neg();
    let _k = (5 as UInt128).wrapping_neg();
    let _l = (5 as USize).wrapping_neg();
    assert_eq(_a.to_int(), -5);
    assert_eq(_b.to_int(), -5);
    assert_eq(_c.to_int(), -5);
    assert_eq(_d.to_int(), -5);
    assert_eq(_e.to_int(), -5);
    assert_eq(_f.to_int(), -5);
    assert(_g.to_int() == 251);
    assert(_h.to_int() == 65531);
    assert(_i.to_int() != 0);
    assert(_j.to_int() != 0);
    assert(_k.to_int() != 0);
    assert(_l.to_int() != 0);
}

@test
fn test_all_signed_have_checked_neg() {
    assert((5 as Int8).checked_neg() is Some);
    assert((5 as Int16).checked_neg() is Some);
    assert((5 as Int32).checked_neg() is Some);
    assert((5 as Int64).checked_neg() is Some);
    assert((5 as Int128).checked_neg() is Some);
    assert((5 as ISize).checked_neg() is Some);
}

@test
fn test_all_have_ilog2() {
    assert_eq((8 as Int8).ilog2(), 3);
    assert_eq((8 as Int16).ilog2(), 3);
    assert_eq((8 as Int32).ilog2(), 3);
    assert_eq((8 as Int64).ilog2(), 3);
    assert_eq((8 as Int128).ilog2(), 3);
    assert_eq((8 as ISize).ilog2(), 3);
    assert_eq((8 as UInt8).ilog2(), 3);
    assert_eq((8 as UInt16).ilog2(), 3);
    assert_eq((8 as UInt32).ilog2(), 3);
    assert_eq((8 as UInt64).ilog2(), 3);
    assert_eq((8 as UInt128).ilog2(), 3);
    assert_eq((8 as USize).ilog2(), 3);
    assert_eq((8).ilog2(), 3);
}

@test
fn test_all_have_is_power_of_two() {
    assert((8 as Int8).is_power_of_two());
    assert((8 as Int16).is_power_of_two());
    assert((8 as Int32).is_power_of_two());
    assert((8 as Int64).is_power_of_two());
    assert((8 as Int128).is_power_of_two());
    assert((8 as ISize).is_power_of_two());
    assert((8 as UInt8).is_power_of_two());
    assert((8 as UInt16).is_power_of_two());
    assert((8 as UInt32).is_power_of_two());
    assert((8 as UInt64).is_power_of_two());
    assert((8 as UInt128).is_power_of_two());
    assert((8 as USize).is_power_of_two());
    assert((8).is_power_of_two());
}
