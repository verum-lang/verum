// @test: typecheck-pass
// @level: L1
// @tags: primitives, integers, checked-rem, wrapping-neg, abs-diff, ilog2, ilog10, is-power-of-two
// @description: Tests for advanced integer methods: checked_rem, wrapping_neg, checked_neg, abs_diff, ilog2, ilog10, is_power_of_two

mount core.base.primitives.{
    Int8, Int16, Int32, Int64, Int128, ISize,
    UInt8, UInt16, UInt32, UInt64, UInt128, USize
};

// =============================================================================
// Int - checked_rem
// =============================================================================

@test
fn test_int_checked_rem_normal() {
    let result = (10).checked_rem(3);
    assert(result is Some);
    assert_eq(result.unwrap(), 1);
}

@test
fn test_int_checked_rem_zero_divisor() {
    let result = (10).checked_rem(0);
    assert(result is None);
}

@test
fn test_int_checked_rem_negative() {
    let result = (-10).checked_rem(3);
    assert(result is Some);
}

// =============================================================================
// Int - wrapping_neg
// =============================================================================

@test
fn test_int_wrapping_neg() {
    assert_eq((5).wrapping_neg(), -5);
    assert_eq((-5).wrapping_neg(), 5);
    assert_eq((0).wrapping_neg(), 0);
}

// =============================================================================
// Int - checked_neg
// =============================================================================

@test
fn test_int_checked_neg_normal() {
    let result = (5).checked_neg();
    assert(result is Some);
    assert_eq(result.unwrap(), -5);
}

@test
fn test_int_checked_neg_zero() {
    let result = (0).checked_neg();
    assert(result is Some);
    assert_eq(result.unwrap(), 0);
}

@test
fn test_int_checked_neg_min() {
    // Int.MIN negation would overflow — should be None
    let result = (-9223372036854775808).checked_neg();
    assert(result is None);
}

// =============================================================================
// Int - abs_diff
// =============================================================================

@test
fn test_int_abs_diff() {
    assert_eq((10).abs_diff(3), 7);
    assert_eq((3).abs_diff(10), 7);
    assert_eq((5).abs_diff(5), 0);
    assert_eq((-3).abs_diff(3), 6);
    assert_eq((3).abs_diff(-3), 6);
}

// =============================================================================
// Int - ilog2
// =============================================================================

@test
fn test_int_ilog2() {
    assert_eq((1).ilog2(), 0);
    assert_eq((2).ilog2(), 1);
    assert_eq((4).ilog2(), 2);
    assert_eq((8).ilog2(), 3);
    assert_eq((16).ilog2(), 4);
    assert_eq((1024).ilog2(), 10);
}

@test
fn test_int_ilog2_non_power() {
    assert_eq((3).ilog2(), 1);
    assert_eq((5).ilog2(), 2);
    assert_eq((7).ilog2(), 2);
    assert_eq((15).ilog2(), 3);
}

// =============================================================================
// Int - ilog10
// =============================================================================

@test
fn test_int_ilog10() {
    assert_eq((1).ilog10(), 0);
    assert_eq((9).ilog10(), 0);
    assert_eq((10).ilog10(), 1);
    assert_eq((99).ilog10(), 1);
    assert_eq((100).ilog10(), 2);
    assert_eq((999).ilog10(), 2);
    assert_eq((1000).ilog10(), 3);
    assert_eq((1000000).ilog10(), 6);
}

// =============================================================================
// Int - is_power_of_two
// =============================================================================

@test
fn test_int_is_power_of_two() {
    assert((1).is_power_of_two());
    assert((2).is_power_of_two());
    assert((4).is_power_of_two());
    assert((8).is_power_of_two());
    assert((16).is_power_of_two());
    assert((256).is_power_of_two());
    assert((1024).is_power_of_two());
}

@test
fn test_int_not_power_of_two() {
    assert(!(0).is_power_of_two());
    assert(!(3).is_power_of_two());
    assert(!(5).is_power_of_two());
    assert(!(6).is_power_of_two());
    assert(!(7).is_power_of_two());
    assert(!(-1).is_power_of_two());
    assert(!(-4).is_power_of_two());
}

// =============================================================================
// Int8 - all new methods
// =============================================================================

@test
fn test_int8_checked_rem() {
    let a = 10 as Int8;
    let b = 3 as Int8;
    let result = a.checked_rem(b);
    assert(result is Some);
    assert_eq(result.unwrap().to_int(), 1);

    let zero = 0 as Int8;
    assert(a.checked_rem(zero) is None);
}

@test
fn test_int8_wrapping_neg() {
    let a = 5 as Int8;
    assert_eq(a.wrapping_neg().to_int(), -5);

    // MIN wrapping_neg wraps to MIN (since -(-128) = 128 > 127)
    let min_val = -128 as Int8;
    let neg = min_val.wrapping_neg();
    assert_eq(neg.to_int(), -128);
}

@test
fn test_int8_checked_neg() {
    let a = 5 as Int8;
    let result = a.checked_neg();
    assert(result is Some);
    assert_eq(result.unwrap().to_int(), -5);

    let zero = 0 as Int8;
    assert(zero.checked_neg() is Some);
}

@test
fn test_int8_abs_diff() {
    let a = 10 as Int8;
    let b = 3 as Int8;
    assert_eq(a.abs_diff(b), 7);
    assert_eq(b.abs_diff(a), 7);

    let neg = -5 as Int8;
    assert_eq(neg.abs_diff(a), 15);
}

@test
fn test_int8_ilog2() {
    let a = 4 as Int8;
    assert_eq(a.ilog2(), 2);
    let b = 1 as Int8;
    assert_eq(b.ilog2(), 0);
    let c = 127 as Int8;
    assert_eq(c.ilog2(), 6);
}

@test
fn test_int8_ilog10() {
    let a = 1 as Int8;
    assert_eq(a.ilog10(), 0);
    let b = 10 as Int8;
    assert_eq(b.ilog10(), 1);
    let c = 99 as Int8;
    assert_eq(c.ilog10(), 1);
    let d = 100 as Int8;
    assert_eq(d.ilog10(), 2);
}

@test
fn test_int8_is_power_of_two() {
    assert((1 as Int8).is_power_of_two());
    assert((2 as Int8).is_power_of_two());
    assert((4 as Int8).is_power_of_two());
    assert((64 as Int8).is_power_of_two());
    assert(!(0 as Int8).is_power_of_two());
    assert(!(3 as Int8).is_power_of_two());
    assert(!(-1 as Int8).is_power_of_two());
}

// =============================================================================
// Int16 - all new methods
// =============================================================================

@test
fn test_int16_checked_rem() {
    let a = 1000 as Int16;
    let b = 7 as Int16;
    let result = a.checked_rem(b);
    assert(result is Some);
    assert_eq(result.unwrap().to_int(), 6);
    assert(a.checked_rem(0 as Int16) is None);
}

@test
fn test_int16_wrapping_neg() {
    let a = 100 as Int16;
    assert_eq(a.wrapping_neg().to_int(), -100);
}

@test
fn test_int16_checked_neg() {
    let a = 100 as Int16;
    assert(a.checked_neg() is Some);
    assert_eq(a.checked_neg().unwrap().to_int(), -100);
}

@test
fn test_int16_abs_diff() {
    let a = 1000 as Int16;
    let b = -1000 as Int16;
    assert_eq(a.abs_diff(b), 2000);
}

@test
fn test_int16_ilog2() {
    let a = 256 as Int16;
    assert_eq(a.ilog2(), 8);
    let b = 32767 as Int16;
    assert_eq(b.ilog2(), 14);
}

@test
fn test_int16_ilog10() {
    let a = 1000 as Int16;
    assert_eq(a.ilog10(), 3);
    let b = 9999 as Int16;
    assert_eq(b.ilog10(), 3);
    let c = 10000 as Int16;
    assert_eq(c.ilog10(), 4);
}

@test
fn test_int16_is_power_of_two() {
    assert((1024 as Int16).is_power_of_two());
    assert((16384 as Int16).is_power_of_two());
    assert(!(1000 as Int16).is_power_of_two());
}

// =============================================================================
