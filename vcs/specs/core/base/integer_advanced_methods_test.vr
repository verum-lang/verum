// =============================================================================
// ISize - all new methods
// =============================================================================

@test
fn test_isize_checked_rem() {
    let a = 100 as ISize;
    let b = 7 as ISize;
    assert(a.checked_rem(b) is Some);
    assert(a.checked_rem(0 as ISize) is None);
}

@test
fn test_isize_wrapping_neg_checked_neg() {
    let a = 42 as ISize;
    assert_eq(a.wrapping_neg().to_int(), -42);
    assert(a.checked_neg() is Some);
    assert_eq(a.checked_neg().unwrap().to_int(), -42);
}

@test
fn test_isize_abs_diff() {
    let a = 100 as ISize;
    let b = -50 as ISize;
    assert_eq(a.abs_diff(b), 150);
}

@test
fn test_isize_ilog2_ilog10() {
    let a = 1024 as ISize;
    assert_eq(a.ilog2(), 10);
    let b = 1000 as ISize;
    assert_eq(b.ilog10(), 3);
}

@test
fn test_isize_is_power_of_two() {
    assert((256 as ISize).is_power_of_two());
    assert(!(255 as ISize).is_power_of_two());
}

// =============================================================================
// UInt8 - all new methods
// =============================================================================

@test
fn test_uint8_checked_rem() {
    let a = 10 as UInt8;
    let b = 3 as UInt8;
    assert(a.checked_rem(b) is Some);
    assert_eq(a.checked_rem(b).unwrap().to_int(), 1);
    assert(a.checked_rem(0 as UInt8) is None);
}

@test
fn test_uint8_wrapping_neg() {
    let a = 1 as UInt8;
    // wrapping_neg(1) for u8 = 255
    let neg = a.wrapping_neg();
    assert_eq(neg.to_int(), 255);

    let zero = 0 as UInt8;
    assert_eq(zero.wrapping_neg().to_int(), 0);
}

@test
fn test_uint8_abs_diff() {
    let a = 200 as UInt8;
    let b = 50 as UInt8;
    assert_eq(a.abs_diff(b), 150);
    assert_eq(b.abs_diff(a), 150);
}

@test
fn test_uint8_ilog2() {
    let a = 128 as UInt8;
    assert_eq(a.ilog2(), 7);
    let b = 1 as UInt8;
    assert_eq(b.ilog2(), 0);
    let c = 255 as UInt8;
    assert_eq(c.ilog2(), 7);
}

@test
fn test_uint8_ilog10() {
    let a = 1 as UInt8;
    assert_eq(a.ilog10(), 0);
    let b = 99 as UInt8;
    assert_eq(b.ilog10(), 1);
    let c = 100 as UInt8;
    assert_eq(c.ilog10(), 2);
}

@test
fn test_uint8_is_power_of_two() {
    assert((1 as UInt8).is_power_of_two());
    assert((2 as UInt8).is_power_of_two());
    assert((128 as UInt8).is_power_of_two());
    assert(!(0 as UInt8).is_power_of_two());
    assert(!(3 as UInt8).is_power_of_two());
    assert(!(255 as UInt8).is_power_of_two());
}

// =============================================================================
// UInt16 - all new methods
// =============================================================================

@test
fn test_uint16_checked_rem() {
    let a = 1000 as UInt16;
    assert(a.checked_rem(7 as UInt16) is Some);
    assert(a.checked_rem(0 as UInt16) is None);
}

@test
fn test_uint16_wrapping_neg() {
    let a = 1 as UInt16;
    assert_eq(a.wrapping_neg().to_int(), 65535);
}

@test
fn test_uint16_abs_diff_ilog2() {
    let a = 1000 as UInt16;
    let b = 500 as UInt16;
    assert_eq(a.abs_diff(b), 500);
    assert_eq(a.ilog2(), 9);
}

@test
fn test_uint16_ilog10_is_power_of_two() {
    let a = 10000 as UInt16;
    assert_eq(a.ilog10(), 4);
    assert((4096 as UInt16).is_power_of_two());
    assert(!(4095 as UInt16).is_power_of_two());
}

// =============================================================================
// UInt32 - all new methods
// =============================================================================

@test
fn test_uint32_checked_rem() {
    let a = 100000 as UInt32;
    assert(a.checked_rem(7 as UInt32) is Some);
    assert(a.checked_rem(0 as UInt32) is None);
}

@test
fn test_uint32_wrapping_neg() {
    let a = 1 as UInt32;
    let neg = a.wrapping_neg();
    // wrapping_neg(1) for u32 = 2^32 - 1 = 4294967295
    // But to_int() truncates large unsigned values
    assert(neg.to_int() != 0);
}

@test
fn test_uint32_abs_diff_ilog2() {
    let a = 1000000 as UInt32;
    let b = 500000 as UInt32;
    assert_eq(a.abs_diff(b), 500000);
    assert_eq(a.ilog2(), 19);
}

@test
fn test_uint32_ilog10_is_power_of_two() {
    let a = 1000000 as UInt32;
    assert_eq(a.ilog10(), 6);
    assert((1048576 as UInt32).is_power_of_two());
    assert(!(1000000 as UInt32).is_power_of_two());
}

