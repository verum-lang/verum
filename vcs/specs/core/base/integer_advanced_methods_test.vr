// UInt64 - all new methods
// =============================================================================

@test
fn test_uint64_checked_rem() {
    let a = 100 as UInt64;
    assert(a.checked_rem(7 as UInt64) is Some);
    assert(a.checked_rem(0 as UInt64) is None);
}

@test
fn test_uint64_wrapping_neg() {
    let a = 1 as UInt64;
    let neg = a.wrapping_neg();
    assert(neg.to_int() != 0);
}

@test
fn test_uint64_abs_diff() {
    let a = 100 as UInt64;
    let b = 50 as UInt64;
    assert_eq(a.abs_diff(b), 50);
}

@test
fn test_uint64_ilog2_ilog10() {
    let a = 1024 as UInt64;
    assert_eq(a.ilog2(), 10);
    let b = 1000000 as UInt64;
    assert_eq(b.ilog10(), 6);
}

@test
fn test_uint64_is_power_of_two() {
    assert((1 as UInt64).is_power_of_two());
    assert((512 as UInt64).is_power_of_two());
    assert(!(511 as UInt64).is_power_of_two());
}

