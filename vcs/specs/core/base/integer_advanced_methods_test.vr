@test
fn test_int32_wrapping_neg_and_checked_neg() {
    let a = 100000 as Int32;
    assert_eq(a.wrapping_neg().to_int(), -100000);
    assert(a.checked_neg() is Some);
    assert_eq(a.checked_neg().unwrap().to_int(), -100000);
}

@test
fn test_int32_abs_diff() {
    let a = 1000000 as Int32;
    let b = -1000000 as Int32;
    assert_eq(a.abs_diff(b), 2000000);
}

@test
fn test_int32_ilog2() {
    let a = 1048576 as Int32;
    assert_eq(a.ilog2(), 20);
}

@test
fn test_int32_ilog10() {
    let a = 1000000 as Int32;
    assert_eq(a.ilog10(), 6);
}

@test
fn test_int32_is_power_of_two() {
    assert((1048576 as Int32).is_power_of_two());
    assert(!(999999 as Int32).is_power_of_two());
}

// =============================================================================
// Int64 - all new methods
