@test
fn test_int64_checked_rem() {
    let a = 100 as Int64;
    let b = 7 as Int64;
    assert(a.checked_rem(b) is Some);
    assert(a.checked_rem(0 as Int64) is None);
}

@test
fn test_int64_wrapping_neg_and_checked_neg() {
    let a = 12345 as Int64;
    assert_eq(a.wrapping_neg().to_int(), -12345);
    assert(a.checked_neg() is Some);
}

@test
fn test_int64_abs_diff_ilog2() {
    let a = 100 as Int64;
    let b = 50 as Int64;
    assert_eq(a.abs_diff(b), 50);
    assert_eq(a.ilog2(), 6);
}

@test
fn test_int64_ilog10_is_power_of_two() {
    let a = 1000000 as Int64;
    assert_eq(a.ilog10(), 6);
    assert((1024 as Int64).is_power_of_two());
    assert(!(1000 as Int64).is_power_of_two());
}

