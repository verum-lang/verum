@test
fn test_int128_checked_rem() {
    let a = 100 as Int128;
    let b = 7 as Int128;
    assert(a.checked_rem(b) is Some);
    assert(a.checked_rem(0 as Int128) is None);
}

@test
fn test_int128_wrapping_neg() {
    let a = 42 as Int128;
    assert_eq(a.wrapping_neg().to_int(), -42);
}

@test
fn test_int128_checked_neg() {
    let a = 42 as Int128;
    assert(a.checked_neg() is Some);
    assert_eq(a.checked_neg().unwrap().to_int(), -42);

    let zero = 0 as Int128;
    assert(zero.checked_neg() is Some);
}

@test
fn test_int128_ilog2() {
    let a = 1024 as Int128;
    assert_eq(a.ilog2(), 10);
    let b = 1 as Int128;
    assert_eq(b.ilog2(), 0);
}

@test
fn test_int128_is_power_of_two() {
