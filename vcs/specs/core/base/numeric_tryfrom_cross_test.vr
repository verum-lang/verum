// =============================================================================
// numeric_tryfrom_cross_test.vr - Cross-type TryFrom narrowing conversions
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: base, primitives, tryfrom, conversions, numeric, cross-type
// @description: Tests for TryFrom narrowing conversions between sized integer types.
//               Covers Int32→Int16/Int8, Int16→Int8, UInt32→UInt16/UInt8,
//               UInt16→UInt8, and signed↔unsigned cross-conversions.
// =============================================================================

mount core.base.protocols.{TryFrom, Eq};
mount core.base.primitives.TryFromIntError;

// =============================================================================
// Section 1: TryFrom<Int32> for Int16
// =============================================================================

@test
fn test_int32_to_int16_valid_zero() {
    let val = 0 as Int32;
    let result = Int16.try_from(val);
    assert(result.is_ok());
}

@test
fn test_int32_to_int16_valid_positive() {
    let val = 1000 as Int32;
    let result = Int16.try_from(val);
    assert(result.is_ok());
}

@test
fn test_int32_to_int16_valid_negative() {
    let val = 0 as Int32;
    let neg = val - 1000_i32;
    let result = Int16.try_from(neg);
    assert(result.is_ok());
}

@test
fn test_int32_to_int16_max() {
    let val = 32767 as Int32;
    let result = Int16.try_from(val);
    assert(result.is_ok());
}

@test
fn test_int32_to_int16_overflow() {
    let val = 32768 as Int32;
    let result = Int16.try_from(val);
    assert(result.is_err());
}

@test
fn test_int32_to_int16_large_overflow() {
    let val = 100000 as Int32;
    let result = Int16.try_from(val);
    assert(result.is_err());
}

