// =============================================================================
// Section 8: Cross-sign conversions
// =============================================================================

@test
fn test_uint64_to_int_valid() {
    // UInt64 value within Int range
    let val = 1000 as UInt64;
    let result = Int.try_from(val);
    assert(result.is_ok());
}

@test
fn test_uint32_to_int16_valid() {
    let val = 100 as UInt32;
    let result = Int16.try_from(val);
    assert(result.is_ok());
}

@test
fn test_uint32_to_int16_overflow() {
    let val = 40000 as UInt32;
    let result = Int16.try_from(val);
    assert(result.is_err());
}

@test
fn test_uint16_to_int8_valid() {
    let val = 100 as UInt16;
    let result = Int8.try_from(val);
    assert(result.is_ok());
}

@test
fn test_uint16_to_int8_overflow() {
    let val = 200 as UInt16;
    let result = Int8.try_from(val);
    assert(result.is_err());
}

// =============================================================================
// Section 9: Comprehensive boundary tests
// =============================================================================

@test
fn test_cross_type_chain_narrowing() {
    // A value that fits in Int8 should pass through all narrowing chains
    let val32 = 42 as Int32;
    let r16 = Int16.try_from(val32);
    assert(r16.is_ok());

    let val16 = 42 as Int16;
    let r8 = Int8.try_from(val16);
    assert(r8.is_ok());
}

@test
fn test_unsigned_chain_narrowing() {
    let val32 = 200 as UInt32;
    let r16 = UInt16.try_from(val32);
    assert(r16.is_ok());

    let val16 = 200 as UInt16;
    let r8 = UInt8.try_from(val16);
    assert(r8.is_ok());
}

@test
fn test_cross_type_all_fail_for_large() {
    // 100000 is too large for Int16 and Int8
    let val = 100000 as Int32;
    let r16 = Int16.try_from(val);
    let r8 = Int8.try_from(val);
    assert(r16.is_err());
    assert(r8.is_err());
}

fn main() {
    // Tests run via @test annotations
}
