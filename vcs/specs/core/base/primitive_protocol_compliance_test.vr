// =============================================================================
// Section 8: Hash Protocol — Different values → different hashes
// =============================================================================

@test
fn test_hash_different_int8() {
    let a: Int8 = 1 as Int8;
    let b: Int8 = 2 as Int8;
    let mut h1 = DefaultHasher.new();
    let mut h2 = DefaultHasher.new();
    a.hash(&mut h1);
    b.hash(&mut h2);
    assert_ne(h1.finish(), h2.finish());
}

@test
fn test_hash_different_uint64() {
    let a: UInt64 = 0 as UInt64;
    let b: UInt64 = 1 as UInt64;
    let mut h1 = DefaultHasher.new();
    let mut h2 = DefaultHasher.new();
    a.hash(&mut h1);
    b.hash(&mut h2);
    assert_ne(h1.finish(), h2.finish());
}

// =============================================================================
// Section 9: Clone Protocol — Sized Integers
// =============================================================================

@test
fn test_clone_int8() {
    let a: Int8 = 42 as Int8;
    let b: Int8 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_int16() {
    let a: Int16 = 1000 as Int16;
    let b: Int16 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_int32() {
    let a: Int32 = 100000 as Int32;
    let b: Int32 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_int64() {
    let a: Int64 = 999999 as Int64;
    let b: Int64 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_int128() {
    let a: Int128 = 42 as Int128;
    let b: Int128 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_isize() {
    let a: ISize = 77 as ISize;
    let b: ISize = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_uint8() {
    let a: UInt8 = 200 as UInt8;
    let b: UInt8 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_uint16() {
    let a: UInt16 = 50000 as UInt16;
    let b: UInt16 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_uint32() {
    let a: UInt32 = 3000000 as UInt32;
    let b: UInt32 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_uint64() {
    let a: UInt64 = 9000000 as UInt64;
    let b: UInt64 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_uint128() {
    let a: UInt128 = 42 as UInt128;
    let b: UInt128 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_clone_usize() {
    let a: USize = 256 as USize;
    let b: USize = a.clone();
    assert(a.eq(&b));
}

// =============================================================================
// Section 10: Clone Independence — clone produces independent value
// =============================================================================

@test
fn test_clone_independence_int32() {
    let mut a: Int32 = 100 as Int32;
    let b: Int32 = a.clone();
    a = 200 as Int32;
    assert_eq(b, 100 as Int32);
}

@test
fn test_clone_independence_uint64() {
    let mut a: UInt64 = 100 as UInt64;
    let b: UInt64 = a.clone();
    a = 200 as UInt64;
    assert_eq(b, 100 as UInt64);
}

// =============================================================================
// Section 11: Float32 — Eq, PartialOrd, Clone, Copy
// =============================================================================

@test
fn test_eq_float32() {
    let a: Float32 = 3.14 as Float32;
    let b: Float32 = 3.14 as Float32;
    let c: Float32 = 2.71 as Float32;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_float32_zero() {
    let a: Float32 = 0.0 as Float32;
    let b: Float32 = 0.0 as Float32;
    assert(a.eq(&b));
}

@test
fn test_partial_ord_float32() {
    let a: Float32 = 1.0 as Float32;
    let b: Float32 = 2.0 as Float32;
    let c: Float32 = 1.0 as Float32;
    let r1: Maybe<Ordering> = a.partial_cmp(&b);
    assert(r1 is Some);
    let r2: Maybe<Ordering> = b.partial_cmp(&a);
    assert(r2 is Some);
    let r3: Maybe<Ordering> = a.partial_cmp(&c);
    assert(r3 is Some);
}

@test
fn test_partial_ord_float32_nan() {
    let nan: Float32 = Float32.nan();
    let one: Float32 = 1.0 as Float32;
    let r: Maybe<Ordering> = nan.partial_cmp(&one);
    assert(r is None);
    let r2: Maybe<Ordering> = one.partial_cmp(&nan);
    assert(r2 is None);
}

@test
fn test_clone_float32() {
    let a: Float32 = 3.14 as Float32;
    let b: Float32 = a.clone();
    assert(a.eq(&b));
}

// =============================================================================
// Section 12: Byte — Display
// =============================================================================

@test
fn test_display_byte() {
    let b: Byte = 65;
    // Byte should have Display protocol — verify it type-checks
    let val: Int = b as Int;
    assert_eq(val, 65);
}

// =============================================================================
// Section 13: Ord negative values — signed integers
// =============================================================================

@test
fn test_ord_negative_int8() {
    let a: Int8 = -10 as Int8;
    let b: Int8 = 10 as Int8;
    assert(a.cmp(&b) is Less);
}

@test
fn test_ord_negative_int32() {
    let a: Int32 = -1000 as Int32;
    let b: Int32 = 1000 as Int32;
    assert(a.cmp(&b) is Less);
    let c: Int32 = -1000 as Int32;
    assert(a.cmp(&c) is Equal);
}

// =============================================================================
// Section 14: Eq with zero values
// =============================================================================

@test
fn test_eq_zero_signed() {
    let z8: Int8 = 0 as Int8;
    let z16: Int16 = 0 as Int16;
    let z32: Int32 = 0 as Int32;
    let z64: Int64 = 0 as Int64;
    let z128: Int128 = 0 as Int128;
    let zis: ISize = 0 as ISize;
    assert(z8.eq(&(0 as Int8)));
    assert(z16.eq(&(0 as Int16)));
    assert(z32.eq(&(0 as Int32)));
    assert(z64.eq(&(0 as Int64)));
    assert(z128.eq(&(0 as Int128)));
    assert(zis.eq(&(0 as ISize)));
}

@test
fn test_eq_zero_unsigned() {
    let z8: UInt8 = 0 as UInt8;
    let z16: UInt16 = 0 as UInt16;
    let z32: UInt32 = 0 as UInt32;
    let z64: UInt64 = 0 as UInt64;
    let z128: UInt128 = 0 as UInt128;
    let zus: USize = 0 as USize;
    assert(z8.eq(&(0 as UInt8)));
    assert(z16.eq(&(0 as UInt16)));
    assert(z32.eq(&(0 as UInt32)));
    assert(z64.eq(&(0 as UInt64)));
    assert(z128.eq(&(0 as UInt128)));
    assert(zus.eq(&(0 as USize)));
}
