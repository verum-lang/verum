// =============================================================================
// primitive_protocol_compliance_test.vr - Protocol compliance for ALL primitives
// =============================================================================
// @test: typecheck-pass
// @level: L0
// @tier: 0
// @tags: base, protocols, eq, ord, hash, clone, copy, compliance, sized-integers
// @description: Verifies every primitive type correctly implements core protocols
//               (Eq, Ord, Hash, Clone, Copy). TDD — these tests expose gaps.
// =============================================================================

mount core.*;
mount core.base.protocols.{Eq, Ord, PartialOrd, Hash, Hasher, DefaultHasher, Clone, Copy};
mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: Eq Protocol — Sized Signed Integers
// =============================================================================

@test
fn test_eq_int8() {
    let a: Int8 = 42 as Int8;
    let b: Int8 = 42 as Int8;
    let c: Int8 = 10 as Int8;
    assert(a.eq(&b));
    assert(!a.eq(&c));
    assert(a.ne(&c));
}

@test
fn test_eq_int16() {
    let a: Int16 = 1000 as Int16;
    let b: Int16 = 1000 as Int16;
    let c: Int16 = 2000 as Int16;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_int32() {
    let a: Int32 = 100000 as Int32;
    let b: Int32 = 100000 as Int32;
    let c: Int32 = 200000 as Int32;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_int64() {
    let a: Int64 = 1000000 as Int64;
    let b: Int64 = 1000000 as Int64;
    let c: Int64 = 2000000 as Int64;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_int128() {
    let a: Int128 = 999 as Int128;
    let b: Int128 = 999 as Int128;
    let c: Int128 = 0 as Int128;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_isize() {
    let a: ISize = 77 as ISize;
    let b: ISize = 77 as ISize;
    let c: ISize = 88 as ISize;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

// =============================================================================
// Section 2: Eq Protocol — Sized Unsigned Integers
// =============================================================================

@test
fn test_eq_uint8() {
    let a: UInt8 = 200 as UInt8;
    let b: UInt8 = 200 as UInt8;
    let c: UInt8 = 100 as UInt8;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_uint16() {
    let a: UInt16 = 50000 as UInt16;
    let b: UInt16 = 50000 as UInt16;
    let c: UInt16 = 30000 as UInt16;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_uint32() {
    let a: UInt32 = 3000000 as UInt32;
    let b: UInt32 = 3000000 as UInt32;
    let c: UInt32 = 1000000 as UInt32;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_uint64() {
    let a: UInt64 = 9000000 as UInt64;
    let b: UInt64 = 9000000 as UInt64;
    let c: UInt64 = 1 as UInt64;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_uint128() {
    let a: UInt128 = 42 as UInt128;
    let b: UInt128 = 42 as UInt128;
    let c: UInt128 = 0 as UInt128;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_eq_usize() {
    let a: USize = 256 as USize;
    let b: USize = 256 as USize;
    let c: USize = 512 as USize;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

// =============================================================================
// Section 3: Eq Protocol — Self-equality (reflexivity)
// =============================================================================

@test
fn test_eq_self_equality_signed() {
    let a: Int8 = 127 as Int8;
    assert(a.eq(&a));
    let b: Int16 = 32000 as Int16;
    assert(b.eq(&b));
    let c: Int32 = 100 as Int32;
    assert(c.eq(&c));
    let d: Int64 = 999 as Int64;
    assert(d.eq(&d));
    let e: Int128 = 1 as Int128;
    assert(e.eq(&e));
    let f: ISize = 50 as ISize;
    assert(f.eq(&f));
}

@test
fn test_eq_self_equality_unsigned() {
    let a: UInt8 = 255 as UInt8;
    assert(a.eq(&a));
    let b: UInt16 = 65000 as UInt16;
    assert(b.eq(&b));
    let c: UInt32 = 100 as UInt32;
    assert(c.eq(&c));
    let d: UInt64 = 999 as UInt64;
    assert(d.eq(&d));
    let e: UInt128 = 1 as UInt128;
    assert(e.eq(&e));
    let f: USize = 50 as USize;
    assert(f.eq(&f));
}

// =============================================================================
// Section 4: Ord Protocol — Sized Signed Integers
// =============================================================================

@test
fn test_ord_int8() {
    let a: Int8 = 10 as Int8;
    let b: Int8 = 20 as Int8;
    let c: Int8 = 10 as Int8;
    assert(a.cmp(&b) is Less);
    assert(b.cmp(&a) is Greater);
    assert(a.cmp(&c) is Equal);
}

@test
fn test_ord_int16() {
    let a: Int16 = 100 as Int16;
    let b: Int16 = 200 as Int16;
    let c: Int16 = 100 as Int16;
    assert(a.cmp(&b) is Less);
    assert(b.cmp(&a) is Greater);
    assert(a.cmp(&c) is Equal);
}

@test
fn test_ord_int32() {
    let a: Int32 = 1000 as Int32;
    let b: Int32 = 2000 as Int32;
    assert(a.cmp(&b) is Less);
    assert(b.cmp(&a) is Greater);
}

@test
fn test_ord_int64() {
    let a: Int64 = 10000 as Int64;
    let b: Int64 = 20000 as Int64;
    assert(a.cmp(&b) is Less);
    assert(b.cmp(&a) is Greater);
}

@test
fn test_ord_int128() {
    let a: Int128 = 1 as Int128;
    let b: Int128 = 2 as Int128;
    assert(a.cmp(&b) is Less);
}

@test
fn test_ord_isize() {
    let a: ISize = 5 as ISize;
    let b: ISize = 10 as ISize;
    assert(a.cmp(&b) is Less);
    assert(b.cmp(&a) is Greater);
}

// =============================================================================
// Section 5: Ord Protocol — Sized Unsigned Integers
// =============================================================================

@test
fn test_ord_uint8() {
    let a: UInt8 = 10 as UInt8;
    let b: UInt8 = 200 as UInt8;
    assert(a.cmp(&b) is Less);
    assert(b.cmp(&a) is Greater);
}

@test
fn test_ord_uint16() {
    let a: UInt16 = 100 as UInt16;
    let b: UInt16 = 60000 as UInt16;
    assert(a.cmp(&b) is Less);
}

@test
fn test_ord_uint32() {
    let a: UInt32 = 100 as UInt32;
    let b: UInt32 = 200 as UInt32;
    assert(a.cmp(&b) is Less);
}

@test
fn test_ord_uint64() {
    let a: UInt64 = 100 as UInt64;
    let b: UInt64 = 200 as UInt64;
    assert(a.cmp(&b) is Less);
}

@test
fn test_ord_uint128() {
    let a: UInt128 = 0 as UInt128;
    let b: UInt128 = 1 as UInt128;
    assert(a.cmp(&b) is Less);
}

@test
fn test_ord_usize() {
    let a: USize = 10 as USize;
    let b: USize = 20 as USize;
    assert(a.cmp(&b) is Less);
}

// =============================================================================
// Section 6: Ord Protocol — min/max
// =============================================================================

@test
fn test_ord_min_max_signed() {
    let a: Int8 = 10 as Int8;
    let b: Int8 = 20 as Int8;
    assert_eq(a.cmp(&b) is Less, true);

    let c: Int32 = 100 as Int32;
    let d: Int32 = 50 as Int32;
    assert(c.cmp(&d) is Greater);
}

@test
fn test_ord_min_max_unsigned() {
    let a: UInt8 = 10 as UInt8;
    let b: UInt8 = 20 as UInt8;
    assert(a.cmp(&b) is Less);

    let c: UInt64 = 100 as UInt64;
    let d: UInt64 = 50 as UInt64;
    assert(c.cmp(&d) is Greater);
}

// =============================================================================
// Section 7: Hash Protocol — Sized Integers (equal values → equal hashes)
// =============================================================================

@test
fn test_hash_int8() {
    let a: Int8 = 42 as Int8;
    let b: Int8 = 42 as Int8;
    let mut h1 = DefaultHasher.new();
    let mut h2 = DefaultHasher.new();
    a.hash(&mut h1);
    b.hash(&mut h2);
    assert_eq(h1.finish(), h2.finish());
}

@test
fn test_hash_int16() {
    let a: Int16 = 1000 as Int16;
    let b: Int16 = 1000 as Int16;
    let mut h1 = DefaultHasher.new();
    let mut h2 = DefaultHasher.new();
    a.hash(&mut h1);
    b.hash(&mut h2);
    assert_eq(h1.finish(), h2.finish());
}

@test
