fn test_sub_assign_to_negative() {
    let mut c = Counter { count: 5 };
    c.sub_assign(10);
    assert(c.count == -5);
}

@test
fn test_add_sub_assign_combined() {
    let mut c = Counter { count: 100 };
    c.add_assign(50);
    c.sub_assign(30);
    assert(c.count == 120);
}

@test
fn test_mul_assign_by_zero() {
    let mut a = Accumulator { value: 42 };
    a.mul_assign(0);
    assert(a.value == 0);
}

@test
fn test_div_assign_by_one() {
    let mut a = Accumulator { value: 42 };
    a.div_assign(1);
    assert(a.value == 42);
}

@test
fn test_rem_assign_smaller_divisor() {
    let mut a = Accumulator { value: 3 };
    a.rem_assign(5);
    assert(a.value == 3);
}

@test
fn test_shl_assign_by_zero() {
    let mut s = Shifter { value: 42 };
