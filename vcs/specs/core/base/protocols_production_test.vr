// =============================================================================
// protocols_production_test.vr - Production-grade protocol tests
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: protocols, production, error, fromstr, tostring, borrow, assign, core
// @description: Tests for production-grade protocols: Error (with source chain),
//               FromStr, ToString (blanket from Display), Borrow/BorrowMut,
//               compound assignment operators (AddAssign, SubAssign, etc).
// =============================================================================

module specs.core.base.protocols_production_test;

mount core.*;
mount core.base.ordering.{Ordering};

// =============================================================================
// Error Protocol Tests
// =============================================================================

// Define a simple error type
type SimpleError is {
    message: Text,
};

implement Describable for SimpleError {
    fn description(&self) -> Text {
        self.message.clone()
    }
}

implement ErrorSource for SimpleError {}

@test
fn test_error_description() {
    let err = SimpleError { message: "something went wrong" };
    assert(err.description() == "something went wrong");
}

@test
fn test_error_source_default_none() {
    let err = SimpleError { message: "leaf error" };
    // Default implementation returns None
    assert(err.source().is_none());
}

// =============================================================================
// FromStr Protocol Tests
// =============================================================================

// A simple type that can be parsed from text
type Color is Red | Green | Blue;

type ColorParseError is {
    input: Text,
};

implement Describable for ColorParseError {
    fn description(&self) -> Text {
        let mut msg: Text = "unknown color: ";
        msg.push_str(&self.input);
        msg
    }
}

implement FromStr for Color {
    type ParseError = ColorParseError;

    fn from_str(s: &Text) -> Result<Color, ColorParseError> {
        if *s == "red" {
            Ok(Red)
        } else if *s == "green" {
            Ok(Green)
        } else if *s == "blue" {
            Ok(Blue)
        } else {
            Err(ColorParseError { input: s.clone() })
        }
    }
}

@test
fn test_from_str_valid() {
    let r: Result<Color, ColorParseError> = Color.from_str("red");
    assert(r.is_ok());
}

@test
fn test_from_str_invalid() {
    let r: Result<Color, ColorParseError> = Color.from_str("purple");
    assert(r.is_err());
}

@test
fn test_from_str_all_variants() {
    assert(Color.from_str("red").is_ok());
    assert(Color.from_str("green").is_ok());
    assert(Color.from_str("blue").is_ok());
}

// =============================================================================
// ToString Protocol Tests (blanket from Display)
// =============================================================================

type Pair is {
    x: Int,
    y: Int,
};

implement Display for Pair {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&f"({self.x}, {self.y})")
    }
}

@test
fn test_to_string_from_display() {
    let p = Pair { x: 3, y: 4 };
    let s = p.to_string();
    assert(s == "(3, 4)");
}

@test
fn test_to_string_int() {
    let n: Int = 42;
    // Int implements Display, so it should get ToString via blanket
    let s = n.to_string();
    assert(s == "42");
}

// =============================================================================
// Borrow / BorrowMut Protocol Tests
// =============================================================================

type Wrapper is {
    value: Int,
};

implement Borrow<Int> for Wrapper {
    fn borrow(&self) -> &Int {
        &self.value
    }
}

@test
fn test_borrow_basic() {
    let w = Wrapper { value: 42 };
    let borrowed: &Int = w.borrow();
    assert(*borrowed == 42);
}

// =============================================================================
// Compound Assignment Protocols Tests
// =============================================================================

type Counter is {
    count: Int,
};

implement AddAssign<Int> for Counter {
    fn add_assign(&mut self, rhs: Int) {
        self.count = self.count + rhs;
    }
}

implement SubAssign<Int> for Counter {
    fn sub_assign(&mut self, rhs: Int) {
        self.count = self.count - rhs;
    }
}

@test
fn test_add_assign() {
    let mut c = Counter { count: 10 };
    c.add_assign(5);
    assert(c.count == 15);
}

@test
fn test_sub_assign() {
    let mut c = Counter { count: 10 };
    c.sub_assign(3);
    assert(c.count == 7);
}

type Accumulator is {
    value: Int,
};

implement MulAssign<Int> for Accumulator {
    fn mul_assign(&mut self, rhs: Int) {
        self.value = self.value * rhs;
    }
}

implement DivAssign<Int> for Accumulator {
    fn div_assign(&mut self, rhs: Int) {
        self.value = self.value / rhs;
    }
}

implement RemAssign<Int> for Accumulator {
    fn rem_assign(&mut self, rhs: Int) {
        self.value = self.value % rhs;
    }
}

@test
fn test_mul_assign() {
    let mut a = Accumulator { value: 5 };
    a.mul_assign(3);
    assert(a.value == 15);
}

@test
fn test_div_assign() {
    let mut a = Accumulator { value: 20 };
    a.div_assign(4);
    assert(a.value == 5);
}

@test
fn test_rem_assign() {
    let mut a = Accumulator { value: 17 };
    a.rem_assign(5);
    assert(a.value == 2);
}

// Bitwise compound assignment tests
type Flags is {
    bits: Int,
};

implement BitAndAssign<Int> for Flags {
    fn bitand_assign(&mut self, rhs: Int) {
        self.bits = self.bits & rhs;
    }
}

implement BitOrAssign<Int> for Flags {
    fn bitor_assign(&mut self, rhs: Int) {
        self.bits = self.bits | rhs;
    }
}

implement BitXorAssign<Int> for Flags {
    fn bitxor_assign(&mut self, rhs: Int) {
        self.bits = self.bits ^ rhs;
    }
}

@test
fn test_bitor_assign() {
    let mut f = Flags { bits: 0b1010 };
    f.bitor_assign(0b0101);
    assert(f.bits == 0b1111);
}

@test
fn test_bitand_assign() {
    let mut f = Flags { bits: 0b1111 };
    f.bitand_assign(0b1010);
    assert(f.bits == 0b1010);
}

@test
fn test_bitxor_assign() {
    let mut f = Flags { bits: 0b1100 };
    f.bitxor_assign(0b1010);
    assert(f.bits == 0b0110);
}

// Shift compound assignment tests
type Shifter is {
    value: Int,
};

implement ShlAssign<Int> for Shifter {
    fn shl_assign(&mut self, rhs: Int) {
        self.value = self.value << rhs;
    }
}

implement ShrAssign<Int> for Shifter {
    fn shr_assign(&mut self, rhs: Int) {
        self.value = self.value >> rhs;
    }
}

@test
fn test_shl_assign() {
    let mut s = Shifter { value: 1 };
    s.shl_assign(3);
    assert(s.value == 8);
}

@test
fn test_shr_assign() {
    let mut s = Shifter { value: 16 };
    s.shr_assign(2);
    assert(s.value == 4);
}

// =============================================================================
// Additional Error Protocol Tests
// =============================================================================

// Error with source chaining
type AppError is {
    message: Text,
    cause: Maybe<SimpleError>,
};

implement Describable for AppError {
    fn description(&self) -> Text {
        self.message.clone()
    }
}

implement ErrorSource for AppError {
    fn source(&self) -> Maybe<&dyn Describable> {
        // Default returns None since we can't cast to dyn Describable
        None
    }
}

@test
fn test_app_error_with_cause() {
    let cause = SimpleError { message: "root cause" };
    let err = AppError { message: "app failed", cause: Some(cause) };
    assert(err.description() == "app failed");
    assert(err.cause.is_some());
}

@test
fn test_app_error_without_cause() {
    let err = AppError { message: "standalone", cause: None };
    assert(err.source().is_none());
    assert(err.cause.is_none());
}

@test
fn test_color_parse_error_description() {
    let err = ColorParseError { input: "magenta" };
    let desc = err.description();
    assert(desc.contains(&"unknown color"));
    assert(desc.contains(&"magenta"));
}

