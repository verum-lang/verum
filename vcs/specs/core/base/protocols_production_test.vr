    let red: Result<Color, ColorParseError> = Color.from_str("red");
    let green: Result<Color, ColorParseError> = Color.from_str("green");
    let blue: Result<Color, ColorParseError> = Color.from_str("blue");
    assert(red.is_ok());
    assert(green.is_ok());
    assert(blue.is_ok());
}

