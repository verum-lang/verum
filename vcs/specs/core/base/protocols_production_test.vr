    assert(s.value == 42);
}

@test
fn test_shr_assign_by_zero() {
    let mut s = Shifter { value: 42 };
    s.shr_assign(0);
    assert(s.value == 42);
}

@test
fn test_bitor_assign_with_zero() {
    let mut f = Flags { bits: 0b1010 };
    f.bitor_assign(0);
    assert(f.bits == 0b1010);
}

@test
fn test_bitand_assign_with_all_ones() {
