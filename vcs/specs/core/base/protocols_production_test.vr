fn test_from_str_empty_string() {
    let r: Result<Color, ColorParseError> = Color.from_str("");
    assert(r.is_err());
}

@test
fn test_from_str_case_sensitive() {
    // "Red" should NOT match "red" - case sensitive
    let r: Result<Color, ColorParseError> = Color.from_str("Red");
    assert(r.is_err());
}

