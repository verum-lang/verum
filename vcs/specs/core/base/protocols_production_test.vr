}

// =============================================================================
// PartialOrd Protocol Tests
// =============================================================================

type Versioned is {
    major: Int,
    minor: Int,
    comparable: Bool,
};

implement PartialEq for Versioned {
    fn eq(&self, other: &Self) -> Bool {
        self.major == other.major && self.minor == other.minor
    }
}

implement PartialOrd for Versioned {
    fn partial_cmp(&self, other: &Self) -> Maybe<Ordering> {
        // Versions are only comparable if both have comparable flag
        if !self.comparable || !other.comparable {
            return None;
        }
        if self.major != other.major {
            if self.major < other.major {
                Some(Ordering.Less)
            } else {
                Some(Ordering.Greater)
            }
        } else if self.minor != other.minor {
            if self.minor < other.minor {
                Some(Ordering.Less)
            } else {
                Some(Ordering.Greater)
            }
        } else {
            Some(Ordering.Equal)
        }
    }
}

@test
fn test_partial_ord_comparable_versions() {
    let v1 = Versioned { major: 1, minor: 0, comparable: true };
    let v2 = Versioned { major: 2, minor: 0, comparable: true };
    assert(v1.lt(&v2));
    assert(!v1.gt(&v2));
}

@test
fn test_partial_ord_incomparable_versions() {
    let v1 = Versioned { major: 1, minor: 0, comparable: false };
    let v2 = Versioned { major: 2, minor: 0, comparable: true };
    // Both must be comparable for comparison to succeed
    assert(!v1.lt(&v2));
    assert(!v1.gt(&v2));
    assert(!v1.le(&v2));
    assert(!v1.ge(&v2));
}

@test
fn test_partial_ord_equal_versions() {
    let v1 = Versioned { major: 1, minor: 5, comparable: true };
    let v2 = Versioned { major: 1, minor: 5, comparable: true };
    assert(v1.le(&v2));
    assert(v1.ge(&v2));
}

// =============================================================================
// AsRef / AsMut Protocol Tests
// =============================================================================

type TextBox is {
    content: Text,
};

implement AsRef<Text> for TextBox {
    fn as_ref(&self) -> &Text {
        &self.content
    }
}

implement AsMut<Text> for TextBox {
    fn as_mut(&mut self) -> &mut Text {
        &mut self.content
    }
}

@test
fn test_as_ref_text_box() {
    let tbox = TextBox { content: "hello" };
    let r: &Text = tbox.as_ref();
    assert(*r == "hello");
}

@test
fn test_as_mut_text_box() {
    let mut tbox = TextBox { content: "hello" };
    let r: &mut Text = tbox.as_mut();
    r.push_str(" world");
    assert(tbox.content == "hello world");
}

// =============================================================================
// Zero / One Protocol Tests
// =============================================================================

type Distance is {
    meters: Int,
};

implement Zero for Distance {
    fn zero() -> Distance {
        Distance { meters: 0 }
    }

    fn is_zero(&self) -> Bool {
        self.meters == 0
    }
}

implement One for Distance {
    fn one() -> Distance {
        Distance { meters: 1 }
    }

    fn is_one(&self) -> Bool {
        self.meters == 1
    }
}

@test
fn test_zero_protocol() {
    let d = Distance.zero();
    assert(d.is_zero());
    assert(d.meters == 0);
}

@test
fn test_one_protocol() {
    let d = Distance.one();
    assert(d.is_one());
    assert(d.meters == 1);
}

@test
fn test_zero_one_not_overlap() {
    let zero_dist = Distance.zero();
    let one_dist = Distance.one();
    assert(!zero_dist.is_one());
    assert(!one_dist.is_zero());
}

fn main() {
    // Tests run via @test annotations
}
