// =============================================================================
// Euclidean division properties
// =============================================================================

@test
fn test_rem_euclid_property_positive_divisor() {
    // For any a and positive b, rem_euclid(a, b) is in [0, b)
    assert((-7).rem_euclid(3) >= 0);
    assert((-7).rem_euclid(3) < 3);
    assert(7.rem_euclid(3) >= 0);
    assert(7.rem_euclid(3) < 3);
}

@test
fn test_div_euclid_reconstruction() {
    // Property: a == div_euclid(a,b) * b + rem_euclid(a,b)
    let a = -7;
    let b = 3;
    assert_eq(a, a.div_euclid(b) * b + a.rem_euclid(b));
}

@test
fn test_div_euclid_vs_truncated() {
    // For positive args, euclidean == truncated
    assert_eq(7.div_euclid(3), 7 / 3);
    assert_eq(7.rem_euclid(3), 7 % 3);
    // For negative dividend, they differ
    assert_eq((-7).div_euclid(3), -3);
    assert_eq((-7) / 3, -2);
}

// =============================================================================
// Int16/Int32/Int64/ISize signed types
// =============================================================================

@test
fn test_int16_all_new_methods() {
    let a = 10 as Int16;
    let b = 3 as Int16;
    assert(a.wrapping_shl(0).to_int() == 10);
    assert(a.wrapping_shr(0).to_int() == 10);
    assert(a.wrapping_div(b).to_int() == 3);
    assert(a.wrapping_rem(b).to_int() == 1);
    assert(a.div_euclid(b).to_int() == 3);
    assert(a.rem_euclid(b).to_int() == 1);
    assert(a.saturating_pow(2).to_int() == 100);
    let pair = a.overflowing_shl(0);
    assert_eq(pair.1, false);
}

@test
fn test_int32_all_new_methods() {
    let a = 10 as Int32;
    let b = 3 as Int32;
    assert(a.wrapping_shl(0).to_int() == 10);
    assert(a.wrapping_shr(0).to_int() == 10);
    assert(a.wrapping_div(b).to_int() == 3);
    assert(a.wrapping_rem(b).to_int() == 1);
    assert(a.div_euclid(b).to_int() == 3);
    assert(a.rem_euclid(b).to_int() == 1);
    assert(a.saturating_pow(2).to_int() == 100);
    let pair = a.overflowing_shl(0);
    assert_eq(pair.1, false);
}

@test
fn test_int64_all_new_methods() {
    let a = 10 as Int64;
    let b = 3 as Int64;
