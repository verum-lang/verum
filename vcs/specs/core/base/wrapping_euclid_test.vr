// @test: typecheck-pass
// @level: L1
// @tags: primitives, wrapping, euclidean, division, shift, saturating, overflowing
// @description: Tests for wrapping_shl/shr, wrapping_div/rem, div_euclid/rem_euclid, saturating_pow, overflowing_shl/shr

mount core.base.primitives.{Int8, Int16, Int32, Int64, Int128, UInt8, UInt16, UInt32, UInt64, UInt128, ISize, USize};

// =============================================================================
// Int - wrapping_shl / wrapping_shr
// =============================================================================

@test
fn test_int_wrapping_shl_basic() {
    assert_eq(1.wrapping_shl(0), 1);
    assert_eq(1.wrapping_shl(1), 2);
    assert_eq(1.wrapping_shl(10), 1024);
}

@test
fn test_int_wrapping_shl_wraps() {
    // Shift >= 64 wraps (modulo 64)
    assert_eq(1.wrapping_shl(64), 1);  // 64 % 64 = 0
    assert_eq(1.wrapping_shl(65), 2);  // 65 % 64 = 1
}

@test
fn test_int_wrapping_shr_basic() {
    assert_eq(1024.wrapping_shr(0), 1024);
    assert_eq(1024.wrapping_shr(10), 1);
}

@test
fn test_int_wrapping_shr_wraps() {
    assert_eq(1024.wrapping_shr(64), 1024);  // 64 % 64 = 0
}

// =============================================================================
// Int - wrapping_div / wrapping_rem
// =============================================================================

@test
fn test_int_wrapping_div_basic() {
    assert_eq(10.wrapping_div(3), 3);
    assert_eq(10.wrapping_div(2), 5);
    assert_eq((-10).wrapping_div(3), -3);
}

@test
fn test_int_wrapping_div_min_neg1() {
    // INT_MIN / -1 would overflow; wrapping returns MIN
    let min_val = -9223372036854775808;
    assert_eq(min_val.wrapping_div(-1), min_val);
}

@test
fn test_int_wrapping_rem_basic() {
    assert_eq(10.wrapping_rem(3), 1);
    assert_eq((-10).wrapping_rem(3), -1);
}

@test
fn test_int_wrapping_rem_min_neg1() {
    let min_val = -9223372036854775808;
    assert_eq(min_val.wrapping_rem(-1), 0);
}

// =============================================================================
// Int - div_euclid / rem_euclid
// =============================================================================

@test
fn test_int_div_euclid_positive() {
    assert_eq(7.div_euclid(3), 2);
    assert_eq(7.rem_euclid(3), 1);
}

@test
fn test_int_div_euclid_negative_dividend() {
    // -7 / 3 in truncated: -2 rem -1
    // -7 div_euclid 3: -3, rem_euclid: 2
    assert_eq((-7).div_euclid(3), -3);
    assert_eq((-7).rem_euclid(3), 2);
}

@test
fn test_int_div_euclid_negative_divisor() {
    assert_eq(7.div_euclid(-3), -2);
    assert_eq(7.rem_euclid(-3), 1);
}

@test
fn test_int_div_euclid_both_negative() {
    assert_eq((-7).div_euclid(-3), 3);
    assert_eq((-7).rem_euclid(-3), 2);
}

@test
fn test_int_rem_euclid_always_non_negative() {
    // Key property: rem_euclid always returns >= 0
    assert((-1).rem_euclid(5) >= 0);
    assert((-4).rem_euclid(3) >= 0);
    assert((-10).rem_euclid(7) >= 0);
}

// =============================================================================
// Int - saturating_pow
// =============================================================================

@test
fn test_int_saturating_pow_basic() {
    assert_eq(2.saturating_pow(10), 1024);
    assert_eq(3.saturating_pow(3), 27);
}

@test
fn test_int_saturating_pow_saturates_positive() {
    assert_eq(2.saturating_pow(63), 9223372036854775807);  // saturates to MAX
    assert_eq(10.saturating_pow(19), 9223372036854775807);
}

@test
fn test_int_saturating_pow_saturates_negative() {
    assert_eq((-2).saturating_pow(63), -9223372036854775808);  // saturates to MIN (odd exp)
    assert_eq((-2).saturating_pow(64), 9223372036854775807);   // saturates to MAX (even exp)
}

// =============================================================================
// Int - overflowing_shl / overflowing_shr
// =============================================================================

@test
fn test_int_overflowing_shl_no_overflow() {
    let pair = 1.overflowing_shl(10);
    assert_eq(pair.0, 1024);
    assert_eq(pair.1, false);
}

@test
fn test_int_overflowing_shl_overflow() {
    let pair = 1.overflowing_shl(64);
    assert_eq(pair.1, true);
}

@test
fn test_int_overflowing_shr_no_overflow() {
    let pair = 1024.overflowing_shr(10);
    assert_eq(pair.0, 1);
    assert_eq(pair.1, false);
}

@test
fn test_int_overflowing_shr_overflow() {
    let pair = 1024.overflowing_shr(64);
    assert_eq(pair.1, true);
}

// =============================================================================
// Sized type: Int8 - all new methods
// =============================================================================

@test
fn test_int8_wrapping_shl() {
    let one = 1 as Int8;
    assert(one.wrapping_shl(0).to_int() == 1);
    assert(one.wrapping_shl(6).to_int() == 64);
}

@test
fn test_int8_wrapping_div() {
    let ten = 10 as Int8;
    let three = 3 as Int8;
    assert(ten.wrapping_div(three).to_int() == 3);
}

@test
fn test_int8_div_euclid() {
    let neg = -7 as Int8;
    let pos = 3 as Int8;
    assert(neg.div_euclid(pos).to_int() == -3);
    assert(neg.rem_euclid(pos).to_int() == 2);
}

@test
fn test_int8_saturating_pow() {
    let two = 2 as Int8;
    assert(two.saturating_pow(6).to_int() == 64);
    assert(two.saturating_pow(7).to_int() == 127);  // saturates to MAX
}

@test
fn test_int8_overflowing_shl() {
    let one = 1 as Int8;
    let pair = one.overflowing_shl(3);
    assert(pair.0.to_int() == 8);
    assert_eq(pair.1, false);
    let pair2 = one.overflowing_shl(8);
    assert_eq(pair2.1, true);
}

// =============================================================================
// Sized type: UInt8 - all new methods
// =============================================================================

@test
fn test_uint8_wrapping_shl() {
    let one = 1 as UInt8;
    assert(one.wrapping_shl(0).to_int() == 1);
    assert(one.wrapping_shl(7).to_int() == 128);
}

@test
fn test_uint8_wrapping_div() {
    let ten = 10 as UInt8;
    let three = 3 as UInt8;
    assert(ten.wrapping_div(three).to_int() == 3);
}

@test
fn test_uint8_div_euclid() {
    let a = 7 as UInt8;
    let b = 3 as UInt8;
    assert(a.div_euclid(b).to_int() == 2);
    assert(a.rem_euclid(b).to_int() == 1);
}

@test
fn test_uint8_saturating_pow() {
    let two = 2 as UInt8;
    assert(two.saturating_pow(7).to_int() == 128);
    assert(two.saturating_pow(8).to_int() == 255);  // saturates to MAX
}

@test
fn test_uint8_overflowing_shl() {
    let one = 1 as UInt8;
    let pair = one.overflowing_shl(3);
    assert(pair.0.to_int() == 8);
    assert_eq(pair.1, false);
}

// =============================================================================
// Cross-type: all types have all methods
// =============================================================================

@test
fn test_all_have_wrapping_shl() {
    let _a = (1).wrapping_shl(0);
    let _b = 1_i8.wrapping_shl(0);
    let _c = 1_i16.wrapping_shl(0);
    let _d = 1_i32.wrapping_shl(0);
    let _e = 1_i64.wrapping_shl(0);
    let _f = (1 as Int128).wrapping_shl(0);
    let _g = 1_u8.wrapping_shl(0);
    let _h = 1_u16.wrapping_shl(0);
    let _i = 1_u32.wrapping_shl(0);
    let _j = 1_u64.wrapping_shl(0);
    let _k = (1 as UInt128).wrapping_shl(0);
    let _l = (1 as ISize).wrapping_shl(0);
    let _m = (1 as USize).wrapping_shl(0);
    assert_eq(_a, 1);
    assert(_b.to_int() == 1);
    assert(_c.to_int() == 1);
    assert(_d.to_int() == 1);
    assert(_e.to_int() == 1);
    assert(_f.to_int() == 1);
    assert(_g.to_int() == 1);
    assert(_h.to_int() == 1);
    assert(_i.to_int() == 1);
    assert(_j.to_int() == 1);
    assert(_k.to_int() == 1);
    assert(_l.to_int() == 1);
    assert(_m.to_int() == 1);
}

