// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: core, base, return, explicit, implicit
// @description: Tests for explicit and implicit return from functions

module specs.core.base.return_test;

mount core.base.maybe.{Maybe, Some, None};

fn extract_with_explicit_return(m: Maybe<Int>) -> Int {
    match m {
        Some(v) => {
            return v * 2;
        }
        None => {
            return 0;
        }
    }
}

fn extract_implicit(m: Maybe<Int>) -> Int {
    match m {
        Some(v) => v * 2,
        None => 0,
    }
}

@test
fn test_explicit_return_some() {
    let some_val: Maybe<Int> = Some(5);
    let result = extract_with_explicit_return(some_val);
    assert_eq(result, 10);
}

@test
fn test_explicit_return_none() {
    let none_val: Maybe<Int> = None;
    let result = extract_with_explicit_return(none_val);
    assert_eq(result, 0);
}

@test
fn test_implicit_return_some() {
    let some_val: Maybe<Int> = Some(5);
    let result = extract_implicit(some_val);
    assert_eq(result, 10);
}

@test
fn test_implicit_return_none() {
    let none_val: Maybe<Int> = None;
    let result = extract_implicit(none_val);
    assert_eq(result, 0);
}

// =============================================================================
// Section 2: Return from if/else
// =============================================================================

fn return_from_if(x: Int) -> Int {
    if x > 10 {
        return x * 2;
    } else {
        return x + 5;
    }
}

@test
fn test_return_from_if_true_branch() {
    assert_eq(return_from_if(20), 40);
}

@test
fn test_return_from_if_false_branch() {
    assert_eq(return_from_if(3), 8);
}

@test
fn test_return_from_if_boundary() {
    assert_eq(return_from_if(10), 15);
    assert_eq(return_from_if(11), 22);
}

// =============================================================================
// Section 3: Implicit return from if/else
// =============================================================================

fn implicit_if(x: Int) -> Int {
    if x > 0 { x } else { 0 - x }
}

@test
fn test_implicit_if_positive() {
    assert_eq(implicit_if(5), 5);
}

@test
fn test_implicit_if_negative() {
    assert_eq(implicit_if(-5), 5);
}

@test
fn test_implicit_if_zero() {
    assert_eq(implicit_if(0), 0);
}

// =============================================================================
// Section 4: Early return
// =============================================================================

fn early_return_guard(x: Int) -> Int {
    if x < 0 {
        return -1;
    }
    if x == 0 {
        return 0;
    }
    x * x
}

@test
fn test_early_return_negative() {
    assert_eq(early_return_guard(-10), -1);
}

@test
fn test_early_return_zero() {
    assert_eq(early_return_guard(0), 0);
}

@test
fn test_early_return_positive() {
    assert_eq(early_return_guard(5), 25);
}

// =============================================================================
// Section 5: Return Maybe/Result types
// =============================================================================

fn find_first_positive(a: Int, b: Int, c: Int) -> Maybe<Int> {
    if a > 0 { return Some(a); }
    if b > 0 { return Some(b); }
    if c > 0 { return Some(c); }
    None
}

@test
fn test_return_maybe_first() {
    let result = find_first_positive(5, 10, 15);
    assert(result.is_some());
    assert_eq(result.unwrap(), 5);
}

@test
fn test_return_maybe_second() {
    let result = find_first_positive(-1, 10, 15);
    assert(result.is_some());
    assert_eq(result.unwrap(), 10);
}

@test
fn test_return_maybe_third() {
    let result = find_first_positive(-1, -2, 15);
    assert(result.is_some());
    assert_eq(result.unwrap(), 15);
}

@test
fn test_return_maybe_none() {
    let result = find_first_positive(-1, -2, -3);
    assert(result.is_none());
}

// =============================================================================
// Section 6: Return from nested match
// =============================================================================

fn nested_match_return(outer: Maybe<Maybe<Int>>) -> Int {
    match outer {
        Some(inner) => {
            match inner {
                Some(v) => {
                    return v;
                }
                None => {
                    return -1;
                }
            }
        }
        None => {
            return -2;
        }
    }
}

@test
fn test_nested_match_some_some() {
    let val: Maybe<Maybe<Int>> = Some(Some(42));
    assert_eq(nested_match_return(val), 42);
}

@test
fn test_nested_match_some_none() {
    let val: Maybe<Maybe<Int>> = Some(None);
    assert_eq(nested_match_return(val), -1);
}

@test
fn test_nested_match_none() {
    let val: Maybe<Maybe<Int>> = None;
    assert_eq(nested_match_return(val), -2);
}

// =============================================================================
// Section 7: Return different types
// =============================================================================

fn return_text(x: Int) -> Text {
    if x > 0 {
        return "positive";
    }
    "non-positive"
}

fn return_bool(x: Int) -> Bool {
    if x == 0 {
        return true;
    }
    false
}

@test
fn test_return_text_positive() {
    assert_eq(return_text(1), "positive");
}

@test
fn test_return_text_non_positive() {
    assert_eq(return_text(-1), "non-positive");
}

@test
fn test_return_bool_true() {
    assert(return_bool(0));
}

@test
fn test_return_bool_false() {
    assert(!return_bool(5));
}

// =============================================================================
// Section 8: Return with computation
// =============================================================================

fn factorial_like(n: Int) -> Int {
    if n <= 1 {
        return 1;
    }
    n * factorial_like(n - 1)
}

@test
fn test_factorial_base() {
    assert_eq(factorial_like(0), 1);
    assert_eq(factorial_like(1), 1);
}

@test
fn test_factorial_recursive() {
    assert_eq(factorial_like(5), 120);
}

// =============================================================================
// Section 9: Return from while loop
// =============================================================================

fn find_in_while(target: Int) -> Maybe<Int> {
    let items = List.from([10, 20, 30, 40, 50]);
    let mut i = 0;
    while i < items.len() {
        if items[i] == target {
            return Some(i);
        }
        i = i + 1;
    }
    None
}

@test
fn test_return_from_while_found() {
    let result = find_in_while(30);
    assert(result.is_some());
    assert_eq(result.unwrap(), 2);
}

@test
fn test_return_from_while_not_found() {
    let result = find_in_while(99);
    assert(result.is_none());
}

// =============================================================================
// Section 10: Return from for loop
// =============================================================================

fn first_over_threshold(threshold: Int) -> Maybe<Int> {
    let items = List.from([1, 5, 12, 3, 25]);
    for item in items.iter() {
        if item > threshold {
            return Some(item);
        }
    }
    None
}

@test
fn test_return_from_for_found() {
    let result = first_over_threshold(10);
    assert(result.is_some());
    assert_eq(result.unwrap(), 12);
}

@test
fn test_return_from_for_none() {
    let result = first_over_threshold(100);
    assert(result.is_none());
}

// =============================================================================
// Section 11: Return Result type
// =============================================================================

fn safe_divide(a: Int, b: Int) -> Result<Int, Text> {
    if b == 0 {
        return Err("division by zero");
    }
    Ok(a / b)
}

@test
fn test_return_result_ok() {
    let result = safe_divide(10, 2);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 5);
}

@test
fn test_return_result_err() {
    let result = safe_divide(10, 0);
    assert(result.is_err());
}

// =============================================================================
// Section 12: Return unit (implicit)
// =============================================================================

fn do_nothing() {
    // Implicit unit return
}

fn return_unit_explicit() -> () {
    return ();
}

@test
fn test_return_unit_implicit() {
    let _result: () = do_nothing();
    // Typed binding confirms function returns ()
}

@test
fn test_return_unit_explicit() {
    let _result: () = return_unit_explicit();
    // Typed binding confirms function returns ()
}

// =============================================================================
// Section 13: Multiple early returns with guards
// =============================================================================

fn classify(x: Int) -> Text {
    if x < 0 { return "negative"; }
    if x == 0 { return "zero"; }
    if x < 10 { return "small"; }
    if x < 100 { return "medium"; }
    "large"
}

@test
fn test_classify_negative() {
    assert_eq(classify(-5), "negative");
}

@test
fn test_classify_zero() {
    assert_eq(classify(0), "zero");
}

@test
fn test_classify_small() {
    assert_eq(classify(5), "small");
}

@test
fn test_classify_medium() {
    assert_eq(classify(50), "medium");
}

@test
fn test_classify_large() {
    assert_eq(classify(200), "large");
}

// =============================================================================
// Section 14: Return from nested function calls
// =============================================================================

fn inner_helper(x: Int) -> Int {
    if x > 0 { return x * 10; }
    0
}

fn outer_caller(x: Int) -> Int {
    let inner_result = inner_helper(x);
    if inner_result > 100 {
        return inner_result;
    }
    inner_result + 1
}

@test
fn test_nested_return_large() {
    assert_eq(outer_caller(20), 200);
}

@test
fn test_nested_return_small() {
    assert_eq(outer_caller(5), 51);
}

@test
fn test_nested_return_zero() {
    assert_eq(outer_caller(0), 1);
}

// =============================================================================
// Section 15: Return Float and Text types
// =============================================================================

fn return_float(x: Int) -> Float {
    if x > 0 { return 3.14; }
    0.0
}

@test
fn test_return_float_positive() {
    assert_eq(return_float(1), 3.14);
}

@test
fn test_return_float_non_positive() {
    assert_eq(return_float(-1), 0.0);
}

fn return_list_len(items: List<Int>) -> Int {
    if items.len() == 0 {
        return -1;
    }
    items.len()
}

@test
fn test_return_list_len_empty() {
    let empty: List<Int> = List.new();
    assert_eq(return_list_len(empty), -1);
}

@test
fn test_return_list_len_nonempty() {
    let items = List.from([1, 2, 3]);
    assert_eq(return_list_len(items), 3);
}

// =============================================================================
// Section 16: Return from deeply nested blocks
// =============================================================================

fn deep_return(a: Int, b: Int, c: Int) -> Int {
    if a > 0 {
        if b > 0 {
            if c > 0 {
                return a + b + c;
            }
            return a + b;
        }
        return a;
    }
    0
}

@test
fn test_deep_return_all_positive() {
    assert_eq(deep_return(1, 2, 3), 6);
}

@test
fn test_deep_return_two_positive() {
    assert_eq(deep_return(1, 2, -1), 3);
}

@test
fn test_deep_return_one_positive() {
    assert_eq(deep_return(1, -1, -1), 1);
}

@test
fn test_deep_return_none_positive() {
    assert_eq(deep_return(-1, -1, -1), 0);
}

// =============================================================================
// Section 17: Return from while loops
// =============================================================================

fn first_positive(items: List<Int>) -> Int {
    let mut i = 0;
    while i < items.len() {
        if items[i] > 0 {
            return items[i];
        }
        i = i + 1;
    }
    -1
}

@test
fn test_return_from_while_found() {
    let items = List.from([-3, -1, 5, 10]);
    assert_eq(first_positive(items), 5);
}

@test
fn test_return_from_while_not_found() {
    let items = List.from([-3, -1, -5]);
    assert_eq(first_positive(items), -1);
}

@test
fn test_return_from_while_first_element() {
    let items = List.from([7, -1, -5]);
    assert_eq(first_positive(items), 7);
}

// =============================================================================
// Section 18: Return with arithmetic expressions
// =============================================================================

fn clamp_value(x: Int, lo: Int, hi: Int) -> Int {
    if x < lo {
        return lo;
    }
    if x > hi {
        return hi;
    }
    x
}

@test
fn test_return_clamp_below() {
    assert_eq(clamp_value(-5, 0, 100), 0);
}

@test
fn test_return_clamp_above() {
    assert_eq(clamp_value(200, 0, 100), 100);
}

@test
fn test_return_clamp_in_range() {
    assert_eq(clamp_value(50, 0, 100), 50);
}

@test
fn test_return_clamp_at_boundary() {
    assert_eq(clamp_value(0, 0, 100), 0);
    assert_eq(clamp_value(100, 0, 100), 100);
}

fn main() {
    // Tests run via @test annotations
}
