// SECTION 30: Flatten
// =============================================================================

@test
fn test_flatten_ok_ok() {
    let r: Result<Result<Int, Text>, Text> = Ok(Ok(42));
    let flat: Result<Int, Text> = r.flatten();
    assert(flat.is_ok());
    assert_eq(flat.unwrap_or(0), 42);
}

@test
fn test_flatten_ok_err() {
    let r: Result<Result<Int, Text>, Text> = Ok(Err("inner error"));
    let flat: Result<Int, Text> = r.flatten();
    assert(flat.is_err());
    assert_eq(flat.err().unwrap(), "inner error");
}

@test
fn test_flatten_err() {
    let r: Result<Result<Int, Text>, Text> = Err("outer error");
    let flat: Result<Int, Text> = r.flatten();
    assert(flat.is_err());
    assert_eq(flat.err().unwrap(), "outer error");
}

// =============================================================================
// SECTION 31: Additional Edge Cases
// =============================================================================

@test
fn test_map_or_else_both_cases() {
    let ok: Result<Int, Text> = Ok(10);
    let err: Result<Int, Text> = Err("fail");

    let ok_val: Text = ok.map_or_else(|e| f"err: {e}", |v| f"ok: {v}");
    let err_val: Text = err.map_or_else(|e| f"err: {e}", |v| f"ok: {v}");

    assert_eq(ok_val, "ok: 10");
    assert_eq(err_val, "err: fail");
}

@test
fn test_and_then_chain_type_change() {
    // and_then can change the Ok type
    let r: Result<Text, Text> = Ok("42");
    let parsed: Result<Int, Text> = r.and_then(|s| {
        // Simulate parsing
        if s == "42" { Ok(42) } else { Err("parse error") }
    });
    assert(parsed.is_ok());
    assert_eq(parsed.unwrap_or(0), 42);
}

@test
fn test_result_eq_exhaustive() {
    let ok1: Result<Int, Int> = Ok(1);
    let ok2: Result<Int, Int> = Ok(1);
    let ok3: Result<Int, Int> = Ok(2);
    let err1: Result<Int, Int> = Err(1);
    let err2: Result<Int, Int> = Err(1);
    let err3: Result<Int, Int> = Err(2);

    // Same variant, same value
    assert(ok1 == ok2);
    assert(err1 == err2);
    // Same variant, different value
    assert(ok1 != ok3);
    assert(err1 != err3);
    // Different variants
    assert(ok1 != err1);
    assert(err1 != ok1);
}

@test
fn test_result_inspect_chain() {
    let mut ok_count = 0;
    let mut err_count = 0;

    let r: Result<Int, Text> = Ok(42);
    let _ = r
        .inspect(|_| { ok_count = ok_count + 1; })
        .inspect_err(|_| { err_count = err_count + 1; })
        .map(|v| v * 2);

    assert_eq(ok_count, 1);
    assert_eq(err_count, 0);
}

@test
fn test_result_recover_chain() {
    // Chain recover operations
    let r: Result<Int, Text> = Err("error");
    let recovered: Int = r
        .map(|v| v * 2)
        .unwrap_or(0);
    assert_eq(recovered, 0);
}

@test
fn test_validated_zip_chain() {
    // Multiple zip_with accumulating errors
    let v1: Validated<Text, Int> = Validated.valid(10);
    let v2: Validated<Text, Int> = Validated.valid(20);
    let v3: Validated<Text, Int> = Validated.valid(30);

    let combined: Validated<Text, Int> = v1
        .zip_with(v2, |a, b| a + b)
        .zip_with(v3, |ab, c| ab + c);
    assert(combined.is_valid());
}

@test
fn test_validated_zip_chain_with_errors() {
    let v1: Validated<Text, Int> = Validated.invalid("error 1");
    let v2: Validated<Text, Int> = Validated.invalid("error 2");
    let v3: Validated<Text, Int> = Validated.invalid("error 3");

    let combined: Validated<Text, Int> = v1
        .zip_with(v2, |a, b| a + b)
        .zip_with(v3, |ab, c| ab + c);
    assert(combined.is_invalid());
    let errors = combined.errors();
    assert_eq(errors.len(), 3);
}

@test
fn test_exit_to_result_defect() {
    let e: Exit<Text, Int> = Exit.die("unexpected");
    let r: Result<Int, Text> = e.to_result();
    // Defect should also produce an error in to_result
    assert(r.is_err());
}

@test
fn test_cause_map_error() {
    let c: Cause<Int> = Cause.fail(42);
    let mapped: Cause<Text> = c.map_error(|i| f"error: {i}");
    let failures = mapped.failures();
    assert_eq(failures.len(), 1);
}

// =============================================================================
// Section: Transposition Tests
// =============================================================================

@test
fn test_transpose_result_ok_some() {
    let r: Result<Maybe<Int>, Text> = Ok(Some(42));
    let result = transpose_result(r);
    assert(result.is_some());
    let inner = result.unwrap();
    assert(inner.is_ok());
    assert_eq(inner.unwrap(), 42);
}

@test
fn test_transpose_result_ok_none() {
    let r: Result<Maybe<Int>, Text> = Ok(None);
    let result = transpose_result(r);
    assert(result.is_none());
}

@test
fn test_transpose_result_err() {
    let r: Result<Maybe<Int>, Text> = Err("fail");
    let result = transpose_result(r);
    assert(result.is_some());
    let inner = result.unwrap();
    assert(inner.is_err());
}

@test
fn test_transpose_maybe_some_ok() {
    let m: Maybe<Result<Int, Text>> = Some(Ok(42));
    let result = transpose_maybe(m);
    assert(result.is_ok());
    let inner = result.unwrap();
    assert(inner.is_some());
    assert_eq(inner.unwrap(), 42);
}

@test
fn test_transpose_maybe_some_err() {
    let m: Maybe<Result<Int, Text>> = Some(Err("fail"));
    let result = transpose_maybe(m);
    assert(result.is_err());
}

@test
fn test_transpose_maybe_none() {
    let m: Maybe<Result<Int, Text>> = None;
    let result = transpose_maybe(m);
    assert(result.is_ok());
    let inner = result.unwrap();
    assert(inner.is_none());
}

@test
fn test_transpose_roundtrip() {
    // transpose_result then transpose_maybe should roundtrip (for Ok(Some(v)) and Err(e))
    let original: Result<Maybe<Int>, Text> = Ok(Some(99));
    let transposed = transpose_result(original);
    let back = transpose_maybe(transposed);
    assert(back.is_ok());
    let maybe_val = back.unwrap();
    assert(maybe_val.is_some());
    assert_eq(maybe_val.unwrap(), 99);
}

