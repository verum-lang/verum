@test
fn test_defect_info_new() {
    let d = DefectInfo.new("unexpected state");
    assert_eq(d.message, "unexpected state");
    assert(d.location.is_none());
    assert(d.backtrace.is_none());
}

@test
fn test_defect_info_with_location() {
    let d = DefectInfo.new("bug")
        .with_location("src/main.vr:42");
    assert_eq(d.message, "bug");
    assert(d.location.is_some());
    assert_eq(d.location.unwrap(), "src/main.vr:42");
}

@test
fn test_defect_info_clone() {
    let d1 = DefectInfo.new("error").with_location("file.vr:1");
    let d2 = d1.clone();
    assert_eq(d1.message, d2.message);
}

// =============================================================================
// SECTION 24: Cause Type
// =============================================================================

@test
fn test_cause_fail() {
    let c: Cause<Text> = Cause.fail("error");
    assert(!c.is_empty());
    let failures = c.failures();
    assert_eq(failures.len(), 1);
}

@test
fn test_cause_die() {
    let c: Cause<Text> = Cause.die("bug");
    assert(!c.is_empty());
    let defects = c.defects();
    assert_eq(defects.len(), 1);
}

@test
fn test_cause_empty() {
    let c: Cause<Text> = Empty;
    assert(c.is_empty());
}

@test
fn test_cause_then() {
    let c1: Cause<Text> = Cause.fail("first");
    let c2: Cause<Text> = Cause.fail("second");
    let combined: Cause<Text> = c1.then(c2);
    assert(!combined.is_empty());
    let failures = combined.failures();
    assert_eq(failures.len(), 2);
}

@test
fn test_cause_both() {
    let c1: Cause<Text> = Cause.fail("error1");
    let c2: Cause<Text> = Cause.fail("error2");
    let combined: Cause<Text> = c1.both(c2);
    assert(!combined.is_empty());
    let failures = combined.failures();
    assert_eq(failures.len(), 2);
}

@test
fn test_cause_then_with_empty() {
    let c: Cause<Text> = Cause.fail("error");
    let empty: Cause<Text> = Empty;
    // then with Empty should return the non-empty cause
    let result: Cause<Text> = c.then(empty);
    let failures = result.failures();
    assert_eq(failures.len(), 1);
}

@test
fn test_cause_failures_mixed() {
    let c1: Cause<Text> = Cause.fail("error");
    let c2: Cause<Text> = Cause.die("defect");
    let combined: Cause<Text> = c1.then(c2);
    // failures() only returns Fail variants
    let failures = combined.failures();
    assert_eq(failures.len(), 1);
    // defects() only returns Die variants
    let defects = combined.defects();
    assert_eq(defects.len(), 1);
}

