// =============================================================================

@test
fn test_validated_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    assert(v.is_valid());
    assert(!v.is_invalid());
}

@test
fn test_validated_invalid_single() {
    let v: Validated<Text, Int> = Validated.invalid("error");
    assert(!v.is_valid());
    assert(v.is_invalid());
    let errors = v.errors();
    assert_eq(errors.len(), 1);
}

@test
fn test_validated_invalid_multiple() {
    let v: Validated<Text, Int> = Validated.invalid_all(["error1", "error2", "error3"]);
    assert(v.is_invalid());
    let errors = v.errors();
    assert_eq(errors.len(), 3);
}

@test
fn test_validated_map_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    let mapped: Validated<Text, Int> = v.map(|x| x * 2);
    assert(mapped.is_valid());
}

@test
fn test_validated_map_invalid() {
    let v: Validated<Text, Int> = Validated.invalid("error");
    let mapped: Validated<Text, Int> = v.map(|x| x * 2);
    assert(mapped.is_invalid());
}

@test
fn test_validated_from_result_ok() {
    let r: Result<Int, Text> = Ok(42);
    let v: Validated<Text, Int> = Validated.from_result(r);
    assert(v.is_valid());
}

@test
fn test_validated_from_result_err() {
    let r: Result<Int, Text> = Err("error");
    let v: Validated<Text, Int> = Validated.from_result(r);
    assert(v.is_invalid());
}

@test
fn test_validated_to_result_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    let r = v.to_result();
    assert(r is Ok);
}

@test
fn test_validated_to_result_invalid() {
    let v: Validated<Text, Int> = Validated.invalid_all(["e1", "e2"]);
    let r = v.to_result();
    assert(r is Err);
    let errors = r.err().unwrap();
    assert_eq(errors.len(), 2);
}

@test
fn test_validated_zip_with_both_valid() {
    let v1: Validated<Text, Int> = Validated.valid(10);
    let v2: Validated<Text, Int> = Validated.valid(20);
    let combined: Validated<Text, Int> = v1.zip_with(v2, |a, b| a + b);
    assert(combined.is_valid());
}

@test
fn test_validated_zip_with_first_invalid() {
    let v1: Validated<Text, Int> = Validated.invalid("error1");
    let v2: Validated<Text, Int> = Validated.valid(20);
    let combined: Validated<Text, Int> = v1.zip_with(v2, |a, b| a + b);
    assert(combined.is_invalid());
    let errors = combined.errors();
    assert_eq(errors.len(), 1);
}

@test
fn test_validated_zip_with_both_invalid_accumulates() {
    let v1: Validated<Text, Int> = Validated.invalid("error1");
    let v2: Validated<Text, Int> = Validated.invalid("error2");
    let combined: Validated<Text, Int> = v1.zip_with(v2, |a, b| a + b);
    assert(combined.is_invalid());
    let errors = combined.errors();
    // Both errors should be accumulated
    assert_eq(errors.len(), 2);
}

@test
fn test_validated_and_then_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    let result: Validated<Text, Int> = v.and_then(|x| {
        if x > 0 {
            Validated.valid(x * 2)
        } else {
            Validated.invalid("must be positive")
        }
    });
    assert(result.is_valid());
}

@test
fn test_validated_and_then_invalid_in_continuation() {
    let v: Validated<Text, Int> = Validated.valid(-1);
    let result: Validated<Text, Int> = v.and_then(|x| {
        if x > 0 {
            Validated.valid(x * 2)
        } else {
            Validated.invalid("must be positive")
        }
    });
    assert(result.is_invalid());
}

@test
fn test_validated_value_or_default_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    assert_eq(v.value_or_default(), 42);
}

@test
fn test_validated_value_or_default_invalid() {
    let v: Validated<Text, Int> = Validated.invalid("error");
    assert_eq(v.value_or_default(), 0);  // Int default
}

@test
fn test_validated_clone() {
    let v1: Validated<Text, Int> = Validated.valid(42);
    let v2: Validated<Text, Int> = v1.clone();
    assert(v2.is_valid());
}

// =============================================================================
// SECTION 26: Iteration (using .next() since ResultIter doesn't impl IntoIterator)
// =============================================================================

@test
fn test_iter_ok() {
    let r: Result<Int, Text> = Ok(42);
    let mut iter = r.iter();
    // First call should return Some with the value
    let first = iter.next();
    assert(first.is_some());
    assert_eq(*first.unwrap(), 42);
    // Second call should return None
    let second = iter.next();
    assert(second.is_none());
}

@test
fn test_iter_err() {
    let r: Result<Int, Text> = Err("error");
    let mut iter = r.iter();
    // First call should return None for Err
    let first = iter.next();
    assert(first.is_none());
}

@test
fn test_into_iter_ok() {
    let r: Result<Int, Text> = Ok(42);
    let mut iter = r.into_iter();
    // First call should return Some with the value
    let first = iter.next();
    assert(first.is_some());
    assert_eq(first.unwrap(), 42);
    // Second call should return None
    let second = iter.next();
    assert(second.is_none());
}

@test
fn test_into_iter_err() {
    let r: Result<Int, Text> = Err("error");
    let mut iter = r.into_iter();
    // First call should return None for Err
    let first = iter.next();
    assert(first.is_none());
}

// =============================================================================
// SECTION 27: map_err
// =============================================================================

@test
fn test_map_err_with_err() {
    let r: Result<Int, Text> = Err("error");
    let mapped: Result<Int, Int> = r.map_err(|e| e.len());
    assert(mapped.is_err());
    assert_eq(mapped.err().unwrap(), 5); // "error".len() = 5
}

@test
fn test_map_err_with_ok() {
    let r: Result<Int, Text> = Ok(42);
    let mapped: Result<Int, Int> = r.map_err(|e| e.len());
    assert(mapped.is_ok());
    assert_eq(mapped.unwrap_or(0), 42);
}

@test
fn test_map_err_transform_type() {
    let r: Result<Int, Int> = Err(404);
    let mapped: Result<Int, Text> = r.map_err(|code| f"Error code: {code}");
    assert(mapped.is_err());
    assert_eq(mapped.err().unwrap(), "Error code: 404");
}

@test
fn test_map_err_identity() {
    let r: Result<Int, Text> = Err("unchanged");
    let mapped: Result<Int, Text> = r.map_err(|e| e);
    assert(mapped.is_err());
    assert_eq(mapped.err().unwrap(), "unchanged");
}

// =============================================================================
// SECTION 28: Complex Chaining
// =============================================================================

@test
fn test_chain_map_and_then() {
    let r: Result<Int, Text> = Ok(5);
    let result: Result<Int, Text> = r
        .map(|v| v * 2)             // Ok(10)
        .and_then(|v| {
            if v > 5 { Ok(v + 100) } else { Err("too small") }
        });                          // Ok(110)
    assert(result.is_ok());
    assert_eq(result.unwrap_or(0), 110);
}

@test
fn test_chain_map_and_then_fail() {
    let r: Result<Int, Text> = Ok(2);
    let result: Result<Int, Text> = r
        .map(|v| v * 2)             // Ok(4)
        .and_then(|v| {
            if v > 5 { Ok(v + 100) } else { Err("too small") }
        });                          // Err("too small")
    assert(result.is_err());
    assert_eq(result.err().unwrap(), "too small");
}

@test
fn test_chain_or_else_recovery() {
    let r: Result<Int, Text> = Err("initial error");
    let result: Result<Int, Text> = r
        .or_else(|_| Err("second error"))
        .or_else(|_| Ok(42));        // Recover on second try
    assert(result.is_ok());
    assert_eq(result.unwrap_or(0), 42);
}

@test
fn test_chain_map_err_and_then() {
    let r: Result<Int, Int> = Err(404);
    let result: Result<Int, Text> = r
        .map_err(|code| f"HTTP {code}")
        .or_else(|e| {
            if e == "HTTP 404" { Ok(-1) } else { Err(e) }
        });
    assert(result.is_ok());
    assert_eq(result.unwrap_or(0), -1);
}

@test
fn test_chain_multiple_maps() {
    let r: Result<Int, Text> = Ok(2);
    let result: Result<Int, Text> = r
        .map(|v| v + 1)     // Ok(3)
        .map(|v| v * 3)     // Ok(9)
        .map(|v| v - 1);    // Ok(8)
    assert_eq(result.unwrap_or(0), 8);
}

@test
fn test_chain_and_then_sequence() {
    // Simulate a multi-step validation
    let input: Result<Int, Text> = Ok(50);
    let result: Result<Int, Text> = input
        .and_then(|v| {
            if v > 0 { Ok(v) } else { Err("must be positive") }
        })
        .and_then(|v| {
            if v <= 100 { Ok(v) } else { Err("must be <= 100") }
        })
        .and_then(|v| {
            if v % 2 == 0 { Ok(v / 2) } else { Err("must be even") }
        });
    assert(result.is_ok());
    assert_eq(result.unwrap_or(0), 25);
}

@test
fn test_chain_and_then_early_failure() {
    let input: Result<Int, Text> = Ok(-5);
    let result: Result<Int, Text> = input
        .and_then(|v| {
            if v > 0 { Ok(v) } else { Err("must be positive") }
        })
        .and_then(|v| {
            // Should not be reached
            Ok(v * 2)
        });
    assert(result.is_err());
    assert_eq(result.err().unwrap(), "must be positive");
}

// =============================================================================
// SECTION 29: Nested Context
// =============================================================================

@test
fn test_nested_context() {
    let r: Result<Int, Text> = Err("root cause");
    let result = r
        .context("layer 1")
        .context("layer 2");
    assert(result is Err);
    let outer = result.err().unwrap();
    assert_eq(*outer.message(), "layer 2");
    let inner = outer.source();
    assert_eq(*inner.message(), "layer 1");
    assert_eq(*inner.source(), "root cause");
}

@test
fn test_context_preserves_ok_through_layers() {
    let r: Result<Int, Text> = Ok(42);
    let result = r
        .context("layer 1")
        .context("layer 2");
    assert(result is Ok);
    assert_eq(result.unwrap_or(0), 42);
}

