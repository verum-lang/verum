    let text = format_debug(&val);
    assert(text.contains("Err"));
}

// =============================================================================
// Section 4: Formatter API - Direct Usage
// =============================================================================

@test
fn test_formatter_write_str() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    let result = f.write_str("hello");
    assert(result.is_ok());
    assert_eq(buf, "hello");
}

@test
fn test_formatter_write_str_multiple() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    f.write_str("hello");
    f.write_str(" ");
    f.write_str("world");
    assert_eq(buf, "hello world");
}

@test
fn test_formatter_write_char() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    f.write_char('H');
    f.write_char('i');
    assert_eq(buf, "Hi");
}

@test
fn test_formatter_write_int() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    f.write_int(42);
    assert_eq(buf, "42");
}

@test
fn test_formatter_write_int_negative() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    f.write_int(-99);
    assert_eq(buf, "-99");
}

@test
fn test_formatter_write_int_zero() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    f.write_int(0);
    assert_eq(buf, "0");
}

@test
fn test_formatter_write_float() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    f.write_float(3.14);
    assert(buf.len() > 0);
}

@test
fn test_formatter_mixed_writes() {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    f.write_str("value=");
    f.write_int(42);
    f.write_str(", ok=");
    f.write_str("true");
    assert_eq(buf, "value=42, ok=true");
}

// =============================================================================
// Section 5: Custom Type Display/Debug
// =============================================================================

type Color is {
    r: Byte,
    g: Byte,
    b: Byte,
};

implement Display for Color {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("rgb(")?;
        f.write_int(self.r as Int)?;
        f.write_str(", ")?;
        f.write_int(self.g as Int)?;
        f.write_str(", ")?;
        f.write_int(self.b as Int)?;
        f.write_str(")")
    }
}

implement Debug for Color {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("Color { r: ")?;
        f.write_int(self.r as Int)?;
        f.write_str(", g: ")?;
        f.write_int(self.g as Int)?;
        f.write_str(", b: ")?;
        f.write_int(self.b as Int)?;
        f.write_str(" }")
    }
}

@test
fn test_custom_display() {
    let c = Color { r: 255, g: 128, b: 0 };
    let text = format_display(&c);
    assert_eq(text, "rgb(255, 128, 0)");
}

@test
fn test_custom_debug() {
    let c = Color { r: 255, g: 128, b: 0 };
    let text = format_debug(&c);
    assert_eq(text, "Color { r: 255, g: 128, b: 0 }");
}

@test
fn test_custom_display_zero_values() {
    let c = Color { r: 0, g: 0, b: 0 };
    let text = format_display(&c);
    assert_eq(text, "rgb(0, 0, 0)");
}

// =============================================================================
// Section 6: Display vs Debug Difference
// =============================================================================

@test
fn test_display_vs_debug_char() {
    let val: Char = 'X';
    let disp = format_display(&val);
    let dbg = format_debug(&val);
    // Display just outputs the char, Debug wraps in quotes
    assert_eq(disp, "X");
    assert_eq(dbg, "'X'");
}

@test
fn test_display_vs_debug_text() {
    let val: Text = "hello";
    let disp = format_display(&val);
    let dbg = format_debug(&val);
    // Display outputs raw text, Debug wraps in double quotes
    assert_eq(disp, "hello");
    assert(dbg.starts_with("\""));
}

@test
fn test_display_vs_debug_bool() {
    let val: Bool = true;
    let disp = format_display(&val);
    let dbg = format_debug(&val);
    // Both should output "true" for Bool
    assert_eq(disp, "true");
    assert_eq(dbg, "true");
}

