// =============================================================================
// Section 10: Display for BTreeMap and BTreeSet (sorted, deterministic)
// =============================================================================

@test
fn test_display_btreemap_single() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 100);
    let text = format_display(&m);
    assert_eq(text, "{1: 100}");
}

@test
fn test_display_btreemap_multiple() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(3, 300);
    m.insert(1, 100);
    m.insert(2, 200);
    let text = format_display(&m);
    // BTreeMap iterates in sorted key order
    assert_eq(text, "{1: 100, 2: 200, 3: 300}");
}

@test
fn test_display_btreemap_empty() {
    let m: BTreeMap<Int, Int> = BTreeMap.new();
    let text = format_display(&m);
    assert_eq(text, "{}");
}

@test
fn test_display_btreeset_single() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(42);
    let text = format_display(&s);
    assert_eq(text, "{42}");
}

@test
fn test_display_btreeset_multiple() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(3);
    s.insert(1);
    s.insert(2);
    let text = format_display(&s);
    // BTreeSet iterates in sorted order
    assert_eq(text, "{1, 2, 3}");
}

@test
fn test_display_btreeset_empty() {
    let s: BTreeSet<Int> = BTreeSet.new();
    let text = format_display(&s);
    assert_eq(text, "{}");
}

// =============================================================================
// Section 11: Display for Hash Map and Set (single-element for determinism)
// =============================================================================

@test
fn test_display_map_single() {
    let mut m: Map<Int, Int> = Map.new();
    m.insert(1, 100);
    let text = format_display(&m);
    assert_eq(text, "{1: 100}");
}

@test
fn test_display_map_empty() {
    let m: Map<Int, Int> = Map.new();
    let text = format_display(&m);
    assert_eq(text, "{}");
}

@test
fn test_display_map_multiple_contains() {
    let mut m: Map<Int, Int> = Map.new();
    m.insert(1, 10);
    m.insert(2, 20);
    let text = format_display(&m);
    // Hash order not deterministic, check structure
    assert(text.starts_with("{"));
    assert(text.ends_with("}"));
    assert(text.contains("1: 10"));
    assert(text.contains("2: 20"));
}

@test
fn test_display_set_single() {
    let mut s: Set<Int> = Set.new();
    s.insert(42);
    let text = format_display(&s);
    assert_eq(text, "{42}");
}

@test
fn test_display_set_empty() {
    let s: Set<Int> = Set.new();
    let text = format_display(&s);
    assert_eq(text, "{}");
}

@test
fn test_display_set_multiple_contains() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    let text = format_display(&s);
    assert(text.starts_with("{"));
    assert(text.ends_with("}"));
    assert(text.contains("1"));
    assert(text.contains("2"));
    assert(text.contains("3"));
}

// =============================================================================
// Section 12: Display for BinaryHeap
// =============================================================================

@test
fn test_display_heap_single() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(42);
    let text = format_display(&h);
    assert_eq(text, "Heap[42]");
}

@test
fn test_display_heap_empty() {
    let h: BinaryHeap<Int> = BinaryHeap.new();
    let text = format_display(&h);
    assert_eq(text, "Heap[]");
}

@test
fn test_display_heap_multiple() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(5);
    h.push(3);
    let text = format_display(&h);
    // Heap order: max at front, but internal order varies
    assert(text.starts_with("Heap["));
    assert(text.ends_with("]"));
    assert(text.contains("5"));
    assert(text.contains("1"));
    assert(text.contains("3"));
}

