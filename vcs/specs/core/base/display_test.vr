// =============================================================================
// display_test.vr - Tests for Display and Debug protocol formatting
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: core, base, protocols, display, debug, formatting
// @description: Comprehensive tests for Display and Debug formatting of all
//               primitive types, custom types, and the Formatter API.
//
// Coverage:
// - Display protocol: Int, Float, Bool, Char, Byte, Text, Unit
// - Debug protocol: Int, Float, Bool, Char, Byte, Text, Maybe, Result
// - Formatter API: write_str, write_char, write_int, write_float
// - Helper functions: format_display, format_debug
// =============================================================================

module specs.core.base.display_test;

mount core.base.protocols.{Display, Debug, Eq, Clone};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.text.format.{
    Formatter, FormatSpec, FormatError, format_display, format_debug,
};
mount core.text.text.Text;
mount core.collections.list.List;
mount core.collections.map.Map;
mount core.collections.set.Set;
mount core.collections.deque.Deque;
mount core.collections.heap.BinaryHeap;
mount core.collections.btree.{BTreeMap, BTreeSet};

// =============================================================================
// Section 1: Display for Primitive Types via format_display
// =============================================================================

@test
fn test_display_int_positive() {
    let val: Int = 42;
    let text = format_display(&val);
    assert_eq(text, "42");
}

@test
fn test_display_int_negative() {
    let val: Int = -123;
    let text = format_display(&val);
    assert_eq(text, "-123");
}

@test
fn test_display_int_zero() {
    let val: Int = 0;
    let text = format_display(&val);
    assert_eq(text, "0");
}

@test
fn test_display_int_large() {
    let val: Int = 1000000;
    let text = format_display(&val);
    assert_eq(text, "1000000");
}

@test
fn test_display_float_simple() {
    let val: Float = 3.14;
    let text = format_display(&val);
    // Float formatting - just verify it contains the integral part
    assert(text.len() > 0);
}

@test
fn test_display_float_integer() {
    let val: Float = 42.0;
    let text = format_display(&val);
    assert(text.len() > 0);
}

@test
fn test_display_float_negative() {
    let val: Float = -2.5;
    let text = format_display(&val);
    assert(text.starts_with("-"));
}

@test
fn test_display_float_zero() {
    let val: Float = 0.0;
    let text = format_display(&val);
    assert(text.len() > 0);
}

@test
fn test_display_bool_true() {
    let val: Bool = true;
    let text = format_display(&val);
    assert_eq(text, "true");
}

@test
fn test_display_bool_false() {
    let val: Bool = false;
    let text = format_display(&val);
    assert_eq(text, "false");
}

@test
fn test_display_char_ascii() {
    let val: Char = 'A';
    let text = format_display(&val);
    assert_eq(text, "A");
}

@test
fn test_display_char_digit() {
    let val: Char = '7';
