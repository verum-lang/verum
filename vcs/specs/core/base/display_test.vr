}

@test
fn test_debug_maybe_none() {
    let val: Maybe<Int> = None;
    let text = format_debug(&val);
    assert_eq(text, "None");
}

@test
fn test_debug_result_ok() {
    let val: Result<Int, Text> = Ok(42);
    let text = format_debug(&val);
    assert(text.contains("Ok"));
    assert(text.contains("42"));
}

@test
fn test_debug_result_err() {
