}

// =============================================================================
// Section 2: Debug for Primitive Types via format_debug
// =============================================================================

@test
fn test_debug_int() {
    let val: Int = 42;
    let text = format_debug(&val);
    assert_eq(text, "42");
}

@test
fn test_debug_int_negative() {
    let val: Int = -99;
    let text = format_debug(&val);
    assert_eq(text, "-99");
}

@test
fn test_debug_float() {
    let val: Float = 3.14;
    let text = format_debug(&val);
    assert(text.len() > 0);
}

@test
fn test_debug_bool_true() {
    let val: Bool = true;
    let text = format_debug(&val);
    assert_eq(text, "true");
}

@test
fn test_debug_bool_false() {
    let val: Bool = false;
    let text = format_debug(&val);
    assert_eq(text, "false");
}

@test
fn test_debug_char_simple() {
    let val: Char = 'A';
    let text = format_debug(&val);
    // Debug for Char wraps in single quotes: 'A'
    assert_eq(text, "'A'");
}

@test
fn test_debug_char_newline() {
    let val: Char = '\n';
    let text = format_debug(&val);
    // Debug for Char escapes newline: '\n'
    assert_eq(text, "'\\n'");
}

@test
fn test_debug_char_tab() {
    let val: Char = '\t';
    let text = format_debug(&val);
    assert_eq(text, "'\\t'");
}

@test
fn test_debug_char_backslash() {
    let val: Char = '\\';
    let text = format_debug(&val);
    assert_eq(text, "'\\\\'");
}

@test
fn test_debug_char_single_quote() {
    let val: Char = '\'';
    let text = format_debug(&val);
    assert_eq(text, "'\\''");
}

@test
fn test_debug_byte() {
    let val: Byte = 0;
    let text = format_debug(&val);
    // Debug for Byte shows hex: 0x00
    assert_eq(text, "0x00");
}

@test
fn test_debug_byte_hex() {
    let val: Byte = 255;
    let text = format_debug(&val);
    assert_eq(text, "0xff");
}

@test
fn test_debug_byte_mid() {
    let val: Byte = 42;
    let text = format_debug(&val);
    assert_eq(text, "0x2a");
}

@test
fn test_debug_text() {
    let val: Text = "hello";
    let text = format_debug(&val);
    // Debug for Text wraps in double quotes
    assert(text.starts_with("\""));
    assert(text.ends_with("\""));
}

@test
fn test_debug_text_empty() {
    let val: Text = "";
    let text = format_debug(&val);
    assert_eq(text, "\"\"");
}

