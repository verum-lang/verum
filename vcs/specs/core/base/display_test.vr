// =============================================================================
// Section 14: Display vs Debug for collections
// =============================================================================

@test
fn test_display_vs_debug_list() {
    let mut list: List<Int> = List.new();
    list.push(1);
    list.push(2);
    let disp = format_display(&list);
    let dbg = format_debug(&list);
    // Display: [1, 2], Debug: List[1, 2] (or similar)
    assert_eq(disp, "[1, 2]");
    assert(dbg.len() > 0);
}

@test
fn test_display_vs_debug_btreemap() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 10);
    let disp = format_display(&m);
    let dbg = format_debug(&m);
    assert_eq(disp, "{1: 10}");
    assert_eq(dbg, "BTreeMap{1: 10}");
}

@test
fn test_display_vs_debug_btreeset() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(5);
    let disp = format_display(&s);
    let dbg = format_debug(&s);
    assert_eq(disp, "{5}");
    assert_eq(dbg, "BTreeSet{5}");
}

@test
fn test_display_vs_debug_maybe() {
    let val: Maybe<Int> = Some(99);
    let disp = format_display(&val);
    let dbg = format_debug(&val);
    assert_eq(disp, "Some(99)");
    assert(dbg.contains("Some"));
    assert(dbg.contains("99"));
}

@test
fn test_display_vs_debug_result() {
    let val: Result<Int, Text> = Ok(7);
    let disp = format_display(&val);
    let dbg = format_debug(&val);
    assert_eq(disp, "Ok(7)");
    assert(dbg.contains("Ok"));
    assert(dbg.contains("7"));
}

