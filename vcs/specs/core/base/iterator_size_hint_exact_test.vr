// SECTION 24: ExactSizeIterator for ZipIter
// =============================================================================

@test
fn test_zip_exact_size() {
    let iter = range(0, 5).zip(range(0, 3));
    assert_eq(iter.len(), 3);
}

@test
fn test_zip_exact_size_equal() {
    let iter = range(0, 4).zip(range(0, 4));
    assert_eq(iter.len(), 4);
}

// =============================================================================
// SECTION 25: ExactSizeIterator for StepByIter
// =============================================================================

@test
fn test_step_by_exact_size() {
    let iter = range(0, 10).step_by(3);
    assert_eq(iter.len(), 4); // ceil(10/3) = 4
}

@test
fn test_step_by_exact_size_exact() {
    let iter = range(0, 9).step_by(3);
    assert_eq(iter.len(), 3); // ceil(9/3) = 3
}

// =============================================================================
// SECTION 26: ExactSizeIterator for Rev
// =============================================================================

@test
fn test_rev_exact_size() {
    let iter = range(0, 5).rev();
    assert_eq(iter.len(), 5);
}

// =============================================================================
// SECTION 27: DoubleEndedIterator for EnumerateIter
// =============================================================================

@test
fn test_enumerate_next_back_basic() {
    let mut iter = range(0, 5).enumerate();
    // 0..5 enumerate: (0,0),(1,1),(2,2),(3,3),(4,4)
    assert_eq(iter.next_back(), Some((4, 4)));
    assert_eq(iter.next_back(), Some((3, 3)));
    assert_eq(iter.next_back(), Some((2, 2)));
    assert_eq(iter.next_back(), Some((1, 1)));
    assert_eq(iter.next_back(), Some((0, 0)));
    assert_eq(iter.next_back(), None);
}

@test
fn test_enumerate_mixed_front_back() {
    let mut iter = range(10, 15).enumerate();
    // (0,10),(1,11),(2,12),(3,13),(4,14)
    assert_eq(iter.next(), Some((0, 10)));
    assert_eq(iter.next_back(), Some((4, 14)));
    assert_eq(iter.next(), Some((1, 11)));
    assert_eq(iter.next_back(), Some((3, 13)));
    assert_eq(iter.next(), Some((2, 12)));
    assert_eq(iter.next(), None);
    assert_eq(iter.next_back(), None);
}

@test
fn test_enumerate_next_back_empty() {
    let mut iter = range(0, 0).enumerate();
    assert_eq(iter.next_back(), None);
}

@test
fn test_enumerate_rfold() {
    let result = range(0, 3).enumerate().rfold(0, |acc, pair| acc + pair.0);
    // Indices from back: 2,1,0 => 0+2+1+0 = 3
    assert_eq(result, 3);
}

// =============================================================================
// SECTION 28: DoubleEndedIterator for TakeIter
// =============================================================================

@test
fn test_take_next_back_basic() {
    let mut iter = range(0, 10).take(3);
    // take(3) from [0..10] yields 0,1,2
    // next_back: 2,1,0
    assert_eq(iter.next_back(), Some(2));
    assert_eq(iter.next_back(), Some(1));
    assert_eq(iter.next_back(), Some(0));
    assert_eq(iter.next_back(), None);
}

@test
fn test_take_next_back_exceeds() {
    let mut iter = range(0, 3).take(10);
    // Only 3 elements available
    assert_eq(iter.next_back(), Some(2));
    assert_eq(iter.next_back(), Some(1));
    assert_eq(iter.next_back(), Some(0));
    assert_eq(iter.next_back(), None);
}

@test
fn test_take_mixed_front_back() {
    let mut iter = range(0, 10).take(5);
    // Elements: 0,1,2,3,4
    assert_eq(iter.next(), Some(0));
    assert_eq(iter.next_back(), Some(4));
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next_back(), Some(3));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next(), None);
}

@test
fn test_take_next_back_zero() {
    let mut iter = range(0, 10).take(0);
    assert_eq(iter.next_back(), None);
}

// =============================================================================
// SECTION 29: DoubleEndedIterator for SkipIter
// =============================================================================

@test
fn test_skip_next_back_basic() {
    let mut iter = range(0, 10).skip(7);
    // Elements after skip: 7,8,9
    // next_back: 9,8,7
    assert_eq(iter.next_back(), Some(9));
    assert_eq(iter.next_back(), Some(8));
    assert_eq(iter.next_back(), Some(7));
    assert_eq(iter.next_back(), None);
}

@test
fn test_skip_next_back_exceeds() {
    let mut iter = range(0, 3).skip(10);
    // No elements after skip
    assert_eq(iter.next_back(), None);
}

@test
fn test_skip_mixed_front_back() {
    let mut iter = range(0, 10).skip(3);
    // Elements: 3,4,5,6,7,8,9
    assert_eq(iter.next(), Some(3));
    assert_eq(iter.next_back(), Some(9));
    assert_eq(iter.next(), Some(4));
    assert_eq(iter.next_back(), Some(8));
}

// =============================================================================
// SECTION 30: Cloned ExactSizeIterator
// =============================================================================

@test
fn test_cloned_exact_size() {
    let items: List<Int> = [1, 2, 3, 4, 5];
    let iter = items.iter().cloned();
    assert_eq(iter.len(), 5);
}

// =============================================================================
// SECTION 31: size_hint consistency checks
// =============================================================================

@test
fn test_size_hint_decreases_with_consumption() {
    let mut iter = range(0, 5).map(|x| x * 2);
    let (l1, u1) = iter.size_hint();
    assert_eq(l1, 5);
    assert_eq(u1, Some(5));

    let _ = iter.next();
    let (l2, u2) = iter.size_hint();
    assert_eq(l2, 4);
    assert_eq(u2, Some(4));

    let _ = iter.next();
    let (l3, u3) = iter.size_hint();
    assert_eq(l3, 3);
    assert_eq(u3, Some(3));
}

@test
fn test_chain_size_hint_decreases() {
    let mut iter = range(0, 3).chain(range(0, 2));
    assert_eq(iter.size_hint(), (5, Some(5)));

    let _ = iter.next();
    assert_eq(iter.size_hint(), (4, Some(4)));

    let _ = iter.next();
    assert_eq(iter.size_hint(), (3, Some(3)));
}

@test
fn test_zip_size_hint_correct() {
    let iter = range(0, 5).zip(range(0, 3));
    let (lower, upper) = iter.size_hint();
    assert_eq(lower, 3);
    assert_eq(upper, Some(3));
}

@test
fn test_enumerate_size_hint_matches_inner() {
    let iter = range(0, 7).enumerate();
    let (lower, upper) = iter.size_hint();
    assert_eq(lower, 7);
    assert_eq(upper, Some(7));
}

// =============================================================================
// SECTION 32: ExactSizeIterator len consistency with count
// =============================================================================

@test
fn test_exact_size_len_equals_count() {
    let iter = range(0, 10).map(|x| x + 1);
    let len = iter.len();
    let count = range(0, 10).map(|x| x + 1).count();
    assert_eq(len, count);
}

@test
fn test_take_len_equals_count() {
    let iter = range(0, 10).take(5);
    let len = iter.len();
    let count = range(0, 10).take(5).count();
    assert_eq(len, count);
}

@test
fn test_skip_len_equals_count() {
    let iter = range(0, 10).skip(3);
    let len = iter.len();
    let count = range(0, 10).skip(3).count();
    assert_eq(len, count);
}

@test
fn test_chain_len_equals_count() {
    let iter = range(0, 5).chain(range(0, 3));
    let len = iter.len();
    let count = range(0, 5).chain(range(0, 3)).count();
    assert_eq(len, count);
}

@test
fn test_zip_len_equals_count() {
    let iter = range(0, 5).zip(range(0, 3));
    let len = iter.len();
    let count = range(0, 5).zip(range(0, 3)).count();
    assert_eq(len, count);
}
