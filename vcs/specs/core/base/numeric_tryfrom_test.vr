// =============================================================================
// numeric_tryfrom_test.vr - TryFrom narrowing conversion tests
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: base, primitives, tryfrom, conversions, numeric
// @description: Tests for TryFrom<Int> narrowing conversions to sized integer types.
//               These are fundamental for production-quality numeric handling.
//               Verifies bounds checking for Int → Int8/Int16/Int32/UInt8/UInt16/UInt32/UInt64
//               and cross-sign conversions.
// =============================================================================

mount core.base.protocols.{TryFrom, Eq};
mount core.base.primitives.TryFromIntError;

// =============================================================================
// Section 1: TryFrom<Int> for Int8
// =============================================================================

@test
fn test_int_to_int8_valid_zero() {
    let result = Int8.try_from(0);
    assert(result.is_ok());
}

@test
fn test_int_to_int8_valid_positive() {
    let result = Int8.try_from(42);
    assert(result.is_ok());
}

@test
fn test_int_to_int8_valid_negative() {
    let result = Int8.try_from(-42);
    assert(result.is_ok());
}

@test
fn test_int_to_int8_max_boundary() {
    let result = Int8.try_from(127);
    assert(result.is_ok());
}

@test
fn test_int_to_int8_min_boundary() {
    let result = Int8.try_from(-128);
    assert(result.is_ok());
}

@test
fn test_int_to_int8_overflow_positive() {
    let result = Int8.try_from(128);
    assert(result.is_err());
}

@test
fn test_int_to_int8_overflow_negative() {
    let result = Int8.try_from(-129);
    assert(result.is_err());
}

@test
fn test_int_to_int8_large_overflow() {
    let result = Int8.try_from(1000);
    assert(result.is_err());
}

// =============================================================================
// Section 2: TryFrom<Int> for Int16
// =============================================================================

@test
fn test_int_to_int16_valid_zero() {
    let result = Int16.try_from(0);
    assert(result.is_ok());
}

@test
fn test_int_to_int16_valid() {
    let result = Int16.try_from(1000);
    assert(result.is_ok());
}

@test
fn test_int_to_int16_max_boundary() {
    let result = Int16.try_from(32767);
    assert(result.is_ok());
}

@test
fn test_int_to_int16_min_boundary() {
    let result = Int16.try_from(-32768);
    assert(result.is_ok());
}

@test
fn test_int_to_int16_overflow_positive() {
    let result = Int16.try_from(32768);
    assert(result.is_err());
}

@test
fn test_int_to_int16_overflow_negative() {
    let result = Int16.try_from(-32769);
    assert(result.is_err());
}

// =============================================================================
// Section 3: TryFrom<Int> for Int32
// =============================================================================

@test
fn test_int_to_int32_valid_zero() {
    let result = Int32.try_from(0);
    assert(result.is_ok());
}

@test
fn test_int_to_int32_valid() {
    let result = Int32.try_from(100000);
    assert(result.is_ok());
}

@test
fn test_int_to_int32_max_boundary() {
    let result = Int32.try_from(2147483647);
    assert(result.is_ok());
}

@test
fn test_int_to_int32_min_boundary() {
    let result = Int32.try_from(-2147483648);
    assert(result.is_ok());
}

@test
fn test_int_to_int32_overflow_positive() {
    let result = Int32.try_from(2147483648);
    assert(result.is_err());
}

@test
fn test_int_to_int32_overflow_negative() {
    let result = Int32.try_from(-2147483649);
    assert(result.is_err());
}

