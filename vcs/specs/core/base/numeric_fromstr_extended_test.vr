// =============================================================================
// Float64 FromStr
// =============================================================================

@test
fn test_float64_fromstr_integer() {
    let s = "42";
    let result = Float64.from_str(&s);
    assert(result is Ok);
}

@test
fn test_float64_fromstr_decimal() {
    let s = "3.14159";
    let result = Float64.from_str(&s);
    assert(result is Ok);
}

@test
fn test_float64_fromstr_negative() {
    let s = "-100.5";
    let result = Float64.from_str(&s);
    assert(result is Ok);
}

@test
fn test_float64_fromstr_scientific() {
    let s = "1.5e10";
    let result = Float64.from_str(&s);
    assert(result is Ok);
}

@test
fn test_float64_fromstr_invalid() {
    let s = "xyz";
    let result = Float64.from_str(&s);
    assert(result is Err);
}

// =============================================================================
// Cross-type consistency
// =============================================================================

@test
fn test_all_integer_fromstr_parse_42() {
    let s = "42";
    assert(Int64.from_str(&s) is Ok);
    assert(Int128.from_str(&s) is Ok);
    assert(UInt128.from_str(&s) is Ok);
    assert(ISize.from_str(&s) is Ok);
    assert(USize.from_str(&s) is Ok);
}

@test
fn test_all_float_fromstr_parse_pi() {
    let s = "3.14";
    assert(Float32.from_str(&s) is Ok);
    assert(Float64.from_str(&s) is Ok);
}

@test
fn test_empty_string_all_types() {
    let s = "";
    assert(Int64.from_str(&s) is Err);
    assert(Int128.from_str(&s) is Err);
    assert(UInt128.from_str(&s) is Err);
    assert(ISize.from_str(&s) is Err);
    assert(USize.from_str(&s) is Err);
    assert(Float32.from_str(&s) is Err);
    assert(Float64.from_str(&s) is Err);
}
