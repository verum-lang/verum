// @test: typecheck-pass
// @level: L1
// @tags: primitives, fromstr, parsing, int64, int128, uint128, isize, usize, float32, float64
// @description: Tests for FromStr protocol on Int64, Int128, UInt128, ISize, USize, Float32, Float64

mount core.base.primitives.{Int64, Int128, UInt128, ISize, USize, Float32, Float64};
mount core.base.protocols.{FromStr};

// =============================================================================
// Int64 FromStr
// =============================================================================

@test
fn test_int64_fromstr_valid() {
    let s = "42";
    let result = Int64.from_str(&s);
    assert(result is Ok);
}

@test
fn test_int64_fromstr_negative() {
    let s = "-100";
    let result = Int64.from_str(&s);
    assert(result is Ok);
}

@test
fn test_int64_fromstr_zero() {
    let s = "0";
    let result = Int64.from_str(&s);
    assert(result is Ok);
}

@test
fn test_int64_fromstr_invalid() {
    let s = "abc";
    let result = Int64.from_str(&s);
    assert(result is Err);
}

// =============================================================================
// Int128 FromStr
// =============================================================================

@test
fn test_int128_fromstr_valid() {
    let s = "42";
    let result = Int128.from_str(&s);
    assert(result is Ok);
}

@test
fn test_int128_fromstr_negative() {
    let s = "-999";
    let result = Int128.from_str(&s);
    assert(result is Ok);
}

@test
fn test_int128_fromstr_invalid() {
    let s = "not_a_number";
    let result = Int128.from_str(&s);
    assert(result is Err);
}

