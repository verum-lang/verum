// =============================================================================
// Float32 FromStr
// =============================================================================

@test
fn test_float32_fromstr_integer() {
    let s = "42";
    let result = Float32.from_str(&s);
    assert(result is Ok);
}

@test
fn test_float32_fromstr_decimal() {
    let s = "3.14";
    let result = Float32.from_str(&s);
    assert(result is Ok);
}

@test
fn test_float32_fromstr_negative() {
    let s = "-2.5";
    let result = Float32.from_str(&s);
    assert(result is Ok);
}

@test
fn test_float32_fromstr_invalid() {
    let s = "not_float";
    let result = Float32.from_str(&s);
    assert(result is Err);
