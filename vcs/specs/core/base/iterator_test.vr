// Section 21: Collect Tests
// =============================================================================

@test
fn test_collect_to_list() {
    let arr = [1, 2, 3, 4, 5];
    let list: List<Int> = arr.iter().map(|x| *x * 2).collect();
    assert_eq(list.len(), 5);
    assert_eq(list[0], 2);
    assert_eq(list[1], 4);
    assert_eq(list[2], 6);
    assert_eq(list[3], 8);
    assert_eq(list[4], 10);
}

@test
fn test_collect_filtered() {
    let arr = [1, 2, 3, 4, 5, 6, 7, 8];
    let evens: List<Int> = arr.iter().filter(|x| *x % 2 == 0).map(|x| *x).collect();
    assert_eq(evens.len(), 4);
    assert_eq(evens[0], 2);
    assert_eq(evens[3], 8);
}

@test
fn test_collect_empty() {
    let arr: [Int; 0] = [];
    let list: List<Int> = arr.iter().map(|x| *x).collect();
    assert_eq(list.len(), 0);
}

@test
fn test_collect_chained() {
    let a = [1, 2, 3];
    let b = [4, 5, 6];
    let combined: List<Int> = a.iter().chain(b.iter()).map(|x| *x).collect();
    assert_eq(combined.len(), 6);
    assert_eq(combined[0], 1);
    assert_eq(combined[5], 6);
}

// =============================================================================
// Section 22: Partition Tests
// =============================================================================

@test
fn test_partition_basic() {
    let arr = [1, 2, 3, 4, 5, 6];
    let (evens, odds): (List<Int>, List<Int>) = arr.iter().map(|x| *x).partition(|x| *x % 2 == 0);
    assert_eq(evens.len(), 3);
    assert_eq(odds.len(), 3);
    assert_eq(evens[0], 2);
    assert_eq(evens[1], 4);
    assert_eq(evens[2], 6);
    assert_eq(odds[0], 1);
    assert_eq(odds[1], 3);
    assert_eq(odds[2], 5);
}

@test
fn test_partition_all_match() {
    let arr = [2, 4, 6, 8];
    let (matched, rest): (List<Int>, List<Int>) = arr.iter().map(|x| *x).partition(|x| *x % 2 == 0);
    assert_eq(matched.len(), 4);
    assert_eq(rest.len(), 0);
}

@test
fn test_partition_none_match() {
    let arr = [1, 3, 5, 7];
    let (matched, rest): (List<Int>, List<Int>) = arr.iter().map(|x| *x).partition(|x| *x % 2 == 0);
    assert_eq(matched.len(), 0);
    assert_eq(rest.len(), 4);
}

@test
fn test_partition_empty() {
    let arr: [Int; 0] = [];
    let (a, b): (List<Int>, List<Int>) = arr.iter().map(|x| *x).partition(|x| *x > 0);
    assert_eq(a.len(), 0);
    assert_eq(b.len(), 0);
}

// =============================================================================
// Section 23: DoubleEndedIterator — rfold, rfind, rev
// =============================================================================

@test
fn test_rfold_basic() {
    let arr = [1, 2, 3, 4, 5];
    let sum = arr.iter().rfold(0, |acc, x| acc + *x);
    assert_eq(sum, 15);
}

@test
fn test_rfold_order() {
    // rfold processes right-to-left, so building a number should show reversed order
    let arr = [1, 2, 3];
    let result = arr.iter().rfold(0, |acc, x| acc * 10 + *x);
    // Right-to-left: start=0, process 3: 0*10+3=3, process 2: 3*10+2=32, process 1: 32*10+1=321
    assert_eq(result, 321);
}

@test
fn test_rfold_empty() {
    let arr: [Int; 0] = [];
    let result = arr.iter().rfold(42, |acc, x| acc + *x);
    assert_eq(result, 42);
}

@test
fn test_rfind_basic() {
    let arr = [1, 2, 3, 4, 5];
    // rfind finds the LAST element matching predicate (from right)
    let result = arr.iter().rfind(|x| *x % 2 == 0);
    let four = 4;
    assert_eq(result, Some(&four));
}

@test
fn test_rfind_not_found() {
    let arr = [1, 3, 5, 7];
    let result = arr.iter().rfind(|x| *x % 2 == 0);
    assert_eq(result, None);
}

@test
fn test_rfind_single() {
    let arr = [42];
    let result = arr.iter().rfind(|x| *x == 42);
    let val = 42;
    assert_eq(result, Some(&val));
}

@test
fn test_rev_basic() {
    let arr = [1, 2, 3, 4, 5];
    let mut iter = arr.iter().rev();
    let five = 5;
    let four = 4;
    let three = 3;
    assert_eq(iter.next(), Some(&five));
    assert_eq(iter.next(), Some(&four));
    assert_eq(iter.next(), Some(&three));
}

@test
fn test_rev_count() {
    let arr = [1, 2, 3, 4, 5];
    assert_eq(arr.iter().rev().count(), 5);
}

@test
fn test_rev_fold() {
    let arr = [1, 2, 3];
    // rev().fold is equivalent to rfold
    let result = arr.iter().rev().fold(0, |acc, x| acc * 10 + *x);
    // Reversed iteration: 3, 2, 1 → 0*10+3=3, 3*10+2=32, 32*10+1=321
    assert_eq(result, 321);
}

@test
fn test_rev_empty() {
    let arr: [Int; 0] = [];
    assert_eq(arr.iter().rev().count(), 0);
}

// =============================================================================
// Section 24: Peekable
// =============================================================================

@test
fn test_peekable_doesnt_consume() {
    let arr = [1, 2, 3];
    let mut iter = arr.iter().peekable();
    // peek should not consume the element
    let peeked = iter.peek();
    assert(peeked.is_some());
    // next should return the same element that was peeked
    let next_val = iter.next();
    assert(next_val.is_some());
}

@test
fn test_peekable_exhausted() {
    let arr = [1];
    let mut iter = arr.iter().peekable();
    let _ = iter.next(); // consume the only element
    let peeked = iter.peek();
    assert(peeked.is_none());
}

@test
fn test_peekable_iteration() {
    let arr = [1, 2, 3];
    let mut iter = arr.iter().peekable();
    // Use peekable as regular iterator
    let mut count = 0;
    loop {
        match iter.next() {
            Some(_) => { count = count + 1; },
            None => break,
        }
    }
    assert_eq(count, 3);
}

@test
fn test_peekable_peek_multiple_times() {
    let arr = [10, 20, 30];
    let mut iter = arr.iter().peekable();
    // Peeking multiple times should return same value
    let p1 = iter.peek();
    let p2 = iter.peek();
    assert(p1.is_some());
    assert(p2.is_some());
    // Now consume it
    let next_val = iter.next();
    assert(next_val.is_some());
    // Next peek should be different
    let p3 = iter.peek();
    assert(p3.is_some());
}

// =============================================================================
// Section 25: Cycle
// =============================================================================

@test
fn test_cycle_take() {
    let arr = [1, 2, 3];
    let mut iter = arr.iter().cycle().take(7);
    let one = 1;
    let two = 2;
    let three = 3;
    assert_eq(iter.next(), Some(&one));
    assert_eq(iter.next(), Some(&two));
    assert_eq(iter.next(), Some(&three));
    assert_eq(iter.next(), Some(&one));
    assert_eq(iter.next(), Some(&two));
    assert_eq(iter.next(), Some(&three));
    assert_eq(iter.next(), Some(&one));
    assert_eq(iter.next(), None);
}

@test
fn test_cycle_count() {
    let arr = [1, 2, 3];
    let count = arr.iter().cycle().take(10).count();
    assert_eq(count, 10);
}

@test
fn test_cycle_fold() {
    let arr = [1, 2, 3];
    // cycle [1,2,3] take 7: 1,2,3,1,2,3,1 → sum = 13
    let sum = arr.iter().cycle().take(7).fold(0, |acc, x| acc + *x);
    assert_eq(sum, 13);
}

