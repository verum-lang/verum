@test
fn test_max_by_key() {
    let arr = [-3, 1, -5, 4, 2];
    let result = arr.iter().map(|x| *x).max_by_key(|x| {
        if *x >= 0 { *x } else { 0 - *x }
    });
    assert_eq(result, Some(-5)); // |-5| = 5 is largest
}

@test
fn test_min_by_key() {
    let arr = [-3, 1, -5, 4, 2];
    let result = arr.iter().map(|x| *x).min_by_key(|x| {
        if *x >= 0 { *x } else { 0 - *x }
    });
    assert_eq(result, Some(1)); // |1| = 1 is smallest
}

@test
fn test_try_fold_success() {
    let arr = [1, 2, 3, 4, 5];
    let result = arr.iter().try_fold(0, |acc, x| Ok(acc + *x));
    assert_eq(result, Ok(15));
}

@test
fn test_try_fold_early_error() {
    let arr = [1, 2, 3, 4, 5];
    let result: Result<Int, Text> = arr.iter().try_fold(0, |acc, x| {
        if *x == 3 { Err("found 3") } else { Ok(acc + *x) }
    });
    assert(result.is_err());
}

@test
fn test_iterator_eq() {
    let a = [1, 2, 3];
    let b = [1, 2, 3];
    assert(a.iter().map(|x| *x).eq(b.iter().map(|x| *x)));
}

@test
fn test_iterator_eq_different() {
    let a = [1, 2, 3];
    let b = [1, 2, 4];
    assert(!a.iter().map(|x| *x).eq(b.iter().map(|x| *x)));
}

@test
fn test_iterator_eq_different_lengths() {
    let a = [1, 2, 3];
    let b = [1, 2];
    assert(!a.iter().map(|x| *x).eq(b.iter().map(|x| *x)));
}

