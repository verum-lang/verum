// =============================================================================
// SECTION: rfold
// =============================================================================

@test
fn test_rfold_concat() {
    let mut iter = range(1, 4);
    let result = iter.rfold("", |acc: Text, x: Int| f"{acc}{x}");
    assert_eq(result, "321"); // Reverse order
}

// =============================================================================
// SECTION: Iterator comparison with cmp and eq
// =============================================================================

@test
fn test_iterator_cmp_prefix() {
    // [1, 2] < [1, 2, 3] (shorter sequence is "less")
    let a = [1, 2];
    let b = [1, 2, 3];
    let ord = a.iter().cmp(b.iter());
    assert(ord is Less);
}

