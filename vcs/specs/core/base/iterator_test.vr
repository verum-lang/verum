@test
fn test_flatten_nested_lists() {
    let nested: List<List<Int>> = [];
    let mut a: List<Int> = [1, 2];
    let mut b: List<Int> = [3, 4];
    let mut outer: List<List<Int>> = [];
    outer.push(a);
    outer.push(b);
    let count = outer.into_iter().flatten().count();
    assert_eq(count, 4);
}

@test
fn test_flatten_empty_outer() {
    let outer: List<List<Int>> = [];
    let count = outer.into_iter().flatten().count();
    assert_eq(count, 0);
}

@test
fn test_flatten_single_inner() {
    let mut outer: List<List<Int>> = [];
    let inner: List<Int> = [1, 2, 3];
    outer.push(inner);
    let count = outer.into_iter().flatten().count();
    assert_eq(count, 3);
}

@test
fn test_flatten_with_empty_inners() {
    let mut outer: List<List<Int>> = [];
    let a: List<Int> = [1, 2];
    let b: List<Int> = [];
    let c: List<Int> = [3];
    outer.push(a);
    outer.push(b);
    outer.push(c);
    let count = outer.into_iter().flatten().count();
    assert_eq(count, 3);
}

@test
fn test_flatten_fold() {
    let mut outer: List<List<Int>> = [];
    let a: List<Int> = [1, 2];
    let b: List<Int> = [3, 4];
    outer.push(a);
    outer.push(b);
    let sum = outer.into_iter().flatten().fold(0, |acc, x| acc + x);
    assert_eq(sum, 10);
}

