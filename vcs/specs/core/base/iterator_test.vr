@test
fn test_from_fn() {
    let mut n = 0;
    let mut iter = from_fn(|| {
        if n < 3 {
            n = n + 1;
            Some(n * 10)
        } else {
            None
        }
    });
    assert_eq(iter.next(), Some(10));
    assert_eq(iter.next(), Some(20));
    assert_eq(iter.next(), Some(30));
    assert_eq(iter.next(), None);
}

@test
fn test_from_fn_count() {
    let mut n = 0;
    let count = from_fn(|| {
        if n < 4 {
            n = n + 1;
            Some(n)
        } else {
            None
        }
    }).count();
    assert_eq(count, 4);
}

