@test
fn test_range_basic() {
    let mut iter = range(0, 5);
    assert_eq(iter.next(), Some(0));
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next(), Some(3));
    assert_eq(iter.next(), Some(4));
    assert_eq(iter.next(), None);
}

@test
fn test_range_count() {
    assert_eq(range(0, 10).count(), 10);
}

@test
fn test_range_empty() {
    assert_eq(range(5, 5).count(), 0);
    assert_eq(range(5, 3).count(), 0);
}

@test
fn test_range_fold() {
    let sum = range(1, 6).fold(0, |acc, x| acc + x);
    assert_eq(sum, 15); // 1+2+3+4+5
}

@test
fn test_repeat_take() {
    let arr: List<Int> = repeat(42).take(5).collect();
    assert_eq(arr.len(), 5);
    assert_eq(arr[0], 42);
    assert_eq(arr[4], 42);
}

@test
fn test_empty_iterator() {
    let arr: [Int; 0] = [];
    let mut iter = arr.iter().take(0);
    assert_eq(iter.next(), None);
    assert_eq(iter.count(), 0);
}

@test
fn test_unfold_basic() {
    // Generate counting sequence using unfold
    let mut iter = unfold(0, |state| {
        let val = *state;
        if val < 5 {
            *state = val + 1;
            Some(val)
        } else {
            None
        }
    });
    assert_eq(iter.next(), Some(0));
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next(), Some(3));
    assert_eq(iter.next(), Some(4));
    assert_eq(iter.next(), None);
}

@test
fn test_successors_basic() {
    let mut iter = successors(Some(1), |x| {
        if *x < 16 { Some(*x * 2) } else { None }
    });
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next(), Some(4));
    assert_eq(iter.next(), Some(8));
    assert_eq(iter.next(), Some(16));
    assert_eq(iter.next(), None);
}

@test
fn test_successors_empty() {
    let first: Maybe<Int> = None;
    let mut iter = successors(first, |x| Some(*x + 1));
    assert_eq(iter.next(), None);
}

// =============================================================================
// Section 28: flat_map, inspect, cmp
// =============================================================================

@test
fn test_flat_map_basic() {
    let arr = [1, 2, 3];
    // flat_map each element to [x, x*10]
    let mut items: List<Int> = [];
    arr.iter().flat_map(|x| {
        let v = *x;
        let pair: List<Int> = [v, v * 10];
        pair.into_iter()
    }).for_each(|item| {
        items.push(item);
    });
    assert_eq(items.len(), 6);
    assert_eq(items[0], 1);
    assert_eq(items[1], 10);
    assert_eq(items[2], 2);
    assert_eq(items[3], 20);
}

@test
fn test_flat_map_count() {
    let arr = [1, 2, 3];
    let count = arr.iter().flat_map(|x| {
        let pair: List<Int> = [*x, *x * 10];
        pair.into_iter()
    }).count();
    assert_eq(count, 6);
}

@test
fn test_inspect_basic() {
    let arr = [1, 2, 3, 4, 5];
    let mut inspected_count = 0;
    let sum = arr.iter().inspect(|_x| {
        inspected_count = inspected_count + 1;
    }).fold(0, |acc, x| acc + *x);
    assert_eq(sum, 15);
    assert_eq(inspected_count, 5);
}

@test
fn test_inspect_with_filter() {
    let arr = [1, 2, 3, 4, 5];
    let mut pre_filter_count = 0;
    let mut post_filter_count = 0;
    let _ = arr.iter()
        .inspect(|_| { pre_filter_count = pre_filter_count + 1; })
        .filter(|x| *x % 2 == 0)
        .inspect(|_| { post_filter_count = post_filter_count + 1; })
        .count();
    assert_eq(pre_filter_count, 5);
    assert_eq(post_filter_count, 2);
}

@test
fn test_cmp_equal() {
    let a = [1, 2, 3];
    let b = [1, 2, 3];
    assert(a.iter().map(|x| *x).cmp(b.iter().map(|x| *x)) == Equal);
}

@test
fn test_cmp_less() {
    let a = [1, 2, 3];
    let b = [1, 2, 4];
    assert(a.iter().map(|x| *x).cmp(b.iter().map(|x| *x)) == Less);
}

@test
fn test_cmp_greater() {
    let a = [1, 2, 4];
    let b = [1, 2, 3];
    assert(a.iter().map(|x| *x).cmp(b.iter().map(|x| *x)) == Greater);
}

@test
fn test_cmp_shorter_is_less() {
    let a = [1, 2];
    let b = [1, 2, 3];
    assert(a.iter().map(|x| *x).cmp(b.iter().map(|x| *x)) == Less);
}

@test
fn test_cmp_longer_is_greater() {
    let a = [1, 2, 3];
    let b = [1, 2];
    assert(a.iter().map(|x| *x).cmp(b.iter().map(|x| *x)) == Greater);
}

@test
fn test_cmp_empty() {
    let a: [Int; 0] = [];
    let b: [Int; 0] = [];
    assert(a.iter().map(|x| *x).cmp(b.iter().map(|x| *x)) == Equal);
}

// =============================================================================
// Section 29: max_by, min_by
// =============================================================================

@test
fn test_max_by_basic() {
    let arr = [1, -5, 3, -2, 4];
    // max by absolute value
    let result = arr.iter().map(|x| *x).max_by(|a, b| {
        let abs_a = if *a >= 0 { *a } else { 0 - *a };
        let abs_b = if *b >= 0 { *b } else { 0 - *b };
        abs_a.cmp(&abs_b)
    });
    assert_eq(result, Some(-5)); // |-5| = 5 is largest
}

@test
fn test_min_by_basic() {
    let arr = [1, -5, 3, -2, 4];
    // min by absolute value
    let result = arr.iter().map(|x| *x).min_by(|a, b| {
        let abs_a = if *a >= 0 { *a } else { 0 - *a };
        let abs_b = if *b >= 0 { *b } else { 0 - *b };
        abs_a.cmp(&abs_b)
    });
    assert_eq(result, Some(1)); // |1| = 1 is smallest
}

// =============================================================================
// Section 30: Edge Cases and Exhaustion
// =============================================================================

@test
fn test_empty_iterator_operations() {
    let arr: [Int; 0] = [];
    // Verify all operations on empty iterators
    assert_eq(arr.iter().count(), 0);
    assert_eq(arr.iter().last(), None);
    assert_eq(arr.iter().find(|_| true), None);
    assert_eq(arr.iter().position(|_| true), None);
    assert_eq(arr.iter().map(|x| *x).min(), None);
    assert_eq(arr.iter().map(|x| *x).max(), None);
    assert_eq(arr.iter().map(|x| *x).reduce(|a, b| a + b), None);
    assert(arr.iter().all(|_| false)); // vacuously true
    assert(!arr.iter().any(|_| true)); // vacuously false
}

@test
fn test_single_element_all_operations() {
    let arr = [42];
    let val = 42;
    assert_eq(arr.iter().count(), 1);
    assert_eq(arr.iter().last(), Some(&val));
    assert_eq(arr.iter().find(|x| *x == 42), Some(&val));
    assert_eq(arr.iter().position(|x| *x == 42), Some(0));
    assert_eq(arr.iter().map(|x| *x).min(), Some(42));
    assert_eq(arr.iter().map(|x| *x).max(), Some(42));
    assert_eq(arr.iter().map(|x| *x).reduce(|a, b| a + b), Some(42));
}

@test
fn test_double_exhaustion() {
    let arr = [1, 2, 3];
    let mut iter = arr.iter();
    // Exhaust iterator
    while iter.next().is_some() {}
    // Calling next again should keep returning None
    assert_eq(iter.next(), None);
    assert_eq(iter.next(), None);
    assert_eq(iter.next(), None);
}

@test
fn test_range_double_ended() {
    let mut iter = range(1, 6);
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next_back(), Some(5));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next_back(), Some(4));
    assert_eq(iter.next(), Some(3));
    assert_eq(iter.next(), None);
    assert_eq(iter.next_back(), None);
}

@test
fn test_range_inclusive_double_ended() {
    let mut iter = range_inclusive(1, 5);
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next_back(), Some(5));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next_back(), Some(4));
    assert_eq(iter.next(), Some(3));
    assert_eq(iter.next(), None);
}

