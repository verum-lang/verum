// =============================================================================
// SECTION: Iterator.sum() / Iterator.product()
// =============================================================================

@test
fn test_iterator_sum() {
    let total: Int = range(1, 6).sum();
    assert_eq(total, 15); // 1+2+3+4+5
}

@test
fn test_iterator_sum_empty() {
    let total: Int = range(0, 0).sum();
    assert_eq(total, 0);
}

@test
fn test_iterator_product() {
    let result: Int = range(1, 6).product();
    assert_eq(result, 120); // 1*2*3*4*5
}

@test
fn test_iterator_product_empty() {
    let result: Int = range(0, 0).product();
    assert_eq(result, 1); // Multiplicative identity
}

@test
fn test_iterator_sum_mapped() {
    let total: Int = range(1, 4).map(|x| x * 10).sum();
    assert_eq(total, 60); // 10+20+30
}

// =============================================================================
// SECTION: DoubleEndedIterator.advance_back_by() / .nth_back()
// =============================================================================

@test
fn test_advance_back_by_basic() {
    let mut iter = range(0, 10);
    let result = iter.advance_back_by(3);
    assert(result.is_ok());
    assert_eq(iter.next_back(), Some(6)); // Skipped 7,8,9
}

@test
fn test_advance_back_by_too_far() {
    let mut iter = range(0, 3);
    let result = iter.advance_back_by(5);
    assert(result.is_err());
}

@test
fn test_advance_back_by_zero() {
    let mut iter = range(0, 5);
    let result = iter.advance_back_by(0);
    assert(result.is_ok());
    assert_eq(iter.next_back(), Some(4));
}

@test
fn test_nth_back_basic() {
    let mut iter = range(0, 10);
    // nth_back(0) = last element = 9
    assert_eq(iter.nth_back(0), Some(9));
    // nth_back(0) again = next from back = 8
    assert_eq(iter.nth_back(0), Some(8));
}

@test
fn test_nth_back_skip() {
    let mut iter = range(0, 10);
    // nth_back(2) = skip 2 from back, return 3rd = 7
    assert_eq(iter.nth_back(2), Some(7));
}

@test
fn test_nth_back_out_of_range() {
    let mut iter = range(0, 3);
    assert_eq(iter.nth_back(10), None);
}

// =============================================================================
// SECTION: unzip()
// =============================================================================

@test
fn test_unzip_basic() {
    let pairs = [(1, "a"), (2, "b"), (3, "c")];
    let (nums, strs) = unzip(pairs.iter().map(|p| (p.0, p.1)));
    assert_eq(nums.len(), 3);
    assert_eq(strs.len(), 3);
    assert_eq(nums[0], 1);
    assert_eq(nums[2], 3);
    assert_eq(strs[0], "a");
    assert_eq(strs[2], "c");
}

@test
fn test_unzip_empty() {
    let empty: [(Int, Int); 0] = [];
    let (a, b) = unzip(empty.iter().map(|p| (p.0, p.1)));
    assert(a.is_empty());
    assert(b.is_empty());
}

@test
fn test_unzip_single() {
    let pairs = [(42, true)];
    let (nums, bools) = unzip(pairs.iter().map(|p| (p.0, p.1)));
    assert_eq(nums.len(), 1);
    assert_eq(nums[0], 42);
    assert_eq(bools[0], true);
}

