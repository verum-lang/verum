// =============================================================================
// overflowing_mul
// =============================================================================

@test
fn test_int8_overflowing_mul_no_overflow() {
    let a = 5 as Int8;
    let b = 10 as Int8;
    let result = a.overflowing_mul(b);
    assert_eq(result.0.to_int(), 50);
    assert_eq(result.1, false);
}

@test
fn test_int8_overflowing_mul_overflow() {
    let a = 100 as Int8;
    let b = 2 as Int8;
    let result = a.overflowing_mul(b);
    // 100 * 2 = 200 > 127, overflows
    assert_eq(result.1, true);
}

@test
fn test_uint8_overflowing_mul_overflow() {
    let a = 200 as UInt8;
    let b = 2 as UInt8;
    let result = a.overflowing_mul(b);
    // 200 * 2 = 400 > 255, overflows
    assert_eq(result.1, true);
}

@test
fn test_int16_overflowing_mul() {
    let a = 100 as Int16;
    let result = a.overflowing_mul(100 as Int16);
    assert_eq(result.0.to_int(), 10000);
    assert_eq(result.1, false);
}

@test
fn test_uint16_overflowing_mul() {
    let a = 100 as UInt16;
    let result = a.overflowing_mul(100 as UInt16);
    assert_eq(result.0.to_int(), 10000);
    assert_eq(result.1, false);
}

@test
fn test_int32_overflowing_mul() {
    let a = 1000 as Int32;
    let result = a.overflowing_mul(1000 as Int32);
    assert_eq(result.0.to_int(), 1000000);
    assert_eq(result.1, false);
}

@test
fn test_uint32_overflowing_mul() {
    let a = 1000 as UInt32;
    let result = a.overflowing_mul(1000 as UInt32);
    assert_eq(result.0.to_int(), 1000000);
    assert_eq(result.1, false);
}

@test
fn test_int64_overflowing_mul() {
    let a = 100000 as Int64;
    let result = a.overflowing_mul(100 as Int64);
    assert_eq(result.0.to_int(), 10000000);
    assert_eq(result.1, false);
}

@test
fn test_uint64_overflowing_mul() {
    let a = 100000 as UInt64;
    let result = a.overflowing_mul(100 as UInt64);
    assert_eq(result.0.to_int(), 10000000);
    assert_eq(result.1, false);
}

@test
fn test_int128_overflowing_mul() {
    let a = 100 as Int128;
    let result = a.overflowing_mul(100 as Int128);
    assert_eq(result.0.to_int(), 10000);
    assert_eq(result.1, false);
}

@test
fn test_uint128_overflowing_mul() {
    let a = 100 as UInt128;
    let result = a.overflowing_mul(100 as UInt128);
    assert_eq(result.0.to_int(), 10000);
    assert_eq(result.1, false);
}

@test
fn test_isize_overflowing_mul() {
    let a = 42 as ISize;
    let result = a.overflowing_mul(10 as ISize);
    assert_eq(result.0.to_int(), 420);
    assert_eq(result.1, false);
}

@test
fn test_usize_overflowing_mul() {
    let a = 42 as USize;
    let result = a.overflowing_mul(10 as USize);
    assert_eq(result.0.to_int(), 420);
    assert_eq(result.1, false);
}

// =============================================================================
// reverse_bits
// =============================================================================

@test
fn test_int8_reverse_bits() {
    let val = 1 as Int8;
    let reversed = val.reverse_bits();
    // Reversing bits of 00000001 gives 10000000 = -128 for signed
    assert(reversed.to_int() != 1);
}

@test
fn test_int16_reverse_bits() {
    let val = 1 as Int16;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

@test
fn test_int32_reverse_bits() {
    let val = 1 as Int32;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

@test
fn test_int64_reverse_bits() {
    let val = 1 as Int64;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

@test
fn test_int128_reverse_bits() {
    let val = 1 as Int128;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

@test
fn test_isize_reverse_bits() {
    let val = 1 as ISize;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

@test
fn test_uint8_reverse_bits() {
    let val = 1 as UInt8;
    let reversed = val.reverse_bits();
    // 00000001 reversed = 10000000 = 128
    assert_eq(reversed.to_int(), 128);
}

@test
fn test_uint16_reverse_bits() {
    let val = 1 as UInt16;
    let reversed = val.reverse_bits();
    assert_eq(reversed.to_int(), 32768);
}

@test
fn test_uint32_reverse_bits() {
    let val = 1 as UInt32;
    let reversed = val.reverse_bits();
    // 2^31 = 2147483648
    assert(reversed.to_int() != 1);
}

@test
fn test_uint64_reverse_bits() {
    let val = 1 as UInt64;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

@test
fn test_uint128_reverse_bits() {
    let val = 1 as UInt128;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

@test
fn test_usize_reverse_bits() {
    let val = 1 as USize;
    let reversed = val.reverse_bits();
    assert(reversed.to_int() != 1);
}

// =============================================================================
// reverse_bits identity: reverse(reverse(x)) == x
// =============================================================================

@test
fn test_reverse_bits_double() {
    let val = 42 as UInt8;
    assert_eq(val.reverse_bits().reverse_bits().to_int(), 42);

    let val16 = 1234 as UInt16;
    assert_eq(val16.reverse_bits().reverse_bits().to_int(), 1234);

    let val32 = 12345 as Int32;
    assert_eq(val32.reverse_bits().reverse_bits().to_int(), 12345);
}

// =============================================================================
// base conversions
// =============================================================================

@test
fn test_int8_to_binary() {
    let val = 5 as Int8;
    let bin: Text = val.to_binary();
    assert_eq(bin, "101");
}

@test
fn test_int8_to_hex() {
    let val = 15 as Int8;
    let hex: Text = val.to_hex();
    assert_eq(hex, "f");
}

@test
fn test_int8_to_octal() {
    let val = 8 as Int8;
    let oct: Text = val.to_octal();
    assert_eq(oct, "10");
}

@test
fn test_int16_to_binary() {
    let val = 255 as Int16;
    let bin: Text = val.to_binary();
    assert_eq(bin, "11111111");
}

@test
fn test_uint8_to_hex() {
    let val = 255 as UInt8;
    let hex: Text = val.to_hex();
    assert_eq(hex, "ff");
}

@test
fn test_uint16_to_binary() {
    let val = 1000 as UInt16;
    let bin: Text = val.to_binary();
    assert_eq(bin, "1111101000");
}

@test
fn test_int32_to_hex() {
    let val = 256 as Int32;
    let hex: Text = val.to_hex();
    assert_eq(hex, "100");
}

@test
fn test_uint32_to_octal() {
    let val = 64 as UInt32;
    let oct: Text = val.to_octal();
    assert_eq(oct, "100");
}

@test
fn test_int64_to_binary() {
    let val = 1024 as Int64;
    let bin: Text = val.to_binary();
    assert_eq(bin, "10000000000");
}

@test
fn test_uint64_to_hex() {
    let val = 65535 as UInt64;
    let hex: Text = val.to_hex();
    assert_eq(hex, "ffff");
}

@test
fn test_int128_to_hex() {
    let val = 4096 as Int128;
    let hex: Text = val.to_hex();
    assert_eq(hex, "1000");
}

@test
fn test_uint128_to_binary() {
    let val = 7 as UInt128;
    let bin: Text = val.to_binary();
    assert_eq(bin, "111");
}

@test
fn test_isize_to_octal() {
    let val = 100 as ISize;
    let oct: Text = val.to_octal();
    assert_eq(oct, "144");
}

@test
fn test_usize_to_hex() {
    let val = 256 as USize;
    let hex: Text = val.to_hex();
    assert_eq(hex, "100");
}

@test
fn test_zero_conversions() {
    assert_eq((0 as Int8).to_binary(), "0");
    assert_eq((0 as UInt8).to_hex(), "0");
    assert_eq((0 as Int16).to_octal(), "0");
    assert_eq((0 as UInt16).to_binary(), "0");
}

@test
fn test_negative_to_binary() {
    let val = -1 as Int8;
    let bin: Text = val.to_binary();
    assert_eq(bin, "-1");
}

@test
fn test_negative_to_hex() {
    let val = -16 as Int16;
    let hex: Text = val.to_hex();
    assert_eq(hex, "-10");
}
