// @test: typecheck-pass
// @level: L1
// @tags: primitives, overflowing, arithmetic, sized-integers
// @description: Tests overflowing_add/sub/mul for all 12 sized integer types

mount core.base.primitives.{
    Int8, Int16, Int32, Int64, Int128, ISize,
    UInt8, UInt16, UInt32, UInt64, UInt128, USize
};

// =============================================================================
// overflowing_add
// =============================================================================

@test
fn test_int8_overflowing_add_no_overflow() {
    let a = 10 as Int8;
    let b = 20 as Int8;
    let result = a.overflowing_add(b);
    assert_eq(result.0.to_int(), 30);
    assert_eq(result.1, false);
}

@test
fn test_int8_overflowing_add_overflow() {
    let a = 127 as Int8;
    let b = 1 as Int8;
    let result = a.overflowing_add(b);
    // Overflow wraps: 127 + 1 = -128 in Int8
    assert_eq(result.1, true);
}

@test
fn test_int16_overflowing_add() {
    let a = 100 as Int16;
    let b = 200 as Int16;
    let result = a.overflowing_add(b);
    assert_eq(result.0.to_int(), 300);
    assert_eq(result.1, false);
}

@test
fn test_int32_overflowing_add() {
    let a = 1000 as Int32;
    let result = a.overflowing_add(2000 as Int32);
    assert_eq(result.0.to_int(), 3000);
    assert_eq(result.1, false);
}

@test
fn test_int64_overflowing_add() {
    let a = 100000 as Int64;
    let result = a.overflowing_add(200000 as Int64);
    assert_eq(result.0.to_int(), 300000);
    assert_eq(result.1, false);
}

@test
fn test_int128_overflowing_add() {
    let a = 100 as Int128;
    let result = a.overflowing_add(200 as Int128);
    assert_eq(result.0.to_int(), 300);
    assert_eq(result.1, false);
}

@test
fn test_isize_overflowing_add() {
    let a = 42 as ISize;
    let result = a.overflowing_add(58 as ISize);
    assert_eq(result.0.to_int(), 100);
    assert_eq(result.1, false);
}

@test
fn test_uint8_overflowing_add_no_overflow() {
    let a = 100 as UInt8;
    let b = 50 as UInt8;
    let result = a.overflowing_add(b);
    assert_eq(result.0.to_int(), 150);
    assert_eq(result.1, false);
}

@test
fn test_uint8_overflowing_add_overflow() {
    let a = 255 as UInt8;
    let b = 1 as UInt8;
    let result = a.overflowing_add(b);
    // 255 + 1 = 0 with overflow
    assert_eq(result.1, true);
}

@test
fn test_uint16_overflowing_add() {
    let a = 1000 as UInt16;
    let result = a.overflowing_add(2000 as UInt16);
    assert_eq(result.0.to_int(), 3000);
    assert_eq(result.1, false);
}

@test
fn test_uint32_overflowing_add() {
    let a = 100000 as UInt32;
    let result = a.overflowing_add(200000 as UInt32);
    assert_eq(result.0.to_int(), 300000);
    assert_eq(result.1, false);
}

@test
fn test_uint64_overflowing_add() {
    let a = 1000000 as UInt64;
    let result = a.overflowing_add(2000000 as UInt64);
    assert_eq(result.0.to_int(), 3000000);
    assert_eq(result.1, false);
}

@test
fn test_uint128_overflowing_add() {
    let a = 100 as UInt128;
    let result = a.overflowing_add(200 as UInt128);
    assert_eq(result.0.to_int(), 300);
    assert_eq(result.1, false);
}

@test
fn test_usize_overflowing_add() {
    let a = 42 as USize;
    let result = a.overflowing_add(58 as USize);
    assert_eq(result.0.to_int(), 100);
    assert_eq(result.1, false);
}

// =============================================================================
// overflowing_sub
// =============================================================================

@test
fn test_int8_overflowing_sub_no_overflow() {
    let a = 50 as Int8;
    let b = 20 as Int8;
    let result = a.overflowing_sub(b);
    assert_eq(result.0.to_int(), 30);
    assert_eq(result.1, false);
}

@test
fn test_int8_overflowing_sub_overflow() {
    let a = -128 as Int8;
    let b = 1 as Int8;
    let result = a.overflowing_sub(b);
    // -128 - 1 overflows to 127
    assert_eq(result.1, true);
}

@test
fn test_uint8_overflowing_sub_overflow() {
    let a = 0 as UInt8;
    let b = 1 as UInt8;
    let result = a.overflowing_sub(b);
    // 0 - 1 overflows for unsigned
    assert_eq(result.1, true);
}

@test
fn test_int16_overflowing_sub() {
    let a = 100 as Int16;
    let result = a.overflowing_sub(50 as Int16);
    assert_eq(result.0.to_int(), 50);
    assert_eq(result.1, false);
}

@test
fn test_uint16_overflowing_sub() {
    let a = 100 as UInt16;
    let result = a.overflowing_sub(50 as UInt16);
    assert_eq(result.0.to_int(), 50);
    assert_eq(result.1, false);
}

@test
fn test_int32_overflowing_sub() {
    let a = 1000 as Int32;
    let result = a.overflowing_sub(500 as Int32);
    assert_eq(result.0.to_int(), 500);
    assert_eq(result.1, false);
}

@test
fn test_uint32_overflowing_sub() {
    let a = 1000 as UInt32;
    let result = a.overflowing_sub(500 as UInt32);
    assert_eq(result.0.to_int(), 500);
    assert_eq(result.1, false);
}

@test
fn test_int64_overflowing_sub() {
    let a = 100000 as Int64;
    let result = a.overflowing_sub(50000 as Int64);
    assert_eq(result.0.to_int(), 50000);
    assert_eq(result.1, false);
}

@test
fn test_uint64_overflowing_sub() {
    let a = 100000 as UInt64;
    let result = a.overflowing_sub(50000 as UInt64);
    assert_eq(result.0.to_int(), 50000);
    assert_eq(result.1, false);
}

@test
fn test_int128_overflowing_sub() {
    let a = 100 as Int128;
    let result = a.overflowing_sub(50 as Int128);
    assert_eq(result.0.to_int(), 50);
    assert_eq(result.1, false);
}

@test
fn test_uint128_overflowing_sub() {
    let a = 100 as UInt128;
    let result = a.overflowing_sub(50 as UInt128);
    assert_eq(result.0.to_int(), 50);
    assert_eq(result.1, false);
}

@test
fn test_isize_overflowing_sub() {
    let a = 100 as ISize;
    let result = a.overflowing_sub(50 as ISize);
    assert_eq(result.0.to_int(), 50);
    assert_eq(result.1, false);
}

@test
fn test_usize_overflowing_sub() {
    let a = 100 as USize;
    let result = a.overflowing_sub(50 as USize);
    assert_eq(result.0.to_int(), 50);
    assert_eq(result.1, false);
