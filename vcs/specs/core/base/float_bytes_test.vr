// =============================================================================
// Section 8: Float32 — ne_bytes and endianness
// =============================================================================

@test
fn test_float32_ne_bytes_roundtrip() {
    let val = 42.0 as Float32;
    let bytes = val.to_ne_bytes();
    let restored = Float32.from_ne_bytes(bytes);
    assert_eq(restored, 42.0 as Float32);
}

@test
fn test_float32_produces_4_bytes() {
    let val = 1.0 as Float32;
    let le = val.to_le_bytes();
    let be = val.to_be_bytes();
    assert_eq(le.len(), 4);
    assert_eq(be.len(), 4);
}

@test
fn test_float32_le_be_reversed() {
    let val = 1.0 as Float32;
    let le = val.to_le_bytes();
    let be = val.to_be_bytes();
    assert_eq(le[0], be[3]);
    assert_eq(le[1], be[2]);
    assert_eq(le[2], be[1]);
    assert_eq(le[3], be[0]);
}

@test
fn test_float32_zero_bytes() {
    let val = 0.0 as Float32;
    let le = val.to_le_bytes();
    assert_eq(le[0], 0 as Byte);
    assert_eq(le[1], 0 as Byte);
    assert_eq(le[2], 0 as Byte);
    assert_eq(le[3], 0 as Byte);
}

@test
fn test_float32_bits_consistency() {
    let val = 1.0 as Float32;
    let bits = val.to_bits();
    let restored_bits = Float32.from_le_bytes(val.to_le_bytes()).to_bits();
    assert_eq(bits, restored_bits);
}

