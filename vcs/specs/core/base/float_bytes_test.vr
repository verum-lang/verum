// =============================================================================
// Section 12: Cross-type consistency
// =============================================================================

@test
fn test_float_float64_same_bytes() {
    // Float and Float64 are both 64-bit, their byte representations should match
    let f = 42.5;
    let f64_val = 42.5 as Float64;
    let f_le = f.to_le_bytes();
    let f64_le = f64_val.to_le_bytes();
    assert_eq(f_le[0], f64_le[0]);
    assert_eq(f_le[1], f64_le[1]);
    assert_eq(f_le[2], f64_le[2]);
    assert_eq(f_le[3], f64_le[3]);
    assert_eq(f_le[4], f64_le[4]);
    assert_eq(f_le[5], f64_le[5]);
    assert_eq(f_le[6], f64_le[6]);
    assert_eq(f_le[7], f64_le[7]);
}

@test
fn test_float_float64_same_be_bytes() {
    let f = 1.0;
    let f64_val = 1.0 as Float64;
    let f_be = f.to_be_bytes();
    let f64_be = f64_val.to_be_bytes();
    assert_eq(f_be[0], f64_be[0]);
    assert_eq(f_be[1], f64_be[1]);
    assert_eq(f_be[2], f64_be[2]);
    assert_eq(f_be[3], f64_be[3]);
    assert_eq(f_be[4], f64_be[4]);
    assert_eq(f_be[5], f64_be[5]);
    assert_eq(f_be[6], f64_be[6]);
    assert_eq(f_be[7], f64_be[7]);
}

@test
fn test_cross_type_from_le_bytes() {
    // Same LE bytes should produce same value across Float and Float64
    let val = 99.99;
    let le = val.to_le_bytes();
    let from_float = Float.from_le_bytes(le);
    let from_float64 = Float64.from_le_bytes(le);
    assert_eq(from_float, 99.99);
    assert_eq(from_float64, 99.99 as Float64);
}

@test
fn test_float32_smaller_than_float64() {
    // Float32 uses 4 bytes, Float/Float64 use 8 bytes
    let f32_val = 1.0 as Float32;
    let f64_val = 1.0;
    let f32_bytes = f32_val.to_le_bytes();
    let f64_bytes = f64_val.to_le_bytes();
    assert_eq(f32_bytes.len(), 4);
    assert_eq(f64_bytes.len(), 8);
}

// =============================================================================
// Section 13: Special values
// =============================================================================

@test
fn test_float_infinity_bytes_roundtrip() {
    let val = Float.infinity();
    let bytes = val.to_le_bytes();
    let restored = Float.from_le_bytes(bytes);
    assert(restored.is_infinite());
    assert(restored > 0.0);
}

@test
fn test_float_neg_infinity_bytes_roundtrip() {
    let val = Float.neg_infinity();
    let bytes = val.to_be_bytes();
    let restored = Float.from_be_bytes(bytes);
    assert(restored.is_infinite());
    assert(restored < 0.0);
}

@test
fn test_float_nan_bytes_roundtrip() {
    let val = Float.nan();
    let bytes = val.to_le_bytes();
    let restored = Float.from_le_bytes(bytes);
    assert(restored.is_nan());
}

@test
fn test_float32_infinity_bytes_roundtrip() {
    let val = Float32.infinity();
    let bytes = val.to_le_bytes();
    let restored = Float32.from_le_bytes(bytes);
    assert(restored.is_infinite());
}

@test
fn test_float32_nan_bytes_roundtrip() {
    let val = Float32.nan();
    let bytes = val.to_be_bytes();
    let restored = Float32.from_be_bytes(bytes);
    assert(restored.is_nan());
}

@test
fn test_float64_infinity_bytes_roundtrip() {
    let val = Float64.infinity();
    let bytes = val.to_le_bytes();
    let restored = Float64.from_le_bytes(bytes);
    assert(restored.is_infinite());
}

@test
fn test_float64_nan_bytes_roundtrip() {
    let val = Float64.nan();
    let bytes = val.to_ne_bytes();
    let restored = Float64.from_ne_bytes(bytes);
    assert(restored.is_nan());
}
