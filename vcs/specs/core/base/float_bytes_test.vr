// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: core, base, float, bytes, conversion
// @description: Tests byte conversion methods for Float, Float32, Float64:
//               to_le_bytes, to_be_bytes, from_le_bytes, from_be_bytes,
//               to_ne_bytes, from_ne_bytes

mount core.*;

// =============================================================================
// Section 1: Float — to_le_bytes / from_le_bytes roundtrip
// =============================================================================

@test
fn test_float_le_bytes_roundtrip_zero() {
    let val = 0.0;
    let bytes = val.to_le_bytes();
    let restored = Float.from_le_bytes(bytes);
    assert_eq(restored, 0.0);
}

@test
fn test_float_le_bytes_roundtrip_one() {
    let val = 1.0;
    let bytes = val.to_le_bytes();
    let restored = Float.from_le_bytes(bytes);
    assert_eq(restored, 1.0);
}

@test
fn test_float_le_bytes_roundtrip_negative() {
    let val = -42.5;
    let bytes = val.to_le_bytes();
    let restored = Float.from_le_bytes(bytes);
    assert_eq(restored, -42.5);
}

@test
fn test_float_le_bytes_roundtrip_pi() {
    let val = 3.141592653589793;
    let bytes = val.to_le_bytes();
    let restored = Float.from_le_bytes(bytes);
    assert_eq(restored, 3.141592653589793);
}

@test
fn test_float_le_bytes_roundtrip_small() {
    let val = 0.001;
    let bytes = val.to_le_bytes();
    let restored = Float.from_le_bytes(bytes);
    assert_eq(restored, 0.001);
}

