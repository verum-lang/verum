// =============================================================================
// Section 4: Float — endianness consistency
// =============================================================================

@test
fn test_float_le_be_produce_8_bytes() {
    let val = 42.0;
    let le = val.to_le_bytes();
    let be = val.to_be_bytes();
    // Both should be 8 bytes for 64-bit float
    assert_eq(le.len(), 8);
    assert_eq(be.len(), 8);
}

@test
fn test_float_le_be_bytes_are_reversed() {
    let val = 1.0;
    let le = val.to_le_bytes();
    let be = val.to_be_bytes();
    // LE and BE should be byte-reversed of each other
    assert_eq(le[0], be[7]);
    assert_eq(le[1], be[6]);
    assert_eq(le[2], be[5]);
    assert_eq(le[3], be[4]);
    assert_eq(le[4], be[3]);
    assert_eq(le[5], be[2]);
    assert_eq(le[6], be[1]);
    assert_eq(le[7], be[0]);
}

@test
fn test_float_ne_equals_le_on_little_endian() {
    // On little-endian systems (x86/ARM), ne == le
    let val = 42.5;
    let ne = val.to_ne_bytes();
    let le = val.to_le_bytes();
    assert_eq(ne[0], le[0]);
    assert_eq(ne[1], le[1]);
    assert_eq(ne[2], le[2]);
    assert_eq(ne[3], le[3]);
    assert_eq(ne[4], le[4]);
    assert_eq(ne[5], le[5]);
    assert_eq(ne[6], le[6]);
    assert_eq(ne[7], le[7]);
}

// =============================================================================
// Section 5: Float — bits consistency
// =============================================================================

@test
fn test_float_bytes_bits_consistency() {
    let val = 1.0;
    let bits = val.to_bits();
    let le_bytes = val.to_le_bytes();
    // Verify the byte representation matches the bit pattern
    let restored_bits = Float.from_le_bytes(le_bytes).to_bits();
    assert_eq(bits, restored_bits);
}

@test
fn test_float_zero_bytes() {
    let val = 0.0;
    let le = val.to_le_bytes();
    // IEEE 754: +0.0 is all zeros
    assert_eq(le[0], 0 as Byte);
    assert_eq(le[1], 0 as Byte);
    assert_eq(le[2], 0 as Byte);
    assert_eq(le[3], 0 as Byte);
    assert_eq(le[4], 0 as Byte);
    assert_eq(le[5], 0 as Byte);
    assert_eq(le[6], 0 as Byte);
    assert_eq(le[7], 0 as Byte);
}

