// =============================================================================
// maybe_intoiter_test.vr - Tests for Maybe IntoIterator
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: base, maybe, intoiterator, core
// @description: Tests for Maybe<T> IntoIterator protocol implementation
// =============================================================================

mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: IntoIterator for Maybe - basic
// =============================================================================

@test
fn test_maybe_some_into_iter() {
    let val: Maybe<Int> = Some(42);
    let mut count = 0;
    let mut sum = 0;
    for x in val {
        count = count + 1;
        sum = sum + x;
    }
    assert_eq(count, 1);
    assert_eq(sum, 42);
}

@test
fn test_maybe_none_into_iter() {
    let val: Maybe<Int> = None;
    let mut count = 0;
    for x in val {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_maybe_some_text_into_iter() {
    let val: Maybe<Text> = Some("hello");
    let mut found = false;
    for x in val {
        assert_eq(x, "hello");
        found = true;
    }
    assert(found);
}

// =============================================================================
// Section 2: MaybeIter properties
// =============================================================================

@test
fn test_maybe_iter_size_hint_some() {
    let val: Maybe<Int> = Some(10);
    let iter = val.iter();
    let hint = iter.size_hint();
    assert_eq(hint.0, 1);
    assert_eq(hint.1, Some(1));
}

@test
fn test_maybe_iter_size_hint_none() {
    let val: Maybe<Int> = None;
    let iter = val.iter();
    let hint = iter.size_hint();
    assert_eq(hint.0, 0);
    assert_eq(hint.1, Some(0));
}

@test
fn test_maybe_iter_next() {
    let val: Maybe<Int> = Some(5);
    let mut iter = val.iter();
    assert_eq(*iter.next().unwrap(), 5);
    assert(iter.next().is_none());
}

@test
fn test_maybe_iter_mut_some() {
    let mut val: Maybe<Int> = Some(10);
    for x in val.iter_mut() {
        *x = 20;
    }
    assert_eq(val.unwrap(), 20);
}

@test
fn test_maybe_iter_mut_none() {
    let mut val: Maybe<Int> = None;
    let mut count = 0;
    for x in val.iter_mut() {
        count = count + 1;
    }
    assert_eq(count, 0);
    assert(val.is_none());
}

// =============================================================================
// Section 3: Using IntoIterator with iterator adapters
// =============================================================================

@test
fn test_maybe_into_iter_collect() {
    let val: Maybe<Int> = Some(42);
    let items: List<Int> = val.into_iter().collect();
    assert_eq(items.len(), 1);
    assert_eq(items[0], 42);
}

@test
fn test_maybe_none_into_iter_collect() {
    let val: Maybe<Int> = None;
    let items: List<Int> = val.into_iter().collect();
    assert(items.is_empty());
}

@test
fn test_maybe_into_iter_map() {
    let val: Maybe<Int> = Some(5);
    let doubled: List<Int> = val.into_iter().map(|x| x * 2).collect();
    assert_eq(doubled.len(), 1);
    assert_eq(doubled[0], 10);
}

@test
fn test_maybe_into_iter_filter() {
    let val: Maybe<Int> = Some(5);
    let filtered: List<Int> = val.into_iter().filter(|x| *x > 10).collect();
    assert(filtered.is_empty());
}

@test
fn test_maybe_into_iter_filter_pass() {
    let val: Maybe<Int> = Some(15);
    let filtered: List<Int> = val.into_iter().filter(|x| *x > 10).collect();
    assert_eq(filtered.len(), 1);
    assert_eq(filtered[0], 15);
}

// =============================================================================
// Main
// =============================================================================

fn main() {
    // Tests run via @test annotations
}
