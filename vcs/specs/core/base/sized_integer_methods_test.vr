    let val = 1 as UInt16;
    let rotated = val.rotate_left(4);
    assert_eq(rotated, 16);
}

@test
fn test_uint16_rotate_right() {
    let val = 16 as UInt16;
    let rotated = val.rotate_right(4);
    assert_eq(rotated, 1);
}

// =============================================================================
// ISize — full method suite (all new)
// =============================================================================

@test
fn test_isize_abs_positive() {
    let val = 42 as ISize;
    assert_eq(val.abs(), 42 as ISize);
}

@test
fn test_isize_abs_negative() {
    let val = 0 as ISize;
    let neg = val - (42 as ISize);
    let result = neg.abs();
    assert_eq(result, 42 as ISize);
}

@test
fn test_isize_signum_positive() {
    let val = 100 as ISize;
    assert_eq(val.signum(), 1 as ISize);
}

@test
fn test_isize_signum_zero() {
    let val = 0 as ISize;
    assert_eq(val.signum(), 0 as ISize);
}

@test
fn test_isize_min() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    assert_eq(a.min(b), 10 as ISize);
}

@test
fn test_isize_max() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    assert_eq(a.max(b), 20 as ISize);
}

@test
fn test_isize_clamp() {
    let val = 100 as ISize;
    let result = val.clamp(0 as ISize, 50 as ISize);
    assert_eq(result, 50 as ISize);
}

@test
fn test_isize_clamp_within() {
    let val = 25 as ISize;
    let result = val.clamp(0 as ISize, 50 as ISize);
    assert_eq(result, 25 as ISize);
}

@test
fn test_isize_checked_add_normal() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    let result = a.checked_add(b);
    assert(result is Some);
}

@test
fn test_isize_checked_sub_normal() {
    let a = 20 as ISize;
    let b = 10 as ISize;
    let result = a.checked_sub(b);
    assert(result is Some);
}

@test
fn test_isize_checked_mul_normal() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    let result = a.checked_mul(b);
    assert(result is Some);
}

@test
fn test_isize_wrapping_add() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    let result = a.wrapping_add(b);
    assert_eq(result, 30 as ISize);
}

@test
fn test_isize_wrapping_sub() {
    let a = 30 as ISize;
    let b = 10 as ISize;
    let result = a.wrapping_sub(b);
    assert_eq(result, 20 as ISize);
}

@test
fn test_isize_wrapping_mul() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    let result = a.wrapping_mul(b);
    assert_eq(result, 200 as ISize);
}

@test
fn test_isize_saturating_add() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    let result = a.saturating_add(b);
    assert_eq(result, 30 as ISize);
}

@test
fn test_isize_saturating_sub() {
    let a = 30 as ISize;
    let b = 10 as ISize;
    let result = a.saturating_sub(b);
    assert_eq(result, 20 as ISize);
}

@test
fn test_isize_saturating_mul() {
    let a = 10 as ISize;
    let b = 20 as ISize;
    let result = a.saturating_mul(b);
    assert_eq(result, 200 as ISize);
}

@test
fn test_isize_leading_zeros() {
    let val = 1 as ISize;
    let lz = val.leading_zeros();
    assert(lz == 63);
}

@test
fn test_isize_trailing_zeros() {
    let val = 8 as ISize;
    let tz = val.trailing_zeros();
    assert(tz == 3);
}

@test
fn test_isize_count_ones() {
    let val = 7 as ISize;
    let ones = val.count_ones();
    assert(ones == 3);
}

@test
fn test_isize_count_zeros() {
    let val = 0 as ISize;
    let zeros = val.count_zeros();
    assert(zeros == 64);
}

@test
fn test_isize_count_consistency() {
    let val = 42 as ISize;
    let ones = val.count_ones();
    let zeros = val.count_zeros();
    assert_eq(ones + zeros, 64);
}

@test
fn test_isize_rotate_left() {
    let val = 1 as ISize;
    let rotated = val.rotate_left(8);
    assert_eq(rotated, 256 as ISize);
}

@test
fn test_isize_rotate_right() {
    let val = 256 as ISize;
    let rotated = val.rotate_right(8);
    assert_eq(rotated, 1 as ISize);
}

@test
fn test_isize_swap_bytes() {
    let val = 1 as ISize;
    let swapped = val.swap_bytes();
    // On 64-bit: 0x0100000000000000
    assert(swapped != 1 as ISize);
}

@test
fn test_isize_to_int() {
    let val = 42 as ISize;
    let result = val.to_int();
    assert_eq(result, 42);
}

