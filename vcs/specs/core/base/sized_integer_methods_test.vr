fn test_uint16_trailing_zeros() {
    let val = 16 as UInt16;  // 0b10000
    let tz = val.trailing_zeros();
    assert(tz == 4);
}

@test
fn test_uint16_trailing_zeros_one() {
    let val = 1 as UInt16;
    let tz = val.trailing_zeros();
    assert(tz == 0);
}

