// @test: typecheck-pass
// @level: L1
// @tags: sized-integers, methods, consistency
// @description: Tests for consistency gap fills in sized integer methods:
//   Int16: checked_mul, saturating_mul, leading_zeros, trailing_zeros, count_ones, count_zeros, rotate_left, rotate_right
//   Int32: wrapping_mul, saturating_mul, count_zeros
//   Int64: wrapping_mul, saturating_mul, count_zeros
//   Int128: wrapping_mul, saturating_mul, count_zeros, rotate_left, rotate_right
//   UInt16: leading_zeros, trailing_zeros, count_ones, count_zeros, rotate_left, rotate_right
//   ISize: full method suite (abs, signum, min, max, clamp, checked_*, wrapping_*, saturating_*, bit ops)
//   USize: full method suite (min, max, clamp, checked_*, wrapping_*, saturating_*, bit ops)

mount core.base.{Maybe, Eq, Ord, Clone, Default, Debug, Display};

// =============================================================================
// Int16 — newly added methods
// =============================================================================

@test
fn test_int16_checked_mul_normal() {
    let a = 10 as Int16;
    let b = 20 as Int16;
    let result = a.checked_mul(b);
    assert(result is Some);
}

@test
fn test_int16_checked_mul_overflow() {
    let a = 32767 as Int16;  // Int16.MAX
    let b = 2 as Int16;
    let result = a.checked_mul(b);
    assert(result is None);
}

@test
fn test_int16_checked_mul_zero() {
    let a = 0 as Int16;
    let b = 32767 as Int16;
    let result = a.checked_mul(b);
    assert(result is Some);
}

@test
fn test_int16_saturating_mul_normal() {
    let a = 10 as Int16;
    let b = 20 as Int16;
    let result = a.saturating_mul(b);
    assert_eq(result, 200 as Int16);
}

@test
fn test_int16_saturating_mul_overflow() {
    let a = 32767 as Int16;
    let b = 2 as Int16;
    let result = a.saturating_mul(b);
    assert_eq(result, 32767 as Int16);  // Saturates to MAX
}

@test
fn test_int16_leading_zeros() {
    let val = 1 as Int16;
    let lz = val.leading_zeros();
    assert(lz == 15);
}

@test
fn test_int16_leading_zeros_zero() {
    let val = 0 as Int16;
    let lz = val.leading_zeros();
    assert(lz == 16);
}

@test
fn test_int16_trailing_zeros() {
    let val = 8 as Int16;  // 0b1000
    let tz = val.trailing_zeros();
    assert(tz == 3);
}

@test
fn test_int16_trailing_zeros_one() {
    let val = 1 as Int16;
    let tz = val.trailing_zeros();
    assert(tz == 0);
}

@test
fn test_int16_count_ones() {
    let val = 7 as Int16;  // 0b0111
    let ones = val.count_ones();
    assert(ones == 3);
}

@test
fn test_int16_count_ones_max() {
    let val = 32767 as Int16;  // all 15 lower bits set
    let ones = val.count_ones();
    assert(ones == 15);
}

@test
fn test_int16_count_zeros() {
    let val = 0 as Int16;
    let zeros = val.count_zeros();
    assert(zeros == 16);
}

@test
fn test_int16_count_zeros_all_ones() {
    // -1 as Int16 = 0xFFFF = all bits set
    let val = 32767 as Int16;
    let ones = val.count_ones();
    let zeros = val.count_zeros();
    assert_eq(ones + zeros, 16);
}

@test
fn test_int16_rotate_left() {
    let val = 1 as Int16;
    let rotated = val.rotate_left(4);
    assert_eq(rotated, 16);
}

@test
fn test_int16_rotate_right() {
    let val = 16 as Int16;  // 0b10000
    let rotated = val.rotate_right(4);
    assert_eq(rotated, 1);
}

// =============================================================================
// Int32 — newly added methods
// =============================================================================

@test
fn test_int32_wrapping_mul_normal() {
    let a = 100 as Int32;
    let b = 200 as Int32;
    let result = a.wrapping_mul(b);
    assert_eq(result, 20000 as Int32);
}

@test
fn test_int32_wrapping_mul_overflow() {
    let a = 2147483647 as Int32;  // Int32.MAX
    let b = 2 as Int32;
    let result = a.wrapping_mul(b);
    // Wraps around — result is -2
    assert(result != 2147483647 as Int32);
}

@test
fn test_int32_saturating_mul_normal() {
    let a = 100 as Int32;
    let b = 200 as Int32;
    let result = a.saturating_mul(b);
    assert_eq(result, 20000 as Int32);
}

@test
fn test_int32_saturating_mul_overflow() {
    let a = 2147483647 as Int32;
    let b = 2 as Int32;
    let result = a.saturating_mul(b);
    assert_eq(result, 2147483647 as Int32);  // Saturates to MAX
}

@test
fn test_int32_count_zeros() {
    let val = 0 as Int32;
    let zeros = val.count_zeros();
    assert(zeros == 32);
}

@test
fn test_int32_count_zeros_consistency() {
    let val = 255 as Int32;  // 8 ones
    let ones = val.count_ones();
    let zeros = val.count_zeros();
    assert_eq(ones + zeros, 32);
}

// =============================================================================
// Int64 — newly added methods
// =============================================================================

@test
fn test_int64_wrapping_mul_normal() {
    let a = 1000 as Int64;
    let b = 2000 as Int64;
    let result = a.wrapping_mul(b);
    assert_eq(result, 2000000 as Int64);
}

@test
fn test_int64_wrapping_mul_overflow() {
    let a = 9223372036854775807 as Int64;  // Int64.MAX
    let b = 2 as Int64;
    let result = a.wrapping_mul(b);
    assert(result != 9223372036854775807 as Int64);  // Wrapped
}

@test
fn test_int64_saturating_mul_normal() {
    let a = 1000 as Int64;
    let b = 2000 as Int64;
    let result = a.saturating_mul(b);
    assert_eq(result, 2000000 as Int64);
}

@test
fn test_int64_saturating_mul_overflow() {
    let a = 9223372036854775807 as Int64;
    let b = 2 as Int64;
    let result = a.saturating_mul(b);
    assert_eq(result, 9223372036854775807 as Int64);  // Saturates to MAX
}

@test
fn test_int64_count_zeros() {
    let val = 0 as Int64;
    let zeros = val.count_zeros();
    assert(zeros == 64);
}

@test
fn test_int64_count_zeros_consistency() {
    let val = 42 as Int64;
    let ones = val.count_ones();
    let zeros = val.count_zeros();
    assert_eq(ones + zeros, 64);
}

