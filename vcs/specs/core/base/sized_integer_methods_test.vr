// =============================================================================
// Cross-type consistency checks
// =============================================================================

@test
fn test_all_signed_have_count_zeros() {
    // Verify count_zeros exists and is consistent for all signed types
    let i16_zeros = 0_i16.count_zeros();
    let i32_zeros = 0_i32.count_zeros();
    let i64_zeros = 0_i64.count_zeros();
    let i128_zeros = (0 as Int128).count_zeros();
    let isize_zeros = (0 as ISize).count_zeros();

    assert_eq(i16_zeros, 16);
    assert_eq(i32_zeros, 32);
    assert_eq(i64_zeros, 64);
    assert_eq(i128_zeros, 128);
    assert_eq(isize_zeros, 64);
}

@test
fn test_all_unsigned_have_count_zeros() {
    let u16_zeros = 0_u16.count_zeros();
    let u32_zeros = 0_u32.count_zeros();
    let u64_zeros = 0_u64.count_zeros();
    let u128_zeros = (0 as UInt128).count_zeros();
    let usize_zeros = (0 as USize).count_zeros();

    assert_eq(u16_zeros, 16);
    assert_eq(u32_zeros, 32);
    assert_eq(u64_zeros, 64);
    assert_eq(u128_zeros, 128);
    assert_eq(usize_zeros, 64);
}

@test
fn test_all_signed_have_saturating_mul() {
    let i8_r = 10_i8.saturating_mul10_i8;
    let i16_r = 10_i16.saturating_mul10_i16;
    let i32_r = 10_i32.saturating_mul10_i32;
    let i64_r = 10_i64.saturating_mul10_i64;
    let i128_r = (10 as Int128).saturating_mul(10 as Int128);
    let isize_r = (10 as ISize).saturating_mul(10 as ISize);

    assert_eq(i8_r, 100 as Int8);
    assert_eq(i16_r, 100 as Int16);
    assert_eq(i32_r, 100 as Int32);
    assert_eq(i64_r, 100 as Int64);
    assert_eq(i128_r, 100 as Int128);
    assert_eq(isize_r, 100 as ISize);
}

@test
fn test_all_unsigned_have_saturating_mul() {
    let u8_r = 10_u8.saturating_mul10_u8;
    let u16_r = 10_u16.saturating_mul10_u16;
    let u32_r = 10_u32.saturating_mul10_u32;
    let u64_r = 10_u64.saturating_mul10_u64;
    let u128_r = (10 as UInt128).saturating_mul(10 as UInt128);
    let usize_r = (10 as USize).saturating_mul(10 as USize);

    assert_eq(u8_r, 100 as UInt8);
    assert_eq(u16_r, 100 as UInt16);
    assert_eq(u32_r, 100 as UInt32);
    assert_eq(u64_r, 100 as UInt64);
    assert_eq(u128_r, 100 as UInt128);
    assert_eq(usize_r, 100 as USize);
}

@test
fn test_all_wrapping_mul() {
    let i8_r = 10_i8.wrapping_mul10_i8;
    let i16_r = 10_i16.wrapping_mul10_i16;
    let i32_r = 10_i32.wrapping_mul10_i32;
    let i64_r = 10_i64.wrapping_mul10_i64;
    let i128_r = (10 as Int128).wrapping_mul(10 as Int128);
    let isize_r = (10 as ISize).wrapping_mul(10 as ISize);

    assert_eq(i8_r, 100 as Int8);
    assert_eq(i16_r, 100 as Int16);
    assert_eq(i32_r, 100 as Int32);
    assert_eq(i64_r, 100 as Int64);
    assert_eq(i128_r, 100 as Int128);
    assert_eq(isize_r, 100 as ISize);
}

@test
fn test_all_have_to_int() {
    assert_eq(42_i8.to_int(), 42);
    assert_eq(42_i16.to_int(), 42);
    assert_eq(42_i32.to_int(), 42);
    assert_eq(42_i64.to_int(), 42);
    assert_eq((42 as Int128).to_int(), 42);
    assert_eq((42 as ISize).to_int(), 42);
    assert_eq(42_u8.to_int(), 42);
    assert_eq(42_u16.to_int(), 42);
    assert_eq(42_u32.to_int(), 42);
    assert_eq(42_u64.to_int(), 42);
    assert_eq((42 as UInt128).to_int(), 42);
    assert_eq((42 as USize).to_int(), 42);
}
