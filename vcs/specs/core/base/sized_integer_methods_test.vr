    assert(ones == 3);
}

@test
fn test_uint16_count_ones_max() {
    let val = 65535 as UInt16;
    let ones = val.count_ones();
    assert(ones == 16);
}

@test
fn test_uint16_count_zeros() {
    let val = 0 as UInt16;
    let zeros = val.count_zeros();
    assert(zeros == 16);
}

@test
