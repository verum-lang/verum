// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: array, protocols, eq, clone, ord, hash
// @description: Test array protocol support (Eq, Clone, Ord, Hash, indexing, nesting)

mount core.*;

// =============================================================================
// Section 1: Array Eq protocol
// =============================================================================

@test
fn test_array_eq_int() {
    let a = [1, 2, 3];
    let b = [1, 2, 3];
    assert(a == b);
}

@test
fn test_array_neq_int() {
    let a = [1, 2, 3];
    let b = [1, 2, 4];
    assert(a != b);
}

@test
fn test_array_eq_bool() {
    let a = [true, false, true];
    let b = [true, false, true];
    assert(a == b);
}

@test
fn test_array_eq_empty() {
    let a: [Int; 0] = [];
    let b: [Int; 0] = [];
    assert(a == b);
}

@test
fn test_array_eq_single() {
    let a = [42];
    let b = [42];
    assert(a == b);
}

// =============================================================================
// Section 2: Array Clone protocol
// =============================================================================

@test
fn test_array_clone_int() {
    let a = [1, 2, 3];
    let b = a.clone();
    assert_eq(b.len(), 3);
    assert(a == b);
}

@test
fn test_array_clone_bool() {
    let a = [true, false];
    let b = a.clone();
    assert_eq(b.len(), 2);
    assert(a == b);
}

// =============================================================================
// Section 3: Array length and indexing
// =============================================================================

@test
fn test_array_len() {
    let a = [10, 20, 30, 40, 50];
    assert_eq(a.len(), 5);
}

@test
fn test_array_index() {
    let a = [10, 20, 30];
    assert_eq(a[0], 10);
    assert_eq(a[1], 20);
    assert_eq(a[2], 30);
}

@test
fn test_array_single_element() {
    let a = [99];
    assert_eq(a.len(), 1);
    assert_eq(a[0], 99);
}

// =============================================================================
// Section 4: Arrays in collections
// =============================================================================

@test
fn test_array_in_list() {
    let pairs: List<[Int; 2]> = [[1, 2], [3, 4]];
    assert_eq(pairs.len(), 2);
}

@test
fn test_array_in_list_access() {
    let items: List<[Int; 3]> = [[1, 2, 3], [4, 5, 6]];
    assert_eq(items.len(), 2);
    let first = items.get(0);
    assert(first is Some);
}

// =============================================================================
// Section 5: Arrays with sized integer elements
// =============================================================================

@test
fn test_array_int32() {
    let a: [Int32; 3] = [1 as Int32, 2 as Int32, 3 as Int32];
    assert_eq(a.len(), 3);
    assert_eq(a[0], 1 as Int32);
}

@test
fn test_array_uint8() {
    let a: [UInt8; 4] = [0 as UInt8, 1 as UInt8, 2 as UInt8, 255 as UInt8];
    assert_eq(a.len(), 4);
    assert_eq(a[3], 255 as UInt8);
}

@test
fn test_array_float() {
    let a = [1.0, 2.5, 3.7];
    assert_eq(a.len(), 3);
}

// =============================================================================
// Section 6: Nested arrays
// =============================================================================

@test
fn test_nested_array() {
    let matrix: [[Int; 2]; 2] = [[1, 2], [3, 4]];
    assert_eq(matrix.len(), 2);
    assert_eq(matrix[0][0], 1);
    assert_eq(matrix[1][1], 4);
}

@test
fn test_nested_array_eq() {
    let a: [[Int; 2]; 2] = [[1, 2], [3, 4]];
    let b: [[Int; 2]; 2] = [[1, 2], [3, 4]];
    assert(a == b);
}

// =============================================================================
// Section 7: Array with mut and assignment
// =============================================================================

@test
fn test_array_mut_assign() {
    let mut a = [1, 2, 3];
    a[0] = 10;
    assert_eq(a[0], 10);
    assert_eq(a[1], 2);
}

@test
fn test_array_mut_all_elements() {
    let mut a = [0, 0, 0];
    a[0] = 1;
    a[1] = 2;
    a[2] = 3;
    assert_eq(a[0], 1);
    assert_eq(a[1], 2);
    assert_eq(a[2], 3);
}
