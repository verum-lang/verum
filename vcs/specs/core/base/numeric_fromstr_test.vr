// =============================================================================
// numeric_fromstr_test.vr - FromStr for sized integer types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: base, primitives, fromstr, parsing, numeric
// @description: Tests for FromStr implementations on sized integer types.
//               Verifies string parsing with valid inputs, boundary values,
//               overflow/underflow detection, and invalid format handling.
// =============================================================================

mount core.base.protocols.{FromStr, Eq};
mount core.text.ParseError;

// =============================================================================
// Section 1: FromStr for Int8
// =============================================================================

@test
fn test_int8_fromstr_zero() {
    let result = Int8.from_str(&"0");
    assert(result.is_ok());
}

@test
fn test_int8_fromstr_positive() {
    let result = Int8.from_str(&"42");
    assert(result.is_ok());
}

@test
fn test_int8_fromstr_negative() {
    let result = Int8.from_str(&"-42");
    assert(result.is_ok());
}

@test
fn test_int8_fromstr_max() {
    let result = Int8.from_str(&"127");
    assert(result.is_ok());
}

@test
fn test_int8_fromstr_min() {
    let result = Int8.from_str(&"-128");
    assert(result.is_ok());
}

@test
fn test_int8_fromstr_overflow() {
    let result = Int8.from_str(&"128");
    assert(result.is_err());
}

@test
fn test_int8_fromstr_underflow() {
    let result = Int8.from_str(&"-129");
    assert(result.is_err());
}

@test
fn test_int8_fromstr_large_overflow() {
    let result = Int8.from_str(&"1000");
    assert(result.is_err());
}

@test
fn test_int8_fromstr_invalid() {
    let result = Int8.from_str(&"abc");
    assert(result.is_err());
}

@test
fn test_int8_fromstr_empty() {
    let result = Int8.from_str(&"");
    assert(result.is_err());
}

