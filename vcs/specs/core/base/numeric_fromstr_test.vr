// =============================================================================
// Section 7: FromStr for UInt64
// =============================================================================

@test
fn test_uint64_fromstr_zero() {
    let result = UInt64.from_str(&"0");
    assert(result.is_ok());
}

@test
fn test_uint64_fromstr_positive() {
    let result = UInt64.from_str(&"1000000");
    assert(result.is_ok());
}

@test
fn test_uint64_fromstr_max_int() {
    // Max Int value should be valid UInt64
    let result = UInt64.from_str(&"9223372036854775807");
    assert(result.is_ok());
}

@test
fn test_uint64_fromstr_negative() {
    let result = UInt64.from_str(&"-1");
    assert(result.is_err());
