@test
fn test_uint64_fromstr_invalid() {
    let result = UInt64.from_str(&"not_a_number");
    assert(result.is_err());
}

// =============================================================================
// Section 8: Edge cases
// =============================================================================

@test
fn test_fromstr_whitespace() {
    // Leading/trailing whitespace should fail (strict parsing)
    let result = Int8.from_str(&" 42");
    assert(result.is_err());
}

@test
fn test_fromstr_plus_sign() {
    // Verum accepts leading '+' in numeric parsing (consistent with from_str_radix)
    let result = Int8.from_str(&"+42");
    assert(result.is_ok());
}

@test
fn test_fromstr_leading_zeros() {
    let result = Int8.from_str(&"007");
    assert(result.is_ok());
}

@test
fn test_fromstr_multiple_types_same_value() {
    let r1 = Int8.from_str(&"100");
    let r2 = Int16.from_str(&"100");
    let r3 = Int32.from_str(&"100");
    let r4 = UInt8.from_str(&"100");
    let r5 = UInt16.from_str(&"100");
    let r6 = UInt32.from_str(&"100");
    let r7 = UInt64.from_str(&"100");
    assert(r1.is_ok());
    assert(r2.is_ok());
    assert(r3.is_ok());
    assert(r4.is_ok());
    assert(r5.is_ok());
    assert(r6.is_ok());
    assert(r7.is_ok());
}

@test
fn test_fromstr_type_limits() {
    // Value valid for Int16 but not Int8
    let r_int8 = Int8.from_str(&"200");
    let r_int16 = Int16.from_str(&"200");
    assert(r_int8.is_err());
    assert(r_int16.is_ok());
}

@test
fn test_fromstr_boundary_cross_type() {
    // 255 valid for UInt8 but not Int8
    let r_uint8 = UInt8.from_str(&"255");
    let r_int8 = Int8.from_str(&"255");
    assert(r_uint8.is_ok());
    assert(r_int8.is_err());
}

@test
fn test_fromstr_negative_unsigned() {
    // All unsigned types should reject negative values
    let r1 = UInt8.from_str(&"-5");
    let r2 = UInt16.from_str(&"-5");
    let r3 = UInt32.from_str(&"-5");
    let r4 = UInt64.from_str(&"-5");
    assert(r1.is_err());
    assert(r2.is_err());
    assert(r3.is_err());
    assert(r4.is_err());
}

fn main() {
    // Tests run via @test annotations
}
