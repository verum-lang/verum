// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: primitives, protocols, arithmetic, sized-integers, zero, one
// @description: Tests for arithmetic protocol implementations on sized integer types and Float32

mount core.*;
mount core.base.protocols.{Zero, One, Add, Sub, Mul, Div, Rem};
mount core.base.protocols.{BitAnd, BitOr, BitXor};
mount core.base.protocols.{AddAssign, SubAssign, MulAssign, DivAssign, RemAssign};
mount core.base.protocols.{BitAndAssign, BitOrAssign, BitXorAssign, ShlAssign, ShrAssign};

// =============================================================================
// Section 1: Zero and One protocols — signed integers
// =============================================================================

@test
fn test_zero_int8() {
    let z: Int8 = Int8.zero();
    assert(z.is_zero());
    assert_eq(z, 0 as Int8);
}

@test
fn test_one_int8() {
    let o: Int8 = Int8.one();
    assert(o.is_one());
    assert_eq(o, 1 as Int8);
}

@test
fn test_zero_int16() {
    let z: Int16 = Int16.zero();
    assert(z.is_zero());
}

@test
fn test_one_int16() {
    let o: Int16 = Int16.one();
    assert(o.is_one());
}

@test
fn test_zero_int32() {
    let z: Int32 = Int32.zero();
    assert(z.is_zero());
    assert_eq(z, 0 as Int32);
}

@test
fn test_one_int32() {
    let o: Int32 = Int32.one();
    assert(o.is_one());
    assert_eq(o, 1 as Int32);
}

@test
fn test_zero_int64() {
    let z: Int64 = Int64.zero();
    assert(z.is_zero());
}

@test
fn test_one_int64() {
    let o: Int64 = Int64.one();
    assert(o.is_one());
}

@test
fn test_zero_int128() {
    let z: Int128 = Int128.zero();
    assert(z.is_zero());
}

@test
fn test_one_int128() {
    let o: Int128 = Int128.one();
    assert(o.is_one());
}

@test
fn test_zero_isize() {
    let z: ISize = ISize.zero();
    assert(z.is_zero());
}

@test
fn test_one_isize() {
    let o: ISize = ISize.one();
    assert(o.is_one());
}

