// =============================================================================
// Section 4: Arithmetic protocols for Int32 (representative signed)
// =============================================================================

@test
fn test_int32_add() {
    let a: Int32 = 10 as Int32;
    let b: Int32 = 20 as Int32;
    let c: Int32 = a + b;
    assert_eq(c, 30 as Int32);
}

@test
fn test_int32_sub() {
    let a: Int32 = 50 as Int32;
    let b: Int32 = 20 as Int32;
    let c: Int32 = a - b;
    assert_eq(c, 30 as Int32);
}

@test
fn test_int32_mul() {
    let a: Int32 = 6 as Int32;
    let b: Int32 = 7 as Int32;
    let c: Int32 = a * b;
    assert_eq(c, 42 as Int32);
}

@test
fn test_int32_div() {
    let a: Int32 = 100 as Int32;
    let b: Int32 = 4 as Int32;
    let c: Int32 = a / b;
    assert_eq(c, 25 as Int32);
}

@test
fn test_int32_rem() {
    let a: Int32 = 17 as Int32;
    let b: Int32 = 5 as Int32;
    let c: Int32 = a % b;
    assert_eq(c, 2 as Int32);
}

// =============================================================================
// Section 5: Bitwise protocols for Int32 (using decimal values)
// =============================================================================

@test
fn test_int32_bitand() {
    let a: Int32 = 255 as Int32;
    let b: Int32 = 15 as Int32;
    let c: Int32 = a & b;
    assert_eq(c, 15 as Int32);
}

@test
fn test_int32_bitor() {
    let a: Int32 = 240 as Int32;
    let b: Int32 = 15 as Int32;
    let c: Int32 = a | b;
    assert_eq(c, 255 as Int32);
}

@test
fn test_int32_bitxor() {
    let a: Int32 = 255 as Int32;
    let b: Int32 = 15 as Int32;
    let c: Int32 = a ^ b;
    assert_eq(c, 240 as Int32);
}

