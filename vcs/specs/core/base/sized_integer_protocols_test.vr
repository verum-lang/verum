// =============================================================================
// Section 11: Float32 arithmetic protocols
// =============================================================================

@test
fn test_float32_add() {
    let a: Float32 = 1.5 as Float32;
    let b: Float32 = 2.5 as Float32;
    let c: Float32 = a + b;
    let expected: Float32 = 4.0 as Float32;
    assert_eq(c, expected);
}

@test
fn test_float32_sub() {
    let a: Float32 = 5.0 as Float32;
    let b: Float32 = 2.0 as Float32;
    let c: Float32 = a - b;
    let expected: Float32 = 3.0 as Float32;
    assert_eq(c, expected);
}

@test
fn test_float32_mul() {
    let a: Float32 = 3.0 as Float32;
    let b: Float32 = 4.0 as Float32;
    let c: Float32 = a * b;
    let expected: Float32 = 12.0 as Float32;
    assert_eq(c, expected);
}

@test
fn test_float32_div() {
    let a: Float32 = 10.0 as Float32;
    let b: Float32 = 2.0 as Float32;
    let c: Float32 = a / b;
    let expected: Float32 = 5.0 as Float32;
    assert_eq(c, expected);
}

@test
fn test_float32_zero_one() {
    let z: Float32 = Float32.zero();
    let o: Float32 = Float32.one();
    let result: Float32 = z + o;
    assert_eq(result, 1.0 as Float32);
}

