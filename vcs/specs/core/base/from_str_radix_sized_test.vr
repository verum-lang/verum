// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: core, base, from_str_radix, sized, parsing
// @description: Tests from_str_radix for all sized integer types

mount core.*;
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: Signed types — from_str_radix
// =============================================================================

@test
fn test_int8_from_str_radix_decimal() {
    assert_eq(Int8.from_str_radix(&"42", 10), Some42_i8);
    assert_eq(Int8.from_str_radix(&"-128", 10), Some-128_i8);
    assert_eq(Int8.from_str_radix(&"127", 10), Some127_i8);
}

@test
fn test_int8_from_str_radix_hex() {
    assert_eq(Int8.from_str_radix(&"7f", 16), Some127_i8);
    assert_eq(Int8.from_str_radix(&"0", 16), Some0_i8);
}

@test
fn test_int8_from_str_radix_overflow() {
    assert(Int8.from_str_radix(&"128", 10).is_none());
    assert(Int8.from_str_radix(&"-129", 10).is_none());
}

@test
fn test_int16_from_str_radix_decimal() {
    assert_eq(Int16.from_str_radix(&"1000", 10), Some1000_i16);
    assert_eq(Int16.from_str_radix(&"-32768", 10), Some-32768_i16);
    assert_eq(Int16.from_str_radix(&"32767", 10), Some32767_i16);
}

@test
fn test_int16_from_str_radix_hex() {
    assert_eq(Int16.from_str_radix(&"ff", 16), Some255_i16);
}

@test
fn test_int16_from_str_radix_overflow() {
    assert(Int16.from_str_radix(&"32768", 10).is_none());
}

@test
fn test_int32_from_str_radix_decimal() {
    assert_eq(Int32.from_str_radix(&"100000", 10), Some100000_i32);
    assert_eq(Int32.from_str_radix(&"-2147483648", 10), Some-2147483648_i32);
}

@test
fn test_int32_from_str_radix_overflow() {
    assert(Int32.from_str_radix(&"2147483648", 10).is_none());
}

@test
fn test_int64_from_str_radix_decimal() {
    assert_eq(Int64.from_str_radix(&"123456789", 10), Some123456789_i64);
    assert_eq(Int64.from_str_radix(&"-1", 10), Some-1_i64);
}

@test
fn test_int64_from_str_radix_binary() {
    assert_eq(Int64.from_str_radix(&"1010", 2), Some10_i64);
}

@test
fn test_int128_from_str_radix_decimal() {
    assert_eq(Int128.from_str_radix(&"999999999", 10), Some(999999999 as Int128));
}

@test
fn test_int128_from_str_radix_hex() {
    assert_eq(Int128.from_str_radix(&"ff", 16), Some(255 as Int128));
}

@test
fn test_isize_from_str_radix_decimal() {
    assert_eq(ISize.from_str_radix(&"42", 10), Some(42 as ISize));
    assert_eq(ISize.from_str_radix(&"-100", 10), Some(-100 as ISize));
}

@test
fn test_isize_from_str_radix_octal() {
    assert_eq(ISize.from_str_radix(&"77", 8), Some(63 as ISize));
}

// =============================================================================
// Section 2: Unsigned types — from_str_radix
// =============================================================================

@test
fn test_uint8_from_str_radix_decimal() {
    assert_eq(UInt8.from_str_radix(&"255", 10), Some255_u8);
    assert_eq(UInt8.from_str_radix(&"0", 10), Some0_u8);
}

@test
fn test_uint8_from_str_radix_hex() {
    assert_eq(UInt8.from_str_radix(&"ff", 16), Some255_u8);
    assert_eq(UInt8.from_str_radix(&"a", 16), Some10_u8);
}

@test
fn test_uint8_from_str_radix_overflow() {
    assert(UInt8.from_str_radix(&"256", 10).is_none());
    assert(UInt8.from_str_radix(&"-1", 10).is_none());
}

@test
fn test_uint16_from_str_radix_decimal() {
    assert_eq(UInt16.from_str_radix(&"65535", 10), Some65535_u16);
    assert_eq(UInt16.from_str_radix(&"1000", 10), Some1000_u16);
}

@test
fn test_uint16_from_str_radix_overflow() {
    assert(UInt16.from_str_radix(&"65536", 10).is_none());
    assert(UInt16.from_str_radix(&"-1", 10).is_none());
}

@test
fn test_uint32_from_str_radix_decimal() {
    assert_eq(UInt32.from_str_radix(&"100000", 10), Some100000_u32);
}

@test
fn test_uint32_from_str_radix_hex() {
    assert_eq(UInt32.from_str_radix(&"deadbeef", 16), Some3735928559_u32);
}

@test
fn test_uint32_from_str_radix_overflow() {
    assert(UInt32.from_str_radix(&"4294967296", 10).is_none());
}

@test
fn test_uint64_from_str_radix_decimal() {
    assert_eq(UInt64.from_str_radix(&"1000000", 10), Some1000000_u64);
}

@test
fn test_uint64_from_str_radix_negative() {
    assert(UInt64.from_str_radix(&"-1", 10).is_none());
}

@test
fn test_uint128_from_str_radix_decimal() {
    assert_eq(UInt128.from_str_radix(&"42", 10), Some(42 as UInt128));
}

@test
fn test_uint128_from_str_radix_negative() {
    assert(UInt128.from_str_radix(&"-1", 10).is_none());
}

@test
fn test_usize_from_str_radix_decimal() {
    assert_eq(USize.from_str_radix(&"42", 10), Some(42 as USize));
}

@test
fn test_usize_from_str_radix_negative() {
    assert(USize.from_str_radix(&"-1", 10).is_none());
}

// =============================================================================
// Section 3: Invalid input
// =============================================================================

@test
fn test_from_str_radix_empty() {
    assert(Int8.from_str_radix(&"", 10).is_none());
    assert(UInt8.from_str_radix(&"", 10).is_none());
}

@test
fn test_from_str_radix_invalid_char() {
    assert(Int8.from_str_radix(&"abc", 10).is_none());
    assert(UInt32.from_str_radix(&"xyz", 10).is_none());
}

@test
fn test_from_str_radix_invalid_radix() {
    assert(Int16.from_str_radix(&"5", 1).is_none());
    assert(UInt16.from_str_radix(&"5", 37).is_none());
}

// =============================================================================
// Section 4: Different bases
// =============================================================================

@test
fn test_from_str_radix_binary() {
    assert_eq(Int8.from_str_radix(&"1111111", 2), Some127_i8);
    assert_eq(UInt8.from_str_radix(&"11111111", 2), Some255_u8);
}

@test
fn test_from_str_radix_octal() {
    assert_eq(Int16.from_str_radix(&"777", 8), Some511_i16);
    assert_eq(UInt16.from_str_radix(&"1000", 8), Some512_u16);
}

@test
fn test_from_str_radix_base36() {
    assert_eq(Int32.from_str_radix(&"zz", 36), Some1295_i32);
}

// =============================================================================
// Section 5: Cross-type consistency with Int
// =============================================================================

@test
fn test_from_str_radix_consistency_with_int() {
    let int_result = Int.from_str_radix(&"ff", 16);
    let int32_result = Int32.from_str_radix(&"ff", 16);
    assert(int_result.is_some());
    assert(int32_result.is_some());
    assert_eq(int_result.unwrap(), int32_result.unwrap().to_int());
}

@test
fn test_from_str_radix_sign_prefix() {
    assert_eq(Int16.from_str_radix(&"+42", 10), Some42_i16);
    assert_eq(Int32.from_str_radix(&"-42", 10), Some-42_i32);
}
