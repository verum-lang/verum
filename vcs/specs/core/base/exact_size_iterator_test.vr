// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: base, iterator, exact_size, protocol
// @description: Tests for ExactSizeIterator protocol implementations

mount core.*;
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: List iterator ExactSizeIterator
// =============================================================================

@test
fn test_list_iter_len() {
    let list = [1, 2, 3, 4, 5];
    let iter = list.iter();
    assert_eq(iter.len(), 5);
}

@test
fn test_list_iter_len_after_next() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.iter();
    iter.next();
    assert_eq(iter.len(), 4);
    iter.next();
    assert_eq(iter.len(), 3);
}

@test
fn test_list_iter_len_exhausted() {
    let list = [1, 2];
    let mut iter = list.iter();
    iter.next();
    iter.next();
    assert_eq(iter.len(), 0);
}

@test
fn test_list_iter_is_empty_false() {
    let list = [1, 2, 3];
    let iter = list.iter();
    assert(!iter.is_empty());
}

@test
fn test_list_iter_is_empty_true() {
    let list: List<Int> = [];
    let iter = list.iter();
    assert(iter.is_empty());
}

@test
fn test_list_iter_is_empty_after_exhaust() {
    let list = [42];
    let mut iter = list.iter();
    assert(!iter.is_empty());
    iter.next();
    assert(iter.is_empty());
}

// =============================================================================
// Section 2: List mutable iterator ExactSizeIterator
// =============================================================================

@test
fn test_list_iter_mut_len() {
    let mut list = [10, 20, 30];
    let iter = list.iter_mut();
    assert_eq(iter.len(), 3);
}

@test
fn test_list_iter_mut_len_after_next() {
    let mut list = [10, 20, 30];
    let mut iter = list.iter_mut();
    iter.next();
    assert_eq(iter.len(), 2);
}

@test
fn test_list_iter_mut_is_empty() {
    let mut list: List<Int> = [];
    let iter = list.iter_mut();
    assert(iter.is_empty());
}

// =============================================================================
// Section 3: IntoList ExactSizeIterator
// =============================================================================

@test
fn test_into_list_len() {
    let list = [1, 2, 3, 4];
    let iter = list.into_iter();
    assert_eq(iter.len(), 4);
}

@test
fn test_into_list_len_after_next() {
    let list = [1, 2, 3, 4];
    let mut iter = list.into_iter();
    iter.next();
    assert_eq(iter.len(), 3);
    iter.next();
    iter.next();
    assert_eq(iter.len(), 1);
}

@test
fn test_into_list_is_empty() {
    let list: List<Int> = [];
    let iter = list.into_iter();
    assert(iter.is_empty());
}

@test
fn test_into_list_is_empty_after_exhaust() {
    let list = [1, 2];
    let mut iter = list.into_iter();
    iter.next();
    iter.next();
    assert(iter.is_empty());
}

// =============================================================================
// Section 4: Drain ExactSizeIterator
// =============================================================================

@test
fn test_drain_len() {
    let mut list = [1, 2, 3, 4, 5];
    let drain = list.drain(1, 4);
    assert_eq(drain.len(), 3);
}

@test
fn test_drain_len_after_next() {
    let mut list = [1, 2, 3, 4, 5];
    let mut drain = list.drain(0, 3);
    drain.next();
    assert_eq(drain.len(), 2);
}

@test
fn test_drain_is_empty() {
    let mut list = [1, 2, 3];
    let mut drain = list.drain(0, 2);
    drain.next();
    drain.next();
    assert(drain.is_empty());
}

// =============================================================================
// Section 5: Deque iterator ExactSizeIterator
// =============================================================================

@test
fn test_deque_iter_len() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    let iter = d.iter();
    assert_eq(iter.len(), 3);
}

@test
fn test_deque_iter_len_after_next() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    let mut iter = d.iter();
    iter.next();
    assert_eq(iter.len(), 2);
}

@test
fn test_deque_iter_is_empty() {
    let d: Deque<Int> = Deque.new();
    let iter = d.iter();
    assert(iter.is_empty());
}

@test
fn test_deque_iter_is_empty_after_exhaust() {
    let mut d = Deque.new();
    d.push_back(1);
    let mut iter = d.iter();
    assert(!iter.is_empty());
    iter.next();
    assert(iter.is_empty());
}

