// =============================================================================
// float64_protocols_test.vr - Float64 full protocol compliance tests
// =============================================================================
// @test: typecheck-pass
// @level: L0
// @tier: 0
// @tags: base, protocols, float64, arithmetic, eq, clone, copy, default, display
// @description: Comprehensive tests for Float64 protocol implementations.
//               Float64 was severely under-implemented (only Neg + compound assigns).
//               This verifies the full protocol suite.
// =============================================================================

mount core.*;
mount core.base.protocols.{Eq, PartialOrd, Hash, Clone, Copy, Default, Debug, Display};
mount core.base.protocols.{Add, Sub, Mul, Div, Rem, Neg, Zero, One};
mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: Arithmetic Protocols
// =============================================================================

@test
fn test_float64_add() {
    let a: Float64 = 1.5 as Float64;
    let b: Float64 = 2.5 as Float64;
    let c: Float64 = a + b;
    assert_eq(c, 4.0 as Float64);
}

@test
fn test_float64_sub() {
    let a: Float64 = 5.0 as Float64;
    let b: Float64 = 2.0 as Float64;
    let c: Float64 = a - b;
    assert_eq(c, 3.0 as Float64);
}

@test
fn test_float64_mul() {
    let a: Float64 = 3.0 as Float64;
    let b: Float64 = 4.0 as Float64;
    let c: Float64 = a * b;
    assert_eq(c, 12.0 as Float64);
}

@test
fn test_float64_div() {
    let a: Float64 = 10.0 as Float64;
    let b: Float64 = 2.0 as Float64;
    let c: Float64 = a / b;
    assert_eq(c, 5.0 as Float64);
}

@test
fn test_float64_rem() {
    let a: Float64 = 7.0 as Float64;
    let b: Float64 = 3.0 as Float64;
    let c: Float64 = a % b;
    assert_eq(c, 1.0 as Float64);
}

@test
fn test_float64_neg() {
    let a: Float64 = 3.14 as Float64;
    let b: Float64 = -a;
    assert_eq(b, -3.14 as Float64);
}

// =============================================================================
// Section 2: Arithmetic Protocol Trait Methods
// =============================================================================

@test
fn test_float64_add_protocol() {
    let a: Float64 = 1.0 as Float64;
    let b: Float64 = 2.0 as Float64;
    let c: Float64 = a.add(b);
    assert_eq(c, 3.0 as Float64);
}

@test
fn test_float64_sub_protocol() {
    let a: Float64 = 5.0 as Float64;
    let b: Float64 = 3.0 as Float64;
    let c: Float64 = a.sub(b);
    assert_eq(c, 2.0 as Float64);
}

@test
fn test_float64_mul_protocol() {
    let a: Float64 = 4.0 as Float64;
    let b: Float64 = 5.0 as Float64;
    let c: Float64 = a.mul(b);
    assert_eq(c, 20.0 as Float64);
}

@test
fn test_float64_div_protocol() {
    let a: Float64 = 20.0 as Float64;
    let b: Float64 = 4.0 as Float64;
    let c: Float64 = a.div(b);
    assert_eq(c, 5.0 as Float64);
}

@test
fn test_float64_rem_protocol() {
    let a: Float64 = 10.0 as Float64;
    let b: Float64 = 3.0 as Float64;
    let c: Float64 = a.rem(b);
    assert_eq(c, 1.0 as Float64);
}

// =============================================================================
// Section 3: Eq Protocol
// =============================================================================

@test
fn test_float64_eq() {
    let a: Float64 = 3.14 as Float64;
    let b: Float64 = 3.14 as Float64;
    let c: Float64 = 2.71 as Float64;
    assert(a.eq(&b));
    assert(!a.eq(&c));
}

@test
fn test_float64_eq_zero() {
    let a: Float64 = 0.0 as Float64;
    let b: Float64 = 0.0 as Float64;
    assert(a.eq(&b));
}

@test
fn test_float64_ne() {
    let a: Float64 = 1.0 as Float64;
    let b: Float64 = 2.0 as Float64;
    assert(a.ne(&b));
    assert(!a.ne(&(1.0 as Float64)));
}

// =============================================================================
// Section 4: PartialOrd Protocol
// =============================================================================

@test
fn test_float64_partial_cmp_less() {
    let a: Float64 = 1.0 as Float64;
    let b: Float64 = 2.0 as Float64;
    let r: Maybe<Ordering> = a.partial_cmp(&b);
    assert(r is Some);
}

@test
fn test_float64_partial_cmp_greater() {
    let a: Float64 = 5.0 as Float64;
    let b: Float64 = 2.0 as Float64;
    let r: Maybe<Ordering> = a.partial_cmp(&b);
    assert(r is Some);
}

@test
fn test_float64_partial_cmp_equal() {
    let a: Float64 = 3.0 as Float64;
    let b: Float64 = 3.0 as Float64;
    let r: Maybe<Ordering> = a.partial_cmp(&b);
    assert(r is Some);
}

@test
fn test_float64_partial_cmp_nan() {
    let nan: Float64 = Float64.nan();
    let one: Float64 = 1.0 as Float64;
    let r1: Maybe<Ordering> = nan.partial_cmp(&one);
    assert(r1 is None);
    let r2: Maybe<Ordering> = one.partial_cmp(&nan);
    assert(r2 is None);
    let r3: Maybe<Ordering> = nan.partial_cmp(&nan);
    assert(r3 is None);
}

// =============================================================================
// Section 5: Clone and Copy
// =============================================================================

@test
fn test_float64_clone() {
    let a: Float64 = 3.14 as Float64;
    let b: Float64 = a.clone();
    assert(a.eq(&b));
}

@test
fn test_float64_clone_independence() {
    let mut a: Float64 = 100.0 as Float64;
    let b: Float64 = a.clone();
    a = 200.0 as Float64;
    assert_eq(b, 100.0 as Float64);
}

@test
fn test_float64_copy_semantics() {
    let a: Float64 = 42.0 as Float64;
    let b: Float64 = a;  // Copy, not move
    assert_eq(a, 42.0 as Float64);
    assert_eq(b, 42.0 as Float64);
}

// =============================================================================
// Section 6: Default
// =============================================================================

@test
fn test_float64_default() {
    let d: Float64 = Float64.default();
    assert_eq(d, 0.0 as Float64);
}

// =============================================================================
// Section 7: Debug and Display
// =============================================================================

@test
fn test_float64_debug() {
    // Verify Debug impl exists — can cast Float64 to Float
    let a: Float64 = 3.14 as Float64;
    let val: Float = a as Float;
    assert(val > 3.0);
}

@test
fn test_float64_display() {
    // Verify Display impl exists — can cast Float64 to Float
    let a: Float64 = 3.14 as Float64;
    let val: Float = a as Float;
    assert(val > 3.0);
}

// =============================================================================
// Section 8: Zero and One
// =============================================================================

@test
fn test_float64_zero() {
    let z: Float64 = Float64.zero();
    assert(z.is_zero());
    assert_eq(z, 0.0 as Float64);
}

@test
fn test_float64_one() {
    let o: Float64 = Float64.one();
    assert(o.is_one());
    assert_eq(o, 1.0 as Float64);
}

@test
fn test_float64_zero_is_zero() {
    let z: Float64 = 0.0 as Float64;
    assert(z.is_zero());
}

@test
fn test_float64_one_is_one() {
    let o: Float64 = 1.0 as Float64;
    assert(o.is_one());
}

// =============================================================================
// Section 9: Special Values
// =============================================================================

@test
fn test_float64_infinity() {
    let inf: Float64 = Float64.infinity();
    assert(inf.is_infinite());
    assert(!inf.is_nan());
    assert(!inf.is_finite());
}

@test
fn test_float64_neg_infinity() {
    let ninf: Float64 = Float64.neg_infinity();
    assert(ninf.is_infinite());
    assert(!ninf.is_nan());
}

@test
fn test_float64_nan_not_equal_to_self() {
    let nan: Float64 = Float64.nan();
    assert(!nan.eq(&nan));
}

@test
fn test_float64_neg_zero() {
    let pz: Float64 = 0.0 as Float64;
    let nz: Float64 = -0.0 as Float64;
    // Positive and negative zero should be equal per IEEE 754
    assert(pz.eq(&nz));
}

// =============================================================================
// Section 10: Cross-Type Consistency with Float
// =============================================================================

@test
fn test_float64_add_consistency() {
    let a64: Float64 = 1.5 as Float64;
    let b64: Float64 = 2.5 as Float64;
    let r64: Float64 = a64 + b64;

    let af: Float = 1.5;
    let bf: Float = 2.5;
    let rf: Float = af + bf;

    // Both should give 4.0
    assert_eq(r64, 4.0 as Float64);
    assert_eq(rf, 4.0);
}

@test
fn test_float64_mul_consistency() {
    let a64: Float64 = 3.0 as Float64;
    let b64: Float64 = 4.0 as Float64;
    let r64: Float64 = a64 * b64;
    assert_eq(r64, 12.0 as Float64);
}

@test
fn test_float64_eq_consistency() {
    let a64: Float64 = 42.0 as Float64;
    let b64: Float64 = 42.0 as Float64;
    assert(a64.eq(&b64));

    let af: Float = 42.0;
    let bf: Float = 42.0;
    assert(af.eq(&bf));
}

// =============================================================================
// Section 11: Compound Assignments (already existed, verify still work)
// =============================================================================

@test
fn test_float64_add_assign() {
    let mut a: Float64 = 1.0 as Float64;
    a += 2.0 as Float64;
    assert_eq(a, 3.0 as Float64);
}

@test
fn test_float64_sub_assign() {
    let mut a: Float64 = 5.0 as Float64;
    a -= 2.0 as Float64;
    assert_eq(a, 3.0 as Float64);
}

@test
fn test_float64_mul_assign() {
    let mut a: Float64 = 3.0 as Float64;
    a *= 4.0 as Float64;
    assert_eq(a, 12.0 as Float64);
}

@test
fn test_float64_div_assign() {
    let mut a: Float64 = 10.0 as Float64;
    a /= 2.0 as Float64;
    assert_eq(a, 5.0 as Float64);
}

@test
fn test_float64_rem_assign() {
    let mut a: Float64 = 7.0 as Float64;
    a %= 3.0 as Float64;
    assert_eq(a, 1.0 as Float64);
}
