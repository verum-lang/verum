// =============================================================================
// Cross-type consistency
// =============================================================================

@test
fn test_all_types_have_checked_shl() {
    let _a = (1).checked_shl(0);
    let _b = 1_i8.checked_shl(0);
    let _c = 1_i16.checked_shl(0);
    let _d = 1_i32.checked_shl(0);
    let _e = 1_i64.checked_shl(0);
    let _f = (1 as Int128).checked_shl(0);
    let _g = 1_u8.checked_shl(0);
    let _h = 1_u16.checked_shl(0);
    let _i = 1_u32.checked_shl(0);
    let _j = 1_u64.checked_shl(0);
    let _k = (1 as UInt128).checked_shl(0);
    let _l = (1 as ISize).checked_shl(0);
    let _m = (1 as USize).checked_shl(0);
    assert(_a is Some);
    assert(_b is Some);
    assert(_c is Some);
    assert(_d is Some);
    assert(_e is Some);
    assert(_f is Some);
    assert(_g is Some);
    assert(_h is Some);
    assert(_i is Some);
    assert(_j is Some);
    assert(_k is Some);
    assert(_l is Some);
    assert(_m is Some);
}

@test
fn test_all_types_have_checked_shr() {
    let _a = (1).checked_shr(0);
    let _b = 1_i8.checked_shr(0);
    let _c = 1_i16.checked_shr(0);
    let _d = 1_i32.checked_shr(0);
    let _e = 1_i64.checked_shr(0);
    let _f = (1 as Int128).checked_shr(0);
    let _g = 1_u8.checked_shr(0);
    let _h = 1_u16.checked_shr(0);
    let _i = 1_u32.checked_shr(0);
    let _j = 1_u64.checked_shr(0);
    let _k = (1 as UInt128).checked_shr(0);
    let _l = (1 as ISize).checked_shr(0);
    let _m = (1 as USize).checked_shr(0);
    assert(_a is Some);
    assert(_b is Some);
    assert(_c is Some);
    assert(_d is Some);
    assert(_e is Some);
    assert(_f is Some);
    assert(_g is Some);
    assert(_h is Some);
    assert(_i is Some);
    assert(_j is Some);
    assert(_k is Some);
    assert(_l is Some);
    assert(_m is Some);
}

@test
fn test_all_types_have_checked_pow() {
    let _a = (2).checked_pow(3);
    let _b = 2_i8.checked_pow(3);
    let _c = 2_i16.checked_pow(3);
    let _d = 2_i32.checked_pow(3);
    let _e = 2_i64.checked_pow(3);
    let _f = (2 as Int128).checked_pow(3);
    let _g = 2_u8.checked_pow(3);
    let _h = 2_u16.checked_pow(3);
    let _i = 2_u32.checked_pow(3);
    let _j = 2_u64.checked_pow(3);
    let _k = (2 as UInt128).checked_pow(3);
    let _l = (2 as ISize).checked_pow(3);
    let _m = (2 as USize).checked_pow(3);
    assert(_a is Some);
    assert(_b is Some);
    assert(_c is Some);
    assert(_d is Some);
    assert(_e is Some);
    assert(_f is Some);
    assert(_g is Some);
    assert(_h is Some);
    assert(_i is Some);
    assert(_j is Some);
    assert(_k is Some);
    assert(_l is Some);
    assert(_m is Some);
}

// =============================================================================
// Edge cases: pow with base 0, 1, -1
// =============================================================================

@test
fn test_checked_pow_base_zero() {
    assert_eq(0.checked_pow(0), Some(1));
    assert_eq(0.checked_pow(1), Some(0));
    assert_eq(0.checked_pow(100), Some(0));
}

@test
fn test_checked_pow_base_one() {
    assert_eq(1.checked_pow(0), Some(1));
    assert_eq(1.checked_pow(1), Some(1));
    assert_eq(1.checked_pow(1000000), Some(1));
}

@test
fn test_checked_pow_base_negative_one() {
    assert_eq((-1).checked_pow(0), Some(1));
    assert_eq((-1).checked_pow(1), Some(-1));
    assert_eq((-1).checked_pow(2), Some(1));
    assert_eq((-1).checked_pow(3), Some(-1));
}

@test
fn test_checked_shl_value_preservation() {
    // Shifting zero always gives zero
    assert_eq(0.checked_shl(0), Some(0));
    assert_eq(0.checked_shl(63), Some(0));
    // Shifting by zero preserves value
    assert_eq(42.checked_shl(0), Some(42));
    assert_eq(42.checked_shr(0), Some(42));
}
