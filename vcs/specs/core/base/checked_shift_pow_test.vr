// @test: typecheck-pass
// @level: L1
// @tags: primitives, checked, shift, pow, overflow
// @description: Tests for checked_shl, checked_shr, checked_pow on all integer types

mount core.base.primitives.{Int8, Int16, Int32, Int64, Int128, UInt8, UInt16, UInt32, UInt64, UInt128, ISize, USize};

// =============================================================================
// Int - checked_shl
// =============================================================================

@test
fn test_int_checked_shl_valid() {
    assert_eq(1.checked_shl(0), Some(1));
    assert_eq(1.checked_shl(1), Some(2));
    assert_eq(1.checked_shl(10), Some(1024));
    assert_eq(1.checked_shl(62), Some(4611686018427387904));
}

@test
fn test_int_checked_shl_overflow() {
    assert(1.checked_shl(64) is None);
    assert(1.checked_shl(65) is None);
    assert(1.checked_shl(100) is None);
    assert(1.checked_shl(-1) is None);
}

@test
fn test_int_checked_shl_zero() {
    assert_eq(0.checked_shl(0), Some(0));
    assert_eq(0.checked_shl(63), Some(0));
}

// =============================================================================
// Int - checked_shr
// =============================================================================

@test
fn test_int_checked_shr_valid() {
    assert_eq(1024.checked_shr(0), Some(1024));
    assert_eq(1024.checked_shr(10), Some(1));
    assert_eq(1024.checked_shr(11), Some(0));
}

@test
fn test_int_checked_shr_overflow() {
    assert(1024.checked_shr(64) is None);
    assert(1024.checked_shr(65) is None);
    assert(1024.checked_shr(-1) is None);
}

// =============================================================================
// Int - checked_pow
// =============================================================================

@test
fn test_int_checked_pow_basic() {
    assert_eq(2.checked_pow(0), Some(1));
    assert_eq(2.checked_pow(1), Some(2));
    assert_eq(2.checked_pow(10), Some(1024));
    assert_eq(3.checked_pow(3), Some(27));
    assert_eq(10.checked_pow(6), Some(1000000));
}

@test
fn test_int_checked_pow_overflow() {
    // 2^63 overflows Int (max is 2^63 - 1)
    assert(2.checked_pow(63) is None);
    assert(10.checked_pow(19) is None);
}

@test
fn test_int_checked_pow_edge() {
    assert_eq(1.checked_pow(1000), Some(1));
    assert_eq(0.checked_pow(0), Some(1));
    assert_eq(0.checked_pow(5), Some(0));
    assert(2.checked_pow(-1) is None);
}

// =============================================================================
// Int8 - checked_shl / checked_shr / checked_pow
// =============================================================================

@test
fn test_int8_checked_shl() {
    let one = 1 as Int8;
    assert(one.checked_shl(0) is Some);
    assert(one.checked_shl(6) is Some);
    assert(one.checked_shl(8) is None);
    assert(one.checked_shl(-1) is None);
}

@test
fn test_int8_checked_shr() {
    let val = 64 as Int8;
    assert(val.checked_shr(0) is Some);
    assert(val.checked_shr(6) is Some);
    assert(val.checked_shr(8) is None);
}

@test
fn test_int8_checked_pow() {
    let two = 2 as Int8;
    assert(two.checked_pow(0) is Some);
    assert(two.checked_pow(6) is Some); // 64 fits in Int8
    assert(two.checked_pow(7) is None); // 128 overflows Int8 signed
    assert(two.checked_pow(-1) is None);
}

// =============================================================================
// Int16 - checked_shl / checked_shr / checked_pow
// =============================================================================

@test
fn test_int16_checked_shl() {
    let one = 1 as Int16;
    assert(one.checked_shl(0) is Some);
    assert(one.checked_shl(14) is Some);
    assert(one.checked_shl(16) is None);
}

@test
fn test_int16_checked_shr() {
    let val = 16384 as Int16;
    assert(val.checked_shr(0) is Some);
    assert(val.checked_shr(14) is Some);
    assert(val.checked_shr(16) is None);
}

@test
fn test_int16_checked_pow() {
    let three = 3 as Int16;
    assert(three.checked_pow(0) is Some);
    assert(three.checked_pow(5) is Some);  // 243 fits
    assert(three.checked_pow(10) is None); // 59049 overflows Int16
}

