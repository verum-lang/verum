@test
fn test_int32_checked_pow() {
    let ten = 10 as Int32;
    assert(ten.checked_pow(0) is Some);
    assert(ten.checked_pow(9) is Some); // 10^9 = 1000000000 fits
    assert(ten.checked_pow(10) is None); // 10^10 overflows Int32
}

