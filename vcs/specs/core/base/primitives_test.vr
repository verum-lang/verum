// =============================================================================
// primitives_test.vr - Comprehensive tests for primitive type methods
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @description: Tests for Int, Float, Bool, Byte, Char, and sized integer types

module test.primitives;

// =============================================================================
// Int Tests
// =============================================================================

@test
fn test_int_constants() {
    // Test MIN/MAX constants
    assert(Int.MIN == -9223372036854775808);
    assert(Int.MAX == 9223372036854775807);
    assert(Int.BITS == 64);

    // Deprecated methods still work
    assert(Int.min_value() == Int.MIN);
    assert(Int.max_value() == Int.MAX);
}

@test
fn test_int_abs() {
    assert((-5).abs() == 5);
    assert((5).abs() == 5);
    assert((0).abs() == 0);
    assert((-1).abs() == 1);
    assert((Int.MAX).abs() == Int.MAX);
}

@test
fn test_int_signum() {
    assert((-100).signum() == -1);
    assert((100).signum() == 1);
    assert((0).signum() == 0);
    assert((-1).signum() == -1);
    assert((1).signum() == 1);
}

@test
fn test_int_predicates() {
    assert((5).is_positive());
    assert(!(-5).is_positive());
    assert(!(0).is_positive());

    assert((-5).is_negative());
    assert(!(5).is_negative());
    assert(!(0).is_negative());

    assert((0).is_zero());
    assert(!(1).is_zero());
    assert(!(-1).is_zero());
}

@test
fn test_int_conversion() {
    let i: Int = 42;
    let f: Float = i.to_float();
    assert(f == 42.0);

    let negative: Int = -100;
    assert(negative.to_float() == -100.0);
}

@test
fn test_int_min_max() {
    assert((5).min(10) == 5);
    assert((10).min(5) == 5);
    assert((-5).min(5) == -5);

    assert((5).max(10) == 10);
    assert((10).max(5) == 10);
    assert((-5).max(5) == 5);
}

@test
fn test_int_clamp() {
    assert((5).clamp(0, 10) == 5);
    assert((-5).clamp(0, 10) == 0);
    assert((15).clamp(0, 10) == 10);
    assert((0).clamp(0, 10) == 0);
    assert((10).clamp(0, 10) == 10);
}

@test
fn test_int_in_range() {
    assert((5).in_range(0, 10));
    assert((0).in_range(0, 10));
    assert(!(10).in_range(0, 10));  // end is exclusive
    assert(!(-1).in_range(0, 10));
    assert(!(15).in_range(0, 10));
}

@test
fn test_int_pow() {
    assert((2).pow(0) == 1);
    assert((2).pow(1) == 2);
    assert((2).pow(10) == 1024);
    assert((3).pow(4) == 81);
    assert((10).pow(3) == 1000);
    assert((-2).pow(3) == -8);
    assert((-2).pow(4) == 16);
}

@test
fn test_int_checked_ops() {
    // checked_add
    match (5).checked_add(10) {
        Some(v) => assert(v == 15),
        None => assert(false),
    }

    // checked_sub
    match (10).checked_sub(5) {
        Some(v) => assert(v == 5),
        None => assert(false),
    }

    // checked_mul
    match (5).checked_mul(10) {
        Some(v) => assert(v == 50),
        None => assert(false),
    }

    // checked_div
    match (10).checked_div(2) {
        Some(v) => assert(v == 5),
        None => assert(false),
    }

    // Division by zero returns None
    assert((10).checked_div(0).is_none());
}

@test
fn test_int_wrapping_ops() {
    assert((5).wrapping_add(10) == 15);
    assert((10).wrapping_sub(5) == 5);
    assert((5).wrapping_mul(10) == 50);

    // Wrapping on overflow
    assert(Int.MAX.wrapping_add(1) == Int.MIN);
    assert(Int.MIN.wrapping_sub(1) == Int.MAX);
}

@test
fn test_int_saturating_ops() {
    assert((5).saturating_add(10) == 15);
    assert((10).saturating_sub(5) == 5);
    assert((5).saturating_mul(10) == 50);

    // Saturates at bounds
    assert(Int.MAX.saturating_add(1) == Int.MAX);
    assert(Int.MIN.saturating_sub(1) == Int.MIN);
}

@test
fn test_int_bit_counting() {
    // count_ones
    assert((0b1010101).count_ones() == 4);
    assert((0).count_ones() == 0);
    assert((-1).count_ones() == 64);  // All bits set for -1

    // count_zeros
    assert((0).count_zeros() == 64);
    assert((-1).count_zeros() == 0);

    // leading_zeros
    assert((1).leading_zeros() == 63);
    assert((0).leading_zeros() == 64);

    // trailing_zeros
    assert((8).trailing_zeros() == 3);  // 8 = 0b1000
    assert((1).trailing_zeros() == 0);
}

@test
fn test_int_rotate() {
    let x: Int = 0b10110001;
    // Note: rotate_left and rotate_right are 64-bit operations
    let rotated = x.rotate_left(4);
    // Verify rotation happened (exact value depends on bit width)
    assert(rotated != x);
}

@test
fn test_int_byte_conversion() {
    let x: Int = 0x0102030405060708;
    let le_bytes = x.to_le_bytes();
    let be_bytes = x.to_be_bytes();

    // Little-endian: least significant byte first
    assert(le_bytes[0] == 0x08);
    assert(le_bytes[7] == 0x01);

    // Big-endian: most significant byte first
    assert(be_bytes[0] == 0x01);
    assert(be_bytes[7] == 0x08);

    // Round-trip
    assert(Int.from_le_bytes(le_bytes) == x);
    assert(Int.from_be_bytes(be_bytes) == x);
}

@test
fn test_int_swap_bytes() {
    let x: Int = 0x0102030405060708;
    let swapped = x.swap_bytes();
    assert(swapped == 0x0807060504030201);
    // Double swap returns original
    assert(swapped.swap_bytes() == x);
}

@test
fn test_int_reverse_bits() {
    let x: Int = 1;  // Bit 0 set
    let reversed = x.reverse_bits();
    // Bit 63 should be set now (sign bit for signed)
    assert(reversed != 0);
    // Double reverse returns original
    assert(reversed.reverse_bits() == x);
}

@test
fn test_int_rotate_right() {
    let x: Int = 0b10110001;
    let rotated = x.rotate_right(4);
    assert(rotated != x);
    // Rotate left then right should give original
    let y: Int = 12345;
    assert(y.rotate_left(17).rotate_right(17) == y);
}

// =============================================================================
// Int Radix Conversion Tests
// =============================================================================

@test
fn test_int_to_binary() {
    assert_eq((42).to_binary(), "101010");
    assert_eq((0).to_binary(), "0");
    assert_eq((1).to_binary(), "1");
    assert_eq((255).to_binary(), "11111111");
}

@test
fn test_int_to_hex() {
    assert_eq((255).to_hex(), "ff");
    assert_eq((0).to_hex(), "0");
    assert_eq((16).to_hex(), "10");
    assert_eq((256).to_hex(), "100");
}

@test
fn test_int_to_octal() {
    assert_eq((8).to_octal(), "10");
    assert_eq((0).to_octal(), "0");
    assert_eq((7).to_octal(), "7");
    assert_eq((64).to_octal(), "100");
}

// =============================================================================
// Float Tests
// =============================================================================

@test
fn test_float_constants() {
    assert(Float.BITS == 64);
    assert(Float.PI > 3.14 && Float.PI < 3.15);
    assert(Float.E > 2.71 && Float.E < 2.72);

    // Deprecated methods
    assert(Float.pi() == Float.PI);
    assert(Float.e() == Float.E);
}

@test
fn test_float_special_values() {
    let inf = Float.infinity();
    let neg_inf = Float.neg_infinity();
    let nan = Float.nan();

    assert(inf.is_infinite());
    assert(neg_inf.is_infinite());
    assert(!nan.is_infinite());

    assert(nan.is_nan());
    assert(!inf.is_nan());
    assert(!neg_inf.is_nan());

    assert(!inf.is_finite());
    assert(!neg_inf.is_finite());
    assert(!nan.is_finite());
    assert((1.0).is_finite());
}

@test
fn test_float_predicates() {
    assert((1.0).is_positive());
    assert(!(-1.0).is_positive());
    assert(!(0.0).is_positive());

    assert((-1.0).is_negative());
    assert(!(1.0).is_negative());
    assert(!(0.0).is_negative());

    assert((0.0).is_zero());
    assert((-0.0).is_zero());
    assert(!(1.0).is_zero());
}

@test
fn test_float_signum() {
    assert((5.0).signum() == 1.0);
    assert((-5.0).signum() == -1.0);
    assert((0.0).signum() == 0.0);

    // NaN signum returns NaN
    let nan_signum = Float.nan().signum();
    assert(nan_signum.is_nan());
}

@test
fn test_float_abs() {
    assert((-5.0).abs() == 5.0);
    assert((5.0).abs() == 5.0);
    assert((0.0).abs() == 0.0);
}

@test
fn test_float_conversion() {
    assert((42.7).to_int() == 42);
    assert((-42.7).to_int() == -42);
    assert((0.9).to_int() == 0);
}

@test
fn test_float_sqrt() {
    assert((4.0).sqrt() == 2.0);
    assert((9.0).sqrt() == 3.0);
    assert((1.0).sqrt() == 1.0);
    assert((0.0).sqrt() == 0.0);
}

@test
fn test_float_cbrt() {
    assert((8.0).cbrt() == 2.0);
    assert((27.0).cbrt() == 3.0);
    assert((-8.0).cbrt() == -2.0);
}

@test
fn test_float_exp_log() {
    // exp
    let e_1 = (1.0).exp();
    assert(e_1 > 2.71 && e_1 < 2.72);
    assert((0.0).exp() == 1.0);

    // ln (natural log)
    assert((1.0).ln() == 0.0);
    let ln_e = Float.E.ln();
    assert(ln_e > 0.99 && ln_e < 1.01);

    // log10
    assert((10.0).log10() == 1.0);
    assert((100.0).log10() == 2.0);

    // log2
    assert((2.0).log2() == 1.0);
    assert((8.0).log2() == 3.0);
}

@test
fn test_float_pow() {
    assert((2.0).pow(3.0) == 8.0);
    assert((2.0).pow(0.5) == (2.0).sqrt());
    assert((10.0).pow(2.0) == 100.0);

    // powi (integer power)
    assert((2.0).powi(3) == 8.0);
    assert((2.0).powi(10) == 1024.0);
}

@test
fn test_float_rounding() {
    // floor
    assert((2.7).floor() == 2.0);
    assert((-2.7).floor() == -3.0);

    // ceil
    assert((2.3).ceil() == 3.0);
    assert((-2.3).ceil() == -2.0);

    // round
    assert((2.5).round() == 3.0);
    assert((2.4).round() == 2.0);

    // trunc
    assert((2.7).trunc() == 2.0);
    assert((-2.7).trunc() == -2.0);

    // fract
    let fract_val = (2.75).fract();
    assert(fract_val > 0.74 && fract_val < 0.76);
}

@test
fn test_float_min_max_clamp() {
    assert((5.0).min(10.0) == 5.0);
    assert((10.0).min(5.0) == 5.0);

    assert((5.0).max(10.0) == 10.0);
    assert((10.0).max(5.0) == 10.0);

    assert((5.0).clamp(0.0, 10.0) == 5.0);
    assert((-5.0).clamp(0.0, 10.0) == 0.0);
    assert((15.0).clamp(0.0, 10.0) == 10.0);
}

@test
fn test_float_fma() {
    // fma(a, b, c) = a * b + c with single rounding
    let result = (2.0).mul_add(3.0, 4.0);
    assert(result == 10.0);
}

@test
fn test_float_hypot() {
    // hypot(3, 4) = 5 (Pythagorean triple)
    assert((3.0).hypot(4.0) == 5.0);
}

@test
fn test_float_trig() {
    let pi = Float.PI;

    // sin
    assert((0.0).sin() == 0.0);
    let sin_half_pi = (pi / 2.0).sin();
    assert(sin_half_pi > 0.99 && sin_half_pi < 1.01);

    // cos
    assert((0.0).cos() == 1.0);
    let cos_pi = pi.cos();
    assert(cos_pi > -1.01 && cos_pi < -0.99);

    // tan
    assert((0.0).tan() == 0.0);

    // sin_cos
    let (s, c) = (0.0).sin_cos();
    assert(s == 0.0);
    assert(c == 1.0);
}

@test
fn test_float_inverse_trig() {
    assert((0.0).asin() == 0.0);
    assert((1.0).acos() == 0.0);
    assert((0.0).atan() == 0.0);

    // atan2
    let pi = Float.PI;
    let atan2_result = (1.0).atan2(1.0);
    assert(atan2_result > pi/4.0 - 0.01 && atan2_result < pi/4.0 + 0.01);
}

@test
fn test_float_hyperbolic() {
    assert((0.0).sinh() == 0.0);
    assert((0.0).cosh() == 1.0);
    assert((0.0).tanh() == 0.0);

    // Inverse hyperbolic
    assert((0.0).asinh() == 0.0);
    assert((1.0).acosh() == 0.0);
    assert((0.0).atanh() == 0.0);
}

@test
fn test_float_angle_conversion() {
    let pi = Float.PI;

    assert(pi.to_degrees() == 180.0);
    assert((180.0).to_radians() == pi);
}

@test
fn test_float_bits() {
    let x: Float = 1.0;
    let bits = x.to_bits();
    let reconstructed = Float.from_bits(bits);
    assert(reconstructed == x);
}

@test
fn test_float_special_constants() {
    let eps = Float.epsilon();
    assert(eps > 0.0);
    assert(eps < 1e-15);

    let min_pos = Float.min_positive();
    assert(min_pos > 0.0);
    assert(min_pos.is_finite());

    let max_val = Float.max_value();
    assert(max_val > 0.0);
    assert(max_val.is_finite());
}

@test
fn test_float_is_normal() {
    assert((1.0).is_normal());
    assert((-1.0).is_normal());
    assert(!(0.0).is_normal());
    assert(!Float.infinity().is_normal());
    assert(!Float.nan().is_normal());
}

@test
fn test_float_exp2() {
    assert((0.0).exp2() == 1.0);
    assert((1.0).exp2() == 2.0);
    assert((3.0).exp2() == 8.0);
    assert((10.0).exp2() == 1024.0);
}

@test
fn test_float_exp_m1_ln_1p() {
    // exp_m1(x) = e^x - 1, more precise near zero
    assert((0.0).exp_m1() == 0.0);
    let val = (1.0).exp_m1();
    assert(val > 1.71 && val < 1.72);

    // ln_1p(x) = ln(1 + x), more precise near zero
    assert((0.0).ln_1p() == 0.0);
    let ln_val = (1.0).ln_1p();  // ln(2)
    assert(ln_val > 0.69 && ln_val < 0.70);
}

@test
fn test_float_log_base() {
    assert((8.0).log_base(2.0) == 3.0);
    assert((1000.0).log_base(10.0) == 3.0);
    assert((1.0).log_base(10.0) == 0.0);
}

@test
fn test_float_copysign() {
    assert((1.0).copysign(-1.0) == -1.0);
    assert((-1.0).copysign(1.0) == 1.0);
    assert((5.0).copysign(1.0) == 5.0);
    assert((5.0).copysign(-1.0) == -5.0);
}

// =============================================================================
// Bool Tests
// =============================================================================

@test
fn test_bool_logic() {
    assert(true.and_then(true));
    assert(!true.and_then(false));
    assert(!false.and_then(true));
    assert(!false.and_then(false));

    assert(true.or_else(true));
    assert(true.or_else(false));
    assert(false.or_else(true));
    assert(!false.or_else(false));

    assert(!true.xor(true));
    assert(true.xor(false));
    assert(false.xor(true));
    assert(!false.xor(false));
}

@test
fn test_bool_to_int() {
    assert(true.to_int() == 1);
    assert(false.to_int() == 0);
}

@test
fn test_bool_select() {
    assert(true.select(10, 20) == 10);
    assert(false.select(10, 20) == 20);
}

// =============================================================================
// Byte Tests
// =============================================================================

@test
fn test_byte_bounds() {
    assert(Byte.min_value() == 0);
    assert(Byte.max_value() == 255);
}

@test
fn test_byte_ascii() {
    let upper_a: Byte = 65;  // 'A'
    let lower_a: Byte = 97;  // 'a'
    let digit: Byte = 48;    // '0'
    let space: Byte = 32;    // ' '

    assert(upper_a.is_ascii_alphabetic());
    assert(lower_a.is_ascii_alphabetic());
    assert(!digit.is_ascii_alphabetic());

    assert(digit.is_ascii_digit());
    assert(!upper_a.is_ascii_digit());

    assert(upper_a.is_ascii_alphanumeric());
    assert(digit.is_ascii_alphanumeric());
    assert(!space.is_ascii_alphanumeric());

    assert(space.is_ascii_whitespace());
    assert(!upper_a.is_ascii_whitespace());
}

@test
fn test_byte_case() {
    let upper_a: Byte = 65;
    let lower_a: Byte = 97;

    assert(lower_a.to_ascii_uppercase() == upper_a);
    assert(upper_a.to_ascii_lowercase() == lower_a);
}

@test
fn test_byte_conversion() {
    let b: Byte = 42;
    assert(b.to_int() == 42);
}

@test
fn test_byte_checked_ops() {
    let a: Byte = 200;
    let b: Byte = 100;

    // Overflow case
    assert(a.checked_add(b).is_none());

    // No overflow
    let c: Byte = 50;
    match c.checked_add(b) {
        Some(v) => assert(v == 150),
        None => assert(false),
    }
}

@test
fn test_byte_saturating() {
    let a: Byte = 200;
    let b: Byte = 100;
    assert(a.saturating_add(b) == 255);  // Saturates at max

    let c: Byte = 50;
    assert(c.saturating_add(b) == 150);
}

@test
fn test_byte_wrapping() {
    let a: Byte = 200;
    let b: Byte = 100;
    assert(a.wrapping_add(b) == 44);  // (200 + 100) % 256 = 44
}

// =============================================================================
// Char Tests
// =============================================================================

@test
fn test_char_constants() {
    assert(Char.replacement() == '\u{FFFD}');
}

@test
fn test_char_ascii() {
    assert('a'.is_ascii());
    assert('Z'.is_ascii());
    assert('0'.is_ascii());
    // Unicode beyond ASCII
    // assert(!'é'.is_ascii());  // Skip for now if unicode literals not supported
}

@test
fn test_char_categories() {
    assert('a'.is_alphabetic());
    assert('Z'.is_alphabetic());
    assert(!'5'.is_alphabetic());

    assert('5'.is_numeric());
    assert(!'a'.is_numeric());

    assert('a'.is_alphanumeric());
    assert('5'.is_alphanumeric());
    assert(!' '.is_alphanumeric());

    assert(' '.is_whitespace());
    assert('\t'.is_whitespace());
    assert('\n'.is_whitespace());
    assert(!'a'.is_whitespace());
}

@test
fn test_char_case() {
    assert('a'.is_lowercase());
    assert(!'A'.is_lowercase());

    assert('A'.is_uppercase());
    assert(!'a'.is_uppercase());

    assert('a'.to_uppercase() == 'A');
    assert('A'.to_lowercase() == 'a');
}

@test
fn test_char_digit() {
    // to_digit
    match '5'.to_digit(10) {
        Some(v) => assert(v == 5),
        None => assert(false),
    }

    match 'a'.to_digit(16) {
        Some(v) => assert(v == 10),
        None => assert(false),
    }

    assert('z'.to_digit(10).is_none());

    // from_digit
    match Char.from_digit(5, 10) {
        Some(c) => assert(c == '5'),
        None => assert(false),
    }

    // is_digit
    assert('5'.is_digit(10));
    assert('a'.is_digit(16));
    assert(!'g'.is_digit(16));
}

@test
fn test_char_utf8_len() {
    assert('a'.len_utf8() == 1);      // ASCII
    // Note: Testing multi-byte chars requires unicode literal support
}

@test
fn test_char_utf16_len() {
    assert('a'.len_utf16() == 1);
}

@test
fn test_char_max_value() {
    let max = Char.max_value();
    assert(max == '\u{10FFFF}');
}

@test
fn test_char_is_control() {
    assert('\0'.is_control());
    assert('\n'.is_control());
    assert('\t'.is_control());
    assert(!'a'.is_control());
    assert(!' '.is_control());
}

// Note: encode_utf8() return type needs runtime verification
// Skipping encode_utf8 test - requires runtime byte buffer

// =============================================================================
// Unit Type Tests
// =============================================================================

@test
fn test_unit_eq() {
    let a: () = ();
    let b: () = ();
    assert(a == b);
}

@test
fn test_unit_default() {
    let u: () = ().default();
    assert(u == ());
}

// =============================================================================
// UInt64 Tests
// =============================================================================

@test
fn test_uint64_constants() {
    assert(UInt64.MIN == 0);
    assert(UInt64.BITS == 64);
}

@test
fn test_uint64_min_max() {
    let a: UInt64 = 100;
    let b: UInt64 = 200;
    assert(a.min(b) == a);
    assert(a.max(b) == b);
}

@test
fn test_uint64_clamp() {
    let x: UInt64 = 150;
    let lo: UInt64 = 100;
    let hi: UInt64 = 200;
    assert(x.clamp(lo, hi) == x);
}

@test
fn test_uint64_bytes() {
    let x: UInt64 = 0x0102030405060708;
    let le = x.to_le_bytes();
    let be = x.to_be_bytes();

    assert(le[0] == 0x08);
    assert(be[0] == 0x01);

    assert(UInt64.from_le_bytes(le) == x);
    assert(UInt64.from_be_bytes(be) == x);
}

@test
fn test_uint64_checked_ops() {
    let a: UInt64 = 100;
    let b: UInt64 = 50;

    match a.checked_add(b) {
        Some(v) => assert(v == 150),
        None => assert(false),
    }

    match a.checked_sub(b) {
        Some(v) => assert(v == 50),
        None => assert(false),
    }

    match a.checked_mul(b) {
        Some(v) => assert(v == 5000),
        None => assert(false),
    }
}

@test
fn test_uint64_bit_ops() {
    let x: UInt64 = 0b1010;
    assert(x.count_ones() == 2);
    assert(x.trailing_zeros() == 1);
}

// =============================================================================
// Int32 Tests
// =============================================================================

@test
fn test_int32_constants() {
    assert(Int32.MIN == -2147483648);
    assert(Int32.MAX == 2147483647);
    assert(Int32.BITS == 32);
}

@test
fn test_int32_abs_signum() {
    let x: Int32 = -42;
    assert(x.abs() == 42);
    assert(x.signum() == -1);

    let y: Int32 = 42;
    assert(y.signum() == 1);
}

@test
fn test_int32_bytes() {
    let x: Int32 = 0x01020304;
    let le = x.to_le_bytes();
    let be = x.to_be_bytes();

    assert(le[0] == 0x04);
    assert(be[0] == 0x01);

    assert(Int32.from_le_bytes(le) == x);
    assert(Int32.from_be_bytes(be) == x);
}

