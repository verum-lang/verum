// =============================================================================
// Protocol Implementations Tests
// =============================================================================

@test
fn test_int_eq() {
    let a: Int = 42;
    let b: Int = 42;
    let c: Int = 43;

    assert(a == b);
    assert(a != c);
}

@test
fn test_int_ord() {
    let a: Int = 10;
    let b: Int = 20;

    assert(a < b);
    assert(b > a);
    assert(a <= a);
    assert(a >= a);
}

@test
fn test_float_eq() {
    let a: Float = 3.14;
    let b: Float = 3.14;

    assert(a == b);

    // NaN != NaN
    let nan = Float.nan();
    assert(nan != nan);
}

@test
fn test_bool_eq_ord() {
    assert(true == true);
    assert(false == false);
    assert(true != false);

    assert(false < true);
    assert(true > false);
}

@test
fn test_char_eq_ord() {
    assert('a' == 'a');
    assert('a' != 'b');
    assert('a' < 'b');
    assert('z' > 'a');
}

@test
fn test_default_values() {
    assert(Int.default() == 0);
    assert(Float.default() == 0.0);
    assert(Bool.default() == false);
    assert(Byte.default() == 0);
    assert(Char.default() == '\0');
}

@test
fn test_clone_copy() {
    let i: Int = 42;
    let i_clone = i.clone();
    assert(i == i_clone);

    let f: Float = 3.14;
    let f_clone = f.clone();
    assert(f == f_clone);

    let b: Bool = true;
    let b_clone = b.clone();
    assert(b == b_clone);
}

// =============================================================================
// Sized Integer Conversion Tests
// =============================================================================

@test
fn test_int8_bounds_and_ops() {
    let x: Int8 = 127;
    let y: Int8 = -128;
    assert(x == Int8.MAX);
    assert(y == Int8.MIN);
    assert(x.abs() == 127);
    assert(-1_i8.abs() == 1);
}

@test
fn test_int16_bounds() {
    assert(Int16.MIN == -32768);
    assert(Int16.MAX == 32767);
    assert(Int16.BITS == 16);
}

@test
fn test_uint8_bounds() {
    assert(UInt8.MIN == 0);
    assert(UInt8.MAX == 255);
    assert(UInt8.BITS == 8);
}

@test
fn test_uint16_bounds() {
    assert(UInt16.MIN == 0);
    assert(UInt16.MAX == 65535);
    assert(UInt16.BITS == 16);
}

@test
fn test_uint32_bounds() {
    assert(UInt32.MIN == 0);
    assert(UInt32.BITS == 32);
}

@test
fn test_int8_checked_arithmetic() {
    let x: Int8 = 100;
    // 100 + 100 overflows Int8
    assert(x.checked_add(100).is_none());
    // 100 + 27 = 127 (max) — OK
    match x.checked_add(27) {
        Some(v) => assert(v == 127),
        None => assert(false),
    }
}

@test
fn test_int16_wrapping() {
    assert(Int16.MAX.wrapping_add(1) == Int16.MIN);
    assert(Int16.MIN.wrapping_sub(1) == Int16.MAX);
}

@test
fn test_uint8_saturating() {
    let x: UInt8 = 250;
    assert(x.saturating_add(10) == 255);
    let y: UInt8 = 5;
    assert(y.saturating_sub(10) == 0);
}

@test
fn test_int_to_sized_conversion() {
    let x: Int = 42;
    let as_i32: Int32 = x as Int32;
    assert(as_i32 == 42);
    let as_i16: Int16 = x as Int16;
    assert(as_i16 == 42);
    let as_i8: Int8 = x as Int8;
    assert(as_i8 == 42);
}

@test
fn test_uint_cross_size_conversion() {
    let x: UInt8 = 200;
    let as_u16: UInt16 = x as UInt16;
    assert(as_u16 == 200);
    let as_u32: UInt32 = x as UInt32;
    assert(as_u32 == 200);
    let as_u64: UInt64 = x as UInt64;
    assert(as_u64 == 200);
}

@test
fn test_signed_unsigned_conversion() {
    let x: Int32 = 100;
    let as_u32: UInt32 = x as UInt32;
    assert(as_u32 == 100);
    let back: Int32 = as_u32 as Int32;
    assert(back == 100);
}

// =============================================================================
// Float Special Value Arithmetic
// =============================================================================

@test
fn test_float_infinity_arithmetic() {
    let inf = Float.infinity();
    let neg_inf = Float.neg_infinity();

    // inf + inf = inf
    assert((inf + inf).is_infinite());
    assert((inf + inf).is_positive());

    // inf + neg_inf = NaN
    assert((inf + neg_inf).is_nan());

    // inf * 2 = inf
    assert((inf * 2.0).is_infinite());

    // inf * -1 = neg_inf
    let neg = inf * -1.0;
    assert(neg.is_infinite());
    assert(neg.is_negative());
}

@test
fn test_float_nan_arithmetic() {
    let nan = Float.nan();

    // NaN propagates through all operations
    assert((nan + 1.0).is_nan());
    assert((nan - 1.0).is_nan());
    assert((nan * 2.0).is_nan());
    assert((nan / 2.0).is_nan());

    // NaN * 0 = NaN (not 0)
    assert((nan * 0.0).is_nan());

    // NaN comparisons are always false
    assert(!(nan == nan));
    assert(!(nan < nan));
    assert(!(nan > nan));
    assert(!(nan <= nan));
    assert(!(nan >= nan));
    assert(nan != nan);
}

@test
fn test_float_negative_zero() {
    let pos_zero = 0.0;
    let neg_zero = -0.0;

    // -0 == +0
    assert(pos_zero == neg_zero);

    // But they have different bit representations
    assert(pos_zero.to_bits() != neg_zero.to_bits());

    // is_zero for both
    assert(pos_zero.is_zero());
    assert(neg_zero.is_zero());
}

@test
fn test_float_division_special() {
    // 1 / 0 = inf
    let inf = 1.0 / 0.0;
    assert(inf.is_infinite());
    assert(inf.is_positive());

    // -1 / 0 = -inf
    let neg_inf = -1.0 / 0.0;
    assert(neg_inf.is_infinite());
    assert(neg_inf.is_negative());

    // 0 / 0 = NaN
    let nan = 0.0 / 0.0;
    assert(nan.is_nan());
}

@test
fn test_float_infinity_comparison() {
    let inf = Float.infinity();
    let neg_inf = Float.neg_infinity();
    let x = 1e308;

    assert(inf > x);
    assert(neg_inf < x);
    assert(neg_inf < inf);
    assert(inf == inf);
}

// =============================================================================
// Bit Rotation Edge Cases
// =============================================================================

@test
fn test_int_rotate_by_zero() {
    let x: Int = 0b10110001;
    assert(x.rotate_left(0) == x);
    assert(x.rotate_right(0) == x);
}

@test
fn test_int_rotate_full_width() {
    let x: Int = 12345;
    // Rotating by full bit width should return original
    assert(x.rotate_left(64) == x);
    assert(x.rotate_right(64) == x);
}

@test
fn test_int_rotate_left_right_inverse() {
    let x: Int = 0xDEADBEEF;
    // Rotate left then right by same amount = identity
    assert(x.rotate_left(13).rotate_right(13) == x);
    assert(x.rotate_left(37).rotate_right(37) == x);
    assert(x.rotate_left(1).rotate_right(1) == x);
}

@test
fn test_int_rotate_equivalences() {
    let x: Int = 0xCAFEBABE;
    // rotate_left(n) == rotate_right(64 - n) for n < 64
    assert(x.rotate_left(17) == x.rotate_right(47));
    assert(x.rotate_left(32) == x.rotate_right(32));
}

// =============================================================================
// Byte Combined Operations
// =============================================================================

@test
fn test_byte_bit_operations() {
    let a: Byte = 0b11001100;
    let b: Byte = 0b10101010;

    // Bitwise operations
    assert((a & b) == 0b10001000);
    assert((a | b) == 0b11101110);
    assert((a ^ b) == 0b01100110);
}

@test
fn test_byte_range() {
    // Test all boundary values
    let min: Byte = 0;
    let max: Byte = 255;
    let mid: Byte = 128;

    assert(min == Byte.min_value());
    assert(max == Byte.max_value());
    assert(mid.to_int() == 128);
}

@test
fn test_byte_ascii_classification_comprehensive() {
    // Test all ASCII control chars
    let null_byte: Byte = 0;
    let tab: Byte = 9;
    let newline: Byte = 10;

    assert(!null_byte.is_ascii_alphabetic());
    assert(!tab.is_ascii_alphabetic());
    assert(!newline.is_ascii_alphabetic());

    // Test digits 0-9
    let zero: Byte = 48;
    let nine: Byte = 57;
    assert(zero.is_ascii_digit());
    assert(nine.is_ascii_digit());

    // Just outside digit range
    let before_zero: Byte = 47;
    let after_nine: Byte = 58;
    assert(!before_zero.is_ascii_digit());
    assert(!after_nine.is_ascii_digit());
}

// =============================================================================
// Char Unicode Edge Cases
// =============================================================================

@test
fn test_char_boundary_values() {
    // Null character
    assert('\0'.is_control());
    assert(!'\0'.is_alphabetic());

    // Space — not control, is whitespace
    assert(' '.is_whitespace());
    assert(!' '.is_control());

    // DEL (127) is control
    let del = '\u{7F}';
    assert(del.is_control());
    assert(!del.is_alphabetic());
}

@test
fn test_char_unicode_categories() {
    // Basic Latin
    assert('A'.is_alphabetic());
    assert('z'.is_alphabetic());
    assert('0'.is_numeric());
    assert('9'.is_numeric());

    // Ensure digits are not alpha and vice versa
    assert(!'0'.is_alphabetic());
    assert(!'A'.is_numeric());
}

@test
fn test_char_case_conversion_edge() {
    // Non-letter characters should be unchanged
    assert('5'.to_uppercase() == '5');
    assert('5'.to_lowercase() == '5');
    assert(' '.to_uppercase() == ' ');
    assert('@'.to_lowercase() == '@');
}

@test
fn test_char_digit_radix() {
    // Decimal digits
    assert('0'.is_digit(10));
    assert('9'.is_digit(10));
    assert(!'a'.is_digit(10));

    // Hexadecimal digits
    assert('0'.is_digit(16));
    assert('9'.is_digit(16));
    assert('a'.is_digit(16));
    assert('f'.is_digit(16));
    assert(!'g'.is_digit(16));

    // Binary digits
    assert('0'.is_digit(2));
    assert('1'.is_digit(2));
    assert(!'2'.is_digit(2));

    // Octal digits
    assert('7'.is_digit(8));
    assert(!'8'.is_digit(8));
}

@test
fn test_char_to_digit_all_hex() {
    // Verify to_digit for all hex digits
    assert_eq('0'.to_digit(16), Some(0));
    assert_eq('1'.to_digit(16), Some(1));
    assert_eq('9'.to_digit(16), Some(9));
    assert_eq('a'.to_digit(16), Some(10));
    assert_eq('b'.to_digit(16), Some(11));
    assert_eq('f'.to_digit(16), Some(15));
}

@test
fn test_char_from_digit_roundtrip() {
    // Verify from_digit -> to_digit roundtrip for decimal
    let mut i = 0;
    while i < 10 {
        let ch = Char.from_digit(i, 10);
        assert(ch.is_some());
        let d = ch.unwrap().to_digit(10);
        assert(d.is_some());
        assert_eq(d.unwrap(), i);
        i = i + 1;
    }
}

// =============================================================================
// Int Advanced Operations
// =============================================================================

@test
fn test_int_overflowing_add() {
    // Normal case
    let (val, overflow) = (5).overflowing_add(10);
    assert_eq(val, 15);
    assert(!overflow);

    // Overflow case
    let (val2, overflow2) = Int.MAX.overflowing_add(1);
    assert_eq(val2, Int.MIN);
    assert(overflow2);
}

@test
fn test_int_overflowing_mul() {
    let (val, overflow) = (5).overflowing_mul(10);
    assert_eq(val, 50);
    assert(!overflow);
}

@test
fn test_int_pow_edge_cases() {
    // Any number to power 0 is 1
    assert((0).pow(0) == 1);
    assert((100).pow(0) == 1);
    assert((-5).pow(0) == 1);

    // 0 to any positive power is 0
    assert((0).pow(1) == 0);
    assert((0).pow(10) == 0);

    // 1 to any power is 1
    assert((1).pow(100) == 1);
    assert((1).pow(0) == 1);

    // -1 to even/odd powers
    assert((-1).pow(2) == 1);
    assert((-1).pow(3) == -1);
    assert((-1).pow(100) == 1);
    assert((-1).pow(101) == -1);
}

@test
fn test_int_count_ones_patterns() {
    assert((0).count_ones() == 0);
    assert((1).count_ones() == 1);
    assert((3).count_ones() == 2);     // 0b11
    assert((7).count_ones() == 3);     // 0b111
    assert((15).count_ones() == 4);    // 0b1111
    assert((255).count_ones() == 8);   // 0b11111111
}

@test
fn test_float_classify() {
    // Normal numbers
    assert((1.0).is_normal());
    assert((-42.5).is_normal());

    // Subnormal — very small but not zero
    let tiny = Float.min_positive() / 2.0;
    assert(!tiny.is_normal());
    assert(tiny.is_finite());

    // Zero
    assert(!(0.0).is_normal());

    // Infinity
    assert(!Float.infinity().is_normal());

    // NaN
    assert(!Float.nan().is_normal());
}

@test
fn test_float_total_cmp_with_nan() {
    // NaN should not equal itself
    let nan1 = Float.nan();
    let nan2 = Float.nan();
    assert(nan1 != nan2);

    // Regular comparison still works
    assert(1.0 < 2.0);
    assert(-1.0 < 1.0);
    assert(0.0 == 0.0);
}

// =============================================================================
// Int.overflowing_sub (gap)
// =============================================================================

@test
fn test_int_overflowing_sub() {
    // Normal case
    let (val, overflow) = (10).overflowing_sub(5);
    assert_eq(val, 5);
    assert(!overflow);

    // Overflow case (underflow)
    let (val2, overflow2) = Int.MIN.overflowing_sub(1);
    assert_eq(val2, Int.MAX);
    assert(overflow2);

    // Zero difference
    let (val3, overflow3) = (42).overflowing_sub(42);
    assert_eq(val3, 0);
    assert(!overflow3);
}

// =============================================================================
// Byte.wrapping_sub (gap)
// =============================================================================

@test
fn test_byte_wrapping_sub() {
    let a: Byte = 100;
    let b: Byte = 50;
    assert(a.wrapping_sub(b) == 50);

    // Underflow wraps
    let c: Byte = 10;
    let d: Byte = 20;
    assert(c.wrapping_sub(d) == 246);  // (10 - 20) mod 256 = 246

    // Zero wrapping
    let zero: Byte = 0;
    let one: Byte = 1;
    assert(zero.wrapping_sub(one) == 255);
}

@test
fn test_byte_saturating_sub() {
    let a: Byte = 100;
    let b: Byte = 50;
    assert(a.saturating_sub(b) == 50);

    // Saturates at 0 (not underflow)
    let c: Byte = 10;
    let d: Byte = 20;
    assert(c.saturating_sub(d) == 0);
}

@test
fn test_byte_checked_sub() {
    let a: Byte = 100;
    let b: Byte = 50;
    match a.checked_sub(b) {
        Some(v) => assert(v == 50),
        None => assert(false),
    }

    // Underflow returns None
    let c: Byte = 10;
    let d: Byte = 20;
    assert(c.checked_sub(d).is_none());
}


// =============================================================================
// UInt64 Extended Tests (gap: wrapping, saturating, rotate, swap, to_int)
// =============================================================================

@test
fn test_uint64_wrapping_add_sub() {
    let a: UInt64 = 100;
    let b: UInt64 = 50;
    assert(a.wrapping_add(b) == 150);
    assert(a.wrapping_sub(b) == 50);

    // Wrapping on overflow
    assert(UInt64.MAX.wrapping_add(1) == 0);

    // Wrapping on underflow
    let zero: UInt64 = 0;
    assert(zero.wrapping_sub(1) == UInt64.MAX);
}

@test
fn test_uint64_saturating_add_sub() {
    let a: UInt64 = 100;
    let b: UInt64 = 50;
    assert(a.saturating_add(b) == 150);
    assert(a.saturating_sub(b) == 50);

    // Saturates at max
    assert(UInt64.MAX.saturating_add(1) == UInt64.MAX);

    // Saturates at 0
    let zero: UInt64 = 0;
    assert(zero.saturating_sub(1) == 0);
}

@test
fn test_uint64_leading_trailing_zeros() {
    let x: UInt64 = 1;
    assert(x.leading_zeros() == 63);
    assert(x.trailing_zeros() == 0);

    let y: UInt64 = 8;  // 0b1000
    assert(y.trailing_zeros() == 3);
}

@test
fn test_uint64_rotate() {
    let x: UInt64 = 0xDEADBEEF;
    // Rotate left then right by same amount = identity
    assert(x.rotate_left(13).rotate_right(13) == x);
    assert(x.rotate_left(32).rotate_right(32) == x);
    assert(x.rotate_left(1).rotate_right(1) == x);

    // Rotate by 0 = identity
    assert(x.rotate_left(0) == x);
    assert(x.rotate_right(0) == x);
}

@test
fn test_uint64_swap_bytes() {
    let x: UInt64 = 0x0102030405060708;
    let swapped = x.swap_bytes();
    assert(swapped == 0x0807060504030201);
    // Double swap returns original
    assert(swapped.swap_bytes() == x);
}

@test
fn test_uint64_to_int() {
    let x: UInt64 = 42;
    assert(x.to_int() == 42);

    let zero: UInt64 = 0;
    assert(zero.to_int() == 0);
}

// =============================================================================
// UInt32 Comprehensive Tests (gap: almost all methods untested)
// =============================================================================

@test
fn test_uint32_constants() {
    assert(UInt32.MIN == 0);
    assert(UInt32.MAX == 4294967295);
    assert(UInt32.BITS == 32);
}

@test
fn test_uint32_min_max_clamp() {
    let a: UInt32 = 100;
    let b: UInt32 = 200;
    assert(a.min(b) == a);
    assert(a.max(b) == b);

    let x: UInt32 = 150;
    assert(x.clamp(100, 200) == 150);
    assert(x.clamp(200, 300) == 200);
    assert(x.clamp(0, 100) == 100);
}

@test
fn test_uint32_bytes() {
    let x: UInt32 = 0x01020304;
    let le = x.to_le_bytes();
    let be = x.to_be_bytes();

    assert(le[0] == 0x04);
    assert(le[3] == 0x01);
    assert(be[0] == 0x01);
    assert(be[3] == 0x04);

    assert(UInt32.from_le_bytes(le) == x);
    assert(UInt32.from_be_bytes(be) == x);
}

@test
fn test_uint32_checked_ops() {
    let a: UInt32 = 100;
    let b: UInt32 = 50;

    match a.checked_add(b) {
        Some(v) => assert(v == 150),
        None => assert(false),
    }

    match a.checked_sub(b) {
        Some(v) => assert(v == 50),
        None => assert(false),
    }

    match a.checked_mul(b) {
        Some(v) => assert(v == 5000),
        None => assert(false),
    }

    // Overflow returns None
    assert(UInt32.MAX.checked_add(1).is_none());

    // Underflow returns None
    let zero: UInt32 = 0;
    assert(zero.checked_sub(1).is_none());
}

@test
fn test_uint32_wrapping_ops() {
    let a: UInt32 = 100;
    let b: UInt32 = 50;
    assert(a.wrapping_add(b) == 150);
    assert(a.wrapping_sub(b) == 50);

    // Wrapping overflow
    assert(UInt32.MAX.wrapping_add(1) == 0);
    let zero: UInt32 = 0;
    assert(zero.wrapping_sub(1) == UInt32.MAX);
}

@test
fn test_uint32_saturating_ops() {
    let a: UInt32 = 100;
    let b: UInt32 = 50;
    assert(a.saturating_add(b) == 150);
    assert(a.saturating_sub(b) == 50);

    assert(UInt32.MAX.saturating_add(1) == UInt32.MAX);
    let zero: UInt32 = 0;
    assert(zero.saturating_sub(1) == 0);
}

@test
fn test_uint32_bit_ops() {
    let x: UInt32 = 0b10100101;
    assert(x.count_ones() == 4);
    assert(x.trailing_zeros() == 0);

    let y: UInt32 = 16;  // 0b10000
    assert(y.trailing_zeros() == 4);
    assert(y.leading_zeros() == 27);  // 32 - 5 = 27
}

@test
fn test_uint32_rotate() {
    let x: UInt32 = 0xDEADBEEF;
    assert(x.rotate_left(16).rotate_right(16) == x);
    assert(x.rotate_left(0) == x);
}

