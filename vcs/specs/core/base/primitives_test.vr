@test
fn test_uint128_checked_ops() {
    let a: UInt128 = 1000;
    let b: UInt128 = 500;

    match a.checked_add(b) {
        Some(v) => assert(v == 1500),
        None => assert(false),
    }

    match a.checked_sub(b) {
        Some(v) => assert(v == 500),
        None => assert(false),
    }

    match a.checked_mul(b) {
        Some(v) => assert(v == 500000),
        None => assert(false),
    }

    // Underflow returns None
    let zero: UInt128 = 0;
    assert(zero.checked_sub(1).is_none());
}

@test
fn test_uint128_wrapping_ops() {
    let a: UInt128 = 100;
    let b: UInt128 = 50;
    assert(a.wrapping_add(b) == 150);
    assert(a.wrapping_sub(b) == 50);

    // Wrapping on overflow
    assert(UInt128.MAX.wrapping_add(1) == 0);
}

