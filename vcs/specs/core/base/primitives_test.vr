// =============================================================================
// Float32 Extended Tests (gap: trig, exp, ln, pow, rounding)
// =============================================================================

@test
fn test_float32_rounding() {
    let x: Float32 = 2.7;
    assert(x.floor() == 2.0);
    assert(x.ceil() == 3.0);
    assert(x.round() == 3.0);
    assert(x.trunc() == 2.0);

    let y: Float32 = -2.7;
    assert(y.floor() == -3.0);
    assert(y.ceil() == -2.0);
    assert(y.trunc() == -2.0);
}

@test
fn test_float32_cbrt() {
    let x: Float32 = 8.0;
    assert(x.cbrt() == 2.0);

    let y: Float32 = 27.0;
    assert(y.cbrt() == 3.0);
}

@test
fn test_float32_exp_ln() {
    let zero: Float32 = 0.0;
    assert(zero.exp() == 1.0);

    let one: Float32 = 1.0;
    assert(one.ln() == 0.0);
}

@test
fn test_float32_exp2_log2() {
    let zero: Float32 = 0.0;
    assert(zero.exp2() == 1.0);

    let one: Float32 = 1.0;
    assert(one.exp2() == 2.0);

    let two: Float32 = 2.0;
    assert(two.log2() == 1.0);

    let eight: Float32 = 8.0;
    assert(eight.log2() == 3.0);
}

@test
fn test_float32_log10() {
    let ten: Float32 = 10.0;
    assert(ten.log10() == 1.0);

    let hundred: Float32 = 100.0;
    assert(hundred.log10() == 2.0);
}

@test
fn test_float32_pow() {
    let two: Float32 = 2.0;
    let three: Float32 = 3.0;
    assert(two.pow(three) == 8.0);

    let ten: Float32 = 10.0;
    let two_f: Float32 = 2.0;
    assert(ten.pow(two_f) == 100.0);
}

@test
fn test_float32_trig() {
    let zero: Float32 = 0.0;
    assert(zero.sin() == 0.0);
    assert(zero.cos() == 1.0);
    assert(zero.tan() == 0.0);
}

@test
fn test_float32_inverse_trig() {
    let zero: Float32 = 0.0;
    assert(zero.asin() == 0.0);
    assert(zero.atan() == 0.0);

    let one: Float32 = 1.0;
    assert(one.acos() == 0.0);
}

@test
fn test_float32_hyperbolic() {
    let zero: Float32 = 0.0;
    assert(zero.sinh() == 0.0);
    assert(zero.cosh() == 1.0);
    assert(zero.tanh() == 0.0);
}

@test
fn test_float32_atan2() {
    let zero: Float32 = 0.0;
    let one: Float32 = 1.0;
    assert(zero.atan2(one) == 0.0);
}

@test
fn test_float32_min_max() {
    let a: Float32 = 5.0;
    let b: Float32 = 10.0;
    assert(a.min(b) == 5.0);
    assert(a.max(b) == 10.0);
}

@test
fn test_float32_mul_add() {
    let two: Float32 = 2.0;
    let three: Float32 = 3.0;
    let four: Float32 = 4.0;
    // 2 * 3 + 4 = 10
    assert(two.mul_add(three, four) == 10.0);
}

@test
fn test_float32_hypot() {
    let three: Float32 = 3.0;
    let four: Float32 = 4.0;
    assert(three.hypot(four) == 5.0);
}

@test
fn test_float32_to_float() {
    let x: Float32 = 3.14;
    let f: Float = x.to_float();
    // Should be approximately equal (Float32 has less precision)
    assert(f > 3.13 && f < 3.15);
}

@test
fn test_float32_is_finite() {
    let x: Float32 = 1.0;
    assert(x.is_finite());
    assert(!Float32.infinity().is_finite());
    assert(!Float32.nan().is_finite());
}

