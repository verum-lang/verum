@test
fn test_uint16_bytes() {
    let x: UInt16 = 0x0102;
    let le = x.to_le_bytes();
    let be = x.to_be_bytes();

    assert(le[0] == 0x02);
    assert(le[1] == 0x01);
    assert(be[0] == 0x01);
    assert(be[1] == 0x02);

    assert(UInt16.from_le_bytes(le) == x);
    assert(UInt16.from_be_bytes(be) == x);
}

@test
fn test_uint16_checked_ops() {
    let a: UInt16 = 100;
    let b: UInt16 = 50;

    match a.checked_add(b) {
        Some(v) => assert(v == 150),
        None => assert(false),
    }

    match a.checked_sub(b) {
        Some(v) => assert(v == 50),
        None => assert(false),
    }

    // Overflow
    assert(UInt16.MAX.checked_add(1).is_none());
}

@test
