}

// =============================================================================
// ISize/USize Extended Tests
// =============================================================================

@test
fn test_isize_to_int() {
    let pos: ISize = 42;
    assert(pos.to_int() == 42);
    let neg: ISize = -42;
    assert(neg.to_int() == -42);
}

@test
fn test_usize_to_int() {
    let x: USize = 42;
    assert(x.to_int() == 42);
    let zero: USize = 0;
    assert(zero.to_int() == 0);
}

@test
fn test_usize_max() {
    assert(USize.MAX > 0);
    assert(USize.BITS == 64);
}

