fn test_uint128_saturating_ops() {
    assert(UInt128.MAX.saturating_add(1) == UInt128.MAX);
    let zero: UInt128 = 0;
    assert(zero.saturating_sub(1) == 0);
}

@test
fn test_uint128_bit_ops() {
