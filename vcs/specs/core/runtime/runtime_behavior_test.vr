@test
fn test_steal_result_success() {
    let r: StealResult<Int> = StealResult.Success(42);
    assert(r is StealResult.Success);
}

@test
fn test_steal_result_empty() {
    let r: StealResult<Int> = StealResult.Empty;
    assert(r is StealResult.Empty);
}

@test
fn test_steal_result_retry() {
    let r: StealResult<Int> = StealResult.Retry;
    assert(r is StealResult.Retry);
}

// =============================================================================
// Section 17: Stack Allocator Types
// =============================================================================

@test
fn test_stack_allocator_construction() {
    let alloc = StackAllocator<4096>.new();
    assert_eq(alloc.capacity(), 4096);
    assert_eq(alloc.used(), 0);
    assert_eq(alloc.remaining(), 4096);
}

@test
fn test_stack_allocator_watermark() {
    let alloc = StackAllocator<4096>.new();
    assert_eq(alloc.watermark(), 0);
}

@test
fn test_arena_allocator_construction() {
    let alloc = ArenaAllocator<4096, 4>.new();
    assert_eq(alloc.used(), 0);
}

@test
fn test_pool_allocator_construction() {
    let alloc = PoolAllocator<64, 100>.new();
    assert_eq(alloc.block_size(), 64);
    assert_eq(alloc.block_count(), 100);
    assert_eq(alloc.allocated(), 0);
    assert_eq(alloc.available(), 100);
}

@test
fn test_allocator_invariants() {
    let alloc = StackAllocator<8192>.new();
    assert_eq(alloc.used() + alloc.remaining(), alloc.capacity());
}

@test
fn test_pool_allocator_invariants() {
    let alloc = PoolAllocator<32, 50>.new();
    assert_eq(alloc.allocated() + alloc.available(), alloc.block_count());
}

