fn test_spawn_config_full_setup() {
    let config = SpawnConfig.new()
        .with_name("worker-1")
        .with_priority(PriorityLevel.High)
        .with_isolation(EnvIsolationLevel.SendOnly)
        .with_timeout_ms(30000 as UInt64)
        .with_stack_size(65536)
        .with_exponential_retry(3 as UInt16, 100 as UInt32, 5000 as UInt32, 0.1 as Float32)
        .with_restart_limits(5, 120 as UInt64);
    let _: SpawnConfig = config;
}

