@test
fn test_child_spec_new() {
    let spec = ChildSpec.new("worker");
    let _: ChildSpec = spec;
}

@test
fn test_child_spec_permanent() {
    let spec = ChildSpec.permanent("permanent-worker");
    let _: ChildSpec = spec;
}

@test
fn test_child_spec_temporary() {
    let spec = ChildSpec.temporary("temp-worker");
    let _: ChildSpec = spec;
}

@test
fn test_child_spec_with_restart() {
    let spec = ChildSpec.new("worker").with_restart(SupervisorRestartStrategy.Transient);
    let _: ChildSpec = spec;
}

@test
fn test_child_spec_with_shutdown_timeout() {
    let spec = ChildSpec.new("worker").with_shutdown_timeout_ms(5000 as UInt32);
    let _: ChildSpec = spec;
}

@test
fn test_child_spec_with_restart_limits() {
    let spec = ChildSpec.new("worker").with_restart_limits(3 as UInt16, 60 as UInt32);
    let _: ChildSpec = spec;
}

@test
fn test_child_spec_with_priority() {
    let spec = ChildSpec.new("worker").with_priority(192);
    let _: ChildSpec = spec;
}

@test
fn test_child_spec_chained_builder() {
    let spec = ChildSpec.new("worker")
        .with_restart(SupervisorRestartStrategy.Permanent)
        .with_shutdown_timeout_ms(10000 as UInt32)
        .with_restart_limits(5 as UInt16, 120 as UInt32)
        .with_priority(255);
    let _: ChildSpec = spec;
}

// =============================================================================
// Section 11: RestartIntensity
// =============================================================================

@test
fn test_restart_intensity_new() {
    let ri = RestartIntensity.new(5 as UInt16, 60 as UInt32);
    assert_eq(ri.current_count(), 0);
}

@test
fn test_restart_intensity_record() {
    let mut ri = RestartIntensity.new(3 as UInt16, 60 as UInt32);
    assert(ri.record_restart());
    assert(ri.record_restart());
    assert(ri.record_restart());
    assert_eq(ri.current_count(), 3);
}

@test
fn test_restart_intensity_would_allow() {
    let ri = RestartIntensity.new(3 as UInt16, 60 as UInt32);
    assert(ri.would_allow_restart());
}

@test
fn test_restart_intensity_reset() {
    let mut ri = RestartIntensity.new(3 as UInt16, 60 as UInt32);
    ri.record_restart();
    ri.record_restart();
    ri.reset();
    assert_eq(ri.current_count(), 0);
}

// =============================================================================
// Section 12: ShutdownStrategy
// =============================================================================

@test
fn test_shutdown_graceful() {
    let s = ShutdownStrategy.graceful();
    assert_eq(s.timeout_ms() as Int, 5000);
}

@test
fn test_shutdown_brutal() {
    let s = ShutdownStrategy.brutal();
    assert_eq(s.timeout_ms() as Int, 100);
}

@test
fn test_shutdown_custom_timeout() {
    let s = ShutdownStrategy.Graceful { timeout_ms: 10000 };
    assert_eq(s.timeout_ms() as Int, 10000);
}

// =============================================================================
// Section 13: EscalationPolicy and EscalationReason
// =============================================================================

@test
fn test_escalation_policy_all_variants() {
    let policies = [
        EscalationPolicy.EscalateToParent,
        EscalationPolicy.RestartSubtree,
        EscalationPolicy.Terminate,
        EscalationPolicy.LogAndIgnore,
    ];
    assert(policies[0] is EscalationPolicy.EscalateToParent);
    assert(policies[1] is EscalationPolicy.RestartSubtree);
    assert(policies[2] is EscalationPolicy.Terminate);
    assert(policies[3] is EscalationPolicy.LogAndIgnore);
}

@test
fn test_escalation_reason_all_strategies_exhausted() {
    let reason = EscalationReason.AllStrategiesExhausted;
    assert(reason is EscalationReason.AllStrategiesExhausted);
    let desc = reason.description();
    assert(desc.len() > 0);
}

