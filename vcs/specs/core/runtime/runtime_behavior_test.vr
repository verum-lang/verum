@test
fn test_execution_tier_all() {
    assert(ExecutionTier.Tier0_Full is ExecutionTier.Tier0_Full);
    assert(ExecutionTier.Tier1_Epoch is ExecutionTier.Tier1_Epoch);
    assert(ExecutionTier.Tier2_Gen is ExecutionTier.Tier2_Gen);
    assert(ExecutionTier.Tier3_Unchecked is ExecutionTier.Tier3_Unchecked);
}

@test
fn test_isolation_levels() {
    assert(EnvIsolationLevel.Shared is EnvIsolationLevel.Shared);
    assert(EnvIsolationLevel.SendOnly is EnvIsolationLevel.SendOnly);
    assert(EnvIsolationLevel.Full is EnvIsolationLevel.Full);
}

@test
fn test_task_id_main() {
    let id = TaskId.main();
    let _: TaskId = id;
}

@test
fn test_task_id_new() {
    let id = TaskId.new(None);
    let _: TaskId = id;
}

