// =============================================================================
// runtime_behavior_test.vr - Tests for runtime behavior and lifecycle
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: runtime, recovery, circuit-breaker, retry, backoff, supervisor, spawn,
//        behavior, lifecycle, config
// @description: Extended tests for runtime behavior: RecoveryCircuitBreaker lifecycle,
//               RecoveryBackoffStrategy edge cases, RuntimeRetryConfig, RuntimeRecoveryStrategy,
//               JitterConfig, Supervisor, SpawnConfig, TaskQueue.
// =============================================================================

module specs.core.runtime.runtime_behavior_test;

mount core.runtime.recovery.{
    RecoveryBackoffStrategy, RecoveryCircuitState, JitterConfig,
    RecoveryCircuitBreaker, RecoveryCircuitBreakerConfig, CircuitBreakerStats,
    CircuitBreakerError, ErrorPredicate,
    RuntimeRetryConfig, RetryPredicate,
    RuntimeRecoveryStrategy, InlineRetryPolicy,
};
mount core.runtime.spawn.{
    PriorityLevel, SpawnConfig, SpawnConfigBuilder,
    InlineContextStorage,
};
mount core.runtime.supervisor.{
    SupervisorId, ChildId, SupervisionStrategy,
    SupervisorRestartStrategy, FailureReason, ChildStatus,
    ChildSpec, RestartIntensity, ShutdownStrategy,
    SupervisorConfig, EscalationPolicy, EscalationReason,
};
mount core.runtime.env.{ExecutionTier, EnvIsolationLevel, CpuAffinity, TaskId, RuntimeRestartPolicy};
mount core.runtime.task_queue.{StealResult, WorkDeque, Stealer, WorkStealingPool, BoundedQueue};
mount core.runtime.stack_alloc.{
    StackAllocator, ArenaAllocator, PoolAllocator,
    StackSavepoint, ArenaSavepoint,
};
mount core.runtime.config.{InitError, RuntimeIoError, IoOp};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.base.protocols.TypeId;
mount core.collections.list.List;

// =============================================================================
// Section 1: RecoveryCircuitBreakerConfig
// =============================================================================

@test
fn test_circuit_breaker_config_default() {
    let config = RecoveryCircuitBreakerConfig {
        failure_threshold: 5 as UInt16,
        required_successes: 3 as UInt16,
        timeout_ms: 30000 as UInt32,
        error_predicate: ErrorPredicate.AllErrors,
    };
    assert_eq(config.failure_threshold as Int, 5);
    assert_eq(config.required_successes as Int, 3);
}

@test
fn test_circuit_breaker_config_aggressive() {
    let config = RecoveryCircuitBreakerConfig {
        failure_threshold: 1 as UInt16,
        required_successes: 1 as UInt16,
        timeout_ms: 1000 as UInt32,
        error_predicate: ErrorPredicate.AllErrors,
    };
    assert_eq(config.failure_threshold as Int, 1);
}

@test
fn test_circuit_breaker_config_conservative() {
    let config = RecoveryCircuitBreakerConfig {
        failure_threshold: 100 as UInt16,
        required_successes: 50 as UInt16,
        timeout_ms: 600000 as UInt32,
        error_predicate: ErrorPredicate.AllErrors,
    };
    assert_eq(config.failure_threshold as Int, 100);
}

@test
fn test_circuit_breaker_stats_initial() {
    let stats = CircuitBreakerStats {
        state: RecoveryCircuitState.Closed,
        failure_count: 0 as UInt16,
        success_count: 0 as UInt16,
        total_calls: 0 as UInt64,
        total_failures: 0 as UInt64,
        state_changes: 0 as UInt64,
    };
    assert(stats.state is RecoveryCircuitState.Closed);
    assert_eq(stats.failure_count as Int, 0);
}

@test
fn test_circuit_breaker_stats_after_activity() {
    let stats = CircuitBreakerStats {
        state: RecoveryCircuitState.Closed,
        failure_count: 2 as UInt16,
        success_count: 100 as UInt16,
        total_calls: 105 as UInt64,
        total_failures: 5 as UInt64,
        state_changes: 3 as UInt64,
    };
    assert(stats.state is RecoveryCircuitState.Closed);
}

@test
fn test_circuit_breaker_error_open() {
    let err: CircuitBreakerError<Text> = CircuitBreakerError.Open;
    assert(err is CircuitBreakerError.Open);
}

@test
fn test_circuit_breaker_error_failed() {
    let err: CircuitBreakerError<Text> = CircuitBreakerError.Failed("some error");
    assert(err is CircuitBreakerError.Failed);
}

// =============================================================================
// Section 2: RecoveryBackoffStrategy Edge Cases
// =============================================================================

@test
fn test_backoff_exponential_zero_attempt() {
    let backoff = RecoveryBackoffStrategy.Exponential { base_ms: 100, max_ms: 10000, multiplier: 2 };
    assert_eq(backoff.calculate_delay_ms(0), 100);
}

@test
fn test_backoff_exponential_high_attempt() {
    let backoff = RecoveryBackoffStrategy.Exponential { base_ms: 100, max_ms: 10000, multiplier: 2 };
    let delay = backoff.calculate_delay_ms(10);
    assert_eq(delay, 10000);
}

@test
fn test_backoff_linear_zero_increment() {
    let backoff = RecoveryBackoffStrategy.Linear { base_ms: 500, increment_ms: 0, max_ms: 5000 };
    assert_eq(backoff.calculate_delay_ms(0), 500);
    assert_eq(backoff.calculate_delay_ms(5), 500);
}

@test
fn test_backoff_linear_large_increment() {
    let backoff = RecoveryBackoffStrategy.Linear { base_ms: 100, increment_ms: 1000, max_ms: 2000 };
    assert_eq(backoff.calculate_delay_ms(0), 100);
    assert_eq(backoff.calculate_delay_ms(1), 1100);
    assert_eq(backoff.calculate_delay_ms(2), 2000);
}

@test
fn test_backoff_none_always_zero() {
    let backoff = RecoveryBackoffStrategy.None;
    assert_eq(backoff.calculate_delay_ms(0), 0);
    assert_eq(backoff.calculate_delay_ms(100), 0);
}

@test
fn test_backoff_fixed_consistent() {
    let backoff = RecoveryBackoffStrategy.Fixed { delay_ms: 250 };
    for i in range(0, 10) {
        assert_eq(backoff.calculate_delay_ms(i), 250);
    }
}

@test
fn test_backoff_exponential_convenience() {
    let backoff = RecoveryBackoffStrategy.exponential(100, 10000);
    assert(backoff is RecoveryBackoffStrategy.Exponential);
    assert_eq(backoff.calculate_delay_ms(0), 100);
}

@test
fn test_backoff_exponential_multiplier_3() {
    let backoff = RecoveryBackoffStrategy.Exponential { base_ms: 10, max_ms: 100000, multiplier: 3 };
    assert_eq(backoff.calculate_delay_ms(0), 10);
    assert_eq(backoff.calculate_delay_ms(1), 30);
    assert_eq(backoff.calculate_delay_ms(2), 90);
}

// =============================================================================
// Section 3: RecoveryCircuitState
// =============================================================================

@test
fn test_circuit_state_closed() {
    let s = RecoveryCircuitState.Closed;
    assert(s is RecoveryCircuitState.Closed);
    assert_eq(s.to_u8(), 0);
}

@test
fn test_circuit_state_open() {
    let s = RecoveryCircuitState.Open;
    assert_eq(s.to_u8(), 1);
}

@test
fn test_circuit_state_half_open() {
    let s = RecoveryCircuitState.HalfOpen;
    assert_eq(s.to_u8(), 2);
}

@test
fn test_circuit_state_from_u8() {
    assert(RecoveryCircuitState.from_u8(0) is RecoveryCircuitState.Closed);
    assert(RecoveryCircuitState.from_u8(1) is RecoveryCircuitState.Open);
    assert(RecoveryCircuitState.from_u8(2) is RecoveryCircuitState.HalfOpen);
}

@test
fn test_circuit_state_round_trip() {
    let states = [RecoveryCircuitState.Closed, RecoveryCircuitState.Open, RecoveryCircuitState.HalfOpen];
    for i in range(0, 3) {
        let s = states[i];
        let n = s.to_u8();
        let recovered = RecoveryCircuitState.from_u8(n);
        assert_eq(recovered.to_u8(), n);
    }
}

// =============================================================================
// Section 4: JitterConfig
// =============================================================================

@test
fn test_jitter_none() {
    let j = JitterConfig.None;
    assert_eq(j.apply(1000), 1000);
}

@test
fn test_jitter_proportional() {
    let j = JitterConfig.Proportional(10);
    let result = j.apply(1000);
    assert(result >= 900);
    assert(result <= 1100);
}

@test
fn test_jitter_fixed() {
    let j = JitterConfig.Fixed(50);
    let result = j.apply(1000);
    assert(result >= 950);
    assert(result <= 1050);
}

@test
fn test_jitter_full() {
    let j = JitterConfig.Full;
    let result = j.apply(1000);
    assert(result >= 0);
    assert(result <= 1000);
}

@test
fn test_jitter_none_zero_delay() {
    let j = JitterConfig.None;
    assert_eq(j.apply(0), 0);
}

// =============================================================================
// Section 5: RuntimeRetryConfig
// =============================================================================

@test
fn test_retry_config_basic() {
    let config = RuntimeRetryConfig {
        max_attempts: 3,
        backoff: RecoveryBackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    assert_eq(config.max_attempts, 3);
}

@test
fn test_retry_config_with_exponential() {
    let config = RuntimeRetryConfig {
        max_attempts: 5,
        backoff: RecoveryBackoffStrategy.Exponential { base_ms: 100, max_ms: 10000, multiplier: 2 },
        jitter: JitterConfig.Proportional(10),
        retry_on: RetryPredicate.TransientOnly,
    };
    assert_eq(config.max_attempts, 5);
}

@test
fn test_retry_config_no_retries() {
    let config = RuntimeRetryConfig {
        max_attempts: 0,
        backoff: RecoveryBackoffStrategy.None,
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    assert_eq(config.max_attempts, 0);
}

// =============================================================================
// Section 6: RuntimeRecoveryStrategy
// =============================================================================

@test
fn test_recovery_strategy_none() {
    let s = RuntimeRecoveryStrategy.None;
    assert(s is RuntimeRecoveryStrategy.None);
}

@test
fn test_recovery_strategy_retry() {
    let config = RuntimeRetryConfig {
        max_attempts: 3,
        backoff: RecoveryBackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let s = RuntimeRecoveryStrategy.Retry(config);
    assert(s is RuntimeRecoveryStrategy.Retry);
}

@test
fn test_recovery_strategy_use_breaker() {
    let config = RecoveryCircuitBreakerConfig {
        failure_threshold: 5 as UInt16,
        required_successes: 3 as UInt16,
        timeout_ms: 30000 as UInt32,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let s = RuntimeRecoveryStrategy.UseBreaker(config);
    assert(s is RuntimeRecoveryStrategy.UseBreaker);
}

@test
fn test_recovery_strategy_supervision() {
    let s = RuntimeRecoveryStrategy.Supervision;
    assert(s is RuntimeRecoveryStrategy.Supervision);
}

@test
fn test_recovery_strategy_convenience_retry() {
    let s = RuntimeRecoveryStrategy.retry(3);
    assert(s is RuntimeRecoveryStrategy.Retry);
}

@test
fn test_recovery_strategy_convenience_cb() {
    let s = RuntimeRecoveryStrategy.circuit_breaker(5);
    assert(s is RuntimeRecoveryStrategy.UseBreaker);
}

// =============================================================================
// Section 7: Supervision Strategy
// =============================================================================

@test
fn test_supervision_one_for_one_desc() {
    let s = SupervisionStrategy.OneForOne;
    let desc = s.description();
    assert(desc.len() > 0);
}

@test
fn test_supervision_one_for_all_desc() {
    let s = SupervisionStrategy.OneForAll;
    let desc = s.description();
    assert(desc.len() > 0);
}

@test
fn test_supervision_rest_for_one_desc() {
    let s = SupervisionStrategy.RestForOne;
    let desc = s.description();
    assert(desc.len() > 0);
}

// =============================================================================
// Section 8: SupervisorRestartStrategy behavior
// =============================================================================

@test
fn test_restart_permanent_on_error() {
    let s = SupervisorRestartStrategy.Permanent;
    let reason = FailureReason.ErrorExit("something failed");
    assert(s.should_restart(&reason));
}

@test
fn test_restart_permanent_on_normal() {
    let s = SupervisorRestartStrategy.Permanent;
    let reason = FailureReason.NormalExit;
    assert(s.should_restart(&reason));
}

@test
fn test_restart_transient_on_panic() {
    let s = SupervisorRestartStrategy.Transient;
    let reason = FailureReason.Panic("error");
    assert(s.should_restart(&reason));
}

@test
fn test_restart_transient_on_normal() {
    let s = SupervisorRestartStrategy.Transient;
    let reason = FailureReason.NormalExit;
    assert(!s.should_restart(&reason));
}

@test
fn test_restart_temporary_on_panic() {
    let s = SupervisorRestartStrategy.Temporary;
    let reason = FailureReason.Panic("error");
    assert(!s.should_restart(&reason));
}

@test
fn test_restart_temporary_on_normal() {
    let s = SupervisorRestartStrategy.Temporary;
    let reason = FailureReason.NormalExit;
    assert(!s.should_restart(&reason));
}

// =============================================================================
// Section 9: FailureReason classification
// =============================================================================

@test
fn test_failure_normal_not_abnormal() {
    let r = FailureReason.NormalExit;
    assert(!r.is_abnormal());
}

@test
fn test_failure_error_exit_is_abnormal() {
    let r = FailureReason.ErrorExit("oops");
    assert(r.is_abnormal());
}

@test
fn test_failure_panic_is_abnormal() {
    let r = FailureReason.Panic("panic");
    assert(r.is_abnormal());
}

@test
fn test_failure_timeout_is_abnormal() {
    let r = FailureReason.Timeout;
    assert(r.is_abnormal());
}

@test
fn test_failure_cancelled_is_abnormal() {
    let r = FailureReason.Cancelled;
    assert(r.is_abnormal());
}

@test
fn test_failure_supervisor_shutdown() {
    let r = FailureReason.SupervisorShutdown;
    assert(!r.is_abnormal());
}

@test
fn test_failure_reason_descriptions() {
    let reasons = [
        FailureReason.NormalExit,
        FailureReason.Timeout,
        FailureReason.Cancelled,
        FailureReason.Manual,
    ];
    for i in range(0, 4) {
        let desc = reasons[i].description();
        assert(desc.len() > 0);
    }
}

