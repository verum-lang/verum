// =============================================================================
// Section 15: RetryPolicy Mutation and Lifecycle
// =============================================================================

@test
fn test_retry_policy_record_retry() {
    let config = RetryConfig {
        max_attempts: 5,
        backoff: BackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let mut policy = RetryPolicy.new(config);
    policy.record_retry("timeout error");
    assert_eq(policy.current_attempt, 1);
    assert_eq(policy.total_retries, 1);
    assert(policy.last_error.is_some());
}

@test
fn test_retry_policy_multiple_retries() {
    let config = RetryConfig {
        max_attempts: 5,
        backoff: BackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let mut policy = RetryPolicy.new(config);
    policy.record_retry("error 1");
    policy.record_retry("error 2");
    policy.record_retry("error 3");
    assert_eq(policy.current_attempt, 3);
    assert_eq(policy.total_retries, 3);
    assert(policy.should_retry()); // 3 < 5
}

@test
fn test_retry_policy_exhausted() {
    let config = RetryConfig {
        max_attempts: 2,
        backoff: BackoffStrategy.Fixed { delay_ms: 50 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let mut policy = RetryPolicy.new(config);
    policy.record_retry("fail 1");
    policy.record_retry("fail 2");
    assert(!policy.should_retry()); // 2 >= 2
}

@test
fn test_retry_policy_reset_after_retries() {
    let config = RetryConfig {
        max_attempts: 3,
        backoff: BackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let mut policy = RetryPolicy.new(config);
    policy.record_retry("error");
    policy.record_retry("error");
    assert_eq(policy.current_attempt, 2);
    policy.reset();
    assert_eq(policy.current_attempt, 0);
    assert(policy.last_error.is_none());
    assert(policy.should_retry());
}

@test
fn test_retry_policy_last_error_updates() {
    let config = RetryConfig {
        max_attempts: 5,
        backoff: BackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let mut policy = RetryPolicy.new(config);
    policy.record_retry("first error");
    match policy.last_error {
        Some(msg) => assert_eq(msg, "first error"),
        None => panic("Expected error"),
    }
    policy.record_retry("second error");
    match policy.last_error {
        Some(msg) => assert_eq(msg, "second error"),
        None => panic("Expected error"),
    }
}

// =============================================================================
// Section 16: BackoffStrategy Delay Calculations Extended
// =============================================================================

@test
fn test_backoff_exponential_large_attempt() {
    let backoff = BackoffStrategy.Exponential { base_ms: 100, max_ms: 60000, multiplier: 2 };
    // attempt 10: 100 * 2^10 = 102400, capped at 60000
    assert_eq(backoff.calculate_delay_ms(10), 60000);
}

@test
fn test_backoff_linear_exact_cap() {
    let backoff = BackoffStrategy.Linear { base_ms: 100, increment_ms: 100, max_ms: 500 };
    // attempt 4: 100 + 4*100 = 500 (exactly at cap)
    assert_eq(backoff.calculate_delay_ms(4), 500);
    // attempt 5: 100 + 5*100 = 600, capped at 500
    assert_eq(backoff.calculate_delay_ms(5), 500);
}

@test
fn test_backoff_exponential_multiplier_three() {
    let backoff = BackoffStrategy.Exponential { base_ms: 10, max_ms: 100000, multiplier: 3 };
    assert_eq(backoff.calculate_delay_ms(0), 10);
    assert_eq(backoff.calculate_delay_ms(1), 30);
    assert_eq(backoff.calculate_delay_ms(2), 90);
    assert_eq(backoff.calculate_delay_ms(3), 270);
}

// =============================================================================
// Section 17: CircuitBreaker Extended State Transitions
// =============================================================================

@test
fn test_circuit_breaker_failure_count_in_stats() {
    let config = CircuitBreakerConfig {
        failure_threshold: 5,
        required_successes: 3,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);
    cb.record_failure();
    cb.record_failure();
    let stats = cb.stats();
    assert_eq(stats.failure_count, 2);
    assert_eq(stats.total_failures, 2);
}

@test
fn test_circuit_breaker_mixed_operations() {
    let config = CircuitBreakerConfig {
        failure_threshold: 5,
        required_successes: 3,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);
    cb.record_success();
    cb.record_failure();
    cb.record_success();
    cb.record_failure();
    cb.record_success();
    let stats = cb.stats();
    assert_eq(stats.total_calls, 5);
    assert_eq(stats.total_failures, 2);
    assert(cb.state() is CircuitState.Closed);
}

@test
fn test_circuit_breaker_opens_then_stats() {
    let config = CircuitBreakerConfig {
        failure_threshold: 2,
        required_successes: 1,
        timeout_ms: 999999999,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);
    cb.record_failure();
    cb.record_failure();
    assert(cb.state() is CircuitState.Open);
    let stats = cb.stats();
    assert(stats.state is CircuitState.Open);
    assert(stats.state_changes > 0);
}

@test
fn test_circuit_breaker_reset_clears_stats() {
    let config = CircuitBreakerConfig {
        failure_threshold: 3,
        required_successes: 2,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);
    cb.record_failure();
    cb.record_failure();
    cb.record_failure();
    assert(cb.state() is CircuitState.Open);
    cb.reset();
    assert(cb.state() is CircuitState.Closed);
    assert(cb.allow_request());
    let stats = cb.stats();
    assert_eq(stats.failure_count, 0);
    assert_eq(stats.success_count, 0);
}

// =============================================================================
// Section 18: RecoveryStrategy Pattern Extraction
// =============================================================================

@test
fn test_recovery_strategy_retry_extracts_config() {
    let strategy = RecoveryStrategy.retry(3);
    match strategy {
        RecoveryStrategy.Retry(config) => {
            assert_eq(config.max_attempts, 3);
        }
        _ => panic("Expected Retry"),
    }
}

@test
fn test_recovery_strategy_circuit_breaker_extracts_config() {
    let strategy = RecoveryStrategy.circuit_breaker(5);
    match strategy {
        RecoveryStrategy.UseBreaker(config) => {
            assert_eq(config.failure_threshold, 5);
        }
        _ => panic("Expected UseBreaker"),
    }
}

@test
fn test_recovery_strategy_match_all_variants() {
    let strategies = [
        RecoveryStrategy.None,
        RecoveryStrategy.Supervision,
    ];
    for s in strategies {
        let matched = match s {
            RecoveryStrategy.None => true,
            RecoveryStrategy.Retry(_) => true,
            RecoveryStrategy.UseBreaker(_) => true,
            RecoveryStrategy.Composed(_) => true,
            RecoveryStrategy.Supervision => true,
        };
        assert(matched);
    }
}

// =============================================================================
// Section 19: RetryConfig with Different Backoff Strategies
// =============================================================================

@test
fn test_retry_config_with_linear_backoff() {
    let config = RetryConfig {
        max_attempts: 5,
        backoff: BackoffStrategy.Linear { base_ms: 100, increment_ms: 50, max_ms: 500 },
        jitter: JitterConfig.Proportional(10),
        retry_on: RetryPredicate.AllErrors,
    };
    assert_eq(config.max_attempts, 5);
    assert(config.backoff is BackoffStrategy.Linear);
}

@test
fn test_retry_config_with_no_backoff() {
    let config = RetryConfig {
        max_attempts: 10,
        backoff: BackoffStrategy.None,
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.TransientOnly,
    };
    assert_eq(config.max_attempts, 10);
    assert(config.retry_on is RetryPredicate.TransientOnly);
}

@test
fn test_retry_policy_next_delay_exponential() {
    let config = RetryConfig {
        max_attempts: 5,
        backoff: BackoffStrategy.Exponential { base_ms: 100, max_ms: 5000, multiplier: 2 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let policy = RetryPolicy.new(config);
    // At attempt 0, delay should be base
    assert_eq(policy.next_delay_ms(), 100);
}

// =============================================================================
// Section 20: CircuitBreakerError Typing
// =============================================================================

@test
fn test_circuit_breaker_error_open_int() {
    let err: CircuitBreakerError<Int> = CircuitBreakerError.Open;
    assert(err is CircuitBreakerError.Open);
}

@test
fn test_circuit_breaker_error_failed_int() {
    let err: CircuitBreakerError<Int> = CircuitBreakerError.Failed(42);
    match err {
        CircuitBreakerError.Failed(code) => assert_eq(code, 42),
        _ => panic("Expected Failed"),
    }
}

// =============================================================================
// Section 21: JitterConfig Pattern Extraction
// =============================================================================

@test
fn test_jitter_proportional_value() {
    let jitter = JitterConfig.Proportional(25);
    match jitter {
        JitterConfig.Proportional(pct) => assert_eq(pct, 25),
        _ => panic("Expected Proportional"),
    }
}

@test
fn test_jitter_fixed_value() {
    let jitter = JitterConfig.Fixed(200);
    match jitter {
        JitterConfig.Fixed(ms) => assert_eq(ms, 200),
        _ => panic("Expected Fixed"),
    }
}

@test
fn test_jitter_match_all_variants() {
    let jitters = [
        JitterConfig.None,
        JitterConfig.Proportional(10),
        JitterConfig.Fixed(50),
        JitterConfig.Full,
    ];
    for j in jitters {
        let matched = match j {
            JitterConfig.None => true,
            JitterConfig.Proportional(_) => true,
            JitterConfig.Fixed(_) => true,
            JitterConfig.Full => true,
        };
        assert(matched);
    }
}

