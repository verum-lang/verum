@test
fn test_inline_retry_policy_default() {
    let policy: InlineRetryPolicy = InlineRetryPolicy.default();
    assert_eq(policy.max_attempts, 3);
    assert_eq(policy.current_attempt, 0);
    assert_eq(policy.backoff_type, 2);  // Exponential
    assert_eq(policy.backoff_base_ms, 100);
    assert_eq(policy.backoff_max_ms, 5000);
    assert_eq(policy.jitter_type, 1);   // Proportional
    assert_eq(policy.jitter_value, 10); // 10%
}

