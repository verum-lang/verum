@test
fn test_circuit_breaker_config_construction() {
    let config: CircuitBreakerConfig = CircuitBreakerConfig {
        failure_threshold: 5,
        required_successes: 3,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    assert_eq(config.failure_threshold, 5);
    assert_eq(config.required_successes, 3);
    assert_eq(config.timeout_ms, 60000);
}

@test
fn test_circuit_breaker_config_custom_threshold() {
    let config: CircuitBreakerConfig = CircuitBreakerConfig {
        failure_threshold: 10,
        required_successes: 5,
        timeout_ms: 30000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    assert_eq(config.failure_threshold, 10);
    assert_eq(config.required_successes, 5);
    assert_eq(config.timeout_ms, 30000);
}

// =============================================================================
// Section 7: CircuitBreaker Construction and State
// =============================================================================

@test
fn test_circuit_breaker_new() {
    let config = CircuitBreakerConfig {
        failure_threshold: 5,
        required_successes: 3,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);
    assert(cb.state() is CircuitState.Closed);
}

@test
fn test_circuit_breaker_initial_state_closed() {
    let config = CircuitBreakerConfig {
        failure_threshold: 3,
        required_successes: 2,
        timeout_ms: 10000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);
    // New circuit breaker should be closed
    assert(cb.state() is CircuitState.Closed);
    assert(cb.allow_request());
}

@test
fn test_circuit_breaker_stats_initial() {
    let config = CircuitBreakerConfig {
        failure_threshold: 5,
        required_successes: 3,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);
    let stats: CircuitBreakerStats = cb.stats();
    assert(stats.state is CircuitState.Closed);
    assert_eq(stats.failure_count, 0);
    assert_eq(stats.success_count, 0);
    assert_eq(stats.total_calls, 0);
    assert_eq(stats.total_failures, 0);
    assert_eq(stats.state_changes, 0);
}

// =============================================================================
// Section 8: CircuitBreaker State Transitions
// =============================================================================

@test
fn test_circuit_breaker_success_stays_closed() {
    let config = CircuitBreakerConfig {
        failure_threshold: 3,
        required_successes: 2,
        timeout_ms: 10000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);

    cb.record_success();
    cb.record_success();
    cb.record_success();

    assert(cb.state() is CircuitState.Closed);
    let stats = cb.stats();
    assert_eq(stats.total_calls, 3);
    assert_eq(stats.total_failures, 0);
}

@test
fn test_circuit_breaker_opens_on_threshold() {
    let config = CircuitBreakerConfig {
        failure_threshold: 3,
        required_successes: 2,
        timeout_ms: 10000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);

    // Record failures up to threshold
    cb.record_failure();
    assert(cb.state() is CircuitState.Closed);
    cb.record_failure();
    assert(cb.state() is CircuitState.Closed);
    cb.record_failure();  // This should open the circuit
    assert(cb.state() is CircuitState.Open);
}

@test
fn test_circuit_breaker_open_rejects_requests() {
    let config = CircuitBreakerConfig {
        failure_threshold: 2,
        required_successes: 1,
        timeout_ms: 999999999,  // Very long timeout to ensure it stays open
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);

    // Open the circuit
    cb.record_failure();
    cb.record_failure();
    assert(cb.state() is CircuitState.Open);

    // Should not allow requests while open (with large timeout)
    // Note: allow_request checks timeout - with large timeout it stays open
    assert(!cb.allow_request());
}

@test
fn test_circuit_breaker_success_resets_failure_count() {
    let config = CircuitBreakerConfig {
        failure_threshold: 3,
        required_successes: 2,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);

    // Two failures...
    cb.record_failure();
    cb.record_failure();
    // A success resets failure count
    cb.record_success();
    // Now one more failure should NOT open (count was reset)
    cb.record_failure();
    assert(cb.state() is CircuitState.Closed);
}

@test
fn test_circuit_breaker_reset() {
    let config = CircuitBreakerConfig {
        failure_threshold: 2,
        required_successes: 1,
        timeout_ms: 999999999,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);

    // Open the circuit
    cb.record_failure();
    cb.record_failure();
    assert(cb.state() is CircuitState.Open);

    // Reset should close it
    cb.reset();
    assert(cb.state() is CircuitState.Closed);
    assert(cb.allow_request());
}

@test
fn test_circuit_breaker_stats_after_operations() {
    let config = CircuitBreakerConfig {
        failure_threshold: 5,
        required_successes: 3,
        timeout_ms: 60000,
        error_predicate: ErrorPredicate.AllErrors,
    };
    let cb = CircuitBreaker.new(config);

    cb.record_success();
    cb.record_success();
    cb.record_failure();
    cb.record_success();

    let stats = cb.stats();
    assert_eq(stats.total_calls, 4);
    assert_eq(stats.total_failures, 1);
}

// =============================================================================
// Section 9: CircuitBreakerError
