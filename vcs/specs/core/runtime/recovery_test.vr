@test
fn test_jitter_none() {
    let jitter: JitterConfig = JitterConfig.None;
    assert(jitter is JitterConfig.None);
}

@test
fn test_jitter_proportional() {
    let jitter: JitterConfig = JitterConfig.Proportional(10);
    assert(jitter is JitterConfig.Proportional);
}

@test
fn test_jitter_fixed() {
    let jitter: JitterConfig = JitterConfig.Fixed(100);
    assert(jitter is JitterConfig.Fixed);
}

@test
fn test_jitter_full() {
    let jitter: JitterConfig = JitterConfig.Full;
    assert(jitter is JitterConfig.Full);
}

@test
fn test_jitter_none_apply() {
    let jitter: JitterConfig = JitterConfig.None;
    // No jitter means delay unchanged
    assert_eq(jitter.apply(100), 100);
    assert_eq(jitter.apply(500), 500);
}

@test
fn test_jitter_match_proportional() {
    let jitter: JitterConfig = JitterConfig.Proportional(15);
    match jitter {
        JitterConfig.Proportional(pct) => assert_eq(pct, 15),
        _ => panic("Expected Proportional"),
    }
}

@test
fn test_jitter_match_fixed() {
    let jitter: JitterConfig = JitterConfig.Fixed(50);
    match jitter {
        JitterConfig.Fixed(ms) => assert_eq(ms, 50),
        _ => panic("Expected Fixed"),
    }
}

// =============================================================================
// Section 5: Edge Cases
// =============================================================================

@test
fn test_backoff_linear_zero_increment() {
    let backoff: BackoffStrategy = BackoffStrategy.Linear { base_ms: 100, increment_ms: 0, max_ms: 1000 };
    // With zero increment, delay stays at base
    assert_eq(backoff.calculate_delay_ms(0), 100);
    assert_eq(backoff.calculate_delay_ms(10), 100);
}

@test
fn test_backoff_exponential_multiplier_one() {
    let backoff: BackoffStrategy = BackoffStrategy.Exponential { base_ms: 100, max_ms: 1000, multiplier: 1 };
    // With multiplier 1, delay stays at base
    assert_eq(backoff.calculate_delay_ms(0), 100);
    assert_eq(backoff.calculate_delay_ms(5), 100);
}

@test
fn test_backoff_fixed_zero() {
    let backoff: BackoffStrategy = BackoffStrategy.Fixed { delay_ms: 0 };
    assert_eq(backoff.calculate_delay_ms(0), 0);
}

// =============================================================================
// Section 6: CircuitBreakerConfig
