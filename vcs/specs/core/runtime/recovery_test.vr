@test
fn test_circuit_breaker_error_open() {
    let err: CircuitBreakerError<Text> = CircuitBreakerError.Open;
    assert(err is CircuitBreakerError.Open);
}

@test
fn test_circuit_breaker_error_failed() {
    let err: CircuitBreakerError<Text> = CircuitBreakerError.Failed("service unavailable");
    match err {
        CircuitBreakerError.Failed(msg) => assert_eq(msg, "service unavailable"),
        _ => panic("Expected Failed"),
    }
}

// =============================================================================
// Section 10: RetryConfig and RetryPolicy
// =============================================================================

@test
fn test_retry_config_construction() {
    let config: RetryConfig = RetryConfig {
        max_attempts: 3,
        backoff: BackoffStrategy.Exponential { base_ms: 100, max_ms: 5000, multiplier: 2 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    assert_eq(config.max_attempts, 3);
}

@test
fn test_retry_policy_new() {
    let config = RetryConfig {
        max_attempts: 3,
        backoff: BackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let policy = RetryPolicy.new(config);
    assert_eq(policy.current_attempt, 0);
    assert_eq(policy.total_retries, 0);
    assert(policy.last_error is None);
}

@test
fn test_retry_policy_should_retry() {
    let config = RetryConfig {
        max_attempts: 3,
        backoff: BackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let policy = RetryPolicy.new(config);
    // Fresh policy should allow retry
    assert(policy.should_retry());
}

@test
fn test_retry_policy_next_delay_fixed() {
    let config = RetryConfig {
        max_attempts: 3,
        backoff: BackoffStrategy.Fixed { delay_ms: 200 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let policy = RetryPolicy.new(config);
    assert_eq(policy.next_delay_ms(), 200);
}

@test
fn test_retry_policy_reset() {
    let config = RetryConfig {
        max_attempts: 3,
        backoff: BackoffStrategy.Fixed { delay_ms: 100 },
        jitter: JitterConfig.None,
        retry_on: RetryPredicate.AllErrors,
    };
    let mut policy = RetryPolicy.new(config);
    policy.current_attempt = 2;
    policy.reset();
    assert_eq(policy.current_attempt, 0);
    assert(policy.last_error is None);
}

