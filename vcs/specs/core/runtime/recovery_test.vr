// =============================================================================
// recovery_test.vr - Tests for runtime recovery types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: runtime, recovery, circuit-breaker, retry, backoff, core
// @description: Tests for error recovery types: BackoffStrategy, CircuitState, JitterConfig
// =============================================================================

mount core.runtime.recovery.{
    BackoffStrategy,
    CircuitState,
    JitterConfig,
    CircuitBreaker,
    CircuitBreakerConfig,
    CircuitBreakerStats,
    CircuitBreakerError,
    ErrorPredicate,
    RetryConfig,
    RetryPolicy,
    RetryPredicate,
    RecoveryStrategy,
    InlineRetryPolicy,
};

// =============================================================================
// Section 1: BackoffStrategy Variants
// =============================================================================

@test
fn test_backoff_fixed() {
    let backoff: BackoffStrategy = BackoffStrategy.Fixed { delay_ms: 100 };
    assert(backoff is BackoffStrategy.Fixed);
}

@test
fn test_backoff_linear() {
    let backoff: BackoffStrategy = BackoffStrategy.Linear { base_ms: 100, increment_ms: 50, max_ms: 1000 };
    assert(backoff is BackoffStrategy.Linear);
}

@test
fn test_backoff_exponential() {
    let backoff: BackoffStrategy = BackoffStrategy.Exponential { base_ms: 100, max_ms: 5000, multiplier: 2 };
    assert(backoff is BackoffStrategy.Exponential);
}

@test
fn test_backoff_none() {
    let backoff: BackoffStrategy = BackoffStrategy.None;
    assert(backoff is BackoffStrategy.None);
}

// =============================================================================
// Section 2: BackoffStrategy.calculate_delay_ms
// =============================================================================

@test
fn test_backoff_fixed_delay() {
    let backoff: BackoffStrategy = BackoffStrategy.Fixed { delay_ms: 100 };
    assert_eq(backoff.calculate_delay_ms(0), 100);
    assert_eq(backoff.calculate_delay_ms(1), 100);
    assert_eq(backoff.calculate_delay_ms(5), 100);
}

@test
fn test_backoff_linear_delay() {
    let backoff: BackoffStrategy = BackoffStrategy.Linear { base_ms: 100, increment_ms: 50, max_ms: 1000 };
    assert_eq(backoff.calculate_delay_ms(0), 100);
    assert_eq(backoff.calculate_delay_ms(1), 150);
    assert_eq(backoff.calculate_delay_ms(2), 200);
}

@test
fn test_backoff_linear_delay_capped() {
    let backoff: BackoffStrategy = BackoffStrategy.Linear { base_ms: 100, increment_ms: 200, max_ms: 500 };
    // 100 + 3 * 200 = 700, but capped at 500
    assert_eq(backoff.calculate_delay_ms(3), 500);
}

@test
fn test_backoff_exponential_delay() {
    let backoff: BackoffStrategy = BackoffStrategy.Exponential { base_ms: 100, max_ms: 10000, multiplier: 2 };
    assert_eq(backoff.calculate_delay_ms(0), 100);
    assert_eq(backoff.calculate_delay_ms(1), 200);
    assert_eq(backoff.calculate_delay_ms(2), 400);
    assert_eq(backoff.calculate_delay_ms(3), 800);
}

@test
fn test_backoff_exponential_delay_capped() {
    let backoff: BackoffStrategy = BackoffStrategy.Exponential { base_ms: 100, max_ms: 500, multiplier: 2 };
    // 100 * 2^3 = 800, but capped at 500
    assert_eq(backoff.calculate_delay_ms(3), 500);
}

@test
fn test_backoff_none_delay() {
    let backoff: BackoffStrategy = BackoffStrategy.None;
    assert_eq(backoff.calculate_delay_ms(0), 0);
    assert_eq(backoff.calculate_delay_ms(10), 0);
}

@test
fn test_backoff_exponential_constructor() {
    let backoff: BackoffStrategy = BackoffStrategy.exponential(200, 10000);
    match backoff {
        BackoffStrategy.Exponential { base_ms, max_ms, multiplier } => {
            assert_eq(base_ms, 200);
            assert_eq(max_ms, 10000);
            assert_eq(multiplier, 2);
        }
        _ => panic("Expected Exponential"),
    }
}

@test
fn test_backoff_match_fixed() {
    let backoff: BackoffStrategy = BackoffStrategy.Fixed { delay_ms: 250 };
    match backoff {
        BackoffStrategy.Fixed { delay_ms } => {
            assert_eq(delay_ms, 250);
        }
        _ => panic("Expected Fixed"),
    }
}

@test
fn test_backoff_match_linear() {
    let backoff: BackoffStrategy = BackoffStrategy.Linear { base_ms: 100, increment_ms: 25, max_ms: 2000 };
    match backoff {
        BackoffStrategy.Linear { base_ms, increment_ms, max_ms } => {
            assert_eq(base_ms, 100);
            assert_eq(increment_ms, 25);
            assert_eq(max_ms, 2000);
        }
        _ => panic("Expected Linear"),
    }
}

// =============================================================================
// Section 3: CircuitState
// =============================================================================

@test
fn test_circuit_state_closed() {
    let state: CircuitState = CircuitState.Closed;
    assert(state is CircuitState.Closed);
    assert(!(state is CircuitState.Open));
    assert(!(state is CircuitState.HalfOpen));
}

@test
fn test_circuit_state_open() {
    let state: CircuitState = CircuitState.Open;
    assert(state is CircuitState.Open);
    assert(!(state is CircuitState.Closed));
    assert(!(state is CircuitState.HalfOpen));
}

@test
fn test_circuit_state_half_open() {
    let state: CircuitState = CircuitState.HalfOpen;
    assert(state is CircuitState.HalfOpen);
    assert(!(state is CircuitState.Closed));
    assert(!(state is CircuitState.Open));
}

@test
fn test_circuit_state_to_u8() {
    assert_eq(CircuitState.Closed.to_u8(), 0);
    assert_eq(CircuitState.Open.to_u8(), 1);
    assert_eq(CircuitState.HalfOpen.to_u8(), 2);
}

@test
fn test_circuit_state_from_u8() {
    assert(CircuitState.from_u8(0) is CircuitState.Closed);
    assert(CircuitState.from_u8(1) is CircuitState.Open);
    assert(CircuitState.from_u8(2) is CircuitState.HalfOpen);
    // Unknown values default to Closed
    assert(CircuitState.from_u8(255) is CircuitState.Closed);
}

@test
fn test_circuit_state_match() {
    let state: CircuitState = CircuitState.HalfOpen;
    match state {
        CircuitState.Closed => panic("Expected HalfOpen"),
        CircuitState.Open => panic("Expected HalfOpen"),
        CircuitState.HalfOpen => {} // Expected
    }
}

