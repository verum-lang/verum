}

@test
fn test_shutdown_strategy_custom_timeout() {
    let graceful = ShutdownStrategy.Graceful { timeout_ms: 10000 };

    assert_eq(graceful.timeout_ms(), 10000);

    print("ShutdownStrategy custom timeout test passed");
