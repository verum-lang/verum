@test
fn test_escalation_reason_restart_limit() {
    let child_id = ChildId.new();
    let reason = EscalationReason.RestartLimitExceeded {
        child_id: child_id,
        child_name: "database-worker",
        max_restarts: 3,
        window_secs: 60,
        last_failure: FailureReason.Panic("OOM"),
    };
    let desc = reason.description();
    assert(!desc.is_empty());
}

// =============================================================================
// Section 18: RestartIntensity Edge Cases
// =============================================================================

@test
fn test_restart_intensity_single_restart_limit() {
    let mut intensity = RestartIntensity.new(1, 60000);
    assert(intensity.would_allow_restart());
    let allowed = intensity.record_restart();
    assert(allowed);
    // Now at limit
    assert(!intensity.would_allow_restart());
    let denied = intensity.record_restart();
    assert(!denied);
}

@test
fn test_restart_intensity_zero_limit() {
    let mut intensity = RestartIntensity.new(0, 60000);
    // Zero limit means no restarts allowed
    assert(!intensity.would_allow_restart());
    let denied = intensity.record_restart();
    assert(!denied);
}

@test
fn test_restart_intensity_multiple_resets() {
    let mut intensity = RestartIntensity.new(2, 60000);
    intensity.record_restart();
    intensity.record_restart();
    assert(!intensity.would_allow_restart());

    // First reset
    intensity.reset();
    assert(intensity.would_allow_restart());
    intensity.record_restart();
    assert_eq(intensity.current_count(), 1);

    // Second reset
    intensity.reset();
    assert_eq(intensity.current_count(), 0);
}

