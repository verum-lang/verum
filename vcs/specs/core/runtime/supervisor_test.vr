// =============================================================================
// supervisor_test.vr - Tests for supervision tree types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: runtime, supervisor, erlang, otp, fault-tolerance, core
// @description: Tests for Erlang/OTP-style supervision tree types
//
// Coverage:
// - SupervisorId and ChildId generation
// - SupervisionStrategy variants
// - RestartStrategy behavior
// - FailureReason classification
// - ChildStatus transitions
// - ChildSpec construction and variants
// - RestartIntensity tracking
// - ShutdownStrategy configuration
// - SupervisorConfig construction
// - EscalationPolicy and EscalationReason
// =============================================================================

module specs.core.runtime.supervisor_test;

mount core.runtime.supervisor.{
    SupervisorId,
    ChildId,
    SupervisionStrategy,
    RestartStrategy,
    FailureReason,
    ChildStatus,
    ChildSpec,
    RestartIntensity,
    ShutdownStrategy,
    SupervisorConfig,
    EscalationPolicy,
    EscalationReason,
    SupervisorError,
    SupervisorHandle,
    SupervisorStatus,
    RestartEvent,
};
mount core.runtime.spawn.{PriorityLevel};

// =============================================================================
// Section 1: SupervisorId Tests
// =============================================================================

@test
fn test_supervisor_id_new() {
    let id1 = SupervisorId.new();
    let id2 = SupervisorId.new();

    // IDs should be unique
    assert(id1.raw() != id2.raw());

    print("SupervisorId.new() test passed");
}

@test
fn test_supervisor_id_root() {
    let root = SupervisorId.root();

    // Root ID should be 0
    assert_eq(root.raw(), 0);

    print("SupervisorId.root() test passed");
}

@test
fn test_supervisor_id_raw() {
    let id = SupervisorId.new();
    let raw = id.raw();

    // Raw value should be positive (non-root)
    assert(raw > 0);

    print("SupervisorId.raw() test passed");
}

// =============================================================================
// Section 2: ChildId Tests
// =============================================================================

@test
fn test_child_id_new() {
    let id1 = ChildId.new();
    let id2 = ChildId.new();

    // IDs should be unique
    assert(id1.raw() != id2.raw());

    print("ChildId.new() test passed");
}

@test
fn test_child_id_raw() {
    let id = ChildId.new();
    let raw = id.raw();

    // Raw value should be positive
    assert(raw > 0);

    print("ChildId.raw() test passed");
}

// =============================================================================
// Section 3: SupervisionStrategy Tests
// =============================================================================

@test
fn test_supervision_strategy_variants() {
    let one_for_one = SupervisionStrategy.OneForOne;
    let one_for_all = SupervisionStrategy.OneForAll;
    let rest_for_one = SupervisionStrategy.RestForOne;

    assert(one_for_one is SupervisionStrategy.OneForOne);
    assert(one_for_all is SupervisionStrategy.OneForAll);
    assert(rest_for_one is SupervisionStrategy.RestForOne);

    print("SupervisionStrategy variants test passed");
}

@test
fn test_supervision_strategy_description() {
    let one_for_one = SupervisionStrategy.OneForOne;
    let desc = one_for_one.description();

    assert(!desc.is_empty());

    print("SupervisionStrategy.description() test passed");
}

@test
fn test_supervision_strategy_one_for_one() {
    // OneForOne: Only restart the failed child
    let strategy = SupervisionStrategy.OneForOne;
    let desc = strategy.description();

    assert(desc.contains(&"one") || desc.contains(&"One"));

    print("SupervisionStrategy OneForOne test passed");
}

@test
fn test_supervision_strategy_one_for_all() {
    // OneForAll: Restart all children when one fails
    let strategy = SupervisionStrategy.OneForAll;
    let desc = strategy.description();

    assert(desc.contains(&"all") || desc.contains(&"All"));

    print("SupervisionStrategy OneForAll test passed");
}

@test
fn test_supervision_strategy_rest_for_one() {
    // RestForOne: Restart failed child and all children started after it
    let strategy = SupervisionStrategy.RestForOne;
    let desc = strategy.description();

    assert(desc.contains(&"rest") || desc.contains(&"Rest"));

    print("SupervisionStrategy RestForOne test passed");
}

// =============================================================================
// Section 4: RestartStrategy Tests
// =============================================================================

@test
fn test_restart_strategy_variants() {
    let permanent = RestartStrategy.Permanent;
    let transient = RestartStrategy.Transient;
    let temporary = RestartStrategy.Temporary;

    assert(permanent is RestartStrategy.Permanent);
    assert(transient is RestartStrategy.Transient);
    assert(temporary is RestartStrategy.Temporary);

    print("RestartStrategy variants test passed");
}

@test
fn test_restart_strategy_permanent() {
    // Permanent: Always restart
    let strategy = RestartStrategy.Permanent;

    // Should restart for any failure
    let normal_exit = FailureReason.NormalExit;
    let crash = FailureReason.Panic("test");

    assert(strategy.should_restart(normal_exit));
    assert(strategy.should_restart(crash));

    print("RestartStrategy Permanent test passed");
}

@test
fn test_restart_strategy_transient() {
    // Transient: Only restart on abnormal exit
    let strategy = RestartStrategy.Transient;

    let normal_exit = FailureReason.NormalExit;
    let crash = FailureReason.Panic("test");

    assert(!strategy.should_restart(normal_exit));  // Normal exit: don't restart
    assert(strategy.should_restart(crash));          // Crash: restart

    print("RestartStrategy Transient test passed");
}

@test
fn test_restart_strategy_temporary() {
    // Temporary: Never restart
    let strategy = RestartStrategy.Temporary;

    let normal_exit = FailureReason.NormalExit;
    let crash = FailureReason.Panic("test");

    assert(!strategy.should_restart(normal_exit));
    assert(!strategy.should_restart(crash));

    print("RestartStrategy Temporary test passed");
}

// =============================================================================
// Section 5: FailureReason Tests
// =============================================================================

@test
fn test_failure_reason_variants() {
    let normal = FailureReason.NormalExit;
    let shutdown = FailureReason.SupervisorShutdown;
    let crash = FailureReason.Panic("error");
    let timeout = FailureReason.Timeout;
    let killed = FailureReason.Cancelled;

    assert(normal is FailureReason.NormalExit);
    assert(shutdown is FailureReason.SupervisorShutdown);
    assert(crash is FailureReason.Panic);
    assert(timeout is FailureReason.Timeout);
    assert(killed is FailureReason.Cancelled);

    print("FailureReason variants test passed");
}

@test
fn test_failure_reason_is_abnormal() {
    // Normal exit and shutdown are normal
    assert(!FailureReason.NormalExit.is_abnormal());
    assert(!FailureReason.SupervisorShutdown.is_abnormal());

    // Crash, timeout, killed are abnormal
    let crash = FailureReason.Panic("error");
    assert(crash.is_abnormal());
    assert(FailureReason.Timeout.is_abnormal());
    assert(FailureReason.Cancelled.is_abnormal());

    print("FailureReason.is_abnormal() test passed");
}

@test
fn test_failure_reason_description() {
    let normal = FailureReason.NormalExit;
    let crash = FailureReason.Panic("test error");

    let normal_desc = normal.description();
    let crash_desc = crash.description();

    assert(!normal_desc.is_empty());
    assert(!crash_desc.is_empty());
    assert(crash_desc.contains(&"test error") || crash_desc.contains(&"error"));

    print("FailureReason.description() test passed");
}

// =============================================================================
// Section 6: ChildStatus Tests
// =============================================================================

@test
fn test_child_status_variants() {
    let running = ChildStatus.Running;
    let starting = ChildStatus.Starting;
    let restarting = ChildStatus.Restarting;
    let terminated = ChildStatus.Terminated;
    let failed = ChildStatus.Failed;
    let stopped = ChildStatus.Stopped;

    assert(running is ChildStatus.Running);
    assert(starting is ChildStatus.Starting);
    assert(restarting is ChildStatus.Restarting);
    assert(terminated is ChildStatus.Terminated);
    assert(failed is ChildStatus.Failed);
    assert(stopped is ChildStatus.Stopped);

    print("ChildStatus variants test passed");
}

@test
fn test_child_status_from_u8() {
    // Test conversion from u8
    let running = ChildStatus.from_u8(0);
    let starting = ChildStatus.from_u8(1);
    let restarting = ChildStatus.from_u8(2);
    let terminated = ChildStatus.from_u8(3);
    let failed = ChildStatus.from_u8(4);
    let stopped = ChildStatus.from_u8(5);

    assert(running is ChildStatus.Running);
    assert(starting is ChildStatus.Starting);
    assert(restarting is ChildStatus.Restarting);
    assert(terminated is ChildStatus.Terminated);
    assert(failed is ChildStatus.Failed);
    assert(stopped is ChildStatus.Stopped);

    print("ChildStatus.from_u8() test passed");
}

@test
fn test_child_status_is_active() {
    // Active states: Running, Starting, Restarting
    assert(ChildStatus.Running.is_active());
    assert(ChildStatus.Starting.is_active());
    assert(ChildStatus.Restarting.is_active());

    // Inactive states: Terminated, Failed, Stopped
    assert(!ChildStatus.Terminated.is_active());
    assert(!ChildStatus.Failed.is_active());
    assert(!ChildStatus.Stopped.is_active());

    print("ChildStatus.is_active() test passed");
}

