@test
fn test_child_spec_new() {
    let spec = ChildSpec.new("test");

    // Default values
    assert(spec.restart is RestartStrategy.Transient);

    print("ChildSpec.new() test passed");
}

@test
fn test_child_spec_permanent() {
    let spec = ChildSpec.permanent("test");

    assert(spec.restart is RestartStrategy.Permanent);

    print("ChildSpec.permanent() test passed");
}

@test
fn test_child_spec_temporary() {
    let spec = ChildSpec.temporary("test");

    assert(spec.restart is RestartStrategy.Temporary);

    print("ChildSpec.temporary() test passed");
}

@test
fn test_child_spec_default() {
    let spec = ChildSpec.default();

    // Default should be Transient
    assert(spec.restart is RestartStrategy.Transient);

    print("ChildSpec.default() test passed");
}

@test
fn test_child_spec_with_restart() {
    let spec = ChildSpec.new("test")
        .with_restart(RestartStrategy.Permanent);

    assert(spec.restart is RestartStrategy.Permanent);

    print("ChildSpec.with_restart() test passed");
}

@test
fn test_child_spec_with_shutdown_timeout() {
    let spec = ChildSpec.new("test")
        .with_shutdown_timeout_ms(5000);

    // Verify timeout is set
    assert(spec.shutdown_timeout_ms > 0);
    assert_eq(spec.shutdown_timeout_ms, 5000);

    print("ChildSpec.with_shutdown_timeout_ms() test passed");
}

@test
fn test_child_spec_with_restart_limits() {
    let spec = ChildSpec.new("test")
        .with_restart_limits(3, 60000);  // 3 restarts in 60 seconds

    assert_eq(spec.max_restarts, 3);
    assert_eq(spec.restart_window_secs, 60000);

    print("ChildSpec.with_restart_limits() test passed");
}

@test
fn test_child_spec_with_priority() {
    let spec = ChildSpec.new("test")
        .with_priority(PriorityLevel.High.to_u8());

    assert_eq(spec.priority, PriorityLevel.High.to_u8());

    print("ChildSpec.with_priority() test passed");
}

@test
fn test_child_spec_builder_chain() {
    let spec = ChildSpec.new("test")
        .with_restart(RestartStrategy.Permanent)
        .with_shutdown_timeout_ms(10000)
        .with_restart_limits(5, 120000)
        .with_priority(PriorityLevel.Critical.to_u8());

    assert(spec.restart is RestartStrategy.Permanent);
    assert_eq(spec.shutdown_timeout_ms, 10000);
    assert_eq(spec.max_restarts, 5);
    assert_eq(spec.restart_window_secs, 120000);
    assert_eq(spec.priority, PriorityLevel.Critical.to_u8());

    print("ChildSpec builder chain test passed");
}

// =============================================================================
// Section 8: RestartIntensity Tests
// =============================================================================

@test
fn test_restart_intensity_new() {
    let intensity = RestartIntensity.new(3, 60000);  // 3 restarts in 60 seconds

    assert_eq(intensity.max_restarts, 3);
    assert_eq(intensity.window_ms, 60000);
    assert_eq(intensity.current_count(), 0);

    print("RestartIntensity.new() test passed");
}

@test
fn test_restart_intensity_record_restart() {
    let mut intensity = RestartIntensity.new(3, 60000);

    // First restart should be allowed
    let allowed1 = intensity.record_restart();
    assert(allowed1);
    assert_eq(intensity.current_count(), 1);

    // Second restart should be allowed
    let allowed2 = intensity.record_restart();
    assert(allowed2);
    assert_eq(intensity.current_count(), 2);

    // Third restart should be allowed
    let allowed3 = intensity.record_restart();
    assert(allowed3);
    assert_eq(intensity.current_count(), 3);

    // Fourth restart should NOT be allowed (exceeds limit)
    let allowed4 = intensity.record_restart();
    assert(!allowed4);

    print("RestartIntensity.record_restart() test passed");
}

@test
fn test_restart_intensity_would_allow() {
    let mut intensity = RestartIntensity.new(2, 60000);

    // Should allow first two
    assert(intensity.would_allow_restart());
    intensity.record_restart();

    assert(intensity.would_allow_restart());
    intensity.record_restart();

    // Should not allow third
    assert(!intensity.would_allow_restart());

    print("RestartIntensity.would_allow_restart() test passed");
}

@test
fn test_restart_intensity_reset() {
    let mut intensity = RestartIntensity.new(3, 60000);

    // Record some restarts
    intensity.record_restart();
    intensity.record_restart();
    assert_eq(intensity.current_count(), 2);

    // Reset
    intensity.reset();
    assert_eq(intensity.current_count(), 0);

    // Should allow restarts again
    assert(intensity.would_allow_restart());

    print("RestartIntensity.reset() test passed");
}

