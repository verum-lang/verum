// =============================================================================
// Section 11: EscalationPolicy Tests
// =============================================================================

@test
fn test_escalation_variants() {
    let escalate = EscalationPolicy.EscalateToParent;
    let restart = EscalationPolicy.RestartSubtree;
    let shutdown = EscalationPolicy.Terminate;
    let ignore = EscalationPolicy.LogAndIgnore;

    assert(escalate is EscalationPolicy.EscalateToParent);
    assert(restart is EscalationPolicy.RestartSubtree);
    assert(shutdown is EscalationPolicy.Terminate);
    assert(ignore is EscalationPolicy.LogAndIgnore);

    print("EscalationPolicy variants test passed");
}

// =============================================================================
// Section 12: EscalationReason Tests
// =============================================================================

@test
fn test_escalation_reason_variants() {
    // Test RestartLimitExceeded variant with named fields
    let child_id = ChildId.new();
    let restart_limit = EscalationReason.RestartLimitExceeded {
        child_id: child_id,
        child_name: "worker",
        max_restarts: 10,
        window_secs: 60,
        last_failure: FailureReason.Panic("test error"),
    };
    assert(restart_limit is EscalationReason.RestartLimitExceeded);

    // Test InternalFault variant
    let fault = EscalationReason.InternalFault { error: "internal error" };
    assert(fault is EscalationReason.InternalFault);

    // Test AllStrategiesExhausted variant
    let exhausted = EscalationReason.AllStrategiesExhausted;
    assert(exhausted is EscalationReason.AllStrategiesExhausted);

    print("EscalationReason variants test passed");
}

@test
fn test_escalation_reason_description() {
    let reason = EscalationReason.AllStrategiesExhausted;
    let desc = reason.description();

    assert(!desc.is_empty());

    print("EscalationReason.description() test passed");
}

// =============================================================================
// Section 13: SupervisorError Tests
// =============================================================================

@test
fn test_supervisor_error_too_many_restarts() {
    let err = SupervisorError.TooManyRestarts { count: 5, window_secs: 60 };
    assert(err is SupervisorError.TooManyRestarts);
    let desc = err.description();
    assert(!desc.is_empty());
}

@test
fn test_supervisor_error_child_not_found() {
    let id = ChildId.new();
    let err = SupervisorError.ChildNotFound(id);
    assert(err is SupervisorError.ChildNotFound);
    let desc = err.description();
    assert(!desc.is_empty());
}

@test
fn test_supervisor_error_shutting_down() {
    let err = SupervisorError.ShuttingDown;
    assert(err is SupervisorError.ShuttingDown);
    let desc = err.description();
    assert(!desc.is_empty());
}

@test
fn test_supervisor_error_spawn_failed() {
    let err = SupervisorError.SpawnFailed("task crashed");
    assert(err is SupervisorError.SpawnFailed);
    let desc = err.description();
    assert(desc.contains(&"task crashed") || desc.contains(&"spawn"));
}

@test
fn test_supervisor_error_channel_closed() {
    let err = SupervisorError.ChannelClosed;
    assert(err is SupervisorError.ChannelClosed);
}

@test
fn test_supervisor_error_invalid_spec() {
    let err = SupervisorError.InvalidSpec("missing name");
    assert(err is SupervisorError.InvalidSpec);
    let desc = err.description();
    assert(!desc.is_empty());
}

@test
fn test_supervisor_error_no_parent() {
    let err = SupervisorError.NoParentSupervisor;
    assert(err is SupervisorError.NoParentSupervisor);
}

@test
fn test_supervisor_error_other() {
    let err = SupervisorError.Other("custom error");
    assert(err is SupervisorError.Other);
    let desc = err.description();
    assert_eq(desc, "custom error");
}

@test
fn test_supervisor_error_all_descriptions_non_empty() {
    // Verify every variant produces a non-empty description
    let id = ChildId.new();
    let errors: List<SupervisorError> = [
        SupervisorError.TooManyRestarts { count: 1, window_secs: 10 },
        SupervisorError.ChildNotFound(id),
        SupervisorError.ShuttingDown,
        SupervisorError.SpawnFailed("test"),
        SupervisorError.ChannelClosed,
        SupervisorError.InvalidSpec("test"),
        SupervisorError.NoParentSupervisor,
        SupervisorError.Other("test"),
    ];
    for err in errors.iter() {
        assert(!err.description().is_empty());
    }
}

// =============================================================================
// Section 14: SupervisorHandle Construction
// =============================================================================

@test
fn test_supervisor_handle_new() {
    let config = SupervisorConfig.one_for_one("test-sup");
    let handle: SupervisorHandle = SupervisorHandle.new(config);
    assert(handle.id().raw() > 0);
}

@test
fn test_supervisor_handle_root() {
    let config = SupervisorConfig.one_for_one("root");
    let handle: SupervisorHandle = SupervisorHandle.root(config);
    assert_eq(handle.id().raw(), 0);
}

@test
fn test_supervisor_handle_name() {
    let config = SupervisorConfig.one_for_one("my-supervisor");
    let handle = SupervisorHandle.new(config);
    assert_eq(handle.name(), "my-supervisor");
}

@test
fn test_supervisor_handle_status() {
    let config = SupervisorConfig.one_for_one("status-test");
    let handle = SupervisorHandle.new(config);
    let status: SupervisorStatus = handle.status();
    assert_eq(status.child_count, 0);
    assert_eq(status.running_count, 0);
    assert(status.is_running);
}

@test
fn test_supervisor_handle_unique_ids() {
    let config1 = SupervisorConfig.one_for_one("sup1");
    let config2 = SupervisorConfig.one_for_one("sup2");
    let h1 = SupervisorHandle.new(config1);
    let h2 = SupervisorHandle.new(config2);
    assert(h1.id().raw() != h2.id().raw());
}

// =============================================================================
// Section 15: SupervisorConfig Advanced
// =============================================================================

@test
fn test_supervisor_config_full_builder() {
    let config = SupervisorConfig.one_for_all("full-config")
        .with_restart_limits(5, 120000)
        .with_escalation(EscalationPolicy.Terminate);
    assert(config.strategy is SupervisionStrategy.OneForAll);
    assert_eq(config.max_restarts, 5);
    assert_eq(config.restart_window_secs, 120000);
    assert(config.escalation is EscalationPolicy.Terminate);
}

@test
fn test_supervisor_config_rest_for_one_with_escalation() {
    let config = SupervisorConfig.rest_for_one("rfo-sup")
        .with_escalation(EscalationPolicy.EscalateToParent);
    assert(config.strategy is SupervisionStrategy.RestForOne);
    assert(config.escalation is EscalationPolicy.EscalateToParent);
}

