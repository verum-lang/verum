@test
fn test_escalation_reason_sub_supervisor() {
    let sup_id = SupervisorId.new();
    let inner_reason = EscalationReason.AllStrategiesExhausted;
    let reason = EscalationReason.SubSupervisorEscalation {
        supervisor_id: sup_id,
        reason: Heap.new(inner_reason),
