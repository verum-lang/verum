// =============================================================================
// SECTION 9: EnvIsolationLevel All Variants
// =============================================================================

@test
fn test_isolation_level_send_only() {
    let level = EnvIsolationLevel.SendOnly;
    assert(level is EnvIsolationLevel.SendOnly);
    assert(!(level is EnvIsolationLevel.Shared));
}

@test
fn test_isolation_level_full() {
    let level = EnvIsolationLevel.Full;
    assert(level is EnvIsolationLevel.Full);
    assert(!(level is EnvIsolationLevel.Shared));
    assert(!(level is EnvIsolationLevel.SendOnly));
}

@test
fn test_isolation_level_match_exhaustive() {
    let level = EnvIsolationLevel.SendOnly;
    let val = match level {
        EnvIsolationLevel.Shared => 0,
        EnvIsolationLevel.SendOnly => 1,
        EnvIsolationLevel.Full => 2,
    };
    assert_eq(val, 1);
}

// =============================================================================
// SECTION 10: RecoveryCircuitState All-Pairs Distinctness
// =============================================================================

@test
fn test_circuit_state_closed_not_others() {
    let s = RecoveryCircuitState.Closed;
    assert(s is RecoveryCircuitState.Closed);
    assert(!(s is RecoveryCircuitState.Open));
    assert(!(s is RecoveryCircuitState.HalfOpen));
}

@test
fn test_circuit_state_open_not_others() {
    let s = RecoveryCircuitState.Open;
    assert(s is RecoveryCircuitState.Open);
    assert(!(s is RecoveryCircuitState.Closed));
    assert(!(s is RecoveryCircuitState.HalfOpen));
}

@test
fn test_circuit_state_half_open_not_others() {
    let s = RecoveryCircuitState.HalfOpen;
    assert(s is RecoveryCircuitState.HalfOpen);
    assert(!(s is RecoveryCircuitState.Closed));
    assert(!(s is RecoveryCircuitState.Open));
}

// =============================================================================
// SECTION 11: SupervisionStrategy Match & Distinctness
// =============================================================================

@test
fn test_supervision_strategy_match_exhaustive() {
    let strat = SupervisionStrategy.RestForOne;
    let val = match strat {
        SupervisionStrategy.OneForOne => "1-1",
        SupervisionStrategy.OneForAll => "1-all",
        SupervisionStrategy.RestForOne => "rest-1",
    };
    assert_eq(val, "rest-1");
}

@test
fn test_supervision_strategy_all_distinct() {
    let s1 = SupervisionStrategy.OneForOne;
    let s2 = SupervisionStrategy.OneForAll;
    let s3 = SupervisionStrategy.RestForOne;
    assert(s1 is SupervisionStrategy.OneForOne);
    assert(!(s1 is SupervisionStrategy.OneForAll));
    assert(!(s1 is SupervisionStrategy.RestForOne));
    assert(s2 is SupervisionStrategy.OneForAll);
    assert(!(s2 is SupervisionStrategy.OneForOne));
    assert(s3 is SupervisionStrategy.RestForOne);
    assert(!(s3 is SupervisionStrategy.OneForAll));
}

// =============================================================================
// SECTION 12: RecoveryBackoffStrategy Edge Cases
// =============================================================================

@test
fn test_backoff_strategy_fixed_zero_delay() {
    let strat = RecoveryBackoffStrategy.Fixed { delay_ms: 0 as UInt64 };
    match strat {
        RecoveryBackoffStrategy.Fixed { delay_ms } => { assert_eq(delay_ms, 0 as UInt64); }
        _ => { assert(false); }
    }
}

@test
fn test_backoff_strategy_none_not_others() {
    let s = RecoveryBackoffStrategy.None;
    assert(s is RecoveryBackoffStrategy.None);
    assert(!(s is RecoveryBackoffStrategy.Fixed));
    assert(!(s is RecoveryBackoffStrategy.Linear));
    assert(!(s is RecoveryBackoffStrategy.Exponential));
}

// =============================================================================
// SECTION 13: Additional Tests
// =============================================================================

@test
fn test_execution_tier_tier0() {
    let tier = ExecutionTier.Tier0_Full;
    assert(tier is ExecutionTier.Tier0_Full);
    assert(!(tier is ExecutionTier.Tier1_Epoch));
}

@test
fn test_execution_tier_all_variants() {
    let t0 = ExecutionTier.Tier0_Full;
    let t1 = ExecutionTier.Tier1_Epoch;
    let t2 = ExecutionTier.Tier2_Gen;
    let t3 = ExecutionTier.Tier3_Unchecked;
    assert(t0 is ExecutionTier.Tier0_Full);
    assert(t1 is ExecutionTier.Tier1_Epoch);
    assert(t2 is ExecutionTier.Tier2_Gen);
    assert(t3 is ExecutionTier.Tier3_Unchecked);
}

@test
fn test_isolation_level_send_only() {
    let level = EnvIsolationLevel.SendOnly;
    assert(level is EnvIsolationLevel.SendOnly);
    assert(!(level is EnvIsolationLevel.Shared));
    assert(!(level is EnvIsolationLevel.Full));
}

@test
fn test_isolation_level_full_not_shared() {
    let level = EnvIsolationLevel.Full;
    assert(level is EnvIsolationLevel.Full);
    assert(!(level is EnvIsolationLevel.Shared));
}

@test
fn test_backoff_strategy_linear_fields() {
    let strat = RecoveryBackoffStrategy.Linear {
        base_ms: 100 as UInt64,
        increment_ms: 50 as UInt64,
        max_ms: 5000 as UInt64,
    };
    match strat {
        RecoveryBackoffStrategy.Linear { base_ms, increment_ms, max_ms } => {
            assert_eq(base_ms, 100 as UInt64);
            assert_eq(increment_ms, 50 as UInt64);
            assert_eq(max_ms, 5000 as UInt64);
        }
        _ => { assert(false); }
    }
}

@test
fn test_backoff_strategy_exponential_fields() {
    let strat = RecoveryBackoffStrategy.Exponential {
        base_ms: 100 as UInt64,
        max_ms: 10000 as UInt64,
        multiplier: 2,
    };
    match strat {
        RecoveryBackoffStrategy.Exponential { base_ms, max_ms, multiplier } => {
            assert_eq(base_ms, 100 as UInt64);
            assert_eq(max_ms, 10000 as UInt64);
            assert_eq(multiplier, 2);
        }
        _ => { assert(false); }
    }
}

@test
fn test_supervision_strategy_match_all() {
    fn strategy_name(s: SupervisionStrategy) -> Text {
        match s {
            SupervisionStrategy.OneForOne => "one_for_one",
            SupervisionStrategy.OneForAll => "one_for_all",
            SupervisionStrategy.RestForOne => "rest_for_one",
        }
    }
    assert_eq(strategy_name(SupervisionStrategy.OneForOne), "one_for_one");
    assert_eq(strategy_name(SupervisionStrategy.OneForAll), "one_for_all");
    assert_eq(strategy_name(SupervisionStrategy.RestForOne), "rest_for_one");
}

@test
fn test_execution_tier_match() {
    fn tier_name(t: ExecutionTier) -> Text {
        match t {
            ExecutionTier.Tier0_Full => "full",
            ExecutionTier.Tier1_Epoch => "epoch",
            ExecutionTier.Tier2_Gen => "gen",
            ExecutionTier.Tier3_Unchecked => "unchecked",
        }
    }
    assert_eq(tier_name(ExecutionTier.Tier0_Full), "full");
    assert_eq(tier_name(ExecutionTier.Tier3_Unchecked), "unchecked");
}

