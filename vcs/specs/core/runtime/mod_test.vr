// =============================================================================
// mod_test.vr - Tests for runtime module root types and constants
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: runtime, initialization, execution-env, core
// @description: Tests for runtime module types, constants, and function
//               signatures. Runtime initialization functions (init, shutdown,
//               current_env) require actual runtime to execute, so we test
//               type existence and constant values only.
// =============================================================================

mount core.runtime.{
    ExecutionEnv, MemoryContext, CapabilityContext,
    RecoveryContext, ConcurrencyContext,
    ExecutionTier, RuntimeRestartPolicy, EnvIsolationLevel,
    EXEC_ENV_SLOT, SUPERVISOR_SLOT, RECOVERY_SLOT,
    // Function existence verification
    current_env, current_env_mut, is_initialized,
    init, shutdown,
};
mount core.runtime.spawn.{
    SpawnConfig, SpawnConfigBuilder, PriorityLevel,
};
mount core.runtime.recovery.{
    RetryPolicy, RuntimeRetryConfig, RecoveryCircuitBreaker, RecoveryCircuitState,
    RecoveryBackoffStrategy, RuntimeRecoveryStrategy,
};
mount core.runtime.supervisor.{
    Supervisor, SupervisorId, SupervisorHandle,
    SupervisionStrategy, ChildSpec, RestartIntensity,
};

// =============================================================================
// SECTION 1: Context Slot Constants
// =============================================================================

@test
fn test_exec_env_slot() {
    assert_eq(EXEC_ENV_SLOT, 0);
}

@test
fn test_supervisor_slot() {
    assert_eq(SUPERVISOR_SLOT, 1);
}

@test
fn test_recovery_slot() {
    assert_eq(RECOVERY_SLOT, 2);
}

@test
fn test_slots_unique() {
    assert(EXEC_ENV_SLOT != SUPERVISOR_SLOT);
    assert(SUPERVISOR_SLOT != RECOVERY_SLOT);
    assert(EXEC_ENV_SLOT != RECOVERY_SLOT);
}

// =============================================================================
// SECTION 2: Function Existence Verification
// =============================================================================

@test
fn test_current_env_exists() {
    // Verify the function exists and has correct type
    let _ = current_env;
}

@test
fn test_current_env_mut_exists() {
    let _ = current_env_mut;
}

@test
fn test_is_initialized_exists() {
    let _ = is_initialized;
}

@test
fn test_init_exists() {
    let _ = init;
}

@test
fn test_shutdown_exists() {
    let _ = shutdown;
}

// =============================================================================
// SECTION 3: ExecutionTier Type Tests
// =============================================================================

@test
fn test_isolation_level_shared() {
    let level = EnvIsolationLevel.Shared;
    assert(level is EnvIsolationLevel.Shared);
}

@test
fn test_isolation_level_variants() {
    // Verify all variants exist
    let _ = EnvIsolationLevel.Shared;
}

// =============================================================================
// SECTION 4: PriorityLevel Type Tests
// =============================================================================

@test
fn test_priority_level_variants() {
    let low = PriorityLevel.Low;
    let normal = PriorityLevel.Normal;
    let high = PriorityLevel.High;
    let critical = PriorityLevel.Critical;

    assert(low is PriorityLevel.Low);
    assert(normal is PriorityLevel.Normal);
    assert(high is PriorityLevel.High);
    assert(critical is PriorityLevel.Critical);
}

@test
fn test_priority_level_match() {
    let p = PriorityLevel.High;
    let val = match p {
        PriorityLevel.Low => 0,
        PriorityLevel.Normal => 1,
        PriorityLevel.High => 2,
        PriorityLevel.Critical => 3,
    };
    assert_eq(val, 2);
}

// =============================================================================
// SECTION 5: RecoveryCircuitState Type Tests
// =============================================================================

@test
fn test_circuit_state_closed() {
    let state = RecoveryCircuitState.Closed;
    assert(state is RecoveryCircuitState.Closed);
}

@test
fn test_circuit_state_open() {
    let state = RecoveryCircuitState.Open;
    assert(state is RecoveryCircuitState.Open);
}

@test
fn test_circuit_state_half_open() {
    let state = RecoveryCircuitState.HalfOpen;
    assert(state is RecoveryCircuitState.HalfOpen);
}

@test
fn test_circuit_state_match() {
    let s = RecoveryCircuitState.HalfOpen;
    let val = match s {
        RecoveryCircuitState.Closed => "closed",
        RecoveryCircuitState.Open => "open",
        RecoveryCircuitState.HalfOpen => "half-open",
    };
    assert_eq(val, "half-open");
}

// =============================================================================
// SECTION 6: SupervisionStrategy Type Tests
// =============================================================================

@test
fn test_supervision_strategy_one_for_one() {
    let strat = SupervisionStrategy.OneForOne;
    assert(strat is SupervisionStrategy.OneForOne);
}

@test
fn test_supervision_strategy_one_for_all() {
    let strat = SupervisionStrategy.OneForAll;
    assert(strat is SupervisionStrategy.OneForAll);
}

@test
fn test_supervision_strategy_rest_for_one() {
    let strat = SupervisionStrategy.RestForOne;
    assert(strat is SupervisionStrategy.RestForOne);
}

// =============================================================================
// SECTION 7: RecoveryBackoffStrategy Type Tests
// =============================================================================

@test
fn test_backoff_strategy_fixed() {
    let strat = RecoveryBackoffStrategy.Fixed { delay_ms: 1000 as UInt64 };
    match strat {
        RecoveryBackoffStrategy.Fixed { delay_ms } => { assert_eq(delay_ms, 1000 as UInt64); }
        _ => { assert(false); }
    }
}

@test
fn test_backoff_strategy_exponential() {
    let strat = RecoveryBackoffStrategy.Exponential {
        base_ms: 100 as UInt64,
        max_ms: 10000 as UInt64,
        multiplier: 2,
    };
    match strat {
        RecoveryBackoffStrategy.Exponential { base_ms, max_ms, multiplier } => {
            assert_eq(base_ms, 100 as UInt64);
            assert_eq(multiplier, 2);
        }
        _ => { assert(false); }
    }
}

@test
fn test_backoff_strategy_none() {
    let strat = RecoveryBackoffStrategy.None;
    assert(strat is RecoveryBackoffStrategy.None);
}

@test
fn test_backoff_strategy_linear() {
    let strat = RecoveryBackoffStrategy.Linear {
        base_ms: 100 as UInt64,
        increment_ms: 50 as UInt64,
        max_ms: 5000 as UInt64,
    };
    assert(strat is RecoveryBackoffStrategy.Linear);
}

