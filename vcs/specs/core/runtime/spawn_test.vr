@test
fn test_spawn_config_builder_priority_helpers() {
    let bg = SpawnConfigBuilder.new().background().build_unchecked();
    assert(bg.priority is PriorityLevel.Background);

    let high = SpawnConfigBuilder.new().high_priority().build_unchecked();
    assert(high.priority is PriorityLevel.High);

    let critical = SpawnConfigBuilder.new().critical().build_unchecked();
    assert(critical.priority is PriorityLevel.Critical);

    print("SpawnConfigBuilder priority helpers test passed");
