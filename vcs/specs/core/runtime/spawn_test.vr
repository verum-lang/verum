// =============================================================================
// Section 14: Combined Builder Patterns
// =============================================================================

@test
fn test_builder_combined_name_priority_restart() {
    let config = SpawnConfigBuilder.new()
        .name("worker")
        .high_priority()
        .permanent()
        .build_unchecked();

    assert_eq(config.name, Maybe.Some("worker"));
    assert(config.priority is PriorityLevel.High);
    assert(config.restart.is_some());
    let policy = config.restart.unwrap();
    assert(policy.strategy is RuntimeRestartStrategy.Permanent);
}

@test
fn test_builder_combined_isolation_retry() {
    let config = SpawnConfigBuilder.new()
        .isolated()
        .with_retry_default()
        .build_unchecked();

    assert(config.isolation == Maybe.Some(EnvIsolationLevel.Full));
    assert(config.recovery.is_some());
}

@test
fn test_builder_last_priority_wins() {
    let config = SpawnConfigBuilder.new()
        .background()
        .high_priority()
        .critical()
        .build_unchecked();

    assert(config.priority is PriorityLevel.Critical);
}

@test
fn test_builder_last_restart_wins() {
    let config = SpawnConfigBuilder.new()
        .permanent()
        .temporary()
        .build_unchecked();

    assert(config.restart.is_some());
    let policy = config.restart.unwrap();
    assert(policy.strategy is RuntimeRestartStrategy.Temporary);
}

