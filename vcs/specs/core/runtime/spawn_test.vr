@test
fn test_builder_build_valid_config() {
    let result = SpawnConfigBuilder.new()
        .name("valid-task")
        .high_priority()
        .build();

    assert(result.is_ok());
    let config = result.unwrap();
    assert_eq(config.name, Maybe.Some("valid-task"));
    assert(config.priority is PriorityLevel.High);
}

@test
fn test_builder_build_with_restart() {
    let result = SpawnConfigBuilder.new()
        .permanent()
        .build();

    // permanent() sets max_restarts=10, so should be valid
    assert(result.is_ok());
}

@test
fn test_builder_build_transient_valid() {
    let result = SpawnConfigBuilder.new()
        .transient()
        .build();

    assert(result.is_ok());
}

@test
fn test_builder_build_temporary_valid() {
    let result = SpawnConfigBuilder.new()
        .temporary()
        .build();

    assert(result.is_ok());
}

@test
fn test_builder_build_unchecked_returns_config() {
    let config = SpawnConfigBuilder.new()
        .name("unchecked")
        .critical()
        .build_unchecked();

    assert_eq(config.name, Maybe.Some("unchecked"));
    assert(config.priority is PriorityLevel.Critical);
}

// =============================================================================
// Section 11: RuntimeRestartPolicy and RuntimeRestartStrategy Type Tests
// =============================================================================

@test
fn test_restart_strategy_permanent() {
    let strat = RuntimeRestartStrategy.Permanent;
    assert(strat is RuntimeRestartStrategy.Permanent);
}

@test
fn test_restart_strategy_transient() {
    let strat = RuntimeRestartStrategy.Transient;
    assert(strat is RuntimeRestartStrategy.Transient);
}

@test
fn test_restart_strategy_temporary() {
    let strat = RuntimeRestartStrategy.Temporary;
    assert(strat is RuntimeRestartStrategy.Temporary);
}

@test
fn test_restart_strategy_match() {
    let strat = RuntimeRestartStrategy.Transient;
    let val = match strat {
        RuntimeRestartStrategy.Permanent => "permanent",
        RuntimeRestartStrategy.Transient => "transient",
        RuntimeRestartStrategy.Temporary => "temporary",
    };
    assert_eq(val, "transient");
}

@test
fn test_builder_permanent_sets_restart_policy() {
    let config = SpawnConfigBuilder.new()
        .permanent()
        .build_unchecked();

    assert(config.restart.is_some());
    let policy = config.restart.unwrap();
    assert(policy.strategy is RuntimeRestartStrategy.Permanent);
    assert_eq(policy.max_restarts, 10);
    assert_eq(policy.time_window_secs, 60 as UInt64);
}

@test
fn test_builder_transient_sets_restart_policy() {
    let config = SpawnConfigBuilder.new()
        .transient()
        .build_unchecked();

    assert(config.restart.is_some());
    let policy = config.restart.unwrap();
    assert(policy.strategy is RuntimeRestartStrategy.Transient);
    assert_eq(policy.max_restarts, 5);
}

@test
fn test_builder_temporary_sets_restart_policy() {
    let config = SpawnConfigBuilder.new()
        .temporary()
        .build_unchecked();

    assert(config.restart.is_some());
    let policy = config.restart.unwrap();
    assert(policy.strategy is RuntimeRestartStrategy.Temporary);
    assert_eq(policy.max_restarts, 0);
}

