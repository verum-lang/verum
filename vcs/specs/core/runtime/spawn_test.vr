@test
fn test_spawn_config_builder_restart_helpers() {
    let permanent = SpawnConfigBuilder.new().permanent().build_unchecked();
    // Permanent should set restart strategy to always restart

    let transient = SpawnConfigBuilder.new().transient().build_unchecked();
    // Transient should restart only on failure

    let temporary = SpawnConfigBuilder.new().temporary().build_unchecked();
    // Temporary should never restart

    print("SpawnConfigBuilder restart helpers test passed");
}

