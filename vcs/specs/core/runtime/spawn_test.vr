// =============================================================================
// Section 16: RuntimeRecoveryStrategy Type Tests
// =============================================================================

@test
fn test_recovery_strategy_none() {
    let strat = RuntimeRecoveryStrategy.None;
    assert(strat is RuntimeRecoveryStrategy.None);
}

@test
fn test_recovery_strategy_supervision() {
    let strat = RuntimeRecoveryStrategy.Supervision;
    assert(strat is RuntimeRecoveryStrategy.Supervision);
}

@test
fn test_recovery_strategy_retry_factory() {
    let strat = RuntimeRecoveryStrategy.retry(3);
    assert(strat is RuntimeRecoveryStrategy.Retry);
}

@test
fn test_recovery_strategy_circuit_breaker_factory() {
    let strat = RuntimeRecoveryStrategy.circuit_breaker(5);
    assert(strat is RuntimeRecoveryStrategy.UseBreaker);
}

@test
fn test_recovery_strategy_match() {
    let strat = RuntimeRecoveryStrategy.None;
    let val = match strat {
        RuntimeRecoveryStrategy.None => "none",
        RuntimeRecoveryStrategy.Retry(_) => "retry",
        RuntimeRecoveryStrategy.UseBreaker(_) => "breaker",
        RuntimeRecoveryStrategy.Supervision => "supervision",
        RuntimeRecoveryStrategy.Composed(_) => "composed",
    };
    assert_eq(val, "none");
}

