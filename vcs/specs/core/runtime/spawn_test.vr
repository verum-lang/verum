// =============================================================================
// spawn_test.vr - Comprehensive tests for SupervisorSpawnConfig and task spawning
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: runtime, spawn, priority, config, core
// @description: Tests for SupervisorSpawnConfig builder pattern, PriorityLevel, and spawn utilities
//
// Coverage:
// - PriorityLevel variants and conversion
// - InlineContextStorage operations
// - SupervisorSpawnConfig construction and builder pattern
// - SpawnConfigBuilder validation
// - Configuration application to environment
// =============================================================================

module specs.core.runtime.spawn_test;

mount core.runtime.spawn.{
    PriorityLevel,
    SupervisorSpawnConfig,
    SpawnConfigBuilder,
    InlineContextStorage,
    // Convenience spawn functions (existence verification)
    spawn_with_retry, spawn_high_priority, spawn_background,
    spawn_with_timeout, spawn_named, spawn_isolated,
};
mount core.runtime.recovery.{
    RecoveryBackoffStrategy,
    RuntimeRecoveryStrategy,
    RuntimeRetryConfig, JitterConfig, RetryPredicate,
};
mount core.runtime.env.{EnvIsolationLevel, RuntimeRestartPolicy, RuntimeRestartStrategy};

// =============================================================================
// Section 1: PriorityLevel Tests
// =============================================================================

@test
fn test_priority_level_variants() {
    let bg = PriorityLevel.Background;
    let low = PriorityLevel.Low;
    let normal = PriorityLevel.Normal;
    let high = PriorityLevel.High;
    let critical = PriorityLevel.Critical;

    // Variants exist and are distinct
    assert(bg is PriorityLevel.Background);
    assert(low is PriorityLevel.Low);
    assert(normal is PriorityLevel.Normal);
    assert(high is PriorityLevel.High);
    assert(critical is PriorityLevel.Critical);

    print("PriorityLevel variants test passed");
}

@test
fn test_priority_level_to_u8() {
    assert_eq(PriorityLevel.Background.to_u8(), 32);
    assert_eq(PriorityLevel.Low.to_u8(), 64);
    assert_eq(PriorityLevel.Normal.to_u8(), 128);
    assert_eq(PriorityLevel.High.to_u8(), 192);
    assert_eq(PriorityLevel.Critical.to_u8(), 255);

    print("PriorityLevel to_u8 test passed");
}

@test
fn test_priority_level_from_u8() {
    // Background: 0..48
    assert(PriorityLevel.from_u8(0) is PriorityLevel.Background);
    assert(PriorityLevel.from_u8(32) is PriorityLevel.Background);
    assert(PriorityLevel.from_u8(47) is PriorityLevel.Background);

    // Low: 48..96
    assert(PriorityLevel.from_u8(48) is PriorityLevel.Low);
    assert(PriorityLevel.from_u8(64) is PriorityLevel.Low);
    assert(PriorityLevel.from_u8(95) is PriorityLevel.Low);

    // Normal: 96..160
    assert(PriorityLevel.from_u8(96) is PriorityLevel.Normal);
    assert(PriorityLevel.from_u8(128) is PriorityLevel.Normal);
    assert(PriorityLevel.from_u8(159) is PriorityLevel.Normal);

    // High: 160..224
    assert(PriorityLevel.from_u8(160) is PriorityLevel.High);
    assert(PriorityLevel.from_u8(192) is PriorityLevel.High);
    assert(PriorityLevel.from_u8(223) is PriorityLevel.High);

    // Critical: 224+
    assert(PriorityLevel.from_u8(224) is PriorityLevel.Critical);
    assert(PriorityLevel.from_u8(255) is PriorityLevel.Critical);

    print("PriorityLevel from_u8 test passed");
}

@test
fn test_priority_level_default() {
    let default_priority = PriorityLevel.default();
    assert(default_priority is PriorityLevel.Normal);
    assert_eq(default_priority.to_u8(), 128);

    print("PriorityLevel default test passed");
}

@test
fn test_priority_level_roundtrip() {
    // Converting to u8 and back should preserve level (within bucket)
    let bg = PriorityLevel.Background;
    let bg_u8 = bg.to_u8();
    let bg_back = PriorityLevel.from_u8(bg_u8);
    assert(bg_back is PriorityLevel.Background);

    let critical = PriorityLevel.Critical;
    let critical_u8 = critical.to_u8();
    let critical_back = PriorityLevel.from_u8(critical_u8);
    assert(critical_back is PriorityLevel.Critical);

    print("PriorityLevel roundtrip test passed");
}

@test
fn test_priority_level_ordering() {
    // Higher priority should have higher numeric value
    assert(PriorityLevel.Background.to_u8() < PriorityLevel.Low.to_u8());
    assert(PriorityLevel.Low.to_u8() < PriorityLevel.Normal.to_u8());
    assert(PriorityLevel.Normal.to_u8() < PriorityLevel.High.to_u8());
    assert(PriorityLevel.High.to_u8() < PriorityLevel.Critical.to_u8());

    print("PriorityLevel ordering test passed");
}

// =============================================================================
// Section 2: SupervisorSpawnConfig Construction Tests
// =============================================================================

@test
fn test_spawn_config_new() {
    let config = SupervisorSpawnConfig.new();

    // Default values
    assert(config.name.is_none());
    assert(config.recovery.is_none());
    assert(config.restart.is_none());
    assert(config.isolation.is_none());
    assert(config.supervisor.is_none());
    assert(config.deadline_ns == 0);  // 0 = no deadline
    assert_eq(config.priority, PriorityLevel.Normal);

    print("SupervisorSpawnConfig.new() test passed");
}

@test
fn test_spawn_config_default() {
    let config = SupervisorSpawnConfig.default();

    // Same as new()
    assert(config.name.is_none());
    assert_eq(config.priority, PriorityLevel.Normal);

    print("SupervisorSpawnConfig.default() test passed");
}

// =============================================================================
// Section 3: SupervisorSpawnConfig Builder Methods Tests
// =============================================================================

@test
fn test_spawn_config_with_name() {
    let config = SupervisorSpawnConfig.new().with_name("my-task");

    match config.name {
        Maybe.Some(name) => assert_eq(name, "my-task"),
        Maybe.None => panic("Expected name to be set"),
    }

    print("SupervisorSpawnConfig.with_name() test passed");
}

@test
fn test_spawn_config_with_priority() {
    let config = SupervisorSpawnConfig.new().with_priority(PriorityLevel.High);

    assert(config.priority is PriorityLevel.High);
    assert_eq(config.priority.to_u8(), 192);

    print("SupervisorSpawnConfig.with_priority() test passed");
}

@test
fn test_spawn_config_with_isolation() {
    let shared = SupervisorSpawnConfig.new().with_isolation(EnvIsolationLevel.Shared);
    assert(shared.isolation == Maybe.Some(EnvIsolationLevel.Shared));

    let send_only = SupervisorSpawnConfig.new().with_isolation(EnvIsolationLevel.SendOnly);
    assert(send_only.isolation == Maybe.Some(EnvIsolationLevel.SendOnly));

    let full = SupervisorSpawnConfig.new().with_isolation(EnvIsolationLevel.Full);
    assert(full.isolation == Maybe.Some(EnvIsolationLevel.Full));

    print("SupervisorSpawnConfig.with_isolation() test passed");
}

@test
fn test_spawn_config_with_timeout_ms() {
    let config = SupervisorSpawnConfig.new().with_timeout_ms(5000 as UInt64);

    // Timeout should be converted to deadline in nanoseconds (> 0 means set)
    assert(config.deadline_ns > 0);

    print("SupervisorSpawnConfig.with_timeout_ms() test passed");
}

@test
fn test_spawn_config_with_deadline_ns() {
    let deadline: UInt64 = 1000000000;  // 1 second in nanoseconds
    let config = SupervisorSpawnConfig.new().with_deadline_ns(deadline);

    assert_eq(config.deadline_ns, deadline);

    print("SupervisorSpawnConfig.with_deadline_ns() test passed");
}

@test
fn test_spawn_config_with_stack_size() {
    let config = SupervisorSpawnConfig.new().with_stack_size(65536);  // 64KB

    // stack_size is Int (0 = default), so we just compare directly
    assert_eq(config.stack_size, 65536);

    print("SupervisorSpawnConfig.with_stack_size() test passed");
}

// =============================================================================
// Section 4: SupervisorSpawnConfig Chaining Tests
// =============================================================================

@test
fn test_spawn_config_builder_chain() {
    let config = SupervisorSpawnConfig.new()
        .with_name("worker-1")
        .with_priority(PriorityLevel.High)
        .with_isolation(EnvIsolationLevel.Full)
        .with_timeout_ms(10000 as UInt64)
        .with_stack_size(32768);

    // Verify all settings
    assert_eq(config.name, Maybe.Some("worker-1"));
    assert(config.priority is PriorityLevel.High);
    assert(config.isolation == Maybe.Some(EnvIsolationLevel.Full));
    assert(config.deadline_ns > 0);  // 0 = no deadline, > 0 = set
    assert_eq(config.stack_size, 32768);  // stack_size is Int

    print("SupervisorSpawnConfig builder chain test passed");
}

@test
fn test_spawn_config_clone() {
    let original = SupervisorSpawnConfig.new()
        .with_name("original")
        .with_priority(PriorityLevel.Critical);

    let cloned = original.clone();

    // Should have same values
    assert_eq(cloned.name, original.name);
    assert_eq(cloned.priority.to_u8(), original.priority.to_u8());

    print("SupervisorSpawnConfig clone test passed");
}

