@test
fn test_spawn_config_empty_name() {
    let config = SupervisorSpawnConfig.new().with_name("");

    // Empty name should be allowed (or rejected depending on design)
    assert_eq(config.name, Maybe.Some(""));

    print("SupervisorSpawnConfig empty name test passed");
}

@test
fn test_spawn_config_zero_timeout() {
    let config = SupervisorSpawnConfig.new().with_timeout_ms(0 as UInt64);

    // Zero timeout sets deadline to current time (immediate deadline)
    assert(config.deadline_ns > 0);

    print("SupervisorSpawnConfig zero timeout test passed");
}

@test
fn test_spawn_config_zero_stack_size() {
    let config = SupervisorSpawnConfig.new().with_stack_size(0);

    // Zero stack size means use default (stack_size is Int, 0 = default)
    assert_eq(config.stack_size, 0);

    print("SupervisorSpawnConfig zero stack size test passed");
}

@test
fn test_spawn_config_large_timeout() {
    // Very large timeout (1 day in ms)
    let one_day_ms: UInt64 = (24 as UInt64) * 60 * 60 * 1000;
    let config = SupervisorSpawnConfig.new().with_timeout_ms(one_day_ms);

    assert(config.deadline_ns > 0);

    print("SupervisorSpawnConfig large timeout test passed");
}

@test
fn test_spawn_config_override_priority() {
    // Setting priority multiple times should use the last value
    let config = SupervisorSpawnConfig.new()
        .with_priority(PriorityLevel.Low)
        .with_priority(PriorityLevel.High)
        .with_priority(PriorityLevel.Critical);

    assert(config.priority is PriorityLevel.Critical);

    print("SupervisorSpawnConfig override priority test passed");
}

@test
fn test_spawn_config_override_name() {
    // Setting name multiple times should use the last value
    let config = SupervisorSpawnConfig.new()
        .with_name("first")
        .with_name("second")
        .with_name("third");

    assert_eq(config.name, Maybe.Some("third"));

    print("SupervisorSpawnConfig override name test passed");
}

// =============================================================================
// Section 9: PriorityLevel Match Expression
// =============================================================================

@test
fn test_priority_level_match_all() {
    let levels = [
        PriorityLevel.Background,
        PriorityLevel.Low,
        PriorityLevel.Normal,
        PriorityLevel.High,
        PriorityLevel.Critical,
    ];

    let mut i = 0;
    while i < 5 {
        let val = match levels[i] {
            PriorityLevel.Background => 0,
            PriorityLevel.Low => 1,
            PriorityLevel.Normal => 2,
            PriorityLevel.High => 3,
            PriorityLevel.Critical => 4,
        };
        assert_eq(val, i);
        i = i + 1;
    }
}

@test
fn test_priority_level_is_not_cross() {
    let bg = PriorityLevel.Background;
    assert(!(bg is PriorityLevel.Low));
    assert(!(bg is PriorityLevel.Normal));
    assert(!(bg is PriorityLevel.High));
    assert(!(bg is PriorityLevel.Critical));
}

