// Coverage:
// - Thread, ThreadFn, ThreadError: Thread types
// - spawn: Thread creation
// - Clone flags (CLONE_VM, CLONE_THREAD, etc.)
// - futex operations (wait, wake, requeue)
// - SpinLock, Mutex, Condvar: Synchronization primitives
//
// Test Strategy:
// - Test type construction and constants
// - Test synchronization primitives (single-threaded)
// - Verify clone flag values
// - Test futex operations with timeouts
//
// Note: Multi-threaded tests are limited in single-threaded environment.
//
// Platform: Linux x86_64
// =============================================================================

@cfg(target_os = "linux")
module test.stdlib.sys.linux.thread_test;

mount core.sys.linux.thread.{
    Thread, ThreadFn, ThreadError,
    spawn,

    CLONE_VM, CLONE_FS, CLONE_FILES, CLONE_SIGHAND,
    CLONE_THREAD, CLONE_SETTLS, CLONE_THREAD_FLAGS,

    futex_requeue, futex_cmp_requeue,
    futex_wait_bitset, futex_wake_bitset,
    FUTEX_WAIT, FUTEX_WAKE, FUTEX_REQUEUE,
    FUTEX_PRIVATE_FLAG, FUTEX_BITSET_MATCH_ANY,

    SpinLock, Mutex, Condvar,
};

mount core.sys.linux.{futex_wait, futex_wake};
mount core.sys.linux.time.{Timespec};
mount core.sys.linux.errno.{EAGAIN, ETIMEDOUT};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// Clone Flags Tests
// =============================================================================

@test
fn test_clone_flags() {
    // Individual clone flags
    assert(CLONE_VM == 0x00000100);
    assert(CLONE_FS == 0x00000200);
    assert(CLONE_FILES == 0x00000400);
    assert(CLONE_SIGHAND == 0x00000800);
    assert(CLONE_THREAD == 0x00010000);
    assert(CLONE_SETTLS == 0x00080000);

    // Clone flags are distinct bits
    assert((CLONE_VM & CLONE_FS) == 0);
    assert((CLONE_VM & CLONE_FILES) == 0);
    assert((CLONE_VM & CLONE_SIGHAND) == 0);
    assert((CLONE_THREAD & CLONE_SETTLS) == 0);

    // Combined thread flags
    let expected_thread_flags = CLONE_VM | CLONE_FS | CLONE_FILES |
                                CLONE_SIGHAND | CLONE_THREAD | CLONE_SETTLS;
    assert(CLONE_THREAD_FLAGS == expected_thread_flags);

    // All thread flags should be set
    assert((CLONE_THREAD_FLAGS & CLONE_VM) != 0);
    assert((CLONE_THREAD_FLAGS & CLONE_FS) != 0);
    assert((CLONE_THREAD_FLAGS & CLONE_FILES) != 0);
    assert((CLONE_THREAD_FLAGS & CLONE_SIGHAND) != 0);
    assert((CLONE_THREAD_FLAGS & CLONE_THREAD) != 0);
    assert((CLONE_THREAD_FLAGS & CLONE_SETTLS) != 0);

    print("Clone flags tests passed");
}

// =============================================================================
// Futex Constants Tests
// =============================================================================

@test
fn test_futex_constants() {
    // Basic futex operations
    assert(FUTEX_WAIT == 0);
    assert(FUTEX_WAKE == 1);
    assert(FUTEX_REQUEUE == 3);

    // Private flag (faster, process-local)
    assert(FUTEX_PRIVATE_FLAG == 128);

    // Bitset match all
    assert(FUTEX_BITSET_MATCH_ANY == 0xFFFFFFFF);

    // Operations with private flag
    let wait_private = FUTEX_WAIT | FUTEX_PRIVATE_FLAG;
    let wake_private = FUTEX_WAKE | FUTEX_PRIVATE_FLAG;

    assert(wait_private == 128);
    assert(wake_private == 129);

    print("Futex constants tests passed");
}

// =============================================================================
// SpinLock Tests
// =============================================================================

@test
fn test_spinlock() {
    // Create spinlock
    let mut lock = SpinLock.new();

    // Initially unlocked
    assert(!lock.is_locked());

    // Lock should succeed
    lock.lock();
    assert(lock.is_locked());

    // Try lock should fail (already locked)
    let try_result = lock.try_lock();
    assert(!try_result);

    // Unlock
    lock.unlock();
    assert(!lock.is_locked());

    // Try lock should succeed now
    let try_result2 = lock.try_lock();
    assert(try_result2);
    assert(lock.is_locked());

    lock.unlock();

    // Multiple lock/unlock cycles
    for _ in 0..10 {
        lock.lock();
        assert(lock.is_locked());
        lock.unlock();
        assert(!lock.is_locked());
    }

    print("SpinLock tests passed");
}

// =============================================================================
// Mutex Tests
// =============================================================================

@test
fn test_mutex() {
    // Create mutex
    let mut mutex = Mutex.new();

    // Lock should succeed
    let lock_result = mutex.lock();
    assert(lock_result is Ok);

    // Try lock should fail (already locked by this thread)
    // Note: Behavior depends on mutex type (normal vs recursive)
    let try_result = mutex.try_lock();
    // May or may not succeed depending on implementation

    // Unlock
    mutex.unlock();

    // Try lock should succeed now
    let try_result2 = mutex.try_lock();
    assert(try_result2 is Ok);

    mutex.unlock();

    // Lock with timeout
    let timeout = Timespec { tv_sec: 0, tv_nsec: 1_000_000 };  // 1ms
    let timed_result = mutex.lock_timeout(&timeout);
    assert(timed_result is Ok);
    mutex.unlock();

    print("Mutex tests passed");
}

// =============================================================================
// Condvar Type Tests
// =============================================================================

@test
fn test_condvar_type() {
    // Create condvar
    let condvar = Condvar.new();

    // Create associated mutex
    let mut mutex = Mutex.new();

    // Signal with no waiters should be safe
    condvar.signal();
    condvar.broadcast();

    // Wait with timeout (should timeout immediately since no signal)
    let _ = mutex.lock();

    let timeout = Timespec { tv_sec: 0, tv_nsec: 1_000_000 };  // 1ms
    let wait_result = condvar.wait_timeout(&mut mutex, &timeout);

    // Should timeout (no signal)
    match wait_result {
        Ok(()) => {
            // Spurious wakeup allowed
        }
        Err(e) => {
            // Expected: timeout
        }
    }

    mutex.unlock();

    print("Condvar type tests passed");
}

// =============================================================================
// ThreadError Type Tests
// =============================================================================

@test
fn test_thread_error_types() {
    // Create various ThreadError variants
    let clone_err = ThreadError.CloneFailed { errno: 12 };  // ENOMEM
    let tls_err = ThreadError.TlsSetupFailed { reason: "arch_prctl failed" };
    let stack_err = ThreadError.StackAllocationFailed { size: 8388608 };
    let join_err = ThreadError.JoinFailed { tid: 12345 };
    let detached = ThreadError.AlreadyDetached { tid: 54321 };

    // Pattern matching
    match clone_err {
        ThreadError.CloneFailed { errno } => {
            assert(errno == 12);
        }
        _ => assert(false),
    }

    match tls_err {
        ThreadError.TlsSetupFailed { reason } => {
            assert(reason.contains("arch_prctl"));
        }
        _ => assert(false),
    }

    match stack_err {
        ThreadError.StackAllocationFailed { size } => {
            assert(size == 8388608);  // 8MB
        }
        _ => assert(false),
    }

    match join_err {
        ThreadError.JoinFailed { tid } => {
            assert(tid == 12345);
        }
        _ => assert(false),
    }

    match detached {
        ThreadError.AlreadyDetached { tid } => {
            assert(tid == 54321);
        }
        _ => assert(false),
    }

    print("ThreadError type tests passed");
}

// =============================================================================
// Futex Bitset Tests
// =============================================================================

@test
fn test_futex_bitset() {
    let mut futex_var: Int = 0;

    // Wait with bitset (should fail immediately with wrong value)
    let result = futex_wait_bitset(
        &mut futex_var,
        999,  // Wrong value
        null,
        FUTEX_BITSET_MATCH_ANY
    );

    match result {
        Err(e) => {
            // Expected: EAGAIN (value mismatch)
            assert(e == EAGAIN);
        }
        Ok(()) => {
            // Should not succeed
            assert(false);
        }
    }

    // Wait with bitset and timeout
    let timeout = Timespec { tv_sec: 0, tv_nsec: 1_000_000 };  // 1ms

    let result2 = futex_wait_bitset(
        &mut futex_var,
        0,  // Correct value
        &timeout,
        FUTEX_BITSET_MATCH_ANY
    );

    match result2 {
        Err(e) => {
            // Expected: ETIMEDOUT
            assert(e == ETIMEDOUT);
        }
        Ok(()) => {
            // Spurious wakeup allowed
        }
    }

    // Wake with bitset (no waiters)
    let woken = futex_wake_bitset(&mut futex_var, 1, FUTEX_BITSET_MATCH_ANY);
    assert(woken is Ok);
    assert(woken.unwrap() == 0);  // No waiters

    // Test selective bitset (wake only specific bits)
    let specific_bits = 0x0000000F;  // Only lower 4 bits
    let woken2 = futex_wake_bitset(&mut futex_var, 1, specific_bits);
    assert(woken2 is Ok);

    print("Futex bitset tests passed");
}

