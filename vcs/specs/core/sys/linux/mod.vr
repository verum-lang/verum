// - io_test.vr      : io_uring and epoll I/O drivers
// - thread_test.vr  : Thread creation and synchronization
// - mem_test.vr     : Memory management (mmap, mprotect, madvise)
// - time_test.vr    : Clock operations (clock_gettime, RDTSC)
//
// Platform: Linux x86_64
// Layer: 0 (V-LLSI Kernel)
// =============================================================================

@cfg(target_os = "linux")
module test.stdlib.sys.linux;

// =============================================================================
// Test Module Exports
// =============================================================================

/// Raw syscall tests
public module syscall_test;

/// Errno constants tests
public module errno_test;

/// TLS bootstrap tests
public module tls_test;

/// I/O driver tests (io_uring + epoll)
public module io_test;

/// Thread creation tests
public module thread_test;

/// Memory management tests
public module mem_test;

/// Time and clock tests
public module time_test;
