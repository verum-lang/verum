module specs.core.sys.interrupt_test;

mount core.sys.interrupt.{
    CriticalSection,
    CpuContext,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// CriticalSection Tests
// =============================================================================

@test
fn test_critical_section_construction() {
    let cs = CriticalSection { previous_state: 0 };
    assert_eq(cs.previous_state, 0);
}

@test
fn test_critical_section_with_state() {
    let cs = CriticalSection { previous_state: 1 };
    assert_eq(cs.previous_state, 1);
}

@test
fn test_critical_section_state_preserved() {
    let state: USize = 0xFF;
    let cs = CriticalSection { previous_state: state };
    assert_eq(cs.previous_state, state);
}

// =============================================================================
// CpuContext Tests
// =============================================================================

@test
fn test_cpu_context_zero() {
    let ctx = CpuContext.zero();
    // All registers should be zero
    let _ = ctx;  // Type verification
}

@test
fn test_cpu_context_type_exists() {
    // Verify CpuContext can be used as a type
    let ctx: CpuContext = CpuContext.zero();
    let _ = ctx;
}
