// =============================================================================
// GpioConfig Tests
// =============================================================================

@test
fn test_gpio_config_construction() {
    let config = GpioConfig {
        mode: GpioMode.Input,
        speed: GpioSpeed.Low,
        pull_up: false,
        pull_down: false,
        alternate_function: 0 as UInt8,
        reserved: 0 as UInt8,
    };
    match config.mode {
        GpioMode.Input => { /* expected */ }
        _ => assert(false, "Should be Input mode"),
    }
}

@test
fn test_gpio_config_output_mode() {
    let config = GpioConfig {
        mode: GpioMode.OutputPushPull,
        speed: GpioSpeed.High,
        pull_up: true,
        pull_down: false,
        alternate_function: 0 as UInt8,
        reserved: 0 as UInt8,
    };
    assert(config.pull_up, "pull_up should be true");
    assert(!config.pull_down, "pull_down should be false");
}

@test
fn test_gpio_config_alternate_function() {
    let config = GpioConfig {
        mode: GpioMode.AlternateFunction,
        speed: GpioSpeed.VeryHigh,
        pull_up: false,
        pull_down: false,
        alternate_function: 7 as UInt8,
        reserved: 0 as UInt8,
    };
    assert_eq(config.alternate_function, 7 as UInt8);
}

@test
fn test_gpio_config_size() {
    // GpioConfig should be 16 bits = 2 bytes
    assert_eq(GpioConfig.SIZE_BYTES, 2);
    assert_eq(GpioConfig.SIZE_BITS, 16);
}
