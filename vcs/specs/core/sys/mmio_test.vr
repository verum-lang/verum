// =============================================================================
// MemoryFlags Tests
// =============================================================================

@test
fn test_memory_flags_read() {
    let flags = MemoryFlags.READ;
    // Verify READ flag is non-zero
    assert(flags.0 != 0, "READ flag should be non-zero");
}

@test
fn test_memory_flags_write() {
    let flags = MemoryFlags.WRITE;
    assert(flags.0 != 0, "WRITE flag should be non-zero");
}

@test
fn test_memory_flags_exec() {
    let flags = MemoryFlags.EXEC;
    assert(flags.0 != 0, "EXEC flag should be non-zero");
}

@test
fn test_memory_flags_dma() {
    let flags = MemoryFlags.DMA;
    assert(flags.0 != 0, "DMA flag should be non-zero");
}

@test
fn test_memory_flags_distinct() {
    // All flags should be distinct
    assert(MemoryFlags.READ.0 != MemoryFlags.WRITE.0, "READ != WRITE");
    assert(MemoryFlags.READ.0 != MemoryFlags.EXEC.0, "READ != EXEC");
    assert(MemoryFlags.READ.0 != MemoryFlags.DMA.0, "READ != DMA");
    assert(MemoryFlags.WRITE.0 != MemoryFlags.EXEC.0, "WRITE != EXEC");
    assert(MemoryFlags.WRITE.0 != MemoryFlags.DMA.0, "WRITE != DMA");
    assert(MemoryFlags.EXEC.0 != MemoryFlags.DMA.0, "EXEC != DMA");
}

@test
fn test_memory_flags_values() {
    // Verify exact bit positions
    assert_eq(MemoryFlags.READ.0, 0b0001 as UInt32);
    assert_eq(MemoryFlags.WRITE.0, 0b0010 as UInt32);
    assert_eq(MemoryFlags.EXEC.0, 0b0100 as UInt32);
    assert_eq(MemoryFlags.DMA.0, 0b1000 as UInt32);
}
