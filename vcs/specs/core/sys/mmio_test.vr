module specs.core.sys.mmio_test;

mount core.sys.mmio.{
    AccessMode,
    BarrierKind,
    MemoryFlags,
    MemoryRegion,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// AccessMode Tests
// =============================================================================

@test
fn test_access_mode_read_only() {
    let mode = AccessMode.ReadOnly;
    match mode {
        AccessMode.ReadOnly => { /* expected */ }
        _ => assert(false, "Should be ReadOnly"),
    }
}

@test
fn test_access_mode_write_only() {
    let mode = AccessMode.WriteOnly;
    match mode {
        AccessMode.WriteOnly => { /* expected */ }
        _ => assert(false, "Should be WriteOnly"),
    }
}

@test
fn test_access_mode_read_write() {
    let mode = AccessMode.ReadWrite;
    match mode {
        AccessMode.ReadWrite => { /* expected */ }
        _ => assert(false, "Should be ReadWrite"),
    }
}

@test
fn test_access_mode_read_write_once() {
    let mode = AccessMode.ReadWriteOnce;
    match mode {
        AccessMode.ReadWriteOnce => { /* expected */ }
        _ => assert(false, "Should be ReadWriteOnce"),
    }
}

@test
fn test_access_mode_write_one_to_clear() {
    let mode = AccessMode.WriteOneToClear;
    match mode {
        AccessMode.WriteOneToClear => { /* expected */ }
        _ => assert(false, "Should be WriteOneToClear"),
    }
}

@test
fn test_access_mode_write_one_to_set() {
    let mode = AccessMode.WriteOneToSet;
    match mode {
        AccessMode.WriteOneToSet => { /* expected */ }
        _ => assert(false, "Should be WriteOneToSet"),
    }
}

