mount core.sys.darwin.thread.{
    ThreadError,
    Thread,
    ThreadFn,
    Mutex,
    Condvar,
    SpinLock,
    Once,

    spawn,
    current_thread,
    current_tid,

    ONCE_INIT,
    ONCE_RUNNING,
    ONCE_COMPLETE,
};

// Timespec import removed - condvar.wait_timeout takes Int ms directly

