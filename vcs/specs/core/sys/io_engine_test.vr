@test
fn test_io_interest() {
    // Create each variant
    let read = IOInterest.Read;
    let write = IOInterest.Write;
    let rw = IOInterest.ReadWrite;

    // Pattern matching
    match read {
        IOInterest.Read => { }
        _ => assert(false),
    }

    match write {
        IOInterest.Write => { }
        _ => assert(false),
    }

    match rw {
        IOInterest.ReadWrite => { }
        _ => assert(false),
    }

    print("IOInterest tests passed");
}

// =============================================================================
// Constant Verification Tests
// =============================================================================

@test
fn test_constants() {
    // MAX_PRACTICAL_DURATION should be about 1 year
    let one_year_ns: UInt64 = 365_u64 * 24 * 60 * 60 * 1_000_000_000;
    assert(MAX_PRACTICAL_DURATION == one_year_ns);

    // Standard file descriptors should be 0, 1, 2
    assert(STDIN_FD.as_raw() == 0_i32);
    assert(STDOUT_FD.as_raw() == 1_i32);
    assert(STDERR_FD.as_raw() == 2_i32);

    print("Constants verification passed");
}
