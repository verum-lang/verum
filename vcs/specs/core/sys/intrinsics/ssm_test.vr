// =============================================================================
// Mathematical Constants
// =============================================================================

const PI: Float = 3.14159265358979323846;

fn sin(x: Float) -> Float {
    @vbc(SIN_F64, x)
}

fn sqrt(x: Float) -> Float {
    @vbc(SQRT_F64, x)
}

fn eye(n: USize) -> DynTensor<Float> {
    // Identity matrix of size n x n
    let result = zeros(&[n, n]);
    for i in 0..n {
        result.set(&[i, i], 1.0);
    }
    result
}
