// @test: run
// @tier: 0
// @level: L0
// @tags: stdlib, intrinsics, float, debug
// @description: Test trig with for loop

module test.stdlib.sys.intrinsics.trig_loop_test;

mount core.intrinsics.{
    sin_f64, cos_f64, abs_f64,
};

const PI: Float64 = 3.14159265358979323846;
const EPSILON_F64: Float64 = 1e-10;

fn approx_eq_f64(a: Float64, b: Float64, epsilon: Float64) -> Bool {
    let diff = abs_f64(a - b);
    diff < epsilon
}

fn main() {
    print("Testing Pythagorean identity with for loop...");

    // Pythagorean identity: sin²(x) + cos²(x) = 1
    let angles: List<Float64> = [0.0, 0.5, 1.0, 1.5, 2.0, PI / 4.0, PI / 3.0, PI / 6.0];
    for angle in angles {
        print(f"Testing angle = {angle}");
        let s = sin_f64(angle);
        let c = cos_f64(angle);
        let sum_sq = s * s + c * c;
        print(f"  sin^2 + cos^2 = {sum_sq}");
        assert(approx_eq_f64(sum_sq, 1.0, EPSILON_F64));
    }

    print("All tests passed!");
}
