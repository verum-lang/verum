// =============================================================================
// vcs/specs/stdlib/sys/intrinsics/float_math_test.vr
// =============================================================================
// @test: run
// @tier: 0
// @level: L0
// @tags: stdlib, sys, intrinsics, math, float, trigonometry, transcendental
// @description: Comprehensive tests for floating-point math intrinsics covering
//               trigonometric, exponential, logarithmic, and special functions.
//
// Coverage:
// - Basic math: sqrt, abs, floor, ceil, round, trunc
// - Trigonometric: sin, cos, tan, asin, acos, atan, atan2
// - Hyperbolic: sinh, cosh, tanh, asinh, acosh, atanh
// - Exponential: exp, exp2, expm1, pow, powi
// - Logarithmic: log, log2, log10, log1p
// - Special: hypot, fma, copysign, cbrt
// - Min/Max: minnum, maxnum
// - Both Float32 and Float64 variants
//
// Test Strategy:
// - Known values (0, 1, π, e)
// - Boundary values (infinity, NaN)
// - Identities (sin²+cos²=1, exp(ln(x))=x)
// - Precision tests (error tolerance)
// =============================================================================

module test.stdlib.sys.intrinsics.float_math_test;

// NOTE: Generic intrinsics (sqrt, sin, etc.) are skipped due to incomplete
// VBC monomorphization. Only type-specific variants are imported.
mount core.intrinsics.{
    // Float64 basic
    sqrt_f64, abs_f64, floor_f64, ceil_f64, round_f64, trunc_f64,
    // Float64 trigonometric
    sin_f64, cos_f64, tan_f64, asin_f64, acos_f64, atan_f64, atan2_f64,
    // Float64 hyperbolic
    sinh_f64, cosh_f64, tanh_f64, asinh_f64, acosh_f64, atanh_f64,
    // Float64 exponential/log
    exp_f64, exp2_f64, expm1_f64, log_f64, log2_f64, log10_f64, log1p_f64,
    pow_f64, powi_f64, cbrt_f64,
    // Float64 special
    hypot_f64, fma_f64, copysign_f64, minnum_f64, maxnum_f64,
    // Float64 bit operations
    f64_to_bits, f64_from_bits, f64_infinity, f64_neg_infinity, f64_nan,

    // Float32 basic
    sqrt_f32, abs_f32, floor_f32, ceil_f32, round_f32, trunc_f32,
    // Float32 trigonometric
    sin_f32, cos_f32, tan_f32, asin_f32, acos_f32, atan_f32, atan2_f32,
    // Float32 hyperbolic
    sinh_f32, cosh_f32, tanh_f32, asinh_f32, acosh_f32, atanh_f32,
    // Float32 exponential/log
    exp_f32, exp2_f32, expm1_f32, log_f32, log2_f32, log10_f32, log1p_f32,
    pow_f32, powi_f32, cbrt_f32,
    // Float32 special
    hypot_f32, fma_f32, copysign_f32, minnum_f32, maxnum_f32,
    // Float32 bit operations
    f32_to_bits, f32_from_bits, f32_infinity, f32_neg_infinity, f32_nan,
};

// Mathematical constants (all Float64 to match intrinsic types)
const PI: Float64 = 3.14159265358979323846;
const E: Float64 = 2.71828182845904523536;
const SQRT2: Float64 = 1.41421356237309504880;
const LN2: Float64 = 0.69314718055994530942;
const LN10: Float64 = 2.30258509299404568402;

// Float64 numeric constants for arithmetic operations
const F64_0: Float64 = 0.0;
const F64_1: Float64 = 1.0;
const F64_2: Float64 = 2.0;
const F64_3: Float64 = 3.0;
const F64_4: Float64 = 4.0;
const F64_5: Float64 = 5.0;
const F64_6: Float64 = 6.0;
const F64_10: Float64 = 10.0;
const F64_NEG1: Float64 = -1.0;
const F64_HALF: Float64 = 0.5;

// Tolerances for floating-point comparison
const EPSILON_F64: Float64 = 1e-10;
const EPSILON_F32: Float32 = 1e-5;

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// Helper Functions
// =============================================================================

fn approx_eq_f64(a: Float64, b: Float64, epsilon: Float64) -> Bool {
    let diff = abs_f64(a - b);
    diff < epsilon
}

fn approx_eq_f32(a: Float32, b: Float32, epsilon: Float32) -> Bool {
    let diff = abs_f32(a - b);
    diff < epsilon
}

fn is_nan_f64(x: Float64) -> Bool {
    x != x
}

fn is_nan_f32(x: Float32) -> Bool {
    x != x
}

// =============================================================================
// Basic Math Tests
// =============================================================================

@test
fn test_basic_math() {
    // sqrt
    assert(approx_eq_f64(sqrt_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(sqrt_f64(1.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(sqrt_f64(4.0), 2.0, EPSILON_F64));
    assert(approx_eq_f64(sqrt_f64(2.0), SQRT2, EPSILON_F64));
    assert(approx_eq_f64(sqrt_f64(100.0), 10.0, EPSILON_F64));

    // abs
    assert(abs_f64(5.0) == 5.0);
    assert(abs_f64(-5.0) == 5.0);
    assert(abs_f64(0.0) == 0.0);
    assert(abs_f64(-0.0) == 0.0);

    // floor
    assert(floor_f64(3.7) == 3.0);
    assert(floor_f64(3.0) == 3.0);
    assert(floor_f64(-3.7) == -4.0);
    assert(floor_f64(-3.0) == -3.0);

    // ceil
    assert(ceil_f64(3.2) == 4.0);
    assert(ceil_f64(3.0) == 3.0);
    assert(ceil_f64(-3.2) == -3.0);
    assert(ceil_f64(-3.0) == -3.0);

    // round
    assert(round_f64(3.4) == 3.0);
    assert(round_f64(3.5) == 4.0);  // Round half to even or up
    assert(round_f64(3.6) == 4.0);
    assert(round_f64(-3.4) == -3.0);
    assert(round_f64(-3.5) == -4.0);

    // trunc
    assert(trunc_f64(3.7) == 3.0);
    assert(trunc_f64(-3.7) == -3.0);
    assert(trunc_f64(3.0) == 3.0);
}

// =============================================================================
// Trigonometry Tests
// =============================================================================

@test
fn test_trigonometry() {
    // sin
    assert(approx_eq_f64(sin_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(sin_f64(PI / 2.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(sin_f64(PI), 0.0, EPSILON_F64));
    assert(approx_eq_f64(sin_f64(3.0 * PI / 2.0), -1.0, EPSILON_F64));

    // cos
    assert(approx_eq_f64(cos_f64(0.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(cos_f64(PI / 2.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(cos_f64(PI), -1.0, EPSILON_F64));
    assert(approx_eq_f64(cos_f64(2.0 * PI), 1.0, EPSILON_F64));

    // tan
    assert(approx_eq_f64(tan_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(tan_f64(PI / 4.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(tan_f64(-PI / 4.0), -1.0, EPSILON_F64));

    // Pythagorean identity: sin²(x) + cos²(x) = 1
    let angles: List<Float64> = [0.0, 0.5, 1.0, 1.5, 2.0, PI / 4.0, PI / 3.0, PI / 6.0];
    for angle in angles {
        let s = sin_f64(angle);
        let c = cos_f64(angle);
        assert(approx_eq_f64(s * s + c * c, 1.0, EPSILON_F64));
    }
}

// =============================================================================
// Inverse Trigonometry Tests
// =============================================================================

@test
fn test_inverse_trigonometry() {
    // asin
    assert(approx_eq_f64(asin_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(asin_f64(1.0), PI / 2.0, EPSILON_F64));
    assert(approx_eq_f64(asin_f64(-1.0), -PI / 2.0, EPSILON_F64));
    assert(approx_eq_f64(asin_f64(0.5), PI / 6.0, EPSILON_F64));

    // acos
    assert(approx_eq_f64(acos_f64(1.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(acos_f64(0.0), PI / 2.0, EPSILON_F64));
    assert(approx_eq_f64(acos_f64(-1.0), PI, EPSILON_F64));
    assert(approx_eq_f64(acos_f64(0.5), PI / 3.0, EPSILON_F64));

    // atan
    assert(approx_eq_f64(atan_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(atan_f64(1.0), PI / 4.0, EPSILON_F64));
    assert(approx_eq_f64(atan_f64(-1.0), -PI / 4.0, EPSILON_F64));

    // atan2
    assert(approx_eq_f64(atan2_f64(0.0, 1.0), 0.0, EPSILON_F64));  // East
    assert(approx_eq_f64(atan2_f64(1.0, 0.0), PI / 2.0, EPSILON_F64));  // North
    assert(approx_eq_f64(atan2_f64(0.0, -1.0), PI, EPSILON_F64));  // West
    assert(approx_eq_f64(atan2_f64(-1.0, 0.0), -PI / 2.0, EPSILON_F64));  // South
    assert(approx_eq_f64(atan2_f64(1.0, 1.0), PI / 4.0, EPSILON_F64));  // Northeast

    // Inverse identities: asin(sin(x)) = x for x in [-π/2, π/2]
    assert(approx_eq_f64(asin_f64(sin_f64(0.5)), 0.5, EPSILON_F64));
    assert(approx_eq_f64(atan_f64(tan_f64(0.5)), 0.5, EPSILON_F64));
}

// =============================================================================
// Hyperbolic Function Tests
// =============================================================================

@test
fn test_hyperbolic() {
    // sinh
    assert(approx_eq_f64(sinh_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(sinh_f64(1.0), (E - 1.0/E) / 2.0, 1e-8));

    // cosh
    assert(approx_eq_f64(cosh_f64(0.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(cosh_f64(1.0), (E + 1.0/E) / 2.0, 1e-8));

    // tanh
    assert(approx_eq_f64(tanh_f64(0.0), 0.0, EPSILON_F64));
    // tanh(x) = sinh(x) / cosh(x)
    let x: Float64 = 1.5;
    assert(approx_eq_f64(tanh_f64(x), sinh_f64(x) / cosh_f64(x), EPSILON_F64));

    // Hyperbolic identity: cosh²(x) - sinh²(x) = 1
    let values: List<Float64> = [0.0, 0.5, 1.0, 2.0];
    for x in values {
        let s = sinh_f64(x);
        let c = cosh_f64(x);
        assert(approx_eq_f64(c * c - s * s, 1.0, EPSILON_F64));
    }

    // Inverse hyperbolic functions
    assert(approx_eq_f64(asinh_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(acosh_f64(1.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(atanh_f64(0.0), 0.0, EPSILON_F64));

    // asinh(sinh(x)) = x
    assert(approx_eq_f64(asinh_f64(sinh_f64(1.5)), 1.5, EPSILON_F64));
}

// =============================================================================
// Exponential Function Tests
// =============================================================================

@test
fn test_exponential() {
    // exp
    assert(approx_eq_f64(exp_f64(0.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(exp_f64(1.0), E, EPSILON_F64));
    assert(approx_eq_f64(exp_f64(2.0), E * E, 1e-8));
    assert(approx_eq_f64(exp_f64(-1.0), 1.0 / E, EPSILON_F64));

    // exp2
    assert(approx_eq_f64(exp2_f64(0.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(exp2_f64(1.0), 2.0, EPSILON_F64));
    assert(approx_eq_f64(exp2_f64(3.0), 8.0, EPSILON_F64));
    assert(approx_eq_f64(exp2_f64(-1.0), 0.5, EPSILON_F64));
    assert(approx_eq_f64(exp2_f64(10.0), 1024.0, EPSILON_F64));

    // expm1 (exp(x) - 1, more precise for small x)
    assert(approx_eq_f64(expm1_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(expm1_f64(1.0), E - 1.0, EPSILON_F64));
    // For small x, expm1 is more precise than exp(x)-1
    let small: Float64 = 1e-10;
    let expm1_result = expm1_f64(small);
    assert(approx_eq_f64(expm1_result, small, 1e-15));  // Linear approximation for tiny x
}

// =============================================================================
// Logarithmic Function Tests
// =============================================================================

@test
fn test_logarithmic() {
    // log (natural logarithm)
    assert(approx_eq_f64(log_f64(1.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(log_f64(E), 1.0, EPSILON_F64));
    assert(approx_eq_f64(log_f64(E * E), 2.0, EPSILON_F64));

    // log2
    assert(approx_eq_f64(log2_f64(1.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(log2_f64(2.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(log2_f64(8.0), 3.0, EPSILON_F64));
    assert(approx_eq_f64(log2_f64(1024.0), 10.0, EPSILON_F64));

    // log10
    assert(approx_eq_f64(log10_f64(1.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(log10_f64(10.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(log10_f64(100.0), 2.0, EPSILON_F64));
    assert(approx_eq_f64(log10_f64(1000.0), 3.0, EPSILON_F64));

    // log1p (ln(1 + x), more precise for small x)
    assert(approx_eq_f64(log1p_f64(0.0), 0.0, EPSILON_F64));
    assert(approx_eq_f64(log1p_f64(E - 1.0), 1.0, EPSILON_F64));
    // For small x, log1p(x) ≈ x
    let small: Float64 = 1e-10;
    assert(approx_eq_f64(log1p_f64(small), small, 1e-15));

    // Identity: log(exp(x)) = x
    assert(approx_eq_f64(log_f64(exp_f64(2.5)), 2.5, EPSILON_F64));
    assert(approx_eq_f64(exp_f64(log_f64(3.7)), 3.7, EPSILON_F64));
}

// =============================================================================
// Power Function Tests
// =============================================================================

@test
fn test_power_functions() {
    // pow
    assert(approx_eq_f64(pow_f64(2.0, 3.0), 8.0, EPSILON_F64));
    assert(approx_eq_f64(pow_f64(2.0, 0.0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(pow_f64(2.0, -1.0), 0.5, EPSILON_F64));
    assert(approx_eq_f64(pow_f64(4.0, 0.5), 2.0, EPSILON_F64));  // sqrt
    let one_third: Float64 = F64_1 / F64_3;
    assert(approx_eq_f64(pow_f64(8.0, one_third), 2.0, EPSILON_F64));  // cbrt
    assert(approx_eq_f64(pow_f64(10.0, 2.0), 100.0, EPSILON_F64));

    // powi (integer exponent, faster)
    assert(approx_eq_f64(powi_f64(2.0, 10), 1024.0, EPSILON_F64));
    assert(approx_eq_f64(powi_f64(2.0, 0), 1.0, EPSILON_F64));
    assert(approx_eq_f64(powi_f64(2.0, -1), 0.5, EPSILON_F64));
    assert(approx_eq_f64(powi_f64(10.0, 3), 1000.0, EPSILON_F64));

    // cbrt (cube root)
    assert(approx_eq_f64(cbrt_f64(8.0), 2.0, EPSILON_F64));
    assert(approx_eq_f64(cbrt_f64(27.0), 3.0, EPSILON_F64));
    assert(approx_eq_f64(cbrt_f64(-8.0), -2.0, EPSILON_F64));  // Works for negative numbers
    assert(approx_eq_f64(cbrt_f64(0.0), 0.0, EPSILON_F64));
}

// =============================================================================
// Special Function Tests
// =============================================================================

@test
fn test_special_functions() {
    // hypot (sqrt(x² + y²) without overflow)
    assert(approx_eq_f64(hypot_f64(3.0, 4.0), 5.0, EPSILON_F64));  // 3-4-5 triangle
    assert(approx_eq_f64(hypot_f64(5.0, 12.0), 13.0, EPSILON_F64));  // 5-12-13 triangle
    assert(approx_eq_f64(hypot_f64(1.0, 1.0), SQRT2, EPSILON_F64));
    assert(approx_eq_f64(hypot_f64(0.0, 5.0), 5.0, EPSILON_F64));

    // fma (fused multiply-add: a*b + c with single rounding)
    assert(approx_eq_f64(fma_f64(2.0, 3.0, 4.0), 10.0, EPSILON_F64));  // 2*3+4
    assert(approx_eq_f64(fma_f64(-1.0, 2.0, 5.0), 3.0, EPSILON_F64));  // -1*2+5
    // FMA should be more precise than a*b+c for some edge cases

    // copysign
    assert(copysign_f64(1.0, 1.0) == 1.0);
    assert(copysign_f64(1.0, -1.0) == -1.0);
    assert(copysign_f64(-1.0, 1.0) == 1.0);
    assert(copysign_f64(-1.0, -1.0) == -1.0);
    assert(copysign_f64(5.5, -0.0) == -5.5);  // -0 has negative sign
}

// =============================================================================
// Min/Max Tests
// =============================================================================

@test
fn test_minmax() {
    // minnum
    assert(minnum_f64(1.0, 2.0) == 1.0);
    assert(minnum_f64(2.0, 1.0) == 1.0);
    assert(minnum_f64(-1.0, 1.0) == -1.0);
    assert(minnum_f64(0.0, -0.0) == -0.0 || minnum_f64(0.0, -0.0) == 0.0);  // Either is valid

    // maxnum
    assert(maxnum_f64(1.0, 2.0) == 2.0);
    assert(maxnum_f64(2.0, 1.0) == 2.0);
    assert(maxnum_f64(-1.0, 1.0) == 1.0);

    // NaN propagation (minnum/maxnum return the non-NaN value)
    let nan = f64_nan();
    // If one argument is NaN, return the other
    // (This is the IEEE 754-2008 semantics for minNum/maxNum)
    assert(minnum_f64(1.0, nan) == 1.0 || is_nan_f64(minnum_f64(1.0, nan)));
    assert(maxnum_f64(1.0, nan) == 1.0 || is_nan_f64(maxnum_f64(1.0, nan)));
}

// =============================================================================
// Float32 Variant Tests
// =============================================================================

@test
fn test_float32_variants() {
    let pi_f32: Float32 = 3.14159265;

    // Basic math
    assert(approx_eq_f32(sqrt_f32(4.0), 2.0, EPSILON_F32));
    assert(abs_f32(-5.0) == 5.0);
    assert(floor_f32(3.7) == 3.0);
    assert(ceil_f32(3.2) == 4.0);
    assert(round_f32(3.5) == 4.0);
    assert(trunc_f32(-3.7) == -3.0);

    // Trigonometry
    assert(approx_eq_f32(sin_f32(0.0), 0.0, EPSILON_F32));
    assert(approx_eq_f32(cos_f32(0.0), 1.0, EPSILON_F32));
    assert(approx_eq_f32(sin_f32(pi_f32 / 2.0), 1.0, EPSILON_F32));

    // Inverse trig
    assert(approx_eq_f32(asin_f32(0.0), 0.0, EPSILON_F32));
    assert(approx_eq_f32(acos_f32(1.0), 0.0, EPSILON_F32));
    assert(approx_eq_f32(atan_f32(0.0), 0.0, EPSILON_F32));
    assert(approx_eq_f32(atan2_f32(1.0, 1.0), pi_f32 / 4.0, EPSILON_F32));

    // Hyperbolic
    assert(approx_eq_f32(sinh_f32(0.0), 0.0, EPSILON_F32));
    assert(approx_eq_f32(cosh_f32(0.0), 1.0, EPSILON_F32));
    assert(approx_eq_f32(tanh_f32(0.0), 0.0, EPSILON_F32));

    // Exponential/log
    assert(approx_eq_f32(exp_f32(0.0), 1.0, EPSILON_F32));
    assert(approx_eq_f32(log_f32(1.0), 0.0, EPSILON_F32));
    assert(approx_eq_f32(log2_f32(8.0), 3.0, EPSILON_F32));
    assert(approx_eq_f32(log10_f32(100.0), 2.0, EPSILON_F32));

    // Power
    assert(approx_eq_f32(pow_f32(2.0, 3.0), 8.0, EPSILON_F32));
    assert(approx_eq_f32(cbrt_f32(27.0), 3.0, EPSILON_F32));

    // Special
    assert(approx_eq_f32(hypot_f32(3.0, 4.0), 5.0, EPSILON_F32));
    assert(approx_eq_f32(fma_f32(2.0, 3.0, 4.0), 10.0, EPSILON_F32));
    assert(copysign_f32(1.0, -1.0) == -1.0);

    // Min/max
    assert(minnum_f32(1.0, 2.0) == 1.0);
    assert(maxnum_f32(1.0, 2.0) == 2.0);
}

// =============================================================================
// Special Values Tests
// =============================================================================

@test
fn test_special_values() {
    // Infinity
    let inf = f64_infinity();
    let neg_inf = f64_neg_infinity();

    assert(inf > 0.0);
    assert(neg_inf < 0.0);
    assert(inf == inf);
    assert(neg_inf == neg_inf);
    assert(inf != neg_inf);

    // Operations with infinity
    assert(exp_f64(inf) == inf);
    assert(exp_f64(neg_inf) == 0.0);
    assert(log_f64(inf) == inf);

    // NaN
    let nan = f64_nan();
    assert(is_nan_f64(nan));
    assert(nan != nan);  // NaN != NaN by IEEE definition

    // NaN propagation
    assert(is_nan_f64(nan + 1.0));
    assert(is_nan_f64(nan * 2.0));
    assert(is_nan_f64(sqrt_f64(-1.0)));  // sqrt of negative is NaN
    assert(is_nan_f64(log_f64(-1.0)));   // log of negative is NaN
    assert(is_nan_f64(asin_f64(2.0)));   // asin outside [-1,1] is NaN

    // Float32 special values
    let inf_f32 = f32_infinity();
    let nan_f32 = f32_nan();

    assert(inf_f32 > 0.0);
    assert(is_nan_f32(nan_f32));

    // Bit representation
    assert(f64_to_bits(0.0) == 0);
    assert(f64_to_bits(-0.0) == 0x8000000000000000);
    assert(f64_from_bits(0) == 0.0);

    assert(f32_to_bits(0.0) == 0);
    assert(f32_from_bits(0) == 0.0);
}

// =============================================================================
// Mathematical Identity Tests
// =============================================================================

@test
fn test_identities() {
    // Pythagorean identity: sin²(x) + cos²(x) = 1
    let x: Float64 = 1.234;
    let s = sin_f64(x);
    let c = cos_f64(x);
    assert(approx_eq_f64(s * s + c * c, 1.0, EPSILON_F64));

    // Exponential identity: exp(a + b) = exp(a) * exp(b)
    let a: Float64 = 1.5;
    let b: Float64 = 2.3;
    assert(approx_eq_f64(exp_f64(a + b), exp_f64(a) * exp_f64(b), 1e-8));

    // Logarithm identity: log(a * b) = log(a) + log(b)
    let p: Float64 = 2.0;
    let q: Float64 = 3.0;
    assert(approx_eq_f64(log_f64(p * q), log_f64(p) + log_f64(q), EPSILON_F64));

    // Power identity: (a^b)^c = a^(b*c)
    assert(approx_eq_f64(pow_f64(pow_f64(2.0, 3.0), 2.0), pow_f64(2.0, 6.0), EPSILON_F64));

    // Inverse identity: asin(sin(x)) = x for x in [-π/2, π/2]
    let y: Float64 = 0.7;
    assert(approx_eq_f64(asin_f64(sin_f64(y)), y, EPSILON_F64));

    // exp(ln(x)) = x
    let z: Float64 = 5.5;
    assert(approx_eq_f64(exp_f64(log_f64(z)), z, EPSILON_F64));

    // Hyperbolic identity: cosh²(x) - sinh²(x) = 1
    let w: Float64 = 2.1;
    let sh = sinh_f64(w);
    let ch = cosh_f64(w);
    assert(approx_eq_f64(ch * ch - sh * sh, 1.0, EPSILON_F64));

    // Change of base: log_b(x) = log(x) / log(b)
    assert(approx_eq_f64(log2_f64(8.0), log_f64(8.0) / log_f64(2.0), EPSILON_F64));
    assert(approx_eq_f64(log10_f64(100.0), log_f64(100.0) / log_f64(10.0), EPSILON_F64));
}

