// =============================================================================
// vcs/specs/stdlib/sys/intrinsics/sync_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L0
// @tags: stdlib, sys, intrinsics, sync, spinlock, futex, fence
// @description: Comprehensive tests for synchronization primitives that enable
//               efficient concurrent programming.
//
// Coverage:
// - spin_hint, spin_loop_hint: CPU hints for spin loops
// - memory_fence, atomic_fence, compiler_fence: Memory barriers
// - futex_wait, futex_wake, futex_wake_one, futex_wake_all: OS-level blocking
// - spinlock_try_lock, spinlock_lock, spinlock_unlock, spinlock_is_locked
//
// Test Strategy:
// - Single-threaded correctness
// - Lock/unlock sequences
// - Fence operations don't crash
// - Futex basic operations (single-threaded)
//
// Note: Full concurrency testing requires multi-threading which is
// tested separately in async/sync tests. These tests verify the
// intrinsics work correctly in isolation.
// =============================================================================

module test.stdlib.sys.intrinsics.sync_test;

mount core.intrinsics.{
    // Spin hints
    spin_hint, spin_loop_hint,
    // Memory fences
    memory_fence, compiler_fence,
    MemoryOrder,
    ORDERING_RELAXED, ORDERING_ACQUIRE, ORDERING_RELEASE,
    ORDERING_ACQ_REL, ORDERING_SEQ_CST,
    // Futex operations
    futex_wait, futex_wake, futex_wake_one, futex_wake_all,
    // Spinlock operations
    spinlock_try_lock, spinlock_lock, spinlock_unlock, spinlock_is_locked,
    // Atomic for verification
    atomic_load_u32, atomic_store_u32,
    // Time for timeout tests
    monotonic_nanos,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// Spin Hint Tests
// =============================================================================

@test
fn test_spin_hints() {
    // spin_hint should not crash and should return quickly
    // It's a CPU hint, so we can't verify behavior directly

    let start = monotonic_nanos();

    for i in 0..1000 {
        spin_hint();
    }

    let elapsed = monotonic_nanos() - start;

    // 1000 spin hints should complete in < 1ms
    // (each hint is typically < 100 cycles)
    assert(elapsed < 1_000_000);  // < 1ms

    print(f"1000 spin_hint() calls took {elapsed}ns");

    // spin_loop_hint is an alias
    for i in 0..100 {
        spin_loop_hint();
    }
}

// =============================================================================
// Memory Fence Tests
// =============================================================================

@test
fn test_memory_fences() {
    // Memory fences should not crash
    // We can't directly observe their effect in single-threaded code

    // Test all orderings (ORDERING constants are UInt8, memory_fence expects Int)
    memory_fence(ORDERING_RELAXED as Int);
    memory_fence(ORDERING_ACQUIRE as Int);
    memory_fence(ORDERING_RELEASE as Int);
    memory_fence(ORDERING_ACQ_REL as Int);
    memory_fence(ORDERING_SEQ_CST as Int);

    // atomic_fence uses MemoryOrder sum type (from core/intrinsics/atomic.vr)
    // Test it via memory_fence which accepts Int ordering
    memory_fence(ORDERING_SEQ_CST as Int);
    memory_fence(ORDERING_ACQ_REL as Int);

    // Compiler fence (compile-time only, no runtime cost)
    // compiler_fence from atomic.vr takes MemoryOrder enum
    compiler_fence(SeqCst);
    compiler_fence(Acquire);
    compiler_fence(Release);

    // Verify fences don't corrupt state
    let mut value: UInt32 = 42;
    atomic_store_u32(&mut value as *mut UInt32, 100, ORDERING_RELAXED);
    memory_fence(ORDERING_SEQ_CST as Int);
    let loaded = atomic_load_u32(&value as *const UInt32, ORDERING_RELAXED);
    assert(loaded == 100);

    print("Memory fence tests passed");
}

// =============================================================================
// Spinlock Operation Tests
// =============================================================================

@test
fn test_spinlock_operations() {
    // Initialize lock to unlocked state (0)
    let mut lock: UInt32 = 0;

    // Get pointers upfront to avoid borrow conflicts
    // Use raw pointer operations throughout
    let lock_ptr: *mut UInt32 = &mut lock as *mut UInt32;
    let lock_ptr_const: *const UInt32 = lock_ptr as *const UInt32;

    // Initially unlocked
    assert(!spinlock_is_locked(lock_ptr_const));

    // Try lock should succeed on unlocked
    let acquired = spinlock_try_lock(lock_ptr);
    assert(acquired);
    assert(spinlock_is_locked(lock_ptr_const));

    // Try lock again should fail (already held)
    let acquired2 = spinlock_try_lock(lock_ptr);
    assert(!acquired2);
    assert(spinlock_is_locked(lock_ptr_const));

    // Unlock
    spinlock_unlock(lock_ptr);
    assert(!spinlock_is_locked(lock_ptr_const));

    // Try lock should succeed again
    let acquired3 = spinlock_try_lock(lock_ptr);
    assert(acquired3);
    spinlock_unlock(lock_ptr);

    // Test spinlock_lock (blocking version)
    // In single-threaded context, this should always succeed immediately
    spinlock_lock(lock_ptr);
    assert(spinlock_is_locked(lock_ptr_const));
    spinlock_unlock(lock_ptr);
    assert(!spinlock_is_locked(lock_ptr_const));

    // Multiple lock/unlock cycles
    for i in 0..100 {
        spinlock_lock(lock_ptr);
        assert(spinlock_is_locked(lock_ptr_const));
        spinlock_unlock(lock_ptr);
    }
    assert(!spinlock_is_locked(lock_ptr_const));

    print("Spinlock tests passed");
}

// =============================================================================
// Futex Basic Tests
// =============================================================================

@test
fn test_futex_basic() {
    // Futex wait with wrong expected value should return immediately
    let mut value: UInt32 = 42;

    // Wait with wrong expected value - should return immediately
    let result = futex_wait(&value as *const UInt32, 0, 0);
    // Result should indicate we didn't wait (value != expected)
    // The exact return value may vary by platform

    // Wake with no waiters should return 0
    let woken = futex_wake(&value as *const UInt32, 1);
    assert(woken == 0);  // No threads were waiting

    // Wake one with no waiters
    let woken_one = futex_wake_one(&value as *const UInt32);
    assert(woken_one == 0);

    // Wake all with no waiters
    let woken_all = futex_wake_all(&value as *const UInt32);
    assert(woken_all == 0);

    print("Futex basic tests passed");
}

// =============================================================================
// Futex Timeout Tests
// =============================================================================

@test
fn test_futex_timeout() {
    let value: UInt32 = 42;

    // Wait with correct expected value and short timeout
    let start = monotonic_nanos();

    // Wait for 10ms timeout (10_000_000 ns)
    let timeout_ns: UInt64 = 10_000_000;
    let result = futex_wait(&value as *const UInt32, 42, timeout_ns);

    let elapsed = monotonic_nanos() - start;

    // Should have waited approximately timeout duration
    // Result should indicate timeout (-1)
    assert(result == -1);  // Timeout

    // Elapsed time should be at least close to timeout
    // Allow some tolerance (at least 8ms)
    assert(elapsed >= 8_000_000);

    // Elapsed time shouldn't be too much longer (< 100ms)
    assert(elapsed < 100_000_000);

    print(f"Futex wait with 10ms timeout took {elapsed / 1_000_000}ms");
}

// =============================================================================
// Synchronization Pattern Tests
// =============================================================================

@test
fn test_synchronization_patterns() {
    // Test a simple mutex-like pattern using spinlock

    let mut lock: UInt32 = 0;
    let mut protected_data: Int = 0;

    // Simulate critical section access
    fn critical_section(lock: *mut UInt32, data: *mut Int) {
        spinlock_lock(lock);

        // Inside critical section
        unsafe {
            *data = *data + 1;
        }

        spinlock_unlock(lock);
    }

    // Run critical section multiple times
    for i in 0..100 {
        critical_section(&mut lock as *mut UInt32, &mut protected_data as *mut Int);
    }

    assert(protected_data == 100);

    // Test fence-protected publish pattern
    let mut ready: UInt32 = 0;
    let mut data: Int = 0;

    // Publisher side
    data = 42;  // Store data first
    memory_fence(ORDERING_RELEASE as Int);  // Ensure data is visible
    atomic_store_u32(&mut ready as *mut UInt32, 1, ORDERING_RELEASE);

    // Consumer side (in same thread, just verifying pattern)
    if atomic_load_u32(&ready as *const UInt32, ORDERING_ACQUIRE) == 1 {
        memory_fence(ORDERING_ACQUIRE as Int);  // Ensure we see data
        assert(data == 42);
    }

    print("Synchronization pattern tests passed");
}

// =============================================================================
// Spinlock Performance Test
// =============================================================================

@test
fn test_spinlock_performance() {
    let mut lock: UInt32 = 0;
    let iterations = 10000;

    let start = monotonic_nanos();

    for i in 0..iterations {
        spinlock_lock(&mut lock as *mut UInt32);
        spinlock_unlock(&mut lock as *mut UInt32);
    }

    let elapsed = monotonic_nanos() - start;
    let ns_per_cycle = elapsed / iterations as UInt64;

    print(f"{iterations} lock/unlock cycles took {elapsed}ns ({ns_per_cycle}ns/cycle)");

    // Should be < 1μs per lock/unlock cycle in single-threaded context
    assert(ns_per_cycle < 1000);
}

// =============================================================================
// Edge Cases
// =============================================================================

@test
fn test_sync_edge_cases() {
    // Double unlock (implementation-defined behavior)
    // Most implementations will just set to 0, which is harmless
    let mut lock: UInt32 = 0;
    spinlock_lock(&mut lock as *mut UInt32);
    spinlock_unlock(&mut lock as *mut UInt32);
    spinlock_unlock(&mut lock as *mut UInt32);  // Double unlock - should be safe
    assert(!spinlock_is_locked(&lock as *const UInt32));

    // Fence with different orderings in sequence
    memory_fence(ORDERING_ACQUIRE as Int);
    memory_fence(ORDERING_RELEASE as Int);
    memory_fence(ORDERING_SEQ_CST as Int);

    // Zero timeout futex wait (poll mode)
    let value: UInt32 = 0;
    let result = futex_wait(&value as *const UInt32, 0, 0);
    // With 0 timeout, should return immediately

    print("Edge case tests passed");
}
