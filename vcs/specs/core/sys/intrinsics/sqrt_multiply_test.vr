// @test: run
// @tier: 0
// @level: L0
// @tags: stdlib, intrinsics, float, debug
// @description: Test sqrt multiply

module test.stdlib.sys.intrinsics.sqrt_multiply_test;

mount core.intrinsics.{sqrt_f64};

fn main() {
    print("Testing sqrt_f64...");
    let s = sqrt_f64(4.0);
    let s_sq = s * s;
    print(f"sqrt^2 = {s_sq}");

    print("All tests passed!");
}
