// =============================================================================
// vcs/specs/core/meta/contexts_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: core, meta, contexts, capabilities, compile-time, build-assets, type-info
// @note: contexts.vr has some type errors but imported types resolve fine for tests
// @description: Tests for meta-specific contexts (capabilities) including
//               BuildAssets, TypeInfo, AstAccess, CompileDiag, MacroState,
//               StageInfo, Hygiene, and context group aliases.
//
// Coverage:
// - BuildAssets context: load, load_text, exists, list_dir
// - AssetMetadata type: field access
// - TypeInfo context: name_of, kind_of, fields_of, etc.
// - AstAccess context: parse_expr, parse_type
// - CompileDiag context: emit_warning, emit_error
// - MacroState context: caching, dependency tracking
// - StageInfo context: level, context
// - Hygiene context: InvocationId, gensym
// - ToTokens protocol
// - Context group aliases: MetaCore, MetaFull, MetaNoIO, etc.
//
// Test Strategy:
// - Type existence verification
// - Context method signatures
// - Context group composition
// =============================================================================

module specs.core.meta.contexts_test;

mount core.meta.contexts.{
    AssetMetadata,
    ToTokens,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// AssetMetadata Tests
// =============================================================================

@test
fn test_asset_metadata_construction() {
    let meta = AssetMetadata {
        size: 1024 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: true,
        is_symlink: false,
    };
    assert(meta.is_file, "Should be a file");
    assert(!meta.is_directory, "Should not be a directory");
}

@test
fn test_asset_metadata_directory() {
    let meta = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: true,
        is_file: false,
        is_symlink: false,
    };
    assert(meta.is_directory, "Should be a directory");
}

@test
fn test_asset_metadata_symlink() {
    let meta = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: false,
        is_symlink: true,
    };
    assert(meta.is_symlink, "Should be a symlink");
}

@test
fn test_asset_metadata_size() {
    let meta = AssetMetadata {
        size: 4096 as UInt64,
        modified_ns: 1000000000 as UInt64,
        is_directory: false,
        is_file: true,
        is_symlink: false,
    };
    assert_eq(meta.size, 4096 as UInt64);
    assert_eq(meta.modified_ns, 1000000000 as UInt64);
}

// =============================================================================
// AssetMetadata Extended Tests
// =============================================================================

@test
fn test_asset_metadata_zero_size_file() {
    let meta = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: true,
        is_symlink: false,
    };
    assert_eq(meta.size, 0 as UInt64);
    assert(meta.is_file);
}

@test
fn test_asset_metadata_large_file() {
    let meta = AssetMetadata {
        size: 1073741824 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: true,
        is_symlink: false,
    };
    assert_eq(meta.size, 1073741824 as UInt64);
}

@test
fn test_asset_metadata_all_false() {
    let meta = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: false,
        is_symlink: false,
    };
    assert(!meta.is_directory);
    assert(!meta.is_file);
    assert(!meta.is_symlink);
}

@test
fn test_asset_metadata_modified_ns_nonzero() {
    let meta = AssetMetadata {
        size: 256 as UInt64,
        modified_ns: 1707000000000000000 as UInt64,
        is_directory: false,
        is_file: true,
        is_symlink: false,
    };
    assert(meta.modified_ns > 0 as UInt64);
}

@test
fn test_asset_metadata_symlink_with_size() {
    let meta = AssetMetadata {
        size: 42 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: false,
        is_symlink: true,
    };
    assert(meta.is_symlink);
    assert_eq(meta.size, 42 as UInt64);
}

@test
fn test_asset_metadata_directory_with_timestamp() {
    let meta = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 999999999 as UInt64,
        is_directory: true,
        is_file: false,
        is_symlink: false,
    };
    assert(meta.is_directory);
    assert_eq(meta.modified_ns, 999999999 as UInt64);
}

@test
fn test_asset_metadata_file_and_symlink() {
    // A file that is also a symlink (resolved symlink)
    let meta = AssetMetadata {
        size: 100 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: true,
        is_symlink: true,
    };
    assert(meta.is_file);
    assert(meta.is_symlink);
}

@test
fn test_asset_metadata_dir_and_symlink() {
    // A directory symlink
    let meta = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: true,
        is_file: false,
        is_symlink: true,
    };
    assert(meta.is_directory);
    assert(meta.is_symlink);
}

// =============================================================================
// ToTokens Protocol Test
// =============================================================================

@test
fn test_to_tokens_type_exists() {
    // ToTokens is a protocol - verify it's importable
    let _ = ToTokens;
}

@test
fn test_asset_metadata_boolean_fields_independence() {
    // Test each boolean independently
    let file_only = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: true,
        is_symlink: false,
    };
    let dir_only = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: true,
        is_file: false,
        is_symlink: false,
    };
    let sym_only = AssetMetadata {
        size: 0 as UInt64,
        modified_ns: 0 as UInt64,
        is_directory: false,
        is_file: false,
        is_symlink: true,
    };

    assert(file_only.is_file && !file_only.is_directory && !file_only.is_symlink);
    assert(dir_only.is_directory && !dir_only.is_file && !dir_only.is_symlink);
    assert(sym_only.is_symlink && !sym_only.is_file && !sym_only.is_directory);
}
