// =============================================================================
// vcs/specs/stdlib/meta/meta_runtime_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L3
// @tags: stdlib, meta, meta_runtime, context, compiler, introspection
// @note: MetaRuntime and ProjectInfo contexts not yet resolvable in test functions
// @description: Tests for MetaRuntime and ProjectInfo context types.
//
// Current limitations:
// - `using [MetaRuntime]` causes "undefined context: MetaRuntime"
// - `using [ProjectInfo]` causes "undefined context: ProjectInfo"
// - Meta function calls (MetaRuntime.crate_name(), etc.) not implemented (M001)
//
// These tests verify type imports and basic structure.
// Full context-based tests require compiler support for context resolution.
// =============================================================================

module test.stdlib.meta.meta_runtime_test;

mount core.meta.contexts.{MetaRuntime, ProjectInfo};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// Type Import Verification
// =============================================================================

@test
fn test_meta_runtime_type_import() {
    // Verify MetaRuntime type is importable from core.meta.contexts
    // The type exists but the context system doesn't resolve it for `using`
    let _ = MetaRuntime;
    print("MetaRuntime type import test passed");
}

@test
fn test_project_info_type_import() {
    // Verify ProjectInfo type is importable from core.meta.contexts
    let _ = ProjectInfo;
    print("ProjectInfo type import test passed");
}

// =============================================================================
// API Surface Documentation Tests
// =============================================================================

@test
fn test_meta_runtime_api_surface() {
    // MetaRuntime provides:
    // - crate_name() -> Text
    // - module_path() -> Text
    // - crate_version() -> Text
    // - compiler_version() -> Text
    // - compiler_commit() -> Text
    // - max_recursion_depth() -> Int
    // - max_async_tasks() -> Int
    // - config_value(key: Text) -> Maybe<Text>
    // - is_ci() -> Bool
    //
    // These require `using [MetaRuntime]` context which is not yet resolvable.
    // Verified: type import works, function stubs exist in stdlib.
    print("MetaRuntime API surface documentation test passed");
}

@test
fn test_project_info_api_surface() {
    // ProjectInfo provides:
    // - target_os() -> Text
    // - target_arch() -> Text
    // - target_triple() -> Text
    // - target_pointer_width() -> Int
    // - target_endian() -> Text
