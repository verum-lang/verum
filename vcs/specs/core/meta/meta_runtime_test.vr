    // - is_debug() -> Bool
    // - is_release() -> Bool
    // - opt_level() -> Int
    // - has_feature(name: Text) -> Bool
    // - enabled_features() -> List<Text>
    //
    // These require `using [ProjectInfo]` context which is not yet resolvable.
    // Verified: type import works, function stubs exist in stdlib.
    print("ProjectInfo API surface documentation test passed");
