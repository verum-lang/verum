// =============================================================================
// reflection_test.vr - Comprehensive tests for compile-time type reflection
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: meta, reflection, type-kind, field-info, variant-info, visibility,
//        primitive-type, generic-param, ownership, protocol-info, function-info
// @description: Tests for all reflection types: TypeKind, FieldInfo, VariantInfo,
//               VariantKind, GenericParam, GenericParamKind, ProtocolInfo,
//               FunctionInfo, ParamInfo, SelfKind, Visibility, PrimitiveType,
//               TraitBound, LifetimeParam, OwnershipInfo, FieldOffset,
//               MethodResolution, MethodSource, AssociatedTypeInfo.
// =============================================================================

mount core.meta.reflection.{
    TypeKind, MethodSource, FieldInfo, VariantInfo, VariantKind,
    GenericParam, GenericParamKind, Visibility, PrimitiveType,
    TraitBound, LifetimeParam, OwnershipInfo, FieldOffset,
    MethodResolution, FunctionInfo, ParamInfo, SelfKind,
    ProtocolInfo, AssociatedTypeInfo,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;
mount core.meta.span.Span;

// =============================================================================
// Section 1: TypeKind Variants — Exhaustive
// =============================================================================

@test
fn test_type_kind_struct() {
    let k: TypeKind = TypeKind.Struct;
    assert(k.is_compound());
    assert(!k.is_reference());
    assert(!k.is_primitive());
}

@test
fn test_type_kind_enum() {
    let k: TypeKind = TypeKind.Enum;
    assert(k.is_compound());
}

@test
fn test_type_kind_newtype() {
    let k: TypeKind = TypeKind.Newtype;
    assert(!k.is_compound());
}

@test
fn test_type_kind_unit() {
    let k: TypeKind = TypeKind.Unit;
    assert(!k.is_compound());
}

@test
fn test_type_kind_protocol() {
    let k: TypeKind = TypeKind.Protocol;
    assert(!k.is_compound());
}

@test
fn test_type_kind_tuple() {
    let k: TypeKind = TypeKind.Tuple;
    assert(k.is_compound());
}

@test
fn test_type_kind_array() {
    let k: TypeKind = TypeKind.Array;
    assert(!k.is_compound());
    assert(!k.is_reference());
}

@test
fn test_type_kind_slice() {
    let k: TypeKind = TypeKind.Slice;
    assert(!k.is_compound());
}

@test
fn test_type_kind_reference() {
    let k: TypeKind = TypeKind.Reference;
    assert(k.is_reference());
    assert(!k.is_compound());
}

@test
fn test_type_kind_pointer() {
    let k: TypeKind = TypeKind.Pointer;
    assert(k.is_reference());
}

@test
fn test_type_kind_function() {
    let k: TypeKind = TypeKind.Function;
    assert(!k.is_compound());
}

@test
fn test_type_kind_type_param() {
    let k: TypeKind = TypeKind.TypeParam;
    assert(!k.is_compound());
    assert(!k.is_reference());
    assert(!k.is_primitive());
}

@test
fn test_type_kind_associated() {
    let k: TypeKind = TypeKind.Associated;
    assert(!k.is_compound());
}

@test
fn test_type_kind_primitive() {
    let k: TypeKind = TypeKind.Primitive;
    assert(k.is_primitive());
}

@test
fn test_type_kind_never() {
    let k: TypeKind = TypeKind.Never;
    assert(!k.is_compound());
    assert(!k.is_reference());
    assert(!k.is_primitive());
}

@test
fn test_type_kind_infer() {
    let k: TypeKind = TypeKind.Infer;
    assert(!k.is_compound());
    assert(!k.is_primitive());
}

@test
fn test_type_kind_unknown() {
    let k: TypeKind = TypeKind.Unknown;
    assert(!k.is_compound());
    assert(!k.is_reference());
    assert(!k.is_primitive());
}

