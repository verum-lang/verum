// =============================================================================
// vcs/specs/core/meta/quote_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: core, meta, quote, quasi-quotation, code-generation, token-stream
// @description: Comprehensive tests for quasi-quotation support including
//               QuoteBuilder, GroupBuilder, QuotePart, and convenience functions.
//
// Coverage:
// - QuoteBuilder: construction, basic tokens, literals, delimiters, common patterns, building
// - GroupBuilder: construction, methods, close
// - QuotePart: all variants
// - Convenience functions: empty, ident, string, int, parens, braces, brackets, join_with
//
// Test Strategy:
// - Type existence verification
// - Builder pattern construction and chaining
// - Enum variant matching
// - Convenience function invocation
// =============================================================================

module specs.core.meta.quote_test;

mount core.meta.quote.{
    QuoteBuilder, GroupBuilder, QuotePart,
    empty as quote_empty, ident as quote_ident,
    string as quote_string, int as quote_int,
    parens, braces, brackets, join_with,
};
mount core.meta.token.{TokenStream, TokenTree, Delimiter};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// QuoteBuilder — Construction
// =============================================================================

@test
fn test_quote_builder_new() {
    let builder = QuoteBuilder.new();
    let _ = builder;
}

@test
fn test_quote_builder_build_empty() {
    let builder = QuoteBuilder.new();
    let stream: TokenStream = builder.build();
    assert(stream.is_empty());
}

@test
fn test_quote_builder_build_returns_token_stream() {
    let builder = QuoteBuilder.new();
    let stream: TokenStream = builder.build();
    assert_eq(stream.len(), 0);
}

// =============================================================================
// QuoteBuilder — Basic Tokens
// =============================================================================

@test
fn test_quote_builder_ident() {
    let stream = QuoteBuilder.new()
        .ident("foo")
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_multiple_idents() {
    let stream = QuoteBuilder.new()
        .ident("foo")
        .ident("bar")
        .ident("baz")
        .build();
    assert_eq(stream.len(), 3);
}

@test
fn test_quote_builder_keyword() {
    let stream = QuoteBuilder.new()
        .keyword("let")
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_punct() {
    let stream = QuoteBuilder.new()
        .punct(';')
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_punct_joint() {
    let stream = QuoteBuilder.new()
        .punct_joint('=')
        .punct('>')
        .build();
    assert_eq(stream.len(), 2);
}

@test
fn test_quote_builder_operator() {
    let stream = QuoteBuilder.new()
        .operator("->")
        .build();
    assert_eq(stream.len(), 2);
}

@test
fn test_quote_builder_operator_double_colon() {
    let stream = QuoteBuilder.new()
        .operator("::")
        .build();
    assert_eq(stream.len(), 2);
}

