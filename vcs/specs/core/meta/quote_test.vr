@test
fn test_quote_builder_int_lit() {
    let stream = QuoteBuilder.new()
        .int_lit(42)
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_float_lit() {
    let stream = QuoteBuilder.new()
        .float_lit(3.14)
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_string_lit() {
    let stream = QuoteBuilder.new()
        .string_lit("hello world")
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_char_lit() {
    let stream = QuoteBuilder.new()
        .char_lit('x')
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_bool_lit_true() {
    let stream = QuoteBuilder.new()
        .bool_lit(true)
        .build();
    assert_eq(stream.len(), 1);
}

@test
fn test_quote_builder_bool_lit_false() {
    let stream = QuoteBuilder.new()
        .bool_lit(false)
        .build();
    assert_eq(stream.len(), 1);
