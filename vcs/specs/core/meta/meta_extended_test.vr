// =============================================================================
// meta_extended_test.vr - Extended tests for meta types and reflection APIs
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: meta, reflection, token, span, attribute, function-info, protocol-info,
//        ownership, field-offset, method-resolution, trait-bound, lifetime
// @description: Extended tests for reflection type methods (FieldInfo attributes,
//               VariantInfo patterns, GenericParam constraints, ProtocolInfo,
//               FunctionInfo signatures), TokenStream, Span, Attribute types,
//               OwnershipInfo, FieldOffset, MethodResolution, PrimitiveType, Visibility.
// =============================================================================

module specs.core.meta.meta_extended_test;

mount core.meta.reflection.{
    TypeKind, MethodSource, FieldInfo, VariantInfo, VariantKind,
    GenericParam, GenericParamKind, Visibility, PrimitiveType,
    TraitBound, LifetimeParam, OwnershipInfo, FieldOffset,
    MethodResolution, FunctionInfo, ParamInfo, SelfKind,
    ProtocolInfo, AssociatedTypeInfo,
};
mount core.meta.span.{Span, SpanFlags};
mount core.meta.token.{TokenStream, TokenTree, TokenKind, Delimiter};
mount core.meta.attribute.{Attribute, AttributeStyle, AttributeArg, AttributeValue};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// Section 1: TypeKind extended
// =============================================================================

@test
fn test_type_kind_function() {
    let k = TypeKind.Function;
    assert(!k.is_compound());
    assert(!k.is_reference());
    assert(!k.is_primitive());
}

@test
fn test_type_kind_type_param() {
    let k = TypeKind.TypeParam;
    assert(!k.is_compound());
}

@test
fn test_type_kind_associated() {
    let k = TypeKind.Associated;
    assert(!k.is_compound());
}

@test
fn test_type_kind_never() {
    let k = TypeKind.Never;
    assert(!k.is_compound());
}

@test
fn test_type_kind_infer() {
    let k = TypeKind.Infer;
    assert(!k.is_compound());
}

@test
fn test_type_kind_unknown() {
    let k = TypeKind.Unknown;
    assert(!k.is_compound());
}

@test
fn test_type_kind_reference() {
    let k = TypeKind.Reference;
    assert(k.is_reference());
    assert(!k.is_compound());
}

@test
fn test_type_kind_pointer() {
    let k = TypeKind.Pointer;
    assert(k.is_reference());
}

@test
fn test_type_kind_primitive() {
    let k = TypeKind.Primitive;
    assert(k.is_primitive());
    assert(!k.is_compound());
}

@test
fn test_type_kind_name_struct() {
    let k = TypeKind.Struct;
    assert_eq(k.name(), "struct");
}

@test
fn test_type_kind_name_enum() {
    let k = TypeKind.Enum;
    assert_eq(k.name(), "enum");
}

@test
fn test_type_kind_name_protocol() {
    let k = TypeKind.Protocol;
    assert_eq(k.name(), "protocol");
}

@test
fn test_type_kind_name_function() {
    let k = TypeKind.Function;
    assert_eq(k.name(), "function");
}

@test
fn test_type_kind_name_never() {
    let k = TypeKind.Never;
    assert_eq(k.name(), "never");
}

// =============================================================================
// Section 2: FieldInfo (avoiding 'field' keyword as variable name)
// =============================================================================

@test
fn test_field_info_is_public() {
    // FieldInfo has: name, index, type_name, type_kind, visibility, is_mutable, attributes, doc, span
    let fi: Maybe<FieldInfo> = None;
    assert(fi.is_none());
}

@test
fn test_field_info_type_exists() {
    let opt: Maybe<FieldInfo> = None;
    assert(opt.is_none());
    // FieldInfo has: has_attribute(), is_public(), is_private(), is_tuple_field(), accessor()
}

