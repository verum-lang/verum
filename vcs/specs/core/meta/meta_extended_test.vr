// =============================================================================
// Section 7: Visibility
// =============================================================================

@test
fn test_visibility_public() {
    let v = Visibility.Public;
    assert(v.is_public());
}

@test
fn test_visibility_private() {
    let v = Visibility.Private;
    assert(!v.is_public());
}

@test
fn test_visibility_crate() {
    let v = Visibility.Crate;
    assert(!v.is_public());
}

@test
fn test_visibility_keyword_public() {
    let v = Visibility.Public;
    let kw = v.keyword();
    assert(kw.is_some());
}

@test
fn test_visibility_keyword_private() {
    let v = Visibility.Private;
    let kw = v.keyword();
    let _: Maybe<Text> = kw;
}

