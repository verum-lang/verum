// =============================================================================
// Section 5: PrimitiveType classification
// =============================================================================

@test
fn test_primitive_int() {
    let p = PrimitiveType.Int;
    assert(p.is_numeric());
    assert(p.is_signed());
    assert(!p.is_unsigned());
    assert(!p.is_float());
}

@test
fn test_primitive_float64() {
    let p = PrimitiveType.Float64;
    assert(p.is_numeric());
    assert(p.is_float());
}

@test
fn test_primitive_bool() {
    let p = PrimitiveType.Bool;
    assert(!p.is_numeric());
}

@test
fn test_primitive_char() {
    let p = PrimitiveType.Char;
    assert(!p.is_numeric());
}

@test
fn test_primitive_int8() {
    let p = PrimitiveType.Int8;
    assert(p.is_numeric());
    assert(p.is_signed());
}

@test
fn test_primitive_uint8() {
    let p = PrimitiveType.UInt8;
    assert(p.is_numeric());
    assert(p.is_unsigned());
}

@test
fn test_primitive_int16() {
    let p = PrimitiveType.Int16;
    assert(p.is_signed());
}

@test
fn test_primitive_uint16() {
    let p = PrimitiveType.UInt16;
    assert(p.is_unsigned());
}

@test
fn test_primitive_int32() {
    let p = PrimitiveType.Int32;
    assert(p.is_signed());
}

@test
fn test_primitive_uint32() {
    let p = PrimitiveType.UInt32;
    assert(p.is_unsigned());
}

@test
fn test_primitive_int64() {
    let p = PrimitiveType.Int64;
    assert(p.is_signed());
}

@test
fn test_primitive_uint64() {
    let p = PrimitiveType.UInt64;
    assert(p.is_unsigned());
}

@test
fn test_primitive_float32() {
    let p = PrimitiveType.Float32;
    assert(p.is_float());
}

@test
fn test_primitive_name() {
    let p = PrimitiveType.Int;
    let n = p.name();
    assert(n.len() > 0);
}

@test
fn test_primitive_size() {
    let p = PrimitiveType.Int;
    let s = p.size();
    assert(s > 0);
}

