// =============================================================================
// span_test.vr - Comprehensive tests for source span and location types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: meta, span, source-location, diagnostics, multi-span, span-range
// @description: Tests for SourceLocation, SpanFlags, SpanRange, MultiSpan types,
//               and Span properties/operations.
// =============================================================================

mount core.meta.span.{SourceLocation, SpanFlags, Span, SpanRange, MultiSpan};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// Section 1: SourceLocation — Construction
// =============================================================================

@test
fn test_source_location_new() {
    let loc = SourceLocation.new("test.vr", 10, 5, 100);
    assert_eq(loc.file, "test.vr");
    assert_eq(loc.line, 10);
    assert_eq(loc.column, 5);
    assert_eq(loc.offset, 100);
}

@test
fn test_source_location_display() {
    let loc = SourceLocation.new("main.vr", 42, 13, 500);
    let display = loc.display();
    assert_eq(display, "main.vr:42:13");
}

@test
fn test_source_location_fields_direct() {
    let loc = SourceLocation {
        file: "src/lib.vr",
        line: 1,
        column: 1,
        offset: 0,
    };
    assert_eq(loc.file, "src/lib.vr");
    assert_eq(loc.line, 1);
    assert_eq(loc.column, 1);
    assert_eq(loc.offset, 0);
}

@test
fn test_source_location_large_values() {
    let loc = SourceLocation.new("big_file.vr", 10000, 200, 500000);
    assert_eq(loc.line, 10000);
    assert_eq(loc.column, 200);
    assert_eq(loc.offset, 500000);
}

@test
fn test_source_location_display_single_digit() {
    let loc = SourceLocation.new("a.vr", 1, 1, 0);
    assert_eq(loc.display(), "a.vr:1:1");
}

@test
fn test_source_location_display_deep_path() {
    let loc = SourceLocation.new("src/core/meta/span.vr", 100, 20, 5000);
    assert_eq(loc.display(), "src/core/meta/span.vr:100:20");
}

// =============================================================================
// Section 2: SpanFlags — All Combinations
// =============================================================================

@test
fn test_span_flags_default() {
    let flags = SpanFlags {
        is_expansion: false,
        is_synthetic: false,
        is_hidden: false,
    };
    assert(!flags.is_expansion);
    assert(!flags.is_synthetic);
    assert(!flags.is_hidden);
}

@test
fn test_span_flags_expansion_only() {
    let flags = SpanFlags {
        is_expansion: true,
        is_synthetic: false,
        is_hidden: false,
    };
    assert(flags.is_expansion);
    assert(!flags.is_synthetic);
    assert(!flags.is_hidden);
}

@test
fn test_span_flags_synthetic_only() {
    let flags = SpanFlags {
        is_expansion: false,
        is_synthetic: true,
        is_hidden: false,
    };
    assert(flags.is_synthetic);
    assert(!flags.is_expansion);
}

@test
fn test_span_flags_hidden_only() {
    let flags = SpanFlags {
        is_expansion: false,
        is_synthetic: false,
        is_hidden: true,
    };
    assert(flags.is_hidden);
}

@test
fn test_span_flags_all_set() {
    let flags = SpanFlags {
        is_expansion: true,
        is_synthetic: true,
        is_hidden: true,
    };
    assert(flags.is_expansion);
    assert(flags.is_synthetic);
    assert(flags.is_hidden);
}

@test
fn test_span_flags_expansion_and_synthetic() {
    let flags = SpanFlags {
        is_expansion: true,
        is_synthetic: true,
        is_hidden: false,
    };
    assert(flags.is_expansion);
    assert(flags.is_synthetic);
    assert(!flags.is_hidden);
}

@test
fn test_span_flags_expansion_and_hidden() {
    let flags = SpanFlags {
        is_expansion: true,
        is_synthetic: false,
        is_hidden: true,
    };
    assert(flags.is_expansion);
    assert(!flags.is_synthetic);
    assert(flags.is_hidden);
}

@test
fn test_span_flags_synthetic_and_hidden() {
    let flags = SpanFlags {
        is_expansion: false,
        is_synthetic: true,
        is_hidden: true,
    };
    assert(!flags.is_expansion);
    assert(flags.is_synthetic);
    assert(flags.is_hidden);
}

// =============================================================================
// Section 3: SpanRange
// =============================================================================

@test
fn test_span_range_single() {
    let span = Span.call_site();
    let range = SpanRange.single(span);
    let _ = range.start;
    let _ = range.end;
}

@test
fn test_span_range_new() {
    let s = Span.call_site();
    let e = Span.call_site();
    let range = SpanRange.new(s, e);
    let _ = range;
}

@test
fn test_span_range_to_span() {
    let s = Span.call_site();
    let range = SpanRange.single(s);
    let combined: Span = range.to_span();
    let _ = combined;
}

@test
fn test_span_range_start_location() {
    let s = Span.call_site();
    let range = SpanRange.single(s);
    let loc: Maybe<SourceLocation> = range.start_location();
    let _ = loc;
}

@test
fn test_span_range_end_location() {
    let s = Span.call_site();
    let range = SpanRange.single(s);
    let loc: Maybe<SourceLocation> = range.end_location();
    let _ = loc;
}

@test
fn test_span_range_contains() {
    let s = Span.call_site();
    let range = SpanRange.single(s);
    let test_span = Span.call_site();
    let _ = range.contains(&test_span);
}

// =============================================================================
// Section 4: MultiSpan
// =============================================================================

@test
fn test_multi_span_empty() {
    let ms = MultiSpan.empty();
    assert(ms.is_empty());
    assert(ms.primary_span().is_none());
}

@test
fn test_multi_span_from_span() {
    let s = Span.call_site();
    let ms = MultiSpan.from_span(s);
    assert(!ms.is_empty());
    assert(ms.primary_span().is_some());
}

@test
fn test_multi_span_with_primary() {
    let ms = MultiSpan.empty()
        .with_primary(Span.call_site());
    assert(!ms.is_empty());
    assert(ms.primary_span().is_some());
}

@test
fn test_multi_span_with_labeled_span() {
    let ms = MultiSpan.from_span(Span.call_site())
        .with_span(Span.call_site(), "note: defined here");
    assert(!ms.is_empty());
}

@test
fn test_multi_span_multiple_labels() {
    let ms = MultiSpan.from_span(Span.call_site())
        .with_span(Span.call_site(), "first")
        .with_span(Span.call_site(), "second")
        .with_span(Span.call_site(), "third");
    assert(!ms.is_empty());
}

@test
fn test_multi_span_no_primary_with_labels() {
    let ms = MultiSpan.empty()
        .with_span(Span.call_site(), "note");
    // has labels but no primary
    assert(!ms.is_empty());
    assert(ms.primary_span().is_none());
}

