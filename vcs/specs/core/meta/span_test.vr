// =============================================================================
// Section 9: Additional SourceLocation Tests
// =============================================================================

@test
fn test_source_location_zero_line_column() {
    let loc = SourceLocation.new("unknown.vr", 0, 0, 0);
    assert_eq(loc.line, 0);
    assert_eq(loc.column, 0);
    assert_eq(loc.offset, 0);
}

@test
fn test_source_location_different_files() {
    let loc1 = SourceLocation.new("a.vr", 1, 1, 0);
    let loc2 = SourceLocation.new("b.vr", 1, 1, 0);
    assert(loc1.file != loc2.file);
}

@test
fn test_span_join_self() {
    let s = Span.call_site();
    let joined = s.join(s);
    let _ = joined;
}

@test
fn test_multi_span_empty_primary_none() {
    let ms = MultiSpan.empty();
    assert(ms.is_empty());
    assert(ms.primary_span().is_none());
}

@test
fn test_multi_span_from_span_has_primary() {
    let s = Span.call_site();
    let ms = MultiSpan.from_span(s);
    assert(ms.primary_span().is_some());
}

@test
fn test_span_synthetic_type() {
    let s: Span = Span.synthetic();
    let _: Span = s;
}

@test
fn test_source_location_display_multi_digit() {
    let loc = SourceLocation.new("module/test.vr", 999, 88, 12345);
    assert_eq(loc.display(), "module/test.vr:999:88");
}

@test
fn test_span_range_single_start_end() {
    let s = Span.call_site();
    let range = SpanRange.single(s);
    // start and end should be accessible
    let _s = range.start;
    let _e = range.end;
}

// =============================================================================
// Section 10: Additional Advanced Tests
// =============================================================================

@test
fn test_span_eq_implementation() {
    let s1 = Span.call_site();
    let s2 = Span.call_site();
    // Test Eq trait implementation
    let same = s1.eq(&s1);
    assert(same);
    // Two call_site spans may or may not be equal depending on hygiene
    let _ = s1.eq(&s2);
}

@test
fn test_span_ord_implementation() {
    let s1 = Span.call_site();
    let s2 = Span.def_site();
    // Test Ord trait implementation
    let ordering = s1.cmp(&s2);
    let _ = ordering;
    // Self-comparison should be Equal
    let self_ord = s1.cmp(&s1);
    let _ = self_ord;
}

@test
fn test_source_location_eq_implementation() {
    let loc1 = SourceLocation.new("test.vr", 10, 5, 100);
    let loc2 = SourceLocation.new("test.vr", 10, 5, 100);
    let loc3 = SourceLocation.new("test.vr", 10, 6, 101);
    // Same locations should be equal
    assert(loc1.eq(&loc2));
    // Different column should not be equal
    assert(!loc1.eq(&loc3));
}

@test
fn test_source_location_eq_different_files() {
    let loc1 = SourceLocation.new("a.vr", 1, 1, 0);
    let loc2 = SourceLocation.new("b.vr", 1, 1, 0);
    // Different files should not be equal even with same line/column
    assert(!loc1.eq(&loc2));
}

@test
fn test_span_range_different_start_end() {
    let start = Span.call_site();
    let end = Span.def_site();
    let range = SpanRange.new(start, end);
    // Verify start and end are different spans
    let combined = range.to_span();
    let _ = combined;
    // Both locations should be accessible
    let start_loc = range.start_location();
    let end_loc = range.end_location();
    let _ = start_loc;
    let _ = end_loc;
}

@test
fn test_multi_span_iter_primary_only() {
    let s = Span.call_site();
    let ms = MultiSpan.from_span(s);
    // Test iter() method with only primary span
    let iter = ms.iter();
    let _ = iter;
}

@test
fn test_multi_span_iter_with_labels() {
    let s1 = Span.call_site();
    let s2 = Span.def_site();
    let s3 = Span.mixed_site();
    let ms = MultiSpan.from_span(s1)
        .with_span(s2, "note: defined here")
        .with_span(s3, "note: used here");
    // Test iter() with primary and labeled spans
    let iter = ms.iter();
    let _ = iter;
}

@test
fn test_span_overlaps_non_overlapping() {
    let s1 = Span.call_site();
    let s2 = Span.def_site();
    // Test overlaps with potentially non-overlapping spans
    let result = s1.overlaps(&s2);
    let _ = result;
    // Test symmetry
    let result2 = s2.overlaps(&s1);
    let _ = result2;
}

fn main() {
    // Tests run via @test annotations
}
