// =============================================================================
// elementary_test.vr - Tests for elementary mathematical functions
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: math, elementary, trig, exp, log, power, rounding, core
// @description: Comprehensive tests for trigonometric, exponential, logarithmic,
//               power, rounding, and utility functions from elementary.vr
// =============================================================================

mount core.math.elementary.{
    sin, cos, tan, sincos, asin, acos, atan, atan2,
    asin_safe, acos_safe,
    exp, exp2, expm1,
    log, log2, log10, log1p, log_safe,
    pow, powi, sqrt, sqrt_safe, cbrt, hypot,
    floor, ceil, round, trunc, fract,
    min, max, clamp, abs, signum,
    fma, lerp, inverse_lerp, remap,
    smoothstep, smootherstep,
};
mount core.math.constants.{PI, FRAC_PI_2, FRAC_PI_4, E, LN2, LN10, SQRT2, EPSILON, INFINITY, NEG_INFINITY, NAN};
mount core.base.maybe.{Maybe, Some, None};

// Helper for approximate equality
fn approx_eq(a: Float, b: Float, tolerance: Float) -> Bool {
    if a == b { return true; }
    let diff = abs(a - b);
    diff < tolerance
}

// Default tolerance for most tests
const TOLERANCE: Float = 1e-10;

// =============================================================================
// SECTION 1: Trigonometric Functions - sin
// =============================================================================

@test
fn test_sin_zero() {
    assert(approx_eq(sin(0.0), 0.0, TOLERANCE));
}

@test
fn test_sin_pi_2() {
    assert(approx_eq(sin(FRAC_PI_2), 1.0, TOLERANCE));
}

@test
fn test_sin_pi() {
    assert(approx_eq(sin(PI), 0.0, TOLERANCE));
}

@test
fn test_sin_3pi_2() {
    assert(approx_eq(sin(3.0 * FRAC_PI_2), -1.0, TOLERANCE));
}

@test
fn test_sin_2pi() {
    assert(approx_eq(sin(2.0 * PI), 0.0, TOLERANCE));
}

@test
fn test_sin_negative() {
    // sin(-x) = -sin(x)
    assert(approx_eq(sin(-FRAC_PI_2), -1.0, TOLERANCE));
}

@test
fn test_sin_pi_4() {
    // sin(π/4) = √2/2
    let expected = SQRT2 / 2.0;
    assert(approx_eq(sin(FRAC_PI_4), expected, TOLERANCE));
}

// =============================================================================
// SECTION 2: Trigonometric Functions - cos
// =============================================================================

@test
fn test_cos_zero() {
    assert(approx_eq(cos(0.0), 1.0, TOLERANCE));
}

@test
fn test_cos_pi_2() {
    assert(approx_eq(cos(FRAC_PI_2), 0.0, TOLERANCE));
}

@test
fn test_cos_pi() {
    assert(approx_eq(cos(PI), -1.0, TOLERANCE));
}

@test
fn test_cos_2pi() {
    assert(approx_eq(cos(2.0 * PI), 1.0, TOLERANCE));
}

@test
fn test_cos_negative() {
    // cos(-x) = cos(x)
    assert(approx_eq(cos(-FRAC_PI_4), cos(FRAC_PI_4), TOLERANCE));
}

@test
fn test_cos_pi_4() {
    // cos(π/4) = √2/2
    let expected = SQRT2 / 2.0;
    assert(approx_eq(cos(FRAC_PI_4), expected, TOLERANCE));
}

// =============================================================================
// SECTION 3: Trigonometric Functions - tan
// =============================================================================

@test
fn test_tan_zero() {
    assert(approx_eq(tan(0.0), 0.0, TOLERANCE));
}

@test
fn test_tan_pi_4() {
    // tan(π/4) = 1
    assert(approx_eq(tan(FRAC_PI_4), 1.0, TOLERANCE));
}

@test
fn test_tan_negative_pi_4() {
    // tan(-π/4) = -1
    assert(approx_eq(tan(-FRAC_PI_4), -1.0, TOLERANCE));
}

@test
fn test_tan_pi() {
    assert(approx_eq(tan(PI), 0.0, TOLERANCE));
}

// =============================================================================
// SECTION 4: sincos
// =============================================================================

@test
fn test_sincos_zero() {
    let (s, c) = sincos(0.0);
    assert(approx_eq(s, 0.0, TOLERANCE));
    assert(approx_eq(c, 1.0, TOLERANCE));
}

@test
fn test_sincos_pi_4() {
    let (s, c) = sincos(FRAC_PI_4);
    let expected = SQRT2 / 2.0;
    assert(approx_eq(s, expected, TOLERANCE));
    assert(approx_eq(c, expected, TOLERANCE));
}

@test
fn test_sincos_identity() {
    // sin²(x) + cos²(x) = 1
    let x = 1.234;
    let (s, c) = sincos(x);
    assert(approx_eq(s * s + c * c, 1.0, TOLERANCE));
}

// =============================================================================
// SECTION 5: Inverse Trigonometric Functions
// =============================================================================

@test
fn test_asin_zero() {
    assert(approx_eq(asin(0.0), 0.0, TOLERANCE));
}

@test
fn test_asin_one() {
    assert(approx_eq(asin(1.0), FRAC_PI_2, TOLERANCE));
}

@test
fn test_asin_neg_one() {
    assert(approx_eq(asin(-1.0), -FRAC_PI_2, TOLERANCE));
}

@test
fn test_asin_half() {
    // asin(0.5) = π/6
    assert(approx_eq(asin(0.5), PI / 6.0, TOLERANCE));
}

@test
fn test_asin_safe_valid() {
    let result = asin_safe(0.5);
    assert(result.is_some());
}

@test
fn test_asin_safe_invalid() {
    let result = asin_safe(1.5);
    assert(result.is_none());
}

@test
fn test_acos_zero() {
    assert(approx_eq(acos(0.0), FRAC_PI_2, TOLERANCE));
}

@test
fn test_acos_one() {
    assert(approx_eq(acos(1.0), 0.0, TOLERANCE));
}

@test
fn test_acos_neg_one() {
    assert(approx_eq(acos(-1.0), PI, TOLERANCE));
}

@test
fn test_atan_zero() {
    assert(approx_eq(atan(0.0), 0.0, TOLERANCE));
}

@test
fn test_atan_one() {
    assert(approx_eq(atan(1.0), FRAC_PI_4, TOLERANCE));
}

@test
fn test_atan_neg_one() {
    assert(approx_eq(atan(-1.0), -FRAC_PI_4, TOLERANCE));
}

@test
fn test_atan_large() {
    // atan approaches π/2 as x → ∞
    assert(approx_eq(atan(1000.0), FRAC_PI_2, 0.001));
}

// =============================================================================
// SECTION 6: atan2
// =============================================================================

@test
fn test_atan2_quadrant_1() {
    // First quadrant: (1, 1) -> π/4
    assert(approx_eq(atan2(1.0, 1.0), FRAC_PI_4, TOLERANCE));
}

@test
fn test_atan2_quadrant_2() {
    // Second quadrant: (1, -1) -> 3π/4
    assert(approx_eq(atan2(1.0, -1.0), 3.0 * FRAC_PI_4, TOLERANCE));
}

@test
fn test_atan2_quadrant_3() {
    // Third quadrant: (-1, -1) -> -3π/4
    assert(approx_eq(atan2(-1.0, -1.0), -3.0 * FRAC_PI_4, TOLERANCE));
}

@test
fn test_atan2_quadrant_4() {
    // Fourth quadrant: (-1, 1) -> -π/4
    assert(approx_eq(atan2(-1.0, 1.0), -FRAC_PI_4, TOLERANCE));
}

@test
fn test_atan2_positive_y_axis() {
    assert(approx_eq(atan2(1.0, 0.0), FRAC_PI_2, TOLERANCE));
}

@test
fn test_atan2_negative_y_axis() {
    assert(approx_eq(atan2(-1.0, 0.0), -FRAC_PI_2, TOLERANCE));
}

// =============================================================================
// SECTION 7: Exponential Functions
// =============================================================================

@test
fn test_exp_zero() {
    assert(approx_eq(exp(0.0), 1.0, TOLERANCE));
}

@test
fn test_exp_one() {
    assert(approx_eq(exp(1.0), E, TOLERANCE));
}

@test
fn test_exp_ln2() {
    assert(approx_eq(exp(LN2), 2.0, TOLERANCE));
}

@test
fn test_exp_negative() {
    assert(approx_eq(exp(-1.0), 1.0 / E, TOLERANCE));
}

@test
fn test_exp2_zero() {
    assert(approx_eq(exp2(0.0), 1.0, TOLERANCE));
}

@test
fn test_exp2_one() {
    assert(approx_eq(exp2(1.0), 2.0, TOLERANCE));
}

@test
fn test_exp2_ten() {
    assert(approx_eq(exp2(10.0), 1024.0, TOLERANCE));
}

@test
fn test_expm1_zero() {
    // expm1(0) = 0
    assert(approx_eq(expm1(0.0), 0.0, TOLERANCE));
}

@test
fn test_expm1_small() {
    // For small x, expm1(x) ≈ x
    let x = 1e-15;
    assert(approx_eq(expm1(x), x, 1e-20));
}

@test
fn test_expm1_one() {
    assert(approx_eq(expm1(1.0), E - 1.0, TOLERANCE));
}

// =============================================================================
// SECTION 8: Logarithmic Functions
// =============================================================================

@test
fn test_log_one() {
    assert(approx_eq(log(1.0), 0.0, TOLERANCE));
}

@test
fn test_log_e() {
    assert(approx_eq(log(E), 1.0, TOLERANCE));
}

@test
fn test_log_exp() {
    // log(exp(x)) = x
    let x = 2.5;
    assert(approx_eq(log(exp(x)), x, TOLERANCE));
}

@test
fn test_log_safe_positive() {
    let result = log_safe(E);
    assert(result.is_some());
    if let Some(v) = result {
        assert(approx_eq(v, 1.0, TOLERANCE));
    }
}

@test
fn test_log_safe_zero() {
    let result = log_safe(0.0);
    assert(result.is_none());
}

@test
fn test_log_safe_negative() {
    let result = log_safe(-1.0);
    assert(result.is_none());
}

@test
fn test_log2_one() {
    assert(approx_eq(log2(1.0), 0.0, TOLERANCE));
}

@test
fn test_log2_two() {
    assert(approx_eq(log2(2.0), 1.0, TOLERANCE));
}

@test
fn test_log2_1024() {
    assert(approx_eq(log2(1024.0), 10.0, TOLERANCE));
}

@test
fn test_log10_one() {
    assert(approx_eq(log10(1.0), 0.0, TOLERANCE));
}

@test
fn test_log10_ten() {
    assert(approx_eq(log10(10.0), 1.0, TOLERANCE));
}

@test
fn test_log10_100() {
    assert(approx_eq(log10(100.0), 2.0, TOLERANCE));
}

@test
fn test_log1p_zero() {
    assert(approx_eq(log1p(0.0), 0.0, TOLERANCE));
}

@test
fn test_log1p_small() {
    // For small x, log1p(x) ≈ x
    let x = 1e-15;
    assert(approx_eq(log1p(x), x, 1e-20));
}

@test
fn test_log1p_one() {
    assert(approx_eq(log1p(1.0), LN2, TOLERANCE));
}

