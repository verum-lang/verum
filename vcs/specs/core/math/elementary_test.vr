    assert(approx_eq(hypot(3.0, 4.0), 5.0, TOLERANCE));
}

@test
fn test_hypot_1_1() {
    assert(approx_eq(hypot(1.0, 1.0), SQRT2, TOLERANCE));
}

@test
fn test_hypot_zero() {
    assert(approx_eq(hypot(0.0, 5.0), 5.0, TOLERANCE));
}

// =============================================================================
// SECTION 10: Rounding Functions
// =============================================================================

@test
fn test_floor_positive() {
    assert_eq(floor(2.7), 2.0);
    assert_eq(floor(2.3), 2.0);
    assert_eq(floor(2.0), 2.0);
}

@test
fn test_floor_negative() {
    assert_eq(floor(-2.3), -3.0);
    assert_eq(floor(-2.7), -3.0);
    assert_eq(floor(-2.0), -2.0);
}

@test
fn test_ceil_positive() {
    assert_eq(ceil(2.3), 3.0);
    assert_eq(ceil(2.7), 3.0);
    assert_eq(ceil(2.0), 2.0);
}

@test
fn test_ceil_negative() {
    assert_eq(ceil(-2.3), -2.0);
    assert_eq(ceil(-2.7), -2.0);
    assert_eq(ceil(-2.0), -2.0);
}

@test
fn test_round_half() {
    // Round half away from zero
    assert_eq(round(2.5), 3.0);
    assert_eq(round(-2.5), -3.0);
}

@test
fn test_round_normal() {
    assert_eq(round(2.3), 2.0);
    assert_eq(round(2.7), 3.0);
}

@test
fn test_trunc_positive() {
    assert_eq(trunc(2.7), 2.0);
    assert_eq(trunc(2.3), 2.0);
}

@test
fn test_trunc_negative() {
    assert_eq(trunc(-2.7), -2.0);
    assert_eq(trunc(-2.3), -2.0);
}

@test
fn test_fract_positive() {
    assert(approx_eq(fract(2.75), 0.75, TOLERANCE));
}

@test
fn test_fract_negative() {
    assert(approx_eq(fract(-2.25), -0.25, TOLERANCE));
}

// =============================================================================
// SECTION 11: Min, Max, Clamp
// =============================================================================

@test
fn test_min_basic() {
    assert_eq(min(3.0, 5.0), 3.0);
    assert_eq(min(5.0, 3.0), 3.0);
}

@test
fn test_min_equal() {
    assert_eq(min(3.0, 3.0), 3.0);
}

@test
fn test_min_negative() {
    assert_eq(min(-5.0, -3.0), -5.0);
}

@test
fn test_max_basic() {
    assert_eq(max(3.0, 5.0), 5.0);
    assert_eq(max(5.0, 3.0), 5.0);
}

@test
fn test_max_equal() {
    assert_eq(max(3.0, 3.0), 3.0);
}

@test
fn test_max_negative() {
    assert_eq(max(-5.0, -3.0), -3.0);
}

@test
fn test_clamp_within() {
    assert_eq(clamp(5.0, 0.0, 10.0), 5.0);
}

@test
fn test_clamp_below() {
    assert_eq(clamp(-5.0, 0.0, 10.0), 0.0);
}

@test
fn test_clamp_above() {
    assert_eq(clamp(15.0, 0.0, 10.0), 10.0);
}

// =============================================================================
// SECTION 12: Absolute Value and Sign
// =============================================================================

@test
fn test_abs_positive() {
    assert_eq(abs(5.0), 5.0);
}

@test
fn test_abs_negative() {
    assert_eq(abs(-5.0), 5.0);
}

@test
fn test_abs_zero() {
    assert_eq(abs(0.0), 0.0);
}

@test
fn test_signum_positive() {
    assert_eq(signum(5.0), 1.0);
}

@test
fn test_signum_negative() {
    assert_eq(signum(-5.0), -1.0);
}

@test
fn test_signum_zero() {
    assert_eq(signum(0.0), 0.0);
}

// =============================================================================
// SECTION 13: Fused Multiply-Add
// =============================================================================

@test
fn test_fma_basic() {
    // fma(a, b, c) = a * b + c
    assert(approx_eq(fma(2.0, 3.0, 4.0), 10.0, TOLERANCE));
}

@test
fn test_fma_precision() {
    // FMA should be more precise than separate operations
    let a = 1.0 + 1e-16;
    let b = 1.0 - 1e-16;
    let c = -1.0;
    // (1 + ε)(1 - ε) - 1 = -ε²
    let result = fma(a, b, c);
    assert(abs(result) < 1e-30);
}

// =============================================================================
// SECTION 14: Linear Interpolation
// =============================================================================

@test
fn test_lerp_endpoints() {
    assert_eq(lerp(0.0, 10.0, 0.0), 0.0);
    assert_eq(lerp(0.0, 10.0, 1.0), 10.0);
}

@test
fn test_lerp_middle() {
    assert_eq(lerp(0.0, 10.0, 0.5), 5.0);
}

@test
fn test_lerp_quarter() {
    assert_eq(lerp(0.0, 100.0, 0.25), 25.0);
}

@test
fn test_inverse_lerp_endpoints() {
    assert_eq(inverse_lerp(0.0, 10.0, 0.0), 0.0);
    assert_eq(inverse_lerp(0.0, 10.0, 10.0), 1.0);
}

@test
fn test_inverse_lerp_middle() {
    assert_eq(inverse_lerp(0.0, 10.0, 5.0), 0.5);
}

@test
fn test_remap_basic() {
    // Map [0, 10] -> [0, 100], value 5 -> 50
    assert_eq(remap(5.0, 0.0, 10.0, 0.0, 100.0), 50.0);
}

@test
fn test_remap_reverse() {
    // Map [0, 10] -> [100, 0], value 2 -> 80
    assert_eq(remap(2.0, 0.0, 10.0, 100.0, 0.0), 80.0);
}

// =============================================================================
// SECTION 15: Smooth Interpolation
// =============================================================================

@test
fn test_smoothstep_edges() {
    // Below edge0 returns 0
    assert_eq(smoothstep(0.0, 1.0, -0.5), 0.0);
    // Above edge1 returns 1
    assert_eq(smoothstep(0.0, 1.0, 1.5), 1.0);
}

@test
fn test_smoothstep_middle() {
    // At middle, smoothstep(0, 1, 0.5) = 0.5
    assert_eq(smoothstep(0.0, 1.0, 0.5), 0.5);
}

@test
fn test_smoothstep_smooth() {
    // Values should be smooth (between 0 and 1 for inputs between edges)
    let v = smoothstep(0.0, 1.0, 0.25);
    assert(v > 0.0);
    assert(v < 0.5);
}

@test
fn test_smootherstep_edges() {
    assert_eq(smootherstep(0.0, 1.0, -0.5), 0.0);
    assert_eq(smootherstep(0.0, 1.0, 1.5), 1.0);
}

@test
fn test_smootherstep_middle() {
    assert_eq(smootherstep(0.0, 1.0, 0.5), 0.5);
}

// =============================================================================
// SECTION 16: Mathematical Identities
// =============================================================================

@test
fn test_pythagorean_identity() {
    // sin²(x) + cos²(x) = 1
    let angles = [0.1, 0.5, 1.0, 2.0, 3.0];
    for angle in angles.iter() {
        let s: Float = sin(*angle);
        let c: Float = cos(*angle);
        assert(approx_eq(s * s + c * c, 1.0, TOLERANCE));
    }
}

@test
fn test_exp_log_inverse() {
    // exp(log(x)) = x for x > 0
    let values = [0.1, 1.0, 2.0, 10.0, 100.0];
    for v in values.iter() {
        assert(approx_eq(exp(log(*v)), *v, TOLERANCE));
    }
}

@test
fn test_log_exp_inverse() {
    // log(exp(x)) = x
    let values = [-2.0, -1.0, 0.0, 1.0, 2.0];
    for v in values.iter() {
        assert(approx_eq(log(exp(*v)), *v, TOLERANCE));
    }
}

@test
fn test_sqrt_square_identity() {
    // sqrt(x²) = |x|
    let values = [1.0, 2.0, 3.0, 10.0];
    for v in values.iter() {
        assert(approx_eq(sqrt(*v * *v), *v, TOLERANCE));
    }
}

@test
fn test_cbrt_cube_identity() {
    // cbrt(x³) = x
    let values = [-3.0, -2.0, -1.0, 1.0, 2.0, 3.0];
    for v in values.iter() {
        assert(approx_eq(cbrt(*v * *v * *v), *v, TOLERANCE));
    }
}

// =============================================================================
// Main function
// =============================================================================

fn main() {
    // Tests run via @test annotations
}
