// =============================================================================
// ieee754_test.vr - Tests for IEEE 754 floating-point utilities
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: math, ieee754, float, classification, special-values, decompose,
//        f32, frexp, ldexp, modf, next_up, next_down, ulp, nan-payload
// @description: Tests for IEEE 754 utilities: FpCategory, F64Bits, F32Bits,
//               classification (is_nan, is_infinite, is_finite, is_normal,
//               is_subnormal, is_zero) for both Float and Float32,
//               sign operations (signbit, copysign, negate) for both widths,
//               decomposition (f64/f32 decompose/compose, classify, classify_f32),
//               frexp, ldexp, modf, trunc, next_up, next_down, ulp_distance,
//               special value creation (infinity, neg_infinity, nan, nan_with_payload,
//               nan_payload), and IEEE 754 constant properties.
// =============================================================================

mount core.math.ieee754.{
    // Bit layout types
    F64Bits, F32Bits,
    // Classification enum
    FpCategory,
    // Decompose / compose
    f64_decompose, f64_compose,
    f32_decompose, f32_compose,
    // Classification functions (Float64)
    classify, is_nan, is_infinite, is_finite, is_normal, is_subnormal, is_zero,
    // Classification functions (Float32)
    classify_f32,
    is_nan_f32, is_infinite_f32, is_finite_f32, is_normal_f32, is_subnormal_f32, is_zero_f32,
    // Sign operations (Float64)
    signbit, copysign, negate,
    // Sign operations (Float32)
    signbit_f32, copysign_f32, negate_f32,
    // Decomposition functions
    frexp, ldexp, modf, trunc,
    // Next/previous representable values
    next_up, next_down, ulp_distance,
    // Special value creation
    infinity, neg_infinity, nan_with_payload, nan_payload,
};
mount core.math.constants.{INFINITY, NEG_INFINITY, NAN, EPSILON};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: FpCategory Variant Construction
// =============================================================================

@test
fn test_fp_category_zero() {
    let c: FpCategory = FpCategory.Zero;
    assert(c is FpCategory.Zero);
}

@test
fn test_fp_category_subnormal() {
    let c: FpCategory = FpCategory.Subnormal;
    assert(c is FpCategory.Subnormal);
}

@test
fn test_fp_category_normal() {
    let c: FpCategory = FpCategory.Normal;
    assert(c is FpCategory.Normal);
}

@test
fn test_fp_category_infinite() {
    let c: FpCategory = FpCategory.Infinite;
    assert(c is FpCategory.Infinite);
}

@test
fn test_fp_category_nan() {
    let c: FpCategory = FpCategory.NaN;
    assert(c is FpCategory.NaN);
}

// =============================================================================
// Section 1b: FpCategory Distinctness
// =============================================================================

@test
fn test_fp_category_zero_not_subnormal() {
    let c = FpCategory.Zero;
    assert(!(c is FpCategory.Subnormal));
    assert(!(c is FpCategory.Normal));
    assert(!(c is FpCategory.Infinite));
    assert(!(c is FpCategory.NaN));
}

@test
fn test_fp_category_normal_not_others() {
    let c = FpCategory.Normal;
    assert(!(c is FpCategory.Zero));
    assert(!(c is FpCategory.Subnormal));
    assert(!(c is FpCategory.Infinite));
    assert(!(c is FpCategory.NaN));
}

@test
fn test_fp_category_infinite_not_others() {
    let c = FpCategory.Infinite;
    assert(!(c is FpCategory.Zero));
    assert(!(c is FpCategory.Subnormal));
    assert(!(c is FpCategory.Normal));
    assert(!(c is FpCategory.NaN));
}

@test
fn test_fp_category_nan_not_others() {
    let c = FpCategory.NaN;
    assert(!(c is FpCategory.Zero));
    assert(!(c is FpCategory.Subnormal));
    assert(!(c is FpCategory.Normal));
    assert(!(c is FpCategory.Infinite));
}

@test
fn test_fp_category_exhaustive_match() {
    // Verify all 5 categories can be matched
    let categories = [
        FpCategory.Zero,
        FpCategory.Subnormal,
        FpCategory.Normal,
        FpCategory.Infinite,
        FpCategory.NaN,
    ];
    let mut count = 0;
    for cat in categories {
        match cat {
            FpCategory.Zero => count = count + 1,
            FpCategory.Subnormal => count = count + 1,
            FpCategory.Normal => count = count + 1,
            FpCategory.Infinite => count = count + 1,
            FpCategory.NaN => count = count + 1,
        }
    }
    assert_eq(count, 5);
}

// =============================================================================
// Section 2: F64Bits Construction
// =============================================================================

@test
fn test_f64_bits_zero() {
    let bits = F64Bits { sign: false, exponent: 0, mantissa: 0 };
    assert(!bits.sign);
    assert(bits.exponent == 0);
    assert(bits.mantissa == 0);
}

@test
fn test_f64_bits_negative() {
    let bits = F64Bits { sign: true, exponent: 1023, mantissa: 0 };
    assert(bits.sign);
}

@test
fn test_f64_bits_max_exponent() {
    // Max exponent (0x7FF = 2047) indicates infinity or NaN
    let bits = F64Bits { sign: false, exponent: 0x7FF, mantissa: 0 };
    assert(bits.exponent == 2047);
}

// =============================================================================
// Section 2b: F32Bits Construction
// =============================================================================

@test
fn test_f32_bits_zero() {
    let bits = F32Bits { sign: false, exponent: 0, mantissa: 0 };
    assert(!bits.sign);
    assert(bits.exponent == 0);
    assert(bits.mantissa == 0);
}

@test
fn test_f32_bits_positive_one() {
    // 1.0f32: sign=0, exponent=127 (biased), mantissa=0
    let bits = F32Bits { sign: false, exponent: 127, mantissa: 0 };
    assert(!bits.sign);
    assert(bits.exponent == 127);
    assert(bits.mantissa == 0);
}

@test
fn test_f32_bits_negative() {
    let bits = F32Bits { sign: true, exponent: 127, mantissa: 0 };
    assert(bits.sign);
    assert(bits.exponent == 127);
}

@test
fn test_f32_bits_max_exponent() {
    // Max exponent for Float32 is 0xFF = 255
    let bits = F32Bits { sign: false, exponent: 0xFF, mantissa: 0 };
    assert(bits.exponent == 255);
}

// =============================================================================
// Section 3: classify
// =============================================================================

@test
fn test_classify_zero() {
    let cat = classify(0.0);
    assert(cat is FpCategory.Zero);
}

@test
fn test_classify_normal_positive() {
    let cat = classify(1.0);
    assert(cat is FpCategory.Normal);
}

@test
fn test_classify_normal_negative() {
    let cat = classify(-42.5);
    assert(cat is FpCategory.Normal);
}

@test
fn test_classify_infinity() {
    let cat = classify(INFINITY);
    assert(cat is FpCategory.Infinite);
}

@test
fn test_classify_neg_infinity() {
    let cat = classify(NEG_INFINITY);
    assert(cat is FpCategory.Infinite);
}

@test
fn test_classify_nan() {
    let cat = classify(NAN);
    assert(cat is FpCategory.NaN);
}

// =============================================================================
// Section 3b: classify_f32
// =============================================================================

@test
fn test_classify_f32_zero() {
    let cat = classify_f32(0.0 as Float32);
    assert(cat is FpCategory.Zero);
}

@test
fn test_classify_f32_normal_positive() {
    let cat = classify_f32(1.0 as Float32);
    assert(cat is FpCategory.Normal);
}

@test
fn test_classify_f32_normal_negative() {
    let val = 0.0 as Float32 - 42.5 as Float32;
    let cat = classify_f32(val);
    assert(cat is FpCategory.Normal);
}

