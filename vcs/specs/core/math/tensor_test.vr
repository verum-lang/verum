// =============================================================================
// vcs/specs/core/math/tensor_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: core, math, tensor, dtype, layout, device, ndarray
// @description: Tests for tensor system types including DType, Layout, Device,
//               operation enums, TensorHandle structure, and DynTensor properties.
//
// Coverage:
// - DType: all 14 variants, size_bytes, is_float, is_complex
// - Layout: RowMajor, ColumnMajor, Strided, compute_strides
// - Device: CPU, GPU variants
// - Operation enums: BinaryOp, UnaryOp, ReduceOp
// - DynTensor and Tensor type construction
// - Type existence: Tensor, RuntimeShapedTensor, TensorView, TensorSVD/QR/Eig/LU
// - Creation functions: zeros, ones, full, eye, arange, linspace, from_list, randn, rand, etc.
// - Unary operations: neg, abs, sign, exp, log, sqrt, rsqrt, square
// - Activation functions: relu, sigmoid, gelu, silu, softmax, log_softmax, leaky_relu
// - Reductions: sum, mean, prod, argmax, argmin
// - Shape operations: reshape, flatten, transpose, unsqueeze, squeeze, cat, stack
// - Linear algebra: matmul, mm, bmm, mv, outer, trace, det, svd, qr, inverse, solve
//
// Test Strategy:
// - Exhaustive variant testing for enums
// - Property verification for size/type queries
// - Stride computation correctness for different layouts
// - Function import verification for tensor API surface
// =============================================================================

module specs.core.math.tensor_test;

mount core.math.tensor.{
    DType, Layout, Device,
    DynTensor, TensorHandle,
};
mount core.math.linalg.Numeric;
mount core.math.tensor.{
    Tensor, RuntimeShapedTensor, TensorView,
    TensorSVD, TensorQR, TensorEig, TensorLU,
    zeros, ones, full, zeros_like, ones_like, full_like,
    arange, linspace, eye, from_list, randn, rand, rand_uniform, randint,
    neg, tensor_abs, sign, tensor_exp, tensor_log, tensor_sqrt,
    rsqrt, square, tensor_sin, tensor_cos, tensor_tan, tensor_tanh,
    tensor_sinh, tensor_cosh, tensor_erf,
    ceil, tensor_floor, tensor_round, trunc,
    relu, leaky_relu, sigmoid, gelu, silu, softmax, log_softmax,
    add, sub, mul, tensor_pow, maximum, minimum,
    add_scalar, mul_scalar, div_scalar,
    sum, sum_axis, mean, mean_axis, prod, prod_axis,
    tensor_max, max_axis, tensor_min, min_axis,
    argmax, argmin, var_axis, std_axis,
    reshape, flatten, transpose, transpose_dims, permute,
    unsqueeze, squeeze, squeeze_dim,
    cat, stack, split, tile,
    slice, index_select, gather, scatter, where_tensor, nonzero, one_hot,
    mm, bmm, matmul, mv, outer, tensor_dot,
    norm, frobenius_norm, trace, diag, triu, tril,
    svd, tensor_qr, tensor_cholesky, eig, eigh, tensor_lu,
    solve, tensor_inverse, det,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// DType Tests
// =============================================================================

@test
fn test_dtype_f64_size() {
    let dt = DType.F64;
    assert_eq(dt.size_bytes(), 8 as USize);
}

@test
fn test_dtype_f32_size() {
    let dt = DType.F32;
    assert_eq(dt.size_bytes(), 4 as USize);
}

@test
fn test_dtype_f16_size() {
    let dt = DType.F16;
    assert_eq(dt.size_bytes(), 2 as USize);
}

@test
fn test_dtype_bf16_size() {
    let dt = DType.BF16;
    assert_eq(dt.size_bytes(), 2 as USize);
}

@test
fn test_dtype_i64_size() {
    let dt = DType.I64;
    assert_eq(dt.size_bytes(), 8 as USize);
}

@test
fn test_dtype_i32_size() {
    let dt = DType.I32;
    assert_eq(dt.size_bytes(), 4 as USize);
}

@test
fn test_dtype_i16_size() {
    let dt = DType.I16;
    assert_eq(dt.size_bytes(), 2 as USize);
}

@test
fn test_dtype_i8_size() {
    let dt = DType.I8;
    assert_eq(dt.size_bytes(), 1 as USize);
}

@test
fn test_dtype_u64_size() {
    let dt = DType.U64;
    assert_eq(dt.size_bytes(), 8 as USize);
}

@test
fn test_dtype_u32_size() {
    let dt = DType.U32;
    assert_eq(dt.size_bytes(), 4 as USize);
}

@test
fn test_dtype_u16_size() {
    let dt = DType.U16;
    assert_eq(dt.size_bytes(), 2 as USize);
}

@test
fn test_dtype_u8_size() {
    let dt = DType.U8;
    assert_eq(dt.size_bytes(), 1 as USize);
}

@test
fn test_dtype_bool_size() {
    let dt = DType.Bool;
    assert_eq(dt.size_bytes(), 1 as USize);
}

@test
fn test_dtype_complex64_size() {
    let dt = DType.Complex64;
    assert_eq(dt.size_bytes(), 8 as USize);
}

@test
fn test_dtype_complex128_size() {
    let dt = DType.Complex128;
    assert_eq(dt.size_bytes(), 16 as USize);
}

@test
fn test_dtype_is_float_true() {
    assert(DType.F64.is_float(), "F64 should be float");
    assert(DType.F32.is_float(), "F32 should be float");
    assert(DType.F16.is_float(), "F16 should be float");
    assert(DType.BF16.is_float(), "BF16 should be float");
}

@test
fn test_dtype_is_float_false() {
    assert(!DType.I64.is_float(), "I64 should not be float");
    assert(!DType.I32.is_float(), "I32 should not be float");
    assert(!DType.U8.is_float(), "U8 should not be float");
    assert(!DType.Bool.is_float(), "Bool should not be float");
    assert(!DType.Complex64.is_float(), "Complex64 should not be float");
}

@test
fn test_dtype_is_complex_true() {
    assert(DType.Complex64.is_complex(), "Complex64 should be complex");
    assert(DType.Complex128.is_complex(), "Complex128 should be complex");
}

@test
fn test_dtype_is_complex_false() {
    assert(!DType.F64.is_complex(), "F64 should not be complex");
    assert(!DType.I32.is_complex(), "I32 should not be complex");
    assert(!DType.Bool.is_complex(), "Bool should not be complex");
}

@test
fn test_dtype_match_all_variants() {
    // Verify all 14 DType variants can be matched
    let types = [
        DType.F64, DType.F32, DType.F16, DType.BF16,
        DType.I64, DType.I32, DType.I16, DType.I8,
        DType.U64, DType.U32, DType.U16, DType.U8,
        DType.Bool, DType.Complex64, DType.Complex128,
    ];
    for dt in types {
        let size = dt.size_bytes();
        assert(size > 0 as USize, "All dtypes should have positive size");
    }
}

// =============================================================================
// Layout Tests
// =============================================================================

@test
fn test_layout_row_major_1d() {
    let layout = Layout.RowMajor;
    let shape = [10 as USize];
    let strides = layout.compute_strides(&shape);
    assert_eq(strides.len(), 1);
    assert_eq(strides[0], 1 as ISize);
}

@test
fn test_layout_row_major_2d() {
    let layout = Layout.RowMajor;
    let shape = [3 as USize, 4 as USize];
    let strides = layout.compute_strides(&shape);
    assert_eq(strides.len(), 2);
    // Row-major: last dim stride=1, first dim stride=4
    assert_eq(strides[0], 4 as ISize);
    assert_eq(strides[1], 1 as ISize);
}

@test
fn test_layout_row_major_3d() {
    let layout = Layout.RowMajor;
    let shape = [2 as USize, 3 as USize, 4 as USize];
    let strides = layout.compute_strides(&shape);
    assert_eq(strides.len(), 3);
    // [2,3,4]: strides = [12, 4, 1]
    assert_eq(strides[0], 12 as ISize);
    assert_eq(strides[1], 4 as ISize);
    assert_eq(strides[2], 1 as ISize);
}

@test
fn test_layout_column_major_2d() {
    let layout = Layout.ColumnMajor;
    let shape = [3 as USize, 4 as USize];
    let strides = layout.compute_strides(&shape);
    assert_eq(strides.len(), 2);
    // Column-major: first dim stride=1, second dim stride=3
    assert_eq(strides[0], 1 as ISize);
    assert_eq(strides[1], 3 as ISize);
}

@test
fn test_layout_column_major_3d() {
    let layout = Layout.ColumnMajor;
    let shape = [2 as USize, 3 as USize, 4 as USize];
    let strides = layout.compute_strides(&shape);
    assert_eq(strides.len(), 3);
    // [2,3,4]: strides = [1, 2, 6]
    assert_eq(strides[0], 1 as ISize);
    assert_eq(strides[1], 2 as ISize);
    assert_eq(strides[2], 6 as ISize);
}

@test
fn test_layout_strided_custom() {
    let custom_strides = List.from_slice(&[8 as ISize, 2 as ISize, 1 as ISize]);
    let layout = Layout.Strided(custom_strides.clone());
    let shape = [2 as USize, 3 as USize, 4 as USize];
    let strides = layout.compute_strides(&shape);
    // Strided layout returns the custom strides as-is
    assert_eq(strides[0], 8 as ISize);
    assert_eq(strides[1], 2 as ISize);
    assert_eq(strides[2], 1 as ISize);
}

@test
fn test_layout_row_major_scalar() {
    // Scalar (0-dim) tensor
    let layout = Layout.RowMajor;
    let shape: [USize; 0] = [];
    let strides = layout.compute_strides(&shape);
    assert_eq(strides.len(), 0);
}

@test
fn test_layout_row_major_1_element_2d() {
    let layout = Layout.RowMajor;
    let shape = [1 as USize, 1 as USize];
    let strides = layout.compute_strides(&shape);
    assert_eq(strides[0], 1 as ISize);
    assert_eq(strides[1], 1 as ISize);
}

// =============================================================================
// Device Tests
// =============================================================================

@test
fn test_device_cpu() {
    let dev = Device.CPU;
    match dev {
        Device.CPU => { /* expected */ }
        _ => assert(false, "Should be CPU"),
    }
}

@test
fn test_device_gpu_0() {
    let dev = Device.GPU(0 as USize);
    match dev {
        Device.GPU(idx) => assert_eq(idx, 0 as USize),
        _ => assert(false, "Should be GPU"),
    }
}

@test
fn test_device_gpu_multiple() {
    let dev0 = Device.GPU(0 as USize);
    let dev1 = Device.GPU(1 as USize);
    let dev7 = Device.GPU(7 as USize);
    match dev7 {
        Device.GPU(idx) => assert_eq(idx, 7 as USize),
        _ => assert(false, "Should be GPU(7)"),
    }
}

// =============================================================================
// TensorHandle Type Tests
// =============================================================================
// Note: Direct TensorHandle construction requires @vbc(MEM_ALLOC_TENSOR) which
// returns Unit in typecheck mode. Use TensorHandle.allocate() at runtime instead.

@test
fn test_tensor_handle_type_exists() {
    // Verify TensorHandle type exists and can be used in type position
    let _: fn(DType, &[USize], Device) -> TensorHandle = TensorHandle.allocate;
}

@test
fn test_tensor_handle_allocate_type() {
    // Verify allocate method signature exists
    let _ = TensorHandle.allocate;
}

// =============================================================================
// DType Size Consistency Tests
// =============================================================================

@test
fn test_dtype_integer_sizes_ordered() {
    // Integer sizes: I8 < I16 < I32 < I64
    assert(DType.I8.size_bytes() < DType.I16.size_bytes(), "I8 < I16");
    assert(DType.I16.size_bytes() < DType.I32.size_bytes(), "I16 < I32");
    assert(DType.I32.size_bytes() < DType.I64.size_bytes(), "I32 < I64");
}

@test
fn test_dtype_unsigned_sizes_ordered() {
    assert(DType.U8.size_bytes() < DType.U16.size_bytes(), "U8 < U16");
    assert(DType.U16.size_bytes() < DType.U32.size_bytes(), "U16 < U32");
    assert(DType.U32.size_bytes() < DType.U64.size_bytes(), "U32 < U64");
}

@test
fn test_dtype_float_sizes_ordered() {
    assert(DType.F16.size_bytes() <= DType.F32.size_bytes(), "F16 <= F32");
    assert(DType.F32.size_bytes() < DType.F64.size_bytes(), "F32 < F64");
}

@test
fn test_dtype_signed_unsigned_same_size() {
    // Signed and unsigned of same width should have same size
    assert_eq(DType.I8.size_bytes(), DType.U8.size_bytes());
    assert_eq(DType.I16.size_bytes(), DType.U16.size_bytes());
    assert_eq(DType.I32.size_bytes(), DType.U32.size_bytes());
    assert_eq(DType.I64.size_bytes(), DType.U64.size_bytes());
}

@test
fn test_dtype_complex128_is_double_f64() {
    // Complex128 = two F64 components
    assert_eq(DType.Complex128.size_bytes(), 2 as USize * DType.F64.size_bytes());
}

@test
fn test_dtype_complex64_is_double_f32() {
    // Complex64 = two F32 components
    assert_eq(DType.Complex64.size_bytes(), 2 as USize * DType.F32.size_bytes());
}

