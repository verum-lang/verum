// =============================================================================
// Type Relationship Tests
// =============================================================================

@test
fn test_attention_input_type() {
    // AttentionInput is (DynTensor<Float>, Maybe<DynTensor<Float>>)
    let x = zeros(&[1 as USize, 10 as USize, 512 as USize]);
    let mask: Maybe<DynTensor<Float>> = Maybe.None;
    let input = (x, mask);
    let (_, m) = input;
    match m {
        Maybe.None => { /* no mask */ }
        Maybe.Some(_) => assert(false, "Should be None"),
    }
}

@test
fn test_attention_input_with_mask() {
    let x = zeros(&[1 as USize, 10 as USize, 512 as USize]);
    let mask = Maybe.Some(zeros(&[1 as USize, 1 as USize, 10 as USize, 10 as USize]));
    let input = (x, mask);
    let (_, m) = input;
    match m {
        Maybe.Some(_) => { /* has mask */ }
        Maybe.None => assert(false, "Should have mask"),
    }
}

