fn test_activation_softmax_axis_0() {
    let act = Activation.Softmax(0);
    match act {
        Activation.Softmax(axis) => assert_eq(axis, 0),
        _ => assert(false, "Should be Softmax(0)"),
    }
}

// =============================================================================
// Parameter Tests
// =============================================================================

@test
fn test_parameter_new() {
    let p = Parameter.new(&[3 as USize, 4 as USize]);
    assert(p.requires_grad, "Default parameter should require grad");
}

@test
fn test_parameter_from_tensor() {
    let p = Parameter.from_tensor(zeros(&[5 as USize]));
    assert(p.requires_grad, "from_tensor parameter should require grad");
    match p.grad {
        Maybe.None => { /* expected */ }
        Maybe.Some(_) => assert(false, "Initial grad should be None"),
    }
}

@test
fn test_parameter_zero_grad() {
    let mut p = Parameter.from_tensor(zeros(&[3 as USize]));
    p.accumulate_grad(&ones(&[3 as USize]));
    match p.grad {
        Maybe.Some(_) => { /* has grad */ }
        Maybe.None => assert(false, "Should have grad after accumulate"),
    }
    p.zero_grad();
    match p.grad {
        Maybe.None => { /* expected after zero_grad */ }
        Maybe.Some(_) => assert(false, "After zero_grad, grad should be None"),
    }
}

