// =============================================================================
// vcs/specs/core/math/nn_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: core, math, nn, neural-network, layer, optimizer, transformer
// @description: Tests for the neural networks module including layer types,
//               activation functions, parameter management, optimizers,
//               learning rate schedulers, and transformer components.
//
// Coverage:
// - Parameter: construction, grad tracking, zero_grad
// - Activation variants: ReLU, GELU, SiLU, Tanh, Sigmoid, Softmax
// - Layer types: Linear, Embedding, Conv2d, LayerNorm, RMSNorm, BatchNorm
// - Dropout: construction, probability validation
// - Optimizers: SGD, AdamW construction and configuration
// - Schedulers: CosineScheduler, LinearWarmup
// - Transformer: MultiHeadAttention, FeedForward, TransformerBlock
//
// Test Strategy:
// - Constructor-based type creation (avoids direct record construction issues)
// - Builder pattern verification (with_* methods)
// - Optimizer hyperparameter defaults
// - Scheduler warmup and decay logic
// =============================================================================

module specs.core.math.nn_test;

mount core.math.nn.{
    Parameter,
    Activation,
    Linear, Embedding, Conv2d,
    LayerNorm, RMSNorm, BatchNorm,
    Dropout,
    SGD, AdamW,
    Optimizer, LRScheduler,
    CosineScheduler, LinearWarmup,
    MultiHeadAttention, FeedForward, TransformerBlock,
    AttentionInput,
    RoPE,
    Module, Serializable,
    relu, gelu, silu, sigmoid, softmax_axis, log_softmax, softplus,
    cross_entropy_loss, mse_loss, smooth_l1_loss,
    binary_cross_entropy, binary_cross_entropy_with_logits,
    clip_grad_norm, clip_grad_value,
    sinusoidal_encoding,
};
mount core.math.tensor.{DynTensor, zeros, ones};
mount core.math.elementary.{abs, cos};
mount core.math.constants.{PI};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

