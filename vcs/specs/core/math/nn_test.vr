// =============================================================================
// Dropout Extended Tests
// =============================================================================

@test
fn test_dropout_train_eval_roundtrip() {
    let mut d = Dropout.new(0.3);
    assert(d.training, "starts in training mode");
    d.eval();
    assert(!d.training, "eval sets training=false");
    d.train();
    assert(d.training, "train sets training=true");
    d.eval();
    assert(!d.training, "second eval also works");
    d.train();
    assert(d.training, "second train also works");
}
