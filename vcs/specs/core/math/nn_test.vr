// =============================================================================
// Activation Distinctness Tests
// =============================================================================

@test
fn test_activation_relu_is_not_gelu() {
    let a = Activation.ReLU;
    assert(!(a is Activation.GELU), "ReLU should not be GELU");
    assert(!(a is Activation.SiLU), "ReLU should not be SiLU");
    assert(!(a is Activation.Tanh), "ReLU should not be Tanh");
    assert(!(a is Activation.Sigmoid), "ReLU should not be Sigmoid");
}

@test
fn test_activation_gelu_is_not_others() {
    let a = Activation.GELU;
    assert(!(a is Activation.ReLU), "GELU should not be ReLU");
    assert(!(a is Activation.SiLU), "GELU should not be SiLU");
    assert(!(a is Activation.Tanh), "GELU should not be Tanh");
    assert(!(a is Activation.Sigmoid), "GELU should not be Sigmoid");
}

@test
fn test_activation_softmax_different_axes() {
    let a1 = Activation.Softmax(0);
    let a2 = Activation.Softmax(-1);
    let a3 = Activation.Softmax(1);
    match a1 {
        Activation.Softmax(axis) => assert_eq(axis, 0),
        _ => assert(false, "Should be Softmax"),
    }
    match a2 {
        Activation.Softmax(axis) => assert_eq(axis, -1),
        _ => assert(false, "Should be Softmax"),
    }
    match a3 {
        Activation.Softmax(axis) => assert_eq(axis, 1),
        _ => assert(false, "Should be Softmax"),
    }
}

// =============================================================================
// RoPE Extended Tests
// =============================================================================

@test
fn test_rope_different_base() {
    let rope = RoPE.new(128 as USize, 500000.0);
    assert_eq(rope.dim, 128 as USize);
    assert(rope.base == 500000.0, "Custom base frequency for long context");
}

@test
fn test_rope_different_dims() {
    let rope32 = RoPE.new(32 as USize, 10000.0);
    let rope64 = RoPE.new(64 as USize, 10000.0);
    let rope128 = RoPE.new(128 as USize, 10000.0);
    assert_eq(rope32.dim, 32 as USize);
    assert_eq(rope64.dim, 64 as USize);
    assert_eq(rope128.dim, 128 as USize);
}

