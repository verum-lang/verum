// =============================================================================
// Normalization Layer Tests
// =============================================================================

@test
fn test_layer_norm_construction() {
    let ln = LayerNorm.new(&[512 as USize]);
    assert_eq(ln.normalized_shape.len(), 1);
    assert_eq(ln.normalized_shape[0], 512 as USize);
    assert(ln.eps > 0.0, "eps should be positive");
}

@test
fn test_layer_norm_with_eps() {
    let ln = LayerNorm.new(&[256 as USize]).with_eps(1e-6);
    assert(ln.eps == 1e-6, "custom eps");
}

@test
fn test_rms_norm_construction() {
    let rn = RMSNorm.new(768 as USize);
    assert(rn.eps == 1e-5, "default eps should be 1e-5");
}

@test
fn test_batch_norm_construction() {
    let bn = BatchNorm.new(64 as USize);
    assert_eq(bn.num_features, 64 as USize);
    assert(bn.training, "Should start in training mode");
    assert(bn.momentum == 0.1, "Default momentum");
    assert(bn.eps == 1e-5, "Default eps");
}

@test
fn test_batch_norm_eval_mode() {
    let mut bn = BatchNorm.new(32 as USize);
    bn.eval();
    assert(!bn.training, "Should be in eval mode");
    bn.train();
    assert(bn.training, "Should be back in training mode");
}

// =============================================================================
// Dropout Tests
// =============================================================================

@test
fn test_dropout_construction() {
    let d = Dropout.new(0.1);
    assert(d.p == 0.1, "probability should be 0.1");
    assert(d.training, "should be in training mode");
}

@test
fn test_dropout_eval() {
    let mut d = Dropout.new(0.5);
    d.eval();
    assert(!d.training, "eval should set training=false");
}

@test
fn test_dropout_zero_prob() {
    let d = Dropout.new(0.0);
    assert(d.p == 0.0, "zero dropout probability");
}

// =============================================================================
// SGD Optimizer Tests
// =============================================================================

@test
fn test_sgd_simple() {
    let opt = SGD.simple(0.01);
    assert(opt.lr == 0.01, "lr should be 0.01");
    assert(opt.momentum == 0.0, "simple SGD has no momentum");
    assert(opt.weight_decay == 0.0, "simple SGD has no weight decay");
}

@test
fn test_sgd_with_momentum() {
    let opt = SGD.new(0.01, 0.9, 0.0);
    assert(opt.lr == 0.01, "lr");
    assert(opt.momentum == 0.9, "momentum");
    assert(opt.weight_decay == 0.0, "no weight decay");
}

@test
fn test_sgd_full() {
    let opt = SGD.new(0.001, 0.9, 1e-4);
    assert(opt.lr == 0.001, "lr");
    assert(opt.momentum == 0.9, "momentum");
    assert(opt.weight_decay == 1e-4, "weight decay");
}

@test
fn test_sgd_lr_accessor() {
    let opt = SGD.simple(0.05);
    assert_eq(opt.lr(), 0.05);
}

@test
fn test_sgd_set_lr() {
    let mut opt = SGD.simple(0.01);
    opt.set_lr(0.001);
    assert_eq(opt.lr(), 0.001);
}

// =============================================================================
// AdamW Optimizer Tests
// =============================================================================

@test
fn test_adamw_defaults() {
    let opt = AdamW.new(0.001, 0.01);
    assert(opt.lr == 0.001, "lr");
    assert(opt.beta1 == 0.9, "default beta1");
    assert(opt.beta2 == 0.999, "default beta2");
    assert(opt.eps == 1e-8, "default eps");
    assert(opt.weight_decay == 0.01, "weight_decay");
    assert_eq(opt.step_count, 0 as USize);
}

@test
fn test_adamw_with_betas() {
    let opt = AdamW.new(0.001, 0.01).with_betas(0.95, 0.98);
    assert(opt.beta1 == 0.95, "custom beta1");
    assert(opt.beta2 == 0.98, "custom beta2");
}

@test
fn test_adamw_with_eps() {
    let opt = AdamW.new(0.001, 0.01).with_eps(1e-6);
    assert(opt.eps == 1e-6, "custom eps");
}

@test
fn test_adamw_builder_chain() {
    let opt = AdamW.new(3e-4, 0.1)
        .with_betas(0.9, 0.95)
        .with_eps(1e-5);
    assert(opt.lr == 3e-4, "lr");
    assert(opt.beta1 == 0.9, "beta1");
    assert(opt.beta2 == 0.95, "beta2");
    assert(opt.eps == 1e-5, "eps");
    assert(opt.weight_decay == 0.1, "weight_decay");
}

@test
fn test_adamw_lr_accessor() {
    let opt = AdamW.new(1e-3, 0.01);
    assert_eq(opt.lr(), 1e-3);
}

@test
fn test_adamw_set_lr() {
    let mut opt = AdamW.new(1e-3, 0.01);
    opt.set_lr(5e-4);
    assert_eq(opt.lr(), 5e-4);
}

// =============================================================================
// Learning Rate Scheduler Tests
// =============================================================================

@test
fn test_cosine_scheduler_warmup() {
    let sched = CosineScheduler.new(1e-3, 1e-5, 1000 as USize, 10000 as USize);
    // During warmup, lr should increase linearly
    let lr_0 = sched.get_lr(0 as USize);
    let lr_500 = sched.get_lr(500 as USize);
    let lr_1000 = sched.get_lr(999 as USize);
    assert(lr_0 < lr_500, "lr should increase during warmup");
    assert(lr_500 < lr_1000, "lr should keep increasing during warmup");
}

@test
fn test_cosine_scheduler_at_warmup_end() {
    let sched = CosineScheduler.new(1e-3, 1e-5, 1000 as USize, 10000 as USize);
    // Right at warmup end, lr should be close to initial_lr
    let lr = sched.get_lr(1000 as USize);
    // At step 1000, progress = 0, cos(0) = 1
    // lr = min_lr + 0.5 * (initial_lr - min_lr) * (1 + 1) = initial_lr
    assert(abs(lr - 1e-3) < 1e-6, "lr at warmup end should be initial_lr");
}

@test
fn test_cosine_scheduler_decay() {
    let sched = CosineScheduler.new(1e-3, 0.0, 0 as USize, 1000 as USize);
    // After warmup (0 steps), should decay
    let lr_start = sched.get_lr(0 as USize);
    let lr_mid = sched.get_lr(500 as USize);
    let lr_end = sched.get_lr(999 as USize);
    assert(lr_start > lr_mid, "lr should decrease");
    assert(lr_mid > lr_end, "lr should continue decreasing");
}

@test
fn test_cosine_scheduler_minimum() {
    let sched = CosineScheduler.new(1e-3, 1e-5, 0 as USize, 1000 as USize);
    // At the very end, lr should be close to min_lr
    let lr = sched.get_lr(1000 as USize);
    assert(lr >= 1e-5, "lr should not go below min_lr");
    assert(lr < 1e-3, "lr at end should be less than initial");
}

@test
fn test_linear_warmup_during_warmup() {
    let sched = LinearWarmup { target_lr: 1e-3, warmup_steps: 100 as USize };
    // During warmup, lr scales linearly
    let lr_0 = sched.get_lr(0 as USize);
    let lr_50 = sched.get_lr(50 as USize);
    let lr_100 = sched.get_lr(100 as USize);
    assert(lr_0 < lr_50, "lr should increase");
    assert(lr_50 < lr_100 || abs(lr_50 - lr_100) < 1e-10, "lr should keep increasing");
}

@test
fn test_linear_warmup_at_target() {
    let sched = LinearWarmup { target_lr: 1e-3, warmup_steps: 100 as USize };
    let lr = sched.get_lr(100 as USize);
    assert_eq(lr, 1e-3);
}

@test
fn test_linear_warmup_after_warmup() {
    let sched = LinearWarmup { target_lr: 1e-3, warmup_steps: 100 as USize };
    // After warmup, lr stays at target
    let lr = sched.get_lr(500 as USize);
    assert_eq(lr, 1e-3);
}

