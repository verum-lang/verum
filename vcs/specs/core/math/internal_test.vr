// =============================================================================
// internal_test.vr - Tests for math library internal types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @note: internal.vr fixed — renamed tensor keyword params to t
// @tags: math, internal, mlir, tape, value, ffi, backend
// @description: Tests for MLIRType, ElementType, MemRefLayout, TapeOp,
//               ValueTag, FFIAbi, and BackendCapabilities types.
// =============================================================================

mount core.math.internal.{
    MLIRType, ElementType, MemRefLayout,
    TapeOp, TensorId, ValueTag, FFIAbi,
    BackendCapabilities, Value, FunctionId,
    TensorDebugInfo,
};
mount core.math.tensor.{DType, Device};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// Section 1: ElementType Variants
// =============================================================================

@test
fn test_element_type_f64() {
    let e = ElementType.F64;
    assert(e is ElementType.F64);
}

@test
fn test_element_type_f32() {
    let e = ElementType.F32;
    assert(e is ElementType.F32);
}

@test
fn test_element_type_f16() {
    let e = ElementType.F16;
    assert(e is ElementType.F16);
}

@test
fn test_element_type_bf16() {
    let e = ElementType.BF16;
    assert(e is ElementType.BF16);
}

@test
fn test_element_type_i64() {
    let e = ElementType.I64;
    assert(e is ElementType.I64);
}

@test
fn test_element_type_i32() {
    let e = ElementType.I32;
    assert(e is ElementType.I32);
}

@test
fn test_element_type_i16() {
    let e = ElementType.I16;
    assert(e is ElementType.I16);
}

@test
fn test_element_type_i8() {
    let e = ElementType.I8;
    assert(e is ElementType.I8);
}

@test
fn test_element_type_index() {
    let e = ElementType.Index;
    assert(e is ElementType.Index);
}

@test
fn test_element_type_bool() {
    let e = ElementType.Bool;
    assert(e is ElementType.Bool);
}

@test
fn test_element_type_distinctness_float() {
    assert(!(ElementType.F64 is ElementType.F32));
    assert(!(ElementType.F32 is ElementType.F16));
    assert(!(ElementType.F16 is ElementType.BF16));
}

@test
fn test_element_type_distinctness_int() {
    assert(!(ElementType.I64 is ElementType.I32));
    assert(!(ElementType.I32 is ElementType.I16));
    assert(!(ElementType.I16 is ElementType.I8));
}

@test
fn test_element_type_distinctness_cross() {
    assert(!(ElementType.F64 is ElementType.I64));
    assert(!(ElementType.Index is ElementType.Bool));
    assert(!(ElementType.Bool is ElementType.F32));
}

@test
fn test_element_type_match_exhaustive() {
    let types = [
        ElementType.F64, ElementType.F32, ElementType.F16, ElementType.BF16,
        ElementType.I64, ElementType.I32, ElementType.I16, ElementType.I8,
        ElementType.Index, ElementType.Bool,
    ];
    let mut count = 0;

    for t in types {
        match t {
            ElementType.F64 => count = count + 1,
            ElementType.F32 => count = count + 1,
            ElementType.F16 => count = count + 1,
            ElementType.BF16 => count = count + 1,
            ElementType.I64 => count = count + 1,
            ElementType.I32 => count = count + 1,
            ElementType.I16 => count = count + 1,
            ElementType.I8 => count = count + 1,
            ElementType.Index => count = count + 1,
            ElementType.Bool => count = count + 1,
        }
    }
    assert_eq(count, 10);
}

// =============================================================================
// Section 2: MLIRType Variants
// =============================================================================

@test
fn test_mlir_type_tensor() {
    let t = MLIRType.TensorType {
        element: ElementType.F32,
        shape: List.from(&[2 as ISize, 3 as ISize, 4 as ISize]),
    };
    assert(t is MLIRType.TensorType);
}

@test
fn test_mlir_type_tensor_values() {
    let t = MLIRType.TensorType {
        element: ElementType.F64,
        shape: List.from(&[10 as ISize, 20 as ISize]),
    };
    match t {
        MLIRType.TensorType { element, shape } => {
            assert(element is ElementType.F64);
            assert_eq(shape.len(), 2);
        }
        _ => panic("expected TensorType"),
    }
}

@test
fn test_mlir_type_memref() {
    let t = MLIRType.MemRefType {
        element: ElementType.I32,
        shape: List.from(&[100 as ISize]),
        layout: MemRefLayout.Contiguous,
    };
    assert(t is MLIRType.MemRefType);
}

@test
fn test_mlir_type_memref_strided() {
    let t = MLIRType.MemRefType {
        element: ElementType.F16,
        shape: List.from(&[8 as ISize, 16 as ISize]),
        layout: MemRefLayout.Strided(List.from(&[16 as ISize, 1 as ISize])),
    };
    match t {
        MLIRType.MemRefType { element, shape, layout } => {
            assert(element is ElementType.F16);
            assert(layout is MemRefLayout.Strided);
        }
        _ => panic("expected MemRefType"),
    }
}

@test
fn test_mlir_type_scalar() {
    let t = MLIRType.ScalarType(ElementType.Bool);
    assert(t is MLIRType.ScalarType);
}

@test
fn test_mlir_type_tensor_is_not_scalar() {
    let t = MLIRType.TensorType {
        element: ElementType.F32,
        shape: List.from(&[1 as ISize]),
    };
    assert(!(t is MLIRType.ScalarType));
}

@test
fn test_mlir_type_memref_is_not_scalar() {
    let m = MLIRType.MemRefType {
        element: ElementType.F32,
        shape: List.from(&[1 as ISize]),
        layout: MemRefLayout.Contiguous,
    };
    assert(!(m is MLIRType.ScalarType));
}

@test
fn test_mlir_type_scalar_is_not_tensor() {
    let s = MLIRType.ScalarType(ElementType.F32);
    assert(!(s is MLIRType.TensorType));
    assert(!(s is MLIRType.MemRefType));
}

// =============================================================================
// Section 3: MemRefLayout Variants
// =============================================================================

@test
fn test_memref_layout_contiguous() {
    let l = MemRefLayout.Contiguous;
    assert(l is MemRefLayout.Contiguous);
}

@test
fn test_memref_layout_strided() {
    let l = MemRefLayout.Strided(List.from(&[4 as ISize, 1 as ISize]));
    assert(l is MemRefLayout.Strided);
}

@test
fn test_memref_layout_affine_map() {
    let l = MemRefLayout.AffineMap("(d0, d1) -> (d0 * 4 + d1)");
    assert(l is MemRefLayout.AffineMap);
}

@test
fn test_memref_layout_distinctness() {
    assert(!(MemRefLayout.Contiguous is MemRefLayout.Strided));
    assert(!(MemRefLayout.Contiguous is MemRefLayout.AffineMap));
    let strided = MemRefLayout.Strided(List.from(&[1 as ISize]));
    assert(!(strided is MemRefLayout.Contiguous));
}

