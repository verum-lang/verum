// =============================================================================
// Section 18: BackendCapabilities Additional Configurations
// =============================================================================

@test
fn test_backend_capabilities_all_true() {
    let caps = BackendCapabilities {
        has_sse42: true,
        has_avx: true,
        has_avx2: true,
        has_fma: true,
        has_avx512f: true,
        has_avx512bw: true,
        has_avx512vl: true,
        has_neon: true,
        has_sve: true,
        has_cuda: true,
        cuda_compute_capability: Some((9 as USize, 0 as USize)),
        has_metal: true,
        metal_gpu_family: Some(9 as USize),
    };
    assert(caps.has_sse42);
    assert(caps.has_avx);
    assert(caps.has_avx2);
    assert(caps.has_fma);
    assert(caps.has_avx512f);
    assert(caps.has_avx512bw);
    assert(caps.has_avx512vl);
    assert(caps.has_neon);
    assert(caps.has_sve);
    assert(caps.has_cuda);
    assert(caps.has_metal);
}

@test
fn test_backend_capabilities_cuda_arm_combo() {
    let caps = BackendCapabilities {
        has_sse42: false,
        has_avx: false,
        has_avx2: false,
        has_fma: false,
        has_avx512f: false,
        has_avx512bw: false,
        has_avx512vl: false,
        has_neon: true,
        has_sve: false,
        has_cuda: true,
        cuda_compute_capability: Some((8 as USize, 6 as USize)),
        has_metal: false,
        metal_gpu_family: None,
    };
    assert(caps.has_neon);
    assert(caps.has_cuda);
    assert(!caps.has_sse42);
    assert(!caps.has_metal);
}

@test
fn test_backend_capabilities_x86_no_avx512() {
    let caps = BackendCapabilities {
        has_sse42: true,
        has_avx: true,
        has_avx2: true,
        has_fma: true,
        has_avx512f: false,
        has_avx512bw: false,
        has_avx512vl: false,
        has_neon: false,
        has_sve: false,
        has_cuda: false,
        cuda_compute_capability: None,
        has_metal: false,
        metal_gpu_family: None,
    };
    assert(caps.has_sse42);
    assert(caps.has_avx2);
    assert(caps.has_fma);
    assert(!caps.has_avx512f);
    assert(!caps.has_cuda);
}

@test
fn test_backend_capabilities_metal_only() {
    let caps = BackendCapabilities {
        has_sse42: false,
        has_avx: false,
        has_avx2: false,
        has_fma: false,
        has_avx512f: false,
        has_avx512bw: false,
        has_avx512vl: false,
        has_neon: true,
        has_sve: false,
        has_cuda: false,
        cuda_compute_capability: None,
        has_metal: true,
        metal_gpu_family: Some(8 as USize),
    };
    assert(!caps.has_cuda);
    assert(caps.has_metal);
    assert(caps.has_neon);
    assert(!caps.has_avx);
}

@test
fn test_backend_capabilities_as_param() {
    fn accept_caps(c: &BackendCapabilities) -> Bool { true }
    let caps = BackendCapabilities {
        has_sse42: false,
        has_avx: false,
        has_avx2: false,
        has_fma: false,
        has_avx512f: false,
        has_avx512bw: false,
        has_avx512vl: false,
        has_neon: false,
        has_sve: false,
        has_cuda: false,
        cuda_compute_capability: None,
        has_metal: false,
        metal_gpu_family: None,
    };
    assert(accept_caps(&caps));
}

// =============================================================================
// Section 19: Cross-Type Interactions
// =============================================================================

@test
fn test_element_type_in_mlir_and_tape() {
    // ElementType used in MLIRType
    let mlir = MLIRType.TensorType {
        element: ElementType.F32,
        shape: List.from(&[16 as ISize, 32 as ISize]),
    };
    assert(mlir is MLIRType.TensorType);

    // Same ElementType concept in TapeOp context (ops on F32 tensors)
    let op = TapeOp.MatMul;
    assert(op is TapeOp.MatMul);
}

@test
fn test_tensor_id_in_tape_ops() {
    let id1 = 100 as TensorId;
    let id2 = 200 as TensorId;
    let id3 = 300 as TensorId;

    let custom = TapeOp.Custom {
        name: "fused_attention",
        saved_tensors: List.from(&[id1, id2, id3]),
    };
    assert(custom is TapeOp.Custom);

    let bn = TapeOp.BatchNorm { running_mean: id1, running_var: id2 };
    assert(bn is TapeOp.BatchNorm);
}

@test
fn test_ffi_abi_as_param() {
    fn accept_abi(a: &FFIAbi) -> Bool { true }
    let abi = FFIAbi.C;
    assert(accept_abi(&abi));
}

@test
fn test_value_tag_as_param() {
    fn accept_tag(t: &ValueTag) -> Bool { true }
    let tag = ValueTag.TagFloat;
    assert(accept_tag(&tag));
}

