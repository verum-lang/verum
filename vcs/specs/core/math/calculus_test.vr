// Type and Variant Tests
// =============================================================================

@test
fn test_root_result_found() {
    let result = RootResult.Found(1.414);
    match result {
        RootResult.Found(x) => assert(abs(x - 1.414) < 0.001, "Found should contain value"),
        _ => assert(false, "Should be Found"),
    }
}

@test
fn test_root_result_no_convergence() {
    let result = RootResult.NoConvergence(1.5);
    match result {
        RootResult.NoConvergence(x) => assert(abs(x - 1.5) < 0.001, "Should contain last approx"),
        _ => assert(false, "Should be NoConvergence"),
    }
}

@test
fn test_optim_result_construction() {
    let x = vec2(0.0, 0.0);
    let result = OptimResult {
        x,
        f_val: 0.0,
        converged: true,
        iterations: 42,
    };
    assert(result.converged == true, "converged field");
    assert(result.iterations == 42, "iterations field");
    assert(abs(result.f_val) < EPSILON, "f_val field");
}

// =============================================================================
// Error Order Verification Tests
// =============================================================================

@test
fn test_forward_diff_error_order() {
    // Forward difference error should scale as O(h)
    let err_h1: Float = abs(diff_forward(square, 1.0, 0.1) - 2.0);
    let err_h2: Float = abs(diff_forward(square, 1.0, 0.01) - 2.0);
    let ratio = err_h1 / err_h2;
    // For O(h), ratio should be approximately 10
    assert(ratio > 5.0 && ratio < 20.0, "forward diff should be O(h)");
}

@test
fn test_central_diff_error_order() {
    // Central difference error should scale as O(h²)
    let err_h1: Float = abs(diff_central(square, 1.0, 0.1) - 2.0);
    let err_h2: Float = abs(diff_central(square, 1.0, 0.01) - 2.0);
    let ratio = err_h1 / err_h2;
    // For O(h²), ratio should be approximately 100
    assert(ratio > 50.0 && ratio < 200.0, "central diff should be O(h²)");
}

@test
fn test_trapezoid_error_order() {
    // Trapezoidal rule error should scale as O(h²) = O(1/n²)
    let err_n100: Float = abs(trapezoid(sine, 0.0, PI, 100) - 2.0);
    let err_n200: Float = abs(trapezoid(sine, 0.0, PI, 200) - 2.0);
    let ratio = err_n100 / err_n200;
    // For O(1/n²), doubling n reduces error by ~4
    assert(ratio > 3.0 && ratio < 5.0, "trapezoid should be O(h²)");
}

@test
fn test_simpson_error_order() {
    // Simpson's error should scale as O(h⁴) = O(1/n⁴)
    let err_n10: Float = abs(simpson(sine, 0.0, PI, 10) - 2.0);
    let err_n20: Float = abs(simpson(sine, 0.0, PI, 20) - 2.0);
    let ratio = err_n10 / err_n20;
    // For O(1/n⁴), doubling n reduces error by ~16
    assert(ratio > 10.0 && ratio < 25.0, "Simpson should be O(h⁴)");
}

