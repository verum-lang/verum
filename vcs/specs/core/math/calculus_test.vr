@test
fn test_optimal_h_at_zero() {
    // optimal_h should return a small positive value based on machine epsilon
    let h = optimal_h(0.0);
    assert(h > 0.0, "optimal_h should be positive");
    assert(h < 0.01, "optimal_h should be small");
}

@test
fn test_optimal_h_at_large_x() {
    // optimal_h should scale with |x|
    let h_small = optimal_h(1.0);
    let h_large = optimal_h(1000.0);
    assert(h_large > h_small, "optimal_h should scale with |x|");
}

@test
fn test_optimal_h_symmetric() {
    // optimal_h(x) should equal optimal_h(-x) since it depends on abs(x)
    let h_pos = optimal_h(5.0);
    let h_neg = optimal_h(0.0 - 5.0);
    assert(abs(h_pos - h_neg) < EPSILON, "optimal_h should be symmetric");
}

@test
fn test_diff_central_cube_at_zero() {
    // f(x) = x³, f'(0) = 0
    let result = diff_central(cube, 0.0, 0.001);
    assert(abs(result) < 1e-6, "derivative of x³ at 0 should be 0");
}

@test
fn test_diff_central_cube_at_2() {
    // f(x) = x³, f'(2) = 12
    let result = diff_central(cube, 2.0, 0.001);
    assert(abs(result - 12.0) < 1e-4, "derivative of x³ at 2 should be 12");
}

@test
fn test_diff2_central_exp() {
    // f(x) = e^x, f''(x) = e^x, f''(1) = e
    let result = diff2_central(exponential, 1.0, 0.01);
    assert(abs(result - E) < 0.01, "second derivative of e^x at 1 should be e");
}

@test
fn test_diff2_central_exp_at_zero() {
    // f''(0) = e^0 = 1
    let result = diff2_central(exponential, 0.0, 0.01);
    assert(abs(result - 1.0) < 0.01, "second derivative of e^x at 0 should be 1");
}

@test
fn test_diff_forward_sin() {
    // f'(0) = cos(0) = 1
    let result = diff_forward(sine, 0.0, 0.001);
    assert(abs(result - 1.0) < 0.01, "forward diff of sin at 0 should be ~1");
}

@test
fn test_diff_backward_exp() {
    // f'(0) = 1
    let result = diff_backward(exponential, 0.0, 0.001);
    assert(abs(result - 1.0) < 0.01, "backward diff of e^x at 0 should be ~1");
}

@test
fn test_diff_central_5pt_sin() {
    // 5-point stencil of sin at π/3, f'(π/3) = cos(π/3) = 0.5
    let result = diff_central_5pt(sine, PI / 3.0, 0.1);
    assert(abs(result - 0.5) < 1e-7, "5-point stencil of sin at pi/3 should be 0.5");
}

@test
fn test_richardson_sin() {
    // Richardson extrapolation for sin at 0, f'(0) = 1
    let result = richardson(sine, 0.0, 0.1, 4);
    assert(abs(result - 1.0) < 1e-10, "Richardson for sin at 0 should be 1");
}

@test
fn test_derivative_exp_at_zero() {
    // Auto derivative of e^x at 0 = 1
    let result = derivative(exponential, 0.0);
    assert(abs(result - 1.0) < 1e-6, "auto derivative of e^x at 0 should be 1");
}

// =============================================================================
// Additional Multi-variable Tests
// =============================================================================

@test
fn test_gradient_rosenbrock_at_min() {
    // Gradient of Rosenbrock at (1,1) should be [0, 0]
    let x = vec2(1.0, 1.0);
    let grad = gradient(rosenbrock, &x, 0.0001);
    assert(abs(grad.get(0)) < 0.01, "Rosenbrock gradient x at minimum should be ~0");
    assert(abs(grad.get(1)) < 0.01, "Rosenbrock gradient y at minimum should be ~0");
}

@test
fn test_gradient_rosenbrock_at_origin() {
    // At (0,0): grad = [-2*(1-0) - 400*0*(0-0), 200*(0-0)] = [-2, 0]
    let x = vec2(0.0, 0.0);
    let grad = gradient(rosenbrock, &x, 0.0001);
    assert(abs(grad.get(0) + 2.0) < 0.1, "Rosenbrock gradient x at origin should be ~-2");
    assert(abs(grad.get(1)) < 0.1, "Rosenbrock gradient y at origin should be ~0");
}

@test
fn test_hessian_rosenbrock_at_min() {
    // Hessian of Rosenbrock at (1,1):
    // H = [[2 + 800*1 - 400*(1-3*1), -400*1], [-400*1, 200]]
    //   = [[802, -400], [-400, 200]]
    let x = vec2(1.0, 1.0);
    let hess = hessian(rosenbrock, &x, 0.005);
    assert(abs(hess.get(0, 0) - 802.0) < 5.0, "H[0,0] at Rosenbrock minimum should be ~802");
    assert(abs(hess.get(0, 1) + 400.0) < 5.0, "H[0,1] at Rosenbrock minimum should be ~-400");
    assert(abs(hess.get(1, 0) + 400.0) < 5.0, "H[1,0] at Rosenbrock minimum should be ~-400");
    assert(abs(hess.get(1, 1) - 200.0) < 5.0, "H[1,1] at Rosenbrock minimum should be ~200");
}

@test
fn test_jacobian_identity() {
    // Jacobian of identity map f(x) = x should be identity matrix
    let id_map = |x: &Vector<Float>| -> Vector<Float> { x.clone() };
    let x = vec2(3.0, 7.0);
    let jac = jacobian(id_map, &x, 0.001);
    assert(abs(jac.get(0, 0) - 1.0) < 0.01, "J[0,0] of identity should be 1");
    assert(abs(jac.get(0, 1)) < 0.01, "J[0,1] of identity should be 0");
    assert(abs(jac.get(1, 0)) < 0.01, "J[1,0] of identity should be 0");
    assert(abs(jac.get(1, 1) - 1.0) < 0.01, "J[1,1] of identity should be 1");
}

