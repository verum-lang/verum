@test
fn test_trapezoid_constant() {
    // Integral of constant function: integral from 0 to 1 of 5 dx = 5
    let result = trapezoid(|x| 5.0, 0.0, 1.0, 10);
    assert(abs(result - 5.0) < 1e-10, "trapezoid of constant 5 on [0,1] should be 5");
}

@test
fn test_simpson_exp() {
    // Integral of e^x from 0 to 1 = e - 1
    let expected = E - 1.0;
    let result = simpson(exponential, 0.0, 1.0, 100);
    assert(abs(result - expected) < 1e-10, "Simpson of e^x on [0,1] should be e-1");
}

@test
fn test_simpson38_exp() {
    // Integral of e^x from 0 to 1 = e - 1
    let expected = E - 1.0;
    let result = simpson38(exponential, 0.0, 1.0, 99);
    assert(abs(result - expected) < 1e-6, "Simpson 3/8 of e^x on [0,1]");
}

@test
fn test_romberg_vs_gauss_legendre() {
    // Both should agree on integral of e^x from 0 to 1
    let expected = E - 1.0;
    let result_r = romberg(exponential, 0.0, 1.0, 10, 1e-12);
    let result_g = gauss_legendre(exponential, 0.0, 1.0, 5);
    assert(abs(result_r - expected) < 1e-8, "Romberg should be accurate");
    assert(abs(result_g - expected) < 1e-8, "GL should be accurate");
    assert(abs(result_r - result_g) < 1e-6, "Romberg and GL should agree");
}

@test
fn test_gauss_legendre_default() {
    // Using n != 2,3,5 defaults to 5-point
    let result = gauss_legendre(square, 0.0, 1.0, 7);
    assert(abs(result - 1.0 / 3.0) < 1e-8, "GL default (5-point) of x²");
}

@test
fn test_adaptive_simpson_tight_tol() {
    // With very tight tolerance, adaptive should refine more
    let result = adaptive_simpson(sine, 0.0, PI, 1e-12, 30);
    assert(abs(result - 2.0) < 1e-10, "adaptive Simpson with tight tol should be very accurate");
}

@test
fn test_integration_odd_function_symmetry() {
    // Integral of x³ from -1 to 1 = 0 (odd function over symmetric interval)
    let result = simpson(cube, -1.0, 1.0, 4);
    assert(abs(result) < 1e-10, "integral of odd function on symmetric interval should be 0");
}

@test
fn test_integration_even_function_symmetry() {
    // Integral of x² from -1 to 1 = 2/3 (even function, double half-range)
    let result = simpson(square, -1.0, 1.0, 100);
    assert(abs(result - 2.0 / 3.0) < 1e-10, "integral of x² on [-1,1] should be 2/3");
}

@test
fn test_trapezoid_exp() {
    // Integral of e^x from 0 to 1 = e - 1
    let expected = E - 1.0;
    let result = trapezoid(exponential, 0.0, 1.0, 10000);
    assert(abs(result - expected) < 1e-6, "trapezoid of e^x with many points should be accurate");
}

@test
fn test_gauss_legendre_sin() {
    // GL 5-point on integral of sin from 0 to pi = 2
    let result = gauss_legendre(sine, 0.0, PI, 5);
    assert(abs(result - 2.0) < 0.01, "GL 5-point of sin on [0,pi]");
}

// =============================================================================
// Additional ODE Solver Tests
// =============================================================================

// Harmonic oscillator: y'' = -y  =>  system: y1' = y2, y2' = -y1
// Solution: y1(t) = cos(t), y2(t) = -sin(t)  for y1(0)=1, y2(0)=0
fn harmonic_ode(t: Float, y: &Vector<Float>) -> Vector<Float> {
    let mut dy = Vector.zeros(2);
    dy.set(0, y.get(1));
    let neg_y0 = 0.0 - y.get(0);
    dy.set(1, neg_y0);
    dy
}

@test
fn test_rk4_harmonic_oscillator() {
    // Solve y'' = -y as a 2D system
    let y0 = vec2(1.0, 0.0);  // y(0) = cos(0) = 1, y'(0) = -sin(0) = 0
    let sol: List<(Float, Vector<Float>)> = rk4(harmonic_ode, &y0, 0.0, PI, 0.01);
    let last = sol[sol.len() - 1];
    // y1(pi) = cos(pi) = -1, y2(pi) = -sin(pi) = 0
    let y1_final = last.1.get(0);
    let y2_final = last.1.get(1);
    assert(abs(y1_final + 1.0) < 1e-6, "RK4 harmonic: y1(pi) should be -1");
    assert(abs(y2_final) < 1e-5, "RK4 harmonic: y2(pi) should be ~0");
}

@test
fn test_euler_large_step() {
    // With a larger step, Euler should still not crash, but accuracy degrades
    let y0 = vec1(1.0);
    let sol: List<(Float, Vector<Float>)> = euler(exp_ode, &y0, 0.0, 1.0, 0.1);
    let last = sol[sol.len() - 1];
    let y_final = last.1.get(0);
    // Euler with h=0.1 won't be very accurate but should be in the right ballpark
    assert(abs(y_final - E) < 0.2, "Euler with h=0.1 should be roughly correct");
    assert(y_final > 2.0, "Euler solution should still be growing");
}

@test
fn test_rk45_tight_vs_loose_tolerance() {
    let y0 = vec1(1.0);
    let sol_loose: List<(Float, Vector<Float>)> = rk45(exp_ode, &y0, 0.0, 1.0, 1e-4);
    let sol_tight: List<(Float, Vector<Float>)> = rk45(exp_ode, &y0, 0.0, 1.0, 1e-10);

    let err_loose: Float = abs(sol_loose[sol_loose.len() - 1].1.get(0) - E);
    let err_tight: Float = abs(sol_tight[sol_tight.len() - 1].1.get(0) - E);

    // Tighter tolerance should give more accurate answer (or at least as accurate)
    assert(err_tight <= err_loose + 1e-4, "tighter tol should not be less accurate");
}

@test
fn test_rk4_decay_at_t2() {
    // dy/dt = -y, y(0) = 1 => y(2) = e^(-2)
    let y0 = vec1(1.0);
    let sol: List<(Float, Vector<Float>)> = rk4(decay_ode, &y0, 0.0, 2.0, 0.01);
    let last = sol[sol.len() - 1];
    let y_final = last.1.get(0);
    let neg_two: Float = 0.0 - 2.0;
    let expected = exp(neg_two);
    assert(abs(y_final - expected) < 1e-7, "RK4 decay: y(2) should be e^(-2)");
}

@test
fn test_ode_trajectory_monotonicity() {
    // For dy/dt = y, y(0) = 1, solution e^t is monotonically increasing
    let y0 = vec1(1.0);
    let sol: List<(Float, Vector<Float>)> = rk4(exp_ode, &y0, 0.0, 1.0, 0.1);
    let mut prev = sol[0].1.get(0);
    for i in 1..sol.len() {
        let curr = sol[i].1.get(0);
        assert(curr > prev, "exponential trajectory should be monotonically increasing");
        prev = curr;
    }
}

@test
fn test_heun_decay() {
    // dy/dt = -y, y(0) = 1 => y(1) = e^(-1)
    let y0 = vec1(1.0);
    let sol: List<(Float, Vector<Float>)> = heun(decay_ode, &y0, 0.0, 1.0, 0.01);
    let last = sol[sol.len() - 1];
    let y_final = last.1.get(0);
    let neg_one: Float = 0.0 - 1.0;
    let expected = exp(neg_one);
    assert(abs(y_final - expected) < 0.001, "Heun decay: y(1) should be e^(-1)");
}

// =============================================================================
// Additional Root Finding Tests
// =============================================================================

@test
fn test_newton_raphson_exp() {
    // Find root of e^x - 3 = 0 => x = ln(3)
    let result = newton_raphson(
        |x| exp(x) - 3.0,
        |x| exp(x),
        1.0, 1e-12, 50,
    );
    match result {
        RootResult.Found(x) => {
            assert(abs(x - log(3.0)) < 1e-10, "Newton-Raphson should find ln(3)");
        }
        RootResult.NoConvergence(_) => {
            assert(false, "Newton-Raphson should converge for e^x - 3");
        }
    }
}

@test
fn test_secant_cubic_root() {
    // Find root of x³ - 8 = 0 => x = 2
    let result = secant(|x| x * x * x - 8.0, 1.0, 3.0, 1e-10, 50);
    match result {
        RootResult.Found(x) => {
            assert(abs(x - 2.0) < 1e-8, "Secant should find cube root of 8");
        }
        RootResult.NoConvergence(_) => {
            assert(false, "Secant should converge for x³ - 8");
        }
    }
}

@test
fn test_secant_vs_newton_agreement() {
    // Both should find the same root for e^x - 2 = 0
    let expected = log(2.0);
    let r_secant = secant(|x| exp(x) - 2.0, 0.0, 1.0, 1e-10, 50);
    let r_newton = newton(|x| exp(x) - 2.0, 0.5, 1e-10, 50);

    let x_secant = match r_secant { RootResult.Found(x) => x, _ => 0.0 };
    let x_newton = match r_newton { RootResult.Found(x) => x, _ => 0.0 };

    assert(abs(x_secant - expected) < 1e-8, "secant should find ln(2)");
    assert(abs(x_newton - expected) < 1e-8, "newton should find ln(2)");
    assert(abs(x_secant - x_newton) < 1e-6, "secant and newton should agree");
}

@test
fn test_bisection_convergence_speed() {
    // Bisection on [0, 4] for x² - 2 with tol=1e-10
    // Bisection needs about log2((b-a)/tol) ≈ log2(4/1e-10) ≈ 35 iterations
    // With 100 max_iter, it should easily converge
    let result = bisection(|x| x * x - 2.0, 0.0, 4.0, 1e-10, 100);
    match result {
        RootResult.Found(x) => {
            assert(abs(x - sqrt(2.0)) < 1e-9, "bisection with wide bracket");
        }
        RootResult.NoConvergence(_) => {
            assert(false, "bisection should converge with 100 iterations");
        }
    }
}

@test
fn test_brent_cos() {
    // Find root of cos(x) near pi/2
    let cos_fn = |x: Float| -> Float { cos(x) };
    let result = brent(cos_fn, 1.0, 2.0, 1e-12, 100);
    match result {
        RootResult.Found(x) => {
            assert(abs(x - PI / 2.0) < 1e-10, "Brent should find pi/2 for cos");
        }
        RootResult.NoConvergence(_) => {
            assert(false, "Brent should converge for cos on [1,2]");
        }
    }
}

@test
fn test_newton_cos() {
    // Find root of cos(x) starting near pi/2
    let result = newton(|x| cos(x), 1.0, 1e-10, 50);
    match result {
        RootResult.Found(x) => {
            assert(abs(x - PI / 2.0) < 1e-8, "Newton should find pi/2 for cos");
        }
        RootResult.NoConvergence(_) => {
            assert(false, "Newton should converge for cos");
        }
    }
}

// =============================================================================
// Additional Optimization Tests
// =============================================================================

@test
fn test_gradient_descent_different_start() {
    // Starting from (-3, 4) should still converge to (0, 0)
    let neg_three: Float = 0.0 - 3.0;
    let x0 = vec2(neg_three, 4.0);
    let result = gradient_descent(sphere, sphere_grad, &x0, 0.1, 1e-8, 1000);
    assert(result.converged, "GD should converge from (-3, 4)");
    assert(abs(result.x.get(0)) < 1e-3, "x should be near 0");
    assert(abs(result.x.get(1)) < 1e-3, "y should be near 0");
}

@test
fn test_gradient_descent_bt_different_start() {
    // Starting from (10, -10) on sphere
    let neg_ten: Float = 0.0 - 10.0;
    let x0 = vec2(10.0, neg_ten);
    let result = gradient_descent_bt(sphere, sphere_grad, &x0, 1e-8, 1000);
    assert(result.converged, "GD-BT should converge from (10, -10)");
    assert(abs(result.f_val) < 1e-6, "minimum value should be ~0");
}

@test
fn test_bfgs_f_val_at_minimum() {
    // For sphere function, f_val at minimum should be ~0
    let x0 = vec2(3.0, 4.0);
    let result = bfgs(sphere, sphere_grad, &x0, 1e-8, 1000);
    assert(result.converged, "BFGS should converge on sphere");
    assert(abs(result.f_val) < 1e-6, "f_val at minimum should be ~0");
}

@test
fn test_newton_optimize_iterations_on_quadratic() {
    // Newton's method on a quadratic should converge in very few iterations
    let x0 = vec2(10.0, 10.0);
    let result = newton_optimize(sphere, sphere_grad, sphere_hess, &x0, 1e-10, 100);
    assert(result.converged, "Newton should converge on quadratic");
    assert(result.iterations <= 3, "Newton on quadratic should converge in <=3 iterations");
}

@test
fn test_bfgs_iterations() {
    // BFGS on sphere should converge in relatively few iterations
    let x0 = vec2(5.0, 5.0);
    let result = bfgs(sphere, sphere_grad, &x0, 1e-8, 1000);
    assert(result.converged, "BFGS should converge");
    assert(result.iterations < 50, "BFGS on sphere should not need many iterations");
}

@test
fn test_gradient_descent_bt_rosenbrock() {
    // GD-BT on Rosenbrock - harder optimization problem
    let x0 = vec2(0.0, 0.0);
    let result = gradient_descent_bt(rosenbrock, rosenbrock_grad, &x0, 1e-4, 10000);
    // May not fully converge but should get closer to (1,1)
    let dist = abs(result.x.get(0) - 1.0) + abs(result.x.get(1) - 1.0);
    assert(dist < 2.0, "GD-BT on Rosenbrock should make progress toward minimum");
}

// =============================================================================
// Additional Error Order and Cross-method Tests
// =============================================================================

@test
fn test_5pt_error_order() {
    // 5-point stencil should be O(h⁴) for smooth functions
    let err_h1: Float = abs(diff_central_5pt(exponential, 1.0, 0.1) - E);
    let err_h2: Float = abs(diff_central_5pt(exponential, 1.0, 0.05) - E);
    let ratio = err_h1 / err_h2;
    // For O(h⁴), halving h reduces error by ~16
    assert(ratio > 10.0 && ratio < 25.0, "5-point stencil should be O(h^4)");
}

@test
fn test_backward_diff_error_order() {
    // Backward difference error should scale as O(h), similar to forward
    let err_h1: Float = abs(diff_backward(square, 1.0, 0.1) - 2.0);
    let err_h2: Float = abs(diff_backward(square, 1.0, 0.01) - 2.0);
    let ratio = err_h1 / err_h2;
    assert(ratio > 5.0 && ratio < 20.0, "backward diff should be O(h)");
}

@test
fn test_simpson38_error_order() {
    // Simpson 3/8 is also O(h⁴)
    let err_n1: Float = abs(simpson38(sine, 0.0, PI, 9) - 2.0);
    let err_n2: Float = abs(simpson38(sine, 0.0, PI, 18) - 2.0);
    let ratio = err_n1 / err_n2;
    // Doubling n for O(1/n⁴) should reduce error by ~16
    assert(ratio > 8.0 && ratio < 30.0, "Simpson 3/8 should be O(h^4)");
}

@test
fn test_heun_vs_euler_accuracy() {
    // Heun (2nd order) should be more accurate than Euler (1st order)
    let y0 = vec1(1.0);
    let h = 0.1;
    let sol_euler: List<(Float, Vector<Float>)> = euler(exp_ode, &y0, 0.0, 1.0, h);
    let sol_heun: List<(Float, Vector<Float>)> = heun(exp_ode, &y0, 0.0, 1.0, h);

    let err_euler: Float = abs(sol_euler[sol_euler.len() - 1].1.get(0) - E);
    let err_heun: Float = abs(sol_heun[sol_heun.len() - 1].1.get(0) - E);

    assert(err_heun < err_euler, "Heun should be more accurate than Euler");
}

@test
fn test_midpoint_vs_euler_accuracy() {
    // Midpoint (2nd order) should be more accurate than Euler (1st order)
    let y0 = vec1(1.0);
    let h = 0.1;
    let sol_euler: List<(Float, Vector<Float>)> = euler(exp_ode, &y0, 0.0, 1.0, h);
    let sol_mid: List<(Float, Vector<Float>)> = midpoint(exp_ode, &y0, 0.0, 1.0, h);

    let err_euler: Float = abs(sol_euler[sol_euler.len() - 1].1.get(0) - E);
    let err_mid: Float = abs(sol_mid[sol_mid.len() - 1].1.get(0) - E);

    assert(err_mid < err_euler, "Midpoint should be more accurate than Euler");
}
