@test
fn test_random_key_split_n() {
    let key = RandomKey.new(42);
    let keys = key.split_n(5);
    assert_eq(keys.len(), 5);
}

@test
fn test_random_key_split_n_zero() {
    let key = RandomKey.new(42);
    let keys = key.split_n(0);
    assert_eq(keys.len(), 0);
}

@test
fn test_random_key_split_n_deterministic() {
    let key1 = RandomKey.new(42);
    let key2 = RandomKey.new(42);
    let keys1 = key1.split_n(3);
    let keys2 = key2.split_n(3);
    assert(keys1[0].high == keys2[0].high);
    assert(keys1[0].low == keys2[0].low);
    assert(keys1[2].high == keys2[2].high);
}

