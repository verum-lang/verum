// =============================================================================
// Additional Edge Case Tests
// =============================================================================

@test
fn test_uniform_01_multiple_keys() {
    // Different keys produce different values (with very high probability)
    let k1 = RandomKey.new(1);
    let k2 = RandomKey.new(2);
    let k3 = RandomKey.new(3);
    let x1 = uniform_01(k1);
    let x2 = uniform_01(k2);
    let x3 = uniform_01(k3);
    // At least two of three should differ
    assert(x1 != x2 || x2 != x3);
}

@test
fn test_xorshift128_sequence_length() {
    let mut gen = XorShift128.new(42);
    // Generate a long sequence without issues
    for _ in 0..1000 {
        let v = gen.next_u64();
        let _ = v;
    }
    // Should still produce valid f64
    let x = gen.next_f64();
    assert(x >= 0.0);
    assert(x < 1.0);
}

@test
fn test_pcg_u64_generation() {
    let mut gen = PCG.new(42, 0);
    let v = gen.next_u64();
    let _ = v;
    // Deterministic
    let mut gen2 = PCG.new(42, 0);
    let v2 = gen2.next_u64();
    assert(v == v2);
}

@test
fn test_random_key_fold_in_chain() {
    // Chaining fold_in produces unique keys
    let base = RandomKey.new(42);
    let k1 = base.fold_in(1);
    let k2 = k1.fold_in(2);
    let k3 = k2.fold_in(3);
    // All should be different
    assert(k1.high != k2.high || k1.low != k2.low);
    assert(k2.high != k3.high || k2.low != k3.low);
}
