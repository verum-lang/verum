@test
fn test_rng_creation() {
    let mut rng = Rng.new(42);
    let _ = rng;
}

@test
fn test_rng_from_key() {
    let key = RandomKey.new(123);
    let mut rng = Rng.from_key(key);
    let _ = rng;
}

@test
fn test_rng_next_key() {
    let mut rng = Rng.new(42);
    let k = rng.next_key();
    let _ = k;
}

@test
fn test_rng_uniform_01() {
    let mut rng = Rng.new(42);
    let x = rng.uniform_01();
    assert(x >= 0.0);
    assert(x < 1.0);
}

@test
fn test_rng_uniform_range() {
    let mut rng = Rng.new(42);
    let x = rng.uniform(10.0, 20.0);
    assert(x >= 10.0);
    assert(x < 20.0);
}

@test
fn test_rng_normal_01() {
    let mut rng = Rng.new(42);
    let x = rng.normal_01();
    assert(x > -10.0);
    assert(x < 10.0);
}

@test
fn test_rng_normal_params() {
    let mut rng = Rng.new(42);
    let x = rng.normal(100.0, 10.0);
    assert(x > 50.0);
    assert(x < 150.0);
}

@test
fn test_rng_exponential() {
    let mut rng = Rng.new(42);
    let x = rng.exponential(1.0);
    assert(x >= 0.0);
}

@test
fn test_rng_bernoulli() {
    let mut rng = Rng.new(42);
    let b = rng.bernoulli(0.5);
    let _ = b;
}

@test
fn test_rng_uniform_int() {
    let mut rng = Rng.new(42);
    let x = rng.uniform_int(100);
    assert(x < 100);
}

@test
fn test_rng_permutation() {
    let mut rng = Rng.new(42);
    let perm = rng.permutation(5);
    assert_eq(perm.len(), 5);
}

@test
fn test_rng_shuffle() {
    let mut rng = Rng.new(42);
    let mut v = [1, 2, 3, 4, 5];
    rng.shuffle(&mut v);
    assert_eq(v.len(), 5);
}

