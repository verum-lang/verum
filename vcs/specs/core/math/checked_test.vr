@test
fn test_saturating_add_normal() {
    assert_eq(saturating_add(10 as Int64, 20 as Int64), 30 as Int64);
}

@test
fn test_saturating_add_overflow_max() {
    assert_eq(saturating_add(Int64.MAX, 1 as Int64), Int64.MAX);
    assert_eq(saturating_add(Int64.MAX, 100 as Int64), Int64.MAX);
}

@test
fn test_saturating_add_overflow_min() {
    assert_eq(saturating_add(Int64.MIN, -1 as Int64), Int64.MIN);
    assert_eq(saturating_add(Int64.MIN, -100 as Int64), Int64.MIN);
}

@test
fn test_saturating_sub_normal() {
    assert_eq(saturating_sub(30 as Int64, 10 as Int64), 20 as Int64);
}

@test
fn test_saturating_sub_overflow_min() {
    assert_eq(saturating_sub(Int64.MIN, 1 as Int64), Int64.MIN);
}

@test
fn test_saturating_sub_overflow_max() {
    assert_eq(saturating_sub(Int64.MAX, -1 as Int64), Int64.MAX);
}

@test
fn test_saturating_mul_normal() {
    assert_eq(saturating_mul(7 as Int64, 6 as Int64), 42 as Int64);
}

@test
fn test_saturating_mul_overflow_positive() {
    assert_eq(saturating_mul(Int64.MAX, 2 as Int64), Int64.MAX);
}

@test
fn test_saturating_mul_overflow_negative() {
    assert_eq(saturating_mul(Int64.MAX, -2 as Int64), Int64.MIN);
}

@test
fn test_saturating_neg_normal() {
    assert_eq(saturating_neg42_i64, -42 as Int64);
}

@test
fn test_saturating_neg_min() {
    assert_eq(saturating_neg(Int64.MIN), Int64.MAX);
}

@test
fn test_saturating_abs_normal() {
    assert_eq(saturating_abs-42_i64, 42 as Int64);
}

@test
fn test_saturating_abs_min() {
    assert_eq(saturating_abs(Int64.MIN), Int64.MAX);
}

