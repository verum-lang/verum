// =============================================================================
// checked_test.vr - Tests for overflow-checked arithmetic
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: math, checked, overflow, saturating, wrapping, core
// @note: checked.vr uses LLVM intrinsics — typecheck-pass tests verify type signatures
// @description: Comprehensive tests for checked, saturating, and wrapping arithmetic
// =============================================================================

mount core.math.checked.{
    CheckedResult,
    checked_add, checked_sub, checked_mul, checked_div, checked_neg, checked_abs,
    checked_add_u, checked_sub_u, checked_mul_u, checked_div_u,
    checked_add_i32, checked_mul_i32, checked_add_u32,
    saturating_add, saturating_sub, saturating_mul, saturating_neg, saturating_abs,
    saturating_add_u, saturating_sub_u, saturating_mul_u,
    wrapping_add, wrapping_sub, wrapping_mul, wrapping_neg,
    wrapping_add_u, wrapping_sub_u, wrapping_mul_u,
    would_add_overflow, would_sub_overflow, would_mul_overflow,
    adc, sbb,
};

// Helper to check if result is Ok
fn is_ok<T>(result: CheckedResult<T>) -> Bool {
    match result {
        CheckedResult.Ok(_) => true,
        CheckedResult.Overflow => false,
    }
}

// Helper to unwrap Ok value (panics on Overflow)
fn unwrap<T>(result: CheckedResult<T>) -> T {
    match result {
        CheckedResult.Ok(v) => v,
        CheckedResult.Overflow => panic("Unexpected overflow"),
    }
}

// =============================================================================
// SECTION 1: Checked Addition (Int64)
// =============================================================================

@test
fn test_checked_add_normal() {
    let result = checked_add(10 as Int64, 20 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), 30 as Int64);
}

@test
fn test_checked_add_negative() {
    let result = checked_add(-10 as Int64, 20 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), 10 as Int64);
}

@test
fn test_checked_add_zero() {
    let result = checked_add(42 as Int64, 0 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), 42 as Int64);
}

@test
fn test_checked_add_overflow_positive() {
    let result = checked_add(Int64.MAX, 1 as Int64);
    assert(!is_ok(result));
}

@test
fn test_checked_add_overflow_negative() {
    let result = checked_add(Int64.MIN, -1 as Int64);
    assert(!is_ok(result));
}

@test
fn test_checked_add_near_max() {
    let result = checked_add(Int64.MAX - 1, 1 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), Int64.MAX);
}

// =============================================================================
// SECTION 2: Checked Subtraction (Int64)
// =============================================================================

@test
fn test_checked_sub_normal() {
    let result = checked_sub(30 as Int64, 10 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), 20 as Int64);
}

@test
fn test_checked_sub_negative_result() {
    let result = checked_sub(10 as Int64, 30 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), -20 as Int64);
}

@test
fn test_checked_sub_zero() {
    let result = checked_sub(42 as Int64, 0 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), 42 as Int64);
}

@test
fn test_checked_sub_overflow_positive() {
    let result = checked_sub(Int64.MIN, 1 as Int64);
    assert(!is_ok(result));
}

@test
fn test_checked_sub_overflow_negative() {
    let result = checked_sub(Int64.MAX, -1 as Int64);
    assert(!is_ok(result));
}

