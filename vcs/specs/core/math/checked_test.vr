// =============================================================================

@test
fn test_checked_mul_normal() {
    let result = checked_mul(7 as Int64, 6 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), 42 as Int64);
}

@test
fn test_checked_mul_negative() {
    let result = checked_mul(-7 as Int64, 6 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), -42 as Int64);
}

@test
fn test_checked_mul_zero() {
    let result = checked_mul(Int64.MAX, 0 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), 0 as Int64);
}

@test
fn test_checked_mul_one() {
    let result = checked_mul(Int64.MAX, 1 as Int64);
    assert(is_ok(result));
    assert_eq(unwrap(result), Int64.MAX);
}

@test
fn test_checked_mul_overflow() {
    let result = checked_mul(Int64.MAX, 2 as Int64);
    assert(!is_ok(result));
}

@test
fn test_checked_mul_overflow_negative() {
    let result = checked_mul(Int64.MIN, -1 as Int64);
    assert(!is_ok(result));  // -MIN overflows
}

