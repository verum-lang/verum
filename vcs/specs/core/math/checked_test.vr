    assert_eq(wrapping_sub_u(0 as UInt64, 1 as UInt64), UInt64.MAX);
}

@test
fn test_wrapping_mul_u_normal() {
    assert_eq(wrapping_mul_u(7 as UInt64, 6 as UInt64), 42 as UInt64);
}

// =============================================================================
// SECTION 11: Overflow Detection
// =============================================================================

@test
fn test_would_add_overflow_false() {
    assert(!would_add_overflow(10 as Int64, 20 as Int64));
}

@test
fn test_would_add_overflow_true() {
    assert(would_add_overflow(Int64.MAX, 1 as Int64));
}

@test
fn test_would_sub_overflow_false() {
    assert(!would_sub_overflow(30 as Int64, 10 as Int64));
}

@test
fn test_would_sub_overflow_true() {
    assert(would_sub_overflow(Int64.MIN, 1 as Int64));
}

@test
fn test_would_mul_overflow_false() {
    assert(!would_mul_overflow(7 as Int64, 6 as Int64));
}

@test
fn test_would_mul_overflow_true() {
    assert(would_mul_overflow(Int64.MAX, 2 as Int64));
}

// =============================================================================
// SECTION 12: Add/Subtract with Carry/Borrow
// =============================================================================

@test
fn test_adc_no_carry_in() {
    let (result, carry_out) = adc(10 as UInt64, 20 as UInt64, false);
    assert_eq(result, 30 as UInt64);
    assert(!carry_out);
}

@test
fn test_adc_with_carry_in() {
    let (result, carry_out) = adc(10 as UInt64, 20 as UInt64, true);
    assert_eq(result, 31 as UInt64);
    assert(!carry_out);
}

@test
fn test_adc_overflow() {
    let (result, carry_out) = adc(UInt64.MAX, 1 as UInt64, false);
    assert_eq(result, 0 as UInt64);
    assert(carry_out);
}

@test
fn test_sbb_no_borrow_in() {
    let (result, borrow_out) = sbb(30 as UInt64, 10 as UInt64, false);
    assert_eq(result, 20 as UInt64);
    assert(!borrow_out);
}

@test
fn test_sbb_with_borrow_in() {
    let (result, borrow_out) = sbb(30 as UInt64, 10 as UInt64, true);
    assert_eq(result, 19 as UInt64);
    assert(!borrow_out);
}

@test
fn test_sbb_underflow() {
    let (_, borrow_out) = sbb(10 as UInt64, 20 as UInt64, false);
    assert(borrow_out);
}

