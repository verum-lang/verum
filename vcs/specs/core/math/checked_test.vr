// =============================================================================
// SECTION 9: Wrapping Operations
// =============================================================================

@test
fn test_wrapping_add_normal() {
    assert_eq(wrapping_add(10 as Int64, 20 as Int64), 30 as Int64);
}

@test
fn test_wrapping_add_overflow() {
    // MAX + 1 wraps to MIN
    assert_eq(wrapping_add(Int64.MAX, 1 as Int64), Int64.MIN);
}

@test
fn test_wrapping_sub_normal() {
    assert_eq(wrapping_sub(30 as Int64, 10 as Int64), 20 as Int64);
}

@test
fn test_wrapping_sub_underflow() {
    // MIN - 1 wraps to MAX
    assert_eq(wrapping_sub(Int64.MIN, 1 as Int64), Int64.MAX);
}

@test
fn test_wrapping_mul_normal() {
    assert_eq(wrapping_mul(7 as Int64, 6 as Int64), 42 as Int64);
}

@test
fn test_wrapping_neg_normal() {
    assert_eq(wrapping_neg42_i64, -42 as Int64);
}

@test
fn test_wrapping_neg_min() {
    // -MIN wraps back to MIN
    assert_eq(wrapping_neg(Int64.MIN), Int64.MIN);
}

