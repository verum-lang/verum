// =============================================================================
// SECTION: CheckedResult Method Tests
// =============================================================================

@test
fn test_checked_result_is_ok() {
    let ok_result = checked_add(1 as Int64, 2 as Int64);
    assert(ok_result.is_ok());
    assert(!ok_result.is_overflow());
}

@test
fn test_checked_result_is_overflow() {
    let overflow_result = checked_add(Int64.MAX, 1 as Int64);
    assert(!overflow_result.is_ok());
    assert(overflow_result.is_overflow());
}

@test
fn test_checked_result_unwrap_ok() {
    let result = checked_add(10 as Int64, 20 as Int64);
    assert_eq(result.unwrap(), 30 as Int64);
}

@test
fn test_checked_result_expect_ok() {
    let result = checked_add(5 as Int64, 7 as Int64);
    assert_eq(result.expect("should not overflow"), 12 as Int64);
}

@test
fn test_checked_result_unwrap_or_ok() {
    let result = checked_add(3 as Int64, 4 as Int64);
    assert_eq(result.unwrap_or0_i64, 7 as Int64);
}

@test
fn test_checked_result_unwrap_or_overflow() {
    let result = checked_add(Int64.MAX, 1 as Int64);
    assert_eq(result.unwrap_or0_i64, 0 as Int64);
}

fn make_fallback() -> Int64 {
    -1 as Int64
}

@test
fn test_checked_result_unwrap_or_else_ok() {
    let result = checked_add(1 as Int64, 1 as Int64);
    assert_eq(result.unwrap_or_else(make_fallback), 2 as Int64);
}

@test
fn test_checked_result_unwrap_or_else_overflow() {
    let result = checked_add(Int64.MAX, 1 as Int64);
    assert_eq(result.unwrap_or_else(make_fallback), -1 as Int64);
}

fn double_val(x: Int64) -> Int64 {
    x * 2
}

@test
fn test_checked_result_map_ok() {
    let result = checked_add(3 as Int64, 4 as Int64);
    let mapped = result.map(double_val);
    assert(mapped.is_ok());
    assert_eq(mapped.unwrap(), 14 as Int64);
}

@test
fn test_checked_result_map_overflow() {
    let result = checked_add(Int64.MAX, 1 as Int64);
    let mapped = result.map(double_val);
    assert(mapped.is_overflow());
}

fn add_ten_checked(x: Int64) -> CheckedResult<Int64> {
    checked_add(x, 10 as Int64)
}

@test
fn test_checked_result_and_then_ok() {
    let result = checked_add(5 as Int64, 3 as Int64);
    let chained = result.and_then(add_ten_checked);
    assert(chained.is_ok());
    assert_eq(chained.unwrap(), 18 as Int64);
}

@test
fn test_checked_result_and_then_first_overflow() {
    let result = checked_add(Int64.MAX, 1 as Int64);
    let chained = result.and_then(add_ten_checked);
    assert(chained.is_overflow());
}

@test
fn test_checked_result_and_then_second_overflow() {
    let result = checked_add(Int64.MAX - 5, 3 as Int64);
    // Result is Int64.MAX - 2, then add 10 should overflow
    let chained = result.and_then(add_ten_checked);
    assert(chained.is_overflow());
}

@test
fn test_checked_result_and_ok() {
    let a = checked_add(1 as Int64, 2 as Int64);
    let b = checked_mul(3 as Int64, 4 as Int64);
    let result = a.and(b);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 12 as Int64);
}

@test
fn test_checked_result_and_first_overflow() {
    let a = checked_add(Int64.MAX, 1 as Int64);
    let b = checked_mul(3 as Int64, 4 as Int64);
    let result = a.and(b);
    assert(result.is_overflow());
}

@test
fn test_checked_result_or_ok() {
    let a = checked_add(1 as Int64, 2 as Int64);
    let b = checked_mul(3 as Int64, 4 as Int64);
    let result = a.or(b);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 3 as Int64);
}

@test
fn test_checked_result_or_first_overflow() {
    let a = checked_add(Int64.MAX, 1 as Int64);
    let b = checked_mul(3 as Int64, 4 as Int64);
    let result = a.or(b);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 12 as Int64);
}

@test
fn test_checked_result_ok_conversion() {
    let result = checked_add(1 as Int64, 2 as Int64);
    let maybe_val = result.ok();
    assert(maybe_val.is_some());
}

@test
fn test_checked_result_ok_conversion_overflow() {
    let result = checked_add(Int64.MAX, 1 as Int64);
    let maybe_val = result.ok();
    assert(maybe_val.is_none());
}

// =============================================================================
// SECTION: Try Protocol Tests
// =============================================================================

/// Test that CheckedResult implements Try — chain operations with ?
fn chain_add_mul(a: Int64, b: Int64, c: Int64) -> CheckedResult<Int64> {
    let sum = checked_add(a, b).unwrap_or0_i64;
    checked_mul(sum, c)
}

@test
fn test_try_protocol_chain_ok() {
    // (3 + 4) * 5 = 35
    let result = chain_add_mul(3 as Int64, 4 as Int64, 5 as Int64);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 35 as Int64);
}

@test
fn test_try_protocol_chain_mul_overflow() {
    // (MAX/2 + MAX/2) * 2 should overflow on mul
    let result = chain_add_mul(Int64.MAX / 2, Int64.MAX / 2, 3 as Int64);
    // MAX/2 + MAX/2 = MAX - 1 (or MAX depending on rounding), * 3 overflows
    assert(result.is_overflow());
}

/// Multiple chained operations
fn triple_add(a: Int64, b: Int64, c: Int64) -> CheckedResult<Int64> {
    let ab = checked_add(a, b);
    match ab {
        CheckedResult.Ok(sum) => checked_add(sum, c),
        CheckedResult.Overflow => CheckedResult.Overflow,
    }
}

@test
fn test_triple_add_ok() {
    let result = triple_add(10 as Int64, 20 as Int64, 30 as Int64);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 60 as Int64);
}

@test
fn test_triple_add_overflow_first() {
    let result = triple_add(Int64.MAX, 1 as Int64, 1 as Int64);
    assert(result.is_overflow());
}

@test
fn test_triple_add_overflow_second() {
    let result = triple_add(Int64.MAX - 1, 1 as Int64, 1 as Int64);
    // MAX - 1 + 1 = MAX, then MAX + 1 overflows
    assert(result.is_overflow());
}

/// Test and_then chaining pattern
@test
fn test_and_then_chain() {
    let result = checked_add(10 as Int64, 20 as Int64)
        .and_then(|sum| checked_mul(sum, 3 as Int64));
    assert(result.is_ok());
    assert_eq(result.unwrap(), 90 as Int64);
}

@test
fn test_and_then_chain_overflow() {
    let result = checked_add(Int64.MAX, 1 as Int64)
        .and_then(|sum| checked_mul(sum, 3 as Int64));
    assert(result.is_overflow());
}

