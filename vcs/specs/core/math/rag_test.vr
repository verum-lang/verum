@test
fn test_hybrid_retriever_new() {
    let dense = HNSWVectorStore.with_defaults(128 as USize);
    let sparse = BM25Index.new();
    let retriever = HybridRetriever.new(dense, sparse);

    assert(retriever.dense_weight == 0.5);
    assert(retriever.rrf_k == 60.0);

    print("hybrid_retriever_new test passed");
}

@test
fn test_hybrid_retriever_with_dense_weight() {
    let dense = HNSWVectorStore.with_defaults(64 as USize);
    let sparse = BM25Index.new();
    let retriever = HybridRetriever.new(dense, sparse)
