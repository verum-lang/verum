// =============================================================================
// vcs/specs/core/math/rag_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L3
// @tags: stdlib, math, rag, retrieval, vector-store, chunking, bm25, hybrid
// @note: RAG module — types resolve for typecheck
// @description: Comprehensive tests for the RAG (Retrieval-Augmented Generation)
//               module which provides document chunking, vector storage, sparse
//               text search, and hybrid retrieval for LLM applications.
//
// Coverage:
// - Document: construction (.new, .with_metadata, .with_embedding), field access,
//   mutation (.add_metadata, .set_embedding), boolean queries (.has_embedding)
// - HNSWConfig: .default(), .with_m(), field verification
// - HNSWIndex: construction, .len(), .search(), .remove()
// - HNSWVectorStore: .new(), .with_defaults()
// - VectorStore protocol: method signatures
// - ChunkStrategy sum type: all 4 variants (FixedSize, Separator, Recursive, Sentence)
// - TextChunker: .new(), .with_separator(), .chunk()
// - RAGPipeline: generic construction, builder pattern
// - SparseIndex protocol: method signatures
// - BM25Config: .default(), field verification
// - BM25Index: .new(), SparseIndex protocol impl
// - HybridRetriever: generic construction, .with_dense_weight()
//
// Test Strategy:
// - Constructor verification for all public types
// - Method existence and return type validation
// - Sum type variant construction and pattern matching
// - Builder pattern chain verification
// - Protocol implementation verification
// - Generic type parameter constraint checking
// =============================================================================

module test.stdlib.math.rag_test;

mount core.math.rag.{
    Document, VectorStore, HNSWConfig, HNSWIndex, HNSWVectorStore,
    ChunkStrategy, TextChunker, RAGPipeline,
    SparseIndex, BM25Config, BM25Index, HybridRetriever,
};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// Document Construction Tests
// =============================================================================

@test
fn test_document_new() {
    let doc = Document.new("doc1", "Hello world");
    assert(doc.id == "doc1");
    assert(doc.content == "Hello world");

    print("document_new test passed");
}

@test
fn test_document_new_empty_content() {
    let doc = Document.new("empty", "");
    assert(doc.id == "empty");
    assert(doc.content == "");

    print("document_new_empty_content test passed");
}

@test
fn test_document_with_metadata() {
    let metadata: Map<Text, Value> = Map.new();
    let doc = Document.with_metadata("doc2", "Some content", metadata);
    assert(doc.id == "doc2");
    assert(doc.content == "Some content");

    print("document_with_metadata test passed");
}

@test
fn test_document_with_metadata_empty_map() {
    let doc = Document.with_metadata("doc3", "Content here", Map.new());
    assert(doc.id == "doc3");

    print("document_with_metadata_empty_map test passed");
}

@test
fn test_document_has_embedding_false() {
    let doc = Document.new("doc4", "No embedding");
    assert(!doc.has_embedding());

    print("document_has_embedding_false test passed");
}

@test
fn test_document_has_embedding_with_metadata_false() {
    let doc = Document.with_metadata("doc5", "Also no embedding", Map.new());
    assert(!doc.has_embedding());

    print("document_has_embedding_with_metadata_false test passed");
}

@test
fn test_document_id_access() {
    let doc = Document.new("unique-id-123", "Test content");
    let id: Text = doc.id;
    assert(id.len() > 0);
    assert(id == "unique-id-123");

    print("document_id_access test passed");
}

@test
fn test_document_content_access() {
    let content_text = "This is a longer piece of content for testing";
    let doc = Document.new("doc6", content_text);
    assert(doc.content == content_text);
    assert(doc.content.len() > 0);

    print("document_content_access test passed");
}

@test
fn test_document_metadata_initially_empty() {
    let doc = Document.new("doc7", "Content");
    assert(doc.metadata.len() == 0);

    print("document_metadata_initially_empty test passed");
}

@test
fn test_document_embedding_initially_none() {
    let doc = Document.new("doc8", "Content");
    assert(doc.embedding.is_none());

    print("document_embedding_initially_none test passed");
}

