@test
fn test_document_metadata_map_type() {
    let doc = Document.new("type_test", "Content");
    let metadata: Map<Text, Value> = doc.metadata;
    assert(metadata.len() == 0);

    print("document_metadata_map_type test passed");
}

@test
fn test_document_embedding_maybe_type() {
    let doc = Document.new("maybe_test", "Content");
    let embedding: Maybe<DynTensor<Float>> = doc.embedding;
    assert(embedding.is_none());

    print("document_embedding_maybe_type test passed");
}

// =============================================================================
// Edge Case Tests
// =============================================================================

@test
fn test_document_with_long_id() {
    let long_id = "a".repeat(1000);
    let doc = Document.new(long_id, "Content");
    assert(doc.id.len() == 1000);

    print("document_with_long_id test passed");
}

@test
fn test_document_with_long_content() {
    let long_content = "word ".repeat(10000);
    let doc = Document.new("long_doc", long_content);
    assert(doc.content.len() > 0);

    print("document_with_long_content test passed");
}

@test
fn test_text_chunker_small_chunk_size() {
    let chunker = TextChunker.new(10 as USize, 2 as USize);
    assert(chunker.chunk_size == 10);
    assert(chunker.chunk_overlap == 2);

    print("text_chunker_small_chunk_size test passed");
}

@test
fn test_hnsw_index_different_dimensions() {
    let idx_small = HNSWIndex.new(2 as USize, 4 as USize, 50 as USize);
    let idx_medium = HNSWIndex.new(128 as USize, 16 as USize, 200 as USize);
    let idx_large = HNSWIndex.new(1024 as USize, 32 as USize, 400 as USize);

    assert(idx_small.dim == 2);
    assert(idx_medium.dim == 128);
    assert(idx_large.dim == 1024);

    print("hnsw_index_different_dimensions test passed");
}

@test
fn test_bm25_config_edge_values() {
    let config = BM25Config { k1: 0.0, b: 0.0 };
    assert(config.k1 == 0.0);
    assert(config.b == 0.0);

    let config2 = BM25Config { k1: 3.0, b: 1.0 };
    assert(config2.k1 == 3.0);
    assert(config2.b == 1.0);

    print("bm25_config_edge_values test passed");
}

// =============================================================================
// Protocol Implementation Verification
// =============================================================================

@test
fn test_hnsw_vector_store_implements_vector_store() {
    // Verify HNSWVectorStore can be used where VectorStore is expected
    let store = HNSWVectorStore.with_defaults(128 as USize);

    // These methods come from VectorStore protocol
    let _count: USize = store.count();

    print("hnsw_vector_store_implements_vector_store test passed");
}

@test
fn test_bm25_index_implements_sparse_index() {
    // Verify BM25Index can be used where SparseIndex is expected
    let index = BM25Index.new();

    // These methods come from SparseIndex protocol
    let _count: USize = index.count();

    print("bm25_index_implements_sparse_index test passed");
}

// =============================================================================
// Comprehensive Construction Tests
// =============================================================================

@test
fn test_all_chunk_strategies_constructible() {
    // Verify all ChunkStrategy variants can be constructed
    let strategies: List<ChunkStrategy> = List.new();

    let s1 = ChunkStrategy.FixedSize { size: 100 as USize, overlap: 10 as USize };
    let s2 = ChunkStrategy.Separator { separator: "\n", max_size: 500 as USize };
    let s3 = ChunkStrategy.Recursive { separators: List.new(), max_size: 500 as USize };
    let s4 = ChunkStrategy.Sentence { max_sentences: 3 as USize };

    // All should be ChunkStrategy type
    let _ = s1;
    let _ = s2;
    let _ = s3;
    let _ = s4;

    print("all_chunk_strategies_constructible test passed");
}

@test
fn test_all_record_types_constructible() {
    // Verify all public record types can be constructed via their constructors
    let _doc = Document.new("id", "content");
    let _config = HNSWConfig.default();
    let _index = HNSWIndex.new(64 as USize, 16 as USize, 200 as USize);
    let _store = HNSWVectorStore.with_defaults(64 as USize);
    let _chunker = TextChunker.new(512 as USize, 50 as USize);
    let _bm25_config = BM25Config.default();
    let _bm25_index = BM25Index.new();

    print("all_record_types_constructible test passed");
}

@test
fn test_hybrid_retriever_generic_instantiation() {
    // Verify HybridRetriever generic type resolves with concrete implementations
    let retriever: HybridRetriever<HNSWVectorStore, BM25Index> =
        HybridRetriever.new(
            HNSWVectorStore.with_defaults(128 as USize),
            BM25Index.new(),
        );

    assert(retriever.dense_weight == 0.5);

    print("hybrid_retriever_generic_instantiation test passed");
}
