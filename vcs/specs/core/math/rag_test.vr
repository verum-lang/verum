// =============================================================================
// ChunkStrategy Sum Type Tests
// =============================================================================

@test
fn test_chunk_strategy_fixed_size() {
    let strategy = ChunkStrategy.FixedSize {
        size: 512 as USize,
        overlap: 50 as USize,
    };
    assert(strategy is ChunkStrategy.FixedSize);

    print("chunk_strategy_fixed_size test passed");
}

@test
fn test_chunk_strategy_fixed_size_no_overlap() {
    let strategy = ChunkStrategy.FixedSize {
        size: 1000 as USize,
        overlap: 0 as USize,
    };
    assert(strategy is ChunkStrategy.FixedSize);

    print("chunk_strategy_fixed_size_no_overlap test passed");
}

@test
fn test_chunk_strategy_separator() {
    let strategy = ChunkStrategy.Separator {
        separator: "\n\n",
        max_size: 1024 as USize,
    };
    assert(strategy is ChunkStrategy.Separator);

    print("chunk_strategy_separator test passed");
}

@test
fn test_chunk_strategy_separator_custom() {
    let strategy = ChunkStrategy.Separator {
        separator: "---",
        max_size: 2048 as USize,
    };
    assert(strategy is ChunkStrategy.Separator);

    print("chunk_strategy_separator_custom test passed");
}

@test
fn test_chunk_strategy_recursive() {
    let separators = List.from(&["\n\n", "\n", ". ", " "]);
    let strategy = ChunkStrategy.Recursive {
        separators,
        max_size: 512 as USize,
    };
    assert(strategy is ChunkStrategy.Recursive);

    print("chunk_strategy_recursive test passed");
}

@test
fn test_chunk_strategy_sentence() {
    let strategy = ChunkStrategy.Sentence {
        max_sentences: 5 as USize,
    };
    assert(strategy is ChunkStrategy.Sentence);

    print("chunk_strategy_sentence test passed");
}

@test
fn test_chunk_strategy_sentence_single() {
    let strategy = ChunkStrategy.Sentence {
        max_sentences: 1 as USize,
    };
    assert(strategy is ChunkStrategy.Sentence);

    print("chunk_strategy_sentence_single test passed");
}

@test
fn test_chunk_strategy_variant_discrimination() {
    let fixed = ChunkStrategy.FixedSize { size: 100 as USize, overlap: 10 as USize };
    let sep = ChunkStrategy.Separator { separator: "\n", max_size: 200 as USize };
    let rec = ChunkStrategy.Recursive { separators: List.new(), max_size: 300 as USize };
    let sent = ChunkStrategy.Sentence { max_sentences: 3 as USize };

    assert(fixed is ChunkStrategy.FixedSize);
    assert(!(fixed is ChunkStrategy.Separator));
    assert(!(fixed is ChunkStrategy.Recursive));
    assert(!(fixed is ChunkStrategy.Sentence));

    assert(sep is ChunkStrategy.Separator);
    assert(!(sep is ChunkStrategy.FixedSize));

    assert(rec is ChunkStrategy.Recursive);
    assert(!(rec is ChunkStrategy.Sentence));

    assert(sent is ChunkStrategy.Sentence);
    assert(!(sent is ChunkStrategy.Recursive));

    print("chunk_strategy_variant_discrimination test passed");
}

// =============================================================================
// TextChunker Tests
// =============================================================================

@test
fn test_text_chunker_new() {
    let chunker = TextChunker.new(512 as USize, 50 as USize);
    assert(chunker.chunk_size == 512);
    assert(chunker.chunk_overlap == 50);

    print("text_chunker_new test passed");
}

@test
fn test_text_chunker_new_no_overlap() {
    let chunker = TextChunker.new(1000 as USize, 0 as USize);
    assert(chunker.chunk_size == 1000);
    assert(chunker.chunk_overlap == 0);

    print("text_chunker_new_no_overlap test passed");
}

@test
fn test_text_chunker_new_large() {
    let chunker = TextChunker.new(4096 as USize, 256 as USize);
    assert(chunker.chunk_size == 4096);
    assert(chunker.chunk_overlap == 256);

    print("text_chunker_new_large test passed");
}

@test
fn test_text_chunker_with_separator() {
    let chunker = TextChunker.with_separator(512 as USize, 50 as USize, "\n");
    assert(chunker.chunk_size == 512);
    assert(chunker.chunk_overlap == 50);
    assert(chunker.separator == "\n");

    print("text_chunker_with_separator test passed");
}

@test
fn test_text_chunker_with_separator_custom() {
    let chunker = TextChunker.with_separator(1024 as USize, 100 as USize, "---");
    assert(chunker.separator == "---");

    print("text_chunker_with_separator_custom test passed");
}

@test
fn test_text_chunker_default_separator() {
    let chunker = TextChunker.new(512 as USize, 50 as USize);
    assert(chunker.separator == "\n\n");

    print("text_chunker_default_separator test passed");
}

@test
fn test_text_chunker_chunk_empty_text() {
    let chunker = TextChunker.new(100 as USize, 10 as USize);
    let chunks = chunker.chunk(&"");
    // Empty text should produce no chunks or one empty chunk
    let chunk_count: Int = chunks.len();
    assert(chunk_count >= 0);

    print("text_chunker_chunk_empty_text test passed");
}

@test
fn test_text_chunker_chunk_short_text() {
    let chunker = TextChunker.new(1000 as USize, 100 as USize);
    let text = "This is a short text that fits in one chunk.";
    let chunks = chunker.chunk(&text);
    assert(chunks.len() >= 1);

    print("text_chunker_chunk_short_text test passed");
}

@test
fn test_text_chunker_chunk_returns_list() {
    let chunker = TextChunker.new(50 as USize, 10 as USize);
    let text = "First paragraph.\n\nSecond paragraph.\n\nThird paragraph.";
    let chunks: List<Text> = chunker.chunk(&text);
    assert(chunks.len() > 0);

    print("text_chunker_chunk_returns_list test passed");
}

@test
fn test_text_chunker_field_types() {
    let chunker = TextChunker.new(256 as USize, 32 as USize);
    let size: USize = chunker.chunk_size;
    let overlap: USize = chunker.chunk_overlap;
    let sep: Text = chunker.separator;

    assert(size > 0);
    assert(overlap < size);
    assert(sep.len() > 0);

    print("text_chunker_field_types test passed");
}

