    let doc = Document.new("doc_embed", "Document for embedding");
    // Before setting embedding
    assert(!doc.has_embedding());
    assert(doc.embedding.is_none());

    print("document_set_embedding_changes_has_embedding test passed");
}

// =============================================================================
// Multiple Document Construction Tests
// =============================================================================

@test
fn test_multiple_documents() {
    let doc1 = Document.new("id1", "First document content");
    let doc2 = Document.new("id2", "Second document content");
    let doc3 = Document.new("id3", "Third document content");

    assert(doc1.id != doc2.id);
    assert(doc2.id != doc3.id);
    assert(doc1.id != doc3.id);

    assert(doc1.content != doc2.content);

    print("multiple_documents test passed");
}

@test
fn test_document_list() {
    let docs: List<Document> = List.new();
    assert(docs.len() == 0);

    print("document_list test passed");
}

@test
fn test_document_in_list() {
    let mut docs: List<Document> = List.new();
    docs.push(Document.new("a", "Alpha"));
    docs.push(Document.new("b", "Beta"));
    docs.push(Document.new("c", "Gamma"));
    assert(docs.len() == 3);

    print("document_in_list test passed");
}

// =============================================================================
// Config Comparison Tests
// =============================================================================

@test
fn test_hnsw_config_default_vs_with_m_16() {
    let default_config = HNSWConfig.default();
    let custom_config = HNSWConfig.with_m(16 as USize);

    // Both should have m=16
    assert(default_config.m == custom_config.m);
    assert(default_config.ef_construction == custom_config.ef_construction);
    assert(default_config.ef_search == custom_config.ef_search);
    assert(default_config.max_level == custom_config.max_level);

    print("hnsw_config_default_vs_with_m_16 test passed");
}

@test
fn test_hnsw_config_various_m_values() {
    let c4 = HNSWConfig.with_m(4 as USize);
    let c8 = HNSWConfig.with_m(8 as USize);
    let c16 = HNSWConfig.with_m(16 as USize);
    let c32 = HNSWConfig.with_m(32 as USize);

    assert(c4.m < c8.m);
    assert(c8.m < c16.m);
    assert(c16.m < c32.m);

    print("hnsw_config_various_m_values test passed");
}

// =============================================================================
// BM25 Integration Tests
// =============================================================================

@test
fn test_bm25_index_add_document() {
    let mut index = BM25Index.new();
    let doc = Document.new("bm25_doc1", "Hello world this is a test document");
    // SparseIndex protocol: add takes &Document
    index.add(&doc);
    assert(index.documents.len() == 1);
    assert(index.doc_lengths.len() == 1);

    print("bm25_index_add_document test passed");
}

@test
fn test_bm25_index_add_multiple_documents() {
    let mut index = BM25Index.new();
    index.add(&Document.new("d1", "First document about cats"));
    index.add(&Document.new("d2", "Second document about dogs"));
    index.add(&Document.new("d3", "Third document about birds"));

    assert(index.documents.len() == 3);
    assert(index.doc_lengths.len() == 3);
    assert(index.avg_doc_length > 0.0);

    print("bm25_index_add_multiple_documents test passed");
}

@test
fn test_bm25_index_search_empty() {
    let index = BM25Index.new();
    let results = index.search(&"query", 5 as USize);
    assert(results.len() == 0);

    print("bm25_index_search_empty test passed");
}

@test
fn test_bm25_index_search_returns_list() {
    let mut index = BM25Index.new();
    index.add(&Document.new("d1", "machine learning deep neural network"));
    index.add(&Document.new("d2", "natural language processing text"));

    let results: List<(Document, Float)> = index.search(&"machine learning", 5 as USize);
    // Results should contain matches
    assert(results.len() >= 0);

    print("bm25_index_search_returns_list test passed");
}

@test
fn test_bm25_index_count() {
    let mut index = BM25Index.new();
    assert(index.count() == 0);

    index.add(&Document.new("d1", "content one"));
    assert(index.count() == 1);

    index.add(&Document.new("d2", "content two"));
    assert(index.count() == 2);

    print("bm25_index_count test passed");
}

// =============================================================================
// VectorStore Protocol Verification
// =============================================================================

@test
fn test_hnsw_vector_store_count_method() {
    let store = HNSWVectorStore.with_defaults(128 as USize);
    let count: USize = store.count();
    assert(count == 0);

    print("hnsw_vector_store_count_method test passed");
}

@test
fn test_hnsw_vector_store_delete_empty() {
    let mut store = HNSWVectorStore.with_defaults(128 as USize);
    let ids: List<Text> = List.new();
    store.delete(&ids);
    assert(store.count() == 0);

    print("hnsw_vector_store_delete_empty test passed");
}

// =============================================================================
// HybridRetriever with BM25 and HNSW Tests
// =============================================================================

@test
fn test_hybrid_retriever_add_document_to_sparse() {
    let dense = HNSWVectorStore.with_defaults(128 as USize);
    let sparse = BM25Index.new();
    let mut retriever = HybridRetriever.new(dense, sparse);

    let doc = Document.new("hybrid1", "Test document for hybrid search");
    retriever.add(&doc);

    // Document should be added to sparse index (no embedding, so not in dense)
    assert(retriever.count() == 1);

    print("hybrid_retriever_add_document_to_sparse test passed");
}

@test
fn test_hybrid_retriever_weight_bounds() {
    let dense = HNSWVectorStore.with_defaults(64 as USize);
    let sparse = BM25Index.new();

    // Test various valid weights
    let r1 = HybridRetriever.new(dense, sparse).with_dense_weight(0.0);
    assert(r1.dense_weight == 0.0);

    let dense2 = HNSWVectorStore.with_defaults(64 as USize);
    let sparse2 = BM25Index.new();
    let r2 = HybridRetriever.new(dense2, sparse2).with_dense_weight(0.5);
    assert(r2.dense_weight == 0.5);

    let dense3 = HNSWVectorStore.with_defaults(64 as USize);
    let sparse3 = BM25Index.new();
    let r3 = HybridRetriever.new(dense3, sparse3).with_dense_weight(1.0);
    assert(r3.dense_weight == 1.0);

    print("hybrid_retriever_weight_bounds test passed");
}

// =============================================================================
// TextChunker with Documents Tests
// =============================================================================

@test
fn test_text_chunker_chunk_multiline() {
    let chunker = TextChunker.new(100 as USize, 20 as USize);
    let text = "First paragraph of text.\n\nSecond paragraph of text.\n\nThird paragraph of text.";
    let chunks = chunker.chunk(&text);

    // Should produce at least one chunk
    assert(chunks.len() > 0);

    // Each chunk should be non-empty
    for chunk in &chunks {
        assert(chunk.len() > 0);
    }

    print("text_chunker_chunk_multiline test passed");
}

@test
fn test_text_chunker_chunk_single_paragraph() {
    let chunker = TextChunker.new(10000 as USize, 100 as USize);
    let text = "This is a single paragraph with no separators.";
    let chunks = chunker.chunk(&text);

    // Short text with large chunk size should produce exactly 1 chunk
    assert(chunks.len() == 1);
    assert(chunks[0] == text);

    print("text_chunker_chunk_single_paragraph test passed");
}

@test
fn test_text_chunker_with_separator_newline() {
    let chunker = TextChunker.with_separator(200 as USize, 20 as USize, "\n");
    let text = "Line one\nLine two\nLine three\nLine four";
    let chunks = chunker.chunk(&text);
    assert(chunks.len() > 0);

    print("text_chunker_with_separator_newline test passed");
}

