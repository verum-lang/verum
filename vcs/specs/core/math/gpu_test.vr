@test
fn test_device_info_as_gpu_on_cpu() {
    let info = DeviceInfo.Cpu(CpuInfo.default());
    let result = info.as_gpu();
    assert(result is None);
}

@test
fn test_device_info_as_cpu_on_gpu() {
    let gpu = GpuInfo {
        name: "Test",
        vendor: Vendor.Nvidia,
