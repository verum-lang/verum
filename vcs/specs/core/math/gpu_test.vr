// =============================================================================
// gpu_test.vr - Tests for GPU/accelerator compute module
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: math, gpu, device, compute, memory, kernel, stream
// @description: Tests for GPUBackend, Vendor, DeviceId, ComputeCapability,
//               CpuInfo, MemorySpace, Dim3, LaunchConfig, TransferDirection,
//               DeviceSelection, DeviceSelector, DeviceInfo, and MemoryInfo.
// =============================================================================

mount core.math.gpu.{
    GPUBackend, Vendor, DeviceId, ComputeCapability,
    CpuInfo, GpuInfo, DeviceInfo, DeviceSelection, DeviceSelector,
    MemorySpace, Dim3, LaunchConfig, TransferDirection,
    StreamHandle, EventHandle, MemoryInfo,
    GPUDevice, CPUDevice,
};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: GPUBackend Variants
// =============================================================================

@test
fn test_gpu_backend_cuda() {
    let b = GPUBackend.CUDA;
    assert(b is GPUBackend.CUDA);
}

@test
fn test_gpu_backend_rocm() {
    let b = GPUBackend.ROCm;
    assert(b is GPUBackend.ROCm);
}

@test
fn test_gpu_backend_metal() {
    let b = GPUBackend.Metal;
    assert(b is GPUBackend.Metal);
}

@test
fn test_gpu_backend_vulkan() {
    let b = GPUBackend.Vulkan;
    assert(b is GPUBackend.Vulkan);
}

@test
fn test_gpu_backend_sycl() {
    let b = GPUBackend.SYCL;
    assert(b is GPUBackend.SYCL);
}

@test
fn test_gpu_backend_none() {
    let b = GPUBackend.None;
    assert(b is GPUBackend.None);
}

@test
fn test_gpu_backend_eq() {
    assert_eq(GPUBackend.CUDA, GPUBackend.CUDA);
    assert_eq(GPUBackend.Metal, GPUBackend.Metal);
    assert_eq(GPUBackend.None, GPUBackend.None);
}

@test
fn test_gpu_backend_neq() {
    assert(GPUBackend.CUDA != GPUBackend.ROCm);
    assert(GPUBackend.Metal != GPUBackend.Vulkan);
    assert(GPUBackend.SYCL != GPUBackend.None);
}

