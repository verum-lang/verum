// =============================================================================
// Section 23: MemorySpace Exhaustive & Distinctness
// =============================================================================

@test
fn test_memory_space_match_exhaustive() {
    let mut count = 0;
    let m1 = MemorySpace.Host;
    match m1 { MemorySpace.Host => { count = count + 1; }, _ => {} }
    let m2 = MemorySpace.HostPinned;
    match m2 { MemorySpace.HostPinned => { count = count + 1; }, _ => {} }
    let m3 = MemorySpace.Global;
    match m3 { MemorySpace.Global => { count = count + 1; }, _ => {} }
    let m4 = MemorySpace.Shared;
    match m4 { MemorySpace.Shared => { count = count + 1; }, _ => {} }
    let m5 = MemorySpace.Local;
    match m5 { MemorySpace.Local => { count = count + 1; }, _ => {} }
    let m6 = MemorySpace.Constant;
    match m6 { MemorySpace.Constant => { count = count + 1; }, _ => {} }
    let m7 = MemorySpace.Texture;
    match m7 { MemorySpace.Texture => { count = count + 1; }, _ => {} }
    let m8 = MemorySpace.Unified;
    match m8 { MemorySpace.Unified => { count = count + 1; }, _ => {} }
    assert_eq(count, 8);
}

@test
fn test_memory_space_host_not_unified() {
    let ms = MemorySpace.Host;
    assert(!ms.is_unified());
}

@test
fn test_memory_space_host_pinned_not_unified() {
    let ms = MemorySpace.HostPinned;
    assert(!ms.is_unified());
}

@test
fn test_memory_space_global_not_host_or_unified() {
    let ms = MemorySpace.Global;
    assert(!ms.is_host());
    assert(!ms.is_unified());
    assert(ms.is_device());
}

@test
fn test_memory_space_shared_not_host_or_unified() {
    let ms = MemorySpace.Shared;
    assert(!ms.is_host());
    assert(!ms.is_unified());
}

@test
fn test_memory_space_local_not_host_or_unified() {
    let ms = MemorySpace.Local;
    assert(!ms.is_host());
    assert(!ms.is_unified());
}

@test
fn test_memory_space_constant_not_host_or_unified() {
    let ms = MemorySpace.Constant;
    assert(!ms.is_host());
    assert(!ms.is_unified());
}

@test
fn test_memory_space_texture_not_host_or_unified() {
    let ms = MemorySpace.Texture;
    assert(!ms.is_host());
    assert(!ms.is_unified());
}

