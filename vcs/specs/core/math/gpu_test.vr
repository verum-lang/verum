// =============================================================================
// Section 3: DeviceId Construction and Methods
// =============================================================================

@test
fn test_device_id_cpu() {
    let id = DeviceId.cpu();
    assert(id.is_cpu());
    assert(!id.is_gpu());
    assert(!id.is_tpu());
}

@test
fn test_device_id_gpu() {
    let id = DeviceId.gpu(0 as U16);
    assert(id.is_gpu());
    assert(!id.is_cpu());
    assert(!id.is_tpu());
}

@test
fn test_device_id_gpu_index() {
    let id = DeviceId.gpu(3 as U16);
    assert(id.is_gpu());
    assert_eq(id.device_index(), 3 as U16);
}

@test
fn test_device_id_tpu() {
    let id = DeviceId.tpu(0 as U16);
    assert(id.is_tpu());
    assert(!id.is_cpu());
    assert(!id.is_gpu());
}

@test
fn test_device_id_tpu_index() {
    let id = DeviceId.tpu(5 as U16);
    assert_eq(id.device_index(), 5 as U16);
}

@test
fn test_device_id_cpu_index() {
    let id = DeviceId.cpu();
    assert_eq(id.device_index(), 0 as U16);
}

@test
fn test_device_id_eq() {
    assert_eq(DeviceId.cpu(), DeviceId.cpu());
    assert_eq(DeviceId.gpu(0 as U16), DeviceId.gpu(0 as U16));
    assert_eq(DeviceId.gpu(1 as U16), DeviceId.gpu(1 as U16));
}

@test
fn test_device_id_neq() {
    assert(DeviceId.cpu() != DeviceId.gpu(0 as U16));
    assert(DeviceId.gpu(0 as U16) != DeviceId.gpu(1 as U16));
    assert(DeviceId.gpu(0 as U16) != DeviceId.tpu(0 as U16));
}

@test
fn test_device_id_raw() {
    let cpu = DeviceId.cpu();
    let _raw: U16 = cpu.raw();
    assert(cpu.raw() == (0 as U16));
}

// =============================================================================
// Section 4: ComputeCapability
// =============================================================================

@test
fn test_compute_capability_default() {
    let cc = ComputeCapability.default();
    assert_eq(cc.major, 0 as U32);
    assert_eq(cc.minor, 0 as U32);
    assert(!cc.tensor_cores);
    assert(!cc.fp16);
    assert(!cc.bf16);
}

@test
fn test_compute_capability_volta() {
    let cc = ComputeCapability.volta();
    assert_eq(cc.major, 7 as U32);
    assert_eq(cc.minor, 0 as U32);
    assert(cc.tensor_cores);
    assert(cc.fp16);
    assert(!cc.bf16);
}

@test
fn test_compute_capability_ampere() {
    let cc = ComputeCapability.ampere();
    assert_eq(cc.major, 8 as U32);
    assert_eq(cc.minor, 0 as U32);
    assert(cc.tensor_cores);
    assert(cc.fp16);
    assert(cc.bf16);
    assert(cc.async_copy);
    assert(!cc.tma);
}

@test
fn test_compute_capability_hopper() {
    let cc = ComputeCapability.hopper();
    assert_eq(cc.major, 9 as U32);
    assert_eq(cc.minor, 0 as U32);
    assert(cc.tensor_cores);
    assert(cc.fp16);
    assert(cc.bf16);
    assert(cc.async_copy);
    assert(cc.tma);
}

@test
fn test_compute_capability_sm_version() {
    let volta = ComputeCapability.volta();
    assert_eq(volta.sm_version(), 70 as U32);

    let ampere = ComputeCapability.ampere();
    assert_eq(ampere.sm_version(), 80 as U32);

    let hopper = ComputeCapability.hopper();
    assert_eq(hopper.sm_version(), 90 as U32);
}

@test
fn test_compute_capability_at_least() {
    let hopper = ComputeCapability.hopper();
    assert(hopper.at_least(7 as U32, 0 as U32));  // >= Volta
    assert(hopper.at_least(8 as U32, 0 as U32));  // >= Ampere
    assert(hopper.at_least(9 as U32, 0 as U32));  // >= Hopper
    assert(!hopper.at_least(10 as U32, 0 as U32)); // < future
}

@test
fn test_compute_capability_at_least_minor() {
    let cc = ComputeCapability {
        major: 8 as U32,
        minor: 6 as U32,
        ..ComputeCapability.default()
    };
    assert(cc.at_least(8 as U32, 0 as U32));
    assert(cc.at_least(8 as U32, 6 as U32));
    assert(!cc.at_least(8 as U32, 7 as U32));
    assert(!cc.at_least(9 as U32, 0 as U32));
}

// =============================================================================
// Section 5: CpuInfo
// =============================================================================

@test
fn test_cpu_info_default() {
    let info = CpuInfo.default();
    assert_eq(info.cores, 1 as USize);
    assert_eq(info.threads, 1 as USize);
    assert(!info.has_avx2);
    assert(!info.has_neon);
}

@test
fn test_cpu_info_simd_width_no_simd() {
    let info = CpuInfo.default();
    assert_eq(info.simd_width(), 8 as USize);
}

@test
fn test_cpu_info_simd_width_sse42() {
    let mut info = CpuInfo.default();
    info.has_sse42 = true;
    assert_eq(info.simd_width(), 16 as USize);
}

@test
fn test_cpu_info_simd_width_avx2() {
    let mut info = CpuInfo.default();
    info.has_avx2 = true;
    assert_eq(info.simd_width(), 32 as USize);
}

@test
fn test_cpu_info_simd_width_avx512() {
    let mut info = CpuInfo.default();
    info.has_avx512f = true;
    assert_eq(info.simd_width(), 64 as USize);
}

@test
fn test_cpu_info_simd_width_neon() {
    let mut info = CpuInfo.default();
    info.has_neon = true;
    assert_eq(info.simd_width(), 16 as USize);
}

