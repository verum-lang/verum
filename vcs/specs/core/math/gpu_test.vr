@test
fn test_memory_space_host() {
    let ms = MemorySpace.Host;
    assert(ms.is_host());
    assert(!ms.is_device());
    assert(!ms.is_unified());
}

@test
fn test_memory_space_host_pinned() {
    let ms = MemorySpace.HostPinned;
    assert(ms.is_host());
    assert(!ms.is_device());
}

@test
fn test_memory_space_global() {
    let ms = MemorySpace.Global;
    assert(ms.is_device());
    assert(!ms.is_host());
}

@test
fn test_memory_space_shared() {
    let ms = MemorySpace.Shared;
    assert(ms.is_device());
}

@test
fn test_memory_space_local() {
    let ms = MemorySpace.Local;
    assert(ms.is_device());
}

@test
fn test_memory_space_constant() {
    let ms = MemorySpace.Constant;
    assert(ms.is_device());
}

@test
fn test_memory_space_texture() {
    let ms = MemorySpace.Texture;
    assert(ms.is_device());
}

@test
fn test_memory_space_unified() {
    let ms = MemorySpace.Unified;
    assert(ms.is_unified());
    assert(!ms.is_host());
    assert(!ms.is_device());
}

// =============================================================================
// Section 7: Dim3 Construction and Methods
// =============================================================================

@test
fn test_dim3_new() {
    let d = Dim3.new(4 as U32, 8 as U32, 2 as U32);
    assert_eq(d.x, 4 as U32);
    assert_eq(d.y, 8 as U32);
    assert_eq(d.z, 2 as U32);
}

@test
fn test_dim3_d1() {
    let d = Dim3.d1(256 as U32);
    assert_eq(d.x, 256 as U32);
    assert_eq(d.y, 1 as U32);
    assert_eq(d.z, 1 as U32);
}

@test
fn test_dim3_d2() {
    let d = Dim3.d2(16 as U32, 16 as U32);
    assert_eq(d.x, 16 as U32);
    assert_eq(d.y, 16 as U32);
    assert_eq(d.z, 1 as U32);
}

@test
fn test_dim3_total() {
    let d = Dim3.new(4 as U32, 8 as U32, 2 as U32);
    assert_eq(d.total(), 64 as USize);
}

@test
fn test_dim3_d1_total() {
    let d = Dim3.d1(1024 as U32);
    assert_eq(d.total(), 1024 as USize);
}

@test
fn test_dim3_d2_total() {
    let d = Dim3.d2(32 as U32, 32 as U32);
    assert_eq(d.total(), 1024 as USize);
}

// =============================================================================
// Section 8: LaunchConfig
// =============================================================================

@test
fn test_launch_config_default() {
    let config = LaunchConfig.default();
    assert_eq(config.grid.x, 1 as U32);
    assert_eq(config.block.x, 256 as U32);
    assert_eq(config.shared_mem, 0 as USize);
}

@test
fn test_launch_config_for_elements() {
    let config = LaunchConfig.for_elements(1024 as USize, 256 as U32);
    assert_eq(config.block.x, 256 as U32);
    assert_eq(config.grid.x, 4 as U32);  // 1024 / 256
}

@test
fn test_launch_config_for_elements_non_divisible() {
    let config = LaunchConfig.for_elements(1000 as USize, 256 as U32);
    assert_eq(config.grid.x, 4 as U32);  // ceil(1000/256) = 4
}

@test
fn test_launch_config_for_matrix() {
    let config = LaunchConfig.for_matrix(512 as USize, 512 as USize, 16 as U32, 16 as U32);
    assert_eq(config.block.x, 16 as U32);
    assert_eq(config.block.y, 16 as U32);
    assert_eq(config.grid.x, 32 as U32);  // 512/16
    assert_eq(config.grid.y, 32 as U32);
}

@test
fn test_launch_config_total_threads() {
    let config = LaunchConfig.for_elements(1024 as USize, 256 as U32);
    assert_eq(config.total_threads(), 1024 as USize);
}

@test
fn test_launch_config_total_threads_matrix() {
    let config = LaunchConfig.for_matrix(64 as USize, 64 as USize, 16 as U32, 16 as U32);
    let grid_total = config.grid.total();
    let block_total = config.block.total();
    assert_eq(config.total_threads(), grid_total * block_total);
}

