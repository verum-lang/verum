// =============================================================================
// Section 27: MemoryInfo Extended
// =============================================================================

@test
fn test_memory_info_used_calculation() {
    let four_gb = (4 * 1024 * 1024 * 1024) as USize;
    let eight_gb = (8 * 1024 * 1024 * 1024) as USize;
    let info = MemoryInfo {
        free: four_gb,
        total: eight_gb,
    };
    let used = info.total - info.free;
    assert_eq(used, four_gb);
}

@test
fn test_memory_info_all_free() {
    let sixteen_gb = (16 * 1024 * 1024 * 1024) as USize;
    let info = MemoryInfo {
        free: sixteen_gb,
        total: sixteen_gb,
    };
    assert_eq(info.free, info.total);
}

@test
fn test_memory_info_zero_free() {
    let eight_gb = (8 * 1024 * 1024 * 1024) as USize;
    let info = MemoryInfo {
        free: 0 as USize,
        total: eight_gb,
    };
    assert_eq(info.free, 0 as USize);
    assert_eq(info.total, eight_gb);
}

