// =============================================================================
// Section 14: GPUBackend Exhaustive Match & Cross-Checks
// =============================================================================

@test
fn test_gpu_backend_match_exhaustive() {
    let mut count = 0;
    let b1 = GPUBackend.CUDA;
    match b1 { GPUBackend.CUDA => { count = count + 1; }, _ => {} }
    let b2 = GPUBackend.ROCm;
    match b2 { GPUBackend.ROCm => { count = count + 1; }, _ => {} }
    let b3 = GPUBackend.Metal;
    match b3 { GPUBackend.Metal => { count = count + 1; }, _ => {} }
    let b4 = GPUBackend.Vulkan;
    match b4 { GPUBackend.Vulkan => { count = count + 1; }, _ => {} }
    let b5 = GPUBackend.SYCL;
    match b5 { GPUBackend.SYCL => { count = count + 1; }, _ => {} }
    let b6 = GPUBackend.None;
    match b6 { GPUBackend.None => { count = count + 1; }, _ => {} }
    assert_eq(count, 6);
}

@test
fn test_gpu_backend_all_distinct() {
    assert(GPUBackend.CUDA != GPUBackend.ROCm);
    assert(GPUBackend.CUDA != GPUBackend.Metal);
    assert(GPUBackend.CUDA != GPUBackend.Vulkan);
    assert(GPUBackend.CUDA != GPUBackend.SYCL);
    assert(GPUBackend.CUDA != GPUBackend.None);
    assert(GPUBackend.ROCm != GPUBackend.Metal);
    assert(GPUBackend.ROCm != GPUBackend.Vulkan);
    assert(GPUBackend.ROCm != GPUBackend.SYCL);
    assert(GPUBackend.ROCm != GPUBackend.None);
    assert(GPUBackend.Metal != GPUBackend.Vulkan);
    assert(GPUBackend.Metal != GPUBackend.SYCL);
    assert(GPUBackend.Metal != GPUBackend.None);
    assert(GPUBackend.Vulkan != GPUBackend.SYCL);
    assert(GPUBackend.Vulkan != GPUBackend.None);
    assert(GPUBackend.SYCL != GPUBackend.None);
}

// =============================================================================
// Section 15: Vendor Exhaustive Match & Cross-Checks
// =============================================================================

@test
fn test_vendor_match_exhaustive() {
    let mut count = 0;
    let v1 = Vendor.Nvidia;
    match v1 { Vendor.Nvidia => { count = count + 1; }, _ => {} }
    let v2 = Vendor.Amd;
    match v2 { Vendor.Amd => { count = count + 1; }, _ => {} }
    let v3 = Vendor.Intel;
    match v3 { Vendor.Intel => { count = count + 1; }, _ => {} }
    let v4 = Vendor.Apple;
    match v4 { Vendor.Apple => { count = count + 1; }, _ => {} }
    let v5 = Vendor.Google;
    match v5 { Vendor.Google => { count = count + 1; }, _ => {} }
    let v6 = Vendor.Qualcomm;
    match v6 { Vendor.Qualcomm => { count = count + 1; }, _ => {} }
    let v7 = Vendor.Unknown;
    match v7 { Vendor.Unknown => { count = count + 1; }, _ => {} }
    assert_eq(count, 7);
}

@test
fn test_vendor_all_distinct() {
    assert(Vendor.Nvidia != Vendor.Amd);
    assert(Vendor.Nvidia != Vendor.Intel);
    assert(Vendor.Nvidia != Vendor.Apple);
    assert(Vendor.Nvidia != Vendor.Google);
    assert(Vendor.Nvidia != Vendor.Qualcomm);
    assert(Vendor.Nvidia != Vendor.Unknown);
    assert(Vendor.Amd != Vendor.Intel);
    assert(Vendor.Amd != Vendor.Apple);
    assert(Vendor.Amd != Vendor.Google);
    assert(Vendor.Amd != Vendor.Qualcomm);
    assert(Vendor.Amd != Vendor.Unknown);
    assert(Vendor.Intel != Vendor.Apple);
    assert(Vendor.Intel != Vendor.Google);
    assert(Vendor.Intel != Vendor.Qualcomm);
    assert(Vendor.Intel != Vendor.Unknown);
    assert(Vendor.Apple != Vendor.Google);
    assert(Vendor.Apple != Vendor.Qualcomm);
    assert(Vendor.Apple != Vendor.Unknown);
    assert(Vendor.Google != Vendor.Qualcomm);
    assert(Vendor.Google != Vendor.Unknown);
    assert(Vendor.Qualcomm != Vendor.Unknown);
}

// =============================================================================
// Section 16: DeviceId Extended Tests
// =============================================================================

@test
fn test_device_id_gpu_multi_0() {
    let id0 = DeviceId.gpu(0 as U16);
    assert(id0.is_gpu());
    assert_eq(id0.device_index(), 0 as U16);
}

@test
fn test_device_id_gpu_multi_1() {
    let id1 = DeviceId.gpu(1 as U16);
    assert(id1.is_gpu());
    assert_eq(id1.device_index(), 1 as U16);
}

@test
fn test_device_id_gpu_multi_7() {
    let id7 = DeviceId.gpu(7 as U16);
    assert(id7.is_gpu());
    assert_eq(id7.device_index(), 7 as U16);
}

@test
fn test_device_id_gpu_max_index() {
    // INDEX_MASK is 0x0FFF = 4095, so max 12-bit index
    let id_max = DeviceId.gpu(4095 as U16);
    assert(id_max.is_gpu());
    assert_eq(id_max.device_index(), 4095 as U16);
}

@test
fn test_device_id_tpu_multi() {
    let t0 = DeviceId.tpu(0 as U16);
    let t1 = DeviceId.tpu(1 as U16);
    assert(t0.is_tpu());
    assert(t1.is_tpu());
    assert(t0 != t1);
    assert_eq(t0.device_index(), 0 as U16);
    assert_eq(t1.device_index(), 1 as U16);
}

@test
fn test_device_id_raw_gpu() {
    let gpu0 = DeviceId.gpu(0 as U16);
    // GPU_BASE is 0x1000
    assert_eq(gpu0.raw(), 0x1000 as U16);
}

@test
fn test_device_id_raw_tpu() {
    let tpu0 = DeviceId.tpu(0 as U16);
    // TPU_BASE is 0x2000
    assert_eq(tpu0.raw(), 0x2000 as U16);
}

@test
fn test_device_id_different_types_different_raw() {
    let cpu = DeviceId.cpu();
    let gpu = DeviceId.gpu(0 as U16);
    let tpu = DeviceId.tpu(0 as U16);
    assert(cpu.raw() != gpu.raw());
    assert(cpu.raw() != tpu.raw());
    assert(gpu.raw() != tpu.raw());
}

// =============================================================================
// Section 17: ComputeCapability Extended Tests
// =============================================================================

@test
fn test_compute_capability_custom_construction() {
    let cc = ComputeCapability {
        major: 7 as U32,
        minor: 5 as U32,
        tensor_cores: true,
        fp16: true,
        bf16: false,
        int8_dp4a: true,
        async_copy: false,
        tma: false,
    };
    assert_eq(cc.major, 7 as U32);
    assert_eq(cc.minor, 5 as U32);
    assert(cc.tensor_cores);
    assert(cc.fp16);
    assert(!cc.bf16);
    assert(cc.int8_dp4a);
    assert(!cc.async_copy);
    assert(!cc.tma);
}

@test
fn test_compute_capability_sm_version_custom() {
    let cc = ComputeCapability {
        major: 7 as U32,
        minor: 5 as U32,
        ..ComputeCapability.default()
    };
    assert_eq(cc.sm_version(), 75 as U32);
}

@test
fn test_compute_capability_at_least_same_major_higher_minor() {
    let cc = ComputeCapability {
        major: 8 as U32,
        minor: 0 as U32,
        ..ComputeCapability.default()
    };
    // Same major, higher minor should fail
    assert(!cc.at_least(8 as U32, 1 as U32));
}

@test
fn test_compute_capability_at_least_higher_major_lower_minor() {
    let cc = ComputeCapability {
        major: 9 as U32,
        minor: 0 as U32,
        ..ComputeCapability.default()
    };
    // Higher major satisfies even with lower minor
    assert(cc.at_least(8 as U32, 9 as U32));
}

@test
fn test_compute_capability_at_least_exact_match() {
    let cc = ComputeCapability {
        major: 7 as U32,
        minor: 5 as U32,
        ..ComputeCapability.default()
    };
    assert(cc.at_least(7 as U32, 5 as U32));
}

@test
fn test_compute_capability_default_sm_version() {
    let cc = ComputeCapability.default();
    assert_eq(cc.sm_version(), 0 as U32);
}

@test
fn test_compute_capability_volta_int8() {
    let cc = ComputeCapability.volta();
    assert(cc.int8_dp4a);
}

@test
fn test_compute_capability_ampere_int8() {
    let cc = ComputeCapability.ampere();
    assert(cc.int8_dp4a);
}

@test
fn test_compute_capability_hopper_int8() {
    let cc = ComputeCapability.hopper();
    assert(cc.int8_dp4a);
}

// =============================================================================
// Section 18: CpuInfo Extended Tests
// =============================================================================

@test
fn test_cpu_info_custom_construction() {
    let info = CpuInfo {
        vendor: "Intel",
        cores: 8 as USize,
        threads: 16 as USize,
        l1_cache: (64 * 1024) as USize,
        l2_cache: (512 * 1024) as USize,
        l3_cache: (16 * 1024 * 1024) as USize,
        has_sse42: true,
        has_avx: true,
        has_avx2: true,
        has_fma: true,
        has_avx512f: false,
        has_neon: false,
    };
    assert_eq(info.vendor, "Intel");
    assert_eq(info.cores, 8 as USize);
    assert_eq(info.threads, 16 as USize);
    assert(info.has_sse42);
    assert(info.has_avx);
    assert(info.has_avx2);
    assert(info.has_fma);
    assert(!info.has_avx512f);
    assert(!info.has_neon);
}

@test
fn test_cpu_info_simd_width_avx_only() {
    let mut info = CpuInfo.default();
    info.has_avx = true;
    // has_avx2 is false but has_avx is true => 32 (avx branch)
    assert_eq(info.simd_width(), 32 as USize);
}

@test
fn test_cpu_info_default_vendor() {
    let info = CpuInfo.default();
    assert_eq(info.vendor, "Unknown");
}

@test
fn test_cpu_info_default_cache_values() {
    let info = CpuInfo.default();
    assert_eq(info.l1_cache, (32 * 1024) as USize);
    assert_eq(info.l2_cache, (256 * 1024) as USize);
    assert_eq(info.l3_cache, (8 * 1024 * 1024) as USize);
}

@test
fn test_cpu_info_simd_priority_avx512_over_avx2() {
    let mut info = CpuInfo.default();
    info.has_avx512f = true;
    info.has_avx2 = true;
    // AVX-512 takes priority
    assert_eq(info.simd_width(), 64 as USize);
}

