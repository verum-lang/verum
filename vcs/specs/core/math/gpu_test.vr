@test
fn test_device_info_gpu_construction() {
    let gpu = GpuInfo {
        name: "RTX 4090",
        vendor: Vendor.Nvidia,
        backend: GPUBackend.CUDA,
        memory_bytes: (24 * 1024 * 1024 * 1024) as USize,
        compute_capability: ComputeCapability.hopper(),
        multiprocessors: 128 as U32,
        max_threads_per_block: 1024 as U32,
        warp_size: 32 as U32,
        shared_memory_per_block: (48 * 1024) as USize,
        memory_bandwidth_gbps: 1000.0 as F64,
    };
    let info = DeviceInfo.Gpu(gpu);
    assert(info.is_gpu());
    assert(!info.is_cpu());
}

@test
fn test_device_info_gpu_name() {
