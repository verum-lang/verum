// =============================================================================
// Section 25: LaunchConfig Extended Tests
// =============================================================================

@test
fn test_launch_config_for_volume() {
    let config = LaunchConfig.for_volume(
        64 as USize, 64 as USize, 64 as USize,
        8 as U32, 8 as U32, 8 as U32,
    );
    assert_eq(config.grid.x, 8 as U32);   // 64/8
    assert_eq(config.grid.y, 8 as U32);   // 64/8
    assert_eq(config.grid.z, 8 as U32);   // 64/8
    assert_eq(config.block.x, 8 as U32);
    assert_eq(config.block.y, 8 as U32);
    assert_eq(config.block.z, 8 as U32);
}

@test
fn test_launch_config_for_volume_total_threads() {
    let config = LaunchConfig.for_volume(
        64 as USize, 64 as USize, 64 as USize,
        8 as U32, 8 as U32, 8 as U32,
    );
    // grid: 8*8*8 = 512 blocks, block: 8*8*8 = 512 threads each
    assert_eq(config.total_threads(), (512 * 512) as USize);
}

@test
fn test_launch_config_with_shared_mem() {
    let config = LaunchConfig.default().with_shared_mem(4096 as USize);
    assert_eq(config.shared_mem, 4096 as USize);
    // Other fields preserved
    assert_eq(config.grid.x, 1 as U32);
    assert_eq(config.block.x, 256 as U32);
}

@test
fn test_launch_config_for_matrix_non_divisible() {
    // rows=100, cols=100, block=16x16 => grid = ceil(100/16) = 7
    let config = LaunchConfig.for_matrix(100 as USize, 100 as USize, 16 as U32, 16 as U32);
    assert_eq(config.grid.x, 7 as U32);
    assert_eq(config.grid.y, 7 as U32);
}

@test
fn test_launch_config_for_elements_single_block() {
    let config = LaunchConfig.for_elements(128 as USize, 256 as U32);
    assert_eq(config.grid.x, 1 as U32);
    assert_eq(config.block.x, 256 as U32);
}

@test
fn test_launch_config_default_stream_none() {
    let config = LaunchConfig.default();
    assert(config.stream is None);
}

@test
fn test_launch_config_for_elements_large() {
    let config = LaunchConfig.for_elements(1000000 as USize, 256 as U32);
    // ceil(1000000/256) = 3907
    assert_eq(config.grid.x, 3907 as U32);
}

