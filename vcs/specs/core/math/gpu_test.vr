}

// =============================================================================
// Section 21: DeviceSelection Exhaustive Match
// =============================================================================

@test
fn test_device_selection_match_exhaustive() {
    let mut count = 0;
    let s1 = DeviceSelection.FirstGpu;
    match s1 { DeviceSelection.FirstGpu => { count = count + 1; }, _ => {} }
    let s2 = DeviceSelection.MaxMemoryGpu;
    match s2 { DeviceSelection.MaxMemoryGpu => { count = count + 1; }, _ => {} }
    let s3 = DeviceSelection.MaxComputeGpu;
    match s3 { DeviceSelection.MaxComputeGpu => { count = count + 1; }, _ => {} }
    let s4 = DeviceSelection.CpuOnly;
    match s4 { DeviceSelection.CpuOnly => { count = count + 1; }, _ => {} }
    let s5 = DeviceSelection.ByIndex(0 as USize);
    match s5 { DeviceSelection.ByIndex(_) => { count = count + 1; }, _ => {} }
    assert_eq(count, 5);
}

@test
fn test_device_selection_by_index_values() {
    let s0 = DeviceSelection.ByIndex(0 as USize);
    let s1 = DeviceSelection.ByIndex(1 as USize);
    let s99 = DeviceSelection.ByIndex(99 as USize);
    assert(s0 is DeviceSelection.ByIndex);
    assert(s1 is DeviceSelection.ByIndex);
    assert(s99 is DeviceSelection.ByIndex);
}

