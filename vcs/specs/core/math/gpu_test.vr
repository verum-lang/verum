// =============================================================================

@test
fn test_memory_info_construction() {
    let four_gb = (4 * 1024 * 1024 * 1024) as USize;
    let eight_gb = (8 * 1024 * 1024 * 1024) as USize;
    let info = MemoryInfo {
        free: four_gb,
        total: eight_gb,
    };
    assert(info.free <= info.total);
}

