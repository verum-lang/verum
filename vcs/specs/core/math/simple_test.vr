// =============================================================================
// Section 10: Function Signature Type Checking
// =============================================================================

@test
fn test_zeros_returns_tensor() {
    fn check() -> Tensor { zeros(&[2 as USize, 3 as USize]) }
    let _ = check;

}

@test
fn test_ones_returns_tensor() {
    fn check() -> Tensor { ones(&[4 as USize]) }
    let _ = check;

}

@test
fn test_full_returns_tensor() {
    fn check() -> Tensor { full(&[2 as USize], 3.14) }
    let _ = check;

}

@test
fn test_eye_returns_tensor() {
    fn check() -> Tensor { eye(4 as USize) }
    let _ = check;

}

@test
fn test_arange_returns_tensor() {
    fn check() -> Tensor { arange(0.0, 10.0, 1.0) }
    let _ = check;

}

@test
fn test_linspace_returns_tensor() {
    fn check() -> Tensor { linspace(0.0, 1.0, 11 as USize) }
    let _ = check;

}

