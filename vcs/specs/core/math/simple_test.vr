// =============================================================================
// simple_test.vr - Tests for simple math API types and function signatures
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: math, simple, tensor, alias, prototyping, module, dataloader, batch
// @description: Tests for Tensor/Tensor32 type aliases, Batch record, DataLoader
//               protocol, Module protocol, Sequential type, and function import
//               existence from the simple math module.
// =============================================================================

mount core.math.simple.{
    Tensor, Tensor32, Batch, Sequential,
};

// =============================================================================
// Section 1: Type Alias Existence
// =============================================================================

@test
fn test_tensor_type_exists() {
    let _: fn() -> Tensor = || panic("type check only");

}

@test
fn test_tensor32_type_exists() {
    let _: fn() -> Tensor32 = || panic("type check only");

}

@test
fn test_tensor_as_parameter_type() {
    fn accept_tensor(t: &Tensor) -> Bool { true }
    let _ = accept_tensor;

}

@test
fn test_tensor32_as_parameter_type() {
    fn accept_tensor32(t: &Tensor32) -> Bool { true }
    let _ = accept_tensor32;

}

@test
fn test_tensor_as_return_type() {
    fn return_tensor() -> Tensor { panic("type check only") }
    let _ = return_tensor;

}

@test
fn test_tensor32_as_return_type() {
    fn return_tensor32() -> Tensor32 { panic("type check only") }
    let _ = return_tensor32;

}

@test
fn test_tensor_in_collection() {
    // Tensor should work as List element type
    fn make_list() -> List<Tensor> { panic("type check only") }
    let _ = make_list;

}

@test
fn test_tensor32_in_collection() {
    fn make_list() -> List<Tensor32> { panic("type check only") }
    let _ = make_list;

}

// =============================================================================
// Section 2: Batch Type
// =============================================================================

@test
fn test_batch_type_exists() {
    fn accept_batch(b: &Batch) -> Bool { true }
    let _ = accept_batch;

}

@test
fn test_batch_has_input_field() {
    // Batch has input: Tensor
    fn get_input(b: &Batch) -> &Tensor { &b.input }
    let _ = get_input;

}

@test
fn test_batch_has_target_field() {
    // Batch has target: Tensor
    fn get_target(b: &Batch) -> &Tensor { &b.target }
    let _ = get_target;

}

@test
fn test_batch_field_types_clone() {
    // Verify both fields are Tensor type through function signatures
    fn get_input(b: &Batch) -> &Tensor { &b.input }
    fn get_target(b: &Batch) -> &Tensor { &b.target }
    let _ = get_input;
    let _ = get_target;
}

