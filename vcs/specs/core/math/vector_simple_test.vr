// @description: Simple test for Vector without assertions

module specs.core.math.vector_simple_test;

mount core.math.{Vector};

fn main() {
    print("Creating Vector.zeros(3)...");
    let v0: Vector<Float> = Vector.zeros(3);
    print("Vector created!");

    print("Getting length...");
    let len = v0.len();
    print(f"Length = {len}");

    print("Test done!");
}
