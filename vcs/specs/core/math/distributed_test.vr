// =============================================================================
// Section 21: ReduceOp Distinctness Extended
// =============================================================================

@test
fn test_reduce_op_distinctness_full() {
    assert(!(ReduceOp.Sum is ReduceOp.Avg));
    assert(!(ReduceOp.Sum is ReduceOp.Min));
    assert(!(ReduceOp.Sum is ReduceOp.Max));
    assert(!(ReduceOp.Sum is ReduceOp.Product));
    assert(!(ReduceOp.Avg is ReduceOp.Min));
    assert(!(ReduceOp.Avg is ReduceOp.Max));
    assert(!(ReduceOp.Avg is ReduceOp.Product));
    assert(!(ReduceOp.Min is ReduceOp.Max));
    assert(!(ReduceOp.Min is ReduceOp.Product));
    assert(!(ReduceOp.Max is ReduceOp.Product));
}

