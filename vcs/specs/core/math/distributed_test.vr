// =============================================================================
// Section 24: SliceOrIndex Match Exhaustive
// =============================================================================

@test
fn test_slice_or_index_match() {
    let slices = [
        SliceOrIndex.All,
        SliceOrIndex.Range { start: 0, end: 5, step: 1 },
        SliceOrIndex.Index { value: 3 },
    ];
    let mut all_count = 0;
    let mut range_count = 0;
    let mut index_count = 0;

    for s in slices {
        if s is SliceOrIndex.All {
            all_count = all_count + 1;
        } else if s is SliceOrIndex.Range {
            range_count = range_count + 1;
        } else if s is SliceOrIndex.Index {
            index_count = index_count + 1;
        }
    }
    assert_eq(all_count, 1);
    assert_eq(range_count, 1);
    assert_eq(index_count, 1);
}

@test
fn test_slice_or_index_distinctness() {
    let all = SliceOrIndex.All;
    let range = SliceOrIndex.Range { start: 0, end: 10, step: 1 };
    let idx = SliceOrIndex.Index { value: 5 };

    assert(!(all is SliceOrIndex.Range));
    assert(!(all is SliceOrIndex.Index));
    assert(!(range is SliceOrIndex.All));
    assert(!(range is SliceOrIndex.Index));
    assert(!(idx is SliceOrIndex.All));
    assert(!(idx is SliceOrIndex.Range));
}

// =============================================================================
// Section 25: PipelineSchedule Match Exhaustive
// =============================================================================

@test
fn test_pipeline_schedule_match_exhaustive() {
    let schedules = [
        PipelineSchedule.GPipe,
        PipelineSchedule.OneFOneBSchedule,
        PipelineSchedule.Interleaved,
    ];
    let mut counts = [0, 0, 0];
    for s in schedules {
        match s {
            PipelineSchedule.GPipe => counts[0] = counts[0] + 1,
            PipelineSchedule.OneFOneBSchedule => counts[1] = counts[1] + 1,
            PipelineSchedule.Interleaved => counts[2] = counts[2] + 1,
        }
    }
    assert_eq(counts[0], 1);
    assert_eq(counts[1], 1);
    assert_eq(counts[2], 1);
}

