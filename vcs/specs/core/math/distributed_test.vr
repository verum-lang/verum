@test
fn test_reduce_op_sum() {
    let op = ReduceOp.Sum;
    assert(op is ReduceOp.Sum);
}

@test
fn test_reduce_op_avg() {
    let op = ReduceOp.Avg;
    assert(op is ReduceOp.Avg);
}

@test
fn test_reduce_op_min() {
    let op = ReduceOp.Min;
    assert(op is ReduceOp.Min);
}

@test
fn test_reduce_op_max() {
    let op = ReduceOp.Max;
    assert(op is ReduceOp.Max);
}

@test
fn test_reduce_op_product() {
    let op = ReduceOp.Product;
    assert(op is ReduceOp.Product);
}

@test
fn test_reduce_op_match_exhaustive() {
    let ops = [ReduceOp.Sum, ReduceOp.Avg, ReduceOp.Min, ReduceOp.Max, ReduceOp.Product];
    let mut sum_count = 0;
    let mut avg_count = 0;
    let mut min_count = 0;
    let mut max_count = 0;
    let mut prod_count = 0;

    for op in ops {
        match op {
            ReduceOp.Sum => sum_count = sum_count + 1,
            ReduceOp.Avg => avg_count = avg_count + 1,
            ReduceOp.Min => min_count = min_count + 1,
            ReduceOp.Max => max_count = max_count + 1,
            ReduceOp.Product => prod_count = prod_count + 1,
        }
    }
    assert_eq(sum_count, 1);
    assert_eq(avg_count, 1);
    assert_eq(min_count, 1);
    assert_eq(max_count, 1);
    assert_eq(prod_count, 1);
}

