// =============================================================================
// Section 6: SupervisionStrategy Variants
// =============================================================================

@test
fn test_supervision_strategy_restart() {
    let s = SupervisionStrategy.Restart;
    assert(s is SupervisionStrategy.Restart);
}

@test
fn test_supervision_strategy_escalate() {
    let s = SupervisionStrategy.Escalate;
    assert(s is SupervisionStrategy.Escalate);
}

@test
fn test_supervision_strategy_ignore() {
    let s = SupervisionStrategy.Ignore;
    assert(s is SupervisionStrategy.Ignore);
}

@test
fn test_supervision_strategy_restart_all() {
    let s = SupervisionStrategy.RestartAll;
    assert(s is SupervisionStrategy.RestartAll);
}

@test
fn test_supervision_strategy_match_exhaustive() {
    let strategies = [
        SupervisionStrategy.Restart,
        SupervisionStrategy.Escalate,
        SupervisionStrategy.Ignore,
        SupervisionStrategy.RestartAll,
    ];
    let mut counts = [0, 0, 0, 0];

    for s in strategies {
        match s {
            SupervisionStrategy.Restart => counts[0] = counts[0] + 1,
            SupervisionStrategy.Escalate => counts[1] = counts[1] + 1,
            SupervisionStrategy.Ignore => counts[2] = counts[2] + 1,
            SupervisionStrategy.RestartAll => counts[3] = counts[3] + 1,
        }
    }
    assert_eq(counts[0], 1);
    assert_eq(counts[1], 1);
    assert_eq(counts[2], 1);
    assert_eq(counts[3], 1);
}

