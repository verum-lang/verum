// =============================================================================
// distributed_test.vr - Tests for distributed training types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @note: distributed.vr fixed — renamed keyword params, inlined where clauses, replaced @parallel for
// @tags: math, distributed, training, parallelism, supervision, mesh
// @description: Tests for CommBackend, ReduceOp, PipelineSchedule,
//               ShardingStrategy, SupervisionStrategy, SupervisionDecision,
//               SliceOrIndex, MeshDims, ActorDeviceId, DType, MeshFailure,
//               DefaultSupervision, and Message types.
// =============================================================================

mount core.math.distributed.{
    CommBackend, ReduceOp, PipelineSchedule,
    ShardingStrategy, SupervisionStrategy, SupervisionDecision,
    SliceOrIndex, MeshDims, ActorDeviceId, ActorId,
    DType, DefaultSupervision, Message,
    ProcessGroup, ColumnParallelLinear, RowParallelLinear,
    MeshSelector, MeshFailure, RdmaRef,
    current_rank, world_size, barrier,
    all_reduce, all_gather, reduce_scatter,
    broadcast, send_to, recv_from,
};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: CommBackend Variants
// =============================================================================

@test
fn test_comm_backend_nccl() {
    let b = CommBackend.NCCL;
    assert(b is CommBackend.NCCL);
}

@test
fn test_comm_backend_gloo() {
    let b = CommBackend.Gloo;
    assert(b is CommBackend.Gloo);
}

@test
fn test_comm_backend_mpi() {
    let b = CommBackend.MPI;
    assert(b is CommBackend.MPI);
}

@test
fn test_comm_backend_distinctness() {
    let nccl = CommBackend.NCCL;
    let gloo = CommBackend.Gloo;
    let mpi = CommBackend.MPI;

    assert(!(nccl is CommBackend.Gloo));
    assert(!(nccl is CommBackend.MPI));
    assert(!(gloo is CommBackend.NCCL));
    assert(!(gloo is CommBackend.MPI));
    assert(!(mpi is CommBackend.NCCL));
    assert(!(mpi is CommBackend.Gloo));
}

@test
fn test_comm_backend_match_exhaustive() {
    let backends = [CommBackend.NCCL, CommBackend.Gloo, CommBackend.MPI];
    let mut nccl_count = 0;
    let mut gloo_count = 0;
    let mut mpi_count = 0;

    for b in backends {
        match b {
            CommBackend.NCCL => nccl_count = nccl_count + 1,
            CommBackend.Gloo => gloo_count = gloo_count + 1,
            CommBackend.MPI => mpi_count = mpi_count + 1,
        }
    }
    assert_eq(nccl_count, 1);
    assert_eq(gloo_count, 1);
    assert_eq(mpi_count, 1);
}

