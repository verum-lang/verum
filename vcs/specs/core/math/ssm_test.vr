@test
fn test_activation_gelu_not_silu() {
    let g = Activation.GELU;
    let s = Activation.SiLU;
    assert(g is Activation.GELU);
    assert(!(g is Activation.SiLU));
    assert(s is Activation.SiLU);
    assert(!(s is Activation.GELU));
}

@test
fn test_discretization_in_maybe() {
    let m: Maybe<DiscretizationMethod> = Some(DiscretizationMethod.Bilinear);
    assert(m.is_some());
}

