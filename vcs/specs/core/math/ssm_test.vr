@test
fn test_routing_strategy_with_different_k_values() {
    let topk_1 = RoutingStrategy.TopK { k: 1 as USize };
    let topk_2 = RoutingStrategy.TopK { k: 2 as USize };
    let topk_4 = RoutingStrategy.TopK { k: 4 as USize };
    let topk_8 = RoutingStrategy.TopK { k: 8 as USize };

    assert(topk_1 is RoutingStrategy.TopK);
    assert(topk_2 is RoutingStrategy.TopK);
    assert(topk_4 is RoutingStrategy.TopK);
    assert(topk_8 is RoutingStrategy.TopK);
}

@test
fn test_balance_loss_all_variants_with_values() {
    let aux_small = BalanceLoss.Auxiliary { coefficient: 0.001 };
    let aux_medium = BalanceLoss.Auxiliary { coefficient: 0.01 };
    let aux_large = BalanceLoss.Auxiliary { coefficient: 0.1 };

    let z_small = BalanceLoss.ZLoss { coefficient: 0.0001 };
    let z_medium = BalanceLoss.ZLoss { coefficient: 0.001 };
    let z_large = BalanceLoss.ZLoss { coefficient: 0.01 };

    let combined1 = BalanceLoss.Combined { aux: 0.01, z: 0.001 };
    let combined2 = BalanceLoss.Combined { aux: 0.05, z: 0.005 };

    assert(aux_small is BalanceLoss.Auxiliary);
    assert(aux_medium is BalanceLoss.Auxiliary);
    assert(aux_large is BalanceLoss.Auxiliary);
    assert(z_small is BalanceLoss.ZLoss);
    assert(z_medium is BalanceLoss.ZLoss);
    assert(z_large is BalanceLoss.ZLoss);
    assert(combined1 is BalanceLoss.Combined);
    assert(combined2 is BalanceLoss.Combined);
}

fn main() {
    // Tests run via @test annotations
}
