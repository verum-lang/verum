// =============================================================================
// Section 9: RoutingStrategy Match Exhaustive
// =============================================================================

@test
fn test_routing_strategy_match_exhaustive() {
    let strategies = [
        RoutingStrategy.TopK { k: 2 as USize },
        RoutingStrategy.ExpertChoice { k: 4 as USize },
        RoutingStrategy.SoftMoE,
    ];
    let mut topk_count = 0;
    let mut ec_count = 0;
    let mut soft_count = 0;

    for s in strategies {
        if s is RoutingStrategy.TopK {
            topk_count = topk_count + 1;
        } else if s is RoutingStrategy.ExpertChoice {
            ec_count = ec_count + 1;
        } else if s is RoutingStrategy.SoftMoE {
            soft_count = soft_count + 1;
        }
    }
    assert_eq(topk_count, 1);
    assert_eq(ec_count, 1);
    assert_eq(soft_count, 1);
}

// =============================================================================
// Section 10: BalanceLoss Match Exhaustive
// =============================================================================

@test
fn test_balance_loss_match_exhaustive() {
    let losses = [
        BalanceLoss.Auxiliary { coefficient: 0.01 },
        BalanceLoss.ZLoss { coefficient: 0.001 },
        BalanceLoss.Combined { aux: 0.01, z: 0.001 },
    ];
    let mut aux_count = 0;
    let mut z_count = 0;
    let mut combined_count = 0;

    for bl in losses {
        if bl is BalanceLoss.Auxiliary {
            aux_count = aux_count + 1;
        } else if bl is BalanceLoss.ZLoss {
            z_count = z_count + 1;
        } else if bl is BalanceLoss.Combined {
            combined_count = combined_count + 1;
        }
    }
    assert_eq(aux_count, 1);
    assert_eq(z_count, 1);
    assert_eq(combined_count, 1);
}

