// =============================================================================
// Section 12: Type Parameter Constraints
// =============================================================================

@test
fn test_activation_as_parameter() {
    fn apply_activation(a: Activation) -> Bool {
        match a {
            Activation.GELU => true,
            Activation.SiLU => true,
            Activation.ReLU => true,
            Activation.Tanh => true,
            Activation.Sigmoid => true,
        }
    }
    assert(apply_activation(Activation.GELU));
    assert(apply_activation(Activation.SiLU));
    assert(apply_activation(Activation.ReLU));
    assert(apply_activation(Activation.Tanh));
    assert(apply_activation(Activation.Sigmoid));
}

@test
fn test_discretization_as_parameter() {
    fn describe_method(m: DiscretizationMethod) -> Bool {
        match m {
            DiscretizationMethod.ZeroOrderHold => true,
            DiscretizationMethod.Bilinear => true,
            DiscretizationMethod.Euler => true,
        }
    }
    assert(describe_method(DiscretizationMethod.ZeroOrderHold));
    assert(describe_method(DiscretizationMethod.Bilinear));
    assert(describe_method(DiscretizationMethod.Euler));
}

