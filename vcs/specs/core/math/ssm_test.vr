// =============================================================================
// ssm_test.vr - Tests for State Space Model types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @note: ssm.vr fixed — changed meta D: Type to D: meta Type syntax
// @tags: math, ssm, mamba, state-space, moe, routing, discretization, jamba,
//        expert, activation, router, bi-mamba
// @description: Tests for DiscretizationMethod, RoutingStrategy, BalanceLoss,
//               Activation sum types, JambaLayer variants, and type existence
//               for StateSpaceKernel, S4Layer, MambaBlock, BiMambaBlock, Mamba,
//               Router, MoELayer, MoETransformerBlock, Expert, Jamba from the
//               SSM module.
// =============================================================================

mount core.math.ssm.{
    DiscretizationMethod, RoutingStrategy, BalanceLoss, Activation,
    StateSpaceKernel, S4Layer, MambaBlock, BiMambaBlock, Mamba,
    JambaLayer, Jamba,
    Expert, Router, MoELayer, MoETransformerBlock,
};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: DiscretizationMethod Variants
// =============================================================================

@test
fn test_discretization_zoh() {
    let m = DiscretizationMethod.ZeroOrderHold;
    assert(m is DiscretizationMethod.ZeroOrderHold);
}

@test
fn test_discretization_bilinear() {
    let m = DiscretizationMethod.Bilinear;
    assert(m is DiscretizationMethod.Bilinear);
}

@test
fn test_discretization_euler() {
    let m = DiscretizationMethod.Euler;
    assert(m is DiscretizationMethod.Euler);
}

@test
fn test_discretization_distinctness() {
    let zoh = DiscretizationMethod.ZeroOrderHold;
    let bil = DiscretizationMethod.Bilinear;
    let euler = DiscretizationMethod.Euler;

    assert(!(zoh is DiscretizationMethod.Bilinear));
    assert(!(zoh is DiscretizationMethod.Euler));
    assert(!(bil is DiscretizationMethod.ZeroOrderHold));
    assert(!(bil is DiscretizationMethod.Euler));
    assert(!(euler is DiscretizationMethod.ZeroOrderHold));
    assert(!(euler is DiscretizationMethod.Bilinear));
}

@test
fn test_discretization_match_exhaustive() {
    let methods = [
        DiscretizationMethod.ZeroOrderHold,
        DiscretizationMethod.Bilinear,
        DiscretizationMethod.Euler,
    ];
    let mut zoh_count = 0;
    let mut bil_count = 0;
    let mut euler_count = 0;

    for m in methods {
        match m {
            DiscretizationMethod.ZeroOrderHold => zoh_count = zoh_count + 1,
            DiscretizationMethod.Bilinear => bil_count = bil_count + 1,
            DiscretizationMethod.Euler => euler_count = euler_count + 1,
        }
    }
    assert_eq(zoh_count, 1);
    assert_eq(bil_count, 1);
    assert_eq(euler_count, 1);
}

// =============================================================================
// Section 2: RoutingStrategy Variants
// =============================================================================

@test
fn test_routing_strategy_top_k() {
    let s = RoutingStrategy.TopK { k: 2 as USize };
    assert(s is RoutingStrategy.TopK);
}

@test
fn test_routing_strategy_top_k_values() {
    // Record variant field destructuring not supported in match — test construction instead
    let k_val = 4 as USize;
    let s = RoutingStrategy.TopK { k: k_val };
    assert(s is RoutingStrategy.TopK);
    assert_eq(k_val, 4 as USize);
}

@test
fn test_routing_strategy_expert_choice() {
    let s = RoutingStrategy.ExpertChoice { k: 8 as USize };
    assert(s is RoutingStrategy.ExpertChoice);
}

@test
fn test_routing_strategy_expert_choice_values() {
    let k_val = 16 as USize;
    let s = RoutingStrategy.ExpertChoice { k: k_val };
    assert(s is RoutingStrategy.ExpertChoice);
    assert_eq(k_val, 16 as USize);
}

@test
fn test_routing_strategy_soft_moe() {
    let s = RoutingStrategy.SoftMoE;
    assert(s is RoutingStrategy.SoftMoE);
}

@test
fn test_routing_strategy_distinctness() {
    let topk = RoutingStrategy.TopK { k: 2 as USize };
    let ec = RoutingStrategy.ExpertChoice { k: 2 as USize };
    let soft = RoutingStrategy.SoftMoE;

    assert(!(topk is RoutingStrategy.ExpertChoice));
    assert(!(topk is RoutingStrategy.SoftMoE));
    assert(!(ec is RoutingStrategy.TopK));
    assert(!(ec is RoutingStrategy.SoftMoE));
    assert(!(soft is RoutingStrategy.TopK));
    assert(!(soft is RoutingStrategy.ExpertChoice));
}

// =============================================================================
// Section 3: BalanceLoss Variants
// =============================================================================

@test
fn test_balance_loss_auxiliary() {
    let bl = BalanceLoss.Auxiliary { coefficient: 0.01 };
    assert(bl is BalanceLoss.Auxiliary);
}

@test
fn test_balance_loss_auxiliary_value() {
    let coeff = 0.05;
    let bl = BalanceLoss.Auxiliary { coefficient: coeff };
    assert(bl is BalanceLoss.Auxiliary);
    assert_eq(coeff, 0.05);
}

@test
fn test_balance_loss_zloss() {
    let bl = BalanceLoss.ZLoss { coefficient: 0.001 };
    assert(bl is BalanceLoss.ZLoss);
}

@test
fn test_balance_loss_zloss_value() {
    let coeff = 0.1;
    let bl = BalanceLoss.ZLoss { coefficient: coeff };
    assert(bl is BalanceLoss.ZLoss);
    assert_eq(coeff, 0.1);
}

@test
fn test_balance_loss_combined() {
    let bl = BalanceLoss.Combined { aux: 0.01, z: 0.001 };
    assert(bl is BalanceLoss.Combined);
}

@test
fn test_balance_loss_combined_values() {
    let aux_val = 0.02;
    let z_val = 0.003;
    let bl = BalanceLoss.Combined { aux: aux_val, z: z_val };
    assert(bl is BalanceLoss.Combined);
    assert_eq(aux_val, 0.02);
    assert_eq(z_val, 0.003);
}

@test
fn test_balance_loss_distinctness() {
    let aux = BalanceLoss.Auxiliary { coefficient: 0.01 };
    let zloss = BalanceLoss.ZLoss { coefficient: 0.01 };
    let combined = BalanceLoss.Combined { aux: 0.01, z: 0.01 };

    assert(!(aux is BalanceLoss.ZLoss));
    assert(!(aux is BalanceLoss.Combined));
    assert(!(zloss is BalanceLoss.Auxiliary));
    assert(!(zloss is BalanceLoss.Combined));
    assert(!(combined is BalanceLoss.Auxiliary));
    assert(!(combined is BalanceLoss.ZLoss));
}

// =============================================================================
// Section 4: Activation Variants
// =============================================================================

@test
fn test_activation_gelu() {
    let a = Activation.GELU;
    assert(a is Activation.GELU);
}

@test
fn test_activation_silu() {
    let a = Activation.SiLU;
    assert(a is Activation.SiLU);
}

@test
fn test_activation_relu() {
    let a = Activation.ReLU;
    assert(a is Activation.ReLU);
}

@test
fn test_activation_tanh() {
    let a = Activation.Tanh;
    assert(a is Activation.Tanh);
}

@test
fn test_activation_sigmoid() {
    let a = Activation.Sigmoid;
    assert(a is Activation.Sigmoid);
}

@test
fn test_activation_match_exhaustive() {
    let activations = [
        Activation.GELU,
        Activation.SiLU,
        Activation.ReLU,
        Activation.Tanh,
        Activation.Sigmoid,
    ];
    let mut counts = [0, 0, 0, 0, 0];

    for a in activations {
        match a {
            Activation.GELU => counts[0] = counts[0] + 1,
            Activation.SiLU => counts[1] = counts[1] + 1,
            Activation.ReLU => counts[2] = counts[2] + 1,
            Activation.Tanh => counts[3] = counts[3] + 1,
            Activation.Sigmoid => counts[4] = counts[4] + 1,
        }
    }
    assert_eq(counts[0], 1);
    assert_eq(counts[1], 1);
    assert_eq(counts[2], 1);
    assert_eq(counts[3], 1);
    assert_eq(counts[4], 1);
}

@test
fn test_activation_distinctness() {
    assert(!(Activation.GELU is Activation.SiLU));
    assert(!(Activation.GELU is Activation.ReLU));
    assert(!(Activation.SiLU is Activation.ReLU));
    assert(!(Activation.ReLU is Activation.Tanh));
    assert(!(Activation.Tanh is Activation.Sigmoid));
}

