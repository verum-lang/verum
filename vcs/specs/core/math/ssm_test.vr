fn test_routing_strategy_topk_small_k() {
    let s = RoutingStrategy.TopK { k: 1 as USize };
    assert(s is RoutingStrategy.TopK);
}

@test
fn test_balance_loss_combined_equal_weights() {
    let bl = BalanceLoss.Combined { aux: 0.01, z: 0.01 };
    assert(bl is BalanceLoss.Combined);
}

