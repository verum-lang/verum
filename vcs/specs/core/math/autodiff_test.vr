    assert(op is OpType.Pow);
}

@test
fn test_optype_neg() {
    let op = OpType.Neg;
    assert(op is OpType.Neg);
}

@test
fn test_optype_exp() {
    let op = OpType.Exp;
    assert(op is OpType.Exp);
}

@test
fn test_optype_log() {
    let op = OpType.Log;
    assert(op is OpType.Log);
}

@test
fn test_optype_sqrt() {
    let op = OpType.Sqrt;
    assert(op is OpType.Sqrt);
}

@test
fn test_optype_sin() {
    let op = OpType.Sin;
    assert(op is OpType.Sin);
}

@test
fn test_optype_cos() {
    let op = OpType.Cos;
    assert(op is OpType.Cos);
}

@test
fn test_optype_tanh() {
    let op = OpType.Tanh;
    assert(op is OpType.Tanh);
}

@test
fn test_optype_matmul() {
    let op = OpType.Matmul;
    assert(op is OpType.Matmul);
}

@test
fn test_optype_softmax() {
    let op = OpType.Softmax;
    assert(op is OpType.Softmax);
}

@test
fn test_optype_sum() {
    let op = OpType.Sum;
    assert(op is OpType.Sum);
}

@test
fn test_optype_mean() {
    let op = OpType.Mean;
    assert(op is OpType.Mean);
}

@test
fn test_optype_reshape() {
    let op = OpType.Reshape;
    assert(op is OpType.Reshape);
}

@test
fn test_optype_transpose() {
    let op = OpType.Transpose;
    assert(op is OpType.Transpose);
}

@test
fn test_optype_custom() {
    let op = OpType.Custom("my_op");
    assert(op is OpType.Custom);
}

@test
fn test_optype_distinctness_arithmetic() {
    assert(!(OpType.Add is OpType.Sub));
    assert(!(OpType.Sub is OpType.Mul));
    assert(!(OpType.Mul is OpType.Div));
    assert(!(OpType.Div is OpType.Pow));
    assert(!(OpType.Pow is OpType.Neg));
}

@test
fn test_optype_distinctness_transcendental() {
    assert(!(OpType.Exp is OpType.Log));
    assert(!(OpType.Log is OpType.Sqrt));
    assert(!(OpType.Sqrt is OpType.Sin));
    assert(!(OpType.Sin is OpType.Cos));
    assert(!(OpType.Cos is OpType.Tanh));
}

@test
fn test_optype_distinctness_tensor() {
    assert(!(OpType.Matmul is OpType.Softmax));
    assert(!(OpType.Softmax is OpType.Sum));
    assert(!(OpType.Sum is OpType.Mean));
    assert(!(OpType.Mean is OpType.Reshape));
    assert(!(OpType.Reshape is OpType.Transpose));
}

@test
fn test_optype_match_exhaustive() {
    let ops = [
        OpType.Add, OpType.Sub, OpType.Mul, OpType.Div,
        OpType.Pow, OpType.Neg, OpType.Exp, OpType.Log,
        OpType.Sqrt, OpType.Sin, OpType.Cos, OpType.Tanh,
        OpType.Matmul, OpType.Softmax, OpType.Sum, OpType.Mean,
        OpType.Reshape, OpType.Transpose, OpType.Custom("test"),
    ];
    let mut count = 0;
    for op in ops {
        match op {
            OpType.Add => count = count + 1,
            OpType.Sub => count = count + 1,
            OpType.Mul => count = count + 1,
            OpType.Div => count = count + 1,
            OpType.Pow => count = count + 1,
            OpType.Neg => count = count + 1,
            OpType.Exp => count = count + 1,
            OpType.Log => count = count + 1,
            OpType.Sqrt => count = count + 1,
            OpType.Sin => count = count + 1,
            OpType.Cos => count = count + 1,
            OpType.Tanh => count = count + 1,
            OpType.Matmul => count = count + 1,
            OpType.Softmax => count = count + 1,
            OpType.Sum => count = count + 1,
            OpType.Mean => count = count + 1,
            OpType.Reshape => count = count + 1,
            OpType.Transpose => count = count + 1,
            OpType.Custom(_) => count = count + 1,
        }
    }
    assert_eq(count, 19);
}

