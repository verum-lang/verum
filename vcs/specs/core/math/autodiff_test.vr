// =============================================================================
// vcs/specs/core/math/autodiff_test.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @note: autodiff.vr fixed — corrected meta syntax and Tensor<T, []> to DynTensor<T>
// @tags: core, math, autodiff, gradient, vjp, jvp, differentiation, optype,
//        compute-graph, checkpoint, memory-tracker
// @description: Tests for the automatic differentiation system including
//               DiffMode selection, Differentiable protocol, VJP/JVP results,
//               gradient API, checkpointing, higher-order derivative types,
//               OpType variants, compute graph types, and memory optimization.
//
// Coverage:
// - DiffMode: ReverseMode, ForwardMode, MixedMode, auto selection
// - Differentiable protocol: Float, Vector, Matrix implementations
// - VJPResult, JVPResult type structures
// - OpType: all 18 unit variants + Custom
// - Compute graph: NodeId, TensorId, GraphNode, GraphEdge, CheckpointData
// - MemoryTracker: construction and field access
// - ComputeGraph: construction
// - GradientScope type
// - VJPRule, JVPRule opaque handle types
// - Function imports: vjp, jvp, grad, value_and_grad, stop_gradient,
//   custom_vjp, jacobian, hessian, hvp, gnvp, checkpoint, recompute,
//   with_no_grad, with_inference, compute_checkpoint_schedule
//
// Test Strategy:
// - Type construction and variant matching
// - Protocol implementation verification
// - Auto mode selection logic
// - Result type field access
// - OpType exhaustive variant coverage
// - Compute graph type existence and field access
// - Function import existence verification
// =============================================================================

module specs.core.math.autodiff_test;

mount core.math.autodiff.{
    DiffMode,
    Differentiable,
    VJPResult, JVPResult,
    OpType, GradientScope,
    NodeId, TensorId,
    GraphNode, GraphEdge, CheckpointData,
    MemoryTracker, ComputeGraph,
    VJPRule, JVPRule,
    vjp, jvp, grad, value_and_grad, stop_gradient, custom_vjp,
    jacobian, hessian, hvp, gnvp,
    checkpoint, recompute,
    with_no_grad, with_inference,
    compute_checkpoint_schedule,
};
mount core.math.linalg.{Vector, Matrix};

// =============================================================================
// Test Entry Point
// =============================================================================

fn main() {
    // Tests run via @test annotations
}

// =============================================================================
// DiffMode Tests
// =============================================================================

@test
fn test_diff_mode_reverse() {
    let mode = DiffMode.ReverseMode;
    match mode {
        DiffMode.ReverseMode => { /* expected */ }
        _ => assert(false, "Should be ReverseMode"),
    }
}

@test
fn test_diff_mode_forward() {
    let mode = DiffMode.ForwardMode;
    match mode {
        DiffMode.ForwardMode => { /* expected */ }
        _ => assert(false, "Should be ForwardMode"),
    }
}

@test
fn test_diff_mode_mixed() {
    let thresh = 1.5;
    let mode = DiffMode.MixedMode { threshold: thresh };
    assert(mode is DiffMode.MixedMode);
    assert_eq(thresh, 1.5);
}

@test
fn test_diff_mode_default() {
    let mode = DiffMode.default();
    match mode {
        DiffMode.ReverseMode => { /* expected: default is ReverseMode */ }
        _ => assert(false, "Default mode should be ReverseMode"),
    }
}

@test
fn test_diff_mode_auto_reverse() {
    // When output_dim < input_dim, reverse mode is preferred
    let mode = DiffMode.auto(1000, 1);
    match mode {
        DiffMode.ReverseMode => { /* expected: scalar output, many inputs */ }
        _ => assert(false, "Should select ReverseMode for output_dim < input_dim"),
    }
}

@test
fn test_diff_mode_auto_forward() {
    // When output_dim > input_dim, forward mode is preferred
    let mode = DiffMode.auto(1, 1000);
    match mode {
        DiffMode.ForwardMode => { /* expected: many outputs, scalar input */ }
        _ => assert(false, "Should select ForwardMode for output_dim > input_dim"),
    }
}

@test
fn test_diff_mode_auto_equal() {
    // When equal, ratio = 1.0 which is NOT > 1.0, so ReverseMode
    let mode = DiffMode.auto(100, 100);
    match mode {
        DiffMode.ReverseMode => { /* expected: ratio = 1.0, not > 1.0 */ }
        _ => assert(false, "Should select ReverseMode for equal dims"),
    }
}

// =============================================================================
// Differentiable Protocol Tests (Float)
// =============================================================================

@test
fn test_float_zero_tangent() {
    let z: Float = Float.zero_tangent();
    assert_eq(z, 0.0);
}

@test
fn test_float_add_tangent() {
    let result = Float.add_tangent(3.0, 4.0);
    assert_eq(result, 7.0);
}

@test
fn test_float_scale_tangent() {
    let result = Float.scale_tangent(5.0, 2.0);
    assert_eq(result, 10.0);
}

@test
fn test_float_tangent_identity() {
    // Adding zero tangent should be identity
    let x = 42.0;
    let result = Float.add_tangent(x, Float.zero_tangent());
    assert_eq(result, x);
}

@test
fn test_float_scale_zero() {
    let result = Float.scale_tangent(100.0, 0.0);
    assert_eq(result, 0.0);
}

@test
fn test_float_scale_one() {
    let result = Float.scale_tangent(42.0, 1.0);
    assert_eq(result, 42.0);
}

// =============================================================================
// Differentiable Protocol Tests (Vector) — using concrete operations
// =============================================================================

@test
fn test_vector_zero_tangent() {
    // Vector<Float>.zero_tangent() returns Vector.zeros(0)
    let z: Vector<Float> = Vector.zeros(0);
    assert_eq(z.len(), 0);
}

@test
fn test_vector_add_tangent() {
    let mut a: Vector<Float> = Vector.zeros(3);
    a.set(0, 1.0); a.set(1, 2.0); a.set(2, 3.0);
    let mut b: Vector<Float> = Vector.zeros(3);
    b.set(0, 4.0); b.set(1, 5.0); b.set(2, 6.0);
    // Differentiable.add_tangent delegates to a.add(&b)
    let result: Vector<Float> = a.add(&b);
    assert_eq(result.get(0), 5.0);
    assert_eq(result.get(1), 7.0);
    assert_eq(result.get(2), 9.0);
}

@test
fn test_vector_scale_tangent() {
    let mut v: Vector<Float> = Vector.zeros(3);
    v.set(0, 1.0); v.set(1, 2.0); v.set(2, 3.0);
    // Differentiable.scale_tangent delegates to v.scale(s) (in-place)
    v.scale(2.0);
    assert_eq(v.get(0), 2.0);
    assert_eq(v.get(1), 4.0);
    assert_eq(v.get(2), 6.0);
}

// =============================================================================
// Differentiable Protocol Tests (Matrix) — using concrete operations
// =============================================================================

@test
fn test_matrix_zero_tangent() {
    // Matrix<Float>.zero_tangent() returns Matrix.zeros(0, 0)
    let z: Matrix<Float> = Matrix.zeros(0, 0);
    assert_eq(z.rows(), 0);
    assert_eq(z.cols(), 0);
}

@test
fn test_matrix_add_tangent() {
    let mut a: Matrix<Float> = Matrix.zeros(2, 2);
    a.set(0, 0, 1.0); a.set(0, 1, 2.0);
    a.set(1, 0, 3.0); a.set(1, 1, 4.0);
    let mut b: Matrix<Float> = Matrix.zeros(2, 2);
    b.set(0, 0, 5.0); b.set(0, 1, 6.0);
    b.set(1, 0, 7.0); b.set(1, 1, 8.0);
    // Differentiable.add_tangent delegates to a.add(&b)
    let result: Matrix<Float> = a.add(&b);
    assert_eq(result.get(0, 0), 6.0);
    assert_eq(result.get(1, 1), 12.0);
}

@test
fn test_matrix_scale_tangent() {
    let mut m: Matrix<Float> = Matrix.zeros(2, 2);
    m.set(0, 0, 1.0); m.set(0, 1, 2.0);
    m.set(1, 0, 3.0); m.set(1, 1, 4.0);
    // Matrix has scaled() which returns a new matrix
    let result: Matrix<Float> = m.scaled(3.0);
    assert_eq(result.get(0, 0), 3.0);
    assert_eq(result.get(0, 1), 6.0);
    assert_eq(result.get(1, 0), 9.0);
    assert_eq(result.get(1, 1), 12.0);
}

// =============================================================================
// Auto Mode Selection Property Tests
// =============================================================================

@test
fn test_auto_mode_always_valid() {
    // auto() should never fail regardless of dimensions
    let _ = DiffMode.auto(0, 0);
    let _ = DiffMode.auto(1, 0);
    let _ = DiffMode.auto(0, 1);
    let _ = DiffMode.auto(10000, 1);
    let _ = DiffMode.auto(1, 10000);
}

@test
fn test_auto_mode_neural_net() {
    // Typical neural net: many parameters, scalar loss
    // Should use reverse mode (backprop)
    let mode = DiffMode.auto(1000000, 1);
    match mode {
        DiffMode.ReverseMode => { /* expected for training */ }
        _ => assert(false, "Neural net training should use ReverseMode"),
    }
}

@test
fn test_auto_mode_sensitivity_analysis() {
    // Sensitivity analysis: one parameter, many outputs
    // Should use forward mode
    let mode = DiffMode.auto(1, 1000);
    match mode {
        DiffMode.ForwardMode => { /* expected for sensitivity */ }
        _ => assert(false, "Sensitivity analysis should use ForwardMode"),
    }
}

