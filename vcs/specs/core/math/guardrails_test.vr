// =============================================================================
// guardrails_test.vr - Tests for AI safety guardrails module
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: math, guardrails, safety, ai, filtering, agent
// @description: Tests for GuardrailResult variants and methods, GuardrailMode
//               variants, GuardrailChain construction, KeywordFilter,
//               LengthGuardrail, RateLimitGuardrail, Pattern, and
//               GuardrailBuilder types.
// =============================================================================

mount core.math.guardrails.{
    GuardrailResult, GuardrailMode, GuardrailChain,
    KeywordFilter, LengthGuardrail, RateLimitGuardrail,
    Pattern, ClassificationResult, GuardrailBuilder,
    PIIFilter, ContentClassifier, TopicGuardrail,
    GuardedAgent, Guardrail,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// Section 1: GuardrailResult Variant Construction
// =============================================================================

@test
fn test_guardrail_result_pass() {
    let result = GuardrailResult.Pass;
    assert(result is GuardrailResult.Pass);
}

@test
fn test_guardrail_result_block() {
    let result = GuardrailResult.Block { reason: "unsafe content" };
    assert(result is GuardrailResult.Block);
}

@test
fn test_guardrail_result_modify() {
    let result = GuardrailResult.Modify {
        original: "hello world",
        modified: "hello [REDACTED]",
        changes: List.new(),
    };
    assert(result is GuardrailResult.Modify);
}

// =============================================================================
// Section 2: GuardrailResult Methods
// =============================================================================

@test
fn test_guardrail_result_is_pass_true() {
    let result = GuardrailResult.Pass;
    assert(result.is_pass());
}

@test
fn test_guardrail_result_is_pass_false_block() {
    let result = GuardrailResult.Block { reason: "blocked" };
    assert(!result.is_pass());
}

@test
fn test_guardrail_result_is_pass_false_modify() {
    let result = GuardrailResult.Modify {
        original: "a",
        modified: "b",
        changes: List.new(),
    };
    assert(!result.is_pass());
}

@test
fn test_guardrail_result_is_blocked_true() {
    let result = GuardrailResult.Block { reason: "harmful" };
    assert(result.is_blocked());
}

@test
fn test_guardrail_result_is_blocked_false_pass() {
    let result = GuardrailResult.Pass;
    assert(!result.is_blocked());
}

@test
fn test_guardrail_result_is_blocked_false_modify() {
    let result = GuardrailResult.Modify {
        original: "a",
        modified: "b",
        changes: List.new(),
    };
    assert(!result.is_blocked());
}

@test
fn test_guardrail_result_is_modified_true() {
    let result = GuardrailResult.Modify {
        original: "test",
        modified: "test [REDACTED]",
        changes: List.new(),
    };
    assert(result.is_modified());
}

@test
fn test_guardrail_result_is_modified_false_pass() {
    let result = GuardrailResult.Pass;
    assert(!result.is_modified());
}

@test
fn test_guardrail_result_is_modified_false_block() {
    let result = GuardrailResult.Block { reason: "blocked" };
    assert(!result.is_modified());
}

// =============================================================================
// Section 3: GuardrailResult effective_text
// =============================================================================

@test
fn test_guardrail_result_effective_text_pass() {
    let result = GuardrailResult.Pass;
    let original = "hello world";
    let effective = result.effective_text(&original);
    assert_eq(effective, "hello world");
}

@test
fn test_guardrail_result_effective_text_block() {
    let result = GuardrailResult.Block { reason: "unsafe" };
    let original = "hello world";
    let effective = result.effective_text(&original);
    // Block returns original unchanged
    assert_eq(effective, "hello world");
}

@test
fn test_guardrail_result_effective_text_modify() {
    let result = GuardrailResult.Modify {
        original: "hello world",
        modified: "hello [REDACTED]",
        changes: List.new(),
    };
    let original = "hello world";
    let effective = result.effective_text(&original);
    assert_eq(effective, "hello [REDACTED]");
}

// =============================================================================
// Section 4: GuardrailResult Match Exhaustive
// =============================================================================

@test
fn test_guardrail_result_match_all_variants() {
    let pass = GuardrailResult.Pass;
    let block = GuardrailResult.Block { reason: "test" };
    let modify = GuardrailResult.Modify {
        original: "a",
        modified: "b",
        changes: List.new(),
    };

    let mut pass_count = 0;
    let mut block_count = 0;
    let mut modify_count = 0;

    match pass {
        GuardrailResult.Pass => pass_count = pass_count + 1,
        GuardrailResult.Block { .. } => block_count = block_count + 1,
        GuardrailResult.Modify { .. } => modify_count = modify_count + 1,
    }
    assert_eq(pass_count, 1);

    match block {
        GuardrailResult.Pass => pass_count = pass_count + 1,
        GuardrailResult.Block { .. } => block_count = block_count + 1,
        GuardrailResult.Modify { .. } => modify_count = modify_count + 1,
    }
    assert_eq(block_count, 1);

    match modify {
        GuardrailResult.Pass => pass_count = pass_count + 1,
        GuardrailResult.Block { .. } => block_count = block_count + 1,
        GuardrailResult.Modify { .. } => modify_count = modify_count + 1,
    }
    assert_eq(modify_count, 1);
}

// =============================================================================
// Section 5: GuardrailMode Variants
// =============================================================================

@test
fn test_guardrail_mode_strict_all() {
    let mode = GuardrailMode.StrictAll;
    assert(mode is GuardrailMode.StrictAll);
}

@test
fn test_guardrail_mode_first_block() {
    let mode = GuardrailMode.FirstBlock;
    assert(mode is GuardrailMode.FirstBlock);
}

@test
fn test_guardrail_mode_log_only() {
    let mode = GuardrailMode.LogOnly;
    assert(mode is GuardrailMode.LogOnly);
}

@test
fn test_guardrail_mode_distinctness() {
    let strict = GuardrailMode.StrictAll;
    let first = GuardrailMode.FirstBlock;
    let log = GuardrailMode.LogOnly;

    assert(!(strict is GuardrailMode.FirstBlock));
    assert(!(strict is GuardrailMode.LogOnly));
    assert(!(first is GuardrailMode.StrictAll));
    assert(!(first is GuardrailMode.LogOnly));
    assert(!(log is GuardrailMode.StrictAll));
    assert(!(log is GuardrailMode.FirstBlock));
}

@test
fn test_guardrail_mode_match_exhaustive() {
    let modes = [GuardrailMode.StrictAll, GuardrailMode.FirstBlock, GuardrailMode.LogOnly];
    let mut strict_count = 0;
    let mut first_count = 0;
    let mut log_count = 0;

    for mode in modes {
        match mode {
            GuardrailMode.StrictAll => strict_count = strict_count + 1,
            GuardrailMode.FirstBlock => first_count = first_count + 1,
            GuardrailMode.LogOnly => log_count = log_count + 1,
        }
    }
    assert_eq(strict_count, 1);
    assert_eq(first_count, 1);
    assert_eq(log_count, 1);
}

