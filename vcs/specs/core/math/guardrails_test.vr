    assert_eq(guard.max_length, 5000);
}

@test
fn test_length_guardrail_no_limits() {
    let guard = LengthGuardrail.new(0, 0);
    assert_eq(guard.min_length, 0);
    assert_eq(guard.max_length, 0);
}

