@test
fn test_pattern_new() {
    let pattern = Pattern.new("email", "[a-zA-Z0-9]+@[a-z]+\\.[a-z]+");
    assert_eq(pattern.name, "email");
}

@test
fn test_pattern_fields() {
    let pattern = Pattern {
        name: "phone",
        regex_str: "\\d{3}-\\d{4}",
    };
    assert_eq(pattern.name, "phone");
    assert_eq(pattern.regex_str, "\\d{3}-\\d{4}");
}

