@test
fn test_guardrail_result_pass_is_not_block() {
    let result = GuardrailResult.Pass;
    assert(!(result is GuardrailResult.Block));
    assert(!(result is GuardrailResult.Modify));
}

@test
fn test_guardrail_result_block_is_not_pass_or_modify() {
    let result = GuardrailResult.Block { reason: "test" };
    assert(!(result is GuardrailResult.Pass));
    assert(!(result is GuardrailResult.Modify));
}

@test
fn test_guardrail_result_modify_is_not_pass_or_block() {
    let result = GuardrailResult.Modify {
        original: "a",
        modified: "b",
        changes: List.new(),
    };
    assert(!(result is GuardrailResult.Pass));
    assert(!(result is GuardrailResult.Block));
}

