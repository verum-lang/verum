@test
fn test_keyword_filter_empty_keywords() {
    let filter = KeywordFilter.new([]);
    assert_eq(filter.blocked_keywords.len(), 0);
    assert(filter.case_insensitive);
}

@test
fn test_keyword_filter_single_keyword() {
    let filter = KeywordFilter.new(["danger"]);
    assert_eq(filter.blocked_keywords.len(), 1);
}

@test
fn test_keyword_filter_many_keywords() {
    let filter = KeywordFilter.new(["a", "b", "c", "d", "e", "f", "g"]);
    assert_eq(filter.blocked_keywords.len(), 7);
}

@test
fn test_keyword_filter_case_sensitive_flag() {
    let filter = KeywordFilter.new(["Test"]).with_case_sensitive();
    assert(!filter.case_insensitive);
    assert_eq(filter.blocked_keywords.len(), 1);
}

