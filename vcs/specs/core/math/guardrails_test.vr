@test
fn test_keyword_filter_new() {
    let filter = KeywordFilter.new(["password", "secret"]);
    assert(filter.case_insensitive);
}

@test
fn test_keyword_filter_case_sensitive() {
    let filter = KeywordFilter.new(["test"]).with_case_sensitive();
    assert(!filter.case_insensitive);
}

@test
fn test_keyword_filter_blocked_keywords() {
    let keywords = ["admin", "root", "sudo"];
    let filter = KeywordFilter.new(keywords);
    assert_eq(filter.blocked_keywords.len(), 3);
}

