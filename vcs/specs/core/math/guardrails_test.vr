// =============================================================================
// Section 23: GuardrailBuilder Chaining
// =============================================================================

@test
fn test_guardrail_builder_with_blocked_keywords() {
    let builder = GuardrailBuilder.new()
        .with_blocked_keywords(["password", "secret"]);
    // Builder should still have strict mode (default)
    assert(builder.chain.mode is GuardrailMode.StrictAll);
}

@test
fn test_guardrail_builder_with_length_limits() {
    let builder = GuardrailBuilder.new()
        .with_length_limits(10, 5000);
    assert(builder.chain.mode is GuardrailMode.StrictAll);
}

@test
fn test_guardrail_builder_chain_multiple() {
    let chain = GuardrailBuilder.new()
        .strict()
        .with_blocked_keywords(["forbidden"])
        .with_length_limits(1, 10000)
        .build();
    assert(chain.mode is GuardrailMode.StrictAll);
}

@test
fn test_guardrail_builder_first_block_with_keywords() {
    let chain = GuardrailBuilder.new()
        .first_block()
        .with_blocked_keywords(["unsafe", "harmful"])
        .build();
    assert(chain.mode is GuardrailMode.FirstBlock);
}

@test
fn test_guardrail_builder_log_only_with_length() {
    let chain = GuardrailBuilder.new()
        .log_only()
        .with_length_limits(0, 1000)
        .build();
    assert(chain.mode is GuardrailMode.LogOnly);
}

@test
fn test_guardrail_builder_with_pii_filter() {
    let chain = GuardrailBuilder.new()
        .strict()
        .with_pii_filter()
        .build();
    assert(chain.mode is GuardrailMode.StrictAll);
}

