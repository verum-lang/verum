// =============================================================================
// Section 15: GuardrailResult Additional Variant Values
// =============================================================================

@test
fn test_guardrail_result_block_empty_reason() {
    let result = GuardrailResult.Block { reason: "" };
    assert(result.is_blocked());
}

@test
fn test_guardrail_result_modify_empty_changes() {
    let result = GuardrailResult.Modify {
        original: "original text",
        modified: "modified text",
        changes: List.new(),
    };
    assert(result.is_modified());
}

@test
fn test_guardrail_result_modify_multiple_changes() {
    let mut changes = List.new();
    changes.push("removed email");
    changes.push("removed phone");
    changes.push("removed SSN");
    let result = GuardrailResult.Modify {
        original: "contact: john@test.com 555-1234 123-45-6789",
        modified: "contact: [REDACTED] [REDACTED] [REDACTED]",
        changes,
    };
    assert(result.is_modified());
}

@test
fn test_guardrail_result_modify_empty_strings() {
    let result = GuardrailResult.Modify {
        original: "",
        modified: "",
        changes: List.new(),
    };
    assert(result.is_modified());
    assert(!result.is_pass());
    assert(!result.is_blocked());
}

