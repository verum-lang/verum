@test
fn test_blas1_rot() {
    // Apply plane rotation
    let mut x: Vector<Float> = Vector.zeros(3);
    x.set(0, 1.0);
    x.set(1, 2.0);
    x.set(2, 3.0);

    let mut y: Vector<Float> = Vector.zeros(3);
    y.set(0, 4.0);
    y.set(1, 5.0);
    y.set(2, 6.0);

    // Apply rotation with c=0.6, s=0.8
    rot(&mut x, &mut y, 0.6, 0.8);

    // x_new = c*x + s*y = 0.6*1 + 0.8*4 = 3.8
    assert(approx_eq(x.get(0), 3.8, 1e-10));
    // y_new = -s*x + c*y = -0.8*1 + 0.6*4 = 1.6
    assert(approx_eq(y.get(0), 1.6, 1e-10));

    print("BLAS1 rot tests passed");
}

@test
fn test_blas2_syr() {
    // Symmetric rank-1 update: A := α*x*x^T + A
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 1.0);
    A.set(0, 1, 2.0);
    A.set(1, 0, 2.0);
    A.set(1, 1, 3.0);

    let mut x: Vector<Float> = Vector.zeros(2);
    x.set(0, 1.0);
    x.set(1, 2.0);

    // A := 1*x*x^T + A
    // x*x^T = [[1,2],[2,4]]
    // Result (upper) = [[2,4],[2,7]]
    syr(TriangularType.Upper, 1.0, &x, &mut A);

    assert(approx_eq(A.get(0, 0), 2.0, 1e-12));
    assert(approx_eq(A.get(1, 1), 7.0, 1e-12));

    print("BLAS2 syr tests passed");
}

