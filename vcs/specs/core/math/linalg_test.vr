    let mut v: Vector<Float> = Vector.zeros(3);
    v.set(0, 1.0);
    v.set(1, 2.0);
    v.set(2, 3.0);
    // ||v||^2 = 1 + 4 + 9 = 14
    assert(approx_eq(dot(&v, &v), 14.0, 1e-12));
}

