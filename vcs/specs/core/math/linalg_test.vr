@test
fn test_lu_decomposition() {
    // Test matrix
    let mut A: Matrix<Float> = Matrix.zeros(3, 3);
    A.set(0, 0, 2.0);
    A.set(0, 1, 1.0);
    A.set(0, 2, 1.0);
    A.set(1, 0, 4.0);
    A.set(1, 1, 3.0);
    A.set(1, 2, 3.0);
    A.set(2, 0, 8.0);
    A.set(2, 1, 7.0);
    A.set(2, 2, 9.0);

    let decomp = lu(&A);

    // Solve Ax = b
    let mut b: Vector<Float> = Vector.zeros(3);
    b.set(0, 5.0);
    b.set(1, 11.0);
    b.set(2, 25.0);

    let x = lu_solve(&decomp, &b);

    // Verify: A*x should equal b
    let ax_result = A.matvec(&x);
    assert(vector_approx_eq(&ax_result, &b, 1e-10));

    print("LU decomposition tests passed");
}

@test
fn test_qr_decomposition() {
    // Test matrix
    let mut A: Matrix<Float> = Matrix.zeros(3, 2);
    A.set(0, 0, 1.0);
    A.set(0, 1, 2.0);
    A.set(1, 0, 3.0);
    A.set(1, 1, 4.0);
    A.set(2, 0, 5.0);
    A.set(2, 1, 6.0);

    let decomp = qr(&A);

    // Q should be orthogonal: Q^T * Q = I
    let qt_q = decomp.q.transpose().matmul(&decomp.q);
    for i in 0..qt_q.rows() {
        for j in 0..qt_q.cols() {
            let expected = if i == j { 1.0 } else { 0.0 };
            assert(approx_eq(qt_q.get(i, j), expected, 1e-10));
        }
    }

    // R should be upper triangular (zeros below diagonal)
    for i in 1..decomp.r.rows() {
        let limit = if i < decomp.r.cols() { i } else { decomp.r.cols() };
        for j in 0..limit {
            assert(approx_eq(decomp.r.get(i, j), 0.0, 1e-10));
        }
    }

    // Q*R should equal A
    let qr_product = decomp.q.matmul(&decomp.r);
    assert(matrix_approx_eq(&qr_product, &A, 1e-10));

    print("QR decomposition tests passed");
}

@test
fn test_cholesky_decomposition() {
    // Symmetric positive definite matrix
    // A = [[4, 2], [2, 5]]
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 4.0);
    A.set(0, 1, 2.0);
    A.set(1, 0, 2.0);
    A.set(1, 1, 5.0);

    match cholesky(&A) {
        Maybe.Some(decomp) => {
            // L should be lower triangular
            assert(approx_eq(decomp.l.get(0, 1), 0.0, 1e-12));

            // L * L^T should equal A
            let l_lt = decomp.l.matmul(&decomp.l.transpose());
            assert(matrix_approx_eq(&l_lt, &A, 1e-10));

            // Test solve
            let mut b: Vector<Float> = Vector.zeros(2);
            b.set(0, 10.0);
            b.set(1, 17.0);

            let x = cholesky_solve(&decomp, &b);

            // Verify: A*x = b
            let ax_result = A.matvec(&x);
            assert(vector_approx_eq(&ax_result, &b, 1e-10));
        }
        Maybe.None => {
            assert(false);  // Should succeed for positive definite matrix
        }
    }

    // Non-positive definite matrix should fail
    let mut B: Matrix<Float> = Matrix.zeros(2, 2);
    B.set(0, 0, 1.0);
    B.set(0, 1, 2.0);
    B.set(1, 0, 2.0);
    B.set(1, 1, 1.0);  // det = 1 - 4 = -3 < 0

    match cholesky(&B) {
        Maybe.Some(_) => {
            assert(false);  // Should fail for non-positive definite
        }
        Maybe.None => {
            // Expected
        }
    }

    print("Cholesky decomposition tests passed");
}

