}

@test
fn test_cond_diagonal() {
    let mut d: Vector<Float> = Vector.zeros(2);
    d.set(0, 10.0);
    d.set(1, 1.0);
    let a = Matrix.diag(&d);
    let c = cond(&a);
    // cond = max_sv / min_sv = 10 / 1 = 10
    assert(approx_eq(c, 10.0, 1e-6));

    print("Condition number diagonal test passed");
}

