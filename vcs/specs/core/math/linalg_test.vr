// TriangularType and DiagonalType Tests
// =============================================================================

@test
fn test_triangular_type_upper() {
    let t = TriangularType.Upper;
    assert(t is TriangularType.Upper);
}

@test
fn test_triangular_type_lower() {
    let t = TriangularType.Lower;
    assert(t is TriangularType.Lower);
}

@test
fn test_diagonal_type_unit() {
    let d = DiagonalType.Unit;
    assert(d is DiagonalType.Unit);
}

@test
fn test_diagonal_type_nonunit() {
    let d = DiagonalType.NonUnit;
    assert(d is DiagonalType.NonUnit);
}

// =============================================================================
// LU Solve Verify Tests
// =============================================================================

@test
fn test_lu_solve_2x2() {
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 2.0);
    A.set(0, 1, 1.0);
    A.set(1, 0, 5.0);
    A.set(1, 1, 7.0);

    let decomp = lu(&A);

    let mut b: Vector<Float> = Vector.zeros(2);
    b.set(0, 11.0);
    b.set(1, 13.0);

    let x = lu_solve(&decomp, &b);
    let ax = A.matvec(&x);
    assert(vector_approx_eq(&ax, &b, 1e-10));
}

@test
fn test_determinant_3x3() {
    let mut A: Matrix<Float> = Matrix.zeros(3, 3);
    A.set(0, 0, 1.0);
    A.set(0, 1, 2.0);
    A.set(0, 2, 3.0);
    A.set(1, 0, 4.0);
    A.set(1, 1, 5.0);
    A.set(1, 2, 6.0);
    A.set(2, 0, 7.0);
    A.set(2, 1, 8.0);
    A.set(2, 2, 10.0);

    // det = 1*(50-48) - 2*(40-42) + 3*(32-35) = 2+4-9 = -3
    assert(approx_eq(determinant(&A), -3.0, 1e-8));
}

@test
fn test_inverse_2x2_specific() {
    // A = [[2, 1], [7, 4]]
    // det = 8 - 7 = 1
    // A^-1 = [[4, -1], [-7, 2]]
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 2.0);
    A.set(0, 1, 1.0);
    A.set(1, 0, 7.0);
    A.set(1, 1, 4.0);

    match inverse(&A) {
        Maybe.Some(a_inv) => {
            assert(approx_eq(a_inv.get(0, 0), 4.0, 1e-10));
            assert(approx_eq(a_inv.get(0, 1), -1.0, 1e-10));
            assert(approx_eq(a_inv.get(1, 0), -7.0, 1e-10));
            assert(approx_eq(a_inv.get(1, 1), 2.0, 1e-10));
        }
        Maybe.None => {
            assert(false);
        }
    }
}
