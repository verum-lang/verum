@test
fn test_solve() {
    // 2x2 system
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 3.0);
    A.set(0, 1, 1.0);
    A.set(1, 0, 1.0);
    A.set(1, 1, 2.0);

    let mut b: Vector<Float> = Vector.zeros(2);
    b.set(0, 9.0);
    b.set(1, 8.0);

    match solve(&A, &b) {
        Maybe.Some(x) => {
            // Verify: A*x = b
            let ax_result = A.matvec(&x);
            assert(vector_approx_eq(&ax_result, &b, 1e-10));

            // Solution should be [2, 3]
            assert(approx_eq(x.get(0), 2.0, 1e-10));
            assert(approx_eq(x.get(1), 3.0, 1e-10));
        }
        Maybe.None => {
            assert(false);
        }
    }

    print("Solve tests passed");
}

@test
fn test_inverse() {
    // 2x2 matrix
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 4.0);
    A.set(0, 1, 7.0);
    A.set(1, 0, 2.0);
    A.set(1, 1, 6.0);

    match inverse(&A) {
        Maybe.Some(a_inv) => {
            // A * A^-1 should be identity
            let ident = A.matmul(&a_inv);
            assert(approx_eq(ident.get(0, 0), 1.0, 1e-10));
            assert(approx_eq(ident.get(0, 1), 0.0, 1e-10));
            assert(approx_eq(ident.get(1, 0), 0.0, 1e-10));
            assert(approx_eq(ident.get(1, 1), 1.0, 1e-10));

            // A^-1 * A should also be identity
            let ident2 = a_inv.matmul(&A);
            assert(approx_eq(ident2.get(0, 0), 1.0, 1e-10));
            assert(approx_eq(ident2.get(1, 1), 1.0, 1e-10));
        }
        Maybe.None => {
            assert(false);
        }
    }

    // Singular matrix should fail
    let mut S: Matrix<Float> = Matrix.zeros(2, 2);
    S.set(0, 0, 1.0);
    S.set(0, 1, 2.0);
    S.set(1, 0, 2.0);
    S.set(1, 1, 4.0);  // Rank 1

    match inverse(&S) {
        Maybe.Some(_) => {
            assert(false);  // Should fail for singular matrix
        }
        Maybe.None => {
            // Expected
        }
    }

    print("Inverse tests passed");
}

@test
fn test_determinant() {
    // 2x2 matrix: det = ad - bc
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 3.0);
    A.set(0, 1, 8.0);
    A.set(1, 0, 4.0);
    A.set(1, 1, 6.0);

    // det = 3*6 - 8*4 = 18 - 32 = -14
    assert(approx_eq(determinant(&A), -14.0, 1e-10));

    // Identity matrix has determinant 1
    let id: Matrix<Float> = Matrix.eye(3);
    assert(approx_eq(determinant(&id), 1.0, 1e-10));

    // Singular matrix has determinant 0
    let mut S: Matrix<Float> = Matrix.zeros(2, 2);
    S.set(0, 0, 1.0);
    S.set(0, 1, 2.0);
    S.set(1, 0, 2.0);
    S.set(1, 1, 4.0);
    assert(approx_eq(determinant(&S), 0.0, 1e-10));

    print("Determinant tests passed");
}

