@test
fn test_svd_2x2() {
    let mut A: Matrix<Float> = Matrix.zeros(2, 2);
    A.set(0, 0, 3.0);
    A.set(0, 1, 0.0);
    A.set(1, 0, 0.0);
    A.set(1, 1, 4.0);

    let decomp = svd(&A);

    // Singular values should be 4 and 3 (sorted descending)
    assert(decomp.s.get(0) >= decomp.s.get(1));

    // U should be orthogonal: U^T * U = I
    let ut_u = decomp.u.transpose().matmul(&decomp.u);
    assert(approx_eq(ut_u.get(0, 0), 1.0, 1e-10));
    assert(approx_eq(ut_u.get(1, 1), 1.0, 1e-10));

    // V should be orthogonal: V^T * V = I
    let vt_v = decomp.vt.transpose().matmul(&decomp.vt);
    assert(approx_eq(vt_v.get(0, 0), 1.0, 1e-10));

    print("SVD 2x2 tests passed");
}

@test
fn test_svd_diagonal() {
    // SVD of diagonal matrix should return diagonal singular values
    let mut A: Matrix<Float> = Matrix.zeros(3, 3);
    A.set(0, 0, 5.0);
    A.set(1, 1, 3.0);
    A.set(2, 2, 1.0);

    let decomp = svd(&A);

    // Singular values in descending order
    assert(decomp.s.get(0) >= decomp.s.get(1));
    assert(decomp.s.get(1) >= decomp.s.get(2));

    print("SVD diagonal tests passed");
}

