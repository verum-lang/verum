// =============================================================================
// Section 10: Error Kind Distinctness
// =============================================================================

@test
fn test_error_kinds_are_distinct() {
    let refused = StreamError.new(IoErrorKind.ConnectionRefused);
    let reset = StreamError.new(IoErrorKind.ConnectionReset);
    let timeout = StreamError.new(IoErrorKind.TimedOut);
    // Each error kind should be distinct
    assert(refused.kind() != reset.kind());
    assert(reset.kind() != timeout.kind());
    assert(refused.kind() != timeout.kind());
}

// =============================================================================
// Section 11: Shutdown Exhaustive Match
// =============================================================================

@test
fn test_shutdown_exhaustive_match() {
    let variants = [Shutdown.Read, Shutdown.Write, Shutdown.Both];
    let mut read_count = 0;
    let mut write_count = 0;
    let mut both_count = 0;

    for s in variants {
        match s {
            Shutdown.Read => { read_count = read_count + 1; }
            Shutdown.Write => { write_count = write_count + 1; }
            Shutdown.Both => { both_count = both_count + 1; }
        }
    }
    assert_eq(read_count, 1);
    assert_eq(write_count, 1);
    assert_eq(both_count, 1);
}

@test
fn test_shutdown_is_operator() {
    let read = Shutdown.Read;
    let write = Shutdown.Write;
    let both = Shutdown.Both;

    assert(read is Shutdown.Read);
    assert(!(read is Shutdown.Write));
    assert(!(read is Shutdown.Both));

    assert(write is Shutdown.Write);
    assert(!(write is Shutdown.Read));
    assert(!(write is Shutdown.Both));

    assert(both is Shutdown.Both);
    assert(!(both is Shutdown.Read));
    assert(!(both is Shutdown.Write));
}

