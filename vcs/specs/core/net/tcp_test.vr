// =============================================================================
// tcp_test.vr - Comprehensive tests for TCP stream and listener types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: net, tcp, stream, listener, socket, shutdown, error
// @description: Tests for TcpStream, TcpListener, Incoming, Shutdown types
//               and TCP error conditions via StreamError/IoErrorKind
// =============================================================================

mount core.net.{TcpStream, TcpListener, Incoming};
mount core.net.tcp.Shutdown;
mount core.net.{SocketAddr, SocketAddrV4, SocketAddrV6, Ipv4Addr, Ipv6Addr};
mount core.io.protocols.{IoResult, StreamError, IoErrorKind};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: TcpStream Type Existence
// =============================================================================

@test
fn test_tcp_stream_type_exists() {
    // TcpStream wraps a file descriptor
    // Can't construct without real socket, verify type compiles
    let opt: Maybe<TcpStream> = None;
    assert(opt.is_none());
}

