// =============================================================================
// Section 18: Shutdown Half-Close Patterns
// =============================================================================

@test
fn test_shutdown_read_half_close() {
    // Half-close read: remote can still send but we stop receiving
    let how = Shutdown.Read;
    let name = match how {
        Shutdown.Read => "read",
        Shutdown.Write => "write",
        Shutdown.Both => "both",
    };
    assert_eq(name, "read");
}

@test
fn test_shutdown_write_half_close() {
    // Half-close write: sends FIN, remote gets EOF on read
    let how = Shutdown.Write;
    let name = match how {
        Shutdown.Read => "read",
        Shutdown.Write => "write",
        Shutdown.Both => "both",
    };
    assert_eq(name, "write");
}

@test
fn test_shutdown_both_full_close() {
    // Full close: both halves shut down
    let how = Shutdown.Both;
    let name = match how {
        Shutdown.Read => "read",
        Shutdown.Write => "write",
        Shutdown.Both => "both",
    };
    assert_eq(name, "both");
}

@test
fn test_shutdown_variant_count() {
    // Shutdown has exactly 3 variants
    let variants = [Shutdown.Read, Shutdown.Write, Shutdown.Both];
    assert_eq(variants.len(), 3);
}

// =============================================================================
// Section 19: Socket Option Patterns
// =============================================================================

@test
fn test_tcp_nodelay_enable_disable() {
    // TCP_NODELAY can be enabled (true) or disabled (false)
    let enable: Bool = true;
    let disable: Bool = false;
    assert(enable != disable);
}

@test
fn test_tcp_keepalive_enable_disable() {
    // SO_KEEPALIVE can be enabled or disabled
    let enable: Bool = true;
    let disable: Bool = false;
    assert(enable);
    assert(!disable);
}

@test
fn test_tcp_timeout_some_value() {
    // Timeout as Some(milliseconds)
    let timeout: Maybe<Int> = Some(30000);
    match timeout {
        Some(ms) => assert_eq(ms, 30000),
        None => panic("expected Some"),
    }
}

@test
fn test_tcp_timeout_none_infinite() {
    // Timeout as None means infinite/blocking
    let timeout: Maybe<Int> = None;
    assert(timeout.is_none());
    let effective_ms = timeout.unwrap_or(0);
    assert_eq(effective_ms, 0);
}

@test
fn test_tcp_read_write_timeout_types() {
    // Both read and write timeouts use Maybe<Int>
    let read_timeout: Maybe<Int> = Some(5000);
    let write_timeout: Maybe<Int> = Some(10000);
    assert(read_timeout.is_some());
    assert(write_timeout.is_some());
    assert(read_timeout.unwrap() != write_timeout.unwrap());
}

