// =============================================================================
// Section 4: Shutdown Variants
// =============================================================================

@test
fn test_shutdown_read() {
    let s: Shutdown = Shutdown.Read;
    assert(s is Shutdown.Read);
    assert(!(s is Shutdown.Write));
    assert(!(s is Shutdown.Both));
}

@test
fn test_shutdown_write() {
    let s: Shutdown = Shutdown.Write;
    assert(s is Shutdown.Write);
    assert(!(s is Shutdown.Read));
    assert(!(s is Shutdown.Both));
}

@test
fn test_shutdown_both() {
    let s: Shutdown = Shutdown.Both;
    assert(s is Shutdown.Both);
    assert(!(s is Shutdown.Read));
    assert(!(s is Shutdown.Write));
}

@test
fn test_shutdown_match_read() {
    let s = Shutdown.Read;
    assert(s is Shutdown.Read);
}

@test
fn test_shutdown_match_write() {
    let s = Shutdown.Write;
    assert(s is Shutdown.Write);
}

@test
fn test_shutdown_match_both() {
    let s = Shutdown.Both;
    assert(s is Shutdown.Both);
}

