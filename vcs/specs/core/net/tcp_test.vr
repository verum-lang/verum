@test
fn test_tcp_error_new_has_no_message() {
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    assert(err.message().is_none());
}

@test
fn test_tcp_error_with_message_has_message() {
    let err = StreamError.with_message(IoErrorKind.BrokenPipe, "write to closed socket");
    assert(err.message().is_some());
}

@test
fn test_tcp_error_message_content() {
    let msg = "connection to 10.0.0.1:5432 refused";
    let err = StreamError.with_message(IoErrorKind.ConnectionRefused, msg);
    assert_eq(err.kind(), IoErrorKind.ConnectionRefused);
    assert(err.message().is_some());
}

@test
fn test_tcp_error_reset_with_context() {
    let err = StreamError.with_message(IoErrorKind.ConnectionReset, "peer forcibly closed");
    assert_eq(err.kind(), IoErrorKind.ConnectionReset);
    assert(err.message().is_some());
}

@test
fn test_tcp_error_broken_pipe_with_context() {
    let err = StreamError.with_message(IoErrorKind.BrokenPipe, "write after peer shutdown");
    assert_eq(err.kind(), IoErrorKind.BrokenPipe);
    assert(err.message().is_some());
}

// =============================================================================
// Section 22: Address Patterns for TCP Scenarios
// =============================================================================

@test
fn test_tcp_dual_stack_bind_addrs() {
    // Server binding to both IPv4 and IPv6 wildcard addresses
    let v4 = SocketAddr.new_v4(Ipv4Addr.unspecified(), 8080);
    let v6 = SocketAddr.new_v6(Ipv6Addr.unspecified(), 8080);
    assert(v4 is SocketAddr.V4);
    assert(v6 is SocketAddr.V6);
}

@test
fn test_tcp_common_service_ports() {
    // Commonly used TCP service ports
    let ssh_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 22);
    let smtp_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 25);
    let dns_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 53);
    let http_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 80);
    let https_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 443);
    let postgres_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 5432);
    let mysql_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 3306);
    let redis_addr = SocketAddrV4.new(Ipv4Addr.localhost(), 6379);

    assert_eq(ssh_addr.port(), 22);
    assert_eq(smtp_addr.port(), 25);
    assert_eq(dns_addr.port(), 53);
    assert_eq(http_addr.port(), 80);
    assert_eq(https_addr.port(), 443);
    assert_eq(postgres_addr.port(), 5432);
    assert_eq(mysql_addr.port(), 3306);
    assert_eq(redis_addr.port(), 6379);
}

@test
fn test_tcp_multicast_addr_not_valid_for_tcp() {
    // Multicast addresses are for UDP, not TCP
    let addr = Ipv4Addr.new(224, 0, 0, 1);
    assert(addr.is_multicast());
    // TCP should not bind to multicast; verify address classification
    assert(!addr.is_loopback());
    assert(!addr.is_private());
}

@test
fn test_tcp_broadcast_addr_not_valid_for_tcp() {
    // Broadcast address is not valid for TCP
    let addr = Ipv4Addr.broadcast();
    assert(addr.is_broadcast());
    assert(!addr.is_loopback());
}

@test
fn test_tcp_ipv6_link_local_addr() {
    // Link-local IPv6 address (fe80::1) with scope_id
    let addr = SocketAddrV6.new(
        Ipv6Addr.new(0xfe80, 0, 0, 0, 0, 0, 0, 1),
        8080, 0, 1
    );
    assert_eq(addr.port(), 8080);
}

@test
fn test_tcp_loopback_both_families() {
    // Loopback addresses in both IPv4 and IPv6
    let v4_lo = Ipv4Addr.localhost();
    let v6_lo = Ipv6Addr.localhost();
    assert(v4_lo.is_loopback());
    assert(v6_lo.is_loopback());
}

// =============================================================================
// Section 23: IoResult Alias Patterns
// =============================================================================

@test
fn test_io_result_ok_bytes_read() {
    // IoResult<Int> for bytes read
    let result: IoResult<Int> = Ok(4096);
    assert(result.is_ok());
    match result {
        Ok(n) => assert_eq(n, 4096),
        Err(_) => panic("expected Ok"),
    }
}

@test
fn test_io_result_ok_unit() {
    // IoResult<()> for operations that return nothing
    let result: Result<(), StreamError> = Ok(());
    assert(result.is_ok());
}

@test
fn test_io_result_err_conversion() {
    // IoResult wraps StreamError
    let err = StreamError.new(IoErrorKind.BrokenPipe);
    let result: IoResult<Int> = Err(err);
    assert(result.is_err());
    match result {
        Ok(_) => panic("expected Err"),
        Err(e) => assert_eq(e.kind(), IoErrorKind.BrokenPipe),
    }
}

// =============================================================================
// Section 24: TCP Error Classification Groups
// =============================================================================

@test
fn test_tcp_all_io_error_kinds_exist() {
    // Verify all IoErrorKind variants exist
    let kinds = [
        IoErrorKind.NotFound,
        IoErrorKind.PermissionDenied,
        IoErrorKind.ConnectionRefused,
        IoErrorKind.ConnectionReset,
        IoErrorKind.ConnectionAborted,
        IoErrorKind.NotConnected,
        IoErrorKind.AddrInUse,
        IoErrorKind.AddrNotAvailable,
        IoErrorKind.BrokenPipe,
        IoErrorKind.AlreadyExists,
        IoErrorKind.WouldBlock,
        IoErrorKind.InvalidInput,
        IoErrorKind.InvalidData,
        IoErrorKind.TimedOut,
        IoErrorKind.WriteZero,
        IoErrorKind.Interrupted,
        IoErrorKind.UnexpectedEof,
        IoErrorKind.OutOfMemory,
        IoErrorKind.Unsupported,
        IoErrorKind.Other,
    ];
    assert_eq(kinds.len(), 20);
}

@test
fn test_tcp_network_error_group() {
    // Errors specifically related to network/connection issues
    let network_kinds = [
        IoErrorKind.ConnectionRefused,
        IoErrorKind.ConnectionReset,
        IoErrorKind.ConnectionAborted,
        IoErrorKind.NotConnected,
        IoErrorKind.BrokenPipe,
        IoErrorKind.TimedOut,
    ];
    for kind in network_kinds {
        let err = StreamError.new(kind);
        let is_network = match err.kind() {
            IoErrorKind.ConnectionRefused => true,
            IoErrorKind.ConnectionReset => true,
            IoErrorKind.ConnectionAborted => true,
            IoErrorKind.NotConnected => true,
            IoErrorKind.BrokenPipe => true,
            IoErrorKind.TimedOut => true,
            _ => false,
        };
        assert(is_network);
    }
}

@test
fn test_tcp_resource_error_group() {
    // Errors related to resource availability
    let resource_kinds = [
        IoErrorKind.AddrInUse,
        IoErrorKind.AddrNotAvailable,
        IoErrorKind.OutOfMemory,
        IoErrorKind.AlreadyExists,
    ];
    for kind in resource_kinds {
        let err = StreamError.new(kind);
        let is_resource = match err.kind() {
            IoErrorKind.AddrInUse => true,
            IoErrorKind.AddrNotAvailable => true,
            IoErrorKind.OutOfMemory => true,
            IoErrorKind.AlreadyExists => true,
            _ => false,
        };
        assert(is_resource);
    }
}

// =============================================================================
// Section 25: Result Chaining and Transformation
// =============================================================================

@test
fn test_tcp_result_map_ok() {
    let result: Result<Int, StreamError> = Ok(512);
    let doubled = result.map(|n| n * 2);
    assert_eq(doubled.unwrap(), 1024);
}

@test
fn test_tcp_result_map_err_preserves_error() {
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    let result: Result<Int, StreamError> = Err(err);
    let mapped = result.map(|n| n * 2);
    assert(mapped.is_err());
}

@test
fn test_tcp_result_unwrap_or_default() {
    let err = StreamError.new(IoErrorKind.TimedOut);
    let result: Result<Int, StreamError> = Err(err);
    let val = result.unwrap_or(0);
    assert_eq(val, 0);
}

@test
fn test_tcp_result_ok_unwrap() {
    let result: Result<Int, StreamError> = Ok(8192);
    assert_eq(result.unwrap(), 8192);
}

@test
fn test_tcp_result_and_then_chain() {
    let result: Result<Int, StreamError> = Ok(100);
    let chained: Result<Int, StreamError> = result.and_then(|n| Ok(n + 50));
    match chained {
        Ok(v) => assert_eq(v, 150),
        Err(_) => panic("expected Ok"),
    }
}

@test
fn test_tcp_result_and_then_err_short_circuit() {
    let err = StreamError.new(IoErrorKind.BrokenPipe);
    let result: Result<Int, StreamError> = Err(err);
    let chained: Result<Int, StreamError> = result.and_then(|n| Ok(n + 50));
    assert(chained.is_err());
}

// =============================================================================
// Section 26: TCP Connection State Modeling
// =============================================================================

@test
fn test_tcp_connection_states_as_variants() {
    // Model TCP connection states using Shutdown and error patterns
    // ESTABLISHED: both read and write active
    let established_read: Bool = true;
    let established_write: Bool = true;
    assert(established_read);
    assert(established_write);

    // CLOSE_WAIT: write still active after read shutdown
    let close_wait_read: Bool = false;
    let close_wait_write: Bool = true;
    assert(!close_wait_read);
    assert(close_wait_write);
}

@test
fn test_tcp_graceful_shutdown_sequence() {
    // Model graceful TCP close: shutdown write, then full close
    let step1 = Shutdown.Write;  // Send FIN
    let step2 = Shutdown.Both;   // Full close

    assert(step1 is Shutdown.Write);
    assert(step2 is Shutdown.Both);
}

// =============================================================================
// Section 27: Address Set Port Patterns
// =============================================================================

@test
fn test_tcp_addr_set_port() {
    let mut addr = SocketAddrV4.new(Ipv4Addr.localhost(), 8080);
    assert_eq(addr.port(), 8080);
    addr.set_port(9090);
    assert_eq(addr.port(), 9090);
}

@test
fn test_tcp_addr_set_port_to_zero() {
    let mut addr = SocketAddrV4.new(Ipv4Addr.localhost(), 8080);
    addr.set_port(0);
    assert_eq(addr.port(), 0);
}

@test
fn test_tcp_addr_set_port_max() {
    let mut addr = SocketAddrV4.new(Ipv4Addr.localhost(), 0);
    addr.set_port(65535);
    assert_eq(addr.port(), 65535);
}

// =============================================================================
// Section 28: Error Clone Pattern
// =============================================================================

@test
fn test_tcp_stream_error_clone() {
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    let cloned = err.clone();
    assert_eq(cloned.kind(), IoErrorKind.ConnectionRefused);
}

@test
fn test_tcp_stream_error_clone_with_message() {
    let err = StreamError.with_message(IoErrorKind.TimedOut, "dial tcp timeout");
    let cloned = err.clone();
    assert_eq(cloned.kind(), IoErrorKind.TimedOut);
    assert(cloned.message().is_some());
}

