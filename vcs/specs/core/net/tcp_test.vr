    assert_eq(err.kind(), IoErrorKind.InvalidInput);
}

@test
fn test_tcp_error_invalid_data() {
    let err = StreamError.new(IoErrorKind.InvalidData);
    assert_eq(err.kind(), IoErrorKind.InvalidData);
}

@test
fn test_tcp_error_other() {
    let err = StreamError.new(IoErrorKind.Other);
    assert_eq(err.kind(), IoErrorKind.Other);
}

@test
fn test_tcp_error_from_raw_os_error() {
    // ECONNREFUSED = 111 on Linux
    let err = StreamError.from_raw_os_error(111);
    assert_eq(err.kind(), IoErrorKind.ConnectionRefused);
}

@test
fn test_tcp_error_from_errno_econnreset() {
    // ECONNRESET = 104 on Linux
    let err = StreamError.from_errno(104);
    assert_eq(err.kind(), IoErrorKind.ConnectionReset);
}

@test
fn test_tcp_error_from_errno_epipe() {
    // EPIPE = 32 on Linux
    let err = StreamError.from_errno(32);
    assert_eq(err.kind(), IoErrorKind.BrokenPipe);
}

@test
fn test_tcp_error_from_errno_eagain() {
    // EAGAIN = 11 on Linux
    let err = StreamError.from_errno(11);
    assert_eq(err.kind(), IoErrorKind.WouldBlock);
}

@test
fn test_tcp_error_from_errno_etimedout() {
    // ETIMEDOUT = 110 on Linux
    let err = StreamError.from_errno(110);
    assert_eq(err.kind(), IoErrorKind.TimedOut);
}

@test
fn test_tcp_error_from_errno_unknown() {
    // Unknown errno maps to Other
    let err = StreamError.from_errno(999);
    assert_eq(err.kind(), IoErrorKind.Other);
}

