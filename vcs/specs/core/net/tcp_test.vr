@test
fn test_tcp_server_socket_addr() {
    // Server binds to 0.0.0.0:port
    let server_addr = SocketAddrV4.new(Ipv4Addr.unspecified(), 3000);
    assert_eq(server_addr.port(), 3000);
    assert(server_addr.ip().is_unspecified());
}

@test
fn test_tcp_client_socket_addr() {
    // Client connects to specific host:port
    let client_addr = SocketAddrV4.new(Ipv4Addr.new(192, 168, 1, 100), 8080);
    assert_eq(client_addr.port(), 8080);
    assert(!client_addr.ip().is_loopback());
}

@test
fn test_tcp_socket_addr_v4_v6_coexistence() {
    // Server can bind to both v4 and v6
    let v4_addr = SocketAddr.new_v4(Ipv4Addr.unspecified(), 9000);
    let v6_addr = SocketAddr.new_v6(Ipv6Addr.unspecified(), 9000);

    assert(v4_addr is SocketAddr.V4);
    assert(v6_addr is SocketAddr.V6);
}

@test
fn test_tcp_ephemeral_port() {
    // Port 0 means OS assigns ephemeral port
    let addr = SocketAddrV4.new(Ipv4Addr.localhost(), 0);
    assert_eq(addr.port(), 0);
}

@test
fn test_tcp_private_network_addrs() {
    // Common private network addresses used in TCP
    let addr_10 = SocketAddrV4.new(Ipv4Addr.new(10, 0, 0, 1), 80);
    let addr_172 = SocketAddrV4.new(Ipv4Addr.new(172, 16, 0, 1), 80);
    let addr_192 = SocketAddrV4.new(Ipv4Addr.new(192, 168, 0, 1), 80);

    assert(addr_10.ip().is_private());
    assert(addr_172.ip().is_private());
    assert(addr_192.ip().is_private());
}

// =============================================================================
// Section 15: Multiple Error Kinds Match Pattern
// =============================================================================

@test
fn test_tcp_retryable_errors() {
    // Errors that should trigger retry logic
    let retryable_kinds = [
        IoErrorKind.ConnectionRefused,
        IoErrorKind.TimedOut,
        IoErrorKind.Interrupted,
        IoErrorKind.WouldBlock,
    ];

    for kind in retryable_kinds {
        let err = StreamError.new(kind);
        let should_retry = match err.kind() {
            IoErrorKind.ConnectionRefused => true,
            IoErrorKind.TimedOut => true,
            IoErrorKind.Interrupted => true,
            IoErrorKind.WouldBlock => true,
            _ => false,
        };
        assert(should_retry);
    }
}

@test
fn test_tcp_fatal_errors() {
    // Errors that should NOT trigger retry
    let fatal_kinds = [
        IoErrorKind.PermissionDenied,
        IoErrorKind.AddrInUse,
        IoErrorKind.AddrNotAvailable,
    ];

    for kind in fatal_kinds {
        let err = StreamError.new(kind);
        let is_fatal = match err.kind() {
            IoErrorKind.PermissionDenied => true,
            IoErrorKind.AddrInUse => true,
            IoErrorKind.AddrNotAvailable => true,
            _ => false,
        };
        assert(is_fatal);
    }
}

