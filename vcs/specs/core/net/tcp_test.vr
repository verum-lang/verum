@test
fn test_tcp_error_all_connection_kinds() {
    // All connection-related error kinds
    let kinds = [
        IoErrorKind.ConnectionRefused,
        IoErrorKind.ConnectionReset,
        IoErrorKind.ConnectionAborted,
        IoErrorKind.NotConnected,
    ];
    for kind in kinds {
        let err = StreamError.new(kind);
        assert_eq(err.kind(), kind);
    }
}

@test
fn test_tcp_error_with_context_message() {
    let err = StreamError.with_message(IoErrorKind.ConnectionRefused, "connect to 127.0.0.1:8080 refused");
    assert_eq(err.kind(), IoErrorKind.ConnectionRefused);
    assert(err.message().is_some());
}

@test
fn test_tcp_error_addr_in_use_with_port() {
    let err = StreamError.with_message(IoErrorKind.AddrInUse, "port 80 already in use");
    assert_eq(err.kind(), IoErrorKind.AddrInUse);
}

@test
fn test_tcp_error_timed_out_with_context() {
    let err = StreamError.with_message(IoErrorKind.TimedOut, "connection timed out after 30000ms");
    assert_eq(err.kind(), IoErrorKind.TimedOut);
}

// =============================================================================
// Section 13: IoResult Patterns for TCP
// =============================================================================

@test
fn test_tcp_result_ok_chain() {
    let result: Result<Int, StreamError> = Ok(1024);
    let mapped = result.map(|n| n * 2);
    match mapped {
        Ok(n) => assert_eq(n, 2048),
        Err(_) => panic("expected Ok"),
    }
}

@test
fn test_tcp_result_err_chain() {
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
    match result {
        Ok(_) => panic("expected Err"),
        Err(e) => assert_eq(e.kind(), IoErrorKind.ConnectionRefused),
    }
}

@test
fn test_tcp_result_or_else() {
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    let result: Result<Int, StreamError> = Err(err);
    let fallback: Int = result.unwrap_or(0);
    assert_eq(fallback, 0);
}

