// =============================================================================
// Section 15: Error Types for UDP
// =============================================================================

@test
fn test_udp_error_with_message() {
    let err = StreamError.with_message(IoErrorKind.AddrInUse, "Port 5000 already bound");
    assert_eq(err.kind(), IoErrorKind.AddrInUse);
    assert(err.message().is_some());
}

@test
fn test_udp_error_without_message() {
    let err = StreamError.new(IoErrorKind.WouldBlock);
    assert_eq(err.kind(), IoErrorKind.WouldBlock);
    assert(err.message().is_none());
}

@test
fn test_udp_error_broken_pipe() {
    // Rare for UDP, but can occur in certain connected scenarios
    let err = StreamError.new(IoErrorKind.BrokenPipe);
    assert_eq(err.kind(), IoErrorKind.BrokenPipe);
}

@test
fn test_udp_error_interrupted() {
    // System call interrupted by signal
    let err = StreamError.new(IoErrorKind.Interrupted);
    assert_eq(err.kind(), IoErrorKind.Interrupted);
}

@test
fn test_udp_error_invalid_input() {
    // e.g., buffer too large, invalid address
    let err = StreamError.new(IoErrorKind.InvalidInput);
    assert_eq(err.kind(), IoErrorKind.InvalidInput);
}

@test
fn test_udp_error_connection_reset() {
    // ICMP destination unreachable on connected UDP
    let err = StreamError.new(IoErrorKind.ConnectionReset);
    assert_eq(err.kind(), IoErrorKind.ConnectionReset);
}

@test
fn test_udp_error_other() {
    let err = StreamError.new(IoErrorKind.Other);
    assert_eq(err.kind(), IoErrorKind.Other);
}

@test
fn test_udp_error_from_raw_os_errno() {
    // EACCES (13) maps to PermissionDenied
    let err = StreamError.from_raw_os_error(13);
    assert_eq(err.kind(), IoErrorKind.PermissionDenied);
}

@test
fn test_udp_error_from_errno_eagain() {
    // EAGAIN (11) maps to WouldBlock
    let err = StreamError.from_errno(11);
    assert_eq(err.kind(), IoErrorKind.WouldBlock);
}

@test
fn test_udp_error_from_errno_connrefused() {
    // ECONNREFUSED (111) maps to ConnectionRefused
    let err = StreamError.from_raw_os_error(111);
    assert_eq(err.kind(), IoErrorKind.ConnectionRefused);
}

// =============================================================================
// Section 16: Address Patterns for UDP
// =============================================================================

@test
fn test_udp_private_network_10() {
    // 10.0.0.0/8 private range
    let addr = Ipv4Addr.new(10, 0, 0, 1);
    assert(addr.is_private());
    assert(!addr.is_loopback());
}

@test
fn test_udp_private_network_172() {
    // 172.16.0.0/12 private range
    let addr = Ipv4Addr.new(172, 16, 0, 1);
    assert(addr.is_private());
}

@test
fn test_udp_private_network_192() {
    // 192.168.0.0/16 private range
    let addr = Ipv4Addr.new(192, 168, 0, 1);
    assert(addr.is_private());
}

@test
fn test_udp_well_known_ports() {
    // Test well-known UDP service ports
    let dhcp_server = SocketAddrV4.new(Ipv4Addr.unspecified(), 67);
    let dhcp_client = SocketAddrV4.new(Ipv4Addr.unspecified(), 68);
    let ntp = SocketAddrV4.new(Ipv4Addr.unspecified(), 123);
    let snmp = SocketAddrV4.new(Ipv4Addr.unspecified(), 161);
    assert_eq(dhcp_server.port(), 67);
    assert_eq(dhcp_client.port(), 68);
    assert_eq(ntp.port(), 123);
    assert_eq(snmp.port(), 161);
}

@test
fn test_udp_socket_addr_v4_construction() {
    // SocketAddr wrapping for V4
    let ip = Ipv4Addr.new(127, 0, 0, 1);
    let sa = SocketAddr.new_v4(ip, 4000);
    assert(sa.is_ipv4());
}

@test
fn test_udp_socket_addr_v6_construction() {
    // SocketAddr wrapping for V6
    let ip = Ipv6Addr.localhost();
    let sa = SocketAddr.new_v6(ip, 4001);
    assert(sa.is_ipv6());
}

// =============================================================================
// Section 17: send_to / recv_from Types
// =============================================================================

@test
fn test_udp_send_to_result_type() {
    // send_to returns Result<Int, IoError> where Int = bytes sent
    let result: Result<Int, StreamError> = Ok(512);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 512);
}

@test
fn test_udp_recv_from_result_type() {
    // recv_from returns Result<(Int, SocketAddr), IoError>
    let addr = SocketAddr.new_v4(Ipv4Addr.localhost(), 9999);
    let result: Result<(Int, SocketAddr), StreamError> = Ok((256, addr));
    assert(result.is_ok());
}

@test
fn test_udp_peek_from_result_type() {
    // peek_from returns Result<(Int, SocketAddr), IoError>
    let addr = SocketAddr.new_v4(Ipv4Addr.new(10, 0, 0, 5), 7777);
    let result: Result<(Int, SocketAddr), StreamError> = Ok((64, addr));
    assert(result.is_ok());
}

// =============================================================================
// Section 18: try_clone Pattern
// =============================================================================

@test
fn test_udp_try_clone_result_type() {
    // try_clone returns Result<UdpSocket, IoError>
    let result: Result<UdpSocket, StreamError> = Err(StreamError.new(IoErrorKind.Other));
    assert(result.is_err());
}

// =============================================================================
// Section 19: Result Chaining for UDP Operations
// =============================================================================

@test
fn test_udp_result_map() {
    // Chaining with map on OK result
    let result: Result<Int, StreamError> = Ok(1024);
    let doubled = result.map(|n| n * 2);
    assert(doubled.is_ok());
    assert_eq(doubled.unwrap(), 2048);
}

@test
fn test_udp_result_map_err() {
    // Chaining with map_err for error transformation
    let err = StreamError.new(IoErrorKind.WouldBlock);
    let result: Result<Int, StreamError> = Err(err);
    let mapped = result.map_err(|e| StreamError.with_message(e.kind(), "UDP send blocked"));
    assert(mapped.is_err());
}

@test
fn test_udp_result_and_then() {
    // Chaining multiple fallible operations
    let result: Result<Int, StreamError> = Ok(100);
    let chained: Result<Int, StreamError> = result.and_then(|n| Ok(n + 50));
    assert(chained.is_ok());
    assert_eq(chained.unwrap(), 150);
}

@test
fn test_udp_result_or_else() {
    // Fallback on error
    let err = StreamError.new(IoErrorKind.WouldBlock);
    let result: Result<Int, StreamError> = Err(err);
    let fallback: Result<Int, StreamError> = result.or_else(|_e| Ok(0));
    assert(fallback.is_ok());
    assert_eq(fallback.unwrap(), 0);
}

@test
fn test_udp_result_unwrap_or() {
    // Default value on error
    let err = StreamError.new(IoErrorKind.TimedOut);
    let result: Result<Int, StreamError> = Err(err);
    let val = result.unwrap_or(0);
    assert_eq(val, 0);
}

// =============================================================================
// Section 20: local_addr / peer_addr Types
// =============================================================================

@test
fn test_udp_local_addr_result_type() {
    // local_addr returns Result<SocketAddr, IoError>
    let addr = SocketAddr.new_v4(Ipv4Addr.unspecified(), 0);
    let result: Result<SocketAddr, StreamError> = Ok(addr);
    assert(result.is_ok());
}

@test
fn test_udp_peer_addr_not_connected() {
    // peer_addr returns Err(NotConnected) when not connected
    let err = StreamError.new(IoErrorKind.NotConnected);
    let result: Result<SocketAddr, StreamError> = Err(err);
    assert(result.is_err());
}

// =============================================================================
// Section 21: IPv6 Multicast Addresses
// =============================================================================

@test
fn test_udp_ipv6_multicast() {
    // IPv6 multicast: ff00::/8
    let mcast = Ipv6Addr.new(0xff02, 0, 0, 0, 0, 0, 0, 1);
    assert(mcast.is_multicast());
}

@test
fn test_udp_ipv6_non_multicast() {
    let addr = Ipv6Addr.localhost();
    assert(!addr.is_multicast());
}

@test
fn test_udp_ipv6_link_local() {
    // Link-local address fe80.1
    let addr = Ipv6Addr.new(0xfe80, 0, 0, 0, 0, 0, 0, 1);
    assert(addr.is_link_local());
}

@test
fn test_udp_ipv6_unspecified() {
    let addr = Ipv6Addr.unspecified();
    assert(addr.is_unspecified());
    assert(!addr.is_loopback());
}

// =============================================================================
// Section 22: IoResult Type Alias
// =============================================================================

@test
fn test_udp_io_result_alias_ok() {
    // IoResult<T> is Result<T, StreamError>
    let result: IoResult<Int> = Ok(42);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 42);
}

@test
fn test_udp_io_result_alias_err() {
    let result: IoResult<Int> = Err(StreamError.new(IoErrorKind.TimedOut));
    assert(result.is_err());
}

@test
fn test_udp_io_result_socket_type() {
    // IoResult<UdpSocket> for bind-like operations
    let result: IoResult<UdpSocket> = Err(StreamError.new(IoErrorKind.AddrNotAvailable));
    assert(result.is_err());
}

@test
fn test_udp_io_result_tuple_type() {
    // IoResult<(Int, SocketAddr)> for recv_from-like operations
    let addr = SocketAddr.new_v4(Ipv4Addr.localhost(), 1234);
    let result: IoResult<(Int, SocketAddr)> = Ok((128, addr));
    assert(result.is_ok());
}

@test
fn test_udp_io_result_unit_type() {
    // IoResult<()> for set_* operations (e.g., set_broadcast, set_nonblocking)
    let result: Result<(), StreamError> = Ok(());
    assert(result.is_ok());
}

fn main() {
    // Tests run via @test annotations
}
