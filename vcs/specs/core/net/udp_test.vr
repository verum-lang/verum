// =============================================================================
// udp_test.vr - Comprehensive tests for UDP socket types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: net, udp, socket, datagram, multicast, broadcast
// @description: Tests for UdpSocket type, error conditions via
//               StreamError/IoErrorKind, and address patterns for UDP
//               communication including multicast and broadcast.
// =============================================================================

mount core.net.udp.UdpSocket;
mount core.net.{SocketAddr, SocketAddrV4, SocketAddrV6, Ipv4Addr, Ipv6Addr};
mount core.io.protocols.{IoResult, StreamError, IoErrorKind};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: UdpSocket Type Existence
// =============================================================================

@test
fn test_udp_socket_type_exists() {
    // UdpSocket wraps a file descriptor
    // Can't construct without real socket, verify type compiles
    let opt: Maybe<UdpSocket> = None;
    assert(opt.is_none());
}

// =============================================================================
// Section 2: UDP Error Types
// =============================================================================

@test
fn test_udp_bind_error() {
    let err = StreamError.new(IoErrorKind.AddrInUse);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
    assert_eq(err.kind(), IoErrorKind.AddrInUse);
}

@test
fn test_udp_send_error() {
    let err = StreamError.new(IoErrorKind.NotConnected);
    assert_eq(err.kind(), IoErrorKind.NotConnected);
}

@test
fn test_udp_would_block() {
    let err = StreamError.new(IoErrorKind.WouldBlock);
    assert_eq(err.kind(), IoErrorKind.WouldBlock);
}

@test
fn test_udp_permission_denied() {
    let err = StreamError.new(IoErrorKind.PermissionDenied);
    assert_eq(err.kind(), IoErrorKind.PermissionDenied);
}

@test
fn test_udp_addr_not_available() {
    let err = StreamError.new(IoErrorKind.AddrNotAvailable);
    assert_eq(err.kind(), IoErrorKind.AddrNotAvailable);
}

@test
fn test_udp_connection_refused() {
    // ICMP port unreachable can cause this for connected UDP
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    assert_eq(err.kind(), IoErrorKind.ConnectionRefused);
}

@test
fn test_udp_timed_out() {
    let err = StreamError.new(IoErrorKind.TimedOut);
    assert_eq(err.kind(), IoErrorKind.TimedOut);
}

// =============================================================================
// Section 3: UDP Address Patterns
// =============================================================================

@test
fn test_udp_bind_any() {
    let addr = SocketAddrV4.new(Ipv4Addr.unspecified(), 5000);
    assert_eq(addr.port(), 5000);
}

@test
fn test_udp_bind_localhost() {
    let addr = SocketAddrV4.new(Ipv4Addr.localhost(), 5001);
    assert_eq(addr.port(), 5001);
}

@test
fn test_udp_ephemeral_port() {
    // Port 0 = OS assigns ephemeral port
    let addr = SocketAddrV4.new(Ipv4Addr.unspecified(), 0);
    assert_eq(addr.port(), 0);
}

@test
fn test_udp_high_port() {
    let addr = SocketAddrV4.new(Ipv4Addr.localhost(), 65535);
    assert_eq(addr.port(), 65535);
}

@test
fn test_udp_dns_port() {
    // Standard DNS port
    let addr = SocketAddrV4.new(Ipv4Addr.localhost(), 53);
    assert_eq(addr.port(), 53);
}

// =============================================================================
// Section 4: Multicast Addresses
// =============================================================================

@test
fn test_udp_multicast_addr() {
    // Multicast range: 224.0.0.0 - 239.255.255.255
    let mcast = Ipv4Addr.new(239, 0, 0, 1);
    assert(mcast.is_multicast());
}

@test
fn test_udp_multicast_all_hosts() {
    // 224.0.0.1 = all hosts on local segment
    let mcast = Ipv4Addr.new(224, 0, 0, 1);
    assert(mcast.is_multicast());
}

@test
fn test_udp_multicast_all_routers() {
    // 224.0.0.2 = all routers on local segment
    let mcast = Ipv4Addr.new(224, 0, 0, 2);
    assert(mcast.is_multicast());
}

@test
fn test_udp_non_multicast() {
    let addr = Ipv4Addr.new(192, 168, 1, 1);
    assert(!addr.is_multicast());
}

// =============================================================================
// Section 5: Broadcast Addresses
// =============================================================================

@test
fn test_udp_broadcast_addr() {
    let bcast = Ipv4Addr.broadcast();
    assert(bcast.is_broadcast());
}

@test
fn test_udp_non_broadcast() {
    let addr = Ipv4Addr.localhost();
    assert(!addr.is_broadcast());
}

// =============================================================================
// Section 6: Loopback
// =============================================================================

@test
fn test_udp_loopback_addr() {
    let lo = Ipv4Addr.localhost();
    assert(lo.is_loopback());
}

@test
fn test_udp_non_loopback() {
    let addr = Ipv4Addr.new(10, 0, 0, 1);
    assert(!addr.is_loopback());
}

// =============================================================================
// Section 7: IPv6 UDP Addresses
// =============================================================================

@test
fn test_udp_ipv6_bind_any() {
    let addr = SocketAddrV6.new(Ipv6Addr.unspecified(), 5000, 0, 0);
    assert_eq(addr.port(), 5000);
}

@test
fn test_udp_ipv6_localhost() {
    let addr = SocketAddrV6.new(Ipv6Addr.localhost(), 5001, 0, 0);
    assert_eq(addr.port(), 5001);
}

// =============================================================================
// Section 8: Result Patterns
// =============================================================================

@test
fn test_udp_ok_result() {
    let result: Result<Int, StreamError> = Ok(1024);
    assert(result.is_ok());
}

@test
fn test_udp_err_result() {
    let err = StreamError.new(IoErrorKind.AddrInUse);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
}

// =============================================================================
// Section 9: Error Kind Distinctness
// =============================================================================

@test
fn test_udp_error_kinds_distinct() {
    let would_block = StreamError.new(IoErrorKind.WouldBlock);
    let timed_out = StreamError.new(IoErrorKind.TimedOut);
    let not_connected = StreamError.new(IoErrorKind.NotConnected);
    assert(would_block.kind() != timed_out.kind());
    assert(timed_out.kind() != not_connected.kind());
    assert(would_block.kind() != not_connected.kind());
}

// =============================================================================
// Section 10: UdpSocket Construction Types
// =============================================================================

@test
fn test_udp_socket_maybe_some_type() {
    // Verify Maybe<UdpSocket> can hold Some variant type
    let opt: Maybe<UdpSocket> = None;
    assert(!opt.is_some());
}

@test
fn test_udp_bind_result_type() {
    // The bind method returns Result<UdpSocket, IoError>
    // Verify IoResult<UdpSocket> type alias works
    let result: IoResult<UdpSocket> = Err(StreamError.new(IoErrorKind.AddrInUse));
    assert(result.is_err());
}

@test
fn test_udp_bind_specific_ipv4() {
    // Binding to a specific IPv4 address and port
    let addr = SocketAddrV4.new(Ipv4Addr.new(192, 168, 1, 100), 9090);
    assert_eq(addr.port(), 9090);
    let ip = addr.ip();
    let octets = ip.octets();
    assert_eq(octets.0, 192 as Byte);
    assert_eq(octets.3, 100 as Byte);
}

@test
fn test_udp_bind_ipv6_with_scope() {
    // IPv6 link-local with scope_id for interface selection
    let addr = SocketAddrV6.new(Ipv6Addr.new(0xfe80, 0, 0, 0, 0, 0, 0, 1), 8080, 0, 2);
    assert_eq(addr.port(), 8080);
}

// =============================================================================
// Section 11: Connected UDP Patterns
// =============================================================================

@test
fn test_udp_connected_send_error_type() {
    // send() on unconnected socket returns NotConnected error
    let err = StreamError.new(IoErrorKind.NotConnected);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
    assert_eq(err.kind(), IoErrorKind.NotConnected);
}

@test
fn test_udp_connected_recv_error_type() {
    // recv() on unconnected socket returns NotConnected error
    let err = StreamError.new(IoErrorKind.NotConnected);
    let send_result: Result<Int, StreamError> = Err(err);
    let recv_result: Result<Int, StreamError> = Err(StreamError.new(IoErrorKind.NotConnected));
    assert(send_result.is_err());
    assert(recv_result.is_err());
}

@test
fn test_udp_connect_result_type() {
    // connect() returns Result<(), IoError>
    let result: Result<(), StreamError> = Ok(());
    assert(result.is_ok());
}

@test
fn test_udp_connect_refused_error() {
    // Connected UDP receives ICMP port unreachable as ConnectionRefused
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    let result: Result<(), StreamError> = Err(err);
    assert(result.is_err());
}

// =============================================================================
// Section 12: Broadcast Patterns
// =============================================================================

@test
fn test_udp_set_broadcast_result_type() {
    // set_broadcast returns Result<(), IoError>
    let result: Result<(), StreamError> = Ok(());
    assert(result.is_ok());
}

@test
fn test_udp_broadcast_subnet() {
    // Subnet broadcast address: 192.168.1.255
    let bcast = Ipv4Addr.new(192, 168, 1, 255);
    // Subnet broadcast is NOT the same as 255.255.255.255
    assert(!bcast.is_broadcast());
}

@test
fn test_udp_limited_broadcast() {
    // 255.255.255.255 is the limited broadcast address
    let bcast = Ipv4Addr.new(255, 255, 255, 255);
    assert(bcast.is_broadcast());
    // Broadcast is not multicast
    assert(!bcast.is_multicast());
}

