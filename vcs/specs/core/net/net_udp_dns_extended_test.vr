@test
fn test_dns_error_truncated() {
    let err = DnsError.Truncated;
    assert(err is DnsError.Truncated);
}

@test
fn test_dns_error_other() {
    let err = DnsError.Other("something unexpected");
    assert(err is DnsError.Other);
}

// =============================================================================
// Section 8: DNS Convenience Functions (type existence)
// =============================================================================

@test
fn test_lookup_host_fn_exists() {
    let _: fn(&Text) -> Result<List<IpAddr>, DnsError> = lookup_host;
}

@test
fn test_lookup_host_v4_fn_exists() {
    let _: fn(&Text) -> Result<List<Ipv4Addr>, DnsError> = lookup_host_v4;
}

@test
fn test_lookup_host_v6_fn_exists() {
    let _: fn(&Text) -> Result<List<Ipv6Addr>, DnsError> = lookup_host_v6;
}

@test
fn test_lookup_addr_fn_exists() {
    let _: fn(&IpAddr) -> Result<Text, DnsError> = lookup_addr;
}

@test
fn test_is_ip_address_fn_exists() {
    let _: fn(&Text) -> Bool = is_ip_address;
}

@test
fn test_is_valid_domain_fn_exists() {
    let _: fn(&Text) -> Bool = is_valid_domain;
}

// =============================================================================
// Section 9: DNS Result Types
// =============================================================================

@test
fn test_dns_result_ok() {
    let mut ips: List<IpAddr> = List.new();
    ips.push(IpAddr.V4(Ipv4Addr.localhost()));
    let result: Result<List<IpAddr>, DnsError> = Ok(ips);
    assert(result.is_ok());
}

@test
fn test_dns_result_err() {
    let result: Result<List<IpAddr>, DnsError> = Err(DnsError.NotFound);
    assert(result.is_err());
}

@test
fn test_dns_mx_result_type() {
    let mut records: List<(Int, Text)> = List.new();
    records.push((10, "mail.example.com"));
    let result: Result<List<(Int, Text)>, DnsError> = Ok(records);
    assert(result.is_ok());
}

@test
fn test_dns_txt_result_type() {
    let mut records: List<Text> = List.new();
    records.push("v=spf1");
    let result: Result<List<Text>, DnsError> = Ok(records);
    assert(result.is_ok());
}

@test
fn test_dns_socket_addr_result() {
    let mut addrs: List<SocketAddr> = List.new();
    let ip = Ipv4Addr.localhost();
    let sa = SocketAddrV4.new(ip, 80);
    addrs.push(SocketAddr.V4(sa));
    let result: Result<List<SocketAddr>, DnsError> = Ok(addrs);
    assert(result.is_ok());
}

// =============================================================================
// Section 10: DnsRecordEntry
// =============================================================================

@test
fn test_dns_record_entry_a() {
    let ip = Ipv4Addr.new(93, 184, 216, 34);
    let entry = DnsRecordEntry {
        record: DnsRecord.A(ip),
        ttl: 300,
    };
    assert_eq(entry.ttl, 300);
    assert(entry.record is DnsRecord.A);
}

@test
fn test_dns_record_entry_cname() {
    let entry = DnsRecordEntry {
        record: DnsRecord.CNAME("example.com"),
        ttl: 3600,
    };
    assert_eq(entry.ttl, 3600);
    assert(entry.record is DnsRecord.CNAME);
}

@test
fn test_dns_record_entry_mx() {
    let entry = DnsRecordEntry {
        record: DnsRecord.MX { priority: 10, exchange: "mail.example.com" },
        ttl: 86400,
    };
    assert(entry.record is DnsRecord.MX);
}

@test
fn test_dns_record_entry_txt() {
    let entry = DnsRecordEntry {
        record: DnsRecord.TXT("v=spf1 include:example.com ~all"),
        ttl: 7200,
    };
    assert_eq(entry.ttl, 7200);
    assert(entry.record is DnsRecord.TXT);
}

@test
fn test_dns_record_entry_ns() {
    let entry = DnsRecordEntry {
        record: DnsRecord.NS("ns1.example.com"),
        ttl: 172800,
    };
    assert(entry.record is DnsRecord.NS);
}

// =============================================================================
// Section 11: IpAddr wrapper convenience
// =============================================================================

@test
fn test_ip_addr_v4_wrap() {
    let ip = IpAddr.v4(10, 0, 0, 1);
    assert(ip.is_ipv4());
    assert(!ip.is_ipv6());
}

@test
fn test_ip_addr_v6_wrap() {
    let ip = IpAddr.v6(0, 0, 0, 0, 0, 0, 0, 1);
    assert(!ip.is_ipv4());
    assert(ip.is_ipv6());
}

@test
fn test_ip_addr_loopback_v4() {
    let ip = IpAddr.v4(127, 0, 0, 1);
    assert(ip.is_loopback());
}

@test
fn test_ip_addr_loopback_v6() {
    let ip = IpAddr.v6(0, 0, 0, 0, 0, 0, 0, 1);
    assert(ip.is_loopback());
}

@test
fn test_ip_addr_v4_variant() {
    let ip = IpAddr.V4(Ipv4Addr.localhost());
    assert(ip.is_ipv4());
    assert(ip.is_loopback());
}

@test
fn test_ip_addr_v6_variant() {
    let ip = IpAddr.V6(Ipv6Addr.localhost());
    assert(ip.is_ipv6());
    assert(ip.is_loopback());
}

// =============================================================================
// Main
// =============================================================================

fn main() {
    // Tests run via @test annotations
}
