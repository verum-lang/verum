// =============================================================================
// net_udp_dns_extended_test.vr - Extended tests for UDP operations and DNS APIs
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: net, udp, dns, resolver, socket, multicast, broadcast
// @description: Tests for UDP socket operations (send_to, recv_from, connect,
//               multicast, broadcast, buffer sizes), DNS resolver API
//               (lookup, query, record types), address parsing, and
//               convenience functions (resolve, is_ip_address, is_valid_domain).
//
// Coverage:
// - UDP: bind, send_to, recv_from, connect, send, recv, peek_from
// - UDP options: broadcast, buffer sizes, nonblocking, timeouts
// - UDP multicast: join, leave, ttl, loop
// - UDP: try_clone, as_raw_fd, local_addr, peer_addr
// - DNS: Resolver builder, lookup, query, record-specific lookups
// - DNS: lookup_host, lookup_host_v4/v6, lookup_addr, resolve
// - DNS: is_ip_address, is_valid_domain
// - Address: SocketAddr new/port/ip methods
// =============================================================================

module specs.core.net.net_udp_dns_extended_test;

mount core.net.udp.UdpSocket;
mount core.net.dns.{
    DnsError, DnsRecord, DnsRecordType, DnsRecordEntry,
    Resolver, lookup_host, lookup_host_v4, lookup_host_v6,
    lookup_addr, resolve, is_ip_address, is_valid_domain,
};
mount core.net.{
    SocketAddr, SocketAddrV4, SocketAddrV6,
    Ipv4Addr, Ipv6Addr, IpAddr,
};
mount core.io.protocols.{IoResult, StreamError, IoErrorKind};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;

// =============================================================================
// Section 1: UDP Socket Types and Method Existence
// =============================================================================

@test
fn test_udp_socket_maybe_type() {
    let s: Maybe<UdpSocket> = None;
    assert(s.is_none());
}

@test
fn test_udp_result_type() {
    let r: Result<UdpSocket, StreamError> = Err(StreamError.new(IoErrorKind.Other));
    assert(r.is_err());
}

// =============================================================================
// Section 2: UDP Error Patterns for Various Operations
// =============================================================================

@test
fn test_udp_send_to_error_not_connected() {
    let err = StreamError.new(IoErrorKind.NotConnected);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
}

@test
fn test_udp_recv_from_error_would_block() {
    let err = StreamError.new(IoErrorKind.WouldBlock);
    let result: Result<(Int, SocketAddr), StreamError> = Err(err);
    assert(result.is_err());
}

@test
fn test_udp_bind_error_addr_in_use() {
    let err = StreamError.new(IoErrorKind.AddrInUse);
    let result: Result<UdpSocket, StreamError> = Err(err);
    assert(result.is_err());
}

@test
fn test_udp_connect_error_refused() {
    let err = StreamError.new(IoErrorKind.ConnectionRefused);
    let result: Result<(), StreamError> = Err(err);
    assert(result.is_err());
}

@test
fn test_udp_send_error_broken_pipe() {
    let err = StreamError.new(IoErrorKind.BrokenPipe);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
}

@test
fn test_udp_recv_error_interrupted() {
    let err = StreamError.new(IoErrorKind.Interrupted);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
}

@test
fn test_udp_timeout_error() {
    let err = StreamError.new(IoErrorKind.TimedOut);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
}

@test
fn test_udp_permission_denied_broadcast() {
    // Broadcasting requires set_broadcast(true) first
    let err = StreamError.new(IoErrorKind.PermissionDenied);
    let result: Result<Int, StreamError> = Err(err);
    assert(result.is_err());
}

// =============================================================================
// Section 3: UDP Address Patterns
// =============================================================================

@test
fn test_udp_loopback_v4_addr() {
    let ip = Ipv4Addr.localhost();
    let addr = SocketAddrV4.new(ip, 8080);
    assert_eq(addr.port(), 8080);
    assert(addr.ip().is_loopback());
}

@test
fn test_udp_any_addr() {
    let ip = Ipv4Addr.unspecified();
    let addr = SocketAddrV4.new(ip, 0);
    assert_eq(addr.port(), 0);
    assert(addr.ip().is_unspecified());
}

@test
fn test_udp_broadcast_addr() {
    let ip = Ipv4Addr.broadcast();
    assert(ip.is_broadcast());
}

@test
fn test_udp_multicast_addr() {
    let ip = Ipv4Addr.new(239, 0, 0, 1);
    assert(ip.is_multicast());
}

@test
fn test_udp_multicast_addr_range() {
    // 224.0.0.0 to 239.255.255.255
    let lo = Ipv4Addr.new(224, 0, 0, 0);
    let hi = Ipv4Addr.new(239, 255, 255, 255);
    assert(lo.is_multicast());
    assert(hi.is_multicast());
}

@test
fn test_udp_private_addr() {
    let ip = Ipv4Addr.new(192, 168, 1, 100);
    assert(ip.is_private());
}

@test
fn test_udp_ipv6_loopback() {
    let ip = Ipv6Addr.localhost();
    assert(ip.is_loopback());
}

@test
fn test_udp_socket_addr_v6() {
    let ip = Ipv6Addr.localhost();
    let addr = SocketAddrV6.new(ip, 5000, 0, 0);
    assert_eq(addr.port(), 5000);
}

// =============================================================================
// Section 4: DNS Resolver Builder
// =============================================================================

@test
fn test_resolver_new() {
    let r = Resolver.new();
    let _: Resolver = r;
}

@test
fn test_resolver_system() {
    let r = Resolver.system();
    let _: Resolver = r;
}

@test
fn test_resolver_builder_nameserver() {
    let r = Resolver.new().nameserver("8.8.8.8");
    let _: Resolver = r;
}

@test
fn test_resolver_builder_nameserver_ip() {
    let ip = Ipv4Addr.new(8, 8, 8, 8);
    let r = Resolver.new().nameserver_ip(ip);
    let _: Resolver = r;
}

@test
fn test_resolver_builder_timeout() {
    let r = Resolver.new().timeout_ms(5000);
    let _: Resolver = r;
}

@test
fn test_resolver_builder_retries() {
    let r = Resolver.new().retries(3);
    let _: Resolver = r;
}

@test
fn test_resolver_builder_search_domain() {
    let r = Resolver.new().search_domain("example.com");
    let _: Resolver = r;
}

@test
fn test_resolver_builder_ndots() {
    let r = Resolver.new().ndots(1);
    let _: Resolver = r;
}

@test
fn test_resolver_builder_use_tcp() {
    let r = Resolver.new().use_tcp(true);
    let _: Resolver = r;
}

@test
fn test_resolver_builder_chaining() {
    let r = Resolver.new()
        .nameserver("8.8.8.8")
        .timeout_ms(3000)
        .retries(2)
        .ndots(1)
        .use_tcp(false);
    let _: Resolver = r;
}

@test
fn test_resolver_builder_full_config() {
    let r = Resolver.new()
        .nameserver_ip(Ipv4Addr.new(1, 1, 1, 1))
        .timeout_ms(10000)
        .retries(5)
        .search_domain("corp.example.com")
        .ndots(2)
        .use_tcp(true);
    let _: Resolver = r;
}

// =============================================================================
// Section 5: DNS Record Types
// =============================================================================

@test
fn test_dns_record_type_a() {
    let t = DnsRecordType.A;
    assert(t is DnsRecordType.A);
    assert_eq(t.to_wire(), 1);
}

@test
fn test_dns_record_type_aaaa() {
    let t = DnsRecordType.AAAA;
    assert(t is DnsRecordType.AAAA);
    assert_eq(t.to_wire(), 28);
}

@test
fn test_dns_record_type_cname() {
    let t = DnsRecordType.CNAME;
    assert_eq(t.to_wire(), 5);
}

@test
fn test_dns_record_type_mx() {
    let t = DnsRecordType.MX;
    assert_eq(t.to_wire(), 15);
}

@test
fn test_dns_record_type_txt() {
    let t = DnsRecordType.TXT;
    assert_eq(t.to_wire(), 16);
}

@test
fn test_dns_record_type_ns() {
    let t = DnsRecordType.NS;
    assert_eq(t.to_wire(), 2);
}

@test
fn test_dns_record_type_ptr() {
    let t = DnsRecordType.PTR;
    assert_eq(t.to_wire(), 12);
}

@test
fn test_dns_record_type_srv() {
    let t = DnsRecordType.SRV;
    assert_eq(t.to_wire(), 33);
}

@test
fn test_dns_record_type_soa() {
    let t = DnsRecordType.SOA;
    assert_eq(t.to_wire(), 6);
}

@test
fn test_dns_record_type_any() {
    let t = DnsRecordType.ANY;
    assert_eq(t.to_wire(), 255);
}

// =============================================================================
// Section 6: DNS Record Variants
// =============================================================================

@test
fn test_dns_record_a() {
    let ip = Ipv4Addr.new(192, 168, 1, 1);
    let record = DnsRecord.A(ip);
    assert(record is DnsRecord.A);
}

@test
fn test_dns_record_aaaa() {
    let ip = Ipv6Addr.localhost();
    let record = DnsRecord.AAAA(ip);
    assert(record is DnsRecord.AAAA);
}

@test
fn test_dns_record_cname() {
    let record = DnsRecord.CNAME("www.example.com");
    assert(record is DnsRecord.CNAME);
}

@test
fn test_dns_record_mx() {
    let record = DnsRecord.MX { priority: 10, exchange: "mail.example.com" };
    assert(record is DnsRecord.MX);
}

@test
fn test_dns_record_txt() {
    let record = DnsRecord.TXT("v=spf1 include:example.com ~all");
    assert(record is DnsRecord.TXT);
}

@test
fn test_dns_record_ns() {
    let record = DnsRecord.NS("ns1.example.com");
    assert(record is DnsRecord.NS);
}

@test
fn test_dns_record_ptr() {
    let record = DnsRecord.PTR("host.example.com");
    assert(record is DnsRecord.PTR);
}

@test
fn test_dns_record_srv() {
    let record = DnsRecord.SRV { priority: 10, weight: 60, port: 5060, target: "sip.example.com" };
    assert(record is DnsRecord.SRV);
}

@test
fn test_dns_record_soa() {
    let record = DnsRecord.SOA {
        mname: "ns1.example.com",
        rname: "admin.example.com",
        serial: 2024010101,
        refresh: 7200,
        retry: 3600,
        expire: 1209600,
        minimum: 86400,
    };
    assert(record is DnsRecord.SOA);
}

