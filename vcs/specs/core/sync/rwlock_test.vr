// =============================================================================
// Section 21: Poison Additional Tests
// =============================================================================

@test
fn test_rwlock_not_poisoned_after_read() {
    let rw: RwLock<Int> = RwLock.new(42);

    // Acquire and release read lock
    {
        let _: LockResult<RwLockReadGuard<Int>> = rw.read();
    }

    assert(!rw.is_poisoned());
}

@test
fn test_rwlock_not_poisoned_after_write() {
    let rw: RwLock<Int> = RwLock.new(42);

    // Acquire and release write lock
    {
        let _: LockResult<RwLockWriteGuard<Int>> = rw.write();
    }

    assert(!rw.is_poisoned());
}

@test
fn test_rwlock_clear_poison_three_times() {
    let rw: RwLock<Int> = RwLock.new(0);

    rw.clear_poison();
    assert(!rw.is_poisoned());

    rw.clear_poison();
    assert(!rw.is_poisoned());

    rw.clear_poison();
    assert(!rw.is_poisoned());
}

@test
fn test_rwlock_not_poisoned_after_multiple_operations() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Read
    { let _: LockResult<RwLockReadGuard<Int>> = rw.read(); }
    assert(!rw.is_poisoned());

    // Write
    { let _: LockResult<RwLockWriteGuard<Int>> = rw.write(); }
    assert(!rw.is_poisoned());

    // try_read
    { let _: TryLockResult<RwLockReadGuard<Int>> = rw.try_read(); }
    assert(!rw.is_poisoned());

    // try_write
    { let _: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write(); }
    assert(!rw.is_poisoned());
}

