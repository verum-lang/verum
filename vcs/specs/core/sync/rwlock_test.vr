@test
fn test_rwlock_try_write_modify_and_verify() {
    let rw: RwLock<Int> = RwLock.new(0);

    // try_write and modify
    {
        let result: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 999;
                }
            }
            Err(_) => panic("Expected Ok for try_write"),
        }
    }

    // Verify the change
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 999);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_try_write_fails_during_read() {
    let rw: RwLock<Int> = RwLock.new(333);

    // Hold a read lock
    let r: LockResult<RwLockReadGuard<Int>> = rw.read();
    match r {
        Ok(read_guard) => {
            // try_write should fail
            let w: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
            match w {
                Err(TryLockError.WouldBlock) => {} // Expected
                Ok(_) => panic("Expected WouldBlock"),
                Err(_) => panic("Expected WouldBlock"),
            }
        }
        Err(_) => panic("Expected Ok for read"),
    }
}

@test
fn test_rwlock_try_write_fails_during_write() {
    let rw: RwLock<Int> = RwLock.new(444);

    // Hold a write lock
    let w1: LockResult<RwLockWriteGuard<Int>> = rw.write();
    match w1 {
        Ok(write_guard) => {
            // try_write should fail
            let w2: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
            match w2 {
                Err(TryLockError.WouldBlock) => {} // Expected
                Ok(_) => panic("Expected WouldBlock"),
                Err(_) => panic("Expected WouldBlock"),
            }
        }
        Err(_) => panic("Expected Ok for write"),
    }
}

