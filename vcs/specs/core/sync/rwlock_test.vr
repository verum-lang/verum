@test
fn test_rwlock_write_modify_text() {
    let rw: RwLock<Text> = RwLock.new("initial");

    // Write: modify text
    {
        let result: LockResult<RwLockWriteGuard<Text>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Text as *mut Text;
                    *ptr = "modified";
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read: verify
    let result: LockResult<RwLockReadGuard<Text>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, "modified");
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_write_modify_bool() {
