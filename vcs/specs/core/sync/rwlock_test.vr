@test
fn test_rwlock_write_overwrite_text() {
    let rw: RwLock<Text> = RwLock.new("first");

    // First write
    {
        let result: LockResult<RwLockWriteGuard<Text>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Text as *mut Text;
                    *ptr = "second";
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Second write
    {
        let result: LockResult<RwLockWriteGuard<Text>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Text as *mut Text;
                    *ptr = "third";
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Verify final value
    let result: LockResult<RwLockReadGuard<Text>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, "third");
        }
        Err(_) => panic("Expected Ok"),
    }
}

