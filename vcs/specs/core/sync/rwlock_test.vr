@test
fn test_rwlock_try_read_success_uncontended() {
    let rw: RwLock<Int> = RwLock.new(77);

    let result: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 77);
        }
        Err(_) => panic("Expected Ok for uncontended try_read"),
    }
}

@test
fn test_rwlock_try_read_multiple_times() {
    let rw: RwLock<Int> = RwLock.new(88);

    // try_read multiple times in sequence (no contention)
    {
        let r1: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
        match r1 {
            Ok(guard) => { assert_eq(guard.rwlock.data, 88); }
            Err(_) => panic("Expected Ok for first try_read"),
        }
    }
    {
        let r2: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
        match r2 {
            Ok(guard) => { assert_eq(guard.rwlock.data, 88); }
            Err(_) => panic("Expected Ok for second try_read"),
        }
    }
    {
        let r3: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
        match r3 {
            Ok(guard) => { assert_eq(guard.rwlock.data, 88); }
            Err(_) => panic("Expected Ok for third try_read"),
        }
    }
}

@test
fn test_rwlock_try_read_with_text() {
    let rw: RwLock<Text> = RwLock.new("try_read_text");

    let result: TryLockResult<RwLockReadGuard<Text>> = rw.try_read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, "try_read_text");
        }
        Err(_) => panic("Expected Ok for try_read text"),
    }
}

@test
fn test_rwlock_try_read_with_float() {
    let rw: RwLock<Float> = RwLock.new(6.28);

    let result: TryLockResult<RwLockReadGuard<Float>> = rw.try_read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 6.28);
        }
        Err(_) => panic("Expected Ok for try_read float"),
    }
}

@test
fn test_rwlock_try_read_concurrent_with_read() {
    let rw: RwLock<Int> = RwLock.new(111);

    // Hold a read lock, then try_read should still succeed
    let r1: LockResult<RwLockReadGuard<Int>> = rw.read();
    match r1 {
        Ok(guard1) => {
            let r2: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
            match r2 {
                Ok(guard2) => {
                    assert_eq(guard1.rwlock.data, 111);
                    assert_eq(guard2.rwlock.data, 111);
                }
                Err(_) => panic("try_read should succeed while read held"),
            }
        }
        Err(_) => panic("Expected Ok for read"),
    }
}

