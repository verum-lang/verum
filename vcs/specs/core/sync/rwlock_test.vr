@test
fn test_rwlock_read_write_read_verify() {
    let rw: RwLock<Int> = RwLock.new(10);

    // Read initial
    {
        let result: LockResult<RwLockReadGuard<Int>> = rw.read();
        match result {
            Ok(guard) => { assert_eq(guard.rwlock.data, 10); }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Write new value
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 20;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read again - should see updated value
    {
        let result: LockResult<RwLockReadGuard<Int>> = rw.read();
        match result {
            Ok(guard) => { assert_eq(guard.rwlock.data, 20); }
            Err(_) => panic("Expected Ok"),
        }
    }
}

@test
fn test_rwlock_multiple_writes_accumulate() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Write 1: set to 10
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 10;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Write 2: set to 20
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 20;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Write 3: set to 30
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 30;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Verify final value
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => { assert_eq(guard.rwlock.data, 30); }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_write_set_then_get_mut_override() {
    let mut rw: RwLock<Int> = RwLock.new(0);

    // Write via lock
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 50;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Override via get_mut
    {
        let result: LockResult<&mut Int> = rw.get_mut();
        match result {
            Ok(data) => { *data = 75; }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Verify get_mut value wins
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => { assert_eq(guard.rwlock.data, 75); }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_write_release_then_multiple_readers() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Write a value
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 42;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Multiple readers should see the written value
    let r1: LockResult<RwLockReadGuard<Int>> = rw.read();
    match r1 {
        Ok(guard1) => {
            let r2: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
            match r2 {
                Ok(guard2) => {
                    assert_eq(guard1.rwlock.data, 42);
                    assert_eq(guard2.rwlock.data, 42);
                }
                Err(_) => panic("Expected second reader to succeed"),
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_get_mut_then_read() {
    let mut rw: RwLock<Int> = RwLock.new(0);

    // Modify via get_mut
    {
        let result: LockResult<&mut Int> = rw.get_mut();
        match result {
            Ok(data) => { *data = 123; }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read should see updated value
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => { assert_eq(guard.rwlock.data, 123); }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_get_mut_then_write_then_read() {
    let mut rw: RwLock<Int> = RwLock.new(0);

    // get_mut to set initial
    {
        let result: LockResult<&mut Int> = rw.get_mut();
        match result {
            Ok(data) => { *data = 10; }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Write to override
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 20;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read final
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => { assert_eq(guard.rwlock.data, 20); }
        Err(_) => panic("Expected Ok"),
    }
}

