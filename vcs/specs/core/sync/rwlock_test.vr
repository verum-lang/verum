@test
fn test_rwlock_read_value_unchanged() {
    let rw: RwLock<Int> = RwLock.new(55);

    // Read multiple times - value should never change
    {
        let r1: LockResult<RwLockReadGuard<Int>> = rw.read();
        match r1 {
            Ok(guard) => { assert_eq(guard.rwlock.data, 55); }
            Err(_) => panic("Expected Ok"),
        }
    }
    {
        let r2: LockResult<RwLockReadGuard<Int>> = rw.read();
        match r2 {
            Ok(guard) => { assert_eq(guard.rwlock.data, 55); }
            Err(_) => panic("Expected Ok"),
        }
    }
    {
        let r3: LockResult<RwLockReadGuard<Int>> = rw.read();
        match r3 {
            Ok(guard) => { assert_eq(guard.rwlock.data, 55); }
            Err(_) => panic("Expected Ok"),
        }
    }
}

@test
fn test_rwlock_read_negative_int() {
    let rw: RwLock<Int> = RwLock.new(-42);

    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, -42);
        }
        Err(_) => panic("Expected Ok for read negative"),
    }
}

@test
fn test_rwlock_read_zero() {
    let rw: RwLock<Int> = RwLock.new(0);

    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
