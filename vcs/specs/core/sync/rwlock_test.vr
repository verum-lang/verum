    // Write: set to true
    {
        let result: LockResult<RwLockWriteGuard<Bool>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Bool as *mut Bool;
                    *ptr = true;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read: verify
    let result: LockResult<RwLockReadGuard<Bool>> = rw.read();
    match result {
        Ok(guard) => {
            assert(guard.rwlock.data);
        }
        Err(_) => panic("Expected Ok"),
    }
}

