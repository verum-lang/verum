}

@test
fn test_rwlock_get_mut_multiple_times() {
    let mut rw: RwLock<Int> = RwLock.new(0);

    // First modification
    {
        let result: LockResult<&mut Int> = rw.get_mut();
        match result {
            Ok(data) => { *data = 10; }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Second modification
    {
        let result: LockResult<&mut Int> = rw.get_mut();
        match result {
            Ok(data) => { *data = 20; }
            Err(_) => panic("Expected Ok"),
        }
    }

    let read_result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match read_result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 20);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 13: Poison State Extended Tests
// =============================================================================

@test
fn test_rwlock_not_poisoned_after_normal_use() {
    let rw: RwLock<Int> = RwLock.new(42);

    // Read and release
    {
        let _: LockResult<RwLockReadGuard<Int>> = rw.read();
    }

    // Write and release
    {
        let _: LockResult<RwLockWriteGuard<Int>> = rw.write();
    }

    // Should still not be poisoned
    assert(!rw.is_poisoned());
}

@test
fn test_rwlock_clear_poison_idempotent() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Clear poison multiple times should be fine
    rw.clear_poison();
    rw.clear_poison();
    rw.clear_poison();

    assert(!rw.is_poisoned());
}

// =============================================================================
// Section 14: Read-Write-Read Upgrade Pattern
// =============================================================================

@test
fn test_rwlock_upgrade_pattern() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Read to check value
    {
        let result: LockResult<RwLockReadGuard<Int>> = rw.read();
        match result {
            Ok(guard) => {
                assert_eq(guard.rwlock.data, 0);
                // Drop read guard
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Write to modify
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 42;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read again to verify
    {
        let result: LockResult<RwLockReadGuard<Int>> = rw.read();
        match result {
            Ok(guard) => {
                assert_eq(guard.rwlock.data, 42);
            }
            Err(_) => panic("Expected Ok"),
        }
    }
}

@test
fn test_rwlock_downgrade_pattern() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Write first
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 100;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Then read (downgrade)
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 100);
        }
        Err(_) => panic("Expected Ok"),
    }
}

