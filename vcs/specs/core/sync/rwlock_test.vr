// =============================================================================
// rwlock_test.vr - Tests for RwLock<T> and related types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: sync, rwlock, lock, concurrency, core
// @description: Comprehensive tests for RwLock<T>, RwLockReadGuard, RwLockWriteGuard
// =============================================================================

mount core.sync.rwlock.{RwLock, RwLockReadGuard, RwLockWriteGuard};
mount core.sync.mutex.{LockResult, TryLockResult, PoisonError, TryLockError};
mount core.result.{Result, Ok, Err};

// =============================================================================
// Section 1: RwLock Construction Tests
// =============================================================================

@test
fn test_rwlock_new_int() {
    let rw: RwLock<Int> = RwLock.new(42);
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
            // Access data through rwlock field
            assert_eq(guard.rwlock.data, 42);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_new_text() {
    let rw: RwLock<Text> = RwLock.new("hello");
    let result: LockResult<RwLockReadGuard<Text>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, "hello");
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_new_bool() {
    let rw: RwLock<Bool> = RwLock.new(true);
    let result: LockResult<RwLockReadGuard<Bool>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, true);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_default() {
    let rw: RwLock<Int> = RwLock.default();
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 0); // Int default is 0
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 2: RwLock Read Operations
// =============================================================================

@test
fn test_rwlock_read() {
    let rw: RwLock<Int> = RwLock.new(10);

    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 10);
        }
        Err(_) => panic("Expected Ok for read"),
    }
}

@test
fn test_rwlock_try_read_uncontended() {
    let rw: RwLock<Int> = RwLock.new(20);

    let result: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 20);
        }
        Err(_) => panic("Expected Ok for try_read"),
    }
}

@test
fn test_rwlock_multiple_readers() {
    let rw: RwLock<Int> = RwLock.new(30);

    // Acquire multiple read locks (should all succeed)
    let result1: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result1 {
        Ok(guard1) => {
            let result2: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
            match result2 {
                Ok(guard2) => {
                    // Both readers can access data
                    assert_eq(guard1.rwlock.data, 30);
                    assert_eq(guard2.rwlock.data, 30);
                }
                Err(_) => panic("Expected second reader to succeed"),
            }
        }
        Err(_) => panic("Expected Ok for first read"),
    }
}

// =============================================================================
// Section 3: RwLock Write Operations
// =============================================================================

@test
fn test_rwlock_write() {
    let rw: RwLock<Int> = RwLock.new(100);

    let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 100);
        }
        Err(_) => panic("Expected Ok for write"),
    }
}

@test
fn test_rwlock_try_write_uncontended() {
    let rw: RwLock<Int> = RwLock.new(200);

    let result: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 200);
        }
        Err(_) => panic("Expected Ok for try_write"),
    }
}

@test
fn test_rwlock_write_blocks_read() {
    let rw: RwLock<Int> = RwLock.new(300);

    // Acquire write lock
    let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
    match result {
        Ok(write_guard) => {
            // Try to read - should fail
            let read_result: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
            match read_result {
                Err(TryLockError.WouldBlock) => {} // Expected
                Ok(_) => panic("Expected WouldBlock for read while write held"),
                Err(_) => panic("Expected WouldBlock"),
            }
        }
        Err(_) => panic("Expected Ok for write"),
    }
}

@test
fn test_rwlock_read_blocks_write() {
    let rw: RwLock<Int> = RwLock.new(400);

    // Acquire read lock
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(read_guard) => {
            // Try to write - should fail
            let write_result: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
            match write_result {
                Err(TryLockError.WouldBlock) => {} // Expected
                Ok(_) => panic("Expected WouldBlock for write while read held"),
                Err(_) => panic("Expected WouldBlock"),
            }
        }
        Err(_) => panic("Expected Ok for read"),
    }
}

// =============================================================================
// Section 4: RwLock get_mut and into_inner
// =============================================================================

@test
fn test_rwlock_get_mut() {
    let mut rw: RwLock<Int> = RwLock.new(50);

    // get_mut doesn't require locking (exclusive ownership)
    let result: LockResult<&mut Int> = rw.get_mut();
    match result {
        Ok(data) => {
            *data = 100;
        }
        Err(_) => panic("Expected Ok for get_mut"),
    }

    let read_result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match read_result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 100);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_into_inner() {
    let rw: RwLock<Int> = RwLock.new(77);

    let result: LockResult<Int> = rw.into_inner();
    match result {
        Ok(data) => assert_eq(data, 77),
        Err(_) => panic("Expected Ok for into_inner"),
    }
}

// =============================================================================
// Section 5: RwLock Poison State
// =============================================================================

@test
fn test_rwlock_not_poisoned_initially() {
    let rw: RwLock<Int> = RwLock.new(0);
    assert(!rw.is_poisoned());
}

@test
fn test_rwlock_clear_poison() {
    let rw: RwLock<Int> = RwLock.new(0);
    rw.clear_poison();
    assert(!rw.is_poisoned());
}

// =============================================================================
// Section 6: Multiple Read/Write Cycles
// =============================================================================

@test
fn test_rwlock_read_write_cycles() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Write
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                // Modify through raw pointer (workaround for deref_mut issues)
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 10;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read
    {
        let result: LockResult<RwLockReadGuard<Int>> = rw.read();
        match result {
            Ok(guard) => {
                assert_eq(guard.rwlock.data, 10);
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Write again
    {
        let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Int as *mut Int;
                    *ptr = 20;
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Final read
    let result: LockResult<RwLockReadGuard<Int>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 20);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 7: Lock Release Tests
// =============================================================================

@test
fn test_rwlock_read_release() {
    let rw: RwLock<Int> = RwLock.new(100);

    // Read then release
    {
        let _: LockResult<RwLockReadGuard<Int>> = rw.read();
    }

    // Should be able to write now
    let result: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
    match result {
        Ok(_) => {} // Good - write succeeded after read released
        Err(_) => panic("Expected write to succeed after read release"),
    }
}

@test
fn test_rwlock_write_release() {
    let rw: RwLock<Int> = RwLock.new(100);

    // Write then release
    {
        let _: LockResult<RwLockWriteGuard<Int>> = rw.write();
    }

    // Should be able to read now
    let result: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
    match result {
        Ok(_) => {} // Good - read succeeded after write released
        Err(_) => panic("Expected read to succeed after write release"),
    }
}

// =============================================================================
// Section 8: Write Blocks Write
// =============================================================================

@test
fn test_rwlock_write_blocks_write() {
    let rw: RwLock<Int> = RwLock.new(500);

    // Acquire write lock
    let result: LockResult<RwLockWriteGuard<Int>> = rw.write();
    match result {
        Ok(write_guard) => {
            // Try second write - should fail
            let write_result: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
            match write_result {
                Err(TryLockError.WouldBlock) => {} // Expected
                Ok(_) => panic("Expected WouldBlock for write while write held"),
                Err(_) => panic("Expected WouldBlock"),
            }
        }
        Err(_) => panic("Expected Ok for write"),
    }
}

// =============================================================================
// Section 9: Multiple Reader Tests
// =============================================================================

@test
fn test_rwlock_three_readers() {
    let rw: RwLock<Int> = RwLock.new(99);

    let r1: LockResult<RwLockReadGuard<Int>> = rw.read();
    match r1 {
        Ok(guard1) => {
            let r2: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
            match r2 {
                Ok(guard2) => {
                    let r3: TryLockResult<RwLockReadGuard<Int>> = rw.try_read();
                    match r3 {
                        Ok(guard3) => {
                            // All three readers can access data
                            assert_eq(guard1.rwlock.data, 99);
                            assert_eq(guard2.rwlock.data, 99);
                            assert_eq(guard3.rwlock.data, 99);
                        }
                        Err(_) => panic("Expected third reader to succeed"),
                    }
                }
                Err(_) => panic("Expected second reader to succeed"),
            }
        }
        Err(_) => panic("Expected first reader to succeed"),
    }
}

@test
fn test_rwlock_read_release_then_write() {
    let rw: RwLock<Int> = RwLock.new(0);

    // Acquire and release read lock
    {
        let r: LockResult<RwLockReadGuard<Int>> = rw.read();
        match r {
            Ok(guard) => {
                assert_eq(guard.rwlock.data, 0);
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Now write should succeed
    let w: TryLockResult<RwLockWriteGuard<Int>> = rw.try_write();
    match w {
        Ok(guard) => {
            assert_eq(guard.rwlock.data, 0);
        }
        Err(_) => panic("Expected write after read release to succeed"),
    }
}

// =============================================================================
// Section 10: Generic Type Tests
// =============================================================================

@test
fn test_rwlock_list() {
    let rw: RwLock<List<Int>> = RwLock.new(List.new());

    // Write: add elements
    {
        let result: LockResult<RwLockWriteGuard<List<Int>>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const List<Int> as *mut List<Int>;
                    (*ptr).push(1);
                    (*ptr).push(2);
                    (*ptr).push(3);
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read: verify elements
    let result: LockResult<RwLockReadGuard<List<Int>>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data.len(), 3);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_maybe() {
    let rw: RwLock<Maybe<Text>> = RwLock.new(None);

    // Write: set value
    {
        let result: LockResult<RwLockWriteGuard<Maybe<Text>>> = rw.write();
        match result {
            Ok(mut guard) => {
                unsafe {
                    let ptr = &guard.rwlock.data as *const Maybe<Text> as *mut Maybe<Text>;
                    *ptr = Some("hello");
                }
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Read: verify value
    let result: LockResult<RwLockReadGuard<Maybe<Text>>> = rw.read();
    match result {
        Ok(guard) => {
            assert(guard.rwlock.data.is_some());
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_rwlock_tuple() {
    let rw: RwLock<(Int, Text)> = RwLock.new((42, "answer"));

    let result: LockResult<RwLockReadGuard<(Int, Text)>> = rw.read();
    match result {
        Ok(guard) => {
            assert_eq(guard.rwlock.data.0, 42);
            assert_eq(guard.rwlock.data.1, "answer");
        }
        Err(_) => panic("Expected Ok"),
    }
}

