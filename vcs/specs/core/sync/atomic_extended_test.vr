@test
fn test_futexlock_lock_unlock_cycle() {
    let f = FutexLock.new();
    f.lock();
    assert(f.is_locked());
    f.unlock();
    assert(!f.is_locked());

    f.lock();
    assert(f.is_locked());
    f.unlock();
