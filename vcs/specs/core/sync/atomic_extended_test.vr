@test
fn test_atomicbool_default_value() {
    let a = AtomicBool.default();
    assert_eq(a.load(SeqCst), false);
}

@test
fn test_atomicbool_get_mut_false() {
    let mut a = AtomicBool.new(false);
    let r = a.get_mut();
    assert_eq(*r, false);
