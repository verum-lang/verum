// =============================================================================
// Section 10: Ordering exhaustive usage
// =============================================================================

@test
fn test_atomicint_all_orderings_load() {
    let a = AtomicInt.new(42);
    assert_eq(a.load(Relaxed), 42);
    assert_eq(a.load(Acquire), 42);
    assert_eq(a.load(SeqCst), 42);
}

@test
fn test_atomicint_all_orderings_store() {
    let a = AtomicInt.new(0);
    a.store(1, Relaxed);
    assert_eq(a.load(SeqCst), 1);
    a.store(2, Release);
    assert_eq(a.load(SeqCst), 2);
    a.store(3, SeqCst);
    assert_eq(a.load(SeqCst), 3);
}

@test
fn test_atomicint_fetch_add_with_acqrel() {
    let a = AtomicInt.new(10);
    let old = a.fetch_add(5, AcqRel);
    assert_eq(old, 10);
    assert_eq(a.load(SeqCst), 15);
}

@test
fn test_atomicint_fetch_sub_with_acqrel() {
    let a = AtomicInt.new(100);
    let old = a.fetch_sub(30, AcqRel);
    assert_eq(old, 100);
    assert_eq(a.load(SeqCst), 70);
}

@test
fn test_atomicint_fetch_and_with_acqrel() {
    let a = AtomicInt.new(0xFF);
    let old = a.fetch_and(0x0F, AcqRel);
    assert_eq(old, 0xFF);
    assert_eq(a.load(SeqCst), 0x0F);
}

@test
fn test_atomicint_fetch_or_with_acqrel() {
    let a = AtomicInt.new(0xF0);
    let old = a.fetch_or(0x0F, AcqRel);
    assert_eq(old, 0xF0);
    assert_eq(a.load(SeqCst), 0xFF);
}

@test
fn test_atomicint_swap_with_acqrel() {
    let a = AtomicInt.new(42);
    let old = a.swap(99, AcqRel);
    assert_eq(old, 42);
    assert_eq(a.load(SeqCst), 99);
}

// =============================================================================
// Section 11: AtomicInt fetch_max/fetch_min edge cases
// =============================================================================

@test
fn test_atomicint_fetch_max_returns_old() {
    let a = AtomicInt.new(5);
    let old = a.fetch_max(10, SeqCst);
    assert_eq(old, 5);
    assert_eq(a.load(SeqCst), 10);
}

@test
fn test_atomicint_fetch_min_returns_old() {
    let a = AtomicInt.new(10);
    let old = a.fetch_min(5, SeqCst);
    assert_eq(old, 10);
    assert_eq(a.load(SeqCst), 5);
}

@test
fn test_atomicint_fetch_max_no_change() {
    let a = AtomicInt.new(100);
    let old = a.fetch_max(50, SeqCst);
    assert_eq(old, 100);
    assert_eq(a.load(SeqCst), 100);
}

@test
fn test_atomicint_fetch_min_no_change() {
    let a = AtomicInt.new(5);
    let old = a.fetch_min(50, SeqCst);
    assert_eq(old, 5);
    assert_eq(a.load(SeqCst), 5);
}

@test
fn test_atomicint_fetch_max_with_zero() {
    let a = AtomicInt.new(0);
    let old = a.fetch_max(0, SeqCst);
    assert_eq(old, 0);
    assert_eq(a.load(SeqCst), 0);
}

@test
fn test_atomicint_fetch_min_with_zero() {
    let a = AtomicInt.new(0);
    let old = a.fetch_min(0, SeqCst);
    assert_eq(old, 0);
    assert_eq(a.load(SeqCst), 0);
}

// =============================================================================
// Section 12: Compound patterns
// =============================================================================

@test
fn test_atomicint_increment_decrement_roundtrip() {
    let a = AtomicInt.new(50);
    a.increment(SeqCst);
    a.increment(SeqCst);
    a.decrement(SeqCst);
    assert_eq(a.load(SeqCst), 51);
}

@test
fn test_atomicu32_fetch_ops_chain() {
    let a = AtomicU32.new(0 as UInt32);
    a.fetch_add(100 as UInt32, SeqCst);
    a.fetch_sub(25 as UInt32, SeqCst);
    assert_eq(a.load(SeqCst), 75 as UInt32);
}

@test
fn test_atomicu64_fetch_ops_chain() {
    let a = AtomicU64.new(0 as UInt64);
    a.fetch_add(1000 as UInt64, SeqCst);
    a.fetch_sub(250 as UInt64, SeqCst);
    assert_eq(a.load(SeqCst), 750 as UInt64);
}

@test
fn test_atomicbool_swap_chain() {
    let a = AtomicBool.new(false);
    let v1 = a.swap(true, SeqCst);
    assert_eq(v1, false);
    let v2 = a.swap(false, SeqCst);
    assert_eq(v2, true);
    let v3 = a.swap(true, SeqCst);
    assert_eq(v3, false);
    assert_eq(a.load(SeqCst), true);
}

@test
fn test_fence_relaxed_noop() {
    // Relaxed fence should be a no-op
    fence(Relaxed);
    assert(!false); // Runtime-only: atomics
}

@test
fn test_atomicint_compare_exchange_orderings() {
    let a = AtomicInt.new(10);
    // Test with Acquire/Relaxed
    let r1 = a.compare_exchange(10, 20, Acquire, Relaxed);
    assert(r1.is_ok());
    assert_eq(a.load(SeqCst), 20);

    // Test with Release/Relaxed
    let r2 = a.compare_exchange(20, 30, Release, Relaxed);
    assert(r2.is_ok());
    assert_eq(a.load(SeqCst), 30);

    // Test with AcqRel/Acquire
    let r3 = a.compare_exchange(30, 40, AcqRel, Acquire);
    assert(r3.is_ok());
    assert_eq(a.load(SeqCst), 40);
}

@test
fn test_atomicu8_boundary_values() {
    let a = AtomicU8.new(255);
    assert_eq(a.load(SeqCst), 255);
    a.store(0, SeqCst);
    assert_eq(a.load(SeqCst), 0);
    a.store(127, SeqCst);
    assert_eq(a.load(SeqCst), 127);
}

@test
fn test_atomicu16_boundary_values() {
    let a = AtomicU16.new(65535 as UInt16);
    assert_eq(a.load(SeqCst), 65535 as UInt16);
    a.store(0 as UInt16, SeqCst);
    assert_eq(a.load(SeqCst), 0 as UInt16);
}

@test
fn test_atomicu32_boundary_values() {
    let a = AtomicU32.new(0 as UInt32);
    a.store(0x7FFFFFFF as UInt32, SeqCst);
    assert_eq(a.load(SeqCst), 0x7FFFFFFF as UInt32);
}

@test
fn test_atomicu64_boundary_values() {
    let a = AtomicU64.new(0 as UInt64);
    a.store(0x7FFFFFFFFFFFFFFF as UInt64, SeqCst);
    assert_eq(a.load(SeqCst), 0x7FFFFFFFFFFFFFFF as UInt64);
}

@test
fn test_spinlock_and_futexlock_coexist() {
    // Verify both lock types can exist simultaneously
    let spin = SpinLock.new();
    let futex = FutexLock.new();
    assert(!spin.is_locked());
    assert(!futex.is_locked());

    spin.lock();
    futex.lock();
    assert(spin.is_locked());
    assert(futex.is_locked());

    spin.unlock();
    futex.unlock();
    assert(!spin.is_locked());
    assert(!futex.is_locked());
}
