// @test: typecheck-pass
// @level: L0
// @tags: sync, atomic, atomicptr, spinlock, futexlock, default, get_mut
// @description: Extended atomic tests covering AtomicPtr, SpinLock, FutexLock,
//               Default impls, get_mut methods, and missing API coverage.

mount core.sync.atomic.{
    Ordering, Relaxed, Acquire, Release, AcqRel, SeqCst,
    AtomicInt, AtomicU8, AtomicU16, AtomicU32, AtomicU64, AtomicBool,
    AtomicPtr, SpinLock, FutexLock, fence,
};

// =============================================================================
// Section 1: AtomicInt - Default + get_mut
// =============================================================================

@test
fn test_atomicint_default_value() {
    let a = AtomicInt.default();
    assert_eq(a.load(SeqCst), 0);
}

@test
fn test_atomicint_get_mut() {
    let mut a = AtomicInt.new(42);
    let r = a.get_mut();
    assert_eq(*r, 42);
}

@test
fn test_atomicint_get_mut_modify() {
    let mut a = AtomicInt.new(10);
    *a.get_mut() = 20;
    assert_eq(a.load(SeqCst), 20);
}

// =============================================================================
// Section 2: AtomicU8 - Default + get_mut
// =============================================================================

@test
fn test_atomicu8_default_value() {
    let a = AtomicU8.default();
    assert_eq(a.load(SeqCst), 0);
}

@test
fn test_atomicu8_get_mut() {
    let mut a = AtomicU8.new(42);
    let r = a.get_mut();
    assert_eq(*r, 42);
}

@test
fn test_atomicu8_get_mut_modify() {
    let mut a = AtomicU8.new(10);
    let val: Byte = 20;
    *a.get_mut() = val;
    assert_eq(a.load(SeqCst), 20);
}

// =============================================================================
// Section 3: AtomicU16 - Default + get_mut + compare_exchange failure
// =============================================================================

@test
fn test_atomicu16_default_value() {
    let a = AtomicU16.default();
    assert_eq(a.load(SeqCst), 0 as UInt16);
}

@test
fn test_atomicu16_get_mut() {
    let mut a = AtomicU16.new(1000 as UInt16);
    let r = a.get_mut();
    assert_eq(*r, 1000 as UInt16);
}

@test
fn test_atomicu16_get_mut_modify() {
    let mut a = AtomicU16.new(100 as UInt16);
    *a.get_mut() = 200 as UInt16;
    assert_eq(a.load(SeqCst), 200 as UInt16);
}

@test
fn test_atomicu16_compare_exchange_failure() {
    let a = AtomicU16.new(42 as UInt16);
    let result = a.compare_exchange(10 as UInt16, 99 as UInt16, SeqCst, Relaxed);
    assert(result.is_err());
}

