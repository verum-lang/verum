// =============================================================================
// Section 7: AtomicPtr<T> - Complete coverage
// =============================================================================

@test
fn test_atomicptr_null() {
    let p: AtomicPtr<Int> = AtomicPtr.null();
    assert(p.is_null());
}

@test
fn test_atomicptr_default_is_null() {
    let p: AtomicPtr<Int> = AtomicPtr.default();
    assert(p.is_null());
}

@test
fn test_atomicptr_new_not_null() {
    let mut val = 42;
    let p = AtomicPtr.new(&mut val as &unsafe Int);
    assert(!p.is_null());
}

@test
fn test_atomicptr_store_and_load() {
    let mut val = 100;
    let p: AtomicPtr<Int> = AtomicPtr.null();
    p.store(&mut val as &unsafe Int, Release);
    assert(!p.is_null());
}

@test
fn test_atomicptr_swap() {
    let mut val1 = 10;
    let mut val2 = 20;
    let p = AtomicPtr.new(&mut val1 as &unsafe Int);
    let old = p.swap(&mut val2 as &unsafe Int, SeqCst);
    // After swap, p now points to val2
    assert(!p.is_null());
}

@test
fn test_atomicptr_compare_exchange_success() {
    let mut val1 = 10;
    let mut val2 = 20;
    let ptr1 = &mut val1 as &unsafe Int;
    let ptr2 = &mut val2 as &unsafe Int;
    let p = AtomicPtr.new(ptr1);
    let result = p.compare_exchange(ptr1, ptr2, SeqCst, Relaxed);
    assert(result.is_ok());
}

@test
fn test_atomicptr_compare_exchange_failure() {
    let mut val1 = 10;
    let mut val2 = 20;
    let mut val3 = 30;
    let ptr1 = &mut val1 as &unsafe Int;
    let ptr2 = &mut val2 as &unsafe Int;
    let ptr3 = &mut val3 as &unsafe Int;
    let p = AtomicPtr.new(ptr1);
    // Expect failure: current is ptr1, not ptr2
    let result = p.compare_exchange(ptr2, ptr3, SeqCst, Relaxed);
    assert(result.is_err());
}

@test
fn test_atomicptr_store_null_makes_null() {
    let mut val = 42;
    let p = AtomicPtr.new(&mut val as &unsafe Int);
    assert(!p.is_null());
    // Store a null-like value using another null ptr
    let null_ptr: AtomicPtr<Int> = AtomicPtr.null();
    let null_raw = null_ptr.load(Relaxed);
    p.store(null_raw, SeqCst);
    assert(p.is_null());
}

// =============================================================================
// Section 8: SpinLock - Complete coverage
// =============================================================================

@test
fn test_spinlock_new_is_unlocked() {
    let s = SpinLock.new();
    assert(!s.is_locked());
}

@test
fn test_spinlock_default_is_unlocked() {
    let s = SpinLock.default();
    assert(!s.is_locked());
}

@test
fn test_spinlock_lock_makes_locked() {
    let s = SpinLock.new();
    s.lock();
    assert(s.is_locked());
}

@test
fn test_spinlock_unlock_makes_unlocked() {
    let s = SpinLock.new();
    s.lock();
    assert(s.is_locked());
    s.unlock();
    assert(!s.is_locked());
}

@test
fn test_spinlock_try_lock_succeeds_when_unlocked() {
    let s = SpinLock.new();
    let got = s.try_lock();
    assert(got);
    assert(s.is_locked());
}

@test
fn test_spinlock_try_lock_fails_when_locked() {
    let s = SpinLock.new();
    s.lock();
    let got = s.try_lock();
    assert(!got);
    // Still locked
    assert(s.is_locked());
}

@test
fn test_spinlock_lock_unlock_cycle() {
    let s = SpinLock.new();
    // Lock/unlock multiple times
    s.lock();
    assert(s.is_locked());
    s.unlock();
    assert(!s.is_locked());

    s.lock();
    assert(s.is_locked());
    s.unlock();
    assert(!s.is_locked());
}

@test
fn test_spinlock_try_lock_after_unlock() {
    let s = SpinLock.new();
    s.lock();
    s.unlock();
    // Should succeed after unlock
    let got = s.try_lock();
    assert(got);
    assert(s.is_locked());
}

