// =============================================================================
// mutex_test.vr - Tests for Mutex<T> and related types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: sync, mutex, lock, concurrency, core
// @description: Comprehensive tests for Mutex<T>, MutexGuard, and lock operations
// =============================================================================

mount core.sync.mutex.{Mutex, MutexGuard, LockResult, TryLockResult, PoisonError, TryLockError};
mount core.result.{Result, Ok, Err};

// =============================================================================
// Section 1: Mutex Construction Tests
// =============================================================================

@test
fn test_mutex_new_int() {
    let m: Mutex<Int> = Mutex.new(42);
    let result: TryLockResult<MutexGuard<Int>> = m.try_lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 42);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_new_text() {
    let m: Mutex<Text> = Mutex.new("hello");
    let result: TryLockResult<MutexGuard<Text>> = m.try_lock();
    match result {
        Ok(guard) => {
            let val: &Text = guard.data();
            assert_eq(*val, "hello");
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_new_bool() {
    let m: Mutex<Bool> = Mutex.new(true);
    let result: TryLockResult<MutexGuard<Bool>> = m.try_lock();
    match result {
        Ok(guard) => {
            let val: &Bool = guard.data();
            assert_eq(*val, true);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_default() {
    let m: Mutex<Int> = Mutex.default();
    let result: TryLockResult<MutexGuard<Int>> = m.try_lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 0); // Int default is 0
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 2: Mutex Lock Operations
// =============================================================================

@test
fn test_mutex_lock() {
    let m: Mutex<Int> = Mutex.new(10);

    let result: LockResult<MutexGuard<Int>> = m.lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 10);
            // Guard released when scope ends
        }
        Err(_) => panic("Expected Ok for lock"),
    }
}

@test
fn test_mutex_try_lock_uncontended() {
    let m: Mutex<Int> = Mutex.new(20);

    let result: TryLockResult<MutexGuard<Int>> = m.try_lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 20);
        }
        Err(_) => panic("Expected Ok for try_lock"),
    }
}

@test
fn test_mutex_try_lock_already_locked() {
    let m: Mutex<Int> = Mutex.new(30);

    // Acquire lock via match
    let lock_result: LockResult<MutexGuard<Int>> = m.lock();
    match lock_result {
        Ok(guard1) => {
            // Try to acquire again - should fail
            let try_result: TryLockResult<MutexGuard<Int>> = m.try_lock();
            match try_result {
                Err(TryLockError.WouldBlock) => {} // Expected
                Ok(_) => panic("Expected WouldBlock"),
                Err(_) => panic("Expected WouldBlock"),
            }
            // guard1 released at end of match arm
        }
        Err(_) => panic("Expected Ok"),
    }

    // Now try_lock should succeed
    let result: TryLockResult<MutexGuard<Int>> = m.try_lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 30);
        }
        Err(_) => panic("Expected Ok after release"),
    }
}

// =============================================================================
// Section 3: MutexGuard Operations
// =============================================================================

@test
fn test_mutex_guard_data() {
    let m: Mutex<Int> = Mutex.new(100);
    let result: LockResult<MutexGuard<Int>> = m.lock();
    match result {
        Ok(guard) => {
            // Test data() - read the value
            let value: &Int = guard.data();
            assert_eq(*value, 100);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_guard_data_mut() {
    let m: Mutex<Int> = Mutex.new(100);
    let result: LockResult<MutexGuard<Int>> = m.lock();
    match result {
        Ok(mut guard) => {
            // Test data_mut() - modify the value
            let data: &mut Int = guard.data_mut();
            *data = 200;

            let val: &Int = guard.data();
            assert_eq(*val, 200);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_guard_modify_complex() {
    let m: Mutex<Int> = Mutex.new(0);

    {
        let result: LockResult<MutexGuard<Int>> = m.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = *data + 10;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    {
        let result: LockResult<MutexGuard<Int>> = m.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = *data + 20;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    let result: LockResult<MutexGuard<Int>> = m.lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 30);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 4: Mutex get_mut and into_inner
// =============================================================================

@test
fn test_mutex_get_mut() {
    let mut m: Mutex<Int> = Mutex.new(50);

    // get_mut doesn't require locking (exclusive ownership)
    let result: LockResult<&mut Int> = m.get_mut();
    match result {
        Ok(data) => {
            *data = 100;
        }
        Err(_) => panic("Expected Ok for get_mut"),
    }

    let lock_result: LockResult<MutexGuard<Int>> = m.lock();
    match lock_result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 100);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_into_inner() {
    let m: Mutex<Int> = Mutex.new(77);

    let result: LockResult<Int> = m.into_inner();
    match result {
        Ok(data) => assert_eq(data, 77),
        Err(_) => panic("Expected Ok for into_inner"),
    }
}

// =============================================================================
// Section 5: Mutex Poison State
// =============================================================================

@test
fn test_mutex_not_poisoned_initially() {
    let m: Mutex<Int> = Mutex.new(0);
    assert(!m.is_poisoned());
}

@test
fn test_mutex_clear_poison() {
    let m: Mutex<Int> = Mutex.new(0);
    // Manually set poison for testing (would normally be set by panic)
    // Since we can't easily trigger panic in test, just verify clear works
    m.clear_poison();
    assert(!m.is_poisoned());
}

// =============================================================================
// Section 6: PoisonError Operations
// =============================================================================

@test
fn test_poison_error_get_ref() {
    let guard_data = 42;
    let err: PoisonError<Int> = PoisonError.new(guard_data);

    let ref_data = err.get_ref();
    assert_eq(*ref_data, 42);
}

@test
fn test_poison_error_get_mut() {
    let guard_data = 42;
    let mut err: PoisonError<Int> = PoisonError.new(guard_data);

    let mut_data = err.get_mut();
    *mut_data = 100;
    assert_eq(*err.get_ref(), 100);
}

@test
fn test_poison_error_into_inner() {
    let guard_data = 42;
    let err: PoisonError<Int> = PoisonError.new(guard_data);

    let data = err.into_inner();
    assert_eq(data, 42);
}

// =============================================================================
// Section 7: TryLockError Operations
// =============================================================================

@test
fn test_try_lock_error_would_block() {
    let m: Mutex<Int> = Mutex.new(0);

    // Hold the lock
    let result: LockResult<MutexGuard<Int>> = m.lock();
    match result {
        Ok(_guard) => {
            // Try to lock - should get WouldBlock
            let try_result: TryLockResult<MutexGuard<Int>> = m.try_lock();
            match try_result {
                Err(TryLockError.WouldBlock) => {} // Expected
                _ => panic("Expected WouldBlock"),
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 8: Multiple Lock/Unlock Cycles
// =============================================================================

@test
fn test_mutex_multiple_cycles() {
    let m: Mutex<Int> = Mutex.new(0);

    for i in 0..10 {
        let result: LockResult<MutexGuard<Int>> = m.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = *data + 1;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    let result: LockResult<MutexGuard<Int>> = m.lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 10);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_nested_scopes() {
    let m: Mutex<Int> = Mutex.new(0);

    {
        let result: LockResult<MutexGuard<Int>> = m.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = 1;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    {
        let result: LockResult<MutexGuard<Int>> = m.lock();
        match result {
            Ok(mut guard) => {
                let val: &Int = guard.data();
                assert_eq(*val, 1);
                let data = guard.data_mut();
                *data = 2;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    {
        let result: LockResult<MutexGuard<Int>> = m.lock();
        match result {
            Ok(guard) => {
                let val: &Int = guard.data();
                assert_eq(*val, 2);
            }
            Err(_) => panic("Expected Ok"),
        }
    }
}

// =============================================================================
// Section 9: Type-Specific Tests
// =============================================================================

@test
fn test_mutex_with_list() {
    mount core.collections.list.List;

    let m: Mutex<List<Int>> = Mutex.new(List.new());

    {
        let result: LockResult<MutexGuard<List<Int>>> = m.lock();
        match result {
            Ok(mut guard) => {
                let list: &mut List<Int> = guard.data_mut();
                list.push(1);
                list.push(2);
                list.push(3);
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    let result: LockResult<MutexGuard<List<Int>>> = m.lock();
    match result {
        Ok(guard) => {
            let list: &List<Int> = guard.data();
            assert_eq(list.len(), 3);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_with_option() {
    mount core.maybe.{Maybe, Some, None};

    let m: Mutex<Maybe<Int>> = Mutex.new(None);

    {
        let result: LockResult<MutexGuard<Maybe<Int>>> = m.lock();
        match result {
            Ok(mut guard) => {
                let opt: &mut Maybe<Int> = guard.data_mut();
                *opt = Some(42);
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    let result: LockResult<MutexGuard<Maybe<Int>>> = m.lock();
    match result {
        Ok(guard) => {
            let opt: &Maybe<Int> = guard.data();
            match *opt {
                Some(v) => assert_eq(v, 42),
                None => panic("Expected Some"),
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 10: Edge Cases
// =============================================================================

@test
fn test_mutex_zero_sized_type() {
    let m: Mutex<()> = Mutex.new(());

    let result: LockResult<MutexGuard<()>> = m.lock();
    match result {
        Ok(guard) => {
            let _: &() = guard.data();
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_immediate_drop() {
    let m: Mutex<Int> = Mutex.new(100);

    // Lock and immediately release
    {
        let _: LockResult<MutexGuard<Int>> = m.lock();
    }
    {
        let _: LockResult<MutexGuard<Int>> = m.lock();
    }
    {
        let _: LockResult<MutexGuard<Int>> = m.lock();
    }

    // Should still work
    let result: LockResult<MutexGuard<Int>> = m.lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 100);
        }
        Err(_) => panic("Expected Ok"),
    }
}

