}

@test
fn test_mutex_get_mut_multiple_times() {
    let mut m: Mutex<Int> = Mutex.new(0);

    {
        let result: LockResult<&mut Int> = m.get_mut();
        match result {
            Ok(data) => { *data = 10; }
            Err(_) => panic("Expected Ok"),
        }
    }
    {
        let result: LockResult<&mut Int> = m.get_mut();
        match result {
            Ok(data) => { *data = 20; }
            Err(_) => panic("Expected Ok"),
        }
    }

    let lock_result: LockResult<MutexGuard<Int>> = m.lock();
    match lock_result {
        Ok(guard) => {
            assert_eq(*guard.data(), 20);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 13: TryLockError.Poisoned Test
// =============================================================================

@test
fn test_try_lock_error_poisoned_construction() {
    let poison: PoisonError<Int> = PoisonError.new(42);
    let err: TryLockError<Int> = TryLockError.Poisoned(poison);

    match err {
        TryLockError.Poisoned(pe) => {
            assert_eq(*pe.get_ref(), 42);
        }
        TryLockError.WouldBlock => panic("Expected Poisoned"),
    }
}

// =============================================================================
// Section 14: Mutex with Tuple and Float Types
// =============================================================================

@test
fn test_mutex_with_float() {
    let m: Mutex<Float> = Mutex.new(0.0);

    {
        let result: LockResult<MutexGuard<Float>> = m.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = 2.718;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    let result: LockResult<MutexGuard<Float>> = m.lock();
    match result {
        Ok(guard) => {
            assert(*guard.data() > 2.71 && *guard.data() < 2.72);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_with_tuple() {
    let m: Mutex<(Int, Text)> = Mutex.new((0, "start"));

    let result: LockResult<MutexGuard<(Int, Text)>> = m.lock();
    match result {
        Ok(guard) => {
            let data: &(Int, Text) = guard.data();
            assert_eq(data.0, 0);
            assert_eq(data.1, "start");
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_lock_release_try_lock() {
    let m: Mutex<Int> = Mutex.new(5);

    // Lock, modify, release
    {
        let result: LockResult<MutexGuard<Int>> = m.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = 10;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // try_lock should succeed now
    let result: TryLockResult<MutexGuard<Int>> = m.try_lock();
    match result {
        Ok(guard) => {
            assert_eq(*guard.data(), 10);
        }
        Err(_) => panic("Expected Ok after release"),
    }
}

// =============================================================================
// Section 15: Lock-Modify-Verify Patterns
// =============================================================================

@test
fn test_mutex_lock_modify_verify() {
    let m: Mutex<Int> = Mutex.new(0);
    // Modify via lock
    {
        let result = m.lock();
        match result {
            Ok(mut guard) => {
                *guard.data_mut() = 42;
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    // Verify via try_lock
    let result = m.try_lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), 42),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_lock_increment_many() {
    let m: Mutex<Int> = Mutex.new(0);
    for _i in 0..50 {
        let result = m.lock();
        match result {
            Ok(mut guard) => {
                *guard.data_mut() = *guard.data() + 1;
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    let result = m.lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), 50),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_lock_set_negative() {
    let m: Mutex<Int> = Mutex.new(100);
    {
        let result = m.lock();
        match result {
            Ok(mut guard) => {
                *guard.data_mut() = -50;
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    let result = m.lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), -50),
        Err(_) => panic("Expected Ok"),
    }
}

