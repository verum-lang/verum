    let lock_result: LockResult<MutexGuard<Text>> = m.lock();
    match lock_result {
        Ok(guard) => {
            let val: &Text = guard.data();
            assert_eq(*val, "modified");
        }
        Err(_) => panic("Expected Ok"),
