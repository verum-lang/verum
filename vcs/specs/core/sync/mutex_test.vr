@test
fn test_mutex_try_lock_success_then_modify() {
    let m: Mutex<Int> = Mutex.new(10);
    let result = m.try_lock();
    match result {
        Ok(mut guard) => {
            *guard.data_mut() = 20;
            assert_eq(*guard.data(), 20);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_try_lock_multiple_success() {
    let m: Mutex<Int> = Mutex.new(0);
    for i in 0..5 {
        let result = m.try_lock();
        match result {
            Ok(mut guard) => {
                *guard.data_mut() = i;
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    let result = m.try_lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), 4),
        Err(_) => panic("Expected Ok"),
    }
}

