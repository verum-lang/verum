// =============================================================================
// Section 18: Poison State Deeper
// =============================================================================

@test
fn test_mutex_not_poisoned_after_normal_use() {
    let m: Mutex<Int> = Mutex.new(0);
    {
        let result = m.lock();
        match result {
            Ok(mut guard) => {
                *guard.data_mut() = 42;
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    assert(!m.is_poisoned());
}

@test
fn test_mutex_clear_poison_idempotent() {
    let m: Mutex<Int> = Mutex.new(0);
    m.clear_poison();
    m.clear_poison();
    m.clear_poison();
    assert(!m.is_poisoned());
}

