@test
fn test_poison_error_text_type() {
    let err: PoisonError<Text> = PoisonError.new("error data");
    assert_eq(*err.get_ref(), "error data");
}

@test
fn test_poison_error_bool_type() {
    let err: PoisonError<Bool> = PoisonError.new(true);
    assert_eq(*err.get_ref(), true);
}

@test
fn test_poison_error_into_inner_text() {
    let err: PoisonError<Text> = PoisonError.new("recover");
    let data = err.into_inner();
    assert_eq(data, "recover");
}

@test
fn test_poison_error_get_mut_modify() {
    let mut err: PoisonError<Int> = PoisonError.new(0);
    *err.get_mut() = 100;
    assert_eq(*err.get_ref(), 100);
    *err.get_mut() = 200;
    assert_eq(*err.get_ref(), 200);
}

