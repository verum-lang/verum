// =============================================================================
// Section 21: into_inner Additional Types
// =============================================================================

@test
fn test_mutex_into_inner_list() {
    mount core.collections.list.List;
    let m: Mutex<List<Int>> = Mutex.new(List.new());
    {
        let result = m.lock();
        match result {
            Ok(mut guard) => {
                guard.data_mut().push(1);
                guard.data_mut().push(2);
                guard.data_mut().push(3);
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    let result = m.into_inner();
    match result {
        Ok(list) => assert_eq(list.len(), 3),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_into_inner_tuple() {
    let m: Mutex<(Int, Bool)> = Mutex.new((42, true));
    let result = m.into_inner();
    match result {
        Ok(data) => {
            assert_eq(data.0, 42);
            assert_eq(data.1, true);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 22: get_mut Additional Types
// =============================================================================

@test
fn test_mutex_get_mut_bool() {
    let mut m: Mutex<Bool> = Mutex.new(false);
    let result = m.get_mut();
    match result {
        Ok(data) => {
            *data = true;
        }
        Err(_) => panic("Expected Ok"),
    }
    let lock_result = m.lock();
    match lock_result {
        Ok(guard) => assert_eq(*guard.data(), true),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_get_mut_float() {
    let mut m: Mutex<Float> = Mutex.new(0.0);
    let result = m.get_mut();
    match result {
        Ok(data) => {
            *data = 3.14;
        }
        Err(_) => panic("Expected Ok"),
    }
    let lock_result = m.lock();
    match lock_result {
        Ok(guard) => assert(*guard.data() > 3.13),
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 23: Combined Patterns
// =============================================================================

@test
fn test_mutex_lock_try_lock_alternating() {
    let m: Mutex<Int> = Mutex.new(0);
    // lock, modify, release, try_lock, modify, release...
    {
        let result = m.lock();
        match result {
            Ok(mut guard) => { *guard.data_mut() = 1; }
            Err(_) => panic("Expected Ok"),
        }
    }
    {
        let result = m.try_lock();
        match result {
            Ok(mut guard) => { *guard.data_mut() = 2; }
            Err(_) => panic("Expected Ok"),
        }
    }
    {
        let result = m.lock();
        match result {
            Ok(mut guard) => { *guard.data_mut() = 3; }
            Err(_) => panic("Expected Ok"),
        }
    }
    let result = m.try_lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), 3),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_modify_then_get_mut() {
    let mut m: Mutex<Int> = Mutex.new(0);
    // First modify via lock
    {
        let result = m.lock();
        match result {
            Ok(mut guard) => { *guard.data_mut() = 10; }
            Err(_) => panic("Expected Ok"),
        }
    }
    // Then modify via get_mut
    {
        let result = m.get_mut();
        match result {
            Ok(data) => { *data = 20; }
            Err(_) => panic("Expected Ok"),
        }
    }
    // Verify
    let result = m.lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), 20),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_default_types() {
    // Int default
    let m1: Mutex<Int> = Mutex.default();
    match m1.try_lock() {
        Ok(g) => assert_eq(*g.data(), 0),
        Err(_) => panic("Expected Ok"),
    }
    // Bool default
    let m2: Mutex<Bool> = Mutex.default();
    match m2.try_lock() {
        Ok(g) => assert_eq(*g.data(), false),
        Err(_) => panic("Expected Ok"),
    }
    // Text default
    let m3: Mutex<Text> = Mutex.default();
    match m3.try_lock() {
        Ok(g) => assert_eq(*g.data(), ""),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_large_value_type() {
    let m: Mutex<Int> = Mutex.new(999999999);
    let result = m.lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), 999999999),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_mutex_negative_value() {
    let m: Mutex<Int> = Mutex.new(-1);
    let result = m.lock();
    match result {
        Ok(guard) => assert_eq(*guard.data(), -1),
        Err(_) => panic("Expected Ok"),
    }
}

