fn test_mutex_into_inner_bool() {
    let m: Mutex<Bool> = Mutex.new(false);

    let result: LockResult<Bool> = m.into_inner();
    match result {
        Ok(data) => assert(!data),
        Err(_) => panic("Expected Ok for into_inner"),
    }
}

@test
fn test_mutex_into_inner_float() {
    let m: Mutex<Float> = Mutex.new(3.14);

    let result: LockResult<Float> = m.into_inner();
    match result {
        Ok(data) => assert(data > 3.13 && data < 3.15),
        Err(_) => panic("Expected Ok for into_inner"),
    }
}

