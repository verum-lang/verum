// =============================================================================
// Section 13: AtomicBool Swap and Compare-Exchange
// =============================================================================

@test
fn test_atomicbool_swap_true_to_false() {
    let atomic = AtomicBool.new(true);
    let old = atomic.swap(false, SeqCst);
    assert_eq(old, true);
    assert_eq(atomic.load(SeqCst), false);
}

@test
fn test_atomicbool_swap_false_to_true() {
    let atomic = AtomicBool.new(false);
    let old = atomic.swap(true, SeqCst);
    assert_eq(old, false);
    assert_eq(atomic.load(SeqCst), true);
}

@test
fn test_atomicbool_compare_exchange_success() {
    let atomic = AtomicBool.new(false);
    let result = atomic.compare_exchange(false, true, SeqCst, Relaxed);
    assert(result.is_ok());
    assert_eq(atomic.load(SeqCst), true);
}

@test
fn test_atomicbool_compare_exchange_failure() {
    let atomic = AtomicBool.new(true);
    let result = atomic.compare_exchange(false, true, SeqCst, Relaxed);
    assert(result.is_err());
    assert_eq(atomic.load(SeqCst), true); // Unchanged
}

// =============================================================================
// Section 14: Fence and Ordering Variant Tests
// =============================================================================

@test
fn test_fence_seqcst() {
    // Fence should not panic
    fence(SeqCst);
}

@test
fn test_fence_acquire() {
    fence(Acquire);
}

@test
fn test_fence_release() {
    fence(Release);
}

@test
fn test_fence_acqrel() {
    fence(AcqRel);
}

@test
fn test_ordering_variants_exist() {
    let r = Relaxed;
    let a = Acquire;
    let rel = Release;
    let ar = AcqRel;
    let sc = SeqCst;

    assert(r is Ordering.Relaxed);
    assert(a is Ordering.Acquire);
    assert(rel is Ordering.Release);
    assert(ar is Ordering.AcqRel);
    assert(sc is Ordering.SeqCst);
}

@test
fn test_ordering_match() {
    let ord = AcqRel;
    let val = match ord {
        Ordering.Relaxed => 0,
        Ordering.Acquire => 1,
        Ordering.Release => 2,
        Ordering.AcqRel => 3,
        Ordering.SeqCst => 4,
    };
    assert_eq(val, 3);
}

// =============================================================================
// Section 15: AtomicInt Advanced Patterns
// =============================================================================

@test
fn test_atomicint_cas_loop_increment() {
    let counter = AtomicInt.new(0);

    // Increment 10 times via CAS loop
    for _ in 0..10 {
        let mut current = counter.load(Relaxed);
        loop {
            let result = counter.compare_exchange(current, current + 1, SeqCst, Relaxed);
            match result {
                Ok(_) => { break; },
                Err(actual) => { current = actual; },
            }
        }
    }

    assert_eq(counter.load(SeqCst), 10);
}

@test
fn test_atomicint_swap_chain() {
    let atomic = AtomicInt.new(1);
    let v1 = atomic.swap(2, SeqCst);
    let v2 = atomic.swap(3, SeqCst);
    let v3 = atomic.swap(4, SeqCst);
    assert_eq(v1, 1);
    assert_eq(v2, 2);
    assert_eq(v3, 3);
    assert_eq(atomic.load(SeqCst), 4);
}

@test
fn test_atomicint_mixed_operations() {
    let atomic = AtomicInt.new(0);
    atomic.fetch_add(10, SeqCst);       // 0 + 10 = 10
    atomic.fetch_sub(3, SeqCst);        // 10 - 3 = 7
    let old = atomic.swap(100, SeqCst); // swap 7 -> 100
    assert_eq(old, 7);
    assert_eq(atomic.load(SeqCst), 100);
}

@test
fn test_atomicu32_counter_simulation() {
    let counter = AtomicU32.new0_u32;

    for _ in 0..50 {
        counter.fetch_add(1 as UInt32, Relaxed);
    }

    assert_eq(counter.load(Relaxed), 50 as UInt32);
}

@test
fn test_atomicu64_large_values() {
    let atomic = AtomicU64.new0xFFFFFFFF00000000_u64;
    let old = atomic.fetch_add(0x00000000FFFFFFFF as UInt64, SeqCst);
    assert_eq(old, 0xFFFFFFFF00000000 as UInt64);
    assert_eq(atomic.load(SeqCst), 0xFFFFFFFFFFFFFFFF as UInt64);
}

