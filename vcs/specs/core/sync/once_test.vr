// =============================================================================
// once_test.vr - Tests for Once, OnceState, and OnceLock<T>
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: sync, once, lazy, initialization, concurrency, core
// @description: Comprehensive tests for Once, OnceState, OnceLock<T>
// =============================================================================

mount core.sync.once.{Once, OnceState, OnceLock};
mount core.maybe.{Maybe, Some, None};
mount core.result.{Result, Ok, Err};

// =============================================================================
// Section 1: Once Construction Tests
// =============================================================================

@test
fn test_once_new() {
    let once: Once = Once.new();
    assert(!once.is_completed());
}

@test
fn test_once_initial_state() {
    let once: Once = Once.new();
    match once.state() {
        OnceState.New => {} // Expected
        _ => panic("Expected New state"),
    }
}

@test
fn test_once_default() {
    let once: Once = Once.default();
    assert(!once.is_completed());
    match once.state() {
        OnceState.New => {} // Expected
        _ => panic("Expected New state"),
    }
}

// =============================================================================
// Section 2: Once call_once Tests
// =============================================================================

@test
fn test_once_call_once() {
    let once: Once = Once.new();
    let mut called: Int = 0;

    once.call_once(|| {
        called = called + 1;
    });

    assert_eq(called, 1);
    assert(once.is_completed());
}

@test
fn test_once_call_once_multiple_times() {
    let once: Once = Once.new();
    let mut called: Int = 0;

    // First call - should execute
    once.call_once(|| {
        called = called + 1;
    });

    // Second call - should not execute
    once.call_once(|| {
        called = called + 10;
    });

    // Third call - should not execute
    once.call_once(|| {
        called = called + 100;
    });

    // Only first call should have executed
    assert_eq(called, 1);
}

@test
fn test_once_call_once_state_changes() {
    let once: Once = Once.new();

    // Initially New
    match once.state() {
        OnceState.New => {} // Expected
        _ => panic("Expected New state"),
    }

    once.call_once(|| {});

    // After call_once, should be Done
    match once.state() {
        OnceState.Done => {} // Expected
        _ => panic("Expected Done state"),
    }
}

@test
fn test_once_is_completed_before() {
    let once: Once = Once.new();
    assert(!once.is_completed());
}

@test
fn test_once_is_completed_after() {
    let once: Once = Once.new();
    once.call_once(|| {});
    assert(once.is_completed());
}

// =============================================================================
// Section 3: Once call_once_force Tests
// =============================================================================

@test
fn test_once_call_once_force() {
    let once: Once = Once.new();
    let mut called: Int = 0;

    once.call_once_force(|| {
        called = called + 1;
    });

    assert_eq(called, 1);
    assert(once.is_completed());
}

@test
fn test_once_call_once_force_multiple_times() {
    let once: Once = Once.new();
    let mut called: Int = 0;

    // First call - should execute
    once.call_once_force(|| {
        called = called + 1;
    });

    // Second call - should not execute (already complete)
    once.call_once_force(|| {
        called = called + 10;
    });

    assert_eq(called, 1);
}

