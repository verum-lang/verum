@test
fn test_condvar_wait_while_always_true_predicate() {
    let mutex: Mutex<Bool> = Mutex.new(false);
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Bool>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            // Predicate always true means wait_while would block forever in real execution
            // In typecheck-pass mode, just verify it type-checks
            let _result: LockResult<MutexGuard<Bool>> = cv.wait_while(guard, |_data: &Bool| true);
        }
        Err(_) => panic("Expected Ok"),
    }
}

