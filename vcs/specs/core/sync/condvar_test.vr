@test
fn test_condvar_with_mutex_text() {
    let mutex: Mutex<Text> = Mutex.new("initial");
    let cv: Condvar = Condvar.new();

    {
        let result: LockResult<MutexGuard<Text>> = mutex.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = "updated";
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    cv.notify_one();

    let result: LockResult<MutexGuard<Text>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert_eq(*guard.data(), "updated");
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_with_mutex_bool() {
    let mutex: Mutex<Bool> = Mutex.new(false);
    let cv: Condvar = Condvar.new();

    {
        let result: LockResult<MutexGuard<Bool>> = mutex.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = true;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    cv.notify_all();

    let result: LockResult<MutexGuard<Bool>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert_eq(*guard.data(), true);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_with_mutex_float() {
    let mutex: Mutex<Float> = Mutex.new(0.0);
    let cv: Condvar = Condvar.new();

    {
        let result: LockResult<MutexGuard<Float>> = mutex.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = 99.99;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    cv.notify_one();

    let result: LockResult<MutexGuard<Float>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert_eq(*guard.data(), 99.99);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 18: Multiple Condvars on Different Mutexes
// =============================================================================

@test
fn test_two_condvars_different_mutexes() {
    let mutex1: Mutex<Int> = Mutex.new(10);
    let mutex2: Mutex<Text> = Mutex.new("hello");
    let cv1: Condvar = Condvar.new();
    let cv2: Condvar = Condvar.new();

    // Modify first mutex
    {
        let result: LockResult<MutexGuard<Int>> = mutex1.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = 20;
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    cv1.notify_one();

    // Modify second mutex
    {
        let result: LockResult<MutexGuard<Text>> = mutex2.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = "world";
            }
            Err(_) => panic("Expected Ok"),
        }
    }
    cv2.notify_all();

    // Verify both independently
    assert_eq(cv1.waiter_count(), 0);
    assert_eq(cv2.waiter_count(), 0);

    let r1: LockResult<MutexGuard<Int>> = mutex1.lock();
    match r1 {
        Ok(guard) => { assert_eq(*guard.data(), 20); }
        Err(_) => panic("Expected Ok"),
    }

    let r2: LockResult<MutexGuard<Text>> = mutex2.lock();
    match r2 {
        Ok(guard) => { assert_eq(*guard.data(), "world"); }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvars_created_and_used_independently() {
    let cv_a: Condvar = Condvar.new();
    let cv_b: Condvar = Condvar.default();

    let mutex_a: Mutex<Int> = Mutex.new(0);
    let mutex_b: Mutex<Int> = Mutex.new(0);

    // Use cv_a with mutex_a
    cv_a.notify_one();
    assert_eq(cv_a.waiter_count(), 0);

    // Use cv_b with mutex_b
    cv_b.notify_all();
    assert_eq(cv_b.waiter_count(), 0);

    // Verify mutexes are unaffected by condvar operations
    let r_a: LockResult<MutexGuard<Int>> = mutex_a.lock();
    match r_a {
        Ok(guard) => { assert_eq(*guard.data(), 0); }
        Err(_) => panic("Expected Ok"),
    }

    let r_b: LockResult<MutexGuard<Int>> = mutex_b.lock();
    match r_b {
        Ok(guard) => { assert_eq(*guard.data(), 0); }
        Err(_) => panic("Expected Ok"),
    }
}

