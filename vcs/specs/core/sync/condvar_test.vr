// =============================================================================
// Section 24: Edge Case Combinations
// =============================================================================

@test
fn test_condvar_notify_then_check_waiter_count_repeatedly() {
    let cv: Condvar = Condvar.new();

    assert_eq(cv.waiter_count(), 0);
    cv.notify_one();
    assert_eq(cv.waiter_count(), 0);
    cv.notify_all();
    assert_eq(cv.waiter_count(), 0);
    cv.notify_one();
    assert_eq(cv.waiter_count(), 0);
    cv.notify_all();
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_with_mutex_modify_and_notify_multiple() {
    let mutex: Mutex<List<Int>> = Mutex.new(List.new());
    let cv: Condvar = Condvar.new();

    // Add elements in separate lock/unlock cycles
    for i in 0..5 {
        {
            let result: LockResult<MutexGuard<List<Int>>> = mutex.lock();
            match result {
                Ok(mut guard) => {
                    let data = guard.data_mut();
                    data.push(i);
                }
                Err(_) => panic("Expected Ok"),
            }
        }
        cv.notify_one();
    }

    // Verify all elements were added
    let result: LockResult<MutexGuard<List<Int>>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert_eq(guard.data().len(), 5);
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_with_guard_and_direct_notify_mixed() {
    let cv: Condvar = Condvar.new();

    // Mix guard-based and direct notification
    cv.notify_one();

    {
        let _g: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);
    }

    cv.notify_all();

    {
        let _g: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
    }

    cv.notify_one();

    assert_eq(cv.waiter_count(), 0);
}

