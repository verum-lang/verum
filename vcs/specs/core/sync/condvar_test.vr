@test
fn test_wait_timeout_result_construction_patterns() {
    // Test both possible states
    let signaled = WaitTimeoutResult { timed_out: false };
    let expired = WaitTimeoutResult { timed_out: true };

    assert(!signaled.timed_out());
    assert(expired.timed_out());
}

@test
fn test_wait_timeout_result_in_conditional() {
    let result = WaitTimeoutResult { timed_out: true };
    assert(result.timed_out());
}

// =============================================================================
// Section 13: Condvar Construction Additional Tests
// =============================================================================

@test
fn test_condvar_new_waiter_count_zero() {
    let cv: Condvar = Condvar.new();
    let count: Int = cv.waiter_count();
    assert_eq(count, 0);
    assert(count >= 0);
}

@test
fn test_condvar_default_waiter_count_zero() {
    let cv: Condvar = Condvar.default();
    let count: Int = cv.waiter_count();
    assert_eq(count, 0);
    assert(count >= 0);
}

@test
fn test_multiple_condvars_independent_state() {
    let cv1: Condvar = Condvar.new();
    let cv2: Condvar = Condvar.new();
    let cv3: Condvar = Condvar.default();
    let cv4: Condvar = Condvar.default();

    // Each condvar has its own independent waiter count
    assert_eq(cv1.waiter_count(), 0);
    assert_eq(cv2.waiter_count(), 0);
    assert_eq(cv3.waiter_count(), 0);
    assert_eq(cv4.waiter_count(), 0);

    // Notifying one doesn't affect the others
    cv1.notify_one();
    cv2.notify_all();

    assert_eq(cv1.waiter_count(), 0);
    assert_eq(cv2.waiter_count(), 0);
    assert_eq(cv3.waiter_count(), 0);
    assert_eq(cv4.waiter_count(), 0);
}

// =============================================================================
// Section 14: Notify Guard Extended Tests
// =============================================================================

@test
fn test_notify_one_guard_is_held() {
    let cv: Condvar = Condvar.new();
    let guard: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);

    // Guard is active while held
    assert_eq(cv.waiter_count(), 0);

    // Drop explicitly by going out of scope
    drop(guard);
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_notify_all_guard_is_held() {
    let cv: Condvar = Condvar.new();
    let guard: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);

    // Guard is active while held
    assert_eq(cv.waiter_count(), 0);

    drop(guard);
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_notify_guard_drop_in_scope() {
    let cv: Condvar = Condvar.new();

    {
        let _g1: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
        // g1 will notify_one on drop at end of scope
    }
    // g1 has been dropped, notify_one was called

    {
        let _g2: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);
        // g2 will notify_all on drop at end of scope
    }
    // g2 has been dropped, notify_all was called

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_notify_guard_multiple_same_condvar() {
    let cv: Condvar = Condvar.new();

    // Multiple guards on the same condvar
    {
        let g1: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
        let g2: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);
        let g3: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
        // All three dropped here
    }

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_notify_guard_different_condvars() {
    let cv1: Condvar = Condvar.new();
    let cv2: Condvar = Condvar.new();

    {
        let _g1: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv1);
        let _g2: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv2);
    }

    assert_eq(cv1.waiter_count(), 0);
    assert_eq(cv2.waiter_count(), 0);
}

// =============================================================================
// Section 15: WaitTimeoutResult Extended Patterns
// =============================================================================

@test
fn test_wait_timeout_result_conditional_timed_out() {
    let result = WaitTimeoutResult { timed_out: true };
    let mut handled: Bool = false;

    if result.timed_out() {
        handled = true;
    }

    assert(handled);
}

@test
fn test_wait_timeout_result_conditional_not_timed_out() {
    let result = WaitTimeoutResult { timed_out: false };
    let mut handled: Bool = false;

    if !result.timed_out() {
        handled = true;
    }

    assert(handled);
}

@test
fn test_wait_timeout_result_multiple_checks() {
    let r1 = WaitTimeoutResult { timed_out: true };
    let r2 = WaitTimeoutResult { timed_out: false };
    let r3 = WaitTimeoutResult { timed_out: true };

    // Check multiple results
    assert(r1.timed_out());
    assert(!r2.timed_out());
    assert(r3.timed_out());

    // Consistency: calling timed_out() multiple times on same result
    assert_eq(r1.timed_out(), true);
    assert_eq(r1.timed_out(), true);
    assert_eq(r2.timed_out(), false);
    assert_eq(r2.timed_out(), false);
}

@test
fn test_wait_timeout_result_in_variable_binding() {
    let result = WaitTimeoutResult { timed_out: false };
    let did_timeout: Bool = result.timed_out();
    assert_eq(did_timeout, false);

    let result2 = WaitTimeoutResult { timed_out: true };
    let did_timeout2: Bool = result2.timed_out();
    assert_eq(did_timeout2, true);
}

// =============================================================================
// Section 16: producer_consumer_pair with Various Types
// =============================================================================

@test
fn test_producer_consumer_pair_float() {
    let (mutex, condvar): (Mutex<Float>, Condvar) = producer_consumer_pair(3.14);

    let result: LockResult<MutexGuard<Float>> = mutex.lock();
    match result {
        Ok(guard) => {
            let val: &Float = guard.data();
            assert_eq(*val, 3.14);
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(condvar.waiter_count(), 0);
}

@test
fn test_producer_consumer_pair_list_int() {
    let initial: List<Int> = List.new();
    let (mutex, condvar): (Mutex<List<Int>>, Condvar) = producer_consumer_pair(initial);

    let result: LockResult<MutexGuard<List<Int>>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert_eq(guard.data().len(), 0);
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(condvar.waiter_count(), 0);
}

@test
fn test_producer_consumer_pair_tuple() {
    let (mutex, condvar): (Mutex<(Int, Bool)>, Condvar) = producer_consumer_pair((42, true));

    let result: LockResult<MutexGuard<(Int, Bool)>> = mutex.lock();
    match result {
        Ok(guard) => {
            let val: &(Int, Bool) = guard.data();
            assert_eq(val.0, 42);
            assert_eq(val.1, true);
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(condvar.waiter_count(), 0);
}

@test
fn test_producer_consumer_pair_maybe_int() {
    let (mutex, condvar): (Mutex<Maybe<Int>>, Condvar) = producer_consumer_pair(None);

    let result: LockResult<MutexGuard<Maybe<Int>>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert(guard.data().is_none());
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(condvar.waiter_count(), 0);
}

@test
fn test_producer_consumer_pair_modify_value() {
    let (mutex, condvar): (Mutex<Int>, Condvar) = producer_consumer_pair(0);

    // Modify under lock
    {
        let result: LockResult<MutexGuard<Int>> = mutex.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = 100;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    condvar.notify_one();

    // Verify modified value
    let result: LockResult<MutexGuard<Int>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert_eq(*guard.data(), 100);
        }
        Err(_) => panic("Expected Ok"),
    }
}

