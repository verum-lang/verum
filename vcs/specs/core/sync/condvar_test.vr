// =============================================================================
// condvar_test.vr - Tests for Condvar and related types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: sync, condvar, condition, concurrency, core
// @description: Comprehensive tests for Condvar, CondvarNotifyGuard, WaitTimeoutResult
// =============================================================================

mount core.sync.condvar.{Condvar, CondvarNotifyGuard, WaitTimeoutResult, producer_consumer_pair};
mount core.sync.mutex.{Mutex, MutexGuard, LockResult};
mount core.result.{Result, Ok, Err};

// =============================================================================
// Section 1: Condvar Construction Tests
// =============================================================================

@test
fn test_condvar_new() {
    let cv: Condvar = Condvar.new();
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_default() {
    let cv: Condvar = Condvar.default();
    assert_eq(cv.waiter_count(), 0);
}

// =============================================================================
// Section 2: Condvar Notify Tests (No Waiters)
// =============================================================================

@test
fn test_condvar_notify_one_no_waiters() {
    let cv: Condvar = Condvar.new();

    // Should not block or panic even with no waiters
    cv.notify_one();
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_notify_all_no_waiters() {
    let cv: Condvar = Condvar.new();

    // Should not block or panic even with no waiters
    cv.notify_all();
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_notify_one_multiple_times() {
    let cv: Condvar = Condvar.new();

    cv.notify_one();
    cv.notify_one();
    cv.notify_one();

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_notify_all_multiple_times() {
    let cv: Condvar = Condvar.new();

    cv.notify_all();
    cv.notify_all();
    cv.notify_all();

    assert_eq(cv.waiter_count(), 0);
}

// =============================================================================
// Section 3: Condvar waiter_count Tests
// =============================================================================

@test
fn test_condvar_waiter_count_initial() {
    let cv: Condvar = Condvar.new();
    assert_eq(cv.waiter_count(), 0);
}

// =============================================================================
// Section 4: WaitTimeoutResult Tests
// =============================================================================

@test
fn test_wait_timeout_result_timed_out_true() {
    let result: WaitTimeoutResult = WaitTimeoutResult { timed_out: true };
    assert(result.timed_out());
}

@test
fn test_wait_timeout_result_timed_out_false() {
    let result: WaitTimeoutResult = WaitTimeoutResult { timed_out: false };
    assert(!result.timed_out());
}

// =============================================================================
// Section 5: CondvarNotifyGuard Tests
// =============================================================================

@test
fn test_condvar_notify_one_guard() {
    let cv: Condvar = Condvar.new();

    {
        let guard: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
        // Guard is held here
        // When dropped, it will call notify_one
    }

    // Guard dropped, notify_one called
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_notify_all_guard() {
    let cv: Condvar = Condvar.new();

    {
        let guard: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);
        // Guard is held here
        // When dropped, it will call notify_all
    }

    // Guard dropped, notify_all called
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_notify_guard_nested() {
    let cv: Condvar = Condvar.new();

    {
        let guard1: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
        {
            let guard2: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);
            // Both guards held
        }
        // guard2 dropped, notify_all called
    }
    // guard1 dropped, notify_one called

    assert_eq(cv.waiter_count(), 0);
}

// =============================================================================
// Section 6: producer_consumer_pair Tests
// =============================================================================

@test
fn test_producer_consumer_pair_int() {
    let (mutex, condvar): (Mutex<Int>, Condvar) = producer_consumer_pair(0);

    let result: LockResult<MutexGuard<Int>> = mutex.lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 0);
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(condvar.waiter_count(), 0);
}

@test
fn test_producer_consumer_pair_text() {
    let (mutex, condvar): (Mutex<Text>, Condvar) = producer_consumer_pair("hello");

    let result: LockResult<MutexGuard<Text>> = mutex.lock();
    match result {
        Ok(guard) => {
            let val: &Text = guard.data();
            assert_eq(*val, "hello");
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(condvar.waiter_count(), 0);
}

@test
fn test_producer_consumer_pair_bool() {
    let (mutex, condvar): (Mutex<Bool>, Condvar) = producer_consumer_pair(false);

    let result: LockResult<MutexGuard<Bool>> = mutex.lock();
    match result {
        Ok(guard) => {
            let val: &Bool = guard.data();
            assert_eq(*val, false);
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(condvar.waiter_count(), 0);
}

// =============================================================================
// Section 7: Condvar with Mutex Pattern Tests
// =============================================================================

@test
fn test_condvar_with_mutex_basic() {
    let mutex: Mutex<Int> = Mutex.new(0);
    let cv: Condvar = Condvar.new();

    // Modify value under lock
    {
        let result: LockResult<MutexGuard<Int>> = mutex.lock();
        match result {
            Ok(mut guard) => {
                let data = guard.data_mut();
                *data = 42;
            }
            Err(_) => panic("Expected Ok"),
        }
    }

    // Notify (no one waiting, but should work)
    cv.notify_one();

    // Verify value
    let result: LockResult<MutexGuard<Int>> = mutex.lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 42);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_multiple_modifications() {
    let mutex: Mutex<Int> = Mutex.new(0);
    let cv: Condvar = Condvar.new();

    for i in 0..5 {
        {
            let result: LockResult<MutexGuard<Int>> = mutex.lock();
            match result {
                Ok(mut guard) => {
                    let data = guard.data_mut();
                    *data = *data + 1;
                }
                Err(_) => panic("Expected Ok"),
            }
        }
        cv.notify_one();
    }

    let result: LockResult<MutexGuard<Int>> = mutex.lock();
    match result {
        Ok(guard) => {
            let val: &Int = guard.data();
            assert_eq(*val, 5);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 8: wait_timeout Type Signature Tests
// =============================================================================
// Note: These tests verify the wait_timeout method type-checks correctly.
// In typecheck-pass mode, the code is never executed (wait_timeout would block).

@test
fn test_condvar_wait_timeout_signature_int() {
    let mutex: Mutex<Int> = Mutex.new(42);
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Int>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            // wait_timeout returns LockResult<(MutexGuard<T>, Bool)>
            let result: LockResult<(MutexGuard<Int>, Bool)> = cv.wait_timeout(guard, 1000);
            match result {
                Ok((new_guard, timed_out)) => {
                    let _val: &Int = new_guard.data();
                    let _timeout: Bool = timed_out;
                }
                Err(_) => {}
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_wait_timeout_signature_text() {
    let mutex: Mutex<Text> = Mutex.new("hello");
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Text>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            let result: LockResult<(MutexGuard<Text>, Bool)> = cv.wait_timeout(guard, 5000);
            match result {
                Ok((new_guard, timed_out)) => {
                    let _val: &Text = new_guard.data();
                    let _: Bool = timed_out;
                }
                Err(_) => {}
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_wait_timeout_zero_timeout() {
    let mutex: Mutex<Int> = Mutex.new(0);
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Int>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            // Zero timeout should be valid
            let _result: LockResult<(MutexGuard<Int>, Bool)> = cv.wait_timeout(guard, 0);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_wait_timeout_large_timeout() {
    let mutex: Mutex<Int> = Mutex.new(0);
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Int>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            // Large timeout should be valid
            let _result: LockResult<(MutexGuard<Int>, Bool)> = cv.wait_timeout(guard, 1_000_000_000);
        }
        Err(_) => panic("Expected Ok"),
    }
}

// =============================================================================
// Section 9: wait_while Type Signature Tests
// =============================================================================

@test
fn test_condvar_wait_while_signature() {
    let mutex: Mutex<Int> = Mutex.new(0);
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Int>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            // wait_while takes a predicate fn(&T) -> Bool
            let result: LockResult<MutexGuard<Int>> = cv.wait_while(guard, |data: &Int| *data == 0);
            match result {
                Ok(new_guard) => {
                    let _val: &Int = new_guard.data();
                }
                Err(_) => {}
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_wait_while_signature_text() {
    let mutex: Mutex<Text> = Mutex.new("");
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Text>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            let result: LockResult<MutexGuard<Text>> = cv.wait_while(guard, |data: &Text| data.is_empty());
            match result {
                Ok(new_guard) => {
                    let _val: &Text = new_guard.data();
                }
                Err(_) => {}
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_wait_while_always_false_predicate() {
    let mutex: Mutex<Int> = Mutex.new(42);
    let cv: Condvar = Condvar.new();

    let guard_result: LockResult<MutexGuard<Int>> = mutex.lock();
    match guard_result {
        Ok(guard) => {
            // Predicate always returns false -> wait_while returns immediately
            let result: LockResult<MutexGuard<Int>> = cv.wait_while(guard, |_data: &Int| false);
            match result {
                Ok(_) => {}
                Err(_) => {}
            }
        }
        Err(_) => panic("Expected Ok"),
    }
}

