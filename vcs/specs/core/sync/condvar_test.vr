// =============================================================================
// Section 21: Sequential Notify Patterns
// =============================================================================

@test
fn test_notify_one_in_loop_10_times() {
    let cv: Condvar = Condvar.new();

    for _i in 0..10 {
        cv.notify_one();
    }

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_notify_all_in_loop_5_times() {
    let cv: Condvar = Condvar.new();

    for _i in 0..5 {
        cv.notify_all();
    }

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_alternating_notify_in_loop() {
    let cv: Condvar = Condvar.new();

    for i in 0..8 {
        if i % 2 == 0 {
            cv.notify_one();
        } else {
            cv.notify_all();
        }
    }

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_notify_with_mutex_modifications_in_loop() {
    let mutex: Mutex<Int> = Mutex.new(0);
    let cv: Condvar = Condvar.new();

    for _i in 0..10 {
        {
            let result: LockResult<MutexGuard<Int>> = mutex.lock();
            match result {
                Ok(mut guard) => {
                    let data = guard.data_mut();
                    *data = *data + 1;
                }
                Err(_) => panic("Expected Ok"),
            }
        }
        cv.notify_all();
    }

    let result: LockResult<MutexGuard<Int>> = mutex.lock();
    match result {
        Ok(guard) => {
            assert_eq(*guard.data(), 10);
        }
        Err(_) => panic("Expected Ok"),
    }

    assert_eq(cv.waiter_count(), 0);
}

// =============================================================================
// Section 22: CondvarNotifyGuard Additional Patterns
// =============================================================================

@test
fn test_condvar_notify_guard_one_guard_fields() {
    let cv: Condvar = Condvar.new();

    // notify_one_guard creates a guard that calls notify_one on drop
    {
        let guard: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
        // Guard exists, will call notify_one when it drops
        assert_eq(cv.waiter_count(), 0);
    }
    // Guard dropped, notify_one called
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_notify_guard_all_guard_fields() {
    let cv: Condvar = Condvar.new();

    // notify_all_guard creates a guard that calls notify_all on drop
    {
        let guard: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);
        assert_eq(cv.waiter_count(), 0);
    }
    // Guard dropped, notify_all called
    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_notify_guard_sequential_creation() {
    let cv: Condvar = Condvar.new();

    // Create and drop guards one at a time
    {
        let _g: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
    }
    assert_eq(cv.waiter_count(), 0);

    {
        let _g: CondvarNotifyGuard = CondvarNotifyGuard.notify_all_guard(&cv);
    }
    assert_eq(cv.waiter_count(), 0);

    {
        let _g: CondvarNotifyGuard = CondvarNotifyGuard.notify_one_guard(&cv);
    }
    assert_eq(cv.waiter_count(), 0);
}

