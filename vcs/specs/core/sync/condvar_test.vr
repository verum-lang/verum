// =============================================================================
// Section 11: Edge Cases
// =============================================================================

@test
fn test_condvar_multiple_condvars_same_mutex() {
    let mutex: Mutex<Int> = Mutex.new(0);
    let cv1: Condvar = Condvar.new();
    let cv2: Condvar = Condvar.new();

    // Multiple condvars can use the same mutex
    cv1.notify_one();
    cv2.notify_all();

    assert_eq(cv1.waiter_count(), 0);
    assert_eq(cv2.waiter_count(), 0);
}

@test
fn test_condvar_created_independently() {
    let cv1: Condvar = Condvar.new();
    let cv2: Condvar = Condvar.new();
    let cv3: Condvar = Condvar.new();

    assert_eq(cv1.waiter_count(), 0);
    assert_eq(cv2.waiter_count(), 0);
    assert_eq(cv3.waiter_count(), 0);

    cv1.notify_one();
    cv2.notify_all();
    cv3.notify_one();

    assert_eq(cv1.waiter_count(), 0);
    assert_eq(cv2.waiter_count(), 0);
    assert_eq(cv3.waiter_count(), 0);
}

@test
fn test_condvar_notify_interleaved() {
    let cv: Condvar = Condvar.new();

    // Interleave notify_one and notify_all
    cv.notify_one();
    cv.notify_all();
    cv.notify_one();
    cv.notify_all();

    assert_eq(cv.waiter_count(), 0);
}

@test
fn test_condvar_with_mutex_list() {
    let mutex: Mutex<List<Int>> = Mutex.new(List.new());
    let cv: Condvar = Condvar.new();

    let result: LockResult<MutexGuard<List<Int>>> = mutex.lock();
    match result {
        Ok(mut guard) => {
            let data = guard.data_mut();
            data.push(1);
            data.push(2);
            data.push(3);
        }
        Err(_) => panic("Expected Ok"),
    }

    cv.notify_all();

    let result2: LockResult<MutexGuard<List<Int>>> = mutex.lock();
    match result2 {
        Ok(guard) => {
            assert_eq(guard.data().len(), 3);
        }
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_condvar_with_mutex_maybe() {
    let mutex: Mutex<Maybe<Int>> = Mutex.new(None);
    let cv: Condvar = Condvar.new();

    let result: LockResult<MutexGuard<Maybe<Int>>> = mutex.lock();
    match result {
        Ok(mut guard) => {
            let data = guard.data_mut();
            *data = Some(42);
        }
        Err(_) => panic("Expected Ok"),
    }

    cv.notify_one();

    let result2: LockResult<MutexGuard<Maybe<Int>>> = mutex.lock();
    match result2 {
        Ok(guard) => {
            assert(guard.data().is_some());
        }
        Err(_) => panic("Expected Ok"),
    }
}

