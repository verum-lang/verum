// =============================================================================
// Section 19: TaskId Advanced Properties
// =============================================================================

@test
fn test_task_id_distinct_values_ten() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    let id3: TaskId = TaskId.new();
    let id4: TaskId = TaskId.new();
    let id5: TaskId = TaskId.new();
    let id6: TaskId = TaskId.new();
    let id7: TaskId = TaskId.new();
    let id8: TaskId = TaskId.new();
    let id9: TaskId = TaskId.new();
    let id10: TaskId = TaskId.new();

    // All IDs are strictly increasing
    assert(id1.id < id2.id);
    assert(id2.id < id3.id);
    assert(id3.id < id4.id);
    assert(id4.id < id5.id);
    assert(id5.id < id6.id);
    assert(id6.id < id7.id);
    assert(id7.id < id8.id);
    assert(id8.id < id9.id);
    assert(id9.id < id10.id);
}

@test
fn test_task_id_inequality_chain() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    let id3: TaskId = TaskId.new();
    let id4: TaskId = TaskId.new();

    // All pairwise comparisons are not equal
    assert(id1.ne(&id2));
    assert(id1.ne(&id3));
    assert(id1.ne(&id4));
    assert(id2.ne(&id3));
    assert(id2.ne(&id4));
    assert(id3.ne(&id4));
}

@test
fn test_task_id_field_consistent() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    // Field value difference matches ordering
    assert(id2.id > id1.id);
    assert(id2.id - id1.id >= 1);
}

