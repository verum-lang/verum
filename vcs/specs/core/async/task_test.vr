fn test_join_set_with_nested_maybe() {
    let set: JoinSet<Maybe<Maybe<Int>>> = JoinSet.new();
    assert(set.is_empty());
}

@test
fn test_join_set_with_triple_nested_result() {
    let set: JoinSet<Result<Result<Int, Text>, JoinError>> = JoinSet.new();
    assert(set.is_empty());
