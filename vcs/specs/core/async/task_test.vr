@test
fn test_cancelled_error_construction() {
    let err: JoinError = Cancelled;
    assert(err is Cancelled);
}

@test
fn test_panicked_error_construction() {
    let err: JoinError = Panicked;
    assert(err is Panicked);
}

// =============================================================================
// Section 7: TaskId Uniqueness
// =============================================================================

@test
fn test_task_id_uniqueness_many() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    let id3: TaskId = TaskId.new();
    let id4: TaskId = TaskId.new();
    let id5: TaskId = TaskId.new();

    // All should be unique
    assert(id1.ne(&id2));
    assert(id1.ne(&id3));
    assert(id1.ne(&id4));
    assert(id1.ne(&id5));
    assert(id2.ne(&id3));
    assert(id2.ne(&id4));
    assert(id2.ne(&id5));
    assert(id3.ne(&id4));
    assert(id3.ne(&id5));
    assert(id4.ne(&id5));
}

@test
fn test_task_id_self_equality() {
    let id: TaskId = TaskId.new();
    // Same ID equals itself
    assert(id.eq(&id));
    assert(!id.ne(&id));
}

// =============================================================================
// Section 8: JoinSet Type Parameters
// =============================================================================

@test
fn test_join_set_unit_type() {
    let set: JoinSet<()> = JoinSet.new();
    assert(set.is_empty());
}

@test
fn test_join_set_tuple_type() {
    let set: JoinSet<(Int, Bool)> = JoinSet.new();
    assert(set.is_empty());
}

// =============================================================================
// Section 9: Edge Cases
// =============================================================================

@test
fn test_multiple_yield_now_futures() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let mut fut1: YieldNow = yield_now();
    let mut fut2: YieldNow = yield_now();

    // Both start as pending
    assert(fut1.poll(&mut cx).is_pending());
    assert(fut2.poll(&mut cx).is_pending());

    // Both become ready after second poll
    assert(fut1.poll(&mut cx).is_ready());
    assert(fut2.poll(&mut cx).is_ready());
}

@test
fn test_join_set_operations_sequence() {
    let mut set: JoinSet<Int> = JoinSet.new();

    // Initial state
    assert(set.is_empty());
    assert_eq(set.len(), 0);

    // Cancel and detach on empty
    set.cancel_all();
    set.detach_all();

    // Still empty
    assert(set.is_empty());
    assert_eq(set.len(), 0);
}

// =============================================================================
// Section 10: TaskId Field Access
// =============================================================================

@test
fn test_task_id_field_access() {
    let id: TaskId = TaskId.new();
    // Internal id field is an Int
    let raw: Int = id.id;
    assert(raw > 0);
}

@test
fn test_task_id_monotonically_increasing() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    assert(id2.id > id1.id);
}

// =============================================================================
// Section 11: JoinError in Result Types
// =============================================================================

@test
fn test_join_error_in_ok_result() {
    let result: Result<Int, JoinError> = Ok(42);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 42);
}

@test
fn test_join_error_in_err_result_cancelled() {
    let result: Result<Int, JoinError> = Err(Cancelled);
    assert(result.is_err());
}

@test
fn test_join_error_in_err_result_panicked() {
    let result: Result<Int, JoinError> = Err(Panicked);
    assert(result.is_err());
}

@test
fn test_join_error_result_match_ok() {
    let result: Result<Int, JoinError> = Ok(100);
    let val = match result {
        Ok(v) => v,
        Err(_) => -1,
    };
    assert_eq(val, 100);
}

@test
fn test_join_error_result_match_cancelled() {
    let result: Result<Text, JoinError> = Err(Cancelled);
    let val = match result {
        Ok(s) => s,
        Err(Cancelled) => "cancelled",
        Err(Panicked) => "panicked",
    };
    assert_eq(val, "cancelled");
}

@test
fn test_join_error_result_match_panicked() {
    let result: Result<Text, JoinError> = Err(Panicked);
    let val = match result {
        Ok(s) => s,
        Err(Cancelled) => "cancelled",
        Err(Panicked) => "panicked",
    };
    assert_eq(val, "panicked");
}

