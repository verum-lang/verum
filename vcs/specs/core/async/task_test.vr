// =============================================================================
// Section 13: YieldNow State Detailed
// =============================================================================

@test
fn test_yield_now_yielded_field_false() {
    let y: YieldNow = yield_now();
    assert_eq(y.yielded, false);
}

@test
fn test_yield_now_yielded_field_after_poll() {
    let mut y: YieldNow = yield_now();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let _ = y.poll(&mut cx);
    assert_eq(y.yielded, true);
}

@test
fn test_yield_now_two_independent() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let mut y1: YieldNow = yield_now();
    let mut y2: YieldNow = yield_now();

    // y1 first poll: pending
    assert(y1.poll(&mut cx).is_pending());
    // y2 first poll: pending
    assert(y2.poll(&mut cx).is_pending());
    // y1 second poll: ready
    assert(y1.poll(&mut cx).is_ready());
    // y2 second poll: ready
    assert(y2.poll(&mut cx).is_ready());
}

// =============================================================================
// Section 14: TaskId Equality Reflexive/Symmetric
// =============================================================================

@test
fn test_task_id_eq_reflexive() {
    let id: TaskId = TaskId.new();
    assert(id.eq(&id));
    assert(!id.ne(&id));
}

@test
fn test_task_id_eq_symmetric() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    // If a != b then b != a
    assert(id1.ne(&id2) == id2.ne(&id1));
}

