// =============================================================================
// task_test.vr - Tests for Task spawning and JoinHandle
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: async, task, spawn, joinhandle, joinset, core
// @description: Comprehensive tests for Task spawning, JoinHandle, JoinSet, and related types
// =============================================================================

mount core.async.task.{
    Task, TaskId, JoinHandle, JoinError, Cancelled, Panicked,
    yield_now, YieldNow,
    JoinSet,
};
mount core.async.future.{Future, ready, ReadyFuture};
mount core.async.poll.{Poll, Ready, Pending};
mount core.async.waker.{Waker, Context, noop_waker};
mount core.sync.atomics.{AtomicInt, Relaxed, Acquire};
mount core.maybe.{Maybe, Some, None};
mount core.result.{Result, Ok, Err};

// =============================================================================
// Section 1: TaskId
// =============================================================================

@test
fn test_task_id_creation() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    // Each TaskId should be unique
    assert(id1.ne(&id2));
}

@test
fn test_task_id_equality() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();

    // Same ID equals itself
    assert(id1.eq(&id1));
    // Different IDs are not equal
    assert(!id1.eq(&id2));
}

@test
fn test_task_id_inequality() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();

    assert(id1.ne(&id2));
    assert(!id1.ne(&id1));
}

@test
fn test_task_id_sequential() {
    // TaskIds should be sequential (monotonically increasing)
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    let id3: TaskId = TaskId.new();

    // All three should be different
    assert(id1.ne(&id2));
    assert(id2.ne(&id3));
    assert(id1.ne(&id3));
}

// =============================================================================
// Section 2: JoinError
// =============================================================================

@test
fn test_join_error_cancelled_variant() {
    let error: JoinError = Cancelled;
    match error {
        Cancelled => {} // Expected
        Panicked => panic("Expected Cancelled"),
    }
}

@test
fn test_join_error_panicked_variant() {
    let error: JoinError = Panicked;
    match error {
        Cancelled => panic("Expected Panicked"),
        Panicked => {} // Expected
    }
}

@test
fn test_join_error_is_pattern() {
    let cancelled: JoinError = Cancelled;
    let panicked: JoinError = Panicked;

    assert(cancelled is Cancelled);
    assert(!(cancelled is Panicked));
    assert(panicked is Panicked);
    assert(!(panicked is Cancelled));
}

@test
fn test_join_error_match_all_variants() {
    let errors: List<JoinError> = [Cancelled, Panicked];

    for error in errors.iter() {
        match *error {
            Cancelled => {} // Valid
            Panicked => {} // Valid
        }
    }
}

// =============================================================================
// Section 3: yield_now()
// =============================================================================

@test
fn test_yield_now_returns_yield_future() {
    let fut: YieldNow = yield_now();
    // YieldNow future created
}

@test
fn test_yield_now_future_poll_first() {
    let mut fut: YieldNow = yield_now();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // First poll returns Pending (yields)
    let first_result: Poll<()> = fut.poll(&mut cx);
    assert(first_result.is_pending());
}

@test
fn test_yield_now_future_poll_second() {
    let mut fut: YieldNow = yield_now();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // First poll - pending
    let _: Poll<()> = fut.poll(&mut cx);

    // Second poll returns Ready (resumed)
    let second_result: Poll<()> = fut.poll(&mut cx);
    assert(second_result.is_ready());
}

@test
fn test_yield_now_multiple_yields() {
    // Create multiple yield futures
    let fut1: YieldNow = yield_now();
    let fut2: YieldNow = yield_now();
    let fut3: YieldNow = yield_now();
    // All created successfully
}

// =============================================================================
// Section 4: JoinSet
// =============================================================================

@test
fn test_join_set_new() {
    let set: JoinSet<Int> = JoinSet.new();
    assert(set.is_empty());
    assert_eq(set.len(), 0);
}

@test
fn test_join_set_len_initial() {
    let set: JoinSet<Int> = JoinSet.new();
    assert_eq(set.len(), 0);
}

@test
fn test_join_set_is_empty_true() {
    let set: JoinSet<Int> = JoinSet.new();
    assert(set.is_empty());
}

@test
fn test_join_set_cancel_all_empty() {
    let mut set: JoinSet<Int> = JoinSet.new();
    set.cancel_all();
    // Cancel all tasks on empty set is no-op
    assert(set.is_empty());
}

@test
fn test_join_set_detach_all_empty() {
    let mut set: JoinSet<Int> = JoinSet.new();
    set.detach_all();
    // Detach all tasks on empty set is no-op
    assert(set.is_empty());
}

@test
fn test_join_set_with_different_types() {
    // Int set
    let set_int: JoinSet<Int> = JoinSet.new();
    assert(set_int.is_empty());

    // Bool set
    let set_bool: JoinSet<Bool> = JoinSet.new();
    assert(set_bool.is_empty());

    // Text set
    let set_text: JoinSet<Text> = JoinSet.new();
    assert(set_text.is_empty());
}

// =============================================================================
// Section 5: YieldNow Lifecycle
// =============================================================================

@test
fn test_yield_now_lifecycle() {
    let mut fut: YieldNow = yield_now();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // Initial state - not yielded yet
    // Poll 1: yields
    assert(fut.poll(&mut cx).is_pending());

    // Poll 2: resumes
    assert(fut.poll(&mut cx).is_ready());
}

