fn test_join_set_with_join_error_output() {
    // JoinSet where tasks return Result<T, JoinError>
    let set: JoinSet<Result<Int, JoinError>> = JoinSet.new();
    assert(set.is_empty());
    assert_eq(set.len(), 0);
}

