}

// =============================================================================
// Section 21: YieldNow Extended Polling
// =============================================================================

@test
fn test_yield_now_poll_after_ready() {
    let mut y: YieldNow = yield_now();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // First poll: Pending
    assert(y.poll(&mut cx).is_pending());
    // Second poll: Ready
    assert(y.poll(&mut cx).is_ready());
    // Third poll: still Ready (idempotent)
    assert(y.poll(&mut cx).is_ready());
}

@test
fn test_yield_now_multiple_contexts() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = noop_waker();
    let mut cx1: Context = Context.from_waker(&waker1);
    let mut cx2: Context = Context.from_waker(&waker2);

    let mut y: YieldNow = yield_now();

    // Poll with first context: Pending
    assert(y.poll(&mut cx1).is_pending());
    // Poll with second context: Ready (state persists across contexts)
    assert(y.poll(&mut cx2).is_ready());
}

// =============================================================================
// Section 23: JoinError Pattern Matching Coverage
// =============================================================================

@test
fn test_join_error_all_variants_list() {
    let errors: List<JoinError> = [Cancelled, Panicked];
    assert_eq(errors.len(), 2);

    // Ensure both variants are distinct
    assert(errors[0] is Cancelled);
    assert(errors[1] is Panicked);
}

@test
fn test_join_error_nested_in_maybe_result() {
    let val: Maybe<Result<Int, JoinError>> = Some(Err(Cancelled));

    match val {
        Some(Ok(_)) => panic("Expected error"),
        Some(Err(Cancelled)) => {} // Expected
        Some(Err(Panicked)) => panic("Wrong error"),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 24: JoinSet Operations Chain
// =============================================================================

@test
fn test_join_set_multiple_cancel_detach_cycle() {
    let mut set: JoinSet<Bool> = JoinSet.new();

    // Cancel all
    set.cancel_all();
    assert(set.is_empty());

    // Detach all
    set.detach_all();
    assert(set.is_empty());

    // Cancel again
    set.cancel_all();
    assert(set.is_empty());

    // Detach again
    set.detach_all();
    assert(set.is_empty());
}

@test
fn test_join_set_with_tuple_triple() {
    let set: JoinSet<(Int, Bool, Text)> = JoinSet.new();
    assert(set.is_empty());
    assert_eq(set.len(), 0);
}

fn main() {
    // Tests run via @test annotations
}
