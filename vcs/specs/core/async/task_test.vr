// =============================================================================
// Section 15: Additional TaskId Properties
// =============================================================================

@test
fn test_task_id_six_unique() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    let id3: TaskId = TaskId.new();
    let id4: TaskId = TaskId.new();
    let id5: TaskId = TaskId.new();
    let id6: TaskId = TaskId.new();

    // All strictly increasing
    assert(id1.id < id2.id);
    assert(id2.id < id3.id);
    assert(id3.id < id4.id);
    assert(id4.id < id5.id);
    assert(id5.id < id6.id);
}

@test
fn test_task_id_ne_transitive() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    let id3: TaskId = TaskId.new();
    // If id1 != id2 and id2 != id3, then id1 != id3
    assert(id1.ne(&id2));
    assert(id2.ne(&id3));
    assert(id1.ne(&id3));
}

@test
fn test_task_id_field_positive_multiple() {
    let id1: TaskId = TaskId.new();
    let id2: TaskId = TaskId.new();
    let id3: TaskId = TaskId.new();
    assert(id1.id > 0);
    assert(id2.id > 0);
    assert(id3.id > 0);
}

