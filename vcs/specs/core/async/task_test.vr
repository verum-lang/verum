// =============================================================================
// Section 17: Additional YieldNow Tests
// =============================================================================

@test
fn test_yield_now_three_independent() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let mut y1: YieldNow = yield_now();
    let mut y2: YieldNow = yield_now();
    let mut y3: YieldNow = yield_now();

    // All start pending
    assert(y1.poll(&mut cx).is_pending());
    assert(y2.poll(&mut cx).is_pending());
    assert(y3.poll(&mut cx).is_pending());

    // All become ready
    assert(y1.poll(&mut cx).is_ready());
    assert(y2.poll(&mut cx).is_ready());
    assert(y3.poll(&mut cx).is_ready());
}

@test
fn test_yield_now_yielded_starts_false_multiple() {
    let y1: YieldNow = yield_now();
    let y2: YieldNow = yield_now();
    let y3: YieldNow = yield_now();
    assert_eq(y1.yielded, false);
    assert_eq(y2.yielded, false);
    assert_eq(y3.yielded, false);
}

