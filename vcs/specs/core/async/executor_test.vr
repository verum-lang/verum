// =============================================================================
// Section 19: AsyncRuntime with Various Configs
// =============================================================================

@test
fn test_runtime_with_io_bound_config() {
    let rt = AsyncRuntime.with_config(RuntimeConfig.io_bound());
    assert_eq(rt.config.max_tasks, 100000);
    assert(rt.config.enable_io);
    assert(rt.config.enable_time);
    assert_eq(rt.config.io_sq_entries, 1024);
    assert(!rt.is_running());
}

@test
fn test_runtime_with_custom_config() {
    let config = RuntimeConfig.default()
        .max_tasks(42)
        .task_stack_size(999)
        .work_stealing(false);
    let rt = AsyncRuntime.with_config(config);
    assert_eq(rt.config.max_tasks, 42);
    assert_eq(rt.config.task_stack_size, 999);
    assert(!rt.config.enable_work_stealing);
}

@test
fn test_runtime_multiple_instances() {
    let rt1 = AsyncRuntime.new();
    let rt2 = AsyncRuntime.new();
    let rt3 = AsyncRuntime.with_config(RuntimeConfig.cpu_bound());
    assert_eq(rt1.task_count(), 0);
    assert_eq(rt2.task_count(), 0);
    assert_eq(rt3.task_count(), 0);
    assert(!rt1.is_running());
    assert(!rt2.is_running());
    assert(!rt3.is_running());
}

// =============================================================================
// Section 20: block_on with ReadyFuture (Various Return Types)
// =============================================================================

@test
fn test_block_on_ready_int() {
    let result: Int = block_on(ready(42));
    assert_eq(result, 42);
}

@test
fn test_block_on_ready_text() {
    let result: Text = block_on(ready("hello"));
    assert_eq(result, "hello");
}

@test
fn test_block_on_ready_bool_true() {
    let result: Bool = block_on(ready(true));
    assert(result);
}

@test
fn test_block_on_ready_bool_false() {
    let result: Bool = block_on(ready(false));
    assert(!result);
}

@test
fn test_block_on_ready_float() {
    let result: Float = block_on(ready(3.14));
    assert(result > 3.0);
    assert(result < 4.0);
}

@test
fn test_block_on_ready_unit() {
    let result: () = block_on(ready(()));
    // Unit value returned successfully
    assert(!false); // AsyncRuntime-only: async executor required
}

@test
fn test_block_on_ready_negative_int() {
    let result: Int = block_on(ready(-100));
    assert_eq(result, -100);
}

@test
fn test_block_on_ready_zero() {
    let result: Int = block_on(ready(0));
    assert_eq(result, 0);
}

@test
fn test_block_on_ready_large_int() {
    let result: Int = block_on(ready(999_999_999));
    assert_eq(result, 999_999_999);
}

// =============================================================================
// Section 21: block_on with ReadyFuture (Composite Types)
// =============================================================================

@test
fn test_block_on_ready_maybe_some() {
    let fut: ReadyFuture<Maybe<Int>> = ready(Some(10));
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let mut f = fut;
    let poll = f.poll(&mut cx);
    assert(poll.is_ready());
}

@test
fn test_block_on_ready_maybe_none() {
    let fut: ReadyFuture<Maybe<Int>> = ready(None);
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let mut f = fut;
    let poll = f.poll(&mut cx);
    assert(poll.is_ready());
}

@test
fn test_block_on_ready_result_ok() {
    let fut: ReadyFuture<Result<Int, Text>> = ready(Ok(42));
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let mut f = fut;
    let poll = f.poll(&mut cx);
    assert(poll.is_ready());
}

@test
fn test_block_on_ready_result_err() {
    let fut: ReadyFuture<Result<Int, Text>> = ready(Err("fail"));
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let mut f = fut;
    let poll = f.poll(&mut cx);
    assert(poll.is_ready());
}

@test
fn test_block_on_ready_empty_text() {
    let result: Text = block_on(ready(""));
    assert_eq(result, "");
}

// =============================================================================
// Section 22: Sleep Construction Edge Cases
// =============================================================================

@test
fn test_sleep_ms_one() {
    let s = sleep_ms(1);
    assert_eq(s.deadline_ns, 1_000_000);
    assert(!s.completed);
}

@test
fn test_sleep_secs_zero() {
    let s = sleep_secs(0);
    assert_eq(s.deadline_ns, 0);
    assert(!s.completed);
}

@test
fn test_sleep_new_large_value() {
    let s = Sleep.new(1_000_000_000_000);
    assert_eq(s.deadline_ns, 1_000_000_000_000);
    assert(!s.completed);
    assert_eq(s.registration_id, 0);
}

@test
fn test_sleep_future_poll_completes() {
    // Sleep.poll currently completes immediately (simplified impl)
    let mut s = sleep_ms(50);
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let poll = s.poll(&mut cx);
    assert(poll.is_ready());
    assert(s.completed);
}

// =============================================================================
// Section 23: Timeout Result Patterns
// =============================================================================

@test
fn test_timeout_result_ok_match_value() {
    let result: Result<Int, ExecutorTimeoutError> = Ok(7);
    let val = match result {
        Ok(v) => v,
        Err(_) => -1,
    };
    assert_eq(val, 7);
}

@test
fn test_timeout_result_err_match_value() {
    let result: Result<Int, ExecutorTimeoutError> = Err(ExecutorTimeoutError);
    let val = match result {
        Ok(v) => v,
        Err(_) => -1,
    };
    assert_eq(val, -1);
}

@test
fn test_timeout_result_text_ok() {
    let result: Result<Text, ExecutorTimeoutError> = Ok("data");
    assert(result.is_ok());
    assert_eq(result.unwrap(), "data");
}

@test
fn test_timeout_result_bool_ok() {
    let result: Result<Bool, ExecutorTimeoutError> = Ok(true);
    assert(result.is_ok());
    assert_eq(result.unwrap(), true);
}

// =============================================================================
// Section 24: AsyncExecutionEnv Extended Patterns
// =============================================================================

@test
fn test_execution_env_root() {
    let env = AsyncExecutionEnv { id: 0, parent_id: None };
    assert_eq(env.id, 0);
    assert(env.parent_id is None);
}

@test
fn test_execution_env_chain() {
    let root = AsyncExecutionEnv { id: 1, parent_id: None };
    let child = AsyncExecutionEnv { id: 2, parent_id: Some(root.id) };
    let grandchild = AsyncExecutionEnv { id: 3, parent_id: Some(child.id) };

    assert_eq(root.id, 1);
    assert_eq(child.id, 2);
    assert_eq(grandchild.id, 3);

    match child.parent_id {
        Some(pid) => assert_eq(pid, 1),
        None => panic("expected parent"),
    }
    match grandchild.parent_id {
        Some(pid) => assert_eq(pid, 2),
        None => panic("expected parent"),
    }
}

@test
fn test_execution_env_large_id() {
    let env = AsyncExecutionEnv { id: 999_999, parent_id: Some(999_998) };
    assert_eq(env.id, 999_999);
    match env.parent_id {
        Some(pid) => assert_eq(pid, 999_998),
        None => panic("expected parent"),
    }
}

fn main() {
    // Tests run via @test annotations
}
