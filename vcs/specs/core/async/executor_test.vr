// Section 11: RuntimeConfig IO SQ Entries
// =============================================================================

@test
fn test_runtime_config_default_io_sq_entries() {
    let config = RuntimeConfig.default();
    assert(config.io_sq_entries > 0);
}

@test
fn test_runtime_config_cpu_bound_minimal_io() {
    let config = RuntimeConfig.cpu_bound();
    assert_eq(config.io_sq_entries, 64);
}

@test
fn test_runtime_config_io_bound_large_sq() {
    let config = RuntimeConfig.io_bound();
    assert_eq(config.io_sq_entries, 1024);
}

// =============================================================================
// Section 12: RuntimeBuilder Disable Defaults
// =============================================================================

@test
fn test_runtime_builder_default_has_io() {
    let builder = RuntimeBuilder.new();
    assert(builder.config.enable_io);
    assert(builder.config.enable_time);
}

@test
fn test_runtime_builder_build_preserves_config() {
    let rt = RuntimeBuilder.new()
        .max_tasks(250)
        .stack_size(2048)
        .build();
    assert_eq(rt.config.max_tasks, 250);
    assert_eq(rt.config.task_stack_size, 2048);
}

// =============================================================================
// Section 13: Sleep Duration Calculations
// =============================================================================

@test
fn test_sleep_ms_calculation() {
    // 500ms = 500_000_000 ns
    let s = sleep_ms(500);
    assert_eq(s.deadline_ns, 500_000_000);
}

@test
fn test_sleep_secs_calculation() {
    // 10s = 10_000_000_000 ns
    let s = sleep_secs(10);
    assert_eq(s.deadline_ns, 10_000_000_000);
}

@test
fn test_sleep_new_is_not_completed() {
    let s = Sleep.new(999);
    assert(!s.completed);
    assert_eq(s.registration_id, 0);
    assert_eq(s.deadline_ns, 999);
}

// =============================================================================
// Section 14: Timeout Type Construction
// =============================================================================

@test
fn test_timeout_error_in_result_match() {
    let result: Result<Text, ExecutorTimeoutError> = Err(ExecutorTimeoutError);
    let msg = match result {
        Ok(v) => v,
        Err(_) => "timed out",
    };
    assert_eq(msg, "timed out");
}

@test
fn test_timeout_ok_result() {
    let result: Result<Int, ExecutorTimeoutError> = Ok(100);
    match result {
        Ok(v) => assert_eq(v, 100),
        Err(_) => panic("expected Ok"),
    }
}

// =============================================================================
// Section 15: AsyncRuntime State After Construction
// =============================================================================

@test
fn test_runtime_initial_not_running() {
    let rt = AsyncRuntime.new();
    assert(!rt.is_running());
}

@test
fn test_runtime_initial_zero_tasks() {
    let rt = AsyncRuntime.new();
    assert_eq(rt.task_count(), 0);
}

@test
fn test_runtime_config_accessible() {
    let rt = AsyncRuntime.new();
    assert_eq(rt.config.max_tasks, 10000);
    assert(rt.config.enable_work_stealing);
    assert(rt.config.enable_io);
    assert(rt.config.enable_time);
}

@test
fn test_runtime_cpu_bound_config() {
    let rt = AsyncRuntime.with_config(RuntimeConfig.cpu_bound());
    assert_eq(rt.config.max_tasks, 1000);
    assert(!rt.config.enable_io);
    assert(!rt.config.enable_time);
}

// =============================================================================
// Section 16: RuntimeConfig Presets Comparison
// =============================================================================

@test
fn test_config_presets_differ() {
    let def = RuntimeConfig.default();
    let cpu = RuntimeConfig.cpu_bound();
    let io = RuntimeConfig.io_bound();

    // Different max_tasks
    assert(def.max_tasks != cpu.max_tasks);
    assert(def.max_tasks != io.max_tasks);
    assert(cpu.max_tasks != io.max_tasks);

    // IO-bound has most tasks
    assert(io.max_tasks > def.max_tasks);
    assert(def.max_tasks > cpu.max_tasks);
}

@test
fn test_config_presets_stack_sizes() {
    let def = RuntimeConfig.default();
    let cpu = RuntimeConfig.cpu_bound();
    let io = RuntimeConfig.io_bound();

    // Default has largest stack
    assert(def.task_stack_size > cpu.task_stack_size);
    assert(cpu.task_stack_size > io.task_stack_size);
}

// =============================================================================
// Section 17: RuntimeConfig Custom Construction
// =============================================================================

@test
fn test_runtime_config_custom_all_fields() {
    let config = RuntimeConfig {
        max_tasks: 5000,
        enable_work_stealing: false,
        task_stack_size: 2048,
        enable_io: false,
        enable_time: true,
        io_sq_entries: 128,
    };
    assert_eq(config.max_tasks, 5000);
    assert(!config.enable_work_stealing);
    assert_eq(config.task_stack_size, 2048);
    assert(!config.enable_io);
    assert(config.enable_time);
    assert_eq(config.io_sq_entries, 128);
}

@test
fn test_runtime_config_minimal_custom() {
    let config = RuntimeConfig {
        max_tasks: 1,
        enable_work_stealing: false,
        task_stack_size: 4096,
        enable_io: false,
        enable_time: false,
        io_sq_entries: 0,
    };
    assert_eq(config.max_tasks, 1);
    assert_eq(config.task_stack_size, 4096);
    assert(!config.enable_work_stealing);
    assert(!config.enable_io);
    assert(!config.enable_time);
}

@test
fn test_runtime_config_large_max_tasks() {
    let config = RuntimeConfig.default()
        .max_tasks(1_000_000);
    assert_eq(config.max_tasks, 1_000_000);
}

