// =============================================================================
// executor_test.vr - Comprehensive tests for async executor types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: async, executor, runtime, config, sleep, timeout, builder
// @description: Tests for RuntimeConfig, AsyncRuntime, RuntimeBuilder,
//               Sleep, ExecutorTimeoutError, Timeout, AsyncExecutionEnv types,
//               builder patterns, and configuration presets
// =============================================================================

mount core.async.executor.{
    RuntimeConfig, AsyncRuntime, RuntimeBuilder,
    Sleep, ExecutorTimeoutError, Timeout,
    AsyncExecutionEnv,
    sleep_ms, sleep_secs,
    block_on,
    timeout,
};
mount core.async.future.Future;
mount core.async.poll.{Poll, Ready, Pending};
mount core.async.select.{ReadyFuture, ready};
mount core.async.waker.{Waker, Context, noop_waker};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};

// =============================================================================
// Section 1: RuntimeConfig Default Preset
// =============================================================================

@test
fn test_runtime_config_default() {
    let config: RuntimeConfig = RuntimeConfig.default();
    assert_eq(config.max_tasks, 10000);
    assert(config.enable_work_stealing);
    assert(config.enable_io);
    assert(config.enable_time);
}

@test
fn test_runtime_config_default_stack_size() {
    let config = RuntimeConfig.default();
    assert_eq(config.task_stack_size, 1024 * 1024);
}

// =============================================================================
// Section 2: RuntimeConfig CPU-Bound Preset
// =============================================================================

@test
fn test_runtime_config_cpu_bound() {
    let config: RuntimeConfig = RuntimeConfig.cpu_bound();
    assert_eq(config.max_tasks, 1000);
    assert(config.enable_work_stealing);
    assert(!config.enable_io);
    assert(!config.enable_time);
}

@test
fn test_runtime_config_cpu_bound_stack_size() {
    let config = RuntimeConfig.cpu_bound();
    assert_eq(config.task_stack_size, 512 * 1024);
}

// =============================================================================
// Section 3: RuntimeConfig IO-Bound Preset
// =============================================================================

@test
fn test_runtime_config_io_bound() {
    let config: RuntimeConfig = RuntimeConfig.io_bound();
    assert_eq(config.max_tasks, 100000);
    assert(config.enable_work_stealing);
    assert(config.enable_io);
    assert(config.enable_time);
}

@test
fn test_runtime_config_io_bound_stack_size() {
    let config = RuntimeConfig.io_bound();
    assert_eq(config.task_stack_size, 256 * 1024);
}

// =============================================================================
// Section 4: RuntimeConfig Builder Methods
// =============================================================================

@test
fn test_runtime_config_max_tasks_builder() {
    let config = RuntimeConfig.default()
        .max_tasks(500);
    assert_eq(config.max_tasks, 500);
}

@test
fn test_runtime_config_task_stack_size_builder() {
    let config = RuntimeConfig.default()
        .task_stack_size(8192);
    assert_eq(config.task_stack_size, 8192);
}

@test
fn test_runtime_config_work_stealing_builder() {
    let config = RuntimeConfig.default()
        .work_stealing(false);
    assert(!config.enable_work_stealing);
}

@test
fn test_runtime_config_chained_builder() {
    let config = RuntimeConfig.default()
        .max_tasks(1000)
        .task_stack_size(8192)
        .work_stealing(true);
    assert_eq(config.max_tasks, 1000);
    assert_eq(config.task_stack_size, 8192);
    assert(config.enable_work_stealing);
}

// =============================================================================
// Section 5: RuntimeBuilder
// =============================================================================

@test
fn test_runtime_builder_new() {
    let builder: RuntimeBuilder = RuntimeBuilder.new();
    // Builder starts with default config
    assert_eq(builder.config.max_tasks, 10000);
    assert(builder.config.enable_work_stealing);
}

@test
fn test_runtime_builder_max_tasks() {
    let builder = RuntimeBuilder.new()
        .max_tasks(500);
    assert_eq(builder.config.max_tasks, 500);
}

@test
fn test_runtime_builder_stack_size() {
    let builder = RuntimeBuilder.new()
        .stack_size(4096);
    assert_eq(builder.config.task_stack_size, 4096);
}

@test
fn test_runtime_builder_chain() {
    let builder = RuntimeBuilder.new()
        .max_tasks(500)
        .stack_size(4096)
        .enable_work_stealing()
        .enable_io()
        .enable_time();
    assert_eq(builder.config.max_tasks, 500);
    assert_eq(builder.config.task_stack_size, 4096);
    assert(builder.config.enable_work_stealing);
    assert(builder.config.enable_io);
    assert(builder.config.enable_time);
}

@test
fn test_runtime_builder_build() {
    let runtime: AsyncRuntime = RuntimeBuilder.new()
        .max_tasks(100)
        .build();
    assert_eq(runtime.task_count(), 0);
    assert(!runtime.is_running());
}

// =============================================================================
// Section 6: ExecutorTimeoutError
// =============================================================================

@test
fn test_timeout_error_type() {
    let _err: ExecutorTimeoutError = ExecutorTimeoutError;
    let result: Result<Int, ExecutorTimeoutError> = Err(ExecutorTimeoutError);
    assert(result.is_err());
}

@test
fn test_timeout_error_in_err_result() {
    let result: Result<Int, ExecutorTimeoutError> = Err(ExecutorTimeoutError);
    assert(result.is_err());
}

@test
fn test_timeout_error_in_ok_result() {
    let result: Result<Int, ExecutorTimeoutError> = Ok(42);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 42);
}

@test
fn test_timeout_error_match() {
    let result: Result<Text, ExecutorTimeoutError> = Err(ExecutorTimeoutError);
    assert(result.is_err());
}

// =============================================================================
// Section 7: Sleep Type
// =============================================================================

@test
fn test_sleep_ms_type() {
    let s: Sleep = sleep_ms(100);
    assert_eq(s.deadline_ns, 100 * 1_000_000);
    assert(!s.completed);
}

@test
fn test_sleep_secs_type() {
    let s: Sleep = sleep_secs(1);
    assert_eq(s.deadline_ns, 1_000_000_000);
    assert(!s.completed);
}

@test
fn test_sleep_new() {
    let s: Sleep = Sleep.new(1000000);
    assert_eq(s.deadline_ns, 1000000);
    assert(!s.completed);
    assert_eq(s.registration_id, 0);
}

@test
fn test_sleep_zero_duration() {
    let s: Sleep = sleep_ms(0);
    assert_eq(s.deadline_ns, 0);
    assert(!s.completed);
}

@test
fn test_sleep_large_duration() {
    let s: Sleep = sleep_secs(3600);
    assert_eq(s.deadline_ns, 3600 * 1_000_000_000);
    assert(!s.completed);
}

// =============================================================================
// Section 8: Ready Future with Executor
// =============================================================================

@test
fn test_ready_future_int() {
    let mut fut: ReadyFuture<Int> = ready(42);
    let waker: Waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let poll = fut.poll(&mut cx);
    assert(poll.is_ready());
}

@test
fn test_ready_future_text() {
    let mut fut: ReadyFuture<Text> = ready("hello");
    let waker: Waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let poll = fut.poll(&mut cx);
    assert(poll.is_ready());
}

@test
fn test_ready_future_bool() {
    let mut fut: ReadyFuture<Bool> = ready(true);
    let waker: Waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let poll = fut.poll(&mut cx);
    assert(poll.is_ready());
}

// =============================================================================
// Section 9: AsyncRuntime Type
// =============================================================================

@test
fn test_runtime_new() {
    let rt: AsyncRuntime = AsyncRuntime.new();
    assert_eq(rt.task_count(), 0);
    assert(!rt.is_running());
}

@test
fn test_runtime_with_config() {
    let config = RuntimeConfig.cpu_bound();
    let rt: AsyncRuntime = AsyncRuntime.with_config(config);
    assert_eq(rt.task_count(), 0);
    assert(!rt.is_running());
    assert_eq(rt.config.max_tasks, 1000);
}

// =============================================================================
// Section 10: AsyncExecutionEnv
// =============================================================================

@test
fn test_execution_env_construction() {
    let env = AsyncExecutionEnv { id: 1, parent_id: None };
    assert_eq(env.id, 1);
    assert(env.parent_id is None);
}

@test
fn test_execution_env_with_parent() {
    let env = AsyncExecutionEnv { id: 2, parent_id: Some(1) };
    assert_eq(env.id, 2);
    match env.parent_id {
        Some(pid) => assert_eq(pid, 1),
        None => panic("expected Some"),
    }
}

