@test
fn test_empty_with_tuple() {
    let stream: StreamEmpty<(Int, Text)> = stream_empty();
    let hint = stream.size_hint();
    assert_eq(hint.0, 0);
}

@test
fn test_repeat_with_text() {
    let stream: StreamRepeat<Text> = stream_repeat("hello");
    let hint = stream.size_hint();
    assert(hint.0 > 0);
    assert(hint.1 is None);
}

@test
fn test_repeat_with_bool() {
    let stream: StreamRepeat<Bool> = stream_repeat(true);
    let hint = stream.size_hint();
    assert(hint.0 > 0);
}

@test
fn test_repeat_n_with_text() {
    let stream: StreamRepeatN<Text> = stream_repeat_n("world", 3);
    let hint = stream.size_hint();
    assert_eq(hint.0, 3);
    match hint.1 {
        Some(upper) => assert_eq(upper, 3),
        None => panic("repeat_n should have exact upper bound"),
    }
}

@test
fn test_repeat_n_with_float() {
    let stream = stream_repeat_n(2.718, 10);
    let hint = stream.size_hint();
    assert_eq(hint.0, 10);
}

