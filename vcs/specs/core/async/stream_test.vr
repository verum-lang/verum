// =============================================================================
// stream_test.vr - Tests for async Stream protocol and combinators
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: async, stream, combinators, iterator
// @description: Comprehensive tests for Stream protocol, StreamExt methods,
//               constructors, and combinator types
// =============================================================================

mount core.async.stream.{
    Stream, IntoStream, StreamExt,
    iter, stream_once, stream_empty, stream_repeat, stream_repeat_n, stream_from_fn,
    once_future, stream_poll_fn, stream_unfold, interval,
    StreamIter, StreamOnce, StreamEmpty, StreamRepeat, StreamRepeatN, StreamFromFn,
    OnceFuture, StreamPollFn, StreamUnfold, StreamInterval,
    StreamMap, StreamFilter, StreamFilterMap, StreamTake, StreamTakeWhile,
    StreamSkip, StreamSkipWhile, StreamChain, StreamZip, StreamEnumerate,
    StreamPeekable, StreamFuse, StreamInspect, StreamScan,
    StreamFlatten, StreamFlatMap,
    StreamCollect, StreamFold, StreamForEach, StreamAny, StreamAll, StreamFind, StreamFindMap,
    StreamCount, StreamLast, StreamFirst, StreamMin, StreamMax,
    StreamNth,
    BufferedStream, ChunkedStream,
};
mount core.async.poll.{Poll, Ready, Pending};
mount core.async.waker.{Context, Waker, noop_waker};
mount core.async.future.Future;
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;

// =============================================================================
// Section 1: Stream Protocol Definition
// =============================================================================

// Verify Stream protocol structure
type TestStream is {
    items: List<Int>,
    index: Int,
};

implement Stream for TestStream {
    type Item = Int;

    fn poll_next(&mut self, cx: &mut Context) -> Poll<Maybe<Int>> {
        if self.index < self.items.len() {
            let val = self.items[self.index];
            self.index = self.index + 1;
            Ready(Some(val))
        } else {
            Ready(None)
        }
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let remaining = self.items.len() - self.index;
        (remaining, Some(remaining))
    }
}

@test
fn test_stream_protocol_impl() {
    let stream = TestStream {
        items: List.from([1, 2, 3]),
        index: 0,
    };
    let hint = stream.size_hint();
    assert_eq(hint.0, 3);
}

// =============================================================================
// Section 2: Stream Constructors
// =============================================================================

@test
fn test_iter_constructor() {
    let stream = iter([1, 2, 3, 4, 5].into_iter());
    // Verify it's a valid stream (compiles)
    let hint = stream.size_hint();
    assert(hint.0 >= 0);
}

@test
fn test_once_constructor() {
    let stream: StreamOnce<Int> = stream_once(42);
    let hint = stream.size_hint();
    assert_eq(hint.0, 1);
    match hint.1 {
        Some(upper) => assert_eq(upper, 1),
        None => panic("once should have exact upper bound"),
    }
}

@test
fn test_empty_constructor() {
    let stream: StreamEmpty<Int> = stream_empty();
    let hint = stream.size_hint();
    assert_eq(hint.0, 0);
    match hint.1 {
        Some(upper) => assert_eq(upper, 0),
        None => panic("empty should have exact upper bound"),
    }
}

@test
fn test_repeat_constructor() {
    let stream: StreamRepeat<Int> = stream_repeat(42);
    let hint = stream.size_hint();
    // Repeat has large lower bound and no upper bound
    assert(hint.0 > 0);
    assert(hint.1 is None);
}

@test
fn test_repeat_n_constructor() {
    let stream: StreamRepeatN<Int> = stream_repeat_n(42, 5);
    let hint = stream.size_hint();
    assert_eq(hint.0, 5);
    match hint.1 {
        Some(upper) => assert_eq(upper, 5),
        None => panic("repeat_n should have exact upper bound"),
    }
}

@test
fn test_repeat_n_zero() {
    let stream: StreamRepeatN<Int> = stream_repeat_n(42, 0);
    let hint = stream.size_hint();
    assert_eq(hint.0, 0);
    match hint.1 {
        Some(upper) => assert_eq(upper, 0),
        None => panic("repeat_n(0) should have exact upper bound"),
    }
}

@test
fn test_repeat_n_one() {
    let stream: StreamRepeatN<Int> = stream_repeat_n(99, 1);
    let hint = stream.size_hint();
    assert_eq(hint.0, 1);
}

@test
fn test_from_fn_constructor() {
    let mut count = 0;
    let stream = stream_from_fn(|| {
        if count < 3 {
            count = count + 1;
            Some(count)
        } else {
            None
        }
    });
    assert(!false); // Runtime-only: async executor required
}

