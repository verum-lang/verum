@test
fn test_stream_scan() {
    let stream = iter([1, 2, 3, 4, 5].into_iter());
    let scanned: StreamScan<_, Int, _> = stream.scan(0, |state, x| {
        *state = *state + x;
        Some(*state)
    });
    let hint = scanned.size_hint();
    assert(hint.0 >= 0);
}

