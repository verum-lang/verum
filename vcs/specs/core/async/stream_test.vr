// =============================================================================
// Section 9: TestStream Polling
// =============================================================================

@test
fn test_stream_poll_next_returns_ready() {
    let mut stream = TestStream {
        items: List.from([10, 20, 30]),
        index: 0,
    };
    let waker: Waker = noop_waker();
    let mut cx = Context.from_waker(&waker);

    // First poll returns Ready(Some(10))
    let result = stream.poll_next(&mut cx);
    assert(result.is_ready());
}

@test
fn test_stream_poll_next_sequential() {
    let mut stream = TestStream {
        items: List.from([1, 2, 3]),
        index: 0,
    };
    let waker: Waker = noop_waker();
    let mut cx = Context.from_waker(&waker);

    // Poll three times
    let r1 = stream.poll_next(&mut cx);
    let r2 = stream.poll_next(&mut cx);
    let r3 = stream.poll_next(&mut cx);

    assert(r1.is_ready());
    assert(r2.is_ready());
    assert(r3.is_ready());
}

@test
fn test_stream_poll_exhausted() {
    let mut stream = TestStream {
        items: List.from([42]),
        index: 0,
    };
    let waker: Waker = noop_waker();
    let mut cx = Context.from_waker(&waker);

    // First poll gets value, second gets None
    let _ = stream.poll_next(&mut cx);
    let last = stream.poll_next(&mut cx);
    assert(last.is_ready());
}

@test
fn test_stream_size_hint_decreases() {
    let mut stream = TestStream {
        items: List.from([1, 2, 3, 4, 5]),
        index: 0,
    };
    assert_eq(stream.size_hint().0, 5);

    let waker: Waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let _ = stream.poll_next(&mut cx);
    assert_eq(stream.size_hint().0, 4);

    let _ = stream.poll_next(&mut cx);
    assert_eq(stream.size_hint().0, 3);
}

@test
fn test_stream_empty_from_start() {
    let stream = TestStream {
        items: List.new(),
        index: 0,
    };
    assert_eq(stream.size_hint().0, 0);
    match stream.size_hint().1 {
        Some(upper) => assert_eq(upper, 0),
        None => panic("Expected exact bound"),
    }
}

