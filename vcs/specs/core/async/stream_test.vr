@test
fn test_stream_map() {
    let stream = iter([1, 2, 3].into_iter());
    let mapped: StreamMap<_, _> = stream.map(|x| x * 2);
    // Map preserves size_hint from inner stream
    let hint = mapped.size_hint();
    assert(hint.0 >= 0);
}

@test
fn test_stream_filter() {
    let stream = iter([1, 2, 3, 4, 5].into_iter());
    let filtered: StreamFilter<_, _> = stream.filter(|x| *x > 2);
    // Filter has lower bound 0 (all could be filtered)
    let hint = filtered.size_hint();
    assert(hint.0 >= 0);
}

@test
fn test_stream_filter_map() {
    let stream = iter([1, 2, 3, 4, 5].into_iter());
    let fm: StreamFilterMap<_, _> = stream.filter_map(|x| {
        if x > 2 { Some(x * 10) } else { None }
    });
    let hint = fm.size_hint();
    assert(hint.0 >= 0);
}

@test
fn test_stream_take() {
    let stream = iter([1, 2, 3, 4, 5].into_iter());
    let taken: StreamTake<_> = stream.take(3);
    let hint = taken.size_hint();
    // Take(3) from a 5-element stream: lower <= 3
    assert(hint.0 <= 3);
    // Upper bound should be at most 3
    match hint.1 {
        Some(upper) => assert(upper <= 3),
        None => {} // acceptable
    }
}

@test
fn test_stream_take_zero() {
    let stream = iter([1, 2, 3].into_iter());
    let taken: StreamTake<_> = stream.take(0);
    let hint = taken.size_hint();
    assert_eq(hint.0, 0);
}

