// =============================================================================
// Section 12: Bounded Channel Extended Tests
// =============================================================================

@test
fn test_bounded_capacity_matches() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(5);
    match tx.capacity() {
        Some(cap) => assert_eq(cap, 5),
        None => panic("Expected capacity for bounded channel"),
    }
}

@test
fn test_unbounded_capacity_is_none() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    assert(tx.capacity().is_none());
}

@test
fn test_bounded_send_then_recv() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(2);
    tx.try_send(42);
    let result = rx.try_recv();
    match result {
        Ok(val) => assert_eq(val, 42),
        Err(_) => panic("Expected value"),
    }
}

@test
fn test_bounded_fill_and_drain() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(3);
    tx.try_send(1);
    tx.try_send(2);
    tx.try_send(3);

    // Channel should be full
    assert_eq(tx.len(), 3);

    // Drain
    let v1 = rx.try_recv();
    let v2 = rx.try_recv();
    let v3 = rx.try_recv();

    assert(v1.is_ok());
    assert(v2.is_ok());
    assert(v3.is_ok());
    assert_eq(v1.unwrap(), 1);
    assert_eq(v2.unwrap(), 2);
    assert_eq(v3.unwrap(), 3);

    // Now empty
    assert(rx.is_empty());
}

