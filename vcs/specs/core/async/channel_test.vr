// Section 28: Edge Cases Extended
// =============================================================================

@test
fn test_channel_send_max_int() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(9223372036854775807);
    match rx.try_recv() {
        Ok(v) => assert_eq(v, 9223372036854775807),
        Err(_) => panic("Expected max Int value"),
    }
}

@test
fn test_channel_send_empty_text() {
    let (tx, mut rx): (Sender<Text>, Receiver<Text>) = channel();
    let _ = tx.send("");
    match rx.try_recv() {
        Ok(v) => assert_eq(v, ""),
        Err(_) => panic("Expected empty text"),
    }
}

@test
fn test_try_recv_after_all_consumed() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(1);
    let _ = tx.send(2);
    let _ = rx.try_recv();
    let _ = rx.try_recv();

    // Channel is now empty
    let result = rx.try_recv();
    match result {
        Ok(_) => panic("Expected Empty"),
        Err(err) => assert(err is Empty),
    }
}

@test
fn test_len_consistency_sender_receiver() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(1);
    let _ = tx.send(2);
    let _ = tx.send(3);

    // Both sender and receiver should report same length
    assert_eq(tx.len(), 3);
    assert_eq(rx.len(), 3);
}

@test
fn test_oneshot_with_float() {
    let (tx, rx): (OneshotSender<Float>, OneshotReceiver<Float>) = oneshot();
    let result = tx.send(2.71828);
    match result {
        Ok(_) => {} // Expected
        Err(_) => panic("Oneshot send should succeed"),
    }
}

@test
fn test_oneshot_with_tuple() {
    let (tx, rx): (OneshotSender<(Int, Text)>, OneshotReceiver<(Int, Text)>) = oneshot();
    let result = tx.send((42, "answer"));
    assert(result.is_ok());
}

@test
fn test_bounded_recv_frees_capacity() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(2);
    let _ = tx.send(1);
    let _ = tx.send(2);

    // Full - try_send should fail
    assert(tx.try_send(3).is_err());

    // Receive one to free space
    let _ = rx.try_recv();

    // Now should be able to send again
    assert(tx.try_send(3).is_ok());
    assert_eq(tx.len(), 2);
}

