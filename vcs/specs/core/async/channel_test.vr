// Section 18: Bounded vs Unbounded Properties
// =============================================================================

@test
fn test_unbounded_no_limit() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    // Unbounded: can send many values without blocking
    for i in 0..100 {
        let _ = tx.send(i);
    }
    assert_eq(tx.len(), 100);
}

@test
fn test_bounded_large_capacity() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(1000);
    match tx.capacity() {
        Some(cap) => assert_eq(cap, 1000),
        None => panic("Expected capacity"),
    }
}

