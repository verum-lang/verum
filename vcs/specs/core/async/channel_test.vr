// =============================================================================
// channel_test.vr - Tests for async MPSC channels
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: async, channel, mpsc, sender, receiver, oneshot, core
// @description: Comprehensive tests for async MPSC channels and oneshot channels
// =============================================================================

mount core.async.channel.{
    channel, bounded,
    Sender, Receiver,
    SendError, TrySendError, Full, Disconnected,
    TryRecvError, Empty, RecvError,
    oneshot, OneshotSender, OneshotReceiver,
};
mount core.async.future.Future;
mount core.async.poll.{Poll, Ready, Pending};
mount core.async.waker.{Waker, Context, noop_waker};
mount core.maybe.{Maybe, Some, None};
mount core.result.{Result, Ok, Err};

// =============================================================================
// Section 1: Unbounded Channel Creation
// =============================================================================

@test
fn test_channel_creation() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    // Channel created with sender and receiver
}

@test
fn test_channel_creation_different_types() {
    // Int channel
    let (tx_int, rx_int): (Sender<Int>, Receiver<Int>) = channel();

    // Bool channel
    let (tx_bool, rx_bool): (Sender<Bool>, Receiver<Bool>) = channel();

    // Text channel
    let (tx_text, rx_text): (Sender<Text>, Receiver<Text>) = channel();
}

@test
fn test_channel_initial_state() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    assert(!tx.is_closed());
    assert(!rx.is_closed());
    assert(tx.is_empty());
    assert(rx.is_empty());
}

// =============================================================================
// Section 2: Bounded Channel Creation
// =============================================================================

@test
fn test_bounded_channel_creation() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(10);
    // Bounded channel with capacity 10
}

@test
fn test_bounded_channel_capacity() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(5);
    match tx.capacity() {
        Some(cap) => assert_eq(cap, 5),
        None => panic("Expected bounded capacity"),
    }
}

@test
fn test_unbounded_channel_no_capacity() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    match tx.capacity() {
        Some(_) => panic("Expected None for unbounded"),
        None => {} // Expected
    }
}

// =============================================================================
// Section 3: Sender Operations
// =============================================================================

@test
fn test_sender_send() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let result: Result<(), SendError<Int>> = tx.send(42);
    match result {
        Ok(_) => {} // Expected
        Err(_) => panic("Send should succeed"),
    }
}

@test
fn test_sender_try_send() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let result: Result<(), TrySendError<Int>> = tx.try_send(42);
    match result {
        Ok(_) => {} // Expected
        Err(_) => panic("try_send should succeed"),
    }
}

@test
fn test_sender_multiple_sends() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(1);
    let _ = tx.send(2);
    let _ = tx.send(3);
    assert_eq(tx.len(), 3);
}

@test
fn test_sender_len() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    assert_eq(tx.len(), 0);
    let _ = tx.send(42);
    assert_eq(tx.len(), 1);
}

@test
fn test_sender_is_empty() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    assert(tx.is_empty());
    let _ = tx.send(42);
    assert(!tx.is_empty());
}

@test
fn test_sender_is_closed_false() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    assert(!tx.is_closed());
}

// =============================================================================
// Section 4: Receiver Operations
// =============================================================================

@test
fn test_receiver_try_recv_empty() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let result: Result<Int, TryRecvError> = rx.try_recv();
    match result {
        Ok(_) => panic("Expected Empty error"),
        Err(err) => {
            match err {
                Empty => {} // Expected
                Disconnected => panic("Expected Empty, not Disconnected"),
            }
        }
    }
}

@test
fn test_receiver_try_recv_success() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(42);
    let result: Result<Int, TryRecvError> = rx.try_recv();
    match result {
        Ok(v) => assert_eq(v, 42),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_receiver_len() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    assert_eq(rx.len(), 0);
    let _ = tx.send(42);
    assert_eq(rx.len(), 1);
}

@test
fn test_receiver_is_empty() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    assert(rx.is_empty());
    let _ = tx.send(42);
    assert(!rx.is_empty());
}

@test
fn test_receiver_close() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    rx.close();
    assert(tx.is_closed());
}

// =============================================================================
// Section 5: Sender Clone
// =============================================================================

@test
fn test_sender_clone() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    let tx2: Sender<Int> = tx.clone();
    // Both senders can send
    let _ = tx.send(1);
    let _ = tx2.send(2);
}

@test
fn test_sender_clone_count() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    let tx2: Sender<Int> = tx.clone();
    let tx3: Sender<Int> = tx.clone();
    // Channel remains open with multiple senders
    assert(!tx.is_closed());
}

// =============================================================================
// Section 6: Error Types
// =============================================================================

@test
fn test_send_error() {
    let err: SendError<Int> = SendError(42);
    // SendError wraps the value that failed to send
}

@test
fn test_try_send_error_full() {
    let err: TrySendError<Int> = Full(42);
    match err {
        Full(v) => assert_eq(v, 42),
        Disconnected(_) => panic("Expected Full"),
    }
}

@test
fn test_try_send_error_disconnected() {
    let err: TrySendError<Int> = Disconnected(42);
    match err {
        Full(_) => panic("Expected Disconnected"),
        Disconnected(v) => assert_eq(v, 42),
    }
}

@test
fn test_try_recv_error_empty() {
    let err: TryRecvError = Empty;
    match err {
        Empty => {} // Expected
        Disconnected => panic("Expected Empty"),
    }
}

@test
fn test_try_recv_error_disconnected() {
    let err: TryRecvError = Disconnected;
    match err {
        Empty => panic("Expected Disconnected"),
        Disconnected => {} // Expected
    }
}

@test
fn test_try_recv_error_is_pattern() {
    let empty_err: TryRecvError = Empty;
    let disc_err: TryRecvError = Disconnected;

    assert(empty_err is Empty);
    assert(!(empty_err is Disconnected));
    assert(disc_err is Disconnected);
    assert(!(disc_err is Empty));
}

// =============================================================================
// Section 7: Oneshot Channel
// =============================================================================

@test
fn test_oneshot_creation() {
    let (tx, rx): (OneshotSender<Int>, OneshotReceiver<Int>) = oneshot();
    // Oneshot channel created
}

@test
fn test_oneshot_send() {
    let (tx, rx): (OneshotSender<Int>, OneshotReceiver<Int>) = oneshot();
    let result: Result<(), Int> = tx.send(42);
    match result {
        Ok(_) => {} // Expected
        Err(_) => panic("Oneshot send should succeed"),
    }
}

// =============================================================================
// Section 8: Channel as Future
// =============================================================================

@test
fn test_receiver_poll_empty() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // Polling empty channel returns Pending
    let result: Poll<Maybe<Int>> = rx.poll(&mut cx);
    assert(result.is_pending());
}

@test
fn test_receiver_poll_with_value() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(42);

    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // Polling channel with value returns Ready(Some(value))
    let result: Poll<Maybe<Int>> = rx.poll(&mut cx);
    assert(result.is_ready());
    match result.unwrap() {
        Some(v) => assert_eq(v, 42),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 9: FIFO Order
// =============================================================================

@test
fn test_channel_fifo_order() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(1);
    let _ = tx.send(2);
    let _ = tx.send(3);

    // Receive in FIFO order
    match rx.try_recv() {
        Ok(v) => assert_eq(v, 1),
        Err(_) => panic("Expected value"),
    }
    match rx.try_recv() {
        Ok(v) => assert_eq(v, 2),
        Err(_) => panic("Expected value"),
    }
    match rx.try_recv() {
        Ok(v) => assert_eq(v, 3),
        Err(_) => panic("Expected value"),
    }
}

// =============================================================================
// Section 10: Edge Cases
// =============================================================================

@test
fn test_channel_with_unit() {
    let (tx, mut rx): (Sender<()>, Receiver<()>) = channel();
    let _ = tx.send(());
    match rx.try_recv() {
        Ok(_) => {} // Expected
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_channel_with_negative_int() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(-42);
    match rx.try_recv() {
        Ok(v) => assert_eq(v, -42),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_channel_with_zero() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(0);
    match rx.try_recv() {
        Ok(v) => assert_eq(v, 0),
        Err(_) => panic("Expected Ok"),
    }
}

@test
fn test_bounded_channel_minimum_capacity() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(1);
    match tx.capacity() {
        Some(cap) => assert_eq(cap, 1),
        None => panic("Expected capacity"),
    }
}

// =============================================================================
// Section 11: Bounded Channel Backpressure
// =============================================================================

@test
fn test_bounded_try_send_when_full() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(2);
    // Fill to capacity
    let _ = tx.send(1);
    let _ = tx.send(2);
    assert_eq(tx.len(), 2);

    // try_send should fail with Full
    let result: Result<(), TrySendError<Int>> = tx.try_send(3);
    match result {
        Ok(_) => panic("Expected Full error"),
        Err(err) => {
            match err {
                Full(v) => assert_eq(v, 3),
                Disconnected(_) => panic("Expected Full, not Disconnected"),
            }
        }
    }
}

@test
fn test_bounded_try_send_after_recv() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(1);
    let _ = tx.send(10);
    assert_eq(tx.len(), 1);

    // Receive to free space
    let v = rx.try_recv();
    match v {
        Ok(val) => assert_eq(val, 10),
        Err(_) => panic("Expected value"),
    }

    // Now send should work again
    let result = tx.try_send(20);
    assert(result.is_ok());
}

@test
fn test_bounded_capacity_one() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(1);
    match tx.capacity() {
        Some(cap) => assert_eq(cap, 1),
        None => panic("Expected capacity"),
    }
    let _ = tx.send(99);
    assert_eq(tx.len(), 1);
}

// =============================================================================
// Section 12: Receiver Operations Extended
// =============================================================================

@test
fn test_receiver_try_recv_multiple() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(10);
    let _ = tx.send(20);
    let _ = tx.send(30);

    assert_eq(rx.try_recv().unwrap(), 10);
    assert_eq(rx.try_recv().unwrap(), 20);
    assert_eq(rx.try_recv().unwrap(), 30);

    // Now channel is empty
    match rx.try_recv() {
        Ok(_) => panic("Expected Empty"),
        Err(err) => assert(err is Empty),
    }
}

@test
fn test_receiver_len_decreases_on_recv() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(1);
    let _ = tx.send(2);
    assert_eq(rx.len(), 2);

    let _ = rx.try_recv();
    assert_eq(rx.len(), 1);

    let _ = rx.try_recv();
    assert_eq(rx.len(), 0);
}

@test
fn test_receiver_is_empty_after_drain() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let _ = tx.send(1);
    let _ = tx.send(2);
    assert(!rx.is_empty());

    let _ = rx.try_recv();
    let _ = rx.try_recv();
    assert(rx.is_empty());
}

// =============================================================================
// Section 13: Channel Closure Semantics
// =============================================================================

@test
fn test_sender_detects_receiver_close() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    assert(!tx.is_closed());
    rx.close();
    assert(tx.is_closed());
}

@test
fn test_send_after_close_fails() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    rx.close();

    let result = tx.send(42);
    match result {
        Ok(_) => panic("Expected SendError"),
        Err(_) => {} // Expected
    }
}

@test
fn test_try_send_after_close_returns_disconnected() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    rx.close();

    let result = tx.try_send(42);
    match result {
        Ok(_) => panic("Expected Disconnected"),
        Err(err) => {
            match err {
                Full(_) => panic("Expected Disconnected, not Full"),
                Disconnected(v) => assert_eq(v, 42),
            }
        }
    }
}

// =============================================================================
// Section 14: RecvError Type
// =============================================================================

@test
fn test_recv_error_type_exists() {
    // RecvError is a unit type - verify it can be used as a type annotation
    let _: Maybe<RecvError> = None;
}

// =============================================================================
// Section 15: Oneshot Extended
// =============================================================================

@test
fn test_oneshot_different_types() {
    // Text oneshot
    let (tx_text, rx_text): (OneshotSender<Text>, OneshotReceiver<Text>) = oneshot();

    // Bool oneshot
    let (tx_bool, rx_bool): (OneshotSender<Bool>, OneshotReceiver<Bool>) = oneshot();

    // Unit oneshot
    let (tx_unit, rx_unit): (OneshotSender<()>, OneshotReceiver<()>) = oneshot();
}

@test
fn test_oneshot_receiver_as_future() {
    let (tx, mut rx): (OneshotSender<Int>, OneshotReceiver<Int>) = oneshot();
    let _ = tx.send(42);

    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // Polling oneshot receiver after send should return Ready
    let result: Poll<Result<Int, RecvError>> = rx.poll(&mut cx);
    assert(result.is_ready());
}

// =============================================================================
// Section 16: Channel with Complex Types
// =============================================================================

@test
fn test_channel_with_tuple() {
    let (tx, mut rx): (Sender<(Int, Bool)>, Receiver<(Int, Bool)>) = channel();
    let _ = tx.send((42, true));
    match rx.try_recv() {
        Ok(v) => {
            assert_eq(v.0, 42);
            assert(v.1);
        }
        Err(_) => panic("Expected value"),
    }
}

@test
fn test_channel_with_result() {
    let (tx, mut rx): (Sender<Result<Int, Text>>, Receiver<Result<Int, Text>>) = channel();
    let _ = tx.send(Ok(100));
    let _ = tx.send(Err("fail"));

    match rx.try_recv() {
        Ok(v) => assert(v.is_ok()),
        Err(_) => panic("Expected value"),
    }
    match rx.try_recv() {
        Ok(v) => assert(v.is_err()),
        Err(_) => panic("Expected value"),
    }
}

@test
fn test_channel_with_maybe() {
    let (tx, mut rx): (Sender<Maybe<Int>>, Receiver<Maybe<Int>>) = channel();
    let _ = tx.send(Some(42));
    let _ = tx.send(None);

    match rx.try_recv() {
        Ok(v) => {
            match v {
                Some(n) => assert_eq(n, 42),
                None => panic("Expected Some"),
            }
        }
        Err(_) => panic("Expected value"),
    }
    match rx.try_recv() {
        Ok(v) => assert(v is None),
        Err(_) => panic("Expected value"),
    }
}

// =============================================================================
// Section 17: Multiple Sender Clones
// =============================================================================

@test
fn test_multiple_senders_send() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let tx2 = tx.clone();
    let tx3 = tx.clone();

    let _ = tx.send(1);
    let _ = tx2.send(2);
    let _ = tx3.send(3);

    assert_eq(rx.len(), 3);
}

@test
fn test_sender_clone_independent() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    let tx2 = tx.clone();

    // Both senders should report same state
    assert(!tx.is_closed());
    assert(!tx2.is_closed());
    assert(tx.is_empty());
    assert(tx2.is_empty());
}

