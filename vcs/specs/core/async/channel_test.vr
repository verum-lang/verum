// =============================================================================
// Section 20: Unbounded Channel Bulk Operations
// =============================================================================

@test
fn test_unbounded_send_twenty() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    for i in 0..20 {
        let _ = tx.send(i);
    }
    assert_eq(tx.len(), 20);
}

@test
fn test_unbounded_send_fifty() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    for i in 0..50 {
        let _ = tx.send(i);
    }
    assert_eq(tx.len(), 50);
}

@test
fn test_unbounded_send_and_recv_all() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    for i in 0..10 {
        let _ = tx.send(i);
    }
    assert_eq(rx.len(), 10);

    // Receive all 10 and verify order
    for i in 0..10 {
        match rx.try_recv() {
            Ok(v) => assert_eq(v, i),
            Err(_) => panic("Expected value"),
        }
    }
    assert(rx.is_empty());
}

// =============================================================================
// Section 21: Send/Recv with Various Types
// =============================================================================

@test
fn test_send_recv_text() {
    let (tx, mut rx): (Sender<Text>, Receiver<Text>) = channel();
    let _ = tx.send("hello");
    let _ = tx.send("world");

    match rx.try_recv() {
        Ok(v) => assert_eq(v, "hello"),
        Err(_) => panic("Expected text value"),
    }
    match rx.try_recv() {
        Ok(v) => assert_eq(v, "world"),
        Err(_) => panic("Expected text value"),
    }
}

@test
fn test_send_recv_bool() {
    let (tx, mut rx): (Sender<Bool>, Receiver<Bool>) = channel();
    let _ = tx.send(true);
    let _ = tx.send(false);

    match rx.try_recv() {
        Ok(v) => assert(v),
        Err(_) => panic("Expected bool value"),
    }
    match rx.try_recv() {
        Ok(v) => assert(!v),
        Err(_) => panic("Expected bool value"),
    }
}

@test
fn test_send_recv_float() {
    let (tx, mut rx): (Sender<Float>, Receiver<Float>) = channel();
    let _ = tx.send(3.14);
    let _ = tx.send(2.718);

    match rx.try_recv() {
        Ok(v) => assert_eq(v, 3.14),
        Err(_) => panic("Expected float value"),
    }
    match rx.try_recv() {
        Ok(v) => assert_eq(v, 2.718),
        Err(_) => panic("Expected float value"),
    }
}

@test
fn test_send_recv_maybe_values() {
    let (tx, mut rx): (Sender<Maybe<Text>>, Receiver<Maybe<Text>>) = channel();
    let _ = tx.send(Some("present"));
    let _ = tx.send(None);
    let _ = tx.send(Some("also present"));

    match rx.try_recv() {
        Ok(v) => assert(v.is_some()),
        Err(_) => panic("Expected value"),
    }
    match rx.try_recv() {
        Ok(v) => assert(v.is_none()),
        Err(_) => panic("Expected value"),
    }
    match rx.try_recv() {
        Ok(v) => {
            match v {
                Some(s) => assert_eq(s, "also present"),
                None => panic("Expected Some"),
            }
        }
        Err(_) => panic("Expected value"),
    }
}

// =============================================================================
// Section 22: try_send / try_recv Deeper Patterns
// =============================================================================

@test
fn test_try_send_success_unbounded() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    let result: Result<(), TrySendError<Int>> = tx.try_send(99);
    assert(result.is_ok());
    assert_eq(tx.len(), 1);
}

@test
fn test_try_recv_empty_then_send_then_recv() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();

    // First try_recv on empty should fail with Empty
    let empty_result: Result<Int, TryRecvError> = rx.try_recv();
    assert(empty_result.is_err());
    match empty_result {
        Ok(_) => panic("Expected Empty"),
        Err(e) => assert(e is Empty),
    }

    // Now send and try again
    let _ = tx.send(77);
    let recv_result = rx.try_recv();
    assert(recv_result.is_ok());
    assert_eq(recv_result.unwrap(), 77);
}

@test
fn test_try_send_bounded_full_returns_value() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(1);
    let _ = tx.send(100);

    // Channel is full, try_send should fail
    let result: Result<(), TrySendError<Int>> = tx.try_send(200);
    match result {
        Ok(_) => panic("Expected Full"),
        Err(err) => {
            match err {
                Full(v) => assert_eq(v, 200),
                Disconnected(_) => panic("Expected Full"),
            }
        }
    }
}

@test
fn test_try_send_multiple_bounded() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(3);
    assert(tx.try_send(1).is_ok());
    assert(tx.try_send(2).is_ok());
    assert(tx.try_send(3).is_ok());

    // Fourth send should fail
    let result = tx.try_send(4);
    match result {
        Ok(_) => panic("Expected Full"),
        Err(err) => {
            match err {
                Full(v) => assert_eq(v, 4),
                Disconnected(_) => panic("Expected Full"),
            }
        }
    }
}

// =============================================================================
// Section 23: Channel Closing and Disconnection
// =============================================================================

@test
fn test_close_then_try_send_disconnected() {
    let (tx, mut rx): (Sender<Text>, Receiver<Text>) = channel();
    rx.close();

    let result: Result<(), TrySendError<Text>> = tx.try_send("closed");
    match result {
        Ok(_) => panic("Expected Disconnected"),
        Err(err) => {
            match err {
                Full(_) => panic("Expected Disconnected, not Full"),
                Disconnected(v) => assert_eq(v, "closed"),
            }
        }
    }
}

@test
fn test_close_then_send_error() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    rx.close();

    let result: Result<(), SendError<Int>> = tx.send(55);
    assert(result.is_err());
}

@test
fn test_close_receiver_is_closed_on_sender() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    assert(!tx.is_closed());
    rx.close();
    assert(tx.is_closed());
}

@test
fn test_close_bounded_channel() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(5);
    let _ = tx.send(1);
    let _ = tx.send(2);
    rx.close();

    assert(tx.is_closed());
    let result = tx.send(3);
    assert(result.is_err());
}

// =============================================================================
// Section 24: Error Type Construction and Inspection
// =============================================================================

@test
fn test_send_error_with_text() {
    // Verify SendError type can be parameterized with Text
    let _: Maybe<SendError<Text>> = None;
    let _: Result<(), SendError<Text>> = Ok(());
}

@test
fn test_send_error_with_bool() {
    // Verify SendError type can be parameterized with Bool
    let _: Maybe<SendError<Bool>> = None;
    let _: Result<(), SendError<Bool>> = Ok(());
}

@test
fn test_try_send_error_full_with_text() {
    let err: TrySendError<Text> = Full("overflow");
    match err {
        Full(v) => assert_eq(v, "overflow"),
        Disconnected(_) => panic("Expected Full"),
    }
}

@test
fn test_try_send_error_disconnected_with_text() {
    let err: TrySendError<Text> = Disconnected("lost");
    match err {
        Full(_) => panic("Expected Disconnected"),
        Disconnected(v) => assert_eq(v, "lost"),
    }
}

@test
fn test_try_send_error_is_pattern() {
    let full_err: TrySendError<Int> = Full(10);
    let disc_err: TrySendError<Int> = Disconnected(20);

    assert(full_err is Full);
    assert(!(full_err is Disconnected));
    assert(disc_err is Disconnected);
    assert(!(disc_err is Full));
}

@test
fn test_recv_error_as_type() {
    // RecvError is a unit type - verify it can be used in type positions
    let _: Maybe<RecvError> = None;
    let _: Result<Int, RecvError> = Ok(42);
}

// =============================================================================
// Section 25: Multiple Messages Order Verification
// =============================================================================

@test
fn test_fifo_order_ten_messages() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    for i in 0..10 {
        let _ = tx.send(i);
    }

    for i in 0..10 {
        let result = rx.try_recv();
        assert(result.is_ok());
        assert_eq(result.unwrap(), i);
    }
}

@test
fn test_fifo_order_twenty_messages() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();
    for i in 0..20 {
        let _ = tx.send(i * 10);
    }

    for i in 0..20 {
        let result = rx.try_recv();
        assert(result.is_ok());
        assert_eq(result.unwrap(), i * 10);
    }
    // Verify channel is empty after draining
    assert(rx.is_empty());
}

@test
fn test_bounded_fifo_order() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(5);
    // Send up to capacity
    for i in 0..5 {
        let _ = tx.send(i + 100);
    }

    // Receive in order
    for i in 0..5 {
        match rx.try_recv() {
            Ok(v) => assert_eq(v, i + 100),
            Err(_) => panic("Expected value in bounded FIFO"),
        }
    }
}

@test
fn test_interleaved_send_recv() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = channel();

    let _ = tx.send(1);
    assert_eq(rx.try_recv().unwrap(), 1);

    let _ = tx.send(2);
    assert_eq(rx.try_recv().unwrap(), 2);

    let _ = tx.send(3);
    let _ = tx.send(4);
    assert_eq(rx.try_recv().unwrap(), 3);
    assert_eq(rx.try_recv().unwrap(), 4);

    assert(rx.is_empty());
}

// =============================================================================
// Section 26: Channel with Various Container Types
// =============================================================================

@test
fn test_channel_with_tuple_int_text() {
    let (tx, mut rx): (Sender<(Int, Text)>, Receiver<(Int, Text)>) = channel();
    let _ = tx.send((1, "one"));
    let _ = tx.send((2, "two"));

    match rx.try_recv() {
        Ok(v) => {
            assert_eq(v.0, 1);
            assert_eq(v.1, "one");
        }
        Err(_) => panic("Expected tuple value"),
    }
    match rx.try_recv() {
        Ok(v) => {
            assert_eq(v.0, 2);
            assert_eq(v.1, "two");
        }
        Err(_) => panic("Expected tuple value"),
    }
}

@test
fn test_channel_with_triple_tuple() {
    let (tx, mut rx): (Sender<(Int, Bool, Float)>, Receiver<(Int, Bool, Float)>) = channel();
    let _ = tx.send((42, true, 3.14));

    match rx.try_recv() {
        Ok(v) => {
            assert_eq(v.0, 42);
            assert(v.1);
            assert_eq(v.2, 3.14);
        }
        Err(_) => panic("Expected triple tuple"),
    }
}

@test
fn test_channel_with_nested_result() {
    let (tx, mut rx): (Sender<Result<Text, Int>>, Receiver<Result<Text, Int>>) = channel();
    let _ = tx.send(Ok("success"));
    let _ = tx.send(Err(404));

    let v1 = rx.try_recv().unwrap();
    assert(v1.is_ok());

    let v2 = rx.try_recv().unwrap();
    assert(v2.is_err());
}

// =============================================================================
// Section 27: Bounded Channel Fill/Drain Cycles
// =============================================================================

@test
fn test_bounded_fill_drain_cycle() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(2);

    // First cycle: fill and drain
    let _ = tx.send(1);
    let _ = tx.send(2);
    assert_eq(tx.len(), 2);

    assert_eq(rx.try_recv().unwrap(), 1);
    assert_eq(rx.try_recv().unwrap(), 2);
    assert(rx.is_empty());

    // Second cycle: fill and drain again
    let _ = tx.send(3);
    let _ = tx.send(4);
    assert_eq(tx.len(), 2);

    assert_eq(rx.try_recv().unwrap(), 3);
    assert_eq(rx.try_recv().unwrap(), 4);
    assert(rx.is_empty());
}

@test
fn test_bounded_partial_drain_refill() {
    let (tx, mut rx): (Sender<Int>, Receiver<Int>) = bounded(3);
    let _ = tx.send(10);
    let _ = tx.send(20);
    let _ = tx.send(30);

    // Drain one, refill one
    assert_eq(rx.try_recv().unwrap(), 10);
    assert(tx.try_send(40).is_ok());

    // Verify remaining order
    assert_eq(rx.try_recv().unwrap(), 20);
    assert_eq(rx.try_recv().unwrap(), 30);
    assert_eq(rx.try_recv().unwrap(), 40);
    assert(rx.is_empty());
}

