// =============================================================================
// Section 3: JoinSet advanced operations
// =============================================================================

@test
fn test_join_set_new() {
    let js: JoinSet<Int> = JoinSet.new();
    assert(js.is_empty());
    assert_eq(js.len(), 0);
}

@test
fn test_join_set_cancel_all_empty() {
    let mut js: JoinSet<Int> = JoinSet.new();
    js.cancel_all();
    assert(js.is_empty());
}

@test
fn test_join_set_detach_all_empty() {
    let mut js: JoinSet<Int> = JoinSet.new();
    js.detach_all();
    assert(js.is_empty());
}

@test
fn test_join_set_with_text() {
    let js: JoinSet<Text> = JoinSet.new();
    assert(js.is_empty());
}

@test
fn test_join_set_with_result() {
    let js: JoinSet<Result<Int, Text>> = JoinSet.new();
    assert_eq(js.len(), 0);
}

// =============================================================================
// Section 4: TaskId operations
// =============================================================================

@test
fn test_task_id_uniqueness() {
    let id1 = TaskId.new();
    let id2 = TaskId.new();
    // Each new() should produce a unique ID
    assert(id1.id != id2.id);
}

@test
fn test_task_id_value() {
    let id = TaskId.new();
    assert(id.id >= 0);
}

@test
fn test_task_id_multiple() {
    let mut ids: List<Int> = List.new();
    for i in range(0, 10) {
        let id = TaskId.new();
        ids.push(id.id);
    }
    assert_eq(ids.len(), 10);
    // All should be different
    for i in range(0, 9) {
        for j in range(i + 1, 10) {
            assert(*ids.get(i).unwrap() != *ids.get(j).unwrap());
        }
    }
}

