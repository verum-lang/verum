@test
fn test_nursery_error_cancelled() {
    let err = NurseryError.Cancelled;
    assert(err is NurseryError.Cancelled);
}

@test
fn test_nursery_error_timeout() {
    let err = NurseryError.Timeout { pending_count: 3, completed_count: 5 };
    assert(err is NurseryError.Timeout);
}

@test
fn test_nursery_error_task_limit() {
    let err = NurseryError.TaskLimitExceeded { limit: 10, attempted: 11 };
    assert(err is NurseryError.TaskLimitExceeded);
}

@test
fn test_nursery_error_panic() {
    let err = NurseryError.Panic("task panicked");
    assert(err is NurseryError.Panic);
}

@test
fn test_nursery_error_result() {
    let result: Result<Int, NurseryError> = Err(NurseryError.Cancelled);
    assert(result.is_err());
}

// =============================================================================
// Section 9: Either<A, B> advanced patterns
// =============================================================================

@test
fn test_either_left_float() {
    let e: Either<Float, Int> = Left(3.14);
    assert(e is Left);
}

@test
fn test_either_right_list() {
    let mut l: List<Int> = List.new();
    l.push(1);
    l.push(2);
    let e: Either<Text, List<Int>> = Right(l);
    assert(e is Right);
}

@test
fn test_either_nested() {
    let inner: Either<Int, Text> = Left(42);
    let outer: Either<Either<Int, Text>, Bool> = Left(inner);
    assert(outer is Left);
}

// =============================================================================
// Section 10: SelectAllResult
// =============================================================================

@test
fn test_select_all_result_construction() {
    let mut remaining: List<Int> = List.new();
    remaining.push(2);
    remaining.push(3);
    let sar = SelectAllResult {
        index: 0,
        value: 42,
        remaining: remaining,
    };
    assert_eq(sar.index, 0);
    assert_eq(sar.value, 42);
    assert_eq(sar.remaining.len(), 2);
}

@test
fn test_select_all_result_first() {
    let sar = SelectAllResult {
        index: 0,
        value: "first",
        remaining: List.new(),
    };
    assert_eq(sar.index, 0);
}

@test
fn test_select_all_result_middle() {
    let sar = SelectAllResult {
        index: 5,
        value: 100,
        remaining: List.new(),
    };
    assert_eq(sar.index, 5);
}

