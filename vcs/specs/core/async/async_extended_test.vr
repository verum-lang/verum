@test
fn test_join_error_result_type() {
    let result: Result<Int, JoinError> = Err(JoinError.Cancelled);
    assert(result.is_err());
}

@test
fn test_join_error_result_ok() {
    let result: Result<Int, JoinError> = Ok(42);
    assert(result.is_ok());
}

