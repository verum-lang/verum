// =============================================================================
// Section 13: Channel operations (additional patterns)
// =============================================================================

@test
fn test_bounded_channel_creation() {
    let (tx, rx) = bounded(10);
    let _: Sender<Int> = tx;
    let _: Receiver<Int> = rx;
}

@test
fn test_unbounded_channel_creation() {
    let (tx, rx) = channel();
    let _: Sender<Text> = tx;
    let _: Receiver<Text> = rx;
}

@test
fn test_oneshot_creation() {
    let (tx, rx) = oneshot();
    let _: OneshotSender<Int> = tx;
    let _: OneshotReceiver<Int> = rx;
}

@test
fn test_channel_error_types() {
    let send_err: SendError<Int> = SendError(42);
    assert(send_err is SendError);

    let try_send_err: TrySendError<Int> = TrySendError.Full(10);
    assert(try_send_err is TrySendError.Full);

    let try_send_disconn: TrySendError<Int> = TrySendError.Disconnected(20);
    assert(try_send_disconn is TrySendError.Disconnected);

    let try_recv_err: TryRecvError = TryRecvError.Empty;
    assert(try_recv_err is TryRecvError.Empty);

    let try_recv_disconn: TryRecvError = TryRecvError.Disconnected;
    assert(try_recv_disconn is TryRecvError.Disconnected);

    let recv_err: RecvError = RecvError;
    let _: RecvError = recv_err;
}

@test
fn test_sender_methods_type() {
    let opt: Maybe<Sender<Int>> = None;
    assert(opt.is_none());
}

@test
fn test_receiver_methods_type() {
    let opt: Maybe<Receiver<Int>> = None;
    assert(opt.is_none());
}

// =============================================================================
// Section 14: Duration integration with async
// =============================================================================

@test
fn test_duration_from_secs() {
    let d = Duration.from_secs(5);
    assert_eq(d.as_secs(), 5);
}

@test
fn test_duration_from_millis() {
    let d = Duration.from_millis(1500);
    assert_eq(d.as_millis(), 1500);
}

@test
fn test_duration_zero() {
    let d = Duration.zero();
    assert_eq(d.as_secs(), 0);
    assert_eq(d.as_millis(), 0);
}

// =============================================================================
// Section 15: Poll operations
// =============================================================================

@test
fn test_poll_ready_map() {
    let p: Poll<Int> = Ready(42);
    let mapped = p.map(|x| x * 2);
    assert(mapped.is_ready());
}

@test
fn test_poll_pending_map() {
    let p: Poll<Int> = Pending;
    let mapped = p.map(|x| x * 2);
    assert(mapped.is_pending());
}

@test
fn test_poll_unwrap_or() {
    let p: Poll<Int> = Pending;
    let val = p.unwrap_or(0);
    assert_eq(val, 0);
}

@test
fn test_poll_ready_unwrap() {
    let p: Poll<Int> = Ready(42);
    let val = p.unwrap();
    assert_eq(val, 42);
}

