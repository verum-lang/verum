// =============================================================================
// async_extended_test.vr - Extended async tests for untested APIs
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: async, select, nursery, task, spawn, future, join, timeout, yield
// @description: Tests for untested async APIs: select functions (select_either,
//               race, select_all, join, join3, join4, join_all, timeout,
//               try_first, yield_now), task functions (spawn_blocking, yield_now),
//               nursery helpers (with_nursery, with_nursery_timeout),
//               JoinSet advanced operations, and Future combinator types.
//
// Coverage:
// - select: select_either, race, select_all, join4, join_all, timeout, try_first
// - task: spawn_blocking, yield_now, JoinSet methods
// - nursery: with_nursery, with_nursery_timeout function types
// - future: IntoFuture protocol, FutureExt extension
// =============================================================================

module specs.core.async.async_extended_test;

mount core.async.select.{
    Either, Left, Right,
    SelectAllResult,
    TimeoutError,
    ReadyFuture, NeverFuture,
    select_either, race, select_all,
    join, join3, join4, join_all,
    timeout, try_first,
    yield_now, pending_forever, ready,
};
mount core.async.future.{Future, ReadyFuture as FutReady, PendingFuture, Lazy};
mount core.async.poll.{Poll, Ready, Pending};
mount core.async.waker.{Context, Waker, noop_waker, noop_context};
mount core.async.task.{
    TaskId, Task, JoinHandle, JoinError, JoinSet,
    spawn_blocking, spawn_detached, yield_now as task_yield_now,
};
mount core.async.nursery.{
    Nursery, NurseryOptions, NurseryError, NurseryErrorBehavior,
    TaskHandle, with_nursery, with_nursery_timeout,
};
mount core.async.channel.{
    Sender, Receiver, channel, bounded, oneshot,
    OneshotSender, OneshotReceiver,
    SendError, TrySendError, TryRecvError, RecvError,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;
mount core.time.duration.Duration;

// =============================================================================
