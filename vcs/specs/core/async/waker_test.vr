fn test_context_from_waker_type_annotation() {
    let w: Waker = noop_waker();
    let cx: Context = Context.from_waker(&w);
    let _: Context = cx;
}

@test
fn test_waker_clone_wake_interleaved() {
    let w1: Waker = noop_waker();
    w1.wake_by_ref();
    let w2 = w1.clone();
    w2.wake_by_ref();
    let w3 = w2.clone();
    w3.wake_by_ref();
    assert(w1.will_wake(&w3));
}

@test
fn test_context_consistent_after_waker_wake() {
    let w: Waker = noop_waker();
    let cx: Context = Context.from_waker(&w);
    w.wake_by_ref();
    // Context's waker should still match
    assert(cx.waker().will_wake(&w));
}

@test
fn test_noop_context_waker_type() {
    let cx: Context = noop_context();
    let waker_ref: &Waker = cx.waker();
    let _: &Waker = waker_ref;
}

@test
fn test_waker_will_wake_after_many_clones() {
    let original: Waker = noop_waker();
    let mut current = original.clone();
    let mut i = 0;
    while i < 20 {
        current = current.clone();
        i = i + 1;
    }
    assert(current.will_wake(&original));
}

@test
fn test_context_from_different_noop_wakers() {
    let w1: Waker = noop_waker();
    let w2: Waker = noop_waker();
    let cx1: Context = Context.from_waker(&w1);
    let cx2: Context = Context.from_waker(&w2);
    // Both noop, so they should be compatible
    assert(cx1.waker().will_wake(cx2.waker()));
}

@test
fn test_noop_waker_stable_identity() {
    let w: Waker = noop_waker();
    // Multiple will_wake calls should be stable
    assert(w.will_wake(&w));
    assert(w.will_wake(&w));
    assert(w.will_wake(&w));
}

// =============================================================================
// Section 19: RawWaker and RawWakerVTable Construction
// =============================================================================

@test
fn test_raw_waker_vtable_new_constructor() {
    // Test RawWakerVTable.new() constructor by creating custom vtable
    fn test_clone(data: &unsafe Byte) -> RawWaker {
        RawWaker.new(data, null_ptr())
    }
    fn test_wake(_data: &unsafe Byte) {}
    fn test_wake_by_ref(_data: &unsafe Byte) {}
    fn test_drop(_data: &unsafe Byte) {}

    let vtable: RawWakerVTable = RawWakerVTable.new(
        test_clone,
        test_wake,
        test_wake_by_ref,
        test_drop,
    );
    // Verify fields are accessible
    let _ = vtable.clone;
    let _ = vtable.wake;
    let _ = vtable.wake_by_ref;
    let _ = vtable.drop;
}

@test
fn test_raw_waker_new_constructor() {
    // Test RawWaker.new() constructor
    let data_ptr: &unsafe Byte = null_ptr();
    // Create a minimal vtable for testing
    fn dummy_clone(data: &unsafe Byte) -> RawWaker {
        RawWaker.new(data, null_ptr())
    }
    fn dummy_wake(_data: &unsafe Byte) {}
    fn dummy_wake_by_ref(_data: &unsafe Byte) {}
    fn dummy_drop(_data: &unsafe Byte) {}

    let vtable: RawWakerVTable = RawWakerVTable.new(
        dummy_clone,
        dummy_wake,
        dummy_wake_by_ref,
        dummy_drop,
    );
    let raw: RawWaker = RawWaker.new(data_ptr, &vtable);
    // Verify fields are accessible
    let _data = raw.data;
    let _vtable = raw.vtable;
}

@test
fn test_waker_from_raw_indirect() {
    // Test that waker created via noop_waker uses from_raw internally
    // We verify this by testing the raw field is accessible
    let waker: Waker = noop_waker();
    let raw_ref: &RawWaker = &waker.raw;
    // Verify raw waker has expected structure
    let _data = raw_ref.data;
    let _vtable = raw_ref.vtable;
    assert(waker.will_wake(&waker));
}

// =============================================================================
// Section 20: Waker.wake() Consuming Method
// =============================================================================

@test
fn test_waker_wake_consumes() {
    // wake() consumes the waker (can't use after)
    let waker: Waker = noop_waker();
    let cloned: Waker = waker.clone();
    // wake() takes ownership and consumes
    waker.wake();
    // cloned is still valid
    assert(cloned.will_wake(&cloned));
}

@test
fn test_waker_wake_on_cloned() {
    // Test wake() on a cloned waker
    let original: Waker = noop_waker();
    let cloned1: Waker = original.clone();
    let cloned2: Waker = original.clone();
    // Consume cloned1
    cloned1.wake();
    // original and cloned2 still usable
    assert(original.will_wake(&cloned2));
}

// =============================================================================
// Section 21: Debug Trait and Formatting
// =============================================================================

@test
fn test_waker_debug_trait() {
    // Waker implements Debug for debugging output
    let waker: Waker = noop_waker();
    // Debug trait is implemented (verifiable by type system)
    let _: &Waker = &waker;
    // Format output would be "Waker { .. }" but we can't test runtime output
    waker.wake_by_ref();
}

// =============================================================================
// Section 22: Context and Waker Lifetime Patterns
// =============================================================================

@test
fn test_context_outlives_waker_ref() {
    // Context holds reference to waker
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);
    // Access waker through context multiple times
    let w1 = cx.waker();
    let w2 = cx.waker();
    let w3 = cx.waker();
    // All should be the same waker
    assert(w1.will_wake(w2));
    assert(w2.will_wake(w3));
}

@test
fn test_noop_context_independent_calls() {
    // Multiple calls to noop_context() create independent contexts
    let cx1: Context = noop_context();
    let cx2: Context = noop_context();
    let cx3: Context = noop_context();
    // All use noop wakers which are compatible
    assert(cx1.waker().will_wake(cx2.waker()));
    assert(cx2.waker().will_wake(cx3.waker()));
    assert(cx1.waker().will_wake(cx3.waker()));
}

fn main() {
    // Tests run via @test annotations
}
