// =============================================================================
// waker_test.vr - Comprehensive tests for Waker and Context
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: async, waker, context, rawwaker, vtable, core
// @description: Comprehensive tests for Waker, Context, RawWaker, RawWakerVTable,
//               noop_waker, noop_context, will_wake, clone, wake_by_ref
// =============================================================================

mount core.async.waker.{
    Waker, Context, RawWaker, RawWakerVTable,
    noop_waker, noop_context,
};
mount core.base.memory.null_ptr;

// =============================================================================
// Section 1: noop_waker() - No-Op Waker
// =============================================================================

@test
fn test_noop_waker_creation() {
    let waker: Waker = noop_waker();
    // Noop waker should self-identify
    assert(waker.will_wake(&waker));
}

@test
fn test_noop_waker_wake_by_ref() {
    let waker: Waker = noop_waker();
    waker.wake_by_ref();
    // wake_by_ref does nothing but should not panic; waker still usable
    assert(waker.will_wake(&waker));
}

@test
fn test_noop_waker_clone() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = waker1.clone();
    // Clone creates another noop waker that wakes same task
    assert(waker1.will_wake(&waker2));
}

@test
fn test_noop_waker_will_wake() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = waker1.clone();
    // Cloned wakers should wake the same task
    assert(waker1.will_wake(&waker2));
}

@test
fn test_noop_waker_will_wake_independent() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = noop_waker();
    // Two independently created noop wakers share same vtable and null data ptr
    assert(waker1.will_wake(&waker2));
}

// =============================================================================
// Section 2: Context - Polling Context
// =============================================================================

@test
fn test_context_from_waker() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);
    // Context should provide the same waker
    assert(cx.waker().will_wake(&waker));
}

@test
fn test_context_waker_method() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);
    let retrieved_waker: &Waker = cx.waker();
    assert(retrieved_waker.will_wake(&waker));
}

@test
fn test_context_waker_wake_by_ref() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);
    cx.waker().wake_by_ref();
    // Still usable after wake_by_ref
    assert(cx.waker().will_wake(&waker));
}

// =============================================================================
// Section 3: noop_context() - Convenience Function
// =============================================================================

@test
fn test_noop_context_creation() {
    let cx: Context = noop_context();
    // noop_context should have a valid waker
    let waker_ref: &Waker = cx.waker();
    waker_ref.wake_by_ref();
    assert(waker_ref.will_wake(waker_ref));
}

@test
fn test_noop_context_waker() {
    let cx: Context = noop_context();
    let waker: &Waker = cx.waker();
    waker.wake_by_ref();
    assert(waker.will_wake(waker));
}

// =============================================================================
// Section 4: RawWakerVTable
// =============================================================================

@test
fn test_raw_waker_vtable_through_noop() {
    // VTable is tested indirectly through noop_waker operations
    let w1: Waker = noop_waker();
    let w2: Waker = w1.clone();  // tests vtable.clone
    w2.wake_by_ref();             // tests vtable.wake_by_ref
    assert(w1.will_wake(&w2));
    // w1, w2 drop tests vtable.drop
}

// =============================================================================
// Section 5: Waker Methods
// =============================================================================

@test
fn test_waker_wake_by_ref_multiple_times() {
    let waker: Waker = noop_waker();
    waker.wake_by_ref();
    waker.wake_by_ref();
    waker.wake_by_ref();
    // Still valid after multiple wake_by_ref calls
    assert(waker.will_wake(&waker));
}

@test
fn test_waker_clone_chain() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = waker1.clone();
    let waker3: Waker = waker2.clone();
    waker1.wake_by_ref();
    waker2.wake_by_ref();
    waker3.wake_by_ref();
    // All clones wake the same task
    assert(waker1.will_wake(&waker3));
}

@test
fn test_waker_clone_will_wake_chain() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = waker1.clone();
    let waker3: Waker = waker2.clone();

    assert(waker1.will_wake(&waker2));
    assert(waker2.will_wake(&waker3));
    assert(waker1.will_wake(&waker3));
}

// =============================================================================
// Section 6: Context Usage Patterns
// =============================================================================

@test
fn test_context_usage_in_poll_pattern() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let waker_ref: &Waker = cx.waker();
    waker_ref.wake_by_ref();
    // Waker retrieved from context should match original
    assert(waker_ref.will_wake(&waker));
}

@test
fn test_context_multiple_waker_access() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);

    let w1: &Waker = cx.waker();
    let w2: &Waker = cx.waker();
    w1.wake_by_ref();
    w2.wake_by_ref();
    // Both references should point to same waker
    assert(w1.will_wake(w2));
}

// =============================================================================
// Section 7: Waker Identity
// =============================================================================

@test
fn test_waker_will_wake_self() {
    let waker: Waker = noop_waker();
    assert(waker.will_wake(&waker));
}

@test
fn test_waker_will_wake_clone_symmetric() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = waker1.clone();

    // Symmetric: if a.will_wake(b) then b.will_wake(a)
    assert(waker1.will_wake(&waker2) == waker2.will_wake(&waker1));
}

// =============================================================================
// Section 8: Edge Cases
// =============================================================================

@test
fn test_context_with_noop_context() {
    let cx: Context = noop_context();
    cx.waker().wake_by_ref();
    // waker from noop_context should be self-consistent
    assert(cx.waker().will_wake(cx.waker()));
}

@test
fn test_multiple_noop_wakers() {
    let w1: Waker = noop_waker();
    let w2: Waker = noop_waker();
    let w3: Waker = noop_waker();
    let w4: Waker = noop_waker();
    let w5: Waker = noop_waker();

    w1.wake_by_ref();
    w2.wake_by_ref();
    w3.wake_by_ref();
    w4.wake_by_ref();
    w5.wake_by_ref();
    // All noop wakers share same vtable and null data
    assert(w1.will_wake(&w5));
    assert(w2.will_wake(&w4));
}

@test
fn test_context_from_multiple_wakers() {
    let waker1: Waker = noop_waker();
    let waker2: Waker = noop_waker();

    let cx1: Context = Context.from_waker(&waker1);
    let cx2: Context = Context.from_waker(&waker2);

    cx1.waker().wake_by_ref();
    cx2.waker().wake_by_ref();
    // Both contexts' wakers should be compatible (both noop)
    assert(cx1.waker().will_wake(cx2.waker()));
}

// =============================================================================
// Section 9: Waker Cloning Preserves Identity
// =============================================================================

@test
fn test_clone_preserves_will_wake_transitivity() {
    let w1: Waker = noop_waker();
    let w2: Waker = w1.clone();
    let w3: Waker = w2.clone();
    let w4: Waker = w3.clone();

    // Transitive: w1 ~ w2, w2 ~ w3, w3 ~ w4 => w1 ~ w4
    assert(w1.will_wake(&w4));
    assert(w4.will_wake(&w1));
}

@test
fn test_clone_and_wake_independence() {
    let w1: Waker = noop_waker();
    let w2: Waker = w1.clone();

    // Waking one should not affect the other
    w1.wake_by_ref();
    assert(w2.will_wake(&w1));
    w2.wake_by_ref();
    assert(w1.will_wake(&w2));
}

// =============================================================================
// Section 10: Context Waker Round-Trip
// =============================================================================

@test
fn test_context_waker_round_trip() {
    let original: Waker = noop_waker();
    let cx: Context = Context.from_waker(&original);
    let retrieved: &Waker = cx.waker();
    // Round-trip: original -> context -> waker should match
    assert(retrieved.will_wake(&original));
}

@test
fn test_context_waker_clone_from_context() {
    let original: Waker = noop_waker();
    let cx: Context = Context.from_waker(&original);
    let cloned: Waker = cx.waker().clone();
    // Cloned from context should match original
    assert(cloned.will_wake(&original));
}

// =============================================================================
// Section 11: RawWaker Type Existence
// =============================================================================

mount core.async.waker.{RawWaker, RawWakerVTable};

@test
fn test_raw_waker_type_exists() {
    // Verify RawWaker type is accessible
    let w: Waker = noop_waker();
    let raw: &RawWaker = &w.raw;
    // raw has data and vtable fields
    let _data_ptr = raw.data;
    let _vtable_ptr = raw.vtable;
}

@test
fn test_raw_waker_vtable_type_exists() {
    // RawWakerVTable is accessible through waker
    let w: Waker = noop_waker();
    let vtable: &RawWakerVTable = w.raw.vtable;
    // VTable has four function pointers: clone, wake, wake_by_ref, drop
    let _ = vtable.clone;
    let _ = vtable.wake;
    let _ = vtable.wake_by_ref;
    let _ = vtable.drop;
}

// =============================================================================
// Section 12: Context Waker Stability
// =============================================================================

@test
fn test_context_waker_stable_across_accesses() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);

    // Multiple accesses should return consistent waker
    let w1: &Waker = cx.waker();
    let w2: &Waker = cx.waker();
    let w3: &Waker = cx.waker();
    assert(w1.will_wake(w2));
    assert(w2.will_wake(w3));
    assert(w1.will_wake(w3));
}

@test
fn test_noop_waker_wake_by_ref_many() {
    let waker: Waker = noop_waker();
    // Calling wake_by_ref many times should be harmless
    let mut i = 0;
    while i < 10 {
        waker.wake_by_ref();
        i = i + 1;
    }
    assert(waker.will_wake(&waker));
}

@test
fn test_noop_waker_deep_clone_chain() {
    let w1: Waker = noop_waker();
    let w2: Waker = w1.clone();
    let w3: Waker = w2.clone();
    let w4: Waker = w3.clone();
    let w5: Waker = w4.clone();

    // Deep clone chain preserves identity
    assert(w1.will_wake(&w5));
    assert(w5.will_wake(&w1));
}

// =============================================================================
// Section 13: Context Construction Patterns
// =============================================================================

@test
fn test_context_from_cloned_waker() {
    let original: Waker = noop_waker();
    let cloned: Waker = original.clone();
    let cx: Context = Context.from_waker(&cloned);
    // Context from cloned waker should still match original
    assert(cx.waker().will_wake(&original));
}

@test
fn test_two_contexts_same_waker() {
    let waker: Waker = noop_waker();
    let cx1: Context = Context.from_waker(&waker);
    let cx2: Context = Context.from_waker(&waker);
    // Both contexts share the same waker
    assert(cx1.waker().will_wake(cx2.waker()));
}

@test
fn test_context_waker_clone_round_trip() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);
    let cloned_from_ctx: Waker = cx.waker().clone();
    let cx2: Context = Context.from_waker(&cloned_from_ctx);
    // Round trip: waker -> context -> clone -> context should match
    assert(cx2.waker().will_wake(&waker));
}

// =============================================================================
// Section 14: Waker Wake then Clone
// =============================================================================

@test
fn test_waker_wake_then_clone() {
    let waker: Waker = noop_waker();
    waker.wake_by_ref();
    let cloned: Waker = waker.clone();
    // Clone after wake should still work
    assert(cloned.will_wake(&waker));
}

@test
fn test_waker_clone_then_wake_original() {
    let waker: Waker = noop_waker();
    let cloned: Waker = waker.clone();
    waker.wake_by_ref();
    // Clone should be unaffected by waking original
    assert(cloned.will_wake(&waker));
    cloned.wake_by_ref();
}

// =============================================================================
// Section 15: Context Double Construction
// =============================================================================

@test
fn test_context_sequential_wakers() {
    let w1: Waker = noop_waker();
    let cx1: Context = Context.from_waker(&w1);
    let retrieved1: &Waker = cx1.waker();

    let w2: Waker = noop_waker();
    let cx2: Context = Context.from_waker(&w2);
    let retrieved2: &Waker = cx2.waker();

    // Both contexts are valid simultaneously
    assert(retrieved1.will_wake(retrieved2));
}

@test
fn test_context_waker_ref_stability() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);

    // Get waker ref multiple times and use them
    let r1 = cx.waker();
    r1.wake_by_ref();
    let r2 = cx.waker();
    r2.wake_by_ref();

    assert(r1.will_wake(r2));
    assert(r2.will_wake(&waker));
}

// =============================================================================
// Section 16: Noop Waker Many Clones
// =============================================================================

@test
fn test_noop_waker_ten_clones() {
    let original: Waker = noop_waker();
    let mut wakers: List<Waker> = List.new();
    let mut i = 0;
    while i < 10 {
        wakers.push(original.clone());
        i = i + 1;
    }
    assert_eq(wakers.len(), 10);
    // All clones should wake same task as original
    assert(wakers[0].will_wake(&original));
    assert(wakers[9].will_wake(&original));
}

// =============================================================================
// Section 17: Waker from Context Clone Round Trip
// =============================================================================

@test
fn test_context_clone_waker_wake_round_trip() {
    let original: Waker = noop_waker();
    let cx: Context = Context.from_waker(&original);
    let cloned: Waker = cx.waker().clone();
    cloned.wake_by_ref();
    let cx2: Context = Context.from_waker(&cloned);
    // Full round trip preserves identity
    assert(cx2.waker().will_wake(&original));
}

@test
fn test_multiple_contexts_all_consistent() {
    let waker: Waker = noop_waker();
    let cx1: Context = Context.from_waker(&waker);
    let cx2: Context = Context.from_waker(&waker);
    let cx3: Context = Context.from_waker(&waker);
    // All contexts provide wakers that wake same task
    assert(cx1.waker().will_wake(cx2.waker()));
    assert(cx2.waker().will_wake(cx3.waker()));
    assert(cx1.waker().will_wake(cx3.waker()));
}

@test
fn test_noop_context_waker_matches_noop_waker() {
    let cx: Context = noop_context();
    let standalone: Waker = noop_waker();
    // noop_context's waker should be equivalent to noop_waker
    assert(cx.waker().will_wake(&standalone));
}

@test
fn test_wake_by_ref_preserves_will_wake() {
    let w1: Waker = noop_waker();
    let w2: Waker = w1.clone();
    assert(w1.will_wake(&w2));
    w1.wake_by_ref();
    w2.wake_by_ref();
    // will_wake still holds after both have been woken
    assert(w1.will_wake(&w2));
}

@test
fn test_context_from_waker_explicit_type() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);
    let waker_ref: &Waker = cx.waker();
    let _: &Waker = waker_ref;
    assert(waker_ref.will_wake(&waker));
}

@test
fn test_six_deep_clone_chain() {
    let w1: Waker = noop_waker();
    let w2: Waker = w1.clone();
    let w3: Waker = w2.clone();
    let w4: Waker = w3.clone();
    let w5: Waker = w4.clone();
    let w6: Waker = w5.clone();
    assert(w1.will_wake(&w6));
    assert(w6.will_wake(&w1));
    w6.wake_by_ref();
}

@test
fn test_noop_waker_will_wake_reflexive() {
    let w: Waker = noop_waker();
    // Reflexive: always wakes itself
    assert(w.will_wake(&w));
    assert(w.will_wake(&w));
    assert(w.will_wake(&w));
}

@test
fn test_context_waker_after_multiple_wakes() {
    let waker: Waker = noop_waker();
    let cx: Context = Context.from_waker(&waker);
    // Wake via context multiple times
    cx.waker().wake_by_ref();
    cx.waker().wake_by_ref();
    cx.waker().wake_by_ref();
    cx.waker().wake_by_ref();
    cx.waker().wake_by_ref();
    // Still consistent
    assert(cx.waker().will_wake(&waker));
}

