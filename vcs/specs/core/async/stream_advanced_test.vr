@test
fn test_stream_then_type_exists() {
    let _: Maybe<StreamThen<TestStream, fn(Int) -> ReadyFuture<Text>, ReadyFuture<Text>>> = None;
}

@test
fn test_stream_then_different_output_types() {
    let _: Maybe<StreamThen<TestStream, fn(Int) -> ReadyFuture<Bool>, ReadyFuture<Bool>>> = None;
    let _: Maybe<StreamThen<TestStream, fn(Int) -> ReadyFuture<Float>, ReadyFuture<Float>>> = None;
}

