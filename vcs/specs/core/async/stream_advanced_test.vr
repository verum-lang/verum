@test
fn test_debounced_stream_construction() {
    let stream = test_stream([1, 2, 3]);
    let debounced: DebouncedStream<TestStream> = DebouncedStream {
        stream: stream,
        duration: Duration.from_millis(50),
        last_item: None,
