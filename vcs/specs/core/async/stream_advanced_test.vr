@test
fn test_stream_sum_protocol_exists() {
    let _: Maybe<StreamSum<Int>> = None;
}

@test
fn test_stream_product_protocol_exists() {
    let _: Maybe<StreamProduct<Int>> = None;
}

@test
fn test_sum_stream_type_exists() {
    let _: Maybe<SumStream<TestStream, StreamSum<Int>>> = None;
