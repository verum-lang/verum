// =============================================================================
// Section 10: ChunkedStream (more patterns)
// =============================================================================

@test
fn test_chunked_stream_size_hint() {
    let stream = test_stream([1, 2, 3, 4, 5, 6, 7, 8, 9]);
    let chunked: ChunkedStream<TestStream> = ChunkedStream {
        stream: stream,
        size: 3,
        buffer: [],
        done: false,
    };
    let (lo, hi) = chunked.size_hint();
    assert_eq(lo, 3); // 9 items / 3 per chunk = 3 chunks
}

@test
fn test_chunked_stream_size_hint_partial() {
    let stream = test_stream([1, 2, 3, 4, 5]);
    let chunked: ChunkedStream<TestStream> = ChunkedStream {
        stream: stream,
        size: 3,
        buffer: [],
        done: false,
    };
    let (lo, _) = chunked.size_hint();
    assert_eq(lo, 1); // floor(5/3) = 1
}

@test
fn test_chunked_stream_large_chunk_size() {
    let stream = test_stream([1, 2]);
    let chunked: ChunkedStream<TestStream> = ChunkedStream {
        stream: stream,
        size: 100,
        buffer: [],
        done: false,
    };
    let (lo, _) = chunked.size_hint();
    assert_eq(lo, 0); // 2 items < 100 per chunk
}

@test
fn test_chunked_stream_single_item_chunks() {
    let stream = test_stream([1, 2, 3]);
    let chunked: ChunkedStream<TestStream> = ChunkedStream {
        stream: stream,
        size: 1,
        buffer: [],
        done: false,
    };
    let (lo, _) = chunked.size_hint();
    assert_eq(lo, 3); // 3 items / 1 per chunk = 3
}

// =============================================================================
// Section 11: BufferedStream (more patterns)
// =============================================================================

@test
fn test_buffered_stream_size_hint_with_buffer() {
    let stream = test_stream([4, 5, 6]);
    let buffered: BufferedStream<TestStream> = BufferedStream {
        stream: stream,
        buffer: [1, 2, 3], // 3 items already buffered
        capacity: 10,
        done: false,
    };
    let (lo, hi) = buffered.size_hint();
    assert_eq(lo, 6); // 3 buffered + 3 remaining
}

@test
fn test_buffered_stream_empty() {
    let stream = test_stream([]);
    let buffered: BufferedStream<TestStream> = BufferedStream {
        stream: stream,
        buffer: [],
        capacity: 10,
        done: false,
    };
    let (lo, _) = buffered.size_hint();
    assert_eq(lo, 0);
}

@test
fn test_buffered_stream_done_flag() {
    let stream = test_stream([]);
    let buffered: BufferedStream<TestStream> = BufferedStream {
        stream: stream,
        buffer: [1, 2],
        capacity: 5,
        done: true,
    };
    assert(buffered.done);
    assert_eq(buffered.buffer.len(), 2);
}

@test
fn test_buffered_stream_capacity() {
    let stream = test_stream([1, 2, 3, 4, 5]);
    let buffered: BufferedStream<TestStream> = BufferedStream {
        stream: stream,
        buffer: [],
        capacity: 3,
        done: false,
    };
    assert_eq(buffered.capacity, 3);
}

// =============================================================================
// Section 12: Polling advanced streams
// =============================================================================

@test
fn test_intersperse_poll_first_item() {
    let mut stream: StreamIntersperse<TestStream> = StreamIntersperse {
        stream: test_stream([10, 20]),
        separator: 0,
        next_sep: false,
        item: None,
    };
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let result = stream.poll_next(&mut cx);
    assert(result.is_ready());
}

@test
fn test_merged_stream_poll_gets_item() {
    let mut merged: MergedStream<TestStream, TestStream> = MergedStream {
        stream1: test_stream([1]),
        stream2: test_stream([2]),
        stream1_done: false,
        stream2_done: false,
        prefer_first: true,
    };
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let result = merged.poll_next(&mut cx);
    assert(result.is_ready());
}

@test
fn test_buffered_stream_poll_fills_buffer() {
    let mut buffered: BufferedStream<TestStream> = BufferedStream {
        stream: test_stream([1, 2, 3]),
        buffer: [],
        capacity: 10,
        done: false,
    };
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let result = buffered.poll_next(&mut cx);
    assert(result.is_ready());
}

@test
fn test_chunked_stream_poll() {
    let mut chunked: ChunkedStream<TestStream> = ChunkedStream {
        stream: test_stream([1, 2, 3]),
        size: 3,
        buffer: [],
        done: false,
    };
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let result = chunked.poll_next(&mut cx);
    assert(result.is_ready());
}
