// @test: typecheck-pass
// @level: L1
// @tags: async, stream, intersperse, throttle, merge, window, debounce, sample,
//        then, for_each_concurrent, sum, product
// @description: Extended stream tests covering advanced combinators not tested in
//               stream_test.vr: StreamIntersperse, StreamThen, StreamForEachConcurrent,
//               StreamSum, StreamProduct, ThrottledStream, MergedStream, WindowedStream,
//               DebouncedStream, SampledStream.

mount core.async.stream.{
    Stream, IntoStream, StreamExt,
    iter, stream_once, stream_empty, stream_repeat, stream_repeat_n,
    StreamIter, StreamMap, StreamFilter, StreamTake, StreamChain,
    StreamIntersperse, StreamThen, StreamForEachConcurrent,
    StreamSum, StreamProduct, SumStream, ProductStream,
    ThrottledStream, MergedStream, WindowedStream,
    DebouncedStream, SampledStream,
    BufferedStream, ChunkedStream,
};
mount core.async.poll.{Poll, Ready, Pending};
mount core.async.waker.{Context, Waker, noop_waker};
mount core.async.future.{Future, ReadyFuture};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;
mount core.time.{Duration, Instant};

// Helper: create a test stream from items
type TestStream is {
    items: List<Int>,
    index: Int,
};

implement Stream for TestStream {
    type Item = Int;

    fn poll_next(&mut self, cx: &mut Context) -> Poll<Maybe<Int>> {
        if self.index < self.items.len() {
            let val = self.items[self.index];
            self.index = self.index + 1;
            Ready(Some(val))
        } else {
            Ready(None)
        }
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let remaining = self.items.len() - self.index;
        (remaining, Some(remaining))
    }
}

fn test_stream(items: List<Int>) -> TestStream {
    TestStream { items: items, index: 0 }
}

// Text stream helper
type TextStream is {
    items: List<Text>,
    index: Int,
};

implement Stream for TextStream {
    type Item = Text;

    fn poll_next(&mut self, cx: &mut Context) -> Poll<Maybe<Text>> {
        if self.index < self.items.len() {
            let val = self.items[self.index].clone();
            self.index = self.index + 1;
            Ready(Some(val))
        } else {
            Ready(None)
        }
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let remaining = self.items.len() - self.index;
        (remaining, Some(remaining))
    }
}

// =============================================================================
// Section 1: StreamIntersperse
// =============================================================================

@test
fn test_intersperse_type_exists() {
    let stream = test_stream([1, 2, 3]);
    let interspersed: StreamIntersperse<TestStream> = StreamIntersperse {
        stream: stream,
        separator: 0,
        next_sep: false,
        item: None,
    };
    // Items: 1, 0, 2, 0, 3
    let (lo, _) = interspersed.size_hint();
    assert(lo >= 0);
}

@test
fn test_intersperse_empty_stream() {
    let stream = test_stream([]);
    let interspersed: StreamIntersperse<TestStream> = StreamIntersperse {
        stream: stream,
        separator: 99,
        next_sep: false,
        item: None,
    };
    let (lo, hi) = interspersed.size_hint();
    assert_eq(lo, 0);
}

@test
fn test_intersperse_single_item() {
    let stream = test_stream([42]);
    let interspersed: StreamIntersperse<TestStream> = StreamIntersperse {
        stream: stream,
        separator: 0,
        next_sep: false,
        item: None,
    };
    // Single item, no separator needed
    let (lo, _) = interspersed.size_hint();
    assert(lo >= 0);
}

@test
fn test_intersperse_with_text() {
    let stream = TextStream { items: ["a", "b", "c"], index: 0 };
    let interspersed: StreamIntersperse<TextStream> = StreamIntersperse {
        stream: stream,
        separator: ", ",
        next_sep: false,
        item: None,
    };
    let (lo, _) = interspersed.size_hint();
    assert(lo >= 0);
}

