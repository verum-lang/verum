@test
fn test_product_stream_type_exists() {
    let _: Maybe<ProductStream<TestStream, StreamProduct<Int>>> = None;
}

// =============================================================================
// Section 5: ThrottledStream
// =============================================================================

@test
fn test_throttled_stream_type_exists() {
    let _: Maybe<ThrottledStream<TestStream>> = None;
}

@test
fn test_throttled_stream_construction() {
    let stream = test_stream([1, 2, 3, 4, 5]);
    let throttled: ThrottledStream<TestStream> = ThrottledStream {
        stream: stream,
        count: 10,
        per: Duration.from_secs(1),
        tokens: 10,
        last_refill: Instant.now(),
    };
    assert_eq(throttled.count, 10);
    assert_eq(throttled.tokens, 10);
}

@test
fn test_throttled_stream_size_hint_passthrough() {
    let stream = test_stream([1, 2, 3]);
    let throttled: ThrottledStream<TestStream> = ThrottledStream {
        stream: stream,
        count: 5,
        per: Duration.from_secs(1),
        tokens: 5,
        last_refill: Instant.now(),
    };
    let (lo, hi) = throttled.size_hint();
    assert_eq(lo, 3);
}

@test
fn test_throttled_stream_zero_tokens() {
    let stream = test_stream([1, 2]);
    let throttled: ThrottledStream<TestStream> = ThrottledStream {
        stream: stream,
        count: 5,
        per: Duration.from_secs(1),
        tokens: 0, // No tokens available
        last_refill: Instant.now(),
    };
    assert_eq(throttled.tokens, 0);
}

// =============================================================================
// Section 6: MergedStream
// =============================================================================

@test
fn test_merged_stream_type_exists() {
    let _: Maybe<MergedStream<TestStream, TestStream>> = None;
}

@test
fn test_merged_stream_construction() {
    let s1 = test_stream([1, 2, 3]);
    let s2 = test_stream([4, 5, 6]);
    let merged: MergedStream<TestStream, TestStream> = MergedStream {
        stream1: s1,
        stream2: s2,
        stream1_done: false,
        stream2_done: false,
        prefer_first: true,
    };
    assert(!merged.stream1_done);
    assert(!merged.stream2_done);
}

@test
fn test_merged_stream_size_hint_sums() {
    let s1 = test_stream([1, 2, 3]);
    let s2 = test_stream([4, 5]);
    let merged: MergedStream<TestStream, TestStream> = MergedStream {
        stream1: s1,
        stream2: s2,
        stream1_done: false,
        stream2_done: false,
        prefer_first: true,
    };
    let (lo, hi) = merged.size_hint();
    assert_eq(lo, 5); // 3 + 2
}

@test
fn test_merged_stream_prefer_first() {
    let s1 = test_stream([1]);
    let s2 = test_stream([2]);
    let merged: MergedStream<TestStream, TestStream> = MergedStream {
        stream1: s1,
        stream2: s2,
        stream1_done: false,
        stream2_done: false,
        prefer_first: true,
    };
    assert(merged.prefer_first);
}

@test
fn test_merged_stream_empty_sources() {
    let s1 = test_stream([]);
    let s2 = test_stream([]);
    let merged: MergedStream<TestStream, TestStream> = MergedStream {
        stream1: s1,
        stream2: s2,
        stream1_done: false,
        stream2_done: false,
        prefer_first: true,
    };
    let (lo, _) = merged.size_hint();
    assert_eq(lo, 0);
}

@test
fn test_merged_stream_one_empty() {
    let s1 = test_stream([1, 2, 3]);
    let s2 = test_stream([]);
    let merged: MergedStream<TestStream, TestStream> = MergedStream {
        stream1: s1,
        stream2: s2,
        stream1_done: false,
        stream2_done: false,
        prefer_first: true,
    };
    let (lo, _) = merged.size_hint();
    assert_eq(lo, 3);
}

// =============================================================================
// Section 7: WindowedStream
// =============================================================================

@test
fn test_windowed_stream_type_exists() {
    let _: Maybe<WindowedStream<TestStream>> = None;
}

@test
fn test_windowed_stream_construction() {
    let stream = test_stream([1, 2, 3, 4, 5]);
    let windowed: WindowedStream<TestStream> = WindowedStream {
        stream: stream,
        duration: Duration.from_millis(100),
        buffer: [],
        window_start: Instant.now(),
    };
    assert(windowed.buffer.is_empty());
}

@test
fn test_windowed_stream_empty_buffer() {
    let stream = test_stream([]);
    let windowed: WindowedStream<TestStream> = WindowedStream {
        stream: stream,
        duration: Duration.from_secs(1),
        buffer: [],
        window_start: Instant.now(),
    };
    assert_eq(windowed.buffer.len(), 0);
}

