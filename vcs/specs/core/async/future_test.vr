// =============================================================================
// future_test.vr - Tests for Future protocol and combinators
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: async, future, ready, pending, lazy, map, combinator, core
// @description: Comprehensive tests for Future protocol and future combinators
// =============================================================================

mount core.async.poll.{Poll, Ready, Pending};
mount core.async.future.{
    Future, IntoFuture, FutureExt,
    ReadyFuture, PendingFuture,
    Lazy, MapFuture, AndThenFuture,
    Join2, Join3, Select2,
    ready, pending, lazy,
    join, join3, select,
    SelectResult, Left, Right,
};
mount core.async.waker.{Waker, Context, noop_waker};
mount core.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: ReadyFuture - Immediately Complete
// =============================================================================

@test
fn test_ready_future_construction() {
    let fut: ReadyFuture<Int> = ready(42);
    // Future is ready with the provided value
}

@test
fn test_ready_future_poll_returns_ready() {
    let mut fut: ReadyFuture<Int> = ready(42);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result: Poll<Int> = fut.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 42);
}

@test
fn test_ready_future_int() {
    let mut fut: ReadyFuture<Int> = ready(100);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert(fut.poll(&mut cx).is_ready());
}

@test
fn test_ready_future_bool() {
    let mut fut: ReadyFuture<Bool> = ready(true);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert(fut.poll(&mut cx).is_ready());
}

@test
fn test_ready_future_text() {
    let mut fut: ReadyFuture<Text> = ready("hello");
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert(fut.poll(&mut cx).is_ready());
}

// =============================================================================
// Section 2: PendingFuture - Never Completes
// =============================================================================

@test
fn test_pending_future_construction() {
    let fut: PendingFuture<Int> = pending();
    // Future is always pending
}

@test
fn test_pending_future_poll_returns_pending() {
    let mut fut: PendingFuture<Int> = pending();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result: Poll<Int> = fut.poll(&mut cx);
    assert(result.is_pending());
}

@test
fn test_pending_future_poll_multiple_times() {
    let mut fut: PendingFuture<Int> = pending();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // Polling multiple times should always return Pending
    assert(fut.poll(&mut cx).is_pending());
    assert(fut.poll(&mut cx).is_pending());
    assert(fut.poll(&mut cx).is_pending());
}

@test
fn test_pending_future_bool() {
    let mut fut: PendingFuture<Bool> = pending();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert(fut.poll(&mut cx).is_pending());
}

@test
fn test_pending_future_text() {
    let mut fut: PendingFuture<Text> = pending();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert(fut.poll(&mut cx).is_pending());
}

// =============================================================================
// Section 3: SelectResult Type
// =============================================================================

@test
fn test_select_result_left_pattern() {
    let result: SelectResult<Int, Text> = Left(42);
    match result {
        Left(v) => assert_eq(v, 42),
        Right(_) => panic("Expected Left"),
    }
}

@test
fn test_select_result_right_pattern() {
    let result: SelectResult<Int, Text> = Right("hello");
    match result {
        Left(_) => panic("Expected Right"),
        Right(v) => assert_eq(v, "hello"),
    }
}

@test
fn test_select_result_is_pattern() {
    let left: SelectResult<Int, Int> = Left(1);
    let right: SelectResult<Int, Int> = Right(2);

    assert(left is Left);
    assert(!(left is Right));
    assert(right is Right);
    assert(!(right is Left));
}

@test
fn test_select_result_left_different_types() {
    let result: SelectResult<Bool, Int> = Left(true);
    match result {
        Left(v) => assert(v),
        Right(_) => panic("Expected Left"),
    }
}

@test
fn test_select_result_right_different_types() {
    let result: SelectResult<Int, Bool> = Right(false);
    match result {
        Left(_) => panic("Expected Right"),
        Right(v) => assert(!v),
    }
}

// =============================================================================
// Section 4: ReadyFuture Variations
// =============================================================================

@test
fn test_ready_future_with_unit() {
    let mut fut: ReadyFuture<()> = ready(());
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result: Poll<()> = fut.poll(&mut cx);
    assert(result.is_ready());
}

@test
fn test_ready_future_with_negative() {
    let mut fut: ReadyFuture<Int> = ready(-42);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    assert_eq(fut.poll(&mut cx).unwrap(), -42);
}

@test
fn test_ready_future_with_zero() {
    let mut fut: ReadyFuture<Int> = ready(0);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    assert_eq(fut.poll(&mut cx).unwrap(), 0);
}

@test
fn test_ready_future_with_empty_text() {
    let mut fut: ReadyFuture<Text> = ready("");
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    assert_eq(fut.poll(&mut cx).unwrap(), "");
}

// =============================================================================
// Section 5: PendingFuture Variations
// =============================================================================

@test
fn test_pending_future_unit() {
    let mut fut: PendingFuture<()> = pending();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert(fut.poll(&mut cx).is_pending());
}

@test
fn test_pending_future_tuple() {
    let mut fut: PendingFuture<(Int, Bool)> = pending();
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert(fut.poll(&mut cx).is_pending());
}

// =============================================================================
// Section 6: Multiple Futures
// =============================================================================

@test
fn test_multiple_ready_futures() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let mut fut1: ReadyFuture<Int> = ready(1);
    let mut fut2: ReadyFuture<Int> = ready(2);
    let mut fut3: ReadyFuture<Int> = ready(3);

    assert_eq(fut1.poll(&mut cx).unwrap(), 1);
    assert_eq(fut2.poll(&mut cx).unwrap(), 2);
    assert_eq(fut3.poll(&mut cx).unwrap(), 3);
}

@test
fn test_multiple_pending_futures() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let mut fut1: PendingFuture<Int> = pending();
    let mut fut2: PendingFuture<Int> = pending();
    let mut fut3: PendingFuture<Int> = pending();

    assert(fut1.poll(&mut cx).is_pending());
    assert(fut2.poll(&mut cx).is_pending());
    assert(fut3.poll(&mut cx).is_pending());
}

@test
fn test_mixed_ready_pending() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let mut ready_fut: ReadyFuture<Int> = ready(42);
    let mut pending_fut: PendingFuture<Int> = pending();

    assert(ready_fut.poll(&mut cx).is_ready());
    assert(pending_fut.poll(&mut cx).is_pending());
}

// =============================================================================
// Section 7: SelectResult Comprehensive
// =============================================================================

@test
fn test_select_result_match_exhaustive() {
    let left_result: SelectResult<Int, Int> = Left(10);
    let right_result: SelectResult<Int, Int> = Right(20);

    let left_value: Int = match left_result {
        Left(v) => v,
        Right(v) => v,
    };
    assert_eq(left_value, 10);

    let right_value: Int = match right_result {
        Left(v) => v,
        Right(v) => v,
    };
    assert_eq(right_value, 20);
}

@test
fn test_select_result_nested() {
    let nested: SelectResult<SelectResult<Int, Int>, Int> = Left(Left(42));
    match nested {
        Left(inner) => {
            match inner {
                Left(v) => assert_eq(v, 42),
                Right(_) => panic("Expected inner Left"),
            }
        }
        Right(_) => panic("Expected outer Left"),
    }
}

// =============================================================================
// Section 8: Context and Waker Usage
// =============================================================================

@test
fn test_context_waker_in_poll() {
    let mut fut: ReadyFuture<Int> = ready(42);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // Waker accessible in context
    let waker_ref: &Waker = cx.waker();
    waker_ref.wake_by_ref();

    // Future still pollable
    assert(fut.poll(&mut cx).is_ready());
}

@test
fn test_reuse_context_multiple_polls() {
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let mut fut1: ReadyFuture<Int> = ready(1);
    let mut fut2: ReadyFuture<Int> = ready(2);

    // Same context used for multiple futures
    assert(fut1.poll(&mut cx).is_ready());
    assert(fut2.poll(&mut cx).is_ready());
}

// =============================================================================
// Section 9: Edge Cases
// =============================================================================

@test
fn test_ready_large_value() {
    let mut fut: ReadyFuture<Int> = ready(999999999);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert_eq(fut.poll(&mut cx).unwrap(), 999999999);
}

@test
fn test_ready_negative_large() {
    let mut fut: ReadyFuture<Int> = ready(-999999999);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert_eq(fut.poll(&mut cx).unwrap(), -999999999);
}

// =============================================================================
// Section 10: Lazy Future - Deferred Computation
// =============================================================================

@test
fn test_lazy_future_construction() {
    let fut: Lazy<fn() -> Int, Int> = lazy(|| 42);
    // Lazy future created but not yet evaluated
}

@test
fn test_lazy_future_poll() {
    let mut fut: Lazy<fn() -> Int, Int> = lazy(|| 42);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result: Poll<Int> = fut.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 42);
}

@test
fn test_lazy_future_deferred() {
    // Lazy should not evaluate until polled
    let mut called = false;
    let mut fut: Lazy<fn() -> Int, Int> = lazy(|| {
        100
    });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert_eq(fut.poll(&mut cx).unwrap(), 100);
}

@test
fn test_lazy_future_text() {
    let mut fut: Lazy<fn() -> Text, Text> = lazy(|| "lazy hello");
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert_eq(fut.poll(&mut cx).unwrap(), "lazy hello");
}

// =============================================================================
// Section 11: MapFuture - Transform Output
// =============================================================================

@test
fn test_map_future_construction() {
    let fut: MapFuture<ReadyFuture<Int>, fn(Int) -> Int> = ready(21).map(|x| x * 2);
    // Map future created
}

@test
fn test_map_future_poll() {
    let mut fut: MapFuture<ReadyFuture<Int>, fn(Int) -> Int> = ready(21).map(|x| x * 2);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result: Poll<Int> = fut.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 42);
}

@test
fn test_map_future_type_change() {
    let mut fut: MapFuture<ReadyFuture<Int>, fn(Int) -> Bool> = ready(10).map(|x: Int| -> Bool { x > 5 });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result: Poll<Bool> = fut.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), true);
}

@test
fn test_map_future_to_text() {
    let mut fut = ready(42).map(|x: Int| -> Text { "done" });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    assert(fut.poll(&mut cx).is_ready());
}

// =============================================================================
// Section 12: AndThenFuture - Chain Futures
// =============================================================================

@test
fn test_and_then_future_construction() {
    let fut = ready(21).and_then(|x: Int| -> ReadyFuture<Int> { ready(x * 2) });
    // AndThen future created
}

@test
fn test_and_then_future_poll() {
    let mut fut = ready(21).and_then(|x: Int| -> ReadyFuture<Int> { ready(x * 2) });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 42);
}

@test
fn test_and_then_future_type_change() {
    let mut fut = ready(42).and_then(|x: Int| -> ReadyFuture<Bool> { ready(x > 0) });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), true);
}

// =============================================================================
// Section 13: Join2 - Wait for Two Futures
// =============================================================================

@test
fn test_join2_construction() {
    let fut: Join2<ReadyFuture<Int>, ReadyFuture<Text>> = join(ready(42), ready("hello"));
    // Join2 created
}

@test
fn test_join2_both_ready() {
    let mut fut: Join2<ReadyFuture<Int>, ReadyFuture<Int>> = join(ready(1), ready(2));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    let pair = result.unwrap();
    assert_eq(pair.0, 1);
    assert_eq(pair.1, 2);
}

@test
fn test_join2_different_types() {
    let mut fut: Join2<ReadyFuture<Int>, ReadyFuture<Bool>> = join(ready(42), ready(true));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    let pair = result.unwrap();
    assert_eq(pair.0, 42);
    assert_eq(pair.1, true);
}

@test
fn test_join2_one_pending() {
    let mut fut: Join2<ReadyFuture<Int>, PendingFuture<Int>> = join(ready(1), pending());
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    // One is pending so join stays pending
    let result = fut.poll(&mut cx);
    assert(result.is_pending());
}

@test
fn test_join2_both_pending() {
    let mut fut: Join2<PendingFuture<Int>, PendingFuture<Int>> = join(pending(), pending());
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    assert(fut.poll(&mut cx).is_pending());
}

// =============================================================================
// Section 14: Join3 - Wait for Three Futures
// =============================================================================

@test
fn test_join3_all_ready() {
    let mut fut: Join3<ReadyFuture<Int>, ReadyFuture<Int>, ReadyFuture<Int>> = join3(ready(1), ready(2), ready(3));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    let triple = result.unwrap();
    assert_eq(triple.0, 1);
    assert_eq(triple.1, 2);
    assert_eq(triple.2, 3);
}

@test
fn test_join3_one_pending() {
    let mut fut = join3(ready(1), pending<Int>(), ready(3));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    assert(fut.poll(&mut cx).is_pending());
}

@test
fn test_join3_different_types() {
    let mut fut = join3(ready(42), ready(true), ready("hello"));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    let triple = result.unwrap();
    assert_eq(triple.0, 42);
    assert_eq(triple.1, true);
    assert_eq(triple.2, "hello");
}

// =============================================================================
// Section 15: Select2 - Race Two Futures
// =============================================================================

@test
fn test_select_first_ready() {
    let mut fut: Select2<ReadyFuture<Int>, PendingFuture<Int>> = select(ready(42), pending());
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    match result.unwrap() {
        Left(v) => assert_eq(v, 42),
        Right(_) => panic("Expected Left from select"),
    }
}

@test
fn test_select_second_ready() {
    let mut fut: Select2<PendingFuture<Int>, ReadyFuture<Int>> = select(pending(), ready(99));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    match result.unwrap() {
        Left(_) => panic("Expected Right from select"),
        Right(v) => assert_eq(v, 99),
    }
}

@test
fn test_select_both_ready_picks_first() {
    // When both are ready, select picks the first one
    let mut fut: Select2<ReadyFuture<Int>, ReadyFuture<Int>> = select(ready(1), ready(2));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    match result.unwrap() {
        Left(v) => assert_eq(v, 1),
        Right(_) => panic("Expected Left when both ready"),
    }
}

@test
fn test_select_both_pending() {
    let mut fut: Select2<PendingFuture<Int>, PendingFuture<Int>> = select(pending(), pending());
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    assert(fut.poll(&mut cx).is_pending());
}

@test
fn test_select_different_types() {
    let mut fut = select(ready(42), ready("hello"));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);

    let result = fut.poll(&mut cx);
    assert(result.is_ready());
    match result.unwrap() {
        Left(v) => assert_eq(v, 42),
        Right(_) => panic("Expected Left"),
    }
}

// =============================================================================
// Section 16: FutureExt block() - Synchronous blocking
// =============================================================================

@test
fn test_block_ready() {
    let value: Int = ready(42).block();
    assert_eq(value, 42);
}

@test
fn test_block_ready_text() {
    let value: Text = ready("hello").block();
    assert_eq(value, "hello");
}

@test
fn test_block_ready_bool() {
    let value: Bool = ready(true).block();
    assert_eq(value, true);
}

// =============================================================================
// Main - Run all tests
// =============================================================================

fn main() {
    // Tests run via @test annotations
}
