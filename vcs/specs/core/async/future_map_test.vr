// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: async, future, combinators
// @description: Test future combinators - threshold finding

mount core.async.poll.{Poll, Ready, Pending};
mount core.async.future.{
    Future, IntoFuture, FutureExt,
    ReadyFuture, PendingFuture,
    MapFuture, AndThenFuture,
    Lazy,
    Join2, Join3, Select2,
    ready, pending, lazy,
    join, join3, select,
    SelectResult, Left, Right,
};
mount core.async.waker.{Waker, Context, noop_waker};
mount core.maybe.{Maybe, Some, None};

@test
fn test_map_basic() {
    let fut: MapFuture<ReadyFuture<Int>, fn(Int) -> Int> = ready(21).map(|x| x * 2);
}

@test
fn test_map_poll() {
    let mut fut: MapFuture<ReadyFuture<Int>, fn(Int) -> Int> = ready(21).map(|x| x * 2);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let result: Poll<Int> = fut.poll(&mut cx);
    assert(result.is_ready());
}

@test
fn test_and_then_basic() {
    let fut = ready(21).and_then(|x: Int| -> ReadyFuture<Int> { ready(x * 2) });
}

@test
fn test_lazy_basic() {
    let fut: Lazy<fn() -> Int, Int> = lazy(|| 42);
}

@test
fn test_join2() {
    let a: ReadyFuture<Int> = ready(1);
    let b: ReadyFuture<Text> = ready("hello");
    let joined: Join2<ReadyFuture<Int>, ReadyFuture<Text>> = join(a, b);
}

@test
fn test_select2() {
    let a: ReadyFuture<Int> = ready(1);
    let b: ReadyFuture<Text> = ready("hello");
    let sel: Select2<ReadyFuture<Int>, ReadyFuture<Text>> = select(a, b);
}

@test
fn test_block_ready() {
    let value: Int = ready(42).block();
    assert_eq(value, 42);
}

@test
fn test_ready_text() {
    let mut fut: ReadyFuture<Text> = ready("hello");
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    assert_eq(fut.poll(&mut cx).unwrap(), "hello");
}

