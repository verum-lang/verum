fn test_and_then_type_change() {
    let fut = ready(42).and_then(|x: Int| -> ReadyFuture<Text> { ready("hello") });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), "hello");
