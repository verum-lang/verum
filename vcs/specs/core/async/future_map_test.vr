@test
fn test_and_then_chain_two() {
    let fut = ready(1)
        .and_then(|x: Int| -> ReadyFuture<Int> { ready(x + 10) })
        .and_then(|x: Int| -> ReadyFuture<Int> { ready(x * 3) });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 33);
}

@test
fn test_and_then_to_bool() {
    let fut = ready(10).and_then(|x: Int| -> ReadyFuture<Bool> { ready(x > 5) });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), true);
}

