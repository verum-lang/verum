@test
fn test_map_type_change() {
    let fut = ready(42).map(|x: Int| -> Bool { x > 10 });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
}

@test
fn test_map_to_text() {
    let fut = ready(42).map(|x: Int| -> Text { "hello" });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
}

@test
fn test_map_to_tuple() {
    let fut = ready(5).map(|x: Int| (x, x * 2));
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
}

@test
fn test_map_identity() {
    let fut = ready(99).map(|x| x);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result: Poll<Int> = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 99);
}

@test
fn test_map_chain_two() {
    let fut = ready(10).map(|x| x + 5).map(|x| x * 2);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 30);
}

@test
fn test_map_chain_three() {
    let fut = ready(1)
        .map(|x| x + 1)
        .map(|x| x * 10)
        .map(|x| x - 5);
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 15);
}

@test
fn test_map_on_text() {
    let fut: MapFuture<ReadyFuture<Text>, fn(Text) -> Int> = ready("hello").map(|s: Text| s.len());
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 5);
}

@test
fn test_map_on_bool() {
    let fut = ready(true).map(|b: Bool| -> Int { if b { 1 } else { 0 } });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), 1);
}

@test
fn test_map_on_float() {
    let fut = ready(3.14).map(|x: Float| -> Bool { x > 3.0 });
    let waker: Waker = noop_waker();
    let mut cx: Context = Context.from_waker(&waker);
    let mut f = fut;
    let result = f.poll(&mut cx);
    assert(result.is_ready());
    assert_eq(result.unwrap(), true);
}

