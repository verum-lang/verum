// =============================================================================
// map_production_test.vr - Production-grade Map and Set capacity management tests
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, map, set, reserve, shrink, capacity, production, core
// @description: Tests for Map/Set reserve(), shrink_to_fit(), shrink_to(),
//               and Set::replace(). These are critical for production workloads
//               that need explicit memory management.
// =============================================================================

module specs.core.collections.map_production_test;

mount core.*;
mount core.base.ordering.{Ordering};

// =============================================================================
// Section 1: Map::reserve() Tests
// =============================================================================

@test
fn test_map_reserve_empty() {
    let mut m: Map<Int, Int> = Map.new();
    m.reserve(100);
    assert(m.capacity() >= 100);
    assert(m.len() == 0);
    assert(m.is_empty());
}

@test
fn test_map_reserve_with_existing() {
    let mut m: Map<Int, Int> = Map.new();
    m.insert(1, 10);
    m.insert(2, 20);
    m.insert(3, 30);
    let old_len = m.len();
    m.reserve(50);
    assert(m.capacity() >= 53); // existing 3 + 50
    assert(m.len() == old_len);
    // Verify data preserved after resize
    assert(m.get(&1).unwrap() == &10);
    assert(m.get(&2).unwrap() == &20);
    assert(m.get(&3).unwrap() == &30);
}

@test
fn test_map_reserve_zero() {
    let mut m: Map<Int, Int> = Map.new();
    m.insert(1, 1);
    let cap = m.capacity();
    m.reserve(0);
    // Should not shrink
    assert(m.capacity() >= cap);
}

@test
fn test_map_reserve_already_sufficient() {
    let mut m: Map<Int, Int> = Map.with_capacity(100);
    let cap = m.capacity();
    m.reserve(10); // Already have enough capacity
    assert(m.capacity() == cap); // Should not change
}

// =============================================================================
// Section 2: Map::shrink_to_fit() Tests
// =============================================================================

@test
fn test_map_shrink_to_fit_empty() {
    let mut m: Map<Int, Int> = Map.with_capacity(100);
    assert(m.capacity() >= 100);
    m.shrink_to_fit();
    assert(m.capacity() == 0);
}

@test
fn test_map_shrink_to_fit_with_elements() {
    let mut m: Map<Int, Int> = Map.with_capacity(100);
    m.insert(1, 10);
    m.insert(2, 20);
    m.insert(3, 30);
    let old_cap = m.capacity();
    m.shrink_to_fit();
    assert(m.capacity() < old_cap);
    assert(m.capacity() >= m.len());
    // Data preserved
    assert(m.get(&1).unwrap() == &10);
    assert(m.get(&2).unwrap() == &20);
    assert(m.get(&3).unwrap() == &30);
}

@test
fn test_map_shrink_to_fit_after_removal() {
    let mut m: Map<Int, Int> = Map.new();
    for i in range(0, 50) {
        m.insert(i, i * 10);
    }
    let cap_before = m.capacity();
    // Remove most elements
    for i in range(10, 50) {
        m.remove(&i);
    }
    assert(m.len() == 10);
    m.shrink_to_fit();
    assert(m.capacity() < cap_before);
    // Remaining elements preserved
    for i in range(0, 10) {
        assert(m.contains_key(&i));
    }
}

// =============================================================================
// Section 3: Map::shrink_to() Tests
// =============================================================================

@test
fn test_map_shrink_to() {
    let mut m: Map<Int, Int> = Map.with_capacity(100);
    m.insert(1, 10);
    m.insert(2, 20);
    m.shrink_to(32);
    assert(m.capacity() >= 32);
    assert(m.capacity() <= 100);
    assert(m.get(&1).unwrap() == &10);
    assert(m.get(&2).unwrap() == &20);
}

@test
fn test_map_shrink_to_below_len() {
    let mut m: Map<Int, Int> = Map.with_capacity(100);
    for i in range(0, 20) {
        m.insert(i, i);
    }
    m.shrink_to(5); // Below len, should shrink to minimum for len
    assert(m.capacity() >= m.len());
    // All data preserved
    for i in range(0, 20) {
        assert(m.contains_key(&i));
    }
}

// =============================================================================
// Section 4: Set::reserve() Tests
// =============================================================================

@test
fn test_set_reserve_empty() {
    let mut s: Set<Int> = Set.new();
    s.reserve(100);
    assert(s.capacity() >= 100);
    assert(s.is_empty());
}

@test
fn test_set_reserve_with_existing() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    s.reserve(50);
    assert(s.capacity() >= 53);
    assert(s.contains(&1));
    assert(s.contains(&2));
    assert(s.contains(&3));
}

// =============================================================================
// Section 5: Set::shrink_to_fit() Tests
// =============================================================================

@test
fn test_set_shrink_to_fit_empty() {
    let mut s: Set<Int> = Set.with_capacity(100);
    assert(s.capacity() >= 100);
    s.shrink_to_fit();
    assert(s.capacity() == 0);
}

@test
fn test_set_shrink_to_fit_with_elements() {
    let mut s: Set<Int> = Set.with_capacity(100);
    s.insert(1);
    s.insert(2);
    s.insert(3);
    let old_cap = s.capacity();
    s.shrink_to_fit();
    assert(s.capacity() < old_cap);
    assert(s.contains(&1));
    assert(s.contains(&2));
    assert(s.contains(&3));
}

// =============================================================================
// Section 6: Set::shrink_to() Tests
// =============================================================================

@test
fn test_set_shrink_to() {
    let mut s: Set<Int> = Set.with_capacity(100);
    s.insert(1);
    s.insert(2);
    s.shrink_to(32);
    assert(s.capacity() >= 32);
    assert(s.capacity() <= 100);
}

// =============================================================================
// Section 7: Set::replace() Tests
// =============================================================================

@test
fn test_set_replace_existing() {
    let mut s: Set<Int> = Set.new();
    s.insert(42);
    let old = s.replace(42);
    assert(old.is_some());
    assert(old.unwrap() == 42);
    assert(s.contains(&42));
    assert(s.len() == 1);
}

@test
fn test_set_replace_new() {
    let mut s: Set<Int> = Set.new();
    let old = s.replace(42);
    assert(old.is_none());
    assert(s.contains(&42));
    assert(s.len() == 1);
}

// =============================================================================
// Section 8: Map Integration - Reserve then bulk insert
// =============================================================================

@test
fn test_map_reserve_bulk_insert() {
    let mut m: Map<Int, Int> = Map.new();
    let n = 100;
    m.reserve(n);
    let cap_after_reserve = m.capacity();
    for i in range(0, n) {
        m.insert(i, i * i);
    }
    // Capacity should not have changed (no resize needed)
    assert(m.capacity() == cap_after_reserve);
    assert(m.len() == n);
    // Spot check
    assert(m.get(&0).unwrap() == &0);
    assert(m.get(&50).unwrap() == &2500);
    assert(m.get(&99).unwrap() == &9801);
}

@test
fn test_map_shrink_then_grow() {
    let mut m: Map<Int, Int> = Map.new();
    for i in range(0, 50) {
        m.insert(i, i);
    }
    // Remove most
    for i in range(5, 50) {
        m.remove(&i);
    }
    m.shrink_to_fit();
    let small_cap = m.capacity();
    // Now grow again
    for i in range(100, 200) {
        m.insert(i, i);
    }
    assert(m.len() == 105); // 5 original + 100 new
    assert(m.capacity() > small_cap);
}

