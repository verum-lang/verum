@test
fn test_set_with_capacity_basic() {
    let s: Set<Int> = Set.with_capacity(50);
    assert(s.capacity() >= 50);
    assert(s.is_empty());
}

@test
fn test_set_with_capacity_insert_no_resize() {
    let mut s: Set<Int> = Set.with_capacity(10);
    let cap = s.capacity();
    for i in range(0, 10) {
        s.insert(i);
    }
    assert(s.capacity() == cap);
    assert_eq(s.len(), 10);
}

// =============================================================================
// Section 11: Capacity Tracking Through Operations
// =============================================================================

@test
fn test_map_capacity_after_clear() {
    let mut m: Map<Int, Int> = Map.new();
    for i in range(0, 50) {
        m.insert(i, i);
    }
    let cap_before = m.capacity();
    m.clear();
    // Clear doesn't necessarily free memory
    assert(m.capacity() >= 0);
    assert_eq(m.len(), 0);
}

@test
fn test_set_shrink_to_below_len() {
    let mut s: Set<Int> = Set.with_capacity(100);
    for i in range(0, 20) {
        s.insert(i);
    }
    s.shrink_to(5); // Below len
    assert(s.capacity() >= s.len());
    // All data preserved
    for i in range(0, 20) {
        assert(s.contains(&i));
    }
}

@test
fn test_map_reserve_then_shrink_cycle() {
    let mut m: Map<Int, Int> = Map.new();
    m.reserve(100);
    assert(m.capacity() >= 100);
    m.shrink_to_fit();
    assert(m.capacity() == 0);
    m.reserve(50);
    assert(m.capacity() >= 50);
}

@test
fn test_set_reserve_then_shrink_cycle() {
    let mut s: Set<Int> = Set.new();
    s.reserve(100);
    assert(s.capacity() >= 100);
    s.shrink_to_fit();
    assert(s.capacity() == 0);
    s.reserve(50);
    assert(s.capacity() >= 50);
}

// =============================================================================
// Section 12: Set Replace Edge Cases
// =============================================================================

@test
fn test_set_replace_multiple_times() {
    let mut s: Set<Int> = Set.new();
    let r1 = s.replace(42);
    assert(r1.is_none()); // First insert
    let r2 = s.replace(42);
    assert(r2.is_some()); // Second replaces existing
    let r3 = s.replace(42);
    assert(r3.is_some()); // Third replaces existing
    assert_eq(s.len(), 1); // Always just one element
}

@test
fn test_set_replace_different_values() {
    let mut s: Set<Int> = Set.new();
    s.replace(1);
    s.replace(2);
    s.replace(3);
    assert_eq(s.len(), 3);
    assert(s.contains(&1));
    assert(s.contains(&2));
    assert(s.contains(&3));
}

// =============================================================================
// Section 13: Map Capacity Invariants
// =============================================================================

@test
fn test_map_capacity_ge_len_after_inserts() {
    let mut m: Map<Int, Int> = Map.new();
    for i in range(0, 30) {
        m.insert(i, i);
        assert(m.capacity() >= m.len());
    }
}

@test
fn test_set_capacity_ge_len_after_inserts() {
    let mut s: Set<Int> = Set.new();
    for i in range(0, 30) {
        s.insert(i);
        assert(s.capacity() >= s.len());
    }
}

// =============================================================================
// Section 14: Map Reserve + Immediate Shrink
// =============================================================================

@test
fn test_map_reserve_then_immediate_shrink() {
    let mut m: Map<Int, Int> = Map.new();
    m.reserve(1000);
    assert(m.capacity() >= 1000);
    m.shrink_to_fit();
    // Empty map after shrink should have zero capacity
    assert(m.capacity() == 0);
}

@test
fn test_set_reserve_zero() {
    let mut s: Set<Int> = Set.new();
    s.reserve(0);
    // Reserving zero is a no-op
    assert(s.is_empty());
}

