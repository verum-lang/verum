@test
fn test_map_with_capacity_basic() {
    let m: Map<Int, Text> = Map.with_capacity(50);
    assert(m.capacity() >= 50);
    assert(m.is_empty());
    assert_eq(m.len(), 0);
}

@test
fn test_map_with_capacity_zero() {
    let m: Map<Text, Int> = Map.with_capacity(0);
    assert_eq(m.len(), 0);
}

@test
fn test_map_with_capacity_insert_no_resize() {
    let mut m: Map<Int, Int> = Map.with_capacity(10);
    let cap = m.capacity();
    for i in range(0, 10) {
        m.insert(i, i);
    }
    // Should not have needed to resize
    assert(m.capacity() == cap);
    assert_eq(m.len(), 10);
}

