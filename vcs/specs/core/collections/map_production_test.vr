// Section 16: Set with_capacity Edge Cases
// =============================================================================

@test
fn test_set_with_capacity_zero() {
    let s: Set<Int> = Set.with_capacity(0);
    assert(s.is_empty());
    assert_eq(s.len(), 0);
}

@test
fn test_map_with_capacity_preserves_after_clear() {
    let mut m: Map<Int, Int> = Map.with_capacity(50);
    for i in range(0, 10) {
        m.insert(i, i);
    }
    let cap = m.capacity();
    m.clear();
    assert_eq(m.len(), 0);
    // Capacity preserved after clear
    assert(m.capacity() >= 0);
}

