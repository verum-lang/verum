// =============================================================================
// Main
// =============================================================================

// =============================================================================
// Section 18: Map Reserve Double
// =============================================================================

@test
fn test_map_reserve_double() {
    let mut m: Map<Int, Int> = Map.new();
    m.reserve(50);
    assert(m.capacity() >= 50);
    m.reserve(100);
    assert(m.capacity() >= 100);
}

@test
fn test_set_reserve_already_sufficient() {
    let mut s: Set<Int> = Set.with_capacity(100);
    let cap = s.capacity();
    s.reserve(10);
    // Should not change since we already have plenty
    assert(s.capacity() == cap);
}

@test
fn test_map_shrink_to_larger_than_capacity() {
    let mut m: Map<Int, Int> = Map.with_capacity(10);
    let cap = m.capacity();
    m.shrink_to(1000); // Larger than current capacity - should be no-op
    assert(m.capacity() <= 1000);
}

@test
fn test_set_replace_then_remove() {
    let mut s: Set<Int> = Set.new();
    s.replace(10);
    assert(s.contains(&10));
    s.remove(&10);
    assert(!s.contains(&10));
    assert_eq(s.len(), 0);
}

@test
fn test_map_reserve_then_insert_single() {
    let mut m: Map<Text, Int> = Map.new();
    m.reserve(50);
    let cap = m.capacity();
    m.insert("key", 42);
    // Single insert should not trigger resize
    assert(m.capacity() == cap);
    assert(m.get(&"key").unwrap() == &42);
}

@test
fn test_map_with_capacity_shrink_preserves_data() {
    let mut m: Map<Int, Int> = Map.with_capacity(200);
    for i in range(0, 5) {
        m.insert(i, i * 100);
    }
    m.shrink_to_fit();
    assert(m.capacity() >= 5);
    // All data preserved
    assert(m.get(&0).unwrap() == &0);
    assert(m.get(&4).unwrap() == &400);
    assert_eq(m.len(), 5);
}

@test
fn test_set_shrink_to_fit_after_removal() {
    let mut s: Set<Int> = Set.new();
    for i in range(0, 50) {
        s.insert(i);
    }
    for i in range(10, 50) {
        s.remove(&i);
    }
    assert_eq(s.len(), 10);
    let cap_before = s.capacity();
    s.shrink_to_fit();
    assert(s.capacity() <= cap_before);
    // Remaining data preserved
    for i in range(0, 10) {
        assert(s.contains(&i));
    }
}

@test
fn test_set_capacity_after_remove_all() {
    let mut s: Set<Int> = Set.new();
    for i in range(0, 20) {
        s.insert(i);
    }
    for i in range(0, 20) {
        s.remove(&i);
    }
    assert_eq(s.len(), 0);
    assert(s.is_empty());
    s.shrink_to_fit();
    assert(s.capacity() == 0);
}

@test
fn test_map_reserve_exact_count() {
    let mut m: Map<Int, Int> = Map.new();
    m.reserve(25);
    assert(m.capacity() >= 25);
    for i in range(0, 25) {
        m.insert(i, i);
    }
    assert_eq(m.len(), 25);
    assert(m.capacity() >= 25);
}

@test
fn test_set_replace_returns_old_value() {
    let mut s: Set<Int> = Set.new();
    s.insert(99);
    let old = s.replace(99);
    assert(old.is_some());
    assert(old.unwrap() == 99);
    // Set size unchanged
    assert_eq(s.len(), 1);
}

// =============================================================================
// Section 19: Additional Capacity Invariant Tests
// =============================================================================

@test
fn test_map_capacity_monotonic_during_insert() {
    let mut m: Map<Int, Int> = Map.new();
    let mut prev_cap = m.capacity();
    for i in range(0, 30) {
        m.insert(i, i);
        assert(m.capacity() >= prev_cap);
        prev_cap = m.capacity();
    }
}

@test
fn test_set_capacity_monotonic_during_insert() {
    let mut s: Set<Int> = Set.new();
    let mut prev_cap = s.capacity();
    for i in range(0, 30) {
        s.insert(i);
        assert(s.capacity() >= prev_cap);
        prev_cap = s.capacity();
    }
}

@test
fn test_map_reserve_idempotent() {
    let mut m: Map<Int, Int> = Map.new();
    m.reserve(100);
    let cap1 = m.capacity();
    m.reserve(100);
    let cap2 = m.capacity();
    assert(cap1 == cap2);
}

@test
fn test_set_replace_after_remove() {
    let mut s: Set<Int> = Set.new();
    s.insert(42);
    s.remove(&42);
    assert(!s.contains(&42));
    let old = s.replace(42);
    assert(old.is_none());
    assert(s.contains(&42));
    assert_eq(s.len(), 1);
}

@test
fn test_map_clear_then_reinsert() {
    let mut m: Map<Int, Int> = Map.with_capacity(50);
    for i in range(0, 10) {
        m.insert(i, i);
    }
    m.clear();
    assert_eq(m.len(), 0);
    for i in range(100, 110) {
        m.insert(i, i * 2);
    }
    assert_eq(m.len(), 10);
    assert(m.get(&100).unwrap() == &200);
    assert(m.get(&109).unwrap() == &218);
}

@test
fn test_set_shrink_then_grow_again() {
    let mut s: Set<Int> = Set.new();
    for i in range(0, 50) {
        s.insert(i);
    }
    for i in range(5, 50) {
        s.remove(&i);
    }
    s.shrink_to_fit();
    let small_cap = s.capacity();
    for i in range(100, 200) {
        s.insert(i);
    }
    assert_eq(s.len(), 105);
    assert(s.capacity() > small_cap);
}

@test
fn test_map_shrink_to_fit_preserves_all_data() {
    let mut m: Map<Int, Int> = Map.with_capacity(200);
    for i in range(0, 10) {
        m.insert(i, i * 100);
    }
    m.shrink_to_fit();
    assert(m.capacity() >= 10);
    for i in range(0, 10) {
        assert(m.contains_key(&i));
        assert(m.get(&i).unwrap() == &(i * 100));
    }
}

@test
fn test_set_with_capacity_then_shrink_cycle() {
    let mut s: Set<Int> = Set.with_capacity(200);
    for i in range(0, 5) {
        s.insert(i);
    }
    s.shrink_to_fit();
    assert(s.capacity() >= 5);
    s.reserve(100);
    assert(s.capacity() >= 105);
    s.shrink_to(50);
    assert(s.capacity() >= 5);
    assert(s.capacity() <= 200);
    for i in range(0, 5) {
        assert(s.contains(&i));
    }
}

fn main() {
    // Tests run via @test annotations
}
