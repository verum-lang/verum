@test
fn test_map_shrink_to_zero_empty() {
    let mut m: Map<Int, Int> = Map.with_capacity(100);
    m.shrink_to(0);
    assert(m.capacity() == 0);
}

@test
fn test_map_shrink_to_exact_len() {
    let mut m: Map<Int, Int> = Map.with_capacity(100);
    for i in range(0, 10) {
        m.insert(i, i);
    }
    m.shrink_to(10);
    assert(m.capacity() >= 10);
    assert(m.len() == 10);
}

