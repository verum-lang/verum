// Section 17: Set shrink_to
// =============================================================================

@test
fn test_set_shrink_to_zero_empty() {
    let mut s: Set<Int> = Set.with_capacity(100);
    s.shrink_to(0);
    assert(s.capacity() == 0);
}

@test
fn test_set_shrink_to_exact() {
    let mut s: Set<Int> = Set.with_capacity(100);
    s.insert(1);
    s.insert(2);
    s.shrink_to(32);
    assert(s.capacity() >= 2);
    assert(s.capacity() <= 100);
    assert(s.contains(&1));
    assert(s.contains(&2));
