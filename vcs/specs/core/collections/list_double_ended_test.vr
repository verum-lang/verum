// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, list, iterator, double_ended, rfold, next_back, nth_back
// @description: Tests for DoubleEndedIterator on ListIter, ListIterMut, IntoList, Drain
// NOTE: rfind() skipped due to type checker limitation resolving Self.Item through protocol default methods

mount core.*;
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: ListIter next_back
// =============================================================================

@test
fn test_list_iter_next_back_basic() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.iter();
    assert_eq(*iter.next_back().unwrap(), 5);
    assert_eq(*iter.next_back().unwrap(), 4);
    assert_eq(*iter.next_back().unwrap(), 3);
    assert_eq(*iter.next_back().unwrap(), 2);
    assert_eq(*iter.next_back().unwrap(), 1);
    assert(iter.next_back().is_none());
}

@test
fn test_list_iter_next_back_empty() {
    let list: List<Int> = [];
    let mut iter = list.iter();
    assert(iter.next_back().is_none());
}

@test
fn test_list_iter_next_back_single() {
    let list = [42];
    let mut iter = list.iter();
    assert_eq(*iter.next_back().unwrap(), 42);
    assert(iter.next_back().is_none());
}

@test
fn test_list_iter_bidirectional() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.iter();
    assert_eq(*iter.next().unwrap(), 1);
    assert_eq(*iter.next_back().unwrap(), 5);
    assert_eq(*iter.next().unwrap(), 2);
    assert_eq(*iter.next_back().unwrap(), 4);
    assert_eq(*iter.next().unwrap(), 3);
    assert(iter.next().is_none());
    assert(iter.next_back().is_none());
}

@test
fn test_list_iter_bidirectional_meet_in_middle() {
    let list = [10, 20, 30, 40];
    let mut iter = list.iter();
    assert_eq(*iter.next().unwrap(), 10);
    assert_eq(*iter.next_back().unwrap(), 40);
    assert_eq(*iter.next().unwrap(), 20);
    assert_eq(*iter.next_back().unwrap(), 30);
    assert(iter.next().is_none());
    assert(iter.next_back().is_none());
}

@test
fn test_list_iter_all_from_back() {
    let list = [10, 20, 30];
    let mut iter = list.iter();
    assert_eq(*iter.next_back().unwrap(), 30);
    assert_eq(*iter.next_back().unwrap(), 20);
    assert_eq(*iter.next_back().unwrap(), 10);
    assert(iter.next().is_none());
}

// =============================================================================
// Section 2: ListIter rfold
// =============================================================================

@test
fn test_list_iter_rfold_sum() {
    let list = [1, 2, 3, 4, 5];
    fn add(acc: Int, x: &Int) -> Int { acc + *x }
    let result = list.iter().rfold(0, add);
    assert_eq(result, 15);
}

@test
fn test_list_iter_rfold_build_list() {
    let list = [1, 2, 3];
    fn append(mut acc: List<Int>, x: &Int) -> List<Int> {
        acc.push(*x);
        acc
    }
    let result = list.iter().rfold(List.new(), append);
    // rfold processes from back: 3, 2, 1
    assert_eq(result[0], 3);
    assert_eq(result[1], 2);
    assert_eq(result[2], 1);
}

@test
fn test_list_iter_rfold_empty() {
    let list: List<Int> = [];
    fn add(acc: Int, x: &Int) -> Int { acc + *x }
    let result = list.iter().rfold(0, add);
    assert_eq(result, 0);
}

@test
fn test_list_iter_rfold_product() {
    let list = [1, 2, 3, 4];
    fn mul(acc: Int, x: &Int) -> Int { acc * *x }
    let result = list.iter().rfold(1, mul);
    assert_eq(result, 24);
}

@test
fn test_list_iter_rfold_vs_fold() {
    let list = [1, 2, 3, 4, 5];
    fn add(acc: Int, x: &Int) -> Int { acc + *x }
    let forward = list.iter().fold(0, add);
    let backward = list.iter().rfold(0, add);
    assert_eq(forward, backward);
}

@test
fn test_list_iter_rfold_non_commutative_order() {
    // rfold processes elements in reverse order
    let list = [1, 2, 3];
    fn append(mut acc: List<Int>, x: &Int) -> List<Int> {
        acc.push(*x);
        acc
    }
    let fwd = list.iter().fold(List.new(), append);
    let bwd = list.iter().rfold(List.new(), append);
    // fold: [1, 2, 3], rfold: [3, 2, 1]
    assert_eq(fwd[0], 1);
    assert_eq(bwd[0], 3);
}

// =============================================================================
// Section 3: ListIter nth_back
// =============================================================================

@test
fn test_list_iter_nth_back_basic() {
    let list = [10, 20, 30, 40, 50];
    let mut iter = list.iter();
    assert_eq(*iter.nth_back(0).unwrap(), 50);
}

@test
fn test_list_iter_nth_back_middle() {
    let list = [10, 20, 30, 40, 50];
    let mut iter = list.iter();
    assert_eq(*iter.nth_back(2).unwrap(), 30);
}

@test
fn test_list_iter_nth_back_last() {
    let list = [10, 20, 30, 40, 50];
    let mut iter = list.iter();
    assert_eq(*iter.nth_back(4).unwrap(), 10);
}

@test
fn test_list_iter_nth_back_out_of_bounds() {
    let list = [10, 20, 30];
    let mut iter = list.iter();
    assert(iter.nth_back(5).is_none());
}

@test
fn test_list_iter_nth_back_after_next() {
    let list = [10, 20, 30, 40, 50];
    let mut iter = list.iter();
    iter.next(); // skip 10
    assert_eq(*iter.nth_back(0).unwrap(), 50);
    // remaining: [20, 30, 40]
    assert_eq(*iter.nth_back(0).unwrap(), 40);
}

// =============================================================================
// Section 4: ListIter advance_back_by
// =============================================================================

@test
fn test_list_iter_advance_back_by() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.iter();
    let result = iter.advance_back_by(2);
    assert(result.is_ok());
    assert_eq(*iter.next_back().unwrap(), 3);
}

@test
fn test_list_iter_advance_back_by_all() {
    let list = [1, 2, 3];
    let mut iter = list.iter();
    let result = iter.advance_back_by(3);
    assert(result.is_ok());
    assert(iter.next_back().is_none());
    assert(iter.next().is_none());
}

@test
fn test_list_iter_advance_back_by_too_many() {
    let list = [1, 2, 3];
    let mut iter = list.iter();
    let result = iter.advance_back_by(5);
    assert(result.is_err());
}

@test
fn test_list_iter_advance_back_by_zero() {
    let list = [1, 2, 3];
    let mut iter = list.iter();
    let result = iter.advance_back_by(0);
    assert(result.is_ok());
    assert_eq(*iter.next_back().unwrap(), 3);
}

// =============================================================================
// Section 5: IntoList (owning iterator) DoubleEndedIterator
// =============================================================================

@test
fn test_into_list_next_back() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.into_iter();
    assert_eq(iter.next_back().unwrap(), 5);
    assert_eq(iter.next_back().unwrap(), 4);
    assert_eq(iter.next_back().unwrap(), 3);
    assert_eq(iter.next_back().unwrap(), 2);
    assert_eq(iter.next_back().unwrap(), 1);
    assert(iter.next_back().is_none());
}

@test
fn test_into_list_bidirectional() {
    let list = [10, 20, 30, 40];
    let mut iter = list.into_iter();
    assert_eq(iter.next().unwrap(), 10);
    assert_eq(iter.next_back().unwrap(), 40);
    assert_eq(iter.next().unwrap(), 20);
    assert_eq(iter.next_back().unwrap(), 30);
    assert(iter.next().is_none());
}

@test
fn test_into_list_next_back_empty() {
    let list: List<Int> = [];
    let mut iter = list.into_iter();
    assert(iter.next_back().is_none());
}

@test
fn test_into_list_rfold() {
    let list = [1, 2, 3];
    fn add(acc: Int, x: Int) -> Int { acc + x }
    let result = list.into_iter().rfold(0, add);
    assert_eq(result, 6);
}

@test
fn test_into_list_rfold_order() {
    let list = [1, 2, 3];
    fn append(mut acc: List<Int>, x: Int) -> List<Int> {
        acc.push(x);
        acc
    }
    let result = list.into_iter().rfold(List.new(), append);
    assert_eq(result[0], 3);
    assert_eq(result[1], 2);
    assert_eq(result[2], 1);
}

@test
fn test_into_list_nth_back() {
    let list = [10, 20, 30, 40, 50];
    let mut iter = list.into_iter();
    assert_eq(iter.nth_back(1).unwrap(), 40);
    // remaining: [10, 20, 30]
    assert_eq(iter.nth_back(0).unwrap(), 30);
}

// =============================================================================
// Section 6: ListIterMut DoubleEndedIterator
// =============================================================================

@test
fn test_list_iter_mut_next_back() {
    let mut list = [1, 2, 3, 4, 5];
    let mut iter = list.iter_mut();
    let last = iter.next_back().unwrap();
    *last = 50;
    let second_last = iter.next_back().unwrap();
    *second_last = 40;
    assert_eq(list[3], 40);
    assert_eq(list[4], 50);
}

@test
fn test_list_iter_mut_bidirectional() {
    let mut list = [1, 2, 3, 4];
    let mut iter = list.iter_mut();
    let first = iter.next().unwrap();
    *first = 10;
    let last = iter.next_back().unwrap();
    *last = 40;
    assert_eq(list[0], 10);
    assert_eq(list[3], 40);
}

@test
fn test_list_iter_mut_next_back_empty() {
    let mut list: List<Int> = [];
    let mut iter = list.iter_mut();
    assert(iter.next_back().is_none());
}

@test
fn test_list_iter_mut_all_from_back() {
    let mut list = [1, 2, 3];
    let mut iter = list.iter_mut();
    let third = iter.next_back().unwrap();
    *third = 30;
    let second = iter.next_back().unwrap();
    *second = 20;
    let first = iter.next_back().unwrap();
    *first = 10;
    assert(iter.next_back().is_none());
    assert_eq(list[0], 10);
    assert_eq(list[1], 20);
    assert_eq(list[2], 30);
}

// =============================================================================
// Section 7: Drain DoubleEndedIterator
// =============================================================================

@test
fn test_drain_next_back() {
    let mut list = [1, 2, 3, 4, 5];
    let mut drain = list.drain(1, 4); // drains [2, 3, 4]
    assert_eq(drain.next_back().unwrap(), 4);
    assert_eq(drain.next_back().unwrap(), 3);
    assert_eq(drain.next_back().unwrap(), 2);
    assert(drain.next_back().is_none());
}

@test
fn test_drain_bidirectional() {
    let mut list = [10, 20, 30, 40, 50];
    let mut drain = list.drain(0, 5);
    assert_eq(drain.next().unwrap(), 10);
    assert_eq(drain.next_back().unwrap(), 50);
    assert_eq(drain.next().unwrap(), 20);
    assert_eq(drain.next_back().unwrap(), 40);
    assert_eq(drain.next().unwrap(), 30);
    assert(drain.next().is_none());
}

@test
fn test_drain_next_back_empty_range() {
    let mut list = [1, 2, 3];
    let mut drain = list.drain(1, 1);
    assert(drain.next_back().is_none());
}

// =============================================================================
// Section 8: size_hint with bidirectional consumption
// =============================================================================

@test
fn test_list_iter_size_hint_after_back() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.iter();
    let hint = iter.size_hint();
    assert_eq(hint.0, 5);

    iter.next();
    let hint2 = iter.size_hint();
    assert_eq(hint2.0, 4);

    iter.next_back();
    let hint3 = iter.size_hint();
    assert_eq(hint3.0, 3);
}

@test
fn test_into_list_size_hint_bidirectional() {
    let list = [1, 2, 3, 4];
    let mut iter = list.into_iter();
    assert_eq(iter.size_hint().0, 4);
    iter.next();
    assert_eq(iter.size_hint().0, 3);
    iter.next_back();
    assert_eq(iter.size_hint().0, 2);
}

// =============================================================================
// Section 9: Large list DoubleEndedIterator
// =============================================================================

@test
fn test_list_bidirectional_large() {
    let mut list: List<Int> = List.with_capacity(100);
    let mut i = 0;
    while i < 100 {
        list.push(i);
        i = i + 1;
    }
    let mut iter = list.iter();
    let mut j = 0;
    while j < 10 {
        let expected = j;
        let front_val = *iter.next().unwrap();
        assert_eq(front_val, expected);
        j = j + 1;
    }
    let mut k = 0;
    while k < 10 {
        let expected = 99 - k;
        let back_val = *iter.next_back().unwrap();
        assert_eq(back_val, expected);
        k = k + 1;
    }
    let count = iter.count();
    assert_eq(count, 80);
}

@test
fn test_into_list_bidirectional_large() {
    let mut list: List<Int> = List.with_capacity(50);
    let mut i = 0;
    while i < 50 {
        list.push(i);
        i = i + 1;
    }
    let mut iter = list.into_iter();
    let mut j = 0;
    while j < 5 {
        let expected = j;
        assert_eq(iter.next().unwrap(), expected);
        j = j + 1;
    }
    let mut k = 0;
    while k < 5 {
        let expected = 49 - k;
        assert_eq(iter.next_back().unwrap(), expected);
        k = k + 1;
    }
    let count = iter.count();
    assert_eq(count, 40);
}

// =============================================================================
// Section 10: Edge cases
// =============================================================================

@test
fn test_list_iter_alternating_exhaust() {
    let list = [1, 2, 3];
    let mut iter = list.iter();
    assert_eq(*iter.next().unwrap(), 1);
    assert_eq(*iter.next_back().unwrap(), 3);
    assert_eq(*iter.next().unwrap(), 2);
    assert(iter.next().is_none());
    assert(iter.next_back().is_none());
    // Double check - should still be none
    assert(iter.next().is_none());
    assert(iter.next_back().is_none());
}

@test
fn test_list_iter_next_back_then_fold() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.iter();
    iter.next_back(); // skip 5
    iter.next_back(); // skip 4
    fn add(acc: Int, x: &Int) -> Int { acc + *x }
    let result = iter.fold(0, add); // fold remaining [1, 2, 3]
    assert_eq(result, 6);
}

@test
fn test_list_iter_next_then_rfold() {
    let list = [1, 2, 3, 4, 5];
    let mut iter = list.iter();
    iter.next(); // skip 1
    iter.next(); // skip 2
    fn add(acc: Int, x: &Int) -> Int { acc + *x }
    let result = iter.rfold(0, add); // rfold remaining [3, 4, 5]
    assert_eq(result, 12);
}

@test
fn test_list_iter_two_elements() {
    let list = [1, 2];
    let mut iter = list.iter();
    assert_eq(*iter.next().unwrap(), 1);
    assert_eq(*iter.next_back().unwrap(), 2);
    assert(iter.next().is_none());
    assert(iter.next_back().is_none());
}
