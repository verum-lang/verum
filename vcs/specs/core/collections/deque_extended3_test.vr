@test
fn test_deque_rposition_found() {
    let mut d = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);

    assert_eq(d.rposition(&20).unwrap(), 1);
}

@test
fn test_deque_rposition_last() {
    let mut d = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(10);

    assert_eq(d.rposition(&10).unwrap(), 2);
}

@test
fn test_deque_rposition_not_found() {
    let mut d = Deque.new();
    d.push_back(10);
    d.push_back(20);

    assert(d.rposition(&30).is_none());
}

// =============================================================================
// intersperse tests
// =============================================================================

@test
fn test_deque_intersperse_basic() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let result = d.intersperse(0);
    assert_eq(result.len(), 5);
    assert_eq(*result.get(0).unwrap(), 1);
    assert_eq(*result.get(1).unwrap(), 0);
    assert_eq(*result.get(2).unwrap(), 2);
    assert_eq(*result.get(3).unwrap(), 0);
    assert_eq(*result.get(4).unwrap(), 3);
}

@test
fn test_deque_intersperse_single() {
    let mut d = Deque.new();
    d.push_back(42);

    let result = d.intersperse(0);
    assert_eq(result.len(), 1);
    assert_eq(*result.get(0).unwrap(), 42);
}

@test
fn test_deque_intersperse_empty() {
    let d: Deque<Int> = Deque.new();
    let result = d.intersperse(0);
    assert_eq(result.len(), 0);
}

@test
fn test_deque_intersperse_with_basic() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let mut counter = 0;
    let result = d.intersperse_with(|| {
        counter = counter + 1;
        counter * 100
    });
    assert_eq(result.len(), 5);
    assert_eq(*result.get(0).unwrap(), 1);
    assert_eq(*result.get(2).unwrap(), 2);
    assert_eq(*result.get(4).unwrap(), 3);
}

// =============================================================================
// Integration tests
// =============================================================================

@test
fn test_flat_map_then_reduce() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    // Duplicate each element, then sum
    let sum = d.flat_map(|v| {
        let mut l: List<Int> = [];
        l.push(*v);
        l.push(*v);
        l
    }).reduce(|acc, v| acc + *v);
    assert_eq(sum.unwrap(), 12);  // (1+1) + (2+2) + (3+3)
}

@test
fn test_filter_then_intersperse() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);
    d.push_back(5);

    let result = d.filter(|v| *v % 2 != 0).intersperse(0);
    // [1, 0, 3, 0, 5]
    assert_eq(result.len(), 5);
    assert_eq(*result.get(0).unwrap(), 1);
    assert_eq(*result.get(1).unwrap(), 0);
    assert_eq(*result.get(2).unwrap(), 3);
}
