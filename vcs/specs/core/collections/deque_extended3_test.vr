// @test: typecheck-pass
// @level: L1
// @tags: collections, deque, reduce, flat_map, starts_with, ends_with, position, intersperse
// @description: Tests for Deque extended utility methods: reduce, flat_map, starts_with, ends_with, position, rposition, intersperse

mount core.collections.deque.{Deque};

// =============================================================================
// reduce tests
// =============================================================================

@test
fn test_deque_reduce_sum() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);

    let sum = d.reduce(|acc, v| acc + *v);
    assert(sum.is_some());
    assert_eq(sum.unwrap(), 10);
}

@test
fn test_deque_reduce_max() {
    let mut d = Deque.new();
    d.push_back(3);
    d.push_back(7);
    d.push_back(1);
    d.push_back(5);

    let mx = d.reduce(|acc, v| if *v > acc { *v } else { acc });
    assert_eq(mx.unwrap(), 7);
}

@test
fn test_deque_reduce_single() {
    let mut d = Deque.new();
    d.push_back(42);

    let result = d.reduce(|acc, v| acc + *v);
    assert_eq(result.unwrap(), 42);
}

@test
fn test_deque_reduce_empty() {
    let d: Deque<Int> = Deque.new();
    let result = d.reduce(|acc, v| acc + *v);
    assert(result.is_none());
}

// =============================================================================
// flat_map tests
// =============================================================================

@test
fn test_deque_flat_map_basic() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let result = d.flat_map(|v| {
        let mut l: List<Int> = [];
        l.push(*v);
        l.push(*v * 10);
        l
    });
    assert_eq(result.len(), 6);
    assert_eq(*result.get(0).unwrap(), 1);
    assert_eq(*result.get(1).unwrap(), 10);
    assert_eq(*result.get(2).unwrap(), 2);
    assert_eq(*result.get(3).unwrap(), 20);
    assert_eq(*result.get(4).unwrap(), 3);
    assert_eq(*result.get(5).unwrap(), 30);
}

@test
fn test_deque_flat_map_empty_inner() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);

    let result = d.flat_map(|_v| {
        let l: List<Int> = [];
        l
    });
    assert_eq(result.len(), 0);
}

@test
fn test_deque_flat_map_empty_deque() {
    let d: Deque<Int> = Deque.new();
    let result = d.flat_map(|v| {
        let mut l: List<Int> = [];
        l.push(*v);
        l
    });
    assert_eq(result.len(), 0);
}

// =============================================================================
// starts_with tests
// =============================================================================

@test
fn test_deque_starts_with_basic() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let mut prefix = Deque.new();
    prefix.push_back(1);
    prefix.push_back(2);

    assert(d.starts_with(&prefix));
}

@test
fn test_deque_starts_with_full_match() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);

    let mut prefix = Deque.new();
    prefix.push_back(1);
    prefix.push_back(2);

    assert(d.starts_with(&prefix));
}

@test
fn test_deque_starts_with_no_match() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let mut prefix = Deque.new();
    prefix.push_back(2);
    prefix.push_back(3);

    assert(!d.starts_with(&prefix));
}

@test
fn test_deque_starts_with_empty_prefix() {
    let mut d = Deque.new();
    d.push_back(1);

    let prefix: Deque<Int> = Deque.new();
    assert(d.starts_with(&prefix));
}

@test
fn test_deque_starts_with_prefix_longer() {
    let mut d = Deque.new();
    d.push_back(1);

    let mut prefix = Deque.new();
    prefix.push_back(1);
    prefix.push_back(2);

    assert(!d.starts_with(&prefix));
}

