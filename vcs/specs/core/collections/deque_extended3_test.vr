@test
fn test_deque_ends_with_basic() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let mut suffix = Deque.new();
    suffix.push_back(2);
    suffix.push_back(3);

    assert(d.ends_with(&suffix));
}

@test
fn test_deque_ends_with_full_match() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);

    let mut suffix = Deque.new();
    suffix.push_back(1);
    suffix.push_back(2);

    assert(d.ends_with(&suffix));
}

@test
fn test_deque_ends_with_no_match() {
    let mut d = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let mut suffix = Deque.new();
    suffix.push_back(1);
    suffix.push_back(2);

    assert(!d.ends_with(&suffix));
}

@test
fn test_deque_ends_with_empty_suffix() {
    let mut d = Deque.new();
    d.push_back(1);

    let suffix: Deque<Int> = Deque.new();
    assert(d.ends_with(&suffix));
}

// =============================================================================
// position tests
// =============================================================================

@test
fn test_deque_position_found() {
    let mut d = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);

    assert_eq(d.position(&20).unwrap(), 1);
}

@test
fn test_deque_position_first() {
    let mut d = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(10);

    assert_eq(d.position(&10).unwrap(), 0);
}

@test
fn test_deque_position_not_found() {
    let mut d = Deque.new();
    d.push_back(10);
    d.push_back(20);

    assert(d.position(&30).is_none());
}

@test
fn test_deque_position_empty() {
    let d: Deque<Int> = Deque.new();
    assert(d.position(&1).is_none());
}

