// =============================================================================
// slice_split_iter_test.vr - Slice split iterator tests
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: core, collections, slice, split, iterator
// @description: Tests for Split, SplitInclusive, SplitN, RSplit, RSplitN iterators.
// =============================================================================

mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.{List};

// =============================================================================
// SECTION 1: Split
// =============================================================================

@test
fn test_split_basic() {
    let data: List<Int> = [1, 0, 2, 0, 3];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);

    // First part: [1]
    let part = iter.next();
    assert(part.is_some());

    // Second part: [2]
    let part = iter.next();
    assert(part.is_some());

    // Third part: [3]
    let part = iter.next();
    assert(part.is_some());

    // No more
    assert(iter.next() is None);
}

@test
fn test_split_no_match() {
    let data: List<Int> = [1, 2, 3];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);

    // Entire slice returned as one part
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_all_match() {
    let data: List<Int> = [0, 0, 0];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);

    // 4 empty slices: [], [], [], []
    let p1 = iter.next();
    assert(p1.is_some());

    let p2 = iter.next();
    assert(p2.is_some());

    let p3 = iter.next();
    assert(p3.is_some());

    let p4 = iter.next();
    assert(p4.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_empty_slice() {
    let data: List<Int> = [];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);

    // One empty slice
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_adjacent_separators() {
    let data: List<Int> = [1, 0, 0, 2];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);

    // [1], [], [2]
    let p1 = iter.next();
    assert(p1.is_some());

    let p2 = iter.next();
    assert(p2.is_some());

    let p3 = iter.next();
    assert(p3.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_leading_separator() {
    let data: List<Int> = [0, 1, 2];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);

    // [], [1, 2]
    let p1 = iter.next();
    assert(p1.is_some());

    let p2 = iter.next();
    assert(p2.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_trailing_separator() {
    let data: List<Int> = [1, 2, 0];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);

    // [1, 2], []
    let p1 = iter.next();
    assert(p1.is_some());

    let p2 = iter.next();
    assert(p2.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_count() {
    let data: List<Int> = [1, 0, 2, 0, 3, 0, 4];
    let slice = data.as_slice();
    let count = slice.split(|x| *x == 0).count();
    assert_eq(count, 4);
}

// =============================================================================
// SECTION 2: SplitInclusive
// =============================================================================

@test
fn test_split_inclusive_basic() {
    let data: List<Int> = [1, 2, 0, 3, 4, 0, 5];
    let slice = data.as_slice();
    let mut iter = slice.split_inclusive(|x| *x == 0);

    // [1, 2, 0]
    let p1 = iter.next();
    assert(p1.is_some());

    // [3, 4, 0]
    let p2 = iter.next();
    assert(p2.is_some());

    // [5]
    let p3 = iter.next();
    assert(p3.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_inclusive_no_match() {
    let data: List<Int> = [1, 2, 3];
    let slice = data.as_slice();
    let mut iter = slice.split_inclusive(|x| *x == 0);

    // Entire slice
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_inclusive_last_is_match() {
    let data: List<Int> = [1, 2, 0];
    let slice = data.as_slice();
    let mut iter = slice.split_inclusive(|x| *x == 0);

    // [1, 2, 0]
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_split_inclusive_count() {
    let data: List<Int> = [1, 0, 2, 0, 3];
    let slice = data.as_slice();
    let count = slice.split_inclusive(|x| *x == 0).count();
    assert_eq(count, 3);
}

// =============================================================================
// SECTION 3: SplitN
// =============================================================================

@test
fn test_splitn_basic() {
    let data: List<Int> = [1, 0, 2, 0, 3, 0, 4];
    let slice = data.as_slice();
    let mut iter = slice.splitn(3, |x| *x == 0);

    // [1]
    let p1 = iter.next();
    assert(p1.is_some());

    // [2]
    let p2 = iter.next();
    assert(p2.is_some());

    // [3, 0, 4] (remainder)
    let p3 = iter.next();
    assert(p3.is_some());

    assert(iter.next() is None);
}

@test
fn test_splitn_one() {
    let data: List<Int> = [1, 0, 2, 0, 3];
    let slice = data.as_slice();
    let mut iter = slice.splitn(1, |x| *x == 0);

    // Entire slice returned
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_splitn_zero() {
    let data: List<Int> = [1, 0, 2];
    let slice = data.as_slice();
    let mut iter = slice.splitn(0, |x| *x == 0);

    // No parts returned
    assert(iter.next() is None);
}

@test
fn test_splitn_more_than_matches() {
    let data: List<Int> = [1, 0, 2];
    let slice = data.as_slice();
    let mut iter = slice.splitn(10, |x| *x == 0);

    // [1], [2] - only 2 parts even though n=10
    let p1 = iter.next();
    assert(p1.is_some());
    let p2 = iter.next();
    assert(p2.is_some());

    assert(iter.next() is None);
}

@test
fn test_splitn_count() {
    let data: List<Int> = [1, 0, 2, 0, 3, 0, 4, 0, 5];
    let slice = data.as_slice();
    let count = slice.splitn(3, |x| *x == 0).count();
    assert_eq(count, 3);
}

// =============================================================================
// SECTION 4: RSplit
// =============================================================================

@test
fn test_rsplit_basic() {
    let data: List<Int> = [1, 0, 2, 0, 3];
    let slice = data.as_slice();
    let mut iter = slice.rsplit(|x| *x == 0);

    // [3] (from end)
    let p1 = iter.next();
    assert(p1.is_some());

    // [2]
    let p2 = iter.next();
    assert(p2.is_some());

    // [1]
    let p3 = iter.next();
    assert(p3.is_some());

    assert(iter.next() is None);
}

@test
fn test_rsplit_no_match() {
    let data: List<Int> = [1, 2, 3];
    let slice = data.as_slice();
    let mut iter = slice.rsplit(|x| *x == 0);

    // Entire slice
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_rsplit_empty() {
    let data: List<Int> = [];
    let slice = data.as_slice();
    let mut iter = slice.rsplit(|x| *x == 0);

    // One empty slice
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_rsplit_count() {
    let data: List<Int> = [1, 0, 2, 0, 3];
    let slice = data.as_slice();
    let count = slice.rsplit(|x| *x == 0).count();
    assert_eq(count, 3);
}

// =============================================================================
// SECTION 5: RSplitN
// =============================================================================

@test
fn test_rsplitn_basic() {
    let data: List<Int> = [1, 0, 2, 0, 3, 0, 4];
    let slice = data.as_slice();
    let mut iter = slice.rsplitn(3, |x| *x == 0);

    // [4] (from end)
    let p1 = iter.next();
    assert(p1.is_some());

    // [3]
    let p2 = iter.next();
    assert(p2.is_some());

    // [1, 0, 2] (remainder from beginning)
    let p3 = iter.next();
    assert(p3.is_some());

    assert(iter.next() is None);
}

@test
fn test_rsplitn_one() {
    let data: List<Int> = [1, 0, 2, 0, 3];
    let slice = data.as_slice();
    let mut iter = slice.rsplitn(1, |x| *x == 0);

    // Entire slice returned
    let part = iter.next();
    assert(part.is_some());

    assert(iter.next() is None);
}

@test
fn test_rsplitn_count() {
    let data: List<Int> = [1, 0, 2, 0, 3, 0, 4, 0, 5];
    let slice = data.as_slice();
    let count = slice.rsplitn(3, |x| *x == 0).count();
    assert_eq(count, 3);
}

// =============================================================================
// SECTION 6: Split with various predicates
// =============================================================================

@test
fn test_split_even_numbers() {
    let data: List<Int> = [1, 2, 3, 4, 5];
    let slice = data.as_slice();
    // Split on even numbers
    let count = slice.split(|x| *x % 2 == 0).count();
    assert_eq(count, 3);  // [1], [3], [5]
}

@test
fn test_split_greater_than_threshold() {
    let data: List<Int> = [1, 5, 2, 6, 3];
    let slice = data.as_slice();
    // Split on values > 4
    let count = slice.split(|x| *x > 4).count();
    assert_eq(count, 3);  // [1], [2], [3]
}

// =============================================================================
// SECTION 7: Fused behavior
// =============================================================================

@test
fn test_split_fused() {
    let data: List<Int> = [1, 0, 2];
    let slice = data.as_slice();
    let mut iter = slice.split(|x| *x == 0);
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_rsplit_fused() {
    let data: List<Int> = [1, 0, 2];
    let slice = data.as_slice();
    let mut iter = slice.rsplit(|x| *x == 0);
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_splitn_fused() {
    let data: List<Int> = [1, 0, 2];
    let slice = data.as_slice();
    let mut iter = slice.splitn(2, |x| *x == 0);
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}
