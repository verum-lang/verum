@test
fn test_map_eq_empty_maps() {
    let m1: Map<Text, Int> = Map.new();
    let m2: Map<Text, Int> = Map.new();
    assert(m1 == m2);
}

@test
fn test_map_eq_different_sizes() {
    let mut m1: Map<Text, Int> = Map.new();
    m1.insert("a", 1);
    let mut m2: Map<Text, Int> = Map.new();
    m2.insert("a", 1);
    m2.insert("b", 2);
    assert(!(m1 == m2));
}

@test
fn test_map_eq_same_keys_different_values() {
    let mut m1: Map<Text, Int> = Map.new();
    m1.insert("a", 1);
    m1.insert("b", 2);
    let mut m2: Map<Text, Int> = Map.new();
    m2.insert("a", 1);
    m2.insert("b", 99);
    assert(!(m1 == m2));
}

@test
fn test_map_eq_different_keys_same_values() {
    let mut m1: Map<Text, Int> = Map.new();
    m1.insert("a", 1);
    let mut m2: Map<Text, Int> = Map.new();
    m2.insert("b", 1);
    assert(!(m1 == m2));
}

@test
fn test_map_eq_reflexive() {
    let mut m: Map<Text, Int> = Map.new();
    m.insert("x", 42);
    let clone = m.clone();
    assert(m == clone);
}

// =============================================================================
// Section: Drain — Deeper Tests
// =============================================================================

@test
fn test_map_drain_single_entry() {
    let mut m: Map<Text, Int> = Map.new();
    m.insert("only", 42);
    let mut val = 0;
    for pair in m.drain() {
        val = pair.1;
    }
    assert_eq(val, 42);
    assert(m.is_empty());
}

@test
fn test_map_drain_large() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..50 {
        m.insert(i, i);
    }
    let mut count = 0;
    for _pair in m.drain() {
        count = count + 1;
    }
    assert_eq(count, 50);
    assert(m.is_empty());
}

@test
fn test_map_drain_then_insert() {
    let mut m: Map<Text, Int> = Map.new();
    m.insert("a", 1);
    m.insert("b", 2);
    for _pair in m.drain() {}
    assert(m.is_empty());
    // Reuse after drain
    m.insert("c", 3);
    assert_eq(m.len(), 1);
    assert_eq(*m.get(&"c").unwrap(), 3);
}

// =============================================================================
// Section: Retain — Deeper Tests
// =============================================================================

@test
fn test_map_retain_empty() {
    let mut m: Map<Text, Int> = Map.new();
    m.retain(|_k, _v| true);
    assert(m.is_empty());
}

@test
fn test_map_retain_large_filter_half() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..100 {
        m.insert(i, i);
    }
    // Keep only even keys
    m.retain(|k, _v| *k % 2 == 0);
    assert_eq(m.len(), 50);
    assert(m.contains_key(&0));
    assert(!m.contains_key(&1));
    assert(m.contains_key(&98));
    assert(!m.contains_key(&99));
}

@test
fn test_map_retain_by_value_threshold() {
    let mut m: Map<Text, Int> = Map.new();
    m.insert("low", 5);
    m.insert("mid", 50);
    m.insert("high", 500);
    m.retain(|_k, v| *v >= 50);
    assert_eq(m.len(), 2);
    assert(!m.contains_key(&"low"));
    assert(m.contains_key(&"mid"));
    assert(m.contains_key(&"high"));
}

@test
fn test_map_retain_then_insert() {
    let mut m: Map<Int, Int> = Map.new();
    m.insert(1, 10);
    m.insert(2, 20);
    m.insert(3, 30);
    m.retain(|k, _v| *k <= 1);
    assert_eq(m.len(), 1);
    m.insert(4, 40);
    assert_eq(m.len(), 2);
    assert(m.contains_key(&1));
    assert(m.contains_key(&4));
}

// =============================================================================
// Section: get_or_insert — Additional Patterns
// =============================================================================

@test
fn test_map_get_or_insert_bool() {
    let mut m: Map<Text, Bool> = Map.new();
    let val = m.get_or_insert("flag", true);
    assert_eq(*val, true);
    let val2 = m.get_or_insert("flag", false);
    assert_eq(*val2, true); // Existing value preserved
}

@test
fn test_map_get_or_insert_chained_mutations() {
    let mut m: Map<Text, Int> = Map.new();
    *m.get_or_insert("x", 0) = 10;
    *m.get_or_insert("y", 0) = 20;
    *m.get_or_insert("z", 0) = 30;
    assert_eq(*m.get(&"x").unwrap(), 10);
    assert_eq(*m.get(&"y").unwrap(), 20);
    assert_eq(*m.get(&"z").unwrap(), 30);
}

@test
fn test_map_get_or_default_multiple_keys() {
    let mut m: Map<Text, Int> = Map.new();
    *m.entry("a").or_default() = 1;
    *m.entry("b").or_default() = 2;
    *m.entry("c").or_default() = 3;
    assert_eq(m.len(), 3);
    assert_eq(*m.get(&"a").unwrap(), 1);
    assert_eq(*m.get(&"b").unwrap(), 2);
    assert_eq(*m.get(&"c").unwrap(), 3);
}

// =============================================================================
// Section: count_by/group_by — Additional Patterns
// =============================================================================

@test
fn test_count_by_single_element() {
    let nums = List.from([42]);
    fn identity(n: &Int) -> Int { *n }
    let counts = count_by(nums.iter().map(|n| *n), identity);
    assert_eq(counts.len(), 1);
    assert_eq(*counts.get(&42).unwrap(), 1);
}

@test
fn test_count_by_all_same() {
    let nums = List.from([7, 7, 7, 7, 7]);
    fn identity(n: &Int) -> Int { *n }
    let counts = count_by(nums.iter().map(|n| *n), identity);
    assert_eq(counts.len(), 1);
    assert_eq(*counts.get(&7).unwrap(), 5);
}

@test
fn test_group_by_empty() {
    let empty: List<Int> = List.new();
    fn identity(n: &Int) -> Int { *n }
    let groups = group_by(empty.iter().map(|n| *n), identity);
    assert(groups.is_empty());
}

@test
fn test_group_by_all_unique() {
    let nums = List.from([1, 2, 3, 4, 5]);
    fn identity(n: &Int) -> Int { *n }
    let groups = group_by(nums.iter().map(|n| *n), identity);
    assert_eq(groups.len(), 5);
    for i in 1..6 {
        assert_eq(groups.get(&i).unwrap().len(), 1);
    }
}

