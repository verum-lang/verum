// =============================================================================
// Section: Combined Workflow Patterns
// =============================================================================

@test
fn test_map_entry_api_word_frequency() {
    let words = ["the", "quick", "brown", "fox", "the", "quick", "the"];
    let mut freq: Map<Text, Int> = Map.new();
    for w in words.iter() {
        freq.entry(*w).and_modify(|v| *v = *v + 1).or_insert(1);
    }
    assert_eq(*freq.get(&"the").unwrap(), 3);
    assert_eq(*freq.get(&"quick").unwrap(), 2);
    assert_eq(*freq.get(&"brown").unwrap(), 1);
    assert_eq(*freq.get(&"fox").unwrap(), 1);
}

@test
fn test_map_insert_retain_verify() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..20 {
        m.insert(i, i * i);
    }
    // Retain squares < 100
    m.retain(|_k, v| *v < 100);
    // 0, 1, 4, 9, 16, 25, 36, 49, 64, 81 → keys 0..10
    assert_eq(m.len(), 10);
    assert(m.contains_key(&0));
    assert(m.contains_key(&9));
    assert(!m.contains_key(&10));
}

@test
fn test_map_drain_collect_sum() {
    let mut m: Map<Int, Int> = Map.new();
    m.insert(1, 10);
    m.insert(2, 20);
    m.insert(3, 30);
    m.insert(4, 40);
    let mut sum = 0;
    for pair in m.drain() {
        sum = sum + pair.1;
    }
    assert_eq(sum, 100);
    assert(m.is_empty());
}

@test
fn test_map_get_or_insert_accumulate() {
    let mut m: Map<Text, Int> = Map.new();
    let items = [("a", 1), ("b", 2), ("a", 3), ("b", 4), ("c", 5)];
    for pair in items.iter() {
        let key = pair.0;
        let val = pair.1;
        *m.get_or_insert(key, 0) = *m.get_or_insert(key, 0) + val;
    }
    assert_eq(*m.get(&"a").unwrap(), 4); // 1 + 3
    assert_eq(*m.get(&"b").unwrap(), 6); // 2 + 4
    assert_eq(*m.get(&"c").unwrap(), 5);
}

fn main() {
    // Tests run via @test annotations
}
