@test
fn test_map_into_keys_preserves_all() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..20 {
        m.insert(i, i * 10);
    }
    let keys = m.into_keys();
    assert_eq(keys.len(), 20);
}

@test
fn test_map_into_values_preserves_all() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..20 {
        m.insert(i, i * 10);
    }
    let values = m.into_values();
    assert_eq(values.len(), 20);
}

@test
fn test_map_into_keys_single() {
    let mut m: Map<Text, Int> = Map.new();
    m.insert("only", 1);
    let keys = m.into_keys();
    assert_eq(keys.len(), 1);
}

// =============================================================================
// Section: Capacity — Additional
// =============================================================================

@test
fn test_map_reserve_then_insert() {
    let mut m: Map<Int, Int> = Map.new();
    m.reserve(200);
    for i in 0..100 {
        m.insert(i, i);
    }
    assert_eq(m.len(), 100);
    assert(m.capacity() >= 200);
}

@test
fn test_map_shrink_after_remove() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..100 {
        m.insert(i, i);
    }
    for i in 0..90 {
        m.remove(&i);
    }
    assert_eq(m.len(), 10);
    m.shrink_to_fit();
    assert_eq(m.len(), 10);
    // Remaining data preserved
    for i in 90..100 {
        assert(m.contains_key(&i));
    }
}

// =============================================================================
// Section: Stress Tests — Additional
// =============================================================================

@test
fn test_map_200_entries() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..200 {
        m.insert(i, i * 3);
    }
    assert_eq(m.len(), 200);
    assert_eq(*m.get(&0).unwrap(), 0);
    assert_eq(*m.get(&100).unwrap(), 300);
    assert_eq(*m.get(&199).unwrap(), 597);
}

@test
fn test_map_insert_remove_all_then_reinsert() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..50 {
        m.insert(i, i);
    }
    for i in 0..50 {
        m.remove(&i);
    }
    assert(m.is_empty());
    // Reinsert
    for i in 0..50 {
        m.insert(i, i + 100);
    }
    assert_eq(m.len(), 50);
    assert_eq(*m.get(&0).unwrap(), 100);
    assert_eq(*m.get(&49).unwrap(), 149);
}

@test
fn test_map_alternating_insert_remove() {
    let mut m: Map<Int, Int> = Map.new();
    for i in 0..50 {
        m.insert(i, i);
        if i > 0 && i % 2 == 0 {
            m.remove(&(i - 1));
        }
    }
    // Should have roughly half the entries
    assert(m.len() > 20);
    assert(m.len() <= 50);
}

