// =============================================================================
// heap_test.vr - Comprehensive tests for BinaryHeap<T> (priority queue)
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, heap, priority-queue, core
// @description: Comprehensive tests for BinaryHeap<T> and MinHeap<T> types
// =============================================================================

mount core.collections.heap.{BinaryHeap, Reverse, heap, min_heap, heap_sort};
mount core.collections.list.List;
mount core.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: BinaryHeap Construction Tests
// =============================================================================

@test
fn test_heap_new() {
    let empty: BinaryHeap<Int> = BinaryHeap.new();
    assert(empty.is_empty());
    assert_eq(empty.len(), 0);
}

@test
fn test_heap_with_capacity() {
    let heap: BinaryHeap<Int> = BinaryHeap.with_capacity(10);
    assert(heap.is_empty());
    assert(heap.capacity() >= 10);
}

@test
fn test_heap_default() {
    let heap: BinaryHeap<Int> = BinaryHeap.default();
    assert(heap.is_empty());
}

@test
fn test_heap_from_list() {
    let list = List.from([3, 1, 4, 1, 5, 9, 2, 6]);
    let heap = BinaryHeap.from_list(list);
    assert_eq(heap.len(), 8);
    // Max element should be at the top
    match heap.peek() {
        Some(v) => assert_eq(*v, 9),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 2: BinaryHeap Push and Pop Tests
// =============================================================================

@test
fn test_heap_push_single() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(42);
    assert_eq(heap.len(), 1);
    match heap.peek() {
        Some(v) => assert_eq(*v, 42),
        None => panic("Expected Some"),
    }
}

@test
fn test_heap_push_multiple() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(10);
    heap.push(20);
    heap.push(5);
    assert_eq(heap.len(), 3);
    // Max element should be at the top
    match heap.peek() {
        Some(v) => assert_eq(*v, 20),
        None => panic("Expected Some"),
    }
}

@test
fn test_heap_pop_empty() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    match heap.pop() {
        None => {} // Expected
        Some(_) => panic("Expected None for empty heap"),
    }
}

@test
fn test_heap_pop_single() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(42);
    match heap.pop() {
        Some(v) => assert_eq(v, 42),
        None => panic("Expected Some"),
    }
    assert(heap.is_empty());
}

@test
fn test_heap_pop_order() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(4);
    heap.push(1);
    heap.push(5);
    heap.push(9);
    heap.push(2);
    heap.push(6);

    // Pop should return elements in descending order
    let mut prev = 100; // Larger than any element
    while let Some(v) = heap.pop() {
        assert(v <= prev);
        prev = v;
    }
}

@test
fn test_heap_peek() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();

    // Peek on empty heap
    match heap.peek() {
        None => {} // Expected
        Some(_) => panic("Expected None"),
    }

    heap.push(10);
    heap.push(20);
    heap.push(5);

    // Peek returns max without removing
    match heap.peek() {
        Some(v) => assert_eq(*v, 20),
        None => panic("Expected Some"),
    }
    assert_eq(heap.len(), 3); // Length unchanged
}

// =============================================================================
// Section 3: BinaryHeap Push-Pop and Replace Tests
// =============================================================================

@test
fn test_heap_push_pop() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(5);
    heap.push(10);
    heap.push(15);

    // push_pop with value smaller than max returns the value
    let result = heap.push_pop(3);
    assert_eq(result, 3);
    assert_eq(heap.len(), 3);

    // push_pop with value larger than max returns the max
    // Actually, if value >= max, return value
    // Let me re-check the implementation logic
}

@test
fn test_heap_replace() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();

    // Replace on empty heap
    match heap.replace(10) {
        None => {} // Expected - pushes and returns None
        Some(_) => panic("Expected None for empty heap"),
    }
    assert_eq(heap.len(), 1);

    // Replace returns old max
    heap.push(20);
    match heap.replace(5) {
        Some(v) => assert_eq(v, 20), // Returns old max
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 4: BinaryHeap Clear and Reserve Tests
// =============================================================================

@test
fn test_heap_clear() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(1);
    heap.push(2);
    heap.push(3);

    assert_eq(heap.len(), 3);
    heap.clear();
    assert(heap.is_empty());
    assert_eq(heap.len(), 0);
}

@test
fn test_heap_reserve() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.reserve(100);
    assert(heap.capacity() >= 100);
    assert(heap.is_empty()); // Still empty
}

@test
fn test_heap_shrink_to_fit() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.with_capacity(100);
    heap.push(1);
    heap.push(2);
    assert(heap.capacity() >= 100);
    heap.shrink_to_fit();
    // Capacity should be reduced (at least to near the actual size)
    // Can't assert exact value as it's implementation-dependent
}

// =============================================================================
// Section 5: BinaryHeap Conversion Tests
// =============================================================================

@test
fn test_heap_into_sorted_list() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(4);
    heap.push(1);
    heap.push(5);

    let sorted = heap.into_sorted_list();
    // Should be in ascending order
    assert_eq(sorted.len(), 5);
    assert_eq(sorted[0], 1);
    assert_eq(sorted[1], 1);
    assert_eq(sorted[2], 3);
    assert_eq(sorted[3], 4);
    assert_eq(sorted[4], 5);
}

@test
fn test_heap_into_list() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(5);

    let list = heap.into_list();
    assert_eq(list.len(), 3);
    // First element should be max (heap property)
    assert_eq(list[0], 5);
}

@test
fn test_heap_as_slice() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(5);

    let slice = heap.as_slice();
    assert_eq(slice.len(), 3);
    // First element should be max (heap property)
    assert_eq(slice[0], 5);
}

// =============================================================================
// Section 6: BinaryHeap Iterator Tests
// =============================================================================

@test
fn test_heap_iter() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(5);

    let mut count = 0;
    for _x in heap.iter() {
        count = count + 1;
    }
    assert_eq(count, 3);
    assert_eq(heap.len(), 3); // Iterator doesn't consume
}

@test
fn test_heap_drain() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(5);

    let mut count = 0;
    for _x in heap.drain() {
        count = count + 1;
    }
    assert_eq(count, 3);
    assert(heap.is_empty()); // Drain consumes all elements
}

@test
fn test_heap_drain_sorted() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(5);
    heap.push(2);
    heap.push(4);

    // drain_sorted yields in descending order
    let mut prev = 100;
    for v in heap.drain_sorted() {
        assert(v <= prev);
        prev = v;
    }
    assert(heap.is_empty());
}

@test
fn test_heap_into_iter() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(5);

    let mut count = 0;
    for _x in heap.into_iter() {
        count = count + 1;
    }
    assert_eq(count, 3);
    // heap is consumed by into_iter
}

// =============================================================================
// Section 7: BinaryHeap Retain and Append Tests
// =============================================================================

@test
fn test_heap_retain() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(1);
    heap.push(2);
    heap.push(3);
    heap.push(4);
    heap.push(5);

    // Keep only even numbers
    heap.retain(|x| *x % 2 == 0);
    assert_eq(heap.len(), 2);
    assert(heap.peek().map(|x| *x) == Some(4)); // Max of evens
}

@test
fn test_heap_append() {
    let mut heap1: BinaryHeap<Int> = BinaryHeap.new();
    heap1.push(1);
    heap1.push(3);
    heap1.push(5);

    let mut heap2: BinaryHeap<Int> = BinaryHeap.new();
    heap2.push(2);
    heap2.push(4);
    heap2.push(6);

    heap1.append(&mut heap2);

    assert_eq(heap1.len(), 6);
    assert(heap2.is_empty()); // heap2 is drained

    // Max should be 6
    match heap1.peek() {
        Some(v) => assert_eq(*v, 6),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 8: BinaryHeap Clone Tests
// =============================================================================

@test
fn test_heap_clone() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(3);
    heap.push(1);
    heap.push(5);

    let cloned = heap.clone();

    assert_eq(cloned.len(), 3);
    match cloned.peek() {
        Some(v) => assert_eq(*v, 5),
        None => panic("Expected Some"),
    }

    // Verify independence
    heap.push(10);
    assert_eq(heap.len(), 4);
    assert_eq(cloned.len(), 3); // Clone unchanged
}

// =============================================================================
// Section 9: MinHeap (Reverse) Tests
// =============================================================================

@test
fn test_reverse_wrapper() {
    let r = Reverse.new(10);
    assert_eq(r.into_inner(), 10);
}

@test
fn test_reverse_ord() {
    let r1 = Reverse.new(10);
    let r2 = Reverse.new(20);

    // Reverse reverses comparison
    // 10 < 20 normally, but Reverse(10) > Reverse(20)
    assert(r1 > r2);
    assert(r2 < r1);
}

@test
fn test_min_heap_basic() {
    // Use BinaryHeap<Reverse<Int>> directly as min-heap
    let mut min_heap: BinaryHeap<Reverse<Int>> = BinaryHeap.new();
    min_heap.push(Reverse.new(3));
    min_heap.push(Reverse.new(1));
    min_heap.push(Reverse.new(4));
    min_heap.push(Reverse.new(1));
    min_heap.push(Reverse.new(5));

    // Pop should return minimum first (due to Reverse)
    match min_heap.pop() {
        Some(r) => assert_eq(r.into_inner(), 1),
        None => panic("Expected Some"),
    }

    match min_heap.pop() {
        Some(r) => assert_eq(r.into_inner(), 1),
        None => panic("Expected Some"),
    }

    match min_heap.pop() {
        Some(r) => assert_eq(r.into_inner(), 3),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 10: Manual Heap Sort Test
// =============================================================================

@test
fn test_manual_heap_sort() {
    // Sort a list using BinaryHeap
    let values = List.from([3, 1, 4, 1, 5, 9, 2, 6, 5, 3, 5]);
    let mut heap = BinaryHeap.from_list(values);
    let sorted = heap.into_sorted_list();

    // Should be sorted in ascending order
    let mut prev = 0;
    for x in sorted.iter() {
        assert(*x >= prev);
        prev = *x;
    }
}

// =============================================================================
// Section 11: Edge Cases
// =============================================================================

@test
fn test_heap_duplicate_elements() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.push(5);
    heap.push(5);
    heap.push(5);

    assert_eq(heap.len(), 3);

    // All pops return 5
    assert_eq(heap.pop(), Some(5));
    assert_eq(heap.pop(), Some(5));
    assert_eq(heap.pop(), Some(5));
    assert_eq(heap.pop(), None);
}

@test
fn test_heap_large_scale() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();

    // Insert many elements
    for i in 0..100 {
        heap.push(i);
    }

    assert_eq(heap.len(), 100);

    // Pop should return in descending order
    let mut prev = 100;
    while let Some(v) = heap.pop() {
        assert(v < prev);
        prev = v;
    }
}

@test
fn test_heap_interleaved_operations() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();

    heap.push(10);
    heap.push(5);
    assert_eq(heap.pop(), Some(10));

    heap.push(15);
    heap.push(3);
    assert_eq(heap.pop(), Some(15));
    assert_eq(heap.pop(), Some(5));

    heap.push(20);
    assert_eq(heap.peek().map(|x| *x), Some(20));
    assert_eq(heap.pop(), Some(20));
    assert_eq(heap.pop(), Some(3));
    assert(heap.is_empty());
}

// =============================================================================
// Section 12: Convenience Functions
// =============================================================================

@test
fn test_heap_convenience_function() {
    let arr = [3, 1, 4, 1, 5, 9, 2, 6];
    let h = heap(&arr);
    assert_eq(h.len(), 8);
    match h.peek() {
        Some(v) => assert_eq(*v, 9),
        None => panic("Expected Some"),
    }
}

@test
fn test_min_heap_convenience_function() {
    let arr = [3, 1, 4, 1, 5, 9, 2, 6];
    let mut mh = min_heap(&arr);
    assert_eq(mh.len(), 8);
    // Min-heap: smallest element comes out first
    match mh.pop() {
        Some(r) => assert_eq(r.into_inner(), 1),
        None => panic("Expected Some"),
    }
}

@test
fn test_heap_sort_function() {
    let mut list = List.from([5, 3, 1, 4, 2]);
    heap_sort(&mut list);

    assert_eq(list[0], 1);
    assert_eq(list[1], 2);
    assert_eq(list[2], 3);
    assert_eq(list[3], 4);
    assert_eq(list[4], 5);
}

@test
fn test_heap_sort_already_sorted() {
    let mut list = List.from([1, 2, 3, 4, 5]);
    heap_sort(&mut list);

    for i in 0..5 {
        assert_eq(list[i], i + 1);
    }
}

@test
fn test_heap_sort_reverse() {
    let mut list = List.from([5, 4, 3, 2, 1]);
    heap_sort(&mut list);

    assert_eq(list[0], 1);
    assert_eq(list[4], 5);
}

@test
fn test_heap_sort_empty() {
    let mut list: List<Int> = List.new();
    heap_sort(&mut list);
    assert(list.is_empty());
}

@test
fn test_heap_sort_single() {
    let mut list = List.from([42]);
    heap_sort(&mut list);
    assert_eq(list[0], 42);
}

// =============================================================================
// Additional Edge Case Tests
// =============================================================================

@test
fn test_heap_push_pop_alternating() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(5);
    assert_eq(h.pop(), Some(5));

    h.push(3);
    h.push(7);
    assert_eq(h.pop(), Some(7)); // Max first
    assert_eq(h.pop(), Some(3));
    assert_eq(h.pop(), None);
}

@test
fn test_heap_push_pop_combined() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);
    h.push(15);

    // push_pop: push value then pop max
    let popped = h.push_pop(25);
    assert_eq(popped, 25); // 25 is new max, so it's popped

    let popped2 = h.push_pop(5);
    assert_eq(popped2, 20); // 20 was max
}

@test
fn test_heap_replace_basic() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);
    h.push(15);

    // replace: pop max, push new value
    let old = h.replace(5);
    assert_eq(old, Some(20));
    // Now max should be 15
    assert_eq(*h.peek().unwrap(), 15);
}

@test
fn test_heap_drain_sorted_order() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(3);
    h.push(1);
    h.push(4);
    h.push(1);
    h.push(5);
    h.push(9);

    let mut prev = 10; // Start above max
    let mut drain = h.drain_sorted();
    let mut count = 0;
    loop {
        match drain.next() {
            Some(val) => {
                assert(val <= prev); // Descending order
                prev = val;
                count = count + 1;
            },
            None => break,
        }
    }
    assert_eq(count, 6);
    assert(h.is_empty());
}

@test
fn test_heap_retain_preserves_heap() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(2);
    h.push(3);
    h.push(4);
    h.push(5);
    h.push(6);

    // Keep only even numbers
    h.retain(|x| *x % 2 == 0);
    assert_eq(h.len(), 3);
    // Max should be 6
    assert_eq(*h.peek().unwrap(), 6);
}

@test
fn test_heap_large_ascending() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    let mut i = 0;
    while i < 100 {
        h.push(i);
        i = i + 1;
    }
    assert_eq(h.len(), 100);
    assert_eq(*h.peek().unwrap(), 99); // Max is 99

    // Pop all — should come out in descending order
    let mut prev = 100;
    let mut count = 0;
    loop {
        match h.pop() {
            Some(val) => {
                assert(val < prev);
                prev = val;
                count = count + 1;
            },
            None => break,
        }
    }
    assert_eq(count, 100);
}

@test
fn test_heap_append_merges() {
    let mut h1: BinaryHeap<Int> = BinaryHeap.new();
    h1.push(1);
    h1.push(3);
    h1.push(5);

    let mut h2: BinaryHeap<Int> = BinaryHeap.new();
    h2.push(2);
    h2.push(4);
    h2.push(6);

    h1.append(&mut h2);
    assert_eq(h1.len(), 6);
    assert(h2.is_empty());
    assert_eq(*h1.peek().unwrap(), 6); // Max of combined
}

