// =============================================================================
// Section: push_pop Edge Cases
// =============================================================================

@test
fn test_heap_push_pop_on_empty() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    // push_pop on empty heap returns the value (heap stays empty)
    let result = h.push_pop(42);
    assert_eq(result, 42);
    assert(h.is_empty());
}

@test
fn test_heap_push_pop_equal_to_max() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);
    h.push(15);

    // push_pop with value equal to max
    let result = h.push_pop(20);
    assert_eq(result, 20); // Equal to max, so returned directly
    assert_eq(h.len(), 3);
}

@test
fn test_heap_push_pop_smallest() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);
    h.push(15);

    // push_pop with value smaller than all elements
    let result = h.push_pop(1);
    assert_eq(result, 20); // Returns old max
    assert_eq(h.len(), 3);
    // Now max should be 15
    assert_eq(*h.peek().unwrap(), 15);
}

// =============================================================================
// Section: replace Edge Cases
// =============================================================================

@test
fn test_heap_replace_single_element() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(42);

    let old = h.replace(100);
    assert_eq(old, Some(42));
    assert_eq(h.len(), 1);
    assert_eq(*h.peek().unwrap(), 100);
}

@test
fn test_heap_replace_with_larger() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);

    let old = h.replace(30);
    assert_eq(old, Some(20));
    assert_eq(*h.peek().unwrap(), 30);
}

@test
fn test_heap_replace_with_smaller() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(10);
    h.push(20);

    let old = h.replace(5);
    assert_eq(old, Some(20));
    assert_eq(*h.peek().unwrap(), 10);
}

// =============================================================================
// Section: from_list Edge Cases
// =============================================================================

@test
fn test_heap_from_list_empty() {
    let list: List<Int> = List.new();
    let h = BinaryHeap.from_list(list);
    assert(h.is_empty());
}

@test
fn test_heap_from_list_single() {
    let list = List.from([42]);
    let h = BinaryHeap.from_list(list);
    assert_eq(h.len(), 1);
    assert_eq(*h.peek().unwrap(), 42);
}

@test
fn test_heap_from_list_sorted() {
    let list = List.from([1, 2, 3, 4, 5]);
    let h = BinaryHeap.from_list(list);
    assert_eq(h.len(), 5);
    assert_eq(*h.peek().unwrap(), 5);
}

@test
fn test_heap_from_list_reverse_sorted() {
    let list = List.from([5, 4, 3, 2, 1]);
    let h = BinaryHeap.from_list(list);
    assert_eq(h.len(), 5);
    assert_eq(*h.peek().unwrap(), 5);
}

@test
fn test_heap_from_list_duplicates() {
    let list = List.from([3, 3, 3, 3, 3]);
    let h = BinaryHeap.from_list(list);
    assert_eq(h.len(), 5);
    assert_eq(*h.peek().unwrap(), 3);
}

// =============================================================================
// Section: into_sorted_list Edge Cases
// =============================================================================

@test
fn test_heap_into_sorted_list_empty() {
    let h: BinaryHeap<Int> = BinaryHeap.new();
    let sorted = h.into_sorted_list();
    assert(sorted.is_empty());
}

@test
fn test_heap_into_sorted_list_single() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(42);
    let sorted = h.into_sorted_list();
    assert_eq(sorted.len(), 1);
    assert_eq(sorted[0], 42);
}

@test
fn test_heap_into_sorted_list_duplicates() {
    let list = List.from([5, 3, 5, 1, 3]);
    let h = BinaryHeap.from_list(list);
    let sorted = h.into_sorted_list();
    assert_eq(sorted.len(), 5);
    assert_eq(sorted[0], 1);
    assert_eq(sorted[1], 3);
    assert_eq(sorted[2], 3);
    assert_eq(sorted[3], 5);
    assert_eq(sorted[4], 5);
}

// =============================================================================
// Section: Reverse Wrapper Tests
// =============================================================================

@test
fn test_reverse_eq() {
    let r1 = Reverse.new(10);
    let r2 = Reverse.new(10);
    let r3 = Reverse.new(20);

    assert(r1 == r2);
    assert(r1 != r3);
}

@test
fn test_reverse_clone() {
    let r = Reverse.new(42);
    let cloned = r.clone();
    assert_eq(cloned.into_inner(), 42);
}

@test
fn test_reverse_ordering_detailed() {
    let r1 = Reverse.new(1);
    let r5 = Reverse.new(5);
    let r10 = Reverse.new(10);

    // In a max-heap of Reverse values, smallest original values come out first
    let mut h: BinaryHeap<Reverse<Int>> = BinaryHeap.new();
    h.push(r10);
    h.push(r1);
    h.push(r5);

    // Pop returns Reverse(1) first (biggest Reverse value = smallest original)
    let first = h.pop().unwrap();
    assert_eq(first.into_inner(), 1);

    let second = h.pop().unwrap();
    assert_eq(second.into_inner(), 5);

    let third = h.pop().unwrap();
    assert_eq(third.into_inner(), 10);
}

// =============================================================================
// Section: Min Heap Full Tests
// =============================================================================

@test
fn test_min_heap_pop_all_ascending() {
    let mut mh: BinaryHeap<Reverse<Int>> = BinaryHeap.new();
    mh.push(Reverse.new(5));
    mh.push(Reverse.new(3));
    mh.push(Reverse.new(1));
    mh.push(Reverse.new(4));
    mh.push(Reverse.new(2));

    // Pop all - should come out in ascending order
    let mut results: List<Int> = List.new();
    loop {
        match mh.pop() {
            Some(r) => results.push(r.into_inner()),
            None => break,
        }
    }

    assert_eq(results.len(), 5);
    assert_eq(results[0], 1);
    assert_eq(results[1], 2);
    assert_eq(results[2], 3);
    assert_eq(results[3], 4);
    assert_eq(results[4], 5);
}

@test
fn test_min_heap_peek() {
    let mut mh: BinaryHeap<Reverse<Int>> = BinaryHeap.new();
    mh.push(Reverse.new(30));
    mh.push(Reverse.new(10));
    mh.push(Reverse.new(20));

    // Peek shows minimum
    match mh.peek() {
        Some(r) => assert_eq(r.value, 10),
        None => panic("Expected Some"),
    }
}

@test
fn test_min_heap_convenience_pop_all() {
    let mut mh = min_heap(&[9, 3, 7, 1, 5]);

    let first = mh.pop().unwrap().into_inner();
    assert_eq(first, 1);

    let second = mh.pop().unwrap().into_inner();
    assert_eq(second, 3);

    let third = mh.pop().unwrap().into_inner();
    assert_eq(third, 5);
}

// =============================================================================
// Section: Heap Sort Extended
// =============================================================================

@test
fn test_heap_sort_duplicates() {
    let mut list = List.from([3, 1, 3, 1, 2, 2]);
    heap_sort(&mut list);
    assert_eq(list[0], 1);
    assert_eq(list[1], 1);
    assert_eq(list[2], 2);
    assert_eq(list[3], 2);
    assert_eq(list[4], 3);
    assert_eq(list[5], 3);
}

@test
fn test_heap_sort_two_elements() {
    let mut list = List.from([5, 3]);
    heap_sort(&mut list);
    assert_eq(list[0], 3);
    assert_eq(list[1], 5);
}

@test
fn test_heap_sort_negative_values() {
    let mut list = List.from([3, -1, 4, -5, 0, 2]);
    heap_sort(&mut list);
    assert_eq(list[0], -5);
    assert_eq(list[1], -1);
    assert_eq(list[2], 0);
    assert_eq(list[3], 2);
    assert_eq(list[4], 3);
    assert_eq(list[5], 4);
}

// =============================================================================
// Section: Clear and Capacity Edge Cases
// =============================================================================

@test
fn test_heap_clear_empty() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.clear();
    assert(h.is_empty());
}

@test
fn test_heap_capacity_after_operations() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    let initial_cap = h.capacity();

    // Push many elements
    let mut i = 0;
    while i < 20 {
        h.push(i);
        i = i + 1;
    }

    assert(h.capacity() > initial_cap);
    assert(h.capacity() >= 20);
}

@test
fn test_heap_retain_all() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(2);
    h.push(3);

    h.retain(|_x| true);
    assert_eq(h.len(), 3);
}

@test
fn test_heap_retain_none() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.push(2);
    h.push(3);

    h.retain(|_x| false);
    assert(h.is_empty());
}

@test
fn test_heap_retain_empty() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.retain(|_x| true);
    assert(h.is_empty());
}

// =============================================================================
// Section: Eq Protocol Tests
// =============================================================================

@test
fn test_heap_eq_same_elements() {
    let mut h1: BinaryHeap<Int> = BinaryHeap.new();
    h1.push(3);
    h1.push(1);
    h1.push(2);

    let mut h2: BinaryHeap<Int> = BinaryHeap.new();
    h2.push(1);
    h2.push(2);
    h2.push(3);

    // Same elements but possibly different internal order
    assert_eq(h1, h2);
}

@test
fn test_heap_eq_empty() {
    let h1: BinaryHeap<Int> = BinaryHeap.new();
    let h2: BinaryHeap<Int> = BinaryHeap.new();
    assert_eq(h1, h2);
}

@test
fn test_heap_neq_different_elements() {
    let mut h1: BinaryHeap<Int> = BinaryHeap.new();
    h1.push(1);
    h1.push(2);

    let mut h2: BinaryHeap<Int> = BinaryHeap.new();
    h2.push(1);
    h2.push(3);

    assert(h1 != h2);
}

@test
fn test_heap_neq_different_length() {
    let mut h1: BinaryHeap<Int> = BinaryHeap.new();
    h1.push(1);
    h1.push(2);

    let mut h2: BinaryHeap<Int> = BinaryHeap.new();
    h2.push(1);

    assert(h1 != h2);
}

@test
fn test_heap_eq_single_element() {
    let mut h1: BinaryHeap<Int> = BinaryHeap.new();
    h1.push(42);

    let mut h2: BinaryHeap<Int> = BinaryHeap.new();
    h2.push(42);

    assert_eq(h1, h2);
}

