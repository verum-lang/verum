@test
fn test_btreeset_intersection_both_empty() {
    let a: BTreeSet<Int> = BTreeSet.new();
    let b: BTreeSet<Int> = BTreeSet.new();

    let result = a.intersection(&b);
    assert(result.is_empty());
}

@test
fn test_btreeset_difference_both_empty() {
    let a: BTreeSet<Int> = BTreeSet.new();
    let b: BTreeSet<Int> = BTreeSet.new();

    let result = a.difference(&b);
    assert(result.is_empty());
}

@test
fn test_btreeset_symmetric_difference_both_empty() {
    let a: BTreeSet<Int> = BTreeSet.new();
    let b: BTreeSet<Int> = BTreeSet.new();

    let result = a.symmetric_difference(&b);
    assert(result.is_empty());
}

@test
fn test_btreeset_intersection_with_empty() {
    let mut a: BTreeSet<Int> = BTreeSet.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let b: BTreeSet<Int> = BTreeSet.new();

    let result = a.intersection(&b);
    assert(result.is_empty());
}

@test
fn test_btreeset_difference_from_empty() {
    let a: BTreeSet<Int> = BTreeSet.new();
    let mut b: BTreeSet<Int> = BTreeSet.new();
    b.insert(1);
    b.insert(2);

    let result = a.difference(&b);
    assert(result.is_empty());
}

// =============================================================================
// Section 5.2: BTreeSet Range Tests
// =============================================================================

@test
fn test_btreeset_range_full() {
    let mut set: BTreeSet<Int> = BTreeSet.new();
    set.insert(1);
    set.insert(3);
    set.insert(5);

    let mut count = 0;
    for _x in set.range(..) {
        count = count + 1;
    }
    assert_eq(count, 3);
}

@test
fn test_btreeset_range_empty_result() {
    let mut set: BTreeSet<Int> = BTreeSet.new();
    set.insert(1);
    set.insert(2);
    set.insert(3);

    let mut count = 0;
    for _x in set.range(10..20) {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_btreeset_range_on_empty() {
    let set: BTreeSet<Int> = BTreeSet.new();

    let mut count = 0;
    for _x in set.range(0..10) {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_btreeset_range_single_element() {
    let mut set: BTreeSet<Int> = BTreeSet.new();
    set.insert(5);

    let mut count = 0;
    for x in set.range(5..=5) {
        assert_eq(*x, 5);
        count = count + 1;
    }
    assert_eq(count, 1);
}

// =============================================================================
// Section 5.3: BTreeSet Pop Operations Extended
// =============================================================================

@test
fn test_btreeset_pop_last_all() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(3);
    s.insert(1);
    s.insert(2);

    assert_eq(s.pop_last(), Some(3));
    assert_eq(s.pop_last(), Some(2));
    assert_eq(s.pop_last(), Some(1));
    assert(s.pop_last().is_none());
    assert(s.is_empty());
}

@test
fn test_btreeset_pop_first_single() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(42);

    assert_eq(s.pop_first(), Some(42));
    assert(s.is_empty());
}

@test
fn test_btreeset_pop_last_single() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(42);

    assert_eq(s.pop_last(), Some(42));
    assert(s.is_empty());
}

// =============================================================================
// Section 5.4: BTreeSet Subset/Superset Edge Cases
// =============================================================================

@test
fn test_btreeset_is_superset_of_empty() {
    let mut set: BTreeSet<Int> = BTreeSet.new();
    set.insert(1);
    set.insert(2);

    let empty: BTreeSet<Int> = BTreeSet.new();

    // Any set is superset of empty
    assert(set.is_superset(&empty));
    // Empty is superset of empty
    assert(empty.is_superset(&empty));
}

@test
fn test_btreeset_is_disjoint_both_empty() {
    let a: BTreeSet<Int> = BTreeSet.new();
    let b: BTreeSet<Int> = BTreeSet.new();
    assert(a.is_disjoint(&b));
}

@test
fn test_btreeset_is_disjoint_self() {
    let mut set: BTreeSet<Int> = BTreeSet.new();
    set.insert(1);
    set.insert(2);

    // A set is never disjoint with itself (unless empty)
    assert(!set.is_disjoint(&set));
}

@test
fn test_btreeset_is_disjoint_empty_self() {
    let empty: BTreeSet<Int> = BTreeSet.new();
    assert(empty.is_disjoint(&empty));
}

// =============================================================================
// Section 5.5: BTreeMap/Set with Various Types
// =============================================================================

@test
fn test_btreemap_int_values() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(1, 100);
    map.insert(2, 200);
    map.insert(3, 300);

    let mut total = 0;
    for (_k, v) in map.iter() {
        total = total + *v;
    }
    assert_eq(total, 600);
}

@test
fn test_btreeset_negative_values() {
    let mut set: BTreeSet<Int> = BTreeSet.new();
    set.insert(-10);
    set.insert(-5);
    set.insert(0);
    set.insert(5);
    set.insert(10);

    assert_eq(set.len(), 5);

    match set.first() {
        Some(v) => assert_eq(*v, -10),
        None => panic("Expected Some"),
    }

    match set.last() {
        Some(v) => assert_eq(*v, 10),
        None => panic("Expected Some"),
    }
}

@test
fn test_btreeset_large_range_query() {
    let mut set: BTreeSet<Int> = BTreeSet.new();
    let mut i = 0;
    while i < 50 {
        set.insert(i * 2); // Even numbers 0..98
        i = i + 1;
    }

    // Range 20..=40 should capture 20,22,24,...,40 = 11 elements
    let mut count = 0;
    for x in set.range(20..=40) {
        assert(*x >= 20);
        assert(*x <= 40);
        count = count + 1;
    }
    assert_eq(count, 11);
}

@test
fn test_btreemap_clone_deep() {
    let mut map: BTreeMap<Int, List<Int>> = BTreeMap.new();
    map.insert(1, List.from([10, 20]));
    map.insert(2, List.from([30, 40]));

    let cloned = map.clone();

    assert_eq(cloned.len(), 2);
    assert(cloned.contains_key(&1));
    assert(cloned.contains_key(&2));

    // Verify independence
    map.insert(3, List.from([50]));
    assert_eq(map.len(), 3);
    assert_eq(cloned.len(), 2);
}

@test
fn test_btreemap_entry_word_count() {
    let mut counts: BTreeMap<Text, Int> = BTreeMap.new();
    let words = List.from(["the", "cat", "sat", "on", "the", "mat", "the"]);

    for word in words.iter() {
        let count = counts.entry(*word).or_insert(0);
        *count = *count + 1;
    }

    assert_eq(*counts.get(&"the").unwrap(), 3);
    assert_eq(*counts.get(&"cat").unwrap(), 1);
    assert_eq(*counts.get(&"sat").unwrap(), 1);
    assert_eq(*counts.get(&"on").unwrap(), 1);
    assert_eq(*counts.get(&"mat").unwrap(), 1);
    assert_eq(counts.len(), 5);
}

