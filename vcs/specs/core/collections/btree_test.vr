@test
fn test_btreemap_range_single_element() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(5, 50);

    // Range that includes single element
    let mut count = 0;
    for (k, v) in map.range(5..=5) {
        assert_eq(*k, 5);
        assert_eq(*v, 50);
        count = count + 1;
    }
    assert_eq(count, 1);
}

@test
fn test_btreemap_range_before_all() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(10, 100);
    map.insert(20, 200);

    let mut count = 0;
    for (_k, _v) in map.range(0..5) {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_btreemap_range_after_all() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(10, 100);
    map.insert(20, 200);

    let mut count = 0;
    for (_k, _v) in map.range(30..40) {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_btreemap_range_on_empty() {
    let map: BTreeMap<Int, Int> = BTreeMap.new();

    let mut count = 0;
    for (_k, _v) in map.range(0..10) {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_btreemap_range_all_elements() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(1, 10);
    map.insert(2, 20);
    map.insert(3, 30);

    let mut count = 0;
    for (_k, _v) in map.range(0..100) {
        count = count + 1;
    }
    assert_eq(count, 3);
}

