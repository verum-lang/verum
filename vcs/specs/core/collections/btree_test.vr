@test
fn test_btreemap_get_mut_missing_key() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(1, 10);

    match map.get_mut(&99) {
        None => {} // Expected
        Some(_) => panic("Expected None for missing key"),
    }
}

@test
fn test_btreemap_get_mut_empty_map() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();

    match map.get_mut(&1) {
        None => {} // Expected
        Some(_) => panic("Expected None for empty map"),
    }
}

@test
fn test_btreemap_get_mut_multiple_modifications() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(1, 0);

    // Increment several times
    let mut i = 0;
    while i < 5 {
        match map.get_mut(&1) {
            Some(v) => *v = *v + 1,
            None => panic("Expected Some"),
        }
        i = i + 1;
    }

    assert_eq(*map.get(&1).unwrap(), 5);
}

// =============================================================================
// Section 4.3: BTreeMap Insert/Remove Stress
// =============================================================================

@test
fn test_btreemap_insert_remove_same_key_repeatedly() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();

    let mut i = 0;
    while i < 20 {
        map.insert(1, i);
        assert_eq(map.len(), 1);
        let removed = map.remove(&1);
        assert_eq(removed, Some(i));
        assert(map.is_empty());
        i = i + 1;
    }
}

@test
fn test_btreemap_remove_non_existent() {
    let mut map: BTreeMap<Int, Int> = BTreeMap.new();
    map.insert(1, 10);
    map.insert(2, 20);

    // Remove keys that don't exist
    assert(map.remove(&0).is_none());
    assert(map.remove(&3).is_none());
    assert(map.remove(&100).is_none());

    // Original elements still intact
    assert_eq(map.len(), 2);
    assert(map.contains_key(&1));
    assert(map.contains_key(&2));
}

