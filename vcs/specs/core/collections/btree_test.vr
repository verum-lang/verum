@test
fn test_btreemap_build_from_list() {
    // Build a BTreeMap from a list of pairs manually
    let pairs = List.from([(1, "one"), (2, "two"), (3, "three")]);
    let mut map: BTreeMap<Int, Text> = BTreeMap.new();
    for (k, v) in pairs.into_iter() {
        map.insert(k, v);
    }

    assert_eq(map.len(), 3);
    match map.get(&1) {
        Some(v) => assert_eq(*v, "one"),
        None => panic("Expected Some"),
    }
}

@test
fn test_btreeset_build_from_list() {
    // Build a BTreeSet from a list manually (with duplicates)
    let values = List.from([3, 1, 2, 1, 3]);
    let mut set: BTreeSet<Int> = BTreeSet.new();
    for x in values.into_iter() {
        set.insert(x);
    }

    assert_eq(set.len(), 3); // Duplicates ignored
    assert(set.contains(&1));
    assert(set.contains(&2));
    assert(set.contains(&3));
}

// =============================================================================
// Section: Pop First / Pop Last
// =============================================================================

@test
fn test_btree_pop_first() {
    let mut tree: BTreeMap<Int, Text> = BTreeMap.new();
    tree.insert(3, "three");
    tree.insert(1, "one");
    tree.insert(5, "five");
    tree.insert(2, "two");

    let first = tree.pop_first();
    assert(first.is_some());
    let pair = first.unwrap();
    assert_eq(pair.0, 1);
    assert_eq(pair.1, "one");
    assert_eq(tree.len(), 3);
    assert(!tree.contains_key(&1));
}

@test
fn test_btree_pop_last() {
    let mut tree: BTreeMap<Int, Text> = BTreeMap.new();
    tree.insert(3, "three");
    tree.insert(1, "one");
    tree.insert(5, "five");
    tree.insert(2, "two");

    let last = tree.pop_last();
    assert(last.is_some());
    let pair = last.unwrap();
    assert_eq(pair.0, 5);
    assert_eq(pair.1, "five");
    assert_eq(tree.len(), 3);
    assert(!tree.contains_key(&5));
}

@test
fn test_btree_pop_first_empty() {
    let mut tree: BTreeMap<Int, Int> = BTreeMap.new();
    assert(tree.pop_first().is_none());
}

@test
fn test_btree_pop_last_empty() {
    let mut tree: BTreeMap<Int, Int> = BTreeMap.new();
    assert(tree.pop_last().is_none());
}

@test
fn test_btree_pop_first_repeated() {
    let mut tree: BTreeMap<Int, Int> = BTreeMap.new();
    tree.insert(1, 10);
    tree.insert(2, 20);
    tree.insert(3, 30);

    let a = tree.pop_first().unwrap();
    assert_eq(a.0, 1);
    let b = tree.pop_first().unwrap();
    assert_eq(b.0, 2);
    let c = tree.pop_first().unwrap();
    assert_eq(c.0, 3);
    assert(tree.pop_first().is_none());
    assert_eq(tree.len(), 0);
}

// =============================================================================
// pop_first / pop_last Tests
// =============================================================================

@test
fn test_btreemap_pop_first() {
    let mut bt = BTreeMap.new();
    bt.insert(3, "three");
    bt.insert(1, "one");
    bt.insert(2, "two");

    let first = bt.pop_first();
    assert(first.is_some());
    let (k, v) = first.unwrap();
    assert_eq(k, 1);
    assert_eq(v, "one");
    assert_eq(bt.len(), 2);
}

@test
fn test_btreemap_pop_last() {
    let mut bt = BTreeMap.new();
    bt.insert(3, "three");
    bt.insert(1, "one");
    bt.insert(2, "two");

    let last = bt.pop_last();
    assert(last.is_some());
    let (k, v) = last.unwrap();
    assert_eq(k, 3);
    assert_eq(v, "three");
    assert_eq(bt.len(), 2);
}

@test
fn test_btreemap_pop_first_empty() {
    let mut bt: BTreeMap<Int, Text> = BTreeMap.new();
    assert(bt.pop_first().is_none());
}

@test
fn test_btreemap_pop_last_empty() {
    let mut bt: BTreeMap<Int, Text> = BTreeMap.new();
    assert(bt.pop_last().is_none());
}

@test
fn test_btreemap_pop_first_all() {
    let mut bt = BTreeMap.new();
    bt.insert(5, "e");
    bt.insert(3, "c");
    bt.insert(1, "a");
    bt.insert(4, "d");
    bt.insert(2, "b");

    // Pop all in sorted order
    let f1 = bt.pop_first().unwrap();
    assert_eq(f1.0, 1);
    let f2 = bt.pop_first().unwrap();
    assert_eq(f2.0, 2);
    let f3 = bt.pop_first().unwrap();
    assert_eq(f3.0, 3);
    let f4 = bt.pop_first().unwrap();
    assert_eq(f4.0, 4);
    let f5 = bt.pop_first().unwrap();
    assert_eq(f5.0, 5);
    assert(bt.is_empty());
}

@test
fn test_btreemap_pop_last_all() {
    let mut bt = BTreeMap.new();
    bt.insert(1, "a");
    bt.insert(3, "c");
    bt.insert(2, "b");

    // Pop all in reverse sorted order
    let l1 = bt.pop_last().unwrap();
    assert_eq(l1.0, 3);
    let l2 = bt.pop_last().unwrap();
    assert_eq(l2.0, 2);
    let l3 = bt.pop_last().unwrap();
    assert_eq(l3.0, 1);
    assert(bt.is_empty());
}

// =============================================================================
// Large Tree Behavior
// =============================================================================

@test
fn test_btreemap_large_sorted_order() {
    let mut bt = BTreeMap.new();
    // Insert in reverse order
    let mut i = 100;
    while i > 0 {
        bt.insert(i, i * 10);
        i = i - 1;
    }
    assert_eq(bt.len(), 100);

    // Verify first and last
    let first = bt.first_key_value();
    assert(first.is_some());
    let (fk, _) = first.unwrap();
    assert_eq(*fk, 1);

    let last = bt.last_key_value();
    assert(last.is_some());
    let (lk, _) = last.unwrap();
    assert_eq(*lk, 100);
}

@test
fn test_btreemap_sorted_iteration() {
    let mut bt = BTreeMap.new();
    bt.insert(5, "e");
    bt.insert(1, "a");
    bt.insert(3, "c");
    bt.insert(2, "b");
    bt.insert(4, "d");

    // Iterate and verify sorted order
    let mut prev = 0;
    let mut iter = bt.keys();
    loop {
        match iter.next() {
            Some(k) => {
                assert(k > prev);
                prev = k;
            },
            None => break,
        }
    }
    assert_eq(prev, 5); // Last key should be 5
}

@test
fn test_btreemap_entry_or_insert() {
    let mut bt = BTreeMap.new();
    bt.entry(1).or_insert("one");
    bt.entry(2).or_insert("two");
    bt.entry(1).or_insert("ONE"); // Should not overwrite

    assert_eq(bt.len(), 2);
    assert_eq(*bt.get(&1).unwrap(), "one");
}

