@test
fn test_btreeset_union_basic() {
    let mut a: BTreeSet<Int> = BTreeSet.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b: BTreeSet<Int> = BTreeSet.new();
    b.insert(3);
    b.insert(4);
    b.insert(5);

    let result = a.union(&b);
    assert_eq(result.len(), 5);
    assert(result.contains(&1));
    assert(result.contains(&2));
    assert(result.contains(&3));
    assert(result.contains(&4));
    assert(result.contains(&5));
}

@test
fn test_btreeset_union_disjoint() {
    let mut a: BTreeSet<Int> = BTreeSet.new();
    a.insert(1);
    a.insert(2);

    let mut b: BTreeSet<Int> = BTreeSet.new();
    b.insert(3);
    b.insert(4);

    let result = a.union(&b);
    assert_eq(result.len(), 4);
}

@test
fn test_btreeset_union_empty() {
