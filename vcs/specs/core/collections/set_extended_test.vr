// =============================================================================
// set_extended_test.vr - Tests for Set extract_if, strict subset/superset,
//                        compound-assign operators, and symmetric_difference_update
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, set, extract_if, operators, strict_subset, production, core
// @description: Tests for Set.extract_if(), is_strict_subset(), is_strict_superset(),
//               symmetric_difference_update(), and compound-assign operators
//               (|=, &=, -=, ^=).
// =============================================================================

module specs.core.collections.set_extended_test;

mount core.*;

// =============================================================================
// Helper predicates
// =============================================================================

fn is_even(v: &Int) -> Bool {
    *v % 2 == 0
}

fn is_odd(v: &Int) -> Bool {
    *v % 2 != 0
}

fn is_positive(v: &Int) -> Bool {
    *v > 0
}

fn always_true_pred(v: &Int) -> Bool {
    true
}

fn always_false_pred(v: &Int) -> Bool {
    false
}

fn gt_3(v: &Int) -> Bool {
    *v > 3
}

fn lt_0(v: &Int) -> Bool {
    *v < 0
}

// =============================================================================
// Section 1: Set.extract_if() Tests
// =============================================================================

@test
fn test_extract_if_basic() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    s.insert(4);
    s.insert(5);

    let extracted = s.extract_if(is_even);

    assert_eq(extracted.len(), 2);
    assert_eq(s.len(), 3);
    assert(s.contains(&1));
    assert(s.contains(&3));
    assert(s.contains(&5));
    assert(!s.contains(&2));
    assert(!s.contains(&4));
}

@test
fn test_extract_if_empty_set() {
    let mut s: Set<Int> = Set.new();
    let extracted = s.extract_if(always_true_pred);
    assert_eq(extracted.len(), 0);
    assert_eq(s.len(), 0);
}

@test
fn test_extract_if_none_match() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);

    let extracted = s.extract_if(lt_0);
    assert_eq(extracted.len(), 0);
    assert_eq(s.len(), 3);
}

@test
fn test_extract_if_all_match() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);

    let extracted = s.extract_if(always_true_pred);
    assert_eq(extracted.len(), 3);
    assert(s.is_empty());
}

@test
fn test_extract_if_single_element_match() {
    let mut s: Set<Int> = Set.new();
    s.insert(2);

    let extracted = s.extract_if(is_even);
    assert_eq(extracted.len(), 1);
    assert(s.is_empty());
}

@test
fn test_extract_if_single_element_no_match() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);

    let extracted = s.extract_if(is_even);
    assert_eq(extracted.len(), 0);
    assert_eq(s.len(), 1);
}

@test
fn test_extract_if_set_still_usable() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);

    let _extracted = s.extract_if(is_even);

    // Set should still work after extraction
    s.insert(10);
    assert_eq(s.len(), 3); // 1, 3, 10
    assert(s.contains(&10));
}

@test
fn test_extract_if_larger_set() {
    let mut s: Set<Int> = Set.new();
    for i in range(0, 20) {
        s.insert(i);
    }

    let extracted = s.extract_if(is_even);
    // 0, 2, 4, ..., 18 → 10 even numbers
    assert_eq(extracted.len(), 10);
    assert_eq(s.len(), 10);

    // Verify remaining are all odd
    for i in range(0, 20) {
        if i % 2 != 0 {
            assert(s.contains(&i));
        } else {
            assert(!s.contains(&i));
        }
    }
}

@test
fn test_extract_if_by_threshold() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    s.insert(4);
    s.insert(5);

    let extracted = s.extract_if(gt_3);
    assert_eq(extracted.len(), 2);
    assert_eq(s.len(), 3);
    assert(s.contains(&1));
    assert(s.contains(&2));
    assert(s.contains(&3));
}

// =============================================================================
// Section 2: is_strict_subset / is_strict_superset Tests
// =============================================================================

@test
fn test_strict_subset_proper() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);
    b.insert(3);

    assert(a.is_strict_subset(&b));
    assert(!b.is_strict_subset(&a));
}

@test
fn test_strict_subset_equal_sets() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);

    // Equal sets are NOT strict subsets
    assert(!a.is_strict_subset(&b));
    assert(!b.is_strict_subset(&a));
}

@test
fn test_strict_subset_empty() {
    let a: Set<Int> = Set.new();

    let mut b: Set<Int> = Set.new();
    b.insert(1);

    // Empty is strict subset of non-empty
    assert(a.is_strict_subset(&b));
    // Non-empty is NOT strict subset of empty
    assert(!b.is_strict_subset(&a));
}

@test
fn test_strict_subset_both_empty() {
    let a: Set<Int> = Set.new();
    let b: Set<Int> = Set.new();

    // Equal (both empty) → not strict subset
    assert(!a.is_strict_subset(&b));
}

@test
fn test_strict_subset_disjoint() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(3);
    b.insert(4);

    assert(!a.is_strict_subset(&b));
    assert(!b.is_strict_subset(&a));
}

@test
fn test_strict_superset_proper() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);

    assert(a.is_strict_superset(&b));
    assert(!b.is_strict_superset(&a));
}

@test
fn test_strict_superset_equal() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);

    assert(!a.is_strict_superset(&b));
}

@test
fn test_strict_superset_of_empty() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);

    let b: Set<Int> = Set.new();

    assert(a.is_strict_superset(&b));
    assert(!b.is_strict_superset(&a));
}

// =============================================================================
// Section 3: symmetric_difference_update Tests
// =============================================================================

@test
fn test_symmetric_difference_update_basic() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b: Set<Int> = Set.new();
    b.insert(2);
    b.insert(3);
    b.insert(4);

    a.symmetric_difference_update(&b);

    // Should have {1, 4} — only in one set
    assert_eq(a.len(), 2);
    assert(a.contains(&1));
    assert(a.contains(&4));
    assert(!a.contains(&2));
    assert(!a.contains(&3));
}

@test
fn test_symmetric_difference_update_disjoint() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(3);
    b.insert(4);

    a.symmetric_difference_update(&b);

    // All elements from both sets
    assert_eq(a.len(), 4);
    assert(a.contains(&1));
    assert(a.contains(&2));
    assert(a.contains(&3));
    assert(a.contains(&4));
}

@test
fn test_symmetric_difference_update_identical() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);
    b.insert(3);

    a.symmetric_difference_update(&b);

    // All elements in common → empty result
    assert(a.is_empty());
}

@test
fn test_symmetric_difference_update_empty_other() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let b: Set<Int> = Set.new();
    a.symmetric_difference_update(&b);

    // Unchanged
    assert_eq(a.len(), 2);
    assert(a.contains(&1));
    assert(a.contains(&2));
}

@test
fn test_symmetric_difference_update_self_empty() {
    let mut a: Set<Int> = Set.new();

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);

    a.symmetric_difference_update(&b);

    assert_eq(a.len(), 2);
    assert(a.contains(&1));
    assert(a.contains(&2));
}

// =============================================================================
// Section 4: In-Place Set Operation Method Tests
// =============================================================================
// Note: Compound-assign operators (|=, &=, -=, ^=) have protocol impls
// but the type checker doesn't yet resolve them for custom types.
// Tests use the direct methods instead.

@test
fn test_extend_from_set_union() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(2);
    b.insert(3);

    a.extend_from_set(&b);

    assert_eq(a.len(), 3);
    assert(a.contains(&1));
    assert(a.contains(&2));
    assert(a.contains(&3));
}

@test
fn test_extend_from_set_disjoint() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);

    let mut b: Set<Int> = Set.new();
    b.insert(2);

    a.extend_from_set(&b);

    assert_eq(a.len(), 2);
    assert(a.contains(&1));
    assert(a.contains(&2));
}

@test
fn test_extend_from_set_empty_rhs() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let b: Set<Int> = Set.new();
    a.extend_from_set(&b);

    assert_eq(a.len(), 2);
}

@test
fn test_retain_from_set_intersection() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b: Set<Int> = Set.new();
    b.insert(2);
    b.insert(3);
    b.insert(4);

    a.retain_from_set(&b);

    assert_eq(a.len(), 2);
    assert(a.contains(&2));
    assert(a.contains(&3));
    assert(!a.contains(&1));
    assert(!a.contains(&4));
}

@test
fn test_retain_from_set_disjoint() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(3);
    b.insert(4);

    a.retain_from_set(&b);

    assert(a.is_empty());
}

@test
fn test_remove_from_set_difference() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b: Set<Int> = Set.new();
    b.insert(2);
    b.insert(3);

    a.remove_from_set(&b);

    assert_eq(a.len(), 1);
    assert(a.contains(&1));
    assert(!a.contains(&2));
    assert(!a.contains(&3));
}

@test
fn test_remove_from_set_no_overlap() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(3);

    a.remove_from_set(&b);

    assert_eq(a.len(), 2);
    assert(a.contains(&1));
    assert(a.contains(&2));
}

@test
fn test_remove_from_set_all_removed() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);
    b.insert(3);

    a.remove_from_set(&b);

    assert(a.is_empty());
}

// =============================================================================
// Section 5: Integration / Combined Tests
// =============================================================================

@test
fn test_extract_then_extend() {
    let mut s: Set<Int> = Set.new();
    for i in range(1, 6) {
        s.insert(i);
    }

    // Extract evens
    let _evens = s.extract_if(is_even);
    assert_eq(s.len(), 3); // 1, 3, 5

    // Union with another set
    let mut more: Set<Int> = Set.new();
    more.insert(10);
    more.insert(20);
    s.extend_from_set(&more);

    assert_eq(s.len(), 5);
    assert(s.contains(&1));
    assert(s.contains(&10));
    assert(s.contains(&20));
}

@test
fn test_strict_subset_after_extract() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);

    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);
    b.insert(3);

    // Equal — not strict subset
    assert(!a.is_strict_subset(&b));

    // Remove one from a
    let _extracted = a.extract_if(gt_3); // nothing > 3
    assert(!a.is_strict_subset(&b));     // still equal

    a.remove(&3);
    assert(a.is_strict_subset(&b));      // now strict subset
}

@test
fn test_chain_in_place_operations() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);
    a.insert(4);
    a.insert(5);

    // Remove odds via extract_if
    let odds = a.extract_if(is_odd);
    assert_eq(odds.len(), 3); // 1, 3, 5
    assert_eq(a.len(), 2);    // 2, 4

    // Union with 10, 20
    let mut extras: Set<Int> = Set.new();
    extras.insert(10);
    extras.insert(20);
    a.extend_from_set(&extras);
    assert_eq(a.len(), 4); // 2, 4, 10, 20

    // Subtract {4, 10}
    let mut to_remove: Set<Int> = Set.new();
    to_remove.insert(4);
    to_remove.insert(10);
    a.remove_from_set(&to_remove);
    assert_eq(a.len(), 2); // 2, 20
    assert(a.contains(&2));
    assert(a.contains(&20));
}

@test
fn test_inplace_consistency_with_methods() {
    let mut s1: Set<Int> = Set.new();
    s1.insert(1);
    s1.insert(2);
    s1.insert(3);

    let mut s2: Set<Int> = Set.new();
    s2.insert(2);
    s2.insert(3);
    s2.insert(4);

    // extend_from_set should give same result as union()
    let union_result = s1.union(&s2);

    let mut s1_copy: Set<Int> = Set.new();
    s1_copy.insert(1);
    s1_copy.insert(2);
    s1_copy.insert(3);
    s1_copy.extend_from_set(&s2);

    assert_eq(s1_copy.len(), union_result.len());
    assert(s1_copy.contains(&1));
    assert(s1_copy.contains(&2));
    assert(s1_copy.contains(&3));
    assert(s1_copy.contains(&4));
}

@test
fn test_strict_subset_superset_symmetry() {
    let mut small: Set<Int> = Set.new();
    small.insert(1);
    small.insert(2);

    let mut big: Set<Int> = Set.new();
    big.insert(1);
    big.insert(2);
    big.insert(3);

    assert(small.is_strict_subset(&big));
    assert(big.is_strict_superset(&small));
    assert(!big.is_strict_subset(&small));
    assert(!small.is_strict_superset(&big));
}
