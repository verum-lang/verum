// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, heap, extract_if, shrink_to
// @description: Tests BinaryHeap extract_if and shrink_to methods

mount core.*;
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: BinaryHeap.extract_if
// =============================================================================

@test
fn test_heap_extract_if_basic() {
    let mut heap = BinaryHeap.new();
    heap.push(5); heap.push(3); heap.push(8); heap.push(1); heap.push(6);
    // Extract all elements > 4
    let extracted = heap.extract_if(|x| *x > 4);
    assert_eq(extracted.len(), 3);
    assert_eq(heap.len(), 2);
    // Remaining should be 1 and 3
    assert(heap.peek().is_some());
}

@test
fn test_heap_extract_if_none_match() {
    let mut heap = BinaryHeap.new();
    heap.push(1); heap.push(2); heap.push(3);
    let extracted = heap.extract_if(|x| *x > 10);
    assert_eq(extracted.len(), 0);
    assert_eq(heap.len(), 3);
}

@test
fn test_heap_extract_if_all_match() {
    let mut heap = BinaryHeap.new();
    heap.push(1); heap.push(2); heap.push(3);
    let extracted = heap.extract_if(|x| *x > 0);
    assert_eq(extracted.len(), 3);
    assert_eq(heap.len(), 0);
    assert(heap.is_empty());
}

@test
fn test_heap_extract_if_empty() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    let extracted = heap.extract_if(|_x| true);
    assert_eq(extracted.len(), 0);
}

@test
fn test_heap_extract_if_preserves_heap_property() {
    let mut heap = BinaryHeap.new();
    heap.push(10); heap.push(20); heap.push(30); heap.push(40); heap.push(50);
    // Remove odd multiples of 10 (10, 30, 50)
    let extracted = heap.extract_if(|x| (*x / 10) % 2 != 0);
    assert_eq(extracted.len(), 3);
    assert_eq(heap.len(), 2);
    // Pop should yield max first (40, then 20)
    assert_eq(heap.pop(), Some(40));
    assert_eq(heap.pop(), Some(20));
}

@test
fn test_heap_extract_if_even_numbers() {
    let mut heap = BinaryHeap.new();
    heap.push(1); heap.push(2); heap.push(3); heap.push(4); heap.push(5); heap.push(6);
    let evens = heap.extract_if(|x| *x % 2 == 0);
    assert_eq(evens.len(), 3);
    assert_eq(heap.len(), 3);
    // Remaining should be 1, 3, 5
    assert_eq(heap.pop(), Some(5));
    assert_eq(heap.pop(), Some(3));
    assert_eq(heap.pop(), Some(1));
}

@test
fn test_heap_extract_if_single_element() {
    let mut heap = BinaryHeap.new();
    heap.push(42);
    let extracted = heap.extract_if(|x| *x == 42);
    assert_eq(extracted.len(), 1);
    assert_eq(heap.len(), 0);
}

// =============================================================================
// Section 2: BinaryHeap.shrink_to
// =============================================================================

@test
fn test_heap_shrink_to_basic() {
    let mut heap = BinaryHeap.new();
    let mut i = 0;
    while i < 100 {
        heap.push(i);
        i = i + 1;
    }
    // Remove most elements
    while heap.len() > 5 {
        heap.pop();
    }
    assert_eq(heap.len(), 5);
    // Shrink to 10 (capacity will be at least 10, at least 5)
    heap.shrink_to(10);
    assert_eq(heap.len(), 5);
    // Heap still works
    assert(heap.peek().is_some());
}

@test
fn test_heap_shrink_to_zero() {
    let mut heap = BinaryHeap.new();
    heap.push(1); heap.push(2); heap.push(3);
    // Shrink to 0 — capacity will be at least len (3)
    heap.shrink_to(0);
    assert_eq(heap.len(), 3);
}

@test
fn test_heap_shrink_to_empty() {
    let mut heap: BinaryHeap<Int> = BinaryHeap.new();
    heap.shrink_to(0);
    assert_eq(heap.len(), 0);
}

@test
fn test_heap_shrink_to_large_min() {
    let mut heap = BinaryHeap.new();
    heap.push(1); heap.push(2);
    // Shrink to 1000 — no-op since capacity is likely smaller
    heap.shrink_to(1000);
    assert_eq(heap.len(), 2);
}

@test
fn test_heap_shrink_to_preserves_heap() {
    let mut heap = BinaryHeap.new();
    heap.push(50); heap.push(30); heap.push(40); heap.push(10); heap.push(20);
    heap.shrink_to(5);
    // Heap property should be maintained
    assert_eq(heap.pop(), Some(50));
    assert_eq(heap.pop(), Some(40));
    assert_eq(heap.pop(), Some(30));
    assert_eq(heap.pop(), Some(20));
    assert_eq(heap.pop(), Some(10));
}
