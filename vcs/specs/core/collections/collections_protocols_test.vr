// --- BTreeSet Clone ---

@test
fn test_btreeset_clone() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(3);
    s.insert(1);
    s.insert(2);
    let cloned = s.clone();
    assert_eq(cloned.len(), 3);
}

// --- BTreeSet Default ---

@test
fn test_btreeset_default() {
    let s: BTreeSet<Int> = BTreeSet.default();
    assert(s.is_empty());
}

// --- BTreeSet Eq ---

@test
fn test_btreeset_eq() {
    let mut a: BTreeSet<Int> = BTreeSet.new();
    a.insert(1);
    a.insert(2);
    let mut b: BTreeSet<Int> = BTreeSet.new();
    b.insert(2);
    b.insert(1);
    assert(a == b);
}

@test
fn test_btreeset_ne() {
    let mut a: BTreeSet<Int> = BTreeSet.new();
    a.insert(1);
    let mut b: BTreeSet<Int> = BTreeSet.new();
    b.insert(2);
    assert(a != b);
}

// --- BTreeSet Debug/Display ---

@test
fn test_btreeset_debug() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(1);
    let text = format_debug(&s);
    assert(text.len() > 0);
}

@test
fn test_btreeset_display() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(1);
    let text = format_display(&s);
    assert(text.len() > 0);
}

// --- BTreeSet FromIterator ---

@test
fn test_btreeset_from_iter() {
    let s: BTreeSet<Int> = BTreeSet.from_iter(range(1, 6));
    assert_eq(s.len(), 5);
}

// --- BTreeSet Extend ---

@test
fn test_btreeset_extend() {
    let mut s: BTreeSet<Int> = BTreeSet.new();
    s.insert(1);
    s.extend(range(2, 5));
    assert_eq(s.len(), 4);
}

