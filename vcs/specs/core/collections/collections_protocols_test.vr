// --- BTreeMap Clone ---

@test
fn test_btreemap_clone() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 10);
    m.insert(2, 20);
    let cloned = m.clone();
    assert_eq(cloned.len(), 2);
}

@test
fn test_btreemap_clone_empty() {
    let m: BTreeMap<Int, Int> = BTreeMap.new();
    let cloned = m.clone();
    assert(cloned.is_empty());
}

// --- BTreeMap Default ---

@test
fn test_btreemap_default() {
    let m: BTreeMap<Int, Int> = BTreeMap.default();
    assert(m.is_empty());
}

// --- BTreeMap Eq ---

@test
fn test_btreemap_eq_same() {
    let mut a: BTreeMap<Int, Int> = BTreeMap.new();
    a.insert(1, 10);
    a.insert(2, 20);
    let mut b: BTreeMap<Int, Int> = BTreeMap.new();
    b.insert(1, 10);
    b.insert(2, 20);
    assert(a == b);
}

@test
fn test_btreemap_ne_different() {
    let mut a: BTreeMap<Int, Int> = BTreeMap.new();
    a.insert(1, 10);
    let mut b: BTreeMap<Int, Int> = BTreeMap.new();
    b.insert(1, 99);
    assert(a != b);
}

@test
fn test_btreemap_eq_empty() {
    let a: BTreeMap<Int, Int> = BTreeMap.new();
    let b: BTreeMap<Int, Int> = BTreeMap.new();
    assert(a == b);
}

// --- BTreeMap Debug/Display ---

@test
fn test_btreemap_debug() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 10);
    let text = format_debug(&m);
    assert(text.len() > 0);
}

@test
fn test_btreemap_display() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 10);
    let text = format_display(&m);
    assert(text.len() > 0);
}

// --- BTreeMap FromIterator ---

@test
fn test_btreemap_from_iter() {
    let pairs: List<(Int, Int)> = [(3, 30), (1, 10), (2, 20)];
    let m: BTreeMap<Int, Int> = BTreeMap.from_iter(pairs.iter().map(|p| *p));
    assert_eq(m.len(), 3);
}

// --- BTreeMap Extend ---

@test
fn test_btreemap_extend() {
    let mut m: BTreeMap<Int, Int> = BTreeMap.new();
    m.insert(1, 10);
    let extra: List<(Int, Int)> = [(2, 20), (3, 30)];
    m.extend(extra.iter().map(|p| *p));
    assert_eq(m.len(), 3);
}

// =============================================================================
// BTREESET<T> PROTOCOL TESTS
