// --- BinaryHeap Clone ---

@test
fn test_heap_clone() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(3);
    h.push(1);
    h.push(2);
    let cloned = h.clone();
    assert_eq(cloned.len(), 3);
}

@test
fn test_heap_clone_empty() {
    let h: BinaryHeap<Int> = BinaryHeap.new();
    let cloned = h.clone();
    assert(cloned.is_empty());
}

// --- BinaryHeap Default ---

@test
fn test_heap_default() {
    let h: BinaryHeap<Int> = BinaryHeap.default();
    assert(h.is_empty());
}

@test
fn test_heap_default_usable() {
    let mut h: BinaryHeap<Int> = BinaryHeap.default();
    h.push(42);
    assert_eq(h.len(), 1);
}

// --- BinaryHeap Debug/Display ---

@test
fn test_heap_debug() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(42);
    let text = format_debug(&h);
    assert(text.len() > 0);
}

@test
fn test_heap_display() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(42);
    let text = format_display(&h);
    assert(text.len() > 0);
}

// --- BinaryHeap FromIterator ---

@test
fn test_heap_from_iter() {
    let h: BinaryHeap<Int> = BinaryHeap.from_iter(range(1, 6));
    assert_eq(h.len(), 5);
}

@test
fn test_heap_from_iter_empty() {
    let h: BinaryHeap<Int> = BinaryHeap.from_iter(empty());
    assert(h.is_empty());
}

// --- BinaryHeap Extend ---

@test
fn test_heap_extend() {
    let mut h: BinaryHeap<Int> = BinaryHeap.new();
    h.push(1);
    h.extend(range(2, 5));
    assert_eq(h.len(), 4);
}

// =============================================================================
// LIST<T> PROTOCOL TESTS (gaps)
// =============================================================================

// --- List Debug/Display ---

@test
fn test_list_debug_empty() {
    let l: List<Int> = [];
    let text = format_debug(&l);
    assert(text.len() > 0);
}

@test
fn test_list_debug_nonempty() {
    let l: List<Int> = [1, 2, 3];
    let text = format_debug(&l);
    assert(text.contains(&"1"));
    assert(text.contains(&"3"));
}

@test
fn test_list_display_empty() {
    let l: List<Int> = [];
    let text = format_display(&l);
    assert(text.len() > 0);
}

@test
fn test_list_display_nonempty() {
    let l: List<Int> = [1, 2, 3];
    let text = format_display(&l);
    assert(text.contains(&"1"));
}

// --- List FromIterator ---

@test
fn test_list_from_iter_range() {
    let l: List<Int> = List.from_iter(range(1, 6));
    assert_eq(l.len(), 5);
}

@test
fn test_list_from_iter_empty() {
    let l: List<Int> = List.from_iter(empty());
    assert(l.is_empty());
}

@test
fn test_list_from_iter_mapped() {
    let src: List<Int> = [1, 2, 3];
    let doubled: List<Int> = List.from_iter(src.iter().map(|x| *x * 2));
    assert_eq(doubled.len(), 3);
}

// --- List Default ---

@test
fn test_list_default() {
    let l: List<Int> = List.default();
    assert(l.is_empty());
}

// --- List Eq ---

@test
fn test_list_eq_same() {
    let a: List<Int> = [1, 2, 3];
    let b: List<Int> = [1, 2, 3];
    assert(a == b);
}

@test
fn test_list_ne_different() {
    let a: List<Int> = [1, 2, 3];
    let b: List<Int> = [1, 2, 4];
    assert(a != b);
}

@test
fn test_list_ne_different_length() {
    let a: List<Int> = [1, 2];
    let b: List<Int> = [1, 2, 3];
    assert(a != b);
}

@test
fn test_list_eq_empty() {
    let a: List<Int> = [];
    let b: List<Int> = [];
    assert(a == b);
}

// --- List constructor ---

@test
fn test_list_constructor() {
    let l = list([1, 2, 3, 4, 5]);
    assert_eq(l.len(), 5);
}

// =============================================================================
// CROSS-COLLECTION TESTS
// =============================================================================

@test
fn test_collect_range_into_set() {
    let s: Set<Int> = Set.from_iter(range(0, 10));
    assert_eq(s.len(), 10);
}

@test
fn test_collect_range_into_list() {
    let l: List<Int> = List.from_iter(range(0, 10));
    assert_eq(l.len(), 10);
}

@test
fn test_collect_range_into_deque() {
    let d: Deque<Int> = Deque.from_iter(range(0, 10));
    assert_eq(d.len(), 10);
}

@test
fn test_collect_range_into_btreeset() {
    let s: BTreeSet<Int> = BTreeSet.from_iter(range(0, 10));
    assert_eq(s.len(), 10);
}

@test
fn test_collect_range_into_heap() {
    let h: BinaryHeap<Int> = BinaryHeap.from_iter(range(0, 10));
    assert_eq(h.len(), 10);
}
