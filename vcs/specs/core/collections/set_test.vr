@test
fn test_set_union_with_self() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    let u = s.union(&s);
    assert_eq(u.len(), 3);
}

@test
fn test_set_intersection_with_self() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    let inter = s.intersection(&s);
    assert_eq(inter.len(), 3);
}

@test
fn test_set_difference_with_self() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    let diff = s.difference(&s);
    assert(diff.is_empty());
}

@test
fn test_set_symmetric_difference_with_self() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    let sym = s.symmetric_difference(&s);
    assert(sym.is_empty());
}

// =============================================================================
// Section: Set Algebra — Empty Set Identity
// =============================================================================

@test
fn test_set_union_identity() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    let empty: Set<Int> = Set.new();
    let u1 = s.union(&empty);
    let u2 = empty.union(&s);
    assert_eq(u1.len(), 2);
    assert_eq(u2.len(), 2);
}

@test
fn test_set_intersection_with_empty() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    let empty: Set<Int> = Set.new();
    let inter1 = s.intersection(&empty);
    let inter2 = empty.intersection(&s);
    assert(inter1.is_empty());
    assert(inter2.is_empty());
}

@test
fn test_set_difference_from_empty() {
    let empty: Set<Int> = Set.new();
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    let diff = empty.difference(&s);
    assert(diff.is_empty());
}

// =============================================================================
// Section: Subset/Superset — Extended
// =============================================================================

@test
fn test_set_empty_subset_of_all() {
    let empty: Set<Int> = Set.new();
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    assert(empty.is_subset(&s));
    assert(empty.is_subset(&empty));
}

@test
fn test_set_equal_sets_subset() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);
    assert(a.is_subset(&b));
    assert(b.is_subset(&a));
    assert(a.is_superset(&b));
    assert(b.is_superset(&a));
}

@test
fn test_set_not_subset_when_extra_element() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(99);
    let mut b: Set<Int> = Set.new();
    b.insert(1);
    b.insert(2);
    b.insert(3);
    assert(!a.is_subset(&b)); // a has 99, which is not in b
}

// =============================================================================
// Section: Iterator — Extended
// =============================================================================

@test
fn test_set_iter_empty() {
    let s: Set<Int> = Set.new();
    let mut count = 0;
    let mut iter = s.iter();
    loop {
        match iter.next() {
            Some(_) => count = count + 1,
            None => break,
        }
    }
    assert_eq(count, 0);
}

@test
fn test_set_iter_single() {
    let mut s: Set<Int> = Set.new();
    s.insert(42);
    let mut count = 0;
    let mut val = 0;
    let mut iter = s.iter();
    loop {
        match iter.next() {
            Some(v) => {
                count = count + 1;
                val = *v;
            }
            None => break,
        }
    }
    assert_eq(count, 1);
    assert_eq(val, 42);
}

@test
fn test_set_iter_large() {
    let mut s: Set<Int> = Set.new();
    for i in 0..50 {
        s.insert(i);
    }
    let mut count = 0;
    let mut iter = s.iter();
    loop {
        match iter.next() {
            Some(_) => count = count + 1,
            None => break,
        }
    }
    assert_eq(count, 50);
}

// =============================================================================
// Section: Capacity — Extended
// =============================================================================

@test
fn test_set_capacity_grows() {
    let mut s: Set<Int> = Set.new();
    for i in 0..100 {
        s.insert(i);
    }
    assert(s.capacity() >= 100);
}

@test
fn test_set_reserve_then_insert() {
    let mut s: Set<Int> = Set.new();
    s.reserve(200);
    for i in 0..100 {
        s.insert(i);
    }
    assert_eq(s.len(), 100);
    assert(s.capacity() >= 200);
}

@test
fn test_set_shrink_after_remove() {
    let mut s: Set<Int> = Set.new();
    for i in 0..100 {
        s.insert(i);
    }
    for i in 0..90 {
        s.remove(&i);
    }
    s.shrink_to_fit();
    assert_eq(s.len(), 10);
    for i in 90..100 {
        assert(s.contains(&i));
    }
}

@test
fn test_set_shrink_to_min() {
    let mut s: Set<Int> = Set.with_capacity(100);
    s.insert(1);
    s.insert(2);
    s.shrink_to(5);
    assert_eq(s.len(), 2);
    assert(s.contains(&1));
    assert(s.contains(&2));
}

// =============================================================================
// Section: Stress Tests — Extended
// =============================================================================

@test
fn test_set_insert_200() {
    let mut s: Set<Int> = Set.new();
    for i in 0..200 {
        s.insert(i);
    }
    assert_eq(s.len(), 200);
    assert(s.contains(&0));
    assert(s.contains(&100));
    assert(s.contains(&199));
}

@test
fn test_set_insert_remove_cycle() {
    let mut s: Set<Int> = Set.new();
    for i in 0..50 {
        s.insert(i);
    }
    for i in 0..25 {
        s.remove(&i);
    }
    assert_eq(s.len(), 25);
    for i in 25..50 {
        assert(s.contains(&i));
    }
    for i in 0..25 {
        assert(!s.contains(&i));
    }
}

@test
fn test_set_clear_and_reuse() {
    let mut s: Set<Int> = Set.new();
    for i in 0..20 {
        s.insert(i);
    }
    s.clear();
    assert(s.is_empty());
    for i in 100..110 {
        s.insert(i);
    }
    assert_eq(s.len(), 10);
    assert(s.contains(&100));
    assert(!s.contains(&0));
}

@test
fn test_set_repeated_clear_insert() {
    let mut s: Set<Int> = Set.new();
    for round in 0..5 {
        for i in 0..10 {
            s.insert(round * 10 + i);
        }
        s.clear();
        assert(s.is_empty());
    }
}

@test
fn test_set_alternating_operations() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    assert(s.contains(&1));
    s.remove(&1);
    assert(!s.contains(&1));
    s.insert(1);
    assert(s.contains(&1));
    s.insert(2);
    s.remove(&1);
    assert(!s.contains(&1));
    assert(s.contains(&2));
}

