@test
fn test_set_take_all_elements() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    assert_eq(s.take(&1).unwrap(), 1);
    assert_eq(s.take(&2).unwrap(), 2);
    assert_eq(s.take(&3).unwrap(), 3);
    assert(s.is_empty());
}

@test
fn test_set_take_nonexistent() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    assert(s.take(&99).is_none());
    assert_eq(s.len(), 1);
}

@test
fn test_set_take_text() {
    let mut s: Set<Text> = Set.new();
    s.insert("hello");
    s.insert("world");
    assert_eq(s.take(&"hello").unwrap(), "hello");
    assert_eq(s.len(), 1);
    assert(!s.contains(&"hello"));
    assert(s.contains(&"world"));
}

// =============================================================================
// Section: Get — Extended Tests
// =============================================================================

@test
fn test_set_get_text() {
    let mut s: Set<Text> = Set.new();
    s.insert("test");
    match s.get(&"test") {
        Some(v) => assert_eq(*v, "test"),
        None => panic("Expected Some"),
    }
}

@test
fn test_set_get_after_remove() {
    let mut s: Set<Int> = Set.new();
    s.insert(42);
    s.remove(&42);
    assert(s.get(&42).is_none());
}

@test
fn test_set_get_empty() {
    let s: Set<Int> = Set.new();
    assert(s.get(&1).is_none());
}

