@test
fn test_set_union_large() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    for i in 0..50 {
        a.insert(i);
    }
    for i in 25..75 {
        b.insert(i);
    }
    let u = a.union(&b);
    assert_eq(u.len(), 75); // 0..75
}

@test
fn test_set_intersection_large() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    for i in 0..50 {
        a.insert(i);
    }
    for i in 25..75 {
        b.insert(i);
    }
    let inter = a.intersection(&b);
    assert_eq(inter.len(), 25); // 25..50
}

@test
fn test_set_difference_large() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    for i in 0..50 {
        a.insert(i);
    }
    for i in 25..75 {
        b.insert(i);
    }
    let diff = a.difference(&b);
    assert_eq(diff.len(), 25); // 0..25
}

@test
fn test_set_symmetric_difference_large() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    for i in 0..50 {
        a.insert(i);
    }
    for i in 25..75 {
        b.insert(i);
    }
    let sym = a.symmetric_difference(&b);
    assert_eq(sym.len(), 50); // 0..25 + 50..75
}

// =============================================================================
// Section: Combined Workflow Patterns
// =============================================================================

@test
fn test_set_build_union_check_membership() {
    let mut evens: Set<Int> = Set.new();
    let mut odds: Set<Int> = Set.new();
    for i in 0..20 {
        if i % 2 == 0 {
            evens.insert(i);
        } else {
            odds.insert(i);
        }
    }
    let all = evens.union(&odds);
    assert_eq(all.len(), 20);
    for i in 0..20 {
        assert(all.contains(&i));
    }
}

@test
fn test_set_build_difference_verify() {
    let mut all: Set<Int> = Set.new();
    let mut remove_set: Set<Int> = Set.new();
    for i in 0..20 {
        all.insert(i);
    }
    for i in 5..15 {
        remove_set.insert(i);
    }
    let remaining = all.difference(&remove_set);
    assert_eq(remaining.len(), 10);
    for i in 0..5 {
        assert(remaining.contains(&i));
    }
    for i in 15..20 {
        assert(remaining.contains(&i));
    }
}

@test
fn test_set_retain_then_union() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    for i in 0..10 {
        a.insert(i);
        b.insert(i + 5);
    }
    a.retain(|x| *x < 5);
    let u = a.union(&b);
    assert_eq(a.len(), 5); // 0..5
    assert_eq(u.len(), 15); // 0..5 + 5..15
}

@test
fn test_set_extend_then_retain() {
    let mut s: Set<Int> = Set.new();
    s.insert(1);
    s.insert(2);
    let mut more: Set<Int> = Set.new();
    more.insert(3);
    more.insert(4);
    more.insert(5);
    s.extend_from_set(&more);
    assert_eq(s.len(), 5);
    s.retain(|x| *x > 2);
    assert_eq(s.len(), 3);
    assert(s.contains(&3));
    assert(s.contains(&4));
    assert(s.contains(&5));
}

@test
fn test_set_remove_from_set_then_check() {
    let mut s: Set<Int> = Set.new();
    for i in 0..10 {
        s.insert(i);
    }
    let mut to_remove: Set<Int> = Set.new();
    to_remove.insert(0);
    to_remove.insert(5);
    to_remove.insert(9);
    s.remove_from_set(&to_remove);
    assert_eq(s.len(), 7);
    assert(!s.contains(&0));
    assert(!s.contains(&5));
    assert(!s.contains(&9));
    assert(s.contains(&1));
    assert(s.contains(&8));
}

// =============================================================================
// Section: Len/is_empty Tracking
// =============================================================================

@test
fn test_set_len_tracking() {
    let mut s: Set<Int> = Set.new();
    assert_eq(s.len(), 0);
    s.insert(1);
    assert_eq(s.len(), 1);
    s.insert(2);
    assert_eq(s.len(), 2);
    s.insert(2); // Duplicate
    assert_eq(s.len(), 2);
    s.remove(&1);
    assert_eq(s.len(), 1);
    s.remove(&2);
    assert_eq(s.len(), 0);
}

@test
fn test_set_is_empty_transitions() {
    let mut s: Set<Int> = Set.new();
    assert(s.is_empty());
    s.insert(1);
    assert(!s.is_empty());
    s.remove(&1);
    assert(s.is_empty());
}

