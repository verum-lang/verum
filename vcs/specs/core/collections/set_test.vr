@test
fn test_set_extend_from_set_overlapping() {
    let mut a: Set<Int> = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);
    let mut b: Set<Int> = Set.new();
    b.insert(2);
    b.insert(3);
    b.insert(4);
    a.extend_from_set(&b);
    assert_eq(a.len(), 4);
    assert(a.contains(&1));
    assert(a.contains(&4));
}

