    let mut a = BTreeSet.new();
    a.insert(1); a.insert(2); a.insert(3);
    let mut b = BTreeSet.new();
    b.insert(1); b.insert(2); b.insert(3); b.insert(4); b.insert(5);
    a &= &b;
    assert_eq(a.len(), 3);
    assert(a.contains(&1));
    assert(a.contains(&2));
    assert(a.contains(&3));
}

@test
fn test_bitand_assign_empty_rhs() {
    let mut a = BTreeSet.new();
    a.insert(1); a.insert(2);
    let b: BTreeSet<Int> = BTreeSet.new();
    a &= &b;
    assert_eq(a.len(), 0);
