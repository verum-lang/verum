// =============================================================================
// deque_range_test.vr - Tests for Deque.range()
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, deque, range
// @description: Tests for Deque.range() - returns a sub-slice as List
// =============================================================================

mount core.collections.deque.{Deque};
mount core.collections.list.List;

// =============================================================================
// PART 1: Basic range operations
// =============================================================================

@test
fn test_range_full_deque() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);

    let result: List<Int> = d.range(0, 3);

    assert_eq(result.len(), 3);
    assert_eq(result[0], 10);
    assert_eq(result[1], 20);
    assert_eq(result[2], 30);
}

@test
fn test_range_first_half() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);

    let result: List<Int> = d.range(0, 2);

    assert_eq(result.len(), 2);
    assert_eq(result[0], 1);
    assert_eq(result[1], 2);
}

@test
fn test_range_last_half() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);

    let result: List<Int> = d.range(2, 4);

    assert_eq(result.len(), 2);
    assert_eq(result[0], 3);
    assert_eq(result[1], 4);
}

@test
fn test_range_empty_from_eq_to() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let result: List<Int> = d.range(1, 1);

    assert_eq(result.len(), 0);
}

@test
fn test_range_single_element() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(100);
    d.push_back(200);
    d.push_back(300);

    let result: List<Int> = d.range(1, 2);

    assert_eq(result.len(), 1);
    assert_eq(result[0], 200);
}

@test
fn test_range_empty_deque() {
    let mut d: Deque<Int> = Deque.new();

    let result: List<Int> = d.range(0, 0);

    assert_eq(result.len(), 0);
}

@test
fn test_range_bounds_clamping() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    // to > len should be clamped
    let result: List<Int> = d.range(0, 100);

    assert_eq(result.len(), 3);
    assert_eq(result[0], 1);
    assert_eq(result[1], 2);
    assert_eq(result[2], 3);
}

@test
fn test_range_preserves_order() {
    let mut d: Deque<Int> = Deque.new();
    // Mix front and back pushes to wrap the ring buffer
    d.push_back(3);
    d.push_back(4);
    d.push_back(5);
    d.push_front(2);
    d.push_front(1);

    // Logical order: 1, 2, 3, 4, 5
    let result: List<Int> = d.range(1, 4);

    assert_eq(result.len(), 3);
    assert_eq(result[0], 2);
    assert_eq(result[1], 3);
    assert_eq(result[2], 4);
}
