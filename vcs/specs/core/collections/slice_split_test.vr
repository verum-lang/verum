// =============================================================================
// slice_split_test.vr - Tests for slice split operations
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, slice, split, iterator, core
// @description: Comprehensive tests for predicate-based slice splitting:
//               split, split_inclusive, splitn, rsplit, rsplitn
// =============================================================================

mount core.*;
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.base.ordering.{Ordering};
mount core.collections.slice.{Split, SplitInclusive, SplitN, RSplit, RSplitN};

// =============================================================================
// Helper predicates
// =============================================================================

fn is_zero(x: &Int) -> Bool {
    *x == 0
}

fn is_even(x: &Int) -> Bool {
    *x % 2 == 0
}

fn is_negative(x: &Int) -> Bool {
    *x < 0
}

fn always_true(x: &Int) -> Bool {
    true
}

fn always_false(x: &Int) -> Bool {
    false
}

// =============================================================================
// Section 1: split() Tests
// =============================================================================

@test
fn test_split_basic() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // Should yield [1], [2], [3]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first split"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second split"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third split"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_no_matches() {
    let arr = [1, 2, 3, 4, 5];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // No zeros — should yield the entire slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 5),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_all_match() {
    let arr = [0, 0, 0];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // All zeros — yields 4 empty slices: "", 0, "", 0, "", 0, ""
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected first empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected second empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected third empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected fourth empty"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_empty_slice() {
    let arr: [Int; 0] = [];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // Empty slice yields one empty slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected one empty result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_single_element_match() {
    let arr = [0];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // [0] splits into: empty, empty
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected first empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected second empty"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_single_element_no_match() {
    let arr = [42];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_match_at_start() {
    let arr = [0, 1, 2, 3];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // Leading zero: empty, [1, 2, 3]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected empty first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected second"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_match_at_end() {
    let arr = [1, 2, 3, 0];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // Trailing zero: [1, 2, 3], empty
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected trailing empty"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_consecutive_matches() {
    let arr = [1, 0, 0, 2];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // Two consecutive zeros: [1], [], [2]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected empty between"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_by_even() {
    let arr = [1, 2, 3, 4, 5];
    let slice = &arr;
    let mut iter = slice.split(is_even);

    // Split on 2 and 4: [1], [3], [5]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_with_collect() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut count = 0;
    for part in slice.split(is_zero) {
        count = count + 1;
    }
    assert_eq(count, 3);
}

// =============================================================================
// Section 2: split_inclusive() Tests
// =============================================================================

@test
fn test_split_inclusive_basic() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    // Should yield [1, 0], [2, 0], [3]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 2),
        None => panic("Expected first inclusive split"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 2),
        None => panic("Expected second inclusive split"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third inclusive split"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_inclusive_no_matches() {
    let arr = [1, 2, 3];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    // No zeros — yields the entire slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_inclusive_match_at_end() {
    let arr = [1, 2, 0];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    // [1, 2, 0]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_inclusive_all_match() {
    let arr = [0, 0, 0];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    // Each element is a match: [0], [0], [0]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_inclusive_empty() {
    let arr: [Int; 0] = [];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    // Empty slice yields nothing
    assert(iter.next().is_none());
}

@test
fn test_split_inclusive_single_match() {
    let arr = [0];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_inclusive_single_no_match() {
    let arr = [42];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_inclusive_consecutive() {
    let arr = [1, 0, 0, 2];
    let slice = &arr;
    let mut iter = slice.split_inclusive(is_zero);

    // [1, 0], [0], [2]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 2),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third"),
    }
    assert(iter.next().is_none());
}

// =============================================================================
// Section 3: splitn() Tests
// =============================================================================

@test
fn test_splitn_basic() {
    let arr = [1, 0, 2, 0, 3, 0, 4];
    let slice = &arr;
    let mut iter = slice.splitn(3, is_zero);

    // Split at most 3 times: [1], [2], [3, 0, 4]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => {
            // Remainder: [3, 0, 4]
            assert_eq(s.len(), 3);
        }
        None => panic("Expected remainder"),
    }
    assert(iter.next().is_none());
}

@test
fn test_splitn_n_equals_1() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.splitn(1, is_zero);

    // n=1 — no splitting, return entire slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 5),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_splitn_n_equals_2() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.splitn(2, is_zero);

    // n=2: [1], [2, 0, 3]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected remainder"),
    }
    assert(iter.next().is_none());
}

@test
fn test_splitn_n_larger_than_splits() {
    let arr = [1, 0, 2];
    let slice = &arr;
    let mut iter = slice.splitn(10, is_zero);

    // Only 1 zero — splits into [1], [2], regardless of large n
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    assert(iter.next().is_none());
}

@test
fn test_splitn_no_matches() {
    let arr = [1, 2, 3];
    let slice = &arr;
    let mut iter = slice.splitn(3, is_zero);

    // No zeros — entire slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_splitn_n_equals_0() {
    let arr = [1, 0, 2];
    let slice = &arr;
    let mut iter = slice.splitn(0, is_zero);

    // n=0 — yields nothing
    assert(iter.next().is_none());
}

@test
fn test_splitn_empty_slice() {
    let arr: [Int; 0] = [];
    let slice = &arr;
    let mut iter = slice.splitn(3, is_zero);

    // Empty slice with n>0 yields one empty slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected one empty result"),
    }
    assert(iter.next().is_none());
}

// =============================================================================
// Section 4: rsplit() Tests
// =============================================================================

@test
fn test_rsplit_basic() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.rsplit(is_zero);

    // Reverse split on zeros: [3], [2], [1]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first (from end)"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third (first from start)"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplit_no_matches() {
    let arr = [1, 2, 3];
    let slice = &arr;
    let mut iter = slice.rsplit(is_zero);

    // No zeros — yields entire slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplit_empty_slice() {
    let arr: [Int; 0] = [];
    let slice = &arr;
    let mut iter = slice.rsplit(is_zero);

    // Empty slice yields one empty slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected one empty result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplit_all_match() {
    let arr = [0, 0, 0];
    let slice = &arr;
    let mut iter = slice.rsplit(is_zero);

    // [0, 0, 0] rsplit: empty, empty, empty, empty
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected first empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected second empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected third empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected fourth empty"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplit_match_at_start() {
    let arr = [0, 1, 2];
    let slice = &arr;
    let mut iter = slice.rsplit(is_zero);

    // [0, 1, 2] rsplit: [1, 2], empty
    match iter.next() {
        Some(s) => assert_eq(s.len(), 2),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected trailing empty"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplit_match_at_end() {
    let arr = [1, 2, 0];
    let slice = &arr;
    let mut iter = slice.rsplit(is_zero);

    // [1, 2, 0] rsplit: empty, [1, 2]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected first empty"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 2),
        None => panic("Expected second"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplit_with_collect() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut count = 0;
    for part in slice.rsplit(is_zero) {
        count = count + 1;
    }
    assert_eq(count, 3);
}

// =============================================================================
// Section 5: rsplitn() Tests
// =============================================================================

@test
fn test_rsplitn_basic() {
    let arr = [1, 0, 2, 0, 3, 0, 4];
    let slice = &arr;
    let mut iter = slice.rsplitn(3, is_zero);

    // Split at most 3 from end: [4], [3], [1, 0, 2]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first from end"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => {
            // Remainder: [1, 0, 2]
            assert_eq(s.len(), 3);
        }
        None => panic("Expected remainder"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplitn_n_equals_1() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.rsplitn(1, is_zero);

    // n=1 — no splitting, return entire slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 5),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplitn_n_equals_2() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.rsplitn(2, is_zero);

    // n=2 from end: [3], [1, 0, 2]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected remainder"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplitn_n_equals_0() {
    let arr = [1, 0, 2];
    let slice = &arr;
    let mut iter = slice.rsplitn(0, is_zero);

    // n=0 — yields nothing
    assert(iter.next().is_none());
}

@test
fn test_rsplitn_no_matches() {
    let arr = [1, 2, 3];
    let slice = &arr;
    let mut iter = slice.rsplitn(3, is_zero);

    // No zeros — entire slice
    match iter.next() {
        Some(s) => assert_eq(s.len(), 3),
        None => panic("Expected one result"),
    }
    assert(iter.next().is_none());
}

@test
fn test_rsplitn_n_larger_than_splits() {
    let arr = [1, 0, 2];
    let slice = &arr;
    let mut iter = slice.rsplitn(10, is_zero);

    // Only 1 zero — [2], [1]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    assert(iter.next().is_none());
}

// =============================================================================
// Section 6: split() with various predicates
// =============================================================================

@test
fn test_split_by_negative() {
    let arr = [1, 2, -1, 3, 4, -2, 5];
    let slice = &arr;
    let mut iter = slice.split(is_negative);

    // Split on negatives: [1, 2], [3, 4], [5]
    match iter.next() {
        Some(s) => assert_eq(s.len(), 2),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 2),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected third"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_all_match_predicate() {
    let arr = [2, 4, 6, 8];
    let slice = &arr;
    let mut iter = slice.split(is_even);

    // All even — yields 5 empty slices
    let mut count = 0;
    for part in slice.split(is_even) {
        assert_eq(part.len(), 0);
        count = count + 1;
    }
    assert_eq(count, 5);
}

@test
fn test_split_none_match_predicate() {
    let arr = [1, 3, 5, 7];
    let slice = &arr;
    let mut count = 0;
    for part in slice.split(is_even) {
        count = count + 1;
    }
    assert_eq(count, 1);
}

// =============================================================================
// Section 7: Size hint tests
// =============================================================================

@test
fn test_split_size_hint() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.split(is_zero);
    let hint = iter.size_hint();
    // At least 1, at most len+1 = 6
    assert(hint.0 >= 1);
}

@test
fn test_splitn_size_hint() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.splitn(3, is_zero);
    let hint = iter.size_hint();
    assert(hint.0 >= 1);
}

@test
fn test_rsplit_size_hint() {
    let arr = [1, 0, 2, 0, 3];
    let slice = &arr;
    let mut iter = slice.rsplit(is_zero);
    let hint = iter.size_hint();
    assert(hint.0 >= 1);
}

// =============================================================================
// Section 8: Larger data tests
// =============================================================================

@test
fn test_split_larger_array() {
    let arr = [1, 2, 3, 0, 4, 5, 0, 6, 7, 8, 9, 0, 10];
    let slice = &arr;
    let mut count = 0;
    for part in slice.split(is_zero) {
        count = count + 1;
    }
    // 3 zeros -> 4 parts
    assert_eq(count, 4);
}

@test
fn test_splitn_with_larger_array() {
    let arr = [1, 0, 2, 0, 3, 0, 4, 0, 5];
    let slice = &arr;
    let mut count = 0;
    for part in slice.splitn(3, is_zero) {
        count = count + 1;
    }
    assert_eq(count, 3);
}

@test
fn test_rsplitn_with_larger_array() {
    let arr = [1, 0, 2, 0, 3, 0, 4, 0, 5];
    let slice = &arr;
    let mut count = 0;
    for part in slice.rsplitn(3, is_zero) {
        count = count + 1;
    }
    assert_eq(count, 3);
}

@test
fn test_split_inclusive_larger() {
    let arr = [1, 2, 0, 3, 4, 0, 5];
    let slice = &arr;
    let mut count = 0;
    for part in slice.split_inclusive(is_zero) {
        count = count + 1;
    }
    // [1,2,0], [3,4,0], [5] — 3 parts
    assert_eq(count, 3);
}

// =============================================================================
// Section 9: Edge cases with two-element arrays
// =============================================================================

@test
fn test_split_two_elements_match_first() {
    let arr = [0, 1];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected second"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_two_elements_match_second() {
    let arr = [1, 0];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    match iter.next() {
        Some(s) => assert_eq(s.len(), 1),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected second"),
    }
    assert(iter.next().is_none());
}

@test
fn test_split_two_elements_both_match() {
    let arr = [0, 0];
    let slice = &arr;
    let mut iter = slice.split(is_zero);

    // Three empty slices
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected first"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected second"),
    }
    match iter.next() {
        Some(s) => assert_eq(s.len(), 0),
        None => panic("Expected third"),
    }
    assert(iter.next().is_none());
}
