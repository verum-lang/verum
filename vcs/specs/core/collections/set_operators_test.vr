// =============================================================================
// set_operators_test.vr - Tests for Set operator protocol implementations,
//                         standard protocol implementations, and constructors
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, set, operators, protocols, clone, default, eq, debug,
//        display, from_iter, extend, constructor, production, core
// @description: Comprehensive tests for Set<T> operator protocol method calls
//               (bitor, bitand, sub, bitxor and their assign variants),
//               protocol implementations (Clone, Default, Eq, Debug, Display,
//               FromIterator, Extend, Hash, IntoIterator), constructor
//               functions (set(), set_from_iter()), and algebraic properties.
// =============================================================================

module specs.core.collections.set_operators_test;

mount core.*;
mount core.text.format.{format_display, format_debug};

// =============================================================================
// Helpers
// =============================================================================

fn make_123() -> Set<Int> {
    let mut s = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    s
}

fn make_345() -> Set<Int> {
    let mut s = Set.new();
    s.insert(3);
    s.insert(4);
    s.insert(5);
    s
}

fn make_12345() -> Set<Int> {
    let mut s = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    s.insert(4);
    s.insert(5);
    s
}

fn make_empty() -> Set<Int> {
    Set.new()
}

// =============================================================================
// SECTION 1: BitOrAssign - Union-assign (|=)
// =============================================================================

@test
fn test_bitor_assign_basic() {
    let mut a = make_123();
    let b = make_345();
    a.bitor_assign(&b);
    assert_eq(a.len(), 5);
    assert(a.contains(&1));
    assert(a.contains(&4));
    assert(a.contains(&5));
}

@test
fn test_bitor_assign_empty_rhs() {
    let mut a = make_123();
    let b = make_empty();
    a.bitor_assign(&b);
    assert_eq(a.len(), 3);
}

@test
fn test_bitor_assign_empty_lhs() {
    let mut a = make_empty();
    let b = make_123();
    a.bitor_assign(&b);
    assert_eq(a.len(), 3);
    assert(a.contains(&1));
    assert(a.contains(&2));
    assert(a.contains(&3));
}

@test
fn test_bitor_assign_identical() {
    let mut a = make_123();
    let b = make_123();
    a.bitor_assign(&b);
    assert_eq(a.len(), 3);
}

@test
fn test_bitor_assign_disjoint() {
    let mut a = Set.new();
    a.insert(1);
    a.insert(2);
    let mut b = Set.new();
    b.insert(3);
    b.insert(4);
    a.bitor_assign(&b);
    assert_eq(a.len(), 4);
}

// =============================================================================
// SECTION 2: BitAndAssign - Intersection-assign (&=)
// =============================================================================

@test
fn test_bitand_assign_basic() {
    let mut a = make_123();
    let b = make_345();
    a.bitand_assign(&b);
    assert_eq(a.len(), 1);
    assert(a.contains(&3));
}

@test
fn test_bitand_assign_disjoint() {
    let mut a = make_123();
    let mut b = Set.new();
    b.insert(10);
    b.insert(20);
    a.bitand_assign(&b);
    assert(a.is_empty());
}

@test
fn test_bitand_assign_identical() {
    let mut a = make_123();
    let b = make_123();
    a.bitand_assign(&b);
    assert_eq(a.len(), 3);
}

@test
fn test_bitand_assign_empty_rhs() {
    let mut a = make_123();
    let b = make_empty();
    a.bitand_assign(&b);
    assert(a.is_empty());
}

@test
fn test_bitand_assign_subset() {
    let mut a = make_12345();
    let b = make_123();
    a.bitand_assign(&b);
    assert_eq(a.len(), 3);
    assert(a.contains(&1));
    assert(a.contains(&2));
    assert(a.contains(&3));
}

// =============================================================================
// SECTION 3: SubAssign - Difference-assign (-=)
// =============================================================================

@test
fn test_sub_assign_basic() {
    let mut a = make_123();
    let b = make_345();
    a.sub_assign(&b);
    assert_eq(a.len(), 2);
    assert(a.contains(&1));
    assert(a.contains(&2));
    assert(!a.contains(&3));
}

@test
fn test_sub_assign_disjoint() {
    let mut a = make_123();
    let mut b = Set.new();
    b.insert(10);
    b.insert(20);
    a.sub_assign(&b);
    assert_eq(a.len(), 3);
}

@test
fn test_sub_assign_all_removed() {
    let mut a = make_123();
    let b = make_123();
    a.sub_assign(&b);
    assert(a.is_empty());
}

@test
fn test_sub_assign_empty_rhs() {
    let mut a = make_123();
    let b = make_empty();
    a.sub_assign(&b);
    assert_eq(a.len(), 3);
}

@test
fn test_sub_assign_superset() {
    let mut a = make_12345();
    let b = make_123();
    a.sub_assign(&b);
    assert_eq(a.len(), 2);
    assert(a.contains(&4));
    assert(a.contains(&5));
}

// =============================================================================
// SECTION 4: BitXorAssign - Symmetric-difference-assign (^=)
// =============================================================================

@test
fn test_bitxor_assign_basic() {
    let mut a = make_123();
    let b = make_345();
    a.bitxor_assign(&b);
    assert_eq(a.len(), 4);
    assert(a.contains(&1));
    assert(a.contains(&2));
    assert(!a.contains(&3));
    assert(a.contains(&4));
    assert(a.contains(&5));
}

@test
fn test_bitxor_assign_identical() {
    let mut a = make_123();
    let b = make_123();
    a.bitxor_assign(&b);
    assert(a.is_empty());
}

@test
fn test_bitxor_assign_disjoint() {
    let mut a = make_123();
    let mut b = Set.new();
    b.insert(4);
    b.insert(5);
    a.bitxor_assign(&b);
    assert_eq(a.len(), 5);
}

@test
fn test_bitxor_assign_empty_rhs() {
    let mut a = make_123();
    let b = make_empty();
    a.bitxor_assign(&b);
    assert_eq(a.len(), 3);
}

@test
fn test_bitxor_assign_empty_lhs() {
    let mut a = make_empty();
    let b = make_123();
    a.bitxor_assign(&b);
    assert_eq(a.len(), 3);
}

// =============================================================================
// SECTION 5: Operator algebraic properties
// =============================================================================

@test
fn test_union_commutative() {
    let a = make_123();
    let b = make_345();
    let ab = a.union(&b);
    let ba = b.union(&a);
    assert(ab == ba);
}

@test
fn test_intersection_commutative() {
    let a = make_123();
    let b = make_345();
    let ab = a.intersection(&b);
    let ba = b.intersection(&a);
    assert(ab == ba);
}

@test
fn test_symmetric_difference_commutative() {
    let a = make_123();
    let b = make_345();
    let ab = a.symmetric_difference(&b);
    let ba = b.symmetric_difference(&a);
    assert(ab == ba);
}

@test
fn test_difference_not_commutative() {
    let a = make_123();
    let b = make_345();
    let ab = a.difference(&b);
    let ba = b.difference(&a);
    assert_eq(ab.len(), 2);
    assert_eq(ba.len(), 2);
    assert(ab.contains(&1));
    assert(ba.contains(&4));
}

@test
fn test_union_associative() {
    let a = make_123();
    let mut b = Set.new();
    b.insert(3);
    b.insert(4);
    let mut c = Set.new();
    c.insert(5);
    c.insert(6);
    let ab = a.union(&b);
    let ab_c = ab.union(&c);
    let bc = b.union(&c);
    let a_bc = a.union(&bc);
    assert(ab_c == a_bc);
}

@test
fn test_intersection_associative() {
    let a = make_12345();
    let b = make_123();
    let c = make_345();
    let ab = a.intersection(&b);
    let ab_c = ab.intersection(&c);
    let bc = b.intersection(&c);
    let a_bc = a.intersection(&bc);
    assert(ab_c == a_bc);
}

@test
fn test_union_identity() {
    let a = make_123();
    let empty = make_empty();
    let result = a.union(&empty);
    assert(result == a);
}

@test
fn test_intersection_with_self() {
    let a = make_123();
    let result = a.intersection(&a);
    assert(result == a);
}

@test
fn test_difference_self() {
    let a = make_123();
    let result = a.difference(&a);
    assert(result.is_empty());
}

@test
fn test_symmetric_difference_self() {
    let a = make_123();
    let result = a.symmetric_difference(&a);
    assert(result.is_empty());
}

@test
fn test_de_morgan_property() {
    // A △ B = (A ∪ B) \ (A ∩ B)
    let a = make_123();
    let b = make_345();
    let sym_diff = a.symmetric_difference(&b);
    let union_val = a.union(&b);
    let inter_val = a.intersection(&b);
    let union_minus_inter = union_val.difference(&inter_val);
    assert(sym_diff == union_minus_inter);
}

@test
fn test_distributive_property() {
    // A ∪ (B ∩ C) = (A ∪ B) ∩ (A ∪ C)
    let a = make_123();
    let mut b = Set.new();
    b.insert(2);
    b.insert(4);
    let mut c = Set.new();
    c.insert(3);
    c.insert(5);
    let bc = b.intersection(&c);
    let lhs = a.union(&bc);
    let ab = a.union(&b);
    let ac = a.union(&c);
    let rhs = ab.intersection(&ac);
    assert(lhs == rhs);
}

@test
fn test_absorption_law_1() {
    // A ∪ (A ∩ B) = A
    let a = make_123();
    let b = make_345();
    let ab = a.intersection(&b);
    let result = a.union(&ab);
    assert(result == a);
}

@test
fn test_absorption_law_2() {
    // A ∩ (A ∪ B) = A
    let a = make_123();
    let b = make_345();
    let ab = a.union(&b);
    let result = a.intersection(&ab);
    assert(result == a);
}

@test
fn test_complement_law() {
    // A \ B is disjoint from B
    let a = make_123();
    let b = make_345();
    let diff = a.difference(&b);
    assert(diff.is_disjoint(&b));
}

// =============================================================================
// SECTION 6: Clone protocol
// =============================================================================

@test
fn test_set_clone_basic() {
    let a = make_123();
    let b = a.clone();
    assert_eq(b.len(), 3);
    assert(b.contains(&1));
    assert(b.contains(&2));
    assert(b.contains(&3));
}

@test
fn test_set_clone_empty() {
    let a: Set<Int> = Set.new();
    let b = a.clone();
    assert(b.is_empty());
}

@test
fn test_set_clone_independence() {
    let mut a = make_123();
    let b = a.clone();
    a.insert(99);
    assert_eq(a.len(), 4);
    assert_eq(b.len(), 3);
    assert(!b.contains(&99));
}

@test
fn test_set_clone_text() {
    let mut s: Set<Text> = Set.new();
    s.insert("hello".clone());
    s.insert("world".clone());
    let cloned = s.clone();
    assert_eq(cloned.len(), 2);
    assert(cloned.contains(&"hello"));
    assert(cloned.contains(&"world"));
}

@test
fn test_set_clone_preserves_equality() {
    let a = make_12345();
    let b = a.clone();
    assert(a == b);
}

// =============================================================================
// SECTION 7: Default protocol
// =============================================================================

@test
fn test_set_default() {
    let s: Set<Int> = Set.default();
    assert(s.is_empty());
    assert_eq(s.len(), 0);
}

@test
fn test_set_default_text() {
    let s: Set<Text> = Set.default();
    assert(s.is_empty());
}

@test
fn test_set_default_is_usable() {
    let mut s: Set<Int> = Set.default();
    s.insert(42);
    assert_eq(s.len(), 1);
    assert(s.contains(&42));
}

// =============================================================================
// SECTION 8: Eq protocol
// =============================================================================

@test
fn test_set_eq_same_elements() {
    let a = make_123();
    let b = make_123();
    assert(a == b);
}

@test
fn test_set_ne_different_elements() {
    let a = make_123();
    let b = make_345();
    assert(a != b);
}

@test
fn test_set_ne_different_sizes() {
    let a = make_123();
    let b = make_12345();
    assert(a != b);
}

@test
fn test_set_eq_both_empty() {
    let a: Set<Int> = Set.new();
    let b: Set<Int> = Set.new();
    assert(a == b);
}

@test
fn test_set_eq_insertion_order_irrelevant() {
    let mut a = Set.new();
    a.insert(1);
    a.insert(2);
    a.insert(3);
    let mut b = Set.new();
    b.insert(3);
    b.insert(1);
    b.insert(2);
    assert(a == b);
}

@test
fn test_set_eq_reflexive() {
    let a = make_123();
    assert(a == a);
}

@test
fn test_set_eq_symmetric() {
    let a = make_123();
    let b = make_123();
    assert(a == b);
    assert(b == a);
}

@test
fn test_set_eq_single_element_diff() {
    let a = make_123();
    let mut b = Set.new();
    b.insert(1);
    b.insert(2);
    b.insert(4); // different!
    assert(a != b);
}

