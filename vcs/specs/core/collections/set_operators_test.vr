@test
fn test_set_extend_range() {
    let mut s = make_123();
    s.extend(range(4, 7));
    assert_eq(s.len(), 6);
    assert(s.contains(&4));
    assert(s.contains(&5));
    assert(s.contains(&6));
}

@test
fn test_set_extend_with_duplicates() {
    let mut s = make_123();
    s.extend(range(1, 4));
    assert_eq(s.len(), 3);
}

@test
fn test_set_extend_empty_into_nonempty() {
    let mut s = make_123();
    let empty_list: List<Int> = [];
    s.extend(empty_list.iter().map(|x| *x));
    assert_eq(s.len(), 3);
}

@test
fn test_set_extend_into_empty() {
    let mut s: Set<Int> = Set.new();
    s.extend(range(1, 4));
    assert_eq(s.len(), 3);
}

