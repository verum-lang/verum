}

// =============================================================================
// SECTION 11: FromIterator protocol
// =============================================================================

@test
fn test_set_from_iterator_range() {
    let s: Set<Int> = Set.from_iter(range(1, 6));
    assert_eq(s.len(), 5);
    assert(s.contains(&1));
    assert(s.contains(&5));
}

@test
fn test_set_from_iterator_empty() {
    let s: Set<Int> = Set.from_iter(empty());
    assert(s.is_empty());
}

@test
fn test_set_from_iterator_with_duplicates() {
    let items: List<Int> = [1, 2, 2, 3, 3, 3];
    let s: Set<Int> = Set.from_iter(items.iter().map(|x| *x));
    assert_eq(s.len(), 3);
}

@test
fn test_set_from_iterator_single() {
    let s: Set<Int> = Set.from_iter(once(42));
    assert_eq(s.len(), 1);
    assert(s.contains(&42));
}

@test
fn test_set_from_iterator_large() {
    let s: Set<Int> = Set.from_iter(range(0, 100));
    assert_eq(s.len(), 100);
}

