// SECTION 10: Display formatting
// =============================================================================

@test
fn test_set_display_empty() {
    let s: Set<Int> = Set.new();
    let text = format_display(&s);
    assert(text.len() > 0);
}

@test
fn test_set_display_single() {
    let mut s = Set.new();
    s.insert(1);
    let text = format_display(&s);
