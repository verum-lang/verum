@test
fn test_set_constructor_basic() {
    let s = set(&[1, 2, 3, 4, 5]);
    assert_eq(s.len(), 5);
    assert(s.contains(&1));
    assert(s.contains(&5));
}

@test
fn test_set_constructor_single() {
    let s = set(&[42]);
    assert_eq(s.len(), 1);
    assert(s.contains(&42));
}

@test
fn test_set_constructor_duplicates() {
    let s = set(&[1, 1, 2, 2, 3]);
    assert_eq(s.len(), 3);
}

@test
fn test_set_from_iter_constructor() {
    let s = set_from_iter(range(1, 11));
    assert_eq(s.len(), 10);
    assert(s.contains(&1));
    assert(s.contains(&10));
}

@test
fn test_set_from_iter_constructor_empty() {
    let s: Set<Int> = set_from_iter(empty());
    assert(s.is_empty());
}

// =============================================================================
// SECTION 14: Iterator
// =============================================================================

@test
fn test_set_iter_count() {
    let s = make_123();
    let mut count = 0;
    let mut iter = s.iter();
    loop {
        match iter.next() {
            Some(_) => { count = count + 1; }
            None => { break; }
        }
    }
    assert_eq(count, 3);
}

@test
fn test_set_iter_empty() {
    let s: Set<Int> = Set.new();
    let mut iter = s.iter();
    assert(iter.next() is None);
}

@test
fn test_set_iter_all_present() {
    let s = make_123();
    let mut found_1 = false;
    let mut found_2 = false;
    let mut found_3 = false;
    let mut iter = s.iter();
    loop {
        match iter.next() {
            Some(v) => {
                if *v == 1 { found_1 = true; }
                if *v == 2 { found_2 = true; }
                if *v == 3 { found_3 = true; }
            }
            None => { break; }
        }
    }
    assert(found_1);
    assert(found_2);
    assert(found_3);
}

// =============================================================================
// SECTION 15: Assign operator chaining
// =============================================================================

@test
fn test_assign_chain_union_then_difference() {
    let mut s = make_123();
    let extra = make_345();
    s.bitor_assign(&extra);
    assert_eq(s.len(), 5);

    let mut to_remove = Set.new();
    to_remove.insert(1);
    to_remove.insert(2);
    s.sub_assign(&to_remove);
    assert_eq(s.len(), 3);
    assert(s.contains(&3));
    assert(s.contains(&4));
    assert(s.contains(&5));
}

@test
fn test_assign_chain_intersect_then_xor() {
    let mut s = make_12345();
    let keep = make_123();
    s.bitand_assign(&keep);
    assert_eq(s.len(), 3);

    let mut toggle = Set.new();
    toggle.insert(2);
    toggle.insert(4);
    s.bitxor_assign(&toggle);
    assert_eq(s.len(), 3);
    assert(s.contains(&1));
    assert(!s.contains(&2));
    assert(s.contains(&3));
    assert(s.contains(&4));
}

// =============================================================================
// SECTION 16: Large set operations
// =============================================================================

@test
fn test_large_set_union() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    let mut i = 0;
    while i < 100 {
        a.insert(i);
        i = i + 1;
    }
    i = 50;
    while i < 150 {
        b.insert(i);
        i = i + 1;
    }
    let result = a.union(&b);
    assert_eq(result.len(), 150);
}

@test
fn test_large_set_intersection() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    let mut i = 0;
    while i < 100 {
        a.insert(i);
        i = i + 1;
    }
    i = 50;
    while i < 150 {
        b.insert(i);
        i = i + 1;
    }
    let result = a.intersection(&b);
    assert_eq(result.len(), 50);
}

@test
fn test_large_set_difference() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    let mut i = 0;
    while i < 100 {
        a.insert(i);
        i = i + 1;
    }
    i = 50;
    while i < 150 {
        b.insert(i);
        i = i + 1;
    }
    let result = a.difference(&b);
    assert_eq(result.len(), 50); // 0..49
}

@test
fn test_large_set_symmetric_difference() {
    let mut a: Set<Int> = Set.new();
    let mut b: Set<Int> = Set.new();
    let mut i = 0;
    while i < 100 {
        a.insert(i);
        i = i + 1;
    }
    i = 50;
    while i < 150 {
        b.insert(i);
        i = i + 1;
    }
    let result = a.symmetric_difference(&b);
    assert_eq(result.len(), 100); // 0..49 + 100..149
}

// =============================================================================
// SECTION 17: Text sets
// =============================================================================

@test
fn test_text_set_operations() {
    let mut a: Set<Text> = Set.new();
    a.insert("apple".clone());
    a.insert("banana".clone());
    a.insert("cherry".clone());

    let mut b: Set<Text> = Set.new();
    b.insert("banana".clone());
    b.insert("cherry".clone());
    b.insert("date".clone());

    let union_result = a.union(&b);
    assert_eq(union_result.len(), 4);

    let inter_result = a.intersection(&b);
    assert_eq(inter_result.len(), 2);
    assert(inter_result.contains(&"banana"));
    assert(inter_result.contains(&"cherry"));
}

@test
fn test_text_set_difference() {
    let mut a: Set<Text> = Set.new();
    a.insert("alpha".clone());
    a.insert("beta".clone());
    a.insert("gamma".clone());

    let mut b: Set<Text> = Set.new();
    b.insert("beta".clone());

    let diff = a.difference(&b);
    assert_eq(diff.len(), 2);
    assert(diff.contains(&"alpha"));
    assert(diff.contains(&"gamma"));
}
