@test
fn test_set_debug_empty() {
    let s: Set<Int> = Set.new();
    let text = format_debug(&s);
    assert(text.len() > 0);
}

@test
fn test_set_debug_single() {
    let mut s = Set.new();
    s.insert(42);
    let text = format_debug(&s);
    assert(text.contains(&"42"));
}

@test
fn test_set_debug_multiple() {
    let s = make_123();
    let text = format_debug(&s);
    assert(text.contains(&"{"));
    assert(text.contains(&"}"));
}

