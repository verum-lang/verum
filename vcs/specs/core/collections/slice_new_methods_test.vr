// =============================================================================
// slice_new_methods_test.vr - Tests for new Slice methods
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, slice, core
// @description: Tests for Slice.fill_with and Slice.swap_with_slice

mount core.collections.list.{List};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: fill_with() - Fill with closure-generated values
// =============================================================================

@test
fn test_fill_with_counter() {
    let mut items: List<Int> = [0, 0, 0, 0, 0];
    let mut counter = 0;
    items.as_mut_slice().fill_with(|| {
        counter = counter + 1;
        counter
    });
    assert_eq(items[0], 1);
    assert_eq(items[1], 2);
    assert_eq(items[2], 3);
    assert_eq(items[3], 4);
    assert_eq(items[4], 5);
}

@test
fn test_fill_with_constant() {
    let mut items: List<Int> = [0, 0, 0];
    items.as_mut_slice().fill_with(|| 42);
    assert_eq(items[0], 42);
    assert_eq(items[1], 42);
    assert_eq(items[2], 42);
}

@test
fn test_fill_with_empty_slice() {
    let mut items: List<Int> = [];
    items.as_mut_slice().fill_with(|| 99);
    assert(items.is_empty());
}

@test
fn test_fill_with_single() {
    let mut items: List<Int> = [0];
    items.as_mut_slice().fill_with(|| 7);
    assert_eq(items[0], 7);
}

// =============================================================================
// Section 2: swap_with_slice() - Swap contents of two slices
// =============================================================================

@test
fn test_swap_with_slice_basic() {
    let mut a: List<Int> = [1, 2, 3];
    let mut b: List<Int> = [10, 20, 30];
    a.as_mut_slice().swap_with_slice(b.as_mut_slice());
    assert_eq(a[0], 10);
    assert_eq(a[1], 20);
    assert_eq(a[2], 30);
    assert_eq(b[0], 1);
    assert_eq(b[1], 2);
    assert_eq(b[2], 3);
}

@test
fn test_swap_with_slice_single() {
    let mut a: List<Int> = [42];
    let mut b: List<Int> = [99];
    a.as_mut_slice().swap_with_slice(b.as_mut_slice());
    assert_eq(a[0], 99);
    assert_eq(b[0], 42);
}

@test
fn test_swap_with_slice_preserves_length() {
    let mut a: List<Int> = [1, 2, 3, 4, 5];
    let mut b: List<Int> = [10, 20, 30, 40, 50];
    a.as_mut_slice().swap_with_slice(b.as_mut_slice());
    assert_eq(a.len(), 5);
    assert_eq(b.len(), 5);
}

fn main() {
    // Tests run via @test annotations
}
