@test
fn test_deque_binary_search_found() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(3);
    d.push_back(5);
    d.push_back(7);
    d.push_back(9);
    assert_eq(d.binary_search(&5), Ok(2));
}

@test
fn test_deque_binary_search_missing() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(3);
    d.push_back(5);
    d.push_back(7);
    let result = d.binary_search(&4);
    assert(result.is_err());
}

@test
fn test_deque_binary_search_empty() {
    let d: Deque<Int> = Deque.new();
    let result = d.binary_search(&5);
    match result {
        Err(idx) => assert_eq(idx, 0),
        Ok(_) => panic("expected Err"),
    }
}

@test
fn test_deque_binary_search_first() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);
    assert_eq(d.binary_search(&10), Ok(0));
}

@test
fn test_deque_binary_search_last() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);
    assert_eq(d.binary_search(&30), Ok(2));
}

// =============================================================================
// Ring Buffer Wrap-Around Tests
// =============================================================================

@test
fn test_deque_wraparound_stress() {
    let mut d: Deque<Int> = Deque.new();
    // Push/pop front and back alternately to force wrap-around
    let mut i = 0;
    while i < 50 {
        d.push_back(i);
        d.push_front(100 + i);
        i = i + 1;
    }
    assert_eq(d.len(), 100);

    // Pop everything from front — should get front elements first
    let mut prev_front = d.pop_front();
    assert(prev_front.is_some());
    let mut count = 1;
    while count < 100 {
        let val = d.pop_front();
        assert(val.is_some());
        count = count + 1;
    }
    assert(d.is_empty());
}

@test
fn test_deque_fifo_ordering() {
    let mut d: Deque<Int> = Deque.new();
    // Use as FIFO queue: push_back, pop_front
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    assert_eq(d.pop_front(), Some(1));
    assert_eq(d.pop_front(), Some(2));

    d.push_back(4);
    d.push_back(5);

    assert_eq(d.pop_front(), Some(3));
    assert_eq(d.pop_front(), Some(4));
    assert_eq(d.pop_front(), Some(5));
    assert_eq(d.pop_front(), None);
}

@test
fn test_deque_lifo_ordering() {
    let mut d: Deque<Int> = Deque.new();
    // Use as LIFO stack: push_back, pop_back
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    assert_eq(d.pop_back(), Some(3));
    assert_eq(d.pop_back(), Some(2));
    assert_eq(d.pop_back(), Some(1));
    assert_eq(d.pop_back(), None);
}

@test
fn test_deque_rotate_edge_cases() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);
    d.push_back(5);

    // Rotate by 0 — no change
    d.rotate_left(0);
    assert_eq(*d.front().unwrap(), 1);

    // Rotate left by 2: [1,2,3,4,5] -> [3,4,5,1,2]
    d.rotate_left(2);
    assert_eq(*d.front().unwrap(), 3);
    assert_eq(*d.back().unwrap(), 2);

    // Rotate right by 2: [3,4,5,1,2] -> [1,2,3,4,5]
    d.rotate_right(2);
    assert_eq(*d.front().unwrap(), 1);
    assert_eq(*d.back().unwrap(), 5);
}

@test
fn test_deque_large_push_pop() {
    let mut d: Deque<Int> = Deque.new();
    let mut i = 0;
    while i < 100 {
        d.push_back(i);
        i = i + 1;
    }
    assert_eq(d.len(), 100);

    // Pop all from front
    let mut j = 0;
    while j < 100 {
        let val = d.pop_front();
        assert(val.is_some());
        assert_eq(val.unwrap(), j);
        j = j + 1;
    }
    assert(d.is_empty());
}

@test
fn test_deque_interleaved_push_pop() {
    let mut d: Deque<Int> = Deque.new();
    // Alternate push and pop to exercise wrap-around
    let mut i = 0;
    while i < 20 {
        d.push_back(i);
        if i % 3 == 0 {
            let _ = d.pop_front();
        }
        i = i + 1;
    }
    // Should have some elements left
    assert(d.len() > 0);
}

@test
fn test_deque_binary_search_sorted() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);
    d.push_back(40);
    d.push_back(50);

    assert_eq(d.binary_search(&10), Ok(0));
    assert_eq(d.binary_search(&30), Ok(2));
    assert_eq(d.binary_search(&50), Ok(4));
    assert(d.binary_search(&25).is_err()); // Not found
    assert(d.binary_search(&5).is_err());  // Before all
    assert(d.binary_search(&55).is_err()); // After all
}

// =============================================================================
// Section: Convenience Function Tests
// =============================================================================

@test
fn test_deque_convenience_function() {
    let d = deque(&[1, 2, 3, 4, 5]);
    assert_eq(d.len(), 5);
    assert_eq(*d.front().unwrap(), 1);
    assert_eq(*d.back().unwrap(), 5);
}

@test
fn test_deque_convenience_function_empty() {
    let d: Deque<Int> = deque(&[]);
    assert(d.is_empty());
}

@test
fn test_deque_convenience_preserves_order() {
    let d = deque(&[10, 20, 30]);
    assert_eq(*d.get(0).unwrap(), 10);
    assert_eq(*d.get(1).unwrap(), 20);
    assert_eq(*d.get(2).unwrap(), 30);
}

// =============================================================================
// Section: Retain Tests
// =============================================================================

@test
fn test_deque_retain_evens() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);
    d.push_back(5);
    d.push_back(6);

    d.retain(|x: &Int| *x % 2 == 0);

    assert_eq(d.len(), 3);
    assert_eq(*d.get(0).unwrap(), 2);
    assert_eq(*d.get(1).unwrap(), 4);
    assert_eq(*d.get(2).unwrap(), 6);
}

@test
fn test_deque_retain_all() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    d.retain(|_x: &Int| true);

    assert_eq(d.len(), 3);
}

@test
fn test_deque_retain_none() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    d.retain(|_x: &Int| false);

    assert(d.is_empty());
}

@test
fn test_deque_retain_empty() {
    let mut d: Deque<Int> = Deque.new();
    d.retain(|_x: &Int| true);
    assert(d.is_empty());
}

@test
fn test_deque_retain_threshold() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(5);
    d.push_back(30);
    d.push_back(3);

    d.retain(|x: &Int| *x >= 10);

    assert_eq(d.len(), 3);
    assert_eq(*d.get(0).unwrap(), 10);
    assert_eq(*d.get(1).unwrap(), 20);
    assert_eq(*d.get(2).unwrap(), 30);
}

// =============================================================================
// Section: Truncate Tests
// =============================================================================

@test
fn test_deque_truncate_basic() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);
    d.push_back(5);

    d.truncate(3);

    assert_eq(d.len(), 3);
    assert_eq(*d.get(0).unwrap(), 1);
    assert_eq(*d.get(1).unwrap(), 2);
    assert_eq(*d.get(2).unwrap(), 3);
}

@test
fn test_deque_truncate_to_zero() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    d.truncate(0);

    assert(d.is_empty());
}

@test
fn test_deque_truncate_beyond_len() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);

    d.truncate(100); // Beyond current length - no effect

    assert_eq(d.len(), 2);
}

@test
fn test_deque_truncate_empty() {
    let mut d: Deque<Int> = Deque.new();
    d.truncate(0);
    assert(d.is_empty());
}

@test
fn test_deque_truncate_to_one() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);

    d.truncate(1);

    assert_eq(d.len(), 1);
    assert_eq(*d.front().unwrap(), 10);
}

// =============================================================================
// Section: Insert Tests
// =============================================================================

@test
fn test_deque_insert_middle() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(3);
    d.push_back(4);

    d.insert(1, 2); // Insert 2 at index 1

    assert_eq(d.len(), 4);
    assert_eq(*d.get(0).unwrap(), 1);
    assert_eq(*d.get(1).unwrap(), 2);
    assert_eq(*d.get(2).unwrap(), 3);
    assert_eq(*d.get(3).unwrap(), 4);
}

@test
fn test_deque_insert_front() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(2);
    d.push_back(3);

    d.insert(0, 1); // Insert at front

    assert_eq(d.len(), 3);
    assert_eq(*d.front().unwrap(), 1);
}

@test
fn test_deque_insert_back() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);

    d.insert(2, 3); // Insert at end (index == len)

    assert_eq(d.len(), 3);
    assert_eq(*d.back().unwrap(), 3);
}

@test
fn test_deque_insert_into_empty() {
    let mut d: Deque<Int> = Deque.new();

    d.insert(0, 42);

    assert_eq(d.len(), 1);
    assert_eq(*d.front().unwrap(), 42);
}

@test
fn test_deque_insert_multiple() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(5);

    d.insert(1, 2);
    d.insert(2, 3);
    d.insert(3, 4);

    assert_eq(d.len(), 5);
    assert_eq(*d.get(0).unwrap(), 1);
    assert_eq(*d.get(1).unwrap(), 2);
    assert_eq(*d.get(2).unwrap(), 3);
    assert_eq(*d.get(3).unwrap(), 4);
    assert_eq(*d.get(4).unwrap(), 5);
}

// =============================================================================
// Section: Remove Tests
// =============================================================================

@test
fn test_deque_remove_middle() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.push_back(4);

    let removed = d.remove(1);
    assert_eq(removed, Some(2));

    assert_eq(d.len(), 3);
    assert_eq(*d.get(0).unwrap(), 1);
    assert_eq(*d.get(1).unwrap(), 3);
    assert_eq(*d.get(2).unwrap(), 4);
}

@test
fn test_deque_remove_front() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let removed = d.remove(0);
    assert_eq(removed, Some(1));

    assert_eq(d.len(), 2);
    assert_eq(*d.front().unwrap(), 2);
}

@test
fn test_deque_remove_back() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let removed = d.remove(2);
    assert_eq(removed, Some(3));

    assert_eq(d.len(), 2);
    assert_eq(*d.back().unwrap(), 2);
}

@test
fn test_deque_remove_single() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(42);

    let removed = d.remove(0);
    assert_eq(removed, Some(42));

    assert(d.is_empty());
}

@test
fn test_deque_remove_out_of_bounds() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);

    let removed = d.remove(5);
    assert(removed.is_none());
    assert_eq(d.len(), 2);
}

@test
fn test_deque_remove_empty() {
    let mut d: Deque<Int> = Deque.new();
    let removed = d.remove(0);
    assert(removed.is_none());
}

@test
fn test_deque_remove_negative_index() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);

    let removed: Maybe<Int> = d.remove(-1);
    assert(removed.is_none());
    assert_eq(d.len(), 2);
}

// =============================================================================
// Section: Clone Tests
// =============================================================================

@test
fn test_deque_clone_basic() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let cloned = d.clone();

    assert_eq(cloned.len(), 3);
    assert_eq(*cloned.get(0).unwrap(), 1);
    assert_eq(*cloned.get(1).unwrap(), 2);
    assert_eq(*cloned.get(2).unwrap(), 3);
}

@test
fn test_deque_clone_independence() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);

    let mut cloned = d.clone();

    // Modify original
    d.push_back(30);
    assert_eq(d.len(), 3);

    // Clone unchanged
    assert_eq(cloned.len(), 2);

    // Modify clone
    cloned.push_front(5);
    assert_eq(cloned.len(), 3);
    assert_eq(d.len(), 3); // Original unchanged
}

@test
fn test_deque_clone_empty() {
    let d: Deque<Int> = Deque.new();
    let cloned = d.clone();
    assert(cloned.is_empty());
}

@test
fn test_deque_clone_after_wraparound() {
    let mut d: Deque<Int> = Deque.new();
    // Create wrap-around state
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);
    d.pop_front(); // Remove 1, head advances
    d.push_front(0); // Push to front, may wrap

    let cloned = d.clone();
    assert_eq(cloned.len(), d.len());
    assert_eq(*cloned.front().unwrap(), *d.front().unwrap());
    assert_eq(*cloned.back().unwrap(), *d.back().unwrap());
}

