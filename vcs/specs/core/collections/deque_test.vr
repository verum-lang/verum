@test
fn test_deque_default() {
    let d: Deque<Int> = Deque.default();
    assert(d.is_empty());
    assert_eq(d.len(), 0);
}

@test
fn test_deque_default_text() {
    let d: Deque<Text> = Deque.default();
    assert(d.is_empty());
}

// =============================================================================
// Section: Equality Tests
// =============================================================================

@test
fn test_deque_eq_same_elements() {
    let mut a: Deque<Int> = Deque.new();
    a.push_back(1);
    a.push_back(2);
    a.push_back(3);

    let mut b: Deque<Int> = Deque.new();
    b.push_back(1);
    b.push_back(2);
    b.push_back(3);

    assert(a == b);
}

@test
fn test_deque_eq_different_elements() {
    let mut a: Deque<Int> = Deque.new();
    a.push_back(1);
    a.push_back(2);

    let mut b: Deque<Int> = Deque.new();
    b.push_back(1);
    b.push_back(3);

    assert(a != b);
}

@test
fn test_deque_eq_different_lengths() {
    let mut a: Deque<Int> = Deque.new();
    a.push_back(1);
    a.push_back(2);

    let mut b: Deque<Int> = Deque.new();
    b.push_back(1);

    assert(a != b);
}

@test
fn test_deque_eq_both_empty() {
    let a: Deque<Int> = Deque.new();
    let b: Deque<Int> = Deque.new();
    assert(a == b);
}

@test
fn test_deque_eq_different_construction() {
    // Same logical content, different internal layout
    let mut a: Deque<Int> = Deque.new();
    a.push_back(1);
    a.push_back(2);
    a.push_back(3);

    let mut b: Deque<Int> = Deque.new();
    b.push_front(3);
    b.push_front(2);
    b.push_front(1);

    assert(a == b);
}

// =============================================================================
// Section: Consuming Drain Tests (Pop-based consuming iteration)
// =============================================================================

@test
fn test_deque_drain_front_sum() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);

    // Drain by pop_front (same as DequeIntoIter.next())
    let mut sum = 0;
    loop {
        match d.pop_front() {
            Some(val) => sum = sum + val,
            None => break,
        }
    }
    assert_eq(sum, 60);
    assert(d.is_empty());
}

@test
fn test_deque_drain_front_empty() {
    let mut d: Deque<Int> = Deque.new();
    let mut count = 0;
    loop {
        match d.pop_front() {
            Some(_) => count = count + 1,
            None => break,
        }
    }
    assert_eq(count, 0);
}

@test
fn test_deque_drain_front_ordering() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);
    d.push_back(3);

    let mut expected = 1;
    loop {
        match d.pop_front() {
            Some(val) => {
                assert_eq(val, expected);
                expected = expected + 1;
            }
            None => break,
        }
    }
    assert_eq(expected, 4);
    assert(d.is_empty());
}

// =============================================================================
// Section: Extend Tests
// =============================================================================

@test
fn test_deque_extend_from_list() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);

    let more = List.from([2, 3, 4]);
    d.extend(more.into_iter());

    assert_eq(d.len(), 4);
    assert_eq(*d.get(0).unwrap(), 1);
    assert_eq(*d.get(1).unwrap(), 2);
    assert_eq(*d.get(2).unwrap(), 3);
    assert_eq(*d.get(3).unwrap(), 4);
}

@test
fn test_deque_extend_empty_source() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);

    let empty: List<Int> = List.new();
    d.extend(empty.into_iter());

    assert_eq(d.len(), 1);
}

@test
fn test_deque_extend_into_empty() {
    let mut d: Deque<Int> = Deque.new();

    let source = List.from([10, 20, 30]);
    d.extend(source.into_iter());

    assert_eq(d.len(), 3);
    assert_eq(*d.front().unwrap(), 10);
    assert_eq(*d.back().unwrap(), 30);
}

// =============================================================================
// Section: Capacity Tests
// =============================================================================

@test
fn test_deque_capacity_empty() {
    let d: Deque<Int> = Deque.new();
    assert_eq(d.capacity(), 0);
}

@test
fn test_deque_capacity_with_capacity() {
    let d: Deque<Int> = Deque.with_capacity(10);
    // Capacity rounded to power of 2
    assert(d.capacity() >= 10);
}

@test
fn test_deque_capacity_grows() {
    let mut d: Deque<Int> = Deque.new();
    let initial_cap = d.capacity();

    // Push enough to trigger growth
    let mut i = 0;
    while i < 20 {
        d.push_back(i);
        i = i + 1;
    }

    assert(d.capacity() > initial_cap);
    assert(d.capacity() >= 20);
}

@test
fn test_deque_capacity_power_of_two() {
    let d: Deque<Int> = Deque.with_capacity(7);
    // Should be rounded up to next power of 2 (8)
    assert(d.capacity() >= 7);
    let cap = d.capacity();
    // Capacity should be a power of 2
    assert(cap > 0);
    assert(cap & (cap - 1) == 0); // Power of 2 check
}

// =============================================================================
// Section: Edge Cases
// =============================================================================

@test
fn test_deque_swap_same_index() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(10);
    d.push_back(20);
    d.push_back(30);

    // Swap element with itself - should be no-op
    d.swap(1, 1);
    assert_eq(*d.get(1).unwrap(), 20);
}

@test
fn test_deque_rotate_single_element() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(42);

    d.rotate_left(1);
    assert_eq(*d.front().unwrap(), 42);

    d.rotate_right(1);
    assert_eq(*d.front().unwrap(), 42);
}

@test
fn test_deque_rotate_empty() {
    let mut d: Deque<Int> = Deque.new();
    d.rotate_left(5);  // Should not panic
    d.rotate_right(5); // Should not panic
    assert(d.is_empty());
}

@test
fn test_deque_contains_empty() {
    let d: Deque<Int> = Deque.new();
    assert(!d.contains(&42));
}

@test
fn test_deque_with_capacity_zero() {
    let d: Deque<Int> = Deque.with_capacity(0);
    assert(d.is_empty());
    assert_eq(d.capacity(), 0);
}

@test
fn test_deque_push_pop_cycle() {
    // Push and pop many times to test buffer reuse
    let mut d: Deque<Int> = Deque.new();
    let mut i = 0;
    while i < 100 {
        d.push_back(i);
        let val = d.pop_front();
        assert_eq(val, Some(i));
        i = i + 1;
    }
    assert(d.is_empty());
}

@test
fn test_deque_mixed_front_back_access() {
    let mut d: Deque<Int> = Deque.new();

    // Empty front/back
    assert(d.front().is_none());
    assert(d.back().is_none());
    assert(d.front_mut().is_none());
    assert(d.back_mut().is_none());

    // Single element - front and back are same
    d.push_back(42);
    assert_eq(*d.front().unwrap(), 42);
    assert_eq(*d.back().unwrap(), 42);
}

@test
fn test_deque_get_negative_index() {
    let mut d: Deque<Int> = Deque.new();
    d.push_back(1);
    d.push_back(2);

    assert(d.get(-1).is_none());
    assert(d.get_mut(-1).is_none());
}

fn main() {
    // Tests run via @test annotations
}
