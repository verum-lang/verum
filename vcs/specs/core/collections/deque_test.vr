// =============================================================================
// deque_test.vr - Comprehensive tests for Deque<T> collection
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, deque, double-ended-queue, core
// @description: Comprehensive tests for Deque<T> type and methods
// =============================================================================

mount core.collections.deque.{Deque, deque};
mount core.maybe.{Maybe, Some, None};

// =============================================================================
// Section 1: Construction Tests
// =============================================================================

@test
fn test_deque_new() {
    let empty: Deque<Int> = Deque.new();
    assert(empty.is_empty());
    assert_eq(empty.len(), 0);
}

@test
fn test_deque_with_capacity() {
    let deque: Deque<Int> = Deque.with_capacity(10);
    assert(deque.is_empty());
}

// =============================================================================
// Section 2: Push and Pop Operations
// =============================================================================

@test
fn test_deque_push_back() {
    let mut deque: Deque<Int> = Deque.new();

    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    assert_eq(deque.len(), 3);

    match deque.front() {
        Some(v) => assert_eq(*v, 1),
        None => panic("Expected Some"),
    }

    match deque.back() {
        Some(v) => assert_eq(*v, 3),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_push_front() {
    let mut deque: Deque<Int> = Deque.new();

    deque.push_front(1);
    deque.push_front(2);
    deque.push_front(3);

    assert_eq(deque.len(), 3);

    // Pushed front, so 3 is at front
    match deque.front() {
        Some(v) => assert_eq(*v, 3),
        None => panic("Expected Some"),
    }

    match deque.back() {
        Some(v) => assert_eq(*v, 1),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_pop_back() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    match deque.pop_back() {
        Some(v) => assert_eq(v, 3),
        None => panic("Expected Some"),
    }

    match deque.pop_back() {
        Some(v) => assert_eq(v, 2),
        None => panic("Expected Some"),
    }

    match deque.pop_back() {
        Some(v) => assert_eq(v, 1),
        None => panic("Expected Some"),
    }

    match deque.pop_back() {
        None => {} // Expected
        Some(_) => panic("Expected None"),
    }
}

@test
fn test_deque_pop_front() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    match deque.pop_front() {
        Some(v) => assert_eq(v, 1),
        None => panic("Expected Some"),
    }

    match deque.pop_front() {
        Some(v) => assert_eq(v, 2),
        None => panic("Expected Some"),
    }

    match deque.pop_front() {
        Some(v) => assert_eq(v, 3),
        None => panic("Expected Some"),
    }

    match deque.pop_front() {
        None => {} // Expected
        Some(_) => panic("Expected None"),
    }
}

// =============================================================================
// Section 3: Front and Back Access
// =============================================================================

@test
fn test_deque_front_back() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(10);
    deque.push_back(20);
    deque.push_back(30);

    match deque.front() {
        Some(v) => assert_eq(*v, 10),
        None => panic("Expected Some"),
    }

    match deque.back() {
        Some(v) => assert_eq(*v, 30),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_front_back_mut() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(10);
    deque.push_back(20);

    match deque.front_mut() {
        Some(v) => *v = 100,
        None => panic("Expected Some"),
    }

    match deque.back_mut() {
        Some(v) => *v = 200,
        None => panic("Expected Some"),
    }

    match deque.front() {
        Some(v) => assert_eq(*v, 100),
        None => panic("Expected Some"),
    }

    match deque.back() {
        Some(v) => assert_eq(*v, 200),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 4: Index Access
// =============================================================================

@test
fn test_deque_get() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(10);
    deque.push_back(20);
    deque.push_back(30);

    match deque.get(0) {
        Some(v) => assert_eq(*v, 10),
        None => panic("Expected Some"),
    }

    match deque.get(1) {
        Some(v) => assert_eq(*v, 20),
        None => panic("Expected Some"),
    }

    match deque.get(2) {
        Some(v) => assert_eq(*v, 30),
        None => panic("Expected Some"),
    }

    match deque.get(10) {
        None => {} // Expected - out of bounds
        Some(_) => panic("Expected None"),
    }
}

// =============================================================================
// Section 5: Clear and Properties
// =============================================================================

@test
fn test_deque_clear() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    assert_eq(deque.len(), 3);

    deque.clear();

    assert(deque.is_empty());
    assert_eq(deque.len(), 0);
}

@test
fn test_deque_is_empty() {
    let mut deque: Deque<Int> = Deque.new();
    assert(deque.is_empty());

    deque.push_back(1);
    assert(!deque.is_empty());

    deque.pop_back();
    assert(deque.is_empty());
}

// =============================================================================
// Section 6: Iteration Tests
// =============================================================================

@test
fn test_deque_iter() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    let mut sum = 0;
    let mut iter = deque.iter();
    loop {
        match iter.next() {
            Some(value) => sum = sum + *value,
            None => break,
        }
    }

    assert_eq(sum, 6);  // 1 + 2 + 3
}

// =============================================================================
// Section 7: Mixed Push/Pop Tests (Ring Buffer Behavior)
// =============================================================================

@test
fn test_deque_mixed_operations() {
    let mut deque: Deque<Int> = Deque.new();

    // Push from both ends
    deque.push_back(2);   // [2]
    deque.push_front(1);  // [1, 2]
    deque.push_back(3);   // [1, 2, 3]
    deque.push_front(0);  // [0, 1, 2, 3]

    assert_eq(deque.len(), 4);

    // Pop from both ends
    match deque.pop_front() {
        Some(v) => assert_eq(v, 0),
        None => panic("Expected Some"),
    }

    match deque.pop_back() {
        Some(v) => assert_eq(v, 3),
        None => panic("Expected Some"),
    }

    // Remaining: [1, 2]
    assert_eq(deque.len(), 2);
}

@test
fn test_deque_queue_behavior() {
    // FIFO queue: push_back, pop_front
    let mut queue: Deque<Int> = Deque.new();

    queue.push_back(1);
    queue.push_back(2);
    queue.push_back(3);

    match queue.pop_front() {
        Some(v) => assert_eq(v, 1),
        None => panic("Expected Some"),
    }

    match queue.pop_front() {
        Some(v) => assert_eq(v, 2),
        None => panic("Expected Some"),
    }

    match queue.pop_front() {
        Some(v) => assert_eq(v, 3),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_stack_behavior() {
    // LIFO stack: push_back, pop_back
    let mut stack: Deque<Int> = Deque.new();

    stack.push_back(1);
    stack.push_back(2);
    stack.push_back(3);

    match stack.pop_back() {
        Some(v) => assert_eq(v, 3),
        None => panic("Expected Some"),
    }

    match stack.pop_back() {
        Some(v) => assert_eq(v, 2),
        None => panic("Expected Some"),
    }

    match stack.pop_back() {
        Some(v) => assert_eq(v, 1),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 8: Edge Cases
// =============================================================================

@test
fn test_deque_empty_operations() {
    let empty: Deque<Int> = Deque.new();

    match empty.front() {
        None => {} // Expected
        Some(_) => panic("Front on empty should return None"),
    }

    match empty.back() {
        None => {} // Expected
        Some(_) => panic("Back on empty should return None"),
    }
}

@test
fn test_deque_single_element() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(42);

    assert_eq(deque.len(), 1);

    match deque.front() {
        Some(v) => assert_eq(*v, 42),
        None => panic("Expected Some"),
    }

    match deque.back() {
        Some(v) => assert_eq(*v, 42), // Same element
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 9: Mutable Index Access
// =============================================================================

@test
fn test_deque_get_mut() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(10);
    deque.push_back(20);
    deque.push_back(30);

    // Modify element at index 1
    match deque.get_mut(1) {
        Some(v) => *v = 200,
        None => panic("Expected Some"),
    }

    // Verify the modification
    match deque.get(1) {
        Some(v) => assert_eq(*v, 200),
        None => panic("Expected Some"),
    }

    // Out of bounds returns None
    match deque.get_mut(10) {
        None => {} // Expected
        Some(_) => panic("Expected None for out of bounds"),
    }
}

@test
fn test_deque_index() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(100);
    deque.push_back(200);
    deque.push_back(300);

    // Direct index access
    assert_eq(*deque.index(0), 100);
    assert_eq(*deque.index(1), 200);
    assert_eq(*deque.index(2), 300);
}

// =============================================================================
// Section 10: Reserve and Capacity Management
// =============================================================================

@test
fn test_deque_reserve() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);

    let old_cap = deque.capacity();
    deque.reserve(100);

    // Capacity should increase
    assert(deque.capacity() >= old_cap + 100);
    // Data should be preserved
    assert_eq(deque.len(), 1);
    match deque.front() {
        Some(v) => assert_eq(*v, 1),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_shrink_to_fit() {
    let mut deque: Deque<Int> = Deque.with_capacity(100);
    deque.push_back(1);
    deque.push_back(2);

    let old_cap = deque.capacity();
    assert(old_cap >= 100);

    deque.shrink_to_fit();

    // Capacity should be reduced (implementation dependent)
    // Data should be preserved
    assert_eq(deque.len(), 2);
}

// =============================================================================
// Section 11: Rotation Tests
// =============================================================================

@test
fn test_deque_rotate_left() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);
    deque.push_back(4);

    // [1, 2, 3, 4] -> rotate_left(1) -> [2, 3, 4, 1]
    deque.rotate_left(1);

    match deque.front() {
        Some(v) => assert_eq(*v, 2),
        None => panic("Expected Some"),
    }

    match deque.back() {
        Some(v) => assert_eq(*v, 1),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_rotate_right() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);
    deque.push_back(4);

    // [1, 2, 3, 4] -> rotate_right(1) -> [4, 1, 2, 3]
    deque.rotate_right(1);

    match deque.front() {
        Some(v) => assert_eq(*v, 4),
        None => panic("Expected Some"),
    }

    match deque.back() {
        Some(v) => assert_eq(*v, 3),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_rotate_full() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    // Rotating by len should result in same order
    deque.rotate_left(3);

    match deque.front() {
        Some(v) => assert_eq(*v, 1),
        None => panic("Expected Some"),
    }
}

// =============================================================================
// Section 12: Swap and Contains Tests
// =============================================================================

@test
fn test_deque_swap() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(10);
    deque.push_back(20);
    deque.push_back(30);

    // Swap elements at indices 0 and 2
    deque.swap(0, 2);

    // After swap: [30, 20, 10]
    match deque.get(0) {
        Some(v) => assert_eq(*v, 30),
        None => panic("Expected Some"),
    }

    match deque.get(2) {
        Some(v) => assert_eq(*v, 10),
        None => panic("Expected Some"),
    }
}

@test
fn test_deque_contains() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(10);
    deque.push_back(20);
    deque.push_back(30);

    assert(deque.contains(&10));
    assert(deque.contains(&20));
    assert(deque.contains(&30));
    assert(!deque.contains(&40)); // Not in deque
}

// =============================================================================
// Section 13: Slices and Contiguous Access
// =============================================================================

@test
fn test_deque_as_slices() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    let (s1, s2) = deque.as_slices();

    // Total length should match deque length
    assert_eq(s1.len() + s2.len(), 3);
}

@test
fn test_deque_make_contiguous() {
    let mut deque: Deque<Int> = Deque.new();

    // Create a non-contiguous state by pushing front and back
    deque.push_back(2);
    deque.push_front(1);
    deque.push_back(3);

    // Make contiguous and get slice
    let slice = deque.make_contiguous();

    assert_eq(slice.len(), 3);
    assert_eq(slice[0], 1);
    assert_eq(slice[1], 2);
    assert_eq(slice[2], 3);
}

// =============================================================================
// Section 14: Mutable Iterator Tests
// =============================================================================

@test
fn test_deque_iter_mut() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);

    // Double each element
    let mut iter = deque.iter_mut();
    loop {
        match iter.next() {
            Some(value) => *value = *value * 2,
            None => break,
        }
    }

    // Verify elements were doubled
    match deque.get(0) {
        Some(v) => assert_eq(*v, 2),
        None => panic("Expected Some"),
    }

    match deque.get(1) {
        Some(v) => assert_eq(*v, 4),
        None => panic("Expected Some"),
    }

    match deque.get(2) {
        Some(v) => assert_eq(*v, 6),
        None => panic("Expected Some"),
    }
}

