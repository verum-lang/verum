// =============================================================================
// list_production_test.vr - Production-grade List<T> method tests
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: collections, list, production, find, any, all, starts_with, ends_with, core
// @description: Tests for production-grade List methods: find_by, position_by,
//               rposition, any, all, starts_with, ends_with, fill, resize,
//               split_off, partition_by, repeat_list.
// =============================================================================

module specs.core.collections.list_production_test;

mount core.*;
mount core.base.ordering.{Ordering};

// =============================================================================
// find_by / position_by
// =============================================================================

@test
fn test_find_by_found() {
    let list: List<Int> = [1, 2, 3, 4, 5];
    let result = list.find_by(|x: &Int| -> Bool { *x > 3 });
    assert(result.is_some());
    assert(*result.unwrap() == 4);
}

@test
fn test_find_by_not_found() {
    let list: List<Int> = [1, 2, 3];
    let result = list.find_by(|x: &Int| -> Bool { *x > 10 });
    assert(result.is_none());
}

@test
fn test_find_by_empty() {
    let list: List<Int> = [];
    let result = list.find_by(|x: &Int| -> Bool { *x > 0 });
    assert(result.is_none());
}

@test
fn test_position_by_found() {
    let list: List<Int> = [10, 20, 30, 40];
    let result = list.position_by(|x: &Int| -> Bool { *x == 30 });
    assert(result.is_some());
    assert(result.unwrap() == 2);
}

@test
fn test_position_by_not_found() {
    let list: List<Int> = [10, 20, 30];
    let result = list.position_by(|x: &Int| -> Bool { *x == 99 });
    assert(result.is_none());
}

@test
fn test_position_by_first_match() {
    let list: List<Int> = [1, 2, 3, 2, 1];
    let result = list.position_by(|x: &Int| -> Bool { *x == 2 });
    assert(result.unwrap() == 1); // First occurrence
}

// =============================================================================
// rposition
// =============================================================================

@test
fn test_rposition_found() {
    let list: List<Int> = [1, 2, 3, 2, 1];
    let result = list.rposition(&2);
    assert(result.is_some());
    assert(result.unwrap() == 3); // Last occurrence
}

@test
fn test_rposition_not_found() {
    let list: List<Int> = [1, 2, 3];
    let result = list.rposition(&99);
    assert(result.is_none());
}

@test
fn test_rposition_single() {
    let list: List<Int> = [42];
    let result = list.rposition(&42);
    assert(result.unwrap() == 0);
}

// =============================================================================
// any / all
// =============================================================================

@test
fn test_any_true() {
    let list: List<Int> = [1, 2, 3, 4, 5];
    assert(list.any(|x: &Int| -> Bool { *x > 4 }));
}

@test
fn test_any_false() {
    let list: List<Int> = [1, 2, 3];
    assert(!list.any(|x: &Int| -> Bool { *x > 10 }));
}

@test
fn test_any_empty() {
    let list: List<Int> = [];
    assert(!list.any(|x: &Int| -> Bool { *x > 0 }));
}

@test
fn test_all_true() {
    let list: List<Int> = [2, 4, 6, 8];
    assert(list.all(|x: &Int| -> Bool { *x % 2 == 0 }));
}

@test
fn test_all_false() {
    let list: List<Int> = [2, 4, 5, 8];
    assert(!list.all(|x: &Int| -> Bool { *x % 2 == 0 }));
}

@test
fn test_all_empty() {
    let list: List<Int> = [];
    assert(list.all(|x: &Int| -> Bool { *x > 0 })); // Vacuously true
}

// =============================================================================
// starts_with / ends_with
// =============================================================================

@test
fn test_starts_with_true() {
    let list: List<Int> = [1, 2, 3, 4, 5];
    let prefix: List<Int> = [1, 2, 3];
    assert(list.starts_with(&prefix));
}

@test
fn test_starts_with_false() {
    let list: List<Int> = [1, 2, 3, 4, 5];
    let prefix: List<Int> = [2, 3];
    assert(!list.starts_with(&prefix));
}

@test
fn test_starts_with_empty_prefix() {
    let list: List<Int> = [1, 2, 3];
    let prefix: List<Int> = [];
    assert(list.starts_with(&prefix));
}

@test
fn test_starts_with_longer_prefix() {
    let list: List<Int> = [1, 2];
    let prefix: List<Int> = [1, 2, 3];
    assert(!list.starts_with(&prefix));
}

@test
fn test_ends_with_true() {
    let list: List<Int> = [1, 2, 3, 4, 5];
    let suffix: List<Int> = [3, 4, 5];
    assert(list.ends_with(&suffix));
}

@test
fn test_ends_with_false() {
    let list: List<Int> = [1, 2, 3, 4, 5];
    let suffix: List<Int> = [3, 4];
    assert(!list.ends_with(&suffix));
}

@test
fn test_ends_with_empty_suffix() {
    let list: List<Int> = [1, 2, 3];
    let suffix: List<Int> = [];
    assert(list.ends_with(&suffix));
}

// =============================================================================
// fill
// =============================================================================

@test
fn test_fill_basic() {
    let mut list: List<Int> = [1, 2, 3, 4, 5];
    list.fill(0);
    assert(list.len() == 5);
    assert(list[0] == 0);
    assert(list[4] == 0);
}

@test
fn test_fill_empty() {
    let mut list: List<Int> = [];
    list.fill(42);
    assert(list.is_empty());
}

// =============================================================================
// resize
// =============================================================================

@test
fn test_resize_grow() {
    let mut list: List<Int> = [1, 2, 3];
    list.resize(5, 0);
    assert(list.len() == 5);
    assert(list[0] == 1);
    assert(list[3] == 0);
    assert(list[4] == 0);
}

@test
fn test_resize_shrink() {
    let mut list: List<Int> = [1, 2, 3, 4, 5];
    list.resize(2, 0);
    assert(list.len() == 2);
    assert(list[0] == 1);
    assert(list[1] == 2);
}

@test
fn test_resize_same_size() {
    let mut list: List<Int> = [1, 2, 3];
    list.resize(3, 0);
    assert(list.len() == 3);
}

// =============================================================================
// split_off
// =============================================================================

@test
fn test_split_off_middle() {
    let mut list: List<Int> = [1, 2, 3, 4, 5];
    let tail = list.split_off(3);
    assert(list.len() == 3);
    assert(list[0] == 1);
    assert(list[2] == 3);
    assert(tail.len() == 2);
    assert(tail[0] == 4);
    assert(tail[1] == 5);
}

@test
fn test_split_off_at_start() {
    let mut list: List<Int> = [1, 2, 3];
    let tail = list.split_off(0);
    assert(list.is_empty());
    assert(tail.len() == 3);
}

@test
fn test_split_off_at_end() {
    let mut list: List<Int> = [1, 2, 3];
    let tail = list.split_off(3);
    assert(list.len() == 3);
    assert(tail.is_empty());
}

// =============================================================================
// partition_by
// =============================================================================

@test
fn test_partition_by_basic() {
    let list: List<Int> = [1, 2, 3, 4, 5, 6];
    let pair = list.partition_by(|x: &Int| -> Bool { *x % 2 == 0 });
    let evens = pair.0;
    let odds = pair.1;
    assert(evens.len() == 3);
    assert(odds.len() == 3);
    assert(evens[0] == 2);
    assert(evens[1] == 4);
    assert(evens[2] == 6);
    assert(odds[0] == 1);
    assert(odds[1] == 3);
    assert(odds[2] == 5);
}

@test
fn test_partition_by_all_match() {
    let list: List<Int> = [2, 4, 6];
    let pair = list.partition_by(|x: &Int| -> Bool { *x % 2 == 0 });
    assert(pair.0.len() == 3);
    assert(pair.1.is_empty());
}

@test
fn test_partition_by_none_match() {
    let list: List<Int> = [1, 3, 5];
    let pair = list.partition_by(|x: &Int| -> Bool { *x % 2 == 0 });
    assert(pair.0.is_empty());
    assert(pair.1.len() == 3);
}

@test
fn test_partition_by_empty() {
    let list: List<Int> = [];
    let pair = list.partition_by(|x: &Int| -> Bool { *x > 0 });
    assert(pair.0.is_empty());
    assert(pair.1.is_empty());
}

// =============================================================================
// repeat_list
// =============================================================================

@test
fn test_repeat_list_basic() {
    let list: List<Int> = [1, 2, 3];
    let repeated = list.repeat_list(3);
    assert(repeated.len() == 9);
    assert(repeated[0] == 1);
    assert(repeated[3] == 1);
    assert(repeated[8] == 3);
}

@test
fn test_repeat_list_zero() {
    let list: List<Int> = [1, 2, 3];
    let repeated = list.repeat_list(0);
    assert(repeated.is_empty());
}

@test
fn test_repeat_list_one() {
    let list: List<Int> = [1, 2];
    let repeated = list.repeat_list(1);
    assert(repeated.len() == 2);
    assert(repeated[0] == 1);
    assert(repeated[1] == 2);
}

// =============================================================================
// Edge Cases: rposition / find_by / position_by
// =============================================================================

@test
fn test_rposition_empty() {
    let list: List<Int> = [];
    let result = list.rposition(&42);
    assert(result.is_none());
}

@test
fn test_find_by_first_of_multiple() {
    let list: List<Int> = [10, 20, 30, 20, 10];
    let result = list.find_by(|x: &Int| -> Bool { *x == 20 });
    assert(result.is_some());
    assert(*result.unwrap() == 20);
}

@test
fn test_find_by_always_true() {
    let list: List<Int> = [5, 10, 15];
    let result = list.find_by(|x: &Int| -> Bool { true });
    assert(result.is_some());
    assert(*result.unwrap() == 5); // Returns first element
}

@test
fn test_position_by_empty() {
    let list: List<Int> = [];
    let result = list.position_by(|x: &Int| -> Bool { *x == 1 });
    assert(result.is_none());
}

// =============================================================================
// Edge Cases: any / all with single elements
// =============================================================================

@test
fn test_any_single_match() {
    let list: List<Int> = [42];
    assert(list.any(|x: &Int| -> Bool { *x == 42 }));
}

@test
fn test_any_single_no_match() {
    let list: List<Int> = [42];
    assert(!list.any(|x: &Int| -> Bool { *x == 99 }));
}

@test
fn test_all_single_match() {
    let list: List<Int> = [42];
    assert(list.all(|x: &Int| -> Bool { *x > 0 }));
}

@test
fn test_all_single_no_match() {
    let list: List<Int> = [0];
    assert(!list.all(|x: &Int| -> Bool { *x > 0 }));
}

// =============================================================================
// Edge Cases: starts_with / ends_with identity
// =============================================================================

@test
fn test_starts_with_self() {
    let list: List<Int> = [1, 2, 3];
    assert(list.starts_with(&list));
}

@test
fn test_ends_with_self() {
    let list: List<Int> = [1, 2, 3];
    assert(list.ends_with(&list));
}

// =============================================================================
// Edge Cases: resize / split_off / partition / fill / repeat
// =============================================================================

@test
fn test_resize_to_zero() {
    let mut list: List<Int> = [1, 2, 3, 4, 5];
    list.resize(0, 0);
    assert(list.is_empty());
}

@test
fn test_fill_single_element() {
    let mut list: List<Int> = [99];
    list.fill(0);
    assert_eq(list.len(), 1);
    assert_eq(list[0], 0);
}

@test
fn test_split_off_single_at_one() {
    let mut list: List<Int> = [42];
    let tail = list.split_off(1);
    assert_eq(list.len(), 1);
    assert_eq(list[0], 42);
    assert(tail.is_empty());
}

@test
fn test_partition_by_single_matches() {
    let list: List<Int> = [2];
    let pair = list.partition_by(|x: &Int| -> Bool { *x % 2 == 0 });
    assert_eq(pair.0.len(), 1);
    assert_eq(pair.0[0], 2);
    assert(pair.1.is_empty());
}

@test
fn test_repeat_list_empty() {
    let list: List<Int> = [];
    let repeated = list.repeat_list(5);
    assert(repeated.is_empty());
}

// =============================================================================
// Additional List Production Tests
// =============================================================================

@test
fn test_repeat_list_single() {
    let list: List<Int> = [42];
    let repeated = list.repeat_list(3);
    assert_eq(repeated.len(), 3);
    assert_eq(repeated[0], 42);
    assert_eq(repeated[2], 42);
}

@test
fn test_fill_all_same() {
    let mut list: List<Int> = [1, 2, 3, 4, 5];
    list.fill(0);
    assert_eq(list.len(), 5);
    assert_eq(list[0], 0);
    assert_eq(list[4], 0);
}

@test
fn test_resize_grow() {
    let mut list: List<Int> = [1, 2];
    list.resize(5, 99);
    assert_eq(list.len(), 5);
    assert_eq(list[0], 1);
    assert_eq(list[1], 2);
    assert_eq(list[2], 99);
    assert_eq(list[4], 99);
}

@test
fn test_split_off_middle() {
    let mut list: List<Int> = [1, 2, 3, 4, 5];
    let tail = list.split_off(3);
    assert_eq(list.len(), 3);
    assert_eq(tail.len(), 2);
    assert_eq(tail[0], 4);
}

@test
fn test_any_empty_list() {
    let list: List<Int> = [];
    assert(!list.any(|x: &Int| -> Bool { *x > 0 }));
}

@test
fn test_all_empty_list() {
    let list: List<Int> = [];
    assert(list.all(|x: &Int| -> Bool { *x > 0 }));
}

@test
fn test_starts_with_empty_prefix() {
    let list: List<Int> = [1, 2, 3];
    let empty: List<Int> = [];
    assert(list.starts_with(&empty));
}

@test
fn test_ends_with_empty_suffix() {
    let list: List<Int> = [1, 2, 3];
    let empty: List<Int> = [];
    assert(list.ends_with(&empty));
}

// =============================================================================
// Main
// =============================================================================

fn main() {
    // Tests run via @test annotations
}
