// =============================================================================

@test
fn test_deque_iter_fused() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    deque.push_back(3);
    let mut iter = deque.iter();
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_deque_iter_mut_fused() {
    let mut deque: Deque<Int> = Deque.new();
    deque.push_back(1);
    deque.push_back(2);
    let mut iter = deque.iter_mut();
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

