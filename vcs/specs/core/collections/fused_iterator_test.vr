// =============================================================================
// SECTION 10: Slice iterators are FusedIterator
// =============================================================================

@test
fn test_slice_iter_fused() {
    let data: List<Int> = [1, 2, 3];
    let slice = data.as_slice();
    let mut iter = slice.iter();
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_slice_iter_mut_fused() {
    let mut data: List<Int> = [1, 2, 3];
    let slice = data.as_mut_slice();
    let mut iter = slice.iter_mut();
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_slice_chunks_fused() {
    let data: List<Int> = [1, 2, 3, 4, 5];
    let slice = data.as_slice();
    let mut iter = slice.chunks(2);
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_slice_windows_fused() {
    let data: List<Int> = [1, 2, 3, 4];
    let slice = data.as_slice();
    let mut iter = slice.windows(2);
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}
