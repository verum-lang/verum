// =============================================================================
// SECTION 8: Fused iterator with fuse() adapter on collections
// =============================================================================

@test
fn test_list_iter_fuse_adapter() {
    let list: List<Int> = [1, 2];
    let mut iter = list.iter().fuse();
    assert(iter.next().is_some());
    assert(iter.next().is_some());
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_map_iter_fuse_adapter() {
    let mut map: Map<Int, Int> = Map.new();
    map.insert(1, 10);
    let mut iter = map.iter().fuse();
    assert(iter.next().is_some());
    assert(iter.next() is None);
    assert(iter.next() is None);
}

