// =============================================================================
// fused_iterator_test.vr - FusedIterator for all collection iterator types
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: core, collections, iterator, fused
// @description: Tests that all collection iterator types implement FusedIterator.
//               Verifies that after exhaustion, iterators continue to return None.
// =============================================================================

mount core.base.maybe.{Maybe, Some, None};
mount core.collections.list.{List};
mount core.collections.map.{Map};
mount core.collections.set.{Set};
mount core.collections.deque.{Deque};
mount core.collections.heap.{BinaryHeap};
mount core.collections.btree.{BTreeMap, BTreeSet};

// =============================================================================
// SECTION 1: List iterators are FusedIterator
// =============================================================================

@test
fn test_list_iter_fused() {
    let list: List<Int> = [1, 2, 3];
    let mut iter = list.iter();
    // Exhaust
    while iter.next().is_some() {}
    // Must continue returning None
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_list_iter_mut_fused() {
    let mut list: List<Int> = [1, 2, 3];
    let mut iter = list.iter_mut();
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

@test
fn test_list_drain_fused() {
    let mut list: List<Int> = [1, 2, 3];
    let mut drain = list.drain(0, 3);
    while drain.next().is_some() {}
    assert(drain.next() is None);
    assert(drain.next() is None);
}

