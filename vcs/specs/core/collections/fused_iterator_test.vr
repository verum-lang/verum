@test
fn test_map_iter_fused() {
    let mut map: Map<Int, Int> = Map.new();
    map.insert(1, 10);
    map.insert(2, 20);
    let mut iter = map.iter();
    while iter.next().is_some() {}
    assert(iter.next() is None);
    assert(iter.next() is None);
}

