@test
fn test_time_now_after_sleep_is_greater() {
    let t1 = Time.now();
    Time.sleep_ms(5);
    let t2 = Time.now();
    assert(t2 > t1);
}

@test
fn test_time_monotonic_five_calls_ordered() {
    let t1 = Time.monotonic();
    let t2 = Time.monotonic();
    let t3 = Time.monotonic();
    let t4 = Time.monotonic();
    let t5 = Time.monotonic();
    assert(t1 <= t2);
    assert(t2 <= t3);
    assert(t3 <= t4);
    assert(t4 <= t5);
}

@test
fn test_time_now_saturating_sub_self_is_zero() {
    let t = Time.now();
    let diff = t.saturating_sub(t);
    assert(diff.is_zero());
    assert_eq(diff.as_nanos(), 0);
}

@test
fn test_time_monotonic_double_gap_positive() {
    let t1 = Time.monotonic();
    let t2 = Time.monotonic();
    let t3 = Time.monotonic();
    let gap1 = t2 - t1;
    let gap2 = t3 - t2;
    assert(gap1 >= 0);
    assert(gap2 >= 0);
}

@test
fn test_time_now_as_secs_consistency() {
    let now = Time.now();
    let secs = now.as_secs();
    let secs_f = now.as_secs_f64();
    // Integer seconds should be <= float seconds
    let secs_from_float: Int = secs_f as Int;
    assert(secs_from_float >= secs - 1);
    assert(secs_from_float <= secs + 1);
}

@test
fn test_time_sleep_zero_then_now_ordered() {
    let t1 = Time.now();
    Time.sleep(Duration.zero());
    let t2 = Time.now();
    assert(t2 >= t1);
}

