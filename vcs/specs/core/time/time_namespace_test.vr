@test
fn test_time_now_as_micros_positive() {
    let now = Time.now();
    let micros = now.as_micros();
    assert(micros > 0);
}

@test
fn test_time_now_micros_millis_consistency() {
    let now = Time.now();
    let millis = now.as_millis();
    let micros = now.as_micros();
    // micros / 1000 should equal millis (truncated)
