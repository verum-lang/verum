@test
fn test_time_monotonic_nonnegative() {
    let t = Time.monotonic();
    assert(t >= 0);
}

@test
fn test_time_now_not_zero() {
    let now = Time.now();
    assert(!now.is_zero());
}

@test
fn test_time_now_add_duration() {
    let now = Time.now();
    let added = now + Duration.secs(1);
    assert(added > now);
}

@test
fn test_time_sleep_fn_signature() {
    fn do_sleep(d: Duration) { Time.sleep(d); }
    let _: fn(Duration) -> () = do_sleep;
}

@test
fn test_time_sleep_ms_fn_signature() {
    fn do_sleep_ms(ms: Int) { Time.sleep_ms(ms); }
    let _: fn(Int) -> () = do_sleep_ms;
}

// =============================================================================
// Section 15: Extended Time Namespace Tests
// =============================================================================

@test
fn test_time_now_duration_arithmetic() {
    let t1 = Time.now();
    let t2 = Time.now();
    // Can perform saturating_sub on Time.now() results
    let diff = t2.saturating_sub(t1);
    assert(diff.as_nanos() >= 0);
    // Can add durations to Time.now() results
    let future = t1 + Duration.millis(100);
    assert(future > t1);
}

@test
fn test_time_monotonic_arithmetic_operations() {
    let t1 = Time.monotonic();
    let t2 = Time.monotonic();
    // Can perform subtraction
    let elapsed = t2 - t1;
    assert(elapsed >= 0);
    // Can perform addition
    let future_nanos = t1 + 1000000;
    assert(future_nanos > t1);
}

@test
fn test_time_sleep_secs_actual_usage() {
    // Test Time.sleep_secs with 0 seconds
    let before = Instant.now();
    Time.sleep_secs(0);
    let after = Instant.now();
    let elapsed = after.duration_since(before);
    match elapsed {
        Maybe.Some(dur) => {
            // Should complete quickly
            assert(dur.as_millis() < 50);
        }
        Maybe.None => panic("Expected positive duration"),
    }
}

@test
fn test_time_namespace_method_combination() {
    // Use Time.now(), Time.monotonic(), and Time.sleep() together
    let now1 = Time.now();
    let mono1 = Time.monotonic();

    Time.sleep_ms(5);

    let now2 = Time.now();
    let mono2 = Time.monotonic();

    // Both should have advanced
    assert(now2 > now1);
    assert(mono2 > mono1);
}

@test
fn test_time_now_comparison_chain() {
    // Create a chain of time measurements
    let times = [
        Time.now(),
        Time.now(),
        Time.now(),
        Time.now(),
        Time.now(),
    ];

    // Each should be >= previous
    assert(times[1] >= times[0]);
    assert(times[2] >= times[1]);
    assert(times[3] >= times[2]);
    assert(times[4] >= times[3]);
}

@test
fn test_time_monotonic_vs_instant_now() {
    // Time.monotonic() and Instant.now() should be consistent
    let mono1 = Time.monotonic();
    let inst1 = Instant.now();

    Time.sleep_ms(10);

    let mono2 = Time.monotonic();
    let inst2 = Instant.now();

    // Both elapsed times should be positive
    assert(mono2 > mono1);
    let inst_elapsed = inst2.duration_since(inst1);
    match inst_elapsed {
        Maybe.Some(dur) => {
            assert(dur.as_millis() >= 10);
        }
        Maybe.None => panic("Expected positive duration"),
    }
}

@test
fn test_time_sleep_duration_from_now() {
    // Create a duration from Time.now() and sleep for it
    let base_time = Duration.millis(5);
    let before = Instant.now();
    Time.sleep(base_time);
    let elapsed = before.elapsed();

    // Should have slept at least the requested duration
    assert(elapsed >= base_time);
}

@test
fn test_time_monotonic_large_value_operations() {
    // Time.monotonic() returns large values - test arithmetic
    let mono = Time.monotonic();

    // Should be a large positive number (system uptime)
    assert(mono > 0);

    // Can perform modulo operations
    let remainder = mono % 1000000;
    assert(remainder >= 0);
    assert(remainder < 1000000);

    // Can perform division
    let seconds_approx = mono / 1_000_000_000;
    assert(seconds_approx >= 0);
}

fn main() {
    // Tests run via @test annotations
}
