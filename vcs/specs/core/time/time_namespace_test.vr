// =============================================================================
// Section 12: Additional Time.now() Properties
// =============================================================================

@test
fn test_time_now_as_secs_f64_positive() {
    let now = Time.now();
    let secs_f: Float = now.as_secs_f64();
    assert(secs_f > 0.0);
}

@test
fn test_time_now_greater_than_zero() {
    let now = Time.now();
    let zero = Duration.zero();
    assert(now > zero);
}

@test
fn test_time_now_millis_nanos_consistency() {
    let now = Time.now();
    let millis = now.as_millis();
    let nanos = now.as_nanos();
    // nanos / 1_000_000 should equal millis (truncated)
    assert_eq(nanos / 1_000_000, millis);
}

@test
fn test_time_monotonic_self_difference_zero() {
    let t = Time.monotonic();
    assert(t - t == 0);
}

@test
fn test_time_monotonic_large_value() {
    // System uptime in nanoseconds should be well above zero
    let nanos = Time.monotonic();
    // At least 1 millisecond of uptime
    assert(nanos > 1_000_000);
}

@test
fn test_time_now_four_calls_ordered() {
    let t1 = Time.now();
    let t2 = Time.now();
    let t3 = Time.now();
    let t4 = Time.now();
    assert(t1 <= t2);
    assert(t2 <= t3);
    assert(t3 <= t4);
    // Transitivity
    assert(t1 <= t4);
}

@test
fn test_time_monotonic_four_calls_ordered() {
    let t1 = Time.monotonic();
    let t2 = Time.monotonic();
    let t3 = Time.monotonic();
    let t4 = Time.monotonic();
    assert(t1 <= t2);
    assert(t2 <= t3);
    assert(t3 <= t4);
}

@test
fn test_time_now_subsec_nanos_range() {
    let now = Time.now();
    let subsec = now.subsec_nanos();
    // Subsecond nanos must be in [0, 999_999_999]
    assert(subsec >= 0);
    assert(subsec < 1_000_000_000);
}

@test
fn test_time_sleep_then_monotonic_still_ordered() {
    let before = Time.monotonic();
    Time.sleep_ms(5);
    let after = Time.monotonic();
    assert(after > before);
    // The gap should be at least ~5ms = 5_000_000 nanos
    assert(after - before >= 4_000_000);
}

@test
fn test_time_now_secs_millis_relationship() {
    let now = Time.now();
    let secs = now.as_secs();
    let millis = now.as_millis();
    // millis should be between secs*1000 and (secs+1)*1000
    assert(millis >= secs * 1000);
    assert(millis < (secs + 1) * 1000);
}

