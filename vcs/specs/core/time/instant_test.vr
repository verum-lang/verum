@test
fn test_instant_sub_instant_non_negative() {
    let a = Instant.now();
    let mut sum = 0;
    for i in 0..200 {
        sum = sum + i;
    }
    let b = Instant.now();

    let duration: Duration = b.saturating_duration_since(a);
    assert(duration.as_nanos() >= 0);
}

@test
fn test_instant_sub_instant_same_is_zero() {
    let a = Instant.now();
    let duration: Duration = a.saturating_duration_since(a);
    assert(duration.is_zero());
    assert_eq(duration.as_nanos(), 0);
}

// =============================================================================
// Section 16: Comparison Deeper
// =============================================================================

@test
fn test_instant_reflexive_le() {
    let a = Instant.now();
    assert(a <= a);
    assert(a >= a);
}

@test
fn test_instant_reflexive_eq() {
    let a = Instant.now();
    assert(a == a);
    assert(!(a != a));
}

@test
fn test_instant_now_vs_now_plus_delta() {
    let a = Instant.now();
    let b = a + Duration.secs(1);
    assert(a < b);
    assert(b > a);
    assert(a != b);
    assert(a <= b);
    assert(b >= a);
}

@test
fn test_instant_comparison_transitivity() {
    let a = Instant.now();
    let b = a + Duration.secs(1);
    let c = b + Duration.secs(1);
    // a < b < c
    assert(a < b);
    assert(b < c);
    assert(a < c); // Transitivity
}

// =============================================================================
// Section 17: Benchmark Pattern Deeper
// =============================================================================

@test
fn test_instant_benchmark_elapsed_positive() {
    let start = Instant.now();
    let mut product = 1;
    for i in 1..100 {
        product = product + i * i;
    }
    let elapsed = start.elapsed();
    assert(elapsed.as_nanos() >= 0);
}

@test
fn test_instant_benchmark_two_phases() {
    let total_start = Instant.now();

    // Phase 1
    let phase1_start = Instant.now();
    let mut sum1 = 0;
    for i in 0..500 {
        sum1 = sum1 + i;
    }
    let phase1_elapsed = phase1_start.elapsed();

    // Phase 2
    let phase2_start = Instant.now();
    let mut sum2 = 0;
    for i in 0..500 {
        sum2 = sum2 + i;
    }
    let phase2_elapsed = phase2_start.elapsed();

    let total_elapsed = total_start.elapsed();

    // Individual phases are non-negative
    assert(phase1_elapsed.as_nanos() >= 0);
    assert(phase2_elapsed.as_nanos() >= 0);
    // Total should be >= each individual
    assert(total_elapsed.as_nanos() >= 0);
}

// =============================================================================
// Section 18: Lap Timing Deeper
// =============================================================================

@test
fn test_instant_multiple_laps_cumulative() {
    let start = Instant.now();
    let mut last = start;
    let mut total_lap_nanos = 0;

    for lap in 0..5 {
        let mut sum = 0;
        for i in 0..100 {
            sum = sum + i;
        }

        let now = Instant.now();
        let lap_duration = now.saturating_duration_since(last);
        total_lap_nanos = total_lap_nanos + lap_duration.as_nanos();
        last = now;
    }

    // Sum of all laps should be non-negative
    assert(total_lap_nanos >= 0);

    // Total elapsed should also be non-negative
    let total = start.elapsed();
    assert(total.as_nanos() >= 0);
}

@test
fn test_instant_lap_count_tracking() {
    let start = Instant.now();
    let mut lap_count = 0;

    for _ in 0..10 {
        let lap_start = Instant.now();
        let mut v = 0;
        for j in 0..50 {
            v = v + j;
        }
        let lap_elapsed = lap_start.elapsed();
        assert(lap_elapsed.as_nanos() >= 0);
        lap_count = lap_count + 1;
    }

    assert_eq(lap_count, 10);
    let total = start.elapsed();
    assert(total.as_nanos() >= 0);
}

