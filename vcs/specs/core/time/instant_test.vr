// =============================================================================
// instant_test.vr - Comprehensive tests for Instant type
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: time, instant, monotonic, core
// @description: Comprehensive tests for Instant type and methods
// =============================================================================

mount core.time.{Instant, Duration};
mount core.base.maybe.{Maybe};

// =============================================================================
// Section 1: Construction Tests
// =============================================================================

@test
fn test_instant_now() {
    let instant = Instant.now();
    // Just verify it doesn't crash and returns something
    let elapsed = instant.elapsed();
    assert(elapsed.as_nanos() >= 0);
}

// =============================================================================
// Section 2: Elapsed Time Tests
// =============================================================================

@test
fn test_instant_elapsed() {
    let start = Instant.now();

    // Do some work
    let mut sum = 0;
    for i in 0..1000 {
        sum = sum + i;
    }

    let elapsed = start.elapsed();
    // Should have elapsed some time (at least 0)
    assert(elapsed.as_nanos() >= 0);
}

@test
fn test_instant_duration_since() {
    let earlier = Instant.now();

    // Small delay
    let mut sum = 0;
    for i in 0..100 {
        sum = sum + i;
    }

    let later = Instant.now();

    // duration_since returns Maybe<Duration>
    match later.duration_since(earlier) {
        Maybe.Some(duration) => assert(duration.as_nanos() >= 0),
        Maybe.None => panic("Expected Some for later.duration_since(earlier)"),
    }
}

@test
fn test_instant_saturating_duration_since() {
    let earlier = Instant.now();

    // Small delay
    let mut sum = 0;
    for i in 0..100 {
        sum = sum + i;
    }

    let later = Instant.now();

    // Correct order: positive duration
    let duration = later.saturating_duration_since(earlier);
    assert(duration.as_nanos() >= 0);

    // Reversed order: saturates to zero
    let zero_duration = earlier.saturating_duration_since(later);
    assert(zero_duration.is_zero());
}

// =============================================================================
// Section 3: Arithmetic Tests
// =============================================================================

@test
fn test_instant_add_duration() {
    let instant = Instant.now();
    let duration = Duration.secs(10);

    let future = instant + duration;

    // Future instant should be later
    match future.duration_since(instant) {
        Maybe.Some(diff) => assert_eq(diff.as_secs(), 10),
        Maybe.None => panic("Expected Some"),
    }
}

@test
fn test_instant_sub_duration() {
    let instant = Instant.now();
    let duration = Duration.secs(10);

    // Add then subtract should give us back approximately the same instant
    let future = instant + duration;
    let back = future - duration;

    // Using saturating_duration_since for safe comparison
    let diff = instant.saturating_duration_since(back);
    // Should be approximately 0
    assert(diff.as_secs() < 1);
}

@test
fn test_instant_sub_instant() {
    let earlier = Instant.now();

    // Small work
    let mut sum = 0;
    for i in 0..100 {
        sum = sum + i;
    }

    let later = Instant.now();

    // Instant - Instant gives Duration (saturating)
    // Note: Using method call instead of operator due to type resolution issue
    // (Task #64: later - earlier resolves to wrong Sub implementation)
    let duration: Duration = later.saturating_duration_since(earlier);
    assert(duration.as_nanos() >= 0);
}

// =============================================================================
// Section 4: Comparison Tests
// =============================================================================

@test
fn test_instant_ordering() {
    let first = Instant.now();

    // Small delay
    let mut sum = 0;
    for i in 0..100 {
        sum = sum + i;
    }

    let second = Instant.now();

    assert(first < second);
    assert(second > first);
    assert(first <= first);
    assert(first >= first);
}

@test
fn test_instant_equality() {
    let instant = Instant.now();

    // Same instant should be equal
    assert_eq(instant, instant);
}

// =============================================================================
// Section 5: Checked Operations Tests
// =============================================================================

@test
fn test_instant_checked_add() {
    let instant = Instant.now();
    let duration = Duration.secs(100);

    match instant.checked_add(duration) {
        Maybe.Some(future) => {
            match future.duration_since(instant) {
                Maybe.Some(diff) => assert_eq(diff.as_secs(), 100),
                Maybe.None => panic("Expected Some"),
            }
        }
        Maybe.None => panic("Expected Some"),
    }
}

@test
fn test_instant_checked_sub() {
    let instant = Instant.now();
    let small_duration = Duration.millis(1);

    // Should succeed with small duration
    match instant.checked_sub(small_duration) {
        Maybe.Some(past) => {
            // past should be before instant
            let diff = instant.saturating_duration_since(past);
            assert_eq(diff.as_millis(), 1);
        }
        Maybe.None => {} // Might fail if instant is very close to epoch
    }
}

// =============================================================================
// Section 6: Benchmarking Pattern Tests
// =============================================================================

@test
fn test_instant_benchmark_pattern() {
    let start = Instant.now();

    // Workload to measure
    let mut result = 0;
    for i in 0..10000 {
        result = result + i * i;
    }

    let elapsed = start.elapsed();

    // Just verify pattern works
    assert(elapsed.as_nanos() >= 0);
}

@test
fn test_instant_lap_timing() {
    let start = Instant.now();
    let mut last_lap = start;

    let mut lap_count = 0;

    for lap in 0..3 {
        // Simulate lap work
        let mut sum = 0;
        for i in 0..100 {
            sum = sum + i;
        }

        let now = Instant.now();
        let lap_duration = now.saturating_duration_since(last_lap);
        // Just verify we got a duration
        assert(lap_duration.as_nanos() >= 0);
        last_lap = now;
        lap_count = lap_count + 1;
    }

    // Should have completed 3 laps
    assert_eq(lap_count, 3);

    let total = start.elapsed();
    // Total should be >= 0
    assert(total.as_nanos() >= 0);
}

// =============================================================================
// Section 7: Edge Cases
// =============================================================================

@test
fn test_instant_zero_duration() {
    let instant = Instant.now();
    let zero = Duration.zero();

    let same = instant + zero;
    // Should be effectively the same instant
    let diff = same.saturating_duration_since(instant);
    assert(diff.is_zero());
}

@test
fn test_instant_self_duration() {
    let instant = Instant.now();

    // duration_since self returns Maybe.Some(zero)
    match instant.duration_since(instant) {
        Maybe.Some(diff) => {
            assert(diff.is_zero());
            assert_eq(diff.as_nanos(), 0);
        }
        Maybe.None => panic("Expected Some for self duration"),
    }
}

// =============================================================================
// Section 8: now() Patterns
// =============================================================================

@test
fn test_instant_two_sequential_nows() {
    let first = Instant.now();
    let second = Instant.now();
    // Monotonic: second is never before first
    assert(second >= first);
}

@test
fn test_instant_now_returns_valid() {
    let instant = Instant.now();
    // Elapsed from a just-created instant should be tiny but non-negative
    let e = instant.elapsed();
    assert(e.as_nanos() >= 0);
    assert(e.as_secs() < 60);
}

@test
fn test_instant_now_multiple_calls_monotonic() {
    let a = Instant.now();
    let b = Instant.now();
    let c = Instant.now();
    assert(a <= b);
    assert(b <= c);
    assert(a <= c);
}

// =============================================================================
// Section 9: Elapsed Deeper
// =============================================================================

@test
fn test_instant_elapsed_is_non_negative() {
    let start = Instant.now();
    let elapsed = start.elapsed();
    assert(elapsed.as_nanos() >= 0);
}

@test
fn test_instant_elapsed_from_now_is_tiny() {
    let now = Instant.now();
    let elapsed = now.elapsed();
    // Just created, should be under 1 second
    assert(elapsed.as_secs() == 0);
}

@test
fn test_instant_elapsed_after_work() {
    let start = Instant.now();
    let mut total = 0;
    for i in 0..5000 {
        total = total + i;
    }
    let elapsed = start.elapsed();
    // Should have elapsed at least 0 nanoseconds
    assert(elapsed.as_nanos() >= 0);
    // And should be less than a minute
    assert(elapsed.as_secs() < 60);
}

// =============================================================================
// Section 10: duration_since Deeper
// =============================================================================

@test
fn test_instant_duration_since_same_instant() {
    let a = Instant.now();
    match a.duration_since(a) {
        Maybe.Some(d) => {
            assert(d.is_zero());
            assert_eq(d.as_nanos(), 0);
            assert_eq(d.as_secs(), 0);
        }
        Maybe.None => panic("Expected Some for same instant"),
    }
}

@test
fn test_instant_duration_since_later_from_earlier() {
    let earlier = Instant.now();
    let mut sum = 0;
    for i in 0..500 {
        sum = sum + i;
    }
    let later = Instant.now();

    match later.duration_since(earlier) {
        Maybe.Some(d) => assert(d.as_nanos() >= 0),
        Maybe.None => panic("Expected Some for later.duration_since(earlier)"),
    }
}

@test
fn test_instant_duration_since_earlier_from_later_returns_none() {
    let earlier = Instant.now();
    let mut sum = 0;
    for i in 0..500 {
        sum = sum + i;
    }
    let later = Instant.now();

    // Reversed: earlier.duration_since(later) should return None
    match earlier.duration_since(later) {
        Maybe.Some(_) => {} // Some implementations might saturate to zero
        Maybe.None => {}    // Expected behavior
    }
    // Either way, this should not panic
}

