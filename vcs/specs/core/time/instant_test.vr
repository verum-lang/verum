@test
fn test_instant_self_duration_via_method() {
    let a = Instant.now();
    match a.duration_since(a) {
        Maybe.Some(d) => {
            assert(d.is_zero());
            assert_eq(d.as_nanos(), 0);
            assert_eq(d.as_millis(), 0);
            assert_eq(d.as_secs(), 0);
        }
        Maybe.None => panic("Expected Some for self duration_since"),
    }
}

@test
fn test_instant_self_saturating_duration_is_zero() {
    let a = Instant.now();
    let d = a.saturating_duration_since(a);
    assert(d.is_zero());
    assert_eq(d.as_nanos(), 0);
    assert_eq(d.as_millis(), 0);
}

