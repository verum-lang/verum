@test
fn test_instant_saturating_duration_since_same_is_zero() {
    let a = Instant.now();
    let d = a.saturating_duration_since(a);
    assert(d.is_zero());
    assert_eq(d.as_nanos(), 0);
}

@test
fn test_instant_saturating_duration_since_reversed_saturates() {
    let earlier = Instant.now();
    let mut sum = 0;
    for i in 0..500 {
        sum = sum + i;
    }
    let later = Instant.now();

    // Reversed order saturates to zero
    let d = earlier.saturating_duration_since(later);
    assert(d.is_zero());
    assert_eq(d.as_nanos(), 0);
}

@test
fn test_instant_saturating_duration_since_correct_order() {
    let earlier = Instant.now();
    let mut sum = 0;
    for i in 0..500 {
        sum = sum + i;
    }
    let later = Instant.now();

    let d = later.saturating_duration_since(earlier);
    assert(d.as_nanos() >= 0);
}

// =============================================================================
// Section 12: checked_add Deeper
// =============================================================================

@test
fn test_instant_checked_add_zero_duration() {
    let instant = Instant.now();
    let zero = Duration.zero();

    match instant.checked_add(zero) {
        Maybe.Some(result) => {
            let diff = result.saturating_duration_since(instant);
            assert(diff.is_zero());
        }
        Maybe.None => panic("Expected Some for checked_add zero"),
    }
}

@test
fn test_instant_checked_add_small_duration() {
    let instant = Instant.now();
    let small = Duration.millis(50);

    match instant.checked_add(small) {
        Maybe.Some(result) => {
            match result.duration_since(instant) {
                Maybe.Some(diff) => assert_eq(diff.as_millis(), 50),
                Maybe.None => panic("Expected Some"),
            }
        }
        Maybe.None => panic("Expected Some for checked_add small"),
    }
}

@test
fn test_instant_checked_add_ordering() {
    let instant = Instant.now();
    let d = Duration.secs(5);

    match instant.checked_add(d) {
        Maybe.Some(future) => {
            assert(future > instant);
            assert(instant < future);
        }
        Maybe.None => panic("Expected Some for checked_add ordering"),
    }
}

@test
fn test_instant_checked_add_large_duration() {
    let instant = Instant.now();
    let large = Duration.hours(24);

    match instant.checked_add(large) {
        Maybe.Some(future) => {
            match future.duration_since(instant) {
                Maybe.Some(diff) => assert_eq(diff.as_secs(), 86400),
                Maybe.None => panic("Expected Some for duration_since"),
            }
        }
        Maybe.None => {} // Overflow is acceptable
    }
}

