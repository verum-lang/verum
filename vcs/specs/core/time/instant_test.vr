@test
fn test_instant_checked_sub_zero_duration() {
    let instant = Instant.now();
    let zero = Duration.zero();

    match instant.checked_sub(zero) {
        Maybe.Some(result) => {
            let diff = instant.saturating_duration_since(result);
            assert(diff.is_zero());
        }
        Maybe.None => panic("Expected Some for checked_sub zero"),
    }
}

@test
fn test_instant_checked_sub_small_from_now() {
    let instant = Instant.now();
    let small = Duration.millis(1);

    match instant.checked_sub(small) {
        Maybe.Some(past) => {
            let diff = instant.saturating_duration_since(past);
            assert_eq(diff.as_millis(), 1);
        }
        Maybe.None => {} // Acceptable if instant is near epoch
    }
}

@test
fn test_instant_checked_sub_returns_earlier() {
    let instant = Instant.now();
    let d = Duration.secs(10);

    match instant.checked_sub(d) {
        Maybe.Some(past) => {
            // past should be before instant
            assert(past < instant);
            assert(instant > past);
        }
        Maybe.None => {} // Acceptable
    }
}

// =============================================================================
// Section 14: Operator +/- Deeper
// =============================================================================

@test
fn test_instant_add_then_sub_roundtrip() {
    let instant = Instant.now();
    let d = Duration.secs(42);

    let future = instant + d;
    let back = future - d;

    let diff = instant.saturating_duration_since(back);
    assert(diff.as_secs() < 1);
}

@test
fn test_instant_double_add() {
    let instant = Instant.now();
    let d1 = Duration.secs(5);
    let d2 = Duration.secs(10);

    let step1 = instant + d1;
    let step2 = step1 + d2;

    match step2.duration_since(instant) {
        Maybe.Some(total) => assert_eq(total.as_secs(), 15),
        Maybe.None => panic("Expected Some for double add"),
    }
}

@test
fn test_instant_add_zero_identity() {
    let instant = Instant.now();
    let zero = Duration.zero();

    let same = instant + zero;
    let diff = same.saturating_duration_since(instant);
    assert(diff.is_zero());
}

@test
fn test_instant_sub_duration_ordering() {
    let instant = Instant.now();
    let d = Duration.secs(100);

    let future = instant + d;
    let back = future - d;

    // back should be approximately equal to instant
    let diff_forward = instant.saturating_duration_since(back);
    let diff_backward = back.saturating_duration_since(instant);
    assert(diff_forward.as_secs() < 1);
    assert(diff_backward.as_secs() < 1);
}

