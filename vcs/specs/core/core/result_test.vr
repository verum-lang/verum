@test
fn test_validated_from_result_ok() {
    let result: Result<Int, Text> = Ok(42);
    let v = Validated.from_result(result);
    assert(v.is_valid());
}

/// Test Validated.from_result on Err
@test
fn test_validated_from_result_err() {
    let result: Result<Int, Text> = Err("error");
    let v = Validated.from_result(result);
    assert(v.is_invalid());
}

/// Test Validated.to_result
@test
fn test_validated_to_result_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    let result = v.to_result();
    assert_eq(result.unwrap(), 42);
}

/// Test Validated.to_result on Invalid
@test
fn test_validated_to_result_invalid() {
    let v: Validated<Text, Int> = Validated.invalid_all(["e1", "e2"]);
    let result = v.to_result();
    assert_eq(result.unwrap_err().len(), 2);
}

/// Test Validated.and_then short-circuits
@test
fn test_validated_and_then() {
    let v: Validated<Text, Int> = Validated.valid(42);
    let result = v.and_then(|n| {
        if n > 0 {
            Validated.valid(n * 2)
        } else {
            Validated.invalid("not positive")
        }
    });
    match result {
        Valid(n) => assert_eq(n, 84),
        Invalid(_) => panic("Expected Valid"),
    }
}

