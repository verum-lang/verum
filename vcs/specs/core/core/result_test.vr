// =============================================================================
// SECTION 18: RetryBackoff Tests
// =============================================================================

/// Test RetryBackoff.None
@test
fn test_backoff_none() {
    let strategy = RetryBackoff.None;
    assert_eq(strategy.delay_for_attempt(0), 0);
    assert_eq(strategy.delay_for_attempt(5), 0);
}

/// Test RetryBackoff.Linear
@test
fn test_backoff_linear() {
    let strategy = RetryBackoff.Linear { delay_ms: 100 };
    assert_eq(strategy.delay_for_attempt(0), 100);
    assert_eq(strategy.delay_for_attempt(5), 100);
}

/// Test RetryBackoff.Exponential
@test
fn test_backoff_exponential() {
    let strategy = RetryBackoff.Exponential {
        initial_ms: 100,
        max_ms: 5000,
        multiplier: 2.0,
    };
    assert_eq(strategy.delay_for_attempt(0), 100);  // 100 * 2^0 = 100
    assert_eq(strategy.delay_for_attempt(1), 200);  // 100 * 2^1 = 200
    assert_eq(strategy.delay_for_attempt(2), 400);  // 100 * 2^2 = 400
    assert_eq(strategy.delay_for_attempt(3), 800);  // 100 * 2^3 = 800
}

/// Test RetryBackoff.Exponential caps at max
@test
fn test_backoff_exponential_max() {
    let strategy = RetryBackoff.Exponential {
        initial_ms: 100,
        max_ms: 500,
        multiplier: 2.0,
    };
    assert_eq(strategy.delay_for_attempt(10), 500);  // Capped at max
}

