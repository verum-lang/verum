/// Test Validated.validate_all with all valid
@test
fn test_validate_all_valid() {
    let items: List<Validated<Text, Int>> = List.from([
        Validated.valid(1),
        Validated.valid(2),
        Validated.valid(3),
    ]);
    let result = Validated.validate_all(items);
    match result {
        Valid(values) => {
            assert_eq(values.len(), 3);
            assert_eq(values[0], 1);
            assert_eq(values[1], 2);
            assert_eq(values[2], 3);
        }
        Invalid(_) => panic("Expected Valid"),
    }
}

/// Test Validated.validate_all with some invalid
@test
fn test_validate_all_some_invalid() {
    let items: List<Validated<Text, Int>> = [
        Validated.valid(1),
        Validated.invalid("error1"),
        Validated.valid(3),
        Validated.invalid("error2"),
    ];
    let result = Validated.validate_all(items);
    assert(result.is_invalid());
    let errors = result.errors();
    assert_eq(errors.len(), 2);
}

