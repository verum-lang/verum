/// Test Result in parsing scenario
fn parse_int(s: &Text) -> Result<Int, Text> {
    if s == "42" {
        Ok(42)
    } else if s == "100" {
        Ok(100)
    } else {
        Err(f"invalid number: {s}")
    }
}

@test
fn test_result_parsing_scenario() {
    assert_eq(parse_int("42").unwrap(), 42);
    assert(parse_int("invalid").is_err());
}

/// Test chained transformations
@test
fn test_result_chain_transformations() {
    let result: Result<Int, Text> = Ok(10);
    let final_result = result
        .map(|v| v * 2)           // 20
        .and_then(|v| if v > 15 { Ok(v + 5) } else { Err("too small") })  // Ok(25)
        .map(|v| v.to_string());  // "25"

    assert_eq(final_result.unwrap(), "25");
}

/// Test error recovery chain
@test
fn test_error_recovery_chain() {
    let result: Result<Int, Text> = Err("primary error");
    let recovered = result
        .or_else(|_| Err("secondary error") as Result<Int, Text>)
        .or_else(|_| Ok(0));  // Final fallback

    assert_eq(recovered.unwrap(), 0);
}

/// Test Exit for representing both expected and unexpected errors
@test
fn test_exit_error_handling() {
    fn might_fail(n: Int) -> Exit<Text, Int> {
        if n > 0 {
            Exit.succeed(n * 2)
        } else if n == 0 {
            Exit.fail("zero not allowed")
        } else {
            Exit.die("negative numbers cause bugs!")
        }
    }

    assert(might_fail(10).is_success());
    assert(might_fail(0).is_failure());
    assert(might_fail(-1).is_defect());
}

/// Test Validated for form validation
@test
fn test_validated_form_validation() {
    fn validate_name(name: &Text) -> Validated<Text, Text> {
        if name.len() >= 2 {
            Validated.valid(name.clone())
        } else {
            Validated.invalid("Name too short")
        }
    }

    fn validate_age(age: Int) -> Validated<Text, Int> {
        if age >= 0 && age <= 150 {
            Validated.valid(age)
        } else {
            Validated.invalid("Age out of range")
        }
    }

    // Both valid
    let name_valid = validate_name("Alice");
    let age_valid = validate_age(30);
    let combined = name_valid.zip_with(age_valid, |n, a| (n, a));
    assert(combined.is_valid());

    // Both invalid - errors accumulate
    let name_invalid = validate_name("A");
    let age_invalid = validate_age(-5);
    let combined_errors = name_invalid.zip_with(age_invalid, |n, a| (n, a));
    assert(combined_errors.is_invalid());
    assert_eq(combined_errors.errors().len(), 2);
}

