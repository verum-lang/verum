/// Test Validated.valid
@test
fn test_validated_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    assert(v.is_valid());
    assert(!v.is_invalid());
}

/// Test Validated.invalid
@test
fn test_validated_invalid() {
    let v: Validated<Text, Int> = Validated.invalid("error");
    assert(!v.is_valid());
    assert(v.is_invalid());
}

/// Test Validated.invalid_all
@test
fn test_validated_invalid_all() {
    let v: Validated<Text, Int> = Validated.invalid_all(["error1", "error2"]);
    assert(v.is_invalid());
    let errors = v.errors();
    assert_eq(errors.len(), 2);
}

/// Test Validated.map on Valid
@test
fn test_validated_map_valid() {
    let v: Validated<Text, Int> = Validated.valid(42);
    let mapped = v.map(|n| n * 2);
    match mapped {
        Valid(n) => assert_eq(n, 84),
        Invalid(_) => panic("Expected Valid"),
    }
}

/// Test Validated.map on Invalid
@test
fn test_validated_map_invalid() {
    let v: Validated<Text, Int> = Validated.invalid("error");
    let mapped = v.map(|n| n * 2);
    assert(mapped.is_invalid());
}

/// Test Validated.zip_with accumulates errors
@test
fn test_validated_zip_with_both_valid() {
    let a: Validated<Text, Int> = Validated.valid(10);
    let b: Validated<Text, Int> = Validated.valid(20);
    let result = a.zip_with(b, |x, y| x + y);
    match result {
        Valid(sum) => assert_eq(sum, 30),
        Invalid(_) => panic("Expected Valid"),
    }
}

/// Test Validated.zip_with with first invalid
@test
fn test_validated_zip_with_first_invalid() {
    let a: Validated<Text, Int> = Validated.invalid("error1");
    let b: Validated<Text, Int> = Validated.valid(20);
    let result = a.zip_with(b, |x, y| x + y);
    assert(result.is_invalid());
    assert_eq(result.errors().len(), 1);
}

/// Test Validated.zip_with with both invalid (error accumulation)
@test
fn test_validated_zip_with_both_invalid() {
    let a: Validated<Text, Int> = Validated.invalid("error1");
    let b: Validated<Text, Int> = Validated.invalid("error2");
    let result = a.zip_with(b, |x, y| x + y);
    assert(result.is_invalid());
    assert_eq(result.errors().len(), 2);  // Both errors accumulated!
}

