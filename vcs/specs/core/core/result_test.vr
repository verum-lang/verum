// =============================================================================
// result_test.vr - Comprehensive tests for Result<T, E> and error handling
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: core, result, error-handling, monad, safety, retry
// @description: Tests for Result<T, E> type including predicates, unwrapping,
//               transformations, combinators, retry logic, Exit, Cause, and Validated.
//
// Coverage:
// - Result<T, E> type definition (Ok(T) | Err(E))
// - Predicates (is_ok, is_err, is_ok_and, is_err_and)
// - Conversion to Maybe (ok, err)
// - Unwrapping (unwrap, expect, unwrap_or, unwrap_or_else, unwrap_or_default)
// - Transformations (map, map_err, map_or, map_or_else, and_then, or_else)
// - Combinators (and, or)
// - References (as_ref, as_mut)
// - Inspection (inspect, inspect_err, tap, tap_err, tap_both)
// - Transposition and Flattening
// - Iteration (iter, iter_mut, ResultIter, into_iter)
// - Protocol implementations (Eq, Ord, Clone, Copy, Hash, Debug)
// - Error type
// - Try protocol (? operator support)
// - Retry combinators (retry, retry_linear, retry_immediate, retry_jittered)
// - RetryBackoff and RetryOptions
// - Recovery (recover, recover_with)
// - Context wrapping (context, with_context)
// - ContextError type
// - Exit<E, A> two-channel model
// - Cause<E> lossless error chain
// - Validated<E, A> error accumulation
// =============================================================================

mount core.base.result.{
    Result, Ok, Err,
    ResultIter,
    Error,
    RetryBackoff,
    RetryOptions,
    ContextError,
    Exit, Success, Failure, Defect, DefectInfo,
    Cause, Fail, Die, Then, Both, Empty,
    Validated, Valid, Invalid,
};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.collections.list.{List};

// =============================================================================
// SECTION 1: Type Construction Tests
// =============================================================================

/// Test Ok construction
@test
fn test_ok_construction() {
    let ok: Result<Int, Text> = Ok(42);
    assert(ok.is_ok());
}

/// Test Err construction
@test
fn test_err_construction() {
    let err: Result<Int, Text> = Err("error");
    assert(err.is_err());
}

/// Test Ok with zero value
@test
fn test_ok_zero_value() {
    let ok: Result<Int, Text> = Ok(0);
    assert(ok.is_ok());
    assert_eq(ok.unwrap(), 0);
}

/// Test Ok with empty string
@test
fn test_ok_empty_string() {
    let ok: Result<Text, Int> = Ok("");
    assert(ok.is_ok());
    assert_eq(ok.unwrap(), "");
}

/// Test nested Result
@test
fn test_nested_result() {
    let nested: Result<Result<Int, Text>, Bool> = Ok(Ok(42));
    assert(nested.is_ok());
    let inner = nested.unwrap();
    assert(inner.is_ok());
    assert_eq(inner.unwrap(), 42);
}

// =============================================================================
// SECTION 2: Predicates Tests
// =============================================================================

/// Test is_ok on Ok
@test
fn test_is_ok_on_ok() {
    let result: Result<Int, Text> = Ok(42);
    assert(result.is_ok());
    assert_eq(result.is_ok(), true);
}

/// Test is_ok on Err
@test
fn test_is_ok_on_err() {
    let result: Result<Int, Text> = Err("error");
    assert(!result.is_ok());
    assert_eq(result.is_ok(), false);
}

/// Test is_err on Err
@test
fn test_is_err_on_err() {
    let result: Result<Int, Text> = Err("error");
    assert(result.is_err());
    assert_eq(result.is_err(), true);
}

/// Test is_err on Ok
@test
fn test_is_err_on_ok() {
    let result: Result<Int, Text> = Ok(42);
    assert(!result.is_err());
    assert_eq(result.is_err(), false);
}

/// Test predicates are mutually exclusive
@test
fn test_predicates_mutually_exclusive() {
    let ok: Result<Int, Text> = Ok(42);
    let err: Result<Int, Text> = Err("error");

    assert(ok.is_ok() != ok.is_err());
    assert(err.is_ok() != err.is_err());
}

/// Test is_ok_and with predicate
@test
fn test_is_ok_and_true() {
    let result: Result<Int, Text> = Ok(42);
    assert(result.is_ok_and(|v| v > 10));
}

/// Test is_ok_and with failing predicate
@test
fn test_is_ok_and_false() {
    let result: Result<Int, Text> = Ok(42);
    assert(!result.is_ok_and(|v| v > 100));
}

/// Test is_ok_and on Err
@test
fn test_is_ok_and_on_err() {
    let result: Result<Int, Text> = Err("error");
    assert(!result.is_ok_and(|v| v > 0));
}

/// Test is_err_and with predicate
@test
fn test_is_err_and_true() {
    let result: Result<Int, Text> = Err("error");
    assert(result.is_err_and(|e| e.len() > 0));
}

/// Test is_err_and with failing predicate
@test
fn test_is_err_and_false() {
    let result: Result<Int, Text> = Err("error");
    assert(!result.is_err_and(|e| e.is_empty()));
}

/// Test is_err_and on Ok
@test
fn test_is_err_and_on_ok() {
    let result: Result<Int, Text> = Ok(42);
    assert(!result.is_err_and(|_| true));
}

// =============================================================================
// SECTION 3: Conversion to Maybe Tests
// =============================================================================

/// Test ok() on Ok
@test
fn test_ok_conversion_ok() {
    let result: Result<Int, Text> = Ok(42);
    let maybe = result.ok();
    assert(maybe.is_some());
    assert_eq(maybe.unwrap(), 42);
}

/// Test ok() on Err
@test
fn test_ok_conversion_err() {
    let result: Result<Int, Text> = Err("error");
    let maybe = result.ok();
    assert(maybe.is_none());
}

/// Test err() on Err
@test
fn test_err_conversion_err() {
    let result: Result<Int, Text> = Err("error");
    let maybe = result.err();
    assert(maybe.is_some());
    assert_eq(maybe.unwrap(), "error");
}

/// Test err() on Ok
@test
fn test_err_conversion_ok() {
    let result: Result<Int, Text> = Ok(42);
    let maybe = result.err();
    assert(maybe.is_none());
}

// =============================================================================
// SECTION 4: Unwrapping Tests
// =============================================================================

/// Test unwrap on Ok
@test
fn test_unwrap_ok() {
    let result: Result<Int, Text> = Ok(42);
    assert_eq(result.unwrap(), 42);
}

/// Test unwrap_err on Err
@test
fn test_unwrap_err_err() {
    let result: Result<Int, Text> = Err("error");
    assert_eq(result.unwrap_err(), "error");
}

/// Test expect on Ok
@test
fn test_expect_ok() {
    let result: Result<Int, Text> = Ok(42);
    assert_eq(result.expect("should have value"), 42);
}

/// Test unwrap_or with Ok
@test
fn test_unwrap_or_ok() {
    let result: Result<Int, Text> = Ok(42);
    assert_eq(result.unwrap_or(100), 42);
}

/// Test unwrap_or with Err
@test
fn test_unwrap_or_err() {
    let result: Result<Int, Text> = Err("error");
    assert_eq(result.unwrap_or(100), 100);
}

/// Test unwrap_or_else with Ok
@test
fn test_unwrap_or_else_ok() {
    let result: Result<Int, Text> = Ok(42);
    let value = result.unwrap_or_else(|e| e.len());
    assert_eq(value, 42);
}

/// Test unwrap_or_else with Err
@test
fn test_unwrap_or_else_err() {
    let result: Result<Int, Text> = Err("error");
    let value = result.unwrap_or_else(|e| e.len());
    assert_eq(value, 5);  // "error".len() = 5
}

/// Test unwrap_or_else closure not called for Ok
@test
fn test_unwrap_or_else_not_called_for_ok() {
    let result: Result<Int, Text> = Ok(42);
    let mut called = false;
    let _ = result.unwrap_or_else(|_| {
        called = true;
        100
    });
    assert(!called);
}

/// Test unwrap_or_default with Ok
@test
fn test_unwrap_or_default_ok() {
    let result: Result<Int, Text> = Ok(42);
    assert_eq(result.unwrap_or_default(), 42);
}

/// Test unwrap_or_default with Err
@test
fn test_unwrap_or_default_err() {
    let result: Result<Int, Text> = Err("error");
    assert_eq(result.unwrap_or_default(), 0);  // Int default is 0
}

// =============================================================================
// SECTION 5: Transformations Tests
// =============================================================================

/// Test map on Ok
@test
fn test_map_ok() {
    let result: Result<Int, Text> = Ok(42);
    let doubled = result.map(|v| v * 2);
    assert_eq(doubled.unwrap(), 84);
}

/// Test map on Err
@test
fn test_map_err_result() {
    let result: Result<Int, Text> = Err("error");
    let doubled = result.map(|v| v * 2);
    assert(doubled.is_err());
    assert_eq(doubled.unwrap_err(), "error");
}

/// Test map closure not called for Err
@test
fn test_map_not_called_for_err() {
    let result: Result<Int, Text> = Err("error");
    let mut called = false;
    let _ = result.map(|v| {
        called = true;
        v * 2
    });
    assert(!called);
}

/// Test map_err on Err
@test
fn test_map_err_on_err() {
    let result: Result<Int, Text> = Err("error");
    let mapped = result.map_err(|e| e.len());
    assert_eq(mapped.unwrap_err(), 5);
}

/// Test map_err on Ok
@test
fn test_map_err_on_ok() {
    let result: Result<Int, Text> = Ok(42);
    let mapped = result.map_err(|e| e.len());
    assert_eq(mapped.unwrap(), 42);
}

/// Test map_or on Ok
@test
fn test_map_or_ok() {
    let result: Result<Int, Text> = Ok(42);
    let value = result.map_or(0, |v| v * 2);
    assert_eq(value, 84);
}

/// Test map_or on Err
@test
fn test_map_or_err() {
    let result: Result<Int, Text> = Err("error");
    let value = result.map_or(0, |v| v * 2);
    assert_eq(value, 0);
}

/// Test map_or_else on Ok
@test
fn test_map_or_else_ok() {
    let result: Result<Int, Text> = Ok(42);
    let value = result.map_or_else(|e| e.len(), |v| v * 2);
    assert_eq(value, 84);
}

/// Test map_or_else on Err
@test
fn test_map_or_else_err() {
    let result: Result<Int, Text> = Err("error");
    let value = result.map_or_else(|e| e.len(), |v| v * 2);
    assert_eq(value, 5);
}

/// Test and_then on Ok returning Ok
@test
fn test_and_then_ok_ok() {
    let result: Result<Int, Text> = Ok(42);
    let chained = result.and_then(|v| Ok(v * 2));
    assert_eq(chained.unwrap(), 84);
}

/// Test and_then on Ok returning Err
@test
fn test_and_then_ok_err() {
    let result: Result<Int, Text> = Ok(42);
    let chained = result.and_then(|_| Err("failed") as Result<Int, Text>);
    assert(chained.is_err());
}

/// Test and_then on Err
@test
fn test_and_then_err() {
    let result: Result<Int, Text> = Err("error");
    let chained = result.and_then(|v| Ok(v * 2));
    assert(chained.is_err());
    assert_eq(chained.unwrap_err(), "error");
}

/// Test and_then chaining
@test
fn test_and_then_chaining() {
    let result: Result<Int, Text> = Ok(10);
    let chained = result
        .and_then(|v| Ok(v + 5))
        .and_then(|v| Ok(v * 2))
        .and_then(|v| Ok(v - 10));
    assert_eq(chained.unwrap(), 20);  // ((10 + 5) * 2) - 10 = 20
}

/// Test or_else on Err
@test
fn test_or_else_err() {
    let result: Result<Int, Text> = Err("error");
    let recovered = result.or_else(|e| Ok(e.len() as Int));
    assert_eq(recovered.unwrap(), 5);
}

/// Test or_else on Ok
@test
fn test_or_else_ok() {
    let result: Result<Int, Text> = Ok(42);
    let recovered = result.or_else(|e| Ok(e.len() as Int));
    assert_eq(recovered.unwrap(), 42);
}

// =============================================================================
// SECTION 6: Combinators Tests
// =============================================================================

/// Test and with Ok and Ok
@test
fn test_and_ok_ok() {
    let a: Result<Int, Text> = Ok(1);
    let b: Result<Int, Text> = Ok(2);
    assert_eq(a.and(b).unwrap(), 2);
}

/// Test and with Ok and Err
@test
fn test_and_ok_err() {
    let a: Result<Int, Text> = Ok(1);
    let b: Result<Int, Text> = Err("error");
    assert(a.and(b).is_err());
}

/// Test and with Err and Ok
@test
fn test_and_err_ok() {
    let a: Result<Int, Text> = Err("error");
    let b: Result<Int, Text> = Ok(2);
    assert(a.and(b).is_err());
}

/// Test and with Err and Err
@test
fn test_and_err_err() {
    let a: Result<Int, Text> = Err("first");
    let b: Result<Int, Text> = Err("second");
    assert_eq(a.and(b).unwrap_err(), "first");  // First error preserved
}

/// Test or with Ok and Ok
@test
fn test_or_ok_ok() {
    let a: Result<Int, Text> = Ok(1);
    let b: Result<Int, Int> = Ok(2);
    assert_eq(a.or(b).unwrap(), 1);  // First Ok wins
}

/// Test or with Ok and Err
@test
fn test_or_ok_err() {
    let a: Result<Int, Text> = Ok(1);
    let b: Result<Int, Int> = Err(100);
    assert_eq(a.or(b).unwrap(), 1);
}

/// Test or with Err and Ok
@test
fn test_or_err_ok() {
    let a: Result<Int, Text> = Err("error");
    let b: Result<Int, Int> = Ok(2);
    assert_eq(a.or(b).unwrap(), 2);
}

/// Test or with Err and Err
@test
fn test_or_err_err() {
    let a: Result<Int, Text> = Err("first");
    let b: Result<Int, Int> = Err(100);
    assert_eq(a.or(b).unwrap_err(), 100);  // Second error
}

// =============================================================================
// SECTION 7: Reference Tests
// =============================================================================

/// Test as_ref on Ok
@test
fn test_as_ref_ok() {
    let result: Result<Int, Text> = Ok(42);
    let ref_result = result.as_ref();
    assert(ref_result.is_ok());
    assert_eq(*ref_result.unwrap(), 42);
}

/// Test as_ref on Err
@test
fn test_as_ref_err() {
    let result: Result<Int, Text> = Err("error");
    let ref_result = result.as_ref();
    assert(ref_result.is_err());
    assert_eq(*ref_result.unwrap_err(), "error");
}

/// Test as_mut on Ok
@test
fn test_as_mut_ok() {
    let mut result: Result<Int, Text> = Ok(42);
    let ref_result = result.as_mut();
    *ref_result.unwrap() = 100;
    assert_eq(result.unwrap(), 100);
}

/// Test as_mut on Err
@test
fn test_as_mut_err() {
    let mut result: Result<Int, Text> = Err("error");
    let ref_result = result.as_mut();
    assert(ref_result.is_err());
}

// =============================================================================
// SECTION 8: Inspection Tests
// =============================================================================

/// Test inspect on Ok
@test
fn test_inspect_ok() {
    let mut inspected = false;
    let result: Result<Int, Text> = Ok(42);
    let returned = result.inspect(|v| {
        inspected = true;
        assert_eq(*v, 42);
    });
    assert(inspected);
    assert_eq(returned.unwrap(), 42);
}

/// Test inspect on Err
@test
fn test_inspect_err_result() {
    let mut inspected = false;
    let result: Result<Int, Text> = Err("error");
    let _ = result.inspect(|_| {
        inspected = true;
    });
    assert(!inspected);
}

/// Test inspect_err on Err
@test
fn test_inspect_err_on_err() {
    let mut inspected = false;
    let result: Result<Int, Text> = Err("error");
    let _ = result.inspect_err(|e| {
        inspected = true;
        assert_eq(*e, "error");
    });
    assert(inspected);
}

/// Test inspect_err on Ok
@test
fn test_inspect_err_on_ok() {
    let mut inspected = false;
    let result: Result<Int, Text> = Ok(42);
    let _ = result.inspect_err(|_| {
        inspected = true;
    });
    assert(!inspected);
}

/// Test tap (alias for inspect)
@test
fn test_tap() {
    let mut tapped = false;
    let result: Result<Int, Text> = Ok(42);
    let _ = result.tap(|_| { tapped = true; });
    assert(tapped);
}

/// Test tap_err
@test
fn test_tap_err() {
    let mut tapped = false;
    let result: Result<Int, Text> = Err("error");
    let _ = result.tap_err(|_| { tapped = true; });
    assert(tapped);
}

/// Test tap_both on Ok
@test
fn test_tap_both_ok() {
    let mut on_ok_called = false;
    let mut on_err_called = false;
    let result: Result<Int, Text> = Ok(42);
    let _ = result.tap_both(
        |_| { on_ok_called = true; },
        |_| { on_err_called = true; }
    );
    assert(on_ok_called);
    assert(!on_err_called);
}

/// Test tap_both on Err
@test
fn test_tap_both_err() {
    let mut on_ok_called = false;
    let mut on_err_called = false;
    let result: Result<Int, Text> = Err("error");
    let _ = result.tap_both(
        |_| { on_ok_called = true; },
        |_| { on_err_called = true; }
    );
    assert(!on_ok_called);
    assert(on_err_called);
}

// =============================================================================
// SECTION 9: Iteration Tests
// =============================================================================

/// Test iter on Ok
@test
fn test_iter_ok() {
    let result: Result<Int, Text> = Ok(42);
    let mut iter = result.iter();
    let first = iter.next();
    assert(first.is_some());
    assert_eq(*first.unwrap(), 42);
    assert(iter.next().is_none());
}

/// Test iter on Err
@test
fn test_iter_err() {
    let result: Result<Int, Text> = Err("error");
    let mut iter = result.iter();
    assert(iter.next().is_none());
}

/// Test iter_mut on Ok
@test
fn test_iter_mut_ok() {
    let mut result: Result<Int, Text> = Ok(42);
    let mut iter = result.iter_mut();
    let first = iter.next();
    *first.unwrap() = 100;
    assert_eq(result.unwrap(), 100);
}

/// Test into_iter on Ok
@test
fn test_into_iter_ok() {
    let result: Result<Int, Text> = Ok(42);
    let mut iter = result.into_iter();
    assert_eq(iter.next().unwrap(), 42);
}

/// Test ResultIter size_hint
@test
fn test_result_iter_size_hint() {
    let result: Result<Int, Text> = Ok(42);
    let iter = result.iter();
    let (lower, upper) = iter.size_hint();
    assert_eq(lower, 1);
    assert_eq(upper.unwrap(), 1);
}

// =============================================================================
// SECTION 10: Protocol Implementation Tests
// =============================================================================

/// Test Eq: Ok equals Ok with same value
@test
fn test_eq_ok_ok() {
    let a: Result<Int, Text> = Ok(42);
    let b: Result<Int, Text> = Ok(42);
    assert(a == b);
}

/// Test Eq: Ok not equal Ok with different value
@test
fn test_eq_ok_different() {
    let a: Result<Int, Text> = Ok(42);
    let b: Result<Int, Text> = Ok(100);
    assert(a != b);
}

/// Test Eq: Err equals Err with same error
@test
fn test_eq_err_err() {
    let a: Result<Int, Text> = Err("error");
    let b: Result<Int, Text> = Err("error");
    assert(a == b);
}

/// Test Eq: Ok not equal Err
@test
fn test_eq_ok_err() {
    let a: Result<Int, Text> = Ok(42);
    let b: Result<Int, Text> = Err("error");
    assert(a != b);
}

/// Test Ord: Ok greater than Err
@test
fn test_ord_ok_err() {
    let a: Result<Int, Text> = Ok(42);
    let b: Result<Int, Text> = Err("error");
    assert_eq(a.cmp(&b), Greater);
    assert(a > b);
}

/// Test Ord: Err less than Ok
@test
fn test_ord_err_ok() {
    let a: Result<Int, Text> = Err("error");
    let b: Result<Int, Text> = Ok(42);
    assert_eq(a.cmp(&b), Less);
    assert(a < b);
}

/// Test Ord: Ok compared by value
@test
fn test_ord_ok_ok() {
    let a: Result<Int, Text> = Ok(10);
    let b: Result<Int, Text> = Ok(20);
    assert(a < b);
}

/// Test Clone for Ok
@test
fn test_clone_ok() {
    let result: Result<Int, Text> = Ok(42);
    let cloned = result.clone();
    assert_eq(cloned.unwrap(), 42);
}

/// Test Clone for Err
@test
fn test_clone_err() {
    let result: Result<Int, Text> = Err("error");
    let cloned = result.clone();
    assert_eq(cloned.unwrap_err(), "error");
}

/// Test Debug for Ok
@test
fn test_debug_ok() {
    let result: Result<Int, Text> = Ok(42);
    let debug_str = f"{result:?}";
    assert_eq(debug_str, "Ok(42)");
}

/// Test Debug for Err
@test
fn test_debug_err() {
    let result: Result<Int, Text> = Err("error");
    let debug_str = f"{result:?}";
    assert(debug_str.contains("Err"));
}

// =============================================================================
// SECTION 11: Error Type Tests
// =============================================================================

/// Test Error.new
@test
fn test_error_new() {
    let err = Error.new("something went wrong");
    assert_eq(err.message, "something went wrong");
}

/// Test Error equality
@test
fn test_error_eq() {
    let a = Error.new("error");
    let b = Error.new("error");
    assert(a == b);
}

/// Test Error clone
@test
fn test_error_clone() {
    let err = Error.new("error");
    let cloned = err.clone();
    assert_eq(cloned.message, "error");
}

// =============================================================================
// SECTION 12: Try Protocol Tests (? operator)
// =============================================================================

/// Test ? operator extracts value from Ok
@test
fn test_try_operator_ok() -> Result<Int, Text> {
    let result: Result<Int, Text> = Ok(42);
    let value = result?;
    Ok(value * 2)
}

/// Test ? operator early returns on Err
@test
fn test_try_operator_err() -> Result<Int, Text> {
    let result: Result<Int, Text> = Err("error");
    let value = result?;  // Should early return here
    Ok(value * 2)
}

/// Test ? operator chaining
fn chain_operations(a: Int, b: Int) -> Result<Int, Text> {
    let x = validate_positive(a)?;
    let y = validate_positive(b)?;
    Ok(x + y)
}

fn validate_positive(n: Int) -> Result<Int, Text> {
    if n >= 0 {
        Ok(n)
    } else {
        Err("negative number")
    }
}

@test
fn test_try_chaining_success() {
    let result = chain_operations(10, 20);
    assert_eq(result.unwrap(), 30);
}

@test
fn test_try_chaining_first_err() {
    let result = chain_operations(-10, 20);
    assert(result.is_err());
}

@test
fn test_try_chaining_second_err() {
    let result = chain_operations(10, -20);
    assert(result.is_err());
}

// =============================================================================
// SECTION 13: Recovery Tests
// =============================================================================

/// Test recover on Err
@test
fn test_recover_err() {
    let result: Result<Int, Text> = Err("error");
    let recovered = result.recover(100);
    assert_eq(recovered.unwrap(), 100);
}

/// Test recover on Ok
@test
fn test_recover_ok() {
    let result: Result<Int, Text> = Ok(42);
    let recovered = result.recover(100);
    assert_eq(recovered.unwrap(), 42);
}

/// Test recover_with on Err
@test
fn test_recover_with_err() {
    let result: Result<Int, Text> = Err("error");
    let recovered = result.recover_with(|e| e.len() as Int);
    assert_eq(recovered.unwrap(), 5);
}

