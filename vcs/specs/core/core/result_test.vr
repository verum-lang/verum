/// Test Exit.Success construction
@test
fn test_exit_success() {
    let exit: Exit<Text, Int> = Exit.succeed(42);
    assert(exit.is_success());
    assert(!exit.is_failure());
    assert(!exit.is_defect());
}

/// Test Exit.Failure construction
@test
fn test_exit_failure() {
    let exit: Exit<Text, Int> = Exit.fail("error");
    assert(!exit.is_success());
    assert(exit.is_failure());
    assert(!exit.is_defect());
}

/// Test Exit.Defect construction
@test
fn test_exit_defect() {
    let exit: Exit<Text, Int> = Exit.die("bug!");
    assert(!exit.is_success());
    assert(!exit.is_failure());
    assert(exit.is_defect());
}

/// Test Exit.to_result on Success
@test
fn test_exit_to_result_success() {
    let exit: Exit<Text, Int> = Exit.succeed(42);
    let result = exit.to_result();
    assert_eq(result.unwrap(), 42);
}

/// Test Exit.to_result on Failure
@test
fn test_exit_to_result_failure() {
    let exit: Exit<Text, Int> = Exit.fail("error");
    let result = exit.to_result();
    assert_eq(result.unwrap_err(), "error");
}

/// Test Exit.map on Success
@test
fn test_exit_map_success() {
    let exit: Exit<Text, Int> = Exit.succeed(42);
    let mapped = exit.map(|v| v * 2);
    assert_eq(mapped.to_result().unwrap(), 84);
}

/// Test Exit.map_error on Failure
@test
fn test_exit_map_error() {
    let exit: Exit<Text, Int> = Exit.fail("error");
    let mapped = exit.map_error(|e| e.len());
    match mapped {
        Failure(len) => assert_eq(len, 5),
        _ => panic("Expected Failure"),
    }
}

/// Test Exit.flat_map
@test
fn test_exit_flat_map() {
    let exit: Exit<Text, Int> = Exit.succeed(10);
    let chained = exit.flat_map(|v| Exit.succeed(v * 2));
    assert_eq(chained.to_result().unwrap(), 20);
}

/// Test Exit.fold
@test
fn test_exit_fold() {
    let success: Exit<Text, Int> = Exit.succeed(42);
    let result = success.fold(
        |v| f"success: {v}",
        |e| f"failure: {e}",
        |d| f"defect: {d.message}"
    );
    assert_eq(result, "success: 42");
}

/// Test DefectInfo
@test
fn test_defect_info() {
    let base: DefectInfo = DefectInfo.new("Something broke");
    let info: DefectInfo = base.with_location("main.vr:42");
    assert_eq(info.message, "Something broke");
    assert_eq(info.location.unwrap(), "main.vr:42");
}

// =============================================================================
// SECTION 21: Cause Type Tests
// =============================================================================

/// Test Cause.fail
@test
fn test_cause_fail() {
    let cause: Cause<Text> = Cause.fail("error");
    assert(!cause.is_empty());
    let failures = cause.failures();
    assert_eq(failures.len(), 1);
    assert_eq(*failures[0], "error");
}

/// Test Cause.die
@test
fn test_cause_die() {
    let cause: Cause<Text> = Cause.die("bug!");
    let defects = cause.defects();
    assert_eq(defects.len(), 1);
    assert_eq(defects[0].message, "bug!");
}

/// Test Cause.Empty
@test
fn test_cause_empty() {
    let cause: Cause<Text> = Empty;
    assert(cause.is_empty());
    assert_eq(cause.failures().len(), 0);
}

/// Test Cause.then (sequential composition)
@test
fn test_cause_then() {
    let first: Cause<Text> = Cause.fail("first");
    let second: Cause<Text> = Cause.fail("second");
    let combined = first.then(second);
    let failures = combined.failures();
    assert_eq(failures.len(), 2);
}

/// Test Cause.both (parallel composition)
@test
fn test_cause_both() {
    let left: Cause<Text> = Cause.fail("left");
    let right: Cause<Text> = Cause.fail("right");
    let combined = left.both(right);
    let failures = combined.failures();
    assert_eq(failures.len(), 2);
}

/// Test Cause with Empty is identity
@test
fn test_cause_empty_identity() {
    let cause: Cause<Text> = Cause.fail("error");
    let empty: Cause<Text> = Empty;

    let with_empty_before = empty.clone().then(cause.clone());
    let with_empty_after = cause.clone().then(empty.clone());

    assert_eq(with_empty_before.failures().len(), 1);
    assert_eq(with_empty_after.failures().len(), 1);
}

