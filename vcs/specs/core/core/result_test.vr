// SECTION 16: Context Tests
// =============================================================================

/// Test context on Err
@test
fn test_context_err() {
    let result: Result<Int, Text> = Err("base error");
    let with_context = result.context("Failed to process");
    assert(with_context.is_err());
    let err = with_context.unwrap_err();
    // Use accessor methods instead of direct field access
    // (generic record field access has type resolution issues)
    assert_eq(*err.message(), "Failed to process");
    assert_eq(*err.source(), "base error");
}

/// Test context on Ok
@test
fn test_context_ok() {
    let result: Result<Int, Text> = Ok(42);
    let with_context = result.context("Should not apply");
    assert_eq(with_context.unwrap(), 42);
}

/// Test with_context lazy evaluation
@test
fn test_with_context_lazy() {
    let mut called = false;
    let result: Result<Int, Text> = Ok(42);
    let _ = result.with_context(|| {
        called = true;
        "context"
    });
    assert(!called, "Context function should not be called for Ok");
}

/// Test ContextError methods
@test
fn test_context_error_methods() {
    let err = ContextError.new("context message", "source error");
    assert_eq(*err.message(), "context message");
    assert_eq(*err.source(), "source error");
    assert_eq(err.into_source(), "source error");
}

