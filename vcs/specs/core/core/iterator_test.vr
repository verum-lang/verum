// =============================================================================
// iterator_test.vr - Comprehensive tests for Iterator protocol and adapters
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: iterator, protocol, adapters, transducers, core
// @description: Tests for Iterator protocol, adapters, construction functions, and transducers
// =============================================================================

mount core.prelude.*;
mount core.collections.list.List;
mount core.base.ordering.{Ordering, Less, Equal, Greater};

// =============================================================================
// Section 1: Basic Iterator Protocol - next() and Exhaustion
// =============================================================================

/// Test that range iterator produces expected sequence
@test
fn test_iterator_next_basic() {
    let mut iter = range(0, 5);

    assert_eq(iter.next(), Some(0));
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next(), Some(3));
    assert_eq(iter.next(), Some(4));
    assert_eq(iter.next(), None);
}

/// Test that iterator returns None after exhaustion
@test
fn test_iterator_exhaustion() {
    let mut iter = range(0, 2);

    assert_eq(iter.next(), Some(0));
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next(), None);
    // Continued calls should also return None
    assert_eq(iter.next(), None);
    assert_eq(iter.next(), None);
}

/// Test empty iterator
@test
fn test_iterator_empty_range() {
    let mut iter = range(5, 5);  // Empty range
    assert_eq(iter.next(), None);
}

/// Test iterator with negative range (empty)
@test
fn test_iterator_negative_range() {
    let mut iter = range(10, 5);  // end < start, should be empty
    assert_eq(iter.next(), None);
}

// =============================================================================
// Section 2: Size Hints
// =============================================================================

/// Test size_hint for range
@test
fn test_size_hint_range() {
    let iter = range(0, 10);
    let (lower, upper) = iter.size_hint();
    assert_eq(lower, 10);
    assert_eq(upper, Some(10));
}

/// Test size_hint for empty range
@test
fn test_size_hint_empty() {
    let iter = range(5, 5);
    let (lower, upper) = iter.size_hint();
    assert_eq(lower, 0);
    assert_eq(upper, Some(0));
}

/// Test size_hint updates during iteration
@test
fn test_size_hint_updates() {
    let mut iter = range(0, 5);

    assert_eq(iter.size_hint(), (5, Some(5)));
    iter.next();
    assert_eq(iter.size_hint(), (4, Some(4)));
    iter.next();
    assert_eq(iter.size_hint(), (3, Some(3)));
}

/// Test size_hint for infinite iterator
@test
fn test_size_hint_infinite() {
    let iter = count_from(0);
    let (lower, upper) = iter.size_hint();
    assert_eq(lower, Int.max_value());
    assert_eq(upper, None);
}

// =============================================================================
// Section 3: Consuming Adapters - count, last, nth
// =============================================================================

/// Test count consumes iterator and returns element count
@test
fn test_count_basic() {
    let iter = range(0, 10);
    assert_eq(iter.count(), 10);
}

/// Test count on empty iterator
@test
fn test_count_empty() {
    let iter = range(0, 0);
    assert_eq(iter.count(), 0);
}

/// Test last returns final element
@test
fn test_last_basic() {
    let iter = range(0, 5);
    assert_eq(iter.last(), Some(4));
}

/// Test last on empty iterator
@test
fn test_last_empty() {
    let iter = range(0, 0);
    assert_eq(iter.last(), None);
}

/// Test last on single element
@test
fn test_last_single() {
    let iter = once(42);
    assert_eq(iter.last(), Some(42));
}

/// Test nth returns correct element
@test
fn test_nth_basic() {
    let mut iter = range(0, 10);
    assert_eq(iter.nth(0), Some(0));
    assert_eq(iter.nth(0), Some(1));  // nth consumes elements before it
    assert_eq(iter.nth(2), Some(4));  // Skip 2, 3, return 4
}

/// Test nth past end returns None
@test
fn test_nth_past_end() {
    let mut iter = range(0, 5);
    assert_eq(iter.nth(10), None);
}

/// Test nth on empty iterator
@test
fn test_nth_empty() {
    let mut iter = range(0, 0);
    assert_eq(iter.nth(0), None);
}

// =============================================================================
// Section 4: advance_by
// =============================================================================

/// Test advance_by advances iterator
@test
fn test_advance_by_basic() {
    let mut iter = range(0, 10);
    assert_eq(iter.advance_by(3), Ok(()));
    assert_eq(iter.next(), Some(3));
}

/// Test advance_by with insufficient elements
@test
fn test_advance_by_insufficient() {
    let mut iter = range(0, 5);
    assert_eq(iter.advance_by(10), Err(5));  // Only advanced 5 before exhaustion
}

/// Test advance_by zero
@test
fn test_advance_by_zero() {
    let mut iter = range(0, 5);
    assert_eq(iter.advance_by(0), Ok(()));
    assert_eq(iter.next(), Some(0));
}

// =============================================================================
// Section 5: Transforming Adapters - map
// =============================================================================

/// Test map transforms elements
@test
fn test_map_basic() {
    let iter = range(0, 5).map(|x| x * 2);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 2, 4, 6, 8]);
}

/// Test map preserves size hint
@test
fn test_map_size_hint() {
    let iter = range(0, 10).map(|x| x + 1);
    assert_eq(iter.size_hint(), (10, Some(10)));
}

/// Test map with type conversion
@test
fn test_map_type_conversion() {
    let iter = range(0, 3).map(|x| f"value_{x}");
    let result: List<Text> = iter.collect();
    assert_eq(result, ["value_0", "value_1", "value_2"]);
}

/// Test map laziness
@test
fn test_map_lazy() {
    let mut counter = 0;
    let mut iter = range(0, 5).map(|x| {
        counter = counter + 1;
        x * 2
    });

    assert_eq(counter, 0);  // Nothing computed yet
    iter.next();
    assert_eq(counter, 1);  // Only one element computed
}

// =============================================================================
// Section 6: Transforming Adapters - filter
// =============================================================================

/// Test filter removes non-matching elements
@test
fn test_filter_basic() {
    let iter = range(0, 10).filter(|x| *x % 2 == 0);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 2, 4, 6, 8]);
}

/// Test filter all pass
@test
fn test_filter_all_pass() {
    let iter = range(0, 5).filter(|_| true);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 3, 4]);
}

/// Test filter none pass
@test
fn test_filter_none_pass() {
    let iter = range(0, 5).filter(|_| false);
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

/// Test filter on empty iterator
@test
fn test_filter_empty() {
    let iter = range(0, 0).filter(|x| *x > 0);
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

// =============================================================================
// Section 7: Transforming Adapters - filter_map
// =============================================================================

/// Test filter_map combines filter and map
@test
fn test_filter_map_basic() {
    let iter = range(0, 10).filter_map(|x| {
        if x % 2 == 0 {
            Some(x * 10)
        } else {
            None
        }
    });
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 20, 40, 60, 80]);
}

/// Test filter_map all None
@test
fn test_filter_map_all_none() {
    let iter = range(0, 5).filter_map(|_| -> Maybe<Int> { None });
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

/// Test filter_map all Some
@test
fn test_filter_map_all_some() {
    let iter = range(0, 3).filter_map(|x| Some(x + 100));
    let result: List<Int> = iter.collect();
    assert_eq(result, [100, 101, 102]);
}

// =============================================================================
// Section 8: Transforming Adapters - flat_map
// =============================================================================

/// Test flat_map flattens nested iterators
@test
fn test_flat_map_basic() {
    let iter = range(1, 4).flat_map(|x| range(0, x));
    let result: List<Int> = iter.collect();
    // 1 -> [0], 2 -> [0,1], 3 -> [0,1,2]
    assert_eq(result, [0, 0, 1, 0, 1, 2]);
}

/// Test flat_map with empty inner iterators
@test
fn test_flat_map_empty_inner() {
    let iter = range(0, 3).flat_map(|_| range(0, 0));  // All empty
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

/// Test flat_map single element inner
@test
fn test_flat_map_single_inner() {
    let iter = range(0, 3).flat_map(|x| once(x * 10));
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 10, 20]);
}

// =============================================================================
// Section 9: Transforming Adapters - take
// =============================================================================

/// Test take limits elements
@test
fn test_take_basic() {
    let iter = range(0, 100).take(5);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 3, 4]);
}

/// Test take more than available
@test
fn test_take_more_than_available() {
    let iter = range(0, 3).take(10);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2]);
}

/// Test take zero
@test
fn test_take_zero() {
    let iter = range(0, 10).take(0);
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

/// Test take size hint
@test
fn test_take_size_hint() {
    let iter = range(0, 100).take(5);
    assert_eq(iter.size_hint(), (5, Some(5)));

    let iter2 = range(0, 3).take(10);
    assert_eq(iter2.size_hint(), (3, Some(3)));
}

// =============================================================================
// Section 10: Transforming Adapters - skip
// =============================================================================

/// Test skip removes initial elements
@test
fn test_skip_basic() {
    let iter = range(0, 10).skip(5);
    let result: List<Int> = iter.collect();
    assert_eq(result, [5, 6, 7, 8, 9]);
}

/// Test skip more than available
@test
fn test_skip_more_than_available() {
    let iter = range(0, 5).skip(10);
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

/// Test skip zero
@test
fn test_skip_zero() {
    let iter = range(0, 5).skip(0);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 3, 4]);
}

// =============================================================================
// Section 11: Transforming Adapters - take_while
// =============================================================================

/// Test take_while stops at first failure
@test
fn test_take_while_basic() {
    let iter = range(0, 10).take_while(|x| *x < 5);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 3, 4]);
}

/// Test take_while all pass
@test
fn test_take_while_all_pass() {
    let iter = range(0, 5).take_while(|_| true);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 3, 4]);
}

/// Test take_while none pass
@test
fn test_take_while_none_pass() {
    let iter = range(0, 5).take_while(|_| false);
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

/// Test take_while stops permanently after first failure
@test
fn test_take_while_stops_permanently() {
    // Even if later elements would pass, they're not included
    let iter = [1, 2, 3, -1, 5, 6].iter().take_while(|x| **x > 0);
    let result: List<Int> = iter.map(|x| *x).collect();
    assert_eq(result, [1, 2, 3]);
}

// =============================================================================
// Section 12: Transforming Adapters - skip_while
// =============================================================================

/// Test skip_while skips initial matching elements
@test
fn test_skip_while_basic() {
    let iter = range(0, 10).skip_while(|x| *x < 5);
    let result: List<Int> = iter.collect();
    assert_eq(result, [5, 6, 7, 8, 9]);
}

/// Test skip_while all pass (skips everything)
@test
fn test_skip_while_all_pass() {
    let iter = range(0, 5).skip_while(|_| true);
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

/// Test skip_while none pass (keeps everything)
@test
fn test_skip_while_none_pass() {
    let iter = range(0, 5).skip_while(|_| false);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 3, 4]);
}

/// Test skip_while only skips initial run
@test
fn test_skip_while_only_initial() {
    // Should include -1 and following, even though -1 < 0
    let iter = [-1, -2, 3, -4, 5].iter().skip_while(|x| **x < 0);
    let result: List<Int> = iter.map(|x| *x).collect();
    assert_eq(result, [3, -4, 5]);
}

// =============================================================================
// Section 13: Transforming Adapters - chain
// =============================================================================

/// Test chain concatenates iterators
@test
fn test_chain_basic() {
    let iter = range(0, 3).chain(range(10, 13));
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 10, 11, 12]);
}

/// Test chain with empty first
@test
fn test_chain_empty_first() {
    let iter = range(0, 0).chain(range(1, 4));
    let result: List<Int> = iter.collect();
    assert_eq(result, [1, 2, 3]);
}

/// Test chain with empty second
@test
fn test_chain_empty_second() {
    let iter = range(0, 3).chain(range(0, 0));
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2]);
}

/// Test chain both empty
@test
fn test_chain_both_empty() {
    let iter = range(0, 0).chain(range(0, 0));
    let result: List<Int> = iter.collect();
    assert_eq(result, []);
}

// =============================================================================
// Section 14: Transforming Adapters - zip
// =============================================================================

/// Test zip pairs elements
@test
fn test_zip_basic() {
    let iter = range(0, 3).zip(range(10, 13));
    let result: List<(Int, Int)> = iter.collect();
    assert_eq(result, [(0, 10), (1, 11), (2, 12)]);
}

/// Test zip stops at shorter
@test
fn test_zip_unequal_length() {
    let iter = range(0, 5).zip(range(10, 12));
    let result: List<(Int, Int)> = iter.collect();
    assert_eq(result, [(0, 10), (1, 11)]);
}

/// Test zip with empty
@test
fn test_zip_with_empty() {
    let iter = range(0, 5).zip(range(0, 0));
    let result: List<(Int, Int)> = iter.collect();
    assert_eq(result, []);
}

/// Test zip size hint takes minimum
@test
fn test_zip_size_hint() {
    let iter = range(0, 10).zip(range(0, 5));
    assert_eq(iter.size_hint(), (5, Some(5)));
}

// =============================================================================
// Section 15: Transforming Adapters - enumerate
// =============================================================================

/// Test enumerate adds indices
@test
fn test_enumerate_basic() {
    let iter = ["a", "b", "c"].iter().enumerate();
    let result: List<(Int, &Text)> = iter.collect();
    assert_eq(result.len(), 3);
    assert_eq(result[0].0, 0);
    assert_eq(*result[0].1, "a");
    assert_eq(result[1].0, 1);
    assert_eq(*result[1].1, "b");
    assert_eq(result[2].0, 2);
    assert_eq(*result[2].1, "c");
}

/// Test enumerate on empty
@test
fn test_enumerate_empty() {
    let iter = range(0, 0).enumerate();
    let result: List<(Int, Int)> = iter.collect();
    assert_eq(result, []);
}

/// Test enumerate preserves size hint
@test
fn test_enumerate_size_hint() {
    let iter = range(0, 10).enumerate();
    assert_eq(iter.size_hint(), (10, Some(10)));
}

// =============================================================================
// Section 16: Transforming Adapters - peekable
// =============================================================================

/// Test peekable allows peeking
@test
fn test_peekable_basic() {
    let mut iter = range(0, 5).peekable();

    assert_eq(iter.peek(), Some(&0));
    assert_eq(iter.peek(), Some(&0));  // Doesn't consume
    assert_eq(iter.next(), Some(0));
    assert_eq(iter.peek(), Some(&1));
    assert_eq(iter.next(), Some(1));
}

/// Test peekable exhaustion
@test
fn test_peekable_exhaustion() {
    let mut iter = range(0, 2).peekable();

    assert_eq(iter.next(), Some(0));
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.peek(), None);
    assert_eq(iter.next(), None);
}

/// Test peek_mut allows mutation
@test
fn test_peekable_peek_mut() {
    let mut iter = range(0, 3).peekable();

    if let Some(x) = iter.peek_mut() {
        *x = 100;
    }

    assert_eq(iter.next(), Some(100));
    assert_eq(iter.next(), Some(1));
}

// =============================================================================
// Section 17: Transforming Adapters - dedup
// =============================================================================

/// Test dedup removes consecutive duplicates
@test
fn test_dedup_basic() {
    let iter = [1, 1, 2, 2, 2, 3, 1, 1].iter().map(|x| *x).dedup();
    let result: List<Int> = iter.collect();
    assert_eq(result, [1, 2, 3, 1]);
}

/// Test dedup on unique elements
@test
fn test_dedup_unique() {
    let iter = [1, 2, 3, 4, 5].iter().map(|x| *x).dedup();
    let result: List<Int> = iter.collect();
    assert_eq(result, [1, 2, 3, 4, 5]);
}

/// Test dedup all same
@test
fn test_dedup_all_same() {
    let iter = [5, 5, 5, 5, 5].iter().map(|x| *x).dedup();
    let result: List<Int> = iter.collect();
    assert_eq(result, [5]);
}

/// Test dedup empty
@test
fn test_dedup_empty() {
    let iter: List<Int> = [];
    let result: List<Int> = iter.iter().map(|x| *x).dedup().collect();
    assert_eq(result, []);
}

// =============================================================================
// Section 18: Transforming Adapters - interleave
// =============================================================================

/// Test interleave alternates elements
@test
fn test_interleave_basic() {
    let iter = range(0, 3).interleave(range(10, 13));
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 10, 1, 11, 2, 12]);
}

/// Test interleave unequal lengths
@test
fn test_interleave_unequal() {
    let iter = range(0, 5).interleave(range(10, 12));
    let result: List<Int> = iter.collect();
    // 0, 10, 1, 11, then a exhausted, continues with b
    assert_eq(result, [0, 10, 1, 11, 2, 3, 4]);
}

/// Test interleave with empty
@test
fn test_interleave_with_empty() {
    let iter = range(0, 3).interleave(range(0, 0));
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2]);
}

// =============================================================================
// Section 19: Transforming Adapters - step_by
// =============================================================================

/// Test step_by takes every nth element
@test
fn test_step_by_basic() {
    let iter = range(0, 10).step_by(2);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 2, 4, 6, 8]);
}

/// Test step_by with step 1 (no skipping)
@test
fn test_step_by_one() {
    let iter = range(0, 5).step_by(1);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 2, 3, 4]);
}

/// Test step_by with large step
@test
fn test_step_by_large() {
    let iter = range(0, 10).step_by(3);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 3, 6, 9]);
}

/// Test step_by larger than iterator
@test
fn test_step_by_larger_than_iter() {
    let iter = range(0, 5).step_by(10);
    let result: List<Int> = iter.collect();
    assert_eq(result, [0]);  // Only first element
}

// =============================================================================
// Section 20: Transforming Adapters - inspect
// =============================================================================

/// Test inspect allows side effects
@test
fn test_inspect_basic() {
    let mut seen: List<Int> = [];
    let result: List<Int> = range(0, 5)
        .inspect(|x| seen.push(*x))
        .map(|x| x * 2)
        .collect();

    assert_eq(seen, [0, 1, 2, 3, 4]);
    assert_eq(result, [0, 2, 4, 6, 8]);
}

/// Test inspect doesn't modify values
@test
fn test_inspect_no_modification() {
    let result: List<Int> = range(0, 3)
        .inspect(|_| {})  // No-op
        .collect();

    assert_eq(result, [0, 1, 2]);
}

// =============================================================================
// Section 21: Transforming Adapters - fuse
// =============================================================================

/// Test fuse ensures None forever after first None
@test
fn test_fuse_basic() {
    // Create an iterator that might return Some after None
    // (simulated with a custom implementation)
    let mut fused = range(0, 2).fuse();

    assert_eq(fused.next(), Some(0));
    assert_eq(fused.next(), Some(1));
    assert_eq(fused.next(), None);
    assert_eq(fused.next(), None);
    assert_eq(fused.next(), None);
}

// =============================================================================
// Section 22: Transforming Adapters - cycle
// =============================================================================

/// Test cycle repeats infinitely
@test
fn test_cycle_basic() {
    let iter = [1, 2, 3].iter().map(|x| *x).cycle().take(10);
    let result: List<Int> = iter.collect();
    assert_eq(result, [1, 2, 3, 1, 2, 3, 1, 2, 3, 1]);
}

/// Test cycle on single element
@test
fn test_cycle_single() {
    let iter = once(42).cycle().take(5);
    let result: List<Int> = iter.collect();
    assert_eq(result, [42, 42, 42, 42, 42]);
}

// =============================================================================
// Section 23: Folding Operations - fold
// =============================================================================

/// Test fold accumulates values
@test
fn test_fold_basic() {
    let sum = range(1, 6).fold(0, |acc, x| acc + x);
    assert_eq(sum, 15);  // 1+2+3+4+5
}

/// Test fold with string concatenation
@test
fn test_fold_string() {
    let result = ["a", "b", "c"].iter().fold("", |acc, x| f"{acc}{*x}");
    assert_eq(result, "abc");
}

/// Test fold on empty iterator
@test
fn test_fold_empty() {
    let result = range(0, 0).fold(100, |acc, x| acc + x);
    assert_eq(result, 100);  // Just initial value
}

/// Test fold order (left to right)
@test
fn test_fold_order() {
    let result = [1, 2, 3].iter().fold("", |acc, x| f"{acc}{*x}");
    assert_eq(result, "123");
}

// =============================================================================
// Section 24: Folding Operations - reduce
// =============================================================================

/// Test reduce without initial value
@test
fn test_reduce_basic() {
    let product = range(1, 6).reduce(|a, b| a * b);
    assert_eq(product, Some(120));  // 1*2*3*4*5
}

/// Test reduce on empty iterator
@test
fn test_reduce_empty() {
    let result = range(0, 0).reduce(|a, b| a + b);
    assert_eq(result, None);
}

/// Test reduce on single element
@test
fn test_reduce_single() {
    let result = once(42).reduce(|a, b| a + b);
    assert_eq(result, Some(42));
}

/// Test reduce finds max
@test
fn test_reduce_max() {
    let max_val = [3, 1, 4, 1, 5, 9].iter().map(|x| *x).reduce(|a, b| {
        if a > b { a } else { b }
    });
    assert_eq(max_val, Some(9));
}

// =============================================================================
// Section 25: Folding Operations - try_fold
// =============================================================================

/// Test try_fold succeeds
@test
fn test_try_fold_success() {
    let result = range(1, 5).try_fold(0, |acc, x| Ok(acc + x));
    assert_eq(result, Ok(10));
}

/// Test try_fold short circuits on error
@test
fn test_try_fold_error() {
    let result = range(0, 10).try_fold(0, |acc, x| {
        if x == 5 {
            Err("hit 5")
        } else {
            Ok(acc + x)
        }
    });
    assert_eq(result, Err("hit 5"));
}

/// Test try_fold empty iterator
@test
fn test_try_fold_empty() {
    let result = range(0, 0).try_fold(100, |acc, x| Ok(acc + x));
    assert_eq(result, Ok(100));
}

// =============================================================================
// Section 26: Folding Operations - scan
// =============================================================================

/// Test scan with running sum
@test
fn test_scan_running_sum() {
    let iter = [1, 2, 3, 4].iter().scan(0, |state, x| {
        *state = *state + **x;
        Some(*state)
    });
    let result: List<Int> = iter.collect();
    assert_eq(result, [1, 3, 6, 10]);
}

/// Test scan can terminate early
@test
fn test_scan_early_termination() {
    let iter = range(0, 100).scan(0, |state, x| {
        *state = *state + x;
        if *state > 10 {
            None
        } else {
            Some(*state)
        }
    });
    let result: List<Int> = iter.collect();
    assert_eq(result, [0, 1, 3, 6, 10]);  // Stops when sum > 10
}

// =============================================================================
// Section 27: Boolean Predicates - all
// =============================================================================

/// Test all returns true when all match
@test
fn test_all_true() {
    let result = range(0, 10).all(|x| *x < 100);
    assert(result);
}

/// Test all returns false when any doesn't match
@test
fn test_all_false() {
    let result = range(0, 10).all(|x| *x < 5);
    assert(!result);
}

/// Test all on empty iterator (vacuous truth)
@test
fn test_all_empty() {
    let result = range(0, 0).all(|_| false);
    assert(result);  // Vacuously true
}

/// Test all short circuits
@test
fn test_all_short_circuit() {
    let mut count = 0;
    let result = range(0, 100).all(|x| {
        count = count + 1;
        *x < 5
    });
    assert(!result);
    assert_eq(count, 6);  // Only checked 0-5, stopped at 5
}

