    assert(result);
}

/// Test any returns false when none match
@test
fn test_any_false() {
    let result = range(0, 10).any(|x| *x == 100);
    assert(!result);
}

/// Test any on empty iterator
@test
fn test_any_empty() {
    let result = range(0, 0).any(|_| true);
    assert(!result);
}

/// Test any short circuits
@test
fn test_any_short_circuit() {
    let mut count = 0;
    let result = range(0, 100).any(|x| {
        count = count + 1;
        *x == 5
    });
    assert(result);
    assert_eq(count, 6);  // Checked 0-5, stopped when found 5
}

