    assert_eq(result, [42]);
}

/// Test once then exhausted
@test
fn test_once_exhaustion() {
    let mut iter = once(42);
    assert_eq(iter.next(), Some(42));
    assert_eq(iter.next(), None);
    assert_eq(iter.next(), None);
}

/// Test once size hint
@test
