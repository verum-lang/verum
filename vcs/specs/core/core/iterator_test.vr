// Section 38: Side Effects - for_each
// =============================================================================

/// Test for_each executes on each element
@test
fn test_for_each_basic() {
    let mut sum = 0;
    range(1, 6).for_each(|x| {
        sum = sum + x;
    });
    assert_eq(sum, 15);
}

/// Test for_each on empty
@test
fn test_for_each_empty() {
    let mut count = 0;
    range(0, 0).for_each(|_| {
        count = count + 1;
    });
    assert_eq(count, 0);
}

// =============================================================================
// Section 39: DoubleEndedIterator Protocol
// =============================================================================

/// Test next_back returns from end
@test
fn test_next_back_basic() {
    let mut iter = range(0, 5);

    assert_eq(iter.next_back(), Some(4));
    assert_eq(iter.next_back(), Some(3));
    assert_eq(iter.next_back(), Some(2));
    assert_eq(iter.next_back(), Some(1));
    assert_eq(iter.next_back(), Some(0));
    assert_eq(iter.next_back(), None);
}

/// Test mixing next and next_back
@test
fn test_next_and_next_back_mixed() {
    let mut iter = range(0, 5);

    assert_eq(iter.next(), Some(0));
    assert_eq(iter.next_back(), Some(4));
    assert_eq(iter.next(), Some(1));
    assert_eq(iter.next_back(), Some(3));
    assert_eq(iter.next(), Some(2));
    assert_eq(iter.next(), None);
    assert_eq(iter.next_back(), None);
}

/// Test advance_back_by
@test
fn test_advance_back_by_basic() {
    let mut iter = range(0, 10);
    assert_eq(iter.advance_back_by(3), Ok(()));
    assert_eq(iter.next_back(), Some(6));
}

/// Test nth_back
@test
fn test_nth_back_basic() {
    let mut iter = range(0, 10);
    assert_eq(iter.nth_back(2), Some(7));  // Skip 9, 8, return 7
}

/// Test rfold folds from back
@test
fn test_rfold_basic() {
    let result = ["a", "b", "c"].iter().rfold("", |acc, x| f"{acc}{**x}");
    assert_eq(result, "cba");
}

/// Test rfind finds from back
@test
fn test_rfind_basic() {
    let mut iter = [1, 2, 3, 2, 1].iter();
    let result = iter.rfind(|x| **x == 2);
    assert(result.is_some());
    // Should find the second 2 (index 3)
}

