    assert_eq(result, []);
}

// =============================================================================
// Section 37: Collection Operations - partition
// =============================================================================

/// Test partition splits by predicate
@test
fn test_partition_basic() {
    let (evens, odds): (List<Int>, List<Int>) = range(0, 10).partition(|x| *x % 2 == 0);
    assert_eq(evens, [0, 2, 4, 6, 8]);
    assert_eq(odds, [1, 3, 5, 7, 9]);
}

/// Test partition all left
@test
fn test_partition_all_left() {
    let (left, right): (List<Int>, List<Int>) = range(0, 5).partition(|_| true);
    assert_eq(left, [0, 1, 2, 3, 4]);
    assert_eq(right, []);
}

/// Test partition all right
@test
fn test_partition_all_right() {
    let (left, right): (List<Int>, List<Int>) = range(0, 5).partition(|_| false);
    assert_eq(left, []);
    assert_eq(right, [0, 1, 2, 3, 4]);
}

