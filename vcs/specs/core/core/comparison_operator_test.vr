// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: comparison, operators, bool, ordering, protocol
// @description: Comprehensive tests for comparison operator type inference
//               Verifies that <, >, <=, >= return Bool (not Ordering)

module specs.stdlib.core.comparison_operator_test;

mount core.primitives.*;
mount core.maybe.{Maybe, Some, None};
mount core.result.{Result, Ok, Err};
mount core.collections.list.List;

// =============================================================================
// COMPARISON OPERATOR TYPE VERIFICATION
// =============================================================================
//
// This test suite verifies the fundamental distinction:
// - Comparison OPERATORS (<, >, <=, >=) return Bool
// - The cmp() METHOD returns Ordering
//
// Issue Reference: docs/audit.md Section 3.1
//
// These tests are designed to catch type inference regressions where
// comparison operators might incorrectly return Ordering instead of Bool.

// -----------------------------------------------------------------------------
// Section 1: Basic Int Comparison - Bool Return Type
// -----------------------------------------------------------------------------

@test
fn test_int_less_than_returns_bool() {
    let a: Int = 5;
    let b: Int = 10;

    // The result type MUST be Bool
    let result: Bool = a < b;
    assert(result);

    // Can be used directly in boolean context
    assert(a < b);
}

@test
fn test_int_greater_than_returns_bool() {
    let a: Int = 10;
    let b: Int = 5;

    let result: Bool = a > b;
    assert(result);

    assert(a > b);
}

@test
fn test_int_less_equal_returns_bool() {
    let a: Int = 5;
    let b: Int = 5;

    let result: Bool = a <= b;
    assert(result);

    // Also works with different values
    let result2: Bool = a <= 10;
    assert(result2);
}

@test
fn test_int_greater_equal_returns_bool() {
    let a: Int = 10;
    let b: Int = 10;

    let result: Bool = a >= b;
    assert(result);

    let result2: Bool = a >= 5;
    assert(result2);
}

// -----------------------------------------------------------------------------
// Section 2: Float Comparison - Bool Return Type
// -----------------------------------------------------------------------------

@test
fn test_float_comparison_returns_bool() {
    let a: Float = 3.14;
    let b: Float = 2.71;

    let lt: Bool = b < a;
    let gt: Bool = a > b;
    let le: Bool = a <= a;
    let ge: Bool = b >= b;

    assert(lt);
    assert(gt);
    assert(le);
    assert(ge);
}

// -----------------------------------------------------------------------------
// Section 3: Comparison with References - Auto-deref to Bool
// -----------------------------------------------------------------------------

@test
fn test_reference_comparison_returns_bool() {
    let a: Int = 5;
    let b: Int = 10;
    let ref_a: &Int = &a;
    let ref_b: &Int = &b;

    // Comparing references should auto-deref and return Bool
    let result: Bool = ref_a < ref_b;
    assert(result);

    // Mixed reference and value
    let result2: Bool = *ref_a < b;
    assert(result2);

    let result3: Bool = a < *ref_b;
    assert(result3);
}

// -----------------------------------------------------------------------------
// Section 4: Comparison in Expressions - Type Inference
// -----------------------------------------------------------------------------

@test
fn test_comparison_in_logical_and() {
    let x: Int = 5;

    // Comparison must return Bool to work with &&
    let result: Bool = x > 0 && x < 10;
    assert(result);
}

@test
fn test_comparison_in_logical_or() {
    let x: Int = 15;

    // Comparison must return Bool to work with ||
    let result: Bool = x < 0 || x > 10;
    assert(result);
}

@test
fn test_comparison_in_negation() {
    let x: Int = 5;

    // Comparison must return Bool to work with !
    let result: Bool = !(x > 10);
    assert(result);
}

@test
fn test_comparison_in_ternary_condition() {
    let x: Int = 5;

    // Comparison must return Bool to work as condition
    let result = if x < 10 { "small" } else { "large" };
    assert_eq(result, "small");
}

// -----------------------------------------------------------------------------
// Section 5: Chained Comparisons (via &&)
// -----------------------------------------------------------------------------

@test
fn test_chained_comparisons() {
    let x: Int = 5;

    // Range check: 0 < x < 10
    let in_range: Bool = 0 < x && x < 10;
    assert(in_range);

    // Bounds check: 0 <= x <= 10
    let in_bounds: Bool = 0 <= x && x <= 10;
    assert(in_bounds);
}

// -----------------------------------------------------------------------------
// Section 6: Comparison in Match Guards
// -----------------------------------------------------------------------------

@test
fn test_comparison_in_match_guard() {
    let x: Int = 5;

    let result = match x {
        n if n < 0 => "negative",
        n if n == 0 => "zero",
        n if n < 10 => "small positive",
        _ => "large positive",
    };

    assert_eq(result, "small positive");
}

// -----------------------------------------------------------------------------
// Section 7: Comparison in While/For Conditions
// -----------------------------------------------------------------------------

@test
fn test_comparison_in_while_condition() {
    let mut count = 0;
    let mut i = 0;

    // Comparison must return Bool for while condition
    while i < 5 {
        count = count + 1;
        i = i + 1;
    }

    assert_eq(count, 5);
}

@test
fn test_comparison_in_for_with_break() {
    let mut last = 0;

    for i in 0..10 {
        // Comparison must return Bool for if condition
        if i >= 5 {
            break;
        }
        last = i;
    }

    assert_eq(last, 4);
}

// -----------------------------------------------------------------------------
// Section 8: Generic Function with Comparison Constraint
// -----------------------------------------------------------------------------

fn min_value<T: Ord>(a: T, b: T) -> T {
    // Comparison returns Bool, allowing use in if condition
    if a <= b {
        a
    } else {
        b
    }
}

fn max_value<T: Ord>(a: T, b: T) -> T {
    if a >= b {
        a
    } else {
        b
    }
}

@test
fn test_generic_comparison_returns_bool() {
    assert_eq(min_value(5, 3), 3);
    assert_eq(min_value(2, 8), 2);
    assert_eq(max_value(5, 3), 5);
    assert_eq(max_value(2, 8), 8);
}

// -----------------------------------------------------------------------------
// Section 9: Comparison Result as Function Return
// -----------------------------------------------------------------------------

fn is_positive(x: Int) -> Bool {
    // Directly return comparison result (must be Bool)
    x > 0
}

fn is_in_range(x: Int, min: Int, max: Int) -> Bool {
    x >= min && x <= max
}

@test
fn test_comparison_as_return_value() {
    assert(is_positive(5));
    assert(!is_positive(-5));
    assert(!is_positive(0));

    assert(is_in_range(5, 0, 10));
    assert(!is_in_range(15, 0, 10));
    assert(is_in_range(0, 0, 10));
    assert(is_in_range(10, 0, 10));
}

// -----------------------------------------------------------------------------
// Section 10: Comparison vs cmp() Method - Type Distinction
// -----------------------------------------------------------------------------
// NOTE: The cmp() method returns Ordering, while operators return Bool.
// These are fundamentally different:
// - a < b  : Bool (true or false)
// - a.cmp(b) : Ordering (Less, Equal, or Greater)

@test
fn test_operator_vs_method_distinction() {
    let a: Int = 5;
    let b: Int = 10;

    // Operator returns Bool
    let lt_result: Bool = a < b;
    assert(lt_result);

    // cmp() returns Ordering - used differently
    // (This is valid Verum when Ordering is in scope)
    // let cmp_result: Ordering = a.cmp(b);
    // assert(cmp_result is Less);

    // Key distinction: you CANNOT do this (type mismatch):
    // let wrong: Ordering = a < b;  // ERROR: expected Ordering, got Bool

    // And you CANNOT do this (type mismatch):
    // let wrong2: Bool = a.cmp(b);  // ERROR: expected Bool, got Ordering
}

// -----------------------------------------------------------------------------
// Section 11: Comparison in Closure
// -----------------------------------------------------------------------------

@test
fn test_comparison_in_closure() {
    let list = List.from([5, 2, 8, 1, 9, 3]);

    // Use comparison operators in a simple filter closure
    // Filter returns Bool, so comparison must return Bool
    let mut count = 0;
    for x in list.iter() {
        if *x > 4 {  // comparison operator returns Bool
            count = count + 1;
        }
    }

    assert_eq(count, 3);  // 5, 8, 9
}

// -----------------------------------------------------------------------------
// Section 12: Comparison with Literals
// -----------------------------------------------------------------------------

@test
fn test_comparison_with_literals() {
    let x = 42;

    // All these must return Bool
    let a: Bool = x > 0;
    let b: Bool = x < 100;
    let c: Bool = x >= 42;
    let d: Bool = x <= 42;

    assert(a && b && c && d);
}

// -----------------------------------------------------------------------------
// Section 13: Comparison in Assert
// -----------------------------------------------------------------------------

@test
fn test_comparison_in_assert() {
    let x = 5;
    let y = 10;

    // assert() takes Bool, so comparison must return Bool
    assert(x < y);
    assert(y > x);
    assert(x <= 5);
    assert(y >= 10);
}

// -----------------------------------------------------------------------------
// Section 14: Equality Operators Also Return Bool
// -----------------------------------------------------------------------------

@test
fn test_equality_returns_bool() {
    let a = 5;
    let b = 5;
    let c = 10;

    let eq_result: Bool = a == b;
    let ne_result: Bool = a != c;

    assert(eq_result);
    assert(ne_result);

    // In expressions
    assert(a == b && a != c);
}

// -----------------------------------------------------------------------------
// Section 15: Text/String Comparison Returns Bool
// -----------------------------------------------------------------------------

@test
fn test_text_comparison_returns_bool() {
    let a: Text = "apple";
    let b: Text = "banana";

    let lt: Bool = a < b;
    let gt: Bool = b > a;
    let le: Bool = a <= a;
    let ge: Bool = b >= b;
    let eq: Bool = a == a;
    let ne: Bool = a != b;

    assert(lt);
    assert(gt);
    assert(le);
    assert(ge);
    assert(eq);
    assert(ne);
}

// -----------------------------------------------------------------------------
// Section 16: Char Comparison Returns Bool
// -----------------------------------------------------------------------------

@test
fn test_char_comparison_returns_bool() {
    let a: Char = 'a';
    let z: Char = 'z';

    let lt: Bool = a < z;
    let gt: Bool = z > a;
    let le: Bool = a <= a;
    let ge: Bool = z >= z;

    assert(lt);
    assert(gt);
    assert(le);
    assert(ge);
}

// -----------------------------------------------------------------------------
// Section 17: Array Element Comparison
// -----------------------------------------------------------------------------

@test
fn test_array_element_comparison_returns_bool() {
    let arr = [1, 5, 3, 8, 2];

    // Comparing array elements returns Bool
    let first_less: Bool = arr[0] < arr[1];
    let last_greater: Bool = arr[3] > arr[4];

    assert(first_less);
    assert(last_greater);

    // In loop condition
    let mut inversions = 0;
    for i in 0..4 {
        if arr[i] > arr[i + 1] {
            inversions = inversions + 1;
        }
    }
    // 5 > 3, 8 > 2 = 2 inversions
    assert_eq(inversions, 2);
}

// -----------------------------------------------------------------------------
// Section 18: Tuple Element Comparison (if supported)
// -----------------------------------------------------------------------------

@test
fn test_tuple_element_comparison_returns_bool() {
    let t1: (Int, Int) = (1, 2);
    let t2: (Int, Int) = (3, 4);

    // Comparing tuple elements returns Bool
    let first_less: Bool = t1.0 < t2.0;
    let second_less: Bool = t1.1 < t2.1;

    assert(first_less);
    assert(second_less);
}

// -----------------------------------------------------------------------------
// Section 19: Record Field Comparison
// -----------------------------------------------------------------------------

type Point is { x: Int, y: Int };

@test
fn test_record_field_comparison_returns_bool() {
    let p1 = Point { x: 1, y: 2 };
    let p2 = Point { x: 3, y: 4 };

    // Comparing record fields returns Bool
    let x_less: Bool = p1.x < p2.x;
    let y_less: Bool = p1.y < p2.y;

    assert(x_less);
    assert(y_less);
}

// -----------------------------------------------------------------------------
// Section 20: Complex Expression with Multiple Comparisons
// -----------------------------------------------------------------------------

@test
fn test_complex_comparison_expression() {
    let a = 5;
    let b = 10;
    let c = 15;

    // All intermediate comparisons return Bool, final result is Bool
    let complex: Bool = (a < b && b < c) || (a > c) || (b == 10);
    assert(complex);

    // Nested
    let nested: Bool = if a < b { b < c } else { false };
    assert(nested);
}

// -----------------------------------------------------------------------------
// Section 21: Zero and Boundary Comparisons
// -----------------------------------------------------------------------------

@test
fn test_zero_comparisons() {
    let zero = 0;
    // 0 < 0 is false
    let lt: Bool = zero < zero;
    assert(!lt);
    // 0 <= 0 is true
    let le: Bool = zero <= zero;
    assert(le);
    // 0 > 0 is false
    let gt: Bool = zero > zero;
    assert(!gt);
    // 0 >= 0 is true
    let ge: Bool = zero >= zero;
    assert(ge);
}

@test
fn test_negative_float_comparisons() {
    let neg1: Float = -1.5;
    let neg2: Float = -2.5;
    let zero: Float = 0.0;

    let a: Bool = neg2 < neg1;
    let b: Bool = neg1 < zero;
    let c: Bool = neg2 < zero;

    assert(a);
    assert(b);
    assert(c);
}

@test
fn test_comparison_with_unary_negation() {
    let x: Int = 5;
    let neg_x: Int = -5;

    let result: Bool = neg_x < x;
    assert(result);

    let result2: Bool = neg_x < 0;
    assert(result2);

    let result3: Bool = x > 0;
    assert(result3);
}

@test
fn test_comparison_in_nested_if_else() {
    let x = 50;
    let category = if x < 0 {
        "negative"
    } else if x < 10 {
        "small"
    } else if x < 100 {
        "medium"
    } else {
        "large"
    };
    assert_eq(category, "medium");
}

@test
fn test_comparison_idempotent() {
    let a = 3;
    let b = 7;
    // Same comparison evaluated multiple times gives same result
    let r1: Bool = a < b;
    let r2: Bool = a < b;
    let r3: Bool = a < b;
    assert(r1 == r2);
    assert(r2 == r3);
}

@test
fn test_generic_min_max_with_float() {
    let min_val: Float = min_value(3.14, 2.71);
    let max_val: Float = max_value(3.14, 2.71);
    // min should be approximately 2.71
    assert(min_val < 3.0);
    // max should be approximately 3.14
    assert(max_val > 3.0);
}

@test
fn test_all_four_operators_same_values() {
    let x = 42;
    let y = 42;

    let lt: Bool = x < y;
    let gt: Bool = x > y;
    let le: Bool = x <= y;
    let ge: Bool = x >= y;

    assert(!lt);
    assert(!gt);
    assert(le);
    assert(ge);
}

@test
fn test_comparison_result_assignment_chain() {
    let a = 1;
    let b = 2;
    let c = 3;

    let ab: Bool = a < b;
    let bc: Bool = b < c;
    let both: Bool = ab && bc;
    assert(both);

    let neither: Bool = a > b || b > c;
    assert(!neither);
}

@test
fn test_comparison_negative_integers() {
    let a: Int = -10;
    let b: Int = -5;
    let c: Int = 0;

    let result1: Bool = a < b;
    let result2: Bool = b < c;
    let result3: Bool = a < c;

    assert(result1);
    assert(result2);
    assert(result3);
}

@test
fn test_comparison_bool_in_list_context() {
    let values = [1, 5, 3, 8, 2, 7];
    let mut count_gt_4 = 0;
    let mut count_le_4 = 0;
    for v in values.iter() {
        if *v > 4 {
            count_gt_4 = count_gt_4 + 1;
        }
        if *v <= 4 {
            count_le_4 = count_le_4 + 1;
        }
    }
    assert_eq(count_gt_4, 3);  // 5, 8, 7
    assert_eq(count_le_4, 3);  // 1, 3, 2
}

// -----------------------------------------------------------------------------
// Section 22: Antisymmetry of Strict Inequality
// -----------------------------------------------------------------------------

@test
fn test_strict_inequality_antisymmetric() {
    let a = 3;
    let b = 7;
    // If a < b, then !(b < a)
    assert(a < b);
    assert(!(b < a));
    // If a > b doesn't hold, then b >= a
    assert(!(a > b));
    assert(b > a);
}

// -----------------------------------------------------------------------------
// Section 23: Trichotomy
// -----------------------------------------------------------------------------

@test
fn test_trichotomy_less() {
    let a = 2;
    let b = 5;
    // Exactly one of: a < b, a == b, a > b
    let lt: Bool = a < b;
    let eq: Bool = a == b;
    let gt: Bool = a > b;
    assert(lt && !eq && !gt);
}

@test
fn test_trichotomy_equal() {
    let a = 5;
    let b = 5;
    let lt: Bool = a < b;
    let eq: Bool = a == b;
    let gt: Bool = a > b;
    assert(!lt && eq && !gt);
}

@test
fn test_trichotomy_greater() {
    let a = 8;
    let b = 3;
    let lt: Bool = a < b;
    let eq: Bool = a == b;
    let gt: Bool = a > b;
    assert(!lt && !eq && gt);
}

// -----------------------------------------------------------------------------
// Section 24: Comparison Does Not Mutate
// -----------------------------------------------------------------------------

@test
fn test_comparison_does_not_mutate() {
    let mut x = 10;
    let mut y = 20;
    let _ = x < y;
    let _ = x > y;
    let _ = x <= y;
    let _ = x >= y;
    let _ = x == y;
    let _ = x != y;
    // Values unchanged after comparisons
    assert_eq(x, 10);
    assert_eq(y, 20);
}

// -----------------------------------------------------------------------------
// Section 25: Double Negation
// -----------------------------------------------------------------------------

@test
fn test_double_negation_comparison() {
    let a = 3;
    let b = 7;
    // !!( a < b ) == (a < b)
    let result: Bool = !!(a < b);
    assert(result);
    let result2: Bool = !!(a > b);
    assert(!result2);
}

// -----------------------------------------------------------------------------
// Section 26: Comparison with Arithmetic
// -----------------------------------------------------------------------------

@test
fn test_comparison_with_arithmetic() {
    let x = 5;
    let y = 3;
    // Compare arithmetic results
    let sum_less: Bool = (x + y) < 100;
    let prod_gt: Bool = (x * y) > 10;
    let diff_ge: Bool = (x - y) >= 2;
    assert(sum_less);
    assert(prod_gt);
    assert(diff_ge);
}

@test
fn test_comparison_transitive_chain() {
    let a = 1;
    let b = 5;
    let c = 10;
    let d = 20;
    // a < b < c < d (transitivity)
    assert(a < b && b < c && c < d);
    assert(a < d);  // transitive conclusion
}

// -----------------------------------------------------------------------------
// Section 27: Comparison with Negation
// -----------------------------------------------------------------------------

@test
fn test_not_less_equals_ge() {
    let a = 5;
    let b = 3;
    // !(a < b) should be equivalent to a >= b
    let not_lt: Bool = !(a < b);
    let ge: Bool = a >= b;
    assert_eq(not_lt, ge);
}

@test
fn test_not_greater_equals_le() {
    let a = 3;
    let b = 5;
    let not_gt: Bool = !(a > b);
    let le: Bool = a <= b;
    assert_eq(not_gt, le);
}

// -----------------------------------------------------------------------------
// Section 28: Comparison in Function Return
// -----------------------------------------------------------------------------

@test
fn test_comparison_as_function_return() {
    fn is_positive(x: Int) -> Bool { x > 0 }
    fn is_negative(x: Int) -> Bool { x < 0 }
    fn is_non_negative(x: Int) -> Bool { x >= 0 }
    fn is_non_positive(x: Int) -> Bool { x <= 0 }

    assert(is_positive(5));
    assert(!is_positive(-3));
    assert(is_negative(-1));
    assert(!is_negative(0));
    assert(is_non_negative(0));
    assert(is_non_positive(0));
}

// -----------------------------------------------------------------------------
// Section 29: Float Comparison
// -----------------------------------------------------------------------------

@test
fn test_float_comparison_returns_bool() {
    let a: Float = 1.5;
    let b: Float = 2.5;
    let lt: Bool = a < b;
    let gt: Bool = b > a;
    let le: Bool = a <= a;
    let ge: Bool = b >= b;
    assert(lt);
    assert(gt);
    assert(le);
    assert(ge);
}

@test
fn test_float_equality_returns_bool() {
    let a: Float = 3.14;
    let b: Float = 3.14;
    let c: Float = 2.71;
    let eq: Bool = a == b;
    let ne: Bool = a != c;
    assert(eq);
    assert(ne);
}

// -----------------------------------------------------------------------------
// Section 30: Mixed Comparison Chains
// -----------------------------------------------------------------------------

@test
fn test_comparison_short_circuit_and() {
    let x = 5;
    // Short-circuit: first condition is false so second not needed
    let result: Bool = (x > 10) && (x < 0);
    assert(!result);
}

@test
fn test_comparison_short_circuit_or() {
    let x = 5;
    // Short-circuit: first condition is true so second not needed
    let result: Bool = (x > 0) || (x < -100);
    assert(result);
}

@test
fn test_min_max_via_comparison() {
    fn my_min(a: Int, b: Int) -> Int {
        if a < b { a } else { b }
    }
    fn my_max(a: Int, b: Int) -> Int {
        if a > b { a } else { b }
    }
    assert_eq(my_min(3, 7), 3);
    assert_eq(my_max(3, 7), 7);
    assert_eq(my_min(5, 5), 5);
    assert_eq(my_max(5, 5), 5);
}

// -----------------------------------------------------------------------------
// Section 31: Byte Comparison Returns Bool
// -----------------------------------------------------------------------------

@test
fn test_byte_comparison_returns_bool() {
    let a: Byte = 10 as Byte;
    let b: Byte = 20 as Byte;

    let lt: Bool = a < b;
    let gt: Bool = b > a;
    let le: Bool = a <= a;
    let ge: Bool = b >= b;
    let eq: Bool = a == a;
    let ne: Bool = a != b;

    assert(lt);
    assert(gt);
    assert(le);
    assert(ge);
    assert(eq);
    assert(ne);
}

// -----------------------------------------------------------------------------
// Section 32: Comparison with Maximum and Minimum Bounds
// -----------------------------------------------------------------------------

@test
fn test_comparison_with_int_bounds() {
    let max_int: Int = Int.MAX;
    let min_int: Int = Int.MIN;
    let zero: Int = 0;

    // Compare with bounds
    let max_gt_zero: Bool = max_int > zero;
    let min_lt_zero: Bool = min_int < zero;
    let max_ge_max: Bool = max_int >= max_int;
    let min_le_min: Bool = min_int <= min_int;

    assert(max_gt_zero);
    assert(min_lt_zero);
    assert(max_ge_max);
    assert(min_le_min);

    // Transitivity with bounds
    assert(min_int < zero && zero < max_int);
}

// -----------------------------------------------------------------------------
// Section 33: Comparison Result Storage in Tuple
// -----------------------------------------------------------------------------

@test
fn test_comparison_results_in_tuple() {
    let x = 5;
    let y = 10;

    // Store multiple comparison results in tuple
    let results: (Bool, Bool, Bool, Bool) = (x < y, x > y, x <= y, x >= y);

    assert(results.0);  // x < y is true
    assert(!results.1); // x > y is false
    assert(results.2);  // x <= y is true
    assert(!results.3); // x >= y is false
}

// -----------------------------------------------------------------------------
// Section 34: Comparison Consistency with Arithmetic
// -----------------------------------------------------------------------------

@test
fn test_comparison_respects_arithmetic_order() {
    let a = 10;
    let b = 5;

    // a + 0 == a, comparison should be equal
    assert(!((a + 0) < a));
    assert(!((a + 0) > a));
    assert((a + 0) <= a);
    assert((a + 0) >= a);

    // a + positive > a
    assert((a + 1) > a);
    assert(!((a + 1) < a));

    // a - positive < a
    assert((a - 1) < a);
    assert(!((a - 1) > a));
}

// -----------------------------------------------------------------------------
// Section 35: Comparison of Computed Values
// -----------------------------------------------------------------------------

@test
fn test_comparison_of_computed_values() {
    let x = 12;
    let y = 8;

    // Compare results of computations
    let sum_lt_product: Bool = (x + y) < (x * y);
    let diff_gt_zero: Bool = (x - y) > 0;
    let quotient_eq_one: Bool = (x / y) == 1;

    assert(sum_lt_product);  // 20 < 96
    assert(diff_gt_zero);    // 4 > 0
    assert(quotient_eq_one); // 12 / 8 == 1 (integer division)
}

// -----------------------------------------------------------------------------
// Section 36: Multiple Comparison Operators in Single Expression
// -----------------------------------------------------------------------------

@test
fn test_multiple_operators_single_expression() {
    let a = 5;
    let b = 10;
    let c = 15;
    let d = 10;

    // Combine different comparison operators
    let complex1: Bool = (a < b) && (b <= d) && (c > b) && (a != b);
    let complex2: Bool = (a >= a) || (b < a);
    let complex3: Bool = (a < b) && (b == d) && (c > a);

    assert(complex1);
    assert(complex2);
    assert(complex3);
}

// -----------------------------------------------------------------------------
// Section 37: Comparison Symmetry Properties
// -----------------------------------------------------------------------------

@test
fn test_comparison_symmetry() {
    let x = 7;
    let y = 7;

    // For equal values, <= and >= both true
    assert(x <= y);
    assert(y <= x);
    assert(x >= y);
    assert(y >= x);

    // For equal values, < and > both false
    assert(!(x < y));
    assert(!(y < x));
    assert(!(x > y));
    assert(!(y > x));
}

// -----------------------------------------------------------------------------
// Section 38: Comparison in Conditional Assignment
// -----------------------------------------------------------------------------

@test
fn test_comparison_in_conditional_assignment() {
    let score = 85;

    // Use comparison in conditional assignment
    let grade = if score >= 90 {
        "A"
    } else if score >= 80 {
        "B"
    } else if score >= 70 {
        "C"
    } else if score >= 60 {
        "D"
    } else {
        "F"
    };

    assert_eq(grade, "B");

    // Boolean result can be assigned based on comparison
    let passed: Bool = score >= 60;
    let honors: Bool = score >= 90;

    assert(passed);
    assert(!honors);
}
