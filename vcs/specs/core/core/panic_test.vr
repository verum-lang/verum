// =============================================================================
// Section 22: Location Edge Cases
// =============================================================================

@test
fn test_location_negative_line() {
    // Negative line numbers are technically allowed
    let loc = Location.new("test.vr", -1, 0);
    assert_eq(loc.line, -1);
}

@test
fn test_location_zero_values() {
    let loc = Location.new("", 0, 0);
    assert_eq(loc.file.len(), 0);
    assert_eq(loc.line, 0);
    assert_eq(loc.column, 0);
}

@test
fn test_location_large_values() {
    let loc = Location.new("very/long/path/to/file.vr", 999999, 500);
    assert_eq(loc.line, 999999);
    assert_eq(loc.column, 500);
}

// =============================================================================
// Section 23: PanicInfo Variations
// =============================================================================

@test
fn test_panic_info_empty_message() {
    let info = PanicInfo {
        message: "",
        location: None,
    };

    assert_eq(info.message().len(), 0);
}

@test
fn test_panic_info_long_message() {
    let long_msg = "x".repeat(1000);
    let info = PanicInfo {
        message: long_msg.clone(),
        location: None,
    };

    assert_eq(info.message().len(), 1000);
}

@test
fn test_panic_info_unicode_message() {
    let info = PanicInfo {
        message: "Ошибка: что-то пошло не так 🔥",
        location: None,
    };

    assert(info.message().contains("Ошибка"));
}

