// =============================================================================
// Section 16: CatchResult Type Tests
// =============================================================================

@test
fn test_catch_result_type() {
    // CatchResult<T> is Result<T, PanicInfo>
    let success: CatchResult<Int> = Ok(42);
    let failure: CatchResult<Int> = Err(PanicInfo {
        message: "caught panic",
        location: None,
    });

    match success {
        Ok(v) => assert_eq(v, 42),
        Err(_) => panic("expected Ok"),
    }

    match failure {
        Ok(_) => panic("expected Err"),
        Err(info) => assert_eq(info.message, "caught panic"),
    }
}

