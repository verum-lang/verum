@test
fn test_debug_assert_in_debug() {
    // In debug builds, should check condition
    debug_assert(!false);
    debug_assert(1 == 1);
}

@test
fn test_debug_assert_with_message() {
    debug_assert(true, "debug check");
}

@test
fn test_debug_assert_eq() {
    debug_assert_eq(5, 5);
    debug_assert_eq(5, 5, "values should match");
}

@test
fn test_debug_assert_ne() {
    debug_assert_ne(1, 2);
    debug_assert_ne(1, 2, "values should differ");
}

