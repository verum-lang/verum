@test
fn test_assert_eq_boundary_integers() {
    assert_eq(Int.MAX, Int.MAX);
    assert_eq(Int.MIN, Int.MIN);
    assert_ne(Int.MAX, Int.MIN);
}

@test
fn test_assert_eq_special_floats() {
    assert_eq(Float.INFINITY, Float.INFINITY);
    assert_eq(Float.NEG_INFINITY, Float.NEG_INFINITY);
    assert_ne(Float.INFINITY, Float.NEG_INFINITY);
}

@test
fn test_assert_empty_collections() {
    let empty1: List<Int> = [];
    let empty2: List<Int> = [];
    assert_eq(empty1, empty2);
}

// =============================================================================
// Section 25: Chained Assertions
// =============================================================================

@test
fn test_multiple_assertions() {
    let x = 10;

    assert(x > 0);
    assert(x < 100);
    assert_eq(x, 10);
    assert_ne(x, 0);
}

@test
fn test_assert_result_chain() {
    fn get_value() -> Result<Int, Text> {
        Ok(42)
    }

    let value = assert_ok(get_value());
    assert_eq(value, 42);
    assert(value > 0);
}

@test
fn test_assert_maybe_chain() {
    fn find_item() -> Maybe<Text> {
        Some("found")
    }

    let item = assert_some(find_item());
    assert_eq(item, "found");
    assert(item.len() > 0);
}

// =============================================================================
// Section 26: Debug Assert Optimization
// =============================================================================

@test
fn test_debug_assert_no_side_effects() {
    // In release builds, debug_assert should not evaluate
    let mut counter = 0;

    debug_assert({
        counter = counter + 1;
        true
    });

    // In debug builds counter is 1, in release it's 0
    // Either is acceptable
}

// =============================================================================
// Section 27: Panic Hook Integration
// =============================================================================

@test
fn test_panic_hook_receives_info() {
    // Custom hook can inspect PanicInfo
    fn inspecting_hook(info: &PanicInfo) {
        let _msg = info.message();
        let _loc = info.location();
    }

    let _: PanicHook = inspecting_hook;
}

@test
fn test_panic_hook_location_access() {
    fn location_hook(info: &PanicInfo) {
        match info.location() {
            Some(loc) => {
                let _f = &loc.file;
                let _l = loc.line;
                let _c = loc.column;
            }
            None => {}
        }
    }

    let _: PanicHook = location_hook;
}

// =============================================================================
// Section 28: CatchResult Patterns
// =============================================================================

@test
fn test_catch_result_ok_pattern() {
    let result: CatchResult<Int> = Ok(100);

    let value = match result {
        Ok(v) => v,
        Err(_) => 0,
    };

    assert_eq(value, 100);
}

@test
fn test_catch_result_err_pattern() {
    let info = PanicInfo {
        message: "test panic",
        location: None,
    };
    let result: CatchResult<Int> = Err(info);

    let msg = match result {
        Ok(_) => "no panic",
        Err(info) => info.message,
    };

    assert_eq(msg, "test panic");
}

@test
fn test_catch_result_with_complex_type() {
    type ComplexResult is { data: List<Int>, success: Bool };

    let result: CatchResult<ComplexResult> = Ok(ComplexResult {
        data: [1, 2, 3],
        success: true,
    });

    match result {
        Ok(r) => {
            assert_eq(r.data.len(), 3);
            assert(r.success);
        }
        Err(_) => panic("expected Ok"),
    }
}

