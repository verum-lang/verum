@test
fn test_assert_some_type_inference() {
    let maybe = Some(42); // Type inferred as Maybe<Int>
    let value = assert_some(maybe);
    let _: Int = value; // Verify inferred type
}

@test
fn test_assert_ok_type_inference() {
    let result: Result<Int, Text> = Ok(42);
    let value = assert_ok(result);
    let _: Int = value;
}

@test
fn test_assert_err_type_inference() {
    let result: Result<Int, Text> = Err("error");
    let error = assert_err(result);
    let _: Text = error;
}

// =============================================================================
// Section 30: Integration Patterns
// =============================================================================

@test
fn test_assert_in_helper_function() {
    fn validate_positive(n: Int) {
        assert(n > 0, "number must be positive");
    }

    validate_positive(1);
    validate_positive(100);
}

@test
fn test_assert_eq_in_helper() {
    fn check_expected(actual: Int, expected: Int) {
        assert_eq(actual, expected, "value mismatch");
    }

    check_expected(10, 10);
    check_expected(0, 0);
}

@test
fn test_assert_combination() {
    fn validate_result(result: Result<Int, Text>) -> Int {
        let value = assert_ok(result, "expected success");
        assert(value >= 0, "value must be non-negative");
        value
    }

    let v = validate_result(Ok(42));
    assert_eq(v, 42);
}
