// Section 9: Assert Ok/Err Tests
// =============================================================================

@test
fn test_assert_ok_returns_value() {
    let result: Result<Int, Text> = Ok(100);
    let value = assert_ok(result);
    assert_eq(value, 100);
}

@test
fn test_assert_ok_with_message() {
    let result: Result<Text, Int> = Ok("success");
    let value = assert_ok(result, "operation should succeed");
    assert_eq(value, "success");
}

@test
fn test_assert_err_returns_error() {
    let result: Result<Int, Text> = Err("error message");
    let error = assert_err(result);
    assert_eq(error, "error message");
}

@test
fn test_assert_err_with_message() {
    let result: Result<Text, Int> = Err(404);
    let error = assert_err(result, "should be error");
    assert_eq(error, 404);
}

