// =============================================================================
// panic_test.vr - Comprehensive tests for core/panic.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: panic, assert, control-flow, debugging
// @timeout: 30000
// @description: Comprehensive tests for core/panic.vr
// =============================================================================
//
// Tests for panic, assert, and control flow functions:
// - Assert functions
// - Unreachable markers
// - Debug output
// - Panic info and location types
// - Panic hooks
// - Catch/resume unwind
// - Source location macros
//
// Note: Actual panic/exit tests would terminate the process, so we test
// the type signatures and non-terminating functionality.
//
// =============================================================================

module panic_test;

// Import from core.base.panic directly for full access
mount core.base.panic.{
    panic, panic_at, panic_fmt, abort, exit,
    assert, assert_eq, assert_ne, assert_some, assert_none, assert_ok, assert_err,
    debug_assert, debug_assert_eq, debug_assert_ne,
    unreachable, unreachable_unchecked, unimplemented, todo,
    debug_print, dbg,
    PanicInfo, Location, PanicHook, default_panic_hook,
    catch_unwind, resume_unwind, CatchResult,
    file, line, column, current_location,
};
mount core.{Maybe, Result, Text};
mount core.base.{Debug, Formatter, FormatError};

// =============================================================================
// Section 1: Location Type Tests
// =============================================================================

@test
fn test_location_construction() {
    let loc = Location.new("test.vr", 42, 10);

    assert_eq(loc.file, "test.vr");
    assert_eq(loc.line, 42);
    assert_eq(loc.column, 10);
}

@test
fn test_location_new_with_empty_file() {
    let loc = Location.new("", 0, 0);

    assert_eq(loc.file, "");
    assert_eq(loc.line, 0);
    assert_eq(loc.column, 0);
}

@test
fn test_location_new_with_path() {
    let loc = Location.new("src/core/panic.vr", 100, 5);

    assert_eq(loc.file, "src/core/panic.vr");
    assert_eq(loc.line, 100);
    assert_eq(loc.column, 5);
}

@test
fn test_location_fields_accessible() {
    let loc = Location {
        file: "module.vr",
        line: 55,
        column: 3,
    };

    let _f: Text = loc.file;
    let _l: Int = loc.line;
    let _c: Int = loc.column;
}

// =============================================================================
// Section 2: Location Debug Implementation
// =============================================================================

@test
fn test_location_debug_format() {
    let loc = Location.new("test.vr", 42, 10);

    let mut buffer = Text.new();
    {
        let mut formatter = Formatter.new(&mut buffer);
        let result = loc.fmt_debug(&mut formatter);
        assert(result.is_ok());
    }

    // Debug format should include file:line:column
    assert(buffer.contains("test.vr"));
    assert(buffer.contains("42"));
    assert(buffer.contains("10"));
}

@test
fn test_location_display_format() {
    let loc = Location.new("main.vr", 1, 1);

    let mut buffer = Text.new();
    {
        let mut formatter = Formatter.new(&mut buffer);
        let result = loc.fmt(&mut formatter);
        assert(result.is_ok());
    }

    // Display format should be readable
    assert(buffer.contains("main.vr"));
}

// =============================================================================
// Section 3: PanicInfo Type Tests
// =============================================================================

@test
fn test_panic_info_with_location() {
    let loc = Location.new("error.vr", 99, 5);
    let info = PanicInfo {
        message: "something went wrong",
        location: Some(loc),
    };

    assert_eq(info.message(), &"something went wrong");
    assert(info.location().is_some());
}

@test
fn test_panic_info_without_location() {
    let info = PanicInfo {
        message: "panic without location",
        location: None,
    };

    assert_eq(info.message(), &"panic without location");
    assert(info.location().is_none());
}

@test
fn test_panic_info_message_accessor() {
    let info = PanicInfo {
        message: "test message",
        location: None,
    };

    let msg: &Text = info.message();
    assert_eq(*msg, "test message");
}

@test
fn test_panic_info_location_accessor() {
    let loc = Location.new("file.vr", 10, 20);
    let info = PanicInfo {
        message: "test",
        location: Some(loc),
    };

    let loc_ref = info.location();
    match loc_ref {
        Some(l) => {
            assert_eq(l.line, 10);
            assert_eq(l.column, 20);
        }
        None => panic("expected Some location"),
    }
}

// =============================================================================
// Section 4: PanicInfo Debug Implementation
// =============================================================================

@test
fn test_panic_info_debug_with_location() {
    let loc = Location.new("crash.vr", 50, 8);
    let info = PanicInfo {
        message: "crash reason",
        location: Some(loc),
    };

    let mut buffer = Text.new();
    {
        let mut formatter = Formatter.new(&mut buffer);
        let result = info.fmt_debug(&mut formatter);
        assert(result.is_ok());
    }

    assert(buffer.contains("PanicInfo"));
    assert(buffer.contains("crash reason"));
    assert(buffer.contains("crash.vr"));
}

@test
fn test_panic_info_debug_without_location() {
    let info = PanicInfo {
        message: "no location",
        location: None,
    };

    let mut buffer = Text.new();
    {
        let mut formatter = Formatter.new(&mut buffer);
        let result = info.fmt_debug(&mut formatter);
        assert(result.is_ok());
    }

    assert(buffer.contains("PanicInfo"));
    assert(buffer.contains("no location"));
}

// =============================================================================
// Section 5: Assert Function Tests
// =============================================================================

@test
fn test_assert_true_passes() {
    // True condition should not panic
    assert(1 == 1);
    assert(1 == 1, "this should pass");
}

@test
fn test_assert_with_message() {
    assert(1 == 1, "one equals one");
    assert(2 > 1, "two is greater than one");
}

@test
fn test_assert_complex_condition() {
    let x = 5;
    let y = 10;

    assert(x < y);
    assert(x + y == 15);
    assert(x * 2 == y);
}

// =============================================================================
// Section 6: Assert Equality Tests
// =============================================================================

@test
fn test_assert_eq_integers() {
    assert_eq(5, 5);
    assert_eq(0, 0);
    assert_eq(-1, -1);
    assert_eq(Int.MAX, Int.MAX);
    assert_eq(Int.MIN, Int.MIN);
}

@test
fn test_assert_eq_floats() {
    assert_eq(3.14, 3.14);
    assert_eq(0.0, 0.0);
    assert_eq(-2.5, -2.5);
}

@test
fn test_assert_eq_bools() {
    assert_eq(true, true);
    assert_eq(false, false);
}

@test
fn test_assert_eq_with_message() {
    assert_eq(42, 42, "answer should equal answer");
}

@test
fn test_assert_eq_text() {
    assert_eq("hello", "hello");
    assert_eq("", "");
}

// =============================================================================
// Section 7: Assert Inequality Tests
// =============================================================================

@test
fn test_assert_ne_integers() {
    assert_ne(1, 2);
    assert_ne(0, 1);
    assert_ne(-1, 1);
}

@test
fn test_assert_ne_with_message() {
    assert_ne(1, 2, "one should not equal two");
}

@test
fn test_assert_ne_text() {
    assert_ne("hello", "world");
    assert_ne("", " ");
}

// =============================================================================
// Section 8: Assert Some/None Tests
// =============================================================================

@test
fn test_assert_some_returns_value() {
    let maybe: Maybe<Int> = Some(42);
    let value = assert_some(maybe);
    assert_eq(value, 42);
}

@test
fn test_assert_some_with_message() {
    let maybe: Maybe<Text> = Some("hello");
    let value = assert_some(maybe, "should have value");
    assert_eq(value, "hello");
}

@test
fn test_assert_none_passes() {
    let maybe: Maybe<Int> = None;
    assert_none(maybe);
}

@test
fn test_assert_none_with_message() {
    let maybe: Maybe<Text> = None;
    assert_none(maybe, "should be empty");
}

