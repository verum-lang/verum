// =============================================================================

/// Test From<T> for Maybe<T>
@test
fn test_from_value() {
    let opt: Maybe<Int> = Maybe.from(42);
    assert_eq(opt.unwrap(), 42);
}

/// Test into() conversion
@test
fn test_into_maybe() {
    let opt: Maybe<Int> = 42.into();
    assert_eq(opt.unwrap(), 42);
}

// =============================================================================
// SECTION 20: Try Protocol Tests (? operator)
// =============================================================================

/// Test ? operator extracts value from Some
@test
fn test_try_operator_some() -> Maybe<Int> {
    let opt = Some(42);
    let value = opt?;
    Some(value * 2)
}

/// Test ? operator early returns on None
@test
fn test_try_operator_none() -> Maybe<Int> {
    let opt: Maybe<Int> = None;
    let value = opt?;  // Should early return here
    Some(value * 2)  // Never reached
}

/// Test ? operator in function
fn function_using_try_operator(a: Maybe<Int>, b: Maybe<Int>) -> Maybe<Int> {
    let x = a?;
    let y = b?;
    Some(x + y)
}

/// Test ? operator chaining success
@test
fn test_try_chaining_success() {
    let result = function_using_try_operator(Some(10), Some(20));
    assert_eq(result.unwrap(), 30);
}

/// Test ? operator chaining first None
@test
fn test_try_chaining_first_none() {
    let result = function_using_try_operator(None, Some(20));
    assert(result.is_none());
}

/// Test ? operator chaining second None
@test
fn test_try_chaining_second_none() {
    let result = function_using_try_operator(Some(10), None);
    assert(result.is_none());
}

/// Test ? on Result in Maybe-returning function
@test
fn test_try_result_in_maybe_function() -> Maybe<Int> {
    let result: Result<Int, Text> = Ok(42);
    let value = result?;  // Ok becomes Some, Err becomes None
    Some(value)
}

/// Test ? on Result Err in Maybe-returning function
@test
fn test_try_result_err_in_maybe_function() -> Maybe<Int> {
    let result: Result<Int, Text> = Err("error");
    let value = result?;  // Should early return None
    Some(value)
}

