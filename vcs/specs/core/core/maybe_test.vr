// SECTION 21: Edge Cases and Special Values
// =============================================================================

/// Test Maybe with unit type
@test
fn test_maybe_unit() {
    let some_unit: Maybe<()> = Some(());
    assert(some_unit.is_some());

    let none_unit: Maybe<()> = None;
    assert(none_unit.is_none());
}

/// Test Maybe with boolean
@test
fn test_maybe_bool_false() {
    let some_false = Some(false);
    assert(some_false.is_some());
    assert_eq(some_false.unwrap(), false);
}

/// Test Maybe preserves negative numbers
@test
fn test_maybe_negative() {
    let opt = Some(-42);
    assert_eq(opt.unwrap(), -42);
}

/// Test Maybe with floating point
@test
fn test_maybe_float() {
    let opt = Some(3.14);
    assert(opt.is_some());
    let val = opt.unwrap();
    assert(val > 3.0 && val < 4.0);
}

/// Test Maybe with tuple
@test
fn test_maybe_tuple() {
    let opt = Some((1, "hello", true));
    assert(opt.is_some());
    let (a, b, c) = opt.unwrap();
    assert_eq(a, 1);
    assert_eq(b, "hello");
    assert_eq(c, true);
}

// =============================================================================
// SECTION 22: Integration Tests
// =============================================================================

/// Test Maybe in parsing-like scenario
fn parse_number(s: &Text) -> Maybe<Int> {
    if s == "42" {
        Some(42)
    } else if s == "100" {
        Some(100)
    } else {
        None
    }
}

@test
fn test_maybe_parsing_scenario() {
    let result = parse_number("42");
    assert_eq(result.unwrap(), 42);

    let result2 = parse_number("invalid");
    assert(result2.is_none());
}

/// Test Maybe chaining in computation
@test
fn test_maybe_computation_chain() {
    let result = Some(10)
        .map(|x| x * 2)      // 20
        .filter(|x| x > 15)  // passes
        .and_then(|x| if x < 100 { Some(x + 5) } else { None })  // 25
        .map(|x| x.to_string());  // "25"

    assert_eq(result.unwrap(), "25");
}

/// Test Maybe with early exit pattern
fn find_first_even(numbers: &[Int]) -> Maybe<Int> {
    for n in numbers {
        if n % 2 == 0 {
            return Some(n);
        }
    }
    None
}

@test
fn test_maybe_early_exit() {
    let numbers = [1, 3, 5, 6, 7, 8];
    let result = find_first_even(&numbers);
    assert_eq(result.unwrap(), 6);

    let odd_only = [1, 3, 5, 7];
    let result2 = find_first_even(&odd_only);
    assert(result2.is_none());
}

/// Test Maybe flatten operation using and_then
/// Note: and_then(|inner| inner) is the identity/flatten operation.
/// For true optional chaining, outer?.method() extracts the inner value first,
/// so outer?.and_then(f) would call and_then on Maybe<Int>, not Maybe<Maybe<Int>>.
fn get_nested_value(outer: Maybe<Maybe<Int>>) -> Maybe<Int> {
    outer.and_then(|inner| inner)
}

@test
fn test_option_chaining() {
    let nested = Some(Some(42));
    assert_eq(get_nested_value(nested).unwrap(), 42);

    let inner_none = Some(None);
    assert(get_nested_value(inner_none).is_none());

    let outer_none: Maybe<Maybe<Int>> = None;
    assert(get_nested_value(outer_none).is_none());
}

