@test
fn test_debug_none() {
    let opt: Maybe<Int> = None;
    let debug_str = f"{opt:?}";
    assert_eq(debug_str, "None");
}

/// Test Debug for Some
@test
fn test_debug_some() {
    let opt = Some(42);
    let debug_str = f"{opt:?}";
    assert_eq(debug_str, "Some(42)");
}

