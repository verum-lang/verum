// Section 22: Additional ControlFlow Edge Cases
// =============================================================================

/// Test map_continue with multiple branches in closure
@test
fn test_map_continue_with_conditional() {
    let cf1: ControlFlow<Text, Int> = Continue(10);
    let cf2: ControlFlow<Text, Int> = Continue(5);

    let mapped1 = cf1.map_continue(|x| {
        if x > 7 {
            x * 2
        } else {
            x + 100
        }
    });

    let mapped2 = cf2.map_continue(|x| {
        if x > 7 {
            x * 2
        } else {
            x + 100
        }
    });

    assert_eq(mapped1.continue_value(), 20);   // 10 > 7, so 10 * 2
    assert_eq(mapped2.continue_value(), 105);  // 5 <= 7, so 5 + 100
}

/// Test map_break with error code transformation
@test
fn test_map_break_error_enrichment() {
    type ErrorCode is { code: Int };
    type RichError is { code: Int, severity: Text, timestamp: Int };

    let cf: ControlFlow<ErrorCode, ()> = Break(ErrorCode { code: 500 });
    let enriched = cf.map_break(|ec| {
        let severity = if ec.code >= 500 {
            "critical"
        } else if ec.code >= 400 {
            "warning"
        } else {
            "info"
        };

        RichError {
            code: ec.code,
            severity: severity,
            timestamp: 1234567890,
        }
    });

    assert(enriched.is_break());
    let err = enriched.break_value();
    assert_eq(err.code, 500);
    assert_eq(err.severity, "critical");
    assert_eq(err.timestamp, 1234567890);
}

/// Test ControlFlow with List types
@test
fn test_control_flow_with_lists() {
    let cf_continue: ControlFlow<List<Text>, List<Int>> = Continue([1, 2, 3]);
    let cf_break: ControlFlow<List<Text>, List<Int>> = Break(["error1", "error2"]);

    assert(cf_continue.is_continue());
    assert_eq(cf_continue.continue_value().len(), 3);

    assert(cf_break.is_break());
    assert_eq(cf_break.break_value().len(), 2);

    let mapped = cf_continue.map_continue(|list| {
        list.iter().map(|x| x * 10).collect()
    });

    assert_eq(mapped.continue_value(), [10, 20, 30]);
}

/// Test Try with Result error type conversion pattern
@test
fn test_try_result_error_type_flexibility() {
    type SimpleErr is { msg: Text };
    type DetailedErr is { msg: Text, location: Text };

    fn inner_fn() -> Result<Int, SimpleErr> {
        Err(SimpleErr { msg: "failed" })
    }

    fn outer_fn() -> Result<Int, DetailedErr> {
        let result = inner_fn();
        match result.branch() {
            Continue(v) => Ok(v),
            Break(residual) => {
                match residual {
                    Err(simple) => Err(DetailedErr {
                        msg: simple.msg,
                        location: "outer_fn",
                    }),
                    Ok(_) => unreachable(),
                }
            }
        }
    }

    let result = outer_fn();
    assert(result.is_err());
    let err = result.unwrap_err();
    assert_eq(err.msg, "failed");
    assert_eq(err.location, "outer_fn");
}

// =============================================================================
// Section 23: Advanced Try and FromResidual Patterns
// =============================================================================

/// Test FromResidual with Maybe to Result conversion
@test
fn test_from_residual_maybe_to_result_pattern() {
    // Pattern where we want to convert Maybe failures into Result errors

    fn maybe_operation() -> Maybe<Int> {
        None
    }

    fn result_wrapper() -> Result<Int, Text> {
        let maybe_val = maybe_operation();
        match maybe_val.branch() {
            Continue(v) => Ok(v),
            Break(_) => Err("Maybe was None"),
        }
    }

    let result = result_wrapper();
    assert(result.is_err());
    assert_eq(result.unwrap_err(), "Maybe was None");
}

/// Test Try with nested ControlFlow
@test
fn test_try_with_nested_control_flow() {
    type Inner is ControlFlow<Int, Text>;
    type Outer is ControlFlow<Bool, Inner>;

    let inner_continue: Inner = Continue("success");
    let outer: Outer = Continue(inner_continue);

    assert(outer.is_continue());
    let unwrapped_inner = outer.continue_value();
    assert(unwrapped_inner.is_continue());
    assert_eq(unwrapped_inner.continue_value(), "success");

    // Map through both layers
    let mapped_outer = outer.map_continue(|inner| {
        inner.map_continue(|s| s.len())
    });

    assert(mapped_outer.is_continue());
    let mapped_inner = mapped_outer.continue_value();
    assert(mapped_inner.is_continue());
    assert_eq(mapped_inner.continue_value(), 7);  // "success".len()
}

/// Test Never type in complex generic contexts
@test
fn test_never_in_generic_containers() {
    // List<Never> would be an empty list that can never have elements
    // We can construct it but can't add anything to it

    let empty_list: List<Never> = [];
    assert_eq(empty_list.len(), 0);

    // Map over List<Never> - the closure is never called
    let mapped: List<Int> = empty_list.iter().map(|_: &Never| 42).collect();
    assert_eq(mapped.len(), 0);

    // Maybe<List<Never>> can be None or Some([])
    let maybe_empty: Maybe<List<Never>> = Some([]);
    assert(maybe_empty.is_some());
    assert_eq(maybe_empty.unwrap().len(), 0);
}

/// Test ControlFlow with tuple types and destructuring patterns
@test
fn test_control_flow_with_tuples() {
    let cf1: ControlFlow<(Int, Text), (Bool, Float)> = Continue((true, 3.14));
    let cf2: ControlFlow<(Int, Text), (Bool, Float)> = Break((404, "not found"));

    assert(cf1.is_continue());
    let value = cf1.continue_value();
    assert_eq(value.0, true);
    assert_eq(value.1, 3.14);

    assert(cf2.is_break());
    let error = cf2.break_value();
    assert_eq(error.0, 404);
    assert_eq(error.1, "not found");

    // Map continue value tuple
    let mapped = cf1.map_continue(|pair| {
        let b = pair.0;
        let f: Float = pair.1;
        let new_f: Float = if b { f * 2.0 } else { f };
        (b, new_f)
    });

    assert(mapped.is_continue());
    let new_value = mapped.continue_value();
    assert_eq(new_value.1, 6.28);
}

