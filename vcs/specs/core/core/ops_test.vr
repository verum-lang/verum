/// Test deeply nested ControlFlow
@test
fn test_control_flow_deeply_nested() {
    type Deep is ControlFlow<ControlFlow<Int, Int>, ControlFlow<Int, Int>>;

    let inner_continue: ControlFlow<Int, Int> = Continue(42);
    let outer: Deep = Continue(inner_continue);

    assert(outer.is_continue());
    let inner = outer.continue_value();
    assert(inner.is_continue());
    assert_eq(inner.continue_value(), 42);
}

/// Test ControlFlow with generic wrapper type
@test
fn test_control_flow_generic_wrapper() {
    type Wrapper<T> is { value: T };

    let cf: ControlFlow<Wrapper<Text>, Wrapper<Int>> = Continue(Wrapper { value: 42 });

    assert(cf.is_continue());
    assert_eq(cf.continue_value().value, 42);
}

