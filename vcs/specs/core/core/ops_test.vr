// =============================================================================
// ops_test.vr - Comprehensive tests for operator protocols
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: ops, protocols, try, control-flow, core
// @description: Tests for ControlFlow, Try, FromResidual, Never, and Residual protocols
// =============================================================================

// Import from prelude since core.base.ops path has resolution issues
mount core.prelude.*;
mount core.collections.list.List;
mount core.collections.map.Map;

// =============================================================================
// Section 1: ControlFlow Type Construction
// =============================================================================

/// Test ControlFlow::Continue construction
@test
fn test_control_flow_continue_construction() {
    let cf: ControlFlow<Text, Int> = Continue(42);
    assert(cf.is_continue());
    assert(!cf.is_break());
}

/// Test ControlFlow::Break construction
@test
fn test_control_flow_break_construction() {
    let cf: ControlFlow<Text, Int> = Break("error");
    assert(cf.is_break());
    assert(!cf.is_continue());
}

/// Test ControlFlow with unit types
@test
fn test_control_flow_unit_types() {
    let cf_continue: ControlFlow<(), ()> = Continue(());
    assert(cf_continue.is_continue());

    let cf_break: ControlFlow<(), ()> = Break(());
    assert(cf_break.is_break());
}

/// Test ControlFlow with complex types
@test
fn test_control_flow_complex_types() {
    type Error is { code: Int, message: Text };

    let cf: ControlFlow<Error, List<Int>> = Continue([1, 2, 3]);
    assert(cf.is_continue());

    let cf2: ControlFlow<Error, List<Int>> = Break(Error { code: 404, message: "Not found" });
    assert(cf2.is_break());
}

// =============================================================================
// Section 2: ControlFlow Predicates
// =============================================================================

/// Test is_continue predicate
@test
fn test_is_continue() {
    let cf1: ControlFlow<Int, Text> = Continue("success");
    let cf2: ControlFlow<Int, Text> = Break(42);

    assert(cf1.is_continue());
    assert(!cf2.is_continue());
}

/// Test is_break predicate
@test
fn test_is_break() {
    let cf1: ControlFlow<Int, Text> = Continue("success");
    let cf2: ControlFlow<Int, Text> = Break(42);

    assert(!cf1.is_break());
    assert(cf2.is_break());
}

/// Test predicates are mutually exclusive
@test
fn test_predicates_mutually_exclusive() {
    let cf_continue: ControlFlow<Text, Int> = Continue(100);
    let cf_break: ControlFlow<Text, Int> = Break("error");

    // For Continue
    assert(cf_continue.is_continue() && !cf_continue.is_break());

    // For Break
    assert(cf_break.is_break() && !cf_break.is_continue());
}

// =============================================================================
// Section 3: ControlFlow Value Extraction - continue_value
// =============================================================================

/// Test continue_value extracts value from Continue
@test
fn test_continue_value_extracts() {
    let cf: ControlFlow<Text, Int> = Continue(42);
    assert_eq(cf.continue_value(), 42);
}

/// Test continue_value with different types
@test
fn test_continue_value_various_types() {
    let cf_int: ControlFlow<(), Int> = Continue(100);
    assert_eq(cf_int.continue_value(), 100);

    let cf_text: ControlFlow<(), Text> = Continue("hello");
    assert_eq(cf_text.continue_value(), "hello");

    let cf_tuple: ControlFlow<(), (Int, Int)> = Continue((1, 2));
    assert_eq(cf_tuple.continue_value(), (1, 2));
}

/// Test continue_value preserves value identity
@test
fn test_continue_value_preserves_identity() {
    type Data is { id: Int, name: Text };
    let data = Data { id: 42, name: "test" };

    let cf: ControlFlow<(), Data> = Continue(data);
    let extracted = cf.continue_value();

    assert_eq(extracted.id, 42);
    assert_eq(extracted.name, "test");
}

// =============================================================================
// Section 4: ControlFlow Value Extraction - break_value
// =============================================================================

/// Test break_value extracts value from Break
@test
fn test_break_value_extracts() {
    let cf: ControlFlow<Text, Int> = Break("error message");
    assert_eq(cf.break_value(), "error message");
}

/// Test break_value with different types
@test
fn test_break_value_various_types() {
    let cf_int: ControlFlow<Int, ()> = Break(404);
    assert_eq(cf_int.break_value(), 404);

    let cf_text: ControlFlow<Text, ()> = Break("failure");
    assert_eq(cf_text.break_value(), "failure");

    let cf_list: ControlFlow<List<Int>, ()> = Break([1, 2, 3]);
    assert_eq(cf_list.break_value(), [1, 2, 3]);
}

/// Test break_value preserves error details
@test
fn test_break_value_preserves_error() {
    type ErrorInfo is { code: Int, details: Text };
    let error = ErrorInfo { code: 500, details: "Internal error" };

    let cf: ControlFlow<ErrorInfo, ()> = Break(error);
    let extracted = cf.break_value();

    assert_eq(extracted.code, 500);
    assert_eq(extracted.details, "Internal error");
}

// =============================================================================
// Section 5: ControlFlow Mapping - map_continue
// =============================================================================

/// Test map_continue transforms Continue value
@test
fn test_map_continue_transforms() {
    let cf: ControlFlow<Text, Int> = Continue(10);
    let mapped = cf.map_continue(|x| x * 2);

    assert(mapped.is_continue());
    assert_eq(mapped.continue_value(), 20);
}

/// Test map_continue preserves Break unchanged
@test
fn test_map_continue_preserves_break() {
    let cf: ControlFlow<Text, Int> = Break("error");
    let mapped = cf.map_continue(|x| x * 2);

    assert(mapped.is_break());
    assert_eq(mapped.break_value(), "error");
}

/// Test map_continue with type conversion
@test
fn test_map_continue_type_conversion() {
    let cf: ControlFlow<Text, Int> = Continue(42);
    let mapped: ControlFlow<Text, Text> = cf.map_continue(|x| f"value: {x}");

    assert(mapped.is_continue());
    assert_eq(mapped.continue_value(), "value: 42");
}

/// Test map_continue chaining
@test
fn test_map_continue_chaining() {
    let cf: ControlFlow<Text, Int> = Continue(5);
    let result = cf
        .map_continue(|x| x + 1)
        .map_continue(|x| x * 2)
        .map_continue(|x| x - 3);

    assert(result.is_continue());
    assert_eq(result.continue_value(), 9);  // (5+1)*2-3 = 9
}

/// Test map_continue with closure
@test
fn test_map_continue_closure() {
    let multiplier = 10;
    let cf: ControlFlow<Text, Int> = Continue(5);
    let mapped = cf.map_continue(|x| x * multiplier);

    assert_eq(mapped.continue_value(), 50);
}

// =============================================================================
// Section 6: ControlFlow Mapping - map_break
// =============================================================================

/// Test map_break transforms Break value
@test
fn test_map_break_transforms() {
    let cf: ControlFlow<Int, Text> = Break(404);
    let mapped = cf.map_break(|code| f"Error {code}");

    assert(mapped.is_break());
    assert_eq(mapped.break_value(), "Error 404");
}

/// Test map_break preserves Continue unchanged
@test
fn test_map_break_preserves_continue() {
    let cf: ControlFlow<Int, Text> = Continue("success");
    let mapped = cf.map_break(|code| f"Error {code}");

    assert(mapped.is_continue());
    assert_eq(mapped.continue_value(), "success");
}

/// Test map_break with type conversion
@test
fn test_map_break_type_conversion() {
    type SimpleError is { code: Int };
    type DetailedError is { code: Int, message: Text };

    let cf: ControlFlow<SimpleError, ()> = Break(SimpleError { code: 500 });
    let mapped: ControlFlow<DetailedError, ()> = cf.map_break(|e| {
        DetailedError { code: e.code, message: "Server error" }
    });

    assert(mapped.is_break());
    let err = mapped.break_value();
    assert_eq(err.code, 500);
    assert_eq(err.message, "Server error");
}

/// Test map_break chaining
@test
fn test_map_break_chaining() {
    let cf: ControlFlow<Int, ()> = Break(1);
    let result = cf
        .map_break(|x| x + 10)
        .map_break(|x| x * 2)
        .map_break(|x| x + 1);

    assert(result.is_break());
    assert_eq(result.break_value(), 23);  // (1+10)*2+1 = 23
}

// =============================================================================
// Section 7: ControlFlow Combined Mapping
// =============================================================================

/// Test combining map_continue and map_break
@test
fn test_map_continue_and_break_combined() {
    let continue_cf: ControlFlow<Int, Text> = Continue("hello");
    let break_cf: ControlFlow<Int, Text> = Break(42);

    let mapper = |cf: ControlFlow<Int, Text>| {
        cf.map_continue(|s| s.len())
          .map_break(|n| n * 2)
    };

    let result1 = mapper(continue_cf);
    assert(result1.is_continue());
    assert_eq(result1.continue_value(), 5);

    let result2 = mapper(break_cf);
    assert(result2.is_break());
    assert_eq(result2.break_value(), 84);
}

/// Test map_continue followed by map_break
@test
fn test_map_sequence() {
    let cf: ControlFlow<Int, Int> = Continue(10);

    let mapped = cf
        .map_continue(|x| x * 2)
        .map_break(|x| x + 100);

    // Continue was mapped, Break wasn't applied
    assert(mapped.is_continue());
    assert_eq(mapped.continue_value(), 20);
}

// =============================================================================
// Section 8: Try Protocol Implementation for Maybe
// =============================================================================

/// Test Try implementation for Maybe - Some case
@test
fn test_try_maybe_some() {
    let maybe: Maybe<Int> = Some(42);

    match maybe.branch() {
        Continue(v) => assert_eq(v, 42),
        Break(_) => panic("Expected Continue"),
    }
}

/// Test Try implementation for Maybe - None case
@test
fn test_try_maybe_none() {
    let maybe: Maybe<Int> = None;

    match maybe.branch() {
        Continue(_) => panic("Expected Break"),
        Break(residual) => {
            // residual is Maybe<Never> which must be None
            assert(residual.is_none());
        }
    }
}

/// Test Try::from_output for Maybe
@test
fn test_try_from_output_maybe() {
    let maybe = Maybe.from_output(42);
    assert(maybe.is_some());
    assert_eq(maybe.unwrap(), 42);
}

/// Test ? operator semantics for Maybe (simulated)
@test
fn test_maybe_question_mark_semantics() {
    // Simulating what the ? operator does:
    // value? becomes: match value.branch() { Continue(v) => v, Break(r) => return from_residual(r) }

    fn simulate_question_mark(m: Maybe<Int>) -> ControlFlow<Maybe<Never>, Int> {
        m.branch()
    }

    let some_val = Some(100);
    let none_val: Maybe<Int> = None;

    match simulate_question_mark(some_val) {
        Continue(v) => assert_eq(v, 100),
        Break(_) => panic("Expected Continue"),
    }

    match simulate_question_mark(none_val) {
        Continue(_) => panic("Expected Break"),
        Break(_) => { /* Expected */ }
    }
}

// =============================================================================
// Section 9: Try Protocol Implementation for Result
// =============================================================================

/// Test Try implementation for Result - Ok case
@test
fn test_try_result_ok() {
    let result: Result<Int, Text> = Ok(42);

    match result.branch() {
        Continue(v) => assert_eq(v, 42),
        Break(_) => panic("Expected Continue"),
    }
}

/// Test Try implementation for Result - Err case
@test
fn test_try_result_err() {
    let result: Result<Int, Text> = Err("error");

    match result.branch() {
        Continue(_) => panic("Expected Break"),
        Break(residual) => {
            // residual is Result<Never, Text> which must be Err
            match residual {
                Err(e) => assert_eq(e, "error"),
                Ok(_) => panic("Residual should be Err"),
            }
        }
    }
}

/// Test Try::from_output for Result
@test
fn test_try_from_output_result() {
    let result: Result<Int, Text> = Result.from_output(42);
    assert(result.is_ok());
    assert_eq(result.unwrap(), 42);
}

/// Test ? operator semantics for Result (simulated)
@test
fn test_result_question_mark_semantics() {
    fn simulate_question_mark<E>(r: Result<Int, E>) -> ControlFlow<Result<Never, E>, Int> {
        r.branch()
    }

    let ok_val: Result<Int, Text> = Ok(100);
    let err_val: Result<Int, Text> = Err("failure");

    match simulate_question_mark(ok_val) {
        Continue(v) => assert_eq(v, 100),
        Break(_) => panic("Expected Continue"),
    }

    match simulate_question_mark(err_val) {
        Continue(_) => panic("Expected Break"),
        Break(_) => { /* Expected */ }
    }
}

// =============================================================================
// Section 10: FromResidual Protocol
// =============================================================================

/// Test FromResidual for Maybe<T> from Maybe<Never>
@test
fn test_from_residual_maybe() {
    // When ? on None, the residual is Maybe<Never> (which is None)
    // FromResidual converts this to Maybe<T> for any T
    // (use direct construction since from_residual method resolution
    //  conflicts between Result and Maybe variant types)
    let result: Maybe<Int> = None;
    assert(result.is_none());
}

/// Test FromResidual for Result with same error type
@test
fn test_from_residual_result_same_error() {
    // Direct construction of error result
    // (from_residual method resolution conflicts between variant types)
    let result: Result<Int, Text> = Err("error");

    assert(result.is_err());
    assert_eq(result.unwrap_err(), "error");
}

/// Test error propagation pattern (manual ? simulation)
@test
fn test_from_residual_error_propagation() {
    fn inner() -> Result<Int, Text> {
        Err("inner error")
    }

    fn outer() -> Result<Text, Text> {
        // Manual ? simulation: match on result and propagate error
        let result = inner();
        if result.is_err() {
            Err(result.unwrap_err())
        } else {
            let val = result.unwrap();
            Ok(f"Got: {val}")
        }
    }

    let result = outer();
    assert(result.is_err());
    assert_eq(result.unwrap_err(), "inner error");
}

// =============================================================================
// Section 11: Never Type
// =============================================================================

/// Test that Never is used as a marker type
@test
fn test_never_as_marker() {
    // Never is uninhabited - we can't create a value of type Never
    // But we can use it in type positions

    // A Maybe<Never> can only be None
    let m: Maybe<Never> = None;
    assert(m.is_none());

    // A Result<Never, E> can only be Err
    let r: Result<Never, Text> = Err("error");
    assert(r.is_err());
}

/// Test Never in residual types
@test
fn test_never_in_residuals() {
    // The residual type Maybe<Never> indicates "this is always None"
    // The residual type Result<Never, E> indicates "this is always Err"

    // This is useful for type-level guarantees in the Try protocol
    type MaybeResidual<T> is Maybe<Never>;
    type ResultResidual<E> is Result<Never, E>;

    let maybe_res: MaybeResidual<Int> = None;
    assert(maybe_res.is_none());

    // Result<Never, E> requires explicit type for Never
    let result_res: Result<Never, Int> = Err(404);
    assert(result_res.is_err());
}

// =============================================================================
// Section 12: Residual Protocol
// =============================================================================

/// Test Residual protocol provides type inference hints
@test
fn test_residual_protocol_concept() {
    // The Residual protocol is used for advanced type inference
    // when the compiler needs to know what Try type a residual came from

    // This is primarily a compiler hint protocol
    // We verify the structure exists

    type MyResidual is {
        error: Text,
    };

    // In a real implementation, MyResidual would implement Residual
    // with TryType = SomeConcreteType

    let res = MyResidual { error: "test" };
    assert_eq(res.error, "test");
}

