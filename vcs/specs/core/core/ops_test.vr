/// Test ControlFlow with same B and C types
@test
fn test_control_flow_same_types() {
    let cf1: ControlFlow<Int, Int> = Continue(42);
    let cf2: ControlFlow<Int, Int> = Break(42);

    // Both have the same value but different semantics
    assert(cf1.is_continue());
    assert(cf2.is_break());
    assert_eq(cf1.continue_value(), 42);
    assert_eq(cf2.break_value(), 42);
}

/// Test ControlFlow with nested types
@test
fn test_control_flow_nested_types() {
    let cf: ControlFlow<Maybe<Text>, Result<Int, Text>> = Continue(Ok(42));
    assert(cf.is_continue());

    match cf.continue_value() {
        Ok(v) => assert_eq(v, 42),
        Err(_) => panic("Expected Ok"),
    }
}

/// Test ControlFlow with function types
@test
fn test_control_flow_function_types() {
    type Processor is fn(Int) -> Int;

    let double: Processor = |x| x * 2;
    let cf: ControlFlow<Text, Processor> = Continue(double);

    assert(cf.is_continue());
    let f = cf.continue_value();
    assert_eq(f(21), 42);
}

// =============================================================================
// Section 14: Integration - Try Chain Simulation
// =============================================================================

/// Test simulating a chain of ? operations
@test
fn test_try_chain_simulation() {
    fn step1() -> Result<Int, Text> {
        Ok(10)
    }

    fn step2(x: Int) -> Result<Int, Text> {
        Ok(x * 2)
    }

    fn step3(x: Int) -> Result<Int, Text> {
        if x > 15 {
            Ok(x + 5)
        } else {
            Err("Too small")
        }
    }

    // Simulating: step1()?.pipe(step2)?.pipe(step3)?
    fn chain() -> Result<Int, Text> {
        let r1 = step1();
        if r1.is_err() { Err(r1.unwrap_err()) } else {
        let v1 = r1.unwrap();
        let r2 = step2(v1);
        if r2.is_err() { Err(r2.unwrap_err()) } else {
        let v2 = r2.unwrap();
        let r3 = step3(v2);
        if r3.is_err() { Err(r3.unwrap_err()) } else {
        let v3 = r3.unwrap();
        Ok(v3)
        }}}
    }

    let result = chain();
    assert(result.is_ok());
    assert_eq(result.unwrap(), 25);  // 10 -> 20 -> 25
}

/// Test try chain with failure in middle
@test
fn test_try_chain_failure_middle() {
    fn step1() -> Maybe<Int> {
        Some(10)
    }

    fn step2(_x: Int) -> Maybe<Int> {
        None  // Failure here
    }

    fn step3(x: Int) -> Maybe<Int> {
        Some(x + 100)
    }

    fn chain() -> Maybe<Int> {
        let r1 = step1();
        if r1.is_none() { None } else {
        let v1 = r1.unwrap();
        let r2 = step2(v1);
        if r2.is_none() { None } else {
        let v2 = r2.unwrap();
        let r3 = step3(v2);
        if r3.is_none() { None } else {
        let v3 = r3.unwrap();
        Some(v3)
        }}}
    }

    let result = chain();
    assert(result.is_none());  // Failed at step2
}

