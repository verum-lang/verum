/// Test from_output followed by branch gives Continue
@test
fn test_try_roundtrip_success() {
    // For any T: Try, from_output(x).branch() should be Continue(x)

    let maybe = Maybe.from_output(42);
    match maybe.branch() {
        Continue(v) => assert_eq(v, 42),
        Break(_) => panic("from_output should produce Continue on branch"),
    }

    let result: Result<Int, Text> = Result.from_output(42);
    match result.branch() {
        Continue(v) => assert_eq(v, 42),
        Break(_) => panic("from_output should produce Continue on branch"),
    }
}

/// Test that None value can be propagated as failure
@test
fn test_try_residual_convertible() {
    // A None value represents failure that can be propagated
    let none_maybe: Maybe<Int> = None;
    assert(none_maybe.is_none());

    // Directly construct the converted result
    let converted: Maybe<Int> = None;
    assert(converted.is_none());
}

// =============================================================================
// Section 17: Error Type Conversion with FromResidual
// =============================================================================

/// Test error type conversion between Result types
@test
fn test_from_residual_error_conversion() {
    type InnerError is { code: Int };
    type OuterError is { code: Int, context: Text };

    // Convert inner errors to outer using is_err/unwrap pattern
    fn convert_error<T>(result: Result<T, InnerError>, ctx: Text) -> Result<T, OuterError> {
        if result.is_err() {
            let inner = result.unwrap_err();
            Err(OuterError {
                code: inner.code,
                context: ctx,
            })
        } else {
            Ok(result.unwrap())
        }
    }

    let inner_result: Result<Int, InnerError> = Err(InnerError { code: 404 });
    let outer_result = convert_error(inner_result, "in function foo");

    assert(outer_result.is_err());
    let err = outer_result.unwrap_err();
    assert_eq(err.code, 404);
    assert_eq(err.context, "in function foo");
}

// =============================================================================
// Section 18: Custom Try Implementation Example
// =============================================================================

/// Test custom type implementing Try-like behavior
@test
fn test_custom_try_type() {
    // A custom validation result that can be used with Try-like semantics

    type Validated<T, E> is Valid(T) | Invalid(E);

    // Implement Try-like behavior manually
    fn validated_branch<T, E>(v: Validated<T, E>) -> ControlFlow<E, T> {
        match v {
            Valid(t) => Continue(t),
            Invalid(e) => Break(e),
        }
    }

    fn validated_from_output<T, E>(t: T) -> Validated<T, E> {
        Valid(t)
    }

    // Test the implementation
    let valid: Validated<Int, Text> = Valid(42);
    match validated_branch(valid) {
        Continue(v) => assert_eq(v, 42),
        Break(_) => panic("Expected Continue"),
    }

    let invalid: Validated<Int, Text> = Invalid("validation failed");
    match validated_branch(invalid) {
        Continue(_) => panic("Expected Break"),
        Break(e) => assert_eq(e, "validation failed"),
    }

    let from_out: Validated<Int, Text> = validated_from_output(100);
    match from_out {
        Valid(v) => assert_eq(v, 100),
        Invalid(_) => panic("Expected Valid"),
    }
}

// =============================================================================
// Section 19: ControlFlow Pattern Matching
// =============================================================================

/// Test exhaustive pattern matching on ControlFlow
@test
fn test_control_flow_pattern_matching() {
    fn describe<B: Debug, C: Debug>(cf: ControlFlow<B, C>) -> Text {
        match cf {
            Continue(c) => f"Continuing with {c}",
            Break(b) => f"Breaking with {b}",
        }
    }

    let cf1: ControlFlow<Int, Text> = Continue("success");
    let cf2: ControlFlow<Int, Text> = Break(42);

    assert_eq(describe(cf1), "Continuing with success");
    assert_eq(describe(cf2), "Breaking with 42");
}

/// Test nested pattern matching
@test
fn test_control_flow_nested_pattern_matching() {
    let cf: ControlFlow<Result<Int, Text>, Maybe<Int>> = Continue(Some(42));

    match cf {
        Continue(Some(v)) => assert_eq(v, 42),
        Continue(None) => panic("Expected Some"),
        Break(Ok(_)) => panic("Expected Continue"),
        Break(Err(_)) => panic("Expected Continue"),
    }
}

// =============================================================================
// Section 20: Try in Async-like Context (Simulation)
// =============================================================================

/// Test Try semantics in async-like code patterns
@test
fn test_try_async_pattern() {
    // Simulating async/await with Try-like early return

    type AsyncResult<T, E> is Pending | Ready(Result<T, E>);

    fn poll<T, E>(ar: AsyncResult<T, E>) -> ControlFlow<AsyncResult<T, E>, T> {
        match ar {
            Pending => Break(Pending),
            Ready(result) => match result {
                Ok(v) => Continue(v),
                Err(e) => Break(Ready(Err(e))),
            },
        }
    }

    let pending: AsyncResult<Int, Text> = Pending;
    let ready_ok: AsyncResult<Int, Text> = Ready(Ok(42));
    let ready_err: AsyncResult<Int, Text> = Ready(Err("error"));

    match poll(pending) {
        Break(Pending) => { /* Expected */ }
        _ => panic("Expected pending break"),
    }

    match poll(ready_ok) {
        Continue(v) => assert_eq(v, 42),
        _ => panic("Expected continue with value"),
    }

    match poll(ready_err) {
        Break(Ready(Err(e))) => assert_eq(e, "error"),
        _ => panic("Expected error break"),
    }
}

// =============================================================================
// Section 21: Integration with Real-World Patterns
// =============================================================================

/// Test parsing pipeline with Try semantics
@test
fn test_parsing_pipeline() {
    fn parse_int(s: Text) -> Maybe<Int> {
        s.parse_int().ok()
    }

    fn validate_positive(n: Int) -> Maybe<Int> {
        if n > 0 { Some(n) } else { None }
    }

    fn double(n: Int) -> Maybe<Int> {
        Some(n * 2)
    }

    fn parse_and_process(input: Text) -> Maybe<Int> {
        let r1 = parse_int(input);
        if r1.is_none() { None } else {
        let n = r1.unwrap();
        let r2 = validate_positive(n);
        if r2.is_none() { None } else {
        let valid = r2.unwrap();
        double(valid)
        }}
    }

    assert_eq(parse_and_process("42"), Some(84));
    assert_eq(parse_and_process("-5"), None);  // Fails validation
    assert_eq(parse_and_process("abc"), None); // Fails parsing
}

/// Test configuration loading with Try semantics
@test
fn test_config_loading() {
    type ConfigError is ParseError(Text) | ValidationError(Text) | IoError(Text);

    fn read_config_file(path: Text) -> Result<Text, ConfigError> {
        if path == "valid.txt" {
            Ok("key=value")
        } else {
            Err(IoError(f"File not found: {path}"))
        }
    }

    fn parse_config(content: Text) -> Result<Map<Text, Text>, ConfigError> {
        if content.contains("=") {
            let parts: List<Text> = content.split("=");
            if parts.len() == 2 {
                let mut map = Map.new();
                map.insert(parts[0], parts[1]);
                Ok(map)
            } else {
                Err(ParseError("Invalid format"))
            }
        } else {
            Err(ParseError("Missing ="))
        }
    }

    fn validate_config(config: Map<Text, Text>) -> Result<Map<Text, Text>, ConfigError> {
        if config.contains_key("key") {
            Ok(config)
        } else {
            Err(ValidationError("Missing 'key'"))
        }
    }

    fn load_config(path: Text) -> Result<Map<Text, Text>, ConfigError> {
        let r1 = read_config_file(path);
        if r1.is_err() { Err(r1.unwrap_err()) } else {
        let content = r1.unwrap();
        let r2 = parse_config(content);
        if r2.is_err() { Err(r2.unwrap_err()) } else {
        let parsed = r2.unwrap();
        let r3 = validate_config(parsed);
        if r3.is_err() { Err(r3.unwrap_err()) } else {
        Ok(r3.unwrap())
        }}}
    }

    let result = load_config("valid.txt");
    assert(result.is_ok());

    let error_result = load_config("missing.txt");
    assert(error_result.is_err());
}

