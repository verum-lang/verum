// Section 13: Range with Different Integer Sizes
// -----------------------------------------------------------------------------

@test
fn test_range_with_i32() {
    let start: Int32 = 0;
    let end: Int32 = 5;
    let mut count: Int32 = 0;
    for i in start..end {
        count = count + 1;
    }
    assert_eq(count, 5);
}

@test
fn test_range_with_i8() {
    let start: Int8 = 1;
    let end: Int8 = 6;
    let mut sum: Int = 0;
    for i in start..end {
        sum = sum + (i as Int);
    }
    // 1 + 2 + 3 + 4 + 5 = 15
    assert_eq(sum, 15);
}

@test
fn test_range_with_i16() {
    let start: Int16 = 0;
    let end: Int16 = 4;
    let mut count = 0;
    for i in start..end {
        count = count + 1;
    }
    assert_eq(count, 4);
}

@test
fn test_range_with_i64() {
    let start: Int64 = 10;
    let end: Int64 = 15;
    let mut sum: Int64 = 0;
    for i in start..end {
        sum = sum + i;
    }
    // 10 + 11 + 12 + 13 + 14 = 60
    assert_eq(sum, 60 as Int64);
}

@test
fn test_range_with_u8() {
    let start: UInt8 = 0;
    let end: UInt8 = 10;
    let mut count = 0;
    for i in start..end {
        count = count + 1;
    }
    assert_eq(count, 10);
}

@test
fn test_range_with_u16() {
    let start: UInt16 = 5;
    let end: UInt16 = 10;
    let mut sum: Int = 0;
    for i in start..end {
        sum = sum + (i as Int);
    }
    // 5 + 6 + 7 + 8 + 9 = 35
    assert_eq(sum, 35);
}

@test
fn test_range_with_u32() {
    let start: UInt32 = 0;
    let end: UInt32 = 3;
    let mut count = 0;
    for i in start..end {
        count = count + 1;
    }
    assert_eq(count, 3);
}

@test
fn test_range_inclusive_i32() {
    let start: Int32 = 1;
    let end: Int32 = 5;
    let mut sum: Int = 0;
    let mut r = RangeInclusive { current: start, end: end, done: false };
    loop {
        match r.next() {
            Some(v) => { sum = sum + (v as Int); }
            None => { break; }
        }
    }
    // 1 + 2 + 3 + 4 + 5 = 15
    assert_eq(sum, 15);
}

@test
fn test_range_empty_i32() {
    let start: Int32 = 5;
    let end: Int32 = 5;
    let mut count = 0;
    for i in start..end {
        count = count + 1;
    }
    assert_eq(count, 0);
}

@test
fn test_range_negative_i32() {
    let start: Int32 = -3;
    let end: Int32 = 3;
    let mut count = 0;
    for i in start..end {
        count = count + 1;
    }
    assert_eq(count, 6);
}

// -----------------------------------------------------------------------------
// Section 14: Range Patterns in Functions
// -----------------------------------------------------------------------------

fn process_range(start: Int, end: Int) -> List<Int> {
    let mut result: List<Int> = [];
    for i in start..end {
        result.push(i);
    }
    result
}

@test
fn test_range_in_function() {
    let result = process_range(5, 10);

    assert_eq(result.len(), 5);
    match result.get(0) {
        Some(v) => assert_eq(*v, 5),
        None => assert(false),
    }
    match result.get(4) {
        Some(v) => assert_eq(*v, 9),
        None => assert(false),
    }
}

fn generate_squares(n: Int) -> List<Int> {
    let mut result: List<Int> = [];
    for i in 0..n {
        result.push(i * i);
    }
    result
}

@test
fn test_range_for_generation() {
    let squares = generate_squares(5);

    assert_eq(squares.len(), 5);
    match squares.get(0) {
        Some(v) => assert_eq(*v, 0),
        None => assert(false),
    }
    match squares.get(4) {
        Some(v) => assert_eq(*v, 16),
        None => assert(false),
    }
}

// -----------------------------------------------------------------------------
// Section 15: Range Comparison with While Loop
// -----------------------------------------------------------------------------

@test
fn test_range_equivalent_to_while() {
    // Using range
    let mut sum_for = 0;
    for i in 0..10 {
        sum_for = sum_for + i;
    }

    // Equivalent while loop
    let mut sum_while = 0;
    let mut j = 0;
    while j < 10 {
        sum_while = sum_while + j;
        j = j + 1;
    }

    // Both should produce the same result
    assert_eq(sum_for, sum_while);
    assert_eq(sum_for, 45);
}

// -----------------------------------------------------------------------------
// Section 16: Complex Range Expressions
// -----------------------------------------------------------------------------

@test
fn test_complex_range_bounds() {
    fn calculate_bound(x: Int) -> Int {
        x * x
    }

    let base = 2;
    let mut count = 0;

    for i in calculate_bound(base)..calculate_bound(base + 1) {
        count = count + 1;
    }

    // Range 4..9 has 5 elements
    assert_eq(count, 5);
}

@test
fn test_range_from_tuple() {
    let bounds = (3, 8);

    let mut sum = 0;
    for i in bounds.0..bounds.1 {
        sum = sum + i;
    }

    // 3 + 4 + 5 + 6 + 7 = 25
    assert_eq(sum, 25);
}

@test
fn test_range_from_array_elements() {
    let arr = [2, 10];

    let mut sum = 0;
    for i in arr[0]..arr[1] {
        sum = sum + i;
    }

    // 2 + 3 + 4 + 5 + 6 + 7 + 8 + 9 = 44
    assert_eq(sum, 44);
}

// -----------------------------------------------------------------------------
// Section 17: Inclusive Range Sum
// -----------------------------------------------------------------------------

@test
fn test_inclusive_range_sum() {
    let mut sum = 0;
    for i in 1..=100 {
        sum = sum + i;
    }
    // 1 + 2 + ... + 100 = 5050
    assert_eq(sum, 5050);
}

// -----------------------------------------------------------------------------
// Section 18: Range Collect to List
// -----------------------------------------------------------------------------

@test
fn test_range_collect_to_list() {
    let mut result: List<Int> = [];
    for i in 0..5 {
        result.push(i);
    }
    assert_eq(result.len(), 5);
    assert_eq(result[0], 0);
    assert_eq(result[4], 4);
}

@test
fn test_inclusive_range_collect_to_list() {
    let mut result: List<Int> = [];
    for i in 1..=3 {
        result.push(i);
    }
    assert_eq(result.len(), 3);
    assert_eq(result[0], 1);
    assert_eq(result[2], 3);
}

// -----------------------------------------------------------------------------
// Section 19: Large Range Count
// -----------------------------------------------------------------------------

@test
fn test_large_range_count() {
    let mut count = 0;
    for _ in 0..1000 {
        count = count + 1;
    }
    assert_eq(count, 1000);
}

// -----------------------------------------------------------------------------
// Section 20: Range with Accumulator Patterns
// -----------------------------------------------------------------------------

@test
fn test_range_factorial_pattern() {
    let mut factorial = 1;
    for i in 1..=10 {
        factorial = factorial * i;
    }
    // 10! = 3628800
    assert_eq(factorial, 3628800);
}

@test
fn test_range_fibonacci_steps() {
    let mut a = 0;
    let mut b = 1;
    for _ in 0..10 {
        let temp = a + b;
        a = b;
        b = temp;
    }
    // fib(10) = 55
    assert_eq(a, 55);
}

// -----------------------------------------------------------------------------
// Section 21: Range Boundary Arithmetic
// -----------------------------------------------------------------------------

@test
fn test_range_zero_to_one_exclusive() {
    let mut count = 0;
    for _ in 0..1 {
        count = count + 1;
    }
    assert_eq(count, 1);
}

@test
fn test_inclusive_range_zero_to_zero() {
    let mut count = 0;
    for _ in 0..=0 {
        count = count + 1;
    }
    assert_eq(count, 1);
}

@test
fn test_negative_inclusive_range() {
    let mut sum = 0;
    for i in -5..=-1 {
        sum = sum + i;
    }
    // -5 + -4 + -3 + -2 + -1 = -15
    assert_eq(sum, -15);
}

// -----------------------------------------------------------------------------
// Section 22: Additional Range Tests
// -----------------------------------------------------------------------------

@test
fn test_range_exclusive_count_formula() {
    // For range a..b, count = b - a (when b > a)
    let a = 3;
    let b = 13;
    let mut count = 0;
    for _ in a..b {
        count = count + 1;
    }
    assert_eq(count, b - a);
}

@test
fn test_range_inclusive_count_formula() {
    // For range a..=b, count = b - a + 1 (when b >= a)
    let a = 3;
    let b = 13;
    let mut count = 0;
    for _ in a..=b {
        count = count + 1;
    }
    assert_eq(count, b - a + 1);
}

@test
fn test_range_sum_formula() {
    // Sum of 0..n = n*(n-1)/2
    let n = 20;
    let mut sum = 0;
    for i in 0..n {
        sum = sum + i;
    }
    assert_eq(sum, n * (n - 1) / 2);
}

@test
fn test_inclusive_range_sum_formula() {
    // Sum of 1..=n = n*(n+1)/2
    let n = 20;
    let mut sum = 0;
    for i in 1..=n {
        sum = sum + i;
    }
    assert_eq(sum, n * (n + 1) / 2);
}

@test
fn test_range_with_power_of_two_count() {
    let mut count = 0;
    for _ in 0..64 {
        count = count + 1;
    }
    assert_eq(count, 64);
}

@test
fn test_range_exclusive_boundary_off_by_one() {
    // Verify exclusive range doesn't include end
    let end = 5;
    let mut last_seen = -1;
    for i in 0..end {
        last_seen = i;
    }
    assert_eq(last_seen, end - 1);
}

@test
fn test_inclusive_range_boundary_includes_end() {
    // Verify inclusive range includes end
    let end = 5;
    let mut last_seen = -1;
    for i in 0..=end {
        last_seen = i;
    }
    assert_eq(last_seen, end);
}

@test
fn test_range_negative_to_positive() {
    let mut count = 0;
    for _ in -10..10 {
        count = count + 1;
    }
    assert_eq(count, 20);
}

// =============================================================================
// Additional Range Tests
// =============================================================================

@test
fn test_range_product() {
    // 1 * 2 * 3 * 4 * 5 = 120
    let mut prod = 1;
    for i in 1..6 {
        prod = prod * i;
    }
    assert_eq(prod, 120);
}

@test
fn test_inclusive_range_product() {
    let mut prod = 1;
    for i in 1..=5 {
        prod = prod * i;
    }
    assert_eq(prod, 120);
}

@test
fn test_range_count_evens() {
    let mut evens = 0;
    for i in 0..20 {
        if i % 2 == 0 {
            evens = evens + 1;
        }
    }
    assert_eq(evens, 10);
}

@test
fn test_range_nested_sum() {
    let mut sum = 0;
    for i in 0..3 {
        for j in 0..3 {
            sum = sum + i + j;
        }
    }
    // Each i appears 3 times in sum with j, each j appears 3 times with i
    // sum of i's: (0+1+2)*3 = 9, sum of j's: (0+1+2)*3 = 9, total = 18
    assert_eq(sum, 18);
}

@test
fn test_range_step_simulation() {
    // Simulate step by 2 with range
    let mut count = 0;
    let mut i = 0;
    while i < 10 {
        count = count + 1;
        i = i + 2;
    }
    assert_eq(count, 5);
}

@test
fn test_range_used_for_indexing() {
    let arr = [10, 20, 30, 40, 50];
    let mut sum = 0;
    for i in 0..5 {
        sum = sum + arr[i];
    }
    assert_eq(sum, 150);
}

@test
fn test_range_single_element_inclusive() {
    let mut count = 0;
    for _ in 5..=5 {
        count = count + 1;
    }
    assert_eq(count, 1);
}

@test
fn test_range_empty_when_start_equals_end() {
    let mut count = 0;
    for _ in 5..5 {
        count = count + 1;
    }
    assert_eq(count, 0);
}
