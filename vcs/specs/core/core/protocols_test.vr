// =============================================================================
// Section 26: Protocol Inheritance
// =============================================================================

/// Test Ord extends Eq
@test
fn test_ord_extends_eq() {
    type Ranked is { rank: Int };

    implement Eq for Ranked {
        fn eq(&self, other: &Ranked) -> Bool {
            self.rank == other.rank
        }
    }

    implement Ord for Ranked {
        fn cmp(&self, other: &Ranked) -> Ordering {
            Ordering.from_int(self.rank - other.rank)
        }
    }

    // Ord type can use Eq methods
    let r1 = Ranked { rank: 1 };
    let r2 = Ranked { rank: 1 };

    assert(r1.eq(&r2));  // From Eq
    assert(r1.cmp(&r2) is Equal);  // From Ord
}

/// Test Copy extends Clone
@test
fn test_copy_extends_clone() {
    type Simple is { n: Int };

    implement Clone for Simple {
        fn clone(&self) -> Simple {
            Simple { n: self.n }
        }
    }

    implement Copy for Simple {}

    let s1 = Simple { n: 42 };
    let s2 = s1.clone();  // Can use clone() because Copy extends Clone

    assert_eq(s2.n, 42);
}

/// Test DerefMut extends Deref
@test
fn test_deref_mut_extends_deref() {
    type Cell<T> is { value: T };

    implement<T> Deref for Cell<T> {
        type Target = T;
        fn deref(&self) -> &T { &self.value }
    }

    implement<T> DerefMut for Cell<T> {
        fn deref_mut(&mut self) -> &mut T { &mut self.value }
    }

    let mut cell = Cell { value: 10 };

    // Can use deref (from Deref)
    let ref_val = cell.deref();
    assert_eq(*ref_val, 10);

    // Can use deref_mut (from DerefMut)
    *cell.deref_mut() = 20;
    assert_eq(*cell.deref(), 20);
}

// =============================================================================
// Section 27: Generic Protocol Constraints
// =============================================================================

/// Test function with multiple protocol bounds
@test
fn test_multiple_bounds() {
    fn compare_and_hash<T: Eq + Hash>(a: &T, b: &T) -> (Bool, Int, Int) {
        // Use == operator instead of eq method due to method resolution issue
        (*a == *b, a.hash_value(), b.hash_value())
    }

    type Hashable is { id: Int };

    implement Eq for Hashable {
        fn eq(&self, other: &Hashable) -> Bool {
            self.id == other.id
        }
    }

    implement Hash for Hashable {
        fn hash(&self, hasher: &mut Hasher) {
            hasher.write_int(self.id);
        }
    }

    let h1 = Hashable { id: 42 };
    let h2 = Hashable { id: 42 };

    let (eq, hash1, hash2) = compare_and_hash(&h1, &h2);

    assert(eq);
    assert_eq(hash1, hash2);
}

/// Test generic struct with protocol constraint
@test
fn test_generic_struct_with_bound() {
    type SortedPair<T: Ord> is { min: T, max: T };

    implement<T: Ord> SortedPair<T> {
        fn new(a: T, b: T) -> SortedPair<T> {
            if a.le(&b) {
                SortedPair { min: a, max: b }
            } else {
                SortedPair { min: b, max: a }
            }
        }
    }

    let pair = SortedPair.new(5, 3);
    assert_eq(pair.min, 3);
    assert_eq(pair.max, 5);
}

