/// Test Default implementation
@test
fn test_default_custom_type() {
    type Settings is { enabled: Bool, timeout: Int, name: Text };

    implement Default for Settings {
        fn default() -> Settings {
            Settings { enabled: true, timeout: 30, name: "" }
        }
    }

    let settings = Settings.default();

    assert_eq(settings.enabled, true);
    assert_eq(settings.timeout, 30);
    assert_eq(settings.name, "");
}

/// Test Default in generic context
@test
fn test_default_generic() {
    fn create_default<T: Default>() -> T {
        T.default()
    }

    type Wrapper is { value: Int };

    implement Default for Wrapper {
        fn default() -> Wrapper {
            Wrapper { value: 0 }
        }
    }

    let w: Wrapper = create_default();
    assert_eq(w.value, 0);
}

// =============================================================================
// Section 8: Debug Protocol
// =============================================================================

/// Test Debug implementation
@test
fn test_debug_custom_type() {
    type Person is { name: Text, age: Int };

    implement Debug for Person {
        fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
            f.write_str(&f"Person {{ name: {self.name}, age: {self.age} }}")
        }
    }

    let person = Person { name: "Alice", age: 30 };
    let debug_str = f"{person:?}";

    assert(debug_str.contains("Person"));
    assert(debug_str.contains("Alice"));
    assert(debug_str.contains("30"));
}

