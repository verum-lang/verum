/// Test Formatter write_str
@test
fn test_formatter_write_str() {
    let mut buffer = Text.new();
    let mut formatter = Formatter { buffer: &mut buffer };

    formatter.write_str(&"hello").unwrap();
    formatter.write_str(&" world").unwrap();

    assert_eq(buffer, "hello world");
}

/// Test Formatter write_char
@test
fn test_formatter_write_char() {
    let mut buffer = Text.new();
    let mut formatter = Formatter { buffer: &mut buffer };

    formatter.write_char('a').unwrap();
    formatter.write_char('b').unwrap();
    formatter.write_char('c').unwrap();

    assert_eq(buffer, "abc");
}

// =============================================================================
// Section 16: Operator Protocols - Arithmetic
// =============================================================================

/// Test Add protocol
@test
fn test_add_protocol() {
    type Vector2 is { x: Int, y: Int };

    implement Add<Vector2> for Vector2 {
        type Output = Vector2;

        fn add(self, rhs: Vector2) -> Vector2 {
            Vector2 { x: self.x + rhs.x, y: self.y + rhs.y }
        }
    }

    let v1 = Vector2 { x: 1, y: 2 };
    let v2 = Vector2 { x: 3, y: 4 };
    let sum = v1.add(v2);

    assert_eq(sum.x, 4);
    assert_eq(sum.y, 6);
}

/// Test Sub protocol
@test
fn test_sub_protocol() {
    type Vector2 is { x: Int, y: Int };

    implement Sub<Vector2> for Vector2 {
        type Output = Vector2;

        fn sub(self, rhs: Vector2) -> Vector2 {
            Vector2 { x: self.x - rhs.x, y: self.y - rhs.y }
        }
    }

    let v1 = Vector2 { x: 5, y: 7 };
    let v2 = Vector2 { x: 2, y: 3 };
    let diff = v1.sub(v2);

    assert_eq(diff.x, 3);
    assert_eq(diff.y, 4);
}

/// Test Mul protocol
@test
fn test_mul_protocol() {
    type Scalar is { value: Int };

    implement Mul<Int> for Scalar {
        type Output = Scalar;

        fn mul(self, rhs: Int) -> Scalar {
            Scalar { value: self.value * rhs }
        }
    }

    let s = Scalar { value: 5 };
    let product = s.mul(3);

    assert_eq(product.value, 15);
}

/// Test Div protocol
@test
fn test_div_protocol() {
    type Fraction is { numerator: Int, denominator: Int };

    implement Div<Int> for Fraction {
        type Output = Fraction;

        fn div(self, rhs: Int) -> Fraction {
            Fraction { numerator: self.numerator, denominator: self.denominator * rhs }
        }
    }

    let f = Fraction { numerator: 1, denominator: 2 };
    let divided = f.div(3);

    assert_eq(divided.numerator, 1);
    assert_eq(divided.denominator, 6);
}

/// Test Rem protocol
@test
fn test_rem_protocol() {
    type ModInt is { value: Int };

    implement Rem<Int> for ModInt {
        type Output = ModInt;

        fn rem(self, rhs: Int) -> ModInt {
            ModInt { value: self.value % rhs }
        }
    }

    let m = ModInt { value: 17 };
    let remainder = m.rem(5);

    assert_eq(remainder.value, 2);
}

/// Test Neg protocol
@test
fn test_neg_protocol() {
    type Signed is { value: Int };

    implement Neg for Signed {
        type Output = Signed;

        fn neg(self) -> Signed {
            Signed { value: -self.value }
        }
    }

    let s = Signed { value: 42 };
    let negated = s.neg();

    assert_eq(negated.value, -42);
}

// =============================================================================
// Section 17: Operator Protocols - Bitwise
// =============================================================================

/// Test BitAnd protocol
@test
fn test_bit_and_protocol() {
    type Flags is { bits: Int };

    implement BitAnd<Flags> for Flags {
        type Output = Flags;

        fn bitand(self, rhs: Flags) -> Flags {
            Flags { bits: self.bits & rhs.bits }
        }
    }

    let f1 = Flags { bits: 0b1100 };
    let f2 = Flags { bits: 0b1010 };
    let result = f1.bitand(f2);

    assert_eq(result.bits, 0b1000);
}

/// Test BitOr protocol
@test
fn test_bit_or_protocol() {
    type Flags is { bits: Int };

    implement BitOr<Flags> for Flags {
        type Output = Flags;

        fn bitor(self, rhs: Flags) -> Flags {
            Flags { bits: self.bits | rhs.bits }
        }
    }

    let f1 = Flags { bits: 0b1100 };
    let f2 = Flags { bits: 0b0011 };
    let result = f1.bitor(f2);

    assert_eq(result.bits, 0b1111);
}

/// Test BitXor protocol
@test
fn test_bit_xor_protocol() {
    type Bits is { value: Int };

    implement BitXor<Bits> for Bits {
        type Output = Bits;

        fn bitxor(self, rhs: Bits) -> Bits {
            Bits { value: self.value ^ rhs.value }
        }
    }

    let b1 = Bits { value: 0b1100 };
    let b2 = Bits { value: 0b1010 };
    let result = b1.bitxor(b2);

    assert_eq(result.value, 0b0110);
}

/// Test Not protocol
@test
fn test_not_protocol() {
    type Toggle is { on: Bool };

    implement Not for Toggle {
        type Output = Toggle;

        fn not(self) -> Toggle {
            Toggle { on: !self.on }
        }
    }

    let t = Toggle { on: true };
    let toggled = t.not();

    assert_eq(toggled.on, false);
}

/// Test Shl protocol
@test
fn test_shl_protocol() {
    type BitValue is { bits: Int };

    implement Shl<Int> for BitValue {
        type Output = BitValue;

        fn shl(self, rhs: Int) -> BitValue {
            BitValue { bits: self.bits << rhs }
        }
    }

    let b = BitValue { bits: 1 };
    let shifted = b.shl(4);

    assert_eq(shifted.bits, 16);
}

/// Test Shr protocol
@test
fn test_shr_protocol() {
    type BitValue is { bits: Int };

    implement Shr<Int> for BitValue {
        type Output = BitValue;

        fn shr(self, rhs: Int) -> BitValue {
            BitValue { bits: self.bits >> rhs }
        }
    }

    let b = BitValue { bits: 16 };
    let shifted = b.shr(2);

    assert_eq(shifted.bits, 4);
}

// =============================================================================
// Section 18: Index Protocols
// =============================================================================

/// Test Index protocol
@test
fn test_index_protocol() {
    type Array3 is { elements: (Int, Int, Int) };

    implement Index<Int> for Array3 {
        type Output = Int;

        fn index(&self, idx: Int) -> &Int {
            match idx {
                0 => &self.elements.0,
                1 => &self.elements.1,
                2 => &self.elements.2,
                _ => panic("Index out of bounds"),
            }
        }
    }

    let arr = Array3 { elements: (10, 20, 30) };

    assert_eq(*arr.index(0), 10);
    assert_eq(*arr.index(1), 20);
    assert_eq(*arr.index(2), 30);
}

/// Test IndexMut protocol
@test
fn test_index_mut_protocol() {
    type MutArray is { data: List<Int> };

    implement Index<Int> for MutArray {
        type Output = Int;

        fn index(&self, idx: Int) -> &Int {
            &self.data[idx]
        }
    }

    implement IndexMut<Int> for MutArray {
        fn index_mut(&mut self, idx: Int) -> &mut Int {
            &mut self.data[idx]
        }
    }

    let mut arr = MutArray { data: [1, 2, 3] };
    *arr.index_mut(1) = 100;

    assert_eq(*arr.index(1), 100);
}

