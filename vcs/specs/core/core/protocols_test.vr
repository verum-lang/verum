/// Test AsRef implementation
@test
fn test_as_ref_protocol() {
    type Wrapper is { inner: Text };

    implement AsRef<Text> for Wrapper {
        fn as_ref(&self) -> &Text {
            &self.inner
        }
    }

    let w = Wrapper { inner: "hello" };
    let text_ref: &Text = w.as_ref();

    assert_eq(*text_ref, "hello");
}

/// Test AsMut implementation
@test
fn test_as_mut_protocol() {
    type MutWrapper is { inner: Int };

    implement AsMut<Int> for MutWrapper {
        fn as_mut(&mut self) -> &mut Int {
            &mut self.inner
        }
    }

    let mut w = MutWrapper { inner: 5 };
    let int_ref: &mut Int = w.as_mut();
    *int_ref = 10;

    assert_eq(w.inner, 10);
}

// =============================================================================
// Section 13: From/Into Protocols
// =============================================================================

/// Test From implementation
@test
fn test_from_protocol() {
    type Meters is { value: Float };
    type Feet is { value: Float };

    implement From<Feet> for Meters {
        fn from(feet: Feet) -> Meters {
            Meters { value: feet.value * 0.3048 }
        }
    }

    let feet = Feet { value: 10.0 };
    let meters = Meters.from(feet);

    assert(meters.value > 3.0 && meters.value < 3.1);
}

/// Test Into via From blanket implementation
@test
fn test_into_via_from() {
    type Celsius is { temp: Float };
    type Fahrenheit is { temp: Float };

    implement From<Celsius> for Fahrenheit {
        fn from(c: Celsius) -> Fahrenheit {
            Fahrenheit { temp: c.temp * 9.0 / 5.0 + 32.0 }
        }
    }

    let celsius = Celsius { temp: 0.0 };
    let fahrenheit: Fahrenheit = celsius.into();

    assert_eq(fahrenheit.temp, 32.0);
}

// =============================================================================
// Section 14: TryFrom Protocol
// =============================================================================

/// Test TryFrom implementation
@test
fn test_try_from_protocol() {
    type Percentage is { value: Int };

    implement TryFrom<Int> for Percentage {
        type Error = Text;

        fn try_from(value: Int) -> Result<Percentage, Text> {
            if value >= 0 && value <= 100 {
                Ok(Percentage { value: value })
            } else {
                Err(f"Value {value} is not a valid percentage")
            }
        }
    }

    let valid = Percentage.try_from(50);
    assert(valid.is_ok());
    assert_eq(valid.unwrap().value, 50);

    let invalid = Percentage.try_from(150);
    assert(invalid.is_err());
}

