/// Test Display implementation
@test
fn test_display_custom_type() {
    type Currency is { amount: Int, symbol: Text };

    implement Display for Currency {
        fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
            f.write_str(&f"{self.symbol}{self.amount}")
        }
    }

    let price = Currency { amount: 100, symbol: "$" };
    let display_str = f"{price}";

    assert_eq(display_str, "$100");
}

// =============================================================================
// Section 10: Drop Protocol
// =============================================================================

/// Test Drop protocol concept
@test
fn test_drop_protocol() {
    type Resource is { id: Int, released: Bool };

    implement Drop for Resource {
        fn drop(&mut self) {
            // Mark as released (in real code, would release resources)
            self.released = true;
        }
    }

    // Note: Drop is called automatically when value goes out of scope
    let resource = Resource { id: 1, released: false };
    // When resource goes out of scope, drop() is called
}

// =============================================================================
// Section 11: Deref/DerefMut Protocols
// =============================================================================

/// Test Deref implementation
@test
fn test_deref_protocol() {
    type SmartPtr<T> is { value: T };

    implement<T> Deref for SmartPtr<T> {
        type Target = T;

        fn deref(&self) -> &T {
            &self.value
        }
    }

    let ptr = SmartPtr { value: 42 };
    let ref_val: &Int = ptr.deref();

    assert_eq(*ref_val, 42);
}

/// Test DerefMut implementation
@test
fn test_deref_mut_protocol() {
    type MutBox<T> is { value: T };

    implement<T> Deref for MutBox<T> {
        type Target = T;

        fn deref(&self) -> &T {
            &self.value
        }
    }

    implement<T> DerefMut for MutBox<T> {
        fn deref_mut(&mut self) -> &mut T {
            &mut self.value
        }
    }

    let mut box_val = MutBox { value: 10 };
    let ref_mut = box_val.deref_mut();
    *ref_mut = 20;

    assert_eq(*box_val.deref(), 20);
}

