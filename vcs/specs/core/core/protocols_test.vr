// =============================================================================
// protocols_test.vr - Comprehensive tests for core protocols
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: protocols, eq, ord, hash, clone, default, display, operators, core
// @description: Tests for core protocols: Eq, Ord, PartialOrd, Hash, Clone, etc.
// =============================================================================

mount core.base.protocols.*;
mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.base.maybe.{Maybe, Some, None};
mount core.base.result.{Result, Ok, Err};
mount core.collections.list.List;

// =============================================================================
// Section 1: Eq Protocol
// =============================================================================

/// Test Eq implementation for custom type
@test
fn test_eq_custom_type() {
    type Point is { x: Int, y: Int };

    implement Eq for Point {
        fn eq(&self, other: &Point) -> Bool {
            self.x == other.x && self.y == other.y
        }
    }

    let p1 = Point { x: 1, y: 2 };
    let p2 = Point { x: 1, y: 2 };
    let p3 = Point { x: 3, y: 4 };

    assert(p1.eq(&p2));
    assert(!p1.eq(&p3));
}

/// Test Eq default ne implementation
@test
fn test_eq_default_ne() {
    type EqVal is { n: Int };

    implement Eq for EqVal {
        fn eq(&self, other: &EqVal) -> Bool {
            self.n == other.n
        }
    }

    let v1 = EqVal { n: 42 };
    let v2 = EqVal { n: 42 };
    let v3 = EqVal { n: 99 };

    // ne should be the negation of eq
    assert(!v1.ne(&v2));  // v1 == v2, so ne is false
    assert(v1.ne(&v3));   // v1 != v3, so ne is true
}

/// Test Eq reflexivity property
@test
fn test_eq_reflexivity() {
    type Item is { id: Int };

    implement Eq for Item {
        fn eq(&self, other: &Item) -> Bool {
            self.id == other.id
        }
    }

    let item = Item { id: 100 };
    assert(item.eq(&item));  // x == x
}

/// Test Eq symmetry property
@test
fn test_eq_symmetry() {
    type SymData is { value: Int };

    implement Eq for SymData {
        fn eq(&self, other: &SymData) -> Bool {
            self.value == other.value
        }
    }

    let a = SymData { value: 5 };
    let b = SymData { value: 5 };

    assert(a.eq(&b) == b.eq(&a));  // If a == b then b == a
}

/// Test Eq transitivity property
@test
fn test_eq_transitivity() {
    type Num is { n: Int };

    implement Eq for Num {
        fn eq(&self, other: &Num) -> Bool {
            self.n == other.n
        }
    }

    let a = Num { n: 7 };
    let b = Num { n: 7 };
    let c = Num { n: 7 };

    // If a == b and b == c then a == c
    if a.eq(&b) && b.eq(&c) {
        assert(a.eq(&c));
    }
}

// =============================================================================
// Section 2: Ord Protocol
// =============================================================================

/// Test Ord implementation for custom type
@test
fn test_ord_custom_type() {
    type Score is { points: Int };

    implement Eq for Score {
        fn eq(&self, other: &Score) -> Bool {
            self.points == other.points
        }
    }

    implement Ord for Score {
        fn cmp(&self, other: &Score) -> Ordering {
            if self.points < other.points { Less }
            else if self.points > other.points { Greater }
            else { Equal }
        }
    }

    let s1 = Score { points: 100 };
    let s2 = Score { points: 200 };
    let s3 = Score { points: 100 };

    assert(s1.cmp(&s2) is Less);
    assert(s2.cmp(&s1) is Greater);
    assert(s1.cmp(&s3) is Equal);
}

/// Test Ord default lt implementation
@test
fn test_ord_default_lt() {
    type Level is { n: Int };

    implement Eq for Level {
        fn eq(&self, other: &Level) -> Bool {
            self.n == other.n
        }
    }

    implement Ord for Level {
        fn cmp(&self, other: &Level) -> Ordering {
            Ordering.from_int(self.n - other.n)
        }
    }

    let l1 = Level { n: 5 };
    let l2 = Level { n: 10 };

    assert(l1.lt(&l2));
    assert(!l2.lt(&l1));
    assert(!l1.lt(&l1));  // Not less than itself
}

/// Test Ord default le implementation
@test
fn test_ord_default_le() {
    type Rank is { value: Int };

    implement Eq for Rank {
        fn eq(&self, other: &Rank) -> Bool {
            self.value == other.value
        }
    }

    implement Ord for Rank {
        fn cmp(&self, other: &Rank) -> Ordering {
            Ordering.from_int(self.value - other.value)
        }
    }

    let r1 = Rank { value: 3 };
    let r2 = Rank { value: 5 };
    let r3 = Rank { value: 3 };

    assert(r1.le(&r2));
    assert(r1.le(&r3));  // Equal values
    assert(!r2.le(&r1));
}

/// Test Ord default gt implementation
@test
fn test_ord_default_gt() {
    type Height is { cm: Int };

    implement Eq for Height {
        fn eq(&self, other: &Height) -> Bool {
            self.cm == other.cm
        }
    }

    implement Ord for Height {
        fn cmp(&self, other: &Height) -> Ordering {
            Ordering.from_int(self.cm - other.cm)
        }
    }

    let h1 = Height { cm: 180 };
    let h2 = Height { cm: 170 };

    assert(h1.gt(&h2));
    assert(!h2.gt(&h1));
}

/// Test Ord default ge implementation
@test
fn test_ord_default_ge() {
    type Weight is { kg: Int };

    implement Eq for Weight {
        fn eq(&self, other: &Weight) -> Bool {
            self.kg == other.kg
        }
    }

    implement Ord for Weight {
        fn cmp(&self, other: &Weight) -> Ordering {
            Ordering.from_int(self.kg - other.kg)
        }
    }

    let w1 = Weight { kg: 70 };
    let w2 = Weight { kg: 60 };
    let w3 = Weight { kg: 70 };

    assert(w1.ge(&w2));
    assert(w1.ge(&w3));  // Equal
    assert(!w2.ge(&w1));
}

/// Test Ord max method
@test
fn test_ord_max() {
    type Amount is { value: Int };

    implement Eq for Amount {
        fn eq(&self, other: &Amount) -> Bool {
            self.value == other.value
        }
    }

    implement Ord for Amount {
        fn cmp(&self, other: &Amount) -> Ordering {
            Ordering.from_int(self.value - other.value)
        }
    }

    let a1 = Amount { value: 100 };
    let a2 = Amount { value: 200 };

    let max_val = a1.max(a2);
    assert_eq(max_val.value, 200);
}

/// Test Ord min method
@test
fn test_ord_min() {
    type Price is { cents: Int };

    implement Eq for Price {
        fn eq(&self, other: &Price) -> Bool {
            self.cents == other.cents
        }
    }

    implement Ord for Price {
        fn cmp(&self, other: &Price) -> Ordering {
            Ordering.from_int(self.cents - other.cents)
        }
    }

    let p1 = Price { cents: 999 };
    let p2 = Price { cents: 599 };

    let min_val = p1.min(p2);
    assert_eq(min_val.cents, 599);
}

/// Test Ord clamp method
@test
fn test_ord_clamp() {
    type Temperature is { degrees: Int };

    implement Eq for Temperature {
        fn eq(&self, other: &Temperature) -> Bool {
            self.degrees == other.degrees
        }
    }

    implement Ord for Temperature {
        fn cmp(&self, other: &Temperature) -> Ordering {
            Ordering.from_int(self.degrees - other.degrees)
        }
    }

    let low = Temperature { degrees: 0 };
    let high = Temperature { degrees: 100 };

    // Value within range
    let t1 = Temperature { degrees: 50 };
    assert_eq(t1.clamp(low, high).degrees, 50);

    // Value below range
    let t2 = Temperature { degrees: -10 };
    assert_eq(t2.clamp(low, high).degrees, 0);

    // Value above range
    let t3 = Temperature { degrees: 150 };
    assert_eq(t3.clamp(low, high).degrees, 100);
}

// =============================================================================
// Section 3: PartialOrd Protocol
// =============================================================================

/// Test PartialOrd for type with incomparable values
@test
fn test_partial_ord_incomparable() {
    // Floating point NaN example simulation
    type MaybeFloat is Valid(Float) | Invalid;

    implement Eq for MaybeFloat {
        fn eq(&self, other: &MaybeFloat) -> Bool {
            match (self, other) {
                (Valid(a), Valid(b)) => *a == *b,
                _ => false,  // Invalid never equals anything
            }
        }
    }

    implement PartialOrd for MaybeFloat {
        fn partial_cmp(&self, other: &MaybeFloat) -> Maybe<Ordering> {
            match (self, other) {
                (Valid(a), Valid(b)) => {
                    if *a < *b { Some(Less) }
                    else if *a > *b { Some(Greater) }
                    else { Some(Equal) }
                }
                _ => None,  // Invalid is incomparable
            }
        }
    }

    let v1 = Valid(1.0);
    let v2 = Valid(2.0);
    let inv = Invalid;

    assert_eq(v1.partial_cmp(&v2), Some(Less));
    assert_eq(v2.partial_cmp(&v1), Some(Greater));
    assert_eq(v1.partial_cmp(&inv), None);
    assert_eq(inv.partial_cmp(&v1), None);
}

/// Test PartialOrd default lt handles None
@test
fn test_partial_ord_lt_with_none() {
    type MaybeVal is Val(Int) | NoVal;

    implement Eq for MaybeVal {
        fn eq(&self, other: &MaybeVal) -> Bool {
            match (self, other) {
                (Val(a), Val(b)) => *a == *b,
                (NoVal, NoVal) => true,
                _ => false,
            }
        }
    }

    implement PartialOrd for MaybeVal {
        fn partial_cmp(&self, other: &MaybeVal) -> Maybe<Ordering> {
            match (self, other) {
                (Val(a), Val(b)) => Some(Ordering.from_int(*a - *b)),
                _ => None,
            }
        }
    }

    let v1 = Val(1);
    let v2 = Val(2);
    let no = NoVal;

    assert(v1.lt(&v2));
    assert(!v1.lt(&no));  // Returns false when not comparable
}

// =============================================================================
// Section 4: Hash Protocol
// =============================================================================

/// Test Hash implementation for custom type
@test
fn test_hash_custom_type() {
    type UserId is { id: Int };

    implement Hash for UserId {
        fn hash(&self, hasher: &mut Hasher) {
            hasher.write_int(self.id);
        }
    }

    let user = UserId { id: 12345 };
    let hash1 = user.hash_value();
    let hash2 = user.hash_value();

    // Same value should produce same hash
    assert_eq(hash1, hash2);
}

/// Test Hash produces different values for different inputs
@test
fn test_hash_different_values() {
    type Key is { value: Int };

    implement Hash for Key {
        fn hash(&self, hasher: &mut Hasher) {
            hasher.write_int(self.value);
        }
    }

    let k1 = Key { value: 1 };
    let k2 = Key { value: 2 };

    // Different values should (usually) produce different hashes
    // Note: This is not guaranteed but highly probable
    assert(k1.hash_value() != k2.hash_value());
}

/// Test DefaultHasher
@test
fn test_default_hasher() {
    let mut hasher = DefaultHasher.new();
    hasher.write(&[1u8, 2u8, 3u8]);
    let h1 = hasher.finish();

    let mut hasher2 = DefaultHasher.new();
    hasher2.write(&[1u8, 2u8, 3u8]);
    let h2 = hasher2.finish();

    assert_eq(h1, h2);
}

/// Test Hasher write_int
@test
fn test_hasher_write_int() {
    let mut hasher = DefaultHasher.new();
    hasher.write_int(42);
    let h1 = hasher.finish();

    let mut hasher2 = DefaultHasher.new();
    hasher2.write_int(42);
    let h2 = hasher2.finish();

    assert_eq(h1, h2);
}

/// Test Hasher write_byte
@test
fn test_hasher_write_byte() {
    let mut hasher = DefaultHasher.new();
    hasher.write_byte(0xAB as Byte);
    let h1 = hasher.finish();

    let mut hasher2 = DefaultHasher.new();
    hasher2.write_byte(0xAB as Byte);
    let h2 = hasher2.finish();

    assert_eq(h1, h2);
}

// =============================================================================
// Section 5: Clone Protocol
// =============================================================================

/// Test Clone implementation
@test
fn test_clone_custom_type() {
    type Config is { name: Text, value: Int };

    implement Clone for Config {
        fn clone(&self) -> Config {
            Config { name: self.name.clone(), value: self.value }
        }
    }

    let original = Config { name: "test", value: 42 };
    let cloned = original.clone();

    assert_eq(cloned.name, "test");
    assert_eq(cloned.value, 42);
}

/// Test Clone produces independent copy
@test
fn test_clone_independence() {
    type Counter is { count: Int };

    implement Clone for Counter {
        fn clone(&self) -> Counter {
            Counter { count: self.count }
        }
    }

    let mut original = Counter { count: 0 };
    let cloned = original.clone();

    original.count = 100;

    // Clone should not be affected
    assert_eq(cloned.count, 0);
}

/// Test clone_from method
@test
fn test_clone_from() {
    type Buffer is { data: List<Int> };

    implement Clone for Buffer {
        fn clone(&self) -> Buffer {
            Buffer { data: self.data.clone() }
        }
    }

    let source = Buffer { data: [1, 2, 3] };
    let mut target = Buffer { data: [] };

    target.clone_from(&source);

    assert_eq(target.data, [1, 2, 3]);
}

// =============================================================================
// Section 6: Copy Protocol
// =============================================================================

/// Test Copy marker for trivially copyable type
@test
fn test_copy_marker() {
    type Coordinate is { x: Int, y: Int };

    implement Clone for Coordinate {
        fn clone(&self) -> Coordinate {
            Coordinate { x: self.x, y: self.y }
        }
    }

    implement Copy for Coordinate {}

    fn takes_copy<T: Copy>(val: T) -> T {
        val
    }

    let coord = Coordinate { x: 10, y: 20 };
    let copied = takes_copy(coord);

    // Original is still usable (not moved)
    assert_eq(coord.x, 10);
    assert_eq(copied.x, 10);
}

