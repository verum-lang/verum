/// Test Zero protocol
@test
fn test_zero_protocol() {
    type Natural is { value: Int };

    implement Zero for Natural {
        fn zero() -> Natural {
            Natural { value: 0 }
        }

        fn is_zero(&self) -> Bool {
            self.value == 0
        }
    }

    let zero = Natural.zero();
    assert(zero.is_zero());
    assert_eq(zero.value, 0);

    let nonzero = Natural { value: 5 };
    assert(!nonzero.is_zero());
}

/// Test One protocol
@test
fn test_one_protocol() {
    type Natural is { value: Int };

    implement One for Natural {
        fn one() -> Natural {
            Natural { value: 1 }
        }

        fn is_one(&self) -> Bool {
            self.value == 1
        }
    }

    let one = Natural.one();
    assert(one.is_one());
    assert_eq(one.value, 1);

    let other = Natural { value: 2 };
    assert(!other.is_one());
}

