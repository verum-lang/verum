// =============================================================================
// Section 30: Integration - Combined Protocol Usage
// =============================================================================

/// Test real-world example: Sortable collection item
@test
fn test_sortable_collection_item() {
    type Item is { priority: Int, name: Text };

    implement Eq for Item {
        fn eq(&self, other: &Item) -> Bool {
            self.priority == other.priority && self.name == other.name
        }
    }

    implement Ord for Item {
        fn cmp(&self, other: &Item) -> Ordering {
            // Sort by priority first, then by name
            Ordering.from_int(self.priority - other.priority)
                .then(if self.name < other.name { Less }
                      else if self.name > other.name { Greater }
                      else { Equal })
        }
    }

    implement Clone for Item {
        fn clone(&self) -> Item {
            Item { priority: self.priority, name: self.name.clone() }
        }
    }

    implement Hash for Item {
        fn hash(&self, hasher: &mut Hasher) {
            hasher.write_int(self.priority);
            hasher.write(self.name.as_bytes());
        }
    }

    implement Default for Item {
        fn default() -> Item {
            Item { priority: 0, name: "" }
        }
    }

    implement Debug for Item {
        fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
            f.write_str(&f"Item {{ priority: {self.priority}, name: {self.name} }}")
        }
    }

    // Use the item with various protocols
    let item1 = Item { priority: 1, name: "first" };
    let item2 = Item { priority: 2, name: "second" };
    let item3 = item1.clone();

    assert(item1.lt(&item2));  // Ord
    assert(item1.eq(&item3));  // Eq
    assert_eq(item1.hash_value(), item3.hash_value());  // Hash

    let default_item = Item.default();
    assert_eq(default_item.priority, 0);  // Default
}

/// Test numeric operations example
@test
fn test_numeric_operations_example() {
    type Complex is { real: Float, imag: Float };

    implement Eq for Complex {
        fn eq(&self, other: &Complex) -> Bool {
            self.real == other.real && self.imag == other.imag
        }
    }

    implement Add<Complex> for Complex {
        type Output = Complex;
        fn add(self, rhs: Complex) -> Complex {
            Complex { real: self.real + rhs.real, imag: self.imag + rhs.imag }
        }
    }

    implement Sub<Complex> for Complex {
        type Output = Complex;
        fn sub(self, rhs: Complex) -> Complex {
            Complex { real: self.real - rhs.real, imag: self.imag - rhs.imag }
        }
    }

    implement Mul<Complex> for Complex {
        type Output = Complex;
        fn mul(self, rhs: Complex) -> Complex {
            Complex {
                real: self.real * rhs.real - self.imag * rhs.imag,
                imag: self.real * rhs.imag + self.imag * rhs.real,
            }
        }
    }

    implement Zero for Complex {
        fn zero() -> Complex { Complex { real: 0.0, imag: 0.0 } }
        fn is_zero(&self) -> Bool { self.real == 0.0 && self.imag == 0.0 }
    }

    implement One for Complex {
        fn one() -> Complex { Complex { real: 1.0, imag: 0.0 } }
        fn is_one(&self) -> Bool { self.real == 1.0 && self.imag == 0.0 }
    }

    let c1 = Complex { real: 3.0, imag: 4.0 };
    let c2 = Complex { real: 1.0, imag: 2.0 };

    let sum = c1.add(c2);
    assert_eq(sum.real, 4.0);
    assert_eq(sum.imag, 6.0);

    let zero = Complex.zero();
    assert(zero.is_zero());

    let one = Complex.one();
    assert(one.is_one());
}

