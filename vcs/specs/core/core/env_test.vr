@test
fn test_set_var_basic() {
    let key = "__VERUM_TEST_VAR_SET_1__";
    let value = "test_value_123";

    // Set the variable
    set_var(&key, &value);

    // This may not work on all platforms (esp. Linux without libc)
    // So we just verify no panic
}

@test
fn test_remove_var_basic() {
    let key = "__VERUM_TEST_VAR_REMOVE_1__";

    // Remove the variable (may or may not exist)
    remove_var(&key);

    // Just verify no panic
}

@test
fn test_set_then_get() {
    let key = "__VERUM_TEST_SET_GET__";
    let value = "hello_world";

    set_var(&key, &value);

    // On platforms that support setenv, this should work
    let result = var_opt(&key);

    // Result depends on platform support
    // Don't assert, just verify operation doesn't panic
}

@test
fn test_set_overwrite() {
    let key = "__VERUM_TEST_OVERWRITE__";

    set_var(&key, &"first_value");
    set_var(&key, &"second_value");

    // If supported, second value should overwrite
}

@test
fn test_set_empty_value() {
    let key = "__VERUM_TEST_EMPTY_VAL__";

    set_var(&key, &"");

    // Empty value is valid
}

@test
fn test_remove_nonexistent() {
    let key = "__VERUM_TEST_REMOVE_NONEXISTENT__";

    // Removing non-existent var should not panic
    remove_var(&key);
}

