// =============================================================================
// Section 21: Error Message Quality Tests
// =============================================================================

@test
fn test_var_error_debuggable() {
    let error = VarError.NotPresent;

    // Error should be usable in error messages
    // (Full Debug impl would be in protocols)
}

@test
fn test_var_error_not_unicode_preserves_bytes() {
    let bad_bytes: List<Byte> = [0x80, 0x81, 0x82];
    let error = VarError.NotUnicode(bad_bytes.clone());

    match error {
        VarError.NotUnicode(bytes) => {
            assert_eq(bytes.len(), 3);
            assert_eq(bytes[0], 0x80);
            assert_eq(bytes[1], 0x81);
            assert_eq(bytes[2], 0x82);
        }
        _ => panic("expected NotUnicode"),
    }
}

// =============================================================================
// Section 22: Functional Composition Tests
// =============================================================================

@test
fn test_args_map_transform() {
    let all = args();

    // Transform arguments
    let lengths: List<Int> = all.iter()
        .map(|a: &Text| a.len() as Int)
        .collect();

    assert_eq(lengths.len(), all.len());
}

@test
fn test_args_filter() {
    let all = args();

    // Filter arguments manually without complex chaining
    let mut non_empty: List<Text> = List.new();
    for a in all.iter() {
        if a.len() > 0 {
            non_empty.push(a.clone());
        }
    }

    // All args should be non-empty
    assert_eq(non_empty.len(), all.len());
}

@test
fn test_var_opt_map() {
    let transformed = var_opt(&"PATH").map(|p: Text| p.len());

    // Result is Maybe<Int> (len() returns Int)
    let _: Maybe<Int> = transformed;
}

// =============================================================================
// Section 23: Memory Safety Tests
// =============================================================================

@test
fn test_arg_string_ownership() {
    let a1 = arg(0);
    let a2 = arg(0);

    // Each call returns owned Text
    match (a1, a2) {
        (Some(s1), Some(s2)) => {
            assert_eq(s1, s2);
            // Modifying one shouldn't affect the other
        }
        _ => panic("arg(0) should return Some"),
    }
}

@test
fn test_args_list_ownership() {
    let list1 = args();
    let list2 = args();

    // Each call returns new owned list
    assert_eq(list1.len(), list2.len());
}

@test
fn test_var_string_ownership() {
    let v1 = var_opt(&"PATH");
    let v2 = var_opt(&"PATH");

    // Each call returns owned Text
    match (v1, v2) {
        (Some(s1), Some(s2)) => {
            assert_eq(s1, s2);
        }
        _ => {
            // PATH not set is fine for this test
        }
    }
}

// =============================================================================
// Section 24: Integration Patterns
// =============================================================================

@test
fn test_typical_arg_parsing_pattern() {
    let all = args();

    // Typical pattern: program name + subcommand + flags
    if all.len() >= 1 {
        let _program = &all[0];
    }
    if all.len() >= 2 {
        let _subcommand = &all[1];
    }
}

@test
fn test_typical_config_pattern() {
    // Common pattern: check env var with default
    let debug_mode = var_opt(&"DEBUG").is_some();
    let log_level = var_opt(&"LOG_LEVEL").unwrap_or("info");

    // Both should work
    let _: Bool = debug_mode;
    let _: Text = log_level;
}

// =============================================================================
// Section 25: Stress and Boundary Tests
// =============================================================================

@test
fn test_many_var_lookups() {
    // Many lookups should be efficient
    let mut i = 0;
    while i < 100 {
        let key = f"__VERUM_STRESS_TEST_{i}__";
        let _ = var_opt(&key);
        i = i + 1;
    }
}

@test
fn test_repeated_temp_dir() {
    // Should return same value
    let t1 = temp_dir();
    let t2 = temp_dir();
    assert_eq(t1, t2);
}

@test
fn test_arg_boundary_values() {
    let count = args_count();

    // Test around boundaries
    assert(arg(-1).is_none());
    assert(arg(0).is_some());
    if count > 0 {
        assert(arg(count - 1).is_some());
    }
    assert(arg(count).is_none());
    assert(arg(count + 1).is_none());
    assert(arg(Int.MAX).is_none());
}
