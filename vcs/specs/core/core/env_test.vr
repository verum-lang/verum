@test
fn test_concurrent_var_reads() {
    // Multiple reads should be safe
    let _ = var_opt(&"PATH");
    let _ = var_opt(&"HOME");
    let _ = var_opt(&"USER");

    // All reads should succeed without data races
}

@test
fn test_repeated_args_calls() {
    // Calling args() multiple times should be consistent
    let a1 = args();
    let a2 = args();

    assert_eq(a1.len(), a2.len());

    let mut i = 0;
    while i < a1.len() {
        assert_eq(a1[i], a2[i]);
        i = i + 1;
    }
}

// =============================================================================
// Section 14: VarError Pattern Matching Tests
// =============================================================================

@test
fn test_var_error_exhaustive_match() {
    fn handle_error(e: VarError) -> Text {
        match e {
            VarError.NotPresent => "not present",
            VarError.NotUnicode(bytes) => f"not unicode: {bytes.len()} bytes",
        }
    }

    let e1 = VarError.NotPresent;
    assert_eq(handle_error(e1), "not present");

    let e2 = VarError.NotUnicode([0xFF]);
    assert(handle_error(e2).starts_with("not unicode"));
}

