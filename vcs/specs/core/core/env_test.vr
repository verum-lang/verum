// =============================================================================
// Section 11: Args Iterator Edge Cases
// =============================================================================

@test
fn test_args_iterator_clone() {
    let iter1 = args_os();
    // Args should be clonable if iterator is
}

@test
fn test_args_iterator_multiple_iterations() {
    // Each call to args_os creates fresh iterator
    let iter1 = args_os();
    let iter2 = args_os();

    let (lower1, _) = iter1.size_hint();
    let (lower2, _) = iter2.size_hint();

    assert_eq(lower1, lower2, "multiple iterators should have same count");
}

@test
fn test_args_iterator_partial_consumption() {
    let mut iter = args_os();

    // Consume one
    let first = iter.next();

    // Size hint should reflect remaining
    let (lower, upper) = iter.size_hint();
    let original_count = args_count();

    assert_eq(lower, original_count - 1);
    assert_eq(upper, Some(original_count - 1));
}

