@test
fn test_skip_program_name() {
    // Common pattern: skip first argument
    let all = args();

    if all.len() > 1 {
        let user_args = all[1..];
        // Verify slice works
    }
}

@test
fn test_iterate_with_index() {
    let all = args();

    for (i, a) in all.iter().enumerate() {
        // Index should match position
        let direct = arg(i as Int);
        match direct {
            Some(d) => assert_eq(a, d),
            None => panic("mismatch in iteration"),
        }
    }
}

// =============================================================================
// Section 17: Result/Maybe Integration Tests
// =============================================================================

@test
fn test_var_result_ok_path() {
    // When var exists, Result is Ok
    // We can't guarantee any var exists, so just test the type
    let result: Result<Text, VarError> = var(&"PATH");

    // Either Ok or Err is valid
    match result {
        Ok(value) => {
            // Value should be usable
            let _ = value.len();
        }
        Err(_) => {
            // PATH not set is unusual but valid
        }
    }
}

@test
fn test_var_opt_maybe_some_path() {
    let maybe: Maybe<Text> = var_opt(&"PATH");

    match maybe {
        Some(value) => {
            let _ = value.len();
        }
        None => {
            // Valid
        }
    }
}

@test
fn test_chained_var_opt() {
    // Pattern: try multiple vars
    let value = var_opt(&"HOME")
        .or_else(|| var_opt(&"USERPROFILE"))
        .or_else(|| var_opt(&"HOMEPATH"));

    // Chain should work without panic
}

