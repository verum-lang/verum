// =============================================================================
// env_test.vr - Comprehensive tests for core/env.vr
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: env, process, arguments, environment, system
// @timeout: 30000
// =============================================================================
//
// Tests for environment and process operations:
// - Command line arguments
// - Environment variables
// - Process control
// - Standard environment helpers
//
// =============================================================================

module env_test;

// Import env functions from core.base where they are re-exported
mount core.base.{
    args, arg, args_count, args_os, Args,
    var, var_opt, set_var, remove_var, VarError,
    exit, exit_success, exit_failure,
    home_dir, user, path, temp_dir, shell, locale,
};
mount core.{Maybe, Result, List, Text, Byte};

// =============================================================================
// Section 1: VarError Type Tests
// =============================================================================

@test
fn test_var_error_not_present() {
    let error: VarError = VarError.NotPresent;

    match error {
        VarError.NotPresent => {}, // Expected
        VarError.NotUnicode(_) => panic("expected NotPresent"),
    }
}

@test
fn test_var_error_not_unicode() {
    let bad_bytes: List<Byte> = [0xFF, 0xFE, 0x00];
    let error: VarError = VarError.NotUnicode(bad_bytes);

    match error {
        VarError.NotPresent => panic("expected NotUnicode"),
        VarError.NotUnicode(bytes) => {
            assert_eq(bytes.len(), 3);
        }
    }
}

// =============================================================================
// Section 2: Command Line Arguments Count Tests
// =============================================================================

@test
fn test_args_count_minimum() {
    // Process always has at least the program name as argument
    let count = args_count();
    assert(count >= 1, "should have at least one argument (program name)");
}

@test
fn test_args_count_consistency() {
    // Multiple calls should return same value
    let count1 = args_count();
    let count2 = args_count();
    assert_eq(count1, count2);
}

// =============================================================================
// Section 3: Single Argument Access Tests
// =============================================================================

@test
fn test_arg_first() {
    // First argument should be program name
    let first = arg(0);
    assert(first.is_some(), "first argument should exist");
}

@test
fn test_arg_negative_index() {
    // Negative index should return None
    let result = arg(-1);
    assert(result.is_none(), "negative index should return None");
}

@test
fn test_arg_large_index() {
    // Index beyond args count should return None
    let count = args_count();
    let result = arg(count + 100);
    assert(result.is_none(), "index beyond count should return None");
}

@test
fn test_arg_exact_boundary() {
    // Index exactly at count should return None
    let count = args_count();
    let result = arg(count);
    assert(result.is_none(), "index at exact count should return None");
}

@test
fn test_arg_last_valid() {
    // Last valid index should return Some
    let count = args_count();
    if count > 0 {
        let result = arg(count - 1);
        assert(result.is_some(), "last valid index should return Some");
    }
}

// =============================================================================
// Section 4: Full Arguments List Tests
// =============================================================================

@test
fn test_args_returns_list() {
    let all_args = args();
    assert(all_args.len() >= 1, "args should return at least program name");
}

@test
fn test_args_matches_count() {
    let all_args = args();
    let count = args_count();
    assert_eq(all_args.len() as Int, count);
}

@test
fn test_args_first_matches_arg_zero() {
    let all_args = args();
    let first_arg = arg(0);

    match first_arg {
        Some(expected) => {
            assert_eq(all_args[0], expected);
        }
        None => panic("arg(0) should return Some"),
    }
}

// =============================================================================
// Section 5: Args Iterator Tests
// =============================================================================

@test
fn test_args_os_iterator() {
    let iter = args_os();
    // Iterator should be created without panic
}

@test
fn test_args_os_size_hint() {
    let iter = args_os();
    let (lower, upper) = iter.size_hint();

    assert(lower >= 0, "lower bound should be non-negative");
    assert(upper.is_some(), "upper bound should be known");

    match upper {
        Some(u) => assert_eq(lower, u, "exact size should be known"),
        None => panic("upper bound should be Some"),
    }
}

@test
fn test_args_os_matches_args() {
    let iter = args_os();
    let direct = args();

    let mut collected = List.new();
    for a in iter {
        collected.push(a);
    }

    assert_eq(collected.len(), direct.len());
    let mut idx = 0;
    while idx < collected.len() {
        assert_eq(collected[idx], direct[idx]);
        idx = idx + 1;
    }
}

@test
fn test_args_iterator_next() {
    let mut iter = args_os();

    // First call should return program name
    let first = iter.next();
    assert(first.is_some(), "first next() should return Some");
}

@test
fn test_args_iterator_exhaustion() {
    let mut iter = args_os();
    let count = args_count();

    // Consume all arguments
    for _ in 0..count {
        let _ = iter.next();
    }

    // Next call should return None
    let extra = iter.next();
    assert(extra.is_none(), "exhausted iterator should return None");
}

// =============================================================================
// Section 6: Environment Variable Retrieval Tests
// =============================================================================

@test
fn test_var_not_present() {
    // Non-existent variable should return NotPresent error
    let result = var(&"__VERUM_TEST_DEFINITELY_NOT_SET_12345__");

    match result {
        Ok(_) => panic("should return Err for non-existent var"),
        Err(VarError.NotPresent) => {}, // Expected
        Err(_) => panic("expected NotPresent error"),
    }
}

@test
fn test_var_opt_not_present() {
    // Non-existent variable should return None
    let result = var_opt(&"__VERUM_TEST_DEFINITELY_NOT_SET_54321__");
    assert(result.is_none(), "non-existent var should return None");
}

@test
fn test_var_empty_key() {
    // Empty key should return NotPresent (or error depending on OS)
    let result = var(&"");
    // Either Ok or Err is acceptable, just don't panic
}

