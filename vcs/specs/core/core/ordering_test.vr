// Section 12: from_int()
// =============================================================================

/// Test from_int negative returns Less
@test
fn test_from_int_negative() {
    assert_eq(Ordering.from_int(-1), Less);
    assert_eq(Ordering.from_int(-100), Less);
    assert_eq(Ordering.from_int(-999999), Less);
}

/// Test from_int zero returns Equal
@test
fn test_from_int_zero() {
    assert_eq(Ordering.from_int(0), Equal);
}

/// Test from_int positive returns Greater
@test
fn test_from_int_positive() {
    assert_eq(Ordering.from_int(1), Greater);
    assert_eq(Ordering.from_int(100), Greater);
    assert_eq(Ordering.from_int(999999), Greater);
}

/// Test from_int and to_int are compatible
@test
fn test_from_int_to_int_compatible() {
    // from_int(to_int(x)) == x for all x
    assert_eq(Ordering.from_int(Less.to_int()), Less);
    assert_eq(Ordering.from_int(Equal.to_int()), Equal);
    assert_eq(Ordering.from_int(Greater.to_int()), Greater);
}

/// Test from_int for typical subtraction comparison
@test
fn test_from_int_subtraction_pattern() {
    // Common pattern: from_int(a - b) for comparing a and b
    fn compare_via_subtraction(a: Int, b: Int) -> Ordering {
        Ordering.from_int(a - b)
    }

    assert_eq(compare_via_subtraction(1, 2), Less);
    assert_eq(compare_via_subtraction(2, 2), Equal);
    assert_eq(compare_via_subtraction(3, 2), Greater);
}

