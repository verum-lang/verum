// Section 8: reverse()
// =============================================================================

/// Test reverse Less becomes Greater
@test
fn test_reverse_less() {
    assert_eq(Less.reverse(), Greater);
}

/// Test reverse Equal stays Equal
@test
fn test_reverse_equal() {
    assert_eq(Equal.reverse(), Equal);
}

/// Test reverse Greater becomes Less
@test
fn test_reverse_greater() {
    assert_eq(Greater.reverse(), Less);
}

/// Test reverse is self-inverse (reverse(reverse(x)) == x)
@test
fn test_reverse_self_inverse() {
    assert_eq(Less.reverse().reverse(), Less);
    assert_eq(Equal.reverse().reverse(), Equal);
    assert_eq(Greater.reverse().reverse(), Greater);
}

/// Test reverse maintains symmetry
@test
fn test_reverse_symmetry() {
    // If a.cmp(b) = ord, then b.cmp(a) = ord.reverse()
    // Simulated with values
    assert_eq(Less.reverse(), Greater);
    assert_eq(Greater.reverse(), Less);
}

// =============================================================================
// Section 9: then() - Lexicographic Chaining
// =============================================================================

/// Test then with Less returns Less (ignores second)
@test
fn test_then_less_first() {
    assert_eq(Less.then(Less), Less);
    assert_eq(Less.then(Equal), Less);
    assert_eq(Less.then(Greater), Less);
}

/// Test then with Greater returns Greater (ignores second)
@test
fn test_then_greater_first() {
    assert_eq(Greater.then(Less), Greater);
    assert_eq(Greater.then(Equal), Greater);
    assert_eq(Greater.then(Greater), Greater);
}

/// Test then with Equal returns second ordering
@test
fn test_then_equal_defers() {
    assert_eq(Equal.then(Less), Less);
    assert_eq(Equal.then(Equal), Equal);
    assert_eq(Equal.then(Greater), Greater);
}

/// Test then for lexicographic comparison simulation
@test
fn test_then_lexicographic() {
    // Simulating comparison of (1, 2) vs (1, 3)
    // First components equal, second decides

    fn compare_pairs(a: (Int, Int), b: (Int, Int)) -> Ordering {
        compare_int(a.0, b.0).then(compare_int(a.1, b.1))
    }

    fn compare_int(a: Int, b: Int) -> Ordering {
        if a < b { Less }
        else if a > b { Greater }
        else { Equal }
    }

    assert_eq(compare_pairs((1, 2), (1, 3)), Less);
    assert_eq(compare_pairs((1, 3), (1, 2)), Greater);
    assert_eq(compare_pairs((1, 2), (1, 2)), Equal);
    assert_eq(compare_pairs((0, 5), (1, 0)), Less);  // First component decides
    assert_eq(compare_pairs((2, 0), (1, 9)), Greater);  // First component decides
}

/// Test then chaining multiple times
@test
fn test_then_multiple_chain() {
    // Simulating (a, b, c) comparison

    fn compare_triple(x: (Int, Int, Int), y: (Int, Int, Int)) -> Ordering {
        compare_int(x.0, y.0)
            .then(compare_int(x.1, y.1))
            .then(compare_int(x.2, y.2))
    }

    fn compare_int(a: Int, b: Int) -> Ordering {
        if a < b { Less }
        else if a > b { Greater }
        else { Equal }
    }

    assert_eq(compare_triple((1, 2, 3), (1, 2, 3)), Equal);
    assert_eq(compare_triple((1, 2, 3), (1, 2, 4)), Less);
    assert_eq(compare_triple((1, 2, 3), (1, 3, 0)), Less);
    assert_eq(compare_triple((2, 0, 0), (1, 9, 9)), Greater);
}

// =============================================================================
// Section 10: then_with() - Lazy Lexicographic Chaining
// =============================================================================

/// Test then_with with Less doesn't evaluate function
@test
fn test_then_with_less_short_circuits() {
    let mut called = false;
    let result = Less.then_with(|| {
        called = true;
        Greater
    });

    assert_eq(result, Less);
    assert(!called);  // Function was NOT called
}

/// Test then_with with Greater doesn't evaluate function
@test
fn test_then_with_greater_short_circuits() {
    let mut called = false;
    let result = Greater.then_with(|| {
        called = true;
        Less
    });

    assert_eq(result, Greater);
    assert(!called);  // Function was NOT called
}

/// Test then_with with Equal evaluates function
@test
fn test_then_with_equal_evaluates() {
    let mut called = false;
    let result = Equal.then_with(|| {
        called = true;
        Less
    });

    assert_eq(result, Less);
    assert(called);  // Function WAS called
}

/// Test then_with for lazy comparison
@test
fn test_then_with_lazy_comparison() {
    type ExpensiveData is { id: Int, expensive_field: List<Int> };

    fn cheap_compare(a: &ExpensiveData, b: &ExpensiveData) -> Ordering {
        if a.id < b.id { Less }
        else if a.id > b.id { Greater }
        else { Equal }
    }

    fn expensive_compare(a: &ExpensiveData, b: &ExpensiveData) -> Ordering {
        // This would be expensive - only called if needed
        // Use manual sum to avoid .sum() method resolution issue
        let mut a_sum: Int = 0;
        for x in a.expensive_field.iter() { a_sum = a_sum + *x; }
        let mut b_sum: Int = 0;
        for x in b.expensive_field.iter() { b_sum = b_sum + *x; }
        if a_sum < b_sum { Less }
        else if a_sum > b_sum { Greater }
        else { Equal }
    }

    let a = ExpensiveData { id: 1, expensive_field: [1, 2, 3] };
    let b = ExpensiveData { id: 2, expensive_field: [4, 5, 6] };

    // Different ids - expensive compare not needed
    let result = cheap_compare(&a, &b).then_with(|| expensive_compare(&a, &b));
    assert_eq(result, Less);  // Decided by cheap compare

    // Same ids - expensive compare needed
    let c = ExpensiveData { id: 1, expensive_field: [1, 1, 1] };  // sum = 3
    let d = ExpensiveData { id: 1, expensive_field: [2, 2, 2] };  // sum = 6

    let result2 = cheap_compare(&c, &d).then_with(|| expensive_compare(&c, &d));
    assert_eq(result2, Less);  // Decided by expensive compare
}

