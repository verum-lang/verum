@test
fn test_is_equal_true() {
    assert(Equal.is_equal());
}

/// Test is_equal returns false for Less
@test
fn test_is_equal_false_less() {
    assert(!Less.is_equal());
}

/// Test is_equal returns false for Greater
@test
fn test_is_equal_false_greater() {
    assert(!Greater.is_equal());
}

