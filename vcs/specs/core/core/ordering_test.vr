/// Test clone produces equal value
@test
fn test_clone_produces_equal() {
    let original = Less;
    let cloned = original.clone();
    assert_eq(original, cloned);

    let original2 = Equal;
    let cloned2 = original2.clone();
    assert_eq(original2, cloned2);

    let original3 = Greater;
    let cloned3 = original3.clone();
    assert_eq(original3, cloned3);
}

/// Test clone is independent
@test
fn test_clone_is_independent() {
    let mut original = Less;
    let cloned = original.clone();

    // Changing original doesn't affect clone
    original = Greater;
    assert_eq(cloned, Less);
}

