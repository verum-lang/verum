/// Test to_int for Less
@test
fn test_to_int_less() {
    assert_eq(Less.to_int(), -1);
}

/// Test to_int for Equal
@test
fn test_to_int_equal() {
    assert_eq(Equal.to_int(), 0);
}

/// Test to_int for Greater
@test
fn test_to_int_greater() {
    assert_eq(Greater.to_int(), 1);
}

/// Test to_int values are ordered correctly
@test
fn test_to_int_ordering() {
    assert(Less.to_int() < Equal.to_int());
    assert(Equal.to_int() < Greater.to_int());
}

