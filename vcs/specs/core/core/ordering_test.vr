// Section 19: Pattern Matching
// =============================================================================

/// Test exhaustive pattern matching
@test
fn test_pattern_matching_exhaustive() {
    fn describe(ord: Ordering) -> Text {
        match ord {
            Less => "less than",
            Equal => "equal to",
            Greater => "greater than",
        }
    }

    assert_eq(describe(Less), "less than");
    assert_eq(describe(Equal), "equal to");
    assert_eq(describe(Greater), "greater than");
}

/// Test is pattern
@test
fn test_is_pattern() {
    let ord = Less;
    assert(ord is Less);
    assert(!(ord is Equal));
    assert(!(ord is Greater));
}

/// Test match in conditional context
@test
fn test_match_in_if() {
    fn is_not_equal(ord: Ordering) -> Bool {
        if ord is Less || ord is Greater {
            true
        } else {
            false
        }
    }

    assert(is_not_equal(Less));
    assert(is_not_equal(Greater));
    assert(!is_not_equal(Equal));
}

// =============================================================================
// Section 20: Integration - Sorting Use Case
// =============================================================================

/// Test Ordering used in sorting comparisons
@test
fn test_sorting_with_ordering() {
    fn compare_int(a: Int, b: Int) -> Ordering {
        if a < b { Less }
        else if a > b { Greater }
        else { Equal }
    }

    // Simulate sorting logic
    fn should_swap(ord: Ordering) -> Bool {
        ord.is_greater()
    }

    // For ascending sort
    assert(should_swap(compare_int(5, 3)));  // 5 > 3, swap for ascending
    assert(!should_swap(compare_int(3, 5))); // 3 < 5, no swap
    assert(!should_swap(compare_int(3, 3))); // equal, no swap
}

/// Test Ordering for custom sort order
@test
fn test_custom_sort_order() {
    type Person is { name: Text, age: Int };

    // Sort by age descending, then name ascending
    fn compare_person(a: &Person, b: &Person) -> Ordering {
        // Age descending: reverse the comparison
        let age_cmp = if a.age < b.age { Greater }
                     else if a.age > b.age { Less }
                     else { Equal };

        // Name ascending
        let name_cmp = if a.name < b.name { Less }
                      else if a.name > b.name { Greater }
                      else { Equal };

        age_cmp.then(name_cmp)
    }

    let alice = Person { name: "Alice", age: 30 };
    let bob = Person { name: "Bob", age: 25 };
    let charlie = Person { name: "Charlie", age: 30 };

    // Alice vs Bob: Alice older -> Less (comes first in descending age)
    assert_eq(compare_person(&alice, &bob), Less);

    // Alice vs Charlie: Same age, Alice < Charlie alphabetically
    assert_eq(compare_person(&alice, &charlie), Less);

    // Charlie vs Alice: Same age, Charlie > Alice alphabetically
    assert_eq(compare_person(&charlie, &alice), Greater);
}

// =============================================================================
// Section 21: Integration - Binary Search
// =============================================================================

/// Test Ordering in binary search
@test
fn test_binary_search_with_ordering() {
    fn binary_search(arr: &List<Int>, target: Int) -> Maybe<Int> {
        let mut low = 0;
        let mut high = arr.len() - 1;

        while low <= high {
            let mid = (low + high) / 2;
            let cmp = compare_int(arr[mid], target);

            match cmp {
                Less => low = mid + 1,
                Greater => high = mid - 1,
                Equal => return Some(mid),
            }
        }
        None
    }

    fn compare_int(a: Int, b: Int) -> Ordering {
        if a < b { Less }
        else if a > b { Greater }
        else { Equal }
    }

    let arr = [1, 3, 5, 7, 9, 11, 13];

    assert_eq(binary_search(&arr, 7), Some(3));
    assert_eq(binary_search(&arr, 1), Some(0));
    assert_eq(binary_search(&arr, 13), Some(6));
    assert_eq(binary_search(&arr, 6), None);
    assert_eq(binary_search(&arr, 0), None);
}

// =============================================================================
// Section 22: Integration - Three-Way Comparison Utility
// =============================================================================

/// Test three-way comparison for various types
@test
fn test_three_way_compare() {
    fn cmp_int(a: Int, b: Int) -> Ordering {
        Ordering.from_int(a - b)
    }

    fn cmp_text(a: &Text, b: &Text) -> Ordering {
        if *a < *b { Less }
        else if *a > *b { Greater }
        else { Equal }
    }

    // Integers
    assert_eq(cmp_int(1, 2), Less);
    assert_eq(cmp_int(2, 2), Equal);
    assert_eq(cmp_int(3, 2), Greater);

    // Text
    assert_eq(cmp_text(&"apple", &"banana"), Less);
    assert_eq(cmp_text(&"apple", &"apple"), Equal);
    assert_eq(cmp_text(&"banana", &"apple"), Greater);
}

// =============================================================================
// Section 23: Edge Cases
// =============================================================================

/// Test reverse on all variants preserves round-trip through reverse
@test
fn test_reverse_roundtrip_all() {
    let orderings: List<Ordering> = [Less, Equal, Greater];
    for ord in orderings.iter() {
        // Explicit dereference needed for methods taking self by value on iterator items
        let reversed_twice = (*ord).reverse().reverse();
        assert_eq(*ord, reversed_twice);
    }
}

/// Test then is associative
@test
fn test_then_associative() {
    let orderings: List<Ordering> = [Less, Equal, Greater];
    for a in orderings.iter() {
        for b in orderings.iter() {
            for c in orderings.iter() {
                // (a.then(b)).then(c) == a.then(b.then(c))
                // Explicit dereference needed for methods taking self by value
                let left = (*a).then(*b).then(*c);
                let right = (*a).then((*b).then(*c));
                assert_eq(left, right);
            }
        }
    }
}

/// Test from_int edge cases
@test
fn test_from_int_edge_cases() {
    assert_eq(Ordering.from_int(Int.min_value()), Less);
    assert_eq(Ordering.from_int(Int.max_value()), Greater);
}

/// Test Default in collection context
@test
fn test_default_in_collection() {
    let mut orderings: List<Ordering> = [];
    orderings.push(Ordering.default());
    orderings.push(Ordering.default());

    assert_eq(orderings[0], Equal);
    assert_eq(orderings[1], Equal);
}

// =============================================================================
// Section 24: Ordering in Functional Patterns
// =============================================================================

/// Test mapping over Ordering
@test
fn test_ordering_in_map() {
    let orderings: List<Ordering> = [Less, Equal, Greater];
    // Use explicit for-loop instead of iterator adapter due to closure type inference
    let mut ints: List<Int> = [];
    for o in orderings.iter() {
        ints.push((*o).to_int());
    }
    assert_eq(ints, [-1, 0, 1]);
}

/// Test filtering by Ordering
@test
fn test_ordering_in_filter() {
    let orderings: List<Ordering> = [Less, Equal, Greater, Less, Equal];
    // Use explicit for-loop instead of iterator adapter due to closure type inference
    let mut non_equal: List<Ordering> = [];
    for o in orderings.iter() {
        if !(*o).is_equal() {
            non_equal.push(*o);
        }
    }
    assert_eq(non_equal, [Less, Greater, Less]);
}

/// Test fold with Ordering
@test
fn test_ordering_fold() {
    // Simulate finding the "minimum" ordering in a sequence
    // (where Less < Equal < Greater)
    let orderings: List<Ordering> = [Greater, Equal, Less, Greater];

    // Use explicit for-loop instead of fold due to closure type inference
    let mut min_ord: Ordering = Greater;
    for ord in orderings.iter() {
        if (*ord).to_int() < min_ord.to_int() {
            min_ord = *ord;
        }
    }

    assert_eq(min_ord, Less);
}

// =============================================================================
// Section 25: Stress Tests and Property Verification
// =============================================================================

/// Test all combinations of then
@test
fn test_then_all_combinations() {
    let test_cases: List<(Ordering, Ordering, Ordering)> = [
        (Less, Less, Less),
        (Less, Equal, Less),
        (Less, Greater, Less),
        (Equal, Less, Less),
        (Equal, Equal, Equal),
        (Equal, Greater, Greater),
        (Greater, Less, Greater),
        (Greater, Equal, Greater),
        (Greater, Greater, Greater),
    ];

    for (a, b, expected) in test_cases.iter() {
        // Explicit dereference for method taking self by value
        assert_eq((*a).then(*b), *expected);
    }
}

/// Test reverse truth table
@test
fn test_reverse_truth_table() {
    let test_cases: List<(Ordering, Ordering)> = [
        (Less, Greater),
        (Equal, Equal),
        (Greater, Less),
    ];

    for (input, expected) in test_cases.iter() {
        // Explicit dereference for method taking self by value
        assert_eq((*input).reverse(), *expected);
    }
}

/// Test to_int/from_int roundtrip
@test
fn test_to_from_int_roundtrip() {
    let orderings: List<Ordering> = [Less, Equal, Greater];
    for ord in orderings.iter() {
        // Explicit dereference for method taking self by value
        let int_val = (*ord).to_int();
        let back = Ordering.from_int(int_val);
        assert_eq(*ord, back);
    }
}

/// Test comparison operators form total order
@test
fn test_total_order_properties() {
    // Reflexivity: a == a
    assert_eq(Less, Less);
    assert_eq(Equal, Equal);
    assert_eq(Greater, Greater);

    // Antisymmetry: if a == b and b == a then a and b are the same variant
    // (trivially satisfied for an enum)

    // Transitivity is verified by Eq tests above
}

