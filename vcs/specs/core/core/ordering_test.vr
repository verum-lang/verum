// =============================================================================
// ordering_test.vr - Comprehensive tests for Ordering type
// =============================================================================
// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: ordering, comparison, protocols, core
// @description: Tests for Ordering type, methods, and protocol implementations
// =============================================================================

mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.maybe.{Maybe, Some, None};
mount core.collections.list.List;

// =============================================================================
// Section 1: Ordering Type Construction
// =============================================================================

/// Test Less variant construction
@test
fn test_ordering_less_construction() {
    let ord: Ordering = Less;
    assert(ord is Less);
}

/// Test Equal variant construction
@test
fn test_ordering_equal_construction() {
    let ord: Ordering = Equal;
    assert(ord is Equal);
}

/// Test Greater variant construction
@test
fn test_ordering_greater_construction() {
    let ord: Ordering = Greater;
    assert(ord is Greater);
}

/// Test all three variants are distinct
@test
fn test_ordering_variants_distinct() {
    let less: Ordering = Less;
    let equal: Ordering = Equal;
    let greater: Ordering = Greater;

    assert(!(less is Equal));
    assert(!(less is Greater));
    assert(!(equal is Less));
    assert(!(equal is Greater));
    assert(!(greater is Less));
    assert(!(greater is Equal));
}

// =============================================================================
// Section 2: Predicate - is_less
// =============================================================================

/// Test is_less returns true for Less
@test
fn test_is_less_true() {
    assert(Less.is_less());
}

/// Test is_less returns false for Equal
@test
fn test_is_less_false_equal() {
    assert(!Equal.is_less());
}

/// Test is_less returns false for Greater
@test
fn test_is_less_false_greater() {
    assert(!Greater.is_less());
}

