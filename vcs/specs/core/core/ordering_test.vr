@test
fn test_is_le_less() {
    assert(Less.is_le());
}

/// Test is_le returns true for Equal
@test
fn test_is_le_equal() {
    assert(Equal.is_le());
}

/// Test is_le returns false for Greater
@test
fn test_is_le_greater() {
    assert(!Greater.is_le());
}

// =============================================================================
// Section 6: Predicate - is_ge (greater than or equal)
// =============================================================================

/// Test is_ge returns true for Greater
@test
fn test_is_ge_greater() {
    assert(Greater.is_ge());
}

/// Test is_ge returns true for Equal
@test
fn test_is_ge_equal() {
    assert(Equal.is_ge());
}

/// Test is_ge returns false for Less
@test
fn test_is_ge_less() {
    assert(!Less.is_ge());
}

// =============================================================================
// Section 7: Predicate Relationships
// =============================================================================

/// Test is_le and is_ge overlap only at Equal
@test
fn test_le_ge_overlap_at_equal() {
    // For Less: is_le=true, is_ge=false
    assert(Less.is_le() && !Less.is_ge());

    // For Equal: is_le=true, is_ge=true (overlap)
    assert(Equal.is_le() && Equal.is_ge());

    // For Greater: is_le=false, is_ge=true
    assert(!Greater.is_le() && Greater.is_ge());
}

/// Test exclusive predicates
@test
fn test_exclusive_predicates() {
    // Exactly one of is_less, is_equal, is_greater is true for each variant

    fn count_true(ord: Ordering) -> Int {
        let mut count = 0;
        if ord.is_less() { count = count + 1; }
        if ord.is_equal() { count = count + 1; }
        if ord.is_greater() { count = count + 1; }
        count
    }

    assert_eq(count_true(Less), 1);
    assert_eq(count_true(Equal), 1);
    assert_eq(count_true(Greater), 1);
}

