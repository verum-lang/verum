// =============================================================================

/// Test Copy semantics (implicit copy)
@test
fn test_copy_semantics() {
    fn take_ordering(ord: Ordering) -> Ordering {
        ord
    }

    let original = Less;
    let copied = take_ordering(original);

    // Original is still valid (not moved, but copied)
    assert_eq(original, Less);
    assert_eq(copied, Less);
}

/// Test Copy in assignment
@test
fn test_copy_assignment() {
    let a = Greater;
    let b = a;  // Copy, not move

    assert_eq(a, Greater);
    assert_eq(b, Greater);
}

