/// Test equality of same variants
@test
fn test_eq_same_variants() {
    assert(Less == Less);
    assert(Equal == Equal);
    assert(Greater == Greater);
}

/// Test inequality of different variants
@test
fn test_eq_different_variants() {
    assert(Less != Equal);
    assert(Less != Greater);
    assert(Equal != Less);
    assert(Equal != Greater);
    assert(Greater != Less);
    assert(Greater != Equal);
}

/// Test Eq reflexivity
@test
fn test_eq_reflexivity() {
    let ord = Less;
    assert(ord == ord);
}

/// Test Eq symmetry
@test
fn test_eq_symmetry() {
    let a = Less;
    let b = Less;
    assert(a == b);
    assert(b == a);

    let c = Less;
    let d = Greater;
    assert(!(c == d));
    assert(!(d == c));
}

/// Test Eq transitivity
@test
fn test_eq_transitivity() {
    let a = Equal;
    let b = Equal;
    let c = Equal;
    assert(a == b);
    assert(b == c);
    assert(a == c);  // Transitivity
}

