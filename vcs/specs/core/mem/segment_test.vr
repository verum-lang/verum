@test
fn test_segment_error_mmap_failed() {
    let err = SegmentError.MmapFailed { code: -12 };

    match err {
        MmapFailed { code } => assert_eq(code, -12),
        _ => assert(false, "Wrong error variant"),
    }
}

@test
fn test_segment_error_munmap_failed() {
    let err = SegmentError.MunmapFailed { code: -22 };

    match err {
        MunmapFailed { code } => assert_eq(code, -22),
        _ => assert(false, "Wrong error variant"),
    }
}

@test
fn test_segment_error_out_of_memory() {
    let err = SegmentError.OutOfMemory;

    match err {
        OutOfMemory => { /* OK */ }
        _ => assert(false, "Wrong error variant"),
    }
}

@test
fn test_segment_error_message_mmap() {
    let err = SegmentError.MmapFailed { code: 12 };
    let msg = err.message();
    assert(msg.contains("mmap failed"));
    assert(msg.contains("12"));
}

@test
fn test_segment_error_message_munmap() {
    let err = SegmentError.MunmapFailed { code: 22 };
    let msg = err.message();
    assert(msg.contains("munmap failed"));
    assert(msg.contains("22"));
}

@test
fn test_segment_error_message_oom() {
    let err = SegmentError.OutOfMemory;
    let msg = err.message();
    assert(msg.contains("out of memory"));
}

