// =============================================================================
// VCS Test Suite: stdlib/mem/segment.vr - Segment Management Tests
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: mem, segment, slice, allocator, mimalloc, commit, purge
// @timeout: 30000
// =============================================================================
//
// Tests for the mimalloc-style segment management system with 32 MiB segments
// and 64 KiB slices.
//
// =============================================================================

mount core.mem.segment.{
    // Constants
    SEGMENT_SIZE, SLICE_SIZE, SLICES_PER_SEGMENT, MASK_WORDS, SEGMENT_ALIGN,
    SMALL_PAGE_SIZE, MEDIUM_PAGE_SIZE, LARGE_PAGE_THRESHOLD,
    PURGE_DELAY_NS, MAX_RECLAIM_PER_OP,

    // Slice info
    SliceInfo, SLICE_FREE, SLICE_USED, SLICE_SPAN_START, SLICE_SPAN_CONTINUE,

    // Segment
    Segment, SEGMENT_NORMAL, SEGMENT_HUGE,

    // Functions
    segment_alloc, segment_free, segment_abandon, ptr_to_segment, get_segment_stats,

    // Types
    SegmentError, SegmentStats,
};

// =============================================================================
// Constant Tests
// =============================================================================

@test
fn test_segment_size() {
    // 32 MiB = 32 * 1024 * 1024 = 33554432 bytes
    assert_eq(SEGMENT_SIZE, 33554432);
    assert_eq(SEGMENT_SIZE, 32 * 1024 * 1024);
}

@test
fn test_slice_size() {
    // 64 KiB = 64 * 1024 = 65536 bytes
    assert_eq(SLICE_SIZE, 65536);
    assert_eq(SLICE_SIZE, 64 * 1024);
}

@test
fn test_slices_per_segment() {
    // 32 MiB / 64 KiB = 512 slices
    assert_eq(SLICES_PER_SEGMENT, 512);
    assert_eq(SLICES_PER_SEGMENT, SEGMENT_SIZE / SLICE_SIZE);
}

@test
fn test_mask_words() {
    // 512 slices / 64 bits per word = 8 words
    assert_eq(MASK_WORDS, 8);
    assert_eq(MASK_WORDS, SLICES_PER_SEGMENT / 64);
}

@test
fn test_segment_align() {
    // Segment alignment equals segment size
    assert_eq(SEGMENT_ALIGN, SEGMENT_SIZE);
}

@test
fn test_small_page_size() {
    // Small page = 1 slice = 64 KiB
    assert_eq(SMALL_PAGE_SIZE, SLICE_SIZE);
    assert_eq(SMALL_PAGE_SIZE, 65536);
}

@test
fn test_medium_page_size() {
    // Medium page = 8 slices = 512 KiB
    assert_eq(MEDIUM_PAGE_SIZE, 8 * SLICE_SIZE);
    assert_eq(MEDIUM_PAGE_SIZE, 524288);
}

@test
fn test_large_page_threshold() {
    // Large page threshold = medium page size
    assert_eq(LARGE_PAGE_THRESHOLD, MEDIUM_PAGE_SIZE);
}

@test
fn test_purge_delay() {
    // Default 10ms purge delay
    assert_eq(PURGE_DELAY_NS, 10_000_000);
}

@test
fn test_max_reclaim_per_op() {
    // Maximum 8 segments reclaimed per operation
    assert_eq(MAX_RECLAIM_PER_OP, 8);
}

// =============================================================================
// Slice State Constants Tests
// =============================================================================

@test
fn test_slice_state_free() {
    assert_eq(SLICE_FREE, 0u8);
}

@test
fn test_slice_state_used() {
    assert_eq(SLICE_USED, 1u8);
}

@test
fn test_slice_state_span_start() {
    assert_eq(SLICE_SPAN_START, 2u8);
}

@test
fn test_slice_state_span_continue() {
    assert_eq(SLICE_SPAN_CONTINUE, 3u8);
}

// =============================================================================
// Segment Kind Constants Tests
// =============================================================================

@test
fn test_segment_kind_normal() {
    assert_eq(SEGMENT_NORMAL, 0u8);
}

@test
fn test_segment_kind_huge() {
    assert_eq(SEGMENT_HUGE, 1u8);
}

// =============================================================================
// SliceInfo Tests
// =============================================================================

@test
fn test_slice_info_size() {
    // SliceInfo should be 8 bytes (packed)
    assert_eq(SliceInfo.size, 8);
}

@test
fn test_slice_info_free_constructor() {
    let info = SliceInfo.free();

    assert_eq(info.state, SLICE_FREE);
    assert_eq(info.span_count, 0);
    assert_eq(info.size_class, 0);
    assert_eq(info.flags, 0);
    assert_eq(info.reserved, 0);
}

@test
fn test_slice_info_span_start_constructor() {
    let info = SliceInfo.span_start(4, 23);

    assert_eq(info.state, SLICE_SPAN_START);
    assert_eq(info.span_count, 4);
    assert_eq(info.size_class, 23);
    assert_eq(info.flags, 0);
}

@test
fn test_slice_info_span_continue_constructor() {
    let info = SliceInfo.span_continue();

    assert_eq(info.state, SLICE_SPAN_CONTINUE);
    assert_eq(info.span_count, 0);
    assert_eq(info.size_class, 0);
}

@test
fn test_slice_info_is_free() {
    let free_info = SliceInfo.free();
    let used_info = SliceInfo.span_start(1, 0);

    assert(free_info.is_free());
    assert(!used_info.is_free());
}

@test
fn test_slice_info_is_span_start() {
    let free_info = SliceInfo.free();
    let start_info = SliceInfo.span_start(4, 7);
    let continue_info = SliceInfo.span_continue();

    assert(!free_info.is_span_start());
    assert(start_info.is_span_start());
    assert(!continue_info.is_span_start());
}

@test
fn test_slice_info_span_count_max() {
    // span_count is UInt8, max 255 slices
    let info = SliceInfo.span_start(255, 0);
    assert_eq(info.span_count, 255);
}

@test
fn test_slice_info_size_class_max() {
    // size_class is UInt8, max 255
    let info = SliceInfo.span_start(1, 72);  // Max normal size class
    assert_eq(info.size_class, 72);
}

// =============================================================================
// Segment Header Tests
// =============================================================================

@test
fn test_segment_header_size() {
    // Header should be < 4 KiB to fit in first slice
    // 64 + 32 + 128 + 16 + 16 + 4096 = 4352 bytes
    assert_eq(Segment.HEADER_SIZE, 4352);
    assert(Segment.HEADER_SIZE < SLICE_SIZE);
}

@test
fn test_segment_alignment() {
    // Segment should be 64-byte aligned (cache line)
    assert_eq(Segment.align, 64);
}

@test
fn test_segment_slices_array_size() {
    // Should have 512 slice info entries
    // Each SliceInfo is 8 bytes, so 512 * 8 = 4096 bytes
    let expected_array_size = SLICES_PER_SEGMENT * 8;
    assert_eq(expected_array_size, 4096);
}

// =============================================================================
// Commit Mask Tests
// =============================================================================

@test
fn test_commit_mask_words() {
    // Commit mask should have MASK_WORDS (8) entries
    // This is implicitly tested by the fact that commit_mask is [UInt64; 8]
    assert_eq(MASK_WORDS, 8);
}

@test
fn test_commit_mask_covers_all_slices() {
    // 8 words * 64 bits = 512 bits = 512 slices
    assert_eq(MASK_WORDS * 64, SLICES_PER_SEGMENT);
}

@test
fn test_is_committed_bit_calculation() {
    // Test that bit indexing works correctly
    // Slice 0: word 0, bit 0
    // Slice 63: word 0, bit 63
    // Slice 64: word 1, bit 0
    // Slice 511: word 7, bit 63

    // Simulate bit calculation
    let test_indices = [
        (0, 0, 0),      // slice 0 → word 0, bit 0
        (63, 0, 63),    // slice 63 → word 0, bit 63
        (64, 1, 0),     // slice 64 → word 1, bit 0
        (127, 1, 63),   // slice 127 → word 1, bit 63
        (511, 7, 63),   // slice 511 → word 7, bit 63
    ];

    let mut i = 0;
    while i < 5 {
        let entry = test_indices[i];
        let slice_idx = entry.0;
        let expected_word = entry.1;
        let expected_bit = entry.2;
        let word = slice_idx / 64;
        let bit = slice_idx % 64;
        assert_eq(word, expected_word);
        assert_eq(bit, expected_bit);
        i = i + 1;
    }
}

// =============================================================================
// Slice Pointer Calculation Tests
// =============================================================================

@test
fn test_slice_ptr_offset_calculation() {
    // Slice pointer = segment base + slice_index * SLICE_SIZE
    let base_addr = 0x1000_0000 as Int;

    // Slice 0 should be at base
    let slice0_offset = 0 * SLICE_SIZE;
    assert_eq(slice0_offset, 0);

    // Slice 1 should be at base + 64 KiB
    let slice1_offset = 1 * SLICE_SIZE;
    assert_eq(slice1_offset, 65536);

    // Slice 511 should be at base + 511 * 64 KiB
    let slice511_offset = 511 * SLICE_SIZE;
    assert_eq(slice511_offset, 33488896);
}

@test
fn test_slice_index_from_pointer() {
    // Given a pointer, we can calculate slice index
    let base = 0x1000_0000;
    let ptr1 = base + 65536;   // Slice 1
    let ptr2 = base + 131072;  // Slice 2
    let ptr511 = base + 511 * SLICE_SIZE;

    assert_eq((ptr1 - base) / SLICE_SIZE, 1);
    assert_eq((ptr2 - base) / SLICE_SIZE, 2);
    assert_eq((ptr511 - base) / SLICE_SIZE, 511);
}

// =============================================================================
// ptr_to_segment Tests
// =============================================================================

@test
fn test_ptr_to_segment_alignment_mask() {
    // ptr_to_segment uses alignment mask to find segment start
    let segment_mask = !(SEGMENT_SIZE - 1);

    // Segment size is 32 MiB = 0x200_0000
    // Mask should clear lower 25 bits
    assert_eq(SEGMENT_SIZE - 1, 0x1FF_FFFF);
    assert_eq(segment_mask, !0x1FF_FFFF);
}

@test
fn test_ptr_to_segment_calculation() {
    // Any pointer within a segment should map to segment start
    let segment_base = 0x4000_0000 as Int;  // 1 GiB aligned

    // Test various offsets within the segment
    let test_offsets = [0, 1, 65536, 1000000, SEGMENT_SIZE - 1];

    for offset in test_offsets {
        let ptr = segment_base + offset;
        let segment_addr = ptr & !(SEGMENT_SIZE - 1);
        assert_eq(segment_addr, segment_base);
    }
}

