@test
fn test_global_wraparound_count() {
    let count = wraparound_count();

    // Should be >= 0
    assert(count >= 0);
}

// =============================================================================
// Epoch Truncation Tests
// =============================================================================

@test
fn test_epoch_16bit_truncation() {
    let mut cache = EpochCache {
        cached_epoch: 0x10042 as UInt64,  // More than 16 bits
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    // Check should compare only lower 16 bits
    assert(cache.check0x0042_u16);
}

@test
fn test_epoch_max_truncation() {
    let mut cache = EpochCache {
        cached_epoch: 0xFFFF as UInt64,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    assert(cache.check0xFFFF_u16);
}

// =============================================================================
// Edge Cases
// =============================================================================

@test
fn test_zero_sync_interval_cache() {
    // Zero sync interval means sync on every get
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 0,
    };

    // Should not panic
    cache.get();
}

@test
fn test_very_large_sync_interval() {
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 1_000_000,
    };

    // Many gets without syncing
    for _ in 0..1000 {
        cache.get();
    }

    // Should not have synced yet
    assert(cache.checks_since_sync <= 1000);
}

@test
fn test_epoch_counter_overflow_handling() {
    let mut cache = EpochCache {
        cached_epoch: 0xFFFFFFFFFFFFFFFF as UInt64,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    // Should handle max value without panic
    let epoch = cache.get();
    assert(epoch > 0);
}

// =============================================================================
// Performance Characteristic Tests
// =============================================================================

@test
fn test_cache_hit_is_fast_path() {
    // This is more of a documentation test - verifying the design
    let mut cache = EpochCache.default();

    // First get syncs with global
    cache.sync();
    let epoch1 = cache.cached_epoch;

    // Subsequent gets should use cached value (no atomic load from global)
    for _ in 0..100 {
        let epoch = cache.get();
        // Should return the cached value (may sync, but still valid)
        assert(epoch >= epoch1);
    }
}

@test
fn test_cache_invalidation_affects_next_get() {
    let mut cache = EpochCache {
        cached_epoch: 42,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    cache.invalidate();

    // Next get should trigger sync
    let _epoch = cache.get();

    // After sync, checks_since_sync should be low
    assert(cache.checks_since_sync <= 1);
}

// =============================================================================
// Integration Tests
// =============================================================================

@test
fn test_epoch_callback_notification_flow() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    // We can't easily test callback invocation without shared mutable state,
    // but we can test the registration flow
    // Closure that takes epoch and does nothing (comment inside closure not supported)
    let cb: EpochCallback = |_epoch| { () };

    let id = manager.register_callback(cb);

    // Increment epoch (triggers callbacks)
    manager.increment_epoch();

    // Callback was called (we can't verify easily, but no panic is good)

    // Cleanup
    manager.unregister_callback(id);
}

@test
fn test_epoch_and_cache_interaction() {
    // This tests the typical usage pattern:
    // 1. Thread gets epoch from cache
    // 2. Uses epoch for CBGR validation
    // 3. Cache periodically syncs with global

    let mut cache = EpochCache.default();

    // Simulate typical access pattern
    for _ in 0..2000 {
        let epoch = cache.get();
        // Use epoch for validation...
        assert(epoch >= 0);
    }

    // After 2000 accesses with sync_interval=1000, should have synced at least once
    // This is verified by checks_since_sync being < sync_interval
    assert(cache.checks_since_sync < cache.sync_interval);
}

