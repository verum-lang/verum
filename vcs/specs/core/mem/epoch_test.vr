@test
fn test_register_revocation_callback() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    let id = manager.register_revocation_callback(cb);

    // ID should be 0 (first registration)
    assert_eq(id, 0);
}

@test
fn test_unregister_revocation_callback() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    let id = manager.register_revocation_callback(cb);
    let result = manager.unregister_revocation_callback(id);

    assert(result);
}

