@test
fn test_multiple_callbacks_unique_ids() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb1: EpochCallback = |_epoch| { () };
    let cb2: EpochCallback = |_epoch| { () };
    let cb3: EpochCallback = |_epoch| { () };

    let id1 = manager.register_callback(cb1);
    let id2 = manager.register_callback(cb2);
    let id3 = manager.register_callback(cb3);

    // All IDs should be distinct
    assert(id1 != id2);
    assert(id2 != id3);
    assert(id1 != id3);
}

@test
fn test_revocation_callback_double_unregister() {
