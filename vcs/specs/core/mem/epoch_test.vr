// =============================================================================
// VCS Test Suite: stdlib/mem/epoch.vr - Epoch Management Tests
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: mem, cbgr, epoch, callback, wraparound, cache
// @timeout: 30000
// =============================================================================
//
// Tests for the global epoch management system that handles generation
// counter wraparound and cache invalidation.
//
// =============================================================================

mount core.mem.epoch.{
    EpochManager, EpochCache, EpochCallback, RevocationCallback,
    GLOBAL_EPOCH,  // Note: THREAD_EPOCH_CACHE is not public
    DEFAULT_SYNC_INTERVAL, EPOCH_MAX,
    current_epoch, wraparound_count, cached_epoch, invalidate_epoch_cache,
    register_epoch_callback, unregister_epoch_callback,
    register_revocation_callback, unregister_revocation_callback,
    get_thread_epoch_cache,
};

// =============================================================================
// Constant Tests
// =============================================================================

@test
fn test_default_sync_interval() {
    // Default should be 1000 checks between epoch reloads
    assert_eq(DEFAULT_SYNC_INTERVAL, 1000);
}

@test
fn test_epoch_max() {
    // Epoch is 16-bit
    assert_eq(EPOCH_MAX, 0xFFFF as UInt16);
}

// =============================================================================
// EpochManager Basic Tests
// =============================================================================

@test
fn test_epoch_manager_initial_state() {
    let manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    assert_eq(manager.current_epoch(), 0);
    assert_eq(manager.wraparound_count(), 0);
}

@test
fn test_global_epoch_exists() {
    // GLOBAL_EPOCH should be accessible
    let epoch = current_epoch();
    // Just verify it doesn't panic
    assert(epoch >= 0);
}

@test
fn test_current_epoch_returns_valid() {
    let epoch = current_epoch();

    // Epoch should be a valid 64-bit value
    // (16-bit epoch stored in 64-bit field for atomics)
    assert(epoch <= 0xFFFFFFFFFFFFFFFF as UInt64);
}

// =============================================================================
// Epoch Increment Tests
// =============================================================================

@test
fn test_increment_epoch_returns_new_value() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let new_epoch = manager.increment_epoch();
    assert_eq(new_epoch, 1);
    assert_eq(manager.current_epoch(), 1);
}

@test
fn test_increment_epoch_increases_wraparound_count() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    manager.increment_epoch();

    assert_eq(manager.wraparound_count(), 1);
}

@test
fn test_on_wraparound_increments_epoch() {
    let mut manager = EpochManager {
        epoch: 5,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    manager.on_wraparound();

    assert_eq(manager.current_epoch(), 6);
}

@test
fn test_multiple_increments() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let mut i = 0;
    while i < 100 {
        let new_epoch = manager.increment_epoch();
        assert_eq(new_epoch, (i + 1) as UInt64);
        i = i + 1;
    }

    assert_eq(manager.current_epoch(), 100);
    assert_eq(manager.wraparound_count(), 100);
}

// =============================================================================
// EpochCache Tests
// =============================================================================

@test
fn test_epoch_cache_new() {
    let cache = EpochCache.new(500);

    assert_eq(cache.sync_interval, 500);
    assert_eq(cache.checks_since_sync, 0);
}

@test
fn test_epoch_cache_default() {
    let cache = EpochCache.default();

    assert_eq(cache.sync_interval, DEFAULT_SYNC_INTERVAL);
}

@test
fn test_epoch_cache_get_increments_checks() {
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    cache.get();
    // Note: get() increments checks_since_sync before comparing
    assert(cache.checks_since_sync >= 1);
}

@test
fn test_epoch_cache_sync_resets_counter() {
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 500,
        sync_interval: 1000,
    };

    cache.sync();

    assert_eq(cache.checks_since_sync, 0);
}

@test
fn test_epoch_cache_invalidate_forces_sync() {
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    cache.invalidate();

    // After invalidate, checks_since_sync should be >= sync_interval
    // so next get() triggers sync
    assert_eq(cache.checks_since_sync, cache.sync_interval);
}

@test
fn test_epoch_cache_check_matching() {
    let mut cache = EpochCache {
        cached_epoch: 42,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    // Check with matching epoch (truncated to 16 bits)
    assert(cache.check42_u16);
}

@test
fn test_epoch_cache_check_non_matching() {
    let mut cache = EpochCache {
        cached_epoch: 42,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    // Check with non-matching epoch
    assert(!cache.check99_u16);
}

@test
fn test_epoch_cache_periodic_sync() {
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 10,
    };

    // Perform many gets
    for _ in 0..25 {
        cache.get();
    }

    // After 25 gets with sync_interval=10, should have synced at least twice
    // checks_since_sync should be between 0 and 9
    assert(cache.checks_since_sync < 10);
}

// =============================================================================
// Thread-Local Cache Tests
// =============================================================================

@test
fn test_get_thread_epoch_cache() {
    let cache = get_thread_epoch_cache();

    // Should return a valid cache
    assert_eq(cache.sync_interval, DEFAULT_SYNC_INTERVAL);
}

@test
fn test_cached_epoch_returns_value() {
    let epoch = cached_epoch();

    // Should return a valid epoch
    assert(epoch >= 0);
}

@test
fn test_invalidate_epoch_cache_function() {
    invalidate_epoch_cache();

    let cache = get_thread_epoch_cache();
    // After invalidation, next get should sync
    assert_eq(cache.checks_since_sync, cache.sync_interval);
}

// =============================================================================
// Callback Registration Tests
// =============================================================================

@test
fn test_register_epoch_callback_returns_unique_id() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    // Define callback (captures nothing)
    let cb1: EpochCallback = |_epoch| { () };
    let cb2: EpochCallback = |_epoch| { () };

    let id1 = manager.register_callback(cb1);
    let id2 = manager.register_callback(cb2);

    assert(id1 != id2);
}

@test
fn test_unregister_epoch_callback_removes() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb: EpochCallback = |_epoch| { () };
    let id = manager.register_callback(cb);

    // Unregister should return true
    let result = manager.unregister_callback(id);
    assert(result);
}

@test
fn test_unregister_nonexistent_returns_false() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    // Try to unregister ID that was never registered
    let result = manager.unregister_callback(99999);
    assert(!result);
}

@test
fn test_double_unregister_returns_false() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb: EpochCallback = |_epoch| { () };
    let id = manager.register_callback(cb);

    let first = manager.unregister_callback(id);
    let second = manager.unregister_callback(id);

    assert(first);
    assert(!second);
}

// =============================================================================
