@test
fn test_manager_nonzero_initial_epoch() {
    let mut manager = EpochManager {
        epoch: 100,
        wraparounds: 5,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    assert_eq(manager.current_epoch(), 100);
    assert_eq(manager.wraparound_count(), 5);

    let new_epoch = manager.increment_epoch();
    assert_eq(new_epoch, 101);
    assert_eq(manager.wraparound_count(), 6);
}

@test
fn test_multiple_on_wraparound() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    manager.on_wraparound();
    manager.on_wraparound();
    manager.on_wraparound();

    assert_eq(manager.current_epoch(), 3);
}

@test
fn test_epoch_cache_check_zero_epoch() {
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    assert(cache.check0_u16);
    assert(!cache.check1_u16);
}

@test
fn test_epoch_cache_sync_interval_one() {
    // Sync on every get
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 1,
    };

    for _ in 0..10 {
        cache.get();
    }
    // Should sync frequently
    assert(cache.checks_since_sync <= 1);
}

@test
fn test_register_unregister_multiple_callbacks() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb1: EpochCallback = |_epoch| { () };
    let cb2: EpochCallback = |_epoch| { () };
    let cb3: EpochCallback = |_epoch| { () };

    let id1 = manager.register_callback(cb1);
    let id2 = manager.register_callback(cb2);
    let id3 = manager.register_callback(cb3);

    // Unregister middle one
    assert(manager.unregister_callback(id2));
    // First and third should still unregister
    assert(manager.unregister_callback(id1));
    assert(manager.unregister_callback(id3));
    // All gone now
    assert(!manager.unregister_callback(id1));
}

@test
fn test_revocation_callbacks_unique_ids() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb1: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };
    let cb2: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    let id1 = manager.register_revocation_callback(cb1);
    let id2 = manager.register_revocation_callback(cb2);

    assert(id1 != id2);
}

@test
fn test_epoch_cache_invalidate_then_get_resets() {
    let mut cache = EpochCache {
        cached_epoch: 50,
        checks_since_sync: 500,
        sync_interval: 1000,
    };

    cache.invalidate();
    assert_eq(cache.checks_since_sync, cache.sync_interval);

    // After get, should have synced
    let _epoch = cache.get();
    assert(cache.checks_since_sync <= 1);
}

@test
fn test_epoch_cache_new_various_intervals() {
    let cache1 = EpochCache.new(1);
    assert_eq(cache1.sync_interval, 1);

    let cache2 = EpochCache.new(100);
    assert_eq(cache2.sync_interval, 100);

    let cache3 = EpochCache.new(1_000_000);
    assert_eq(cache3.sync_interval, 1_000_000);
}

// =============================================================================
// Additional Tests
// =============================================================================

@test
fn test_epoch_callback_type_as_parameter() {
    fn accept_callback(cb: EpochCallback) -> Bool { true }
    let _ = accept_callback;
}

@test
fn test_revocation_callback_type_as_parameter() {
    fn accept_callback(cb: RevocationCallback) -> Bool { true }
    let _ = accept_callback;
}

@test
fn test_epoch_cache_repeated_invalidate_sync() {
    let mut cache = EpochCache {
        cached_epoch: 0,
        checks_since_sync: 0,
        sync_interval: 100,
    };

    let mut i = 0;
    while i < 5 {
        cache.invalidate();
        assert_eq(cache.checks_since_sync, cache.sync_interval);
        cache.sync();
        assert_eq(cache.checks_since_sync, 0);
        i = i + 1;
    }
}

@test
fn test_epoch_manager_both_callback_types() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb: EpochCallback = |_epoch| { () };
    let rcb: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    let id1 = manager.register_callback(cb);
    let id2 = manager.register_revocation_callback(rcb);

    assert(id1 >= 0);
    assert(id2 >= 0);

    assert(manager.unregister_callback(id1));
    assert(manager.unregister_revocation_callback(id2));
}

@test
fn test_epoch_cache_check_boundary_values() {
    let mut cache = EpochCache {
        cached_epoch: 0xFFFF as UInt64,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    assert(cache.check0xFFFF_u16);
    assert(!cache.check0_u16);
    assert(!cache.check0xFFFE_u16);
}

@test
fn test_epoch_manager_increment_then_on_wraparound() {
    let mut manager = EpochManager {
        epoch: 10,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    manager.increment_epoch();
    assert_eq(manager.current_epoch(), 11);

    manager.on_wraparound();
    assert_eq(manager.current_epoch(), 12);
}

@test
fn test_epoch_cache_two_caches_independent() {
    let mut cache1 = EpochCache.new(100);
    let mut cache2 = EpochCache.new(500);

    let mut i = 0;
    while i < 50 {
        cache1.get();
        cache2.get();
        i = i + 1;
    }

    assert(cache1.checks_since_sync <= 50);
    assert(cache2.checks_since_sync <= 50);
}

@test
fn test_epoch_manager_sequential_callback_ids_grow() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb1: EpochCallback = |_epoch| { () };
    let cb2: EpochCallback = |_epoch| { () };
    let cb3: EpochCallback = |_epoch| { () };

    let id1 = manager.register_callback(cb1);
    let id2 = manager.register_callback(cb2);
    let id3 = manager.register_callback(cb3);

    // IDs should be strictly increasing
    assert(id1 < id2);
    assert(id2 < id3);
}

@test
fn test_epoch_cache_sync_preserves_interval() {
    let mut cache = EpochCache.new(42);
    cache.sync();
    assert_eq(cache.sync_interval, 42);
    assert_eq(cache.checks_since_sync, 0);

    cache.invalidate();
    assert_eq(cache.sync_interval, 42);

    let _ = cache.get();
    assert_eq(cache.sync_interval, 42);
}

@test
fn test_revocation_callbacks_sequential_ids() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb1: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };
    let cb2: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };
    let cb3: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    let id1 = manager.register_revocation_callback(cb1);
    let id2 = manager.register_revocation_callback(cb2);
    let id3 = manager.register_revocation_callback(cb3);

    // IDs should be strictly increasing
    assert(id1 < id2);
    assert(id2 < id3);
    assert_eq(id1, 0);
    assert_eq(id2, 1);
    assert_eq(id3, 2);
}

@test
fn test_mixed_callback_registration_order() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let epoch_cb: EpochCallback = |_epoch| { () };
    let revoc_cb: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    // Register in mixed order
    let id1 = manager.register_callback(epoch_cb);
    let id2 = manager.register_revocation_callback(revoc_cb);
    let id3 = manager.register_callback(|_epoch| { () });
    let id4 = manager.register_revocation_callback(|_ptr, _old_gen, _new_gen, _epoch| { () });

    // Epoch callback IDs are independent from revocation callback IDs
    assert_eq(id1, 0);
    assert_eq(id2, 0);
    assert_eq(id3, 1);
    assert_eq(id4, 1);
}

@test
fn test_epoch_manager_with_preexisting_callback_ids() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 100,
        next_revocation_id: 200,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let epoch_cb: EpochCallback = |_epoch| { () };
    let revoc_cb: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    let id1 = manager.register_callback(epoch_cb);
    let id2 = manager.register_revocation_callback(revoc_cb);

    // Should start from the preexisting values
    assert_eq(id1, 100);
    assert_eq(id2, 200);
}

@test
fn test_epoch_cache_check_with_high_epoch() {
    let mut cache = EpochCache {
        cached_epoch: 0xABCD1234 as UInt64,
        checks_since_sync: 0,
        sync_interval: 1000,
    };

    // Check truncates to lower 16 bits
    assert(cache.check0x1234_u16);
    assert(!cache.check0xABCD_u16);
    assert(!cache.check0x0000_u16);
}

@test
fn test_epoch_cache_multiple_invalidate_cycles() {
    let mut cache = EpochCache.new(100);

    let mut i = 0;
    while i < 10 {
        cache.invalidate();
        let _epoch = cache.get();
        assert(cache.checks_since_sync <= 1);

        // Do some gets
        let mut j = 0;
        while j < 50 {
            cache.get();
            j = j + 1;
        }

        i = i + 1;
    }
}

@test
fn test_epoch_manager_increment_then_wraparound_count_consistent() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let mut expected_count = 0;
    let mut i = 0;
    while i < 20 {
        let new_epoch = manager.increment_epoch();
        expected_count = expected_count + 1;
        assert_eq(new_epoch, (i + 1) as UInt64);
        assert_eq(manager.wraparound_count(), expected_count);
        i = i + 1;
    }
}

@test
fn test_unregister_multiple_revocation_callbacks_in_order() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
        next_revocation_id: 0,
        callbacks_lock: 0,
        revocation_lock: 0,
    };

    let cb1: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };
    let cb2: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };
    let cb3: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };
    let cb4: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };

    let id1 = manager.register_revocation_callback(cb1);
    let id2 = manager.register_revocation_callback(cb2);
    let id3 = manager.register_revocation_callback(cb3);
    let id4 = manager.register_revocation_callback(cb4);

    // Unregister first and last
    assert(manager.unregister_revocation_callback(id1));
    assert(manager.unregister_revocation_callback(id4));

    // Middle two should still be present
    assert(manager.unregister_revocation_callback(id2));
    assert(manager.unregister_revocation_callback(id3));

    // All should be gone now
    assert(!manager.unregister_revocation_callback(id1));
    assert(!manager.unregister_revocation_callback(id2));
}

@test
fn test_epoch_cache_check_after_multiple_gets() {
    let mut cache = EpochCache {
        cached_epoch: 42,
        checks_since_sync: 0,
        sync_interval: 50,
    };

    // Do many gets
    let mut i = 0;
    while i < 100 {
        let _epoch = cache.get();
        i = i + 1;
    }

    // After many gets, check should still work with proper epoch
    // Note: epoch may have synced, so we check against current cached value
    let current_epoch_truncated = (cache.cached_epoch as UInt16);
    assert(cache.check(current_epoch_truncated));
}
