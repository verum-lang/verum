    };

    let cb: RevocationCallback = |_ptr, _old_gen, _new_gen, _epoch| { () };
    let id = manager.register_revocation_callback(cb);

    let first = manager.unregister_revocation_callback(id);
    let second = manager.unregister_revocation_callback(id);

    assert(first);
    assert(!second);
}

@test
fn test_unregister_revocation_nonexistent() {
    let mut manager = EpochManager {
        epoch: 0,
        wraparounds: 0,
        callbacks: List.new(),
        revocation_callbacks: List.new(),
        next_callback_id: 0,
