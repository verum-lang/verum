// =============================================================================
// VCS Test Suite: stdlib/mem/heap.vr - Thread-Local Heap Tests
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: mem, heap, allocator, page, free-list, cbgr, cross-thread
// @timeout: 30000
// =============================================================================
//
// Tests for the mimalloc-style thread-local heap with lock-free fast path
// and 3-level free lists.
//
// =============================================================================

mount core.mem.heap.{
    // Constants
    DIRECT_LOOKUP_SIZE, PAGE_HEADER_SIZE,
    PAGE_FLAG_IN_FULL_QUEUE, PAGE_FLAG_HAS_ALIGNED, PAGE_FLAG_ZERO_INIT,

    // Types
    PageHeader, PageQueue, HeapStats, LocalHeap, HeapError,

    // Functions
    heap_alloc, heap_alloc_zeroed, heap_free, heap_free_validated,
    get_heap_stats, get_heap, init_thread_heap, shutdown_thread_heap,
    encode_ptr, decode_ptr, init_encoding_keys,
};

mount core.mem.size_class.{BIN_COUNT, BIN_HUGE, BIN_FULL, QUEUE_COUNT, SIZE_CLASSES, size_to_bin};
mount core.mem.segment.{SLICE_SIZE, SLICES_PER_SEGMENT};

// =============================================================================
// Constant Tests
// =============================================================================

@test
fn test_direct_lookup_size() {
    // 129 entries: 0-128 words (0-1024 bytes)
    assert_eq(DIRECT_LOOKUP_SIZE, 129);
}

@test
fn test_page_header_size() {
    // 128 bytes, cache-line aligned
    assert_eq(PAGE_HEADER_SIZE, 128);
}

@test
fn test_page_flag_in_full_queue() {
    assert_eq(PAGE_FLAG_IN_FULL_QUEUE, 0x0001 as UInt16);
}

@test
fn test_page_flag_has_aligned() {
    assert_eq(PAGE_FLAG_HAS_ALIGNED, 0x0002 as UInt16);
}

@test
fn test_page_flag_zero_init() {
    assert_eq(PAGE_FLAG_ZERO_INIT, 0x0004 as UInt16);
}

// =============================================================================
// PageHeader Structure Tests
// =============================================================================

@test
fn test_page_header_alignment() {
    // PageHeader should be 64-byte aligned (cache line)
    assert_eq(PageHeader.align, 64);
}

@test
fn test_page_header_initial_state() {
    // Test default-initialized page header values
    // In real usage, init() would be called
    let page = PageHeader {
        bin: 0,
        kind: 0,
        flags: 0,
        block_size: 0,
        _pad0: 0,
        capacity: 0,
        used: 0,
        free: 0,
        local_free: 0,
        xthread_free: 0,
        next: 0 as &unsafe PageHeader,
        prev: 0 as &unsafe PageHeader,
        segment: 0 as &Segment,
        slice_index: 0,
        slice_count: 0,
        base_generation: 0,
        epoch: 0,
        _pad1: 0,
        slot_generations: 0 as &unsafe [UInt8],
        _pad2: [0 as UInt64; 2],
    };

    assert_eq(page.bin, 0);
    assert_eq(page.used, 0);
    assert_eq(page.free, 0);
}

@test
fn test_page_header_block_ptr_calculation() {
    // block_ptr = base + PAGE_HEADER_SIZE + index * block_size
    let base = 0x1000;
    let block_size = 64;
    let index = 5;

    let expected_ptr = base + PAGE_HEADER_SIZE + index * block_size;
    assert_eq(expected_ptr, 0x1000 + 128 + 320);
    assert_eq(expected_ptr, 0x1000 + 448);
}

@test
fn test_page_header_block_index_calculation() {
    // block_index = (ptr - base - PAGE_HEADER_SIZE) / block_size
    let base = 0x1000;
    let block_size = 64;
    let ptr = 0x1000 + 128 + 320;  // base + header + 5*64

    let index = (ptr - base - PAGE_HEADER_SIZE) / block_size;
    assert_eq(index, 5);
}

@test
fn test_page_header_is_full() {
    // Page is full when used >= capacity
    let mut page = PageHeader {
        bin: 0,
        kind: 0,
        flags: 0,
        block_size: 64,
        _pad0: 0,
        capacity: 100,
        used: 100,
        free: 0,
        local_free: 0,
        xthread_free: 0,
        next: 0 as &unsafe PageHeader,
        prev: 0 as &unsafe PageHeader,
        segment: 0 as &Segment,
        slice_index: 0,
        slice_count: 1,
        base_generation: 0,
        epoch: 0,
        _pad1: 0,
        slot_generations: 0 as &unsafe [UInt8],
        _pad2: [0 as UInt64; 2],
    };

    assert(page.is_full());

    page.used = 99 as UInt32;
    assert(!page.is_full());
}

@test
fn test_page_header_is_empty() {
    // Page is empty when used == 0
    let mut page = PageHeader {
        bin: 0,
        kind: 0,
        flags: 0,
        block_size: 64,
        _pad0: 0,
        capacity: 100,
        used: 0,
        free: 0,
        local_free: 0,
        xthread_free: 0,
        next: 0 as &unsafe PageHeader,
        prev: 0 as &unsafe PageHeader,
        segment: 0 as &Segment,
        slice_index: 0,
        slice_count: 1,
        base_generation: 0,
        epoch: 0,
        _pad1: 0,
        slot_generations: 0 as &unsafe [UInt8],
        _pad2: [0 as UInt64; 2],
    };

    assert(page.is_empty());

    page.used = 1 as UInt32;
    assert(!page.is_empty());
}

// =============================================================================
// PageQueue Tests
// =============================================================================

@test
fn test_page_queue_empty_constructor() {
    let pq = PageQueue.empty();

    assert_eq(pq.first as Int, 0);
    assert_eq(pq.last as Int, 0);
    assert_eq(pq.block_size, 0);
    assert_eq(pq.count, 0);
}

@test
fn test_page_queue_is_empty() {
    let pq = PageQueue.empty();
    assert(pq.is_empty());
}

@test
fn test_page_queue_not_empty_after_push() {
    let mut pq = PageQueue.empty();

    // Simulate having a page
    // (Can't actually push without real page memory)
    pq.count = 1 as UInt32;
    pq.first = 0x1000 as &unsafe PageHeader;

    assert(!pq.is_empty());
}

@test
fn test_page_queue_count_increments() {
    let mut pq = PageQueue {
        first: 0 as &unsafe PageHeader,
        last: 0 as &unsafe PageHeader,
        block_size: 64,
        count: 0,
    };

    // Simulate push
    pq.count = pq.count + 1;
    assert_eq(pq.count, 1);

    pq.count = pq.count + 1;
    assert_eq(pq.count, 2);

    // Simulate remove
    pq.count = pq.count - 1;
    assert_eq(pq.count, 1);
}

@test
fn test_page_queue_peek_empty() {
    let pq = PageQueue.empty();
    let result = pq.peek();
    assert(result.is_none());
}

// =============================================================================
// HeapStats Tests
// =============================================================================

@test
fn test_heap_stats_new() {
    let stats = HeapStats.new();

    assert_eq(stats.alloc_count, 0);
    assert_eq(stats.dealloc_count, 0);
    assert_eq(stats.bytes_allocated, 0);
    assert_eq(stats.bytes_freed, 0);
    assert_eq(stats.live_count, 0);
    assert_eq(stats.live_bytes, 0);
    assert_eq(stats.pages_in_use, 0);
    assert_eq(stats.segments_owned, 0);
}

@test
fn test_heap_stats_tracking() {
    let mut stats = HeapStats.new();

    // Simulate allocation
    stats.alloc_count = stats.alloc_count + 1;
    stats.bytes_allocated = stats.bytes_allocated + 64;
    stats.live_count = stats.live_count + 1;
    stats.live_bytes = stats.live_bytes + 64;

    assert_eq(stats.alloc_count, 1);
    assert_eq(stats.bytes_allocated, 64);
    assert_eq(stats.live_count, 1);

    // Simulate deallocation
    stats.dealloc_count = stats.dealloc_count + 1;
    stats.bytes_freed = stats.bytes_freed + 64;
    stats.live_count = stats.live_count - 1;
    stats.live_bytes = stats.live_bytes - 64;

    assert_eq(stats.dealloc_count, 1);
    assert_eq(stats.bytes_freed, 64);
    assert_eq(stats.live_count, 0);
}

@test
fn test_heap_stats_multiple_allocations() {
    let mut stats = HeapStats.new();

    let sizes = [64, 128, 256, 512, 1024];

    let mut j = 0;
    while j < 5 {
        let size = sizes[j];
        stats.alloc_count = stats.alloc_count + 1;
        stats.bytes_allocated = stats.bytes_allocated + size as UInt64;
        stats.live_count = stats.live_count + 1;
        stats.live_bytes = stats.live_bytes + size as UInt64;
        j = j + 1;
    }

    assert_eq(stats.alloc_count, 5);
    assert_eq(stats.bytes_allocated, 1984);  // 64+128+256+512+1024
    assert_eq(stats.live_count, 5);
}

// =============================================================================
// LocalHeap Tests
// =============================================================================

@test
fn test_local_heap_new() {
    let heap = LocalHeap.new(12345);

    assert_eq(heap.thread_id, 12345);
    assert_eq(heap.segments as Int, 0);
    assert_eq(heap.stats.alloc_count, 0);
}

@test
fn test_local_heap_pages_direct_initialized() {
    let heap = LocalHeap.new(1);

    // All direct pages should be null initially
    let mut i = 0;
    while i < DIRECT_LOOKUP_SIZE {
        assert_eq(heap.pages_direct[i] as Int, 0);
        i = i + 1;
    }
}

@test
fn test_local_heap_page_queues_initialized() {
    let heap = LocalHeap.new(1);

    // All page queues should be empty
    let mut i = 0;
    while i < QUEUE_COUNT {
        assert(heap.pages[i].is_empty());
        assert_eq(heap.pages[i].count, 0);
        i = i + 1;
    }
}

@test
fn test_local_heap_page_queue_block_sizes() {
    let heap = LocalHeap.new(1);

    // Each queue should have correct block size
    let mut i = 0;
    while i < BIN_COUNT {
        assert_eq(heap.pages[i].block_size, SIZE_CLASSES[i] as UInt32);
        i = i + 1;
    }
}

