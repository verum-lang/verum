// =============================================================================
// VCS Test Suite: stdlib/mem/header.vr - AllocationHeader Tests
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: mem, cbgr, header, allocation, generation, epoch
// @timeout: 30000
// =============================================================================
//
// Tests for AllocationHeader, the 32-byte metadata prepended to every
// CBGR-managed allocation. Validates generation/epoch tracking, atomic
// operations, capability storage, and reference validation.
//
// =============================================================================

mount core.mem.header.{
    AllocationHeader, AllocationFlags, ValidationError,
    HEADER_SIZE, HEADER_ALIGN,
    GEN_INITIAL, GEN_UNALLOCATED, GEN_MAX,
    FLAG_BORROWED, FLAG_SHARED, FLAG_PINNED,
    FLAG_LEAKED, FLAG_WEAK, FLAG_LARGE,
};
mount core.mem.capability.{CAP_READ, CAP_WRITE, CAP_OWNED, CAP_BORROW_SHARED};

// =============================================================================
// Constants and Layout Tests
// =============================================================================

@test
fn test_header_size_is_32_bytes() {
    // AllocationHeader must be exactly 32 bytes for cache efficiency
    assert_eq(HEADER_SIZE, 32);
    assert_eq(AllocationHeader.size, 32);
}

@test
fn test_header_alignment_is_8_bytes() {
    // Header must be 8-byte aligned for atomic operations
    assert_eq(HEADER_ALIGN, 8);
    assert_eq(AllocationHeader.align, 8);
}

@test
fn test_generation_constants() {
    // GEN_INITIAL must be 1 (0 reserved for unallocated)
    assert_eq(GEN_INITIAL, 1);

    // GEN_UNALLOCATED must be 0 (sentinel value)
    assert_eq(GEN_UNALLOCATED, 0);

    // GEN_MAX must be 0xFFFFFFFE (one less than wraparound)
    assert_eq(GEN_MAX, 0xFFFFFFFE as UInt32);
}

@test
fn test_flag_constants() {
    // Flags should be distinct bit positions
    assert_eq(FLAG_BORROWED & FLAG_SHARED, 0);
    assert_eq(FLAG_BORROWED & FLAG_PINNED, 0);
    assert_eq(FLAG_SHARED & FLAG_PINNED, 0);
}

// =============================================================================
// Header Construction Tests
// =============================================================================

@test
fn test_header_new_initializes_correctly() {
    let header = AllocationHeader.new(128, 8, 0, CAP_OWNED);

    assert_eq(header.size, 128);
    assert_eq(header.alignment, 8);
    assert_eq(header.load_generation(), GEN_INITIAL);
    assert_eq(header.load_epoch(), 0);
    assert_eq(header.load_capabilities(), CAP_OWNED);
    assert_eq(header.type_id, 0);
    assert_eq(header.flags, 0);
}

@test
fn test_header_new_with_type_id() {
    // Use full constructor with explicit type_id
    let header = AllocationHeader.new(256, 16, 42, CAP_OWNED);

    assert_eq(header.size, 256);
    assert_eq(header.alignment, 16);
    assert_eq(header.type_id, 42);
    assert_eq(header.load_generation(), GEN_INITIAL);
}

@test
fn test_header_default_capabilities() {
    let header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Default should be CAP_OWNED (full access)
    assert(header.has_capability(CAP_READ));
    assert(header.has_capability(CAP_WRITE));
}

// =============================================================================
// Generation Counter Tests
// =============================================================================

@test
fn test_load_generation_atomic() {
    let header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Initial generation should be GEN_INITIAL
    let gen = header.load_generation();
    assert_eq(gen, GEN_INITIAL);
}

@test
fn test_store_generation_atomic() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_generation(100);
    assert_eq(header.load_generation(), 100);

    header.store_generation(999);
    assert_eq(header.load_generation(), 999);
}

@test
fn test_increment_generation_returns_old_value() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // First increment: 1 -> 2, returns 1
    let old1 = header.increment_generation();
    assert_eq(old1, GEN_INITIAL);
    assert_eq(header.load_generation(), GEN_INITIAL + 1);

    // Second increment: 2 -> 3, returns 2
    let old2 = header.increment_generation();
    assert_eq(old2, GEN_INITIAL + 1);
    assert_eq(header.load_generation(), GEN_INITIAL + 2);
}

@test
fn test_increment_generation_sequential() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Increment 1000 times
    let mut i = 0;
    while i < 1000 {
        let old = header.increment_generation();
        assert_eq(old, GEN_INITIAL + i as UInt32);
        i = i + 1;
    }

    assert_eq(header.load_generation(), GEN_INITIAL + 1000);
}

@test
fn test_generation_near_max() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Set to near max
    header.store_generation(GEN_MAX - 1);

    // Increment should reach GEN_MAX
    let old = header.increment_generation();
    assert_eq(old, GEN_MAX - 1);
    assert_eq(header.load_generation(), GEN_MAX);
}

@test
fn test_generation_wraparound_triggers_epoch_increment() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Set to GEN_MAX
    header.store_generation(GEN_MAX);
    let initial_epoch = header.load_epoch();

    // Increment should wrap to GEN_INITIAL and increment epoch
    header.increment_generation();

    assert_eq(header.load_generation(), GEN_INITIAL);
    assert_eq(header.load_epoch(), initial_epoch + 1);
}

// =============================================================================
// Epoch Counter Tests
// =============================================================================

@test
fn test_load_epoch_atomic() {
    let header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Initial epoch should be 0
    assert_eq(header.load_epoch(), 0);
}

@test
fn test_store_epoch_atomic() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_epoch(5);
    assert_eq(header.load_epoch(), 5);

    header.store_epoch(1000);
    assert_eq(header.load_epoch(), 1000);
}

@test
fn test_epoch_max_value() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Epoch is 16-bit
    header.store_epoch(0xFFFF);
    assert_eq(header.load_epoch(), 0xFFFF);
}

// =============================================================================
// Combined Generation+Epoch Tests
// =============================================================================

@test
fn test_load_generation_epoch_fast() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_generation(42);
    header.store_epoch(7);

    let (gen, epoch) = header.load_generation_epoch_fast();
    assert_eq(gen, 42);
    assert_eq(epoch, 7);
}

@test
fn test_load_generation_epoch_combined() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_generation(12345);
    header.store_epoch(99);

    let (gen, epoch) = header.load_generation_epoch_combined();
    assert_eq(gen, 12345);
    assert_eq(epoch, 99);
}

@test
fn test_generation_epoch_consistency() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Set specific values
    header.store_generation(0xABCDEF01);
    header.store_epoch(0x1234);

    // Both methods should return consistent values
    let (gen1, epoch1) = header.load_generation_epoch_fast();
    let (gen2, epoch2) = header.load_generation_epoch_combined();

    assert_eq(gen1, gen2);
    assert_eq(epoch1, epoch2);
}

// =============================================================================
// Capability Tests
// =============================================================================

@test
fn test_load_capabilities() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_capabilities(CAP_OWNED);
    assert_eq(header.load_capabilities(), CAP_OWNED);
}

@test
fn test_store_capabilities() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_capabilities(CAP_BORROW_SHARED);
    assert_eq(header.load_capabilities(), CAP_BORROW_SHARED);
}

@test
fn test_has_capability() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_capabilities(CAP_READ | CAP_WRITE);

    assert(header.has_capability(CAP_READ));
    assert(header.has_capability(CAP_WRITE));
    assert(header.has_capability(CAP_READ | CAP_WRITE));
}

@test
fn test_attenuate_capabilities() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_capabilities(CAP_OWNED);

    // Attenuate to read-only
    header.attenuate_capabilities(CAP_READ);

    assert(header.has_capability(CAP_READ));
    assert(!header.has_capability(CAP_WRITE));
}

// =============================================================================
// Reference Validation Tests
// =============================================================================

@test
fn test_validate_reference_success() {
    let header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    let gen = header.load_generation();
    let epoch = header.load_epoch();

    // Validation should succeed with matching gen/epoch
    let result = header.validate_reference(gen, epoch);
    assert(result.is_ok());
}

@test
fn test_validate_reference_generation_mismatch() {
    let header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    let gen = header.load_generation();
    let epoch = header.load_epoch();

    // Wrong generation should fail
    let result = header.validate_reference(gen + 1, epoch);
    assert(result.is_err());
}

@test
fn test_validate_reference_epoch_mismatch() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    let gen = header.load_generation();
    header.store_epoch(5);

    // Wrong epoch should fail
    let result = header.validate_reference(gen, 0);
    assert(result.is_err());
}

@test
fn test_validate_reference_fast() {
    let header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    let gen = header.load_generation();
    let epoch = header.load_epoch();

    // Fast validation should succeed
    let result = header.validate_reference_fast(gen, epoch);
    assert(result.is_ok());
}

@test
fn test_validate_detects_use_after_free() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Capture initial state
    let old_gen = header.load_generation();
    let old_epoch = header.load_epoch();

    // Simulate deallocation by incrementing generation
    header.increment_generation();

    // Old reference should now fail validation
    let result = header.validate_reference(old_gen, old_epoch);
    assert(result.is_err());
}

// =============================================================================
// Pointer Conversion Tests
// =============================================================================

@test
fn test_from_user_ptr() {
    // Allocate buffer with header space
    let buffer: [Byte; 96] = [0; 96];  // 32 header + 64 user data
    let buffer_ptr = &buffer[0] as &unsafe Byte;

    // Initialize header at buffer start
    unsafe {
        let header = buffer_ptr as &mut AllocationHeader;
        *header = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    }

    // User data starts after header
    let user_ptr = unsafe { ptr_offset(buffer_ptr, HEADER_SIZE) };

    // from_user_ptr should return the header
    let header = unsafe { AllocationHeader.from_user_ptr(user_ptr) };

    assert_eq(header.size, 64);
    assert_eq(header.alignment, 8);
}

@test
fn test_to_user_ptr() {
    let mut buffer: [Byte; 96] = [0; 96];
    let buffer_ptr = &mut buffer[0] as &unsafe mut Byte;

    unsafe {
        let header = buffer_ptr as &unsafe mut AllocationHeader;
        *header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

        let user_ptr = header.user_ptr();

        // User ptr should be HEADER_SIZE bytes after header
        let header_addr = (header as &unsafe Byte) as USize;
        let user_addr = (user_ptr as &unsafe Byte) as USize;
        assert_eq((user_addr - header_addr) as Int, HEADER_SIZE);
    }
}

@test
fn test_user_ptr_roundtrip() {
    let mut buffer: [Byte; 96] = [0; 96];
    let buffer_ptr = &mut buffer[0] as &unsafe mut Byte;

    unsafe {
        let header = buffer_ptr as &unsafe mut AllocationHeader;
        *header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

        let user_ptr = header.user_ptr();
        let header_back = AllocationHeader.from_user_ptr(user_ptr);

        let addr1 = (header as &unsafe Byte) as USize;
        let addr2 = (header_back as &unsafe Byte) as USize;
        assert_eq(addr1, addr2);
    }
}

// =============================================================================
// Flag Tests
// =============================================================================

@test
fn test_set_flag() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.set_flag(FLAG_BORROWED);
    assert(header.has_flag(FLAG_BORROWED));
    assert(!header.has_flag(FLAG_SHARED));
}

@test
fn test_clear_flag() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.set_flag(FLAG_BORROWED);
    assert(header.has_flag(FLAG_BORROWED));

    header.clear_flag(FLAG_BORROWED);
    assert(!header.has_flag(FLAG_BORROWED));
}

@test
fn test_multiple_flags() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.set_flag(FLAG_BORROWED);
    header.set_flag(FLAG_PINNED);

    assert(header.has_flag(FLAG_BORROWED));
    assert(header.has_flag(FLAG_PINNED));
    assert(!header.has_flag(FLAG_SHARED));

    header.clear_flag(FLAG_BORROWED);

    assert(!header.has_flag(FLAG_BORROWED));
    assert(header.has_flag(FLAG_PINNED));
}

