@test
fn test_type_id_stored() {
    let header = AllocationHeader.new_with_type(64, 8, 12345);
    assert_eq(header.type_id, 12345);
}

@test
fn test_type_id_max_value() {
    let header = AllocationHeader.new_with_type(64, 8, 0xFFFF);
    assert_eq(header.type_id, 0xFFFF);
}

// =============================================================================
// Size and Alignment Tests
// =============================================================================

@test
fn test_size_stored_correctly() {
    let header1 = AllocationHeader.new(1, 1, 0, CAP_OWNED);
    assert_eq(header1.size, 1 as UInt32);

    let header2 = AllocationHeader.new((1024 * 1024) as UInt32, 8, 0, CAP_OWNED);
    assert_eq(header2.size, (1024 * 1024) as UInt32);
}

@test
fn test_alignment_stored_correctly() {
    let header1 = AllocationHeader.new(64, 1, 0, CAP_OWNED);
    assert_eq(header1.alignment, 1);

    let header2 = AllocationHeader.new(64, 4096, 0, CAP_OWNED);
    assert_eq(header2.alignment, 4096);
}

// =============================================================================
// Edge Cases
// =============================================================================

@test
fn test_zero_size_allocation() {
    // Zero-size allocations should still have valid headers
    let header = AllocationHeader.new(0, 8, 0, CAP_OWNED);
    assert_eq(header.size, 0);
    assert_eq(header.load_generation(), GEN_INITIAL);
}

@test
fn test_large_size_allocation() {
    // Large allocations should work
    let header = AllocationHeader.new(1_000_000_000, 8, 0, CAP_OWNED);
    assert_eq(header.size, 1_000_000_000);
}

@test
fn test_generation_after_many_increments() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Increment many times
    for _ in 0..10000 {
        header.increment_generation();
    }

    assert_eq(header.load_generation(), GEN_INITIAL + 10000);
}

// =============================================================================
// Memory Ordering Tests (Conceptual)
// =============================================================================

@test
fn test_generation_load_has_acquire_semantics() {
    // This tests that generation loads use acquire ordering
    // ensuring visibility of prior writes
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_generation(42);

    // Acquire load should see the stored value
    let gen = header.load_generation();
    assert_eq(gen, 42);
}

@test
fn test_generation_store_has_release_semantics() {
    // This tests that generation stores use release ordering
    // ensuring prior writes are visible to other threads
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    header.store_generation(100);

    // Value should be visible
    assert_eq(header.load_generation(), 100);
}

// =============================================================================
// Integration Tests
// =============================================================================

@test
fn test_full_allocation_lifecycle() {
    let mut header = AllocationHeader.new(128, 16, 0, CAP_OWNED);

    // Initial state
    assert_eq(header.load_generation(), GEN_INITIAL);
    assert_eq(header.load_epoch(), 0);
    assert(header.has_capability(CAP_READ));
    assert(header.has_capability(CAP_WRITE));

    // Capture reference state
    let ref_gen = header.load_generation();
    let ref_epoch = header.load_epoch();

    // Validate should succeed
    assert(header.validate_reference(ref_gen, ref_epoch).is_ok());

    // Simulate borrow
    header.set_flag(FLAG_BORROWED);
    assert(header.has_flag(FLAG_BORROWED));

    // Simulate deallocation
    header.increment_generation();

    // Old reference should be invalid
    assert(header.validate_reference(ref_gen, ref_epoch).is_err());

    // New reference with correct gen should work
    let new_gen = header.load_generation();
    let new_epoch = header.load_epoch();
    assert(header.validate_reference(new_gen, new_epoch).is_ok());
}

@test
fn test_multiple_allocations_unique_generations() {
    let mut header1 = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    let mut header2 = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Both start at GEN_INITIAL
    assert_eq(header1.load_generation(), GEN_INITIAL);
    assert_eq(header2.load_generation(), GEN_INITIAL);

    // Increment header1 multiple times
    for _ in 0..5 {
        header1.increment_generation();
    }

    // Headers should have different generations
    assert(header1.load_generation() != header2.load_generation());
}

// =============================================================================
// Additional Header Tests
// =============================================================================

@test
fn test_header_new_generation_is_initial() {
    let header = AllocationHeader.new(32, 8, 0, CAP_OWNED);
    assert_eq(header.load_generation(), GEN_INITIAL);
    assert_eq(header.load_generation(), 1);
}

@test
fn test_flag_constants_nonzero() {
    assert(FLAG_BORROWED != 0);
    assert(FLAG_SHARED != 0);
    assert(FLAG_PINNED != 0);
}

@test
fn test_generation_store_then_validate() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    header.store_generation(500);
    let result = header.validate_reference(500, 0);
    assert(result.is_ok());
}

@test
fn test_capability_read_only() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_READ);
    assert(header.has_capability(CAP_READ));
    assert(!header.has_capability(CAP_WRITE));
}

@test
fn test_header_size_different_values() {
    let h1 = AllocationHeader.new(16, 8, 0, CAP_OWNED);
    let h2 = AllocationHeader.new(256, 8, 0, CAP_OWNED);
    let h3 = AllocationHeader.new(4096, 8, 0, CAP_OWNED);
    assert_eq(h1.size, 16);
    assert_eq(h2.size, 256);
    assert_eq(h3.size, 4096);
}

@test
fn test_multiple_epoch_increments() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    header.store_epoch(0);
    header.store_epoch(1);
    header.store_epoch(2);
    assert_eq(header.load_epoch(), 2);
}

@test
fn test_set_clear_all_flags() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    header.set_flag(FLAG_BORROWED);
    header.set_flag(FLAG_SHARED);
    header.set_flag(FLAG_PINNED);
    assert(header.has_flag(FLAG_BORROWED));
    assert(header.has_flag(FLAG_SHARED));
    assert(header.has_flag(FLAG_PINNED));
    header.clear_flag(FLAG_BORROWED);
    header.clear_flag(FLAG_SHARED);
    header.clear_flag(FLAG_PINNED);
    assert(!header.has_flag(FLAG_BORROWED));
    assert(!header.has_flag(FLAG_SHARED));
    assert(!header.has_flag(FLAG_PINNED));
}

@test
fn test_generation_epoch_independence() {
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    header.store_generation(999);
    header.store_epoch(7);
    // Changing generation shouldn't affect epoch and vice versa
    assert_eq(header.load_generation(), 999);
    assert_eq(header.load_epoch(), 7);
    header.store_generation(1);
    assert_eq(header.load_epoch(), 7);
    header.store_epoch(0);
    assert_eq(header.load_generation(), 1);
}

// Import for pointer operations
mount core.intrinsics.{ptr_offset};

// =============================================================================
// Additional Comprehensive Tests (8 new tests)
// =============================================================================

@test
fn test_allocation_flags_type_methods() {
    // Test AllocationFlags type and its is_* methods
    let flags_none = AllocationFlags.none();
    assert(!flags_none.is_pinned());
    assert(!flags_none.is_leaked());
    assert(!flags_none.is_shared());
    assert(!flags_none.has_weak());
    assert(!flags_none.is_large());
    assert(!flags_none.is_arena());

    let flags_pinned = AllocationFlags(FLAG_PINNED);
    assert(flags_pinned.is_pinned());
    assert(!flags_pinned.is_leaked());

    let flags_combined = AllocationFlags(FLAG_SHARED | FLAG_LARGE);
    assert(flags_combined.is_shared());
    assert(flags_combined.is_large());
    assert(!flags_combined.is_pinned());
    assert(!flags_combined.is_arena());
}

@test
fn test_validation_error_constructors() {
    // Test ValidationError constructors and variant matching
    let gen_err = ValidationError.generation_mismatch(100, 200);
    assert(gen_err is ValidationError.GenerationMismatch);

    let epoch_err = ValidationError.epoch_mismatch(5, 10);
    assert(epoch_err is ValidationError.EpochMismatch);

    // Test different mismatch values
    let err1 = ValidationError.generation_mismatch(GEN_INITIAL, GEN_MAX);
    assert(err1 is ValidationError.GenerationMismatch);

    let err2 = ValidationError.epoch_mismatch(0, 0xFFFF);
    assert(err2 is ValidationError.EpochMismatch);
}

@test
fn test_header_total_size_calculation() {
    // Test total_size() method includes header and data
    let header1 = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    assert_eq(header1.total_size(), HEADER_SIZE + 64);

    let header2 = AllocationHeader.new(1024, 16, 0, CAP_OWNED);
    assert_eq(header2.total_size(), HEADER_SIZE + 1024);

    let header3 = AllocationHeader.new(0, 8, 0, CAP_OWNED);
    assert_eq(header3.total_size(), HEADER_SIZE);

    let header4 = AllocationHeader.new((1024 * 1024) as UInt32, 8, 0, CAP_OWNED);
    assert_eq(header4.total_size(), HEADER_SIZE + 1024 * 1024);
}

@test
fn test_header_getter_methods() {
    // Test get_size(), get_alignment(), get_type_id() methods
    let header = AllocationHeader.new(512, 32, 99999, CAP_OWNED);

    assert_eq(header.get_size(), 512);
    assert_eq(header.get_alignment(), 32);
    assert_eq(header.get_type_id(), 99999);

    // Test with different values
    let header2 = AllocationHeader.new(8, 1, 0, CAP_READ);
    assert_eq(header2.get_size(), 8);
    assert_eq(header2.get_alignment(), 1);
    assert_eq(header2.get_type_id(), 0);

    // Test with max alignment
    let header3 = AllocationHeader.new(256, 4096, 0xABCD, CAP_OWNED);
    assert_eq(header3.get_size(), 256);
    assert_eq(header3.get_alignment(), 4096);
    assert_eq(header3.get_type_id(), 0xABCD);
}

@test
fn test_header_specific_flag_setters() {
    // Test set_pinned(), set_leaked(), set_shared(), set_has_weak()
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Initially no flags
    assert(!header.is_pinned());
    assert(!header.is_leaked());
    assert(!header.is_shared());
    assert(!header.has_weak_refs());

    // Set pinned
    header.set_pinned();
    assert(header.is_pinned());
    assert(!header.is_leaked());

    // Set leaked
    header.set_leaked();
    assert(header.is_pinned());
    assert(header.is_leaked());
    assert(!header.is_shared());

    // Set shared
    header.set_shared();
    assert(header.is_pinned());
    assert(header.is_leaked());
    assert(header.is_shared());
    assert(!header.has_weak_refs());

    // Set weak
    header.set_has_weak();
    assert(header.is_pinned());
    assert(header.is_leaked());
    assert(header.is_shared());
    assert(header.has_weak_refs());
}

@test
fn test_header_specific_flag_checkers() {
    // Test is_pinned(), is_leaked(), is_shared(), has_weak_refs() on constructed flags
    let mut header = AllocationHeader.new(128, 8, 0, CAP_OWNED);

    // Set flags directly via flags field
    header.flags = FLAG_PINNED | FLAG_SHARED;
    assert(header.is_pinned());
    assert(header.is_shared());
    assert(!header.is_leaked());
    assert(!header.has_weak_refs());

    // Test leaked and weak combination
    header.flags = FLAG_LEAKED | FLAG_WEAK;
    assert(header.is_leaked());
    assert(header.has_weak_refs());
    assert(!header.is_pinned());
    assert(!header.is_shared());

    // Test all flags
    header.flags = FLAG_PINNED | FLAG_LEAKED | FLAG_SHARED | FLAG_WEAK;
    assert(header.is_pinned());
    assert(header.is_leaked());
    assert(header.is_shared());
    assert(header.has_weak_refs());
}

@test
fn test_capability_attenuation_scenarios() {
    // Test complex capability attenuation scenarios
    let mut header = AllocationHeader.new(64, 8, 0, CAP_OWNED);

    // Start with full ownership (read + write)
    assert(header.has_capability(CAP_READ));
    assert(header.has_capability(CAP_WRITE));

    // Attenuate to read-only
    let old_caps = header.attenuate_capabilities(CAP_READ);
    assert_eq(old_caps, CAP_OWNED);  // Returns old value
    assert(header.has_capability(CAP_READ));
    assert(!header.has_capability(CAP_WRITE));

    // Cannot restore capabilities (attenuation is permanent)
    header.store_capabilities(CAP_OWNED);
    header.attenuate_capabilities(CAP_READ);
    assert(!header.has_capability(CAP_WRITE));

    // Test multiple attenuation steps
    let mut header2 = AllocationHeader.new(64, 8, 0, CAP_OWNED);
    header2.attenuate_capabilities(CAP_READ | CAP_WRITE);
    header2.attenuate_capabilities(CAP_READ);
    assert(header2.has_capability(CAP_READ));
    assert(!header2.has_capability(CAP_WRITE));
}

@test
fn test_validation_with_fast_vs_normal_paths() {
    // Compare validate_reference() vs validate_reference_fast()
    let mut header = AllocationHeader.new(128, 8, 0, CAP_OWNED);

    header.store_generation(777);
    header.store_epoch(3);

    // Both methods should agree
    let result_normal = header.validate_reference(777, 3);
    let result_fast = header.validate_reference_fast(777, 3);

    assert(result_normal.is_ok());
    assert(result_fast.is_ok());

    // Test failure case
    let result_normal_fail = header.validate_reference(778, 3);
    let result_fast_fail = header.validate_reference_fast(778, 3);

    assert(result_normal_fail.is_err());
    assert(result_fast_fail.is_err());

    // Test epoch mismatch
    let result_normal_epoch = header.validate_reference(777, 4);
    let result_fast_epoch = header.validate_reference_fast(777, 4);

    assert(result_normal_epoch.is_err());
    assert(result_fast_epoch.is_err());
}
