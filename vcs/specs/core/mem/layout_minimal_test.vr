}

// =============================================================================
// Section 9: Constants
// =============================================================================

@test
fn test_size_class_count() {
    assert_eq(SIZE_CLASS_COUNT, 11);
}

@test
fn test_page_size() {
    assert_eq(PAGE_SIZE, 65536);
}

@test
fn test_chunk_size() {
    assert_eq(CHUNK_SIZE, 2097152);
}

@test
fn test_large_threshold() {
    assert_eq(LARGE_THRESHOLD, 2048);
}

@test
fn test_max_slots_per_page() {
    assert_eq(MAX_SLOTS_PER_PAGE, 512);
}

@test
fn test_guard_page_size() {
    assert_eq(GUARD_PAGE_SIZE, 4096);
}

@test
fn test_size_classes_array() {
    assert_eq(SIZE_CLASSES[0], 16);
    assert_eq(SIZE_CLASSES[1], 32);
    assert_eq(SIZE_CLASSES[2], 48);
    assert_eq(SIZE_CLASSES[3], 64);
    assert_eq(SIZE_CLASSES[4], 80);
    assert_eq(SIZE_CLASSES[5], 96);
    assert_eq(SIZE_CLASSES[6], 128);
    assert_eq(SIZE_CLASSES[7], 256);
    assert_eq(SIZE_CLASSES[8], 512);
    assert_eq(SIZE_CLASSES[9], 1024);
    assert_eq(SIZE_CLASSES[10], 2048);
}

// =============================================================================
// Section 10: AllocError Variants
// =============================================================================

@test
fn test_alloc_error_out_of_memory() {
    let err = AllocError.OutOfMemory { requested: 1024 };
    assert(err is AllocError.OutOfMemory);
    assert(!(err is AllocError.InvalidSize));
}

@test
fn test_alloc_error_invalid_size() {
    let err = AllocError.InvalidSize { size: -1 };
    assert(err is AllocError.InvalidSize);
}

@test
fn test_alloc_error_invalid_alignment() {
    let err = AllocError.InvalidAlignment { alignment: 3 };
    assert(err is AllocError.InvalidAlignment);
}

@test
fn test_alloc_error_mmap_failed() {
    let err = AllocError.MmapFailed { code: 12 };
    assert(err is AllocError.MmapFailed);
}

@test
fn test_alloc_error_munmap_failed() {
    let err = AllocError.MunmapFailed { code: 22 };
    assert(err is AllocError.MunmapFailed);
}

@test
fn test_alloc_error_page_exhausted() {
    let err = AllocError.PageExhausted;
    assert(err is AllocError.PageExhausted);
}

@test
fn test_alloc_error_invalid_pointer() {
    let err = AllocError.InvalidPointer;
    assert(err is AllocError.InvalidPointer);
}

@test
fn test_alloc_error_message_out_of_memory() {
    let err = AllocError.OutOfMemory { requested: 4096 };
    let msg = err.message();
    assert(msg.contains("out of memory"));
    assert(msg.contains("4096"));
}

@test
fn test_alloc_error_message_invalid_size() {
    let err = AllocError.InvalidSize { size: 0 };
    let msg = err.message();
    assert(msg.contains("invalid"));
    assert(msg.contains("size"));
}

@test
fn test_alloc_error_message_invalid_alignment() {
    let err = AllocError.InvalidAlignment { alignment: 5 };
    let msg = err.message();
    assert(msg.contains("alignment"));
}

@test
fn test_alloc_error_all_variants_distinct() {
    let oom = AllocError.OutOfMemory { requested: 0 };
    let isz = AllocError.InvalidSize { size: 0 };
    let ial = AllocError.InvalidAlignment { alignment: 0 };
    let mmf = AllocError.MmapFailed { code: 0 };
    let muf = AllocError.MunmapFailed { code: 0 };
    let pex = AllocError.PageExhausted;
    let inv = AllocError.InvalidPointer;

    assert(oom is AllocError.OutOfMemory);
    assert(!(oom is AllocError.InvalidSize));
    assert(isz is AllocError.InvalidSize);
    assert(!(isz is AllocError.OutOfMemory));
    assert(ial is AllocError.InvalidAlignment);
    assert(mmf is AllocError.MmapFailed);
    assert(muf is AllocError.MunmapFailed);
    assert(pex is AllocError.PageExhausted);
    assert(inv is AllocError.InvalidPointer);
}

// =============================================================================
// Section 11: Layout Composition Patterns
// =============================================================================

@test
fn test_layout_struct_simulation() {
    // Simulate: type Foo is { a: Int (8, align 8), b: Float (8, align 8) };
    let field_a = Layout.from_size_align(8, 8);
    let field_b = Layout.from_size_align(8, 8);
    let combined = field_a.extend(field_b);
    assert_eq(combined.size(), 16);
    assert_eq(combined.align(), 8);
}

@test
fn test_layout_struct_with_padding() {
    // Simulate: type Bar is { a: Byte (1, align 1), b: Int (8, align 8) };
    let field_a = Layout.from_size_align(1, 1);
    let field_b = Layout.from_size_align(8, 8);
    let combined = field_a.extend(field_b);
    // 1 aligned up to 8 = 8, plus 8 = 16
    assert_eq(combined.size(), 16);
    assert_eq(combined.align(), 8);
}

@test
fn test_layout_array_of_structs() {
    let elem = Layout.from_size_align(24, 8);
    let padded = elem.pad_to_align();
    let array = padded.repeat(10);
    assert_eq(array.size(), 240);
    assert_eq(array.align(), 8);
}

@test
fn test_layout_nested_extend() {
    let a = Layout.from_size_align(4, 4);
    let b = Layout.from_size_align(8, 8);
    let c = Layout.from_size_align(4, 4);
    let ab = a.extend(b);
    let abc = ab.extend(c);
    // a=4 aligned to 8 = 8, +8 = 16, aligned to 4 = 16, +4 = 20
    assert_eq(abc.size(), 20);
    assert_eq(abc.align(), 8);
}

// =============================================================================
// Section 12: align_up/align_down Edge Cases
// =============================================================================

@test
fn test_align_up_power_of_two_inputs() {
    assert_eq(align_up(8, 8), 8);
    assert_eq(align_up(16, 16), 16);
    assert_eq(align_up(32, 32), 32);
    assert_eq(align_up(64, 64), 64);
}

@test
fn test_align_up_just_over() {
    assert_eq(align_up(17, 16), 32);
    assert_eq(align_up(33, 32), 64);
    assert_eq(align_up(65, 64), 128);
}

@test
fn test_align_down_power_of_two_inputs() {
    assert_eq(align_down(8, 8), 8);
    assert_eq(align_down(16, 16), 16);
    assert_eq(align_down(32, 32), 32);
}

@test
fn test_align_down_just_under() {
    assert_eq(align_down(15, 16), 0);
    assert_eq(align_down(31, 32), 0);
    assert_eq(align_down(63, 64), 0);
}

@test
fn test_align_up_align_one() {
    assert_eq(align_up(7, 1), 7);
    assert_eq(align_up(0, 1), 0);
    assert_eq(align_up(100, 1), 100);
}

@test
fn test_align_down_align_one() {
    assert_eq(align_down(7, 1), 7);
    assert_eq(align_down(0, 1), 0);
    assert_eq(align_down(100, 1), 100);
}

fn main() {
    // Tests run via @test annotations
}
