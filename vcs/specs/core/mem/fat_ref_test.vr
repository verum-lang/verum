fn test_fat_ref_epoch() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let fat = unsafe {
        FatRef.new_slice(ptr, 1, 7, CAP_READ, 10, 0)
