@test
fn test_fat_ref_is_empty() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let empty = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_READ, 0, 0)
    };

    let non_empty = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_READ, 1, 0)
    };

    assert(empty.is_empty());
    assert(!non_empty.is_empty());
}

@test
fn test_fat_ref_offset_from_base() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let fat = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_READ, 10, 64)
    };

    assert_eq(fat.offset_from_base(), 64);
}

// =============================================================================
// Capability Check Tests
// =============================================================================

@test
fn test_fat_ref_has_capability() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let fat = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_READ | CAP_WRITE, 10, 0)
    };

    assert(fat.has_capability(CAP_READ));
    assert(fat.has_capability(CAP_WRITE));
    assert(!fat.has_capability(CAP_REVOKE));
}

@test
fn test_fat_ref_can_read() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let readable = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_READ, 10, 0)
    };

    assert(readable.can_read());
}

@test
fn test_fat_ref_can_write() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let writable = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_WRITE | CAP_MUTABLE, 10, 0)
    };

    let readonly = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_READ, 10, 0)
    };

    assert(writable.can_write());
    assert(!readonly.can_write());
}

