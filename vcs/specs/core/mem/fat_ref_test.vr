@test
fn test_fat_ref_offset_value() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;
    let fat = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_READ, 5, 10)
    };
    assert_eq(fat.offset_from_base(), 10);
}
