// =============================================================================
// VCS Test Suite: stdlib/mem/fat_ref.vr - FatRef<T> Tests
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: mem, cbgr, fat_ref, slice, unsized, validation
// @timeout: 30000
// =============================================================================
//
// Tests for FatRef<T>, the 32-byte generational reference for unsized types
// (slices, trait objects). Extends ThinRef with metadata for length/vtable
// and supports offset tracking for subslice views.
//
// =============================================================================

mount core.mem.fat_ref.{
    FatRef, fat_ref_from_heap, empty_slice,
};
mount core.mem.header.{
    AllocationHeader, HEADER_SIZE, GEN_INITIAL, GEN_UNALLOCATED,
};
mount core.mem.capability.{
    CAP_READ, CAP_WRITE, CAP_MUTABLE, CAP_REVOKE, CAP_OWNED,
    CAP_BORROW_SHARED, CAP_READ_WRITE,
};
mount core.mem.{UseAfterFreeError, RevocationError};

mount core.intrinsics.{ptr_offset, ptr_write};

// =============================================================================
// Layout Tests
// =============================================================================

@test
fn test_fat_ref_size_is_32_bytes() {
    // FatRef must be exactly 32 bytes (half cache line)
    assert_eq(FatRef<[Int]>.size, 32);
}

@test
fn test_fat_ref_alignment_is_8() {
    // Must be 8-byte aligned
    assert_eq(FatRef<[Int]>.align, 8);
}

// =============================================================================
// Construction Tests
// =============================================================================

@test
fn test_fat_ref_new_slice() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let fat = unsafe {
        FatRef.new_slice(ptr, 1, 0, CAP_OWNED, 10, 0)
    };

    assert_eq(fat.generation(), 1);
    assert_eq(fat.epoch(), 0);
    assert_eq(fat.len(), 10);
    assert_eq(fat.offset_from_base(), 0);
    assert(!fat.is_null());
}

@test
fn test_fat_ref_new_dyn() {
    let buffer: [Byte; 256] = [0; 256];
    let ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let vtable_ptr = 0x12345678 as Int;  // Fake vtable

    let fat = unsafe {
        FatRef.new_dyn(ptr, 1, 0, CAP_READ, vtable_ptr)
    };

    assert_eq(fat.metadata(), vtable_ptr);
    assert(!fat.is_null());
}

@test
fn test_fat_ref_null() {
    let fat: FatRef<[Int]> = unsafe { FatRef.null() };

    assert(fat.is_null());
    assert_eq(fat.generation(), GEN_UNALLOCATED);
    assert_eq(fat.len(), 0);
}

@test
fn test_empty_slice_function() {
    let fat: FatRef<[Int]> = empty_slice();

    assert(fat.is_null());
    assert(fat.is_empty());
    assert_eq(fat.len(), 0);
}

@test
fn test_fat_ref_from_header() {
    let buffer: [Byte; 256] = [0; 256];
    let header_ptr = &buffer[0] as &unsafe mut AllocationHeader;

    unsafe {
        *header_ptr = AllocationHeader.new(200, 8, 0, CAP_READ_WRITE);
    }

    let user_ptr = &buffer[HEADER_SIZE] as &unsafe Byte;

    let fat = unsafe {
        FatRef.from_header(user_ptr, header_ptr, 5, CAP_READ)
    };

    assert_eq(fat.generation(), GEN_INITIAL);
    assert_eq(fat.len(), 5);
    assert(!fat.is_null());
}

