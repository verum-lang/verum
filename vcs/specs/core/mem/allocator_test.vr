@requires(runtime)
@test
fn test_multiple_large_allocations() {
    let mut ptrs: List<&unsafe Byte> = List.new();

    for _ in 0..5 {
        let (ptr, _, _) = cbgr_alloc(100000, 16).unwrap();
        ptrs.push(ptr);
    }

    // Free in reverse order
    for i in (0..5).rev() {
        cbgr_dealloc(ptrs[i]).unwrap();
    }
}

