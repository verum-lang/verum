/// Test cbgr_alloc rejects zero size
@test
fn test_cbgr_alloc_rejects_zero_size() {
    let result = cbgr_alloc(0, 8);
    assert(result.is_err());
    match result {
        Err(AllocError.InvalidSize { size }) => assert_eq(size, 0),
        _ => panic("Expected InvalidSize error"),
    }
}

/// Test cbgr_alloc rejects negative size
@test
fn test_cbgr_alloc_rejects_negative_size() {
    let result = cbgr_alloc(-100, 8);
    assert(result.is_err());
    match result {
        Err(AllocError.InvalidSize { size }) => assert_eq(size, -100),
        _ => panic("Expected InvalidSize error"),
    }
}

/// Test cbgr_alloc rejects invalid alignment (not power of 2)
@test
fn test_cbgr_alloc_rejects_invalid_alignment() {
    let result = cbgr_alloc(100, 7);
    assert(result.is_err());
    match result {
