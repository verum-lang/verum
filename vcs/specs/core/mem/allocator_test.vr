/// Test allocation routes to correct size class
@requires(runtime)
@test
fn test_allocation_size_class_routing() {
    // Size 10 should use size class 0 (16 bytes)
    let (ptr1, _, _) = cbgr_alloc(10, 1).unwrap();
    cbgr_dealloc(ptr1).unwrap();

    // Size 50 should use size class 3 (64 bytes)
    let (ptr2, _, _) = cbgr_alloc(50, 1).unwrap();
    cbgr_dealloc(ptr2).unwrap();

    // Size 200 should use size class 7 (256 bytes)
    let (ptr3, _, _) = cbgr_alloc(200, 1).unwrap();
    cbgr_dealloc(ptr3).unwrap();

    // Size 1500 should use size class 10 (2048 bytes)
    let (ptr4, _, _) = cbgr_alloc(1500, 1).unwrap();
    cbgr_dealloc(ptr4).unwrap();
}

/// Test large allocation bypasses size classes
@requires(runtime)
@test
fn test_large_allocation_direct_mmap() {
    // Size > LARGE_THRESHOLD should use direct mmap
    let (ptr, gen, epoch) = cbgr_alloc(10000, 8).unwrap();

    assert((ptr as Int) != 0);

    cbgr_dealloc(ptr).unwrap();
}

/// Test allocation respects alignment
@requires(runtime)
@test
fn test_allocation_alignment() {
    for align in [1, 2, 4, 8, 16, 32] {
        let (ptr, _, _) = cbgr_alloc(64, align).unwrap();
        let ptr_val = ptr as Int;

        assert_eq(ptr_val % align, 0, f"Pointer should be {align}-byte aligned");

        cbgr_dealloc(ptr).unwrap();
    }
}

