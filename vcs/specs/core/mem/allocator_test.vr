/// Test SimpleAllocator tracks multiple allocations
@requires(runtime)
@test
fn test_simple_allocator_tracking() {
    let simple = SimpleAllocator.init().unwrap();

    let (ptr1, _, _) = simple.alloc(32, 8).unwrap();
    let (ptr2, _, _) = simple.alloc(64, 8).unwrap();
    let (ptr3, _, _) = simple.alloc(128, 8).unwrap();

    assert_eq(simple.active_allocations(), 3);
    assert_eq(simple.total_bytes_allocated(), 224);

    simple.dealloc(ptr2).unwrap();
    assert_eq(simple.active_allocations(), 2);

    simple.dealloc(ptr1).unwrap();
    simple.dealloc(ptr3).unwrap();
    assert_eq(simple.active_allocations(), 0);

    simple.shutdown();
}

/// Test StackAllocator initialization with capacity
