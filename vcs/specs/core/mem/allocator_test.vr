    let mut allocator = result.unwrap();
    assert_eq(allocator.total_capacity(), 65536);
    assert_eq(allocator.bytes_used(), 0);
    assert_eq(allocator.bytes_remaining(), 65536);
    assert_eq(allocator.allocation_count(), 0);
    allocator.shutdown();
}

