    let (ptr2, _, _) = cbgr_alloc(64, 8).unwrap();
    cbgr_dealloc(ptr1).unwrap();
    let (ptr3, _, _) = cbgr_alloc(48, 8).unwrap();
    cbgr_dealloc(ptr2).unwrap();
    let (ptr4, _, _) = cbgr_alloc(96, 8).unwrap();
    cbgr_dealloc(ptr3).unwrap();
    cbgr_dealloc(ptr4).unwrap();
}

/// Test allocation of all size classes
@requires(runtime)
@test
fn test_alloc_all_size_classes() {
    let mut ptrs: List<&unsafe Byte> = List.new();

    for i in 0..SIZE_CLASS_COUNT {
        let size = SIZE_CLASSES[i];
        let (ptr, _, _) = cbgr_alloc(size, 8).unwrap();
        ptrs.push(ptr);
    }

    for ptr in ptrs.iter() {
        cbgr_dealloc(*ptr).unwrap();
    }
}

