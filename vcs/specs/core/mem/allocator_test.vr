    assert(result.is_err());
    match result {
        Err(AllocError.InvalidPointer) => {},
        _ => panic("Expected InvalidPointer error"),
    }
}

/// Test cbgr_alloc and cbgr_dealloc basic cycle
@requires(runtime)
@test
fn test_cbgr_alloc_dealloc_cycle() {
    let result = cbgr_alloc(64, 8);
    assert(result.is_ok());

    let (ptr, gen, epoch) = result.unwrap();
    assert((ptr as Int) != 0);
    assert(gen > 0);

    let dealloc_result = cbgr_dealloc(ptr);
    assert(dealloc_result.is_ok());
}

/// Test cbgr_alloc_zeroed zeros memory
@requires(runtime)
@test
fn test_cbgr_alloc_zeroed() {
    let result = cbgr_alloc_zeroed(128, 16);
    assert(result.is_ok());

    let (ptr, _, _) = result.unwrap();

    // Check all bytes are zero
    let slice: &[Byte] = unsafe { slice_from_raw_parts(ptr, 128) };
    for i in 0..128 {
        assert_eq(slice[i], 0 as Byte, f"Byte {i} should be zero");
    }

    cbgr_dealloc(ptr).unwrap();
}

/// Test cbgr_alloc returns unique pointers
@requires(runtime)
@test
fn test_cbgr_alloc_unique_pointers() {
    let mut ptrs: List<&unsafe Byte> = List.new();

    for _ in 0..10 {
        let (ptr, _, _) = cbgr_alloc(64, 8).unwrap();

        // Check not duplicate (compare addresses as integers)
        let ptr_val = ptr as Int;
        for existing in ptrs.iter() {
            assert(ptr_val != (*existing as Int), "Pointers must be unique");
        }
        ptrs.push(ptr);
    }

    // Cleanup
    for ptr_ref in ptrs.iter() {
        cbgr_dealloc(*ptr_ref).unwrap();
    }
}

/// Test cbgr_realloc grows allocation
@requires(runtime)
@test
fn test_cbgr_realloc_grow() {
    let (old_ptr, _, _) = cbgr_alloc(64, 8).unwrap();

    // Write some data
    let old_slice: &mut [Byte] = unsafe { slice_from_raw_parts_mut(old_ptr, 64) };
    for i in 0..64 {
        old_slice[i] = (i % 256) as Byte;
    }

    // Reallocate larger
    let result = cbgr_realloc(old_ptr, 64, 256, 8);
    assert(result.is_ok());

    let (new_ptr, _, _) = result.unwrap();

    // Check old data preserved
    let new_slice: &[Byte] = unsafe { slice_from_raw_parts(new_ptr, 256) };
    for i in 0..64 {
        assert_eq(new_slice[i], (i % 256) as Byte, f"Byte {i} should be preserved");
    }

    cbgr_dealloc(new_ptr).unwrap();
}

/// Test cbgr_realloc shrinks allocation
@requires(runtime)
@test
fn test_cbgr_realloc_shrink() {
    let (old_ptr, _, _) = cbgr_alloc(256, 8).unwrap();

    // Write some data
    let old_slice: &mut [Byte] = unsafe { slice_from_raw_parts_mut(old_ptr, 256) };
    for i in 0..256 {
        old_slice[i] = (i % 256) as Byte;
    }

    // Reallocate smaller
    let result = cbgr_realloc(old_ptr, 256, 64, 8);
    assert(result.is_ok());

    let (new_ptr, _, _) = result.unwrap();

    // Check data preserved (only first 64 bytes)
    let new_slice: &[Byte] = unsafe { slice_from_raw_parts(new_ptr, 64) };
    for i in 0..64 {
        assert_eq(new_slice[i], (i % 256) as Byte, f"Byte {i} should be preserved");
    }

    cbgr_dealloc(new_ptr).unwrap();
}

