/// Test allocation at size class boundary
@requires(runtime)
@test
fn test_alloc_at_boundary() {
    // Exactly 16 bytes - first size class
    let (ptr16, _, _) = cbgr_alloc(16, 8).unwrap();
    cbgr_dealloc(ptr16).unwrap();

    // Exactly 2048 bytes - last size class
    let (ptr2048, _, _) = cbgr_alloc(2048, 8).unwrap();
    cbgr_dealloc(ptr2048).unwrap();

    // Just over 2048 - should be large allocation
    let (ptr_large, _, _) = cbgr_alloc(2049, 8).unwrap();
    cbgr_dealloc(ptr_large).unwrap();
}

