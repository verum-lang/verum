    let result = StackAllocator.init(0);
    assert(result.is_err());

    let result2 = StackAllocator.init(-1);
    assert(result2.is_err());
}

/// Test StackAllocator dealloc is no-op
@requires(runtime)
@test
fn test_stack_allocator_dealloc_noop() {
    let mut stack = StackAllocator.init(4096).unwrap();

    let (ptr, _, _) = stack.alloc(64, 8).unwrap();

    // Stack allocator dealloc should succeed but do nothing
    let result = stack.dealloc(ptr);
    assert(result.is_ok());

    // Bytes used should not decrease after dealloc (bump allocator)
    assert(stack.bytes_used() >= 64);

    stack.shutdown();
}

/// Test StackAllocator reset
@requires(runtime)
@test
fn test_stack_allocator_reset() {
    let mut stack = StackAllocator.init(4096).unwrap();

    stack.alloc(100, 8).unwrap();
    stack.alloc(200, 8).unwrap();
    assert(stack.bytes_used() > 0);
    assert_eq(stack.allocation_count(), 2);

    stack.reset();
    assert_eq(stack.bytes_used(), 0);
    assert_eq(stack.allocation_count(), 0);
    assert_eq(stack.bytes_remaining(), 4096);

    // Can allocate again after reset
    stack.alloc(50, 8).unwrap();
    assert(stack.bytes_used() >= 50);

    stack.shutdown();
}

/// Test StackAllocator out of memory
@requires(runtime)
@test
fn test_stack_allocator_oom() {
    let mut stack = StackAllocator.init(256).unwrap();

    // Fill most of the capacity
    stack.alloc(200, 8).unwrap();

    // This should fail — only ~56 bytes remaining
    let result = stack.alloc(100, 8);
    assert(result.is_err());

    stack.shutdown();
}

/// Test StackAllocator peak usage tracking
@requires(runtime)
@test
fn test_stack_allocator_peak_usage() {
    let mut stack = StackAllocator.init(4096).unwrap();

    stack.alloc(100, 8).unwrap();
    stack.alloc(200, 8).unwrap();
    let peak_before_reset = stack.peak();
    assert(peak_before_reset > 0);

    stack.reset();
    // Peak should persist after reset
    assert_eq(stack.peak(), peak_before_reset);

    stack.shutdown();
}

