/// Test Layout with zero size
@test
fn test_layout_zero_size() {
    let layout = Layout.from_size_align(0, 8);
    assert_eq(layout.size(), 0);
    assert_eq(layout.align(), 8);
}

/// Test Layout extend with zero-size layout
@test
fn test_layout_extend_zero_size() {
    let first = Layout.from_size_align(0, 4);
    let second = Layout.from_size_align(16, 8);

    let combined = first.extend(second);
    assert_eq(combined.size(), 16);
    assert_eq(combined.align(), 8);
}

/// Test Layout repeat with large count
@test
fn test_layout_repeat_large() {
    let element = Layout.from_size_align(8, 8);
    let array = element.repeat(1000);

    assert_eq(array.size(), 8000);
    assert_eq(array.align(), 8);
}

// =============================================================================
// SECTION 17: Integration Tests
// =============================================================================

/// Test complete allocation workflow
@requires(runtime)
@test
fn test_complete_allocation_workflow() {
    // 1. Allocate
    let (ptr, gen, epoch) = cbgr_alloc(100, 16).unwrap();

    // 2. Write data
    let slice: &mut [Byte] = unsafe { slice_from_raw_parts_mut(ptr, 100) };
    for i in 0..100 {
        slice[i] = (i % 256) as Byte;
    }

    // 3. Read and verify
    for i in 0..100 {
        assert_eq(slice[i], (i % 256) as Byte);
    }

    // 4. Reallocate larger
    let (new_ptr, new_gen, new_epoch) = cbgr_realloc(ptr, 100, 200, 16).unwrap();

    // 5. Verify data preserved
    let new_slice: &[Byte] = unsafe { slice_from_raw_parts(new_ptr, 200) };
    for i in 0..100 {
        assert_eq(new_slice[i], (i % 256) as Byte);
    }

    // 6. Deallocate
    cbgr_dealloc(new_ptr).unwrap();
}

/// Test allocator under memory pressure
@requires(runtime)
@test
fn test_allocator_memory_pressure() {
    let mut ptrs: List<&unsafe Byte> = List.new();

    // Allocate many small objects
    for _ in 0..100 {
        let (ptr, _, _) = cbgr_alloc(16, 8).unwrap();
        ptrs.push(ptr);
    }

    // Free half
    for i in 0..50 {
        cbgr_dealloc(ptrs[i]).unwrap();
    }

    // Allocate more
    for _ in 0..50 {
        let (ptr, _, _) = cbgr_alloc(16, 8).unwrap();
        ptrs.push(ptr);
    }

    // Free remaining
    for i in 50..ptrs.len() {
        cbgr_dealloc(ptrs[i]).unwrap();
    }
}

/// Test mixed small and large allocations
@requires(runtime)
@test
fn test_mixed_allocation_sizes() {
    let mut ptrs: List<(&unsafe Byte, Int)> = List.new();

    // Mix of sizes
    let sizes = [16, 5000, 64, 10000, 128, 3000, 256, 8000, 512, 20000];

    for size in sizes {
        let (ptr, _, _) = cbgr_alloc(size, 8).unwrap();
        ptrs.push((ptr, size));
    }

    // Verify and free - dereference ptr since iter() yields references
    for (ptr, size) in ptrs.iter() {
        cbgr_dealloc(*ptr as &unsafe Byte).unwrap();
    }
}

