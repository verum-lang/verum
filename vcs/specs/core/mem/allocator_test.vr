/// Test stats track allocations
@requires(runtime)
@test
fn test_alloc_stats_tracking() {
    let stats_before = get_alloc_stats();

    let (ptr, _, _) = cbgr_alloc(64, 8).unwrap();

    let stats_after = get_alloc_stats();

    assert(stats_after.alloc_count > stats_before.alloc_count,
           "alloc_count should increase after allocation");
    assert(stats_after.bytes_allocated > stats_before.bytes_allocated,
           "bytes_allocated should increase after allocation");

    cbgr_dealloc(ptr).unwrap();
}

/// Test stats track deallocations
@requires(runtime)
@test
fn test_dealloc_stats_tracking() {
    let (ptr, _, _) = cbgr_alloc(64, 8).unwrap();

    let stats_before = get_alloc_stats();

    cbgr_dealloc(ptr).unwrap();

    let stats_after = get_alloc_stats();

    assert(stats_after.dealloc_count > stats_before.dealloc_count,
           "dealloc_count should increase after deallocation");
}

