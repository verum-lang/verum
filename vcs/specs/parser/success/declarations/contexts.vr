// @test: parse
// @level: L0
// @tags: parser, declarations, contexts, dependency-injection
// @description: Test context definition parsing with all variations

// Minimal context
context Empty {
}

// Basic context
context Database {
    fn query(&self, sql: Text) -> List<Row>;
    fn execute(&mut self, sql: Text) -> Int;
}

// Async context (keyword before context)
async context HttpClient {
    async fn get(&self, url: Text) -> Response;
    async fn post(&self, url: Text, body: Bytes) -> Response;
}

// Alternative async syntax (keyword after context)
context async NetworkClient {
    async fn connect(&mut self, host: Text, port: Int);
    async fn send(&mut self, data: Bytes);
}

// Context with multiple methods
context Logger {
    fn log(&self, level: Int, message: Text);
    fn debug(&self, message: Text);
    fn info(&self, message: Text);
    fn warn(&self, message: Text);
    fn error(&self, message: Text);
}

// Context with various method signatures
context FileSystem {
    fn read(&self, path: Text) -> Result<Text, IoError>;
    fn write(&mut self, path: Text, content: Text) -> Result<(), IoError>;
    fn exists(&self, path: Text) -> Bool;
    fn delete(&mut self, path: Text) -> Result<(), IoError>;
    fn list_dir(&self, path: Text) -> List<Text>;
}

// Context with methods using Self types (no type/const declarations)
context Repository {
    fn find_by_id(&self, id: Int) -> Maybe<Entity>;
    fn save(&mut self, entity: Entity) -> Int;
}

// Context with configuration-like methods
context Configuration {
    fn version(&self) -> Int;
    fn name(&self) -> Text;
    fn get(&self, key: Text) -> Maybe<Text>;
    fn set(&mut self, key: Text, value: Text);
}

// Generic context
context Cache<T> {
    fn get(&self, key: Text) -> Maybe<T>;
    fn set(&mut self, key: Text, value: T);
    fn invalidate(&mut self, key: Text);
    fn clear(&mut self);
}

// Context with multiple type parameters
context Mapper<A, B> {
    fn map(&self, a: A) -> B;
    fn unmap(&self, b: B) -> A;
}

// Context with bounds
context OrderedCache<T: Ord> {
    fn get_min(&self) -> Maybe<T>;
    fn get_max(&self) -> Maybe<T>;
    fn range(&self, min: T, max: T) -> List<T>;
}

context HashCache<K: Hash + Eq, V> {
    fn get(&self, key: &K) -> Maybe<&V>;
    fn insert(&mut self, key: K, value: V);
}

// Context with context requirements on methods
context TransactionalDatabase {
    fn begin(&mut self) using [Database];
    fn commit(&mut self) using [Database];
    fn rollback(&mut self) using [Database];
}

context ServiceA {
    fn do_work(&self) using [Logger];
}

context ServiceB {
    fn process(&self, data: Data) -> Result<Data, Error> using [ServiceA, Logger];
}

// Context with visibility modifiers
pub context PublicContext {
    fn public_method(&self);
}

internal context InternalContext {
    fn internal_method(&self);
}

protected context ProtectedContext {
    fn protected_method(&self);
}

// Context with method (no visibility on methods - not supported)
context SingleVisibility {
    fn method_one(&self);
    fn method_two(&self);
}

// Context with reference parameters
context BufferManager {
    fn read(&self, buf: &mut [u8]) -> Int;
    fn write(&mut self, buf: &[u8]) -> Int;
    fn peek(&self, buf: &[u8]) -> &[u8];
}

// Context with function type parameters
context CallbackRegistry {
    fn register(&mut self, name: Text, callback: fn());
    fn register_with_arg(&mut self, name: Text, callback: fn(Int));
    fn register_async(&mut self, name: Text, callback: fn() -> Future<()>);
}

// Context protocol (dual-kind - both constraint and injectable)
context protocol Serializable {
    fn serialize(&self) -> Text;
    fn deserialize(text: Text) -> Result<Self, Error>;
}

context protocol Comparable {
    fn compare(&self, other: &Self) -> Ordering;
}

// Context protocol with extension
context protocol OrderedSerializable extends Serializable {
    fn compare(&self, other: &Self) -> Ordering;
}

// Context protocol with generics
context protocol Convertible<T> {
    fn to(&self) -> T;
    fn from(value: T) -> Self;
}

// Context type protocol (alternative full syntax)
context type Hashable is protocol {
    fn hash(&self) -> u64;
};

context type Copyable is protocol extends Clone {
    fn copy(&self) -> Self;
};

// Context groups
using IOContexts = [FileSystem, Network, Console];

using DatabaseContexts = [Database, Cache, TransactionManager];

using AllContexts = [IOContexts, DatabaseContexts, Logger];

// Context group with negations
using Pure = [!IO, !Database, !Network, !FileSystem];

// Context group with transformations
using TransactionalDb = [Database.transactional()];

using ScopedCache = [Cache.scoped(request_id)];

// Complex context group
using WebServiceContexts = [
    Database.transactional() as db,
    Cache.scoped() as cache,
    Logger as log,
    HttpClient,
    !Console
];

// Single context in group
using SimpleDb = [Database];

using LoggingOnly = [Logger];

// Generic context without where clause
context EntityRepository<T: Entity> {
    fn find(&self, id: Int) -> Maybe<T>;
    fn find_all(&self) -> List<T>;
    fn save(&mut self, entity: T) -> Int;
    fn delete(&mut self, id: Int) -> Bool;
}

// Context with where clause on context itself
context Transformer<A, B> {
    fn transform(&self, a: A) -> B;
}

// Async context with complex async methods
async context StreamProcessor {
    async fn process(&mut self, input: Stream<Bytes>) -> Stream<Result<Data, Error>>;
    async fn batch(&mut self, inputs: List<Input>) -> List<Output>;
    async fn stream_map<T, U>(&self, stream: Stream<T>, f: fn(T) -> U) -> Stream<U>;
}

// Context with generic methods
context GenericProcessor {
    fn process<T: Clone>(&self, value: T) -> T;
    fn transform<A, B>(&self, value: A, f: fn(A) -> B) -> B;
}

// Large context with many methods (no type/const declarations)
context CompleteDatabase {
    fn connect(&mut self, url: Text) -> Result<(), DbError>;
    fn disconnect(&mut self);
    fn is_connected(&self) -> Bool;

    fn query(&self, sql: Text) -> Result<List<Row>, DbError>;
    fn query_one(&self, sql: Text) -> Result<Maybe<Row>, DbError>;
    fn execute(&mut self, sql: Text) -> Result<Int, DbError>;
    fn execute_batch(&mut self, statements: List<Text>) -> Result<List<Int>, DbError>;

    fn begin_transaction(&mut self) -> Result<Transaction, DbError>;
    fn commit(&mut self, tx: Transaction) -> Result<(), DbError>;
    fn rollback(&mut self, tx: Transaction) -> Result<(), DbError>;

    async fn query_async(&self, sql: Text) -> Result<List<Row>, DbError>;
    async fn execute_async(&mut self, sql: Text) -> Result<Int, DbError>;
}
