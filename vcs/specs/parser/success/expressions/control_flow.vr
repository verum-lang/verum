// =============================================================================
// CONTROL FLOW EDGE CASES
// =============================================================================

fn test_return_unit_explicit() {
    return ();
}

fn test_return_tuple() {
    return (a, b, c);
}

fn test_return_closure() {
    return |x| x + 1;
}

fn test_break_tuple() {
    let (a, b) = loop {
        break (compute_a(), compute_b());
    };
}

fn test_yield_complex() {
    fn* complex_generator() -> (Int, Text) {
        for i in 0..10 {
            yield (i, f"item_{i}");
        }
    }
}
