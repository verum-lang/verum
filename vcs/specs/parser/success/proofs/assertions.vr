// @test: parse-pass
// @tier: 0
// @category: proofs
// @level: L0
// @tags: parser, proofs, assertions, assert, assume, invariant
// @description: Comprehensive test for assert/assume/invariant builtin function parsing

// ============================================================================
// Basic Assert (builtin_assertion: 'assert')
// Note: Verum uses function call syntax, NOT macro syntax (no !)
// ============================================================================

fn test_basic_assert() {
    // Simple boolean assert
    assert(true);

    // Assert with comparison
    assert(1 < 2);
    assert(5 >= 5);
    assert(10 != 0);

    // Assert with variable
    let x = 42;
    assert(x > 0);
    assert(x == 42);
}

fn test_assert_arithmetic() {
    let a = 10;
    let b = 20;

    // Assert arithmetic expressions
    assert(a + b == 30);
    assert(a * 2 == 20);
    assert(b / 2 == 10);
    assert(b - a == 10);
    assert(b % a == 0);
}

fn test_assert_logical() {
    let p = true;
    let q = false;

    // Assert with logical operators
    assert(p || q);
    assert(p && !q);
    assert(!q);
    assert(p == !q);

    // Assert with implications (expressed as || and !)
    assert(!p || q || true);  // p => q || true
}

// ============================================================================
// Assert with Messages
// ============================================================================

fn test_assert_with_message() {
    let x = 42;

    // Assert with message string
    assert(x > 0, "x must be positive");
    assert(x == 42, "x should equal 42");
    assert(x < 100, f"x ({x}) should be less than 100");

    // Assert with complex message
    let name = "test";
    assert(x > 0, f"Variable {name} with value {x} must be positive");
}

fn test_assert_message_expressions() {
    let a = 10;
    let b = 20;

    // Message with computed values
    assert(a < b, f"Expected {a} < {b}");
    assert(a + b == 30, f"Sum was {a + b}, expected 30");

    // Message with method calls
    let list = [1, 2, 3];
    assert(list.len() == 3, f"List length was {list.len()}");
}

// ============================================================================
// Assert_eq (builtin_assertion: 'assert_eq')
// ============================================================================

fn test_assert_eq() {
    // Basic equality
    assert_eq(1, 1);
    assert_eq(42, 42);
    assert_eq(true, true);

    // Variable equality
    let x = 10;
    let y = 10;
    assert_eq(x, y);

    // Expression equality
    assert_eq(2 + 2, 4);
    assert_eq(10 / 2, 5);
}

fn test_assert_eq_types() {
    // Integer equality
    assert_eq(100, 100);

    // Float equality
    assert_eq(3.14, 3.14);

    // String equality
    assert_eq("hello", "hello");

    // Boolean equality
    assert_eq(true, !false);

    // Tuple equality
    assert_eq((1, 2), (1, 2));

    // List equality
    assert_eq([1, 2, 3], [1, 2, 3]);
}

fn test_assert_eq_with_message() {
    let expected = 42;
    let actual = compute_value();

    // Assert_eq with message
    assert_eq(actual, expected, "Values should match");
    assert_eq(actual, expected, f"Expected {expected}, got {actual}");
}

// ============================================================================
// Assert_ne (builtin_assertion: 'assert_ne')
// ============================================================================

fn test_assert_ne() {
    // Basic inequality
    assert_ne(1, 2);
    assert_ne(true, false);

    // Variable inequality
    let x = 10;
    let y = 20;
    assert_ne(x, y);

    // Expression inequality
    assert_ne(2 + 2, 5);
    assert_ne("hello", "world");
}

fn test_assert_ne_with_message() {
    let a = 10;
    let b = 20;

    assert_ne(a, b, "Values should differ");
    assert_ne(a, b, f"{a} should not equal {b}");
}

// ============================================================================
// Debug_assert (builtin_assertion: 'debug_assert')
// ============================================================================

fn test_debug_assert() {
    // Debug assertions (only checked in debug builds)
    debug_assert(true);
    debug_assert(1 < 2);

    let x = 42;
    debug_assert(x > 0);
    debug_assert(x == 42);

    // Debug assert with message
    debug_assert(x > 0, "x should be positive");
    debug_assert(x < 100, f"x ({x}) too large");
}

fn test_debug_assert_expensive() {
    let list = generate_large_list();

    // Expensive checks only in debug mode
    debug_assert(is_sorted(list), "List should be sorted");
    debug_assert(has_no_duplicates(list), "List should have no duplicates");
    debug_assert(list.all(|x| x > 0), "All elements should be positive");
}

// ============================================================================
// Assume (verification assumption)
// ============================================================================

fn test_assume_basic() {
    // Basic assume
    assume(true);

    let x = get_external_value();
    assume(x > 0);  // Assume property for verification

    // Assume with complex expression
    assume(x > 0 && x < 100);
}

fn test_assume_for_verification() {
    let list = external_data();

    // Assume properties about external data
    assume(list.len() > 0);
    assume(forall i: Int . 0 <= i && i < list.len() => list[i] >= 0);

    // Now we can verify properties that depend on assumptions
    let sum = list.sum();
    assert(sum >= 0);  // This should verify given assumptions
}

fn test_assume_preconditions() {
    let a = read_input();
    let b = read_input();

    // Assume inputs satisfy preconditions
    assume(a > 0, "Input a must be positive");
    assume(b != 0, "Input b must be non-zero");

    let result = a / b;
    assert(result * b <= a);  // Safe given assumptions
}

// ============================================================================
// Loop Invariants (loop_annotation: 'invariant' expression)
// ============================================================================

fn test_loop_invariant_while() {
    let mut i = 0;
    let mut sum = 0;

    while i < 10
        invariant i >= 0
        invariant i <= 10
        invariant sum == i * (i - 1) / 2
    {
        sum = sum + i;
        i = i + 1;
    }

    assert(sum == 45);
}

fn test_loop_invariant_for() {
    let mut product = 1;

    for i in 1..=5
        invariant product >= 1
        invariant product == factorial(i - 1)
    {
        product = product * i;
    }

    assert(product == 120);
}

fn test_loop_invariant_for_await() {
    let mut count = 0;

    for await item in async_stream()
        invariant count >= 0
    {
        count = count + 1;
    }
}

fn test_loop_multiple_invariants() {
    let arr = [1, 2, 3, 4, 5];
    let mut i = 0;
    let mut max = arr[0];

    while i < arr.len()
        invariant 0 <= i
        invariant i <= arr.len()
        invariant max >= arr[0]
        invariant forall j: Int . 0 <= j && j < i => max >= arr[j]
    {
        if arr[i] > max {
            max = arr[i];
        }
        i = i + 1;
    }

    assert(forall j: Int . 0 <= j && j < arr.len() => max >= arr[j]);
}

// ============================================================================
// Decreases Annotations (loop_annotation: 'decreases' expression)
// ============================================================================

fn test_loop_decreases() {
    let mut n = 100;

    while n > 0
        invariant n >= 0
        decreases n
    {
        n = n - 1;
    }
}

fn test_loop_invariant_and_decreases() {
    let mut x = 50;
    let mut y = 0;

    while x > 0
        invariant x >= 0
        invariant x + y == 50
        decreases x
    {
        x = x - 1;
        y = y + 1;
    }

    assert(y == 50);
}

fn test_decreases_tuple() {
    let mut a = 10;
    let mut b = 10;

    while a > 0 || b > 0
        decreases (a, b)
    {
        if a > 0 {
            a = a - 1;
        } else {
            b = b - 1;
        }
    }
}

// ============================================================================
// Assertions in Various Contexts
// ============================================================================

fn test_assert_in_conditional() {
    let x = 42;

    if x > 0 {
        assert(x >= 1);
    } else {
        assert(x <= 0);
    }
}

fn test_assert_in_match() {
    let opt = Some(42);

    match opt {
        Some(n) => {
            assert(n == 42);
            assert(n > 0);
        }
        None => {
            assert(false, "Should not reach here");
        }
    }
}

fn test_assert_in_closure() {
    let validator = |x: Int| {
        assert(x > 0, "Value must be positive");
        x * 2
    };

    let result = validator(21);
    assert_eq(result, 42);
}

fn test_assert_in_async() {
    async fn validated_fetch(url: Text) -> Response {
        assert(url.len() > 0, "URL cannot be empty");
        assert(url.starts_with("https://"), "Must use HTTPS");

        let response = fetch(url).await;
        assert(response.status() < 400, "Request failed");

        response
    }
}

// ============================================================================
// Assertion Expressions (Complex)
// ============================================================================

fn test_assert_complex_expressions() {
    let list = [1, 2, 3, 4, 5];

    // Assert with method chains
    assert(list.filter(|x| x > 2).len() == 3);
    assert(list.map(|x| x * 2).sum() == 30);

    // Assert with quantifiers
    assert(forall i: Int . 0 <= i && i < list.len() => list[i] > 0);
    assert(exists i: Int . list[i] == 3);

    // Assert with nested expressions
    assert((list[0] + list[1]) * list[2] == 9);
}

fn test_assert_with_type_checks() {
    let maybe: Maybe<Int> = Some(42);
    let result: Result<Int, Error> = Ok(10);

    // Assert pattern matching results
    assert(maybe is Some);
    assert(result is Ok);

    // Assert with unwrap (after type check)
    assert(maybe.unwrap() == 42);
    assert(result.unwrap() == 10);
}

// ============================================================================
// Assertions for Verification
// ============================================================================

// Note: For regular functions, preconditions are expressed via assertions or refinement types
// Theorems/lemmas use requires clauses, but with proof_body syntax
fn verified_function(x: Int, y: Int) -> Int
    where ensures result > 0
{
    // Assert preconditions explicitly for verification
    assert(x > 0, "x must be positive");
    assert(y > 0, "y must be positive");

    let sum = x + y;
    assert(sum > x);  // Intermediate verification step
    assert(sum > y);

    sum
}

fn test_verification_assertions() {
    let arr = [1, 2, 3, 4, 5];

    // Assert preconditions before call
    assert(arr.len() > 0);

    let first = arr[0];

    // Assert postconditions
    assert(first == 1);
}

// ============================================================================
// Invariant as Expression (in protocols/types)
// NOTE: Type invariants are a future feature. The syntax below shows the planned design.
// ============================================================================

// Type invariants (future feature - not yet supported in parser)
// When implemented, the syntax will be:
// type SortedList<T: Ord> is {
//     elements: List<T>,
// };
//     invariant is_sorted(elements);

// For now, use regular types without invariants
type SortedList<T: Ord> is {
    elements: List<T>,
};

type BoundedCounter is {
    value: Int,
    max: Int,
};

type CircularBuffer<T> is {
    data: List<T>,
    head: Int,
    tail: Int,
    size: Int,
};

// ============================================================================
// Assertions in Tests
// ============================================================================

fn test_unit_test_pattern() {
    // Arrange
    let input = [3, 1, 4, 1, 5, 9, 2, 6];

    // Act
    let sorted = sort(input);

    // Assert
    assert_eq(sorted.len(), input.len());
    assert(is_sorted(sorted));
    assert(forall x: Int . input.contains(x) == sorted.contains(x));
}

fn test_property_test_pattern() {
    // Property: sorting is idempotent
    let list = random_list();
    let once = sort(list);
    let twice = sort(once);

    assert_eq(once, twice, "Sorting should be idempotent");
}

// ============================================================================
// Edge Cases
// ============================================================================

fn test_assert_edge_cases() {
    // Assert with parenthesized expression
    assert((1 + 1 == 2));

    // Assert with nested parentheses
    assert(((true)));

    // Assert with complex boolean
    assert(true && (false || true) && !false);

    // Assert with empty message (if allowed)
    assert(true, "");

    // Assert on computed boolean
    let check = |x: Int| x > 0;
    assert(check(42));
}

fn test_assume_edge_cases() {
    // Assume trivially true
    assume(true);

    // Assume with complex quantifier
    assume(forall x: Int . forall y: Int . x + y == y + x);

    // Assume for external data
    let external = get_untrusted_data();
    assume(external is not Null);
    assume(external.is_valid());
}

// ============================================================================
// Assertions with Side Effects Consideration
// ============================================================================

fn test_assert_pure_expressions() {
    let counter = Counter.new();

    // Assertions should use pure expressions
    assert(counter.value() >= 0);

    // Not: assert(counter.increment() > 0)  // Would have side effect
}

fn test_debug_assert_expensive_checks() {
    let graph = build_graph();

    // Expensive invariant checks only in debug
    debug_assert(graph.is_connected());
    debug_assert(graph.has_no_cycles());
    debug_assert(forall e: Edge . graph.contains(e) => e.weight > 0);
}
