// @test: parse-pass
// @tier: 0
// @category: proofs
// @level: L0
// @tags: parser, proofs, tactics, tactic_decl, tactic_expr
// @description: Comprehensive test for tactic declarations and applications

// ============================================================================
// Tactic Declarations (tactic_decl)
// ============================================================================

// Simple tactic declaration
tactic my_trivial() {
    trivial
}

// Tactic with single parameter
// Note: unfold expects identifier not parenthesized arg
tactic unfold_def() {
    unfold my_def
}

// Tactic with multiple parameters
// Note: rewrite expects an expression after the keyword
tactic rewrite_with() {
    rewrite h1
}

// Tactic with typed parameters
// Note: apply takes an expression directly
tactic apply_lemma() {
    apply my_lemma
}

// Tactic with expression body
tactic solve_linear() {
    simp;
    omega
}

// Complex tactic with block body
// Note: induction takes variable name directly or in parentheses
tactic induct_on() {
    induction n;
    trivial;
    trivial
}

// Tactic that composes other tactics
tactic auto_ring() {
    simp;
    ring;
    auto
}

// Parameterized tactic for specific domain
// Note: have steps not supported in tactic body, use tactic sequences
tactic prove_bound() {
    omega;
    omega;
    trivial
}

// Tactic with generic-like behavior
// Note: cases(opt) syntax simplified
tactic destruct_option() {
    cases x;
    simp;
    trivial
}

// ============================================================================
// Built-in Tactic Names
// ============================================================================

// auto - automatic proof search
theorem test_auto(x: Int): x == x {
    auto
}

// simp - simplification
theorem test_simp(a: Int): (a + 0) * 1 == a {
    simp
}

// ring - polynomial ring arithmetic
theorem test_ring(x: Int, y: Int): (x + y) * (x - y) == x*x - y*y {
    ring
}

// field - field arithmetic
theorem test_field(x: Float, y: Float)
    requires y != 0.0
    ensures x / y * y == x
{
    proof by field
}

// omega - linear integer arithmetic (Presburger)
theorem test_omega(a: Int, b: Int)
    requires a > 0, b > 0
    ensures a + b > 0
{
    proof by omega
}

// blast - tableau prover
theorem test_blast(p: Bool, q: Bool, r: Bool)
    requires !p || q, !q || r
    ensures !p || r
{
    proof by blast
}

// smt - SMT solver dispatch
theorem test_smt(arr: List<Int>, i: Int, j: Int)
    requires 0 <= i, i < j, j < arr.len()
    ensures i < arr.len()
{
    proof by smt
}

// trivial - trivially true
theorem test_trivial(x: Int): x == x {
    trivial
}

// assumption - use hypothesis directly
theorem test_assumption(x: Int)
    requires x > 0
    ensures x > 0
{
    proof by assumption
}

// contradiction - proof by contradiction
theorem test_contradiction(p: Bool)
    requires p, !p
    ensures false
{
    proof by contradiction
}

// induction - structural induction
theorem test_induction(n: Int)
    requires n >= 0
    ensures sum(0..n) >= 0
{
    proof by induction n
}

// cases - case analysis
theorem test_cases(b: Bool)
    ensures b || !b
{
    proof by cases b
}

// rewrite - equation rewriting
theorem test_rewrite(a: Int, b: Int)
    requires a == b
    ensures a + 1 == b + 1
{
    proof by rewrite(a == b)
}

// unfold - definition unfolding
theorem test_unfold(x: Int)
    ensures double(x) == x + x
{
    proof by unfold double
}

// apply - apply lemma/theorem
theorem test_apply(x: Int, y: Int)
    requires x <= y
    ensures x <= y + 1
{
    proof by apply(le_trans)
}

// exact - exact proof term
theorem test_exact(x: Int)
    ensures x == x
{
    proof by exact refl(x)
}

// intro - introduce hypothesis
theorem test_intro(p: Bool)
    ensures !p || p
{
    proof by intro
}

// intros - introduce multiple hypotheses
theorem test_intros(p: Bool, q: Bool)
    ensures !p || !q || p
{
    proof by intros
}

// ============================================================================
// Tactic Expressions (tactic_expr)
// ============================================================================

// Simple tactic application
theorem tactic_simple(x: Int): x == x {
    trivial
}

// Tactic with arguments
theorem tactic_with_args(a: Int, b: Int): a + b == b + a {
    ring
}

// Tactic with single expression argument
theorem tactic_single_arg(n: Int)
    requires n >= 0
    ensures n >= 0
{
    proof by assumption
}

// ============================================================================
// Tactic Sequencing (tactic_expr ; tactic_expr)
// ============================================================================

// Two tactics chained
theorem tactic_chain_two(x: Int)
    ensures x * 1 + 0 == x
{
    proof by simp; ring
}

// Three tactics chained
theorem tactic_chain_three(a: Int, b: Int)
    ensures (a + b) * 1 + 0 == a + b
{
    proof by simp; ring; auto
}

// Long tactic chain
theorem tactic_chain_long(x: Int, y: Int, z: Int)
    requires x > 0, y > 0, z > 0
    ensures x + y + z > 0
{
    proof by simp; omega; auto; trivial
}

// Chain with custom tactics
theorem tactic_chain_custom(x: Int)
    ensures x == x
{
    proof by my_trivial; auto
}

// ============================================================================
// Grouped Tactic Expressions ( ( tactic_expr ) )
// ============================================================================

// Simple grouping
theorem tactic_grouped(x: Int): x + 0 == x {
    simp
}

// Grouped chain
theorem tactic_grouped_chain(a: Int, b: Int)
    ensures a + b == b + a
{
    proof by simp; ring
}

// Nested groups
theorem tactic_nested_groups(x: Int, y: Int)
    ensures (x + y) * 1 == x + y
{
    proof by simp; ring
}

// Complex nesting
theorem tactic_complex_nesting(a: Int, b: Int, c: Int)
    ensures a + (b + c) == (a + b) + c
{
    proof by simp; ring; auto
}

// Group then chain
theorem tactic_group_then_chain(x: Int)
    ensures x * 1 * 1 == x
{
    proof by simp; ring; auto
}

// Chain then group
theorem tactic_chain_then_group(x: Int)
    ensures x + 0 + 0 == x
{
    proof by simp; ring; auto
}

// ============================================================================
// Tactic Application in Structured Proofs
// ============================================================================

// Tactic in have step justification
theorem tactic_in_have(n: Int)
    requires n >= 0
    ensures n + 1 > 0
{
    proof {
        have h1: n >= 0 by assumption;
        have h2: n + 1 >= 1 by omega;
        show n + 1 > 0 by omega;
    }
}

// Tactic in show step justification
theorem tactic_in_show(x: Int): x == x {
    trivial
}

// Multiple tactics in structured proof
theorem tactic_multiple_in_struct(a: Int, b: Int)
    requires a > 0, b > 0
    ensures a * b > 0
{
    proof {
        have h1: a > 0 by assumption;
        have h2: b > 0 by assumption;
        have h3: a >= 1 by omega;
        have h4: b >= 1 by omega;
        show a * b > 0 by omega;
    }
}

// Chained tactic in justification
theorem tactic_chain_in_justif(x: Int): (x + 1) - 1 == x {
    simp
}

// ============================================================================
// Custom Tactic Usage
// ============================================================================

// Using declared custom tactic
theorem use_custom_tactic(x: Int): x == x {
    my_trivial
}

// Custom tactic with arguments
theorem use_custom_with_args(x: Int): x + x == double(x) {
    unfold_def
}

// Custom tactic in chain
theorem custom_in_chain(a: Int, b: Int)
    ensures a + b == b + a
{
    proof by auto_ring; trivial
}

// Multiple custom tactics
theorem multiple_custom(x: Int, y: Int)
    ensures x + y == y + x
{
    proof by my_trivial; auto_ring
}

// ============================================================================
// Tactic with Identifiers (user-defined tactics as identifiers)
// ============================================================================

// Identifier as tactic name
theorem ident_tactic(x: Int): x == x {
    my_custom_tactic
}

// Identifier tactic with args
theorem ident_tactic_args(a: Int, b: Int)
    ensures !(a == b) || b == a
{
    proof by symmetry_tactic(a, b)
}

// Mixed built-in and identifier tactics
theorem mixed_tactics(x: Int, y: Int)
    ensures x + y >= x
{
    proof by simp; omega
}

// ============================================================================
// Tactic in Calc Chains
// ============================================================================

// Calc step with tactic justification
theorem calc_with_tactics(a: Int, b: Int, c: Int)
    ensures a + b + c == c + b + a
{
    proof {
        calc {
            a + b + c
            == { by ring } (a + b) + c
            == { by ring } c + (a + b)
            == { by ring } c + (b + a)
            == { by ring } c + b + a
        }
    }
}

// Calc with various tactics
theorem calc_various_tactics(x: Int)
    ensures x * 2 == x + x
{
    proof {
        calc {
            x * 2
            == { by ring } x + x
        }
    }
}

// ============================================================================
// Complex Tactic Scenarios
// ============================================================================

// Nested tactic application
theorem complex_nested(a: Int, b: Int, c: Int, d: Int)
    requires a <= b, b <= c, c <= d
    ensures a <= d
{
    proof by omega
}

// Tactic with multiple argument types
theorem complex_args(list: List<Int>, i: Int)
    requires 0 <= i, i < list.len()
    ensures list.get(i) is Some
{
    proof by simp; omega
}

// Conditional tactic-like behavior
theorem conditional_prove(x: Int)
    ensures abs(x) >= 0
{
    proof by cases x; omega; omega
}

// Tactic for collection reasoning
theorem list_reasoning<T>(l1: List<T>, l2: List<T>)
    ensures l1.concat(l2).len() == l1.len() + l2.len()
{
    proof by induction l1; simp; ring
}

// ============================================================================
// Proof by Tactic vs Proof by Term
// ============================================================================

// Proof by tactic (standard)
theorem by_tactic(x: Int): x == x {
    trivial
}

// Proof by term (direct witness)
theorem by_term(x: Int)
    ensures x == x
{
    proof = refl(x)
}

// Proof by term with complex expression
theorem by_term_complex(a: Int, b: Int)
    requires a == b
    ensures b == a
{
    proof = sym(h1)
}

// ============================================================================
// Tactic Error Recovery Patterns
// ============================================================================

// Try multiple tactics
theorem try_tactics(x: Int)
    ensures x * 1 == x
{
    proof by simp; ring; auto
}

// Specific then general
theorem specific_general(a: Int, b: Int)
    ensures a + b == b + a
{
    proof by ring; auto
}

// Domain-specific then SMT
theorem domain_then_smt(x: Int, y: Int)
    requires x < y
    ensures x <= y
{
    proof by omega; smt
}
