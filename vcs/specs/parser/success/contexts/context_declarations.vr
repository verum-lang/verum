// @test: parse-pass
// @tier: 0
// @category: contexts
// @description: Test context type declaration parsing

// Basic context declaration
context Logger {
    fn log(&self, message: Text);
    fn error(&self, message: Text);
    fn warn(&self, message: Text);
    fn debug(&self, message: Text);
}

// Context with return types
context Database {
    fn query(&self, sql: Text) -> Result<Rows, Error>;
    fn execute(&mut self, sql: Text) -> Result<Int, Error>;
    fn transaction(&mut self) -> Transaction;
}

// Async context
async context Network {
    async fn fetch(&self, url: Text) -> Result<Response, Error>;
    async fn post(&self, url: Text, body: Text) -> Result<Response, Error>;
    async fn stream(&self, url: Text) -> AsyncIterator<Chunk>;
}

// Alternative async syntax
context async HttpClient {
    async fn get(&self, url: Text) -> Response;
    async fn post(&self, url: Text, data: Data) -> Response;
    async fn delete(&self, url: Text) -> Bool;
}

// Context with generics
context Repository<T> {
    fn find(&self, id: Int) -> Maybe<T>;
    fn find_all(&self) -> List<T>;
    fn save(&mut self, entity: T) -> Result<T, Error>;
    fn delete(&mut self, id: Int) -> Result<(), Error>;
}

// Context with multiple type parameters
context Cache<K, V> {
    fn get(&self, key: K) -> Maybe<V>;
    fn set(&mut self, key: K, value: V);
    fn remove(&mut self, key: K) -> Maybe<V>;
    fn clear(&mut self);
}

// Context with bounded generics
context EventStore<E: Event> {
    fn append(&mut self, event: E) -> EventId;
    fn read(&self, from: EventId) -> List<E>;
    fn subscribe(&self, handler: fn(E));
}

// Context with path operations
context FileSystem {
    fn open(&self, path: Text) -> Result<FileHandle, Error>;
    fn read(&self, file: FileHandle) -> Result<List<Byte>, Error>;
    fn write(&mut self, file: FileHandle, data: List<Byte>) -> Result<(), Error>;
    fn close(&mut self, file: FileHandle);
}

// Context for configuration
context Config {
    fn max_retries(&self) -> Int;
    fn timeout_ms(&self) -> Int;
    fn get(&self, key: Text) -> Maybe<Text>;
    fn set(&mut self, key: Text, value: Text);
}

// Public context
public context MetricsCollector {
    fn increment(&mut self, name: Text);
    fn gauge(&mut self, name: Text, value: Float);
    fn histogram(&mut self, name: Text, value: Float);
}

// Internal context
internal context InternalState {
    fn get_state(&self) -> State;
    fn set_state(&mut self, state: State);
}

// Context with complex method signatures
context MessageQueue {
    fn send<T: Serialize>(&mut self, topic: Text, message: T) -> Result<MessageId, Error>;
    fn receive<T: Deserialize>(&mut self, topic: Text) -> Result<Maybe<T>, Error>;
    fn acknowledge(&mut self, id: MessageId) -> Result<(), Error>;
}

// Empty context (marker)
context Authenticated {
}

// Context for secure storage
context SecureStorage {
    fn read(&self, key: Text) -> Maybe<Bytes>;
    fn write(&mut self, key: Text, value: Bytes);
    fn delete(&mut self, key: Text);
}
