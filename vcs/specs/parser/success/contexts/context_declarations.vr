// @test: parse-pass
// @tier: 0
// @category: contexts
// @description: Test context type declaration parsing

// Basic context declaration
context Logger {
    fn log(message: Text);
    fn error(message: Text);
    fn warn(message: Text);
    fn debug(message: Text);
}

// Context with return types
context Database {
    fn query(sql: Text) -> Result<Rows, Error>;
    fn execute(sql: Text) -> Result<Int, Error>;
    fn transaction() -> Transaction;
}

// Async context
async context Network {
    async fn fetch(&self, url: Text) -> Result<Response, Error>;
    async fn post(&self, url: Text, body: Text) -> Result<Response, Error>;
    async fn stream(&self, url: Text) -> AsyncIterator<Chunk>;
}

// Alternative async syntax
context async HttpClient {
    async fn get(&self, url: Text) -> Response;
    async fn post(&self, url: Text, data: Data) -> Response;
    async fn delete(&self, url: Text) -> Bool;
}

// Context with generics
context Repository<T> {
    fn find(id: Int) -> Maybe<T>;
    fn find_all() -> List<T>;
    fn save(entity: T) -> Result<T, Error>;
    fn delete(id: Int) -> Result<(), Error>;
}

// Context with multiple type parameters
context Cache<K, V> {
    fn get(key: K) -> Maybe<V>;
    fn set(key: K, value: V);
    fn remove(key: K) -> Maybe<V>;
    fn clear();
}

// Context with bounded generics
context EventStore<E: Event> {
    fn append(event: E) -> EventId;
    fn read(from: EventId) -> List<E>;
    fn subscribe(handler: fn(E));
}

// Context with path operations
context FileSystem {
    fn open(path: Text) -> Result<FileHandle, Error>;
    fn read(file: FileHandle) -> Result<List<Byte>, Error>;
    fn write(file: FileHandle, data: List<Byte>) -> Result<(), Error>;
    fn close(file: FileHandle);
}

// Context for configuration
context Config {
    fn max_retries() -> Int;
    fn timeout_ms() -> Int;
    fn get(key: Text) -> Maybe<Text>;
    fn set(key: Text, value: Text);
}

// Public context
public context MetricsCollector {
    fn increment(name: Text);
    fn gauge(name: Text, value: Float);
    fn histogram(name: Text, value: Float);
}

// Internal context
internal context InternalState {
    fn get_state(&self) -> State;
    fn set_state(&mut self, state: State);
}

// Context with complex method signatures
context MessageQueue {
    fn send<T: Serialize>(topic: Text, message: T) -> Result<MessageId, Error>;
    fn receive<T: Deserialize>(topic: Text) -> Result<Maybe<T>, Error>;
    fn acknowledge(id: MessageId) -> Result<(), Error>;
}

// Empty context (marker)
context Authenticated {
}

// Context for secure storage
context SecureStorage {
    fn read(key: Text) -> Maybe<Bytes>;
    fn write(key: Text, value: Bytes);
    fn delete(key: Text);
}
