// Public module with mixed visibility
pub module database {
    // Public API
    pub fn connect(url: Text) -> Connection {
        internal_connect(url)
    }

    pub type Connection is { id: Int };

    // Internal implementation details
    fn internal_connect(url: Text) -> Connection {
        Connection { id: 1 }
    }

    type InternalConfig is { timeout: Int };
}

// Nested public modules
pub module outer_public {
    pub module inner_public {
        pub fn exposed() -> Int { 42 }
    }

    module inner_private {
        fn hidden() -> Int { 0 }
    }
}

// Public module with various item types
pub module library {
    pub type PublicType is { data: Int };
    pub const PUBLIC_CONST: Int = 100;
    pub fn public_function() -> Int { 1 }

    type PrivateType is { secret: Int };
    const PRIVATE_CONST: Int = 0;
    fn private_function() -> Int { 0 }
}

// All visibility variants in nested modules
module visibility_showcase {
    pub module pub_child {}
    public module public_child {}
    internal module internal_child {}
    protected module protected_child {}
    module default_child {}
}
