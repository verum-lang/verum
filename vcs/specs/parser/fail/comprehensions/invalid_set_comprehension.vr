// @test: parse-fail
// @tier: 0
// @level: L0
// @category: comprehensions
// @tags: parser, comprehensions, set, errors
// @description: Invalid set comprehension syntax that should fail to parse

// ============================================================================
// MISSING REQUIRED ELEMENTS
// ============================================================================

fn test_set_missing_opening_brace() {
    // ERROR: Missing opening brace after 'set'
    let bad = set x for x in items};
}

fn test_set_missing_closing_brace() {
    // ERROR: Missing closing brace
    let bad = set{x for x in items;
}

fn test_set_missing_for_keyword() {
    // ERROR: Missing 'for' keyword
    let bad = set{x x in items};
}

fn test_set_missing_in_keyword() {
    // ERROR: Missing 'in' keyword
    let bad = set{x for x items};
}

fn test_set_missing_expression() {
    // ERROR: Missing element expression
    let bad = set{for x in items};
}

fn test_set_missing_iterator() {
    // ERROR: Missing iterator expression
    let bad = set{x for x in};
}

fn test_set_missing_pattern() {
    // ERROR: Missing pattern after 'for'
    let bad = set{x for in items};
}

// ============================================================================
// INVALID CLAUSE SYNTAX
// ============================================================================

fn test_set_invalid_if_clause() {
    // ERROR: 'if' without condition
    let bad = set{x for x in items if};
}

fn test_set_invalid_let_clause_no_equals() {
    // ERROR: 'let' without '='
    let bad = set{y for x in items let y x * 2};
}

fn test_set_invalid_let_clause_no_value() {
    // ERROR: 'let' without value
    let bad = set{y for x in items let y =};
}

fn test_set_invalid_let_clause_no_pattern() {
    // ERROR: 'let' without pattern
    let bad = set{y for x in items let = x * 2};
}

fn test_set_invalid_nested_for() {
    // ERROR: Nested 'for' without 'in'
    let bad = set{x for x in xs for y ys};
}

// ============================================================================
// SYNTAX CONFUSION
// ============================================================================

fn test_set_using_where_instead_of_if() {
    // ERROR: Using 'where' instead of 'if'
    let bad = set{x for x in items where x > 0};
}

fn test_set_using_colon_like_map() {
    // ERROR: Using key:value syntax in set (that's map syntax)
    let bad = set{k: v for (k, v) in pairs};
}

fn test_set_space_between_set_and_brace() {
    // This might parse as 'set' identifier followed by block - test behavior
    // ERROR: Space between keyword and brace
    let bad = set {x for x in items};
}

// ============================================================================
// STRUCTURAL ERRORS
// ============================================================================

fn test_set_extra_closing_brace() {
    // ERROR: Extra closing brace
    let bad = set{x for x in items}};
}

fn test_set_mismatched_braces() {
    // ERROR: Using bracket instead of brace
    let bad = set{x for x in items];
}

fn test_set_using_brackets() {
    // ERROR: Using brackets instead of braces
    let bad = set[x for x in items];
}

fn test_set_empty_braces() {
    // ERROR: Empty set comprehension
    let bad = set{};
}

// ============================================================================
// INCORRECT KEYWORD USAGE
// ============================================================================

fn test_set_typo_keyword() {
    // ERROR: Typo in 'set' keyword
    let bad = ste{x for x in items};
}

fn test_set_uppercase_keyword() {
    // ERROR: Uppercase 'SET' is not the keyword
    let bad = SET{x for x in items};
}
