type Display is protocol fn show(&self) -> Text; ;

type Iterator is protocol
    type Item;
    fn next(&mut self) -> Maybe<Self.Item>;
;

type Combine is protocol extends Clone fn combine(&self, other: &Self) -> Self; ;
