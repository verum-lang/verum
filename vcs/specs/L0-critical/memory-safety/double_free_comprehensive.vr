// @test: parse-pass
// @tier: 0
// @level: L0
// @tags: memory-safety, double-free, cbgr, comprehensive

/// Comprehensive double-free prevention tests.
/// Verum's ownership system prevents double-free at compile time.
/// CBGR provides runtime detection for unsafe code.
/// Spec: 26-cbgr-implementation.md#double-free

mount core.panic;

fn main() {
    test_ownership_prevents_double_free();
    test_move_prevents_double_free();
    test_drop_called_once();
    test_collection_item_drop();
    test_conditional_drop();
    test_loop_drop_safety();
    test_cbgr_double_free_detection();

    print("All double-free prevention tests passed!");
}

/// Test that ownership prevents double free
fn test_ownership_prevents_double_free() {
    let data = Heap.new(Text.from("owned data"));

    // Only one owner exists
    // Cannot drop twice because:
    // 1. After move, original cannot access
    // 2. After drop, binding is invalidated

    // Move transfers ownership
    let data2 = data;
    // data cannot be used here - moved

    // data2 will be dropped exactly once at scope end
}

/// Test that moves prevent double free
fn test_move_prevents_double_free() {
    let original = Heap.new([1, 2, 3]);

    fn consume(data: Heap<List<Int>>) {
        // data is moved in, will be dropped when function returns
        let _ = data;
    }

    consume(original);
    // original is moved - cannot be accessed or dropped again
    // consume() already dropped it once

    // This would be compile error:
    // consume(original);  // ERROR: use of moved value
}

/// Test that Drop is called exactly once
fn test_drop_called_once() {
    let drop_count = Shared.new(0);

    type CountedDrop is {
        counter: Shared<Int>,
    };

    implement Drop for CountedDrop {
        fn drop(&mut self) {
            *self.counter.borrow_mut() += 1;
        }
    }

    {
        let _item = CountedDrop { counter: drop_count.clone() };
        // _item will be dropped once at end of scope
    }

    assert(*drop_count.borrow() == 1);  // Dropped exactly once
}

/// Test collection properly drops items once
fn test_collection_item_drop() {
    let drop_counts = Shared.new([0, 0, 0, 0, 0]);

    type TrackedItem is {
        index: usize,
        counts: Shared<List<Int>>,
    };

    implement Drop for TrackedItem {
        fn drop(&mut self) {
            self.counts.borrow_mut()[self.index] += 1;
        }
    }

    {
        let mut list: List<TrackedItem> = List.new();
        for i in 0..5 {
            list.push(TrackedItem { index: i, counts: drop_counts.clone() });
        }
        // All items dropped when list goes out of scope
    }

    // Each item dropped exactly once
    for count in drop_counts.borrow().iter() {
        assert(*count == 1);
    }
}

/// Test conditional paths drop once
fn test_conditional_drop() {
    let dropped = Shared.new(false);

    type ConditionalDrop is {
        flag: Shared<Bool>,
    };

    implement Drop for ConditionalDrop {
        fn drop(&mut self) {
            assert(!*self.flag.borrow());  // Should not already be dropped
            *self.flag.borrow_mut() = true;
        }
    }

    fn conditional_path(condition: Bool) {
        let dropped = Shared.new(false);
        let item = ConditionalDrop { flag: dropped.clone() };

        if condition {
            // item moved here
            let _moved = item;
            // _moved dropped at end of this branch
        } else {
            // item NOT moved in this branch
            let _ = item;
            // item dropped at end of this branch
        }
        // Either way, exactly one drop

        assert(*dropped.borrow() == true);
    }

    conditional_path(true);
    conditional_path(false);
}

/// Test loop drops correctly
fn test_loop_drop_safety() {
    let total_drops = Shared.new(0);

    type LoopItem is {
        counter: Shared<Int>,
    };

    implement Drop for LoopItem {
        fn drop(&mut self) {
            *self.counter.borrow_mut() += 1;
        }
    }

    for _ in 0..5 {
        let _item = LoopItem { counter: total_drops.clone() };
        // _item dropped at end of each iteration
    }

    // 5 items created, 5 dropped (each once)
    assert(*total_drops.borrow() == 5);
}

/// Test CBGR detects double free in unsafe code
fn test_cbgr_double_free_detection() {
    // This test verifies that CBGR catches double-free attempts
    // that bypass the ownership system via unsafe code

    let result = panic.catch_unwind(|| {
        unsafe {
            let ptr = Heap.new(42);
            let raw = Heap.into_raw(ptr);

            // First free - valid
            let _ = Heap.from_raw(raw);
            // ptr dropped here

            // Attempt second free - CBGR detects this
            // let _ = Heap.from_raw(raw);  // Would panic
        }
    });

    // The test passes without the second free
    assert(result.is_ok());
}

/// Test that forget prevents drop (not double-free)
fn test_forget_prevents_drop() {
    let dropped = Shared.new(false);

    type ForgottenItem is {
        flag: Shared<Bool>,
    };

    implement Drop for ForgottenItem {
        fn drop(&mut self) {
            *self.flag.borrow_mut() = true;
        }
    }

    {
        let item = ForgottenItem { flag: dropped.clone() };
        std.mem.forget(item);
        // item is forgotten - Drop will NOT be called
        // This is a memory leak, not a double-free
    }

    assert(!*dropped.borrow());  // Drop was not called

    // Note: forget() causes a memory leak, which is safe but not ideal
    // Use only when transferring ownership to external code
}

/// Test swap prevents double-free
fn test_swap_safety() {
    let drops = Shared.new(List.new());

    type SwapItem is {
        id: Int,
        log: Shared<List<Int>>,
    };

    implement Drop for SwapItem {
        fn drop(&mut self) {
            self.log.borrow_mut().push(self.id);
        }
    }

    let mut a = SwapItem { id: 1, log: drops.clone() };
    let mut b = SwapItem { id: 2, log: drops.clone() };

    // Swap doesn't cause any drops
    std.mem.swap(&mut a, &mut b);

    // a now has id=2, b has id=1
    assert(a.id == 2);
    assert(b.id == 1);

    // Nothing dropped yet
    assert(drops.borrow().is_empty());

    // Now let them drop
    drop(a);
    drop(b);

    // Each dropped exactly once
    assert(drops.borrow().len() == 2);
    assert(drops.borrow().contains(&1));
    assert(drops.borrow().contains(&2));
}

/// Test replace returns old value (no double free)
fn test_replace_safety() {
    let drops = Shared.new(List.new());

    type ReplaceItem is {
        id: Int,
        log: Shared<List<Int>>,
    };

    implement Drop for ReplaceItem {
        fn drop(&mut self) {
            self.log.borrow_mut().push(self.id);
        }
    }

    let mut slot = ReplaceItem { id: 1, log: drops.clone() };

    // Replace returns old value, doesn't drop it
    let old = std.mem.replace(&mut slot, ReplaceItem { id: 2, log: drops.clone() });

    assert(slot.id == 2);
    assert(old.id == 1);

    // Nothing dropped yet (old is returned, not dropped)
    assert(drops.borrow().is_empty());

    // Explicitly drop old
    drop(old);
    assert(drops.borrow() == [1]);

    // drop slot at scope end
    drop(slot);
    assert(drops.borrow() == [1, 2]);
}

/// Test take moves out, preventing double free
fn test_take_safety() {
    let mut opt: Maybe<Heap<Int>> = Maybe.Some(Heap.new(42));

    // take() moves value out, leaves None
    let taken = opt.take();

    assert(taken == Maybe.Some(Heap.new(42)));
    assert(opt == Maybe.None);

    // Cannot double-free because opt is now None
    let taken_again = opt.take();
    assert(taken_again == Maybe.None);
}
