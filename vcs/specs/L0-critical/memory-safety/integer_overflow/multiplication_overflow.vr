// @test: parse-pass
// @tier: 0
// @level: L0
// @tags: memory-safety, integer-overflow, multiplication
// @description: Tests that multiplication overflow is detected

fn main() {
    let large = 9223372036854775807;  // Int.MAX

    // Multiplying max value by 2 causes overflow
    let _ = large * 2;  // Panic: Integer overflow
}
