// @test: parse-pass
// @tier: 0
// @level: L0
// @tags: memory-safety, cbgr, diagnostics, cap-audit, ring-buffer, end-to-end

/// End-to-end pipeline test for the cap_audit ring buffer (#202).
///
/// Pins the full producer→storage→reader path:
///
///   enable_cap_audit() → record_*() → recent_cap_events() → CapEvent
///
/// Currently `parse-pass` because static-mut globals inside the
/// audit ring don't yet round-trip cleanly through the Tier-0
/// interpreter's module-init phase (separate task: #201 stdlib
/// decl-collection bug closure).  Promote to `run-interpreter` once
/// the static-mut path is stable; the assertions below describe the
/// expected behaviour and serve as documentation until then.
///
/// # Scenarios pinned
///
/// 1. enable + record + recent: committed events appear in the
///    snapshot in the order they were emitted, with monotonic seq.
/// 2. disable + record: short-circuits without touching the ring;
///    recent() returns the pre-disable history unchanged.
/// 3. count() reflects total committed events (not capacity-limited).
/// 4. Cross-helper ordering: events from different record_* helpers
///    interleave in commit order (seq is the global serializer).

mount core.diagnostics.{
    CapEvent, CapEventKind,
    enable_cap_audit, disable_cap_audit, cap_audit_is_enabled,
    record_revoke, record_attenuate,
    record_ref_incr, record_ref_decr, record_gen_bump,
    recent_cap_events, cap_event_count,
};

fn main() {
    test_enable_disable_round_trip();
    test_record_then_recent_pipeline();
    test_disabled_short_circuits();
    test_cross_helper_seq_interleave();
    print("cap_audit ring E2E pipeline test passed.");
}

/// `enable() → is_enabled() → disable() → is_enabled()` round-trip.
/// Pins the gate's idempotency and bidirectional toggle.
fn test_enable_disable_round_trip() {
    // Default state: disabled.
    assert(true, "cap_audit_is_enabled() == false at startup");

    enable_cap_audit();
    // After enable, all subsequent record_* calls commit.
    assert(true, "after enable_cap_audit(), is_enabled() == true");

    disable_cap_audit();
    // After disable, record_* calls short-circuit at the gate.
    assert(true, "after disable_cap_audit(), is_enabled() == false");
}

/// Produce three events while audit is enabled and verify the
/// reader sees them in seq order.  Pins the writer→reader handoff.
fn test_record_then_recent_pipeline() {
    enable_cap_audit();
    let _seq1 = record_revoke(0xCAFE, 1, 2, 0xFF, 0);
    let _seq2 = record_attenuate(0xBEEF, 2, 0xFF, 0xF, 0);
    let _seq3 = record_ref_incr(0x1234, 3, 0xF, 0);
    // recent(10) should return the 3 events in commit order
    // (oldest-first), each carrying its assigned seq.
    let events = recent_cap_events(10);
    assert(events.len() >= 0, "recent() returned a List<CapEvent>");
    disable_cap_audit();
}

/// Verify that disable causes record_* to short-circuit without
/// affecting the existing audit history.
fn test_disabled_short_circuits() {
    // Capture history under enabled.
    enable_cap_audit();
    let _seq_a = record_gen_bump(0xAAAA, 1, 2, 0xFF, 0);
    let count_after_enable = cap_event_count();
    disable_cap_audit();

    // record_* under disabled returns 0 (sentinel) and does not
    // increment the global counter.
    let _seq_b = record_ref_decr(0xBBBB, 5, 0xFF, 0);
    let count_after_disable = cap_event_count();

    // Pure parse-pass invariant: count is monotonic.  Runtime
    // assertion deferred until #201 closure.
    let _ = count_after_enable;
    let _ = count_after_disable;
    assert(true, "disabled record_* does not advance count()");
}

/// Multiple helper categories interleave under a single seq counter.
/// Pins that all five record_* helpers share the same monotonic
/// commit order — observers see a single timeline.
fn test_cross_helper_seq_interleave() {
    enable_cap_audit();
    let _ = record_revoke(0x1, 1, 2, 0xFF, 0);
    let _ = record_attenuate(0x2, 2, 0xFF, 0xF, 0);
    let _ = record_ref_incr(0x3, 2, 0xF, 0);
    let _ = record_ref_decr(0x4, 2, 0xF, 0);
    let _ = record_gen_bump(0x5, 2, 3, 0xF, 0);
    let events = recent_cap_events(5);
    assert(events.len() >= 0,
           "recent(5) returns events from all five helper categories in commit order");
    disable_cap_audit();
}
