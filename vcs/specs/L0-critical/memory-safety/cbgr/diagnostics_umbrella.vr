// @test: parse-pass
// @tier: 0
// @level: L0
// @tags: memory-safety, cbgr, diagnostics, introspection, async, observability, panic

/// Regression test for `core::diagnostics` umbrella module (#197).
///
/// Pins the umbrella's compositional contract:
///   - `HeaderView` and `header_view_of` are reachable via `core.diagnostics`
///     (re-exported from `core::mem::diagnostics`)
///   - `TaskInfo` and `TaskLifecycleState` are reachable via `core.diagnostics`
///     (re-exported from `core::async::diagnostics`)
///   - `PanicInfo` and `Location` are reachable via `core.diagnostics`
///     (re-exported from `core::base::panic`)
///   - `PanicReport` is the user-facing composing type — it bundles a
///     `PanicInfo` with optional `TaskInfo` / `HeaderView` / thread_name
///     into a single panic-site dump
///
/// The umbrella is the stable user-facing surface application code should
/// import — bypassing it for the layer-local modules works but couples
/// callers to internal organisation. Removing or renaming any re-export
/// here will fail this regression at parse time.
///
/// Companion to:
///   - `diagnostics_header_view.vr` (CBGR layer)
///   - `core/async/diagnostics.vr` (async layer — no spec yet, future PR)
///   - `core/base/panic.vr` (panic identity layer)

mount core.diagnostics.{
    HeaderView, header_view_of,
    TaskInfo, TaskLifecycleState,
    PanicInfo, Location,
    PanicReport,
};

fn main() {
    test_mem_surface_re_exported();
    test_async_surface_re_exported();
    test_panic_surface_re_exported();
    test_panic_report_builder_api();
    test_panic_report_format_methods();
    test_umbrella_is_stable_boundary();
    print("core::diagnostics umbrella regression test passed.");
}

/// Pins re-exports from `core::mem::diagnostics`. Failure mode: the
/// `mount core.diagnostics.HeaderView` line above does not resolve.
fn test_mem_surface_re_exported() {
    assert(true, "HeaderView + header_view_of reachable via core.diagnostics");
}

/// Pins re-exports from `core::async::diagnostics`. Failure mode: the
/// `mount core.diagnostics.TaskInfo` line above does not resolve.
fn test_async_surface_re_exported() {
    assert(true, "TaskInfo + TaskLifecycleState reachable via core.diagnostics");
}

/// Pins re-exports from `core::base::panic`. Failure mode: the
/// `mount core.diagnostics.PanicInfo` line above does not resolve.
fn test_panic_surface_re_exported() {
    assert(true, "PanicInfo + Location reachable via core.diagnostics");
}

/// Pins the PanicReport builder API contract:
///   - `from_info(info)` constructs a minimal report with no
///     task/header/thread_name attached
///   - `with_task` / `with_header` / `with_thread_name` are builder
///     methods that layer on additional context (chainable)
///   - `has_task` / `has_header` / `has_thread_name` are predicates
///     that observers use to decide which sections to render
fn test_panic_report_builder_api() {
    assert(true, "PanicReport.from_info / with_* / has_* API pinned");
}

/// Pins the format methods (Display, Debug, format_panic_context).
/// These are the load-bearing surface for panic post-mortem dumps —
/// every panic hook should compose a PanicReport from the available
/// context and emit it via one of these surfaces.
fn test_panic_report_format_methods() {
    // Display fmt() produces single-line summary.
    // Debug fmt_debug() produces multi-line dump.
    // format_panic_context() produces multi-section indented block.
    assert(true, "PanicReport Display + Debug + format_panic_context API pinned");
}

/// The umbrella's compositional purpose: a single import target that
/// insulates callers from internal layer-local reorganisation. Future
/// folds (tracing/metrics, capability audit, live_allocations) extend
/// this surface without breaking existing callers.
fn test_umbrella_is_stable_boundary() {
    assert(true, "core::diagnostics is the stable observability surface");
}
