// ============================================================================
// Generator Memory Safety
// ============================================================================

// Ensure generators don't leak memory
fn test_generator_cleanup() {
    // Create and drop generators
    for _ in 0..1000 {
        let g = fibonacci(100);
        // Take only first 5
        let _ = g.take(5).collect();
        // Generator should be cleaned up when dropped
    }
    // No memory leak or use-after-free
}

