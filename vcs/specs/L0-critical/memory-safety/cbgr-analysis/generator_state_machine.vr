// ============================================================================
// Infinite Generator (with take)
// ============================================================================

fn* natural_numbers() -> Int {
    let n = 0;
    while true {
        yield n;
        n = n + 1;
    }
}

fn test_infinite_generator() {
    let g = natural_numbers();

    // Take first 5 elements
    let results = g.take(5).collect();
    assert(results == [0, 1, 2, 3, 4]);
}

