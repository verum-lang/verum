// @test: unit
// @tier: 0
// @level: L0
// @tags: generator, yield, state-machine, iterator
// @timeout: 5000
// @expect: pass
//
// Generator State Machine Tests
// Spec: docs/improvements.md Section 17.5
//
// This test suite verifies the generator state machine implementation:
// - Generator creation and initialization
// - Yield suspension and value preservation
// - Resume and register restoration
// - Completion and resource cleanup
// - Multiple independent generators
// - Iterator protocol integration

// ============================================================================
// Basic Generator: Single Yield
// ============================================================================

// Generator that yields a single value then returns
fn* single_yield() -> Int {
    yield 42;
}

fn test_single_yield() {
    let g = single_yield();

    // First resume yields 42
    let result = g.next();
    assert(result is Some(42));

    // Second resume completes
    let final_result = g.next();
    assert(final_result is None);
}

// ============================================================================
// Multi-Yield Generator
// ============================================================================

// Generator that yields multiple values
fn* count_up(limit: Int) -> Int {
    let i = 0;
    while i < limit {
        yield i;
        i = i + 1;
    }
}

fn test_count_up() {
    let g = count_up(5);

    // Should yield 0, 1, 2, 3, 4
    assert(g.next() == Maybe.Some(0));
    assert(g.next() == Maybe.Some(1));
    assert(g.next() == Maybe.Some(2));
    assert(g.next() == Maybe.Some(3));
    assert(g.next() == Maybe.Some(4));
    assert(g.next() == Maybe.None);
}

// ============================================================================
// State Preservation Across Yields
// ============================================================================

// Generator that accumulates state
fn* accumulator() -> Int {
    let sum = 0;
    sum = sum + 10;
    yield sum;  // 10

    sum = sum + 20;
    yield sum;  // 30

    sum = sum + 30;
    yield sum;  // 60
}

fn test_state_preservation() {
    let g = accumulator();

    // State accumulates correctly
    assert(g.next() == Maybe.Some(10));
    assert(g.next() == Maybe.Some(30));
    assert(g.next() == Maybe.Some(60));
    assert(g.next() == Maybe.None);
}

// ============================================================================
// Fibonacci Generator
// ============================================================================

// Classic fibonacci sequence generator
fn* fibonacci(count: Int) -> Int {
    if count <= 0 {
        return;
    }

    let a = 0;
    let b = 1;
    let n = 0;

    while n < count {
        yield a;
        let temp = a + b;
        a = b;
        b = temp;
        n = n + 1;
    }
}

fn test_fibonacci() {
    let g = fibonacci(8);

    // First 8 fibonacci numbers
    assert(g.next() == Maybe.Some(0));
    assert(g.next() == Maybe.Some(1));
    assert(g.next() == Maybe.Some(1));
    assert(g.next() == Maybe.Some(2));
    assert(g.next() == Maybe.Some(3));
    assert(g.next() == Maybe.Some(5));
    assert(g.next() == Maybe.Some(8));
    assert(g.next() == Maybe.Some(13));
    assert(g.next() == Maybe.None);
}

// ============================================================================
// Generator with Early Return
// ============================================================================

fn* early_return(should_return: Bool) -> Int {
    yield 1;

    if should_return {
        return;  // Early exit
    }

    yield 2;
    yield 3;
}

fn test_early_return() {
    // With early return
    let gen1 = early_return(true);
    assert(gen1.next() == Maybe.Some(1));
    assert(gen1.next() == Maybe.None);  // Returns early

    // Without early return
    let gen2 = early_return(false);
    assert(gen2.next() == Maybe.Some(1));
    assert(gen2.next() == Maybe.Some(2));
    assert(gen2.next() == Maybe.Some(3));
    assert(gen2.next() == Maybe.None);
}

// ============================================================================
// Multiple Independent Generators
// ============================================================================

fn test_multiple_generators() {
    // Two independent generators from the same function
    let gen1 = count_up(3);
    let gen2 = count_up(3);

    // Interleave resumes
    assert(gen1.next() == Maybe.Some(0));  // gen1 at 0
    assert(gen2.next() == Maybe.Some(0));  // gen2 at 0
    assert(gen1.next() == Maybe.Some(1));  // gen1 at 1
    assert(gen1.next() == Maybe.Some(2));  // gen1 at 2
    assert(gen2.next() == Maybe.Some(1));  // gen2 at 1
    assert(gen1.next() == Maybe.None);     // gen1 done
    assert(gen2.next() == Maybe.Some(2));  // gen2 at 2
    assert(gen2.next() == Maybe.None);     // gen2 done
}

// ============================================================================
// Generator as Iterator
// ============================================================================

fn test_generator_iterator_protocol() {
    let g = count_up(3);

    // Use generator with for-in loop
    let sum = 0;
    for value in g {
        sum = sum + value;
    }

    // 0 + 1 + 2 = 3
    assert(sum == 3);
}

// ============================================================================
// Generator with Complex Types
// ============================================================================

type Point is { x: Float, y: Float };

fn* point_generator() -> Point {
    yield Point { x: 1.0, y: 2.0 };
    yield Point { x: 3.0, y: 4.0 };
    yield Point { x: 5.0, y: 6.0 };
}

