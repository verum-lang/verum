// @test: run-interpreter-panic
// @tier: 0
// @level: L0
// @tags: codegen, regression, vbc, dispatch, result-unwrap, issue-79
// @timeout: 10000
// @expected-panic: called `unwrap` on an Err value
//
// Regression for #79: `Result.Err(...).unwrap()` must panic, not silently
// return the Err payload. Earlier behaviour returned the inner Err value
// because the interpreter's primitive variant dispatcher (`dispatch_variant_method`
// in crates/verum_vbc/src/interpreter/dispatch_table/handlers/method_dispatch.rs)
// couldn't distinguish `Maybe.Some(v)` from `Result.Err(v)` from runtime
// data alone — both share `(tag>=1, fc=1, type_id == 0x8000+tag)` after
// `MakeVariant` (variant TypeIds collapse parent type info).
//
// Fix (commits d1d32f57 + d2a3509e + e539a60d): the dispatcher now honours
// the qualified call-site method name (`Result.unwrap` vs `Maybe.unwrap`)
// to apply the right type semantics. This regression test exists so a
// future refactor can't silently re-introduce the silent-return that
// masked an entire class of downstream bugs (any `parse(...).unwrap()`
// chain produced malformed values that bubbled up as seemingly-unrelated
// panics).

@main
pub fn main() -> Int {
    let r: Result<Int, Int> = Err(99);
    let _v = r.unwrap();
    print("BUG: returned without panic");
    0
}
