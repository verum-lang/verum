// @test: run-interpreter
// @level: L0
// @tier: 0
// @tags: stdlib-runtime, sync, once, race-safe-set, regression-100-task-31, regression-100-task-39, regression-100-task-40
// @expected-stdout: ok

mount core.sync.once.{OnceLock};

fn main() {
    // 1. try_get_or_set on fresh OnceLock — Ok
    let lock = OnceLock<Int>.new();
    let r1 = lock.try_get_or_set(42);
    assert(r1.is_ok());

    // 2. try_get_or_set after init — Err preserves rejected value
    let r2 = lock.try_get_or_set(100);
    assert(r2.is_err());
    match r2 {
        Ok(_) => panic("expected Err"),
        Err(rejected) => assert(rejected == 100),
    }

    // 3. set wraps try_get_or_set — same behaviour
    let lock2 = OnceLock<Int>.new();
    assert(lock2.set(7).is_ok());
    let r3 = lock2.set(99);
    assert(r3.is_err());
    match r3 {
        Ok(_) => panic("expected Err"),
        Err(rejected) => assert(rejected == 99),
    }

    // 4. is_initialized reflects state
    assert(lock2.is_initialized());
    let lock3 = OnceLock<Int>.new();
    assert(!lock3.is_initialized());

    print("ok");
}
