// @test: run-interpreter
// @level: L0
// @tier: 0
// @tags: stdlib-runtime, closure, higher-order, capture
// @expected-stdout: closures ok

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
    f(x)
}

fn make_adder(n: Int) -> fn(Int) -> Int {
    |x| x + n
}

fn main() {
    // basic closure
    let double = |x| x * 2;
    assert_eq(double(5), 10);

    // higher-order
    assert_eq(apply(double, 7), 14);
    assert_eq(apply(|x| x + 1, 41), 42);

    // captured environment
    let add5 = make_adder(5);
    assert_eq(add5(10), 15);
    assert_eq(add5(0), 5);

    print("closures ok");
}
