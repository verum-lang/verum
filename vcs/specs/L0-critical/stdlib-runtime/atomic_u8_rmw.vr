// @test: run-interpreter
// @level: L0
// @tier: 0
// @tags: stdlib-runtime, atomics, atomic-u8, rmw, regression-100-task-34, regression-100-task-37
// @expected-stdout: load:195
//
// Pins task #37 closure: StructFieldAddr opcode + codegen wiring
// makes `&self.value as *const Byte as *const UInt8` lower to the
// actual heap address of the field inside AtomicU8's data section,
// so atomic_load_u8 reads the live byte instead of returning 0
// from the ptr<0x1000 guard.

mount core.sync.atomic.{AtomicU8, MemoryOrdering};

fn main() {
    let a = AtomicU8.new(0xC3);
    let v = a.load(MemoryOrdering.SeqCst) as Int;
    print(f"load:{v}");
}
