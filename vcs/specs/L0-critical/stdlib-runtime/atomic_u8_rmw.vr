// @test: run-interpreter
// @level: L0
// @tier: 0
// @tags: stdlib-runtime, atomics, atomic-u8, rmw, regression-100-task-34, regression-100-task-37, regression-100-task-38
// @expected-stdout: load:c3
//
// Pins the closure of three architectural fixes:
//   • #34 — width-aware atomic RMW codegen (5074f971)
//   • #37 — StructFieldAddr opcode + atomic-handler ptr extraction
//           (e5f60f3a + 56e990fe)
//   • #38 — f-string `:x` format-spec wrapping (ca32027d) +
//           format_radix_signed byte-array→List<Char> rewrite
//           (this commit)

mount core.sync.atomic.{AtomicU8, MemoryOrdering};

fn main() {
    let a = AtomicU8.new(0xC3);
    let v = a.load(MemoryOrdering.SeqCst) as Int;
    print(f"load:{v:x}");
}
