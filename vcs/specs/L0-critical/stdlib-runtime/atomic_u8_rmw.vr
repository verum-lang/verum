// @test: run-interpreter
// @level: L0
// @tier: 0
// @tags: stdlib-runtime, atomics, atomic-u8, rmw, regression-100-task-34, regression-100-task-37, regression-100-task-38
// @expected-stdout: load:c3
//
// Pins the closure of three architectural fixes:
//   • #34 — width-aware atomic RMW codegen (5074f971)
//   • #37 — StructFieldAddr opcode + atomic-handler ptr extraction
//           (e5f60f3a + 56e990fe)
//   • #38 — f-string `:x` format-spec wrapping (this commit's
//           safe_interpolation.rs change)
//
// The expected output `load:c3` end-to-ends:
//   1. AtomicU8.new(0xC3) constructs the heap object
//   2. `&self.value as *const Byte as *const UInt8` lowers via
//      StructFieldAddr to the real heap-field address
//   3. atomic_load_u8 reads the live byte = 0xC3 = 195 decimal
//   4. `as Int` converts UInt8 to Int (=195)
//   5. f-string `{v:x}` wraps as `v.to_hex()` → "c3"
//   6. concat with literal "load:" → "load:c3"

mount core.sync.atomic.{AtomicU8, MemoryOrdering};

fn main() {
    let a = AtomicU8.new(0xC3);
    let v = a.load(MemoryOrdering.SeqCst) as Int;
    print(f"load:{v:x}");
}
