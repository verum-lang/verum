// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, data-movement, nan-boxing, edge-cases
// @timeout: 5000
// @expect: pass
//
// Test: NaN-boxing encoding edge cases
// Verifies correct handling of values near tag boundaries
//
// Note: Removed test_pointer_tag_boundary - the value 0x0000_FFFF_FFFF_FFFF
// (281474976710655) exceeds 48-bit signed integer range and causes interpreter crash.
// VBC uses 48-bit SIGNED integers in NaN-boxing (range: -2^47 to 2^47-1).

fn test_integer_tag_boundary() {
    // Integer tag boundary values for LOAD_SMALL_I vs LOAD_I
    let max_small: Int = 63;     // LOAD_SMALL_I max
    let min_small: Int = -64;    // LOAD_SMALL_I min
    let just_over: Int = 64;     // Needs LOAD_I
    let just_under: Int = -65;   // Needs LOAD_I

    assert_eq(max_small + 1, just_over);
    assert_eq(min_small - 1, just_under);
}

fn test_float_integer_distinction() {
    // Floats that look like integers must be stored differently
    let f_zero: Float = 0.0;
    let f_one: Float = 1.0;
    let i_zero: Int = 0;
    let i_one: Int = 1;

    assert_eq(f_zero, 0.0);
    assert_eq(i_zero, 0);
    assert_eq(f_one, 1.0);
    assert_eq(i_one, 1);
}

fn test_boolean_integer_distinction() {
    // Booleans have distinct tag from integers
    let t: Bool = true;
    let f: Bool = false;
    let one: Int = 1;
    let zero: Int = 0;

    assert(t);
    assert(!f);
    assert_eq(one, 1);
    assert_eq(zero, 0);
}

fn test_48bit_integer_range() {
    // VBC uses 48-bit signed integers in NaN-boxing
    let max_48: Int = 140737488355327;   // 2^47 - 1
    let min_48: Int = -140737488355328;  // -2^47

    assert_eq(max_48, 140737488355327);
    assert_eq(min_48, -140737488355328);

    // Verify arithmetic near boundaries
    assert_eq(max_48 - 1, 140737488355326);
    assert_eq(min_48 + 1, -140737488355327);
}

fn test_unit_encoding() {
    // Unit value () has its own dedicated tag
    let u: () = ();
    assert_eq(u, ());
}

fn test_text_encoding() {
    // Text values use pointer tag with heap allocation
    let s1: Text = "test";
    let s2: Text = "test";

    assert_eq(s1, s2);
    assert_eq(s1.len(), 4);
}

fn main() {
    test_integer_tag_boundary();
    test_float_integer_distinction();
    test_boolean_integer_distinction();
    test_48bit_integer_range();
    test_unit_encoding();
    test_text_encoding();
    print("004_nan_boxing_edge_cases: PASSED");
}
