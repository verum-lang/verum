// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, arithmetic, bitwise, band, bor, bxor, bnot, shl, shr
// @timeout: 5000
// @expect: pass
//
// Test: BAND, BOR, BXOR, BNOT, SHL, SHR
// Verifies bitwise operations on integers
// Note: Unsigned right shift (>>>) is not supported in Verum grammar

fn test_band() {
    // Basic AND
    assert_eq(0b1100 & 0b1010, 0b1000);
    assert_eq(0xFF & 0x0F, 0x0F);
    assert_eq(0xFF & 0xF0, 0xF0);
    assert_eq(0xFF & 0xFF, 0xFF);
    assert_eq(0xFF & 0x00, 0x00);

    // Identity and annihilator
    assert_eq(42 & -1, 42);  // AND with all 1s = identity
    assert_eq(42 & 0, 0);    // AND with 0 = 0

    // Large values
    assert_eq(0xFFFF_FFFF_FFFF & 0x0000_FFFF_FFFF, 0x0000_FFFF_FFFF);
}

fn test_bor() {
    // Basic OR
    assert_eq(0b1100 | 0b1010, 0b1110);
    assert_eq(0xFF | 0x0F, 0xFF);
    assert_eq(0xF0 | 0x0F, 0xFF);
    assert_eq(0x00 | 0xFF, 0xFF);
    assert_eq(0x00 | 0x00, 0x00);

    // Identity and annihilator
    assert_eq(42 | 0, 42);   // OR with 0 = identity
    assert_eq(42 | -1, -1);  // OR with all 1s = all 1s
}

fn test_bxor() {
    // Basic XOR
    assert_eq(0b1100 ^ 0b1010, 0b0110);
    assert_eq(0xFF ^ 0x0F, 0xF0);
    assert_eq(0xFF ^ 0xFF, 0x00);
    assert_eq(0x00 ^ 0xFF, 0xFF);
    assert_eq(0x00 ^ 0x00, 0x00);

    // Identity
    assert_eq(42 ^ 0, 42);

    // Self-XOR = 0
    assert_eq(42 ^ 42, 0);

    // Double XOR restores value
    let x: Int = 12345;
    let y: Int = 67890;
    assert_eq((x ^ y) ^ y, x);
}

fn test_bnot() {
    // Bitwise NOT
    assert_eq(~0, -1);
    assert_eq(~-1, 0);
    assert_eq(~1, -2);
    assert_eq(~(-2), 1);

    // Double NOT = identity
    assert_eq(~~42, 42);
    assert_eq(~~(-123), -123);

    // NOT relationship with negation
    // ~x = -x - 1
    assert_eq(~5, -6);
    assert_eq(~(-5), 4);
}

fn test_shl() {
    // Left shift - multiply by 2^n
    assert_eq(1 << 0, 1);
    assert_eq(1 << 1, 2);
    assert_eq(1 << 2, 4);
    assert_eq(1 << 3, 8);
    assert_eq(1 << 4, 16);
    assert_eq(1 << 10, 1024);

    // Shift larger values
    assert_eq(5 << 2, 20);
    assert_eq(0xFF << 8, 0xFF00);

    // Shift negative (shifts pattern, not value)
    assert_eq(-1 << 1, -2);

    // Large shifts
    assert_eq(1 << 40, 1099511627776);
}

fn test_shr() {
    // Arithmetic right shift (sign-extending)
    assert_eq(8 >> 1, 4);
    assert_eq(8 >> 2, 2);
    assert_eq(8 >> 3, 1);
    assert_eq(1024 >> 10, 1);

    // Negative numbers - sign extends
    assert_eq(-8 >> 1, -4);
    assert_eq(-8 >> 2, -2);
    assert_eq(-1 >> 1, -1);  // All 1s stays all 1s
    assert_eq(-1 >> 10, -1);

    // Large shifts
    assert_eq(1099511627776 >> 40, 1);
}

fn test_shift_by_zero() {
    // Shifting by 0 = identity
    assert_eq(42 << 0, 42);
    assert_eq(42 >> 0, 42);
    assert_eq(-42 << 0, -42);
    assert_eq(-42 >> 0, -42);
}

fn test_bitwise_laws() {
    let a: Int = 0b10101010;
    let b: Int = 0b11001100;
    let c: Int = 0b11110000;

    // Commutativity
    assert_eq(a & b, b & a);
    assert_eq(a | b, b | a);
    assert_eq(a ^ b, b ^ a);

    // Associativity
    assert_eq((a & b) & c, a & (b & c));
    assert_eq((a | b) | c, a | (b | c));
    assert_eq((a ^ b) ^ c, a ^ (b ^ c));

    // Distributivity
    assert_eq(a & (b | c), (a & b) | (a & c));
    assert_eq(a | (b & c), (a | b) & (a | c));

    // De Morgan's laws
    assert_eq(~(a & b), ~a | ~b);
    assert_eq(~(a | b), ~a & ~b);

    // Idempotence
    assert_eq(a & a, a);
    assert_eq(a | a, a);
}

fn test_bit_manipulation_patterns() {
    // Set bit n
    fn set_bit(x: Int, n: Int) -> Int { x | (1 << n) }

    // Clear bit n
    fn clear_bit(x: Int, n: Int) -> Int { x & ~(1 << n) }

    // Toggle bit n
    fn toggle_bit(x: Int, n: Int) -> Int { x ^ (1 << n) }

    // Check bit n
    fn check_bit(x: Int, n: Int) -> Bool { (x & (1 << n)) != 0 }

    let x: Int = 0b1010;

    assert_eq(set_bit(x, 0), 0b1011);
    assert_eq(clear_bit(x, 1), 0b1000);
    assert_eq(toggle_bit(x, 2), 0b1110);
    assert(check_bit(x, 1));
    assert(!check_bit(x, 0));
}

fn test_power_of_two_detection() {
    // x is power of 2 if x > 0 && (x & (x-1)) == 0
    fn is_power_of_two(x: Int) -> Bool {
        x > 0 && (x & (x - 1)) == 0
    }

    assert(is_power_of_two(1));
    assert(is_power_of_two(2));
    assert(is_power_of_two(4));
    assert(is_power_of_two(1024));
    assert(!is_power_of_two(0));
    assert(!is_power_of_two(3));
    assert(!is_power_of_two(6));
    assert(!is_power_of_two(-4));
}

fn main() {
    test_band();
    test_bor();
    test_bxor();
    test_bnot();
    test_shl();
    test_shr();
    test_shift_by_zero();
    test_bitwise_laws();
    test_bit_manipulation_patterns();
    test_power_of_two_detection();
    print("004_bitwise: PASSED");
}
