// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, arithmetic, integer, basic
// @timeout: 5000
// @expect: pass
//
// Test: ADD_I, SUB_I, MUL_I, DIV_I, MOD_I
// Verifies basic integer arithmetic operations

fn test_add() {
    // Basic addition
    assert_eq(0 + 0, 0);
    assert_eq(1 + 0, 1);
    assert_eq(0 + 1, 1);
    assert_eq(1 + 1, 2);
    assert_eq(1 + 2, 3);
    assert_eq(100 + 200, 300);

    // Negative numbers
    assert_eq(-1 + 1, 0);
    assert_eq(-1 + -1, -2);
    assert_eq(-100 + 50, -50);
    assert_eq(50 + -100, -50);

    // Large numbers
    assert_eq(1000000 + 2000000, 3000000);
    assert_eq(1000000000000 + 1, 1000000000001);
}

fn test_sub() {
    // Basic subtraction
    assert_eq(0 - 0, 0);
    assert_eq(1 - 0, 1);
    assert_eq(1 - 1, 0);
    assert_eq(5 - 3, 2);
    assert_eq(3 - 5, -2);

    // Negative numbers
    assert_eq(-1 - 1, -2);
    assert_eq(-1 - -1, 0);
    assert_eq(-5 - -3, -2);
    assert_eq(-3 - -5, 2);
}

fn test_mul() {
    // Basic multiplication
    assert_eq(0 * 0, 0);
    assert_eq(1 * 0, 0);
    assert_eq(0 * 1, 0);
    assert_eq(1 * 1, 1);
    assert_eq(2 * 3, 6);
    assert_eq(7 * 8, 56);

    // Negative numbers
    assert_eq(-1 * 1, -1);
    assert_eq(1 * -1, -1);
    assert_eq(-1 * -1, 1);
    assert_eq(-5 * 3, -15);
    assert_eq(5 * -3, -15);
    assert_eq(-5 * -3, 15);

    // Powers of 2 (may use shift optimization)
    assert_eq(5 * 2, 10);
    assert_eq(5 * 4, 20);
    assert_eq(5 * 8, 40);
    assert_eq(5 * 16, 80);
}

fn test_div() {
    // Basic division
    assert_eq(0 / 1, 0);
    assert_eq(1 / 1, 1);
    assert_eq(6 / 2, 3);
    assert_eq(6 / 3, 2);
    assert_eq(7 / 2, 3);  // Truncated
    assert_eq(100 / 10, 10);

    // Negative numbers - truncation toward zero
    assert_eq(-6 / 2, -3);
    assert_eq(6 / -2, -3);
    assert_eq(-6 / -2, 3);
    assert_eq(-7 / 2, -3);  // Truncated toward zero
    assert_eq(7 / -2, -3);
}

fn test_mod() {
    // Basic modulo
    assert_eq(0 % 1, 0);
    assert_eq(1 % 1, 0);
    assert_eq(5 % 3, 2);
    assert_eq(7 % 4, 3);
    assert_eq(10 % 5, 0);
    assert_eq(10 % 3, 1);

    // Negative numbers - sign follows dividend
    assert_eq(-5 % 3, -2);
    assert_eq(5 % -3, 2);
    assert_eq(-5 % -3, -2);
    assert_eq(-7 % 4, -3);
    assert_eq(7 % -4, 3);
}

fn test_combined_operations() {
    // Verify operator precedence
    assert_eq(2 + 3 * 4, 14);      // Not 20
    assert_eq((2 + 3) * 4, 20);
    assert_eq(10 - 6 / 2, 7);      // Not 2
    assert_eq((10 - 6) / 2, 2);
    assert_eq(10 % 3 + 2, 3);
    assert_eq(10 % (3 + 2), 0);
}

fn test_identity_properties() {
    let x: Int = 42;

    // Additive identity
    assert_eq(x + 0, x);
    assert_eq(0 + x, x);

    // Multiplicative identity
    assert_eq(x * 1, x);
    assert_eq(1 * x, x);

    // Zero multiplication
    assert_eq(x * 0, 0);
    assert_eq(0 * x, 0);
}

fn test_associativity() {
    let a: Int = 7;
    let b: Int = 11;
    let c: Int = 13;

    // Addition is associative
    assert_eq((a + b) + c, a + (b + c));

    // Multiplication is associative
    assert_eq((a * b) * c, a * (b * c));
}

fn test_commutativity() {
    let a: Int = 17;
    let b: Int = 23;

    // Addition is commutative
    assert_eq(a + b, b + a);

    // Multiplication is commutative
    assert_eq(a * b, b * a);
}

fn test_distributivity() {
    let a: Int = 5;
    let b: Int = 7;
    let c: Int = 3;

    // Distributive property
    assert_eq(a * (b + c), a * b + a * c);
    assert_eq((a + b) * c, a * c + b * c);
}

fn main() {
    test_add();
    test_sub();
    test_mul();
    test_div();
    test_mod();
    test_combined_operations();
    test_identity_properties();
    test_associativity();
    test_commutativity();
    test_distributivity();
    print("001_integer_basic: PASSED");
}
