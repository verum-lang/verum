// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, memoization, dynamic-programming
// @timeout: 50000
// @expected-exit: 0

// =============================================================================
// Fibonacci with memoization (using array cache)
// =============================================================================

fn fib_memo(n: Int, cache: List<Int>) -> Int {
    if n <= 0 { return 0; }
    if n <= 2 { return 1; }
    if cache[n] != -1 { return cache[n]; }

    let result = fib_memo(n - 1, cache) + fib_memo(n - 2, cache);
    cache[n] = result;
    result
}

fn test_fib_memo() {
    let mut cache: List<Int> = [];
    let mut i = 0;
    while i <= 30 {
        cache.push(-1);
        i = i + 1;
    }

    assert_eq(fib_memo(1, cache), 1);
    assert_eq(fib_memo(10, cache), 55);
    assert_eq(fib_memo(20, cache), 6765);
    assert_eq(fib_memo(30, cache), 832040);
    print("  test_fib_memo: ok");
}

// =============================================================================
// Bottom-up DP: Fibonacci
// =============================================================================

fn fib_dp(n: Int) -> Int {
    if n <= 0 { return 0; }
    if n <= 2 { return 1; }

    let mut dp: List<Int> = [];
    let mut i = 0;
    while i <= n {
        dp.push(0);
        i = i + 1;
    }
    dp[1] = 1;
    dp[2] = 1;

    let mut j = 3;
    while j <= n {
        dp[j] = dp[j - 1] + dp[j - 2];
        j = j + 1;
    }
    dp[n]
}

fn test_fib_dp() {
    assert_eq(fib_dp(0), 0);
    assert_eq(fib_dp(1), 1);
    assert_eq(fib_dp(10), 55);
    assert_eq(fib_dp(30), 832040);
    print("  test_fib_dp: ok");
}

// =============================================================================
// Longest Common Subsequence (LCS)
// =============================================================================

fn lcs_length(a: List<Int>, b: List<Int>) -> Int {
    let m = a.len();
    let n = b.len();

    // dp[(m+1) * (n+1)] flat array
    let total = (m + 1) * (n + 1);
    let mut dp: List<Int> = [];
    let mut k = 0;
    while k < total {
        dp.push(0);
        k = k + 1;
    }

    let mut i = 1;
    while i <= m {
        let mut j = 1;
        while j <= n {
            if a[i - 1] == b[j - 1] {
                dp[i * (n + 1) + j] = dp[(i - 1) * (n + 1) + (j - 1)] + 1;
            } else {
                let up = dp[(i - 1) * (n + 1) + j];
                let left = dp[i * (n + 1) + (j - 1)];
                dp[i * (n + 1) + j] = if up > left { up } else { left };
            }
            j = j + 1;
        }
        i = i + 1;
    }
    dp[m * (n + 1) + n]
}

fn test_lcs() {
    let a: List<Int> = [1, 3, 4, 1, 2, 1, 3];
    let b: List<Int> = [3, 4, 1, 2, 1, 3];
    assert_eq(lcs_length(a, b), 6);

    let c: List<Int> = [1, 2, 3];
    let d: List<Int> = [4, 5, 6];
    assert_eq(lcs_length(c, d), 0);

    let e: List<Int> = [1, 2, 3, 4, 5];
    let f: List<Int> = [1, 2, 3, 4, 5];
    assert_eq(lcs_length(e, f), 5);
    print("  test_lcs: ok");
}

// =============================================================================
// Coin change (min coins)
// =============================================================================

fn min_coins(coins: List<Int>, amount: Int) -> Int {
    let inf = amount + 1;
    let mut dp: List<Int> = [];
    let mut i = 0;
    while i <= amount {
        dp.push(inf);
        i = i + 1;
    }
    dp[0] = 0;

    let mut a = 1;
    while a <= amount {
        let mut c = 0;
        while c < coins.len() {
            if coins[c] <= a {
                let prev = dp[a - coins[c]];
                if prev + 1 < dp[a] {
                    dp[a] = prev + 1;
                }
            }
            c = c + 1;
        }
        a = a + 1;
    }

    if dp[amount] > amount { -1 } else { dp[amount] }
}

fn test_coin_change() {
    let coins: List<Int> = [1, 5, 10, 25];
    assert_eq(min_coins(coins, 30), 2);  // 25 + 5
    assert_eq(min_coins(coins, 11), 2);  // 10 + 1
    assert_eq(min_coins(coins, 6), 2);   // 5 + 1
    assert_eq(min_coins(coins, 0), 0);

    let coins2: List<Int> = [2];
    assert_eq(min_coins(coins2, 3), -1); // impossible
    print("  test_coin_change: ok");
}

// =============================================================================
// 0/1 Knapsack
// =============================================================================

fn knapsack(weights: List<Int>, values: List<Int>, capacity: Int) -> Int {
    let n = weights.len();
    let total = (n + 1) * (capacity + 1);
    let mut dp: List<Int> = [];
    let mut k = 0;
    while k < total {
        dp.push(0);
        k = k + 1;
    }

    let mut i = 1;
    while i <= n {
        let mut w = 0;
        while w <= capacity {
            // Don't take item i
            let skip = dp[(i - 1) * (capacity + 1) + w];
            // Take item i (if fits)
            let mut take = 0;
            if weights[i - 1] <= w {
                take = dp[(i - 1) * (capacity + 1) + (w - weights[i - 1])] + values[i - 1];
            }
            dp[i * (capacity + 1) + w] = if take > skip { take } else { skip };
            w = w + 1;
        }
        i = i + 1;
    }
    dp[n * (capacity + 1) + capacity]
}

fn test_knapsack() {
    let weights: List<Int> = [2, 3, 4, 5];
    let values: List<Int> = [3, 4, 5, 6];
    assert_eq(knapsack(weights, values, 5), 7);  // items 0+1: weight=5, value=7

    let w2: List<Int> = [1, 1, 1];
    let v2: List<Int> = [10, 20, 30];
    assert_eq(knapsack(w2, v2, 2), 50); // take items 1+2: value=50
    print("  test_knapsack: ok");
}

fn main() -> Int {
    test_fib_memo();
    test_fib_dp();
    test_lcs();
    test_coin_change();
    test_knapsack();
    print("[OK] 620_interp_memoization");
    0
}
