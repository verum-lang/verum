// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, tensor, linalg
// @timeout: 50000
// @expected-exit: 0
// @description: Linear algebra operations — matmul, dot product, outer product, batch matmul, transpose, determinant, trace, eigenvalue properties, Kronecker product

// ============================================================================
// Vec4: 4-element vector for dot/outer product tests
// ============================================================================

type Vec4 is { v0: Int, v1: Int, v2: Int, v3: Int };

fn vec4_get(v: Vec4, i: Int) -> Int {
    if i == 0 { v.v0 } else if i == 1 { v.v1 } else if i == 2 { v.v2 } else { v.v3 }
}

fn vec4_dot(a: Vec4, b: Vec4) -> Int {
    a.v0 * b.v0 + a.v1 * b.v1 + a.v2 * b.v2 + a.v3 * b.v3
}

fn vec4_norm_sq(v: Vec4) -> Int {
    vec4_dot(v, v)
}

// ============================================================================
// Mat2: 2x2 matrix
// ============================================================================

type Mat2 is { m00: Int, m01: Int, m10: Int, m11: Int };

fn mat2_mul(a: Mat2, b: Mat2) -> Mat2 {
    Mat2 {
        m00: a.m00 * b.m00 + a.m01 * b.m10,
        m01: a.m00 * b.m01 + a.m01 * b.m11,
        m10: a.m10 * b.m00 + a.m11 * b.m10,
        m11: a.m10 * b.m01 + a.m11 * b.m11
    }
}

fn mat2_add(a: Mat2, b: Mat2) -> Mat2 {
    Mat2 {
        m00: a.m00 + b.m00, m01: a.m01 + b.m01,
        m10: a.m10 + b.m10, m11: a.m11 + b.m11
    }
}

fn mat2_scale(m: Mat2, s: Int) -> Mat2 {
    Mat2 {
        m00: m.m00 * s, m01: m.m01 * s,
        m10: m.m10 * s, m11: m.m11 * s
    }
}

fn mat2_det(m: Mat2) -> Int {
    m.m00 * m.m11 - m.m01 * m.m10
}

fn mat2_trace(m: Mat2) -> Int {
    m.m00 + m.m11
}

fn mat2_transpose(m: Mat2) -> Mat2 {
    Mat2 { m00: m.m00, m01: m.m10, m10: m.m01, m11: m.m11 }
}

fn mat2_adjugate(m: Mat2) -> Mat2 {
    Mat2 {
        m00: m.m11,
        m01: 0 - m.m01,
        m10: 0 - m.m10,
        m11: m.m00
    }
}

// ============================================================================
// Mat3: 3x3 matrix stored as 9 fields (row-major)
// ============================================================================

type Mat3 is {
    m00: Int, m01: Int, m02: Int,
    m10: Int, m11: Int, m12: Int,
    m20: Int, m21: Int, m22: Int
};

fn mat3_get(m: Mat3, r: Int, c: Int) -> Int {
    if r == 0 {
        if c == 0 { m.m00 } else if c == 1 { m.m01 } else { m.m02 }
    } else if r == 1 {
        if c == 0 { m.m10 } else if c == 1 { m.m11 } else { m.m12 }
    } else {
        if c == 0 { m.m20 } else if c == 1 { m.m21 } else { m.m22 }
    }
}

fn mat3_mul(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00 * b.m00 + a.m01 * b.m10 + a.m02 * b.m20,
        m01: a.m00 * b.m01 + a.m01 * b.m11 + a.m02 * b.m21,
        m02: a.m00 * b.m02 + a.m01 * b.m12 + a.m02 * b.m22,
        m10: a.m10 * b.m00 + a.m11 * b.m10 + a.m12 * b.m20,
        m11: a.m10 * b.m01 + a.m11 * b.m11 + a.m12 * b.m21,
        m12: a.m10 * b.m02 + a.m11 * b.m12 + a.m12 * b.m22,
        m20: a.m20 * b.m00 + a.m21 * b.m10 + a.m22 * b.m20,
        m21: a.m20 * b.m01 + a.m21 * b.m11 + a.m22 * b.m21,
        m22: a.m20 * b.m02 + a.m21 * b.m12 + a.m22 * b.m22
    }
}

fn mat3_det(m: Mat3) -> Int {
    // Sarrus' rule
    m.m00 * (m.m11 * m.m22 - m.m12 * m.m21)
    - m.m01 * (m.m10 * m.m22 - m.m12 * m.m20)
    + m.m02 * (m.m10 * m.m21 - m.m11 * m.m20)
}

fn mat3_trace(m: Mat3) -> Int {
    m.m00 + m.m11 + m.m22
}

fn mat3_transpose(m: Mat3) -> Mat3 {
    Mat3 {
        m00: m.m00, m01: m.m10, m02: m.m20,
        m10: m.m01, m11: m.m11, m12: m.m21,
        m20: m.m02, m21: m.m12, m22: m.m22
    }
}

// ============================================================================
// Rectangular matrices for non-square matmul
// ============================================================================

type Mat2x3 is { a00: Int, a01: Int, a02: Int, a10: Int, a11: Int, a12: Int };
type Mat3x2 is { b00: Int, b01: Int, b10: Int, b11: Int, b20: Int, b21: Int };

fn mat_mul_2x3_3x2(a: Mat2x3, b: Mat3x2) -> Mat2 {
    Mat2 {
        m00: a.a00 * b.b00 + a.a01 * b.b10 + a.a02 * b.b20,
        m01: a.a00 * b.b01 + a.a01 * b.b11 + a.a02 * b.b21,
        m10: a.a10 * b.b00 + a.a11 * b.b10 + a.a12 * b.b20,
        m11: a.a10 * b.b01 + a.a11 * b.b11 + a.a12 * b.b21
    }
}

fn mat_mul_3x2_2x3(a: Mat3x2, b: Mat2x3) -> Mat3 {
    Mat3 {
        m00: a.b00 * b.a00 + a.b01 * b.a10,
        m01: a.b00 * b.a01 + a.b01 * b.a11,
        m02: a.b00 * b.a02 + a.b01 * b.a12,
        m10: a.b10 * b.a00 + a.b11 * b.a10,
        m11: a.b10 * b.a01 + a.b11 * b.a11,
        m12: a.b10 * b.a02 + a.b11 * b.a12,
        m20: a.b20 * b.a00 + a.b21 * b.a10,
        m21: a.b20 * b.a01 + a.b21 * b.a11,
        m22: a.b20 * b.a02 + a.b21 * b.a12
    }
}

// ============================================================================
// Outer product: vec4 x vec4 -> 4x4 (stored as 16-element flat)
// ============================================================================

type Mat4Flat is {
    e0: Int, e1: Int, e2: Int, e3: Int,
    e4: Int, e5: Int, e6: Int, e7: Int,
    e8: Int, e9: Int, e10: Int, e11: Int,
    e12: Int, e13: Int, e14: Int, e15: Int
};

fn mat4f_get(m: Mat4Flat, r: Int, c: Int) -> Int {
    let idx = r * 4 + c;
    if idx == 0 { m.e0 } else if idx == 1 { m.e1 } else if idx == 2 { m.e2 }
    else if idx == 3 { m.e3 } else if idx == 4 { m.e4 } else if idx == 5 { m.e5 }
    else if idx == 6 { m.e6 } else if idx == 7 { m.e7 } else if idx == 8 { m.e8 }
    else if idx == 9 { m.e9 } else if idx == 10 { m.e10 } else if idx == 11 { m.e11 }
    else if idx == 12 { m.e12 } else if idx == 13 { m.e13 } else if idx == 14 { m.e14 }
    else { m.e15 }
}

fn outer_product(a: Vec4, b: Vec4) -> Mat4Flat {
    Mat4Flat {
        e0:  a.v0 * b.v0, e1:  a.v0 * b.v1, e2:  a.v0 * b.v2, e3:  a.v0 * b.v3,
        e4:  a.v1 * b.v0, e5:  a.v1 * b.v1, e6:  a.v1 * b.v2, e7:  a.v1 * b.v3,
        e8:  a.v2 * b.v0, e9:  a.v2 * b.v1, e10: a.v2 * b.v2, e11: a.v2 * b.v3,
        e12: a.v3 * b.v0, e13: a.v3 * b.v1, e14: a.v3 * b.v2, e15: a.v3 * b.v3
    }
}

// ============================================================================
// Batch matmul: apply same 2x2 transform to a batch of 2x2 matrices
// ============================================================================

type Batch3Mat2 is { m0: Mat2, m1: Mat2, m2: Mat2 };

fn batch_mat2_mul(batch: Batch3Mat2, transform: Mat2) -> Batch3Mat2 {
    Batch3Mat2 {
        m0: mat2_mul(batch.m0, transform),
        m1: mat2_mul(batch.m1, transform),
        m2: mat2_mul(batch.m2, transform)
    }
}

// Kronecker product of 2x2 matrices -> 4x4 (flat)
fn kron_2x2(a: Mat2, b: Mat2) -> Mat4Flat {
    Mat4Flat {
        e0:  a.m00 * b.m00, e1:  a.m00 * b.m01, e2:  a.m01 * b.m00, e3:  a.m01 * b.m01,
        e4:  a.m00 * b.m10, e5:  a.m00 * b.m11, e6:  a.m01 * b.m10, e7:  a.m01 * b.m11,
        e8:  a.m10 * b.m00, e9:  a.m10 * b.m01, e10: a.m11 * b.m00, e11: a.m11 * b.m01,
        e12: a.m10 * b.m10, e13: a.m10 * b.m11, e14: a.m11 * b.m10, e15: a.m11 * b.m11
    }
}

// ============================================================================
// Test 1: Dot product
// ============================================================================

@test
fn test_dot_product() {
    let a = Vec4 { v0: 1, v1: 2, v2: 3, v3: 4 };
    let b = Vec4 { v0: 5, v1: 6, v2: 7, v3: 8 };
    // 1*5 + 2*6 + 3*7 + 4*8 = 5 + 12 + 21 + 32 = 70
    assert_eq(vec4_dot(a, b), 70);

    // Commutativity: a.b = b.a
    assert_eq(vec4_dot(a, b), vec4_dot(b, a));

    // Orthogonal vectors: dot = 0
    let u = Vec4 { v0: 1, v1: 0, v2: 0, v3: 0 };
    let v = Vec4 { v0: 0, v1: 1, v2: 0, v3: 0 };
    assert_eq(vec4_dot(u, v), 0);

    // Self dot = norm squared
    assert_eq(vec4_norm_sq(a), 30);  // 1+4+9+16

    // Zero vector
    let z = Vec4 { v0: 0, v1: 0, v2: 0, v3: 0 };
    assert_eq(vec4_dot(a, z), 0);
    print("  test_dot_product: ok");
}

// ============================================================================
// Test 2: Matrix multiplication (2x2)
// ============================================================================

@test
fn test_matmul_2x2() {
    // [1 2] * [5 6] = [19 22]
    // [3 4]   [7 8]   [43 50]
    let a = Mat2 { m00: 1, m01: 2, m10: 3, m11: 4 };
    let b = Mat2 { m00: 5, m01: 6, m10: 7, m11: 8 };
    let c = mat2_mul(a, b);
    assert_eq(c.m00, 19);
    assert_eq(c.m01, 22);
    assert_eq(c.m10, 43);
    assert_eq(c.m11, 50);

    // Non-commutative: A*B != B*A
    let ba = mat2_mul(b, a);
    assert_eq(ba.m00, 23);
    assert_eq(ba.m01, 34);
    assert_eq(ba.m10, 31);
    assert_eq(ba.m11, 46);

    // Identity multiply
    let id = Mat2 { m00: 1, m01: 0, m10: 0, m11: 1 };
    let ai = mat2_mul(a, id);
    assert_eq(ai.m00, 1);
    assert_eq(ai.m01, 2);
    assert_eq(ai.m10, 3);
    assert_eq(ai.m11, 4);

    // Associativity: (A*B)*C = A*(B*C)
    let cc = Mat2 { m00: 2, m01: 1, m10: 0, m11: 3 };
    let abc1 = mat2_mul(mat2_mul(a, b), cc);
    let abc2 = mat2_mul(a, mat2_mul(b, cc));
    assert_eq(abc1.m00, abc2.m00);
    assert_eq(abc1.m01, abc2.m01);
    assert_eq(abc1.m10, abc2.m10);
    assert_eq(abc1.m11, abc2.m11);
    print("  test_matmul_2x2: ok");
}

// ============================================================================
// Test 3: Matrix multiplication (3x3)
// ============================================================================

@test
fn test_matmul_3x3() {
    // A = [1 0 2; 0 1 0; 3 0 1], B = [1 2 0; 0 1 0; 0 0 1]
    let a = Mat3 { m00: 1, m01: 0, m02: 2, m10: 0, m11: 1, m12: 0, m20: 3, m21: 0, m22: 1 };
    let b = Mat3 { m00: 1, m01: 2, m02: 0, m10: 0, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 };
    let c = mat3_mul(a, b);
    // C[0][0] = 1*1 + 0*0 + 2*0 = 1
    // C[0][1] = 1*2 + 0*1 + 2*0 = 2
    // C[0][2] = 1*0 + 0*0 + 2*1 = 2
    assert_eq(c.m00, 1);
    assert_eq(c.m01, 2);
    assert_eq(c.m02, 2);
    // C[1][0] = 0, C[1][1] = 1, C[1][2] = 0
    assert_eq(c.m10, 0);
    assert_eq(c.m11, 1);
    assert_eq(c.m12, 0);
    // C[2][0] = 3*1+0+1*0 = 3, C[2][1] = 3*2+0+1*0 = 6, C[2][2] = 0+0+1 = 1
    assert_eq(c.m20, 3);
    assert_eq(c.m21, 6);
    assert_eq(c.m22, 1);

    // Identity 3x3
    let id3 = Mat3 { m00: 1, m01: 0, m02: 0, m10: 0, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 };
    let ai = mat3_mul(a, id3);
    assert_eq(ai.m00, a.m00);
    assert_eq(ai.m12, a.m12);
    assert_eq(ai.m22, a.m22);
    print("  test_matmul_3x3: ok");
}

// ============================================================================
// Test 4: Rectangular matmul (2x3 * 3x2 = 2x2, 3x2 * 2x3 = 3x3)
// ============================================================================

@test
fn test_rect_matmul() {
    // A (2x3) = [1 2 3; 4 5 6]
    // B (3x2) = [7 8; 9 10; 11 12]
    let a = Mat2x3 { a00: 1, a01: 2, a02: 3, a10: 4, a11: 5, a12: 6 };
    let b = Mat3x2 { b00: 7, b01: 8, b10: 9, b11: 10, b20: 11, b21: 12 };

    // A*B = 2x2
    let ab = mat_mul_2x3_3x2(a, b);
    // [0][0] = 1*7+2*9+3*11 = 7+18+33 = 58
    // [0][1] = 1*8+2*10+3*12 = 8+20+36 = 64
    // [1][0] = 4*7+5*9+6*11 = 28+45+66 = 139
    // [1][1] = 4*8+5*10+6*12 = 32+50+72 = 154
    assert_eq(ab.m00, 58);
    assert_eq(ab.m01, 64);
    assert_eq(ab.m10, 139);
    assert_eq(ab.m11, 154);

    // B*A = 3x3
    let ba = mat_mul_3x2_2x3(b, a);
    // [0][0] = 7*1+8*4 = 39
    // [0][1] = 7*2+8*5 = 54
    // [0][2] = 7*3+8*6 = 69
    assert_eq(ba.m00, 39);
    assert_eq(ba.m01, 54);
    assert_eq(ba.m02, 69);
    // [2][0] = 11*1+12*4 = 59
    assert_eq(ba.m20, 59);
    print("  test_rect_matmul: ok");
}

// ============================================================================
// Test 5: Outer product
// ============================================================================

@test
fn test_outer_product() {
    let a = Vec4 { v0: 1, v1: 2, v2: 3, v3: 4 };
    let b = Vec4 { v0: 5, v1: 6, v2: 7, v3: 8 };
    let op = outer_product(a, b);
    // M[i][j] = a[i] * b[j]
    assert_eq(mat4f_get(op, 0, 0), 5);   // 1*5
    assert_eq(mat4f_get(op, 0, 3), 8);   // 1*8
    assert_eq(mat4f_get(op, 1, 0), 10);  // 2*5
    assert_eq(mat4f_get(op, 1, 1), 12);  // 2*6
    assert_eq(mat4f_get(op, 3, 3), 32);  // 4*8
    assert_eq(mat4f_get(op, 2, 1), 18);  // 3*6

    // Outer product of unit vectors gives a matrix with one 1
    let e0 = Vec4 { v0: 1, v1: 0, v2: 0, v3: 0 };
    let e2 = Vec4 { v0: 0, v1: 0, v2: 1, v3: 0 };
    let unit_op = outer_product(e0, e2);
    assert_eq(mat4f_get(unit_op, 0, 2), 1);
    assert_eq(mat4f_get(unit_op, 0, 0), 0);
    assert_eq(mat4f_get(unit_op, 1, 2), 0);
    print("  test_outer_product: ok");
}

// ============================================================================
// Test 6: Batch matrix multiply
// ============================================================================

@test
fn test_batch_matmul() {
    let batch = Batch3Mat2 {
        m0: Mat2 { m00: 1, m01: 0, m10: 0, m11: 1 },  // identity
        m1: Mat2 { m00: 2, m01: 0, m10: 0, m11: 2 },  // 2x scale
        m2: Mat2 { m00: 0, m01: 1, m10: 1, m11: 0 }   // swap
    };
    let transform = Mat2 { m00: 3, m01: 1, m10: 0, m11: 2 };
    let result = batch_mat2_mul(batch, transform);

    // I * T = T
    assert_eq(result.m0.m00, 3);
    assert_eq(result.m0.m01, 1);
    assert_eq(result.m0.m10, 0);
    assert_eq(result.m0.m11, 2);

    // 2I * T = 2T
    assert_eq(result.m1.m00, 6);
    assert_eq(result.m1.m01, 2);
    assert_eq(result.m1.m10, 0);
    assert_eq(result.m1.m11, 4);

    // swap * T = [0 2; 3 1]
    assert_eq(result.m2.m00, 0);
    assert_eq(result.m2.m01, 2);
    assert_eq(result.m2.m10, 3);
    assert_eq(result.m2.m11, 1);
    print("  test_batch_matmul: ok");
}

// ============================================================================
// Test 7: Determinant properties
// ============================================================================

@test
fn test_determinant() {
    // 2x2 determinant
    let a = Mat2 { m00: 3, m01: 8, m10: 4, m11: 6 };
    assert_eq(mat2_det(a), -14);

    // Identity det = 1
    let id = Mat2 { m00: 1, m01: 0, m10: 0, m11: 1 };
    assert_eq(mat2_det(id), 1);

    // Singular matrix det = 0
    let sing = Mat2 { m00: 2, m01: 4, m10: 1, m11: 2 };
    assert_eq(mat2_det(sing), 0);

    // det(A*B) = det(A) * det(B)
    let b = Mat2 { m00: 5, m01: 6, m10: 7, m11: 8 };
    let ab = mat2_mul(a, b);
    assert_eq(mat2_det(ab), mat2_det(a) * mat2_det(b));

    // det(kA) = k^2 * det(A) for 2x2
    let ka = mat2_scale(a, 3);
    assert_eq(mat2_det(ka), 9 * mat2_det(a));

    // 3x3 determinant
    let m = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    // This matrix is singular (rows are arithmetic progression)
    assert_eq(mat3_det(m), 0);

    // Non-singular 3x3
    let n = Mat3 { m00: 2, m01: 1, m02: 0, m10: 0, m11: 3, m12: 1, m20: 1, m21: 0, m22: 2 };
    // det = 2*(6-0) - 1*(0-1) + 0 = 12 + 1 = 13
    assert_eq(mat3_det(n), 13);
    print("  test_determinant: ok");
}

// ============================================================================
// Test 8: Trace properties
// ============================================================================

@test
fn test_trace() {
    let a = Mat2 { m00: 5, m01: 3, m10: 7, m11: 11 };
    let b = Mat2 { m00: 2, m01: 4, m10: 1, m11: 8 };

    assert_eq(mat2_trace(a), 16);

    // trace(A+B) = trace(A) + trace(B)
    let apb = mat2_add(a, b);
    assert_eq(mat2_trace(apb), mat2_trace(a) + mat2_trace(b));

    // trace(kA) = k * trace(A)
    let ka = mat2_scale(a, 3);
    assert_eq(mat2_trace(ka), 3 * mat2_trace(a));

    // trace(A^T) = trace(A)
    assert_eq(mat2_trace(mat2_transpose(a)), mat2_trace(a));

    // 3x3 trace
    let m = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    assert_eq(mat3_trace(m), 15);

    // trace(A^T) = trace(A) for 3x3
    assert_eq(mat3_trace(mat3_transpose(m)), mat3_trace(m));
    print("  test_trace: ok");
}

// ============================================================================
// Test 9: Transpose properties
// ============================================================================

@test
fn test_transpose_properties() {
    let a = Mat2 { m00: 1, m01: 2, m10: 3, m11: 4 };
    let b = Mat2 { m00: 5, m01: 6, m10: 7, m11: 8 };

    // (A^T)^T = A
    let att = mat2_transpose(mat2_transpose(a));
    assert_eq(att.m00, a.m00);
    assert_eq(att.m01, a.m01);
    assert_eq(att.m10, a.m10);
    assert_eq(att.m11, a.m11);

    // (A+B)^T = A^T + B^T
    let apb_t = mat2_transpose(mat2_add(a, b));
    let at_bt = mat2_add(mat2_transpose(a), mat2_transpose(b));
    assert_eq(apb_t.m00, at_bt.m00);
    assert_eq(apb_t.m01, at_bt.m01);
    assert_eq(apb_t.m10, at_bt.m10);
    assert_eq(apb_t.m11, at_bt.m11);

    // det(A^T) = det(A)
    assert_eq(mat2_det(mat2_transpose(a)), mat2_det(a));

    // 3x3 transpose
    let m = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    let mt = mat3_transpose(m);
    assert_eq(mat3_get(mt, 0, 1), 4);  // was m[1][0]
    assert_eq(mat3_get(mt, 1, 0), 2);  // was m[0][1]
    assert_eq(mat3_get(mt, 2, 0), 3);  // was m[0][2]
    assert_eq(mat3_det(mt), mat3_det(m));
    print("  test_transpose_properties: ok");
}

// ============================================================================
// Test 10: Adjugate and inverse verification
// ============================================================================

@test
fn test_adjugate_inverse() {
    // A = [2 1; 5 3], det = 6-5 = 1
    let a = Mat2 { m00: 2, m01: 1, m10: 5, m11: 3 };
    let d = mat2_det(a);
    assert_eq(d, 1);

    // Since det=1, adj(A) = inv(A)
    let inv = mat2_adjugate(a);
    let id_check = mat2_mul(a, inv);
    assert_eq(id_check.m00, 1);
    assert_eq(id_check.m01, 0);
    assert_eq(id_check.m10, 0);
    assert_eq(id_check.m11, 1);

    // M * adj(M) = det(M) * I
    let m = Mat2 { m00: 4, m01: 7, m10: 2, m11: 6 };
    let md = mat2_det(m);
    assert_eq(md, 10);
    let adj = mat2_adjugate(m);
    let product = mat2_mul(m, adj);
    assert_eq(product.m00, md);
    assert_eq(product.m01, 0);
    assert_eq(product.m10, 0);
    assert_eq(product.m11, md);
    print("  test_adjugate_inverse: ok");
}

// ============================================================================
// Test 11: Kronecker product
// ============================================================================

@test
fn test_kronecker_product() {
    // kron(I2, I2) = I4
    let id = Mat2 { m00: 1, m01: 0, m10: 0, m11: 1 };
    let k_id = kron_2x2(id, id);
    assert_eq(mat4f_get(k_id, 0, 0), 1);
    assert_eq(mat4f_get(k_id, 0, 1), 0);
    assert_eq(mat4f_get(k_id, 1, 1), 1);
    assert_eq(mat4f_get(k_id, 2, 2), 1);
    assert_eq(mat4f_get(k_id, 3, 3), 1);
    assert_eq(mat4f_get(k_id, 0, 2), 0);

    // kron(A, I) where A = [2 1; 0 3]
    let a = Mat2 { m00: 2, m01: 1, m10: 0, m11: 3 };
    let k_ai = kron_2x2(a, id);
    // Top-left block = 2*I = [2 0; 0 2]
    assert_eq(mat4f_get(k_ai, 0, 0), 2);
    assert_eq(mat4f_get(k_ai, 0, 1), 0);
    assert_eq(mat4f_get(k_ai, 1, 0), 0);
    assert_eq(mat4f_get(k_ai, 1, 1), 2);
    // Top-right block = 1*I = [1 0; 0 1]
    assert_eq(mat4f_get(k_ai, 0, 2), 1);
    assert_eq(mat4f_get(k_ai, 0, 3), 0);
    assert_eq(mat4f_get(k_ai, 1, 2), 0);
    assert_eq(mat4f_get(k_ai, 1, 3), 1);
    // Bottom-left block = 0*I = [0 0; 0 0]
    assert_eq(mat4f_get(k_ai, 2, 0), 0);
    // Bottom-right block = 3*I
    assert_eq(mat4f_get(k_ai, 2, 2), 3);
    assert_eq(mat4f_get(k_ai, 3, 3), 3);
    print("  test_kronecker_product: ok");
}

// ============================================================================
// Test 12: Matrix power (repeated squaring)
// ============================================================================

@test
fn test_matrix_power() {
    // Fibonacci via matrix exponentiation
    // [1 1]^n gives Fibonacci numbers
    // [1 0]
    let fib_mat = Mat2 { m00: 1, m01: 1, m10: 1, m11: 0 };

    // F^2 = [2 1; 1 1]
    let f2 = mat2_mul(fib_mat, fib_mat);
    assert_eq(f2.m00, 2);
    assert_eq(f2.m01, 1);
    assert_eq(f2.m10, 1);
    assert_eq(f2.m11, 1);

    // F^3 = [3 2; 2 1]
    let f3 = mat2_mul(f2, fib_mat);
    assert_eq(f3.m00, 3);
    assert_eq(f3.m01, 2);

    // F^4 = [5 3; 3 2]
    let f4 = mat2_mul(f3, fib_mat);
    assert_eq(f4.m00, 5);
    assert_eq(f4.m01, 3);

    // F^5 = [8 5; 5 3]
    let f5 = mat2_mul(f4, fib_mat);
    assert_eq(f5.m00, 8);
    assert_eq(f5.m01, 5);

    // F^6 = [13 8; 8 5]
    let f6 = mat2_mul(f5, fib_mat);
    assert_eq(f6.m00, 13);
    assert_eq(f6.m01, 8);

    // Verify: det(F^n) = det(F)^n = (-1)^n
    assert_eq(mat2_det(fib_mat), -1);
    assert_eq(mat2_det(f2), 1);      // (-1)^2
    assert_eq(mat2_det(f3), -1);     // (-1)^3
    assert_eq(mat2_det(f6), 1);      // (-1)^6
    print("  test_matrix_power: ok");
}

// ============================================================================
// Test 13: Cayley-Hamilton theorem (2x2)
// A^2 - trace(A)*A + det(A)*I = 0
// ============================================================================

@test
fn test_cayley_hamilton() {
    let a = Mat2 { m00: 3, m01: 1, m10: 4, m11: 2 };
    let tr = mat2_trace(a);    // 3 + 2 = 5
    let dt = mat2_det(a);      // 6 - 4 = 2

    // A^2
    let a2 = mat2_mul(a, a);

    // -trace(A)*A
    let neg_tr_a = mat2_scale(a, 0 - tr);

    // det(A)*I
    let det_i = Mat2 { m00: dt, m01: 0, m10: 0, m11: dt };

    // A^2 - tr*A + det*I should be zero
    let sum1 = mat2_add(a2, neg_tr_a);
    let result = mat2_add(sum1, det_i);
    assert_eq(result.m00, 0);
    assert_eq(result.m01, 0);
    assert_eq(result.m10, 0);
    assert_eq(result.m11, 0);
    print("  test_cayley_hamilton: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_dot_product();
    test_matmul_2x2();
    test_matmul_3x3();
    test_rect_matmul();
    test_outer_product();
    test_batch_matmul();
    test_determinant();
    test_trace();
    test_transpose_properties();
    test_adjugate_inverse();
    test_kronecker_product();
    test_matrix_power();
    test_cayley_hamilton();
    print("[OK] 185_interp_tensor_linalg");
    0
}
