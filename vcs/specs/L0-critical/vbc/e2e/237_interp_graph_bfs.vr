// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, graph, bfs, data-structure
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: BFS on a graph represented as adjacency matrix
// (flattened to 1D). Find shortest path lengths and reachable nodes.

// =============================================================================
// 8x8 adjacency matrix stored as 64-element flat array (8 records of 8)
// For simplicity, we use 8 separate Arr8 records for each row
// =============================================================================

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int,
               v4: Int, v5: Int, v6: Int, v7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 }
    else if i == 2 { a.v2 } else if i == 3 { a.v3 }
    else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn a8_set(a: Arr8, i: Int, val: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { val } else { a.v0 },
        v1: if i == 1 { val } else { a.v1 },
        v2: if i == 2 { val } else { a.v2 },
        v3: if i == 3 { val } else { a.v3 },
        v4: if i == 4 { val } else { a.v4 },
        v5: if i == 5 { val } else { a.v5 },
        v6: if i == 6 { val } else { a.v6 },
        v7: if i == 7 { val } else { a.v7 }
    }
}

fn a8_zeros() -> Arr8 {
    Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
}

// Graph stored as 8 rows (each Arr8), representing adjacency matrix
// adj[i][j] = 1 means edge from i to j
type Graph8 is {
    r0: Arr8, r1: Arr8, r2: Arr8, r3: Arr8,
    r4: Arr8, r5: Arr8, r6: Arr8, r7: Arr8,
    num_nodes: Int
};

fn graph_edge(g: Graph8, from: Int, to: Int) -> Int {
    if from == 0 { a8_get(g.r0, to) }
    else if from == 1 { a8_get(g.r1, to) }
    else if from == 2 { a8_get(g.r2, to) }
    else if from == 3 { a8_get(g.r3, to) }
    else if from == 4 { a8_get(g.r4, to) }
    else if from == 5 { a8_get(g.r5, to) }
    else if from == 6 { a8_get(g.r6, to) }
    else { a8_get(g.r7, to) }
}

// =============================================================================
// Queue for BFS (capacity 16, enough for 8-node graphs)
// =============================================================================

type Arr16 is { v0: Int, v1: Int, v2: Int, v3: Int,
                v4: Int, v5: Int, v6: Int, v7: Int,
                v8: Int, v9: Int, v10: Int, v11: Int,
                v12: Int, v13: Int, v14: Int, v15: Int };

fn q_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 }
    else if i == 2 { a.v2 } else if i == 3 { a.v3 }
    else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else if i == 7 { a.v7 }
    else if i == 8 { a.v8 } else if i == 9 { a.v9 }
    else if i == 10 { a.v10 } else if i == 11 { a.v11 }
    else if i == 12 { a.v12 } else if i == 13 { a.v13 }
    else if i == 14 { a.v14 } else { a.v15 }
}

fn q_set(a: Arr16, i: Int, val: Int) -> Arr16 {
    Arr16 {
        v0: if i == 0 { val } else { a.v0 },
        v1: if i == 1 { val } else { a.v1 },
        v2: if i == 2 { val } else { a.v2 },
        v3: if i == 3 { val } else { a.v3 },
        v4: if i == 4 { val } else { a.v4 },
        v5: if i == 5 { val } else { a.v5 },
        v6: if i == 6 { val } else { a.v6 },
        v7: if i == 7 { val } else { a.v7 },
        v8: if i == 8 { val } else { a.v8 },
        v9: if i == 9 { val } else { a.v9 },
        v10: if i == 10 { val } else { a.v10 },
        v11: if i == 11 { val } else { a.v11 },
        v12: if i == 12 { val } else { a.v12 },
        v13: if i == 13 { val } else { a.v13 },
        v14: if i == 14 { val } else { a.v14 },
        v15: if i == 15 { val } else { a.v15 }
    }
}

fn q16_zeros() -> Arr16 {
    Arr16 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0,
            v8: 0, v9: 0, v10: 0, v11: 0, v12: 0, v13: 0, v14: 0, v15: 0 }
}

// =============================================================================
// BFS: returns distance array from source
// dist[i] = shortest path length from source to i, or -1 if unreachable
// =============================================================================

fn bfs(g: Graph8, source: Int) -> Arr8 {
    let mut dist = Arr8 { v0: -1, v1: -1, v2: -1, v3: -1, v4: -1, v5: -1, v6: -1, v7: -1 };
    let mut visited = a8_zeros();  // 0 = not visited, 1 = visited

    // Initialize source
    dist = a8_set(dist, source, 0);
    visited = a8_set(visited, source, 1);

    // Queue
    let mut queue = q16_zeros();
    let mut qhead = 0;
    let mut qtail = 0;
    queue = q_set(queue, qtail, source);
    qtail = qtail + 1;

    while qhead < qtail {
        let node = q_get(queue, qhead);
        qhead = qhead + 1;
        let cur_dist = a8_get(dist, node);

        // Check all neighbors
        let mut neighbor = 0;
        while neighbor < g.num_nodes {
            if graph_edge(g, node, neighbor) == 1 {
                if a8_get(visited, neighbor) == 0 {
                    visited = a8_set(visited, neighbor, 1);
                    dist = a8_set(dist, neighbor, cur_dist + 1);
                    queue = q_set(queue, qtail, neighbor);
                    qtail = qtail + 1;
                }
            }
            neighbor = neighbor + 1;
        }
    }
    dist
}

// Count reachable nodes from source (including source itself)
fn count_reachable(g: Graph8, source: Int) -> Int {
    let dist = bfs(g, source);
    let mut cnt = 0;
    let mut i = 0;
    while i < g.num_nodes {
        if a8_get(dist, i) >= 0 {
            cnt = cnt + 1;
        }
        i = i + 1;
    }
    cnt
}

// =============================================================================
// Test graphs
// =============================================================================

// Graph 1: Linear chain 0 -> 1 -> 2 -> 3 -> 4
fn make_chain_graph() -> Graph8 {
    let z = a8_zeros();
    let r0 = Arr8 { v0: 0, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r1 = Arr8 { v0: 0, v1: 0, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r2 = Arr8 { v0: 0, v1: 0, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r3 = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    Graph8 { r0: r0, r1: r1, r2: r2, r3: r3, r4: z, r5: z, r6: z, r7: z, num_nodes: 5 }
}

// Graph 2: Diamond
//     0
//    / \
//   1   2
//    \ /
//     3
fn make_diamond_graph() -> Graph8 {
    let z = a8_zeros();
    let r0 = Arr8 { v0: 0, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r1 = Arr8 { v0: 0, v1: 0, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r2 = Arr8 { v0: 0, v1: 0, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r3 = a8_zeros();
    Graph8 { r0: r0, r1: r1, r2: r2, r3: r3, r4: z, r5: z, r6: z, r7: z, num_nodes: 4 }
}

// Graph 3: Undirected (symmetric) with 6 nodes
//   0 - 1 - 2
//   |       |
//   3 - 4 - 5
fn make_grid_graph() -> Graph8 {
    let z = a8_zeros();
    let r0 = Arr8 { v0: 0, v1: 1, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r1 = Arr8 { v0: 1, v1: 0, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r2 = Arr8 { v0: 0, v1: 1, v2: 0, v3: 0, v4: 0, v5: 1, v6: 0, v7: 0 };
    let r3 = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    let r4 = Arr8 { v0: 0, v1: 0, v2: 0, v3: 1, v4: 0, v5: 1, v6: 0, v7: 0 };
    let r5 = Arr8 { v0: 0, v1: 0, v2: 1, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    Graph8 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4, r5: r5, r6: z, r7: z, num_nodes: 6 }
}

// Graph 4: Disconnected — 0-1-2 and 3-4 (separate components)
fn make_disconnected_graph() -> Graph8 {
    let z = a8_zeros();
    let r0 = Arr8 { v0: 0, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r1 = Arr8 { v0: 1, v1: 0, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r2 = Arr8 { v0: 0, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r3 = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    let r4 = Arr8 { v0: 0, v1: 0, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    Graph8 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4, r5: z, r6: z, r7: z, num_nodes: 5 }
}

// =============================================================================
// Tests
// =============================================================================

fn test_chain_bfs() {
    let g = make_chain_graph();
    let dist = bfs(g, 0);
    assert_eq(a8_get(dist, 0), 0);
    assert_eq(a8_get(dist, 1), 1);
    assert_eq(a8_get(dist, 2), 2);
    assert_eq(a8_get(dist, 3), 3);
    assert_eq(a8_get(dist, 4), 4);
    assert_eq(count_reachable(g, 0), 5);
}

fn test_diamond_bfs() {
    let g = make_diamond_graph();
    let dist = bfs(g, 0);
    assert_eq(a8_get(dist, 0), 0);
    assert_eq(a8_get(dist, 1), 1);
    assert_eq(a8_get(dist, 2), 1);
    assert_eq(a8_get(dist, 3), 2);  // Shortest path: 0->1->3 or 0->2->3
    assert_eq(count_reachable(g, 0), 4);
}

fn test_grid_bfs() {
    let g = make_grid_graph();
    // BFS from 0
    let dist = bfs(g, 0);
    assert_eq(a8_get(dist, 0), 0);
    assert_eq(a8_get(dist, 1), 1);
    assert_eq(a8_get(dist, 2), 2);
    assert_eq(a8_get(dist, 3), 1);
    assert_eq(a8_get(dist, 4), 2);
    assert_eq(a8_get(dist, 5), 3);
    assert_eq(count_reachable(g, 0), 6);

    // BFS from 5
    let dist5 = bfs(g, 5);
    assert_eq(a8_get(dist5, 5), 0);
    assert_eq(a8_get(dist5, 2), 1);
    assert_eq(a8_get(dist5, 4), 1);
    assert_eq(a8_get(dist5, 0), 3);
}

fn test_disconnected_bfs() {
    let g = make_disconnected_graph();
    // From node 0, can reach 0, 1, 2 but not 3, 4
    let dist = bfs(g, 0);
    assert_eq(a8_get(dist, 0), 0);
    assert_eq(a8_get(dist, 1), 1);
    assert_eq(a8_get(dist, 2), 2);
    assert_eq(a8_get(dist, 3), -1);  // Unreachable
    assert_eq(a8_get(dist, 4), -1);  // Unreachable
    assert_eq(count_reachable(g, 0), 3);

    // From node 3, can reach 3, 4 but not 0, 1, 2
    assert_eq(count_reachable(g, 3), 2);
}

fn test_single_node_bfs() {
    let z = a8_zeros();
    let g = Graph8 { r0: z, r1: z, r2: z, r3: z, r4: z, r5: z, r6: z, r7: z, num_nodes: 1 };
    let dist = bfs(g, 0);
    assert_eq(a8_get(dist, 0), 0);
    assert_eq(count_reachable(g, 0), 1);
}

fn main() -> Int {
    test_chain_bfs();
    test_diamond_bfs();
    test_grid_bfs();
    test_disconnected_bfs();
    test_single_node_bfs();
    print("[OK] 237_interp_graph_bfs");
    0
}
