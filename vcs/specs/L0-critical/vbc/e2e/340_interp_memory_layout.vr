// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, memory, layout, alignment, packing, cbgr
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Memory layout simulation.
// Computes struct packing, alignment, field offsets, and padding.
// Simulates both packed and aligned layouts for composite types.

// =============================================================================
// Array infrastructure
// =============================================================================

type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn a8_new() -> Arr8 {
    Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 }
}

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 }
    }
}

// =============================================================================
// Memory layout calculator
// A struct has up to 8 fields, each with a size and alignment requirement.
// We compute offsets with proper alignment and total struct size with padding.
// =============================================================================

type StructLayout is {
    field_sizes: Arr8,
    field_aligns: Arr8,
    field_offsets: Arr8,
    num_fields: Int,
    total_size: Int,
    max_align: Int
};

// Helper: round up val to next multiple of align
fn align_up(val: Int, al: Int) -> Int {
    if al <= 0 { return val; }
    let remainder = val % al;
    if remainder == 0 { val }
    else { val + (al - remainder) }
}

// max helper
fn max_of(a: Int, b: Int) -> Int {
    if a > b { a } else { b }
}

// Compute aligned layout
fn compute_layout(sizes: Arr8, aligns: Arr8, num: Int) -> StructLayout {
    let mut offsets = a8_new();
    let mut cur_offset = 0;
    let mut max_al = 1;
    let mut i = 0;

    while i < num {
        let sz = a8_get(sizes, i);
        let al = a8_get(aligns, i);
        // Align current offset
        cur_offset = align_up(cur_offset, al);
        offsets = a8_set(offsets, i, cur_offset);
        cur_offset = cur_offset + sz;
        max_al = max_of(max_al, al);
        i = i + 1;
    }

    // Pad total size to struct alignment
    let total = align_up(cur_offset, max_al);

    StructLayout {
        field_sizes: sizes,
        field_aligns: aligns,
        field_offsets: offsets,
        num_fields: num,
        total_size: total,
        max_align: max_al
    }
}

// Compute packed layout (no padding between fields)
fn compute_packed_layout(sizes: Arr8, num: Int) -> StructLayout {
    let mut offsets = a8_new();
    let mut cur_offset = 0;
    let aligns = a8_new();  // All alignment = 1 (packed)
    let mut i = 0;

    while i < num {
        offsets = a8_set(offsets, i, cur_offset);
        cur_offset = cur_offset + a8_get(sizes, i);
        i = i + 1;
    }

    StructLayout {
        field_sizes: sizes,
        field_aligns: aligns,
        field_offsets: offsets,
        num_fields: num,
        total_size: cur_offset,
        max_align: 1
    }
}

// Calculate total padding in a layout
fn calc_padding(layout: StructLayout) -> Int {
    let mut data_size = 0;
    let mut i = 0;
    while i < layout.num_fields {
        data_size = data_size + a8_get(layout.field_sizes, i);
        i = i + 1;
    }
    layout.total_size - data_size
}

// Simulate reading a field from a flat byte buffer
// memory is simulated as an Arr8 of byte values
// field_offset and field_size determine which bytes to read
// For simplicity, we return the sum of bytes in the field range (as a checksum)
fn read_field_checksum(mem: Arr8, field_offset: Int, field_size: Int) -> Int {
    let mut checksum = 0;
    let mut i = 0;
    while i < field_size {
        let addr = field_offset + i;
        if addr < 8 {
            checksum = checksum + a8_get(mem, addr);
        }
        i = i + 1;
    }
    checksum
}

// Write a value to a field location (writes value to each byte)
fn write_field(mem: Arr8, field_offset: Int, field_size: Int, val: Int) -> Arr8 {
    let mut m = mem;
    let mut i = 0;
    while i < field_size {
        let addr = field_offset + i;
        if addr < 8 {
            m = a8_set(m, addr, val);
        }
        i = i + 1;
    }
    m
}

// =============================================================================
// Tests
// =============================================================================

fn test_align_up() {
    assert_eq(align_up(0, 4), 0);
    assert_eq(align_up(1, 4), 4);
    assert_eq(align_up(3, 4), 4);
    assert_eq(align_up(4, 4), 4);
    assert_eq(align_up(5, 4), 8);
    assert_eq(align_up(7, 8), 8);
    assert_eq(align_up(8, 8), 8);
    assert_eq(align_up(9, 8), 16);
    assert_eq(align_up(0, 1), 0);
    assert_eq(align_up(7, 1), 7);
}

fn test_simple_struct_layout() {
    // struct { i8, i32, i8 } with alignments 1, 4, 1
    // Expected: offset 0 (size 1), offset 4 (size 4), offset 8 (size 1)
    // Total: align_up(9, 4) = 12
    let sizes = a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, 4), 2, 1);
    let aligns = a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, 4), 2, 1);

    let layout = compute_layout(sizes, aligns, 3);
    assert_eq(a8_get(layout.field_offsets, 0), 0);
    assert_eq(a8_get(layout.field_offsets, 1), 4);
    assert_eq(a8_get(layout.field_offsets, 2), 8);
    assert_eq(layout.total_size, 12);
    assert_eq(layout.max_align, 4);
    assert_eq(calc_padding(layout), 6);  // 12 - (1+4+1) = 6
}

fn test_packed_layout() {
    // Same struct packed: i8, i32, i8
    // Expected: offset 0, 1, 5
    // Total: 6
    let sizes = a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, 4), 2, 1);

    let layout = compute_packed_layout(sizes, 3);
    assert_eq(a8_get(layout.field_offsets, 0), 0);
    assert_eq(a8_get(layout.field_offsets, 1), 1);
    assert_eq(a8_get(layout.field_offsets, 2), 5);
    assert_eq(layout.total_size, 6);
    assert_eq(calc_padding(layout), 0);
}

fn test_all_same_alignment() {
    // struct { i32, i32, i32 } all align 4
    let sizes = a8_set(a8_set(a8_set(a8_new(), 0, 4), 1, 4), 2, 4);
    let aligns = a8_set(a8_set(a8_set(a8_new(), 0, 4), 1, 4), 2, 4);

    let layout = compute_layout(sizes, aligns, 3);
    assert_eq(a8_get(layout.field_offsets, 0), 0);
    assert_eq(a8_get(layout.field_offsets, 1), 4);
    assert_eq(a8_get(layout.field_offsets, 2), 8);
    assert_eq(layout.total_size, 12);
    assert_eq(calc_padding(layout), 0);  // No padding needed
}

fn test_mixed_alignment() {
    // struct { i8(1,1), i16(2,2), i8(1,1), i64(8,8) }
    // offset 0: i8 (size 1)
    // offset 2: i16 (align to 2, size 2)
    // offset 4: i8 (size 1)
    // offset 8: i64 (align to 8, size 8)
    // Total: align_up(16, 8) = 16
    let sizes = a8_set(a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, 2), 2, 1), 3, 8);
    let aligns = a8_set(a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, 2), 2, 1), 3, 8);

    let layout = compute_layout(sizes, aligns, 4);
    assert_eq(a8_get(layout.field_offsets, 0), 0);
    assert_eq(a8_get(layout.field_offsets, 1), 2);
    assert_eq(a8_get(layout.field_offsets, 2), 4);
    assert_eq(a8_get(layout.field_offsets, 3), 8);
    assert_eq(layout.total_size, 16);
    assert_eq(layout.max_align, 8);
    assert_eq(calc_padding(layout), 4);  // 16 - (1+2+1+8) = 4
}

fn test_single_field() {
    let sizes = a8_set(a8_new(), 0, 8);
    let aligns = a8_set(a8_new(), 0, 8);

    let layout = compute_layout(sizes, aligns, 1);
    assert_eq(a8_get(layout.field_offsets, 0), 0);
    assert_eq(layout.total_size, 8);
    assert_eq(calc_padding(layout), 0);
}

fn test_tail_padding() {
    // struct { i32(4,4), i8(1,1) }
    // offset 0: i32, offset 4: i8
    // Total: align_up(5, 4) = 8 (3 bytes tail padding)
    let sizes = a8_set(a8_set(a8_new(), 0, 4), 1, 1);
    let aligns = a8_set(a8_set(a8_new(), 0, 4), 1, 1);

    let layout = compute_layout(sizes, aligns, 2);
    assert_eq(a8_get(layout.field_offsets, 0), 0);
    assert_eq(a8_get(layout.field_offsets, 1), 4);
    assert_eq(layout.total_size, 8);
    assert_eq(calc_padding(layout), 3);  // 8 - (4+1) = 3
}

fn test_field_read_write() {
    // Layout: two i32 fields at offsets 0 and 4
    let mem = a8_new();

    // Write field 0 (offset=0, size=2, value=42)
    let m1 = write_field(mem, 0, 2, 42);
    assert_eq(read_field_checksum(m1, 0, 2), 84);  // 42+42

    // Write field 1 (offset=2, size=2, value=10)
    let m2 = write_field(m1, 2, 2, 10);
    assert_eq(read_field_checksum(m2, 2, 2), 20);  // 10+10

    // Field 0 unchanged
    assert_eq(read_field_checksum(m2, 0, 2), 84);
}

fn test_optimal_ordering() {
    // Demonstrate that field ordering affects padding
    // Bad: { i8(1,1), i64(8,8), i8(1,1) }
    let bad_sizes = a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, 8), 2, 1);
    let bad_aligns = a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, 8), 2, 1);
    let bad_layout = compute_layout(bad_sizes, bad_aligns, 3);
    // offset 0: i8, offset 8: i64, offset 16: i8
    // total: align_up(17, 8) = 24
    assert_eq(bad_layout.total_size, 24);
    assert_eq(calc_padding(bad_layout), 14);  // 24 - 10 = 14

    // Good: { i64(8,8), i8(1,1), i8(1,1) }
    let good_sizes = a8_set(a8_set(a8_set(a8_new(), 0, 8), 1, 1), 2, 1);
    let good_aligns = a8_set(a8_set(a8_set(a8_new(), 0, 8), 1, 1), 2, 1);
    let good_layout = compute_layout(good_sizes, good_aligns, 3);
    // offset 0: i64, offset 8: i8, offset 9: i8
    // total: align_up(10, 8) = 16
    assert_eq(good_layout.total_size, 16);
    assert_eq(calc_padding(good_layout), 6);  // 16 - 10 = 6

    // Good layout saves 8 bytes
    assert_eq(bad_layout.total_size - good_layout.total_size, 8);
}

fn test_array_of_structs_stride() {
    // struct { i8(1,1), i32(4,4) }
    // size = 8 (with alignment padding), align = 4
    // Array stride = total_size = 8
    let sizes = a8_set(a8_set(a8_new(), 0, 1), 1, 4);
    let aligns = a8_set(a8_set(a8_new(), 0, 1), 1, 4);
    let layout = compute_layout(sizes, aligns, 2);

    let stride = layout.total_size;
    assert_eq(stride, 8);

    // Element addresses for array of 4 structs
    assert_eq(0 * stride, 0);
    assert_eq(1 * stride, 8);
    assert_eq(2 * stride, 16);
    assert_eq(3 * stride, 24);

    // Field 1 (i32) offset within each element
    let f1_off = a8_get(layout.field_offsets, 1);
    assert_eq(f1_off, 4);

    // Address of field 1 in element 2
    assert_eq(2 * stride + f1_off, 20);
}

fn test_nested_struct_simulation() {
    // Inner struct: { i32(4,4), i16(2,2) } -> size=8, align=4
    let inner_sizes = a8_set(a8_set(a8_new(), 0, 4), 1, 2);
    let inner_aligns = a8_set(a8_set(a8_new(), 0, 4), 1, 2);
    let inner = compute_layout(inner_sizes, inner_aligns, 2);
    assert_eq(inner.total_size, 8);
    assert_eq(inner.max_align, 4);

    // Outer struct: { i8(1,1), Inner(8,4), i8(1,1) }
    let outer_sizes = a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, inner.total_size), 2, 1);
    let outer_aligns = a8_set(a8_set(a8_set(a8_new(), 0, 1), 1, inner.max_align), 2, 1);
    let outer = compute_layout(outer_sizes, outer_aligns, 3);

    // i8 at 0, Inner at 4 (aligned), i8 at 12
    assert_eq(a8_get(outer.field_offsets, 0), 0);
    assert_eq(a8_get(outer.field_offsets, 1), 4);
    assert_eq(a8_get(outer.field_offsets, 2), 12);
    assert_eq(outer.total_size, 16);  // align_up(13, 4) = 16

    // Inner field 0 (i32) address within outer: outer_offset + inner_offset
    let inner_f0_addr = a8_get(outer.field_offsets, 1) + a8_get(inner.field_offsets, 0);
    assert_eq(inner_f0_addr, 4);

    // Inner field 1 (i16) address within outer
    let inner_f1_addr = a8_get(outer.field_offsets, 1) + a8_get(inner.field_offsets, 1);
    assert_eq(inner_f1_addr, 8);
}

fn main() -> Int {
    test_align_up();
    test_simple_struct_layout();
    test_packed_layout();
    test_all_same_alignment();
    test_mixed_alignment();
    test_single_field();
    test_tail_padding();
    test_field_read_write();
    test_optimal_ordering();
    test_array_of_structs_stride();
    test_nested_struct_simulation();
    print("[OK] 340_interp_memory_layout");
    0
}
