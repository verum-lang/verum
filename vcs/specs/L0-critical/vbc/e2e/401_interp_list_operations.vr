// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, list, operations
// @timeout: 15000
// @expected-exit: 0
//
// Tests list creation, indexing, mutation, and iteration.

fn sum_list(arr: List<Int>, len: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < len {
        total = total + arr[i];
        i = i + 1;
    }
    total
}

fn test_list_basics() {
    let arr = [10, 20, 30, 40, 50];
    assert_eq(arr[0], 10);
    assert_eq(arr[1], 20);
    assert_eq(arr[2], 30);
    assert_eq(arr[3], 40);
    assert_eq(arr[4], 50);
    assert_eq(sum_list(arr, 5), 150);
    print("list_basics: ok");
}

fn test_list_mutation() {
    let mut arr = [0, 0, 0, 0, 0];
    let mut i = 0;
    while i < 5 {
        arr[i] = (i + 1) * 10;
        i = i + 1;
    }
    assert_eq(arr[0], 10);
    assert_eq(arr[1], 20);
    assert_eq(arr[2], 30);
    assert_eq(arr[3], 40);
    assert_eq(arr[4], 50);
    print("list_mutation: ok");
}

fn test_list_accumulate() {
    let mut arr = [1, 1, 1, 1, 1, 1, 1, 1];
    // Prefix sum in place
    let mut i = 1;
    while i < 8 {
        arr[i] = arr[i] + arr[i - 1];
        i = i + 1;
    }
    assert_eq(arr[0], 1);
    assert_eq(arr[3], 4);
    assert_eq(arr[7], 8);
    print("list_accumulate: ok");
}

fn test_list_swap() {
    let mut arr = [5, 3, 1, 4, 2];
    // Bubble sort one pass
    let mut i = 0;
    while i < 4 {
        if arr[i] > arr[i + 1] {
            let tmp = arr[i];
            arr[i] = arr[i + 1];
            arr[i + 1] = tmp;
        }
        i = i + 1;
    }
    // After one pass, largest element bubbles to end
    assert_eq(arr[4], 5);
    print("list_swap: ok");
}

fn test_list_search() {
    let arr = [11, 22, 33, 44, 55, 66, 77, 88];
    let mut found = -1;
    let mut i = 0;
    while i < 8 {
        if arr[i] == 55 {
            found = i;
        }
        i = i + 1;
    }
    assert_eq(found, 4);
    print("list_search: ok");
}

fn test_list_max_min() {
    let arr = [42, 17, 93, 8, 56, 71, 3, 64];
    let mut mx = arr[0];
    let mut mn = arr[0];
    let mut i = 1;
    while i < 8 {
        if arr[i] > mx { mx = arr[i]; }
        if arr[i] < mn { mn = arr[i]; }
        i = i + 1;
    }
    assert_eq(mx, 93);
    assert_eq(mn, 3);
    print("list_max_min: ok");
}

fn main() -> Int {
    test_list_basics();
    test_list_mutation();
    test_list_accumulate();
    test_list_swap();
    test_list_search();
    test_list_max_min();
    print("[OK] 401_interp_list_operations");
    0
}
