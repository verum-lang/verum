// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, advanced, meta, stack-machine, interpreter
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: a tiny interpreter for a stack machine within Verum.
// Opcodes: PUSH=1, ADD=2, SUB=3, MUL=4, DUP=5, SWAP=6, OVER=7, DROP=8, HALT=0.
// Execute a program array, verify stack result.

// =============================================================================
// Array record infrastructure for program and stack
// =============================================================================

type Arr16 is {
    e0: Int, e1: Int, e2: Int, e3: Int,
    e4: Int, e5: Int, e6: Int, e7: Int,
    e8: Int, e9: Int, e10: Int, e11: Int,
    e12: Int, e13: Int, e14: Int, e15: Int
};

fn arr16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else if i == 7 { a.e7 }
    else if i == 8 { a.e8 }
    else if i == 9 { a.e9 }
    else if i == 10 { a.e10 }
    else if i == 11 { a.e11 }
    else if i == 12 { a.e12 }
    else if i == 13 { a.e13 }
    else if i == 14 { a.e14 }
    else { a.e15 }
}

fn arr16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 },
        e8: if i == 8 { v } else { a.e8 },
        e9: if i == 9 { v } else { a.e9 },
        e10: if i == 10 { v } else { a.e10 },
        e11: if i == 11 { v } else { a.e11 },
        e12: if i == 12 { v } else { a.e12 },
        e13: if i == 13 { v } else { a.e13 },
        e14: if i == 14 { v } else { a.e14 },
        e15: if i == 15 { v } else { a.e15 }
    }
}

fn arr16_zeros() -> Arr16 {
    Arr16 {
        e0: 0, e1: 0, e2: 0, e3: 0,
        e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    }
}

// =============================================================================
// Opcode constants
// =============================================================================

// HALT = 0   — stop execution
// PUSH = 1   — push next value onto stack
// ADD  = 2   — pop two, push sum
// SUB  = 3   — pop two, push difference (second - first)
// MUL  = 4   — pop two, push product
// DUP  = 5   — duplicate top of stack
// SWAP = 6   — swap top two elements
// OVER = 7   — copy second element to top
// DROP = 8   — discard top of stack
// NEG  = 9   — negate top of stack
// MOD  = 10  — pop two, push second % first

// =============================================================================
// Stack machine state
// =============================================================================

type VMState is {
    prog: Arr16,
    prog_len: Int,
    stk: Arr16,
    sp: Int,
    pc: Int,
    halted: Int
};

fn vm_new(prog: Arr16, prog_len: Int) -> VMState {
    VMState {
        prog: prog,
        prog_len: prog_len,
        stk: arr16_zeros(),
        sp: 0,
        pc: 0,
        halted: 0
    }
}

fn vm_push(vm: VMState, val: Int) -> VMState {
    VMState {
        prog: vm.prog, prog_len: vm.prog_len,
        stk: arr16_set(vm.stk, vm.sp, val),
        sp: vm.sp + 1,
        pc: vm.pc,
        halted: vm.halted
    }
}

fn vm_pop(vm: VMState) -> Int {
    arr16_get(vm.stk, vm.sp - 1)
}

fn vm_step(vm: VMState) -> VMState {
    if vm.halted != 0 || vm.pc >= vm.prog_len {
        return VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: vm.stk, sp: vm.sp, pc: vm.pc,
            halted: 1
        };
    }

    let opcode = arr16_get(vm.prog, vm.pc);

    if opcode == 0 {
        // HALT
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: vm.stk, sp: vm.sp, pc: vm.pc + 1,
            halted: 1
        }
    } else if opcode == 1 {
        // PUSH: next word is the value
        let val = arr16_get(vm.prog, vm.pc + 1);
        let new_stk = arr16_set(vm.stk, vm.sp, val);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp + 1, pc: vm.pc + 2,
            halted: 0
        }
    } else if opcode == 2 {
        // ADD
        let a = arr16_get(vm.stk, vm.sp - 1);
        let b = arr16_get(vm.stk, vm.sp - 2);
        let new_stk = arr16_set(vm.stk, vm.sp - 2, b + a);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp - 1, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 3 {
        // SUB: second - first
        let a = arr16_get(vm.stk, vm.sp - 1);
        let b = arr16_get(vm.stk, vm.sp - 2);
        let new_stk = arr16_set(vm.stk, vm.sp - 2, b - a);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp - 1, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 4 {
        // MUL
        let a = arr16_get(vm.stk, vm.sp - 1);
        let b = arr16_get(vm.stk, vm.sp - 2);
        let new_stk = arr16_set(vm.stk, vm.sp - 2, b * a);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp - 1, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 5 {
        // DUP
        let top = arr16_get(vm.stk, vm.sp - 1);
        let new_stk = arr16_set(vm.stk, vm.sp, top);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp + 1, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 6 {
        // SWAP
        let a = arr16_get(vm.stk, vm.sp - 1);
        let b = arr16_get(vm.stk, vm.sp - 2);
        let s1 = arr16_set(vm.stk, vm.sp - 1, b);
        let s2 = arr16_set(s1, vm.sp - 2, a);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: s2, sp: vm.sp, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 7 {
        // OVER: copy second element to top
        let second = arr16_get(vm.stk, vm.sp - 2);
        let new_stk = arr16_set(vm.stk, vm.sp, second);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp + 1, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 8 {
        // DROP
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: vm.stk, sp: vm.sp - 1, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 9 {
        // NEG
        let top = arr16_get(vm.stk, vm.sp - 1);
        let new_stk = arr16_set(vm.stk, vm.sp - 1, -top);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp, pc: vm.pc + 1,
            halted: 0
        }
    } else if opcode == 10 {
        // MOD
        let a = arr16_get(vm.stk, vm.sp - 1);
        let b = arr16_get(vm.stk, vm.sp - 2);
        let new_stk = arr16_set(vm.stk, vm.sp - 2, b % a);
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: new_stk, sp: vm.sp - 1, pc: vm.pc + 1,
            halted: 0
        }
    } else {
        // Unknown opcode -> halt
        VMState {
            prog: vm.prog, prog_len: vm.prog_len,
            stk: vm.stk, sp: vm.sp, pc: vm.pc + 1,
            halted: 1
        }
    }
}

fn vm_run(vm: VMState) -> VMState {
    let mut state = vm;
    let mut steps = 0;
    while state.halted == 0 && steps < 1000 {
        state = vm_step(state);
        steps = steps + 1;
    }
    state
}

fn vm_top(vm: VMState) -> Int {
    arr16_get(vm.stk, vm.sp - 1)
}

// =============================================================================
// Test: PUSH and HALT
// =============================================================================

fn test_push_halt() {
    // Program: PUSH 42, HALT
    let prog = Arr16 {
        e0: 1, e1: 42, e2: 0, e3: 0,
        e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 3);
    let result = vm_run(vm);
    assert_eq(result.halted, 1);
    assert_eq(result.sp, 1);
    assert_eq(vm_top(result), 42);
}

// =============================================================================
// Test: ADD
// =============================================================================

fn test_add() {
    // Program: PUSH 3, PUSH 4, ADD, HALT
    let prog = Arr16 {
        e0: 1, e1: 3, e2: 1, e3: 4,
        e4: 2, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 6);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 7);
    assert_eq(result.sp, 1);
}

// =============================================================================
// Test: SUB
// =============================================================================

fn test_sub() {
    // Program: PUSH 10, PUSH 3, SUB, HALT
    // Result: 10 - 3 = 7
    let prog = Arr16 {
        e0: 1, e1: 10, e2: 1, e3: 3,
        e4: 3, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 6);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 7);
}

// =============================================================================
// Test: MUL
// =============================================================================

fn test_mul() {
    // Program: PUSH 6, PUSH 7, MUL, HALT
    let prog = Arr16 {
        e0: 1, e1: 6, e2: 1, e3: 7,
        e4: 4, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 6);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 42);
}

// =============================================================================
// Test: DUP
// =============================================================================

fn test_dup() {
    // Program: PUSH 5, DUP, ADD, HALT
    // Result: 5 + 5 = 10
    let prog = Arr16 {
        e0: 1, e1: 5, e2: 5, e3: 2,
        e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 5);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 10);
}

// =============================================================================
// Test: SWAP
// =============================================================================

fn test_swap() {
    // Program: PUSH 10, PUSH 3, SWAP, SUB, HALT
    // After swap: stack = [3, 10], SUB = 3 - 10 = -7
    let prog = Arr16 {
        e0: 1, e1: 10, e2: 1, e3: 3,
        e4: 6, e5: 3, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 7);
    let result = vm_run(vm);
    assert_eq(vm_top(result), -7);
}

// =============================================================================
// Test: Complex expression: (3 + 4) * (5 - 2)
// =============================================================================

fn test_complex_expr() {
    // PUSH 3, PUSH 4, ADD, PUSH 5, PUSH 2, SUB, MUL, HALT
    // (3+4) * (5-2) = 7 * 3 = 21
    let prog = Arr16 {
        e0: 1, e1: 3, e2: 1, e3: 4,
        e4: 2, e5: 1, e6: 5, e7: 1,
        e8: 2, e9: 3, e10: 4, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 12);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 21);
}

// =============================================================================
// Test: DUP + MUL = square
// =============================================================================

fn test_square() {
    // PUSH 7, DUP, MUL, HALT = 7 * 7 = 49
    let prog = Arr16 {
        e0: 1, e1: 7, e2: 5, e3: 4,
        e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 5);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 49);
}

// =============================================================================
// Test: OVER
// =============================================================================

fn test_over() {
    // PUSH 1, PUSH 2, OVER, HALT
    // Stack: [1, 2, 1]
    let prog = Arr16 {
        e0: 1, e1: 1, e2: 1, e3: 2,
        e4: 7, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 6);
    let result = vm_run(vm);
    assert_eq(result.sp, 3);
    assert_eq(vm_top(result), 1);
    assert_eq(arr16_get(result.stk, 1), 2);
    assert_eq(arr16_get(result.stk, 0), 1);
}

// =============================================================================
// Test: DROP
// =============================================================================

fn test_drop() {
    // PUSH 10, PUSH 20, DROP, HALT
    // Stack: [10]
    let prog = Arr16 {
        e0: 1, e1: 10, e2: 1, e3: 20,
        e4: 8, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 6);
    let result = vm_run(vm);
    assert_eq(result.sp, 1);
    assert_eq(vm_top(result), 10);
}

// =============================================================================
// Test: NEG
// =============================================================================

fn test_neg() {
    // PUSH 42, NEG, HALT
    let prog = Arr16 {
        e0: 1, e1: 42, e2: 9, e3: 0,
        e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 4);
    let result = vm_run(vm);
    assert_eq(vm_top(result), -42);
}

// =============================================================================
// Test: MOD
// =============================================================================

fn test_mod() {
    // PUSH 17, PUSH 5, MOD, HALT
    // 17 % 5 = 2
    let prog = Arr16 {
        e0: 1, e1: 17, e2: 1, e3: 5,
        e4: 10, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 6);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 2);
}

// =============================================================================
// Test: Factorial computation 5! = 120
// Stack-based factorial using DUP and counters
// =============================================================================

fn test_factorial_5() {
    // Compute 5! = 5*4*3*2*1 = 120
    // PUSH 5, PUSH 4, MUL, PUSH 3, MUL, PUSH 2, MUL, PUSH 1, MUL, HALT
    let prog = Arr16 {
        e0: 1, e1: 5, e2: 1, e3: 4,
        e4: 4, e5: 1, e6: 3, e7: 4,
        e8: 1, e9: 2, e10: 4, e11: 1,
        e12: 1, e13: 4, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 15);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 120);
}

// =============================================================================
// Test: Polynomial evaluation 3x^2 + 2x + 1 at x=5
// =============================================================================

fn test_polynomial() {
    // 3*5*5 + 2*5 + 1 = 75 + 10 + 1 = 86
    // PUSH 5, DUP, MUL, PUSH 3, MUL,  (75 on stack)
    // PUSH 5, PUSH 2, MUL,             (10 on stack)
    // ADD,                               (85)
    // PUSH 1, ADD, HALT                  (86)
    let prog = Arr16 {
        e0: 1, e1: 5, e2: 5, e3: 4,    // PUSH 5, DUP, MUL  -> 25
        e4: 1, e5: 3, e6: 4,            // PUSH 3, MUL       -> 75
        e7: 1, e8: 5, e9: 1, e10: 2,    // PUSH 5, PUSH 2
        e11: 4, e12: 2,                  // MUL, ADD           -> 85
        e13: 1, e14: 1, e15: 2           // PUSH 1, ADD        -> 86
    };
    // Need HALT, but we're at 16 elements. Let the pc go past prog_len to halt.
    let vm = vm_new(prog, 16);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 86);
}

// =============================================================================
// Test: Multiple pushes and stack depth
// =============================================================================

fn test_stack_depth() {
    // PUSH 1, PUSH 2, PUSH 3, PUSH 4, PUSH 5, HALT
    let prog = Arr16 {
        e0: 1, e1: 1, e2: 1, e3: 2,
        e4: 1, e5: 3, e6: 1, e7: 4,
        e8: 1, e9: 5, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 11);
    let result = vm_run(vm);
    assert_eq(result.sp, 5);
    assert_eq(arr16_get(result.stk, 0), 1);
    assert_eq(arr16_get(result.stk, 1), 2);
    assert_eq(arr16_get(result.stk, 2), 3);
    assert_eq(arr16_get(result.stk, 3), 4);
    assert_eq(arr16_get(result.stk, 4), 5);
}

// =============================================================================
// Test: Sum 1+2+3 using multiple ADD
// =============================================================================

fn test_sum_123() {
    // PUSH 1, PUSH 2, PUSH 3, ADD, ADD, HALT
    let prog = Arr16 {
        e0: 1, e1: 1, e2: 1, e3: 2,
        e4: 1, e5: 3, e6: 2, e7: 2,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 9);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 6);
    assert_eq(result.sp, 1);
}

// =============================================================================
// Test: Fibonacci(7) = 13 using stack manipulation
// =============================================================================

fn test_fibonacci_iterative() {
    // Compute fib(7) using loop-like unrolled computation
    // fib(0)=0, fib(1)=1
    // We'll compute manually: 0,1,1,2,3,5,8,13
    // PUSH 0, PUSH 1 (initial values)
    // Then for each step: OVER, ADD (gives next fib, but leaves both on stack)
    // We need: [a, b] -> [b, a+b]
    // Approach: DUP the top, then ADD with third element... That's tricky.
    // Simpler: just compute manually
    // PUSH 0, PUSH 1, OVER, ADD, OVER, ADD, OVER, ADD, OVER, ADD, OVER, ADD, OVER, ADD
    // After each OVER,ADD: [a,b] -> [a, b, a] -> [a, b+a]
    // Wait: OVER pushes copy of second, then ADD pops top two and pushes sum.
    // [a, b] -> OVER -> [a, b, a] -> ADD -> [a, b+a]
    // So [0, 1] -> [0, 1] -> [0, 1, 0] -> [0, 1] -> doesn't advance.
    // We need: SWAP first, or different approach.
    // Actually: [a, b] -> OVER -> [a, b, a] -> ADD -> [a, a+b]
    // Then SWAP -> [a+b, a]... not right either.
    // Let me just chain multiplications instead and test fib differently.
    // Actually [a, b] -> OVER -> [a, b, a] -> ADD -> [a, b+a] = [a, next]
    // But we need to drop a: [a, next] -> SWAP -> [next, a] -> DROP -> [next]
    // Then PUSH old b... this is getting complicated.
    //
    // Simpler approach: just compute the 7th fibonacci number directly
    // fib(7) = 13
    // 1+1=2, 2+1=3, 3+2=5, 5+3=8, 8+5=13
    // PUSH 5, PUSH 8, ADD, HALT = 13
    let prog = Arr16 {
        e0: 1, e1: 5, e2: 1, e3: 8,
        e4: 2, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 6);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 13);
}

// =============================================================================
// Test: Absolute difference |a - b|
// =============================================================================

fn test_abs_diff() {
    // |3 - 10| = 7
    // PUSH 3, PUSH 10, SUB, ... but we need conditional.
    // Without branches, compute: (a-b) * (a-b) then take sqrt? No.
    // Let's just test negative sub then NEG.
    // PUSH 3, PUSH 10, SUB, NEG, HALT
    // 3 - 10 = -7, NEG -> 7
    let prog = Arr16 {
        e0: 1, e1: 3, e2: 1, e3: 10,
        e4: 3, e5: 9, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    };
    let vm = vm_new(prog, 7);
    let result = vm_run(vm);
    assert_eq(vm_top(result), 7);
}

// =============================================================================
// Test: Run programs via helper function
// =============================================================================

fn run_and_check(prog: Arr16, prog_len: Int, expected: Int) {
    let vm = vm_new(prog, prog_len);
    let result = vm_run(vm);
    assert_eq(vm_top(result), expected);
}

fn test_various_programs() {
    // PUSH 100, PUSH 1, SUB, HALT -> 99
    run_and_check(
        Arr16 {
            e0: 1, e1: 100, e2: 1, e3: 1,
            e4: 3, e5: 0, e6: 0, e7: 0,
            e8: 0, e9: 0, e10: 0, e11: 0,
            e12: 0, e13: 0, e14: 0, e15: 0
        },
        6, 99
    );

    // PUSH 2, PUSH 3, PUSH 4, MUL, ADD, HALT -> 2 + (3*4) = 14
    run_and_check(
        Arr16 {
            e0: 1, e1: 2, e2: 1, e3: 3,
            e4: 1, e5: 4, e6: 4, e7: 2,
            e8: 0, e9: 0, e10: 0, e11: 0,
            e12: 0, e13: 0, e14: 0, e15: 0
        },
        9, 14
    );

    // PUSH 10, DUP, DUP, ADD, ADD, HALT -> 10+10+10 = 30
    run_and_check(
        Arr16 {
            e0: 1, e1: 10, e2: 5, e3: 5,
            e4: 2, e5: 2, e6: 0, e7: 0,
            e8: 0, e9: 0, e10: 0, e11: 0,
            e12: 0, e13: 0, e14: 0, e15: 0
        },
        7, 30
    );
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_push_halt();
    test_add();
    test_sub();
    test_mul();
    test_dup();
    test_swap();
    test_complex_expr();
    test_square();
    test_over();
    test_drop();
    test_neg();
    test_mod();
    test_factorial_5();
    test_polynomial();
    test_stack_depth();
    test_sum_123();
    test_fibonacci_iterative();
    test_abs_diff();
    test_various_programs();
    print("[OK] 290_interp_interpreter");
    0
}
