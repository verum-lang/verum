// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, recursion, algorithms
// @timeout: 50000
// @expected-exit: 0
//
// Interpreter e2e test: recursion patterns — direct, mutual, tree, tail

// =============================================================================
// Basic recursion
// =============================================================================

@allow(unbounded_recursion)
fn factorial(n: Int) -> Int {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

@allow(unbounded_recursion)
fn fibonacci(n: Int) -> Int {
    if n <= 0 { 0 }
    else if n == 1 { 1 }
    else { fibonacci(n - 1) + fibonacci(n - 2) }
}

fn test_basic_recursion() {
    assert_eq(factorial(0), 1);
    assert_eq(factorial(1), 1);
    assert_eq(factorial(5), 120);
    assert_eq(factorial(10), 3628800);

    assert_eq(fibonacci(0), 0);
    assert_eq(fibonacci(1), 1);
    assert_eq(fibonacci(10), 55);
    assert_eq(fibonacci(15), 610);
    print("  test_basic_recursion: ok");
}

// =============================================================================
// Recursive list operations
// =============================================================================

@allow(unbounded_recursion)
fn sum_recursive(items: List<Int>, idx: Int) -> Int {
    if idx >= items.len() {
        0
    } else {
        items[idx] + sum_recursive(items, idx + 1)
    }
}

@allow(unbounded_recursion)
fn max_recursive(items: List<Int>, idx: Int, current_max: Int) -> Int {
    if idx >= items.len() {
        current_max
    } else {
        let new_max = if items[idx] > current_max { items[idx] } else { current_max };
        max_recursive(items, idx + 1, new_max)
    }
}

fn test_recursive_list_ops() {
    let nums: List<Int> = [3, 1, 4, 1, 5, 9, 2, 6];
    assert_eq(sum_recursive(nums, 0), 31);
    assert_eq(max_recursive(nums, 0, 0), 9);
    print("  test_recursive_list_ops: ok");
}

// =============================================================================
// Binary search (recursive)
// =============================================================================

@allow(unbounded_recursion)
fn binary_search(items: List<Int>, target: Int, low: Int, high: Int) -> Int {
    if low > high {
        -1
    } else {
        let mid = (low + high) / 2;
        if items[mid] == target {
            mid
        } else if items[mid] < target {
            binary_search(items, target, mid + 1, high)
        } else {
            binary_search(items, target, low, mid - 1)
        }
    }
}

fn test_binary_search() {
    let sorted: List<Int> = [2, 5, 8, 12, 16, 23, 38, 56, 72, 91];
    assert_eq(binary_search(sorted, 23, 0, 9), 5);
    assert_eq(binary_search(sorted, 2, 0, 9), 0);
    assert_eq(binary_search(sorted, 91, 0, 9), 9);
    assert_eq(binary_search(sorted, 50, 0, 9), -1);
    print("  test_binary_search: ok");
}

// =============================================================================
// Power function (recursive)
// =============================================================================

@allow(unbounded_recursion)
fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { 1 }
    else if exp == 1 { base }
    else if exp % 2 == 0 {
        let half = power(base, exp / 2);
        half * half
    } else {
        base * power(base, exp - 1)
    }
}

fn test_power() {
    assert_eq(power(2, 0), 1);
    assert_eq(power(2, 1), 2);
    assert_eq(power(2, 10), 1024);
    assert_eq(power(3, 5), 243);
    assert_eq(power(5, 3), 125);
    print("  test_power: ok");
}

// =============================================================================
// GCD (Euclidean algorithm)
// =============================================================================

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 { a }
    else { gcd(b, a % b) }
}

fn lcm(a: Int, b: Int) -> Int {
    a / gcd(a, b) * b
}

fn test_gcd_lcm() {
    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(17, 13), 1); // coprime

    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(12, 18), 36);
    print("  test_gcd_lcm: ok");
}

// =============================================================================
// Mutual recursion
// =============================================================================

@allow(unbounded_recursion)
fn is_even_rec(n: Int) -> Bool {
    if n == 0 { true }
    else { is_odd_rec(n - 1) }
}

@allow(unbounded_recursion)
fn is_odd_rec(n: Int) -> Bool {
    if n == 0 { false }
    else { is_even_rec(n - 1) }
}

fn test_mutual_recursion() {
    assert_eq(is_even_rec(0), true);
    assert_eq(is_even_rec(1), false);
    assert_eq(is_even_rec(10), true);
    assert_eq(is_odd_rec(7), true);
    assert_eq(is_odd_rec(8), false);
    print("  test_mutual_recursion: ok");
}

// =============================================================================
// Ackermann function (deeply recursive)
// =============================================================================

@allow(unbounded_recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 { n + 1 }
    else if n == 0 { ackermann(m - 1, 1) }
    else { ackermann(m - 1, ackermann(m, n - 1)) }
}

fn test_ackermann() {
    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(1, 1), 3);
    assert_eq(ackermann(2, 2), 7);
    assert_eq(ackermann(3, 2), 29);
    // ackermann(3, 3) = 61 — deep but tractable
    assert_eq(ackermann(3, 3), 61);
    print("  test_ackermann: ok");
}

// =============================================================================
// Towers of Hanoi (count moves)
// =============================================================================

@allow(unbounded_recursion)
fn hanoi_moves(n: Int) -> Int {
    if n <= 0 { 0 }
    else { 2 * hanoi_moves(n - 1) + 1 }
}

fn test_hanoi() {
    assert_eq(hanoi_moves(1), 1);
    assert_eq(hanoi_moves(3), 7);
    assert_eq(hanoi_moves(5), 31);
    assert_eq(hanoi_moves(10), 1023);
    assert_eq(hanoi_moves(20), 1048575);
    print("  test_hanoi: ok");
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_basic_recursion();
    test_recursive_list_ops();
    test_binary_search();
    test_power();
    test_gcd_lcm();
    test_mutual_recursion();
    test_ackermann();
    test_hanoi();
    print("[OK] 614_interp_recursion");
    0
}
