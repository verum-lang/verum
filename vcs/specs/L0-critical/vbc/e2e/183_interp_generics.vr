// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, generics
// @timeout: 5000
// @expected-exit: 0
//
// Interpreter e2e test: generic functions, generic record types, protocol
// constraints, monomorphization across different type instantiations

// =============================================================================
// Generic type definitions
// =============================================================================

type Pair<A, B> is { first: A, second: B };
type Wrapper<T> is { value: T };
type Triple<A, B, C> is { a: A, b: B, c: C };
type Container<T> is { items: List<T>, label: Text };

// =============================================================================
// Basic generic functions
// =============================================================================

fn identity<T>(x: T) -> T { x }

fn test_identity_monomorphization() {
    // Same generic function instantiated with different types
    assert_eq(identity(42), 42);
    assert_eq(identity(0), 0);
    assert_eq(identity(-100), -100);
    assert_eq(identity(true), true);
    assert_eq(identity(false), false);
    assert_eq(identity("hello"), "hello");
    assert_eq(identity(""), "");
    assert_eq(identity(3.14), 3.14);
}

fn const_val<T>(val: T, _unused: Int) -> T {
    val
}

fn test_const_val() {
    assert_eq(const_val(42, 999), 42);
    assert_eq(const_val("abc", 0), "abc");
    assert_eq(const_val(true, -1), true);
}

// =============================================================================
// Multiple type parameters
// =============================================================================

fn make_pair<A, B>(a: A, b: B) -> Pair<A, B> {
    Pair { first: a, second: b }
}

fn swap_pair<A, B>(p: Pair<A, B>) -> Pair<B, A> {
    Pair { first: p.second, second: p.first }
}

fn test_make_pair() {
    let p1 = make_pair(1, "one");
    assert_eq(p1.first, 1);
    assert_eq(p1.second, "one");

    let p2 = make_pair("hello", 42);
    assert_eq(p2.first, "hello");
    assert_eq(p2.second, 42);

    let p3 = make_pair(true, false);
    assert_eq(p3.first, true);
    assert_eq(p3.second, false);
}

fn test_swap_pair() {
    let p = make_pair(1, "hello");
    let swapped = swap_pair(p);
    assert_eq(swapped.first, "hello");
    assert_eq(swapped.second, 1);
}

fn test_pair_same_type() {
    let p = make_pair(10, 20);
    assert_eq(p.first + p.second, 30);
}

// =============================================================================
// Generic with protocol constraints
// =============================================================================

fn max_of<T: Ord>(a: T, b: T) -> T {
    if a > b { a } else { b }
}

fn min_of<T: Ord>(a: T, b: T) -> T {
    if a < b { a } else { b }
}

fn test_max_min_int() {
    assert_eq(max_of(3, 7), 7);
    assert_eq(max_of(10, 2), 10);
    assert_eq(max_of(5, 5), 5);
    assert_eq(min_of(3, 7), 3);
    assert_eq(min_of(10, 2), 2);
    assert_eq(min_of(5, 5), 5);
}

fn test_max_min_float() {
    assert_eq(max_of(3.14, 2.71), 3.14);
    assert_eq(min_of(3.14, 2.71), 2.71);
    assert_eq(max_of(1.0, 1.0), 1.0);
}

// =============================================================================
// Generic clamp (calls other generic functions)
// =============================================================================

fn clamp<T: Ord>(val: T, low: T, high: T) -> T {
    max_of(low, min_of(val, high))
}

fn test_clamp() {
    assert_eq(clamp(5, 1, 10), 5);
    assert_eq(clamp(-5, 1, 10), 1);
    assert_eq(clamp(50, 1, 10), 10);
    assert_eq(clamp(1, 1, 10), 1);
    assert_eq(clamp(10, 1, 10), 10);
}

// =============================================================================
// Generic wrapper methods
// =============================================================================

implement<T> Wrapper<T> {
    fn new(val: T) -> Wrapper<T> {
        Wrapper { value: val }
    }

    fn into_inner(self) -> T {
        self.value
    }
}

fn test_wrapper_int() {
    let w = Wrapper.new(42);
    assert_eq(w.into_inner(), 42);
}

fn test_wrapper_text() {
    let w = Wrapper.new("hello");
    assert_eq(w.into_inner(), "hello");
}

fn test_wrapper_bool() {
    let w = Wrapper.new(true);
    assert_eq(w.into_inner(), true);
}

// =============================================================================
// Triple type
// =============================================================================

fn make_triple<A, B, C>(a: A, b: B, c: C) -> Triple<A, B, C> {
    Triple { a: a, b: b, c: c }
}

fn test_triple_mixed() {
    let t = make_triple(1, "two", 3.0);
    assert_eq(t.a, 1);
    assert_eq(t.b, "two");
    assert_eq(t.c, 3.0);
}

fn test_triple_same_type() {
    let t = make_triple(10, 20, 30);
    assert_eq(t.a + t.b + t.c, 60);
}

// =============================================================================
// Generic unwrap_or with Maybe
// =============================================================================

fn unwrap_or<T>(opt: Maybe<T>, default: T) -> T {
    match opt {
        Some(v) => v,
        None => default
    }
}

fn test_unwrap_or_int() {
    assert_eq(unwrap_or(Some(42), 0), 42);
    assert_eq(unwrap_or(None, 0), 0);
    assert_eq(unwrap_or(Some(-5), 99), -5);
}

fn test_unwrap_or_text() {
    assert_eq(unwrap_or(Some("hello"), "default"), "hello");
    assert_eq(unwrap_or(None, "default"), "default");
}

// =============================================================================
// Generic map_maybe function
// =============================================================================

fn map_maybe<A, B>(opt: Maybe<A>, f: fn(A) -> B) -> Maybe<B> {
    match opt {
        Some(v) => Some(f(v)),
        None => None
    }
}

fn test_map_maybe() {
    let result = map_maybe(Some(5), |x: Int| -> Int { x * 2 });
    assert_eq(result, Some(10));

    let nothing: Maybe<Int> = map_maybe(None, |x: Int| -> Int { x * 2 });
    assert(nothing is None);
}

// =============================================================================
// Generic apply function
// =============================================================================

fn apply<A, B>(f: fn(A) -> B, val: A) -> B {
    f(val)
}

fn test_apply_generic() {
    let result1 = apply(|x: Int| -> Int { x + 1 }, 10);
    assert_eq(result1, 11);

    let result2 = apply(|x: Int| -> Bool { x > 0 }, 5);
    assert_eq(result2, true);

    let result3 = apply(|x: Int| -> Bool { x > 0 }, -3);
    assert_eq(result3, false);
}

// =============================================================================
// Generic container operations
// =============================================================================

fn test_container_type() {
    let c = Container { items: [1, 2, 3], label: "numbers" };
    assert_eq(c.items.len(), 3);
    assert_eq(c.items[0], 1);
    assert_eq(c.items[2], 3);
    assert_eq(c.label, "numbers");
}

fn test_container_text() {
    let c = Container { items: ["a", "b"], label: "letters" };
    assert_eq(c.items.len(), 2);
    assert_eq(c.items[0], "a");
    assert_eq(c.items[1], "b");
    assert_eq(c.label, "letters");
}

// =============================================================================
// Generic with result type
// =============================================================================

fn ok_or<T>(opt: Maybe<T>, err_msg: Text) -> Result<T, Text> {
    match opt {
        Some(v) => Ok(v),
        None => Err(err_msg)
    }
}

fn test_ok_or() {
    let r1 = ok_or(Some(42), "missing");
    assert(r1 is Ok(_));
    let v1 = match r1 { Ok(v) => v, Err(_) => -1 };
    assert_eq(v1, 42);

    let r2: Result<Int, Text> = ok_or(None, "missing");
    assert(r2 is Err(_));
    let m2 = match r2 { Ok(_) => "ok", Err(e) => e };
    assert_eq(m2, "missing");
}

fn main() -> Int {
    test_identity_monomorphization();
    test_const_val();
    test_make_pair();
    test_swap_pair();
    test_pair_same_type();
    test_max_min_int();
    test_max_min_float();
    test_clamp();
    test_wrapper_int();
    test_wrapper_text();
    test_wrapper_bool();
    test_triple_mixed();
    test_triple_same_type();
    test_unwrap_or_int();
    test_unwrap_or_text();
    test_map_maybe();
    test_apply_generic();
    test_container_type();
    test_container_text();
    test_ok_or();
    print("[OK] 183_interp_generics");
    0
}
