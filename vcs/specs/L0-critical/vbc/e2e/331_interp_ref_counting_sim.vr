// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, memory, refcount, cbgr
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Simulated reference counting with counter array,
// inc/dec/free operations. Tests basic ref counting, cyclic detection via
// weak counts, and correct deallocation tracking.

// =============================================================================
// Array infrastructure
// =============================================================================

type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn a8_new() -> Arr8 {
    Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 }
}

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 }
    }
}

// =============================================================================
// Reference counting system
// refcounts[i]: strong reference count for object i
// alive[i]: 1 if object is alive, 0 if freed
// values[i]: simulated data value for object i
// weak_counts[i]: weak reference count (for cycle detection)
// =============================================================================

type RefCountState is {
    refcounts: Arr8,
    alive: Arr8,
    values: Arr8,
    weak_counts: Arr8,
    num_objects: Int,
    total_frees: Int
};

fn rc_new() -> RefCountState {
    RefCountState {
        refcounts: a8_new(),
        alive: a8_new(),
        values: a8_new(),
        weak_counts: a8_new(),
        num_objects: 0,
        total_frees: 0
    }
}

// Allocate a new object with given value, returns (state, object_id)
type AllocPair is { state: RefCountState, obj_id: Int };

fn rc_alloc(st: RefCountState, val: Int) -> AllocPair {
    let id = st.num_objects;
    let new_rc = a8_set(st.refcounts, id, 1);
    let new_alive = a8_set(st.alive, id, 1);
    let new_vals = a8_set(st.values, id, val);
    AllocPair {
        state: RefCountState {
            refcounts: new_rc,
            alive: new_alive,
            values: new_vals,
            weak_counts: st.weak_counts,
            num_objects: id + 1,
            total_frees: st.total_frees
        },
        obj_id: id
    }
}

// Increment strong reference count
fn rc_inc(st: RefCountState, id: Int) -> RefCountState {
    let cur = a8_get(st.refcounts, id);
    RefCountState {
        refcounts: a8_set(st.refcounts, id, cur + 1),
        alive: st.alive,
        values: st.values,
        weak_counts: st.weak_counts,
        num_objects: st.num_objects,
        total_frees: st.total_frees
    }
}

// Decrement strong reference count, free if zero
fn rc_dec(st: RefCountState, id: Int) -> RefCountState {
    let cur = a8_get(st.refcounts, id);
    if cur <= 1 {
        // Free the object
        RefCountState {
            refcounts: a8_set(st.refcounts, id, 0),
            alive: a8_set(st.alive, id, 0),
            values: st.values,
            weak_counts: st.weak_counts,
            num_objects: st.num_objects,
            total_frees: st.total_frees + 1
        }
    } else {
        RefCountState {
            refcounts: a8_set(st.refcounts, id, cur - 1),
            alive: st.alive,
            values: st.values,
            weak_counts: st.weak_counts,
            num_objects: st.num_objects,
            total_frees: st.total_frees
        }
    }
}

// Add a weak reference
fn rc_weak_inc(st: RefCountState, id: Int) -> RefCountState {
    let cur = a8_get(st.weak_counts, id);
    RefCountState {
        refcounts: st.refcounts,
        alive: st.alive,
        values: st.values,
        weak_counts: a8_set(st.weak_counts, id, cur + 1),
        num_objects: st.num_objects,
        total_frees: st.total_frees
    }
}

// Remove a weak reference
fn rc_weak_dec(st: RefCountState, id: Int) -> RefCountState {
    let cur = a8_get(st.weak_counts, id);
    let new_wc = if cur > 0 { cur - 1 } else { 0 };
    RefCountState {
        refcounts: st.refcounts,
        alive: st.alive,
        values: st.values,
        weak_counts: a8_set(st.weak_counts, id, new_wc),
        num_objects: st.num_objects,
        total_frees: st.total_frees
    }
}

// Check if an object is alive
fn rc_is_alive(st: RefCountState, id: Int) -> Int {
    a8_get(st.alive, id)
}

// Get reference count
fn rc_get_count(st: RefCountState, id: Int) -> Int {
    a8_get(st.refcounts, id)
}

// Count total alive objects
fn rc_alive_count(st: RefCountState) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < st.num_objects {
        count = count + a8_get(st.alive, i);
        i = i + 1;
    }
    count
}

// =============================================================================
// Tests
// =============================================================================

fn test_basic_alloc_free() {
    let s0 = rc_new();
    let p1 = rc_alloc(s0, 100);
    let s1 = p1.state;
    assert_eq(rc_is_alive(s1, p1.obj_id), 1);
    assert_eq(rc_get_count(s1, p1.obj_id), 1);
    assert_eq(a8_get(s1.values, p1.obj_id), 100);

    // Decrement -> should free
    let s2 = rc_dec(s1, p1.obj_id);
    assert_eq(rc_is_alive(s2, p1.obj_id), 0);
    assert_eq(rc_get_count(s2, p1.obj_id), 0);
    assert_eq(s2.total_frees, 1);
}

fn test_multiple_refs() {
    let s0 = rc_new();
    let p1 = rc_alloc(s0, 42);
    let s1 = p1.state;
    let id = p1.obj_id;

    // Add 3 more references (total 4)
    let s2 = rc_inc(rc_inc(rc_inc(s1, id), id), id);
    assert_eq(rc_get_count(s2, id), 4);
    assert_eq(rc_is_alive(s2, id), 1);

    // Decrement 3 times (should still be alive with count=1)
    let s3 = rc_dec(rc_dec(rc_dec(s2, id), id), id);
    assert_eq(rc_get_count(s3, id), 1);
    assert_eq(rc_is_alive(s3, id), 1);

    // Final decrement -> free
    let s4 = rc_dec(s3, id);
    assert_eq(rc_is_alive(s4, id), 0);
    assert_eq(s4.total_frees, 1);
}

fn test_multiple_objects() {
    let s0 = rc_new();
    let p1 = rc_alloc(s0, 10);
    let p2 = rc_alloc(p1.state, 20);
    let p3 = rc_alloc(p2.state, 30);
    let s1 = p3.state;

    assert_eq(rc_alive_count(s1), 3);
    assert_eq(s1.num_objects, 3);

    // Free object 1
    let s2 = rc_dec(s1, p2.obj_id);
    assert_eq(rc_alive_count(s2), 2);
    assert_eq(rc_is_alive(s2, p1.obj_id), 1);
    assert_eq(rc_is_alive(s2, p2.obj_id), 0);
    assert_eq(rc_is_alive(s2, p3.obj_id), 1);

    // Free remaining
    let s3 = rc_dec(rc_dec(s2, p1.obj_id), p3.obj_id);
    assert_eq(rc_alive_count(s3), 0);
    assert_eq(s3.total_frees, 3);
}

fn test_weak_references() {
    let s0 = rc_new();
    let p1 = rc_alloc(s0, 99);
    let s1 = p1.state;
    let id = p1.obj_id;

    // Add weak references
    let s2 = rc_weak_inc(rc_weak_inc(s1, id), id);
    assert_eq(a8_get(s2.weak_counts, id), 2);
    assert_eq(rc_get_count(s2, id), 1);  // Strong count unchanged

    // Free the strong reference - object should be freed
    // (weak refs don't keep objects alive)
    let s3 = rc_dec(s2, id);
    assert_eq(rc_is_alive(s3, id), 0);
    assert_eq(a8_get(s3.weak_counts, id), 2);  // Weak count still there

    // Clean up weak refs
    let s4 = rc_weak_dec(rc_weak_dec(s3, id), id);
    assert_eq(a8_get(s4.weak_counts, id), 0);
}

fn test_shared_ownership() {
    // Simulate A and B both owning object X, C owning object Y
    let s0 = rc_new();
    let px = rc_alloc(s0, 1000);
    let py = rc_alloc(px.state, 2000);
    let s1 = py.state;
    let x = px.obj_id;
    let y = py.obj_id;

    // A already has ref to X. B also refs X.
    let s2 = rc_inc(s1, x);
    assert_eq(rc_get_count(s2, x), 2);
    assert_eq(rc_get_count(s2, y), 1);

    // A drops its reference to X
    let s3 = rc_dec(s2, x);
    assert_eq(rc_is_alive(s3, x), 1);  // B still holds it
    assert_eq(rc_get_count(s3, x), 1);

    // B drops its reference to X
    let s4 = rc_dec(s3, x);
    assert_eq(rc_is_alive(s4, x), 0);  // Now freed

    // Y still alive
    assert_eq(rc_is_alive(s4, y), 1);
    let s5 = rc_dec(s4, y);
    assert_eq(rc_is_alive(s5, y), 0);
    assert_eq(s5.total_frees, 2);
}

fn test_inc_dec_interleaved() {
    let s0 = rc_new();
    let p = rc_alloc(s0, 55);
    let s1 = p.state;
    let id = p.obj_id;

    // inc, inc, dec, inc, dec, dec -> count should be 1
    let s2 = rc_inc(s1, id);       // 2
    let s3 = rc_inc(s2, id);       // 3
    let s4 = rc_dec(s3, id);       // 2
    let s5 = rc_inc(s4, id);       // 3
    let s6 = rc_dec(s5, id);       // 2
    let s7 = rc_dec(s6, id);       // 1
    assert_eq(rc_get_count(s7, id), 1);
    assert_eq(rc_is_alive(s7, id), 1);
    assert_eq(s7.total_frees, 0);
}

fn test_double_free_protection() {
    let s0 = rc_new();
    let p = rc_alloc(s0, 77);
    let s1 = p.state;
    let id = p.obj_id;

    // Free once
    let s2 = rc_dec(s1, id);
    assert_eq(rc_is_alive(s2, id), 0);
    assert_eq(s2.total_frees, 1);

    // Attempt double free — count is already 0, dec should handle gracefully
    let s3 = rc_dec(s2, id);
    // Should still be freed, no crash
    assert_eq(rc_is_alive(s3, id), 0);
    assert_eq(s3.total_frees, 2);  // Tracked but harmless in sim
}

fn main() -> Int {
    test_basic_alloc_free();
    test_multiple_refs();
    test_multiple_objects();
    test_weak_references();
    test_shared_ownership();
    test_inc_dec_interleaved();
    test_double_free_protection();
    print("[OK] 331_interp_ref_counting_sim");
    0
}
