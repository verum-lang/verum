// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, autodiff, reverse-mode, backprop, computation-graph
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Reverse-mode AD simulation
// Full reverse-mode backpropagation with computation graph.
// Ops: CONST=0, ADD=1, MUL=2, SUB=3
// Uses integer-scaled arithmetic (scale=1000).

fn scale() -> Int { 1000 }

fn smul(a: Int, b: Int) -> Int {
    (a * b) / scale()
}

fn abs_val(x: Int) -> Int {
    if x < 0 { 0 - x } else { x }
}

fn within_tol(actual: Int, expected: Int, tol: Int) -> Int {
    if abs_val(actual - expected) <= tol { 1 } else { 0 }
}

// =============================================================================
// Fixed-size arrays (16 slots)
// =============================================================================

type Arr16 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int,
                e8: Int, e9: Int, e10: Int, e11: Int, e12: Int, e13: Int, e14: Int, e15: Int };

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.e0 } else if i == 1 { a.e1 } else if i == 2 { a.e2 }
    else if i == 3 { a.e3 } else if i == 4 { a.e4 } else if i == 5 { a.e5 }
    else if i == 6 { a.e6 } else if i == 7 { a.e7 } else if i == 8 { a.e8 }
    else if i == 9 { a.e9 } else if i == 10 { a.e10 } else if i == 11 { a.e11 }
    else if i == 12 { a.e12 } else if i == 13 { a.e13 } else if i == 14 { a.e14 }
    else { a.e15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        e0: if i == 0 { v } else { a.e0 }, e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 }, e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 }, e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 }, e7: if i == 7 { v } else { a.e7 },
        e8: if i == 8 { v } else { a.e8 }, e9: if i == 9 { v } else { a.e9 },
        e10: if i == 10 { v } else { a.e10 }, e11: if i == 11 { v } else { a.e11 },
        e12: if i == 12 { v } else { a.e12 }, e13: if i == 13 { v } else { a.e13 },
        e14: if i == 14 { v } else { a.e14 }, e15: if i == 15 { v } else { a.e15 }
    }
}

fn a16_zeros() -> Arr16 {
    Arr16 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0,
            e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0 }
}

// =============================================================================
// Computation graph with SUB support
// =============================================================================

type CompGraph is {
    ops: Arr16,
    arg1s: Arr16,
    arg2s: Arr16,
    vals: Arr16,
    sz: Int
};

fn cg_new() -> CompGraph {
    CompGraph { ops: a16_zeros(), arg1s: a16_zeros(), arg2s: a16_zeros(), vals: a16_zeros(), sz: 0 }
}

fn cg_const(g: CompGraph, val: Int) -> CompGraph {
    let idx = g.sz;
    CompGraph {
        ops: a16_set(g.ops, idx, 0),
        arg1s: a16_set(g.arg1s, idx, -1),
        arg2s: a16_set(g.arg2s, idx, -1),
        vals: a16_set(g.vals, idx, val),
        sz: g.sz + 1
    }
}

fn cg_add(g: CompGraph, a1: Int, a2: Int) -> CompGraph {
    let idx = g.sz;
    let v = a16_get(g.vals, a1) + a16_get(g.vals, a2);
    CompGraph {
        ops: a16_set(g.ops, idx, 1),
        arg1s: a16_set(g.arg1s, idx, a1),
        arg2s: a16_set(g.arg2s, idx, a2),
        vals: a16_set(g.vals, idx, v),
        sz: g.sz + 1
    }
}

fn cg_mul(g: CompGraph, a1: Int, a2: Int) -> CompGraph {
    let idx = g.sz;
    let v = smul(a16_get(g.vals, a1), a16_get(g.vals, a2));
    CompGraph {
        ops: a16_set(g.ops, idx, 2),
        arg1s: a16_set(g.arg1s, idx, a1),
        arg2s: a16_set(g.arg2s, idx, a2),
        vals: a16_set(g.vals, idx, v),
        sz: g.sz + 1
    }
}

fn cg_sub(g: CompGraph, a1: Int, a2: Int) -> CompGraph {
    let idx = g.sz;
    let v = a16_get(g.vals, a1) - a16_get(g.vals, a2);
    CompGraph {
        ops: a16_set(g.ops, idx, 3),
        arg1s: a16_set(g.arg1s, idx, a1),
        arg2s: a16_set(g.arg2s, idx, a2),
        vals: a16_set(g.vals, idx, v),
        sz: g.sz + 1
    }
}

fn cg_val(g: CompGraph, idx: Int) -> Int { a16_get(g.vals, idx) }

// =============================================================================
// Reverse-mode backward pass
// =============================================================================

fn cg_backward(g: CompGraph) -> Arr16 {
    let mut adj = a16_zeros();
    adj = a16_set(adj, g.sz - 1, scale()); // seed output adjoint = 1.0

    let mut i = g.sz - 1;
    while i >= 0 {
        let op = a16_get(g.ops, i);
        let a1 = a16_get(g.arg1s, i);
        let a2 = a16_get(g.arg2s, i);
        let gi = a16_get(adj, i);

        if op == 1 {
            // ADD: adjoint passes through to both args
            if a1 >= 0 { adj = a16_set(adj, a1, a16_get(adj, a1) + gi); }
            if a2 >= 0 { adj = a16_set(adj, a2, a16_get(adj, a2) + gi); }
        } else if op == 2 {
            // MUL: adjoint * other arg's value
            if a1 >= 0 { adj = a16_set(adj, a1, a16_get(adj, a1) + smul(gi, a16_get(g.vals, a2))); }
            if a2 >= 0 { adj = a16_set(adj, a2, a16_get(adj, a2) + smul(gi, a16_get(g.vals, a1))); }
        } else if op == 3 {
            // SUB: a1 gets +gi, a2 gets -gi
            if a1 >= 0 { adj = a16_set(adj, a1, a16_get(adj, a1) + gi); }
            if a2 >= 0 { adj = a16_set(adj, a2, a16_get(adj, a2) - gi); }
        }

        if i == 0 { i = -1; } else { i = i - 1; }
    }
    adj
}

// =============================================================================
// Tests
// =============================================================================

fn test_sub_gradient() {
    // f(x,y) = x - y, df/dx = 1, df/dy = -1
    let mut g = cg_new();
    g = cg_const(g, 5 * scale()); // 0: x
    g = cg_const(g, 3 * scale()); // 1: y
    g = cg_sub(g, 0, 1);          // 2: x-y

    assert_eq(cg_val(g, 2), 2 * scale());

    let adj = cg_backward(g);
    assert_eq(a16_get(adj, 0), scale());      // df/dx = 1
    assert_eq(a16_get(adj, 1), 0 - scale());  // df/dy = -1
}

fn test_quadratic() {
    // f(x) = x^2 - 3x + 2
    // f'(x) = 2x - 3
    // At x=4: f(4) = 16-12+2 = 6, f'(4) = 5
    let mut g = cg_new();
    g = cg_const(g, 4 * scale());  // 0: x=4
    g = cg_const(g, 3 * scale());  // 1: const 3
    g = cg_const(g, 2 * scale());  // 2: const 2
    g = cg_mul(g, 0, 0);           // 3: x^2 = 16
    g = cg_mul(g, 1, 0);           // 4: 3*x = 12
    g = cg_sub(g, 3, 4);           // 5: x^2 - 3x = 4
    g = cg_add(g, 5, 2);           // 6: x^2 - 3x + 2 = 6

    assert_eq(cg_val(g, 6), 6 * scale());

    let adj = cg_backward(g);
    // df/dx: from x^2 (2x=8) + from 3x (-3) = 5
    assert_eq(a16_get(adj, 0), 5 * scale());
}

fn test_two_variable_expression() {
    // f(x,y) = x*y - x^2
    // df/dx = y - 2x, df/dy = x
    // At x=3, y=5: f=15-9=6, df/dx=5-6=-1, df/dy=3
    let mut g = cg_new();
    g = cg_const(g, 3 * scale());  // 0: x=3
    g = cg_const(g, 5 * scale());  // 1: y=5
    g = cg_mul(g, 0, 1);           // 2: x*y = 15
    g = cg_mul(g, 0, 0);           // 3: x^2 = 9
    g = cg_sub(g, 2, 3);           // 4: x*y - x^2 = 6

    assert_eq(cg_val(g, 4), 6 * scale());

    let adj = cg_backward(g);
    assert_eq(a16_get(adj, 0), -1 * scale()); // df/dx = -1
    assert_eq(a16_get(adj, 1), 3 * scale());  // df/dy = 3
}

fn test_diamond_graph() {
    // f(x) = (x+1)*(x-1) = x^2 - 1
    // f'(x) = 2x
    // At x=3: f=8, f'=6
    let mut g = cg_new();
    g = cg_const(g, 3 * scale());  // 0: x=3
    g = cg_const(g, scale());      // 1: const 1
    g = cg_add(g, 0, 1);           // 2: x+1 = 4
    g = cg_sub(g, 0, 1);           // 3: x-1 = 2
    g = cg_mul(g, 2, 3);           // 4: (x+1)*(x-1) = 8

    assert_eq(cg_val(g, 4), 8 * scale());

    let adj = cg_backward(g);
    // x appears in both branches: grad from (x+1) and (x-1)
    assert_eq(a16_get(adj, 0), 6 * scale()); // f'(3) = 2*3 = 6
}

fn test_complex_expression() {
    // f(x,y) = (x+y)^2 - x*y
    // = x^2 + 2xy + y^2 - xy = x^2 + xy + y^2
    // df/dx = 2x + y, df/dy = x + 2y
    // At x=2, y=3: f=4+6+9=19, df/dx=7, df/dy=8
    let mut g = cg_new();
    g = cg_const(g, 2 * scale());  // 0: x=2
    g = cg_const(g, 3 * scale());  // 1: y=3
    g = cg_add(g, 0, 1);           // 2: x+y = 5
    g = cg_mul(g, 2, 2);           // 3: (x+y)^2 = 25
    g = cg_mul(g, 0, 1);           // 4: x*y = 6
    g = cg_sub(g, 3, 4);           // 5: (x+y)^2 - x*y = 19

    assert_eq(cg_val(g, 5), 19 * scale());

    let adj = cg_backward(g);
    assert_eq(a16_get(adj, 0), 7 * scale()); // df/dx
    assert_eq(a16_get(adj, 1), 8 * scale()); // df/dy
}

fn test_three_variable() {
    // f(x,y,z) = x*y + y*z + x*z
    // df/dx = y+z, df/dy = x+z, df/dz = y+x
    // At x=1, y=2, z=3: f=2+6+3=11
    let mut g = cg_new();
    g = cg_const(g, scale());      // 0: x=1
    g = cg_const(g, 2 * scale());  // 1: y=2
    g = cg_const(g, 3 * scale());  // 2: z=3
    g = cg_mul(g, 0, 1);           // 3: x*y = 2
    g = cg_mul(g, 1, 2);           // 4: y*z = 6
    g = cg_mul(g, 0, 2);           // 5: x*z = 3
    g = cg_add(g, 3, 4);           // 6: x*y + y*z = 8
    g = cg_add(g, 6, 5);           // 7: x*y + y*z + x*z = 11

    assert_eq(cg_val(g, 7), 11 * scale());

    let adj = cg_backward(g);
    assert_eq(a16_get(adj, 0), 5 * scale()); // df/dx = y+z = 5
    assert_eq(a16_get(adj, 1), 4 * scale()); // df/dy = x+z = 4
    assert_eq(a16_get(adj, 2), 3 * scale()); // df/dz = y+x = 3
}

fn test_chain_operations() {
    // f(x) = ((x+1)*2) - 3
    // = 2x + 2 - 3 = 2x - 1
    // f'(x) = 2
    // At x=5: f=9
    let mut g = cg_new();
    g = cg_const(g, 5 * scale());  // 0: x=5
    g = cg_const(g, scale());      // 1: const 1
    g = cg_const(g, 2 * scale());  // 2: const 2
    g = cg_const(g, 3 * scale());  // 3: const 3
    g = cg_add(g, 0, 1);           // 4: x+1 = 6
    g = cg_mul(g, 4, 2);           // 5: (x+1)*2 = 12
    g = cg_sub(g, 5, 3);           // 6: (x+1)*2 - 3 = 9

    assert_eq(cg_val(g, 6), 9 * scale());

    let adj = cg_backward(g);
    assert_eq(a16_get(adj, 0), 2 * scale()); // df/dx = 2
}

fn main() -> Int {
    test_sub_gradient();
    test_quadratic();
    test_two_variable_expression();
    test_diamond_graph();
    test_complex_expression();
    test_three_variable();
    test_chain_operations();
    print("[OK] 382_interp_autodiff_reverse_mode");
    0
}
