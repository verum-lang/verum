fn main() -> Int {
    test_hanoi_n1();
    test_hanoi_n2();
    test_hanoi_n3();
    test_hanoi_pow2();
    test_hanoi_n4_count();
    print("[OK] 591_interp_towers_of_hanoi");
    0
}
