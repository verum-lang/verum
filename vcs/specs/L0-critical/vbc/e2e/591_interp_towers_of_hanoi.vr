    hanoi_iter(4, stk, count, last);
    assert_eq(count[0], 15);
    // Last move: disc 1 from B(1) to C(2)
    assert_eq(last[0], 1);
    assert_eq(last[1], 1);
    assert_eq(last[2], 2);
