// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, bitwise, shift
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: bitwise AND, OR, XOR, NOT, left shift, right shift

// =============================================================================
// Bitwise AND
// =============================================================================

fn test_bitwise_and() {
    assert_eq(0xFF & 0x0F, 0x0F);
    assert_eq(0xFF & 0x00, 0x00);
    assert_eq(0xFF & 0xFF, 0xFF);
    assert_eq(6 & 3, 2);
    assert_eq(12 & 10, 8);
    assert_eq(0 & 0, 0);
    assert_eq(255 & 255, 255);
}

// =============================================================================
// Bitwise OR
// =============================================================================

fn test_bitwise_or() {
    assert_eq(0xF0 | 0x0F, 0xFF);
    assert_eq(0x00 | 0x00, 0x00);
    assert_eq(1 | 2, 3);
    assert_eq(4 | 8, 12);
    assert_eq(0 | 42, 42);
    assert_eq(42 | 0, 42);
    assert_eq(5 | 3, 7);
}

// =============================================================================
// Bitwise XOR
// =============================================================================

fn test_bitwise_xor() {
    assert_eq(0xFF ^ 0xFF, 0x00);
    assert_eq(0xFF ^ 0x00, 0xFF);
    assert_eq(5 ^ 3, 6);
    assert_eq(10 ^ 10, 0);
    assert_eq(0 ^ 42, 42);
    assert_eq(42 ^ 0, 42);
    // XOR self-inverse: a ^ b ^ b == a
    let a = 123;
    let b = 456;
    assert_eq(a ^ b ^ b, a);
}

// =============================================================================
// Bitwise NOT
// =============================================================================

fn test_bitwise_not() {
    // ~0 == -1 in two's complement
    assert_eq(~0, -1);
    // ~(-1) == 0
    assert_eq(~(-1), 0);
    // Double NOT is identity
    let x = 42;
    assert_eq(~~x, x);
    // ~x == -(x+1) for two's complement
    assert_eq(~5, -6);
    assert_eq(~100, -101);
}

// =============================================================================
// Left shift
// =============================================================================

fn test_left_shift() {
    assert_eq(1 << 0, 1);
    assert_eq(1 << 1, 2);
    assert_eq(1 << 2, 4);
    assert_eq(1 << 3, 8);
    assert_eq(1 << 10, 1024);
    assert_eq(3 << 4, 48);
    assert_eq(1 << 16, 65536);
    assert_eq(1 << 20, 1048576);
}

// =============================================================================
// Right shift
// =============================================================================

fn test_right_shift() {
    assert_eq(1024 >> 10, 1);
    assert_eq(16 >> 2, 4);
    assert_eq(255 >> 4, 15);
    assert_eq(8 >> 3, 1);
    assert_eq(1 >> 0, 1);
    assert_eq(65536 >> 16, 1);
    assert_eq(1048576 >> 20, 1);
}

// =============================================================================
// Bitwise identity laws
// =============================================================================

fn test_bitwise_identity() {
    let x = 42;
    // x & x == x (idempotent)
    assert_eq(x & x, x);
    // x | x == x (idempotent)
    assert_eq(x | x, x);
    // x ^ x == 0 (self-inverse)
    assert_eq(x ^ x, 0);
    // x ^ 0 == x (identity)
    assert_eq(x ^ 0, x);
    // x & 0 == 0 (annihilation)
    assert_eq(x & 0, 0);
    // x | 0 == x (identity)
    assert_eq(x | 0, x);
}

// =============================================================================
// Shift equivalence to multiply/divide by powers of 2
// =============================================================================

fn test_shift_mul_div_equivalence() {
    let x = 42;
    assert_eq(x << 1, x * 2);
    assert_eq(x << 2, x * 4);
    assert_eq(x << 3, x * 8);
    assert_eq(x >> 1, x / 2);
    assert_eq(100 >> 2, 100 / 4);
}

fn main() -> Int {
    test_bitwise_and();
    test_bitwise_or();
    test_bitwise_xor();
    test_bitwise_not();
    test_left_shift();
    test_right_shift();
    test_bitwise_identity();
    test_shift_mul_div_equivalence();
    print("[OK] 214_interp_bitwise_ops");
    0
}
