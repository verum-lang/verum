// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, ml, distributed
// @timeout: 50000
// @expected-exit: 0
// @description: ML distributed operations — single-process stubs for AllReduce, Broadcast, etc.

// ============================================================================
// Vec4: a simple 4-element integer vector (simulating distributed data)
// ============================================================================

type Vec4 is { x: Int, y: Int, z: Int, w: Int };

fn vec4_new(x: Int, y: Int, z: Int, w: Int) -> Vec4 {
    Vec4 { x: x, y: y, z: z, w: w }
}

fn vec4_eq(a: Vec4, b: Vec4) -> Bool {
    a.x == b.x && a.y == b.y && a.z == b.z && a.w == b.w
}

fn vec4_add(a: Vec4, b: Vec4) -> Vec4 {
    Vec4 { x: a.x + b.x, y: a.y + b.y, z: a.z + b.z, w: a.w + b.w }
}

fn vec4_max(a: Vec4, b: Vec4) -> Vec4 {
    Vec4 {
        x: if a.x > b.x { a.x } else { b.x },
        y: if a.y > b.y { a.y } else { b.y },
        z: if a.z > b.z { a.z } else { b.z },
        w: if a.w > b.w { a.w } else { b.w }
    }
}

fn vec4_min(a: Vec4, b: Vec4) -> Vec4 {
    Vec4 {
        x: if a.x < b.x { a.x } else { b.x },
        y: if a.y < b.y { a.y } else { b.y },
        z: if a.z < b.z { a.z } else { b.z },
        w: if a.w < b.w { a.w } else { b.w }
    }
}

fn vec4_scale(a: Vec4, s: Int) -> Vec4 {
    Vec4 { x: a.x * s, y: a.y * s, z: a.z * s, w: a.w * s }
}

fn vec4_sum(a: Vec4) -> Int {
    a.x + a.y + a.z + a.w
}

// ============================================================================
// ReduceOp: operation type for collective reductions
// ============================================================================

type ReduceOp is { code: Int };

fn reduce_op_sum() -> ReduceOp { ReduceOp { code: 0 } }
fn reduce_op_max() -> ReduceOp { ReduceOp { code: 1 } }
fn reduce_op_min() -> ReduceOp { ReduceOp { code: 2 } }
fn reduce_op_prod() -> ReduceOp { ReduceOp { code: 3 } }

// ============================================================================
// ProcessGroup: describes a group of distributed processes
// ============================================================================

type ProcessGroup is {
    rank: Int,
    world_size: Int,
    group_id: Int
};

fn world_group() -> ProcessGroup {
    ProcessGroup { rank: 0, world_size: 1, group_id: 0 }
}

fn make_group(rank: Int, world_size: Int, gid: Int) -> ProcessGroup {
    ProcessGroup { rank: rank, world_size: world_size, group_id: gid }
}

// ============================================================================
// Single-process stub: AllReduce
// In a single-process setting, AllReduce is identity — result == input.
// ============================================================================

fn all_reduce_sum(data: Vec4, group: ProcessGroup) -> Vec4 {
    // With world_size == 1, the only participant is self, so Sum(data) = data
    if group.world_size == 1 {
        data
    } else {
        // Multi-process stub: simulate by just returning data (no actual comm)
        data
    }
}

fn all_reduce_max(data: Vec4, group: ProcessGroup) -> Vec4 {
    // With world_size == 1, max across one process == input
    if group.world_size == 1 {
        data
    } else {
        data
    }
}

fn all_reduce_min(data: Vec4, group: ProcessGroup) -> Vec4 {
    if group.world_size == 1 {
        data
    } else {
        data
    }
}

// ============================================================================
// Single-process stub: Broadcast
// Root broadcasts data; in single-process, data is unchanged.
// ============================================================================

fn broadcast_data(data: Vec4, root: Int, group: ProcessGroup) -> Vec4 {
    // In single process, rank must be root (== 0)
    if group.rank == root {
        data
    } else {
        // Would receive from root, but we're the only process
        data
    }
}

// ============================================================================
// Single-process stub: AllGather
// Each process contributes data; single process gets back its own data.
// Returns (gathered_data, count). Count == world_size.
// ============================================================================

type GatherResult is { data: Vec4, count: Int };

fn all_gather(local_data: Vec4, group: ProcessGroup) -> GatherResult {
    // Single process: gathered result is just our own data, count = 1
    GatherResult { data: local_data, count: group.world_size }
}

// ============================================================================
// Single-process stub: ReduceScatter
// Reduce across all processes, then scatter partitions.
// Single process: reduce is identity, scatter returns a partition.
// For simplicity, returns the full reduced data (only one partition).
// ============================================================================

fn reduce_scatter(data: Vec4, group: ProcessGroup) -> Vec4 {
    // Single process: reduced data == input, scatter of 1 partition == input
    if group.world_size == 1 {
        data
    } else {
        data
    }
}

// ============================================================================
// Single-process stub: Barrier
// Synchronize all processes. In single process, this is a no-op.
// Returns 1 on success.
// ============================================================================

fn barrier_sync(group: ProcessGroup) -> Int {
    // No-op for single process
    1
}

// ============================================================================
// Ring-reduce simulation
// In a ring of N processes, each sends partial sums around the ring.
// With a single process, the "ring" has one node — data goes nowhere.
// Simulate a multi-step ring for testing logic even with world_size=1.
// ============================================================================

type RingState is {
    local_data: Vec4,
    accumulated: Vec4,
    step: Int,
    total_steps: Int
};

fn ring_init(data: Vec4, world_size: Int) -> RingState {
    RingState {
        local_data: data,
        accumulated: data,
        step: 0,
        total_steps: world_size
    }
}

fn ring_step(state: RingState) -> RingState {
    // In a real ring, we'd receive from (rank - 1) and add.
    // Single process: receive from self = add own data again.
    // For correctness in single-process, we just keep the accumulated value.
    let new_step = state.step + 1;
    if new_step >= state.total_steps {
        RingState {
            local_data: state.local_data,
            accumulated: state.accumulated,
            step: new_step,
            total_steps: state.total_steps
        }
    } else {
        // Would accumulate from neighbor, but in single-process this is identity
        RingState {
            local_data: state.local_data,
            accumulated: state.accumulated,
            step: new_step,
            total_steps: state.total_steps
        }
    }
}

fn ring_reduce(data: Vec4, world_size: Int) -> Vec4 {
    let mut state = ring_init(data, world_size);
    let mut i = 0;
    while i < world_size {
        state = ring_step(state);
        i = i + 1;
    }
    state.accumulated
}

// ============================================================================
// Test 1: AllReduce with Sum — single process, result == input
// ============================================================================

fn test_all_reduce_sum() {
    let group = world_group();
    let data = vec4_new(10, 20, 30, 40);

    let result = all_reduce_sum(data, group);

    // Single process: AllReduce Sum returns input unchanged
    assert(vec4_eq(result, data));
    assert_eq(result.x, 10);
    assert_eq(result.y, 20);
    assert_eq(result.z, 30);
    assert_eq(result.w, 40);

    // Sum of result elements should equal sum of input elements
    let s_in = vec4_sum(data);
    let s_out = vec4_sum(result);
    assert_eq(s_in, s_out);
    assert_eq(s_in, 100);

    // Test with negative values
    let neg_data = vec4_new(-15, 25, -35, 45);
    let neg_result = all_reduce_sum(neg_data, group);
    assert_eq(neg_result.x, -15);
    assert_eq(neg_result.y, 25);
    assert_eq(neg_result.z, -35);
    assert_eq(neg_result.w, 45);

    // Sum is preserved for negative data
    let neg_sum = vec4_sum(neg_result);
    assert_eq(neg_sum, 20);

    // Test with zeros
    let zero_data = vec4_new(0, 0, 0, 0);
    let zero_result = all_reduce_sum(zero_data, group);
    assert_eq(zero_result.x, 0);
    assert_eq(zero_result.w, 0);
    assert_eq(vec4_sum(zero_result), 0);

    print("  test_all_reduce_sum: ok");
}

// ============================================================================
// Test 2: AllReduce with Max — single process, result == input
// ============================================================================

fn test_all_reduce_max() {
    let group = world_group();
    let data = vec4_new(100, 200, 300, 400);

    let result = all_reduce_max(data, group);

    // Single process: AllReduce Max returns input unchanged
    assert(vec4_eq(result, data));
    assert_eq(result.x, 100);
    assert_eq(result.y, 200);
    assert_eq(result.z, 300);
    assert_eq(result.w, 400);

    // Verify max invariant: result >= input (trivially true for single process)
    let check_x = result.x >= data.x;
    let check_y = result.y >= data.y;
    let check_z = result.z >= data.z;
    let check_w = result.w >= data.w;
    assert(check_x);
    assert(check_y);
    assert(check_z);
    assert(check_w);

    // Test with mixed positive/negative
    let mixed = vec4_new(-50, 1000, 0, -1);
    let mixed_result = all_reduce_max(mixed, group);
    assert_eq(mixed_result.x, -50);
    assert_eq(mixed_result.y, 1000);
    assert_eq(mixed_result.z, 0);
    assert_eq(mixed_result.w, -1);

    // Verify vec4_max helper (element-wise max of two vectors)
    let a = vec4_new(1, 5, 3, 7);
    let b = vec4_new(4, 2, 6, 0);
    let m = vec4_max(a, b);
    assert_eq(m.x, 4);
    assert_eq(m.y, 5);
    assert_eq(m.z, 6);
    assert_eq(m.w, 7);

    print("  test_all_reduce_max: ok");
}

// ============================================================================
// Test 3: Broadcast from rank 0 — data unchanged in single process
// ============================================================================

fn test_broadcast() {
    let group = world_group();
    let data = vec4_new(42, 43, 44, 45);

    // Broadcast from rank 0 (the only rank)
    let result = broadcast_data(data, 0, group);

    assert(vec4_eq(result, data));
    assert_eq(result.x, 42);
    assert_eq(result.y, 43);
    assert_eq(result.z, 44);
    assert_eq(result.w, 45);

    // Broadcasting preserves exact values (large numbers)
    let large = vec4_new(314159, 271828, 141421, 173205);
    let large_result = broadcast_data(large, 0, group);
    assert_eq(large_result.x, 314159);
    assert_eq(large_result.y, 271828);
    assert_eq(large_result.z, 141421);
    assert_eq(large_result.w, 173205);

    // Verify rank is correct
    assert_eq(group.rank, 0);

    // Broadcasting different data sets
    let small = vec4_new(1, 2, 3, 4);
    let small_result = broadcast_data(small, 0, group);
    assert(vec4_eq(small_result, small));

    print("  test_broadcast: ok");
}

// ============================================================================
// Test 4: AllGather — single process gathers just its own data
// ============================================================================

fn test_all_gather() {
    let group = world_group();
    let local = vec4_new(7, 8, 9, 10);

    let gathered = all_gather(local, group);

    // Count should equal world_size (1)
    assert_eq(gathered.count, 1);

    // Gathered data should equal local data
    assert(vec4_eq(gathered.data, local));
    assert_eq(gathered.data.x, 7);
    assert_eq(gathered.data.y, 8);
    assert_eq(gathered.data.z, 9);
    assert_eq(gathered.data.w, 10);

    // Verify invariant: count == world_size
    assert_eq(gathered.count, group.world_size);

    // Test with large values
    let big = vec4_new(1000000, 2000000, 3000000, 4000000);
    let big_gathered = all_gather(big, group);
    assert_eq(big_gathered.count, 1);
    assert_eq(big_gathered.data.x, 1000000);
    assert_eq(big_gathered.data.y, 2000000);

    // Sum of gathered data equals sum of local data
    let local_sum = vec4_sum(local);
    let gathered_sum = vec4_sum(gathered.data);
    assert_eq(local_sum, gathered_sum);
    assert_eq(local_sum, 34);

    print("  test_all_gather: ok");
}

// ============================================================================
// Test 5: ReduceScatter — returns a partition of the reduced result
// ============================================================================

fn test_reduce_scatter() {
    let group = world_group();
    let data = vec4_new(5, 10, 15, 20);

    let result = reduce_scatter(data, group);

    // Single process: reduce is identity, scatter returns full (only one partition)
    assert(vec4_eq(result, data));
    assert_eq(result.x, 5);
    assert_eq(result.y, 10);
    assert_eq(result.z, 15);
    assert_eq(result.w, 20);

    // Verify sum preservation: sum(result) == sum(data) in single-process case
    let data_sum = vec4_sum(data);
    let result_sum = vec4_sum(result);
    assert_eq(data_sum, result_sum);
    assert_eq(data_sum, 50);

    // Test with unit vector
    let unit = vec4_new(1, 0, 0, 0);
    let unit_result = reduce_scatter(unit, group);
    assert_eq(unit_result.x, 1);
    assert_eq(unit_result.y, 0);
    assert_eq(unit_result.z, 0);
    assert_eq(unit_result.w, 0);

    // ReduceScatter with negative values
    let neg = vec4_new(-10, 20, -30, 40);
    let neg_result = reduce_scatter(neg, group);
    assert(vec4_eq(neg_result, neg));
    assert_eq(vec4_sum(neg_result), 20);

    print("  test_reduce_scatter: ok");
}

// ============================================================================
// Test 6: Barrier — no-op in single process, verify it completes
// ============================================================================

fn test_barrier() {
    let group = world_group();

    // Barrier should return success (1)
    let status = barrier_sync(group);
    assert_eq(status, 1);

    // Multiple barriers should all succeed
    let status2 = barrier_sync(group);
    let status3 = barrier_sync(group);
    assert_eq(status2, 1);
    assert_eq(status3, 1);

    // Barrier doesn't modify group state
    assert_eq(group.rank, 0);
    assert_eq(group.world_size, 1);
    assert_eq(group.group_id, 0);

    // Barrier on a custom group also works
    let custom = make_group(0, 1, 42);
    let custom_status = barrier_sync(custom);
    assert_eq(custom_status, 1);
    assert_eq(custom.group_id, 42);

    // Multiple barriers on different groups
    let g2 = make_group(0, 1, 99);
    let s4 = barrier_sync(g2);
    let s5 = barrier_sync(group);
    assert_eq(s4, 1);
    assert_eq(s5, 1);

    print("  test_barrier: ok");
}

// ============================================================================
// Test 7: Ring-reduce simulation — single-process ring accumulates correctly
// ============================================================================

fn test_ring_reduce() {
    let data = vec4_new(2, 4, 6, 8);

    // Ring reduce with world_size=1: one step, result == input
    let result1 = ring_reduce(data, 1);
    assert(vec4_eq(result1, data));
    assert_eq(result1.x, 2);
    assert_eq(result1.y, 4);
    assert_eq(result1.z, 6);
    assert_eq(result1.w, 8);

    // Verify ring state transitions
    let state0 = ring_init(data, 1);
    assert_eq(state0.step, 0);
    assert_eq(state0.total_steps, 1);
    assert(vec4_eq(state0.accumulated, data));
    assert(vec4_eq(state0.local_data, data));

    let state1 = ring_step(state0);
    assert_eq(state1.step, 1);
    assert(vec4_eq(state1.accumulated, data));

    // Ring reduce with world_size=3 (simulated single-process)
    // All steps are identity in single-process mode
    let result3 = ring_reduce(data, 3);
    assert(vec4_eq(result3, data));

    // Ring reduce with world_size=5
    let result5 = ring_reduce(data, 5);
    assert(vec4_eq(result5, data));
    assert_eq(vec4_sum(result5), 20);

    // Ring state progression: verify step increments
    let state_a = ring_init(data, 4);
    let state_b = ring_step(state_a);
    let state_c = ring_step(state_b);
    assert_eq(state_b.step, 1);
    assert_eq(state_c.step, 2);
    assert_eq(state_c.total_steps, 4);

    print("  test_ring_reduce: ok");
}

// ============================================================================
// Test 8: ProcessGroup — WorldGroup has rank=0, world_size=1
// ============================================================================

fn test_process_group() {
    // Default world group
    let wg = world_group();
    assert_eq(wg.rank, 0);
    assert_eq(wg.world_size, 1);
    assert_eq(wg.group_id, 0);

    // Custom group creation
    let g1 = make_group(2, 8, 1);
    assert_eq(g1.rank, 2);
    assert_eq(g1.world_size, 8);
    assert_eq(g1.group_id, 1);

    // Another group
    let g2 = make_group(0, 4, 99);
    assert_eq(g2.rank, 0);
    assert_eq(g2.world_size, 4);
    assert_eq(g2.group_id, 99);

    // Groups are independent values
    assert_eq(wg.rank, 0);
    assert_eq(g1.rank, 2);
    assert_eq(g2.rank, 0);

    // Verify world_size invariant: rank < world_size for valid groups
    let valid_wg = wg.rank < wg.world_size;
    let valid_g1 = g1.rank < g1.world_size;
    let valid_g2 = g2.rank < g2.world_size;
    assert(valid_wg);
    assert(valid_g1);
    assert(valid_g2);

    // Single-process group always has rank 0
    let single = make_group(0, 1, 5);
    assert_eq(single.rank, 0);
    assert_eq(single.world_size, 1);

    // Group with larger world_size
    let large_group = make_group(7, 16, 3);
    assert_eq(large_group.rank, 7);
    assert_eq(large_group.world_size, 16);
    assert_eq(large_group.group_id, 3);
    let valid_large = large_group.rank < large_group.world_size;
    assert(valid_large);

    print("  test_process_group: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_all_reduce_sum();
    test_all_reduce_max();
    test_broadcast();
    test_all_gather();
    test_reduce_scatter();
    test_barrier();
    test_ring_reduce();
    test_process_group();
    print("[OK] 069_ml_distributed_stub");
    0
}
