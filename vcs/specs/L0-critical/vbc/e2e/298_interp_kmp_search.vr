// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, kmp, string-matching, failure-function
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: KMP (Knuth-Morris-Pratt) string matching algorithm with
// failure function computation. Strings encoded as integer arrays.

// =============================================================================
// Array infrastructure
// =============================================================================

type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 }
    }
}

fn arr8_zeros() -> Arr8 {
    Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 }
}

type Arr16 is {
    e0: Int, e1: Int, e2: Int, e3: Int,
    e4: Int, e5: Int, e6: Int, e7: Int,
    e8: Int, e9: Int, e10: Int, e11: Int,
    e12: Int, e13: Int, e14: Int, e15: Int
};

fn arr16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else if i == 7 { a.e7 }
    else if i == 8 { a.e8 }
    else if i == 9 { a.e9 }
    else if i == 10 { a.e10 }
    else if i == 11 { a.e11 }
    else if i == 12 { a.e12 }
    else if i == 13 { a.e13 }
    else if i == 14 { a.e14 }
    else { a.e15 }
}

fn arr16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 },
        e8: if i == 8 { v } else { a.e8 },
        e9: if i == 9 { v } else { a.e9 },
        e10: if i == 10 { v } else { a.e10 },
        e11: if i == 11 { v } else { a.e11 },
        e12: if i == 12 { v } else { a.e12 },
        e13: if i == 13 { v } else { a.e13 },
        e14: if i == 14 { v } else { a.e14 },
        e15: if i == 15 { v } else { a.e15 }
    }
}

fn arr16_zeros() -> Arr16 {
    Arr16 {
        e0: 0, e1: 0, e2: 0, e3: 0,
        e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0,
        e12: 0, e13: 0, e14: 0, e15: 0
    }
}

// =============================================================================
// KMP Failure function (also called "prefix function")
// fail[i] = length of longest proper prefix of pattern[0..i] that is also a suffix
// =============================================================================

fn kmp_build_failure(pattern: Arr8, plen: Int) -> Arr8 {
    let mut fail = arr8_zeros();
    // fail[0] = 0 always
    let mut i = 1;
    let mut k = 0;
    while i < plen {
        while k > 0 && arr8_get(pattern, k) != arr8_get(pattern, i) {
            k = arr8_get(fail, k - 1);
        }
        if arr8_get(pattern, k) == arr8_get(pattern, i) {
            k = k + 1;
        }
        fail = arr8_set(fail, i, k);
        i = i + 1;
    }
    fail
}

// =============================================================================
// KMP search: find first occurrence of pattern in text
// Returns index of first match, or -1 if not found
// =============================================================================

fn kmp_search_first(text: Arr16, tlen: Int, pattern: Arr8, plen: Int) -> Int {
    if plen == 0 { return 0; }
    let fail = kmp_build_failure(pattern, plen);
    let mut i = 0;
    let mut j = 0;
    while i < tlen {
        while j > 0 && arr8_get(pattern, j) != arr16_get(text, i) {
            j = arr8_get(fail, j - 1);
        }
        if arr8_get(pattern, j) == arr16_get(text, i) {
            j = j + 1;
        }
        if j == plen {
            return i - plen + 1;
        }
        i = i + 1;
    }
    -1
}

// =============================================================================
// KMP search: count all occurrences
// =============================================================================

fn kmp_count_all(text: Arr16, tlen: Int, pattern: Arr8, plen: Int) -> Int {
    if plen == 0 { return 0; }
    let fail = kmp_build_failure(pattern, plen);
    let mut count = 0;
    let mut i = 0;
    let mut j = 0;
    while i < tlen {
        while j > 0 && arr8_get(pattern, j) != arr16_get(text, i) {
            j = arr8_get(fail, j - 1);
        }
        if arr8_get(pattern, j) == arr16_get(text, i) {
            j = j + 1;
        }
        if j == plen {
            count = count + 1;
            j = arr8_get(fail, j - 1);
        }
        i = i + 1;
    }
    count
}

// =============================================================================
// Tests
// =============================================================================

fn test_failure_function_simple() {
    // Pattern "aab" = [0, 0, 1]
    let pat = Arr8 { e0: 0, e1: 0, e2: 1, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let fail = kmp_build_failure(pat, 3);
    assert_eq(arr8_get(fail, 0), 0);  // "a" -> no proper prefix = suffix
    assert_eq(arr8_get(fail, 1), 1);  // "aa" -> "a" is both prefix and suffix
    assert_eq(arr8_get(fail, 2), 0);  // "aab" -> no proper prefix = suffix
}

fn test_failure_function_abab() {
    // Pattern "abab" = [0, 1, 0, 1]
    let pat = Arr8 { e0: 0, e1: 1, e2: 0, e3: 1, e4: 0, e5: 0, e6: 0, e7: 0 };
    let fail = kmp_build_failure(pat, 4);
    assert_eq(arr8_get(fail, 0), 0);  // "a"
    assert_eq(arr8_get(fail, 1), 0);  // "ab"
    assert_eq(arr8_get(fail, 2), 1);  // "aba" -> "a" prefix = "a" suffix
    assert_eq(arr8_get(fail, 3), 2);  // "abab" -> "ab" prefix = "ab" suffix
}

fn test_failure_function_aabaaab() {
    // Pattern "aabaaab" = [0, 0, 1, 0, 0, 0, 1]
    let pat = Arr8 { e0: 0, e1: 0, e2: 1, e3: 0, e4: 0, e5: 0, e6: 1, e7: 0 };
    let fail = kmp_build_failure(pat, 7);
    assert_eq(arr8_get(fail, 0), 0);  // "a"
    assert_eq(arr8_get(fail, 1), 1);  // "aa" -> "a"
    assert_eq(arr8_get(fail, 2), 0);  // "aab"
    assert_eq(arr8_get(fail, 3), 1);  // "aaba" -> "a"
    assert_eq(arr8_get(fail, 4), 2);  // "aabaa" -> "aa"
    assert_eq(arr8_get(fail, 5), 2);  // "aabaaa" -> "aa"
    assert_eq(arr8_get(fail, 6), 3);  // "aabaaab" -> "aab"
}

fn test_search_found() {
    // Text: "abcabcabc" = [0,1,2,0,1,2,0,1,2,...] (use 9 chars)
    let text = Arr16 {
        e0: 0, e1: 1, e2: 2, e3: 0, e4: 1, e5: 2, e6: 0, e7: 1,
        e8: 2, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    // Pattern "cab" = [2, 0, 1]
    let pat = Arr8 { e0: 2, e1: 0, e2: 1, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let pos = kmp_search_first(text, 9, pat, 3);
    assert_eq(pos, 2);  // "cab" first appears at index 2
}

fn test_search_not_found() {
    let text = Arr16 {
        e0: 0, e1: 1, e2: 2, e3: 0, e4: 1, e5: 2, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    // Pattern "xyz" = [3, 4, 5] (not in text)
    let pat = Arr8 { e0: 3, e1: 4, e2: 5, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let pos = kmp_search_first(text, 7, pat, 3);
    assert_eq(pos, -1);
}

fn test_search_at_beginning() {
    let text = Arr16 {
        e0: 5, e1: 6, e2: 7, e3: 8, e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    let pat = Arr8 { e0: 5, e1: 6, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let pos = kmp_search_first(text, 4, pat, 2);
    assert_eq(pos, 0);
}

fn test_search_at_end() {
    let text = Arr16 {
        e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    let pat = Arr8 { e0: 4, e1: 5, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let pos = kmp_search_first(text, 5, pat, 2);
    assert_eq(pos, 3);
}

fn test_count_overlapping() {
    // Text: "aaa" = [0, 0, 0]
    // Pattern: "aa" = [0, 0]
    // Overlapping matches at positions 0 and 1
    let text = Arr16 {
        e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    let pat = Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let count = kmp_count_all(text, 3, pat, 2);
    assert_eq(count, 2);
}

fn test_count_multiple() {
    // Text: "abcabcabc" pattern "abc" -> 3 matches
    let text = Arr16 {
        e0: 0, e1: 1, e2: 2, e3: 0, e4: 1, e5: 2, e6: 0, e7: 1,
        e8: 2, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    let pat = Arr8 { e0: 0, e1: 1, e2: 2, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let count = kmp_count_all(text, 9, pat, 3);
    assert_eq(count, 3);
}

fn test_count_no_match() {
    let text = Arr16 {
        e0: 1, e1: 1, e2: 1, e3: 1, e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    let pat = Arr8 { e0: 2, e1: 2, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let count = kmp_count_all(text, 4, pat, 2);
    assert_eq(count, 0);
}

fn test_single_char_pattern() {
    // Text: "abacaba" = [0,1,0,2,0,1,0]
    // Pattern: "a" = [0]
    let text = Arr16 {
        e0: 0, e1: 1, e2: 0, e3: 2, e4: 0, e5: 1, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    let pat = Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let count = kmp_count_all(text, 7, pat, 1);
    assert_eq(count, 4);
    let first = kmp_search_first(text, 7, pat, 1);
    assert_eq(first, 0);
}

fn test_pattern_equals_text() {
    let text = Arr16 {
        e0: 1, e1: 2, e2: 3, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0,
        e8: 0, e9: 0, e10: 0, e11: 0, e12: 0, e13: 0, e14: 0, e15: 0
    };
    let pat = Arr8 { e0: 1, e1: 2, e2: 3, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let pos = kmp_search_first(text, 3, pat, 3);
    assert_eq(pos, 0);
    let count = kmp_count_all(text, 3, pat, 3);
    assert_eq(count, 1);
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_failure_function_simple();
    test_failure_function_abab();
    test_failure_function_aabaaab();
    test_search_found();
    test_search_not_found();
    test_search_at_beginning();
    test_search_at_end();
    test_count_overlapping();
    test_count_multiple();
    test_count_no_match();
    test_single_char_pattern();
    test_pattern_equals_text();
    print("[OK] 298_interp_kmp_search");
    0
}
