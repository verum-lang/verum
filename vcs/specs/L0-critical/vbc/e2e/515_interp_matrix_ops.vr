// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, matrix, addition, transpose, trace, multiply, linear_algebra
// @timeout: 15000
// @expected-exit: 0
//
// Matrix operations: addition, transpose, trace, and multiply for 3x3 matrices.
// Matrix stored as a 9-field record (row-major).

type Mat3 is {
    a00: Int, a01: Int, a02: Int,
    a10: Int, a11: Int, a12: Int,
    a20: Int, a21: Int, a22: Int
};

fn mat3_get(m: Mat3, r: Int, c: Int) -> Int {
    let idx = r * 3 + c;
    if idx == 0 { m.a00 } else if idx == 1 { m.a01 } else if idx == 2 { m.a02 }
    else if idx == 3 { m.a10 } else if idx == 4 { m.a11 } else if idx == 5 { m.a12 }
    else if idx == 6 { m.a20 } else if idx == 7 { m.a21 } else { m.a22 }
}

fn mat3_set(m: Mat3, r: Int, c: Int, v: Int) -> Mat3 {
    let idx = r * 3 + c;
    Mat3 {
        a00: if idx == 0 { v } else { m.a00 },
        a01: if idx == 1 { v } else { m.a01 },
        a02: if idx == 2 { v } else { m.a02 },
        a10: if idx == 3 { v } else { m.a10 },
        a11: if idx == 4 { v } else { m.a11 },
        a12: if idx == 5 { v } else { m.a12 },
        a20: if idx == 6 { v } else { m.a20 },
        a21: if idx == 7 { v } else { m.a21 },
        a22: if idx == 8 { v } else { m.a22 }
    }
}

fn mat3_add(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        a00: a.a00 + b.a00, a01: a.a01 + b.a01, a02: a.a02 + b.a02,
        a10: a.a10 + b.a10, a11: a.a11 + b.a11, a12: a.a12 + b.a12,
        a20: a.a20 + b.a20, a21: a.a21 + b.a21, a22: a.a22 + b.a22
    }
}

fn mat3_transpose(m: Mat3) -> Mat3 {
    Mat3 {
        a00: m.a00, a01: m.a10, a02: m.a20,
        a10: m.a01, a11: m.a11, a12: m.a21,
        a20: m.a02, a21: m.a12, a22: m.a22
    }
}

fn mat3_trace(m: Mat3) -> Int {
    m.a00 + m.a11 + m.a22
}

fn mat3_mul(a: Mat3, b: Mat3) -> Mat3 {
    let mut result = Mat3 {
        a00: 0, a01: 0, a02: 0,
        a10: 0, a11: 0, a12: 0,
        a20: 0, a21: 0, a22: 0
    };
    let mut i = 0;
    while i < 3 {
        let mut j = 0;
        while j < 3 {
            let mut s = 0;
            let mut k = 0;
            while k < 3 {
                s = s + mat3_get(a, i, k) * mat3_get(b, k, j);
                k = k + 1;
            }
            result = mat3_set(result, i, j, s);
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

fn mat3_identity() -> Mat3 {
    Mat3 {
        a00: 1, a01: 0, a02: 0,
        a10: 0, a11: 1, a12: 0,
        a20: 0, a21: 0, a22: 1
    }
}

fn test_addition() {
    let a = Mat3 {
        a00: 1, a01: 2, a02: 3,
        a10: 4, a11: 5, a12: 6,
        a20: 7, a21: 8, a22: 9
    };
    let b = Mat3 {
        a00: 9, a01: 8, a02: 7,
        a10: 6, a11: 5, a12: 4,
        a20: 3, a21: 2, a22: 1
    };
    let c = mat3_add(a, b);
    // Each row should sum to 10
    assert_eq(c.a00, 10);
    assert_eq(c.a01, 10);
    assert_eq(c.a11, 10);
    assert_eq(c.a22, 10);
    // Trace of sum = trace(A) + trace(B)
    assert_eq(mat3_trace(c), mat3_trace(a) + mat3_trace(b));
    print("addition: ok");
}

fn test_transpose() {
    let m = Mat3 {
        a00: 1, a01: 2, a02: 3,
        a10: 4, a11: 5, a12: 6,
        a20: 7, a21: 8, a22: 9
    };
    let t = mat3_transpose(m);
    // Diagonal unchanged, off-diagonals flipped
    assert_eq(t.a00, 1); assert_eq(t.a11, 5); assert_eq(t.a22, 9);
    assert_eq(t.a01, 4); assert_eq(t.a10, 2); // swapped
    assert_eq(t.a02, 7); assert_eq(t.a20, 3); // swapped
    assert_eq(t.a12, 8); assert_eq(t.a21, 6); // swapped
    // Transpose of transpose = original
    let tt = mat3_transpose(t);
    assert_eq(tt.a01, m.a01);
    assert_eq(tt.a12, m.a12);
    print("transpose: ok");
}

fn test_trace() {
    let m = Mat3 {
        a00: 5, a01: 1, a02: 2,
        a10: 3, a11: 7, a12: 4,
        a20: 6, a21: 8, a22: 9
    };
    // trace = 5 + 7 + 9 = 21
    assert_eq(mat3_trace(m), 21);
    // Identity trace = 3
    assert_eq(mat3_trace(mat3_identity()), 3);
    // Trace is invariant under transpose
    assert_eq(mat3_trace(m), mat3_trace(mat3_transpose(m)));
    print("trace: ok");
}

fn test_multiply() {
    let a = Mat3 {
        a00: 1, a01: 2, a02: 0,
        a10: 3, a11: 4, a12: 0,
        a20: 0, a21: 0, a22: 1
    };
    let b = Mat3 {
        a00: 5, a01: 6, a02: 0,
        a10: 7, a11: 8, a12: 0,
        a20: 0, a21: 0, a22: 1
    };
    let c = mat3_mul(a, b);
    // c[0][0] = 1*5 + 2*7 + 0*0 = 19
    assert_eq(c.a00, 19);
    // c[0][1] = 1*6 + 2*8 + 0*0 = 22
    assert_eq(c.a01, 22);
    // c[1][0] = 3*5 + 4*7 + 0*0 = 43
    assert_eq(c.a10, 43);
    // c[1][1] = 3*6 + 4*8 + 0*0 = 50
    assert_eq(c.a11, 50);
    // c[2][2] = 1 (unchanged)
    assert_eq(c.a22, 1);
    print("multiply: ok");
}

fn test_identity_multiply() {
    let m = Mat3 {
        a00: 3, a01: 1, a02: 4,
        a10: 1, a11: 5, a12: 9,
        a20: 2, a21: 6, a22: 5
    };
    let id = mat3_identity();
    let mi = mat3_mul(m, id);
    let im = mat3_mul(id, m);
    // M * I = I * M = M
    assert_eq(mi.a00, m.a00); assert_eq(mi.a01, m.a01); assert_eq(mi.a22, m.a22);
    assert_eq(im.a10, m.a10); assert_eq(im.a21, m.a21);
    print("identity_multiply: ok");
}

fn main() -> Int {
    test_addition();
    test_transpose();
    test_trace();
    test_multiply();
    test_identity_multiply();
    print("[OK] 515_interp_matrix_ops");
    0
}
