// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, hamming, parity, error_correction
// @timeout: 15000
// @expected-exit: 0
//
// Tests Hamming code, parity checks, bit error detection and correction.

fn popcount(n: Int) -> Int {
    // Count number of 1-bits in n
    let mut x = n;
    let mut cnt = 0;
    while x > 0 {
        cnt = cnt + (x % 2);
        x = x / 2;
    }
    cnt
}

fn bit_at(n: Int, pos: Int) -> Int {
    // Extract bit at position pos (0 = LSB)
    (n / (if pos == 0 { 1 }
           else if pos == 1 { 2 }
           else if pos == 2 { 4 }
           else if pos == 3 { 8 }
           else if pos == 4 { 16 }
           else if pos == 5 { 32 }
           else if pos == 6 { 64 }
           else { 128 })) % 2
}

fn test_parity_bit() {
    // Even parity: parity bit set so total 1-bits is even
    // Data: 1011 (4 bits) -> 3 ones -> odd -> parity bit = 1
    // Transmitted: 10111 (5 bits) -> 4 ones -> even
    let data = [1, 0, 1, 1]; // 4 data bits
    let n = 4;
    let mut ones = 0;
    let mut i = 0;
    while i < n { ones = ones + data[i]; i = i + 1; }
    let parity = ones % 2; // 1 for odd parity -> set parity bit
    assert_eq(parity, 1); // 3 ones is odd -> parity=1 for even parity

    // Transmitted word (data + parity): 10111
    let transmitted = [1, 0, 1, 1, 1];
    let mut total_ones = 0;
    i = 0;
    while i < 5 { total_ones = total_ones + transmitted[i]; i = i + 1; }
    assert_eq(total_ones % 2, 0); // even parity -> no error detected

    // Introduce error at position 2: flip bit 1->0
    let corrupted = [1, 0, 0, 1, 1];
    total_ones = 0;
    i = 0;
    while i < 5 { total_ones = total_ones + corrupted[i]; i = i + 1; }
    assert_eq(total_ones % 2, 1); // odd -> error detected!

    print("parity_bit: ok");
}

fn test_hamming_distance() {
    // Hamming distance = number of positions where bits differ
    // hamming("1011", "1101") = positions 1,2,3 differ? Let's check:
    // 1011 vs 1101: pos0: 1==1, pos1: 0!=1, pos2: 1!=0, pos3: 1==1 -> dist=2
    let a = [1, 0, 1, 1];
    let b = [1, 1, 0, 1];
    let mut dist = 0;
    let mut i = 0;
    while i < 4 {
        if a[i] != b[i] { dist = dist + 1; }
        i = i + 1;
    }
    assert_eq(dist, 2);

    // hamming("0000", "1111") = 4
    let z = [0, 0, 0, 0];
    let o = [1, 1, 1, 1];
    dist = 0; i = 0;
    while i < 4 {
        if z[i] != o[i] { dist = dist + 1; }
        i = i + 1;
    }
    assert_eq(dist, 4);

    // hamming("1010", "1010") = 0 (identical)
    let c = [1, 0, 1, 0];
    let d = [1, 0, 1, 0];
    dist = 0; i = 0;
    while i < 4 {
        if c[i] != d[i] { dist = dist + 1; }
        i = i + 1;
    }
    assert_eq(dist, 0);

    print("hamming_distance: ok");
}

fn test_hamming_74_encode() {
    // Hamming(7,4): encode 4 data bits into 7-bit codeword
    // Data bits: d1,d2,d3,d4 (1-indexed)
    // Parity bits: p1=bit1, p2=bit2, p4=bit4
    // Bit positions: 1=p1, 2=p2, 3=d1, 4=p4, 5=d2, 6=d3, 7=d4
    //
    // Parity equations (even parity):
    // p1 covers bits 1,3,5,7: p1 = d1 XOR d2 XOR d4
    // p2 covers bits 2,3,6,7: p2 = d1 XOR d3 XOR d4
    // p4 covers bits 4,5,6,7: p4 = d2 XOR d3 XOR d4
    //
    // Encode data [1,0,1,1] (d1=1,d2=0,d3=1,d4=1):
    // p1 = 1 XOR 0 XOR 1 = 0
    // p2 = 1 XOR 1 XOR 1 = 1
    // p4 = 0 XOR 1 XOR 1 = 0
    // Codeword: bit1=p1=0, bit2=p2=1, bit3=d1=1, bit4=p4=0, bit5=d2=0, bit6=d3=1, bit7=d4=1
    // = [0, 1, 1, 0, 0, 1, 1] (indexed 1..7)

    let d1 = 1; let d2 = 0; let d3 = 1; let d4 = 1;
    let p1 = (d1 + d2 + d4) % 2; // XOR via mod 2
    let p2 = (d1 + d3 + d4) % 2;
    let p4 = (d2 + d3 + d4) % 2;

    assert_eq(p1, 0);
    assert_eq(p2, 1);
    assert_eq(p4, 0);

    let codeword = [p1, p2, d1, p4, d2, d3, d4]; // bits 1-7 (0-indexed)
    assert_eq(codeword[0], 0); // p1
    assert_eq(codeword[1], 1); // p2
    assert_eq(codeword[2], 1); // d1
    assert_eq(codeword[3], 0); // p4
    assert_eq(codeword[4], 0); // d2
    assert_eq(codeword[5], 1); // d3
    assert_eq(codeword[6], 1); // d4

    print("hamming_74_encode: ok");
}

fn test_hamming_74_decode() {
    // Detect and correct single-bit error in Hamming(7,4)
    // Use codeword from encode test: [0, 1, 1, 0, 0, 1, 1]
    // Introduce error at bit position 5 (0-indexed 4): flip d2 from 0 to 1
    // Corrupted: [0, 1, 1, 0, 1, 1, 1]

    let code = [0, 1, 1, 0, 1, 1, 1]; // corrupted codeword

    // Syndrome computation:
    // s1 = code[0] XOR code[2] XOR code[4] XOR code[6] (bits 1,3,5,7)
    // s2 = code[1] XOR code[2] XOR code[5] XOR code[6] (bits 2,3,6,7)
    // s4 = code[3] XOR code[4] XOR code[5] XOR code[6] (bits 4,5,6,7)

    let s1 = (code[0] + code[2] + code[4] + code[6]) % 2;
    let s2 = (code[1] + code[2] + code[5] + code[6]) % 2;
    let s4 = (code[3] + code[4] + code[5] + code[6]) % 2;

    // Syndrome = s1 + 2*s2 + 4*s4 -> error position (1-indexed)
    let syndrome = s1 + 2 * s2 + 4 * s4;

    // s1 = (0+1+1+1)%2 = 3%2 = 1
    // s2 = (1+1+1+1)%2 = 4%2 = 0
    // s4 = (0+1+1+1)%2 = 3%2 = 1
    // syndrome = 1 + 0 + 4 = 5
    assert_eq(s1, 1);
    assert_eq(s2, 0);
    assert_eq(s4, 1);
    assert_eq(syndrome, 5); // error at bit position 5 (1-indexed) = index 4 (0-indexed)

    // Correct the error: flip bit at position syndrome-1 (0-indexed)
    let mut corrected = [code[0], code[1], code[2], code[3], code[4], code[5], code[6]];
    corrected[syndrome - 1] = if corrected[syndrome - 1] == 0 { 1 } else { 0 };

    // Corrected should match original: [0, 1, 1, 0, 0, 1, 1]
    assert_eq(corrected[0], 0);
    assert_eq(corrected[1], 1);
    assert_eq(corrected[2], 1);
    assert_eq(corrected[3], 0);
    assert_eq(corrected[4], 0); // was 1 (error), now 0 (corrected)
    assert_eq(corrected[5], 1);
    assert_eq(corrected[6], 1);

    print("hamming_74_decode: ok");
}

fn test_burst_error_detection() {
    // CRC-like checksum using XOR for burst error detection
    // Simple longitudinal redundancy check (LRC)
    let data = [0b10110100, 0b01101001, 0b11001010, 0b00111110];
    // Compute XOR of all bytes
    let lrc = data[0] ^ data[1] ^ data[2] ^ data[3];
    // = 0b10110100 XOR 0b01101001 XOR 0b11001010 XOR 0b00111110
    // 0b10110100 = 180
    // 0b01101001 = 105
    // 0b11001010 = 202
    // 0b00111110 = 62
    // 180 XOR 105 = 221 (0b11011101)
    // 221 XOR 202 = 23  (0b00010111)
    // 23  XOR 62  = 41  (0b00101001)
    assert_eq(lrc, 41);

    // Transmitted: data + lrc
    // Verify: XOR of all 5 bytes should be 0
    let check = data[0] ^ data[1] ^ data[2] ^ data[3] ^ lrc;
    assert_eq(check, 0); // no error

    // Corrupt one byte: data[1] flipped at bit 3 (XOR with 8)
    let corrupted_1 = data[1] ^ 8; // 105 XOR 8 = 97
    let check2 = data[0] ^ corrupted_1 ^ data[2] ^ data[3] ^ lrc;
    assert(check2 != 0); // error detected

    print("burst_error_detection: ok");
}

fn main() -> Int {
    test_parity_bit();
    test_hamming_distance();
    test_hamming_74_encode();
    test_hamming_74_decode();
    test_burst_error_detection();
    print("[OK] 448_interp_error_correction");
    0
}
