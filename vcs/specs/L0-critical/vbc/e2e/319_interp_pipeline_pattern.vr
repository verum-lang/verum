// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, design-patterns, pipeline, transform
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Pipeline pattern - data flows through transform stages.
// Each stage applies a transformation to all elements. Supports chaining
// filter, map, and reduce operations on integer arrays.

// =============================================================================
// Array infrastructure
// =============================================================================

type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 } else if i == 1 { a.e1 }
    else if i == 2 { a.e2 } else if i == 3 { a.e3 }
    else if i == 4 { a.e4 } else if i == 5 { a.e5 }
    else if i == 6 { a.e6 } else { a.e7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 }
    }
}

fn a8_zeros() -> Arr8 {
    Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 }
}

// Buffered array with length
type BufArr is { data: Arr8, len: Int };

fn buf_new() -> BufArr {
    BufArr { data: a8_zeros(), len: 0 }
}

fn buf_push(b: BufArr, val: Int) -> BufArr {
    BufArr { data: a8_set(b.data, b.len, val), len: b.len + 1 }
}

fn buf_get(b: BufArr, i: Int) -> Int {
    a8_get(b.data, i)
}

fn buf_from(e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, n: Int) -> BufArr {
    let mut b = buf_new();
    if n > 0 { b = buf_push(b, e0); }
    if n > 1 { b = buf_push(b, e1); }
    if n > 2 { b = buf_push(b, e2); }
    if n > 3 { b = buf_push(b, e3); }
    if n > 4 { b = buf_push(b, e4); }
    b
}

// =============================================================================
// Pipeline stages: map transforms (identified by IDs)
// Map IDs: 1=double, 2=square, 3=add_10, 4=negate, 5=abs, 6=increment
// Filter IDs: 1=positive, 2=even, 3=greater_than_5, 4=less_than_100
// =============================================================================

fn apply_map(val: Int, map_id: Int) -> Int {
    if map_id == 1 { val * 2 }
    else if map_id == 2 { val * val }
    else if map_id == 3 { val + 10 }
    else if map_id == 4 { -val }
    else if map_id == 5 { if val < 0 { -val } else { val } }
    else if map_id == 6 { val + 1 }
    else { val }
}

fn apply_filter(val: Int, filter_id: Int) -> Int {
    if filter_id == 1 { if val > 0 { 1 } else { 0 } }
    else if filter_id == 2 { if val % 2 == 0 { 1 } else { 0 } }
    else if filter_id == 3 { if val > 5 { 1 } else { 0 } }
    else if filter_id == 4 { if val < 100 { 1 } else { 0 } }
    else { 1 }
}

// Pipeline: apply map stage to all elements
fn pipe_map(input: BufArr, map_id: Int) -> BufArr {
    let mut output = buf_new();
    let mut i = 0;
    while i < input.len {
        let val = buf_get(input, i);
        output = buf_push(output, apply_map(val, map_id));
        i = i + 1;
    }
    output
}

// Pipeline: filter stage
fn pipe_filter(input: BufArr, filter_id: Int) -> BufArr {
    let mut output = buf_new();
    let mut i = 0;
    while i < input.len {
        let val = buf_get(input, i);
        if apply_filter(val, filter_id) == 1 {
            output = buf_push(output, val);
        }
        i = i + 1;
    }
    output
}

// Pipeline: reduce to single value
fn pipe_sum(input: BufArr) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < input.len {
        total = total + buf_get(input, i);
        i = i + 1;
    }
    total
}

fn pipe_product(input: BufArr) -> Int {
    let mut prod = 1;
    let mut i = 0;
    while i < input.len {
        prod = prod * buf_get(input, i);
        i = i + 1;
    }
    prod
}

fn pipe_max(input: BufArr) -> Int {
    let mut mx = buf_get(input, 0);
    let mut i = 1;
    while i < input.len {
        let v = buf_get(input, i);
        if v > mx { mx = v; }
        i = i + 1;
    }
    mx
}

fn pipe_min(input: BufArr) -> Int {
    let mut mn = buf_get(input, 0);
    let mut i = 1;
    while i < input.len {
        let v = buf_get(input, i);
        if v < mn { mn = v; }
        i = i + 1;
    }
    mn
}

// =============================================================================
// Tests
// =============================================================================

fn test_map_double() {
    let input = buf_from(1, 2, 3, 4, 5, 5);
    let output = pipe_map(input, 1);
    assert_eq(buf_get(output, 0), 2);
    assert_eq(buf_get(output, 1), 4);
    assert_eq(buf_get(output, 2), 6);
    assert_eq(buf_get(output, 3), 8);
    assert_eq(buf_get(output, 4), 10);
}

fn test_map_square() {
    let input = buf_from(1, 2, 3, 4, 5, 5);
    let output = pipe_map(input, 2);
    assert_eq(buf_get(output, 0), 1);
    assert_eq(buf_get(output, 1), 4);
    assert_eq(buf_get(output, 2), 9);
    assert_eq(buf_get(output, 3), 16);
    assert_eq(buf_get(output, 4), 25);
}

fn test_filter_even() {
    let input = buf_from(1, 2, 3, 4, 5, 5);
    let output = pipe_filter(input, 2);
    assert_eq(output.len, 2);
    assert_eq(buf_get(output, 0), 2);
    assert_eq(buf_get(output, 1), 4);
}

fn test_filter_positive() {
    let mut input = buf_new();
    input = buf_push(input, -3);
    input = buf_push(input, -1);
    input = buf_push(input, 0);
    input = buf_push(input, 2);
    input = buf_push(input, 5);

    let output = pipe_filter(input, 1);
    assert_eq(output.len, 2);
    assert_eq(buf_get(output, 0), 2);
    assert_eq(buf_get(output, 1), 5);
}

fn test_chained_map_filter() {
    // [1,2,3,4,5] -> double -> [2,4,6,8,10] -> filter >5 -> [6,8,10]
    let input = buf_from(1, 2, 3, 4, 5, 5);
    let step1 = pipe_map(input, 1);    // double
    let step2 = pipe_filter(step1, 3); // >5
    assert_eq(step2.len, 3);
    assert_eq(buf_get(step2, 0), 6);
    assert_eq(buf_get(step2, 1), 8);
    assert_eq(buf_get(step2, 2), 10);
}

fn test_full_pipeline() {
    // [1,2,3,4,5] -> double -> filter even -> add_10 -> sum
    let input = buf_from(1, 2, 3, 4, 5, 5);
    let step1 = pipe_map(input, 1);     // [2,4,6,8,10]
    let step2 = pipe_filter(step1, 2);  // all even: [2,4,6,8,10]
    let step3 = pipe_map(step2, 3);     // [12,14,16,18,20]
    let total = pipe_sum(step3);
    assert_eq(total, 80);
}

fn test_reduce_product() {
    let input = buf_from(1, 2, 3, 4, 5, 4);
    let p = pipe_product(input);
    assert_eq(p, 24);  // 1*2*3*4
}

fn test_reduce_max_min() {
    let mut input = buf_new();
    input = buf_push(input, 7);
    input = buf_push(input, 2);
    input = buf_push(input, 9);
    input = buf_push(input, 1);
    input = buf_push(input, 5);

    assert_eq(pipe_max(input), 9);
    assert_eq(pipe_min(input), 1);
}

fn test_empty_after_filter() {
    // All elements filtered out
    let input = buf_from(1, 3, 5, 7, 0, 4);
    let output = pipe_filter(input, 2);  // filter even, only 0 is "even"... wait
    // Actually 0 % 2 == 0, so 0 passes. Let me use only odd values.
    let input2 = buf_from(1, 3, 5, 7, 0, 4);  // 0 is even
    let output2 = pipe_filter(input2, 3);  // >5: only 7
    assert_eq(output2.len, 1);
    assert_eq(buf_get(output2, 0), 7);
}

fn test_negate_then_abs() {
    let input = buf_from(3, 7, 1, 5, 0, 4);
    let step1 = pipe_map(input, 4);   // negate: [-3, -7, -1, -5]
    let step2 = pipe_map(step1, 5);   // abs: [3, 7, 1, 5]
    assert_eq(buf_get(step2, 0), 3);
    assert_eq(buf_get(step2, 1), 7);
    assert_eq(buf_get(step2, 2), 1);
    assert_eq(buf_get(step2, 3), 5);
}

fn test_increment_chain() {
    let input = buf_from(0, 0, 0, 0, 0, 5);
    let s1 = pipe_map(input, 6);  // +1: [1,1,1,1,1]
    let s2 = pipe_map(s1, 6);    // +1: [2,2,2,2,2]
    let s3 = pipe_map(s2, 6);    // +1: [3,3,3,3,3]
    assert_eq(pipe_sum(s3), 15);
}

fn test_complex_pipeline() {
    // [1,2,3,4,5] -> square -> [1,4,9,16,25] -> filter <100 -> sum
    let input = buf_from(1, 2, 3, 4, 5, 5);
    let step1 = pipe_map(input, 2);      // square
    let step2 = pipe_filter(step1, 4);   // <100 (all pass)
    let total = pipe_sum(step2);
    assert_eq(total, 55);  // 1+4+9+16+25
}

fn main() -> Int {
    test_map_double();
    test_map_square();
    test_filter_even();
    test_filter_positive();
    test_chained_map_filter();
    test_full_pipeline();
    test_reduce_product();
    test_reduce_max_min();
    test_empty_after_filter();
    test_negate_then_abs();
    test_increment_chain();
    test_complex_pipeline();
    print("[OK] 319_interp_pipeline_pattern");
    0
}
