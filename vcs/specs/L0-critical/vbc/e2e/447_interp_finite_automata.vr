// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, dfa, nfa, automata, state_machine
// @timeout: 15000
// @expected-exit: 0
//
// Tests DFA/NFA simulation: state transitions, acceptance checking,
// and multiple automata for pattern recognition.

// DFA for strings ending in "ab" over alphabet {a=0, b=1}
// States: 0=start, 1=saw_a, 2=saw_ab (accept)
// Transition table: delta[state][char]
// delta[0][a]=1, delta[0][b]=0
// delta[1][a]=1, delta[1][b]=2
// delta[2][a]=1, delta[2][b]=0

fn dfa_ends_ab(input: Int, n: Int) -> Int {
    // input encoded as single int: digits 0/1 in base 10 reading left-to-right
    // e.g., input=01001011 passed as separate digits via array approach
    // Instead, we use a simple encoding: pass n digits via global knowledge
    // Actually let's use a flat approach: encode as array index sum trick
    // For simplicity: input is the sum-encoded value, we ignore n here
    // We'll call this with a fixed array
    0 // placeholder, actual test uses arrays below
}

fn test_dfa_ends_ab() {
    // DFA: accepts strings ending in "ab"
    // Transition: delta[state * 2 + char] where a=0, b=1
    let delta = [
        1, 0, // state 0: a->1, b->0
        1, 2, // state 1: a->1, b->2
        1, 0  // state 2: a->1, b->0
    ];
    let accept_state = 2;

    // Test "ab" -> should accept
    let ab = [0, 1]; // a, b
    let mut state = 0;
    let mut i = 0;
    while i < 2 { state = delta[state * 2 + ab[i]]; i = i + 1; }
    assert_eq(state, accept_state); // accepted

    // Test "aab" -> should accept
    let aab = [0, 0, 1];
    state = 0; i = 0;
    while i < 3 { state = delta[state * 2 + aab[i]]; i = i + 1; }
    assert_eq(state, accept_state);

    // Test "ba" -> should reject (ends in a, not ab)
    let ba = [1, 0];
    state = 0; i = 0;
    while i < 2 { state = delta[state * 2 + ba[i]]; i = i + 1; }
    assert(state != accept_state);

    // Test "b" -> reject
    let b_only = [1];
    state = 0; state = delta[state * 2 + b_only[0]];
    assert(state != accept_state);

    // Test "aababab" -> accept (ends in ab)
    let long_str = [0, 0, 1, 0, 1, 0, 1];
    state = 0; i = 0;
    while i < 7 { state = delta[state * 2 + long_str[i]]; i = i + 1; }
    assert_eq(state, accept_state);

    // Test "aba" -> reject (ends in a)
    let aba = [0, 1, 0];
    state = 0; i = 0;
    while i < 3 { state = delta[state * 2 + aba[i]]; i = i + 1; }
    assert(state != accept_state);

    print("dfa_ends_ab: ok");
}

fn test_dfa_even_ones() {
    // DFA: accepts binary strings with even number of 1s
    // States: 0=even (start, accept), 1=odd
    // delta[state * 2 + char]
    let delta = [
        0, 1, // state 0: 0->0, 1->1
        1, 0  // state 1: 0->1, 1->0
    ];

    // "0000" -> even ones (0) -> accept
    let s1 = [0, 0, 0, 0];
    let mut state = 0;
    let mut i = 0;
    while i < 4 { state = delta[state * 2 + s1[i]]; i = i + 1; }
    assert_eq(state, 0); // even -> accept

    // "1010" -> 2 ones -> even -> accept
    let s2 = [1, 0, 1, 0];
    state = 0; i = 0;
    while i < 4 { state = delta[state * 2 + s2[i]]; i = i + 1; }
    assert_eq(state, 0);

    // "101" -> 2 ones -> even -> accept
    let s3 = [1, 0, 1];
    state = 0; i = 0;
    while i < 3 { state = delta[state * 2 + s3[i]]; i = i + 1; }
    assert_eq(state, 0);

    // "1" -> 1 one -> odd -> reject
    state = 0; state = delta[state * 2 + 1];
    assert_eq(state, 1); // odd -> reject

    // "11" -> 2 ones -> even -> accept
    state = 0; state = delta[state * 2 + 1]; state = delta[state * 2 + 1];
    assert_eq(state, 0);

    // "111" -> 3 ones -> odd -> reject
    state = 0;
    state = delta[state * 2 + 1];
    state = delta[state * 2 + 1];
    state = delta[state * 2 + 1];
    assert_eq(state, 1);

    print("dfa_even_ones: ok");
}

fn test_dfa_divisible_by_3() {
    // DFA recognizing binary numbers divisible by 3
    // States: remainder 0, 1, 2
    // Transition: reading bit b in state r -> new state = (2*r + b) % 3
    // State 0 is accepting

    // "0" = 0 -> divisible by 3
    let mut state = 0;
    state = (2 * state + 0) % 3;
    assert_eq(state, 0); // 0 % 3 = 0 -> accept

    // "11" = 3 -> divisible by 3
    state = 0;
    state = (2 * state + 1) % 3; // reading '1' -> state 1
    state = (2 * state + 1) % 3; // reading '1' -> (2+1)%3 = 0
    assert_eq(state, 0); // 3 % 3 = 0 -> accept

    // "110" = 6 -> divisible by 3
    state = 0;
    state = (2 * state + 1) % 3;
    state = (2 * state + 1) % 3;
    state = (2 * state + 0) % 3;
    assert_eq(state, 0);

    // "1" = 1 -> not divisible by 3
    state = 0;
    state = (2 * state + 1) % 3;
    assert_eq(state, 1); // reject

    // "10" = 2 -> not divisible
    state = 0;
    state = (2 * state + 1) % 3;
    state = (2 * state + 0) % 3;
    assert_eq(state, 2); // reject

    // "1001" = 9 -> divisible by 3
    state = 0;
    state = (2 * state + 1) % 3; // 1
    state = (2 * state + 0) % 3; // 2
    state = (2 * state + 0) % 3; // 1
    state = (2 * state + 1) % 3; // 0
    assert_eq(state, 0); // 9 % 3 = 0 -> accept

    print("dfa_divisible_by_3: ok");
}

fn test_nfa_simulation() {
    // NFA for strings containing "ab" as substring over {a=0, b=1}
    // NFA states: {0, 1, 2}
    // 0: start, haven't seen 'a' or still looking
    // 1: saw 'a', looking for 'b'
    // 2: accept (saw "ab")
    //
    // Simulate NFA as subset construction (track set of active states as bitmask)
    // State bitmask: bit 0 = state 0, bit 1 = state 1, bit 2 = state 2
    //
    // Transitions:
    // From state 0: on 'a' -> {0, 1}, on 'b' -> {0}
    // From state 1: on 'a' -> {1}, on 'b' -> {0, 2}
    // From state 2: on anything -> {2} (absorbing accept)
    //
    // Subset transitions (bitmask):
    // delta[state_set][char] encoded via computation

    // Test "ab" -> should accept (contains "ab")
    let mut active = 1; // {state 0}
    // Process 'a'=0:
    let mut new_active = 0;
    if active & 1 != 0 { new_active = new_active | 3; }  // state 0 on 'a' -> {0,1}
    if active & 2 != 0 { new_active = new_active | 2; }  // state 1 on 'a' -> {1}
    if active & 4 != 0 { new_active = new_active | 4; }  // state 2 on 'a' -> {2}
    active = new_active; // {0, 1} = bitmask 3
    assert_eq(active, 3);

    // Process 'b'=1:
    new_active = 0;
    if active & 1 != 0 { new_active = new_active | 1; }  // state 0 on 'b' -> {0}
    if active & 2 != 0 { new_active = new_active | 5; }  // state 1 on 'b' -> {0, 2}
    if active & 4 != 0 { new_active = new_active | 4; }  // state 2 on 'b' -> {2}
    active = new_active; // {0, 2} = bitmask 5
    assert_eq(active & 4, 4); // state 2 is active -> accept

    // Test "ba" -> should reject (no "ab")
    active = 1; // {state 0}
    // Process 'b':
    new_active = 0;
    if active & 1 != 0 { new_active = new_active | 1; }
    if active & 2 != 0 { new_active = new_active | 5; }
    if active & 4 != 0 { new_active = new_active | 4; }
    active = new_active; // {0} = 1
    // Process 'a':
    new_active = 0;
    if active & 1 != 0 { new_active = new_active | 3; }
    if active & 2 != 0 { new_active = new_active | 2; }
    if active & 4 != 0 { new_active = new_active | 4; }
    active = new_active; // {0,1} = 3
    assert_eq(active & 4, 0); // state 2 NOT active -> reject

    print("nfa_simulation: ok");
}

fn test_automata_counting() {
    // Count how many strings of length 4 over {0,1} are accepted by DFA (even 1s)
    // Enumerate all 16 strings (0000 to 1111)
    // delta: state 0: 0->0, 1->1; state 1: 0->1, 1->0
    let delta = [0, 1, 1, 0]; // indexed delta[state*2 + char]
    let mut accepted = 0;
    let mut total = 0;

    // Enumerate 4-bit strings using arithmetic
    let mut n = 0;
    while n < 16 {
        let b3 = (n / 8) % 2;
        let b2 = (n / 4) % 2;
        let b1 = (n / 2) % 2;
        let b0 = n % 2;

        let mut state = 0;
        state = delta[state * 2 + b3];
        state = delta[state * 2 + b2];
        state = delta[state * 2 + b1];
        state = delta[state * 2 + b0];

        if state == 0 { accepted = accepted + 1; }
        total = total + 1;
        n = n + 1;
    }

    // Exactly half of all binary strings have even parity -> 8 out of 16
    assert_eq(total, 16);
    assert_eq(accepted, 8);

    print("automata_counting: ok");
}

fn main() -> Int {
    test_dfa_ends_ab();
    test_dfa_even_ones();
    test_dfa_divisible_by_3();
    test_nfa_simulation();
    test_automata_counting();
    print("[OK] 447_interp_finite_automata");
    0
}
