// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, dp, lcs
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Longest Common Subsequence (LCS) of two integer
// sequences using DP. Test equal sequences, disjoint sequences, partial overlap.

// =============================================================================
// Arr8 for input sequences (up to 8 elements)
// =============================================================================

type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

// =============================================================================
// Flat 2D DP table: 9x9 = 81 entries (for sequences up to len 8)
// We need dp[0..m][0..n] where m,n <= 8, so (m+1)*(n+1) <= 81
// Use a record approach, but 81 fields is too many.
// Instead, use row-by-row computation keeping only 2 rows.
// =============================================================================

// Row of up to 9 values (indices 0..8 for length+1)
type Row9 is { r0: Int, r1: Int, r2: Int, r3: Int, r4: Int, r5: Int, r6: Int, r7: Int, r8: Int };

fn row9_new() -> Row9 {
    Row9 { r0: 0, r1: 0, r2: 0, r3: 0, r4: 0, r5: 0, r6: 0, r7: 0, r8: 0 }
}

fn row9_get(r: Row9, i: Int) -> Int {
    if i == 0 { r.r0 }
    else if i == 1 { r.r1 }
    else if i == 2 { r.r2 }
    else if i == 3 { r.r3 }
    else if i == 4 { r.r4 }
    else if i == 5 { r.r5 }
    else if i == 6 { r.r6 }
    else if i == 7 { r.r7 }
    else { r.r8 }
}

fn row9_set(r: Row9, i: Int, v: Int) -> Row9 {
    Row9 {
        r0: if i == 0 { v } else { r.r0 },
        r1: if i == 1 { v } else { r.r1 },
        r2: if i == 2 { v } else { r.r2 },
        r3: if i == 3 { v } else { r.r3 },
        r4: if i == 4 { v } else { r.r4 },
        r5: if i == 5 { v } else { r.r5 },
        r6: if i == 6 { v } else { r.r6 },
        r7: if i == 7 { v } else { r.r7 },
        r8: if i == 8 { v } else { r.r8 }
    }
}

// =============================================================================
// LCS using 2-row DP
// dp[i][j] = LCS length of a[0..i] and b[0..j]
// dp[0][j] = 0, dp[i][0] = 0
// dp[i][j] = dp[i-1][j-1] + 1          if a[i-1] == b[j-1]
//          = max(dp[i-1][j], dp[i][j-1]) otherwise
// =============================================================================

fn max_val(a: Int, b: Int) -> Int {
    if a > b { a } else { b }
}

fn lcs_length(a: Arr8, len_a: Int, b: Arr8, len_b: Int) -> Int {
    // prev_row = dp[i-1][*], curr_row = dp[i][*]
    let mut prev_row = row9_new();  // dp[0][j] = 0 for all j

    let mut i = 1;
    while i <= len_a {
        let mut curr_row = row9_new();  // dp[i][0] = 0
        let mut j = 1;
        while j <= len_b {
            if arr8_get(a, i - 1) == arr8_get(b, j - 1) {
                let v = row9_get(prev_row, j - 1) + 1;
                curr_row = row9_set(curr_row, j, v);
            } else {
                let v = max_val(row9_get(prev_row, j), row9_get(curr_row, j - 1));
                curr_row = row9_set(curr_row, j, v);
            }
            j = j + 1;
        }
        prev_row = curr_row;
        i = i + 1;
    }

    row9_get(prev_row, len_b)
}

// =============================================================================
// Test: equal sequences
// =============================================================================

fn test_lcs_equal() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 0, e6: 0, e7: 0 };
    let b = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 5, b, 5), 5);
}

// =============================================================================
// Test: completely disjoint sequences
// =============================================================================

fn test_lcs_disjoint() {
    let a = Arr8 { e0: 1, e1: 3, e2: 5, e3: 7, e4: 0, e5: 0, e6: 0, e7: 0 };
    let b = Arr8 { e0: 2, e1: 4, e2: 6, e3: 8, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 4, b, 4), 0);
}

// =============================================================================
// Test: partial overlap
// a = [1, 3, 4, 5, 6, 7, 8], b = [1, 2, 4, 5, 7]
// LCS = [1, 4, 5, 7] => length 4
// =============================================================================

fn test_lcs_partial() {
    let a = Arr8 { e0: 1, e1: 3, e2: 4, e3: 5, e4: 6, e5: 7, e6: 8, e7: 0 };
    let b = Arr8 { e0: 1, e1: 2, e2: 4, e3: 5, e4: 7, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 7, b, 5), 4);
}

// =============================================================================
// Test: classic example
// a = [A,B,C,B,D,A,B] encoded as [1,2,3,2,4,1,2]
// b = [B,D,C,A,B,A] encoded as [2,4,3,1,2,1]
// LCS = BCBA or BDAB => length 4
// =============================================================================

fn test_lcs_classic() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 2, e4: 4, e5: 1, e6: 2, e7: 0 };
    let b = Arr8 { e0: 2, e1: 4, e2: 3, e3: 1, e4: 2, e5: 1, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 7, b, 6), 4);
}

// =============================================================================
// Test: one empty sequence
// =============================================================================

fn test_lcs_empty() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let b = Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 3, b, 0), 0);
    assert_eq(lcs_length(b, 0, a, 3), 0);
}

// =============================================================================
// Test: single element sequences
// =============================================================================

fn test_lcs_single() {
    let a = Arr8 { e0: 5, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let b = Arr8 { e0: 5, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 1, b, 1), 1);

    let c = Arr8 { e0: 3, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 1, c, 1), 0);
}

// =============================================================================
// Test: one is subsequence of the other
// a = [1, 2, 3, 4, 5], b = [2, 4]
// LCS = [2, 4] => length 2
// =============================================================================

fn test_lcs_subsequence() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 0, e6: 0, e7: 0 };
    let b = Arr8 { e0: 2, e1: 4, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 5, b, 2), 2);
}

// =============================================================================
// Test: repeated elements
// a = [1, 1, 1, 1], b = [1, 1]
// LCS = [1, 1] => length 2
// =============================================================================

fn test_lcs_repeated() {
    let a = Arr8 { e0: 1, e1: 1, e2: 1, e3: 1, e4: 0, e5: 0, e6: 0, e7: 0 };
    let b = Arr8 { e0: 1, e1: 1, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(lcs_length(a, 4, b, 2), 2);
}

// =============================================================================
// Test: symmetry — LCS(a,b) == LCS(b,a)
// =============================================================================

fn test_lcs_symmetry() {
    let a = Arr8 { e0: 3, e1: 1, e2: 4, e3: 1, e4: 5, e5: 9, e6: 0, e7: 0 };
    let b = Arr8 { e0: 1, e1: 4, e2: 1, e3: 5, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ab = lcs_length(a, 6, b, 4);
    let ba = lcs_length(b, 4, a, 6);
    assert_eq(ab, ba);
    assert_eq(ab, 4);  // LCS = [1, 4, 1, 5]
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_lcs_equal();
    test_lcs_disjoint();
    test_lcs_partial();
    test_lcs_classic();
    test_lcs_empty();
    test_lcs_single();
    test_lcs_subsequence();
    test_lcs_repeated();
    test_lcs_symmetry();
    print("[OK] 274_interp_longest_common_subseq");
    0
}
