// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, tensor, matmul
// @timeout: 50000
// @expected-exit: 0
// @description: Matrix multiplication — 2x2 and 2x3 x 3x2 matmul using flat arrays

// ============================================================================
// Mat2x2: 2x2 matrix stored as 4 Ints (row-major)
// ============================================================================

type Mat2x2 is { m00: Int, m01: Int, m10: Int, m11: Int };

fn mat2_mul(a: Mat2x2, b: Mat2x2) -> Mat2x2 {
    Mat2x2 {
        m00: a.m00 * b.m00 + a.m01 * b.m10,
        m01: a.m00 * b.m01 + a.m01 * b.m11,
        m10: a.m10 * b.m00 + a.m11 * b.m10,
        m11: a.m10 * b.m01 + a.m11 * b.m11
    }
}

// ============================================================================
// Mat2x3 and Mat3x2 for rectangular multiply
// ============================================================================

type Mat2x3 is { a00: Int, a01: Int, a02: Int, a10: Int, a11: Int, a12: Int };
type Mat3x2 is { b00: Int, b01: Int, b10: Int, b11: Int, b20: Int, b21: Int };

fn mat_mul_2x3_3x2(a: Mat2x3, b: Mat3x2) -> Mat2x2 {
    Mat2x2 {
        m00: a.a00 * b.b00 + a.a01 * b.b10 + a.a02 * b.b20,
        m01: a.a00 * b.b01 + a.a01 * b.b11 + a.a02 * b.b21,
        m10: a.a10 * b.b00 + a.a11 * b.b10 + a.a12 * b.b20,
        m11: a.a10 * b.b01 + a.a11 * b.b11 + a.a12 * b.b21
    }
}

// ============================================================================
// Test 1: Identity multiply
// ============================================================================

@test
fn test_identity_mul() {
    let identity = Mat2x2 { m00: 1, m01: 0, m10: 0, m11: 1 };
    let a = Mat2x2 { m00: 3, m01: 7, m10: 2, m11: 5 };
    let result = mat2_mul(identity, a);
    assert_eq(result.m00, 3);
    assert_eq(result.m01, 7);
    assert_eq(result.m10, 2);
    assert_eq(result.m11, 5);

    // A * I = A
    let result2 = mat2_mul(a, identity);
    assert_eq(result2.m00, 3);
    assert_eq(result2.m01, 7);
    assert_eq(result2.m10, 2);
    assert_eq(result2.m11, 5);
    print("  test_identity_mul: ok");
}

// ============================================================================
// Test 2: Known 2x2 result
// ============================================================================

@test
fn test_known_2x2() {
    // [1 2] * [5 6] = [1*5+2*7  1*6+2*8] = [19 22]
    // [3 4]   [7 8]   [3*5+4*7  3*6+4*8]   [43 50]
    let a = Mat2x2 { m00: 1, m01: 2, m10: 3, m11: 4 };
    let b = Mat2x2 { m00: 5, m01: 6, m10: 7, m11: 8 };
    let c = mat2_mul(a, b);
    assert_eq(c.m00, 19);
    assert_eq(c.m01, 22);
    assert_eq(c.m10, 43);
    assert_eq(c.m11, 50);
    print("  test_known_2x2: ok");
}

// ============================================================================
// Test 3: Non-commutative check (A*B != B*A in general)
// ============================================================================

@test
fn test_non_commutative() {
    let a = Mat2x2 { m00: 1, m01: 2, m10: 3, m11: 4 };
    let b = Mat2x2 { m00: 5, m01: 6, m10: 7, m11: 8 };
    let ab = mat2_mul(a, b);
    let ba = mat2_mul(b, a);
    // AB = [19 22; 43 50], BA = [23 34; 31 46]
    assert_eq(ba.m00, 23);
    assert_eq(ba.m01, 34);
    assert_eq(ba.m10, 31);
    assert_eq(ba.m11, 46);
    // Verify they differ
    let diff00 = ab.m00 - ba.m00;
    let diff_nonzero = if diff00 == 0 { 0 } else { 1 };
    assert_eq(diff_nonzero, 1);
    print("  test_non_commutative: ok");
}

// ============================================================================
// Test 4: Rectangular 2x3 * 3x2 = 2x2
// ============================================================================

@test
fn test_rect_mul() {
    // [1 2 3] * [7  8 ] = [1*7+2*9+3*11  1*8+2*10+3*12]
    // [4 5 6]   [9  10]   [4*7+5*9+6*11  4*8+5*10+6*12]
    //           [11 12]
    // = [58  64]
    //   [139 154]
    let a = Mat2x3 { a00: 1, a01: 2, a02: 3, a10: 4, a11: 5, a12: 6 };
    let b = Mat3x2 { b00: 7, b01: 8, b10: 9, b11: 10, b20: 11, b21: 12 };
    let c = mat_mul_2x3_3x2(a, b);
    assert_eq(c.m00, 58);
    assert_eq(c.m01, 64);
    assert_eq(c.m10, 139);
    assert_eq(c.m11, 154);
    print("  test_rect_mul: ok");
}

// ============================================================================
// Test 5: Squaring a matrix
// ============================================================================

@test
fn test_matrix_square() {
    // A^2 where A = [2 1; 1 2]
    // A^2 = [5 4; 4 5]
    let a = Mat2x2 { m00: 2, m01: 1, m10: 1, m11: 2 };
    let a2 = mat2_mul(a, a);
    assert_eq(a2.m00, 5);
    assert_eq(a2.m01, 4);
    assert_eq(a2.m10, 4);
    assert_eq(a2.m11, 5);
    print("  test_matrix_square: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_identity_mul();
    test_known_2x2();
    test_non_commutative();
    test_rect_mul();
    test_matrix_square();
    print("[OK] 132_tensor_opcode_matmul");
    0
}
