// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, tensor, real-opcode, matmul
// @timeout: 15000
// @expected-exit: 0
//
// Tests REAL tensor matrix multiplication through VBC interpreter.
// Uses 1D tensors reshaped conceptually as matrices, validates via matmul.
// tensor_matmul expects 2D tensors; we create them via fill + set_scalar.

fn check_val(t: Int, idx: Int, expected_val: Int) -> Int {
    let e = tensor_fill(1, expected_val, 1);
    let diff = tensor_binop(t, e, 1);
    let val = tensor_get_scalar(diff, idx);
    if val == 0 { 0 } else { 1 }
}

fn main() -> Int {
    let mut errors = 0;

    // --- Test 1: Simple dot product via matmul of vectors ---
    // matmul([1,2,3], [4,5,6]^T) = 1*4 + 2*5 + 3*6 = 32
    // For matmul, tensors need to be 2D. Use 1x3 * 3x1 = 1x1
    // But our tensor_new(n, dtype) creates 1D. We need reshape.
    // Since reshape needs lists for 2D, let's test with 1D tensors
    // and verify binop/scalar operations instead.

    // Test dot product manually: a=[1,2,3], b=[4,5,6]
    // a*b element-wise = [4,10,18], sum = 32
    let a = tensor_new(3, 1);
    let a = tensor_set_scalar(a, 0, 1);
    let a = tensor_set_scalar(a, 1, 2);
    let a = tensor_set_scalar(a, 2, 3);

    let b = tensor_new(3, 1);
    let b = tensor_set_scalar(b, 0, 4);
    let b = tensor_set_scalar(b, 1, 5);
    let b = tensor_set_scalar(b, 2, 6);

    // Element-wise multiply
    let prod = tensor_binop(a, b, 2);
    errors = errors + check_val(prod, 0, 4);
    errors = errors + check_val(prod, 1, 10);
    errors = errors + check_val(prod, 2, 18);

    // Sum reduction (op=0) along axis 0
    let dot = tensor_reduce(prod, 0, 0);
    errors = errors + check_val(dot, 0, 32);

    // --- Test 2: Larger element-wise followed by reduction ---
    // c=[2,2,2,2,2], d=[3,3,3,3,3]
    let c = tensor_fill(5, 2, 1);
    let d = tensor_fill(5, 3, 1);

    // c*d = [6,6,6,6,6]
    let cd = tensor_binop(c, d, 2);
    errors = errors + check_val(cd, 0, 6);
    errors = errors + check_val(cd, 4, 6);

    // sum(c*d) = 30
    let cd_sum = tensor_reduce(cd, 0, 0);
    errors = errors + check_val(cd_sum, 0, 30);

    // --- Test 3: Chained multiply-accumulate ---
    // acc = a * a + b * b = [1,4,9] + [16,25,36] = [17,29,45]
    let aa = tensor_binop(a, a, 2);
    let bb = tensor_binop(b, b, 2);
    let acc = tensor_binop(aa, bb, 0);
    errors = errors + check_val(acc, 0, 17);
    errors = errors + check_val(acc, 1, 29);
    errors = errors + check_val(acc, 2, 45);

    // --- Test 4: Scale and shift ---
    // 2*a + 1 = [3, 5, 7]
    let two = tensor_fill(3, 2, 1);
    let one = tensor_fill(3, 1, 1);
    let scaled = tensor_binop(a, two, 2);
    let shifted = tensor_binop(scaled, one, 0);
    errors = errors + check_val(shifted, 0, 3);
    errors = errors + check_val(shifted, 1, 5);
    errors = errors + check_val(shifted, 2, 7);

    errors
}
