// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, autodiff, chain-rule
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Chain rule implementation
// d/dx[f(g(x))] = f'(g(x)) * g'(x)
// Uses integer-scaled arithmetic (scale=1000).

fn scale() -> Int { 1000 }

fn smul(a: Int, b: Int) -> Int {
    (a * b) / scale()
}

fn sdiv(a: Int, b: Int) -> Int {
    (a * scale()) / b
}

fn abs_val(x: Int) -> Int {
    if x < 0 { 0 - x } else { x }
}

fn within_tol(actual: Int, expected: Int, tol: Int) -> Int {
    if abs_val(actual - expected) <= tol { 1 } else { 0 }
}

// =============================================================================
// Functions and their analytical derivatives
// =============================================================================

// f(x) = x^2, f'(x) = 2x
fn f_sq(x: Int) -> Int { smul(x, x) }
fn f_sq_deriv(x: Int) -> Int { 2 * x }

// g(x) = 3x + 1 (scaled: 3*x + 1000), g'(x) = 3 (scaled: 3000)
fn g_lin(x: Int) -> Int { 3 * x + 1 * scale() }
fn g_lin_deriv(x: Int) -> Int { 3 * scale() }

// h(x) = x^3, h'(x) = 3x^2
fn h_cube(x: Int) -> Int { smul(smul(x, x), x) }
fn h_cube_deriv(x: Int) -> Int { 3 * smul(x, x) }

// p(x) = 2x, p'(x) = 2
fn p_double(x: Int) -> Int { 2 * x }
fn p_double_deriv(x: Int) -> Int { 2 * scale() }

// =============================================================================
// Chain rule: d/dx[f(g(x))] = f'(g(x)) * g'(x)
// =============================================================================

fn test_chain_sq_of_lin() {
    // f(g(x)) = (3x+1)^2
    // d/dx = f'(g(x)) * g'(x) = 2*(3x+1) * 3 = 6*(3x+1)
    // At x=1 (scaled 1000): g(1)=4000, f'(4000)=8000, g'(1)=3000
    // chain = 8000 * 3000 / 1000 = 24000
    let x = 1 * scale();
    let gx = g_lin(x);         // 3*1000 + 1000 = 4000
    let fp_gx = f_sq_deriv(gx); // 2*4000 = 8000
    let gp_x = g_lin_deriv(x);  // 3000
    let chain = smul(fp_gx, gp_x); // 8000*3000/1000 = 24000
    assert_eq(chain, 24000);

    // Verify: d/dx[(3x+1)^2] = 6(3x+1)
    // At x=1: 6*(3+1) = 24 => scaled: 24000
    assert_eq(chain, 24 * scale());
}

fn test_chain_sq_of_lin_at_zero() {
    // At x=0: g(0)=1000, f'(1000)=2000, g'(0)=3000
    // chain = 2000*3000/1000 = 6000
    let x = 0;
    let gx = g_lin(x);
    let fp_gx = f_sq_deriv(gx);
    let gp_x = g_lin_deriv(x);
    let chain = smul(fp_gx, gp_x);
    // d/dx[(3x+1)^2] at x=0 = 6*(0+1) = 6 => 6000
    assert_eq(chain, 6 * scale());
}

fn test_chain_cube_of_double() {
    // f(g(x)) = (2x)^3 = 8x^3
    // d/dx = h'(p(x)) * p'(x) = 3*(2x)^2 * 2 = 24x^2
    // At x=2 (scaled 2000):
    let x = 2 * scale();
    let px = p_double(x);           // 4000
    let hp_px = h_cube_deriv(px);   // 3 * (4000*4000/1000) = 3*16000 = 48000
    let pp_x = p_double_deriv(x);   // 2000
    let chain = smul(hp_px, pp_x);  // 48000*2000/1000 = 96000

    // Expected: 24*x^2 at x=2 = 24*4 = 96 => 96000
    assert_eq(chain, 96 * scale());
}

fn test_chain_double_of_sq() {
    // f(g(x)) = 2*(x^2) = 2x^2
    // d/dx = p'(f_sq(x)) * f_sq'(x) = 2 * 2x = 4x
    let x = 3 * scale();
    let fx = f_sq(x);                // 9000
    let pp_fx = p_double_deriv(x);   // 2000
    let fp_x = f_sq_deriv(x);        // 6000
    let chain = smul(pp_fx, fp_x);   // 2000*6000/1000 = 12000

    // Expected: 4*3 = 12 => 12000
    assert_eq(chain, 12 * scale());
}

fn test_triple_chain() {
    // h(f(g(x))) where h=x^2, f=x^2, g=2x
    // = ((2x)^2)^2 = (4x^2)^2 = 16x^4
    // d/dx = h'(f(g(x))) * f'(g(x)) * g'(x)
    // = 2*(4x^2) * 2*(2x) * 2
    // = 8x^2 * 4x * 2 = 64x^3
    let x = 1 * scale();
    let gx = p_double(x);       // 2000
    let fgx = f_sq(gx);         // 4000000/1000 = 4000
    let hfgx_deriv = f_sq_deriv(fgx);  // 2*4000 = 8000
    let fgx_deriv = f_sq_deriv(gx);    // 2*2000 = 4000
    let gx_deriv = p_double_deriv(x);  // 2000
    let chain = smul(smul(hfgx_deriv, fgx_deriv), gx_deriv);
    // 8000*4000/1000=32000, 32000*2000/1000=64000

    // Expected: 64*1^3 = 64 => 64000
    assert_eq(chain, 64 * scale());
}

fn test_chain_numerical_verification() {
    // Verify chain rule against numerical differentiation
    // f(g(x)) = (3x+1)^2
    let x = 2 * scale();
    let h = 1; // step size 0.001

    // Numerical: central difference of composite
    let comp_plus = f_sq(g_lin(x + h));
    let comp_minus = f_sq(g_lin(x - h));
    let num_deriv = sdiv(comp_plus - comp_minus, 2 * h);

    // Analytical: 6*(3x+1) at x=2 = 6*7 = 42 => 42000
    let gx = g_lin(x);
    let chain = smul(f_sq_deriv(gx), g_lin_deriv(x));

    assert_eq(within_tol(num_deriv, chain, 50), 1);
    assert_eq(within_tol(chain, 42 * scale(), 10), 1);
}

fn test_chain_at_multiple_points() {
    // f(g(x)) = (3x+1)^2, d/dx = 6(3x+1)
    // Test at x = -1, 0, 1, 2, 3
    let h = 1;

    // x = -1: 6*(3*(-1)+1) = 6*(-2) = -12 => -12000
    let x1 = -1 * scale();
    let c1 = smul(f_sq_deriv(g_lin(x1)), g_lin_deriv(x1));
    assert_eq(c1, -12 * scale());

    // x = 0: 6*(0+1) = 6 => 6000
    let c2 = smul(f_sq_deriv(g_lin(0)), g_lin_deriv(0));
    assert_eq(c2, 6 * scale());

    // x = 1: 6*(3+1) = 24 => 24000
    let x3 = 1 * scale();
    let c3 = smul(f_sq_deriv(g_lin(x3)), g_lin_deriv(x3));
    assert_eq(c3, 24 * scale());

    // x = 3: 6*(9+1) = 60 => 60000
    let x5 = 3 * scale();
    let c5 = smul(f_sq_deriv(g_lin(x5)), g_lin_deriv(x5));
    assert_eq(c5, 60 * scale());
}

fn main() -> Int {
    test_chain_sq_of_lin();
    test_chain_sq_of_lin_at_zero();
    test_chain_cube_of_double();
    test_chain_double_of_sq();
    test_triple_chain();
    test_chain_numerical_verification();
    test_chain_at_multiple_points();
    print("[OK] 377_interp_autodiff_chain_rule");
    0
}
