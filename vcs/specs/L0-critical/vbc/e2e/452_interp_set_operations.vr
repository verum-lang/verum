// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, set, union, intersection, difference
// @timeout: 15000
// @expected-exit: 0
//
// Set operations using sorted arrays. Sets are represented as sorted integer
// arrays (ascending, no duplicates). Operations: union, intersection,
// difference, symmetric difference, subset check.

// Check membership in a sorted array of size n.
fn set_contains(arr: [Int; 8], n: Int, val: Int) -> Int {
    let mut lo = 0;
    let mut hi = n - 1;
    let mut found = 0;
    while lo <= hi {
        let mid = (lo + hi) / 2;
        if arr[mid] == val {
            found = 1;
            lo = hi + 1; // break
        } else if arr[mid] < val {
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    found
}

fn test_set_union() {
    // A = {1, 3, 5, 7}   B = {2, 3, 6, 7}
    // Union = {1, 2, 3, 5, 6, 7}
    let a = [1, 3, 5, 7, 0, 0, 0, 0];
    let na = 4;
    let b = [2, 3, 6, 7, 0, 0, 0, 0];
    let nb = 4;

    // Merge two sorted arrays
    let mut un = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut nu = 0;
    let mut ia = 0;
    let mut ib = 0;
    while ia < na && ib < nb {
        if a[ia] < b[ib] {
            un[nu] = a[ia]; nu = nu + 1; ia = ia + 1;
        } else if b[ib] < a[ia] {
            un[nu] = b[ib]; nu = nu + 1; ib = ib + 1;
        } else {
            // equal: include once
            un[nu] = a[ia]; nu = nu + 1; ia = ia + 1; ib = ib + 1;
        }
    }
    while ia < na { un[nu] = a[ia]; nu = nu + 1; ia = ia + 1; }
    while ib < nb { un[nu] = b[ib]; nu = nu + 1; ib = ib + 1; }

    // Expect: {1, 2, 3, 5, 6, 7} -> size 6
    assert_eq(nu, 6);
    assert_eq(un[0], 1);
    assert_eq(un[1], 2);
    assert_eq(un[2], 3);
    assert_eq(un[3], 5);
    assert_eq(un[4], 6);
    assert_eq(un[5], 7);

    // A = {10, 20, 30}  B = {10, 20, 30} -> union same size
    let c = [10, 20, 30, 0, 0, 0, 0, 0];
    let nc = 3;
    let d = [10, 20, 30, 0, 0, 0, 0, 0];
    let nd = 3;
    let mut un2 = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut nu2 = 0;
    let mut ic = 0;
    let mut id = 0;
    while ic < nc && id < nd {
        if c[ic] < d[id] {
            un2[nu2] = c[ic]; nu2 = nu2 + 1; ic = ic + 1;
        } else if d[id] < c[ic] {
            un2[nu2] = d[id]; nu2 = nu2 + 1; id = id + 1;
        } else {
            un2[nu2] = c[ic]; nu2 = nu2 + 1; ic = ic + 1; id = id + 1;
        }
    }
    assert_eq(nu2, 3);
    assert_eq(un2[0], 10);
    assert_eq(un2[2], 30);

    print("set_union: ok");
}

fn test_set_intersection() {
    // A = {1, 2, 4, 6, 8}  B = {2, 4, 5, 8, 9}
    // Intersection = {2, 4, 8}
    let a = [1, 2, 4, 6, 8, 0, 0, 0];
    let na = 5;
    let b = [2, 4, 5, 8, 9, 0, 0, 0];
    let nb = 5;

    let mut inter = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut ni = 0;
    let mut ia = 0;
    let mut ib = 0;
    while ia < na && ib < nb {
        if a[ia] < b[ib] {
            ia = ia + 1;
        } else if b[ib] < a[ia] {
            ib = ib + 1;
        } else {
            inter[ni] = a[ia]; ni = ni + 1;
            ia = ia + 1; ib = ib + 1;
        }
    }
    assert_eq(ni, 3);
    assert_eq(inter[0], 2);
    assert_eq(inter[1], 4);
    assert_eq(inter[2], 8);

    // A = {1, 3, 5}  B = {2, 4, 6} -> disjoint -> intersection empty
    let c = [1, 3, 5, 0, 0, 0, 0, 0];
    let nc = 3;
    let d = [2, 4, 6, 0, 0, 0, 0, 0];
    let nd = 3;
    let mut inter2 = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut ni2 = 0;
    let mut ic = 0;
    let mut id = 0;
    while ic < nc && id < nd {
        if c[ic] < d[id] { ic = ic + 1; }
        else if d[id] < c[ic] { id = id + 1; }
        else { inter2[ni2] = c[ic]; ni2 = ni2 + 1; ic = ic + 1; id = id + 1; }
    }
    assert_eq(ni2, 0);

    print("set_intersection: ok");
}

fn test_set_difference() {
    // A = {1, 2, 4, 6, 8}  B = {2, 4, 5, 8, 9}
    // A - B = elements in A but not in B = {1, 6}
    let a = [1, 2, 4, 6, 8, 0, 0, 0];
    let na = 5;
    let b = [2, 4, 5, 8, 9, 0, 0, 0];
    let nb = 5;

    let mut diff = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut nd_out = 0;
    let mut ia = 0;
    let mut ib = 0;
    while ia < na && ib < nb {
        if a[ia] < b[ib] {
            diff[nd_out] = a[ia]; nd_out = nd_out + 1; ia = ia + 1;
        } else if b[ib] < a[ia] {
            ib = ib + 1;
        } else {
            ia = ia + 1; ib = ib + 1; // in both: skip
        }
    }
    while ia < na { diff[nd_out] = a[ia]; nd_out = nd_out + 1; ia = ia + 1; }

    assert_eq(nd_out, 2);
    assert_eq(diff[0], 1);
    assert_eq(diff[1], 6);

    // B - A = elements in B not in A = {5, 9}
    let mut diff2 = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut nd2 = 0;
    let mut ib2 = 0;
    let mut ia2 = 0;
    while ib2 < nb && ia2 < na {
        if b[ib2] < a[ia2] {
            diff2[nd2] = b[ib2]; nd2 = nd2 + 1; ib2 = ib2 + 1;
        } else if a[ia2] < b[ib2] {
            ia2 = ia2 + 1;
        } else {
            ib2 = ib2 + 1; ia2 = ia2 + 1;
        }
    }
    while ib2 < nb { diff2[nd2] = b[ib2]; nd2 = nd2 + 1; ib2 = ib2 + 1; }

    assert_eq(nd2, 2);
    assert_eq(diff2[0], 5);
    assert_eq(diff2[1], 9);

    print("set_difference: ok");
}

fn test_symmetric_difference() {
    // A = {1, 2, 4, 6, 8}  B = {2, 4, 5, 8, 9}
    // Sym diff = (A-B) union (B-A) = {1, 5, 6, 9}
    let a = [1, 2, 4, 6, 8, 0, 0, 0];
    let na = 5;
    let b = [2, 4, 5, 8, 9, 0, 0, 0];
    let nb = 5;

    let mut sym = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut ns = 0;
    let mut ia = 0;
    let mut ib = 0;
    while ia < na && ib < nb {
        if a[ia] < b[ib] {
            sym[ns] = a[ia]; ns = ns + 1; ia = ia + 1;
        } else if b[ib] < a[ia] {
            sym[ns] = b[ib]; ns = ns + 1; ib = ib + 1;
        } else {
            // equal: skip (not in sym diff)
            ia = ia + 1; ib = ib + 1;
        }
    }
    while ia < na { sym[ns] = a[ia]; ns = ns + 1; ia = ia + 1; }
    while ib < nb { sym[ns] = b[ib]; ns = ns + 1; ib = ib + 1; }

    // Expected {1, 5, 6, 9}
    assert_eq(ns, 4);
    assert_eq(sym[0], 1);
    assert_eq(sym[1], 5);
    assert_eq(sym[2], 6);
    assert_eq(sym[3], 9);

    print("symmetric_difference: ok");
}

fn test_subset_check() {
    // A = {2, 4, 6}  B = {1, 2, 3, 4, 5, 6, 7} -> A is subset of B
    let a = [2, 4, 6, 0, 0, 0, 0, 0];
    let na = 3;
    let b = [1, 2, 3, 4, 5, 6, 7, 0];
    let nb = 7;

    // A is subset of B if every element of A is in B
    let mut is_sub = 1;
    let mut ia = 0;
    let mut ib = 0;
    while ia < na && is_sub == 1 {
        // advance ib until b[ib] >= a[ia]
        while ib < nb && b[ib] < a[ia] { ib = ib + 1; }
        if ib >= nb || b[ib] != a[ia] {
            is_sub = 0;
        } else {
            ia = ia + 1; ib = ib + 1;
        }
    }
    assert_eq(is_sub, 1); // A is subset of B

    // C = {2, 5, 7}  D = {1, 2, 3, 4, 6} -> C is NOT subset of D (5 missing, 7 missing)
    let c = [2, 5, 7, 0, 0, 0, 0, 0];
    let nc = 3;
    let d = [1, 2, 3, 4, 6, 0, 0, 0];
    let nd = 5;

    let mut is_sub2 = 1;
    let mut ic = 0;
    let mut id = 0;
    while ic < nc && is_sub2 == 1 {
        while id < nd && d[id] < c[ic] { id = id + 1; }
        if id >= nd || d[id] != c[ic] {
            is_sub2 = 0;
        } else {
            ic = ic + 1; id = id + 1;
        }
    }
    assert_eq(is_sub2, 0); // C is NOT subset of D

    // Empty set is subset of everything
    let empty = [0, 0, 0, 0, 0, 0, 0, 0];
    let ne = 0;
    let full = [1, 2, 3, 0, 0, 0, 0, 0];
    let nf = 3;
    let mut is_sub3 = 1;
    let mut ie = 0;
    let mut if_ = 0;
    while ie < ne && is_sub3 == 1 {
        while if_ < nf && full[if_] < empty[ie] { if_ = if_ + 1; }
        if if_ >= nf || full[if_] != empty[ie] {
            is_sub3 = 0;
        } else {
            ie = ie + 1; if_ = if_ + 1;
        }
    }
    assert_eq(is_sub3, 1); // empty set is subset

    print("subset_check: ok");
}

fn main() -> Int {
    test_set_union();
    test_set_intersection();
    test_set_difference();
    test_symmetric_difference();
    test_subset_check();
    print("[OK] 452_interp_set_operations");
    0
}
