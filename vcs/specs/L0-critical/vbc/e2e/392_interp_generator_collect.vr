// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, generator, yield, for-loop, advanced
// @timeout: 15000
// @expected-exit: 0
//
// Advanced generator tests: nested generators, early termination,
// generators with complex state, and multiple interleaved generators.

fn* powers_of_two(n: Int) -> Int {
    let mut val = 1;
    let mut i = 0;
    while i < n {
        yield val;
        val = val * 2;
        i = i + 1;
    }
}

fn* triangular_numbers(n: Int) -> Int {
    let mut total = 0;
    let mut i = 1;
    while i <= n {
        total = total + i;
        yield total;
        i = i + 1;
    }
}

fn* alternating(n: Int) -> Int {
    let mut i = 0;
    while i < n {
        if i % 2 == 0 {
            yield i;
        } else {
            yield 0 - i;
        }
        i = i + 1;
    }
}

fn* countdown(start: Int) -> Int {
    let mut i = start;
    while i > 0 {
        yield i;
        i = i - 1;
    }
}

fn test_powers_of_two() {
    let mut total = 0;
    for x in powers_of_two(8) {
        total = total + x;
    }
    // 1 + 2 + 4 + 8 + 16 + 32 + 64 + 128 = 255
    assert_eq(total, 255);
    print("powers_of_two: ok");
}

fn test_triangular_numbers() {
    // Triangular numbers: 1, 3, 6, 10, 15
    let mut last = 0;
    let mut count = 0;
    for t in triangular_numbers(5) {
        last = t;
        count = count + 1;
    }
    assert_eq(count, 5);
    assert_eq(last, 15);
    print("triangular_numbers: ok");
}

fn test_alternating() {
    // 0, -1, 2, -3, 4 → sum = 2
    let mut sum = 0;
    for x in alternating(5) {
        sum = sum + x;
    }
    assert_eq(sum, 2);
    print("alternating: ok");
}

fn test_countdown() {
    // 5, 4, 3, 2, 1 → sum = 15
    let mut total = 0;
    let mut first = 0;
    let mut count = 0;
    for x in countdown(5) {
        if count == 0 {
            first = x;
        }
        total = total + x;
        count = count + 1;
    }
    assert_eq(first, 5);
    assert_eq(total, 15);
    assert_eq(count, 5);
    print("countdown: ok");
}

fn test_early_exit() {
    // Only consume first 3 values from a generator
    let mut count = 0;
    let mut sum = 0;
    for x in powers_of_two(10) {
        if count >= 3 {
            // NOTE: we can't break from for-in loops over generators yet,
            // so we just skip adding. Generator runs to completion.
        } else {
            sum = sum + x;
        }
        count = count + 1;
    }
    // First 3: 1 + 2 + 4 = 7
    assert_eq(sum, 7);
    print("early_exit: ok");
}

fn test_sequential_generators() {
    // Use different generators in sequence
    let mut sum1 = 0;
    for x in powers_of_two(4) {
        sum1 = sum1 + x;
    }
    // 1 + 2 + 4 + 8 = 15
    assert_eq(sum1, 15);

    let mut sum2 = 0;
    for x in countdown(4) {
        sum2 = sum2 + x;
    }
    // 4 + 3 + 2 + 1 = 10
    assert_eq(sum2, 10);

    assert_eq(sum1 + sum2, 25);
    print("sequential_generators: ok");
}

fn test_generator_with_computation() {
    // Use generator results in computation
    let mut max = 0;
    for x in triangular_numbers(10) {
        if x > max {
            max = x;
        }
    }
    // 10th triangular number = 55
    assert_eq(max, 55);
    print("generator_with_computation: ok");
}

fn main() -> Int {
    test_powers_of_two();
    test_triangular_numbers();
    test_alternating();
    test_countdown();
    test_early_exit();
    test_sequential_generators();
    test_generator_with_computation();
    print("[OK] 392_interp_generator_collect");
    0
}
