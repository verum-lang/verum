// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, tensor, linalg
// @timeout: 50000
// @expected-exit: 0
// @description: Linear algebra — 2x2 determinant, trace, inverse (scaled integer arithmetic)

// ============================================================================
// Mat2x2: 2x2 matrix stored as 4 Ints (row-major)
// ============================================================================

type Mat2x2 is { m00: Int, m01: Int, m10: Int, m11: Int };

fn mat_det(m: Mat2x2) -> Int {
    m.m00 * m.m11 - m.m01 * m.m10
}

fn mat_trace(m: Mat2x2) -> Int {
    m.m00 + m.m11
}

// Adjugate (classical adjoint) of a 2x2 matrix
// adj([a b; c d]) = [d -b; -c a]
fn mat_adjugate(m: Mat2x2) -> Mat2x2 {
    Mat2x2 {
        m00: m.m11,
        m01: 0 - m.m01,
        m10: 0 - m.m10,
        m11: m.m00
    }
}

fn mat_add(a: Mat2x2, b: Mat2x2) -> Mat2x2 {
    Mat2x2 {
        m00: a.m00 + b.m00, m01: a.m01 + b.m01,
        m10: a.m10 + b.m10, m11: a.m11 + b.m11
    }
}

fn mat_mul(a: Mat2x2, b: Mat2x2) -> Mat2x2 {
    Mat2x2 {
        m00: a.m00 * b.m00 + a.m01 * b.m10,
        m01: a.m00 * b.m01 + a.m01 * b.m11,
        m10: a.m10 * b.m00 + a.m11 * b.m10,
        m11: a.m10 * b.m01 + a.m11 * b.m11
    }
}

// Scale all elements by s
fn mat_scale(m: Mat2x2, s: Int) -> Mat2x2 {
    Mat2x2 {
        m00: m.m00 * s, m01: m.m01 * s,
        m10: m.m10 * s, m11: m.m11 * s
    }
}

// ============================================================================
// Test 1: Determinant
// ============================================================================

@test
fn test_determinant() {
    // det([3 8; 4 6]) = 3*6 - 8*4 = 18 - 32 = -14
    let m = Mat2x2 { m00: 3, m01: 8, m10: 4, m11: 6 };
    assert_eq(mat_det(m), -14);

    // Identity det = 1
    let id = Mat2x2 { m00: 1, m01: 0, m10: 0, m11: 1 };
    assert_eq(mat_det(id), 1);

    // Singular matrix det = 0
    let sing = Mat2x2 { m00: 2, m01: 4, m10: 1, m11: 2 };
    assert_eq(mat_det(sing), 0);
    print("  test_determinant: ok");
}

// ============================================================================
// Test 2: Trace
// ============================================================================

@test
fn test_trace() {
    let m = Mat2x2 { m00: 5, m01: 3, m10: 7, m11: 11 };
    assert_eq(mat_trace(m), 16);

    let id = Mat2x2 { m00: 1, m01: 0, m10: 0, m11: 1 };
    assert_eq(mat_trace(id), 2);

    // trace(A+B) = trace(A) + trace(B)
    let a = Mat2x2 { m00: 2, m01: 1, m10: 1, m11: 3 };
    let b = Mat2x2 { m00: 4, m01: 2, m10: 2, m11: 5 };
    let ab = mat_add(a, b);
    assert_eq(mat_trace(ab), mat_trace(a) + mat_trace(b));
    print("  test_trace: ok");
}

// ============================================================================
// Test 3: Adjugate and inverse check (scaled)
// ============================================================================

@test
fn test_adjugate() {
    // For M = [4 7; 2 6], adj(M) = [6 -7; -2 4]
    let m = Mat2x2 { m00: 4, m01: 7, m10: 2, m11: 6 };
    let adj = mat_adjugate(m);
    assert_eq(adj.m00, 6);
    assert_eq(adj.m01, -7);
    assert_eq(adj.m10, -2);
    assert_eq(adj.m11, 4);

    // M * adj(M) = det(M) * I
    // det = 4*6 - 7*2 = 10
    let d = mat_det(m);
    assert_eq(d, 10);
    let product = mat_mul(m, adj);
    assert_eq(product.m00, d);
    assert_eq(product.m01, 0);
    assert_eq(product.m10, 0);
    assert_eq(product.m11, d);
    print("  test_adjugate: ok");
}

// ============================================================================
// Test 4: Scaled inverse verification
// ============================================================================

@test
fn test_scaled_inverse() {
    // A = [2 1; 5 3], det = 6-5 = 1
    // inv(A) = adj(A)/det = [3 -1; -5 2]
    let a = Mat2x2 { m00: 2, m01: 1, m10: 5, m11: 3 };
    let d = mat_det(a);
    assert_eq(d, 1);
    let inv = mat_adjugate(a);
    // Since det=1, inv is exact
    let id_check = mat_mul(a, inv);
    assert_eq(id_check.m00, 1);
    assert_eq(id_check.m01, 0);
    assert_eq(id_check.m10, 0);
    assert_eq(id_check.m11, 1);
    print("  test_scaled_inverse: ok");
}

// ============================================================================
// Test 5: det(A*B) = det(A) * det(B)
// ============================================================================

@test
fn test_det_multiplicative() {
    let a = Mat2x2 { m00: 1, m01: 2, m10: 3, m11: 4 };
    let b = Mat2x2 { m00: 5, m01: 6, m10: 7, m11: 8 };
    let ab = mat_mul(a, b);
    let det_a = mat_det(a);
    let det_b = mat_det(b);
    let det_ab = mat_det(ab);
    assert_eq(det_ab, det_a * det_b);
    print("  test_det_multiplicative: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_determinant();
    test_trace();
    test_adjugate();
    test_scaled_inverse();
    test_det_multiplicative();
    print("[OK] 135_tensor_ext_linalg");
    0
}
