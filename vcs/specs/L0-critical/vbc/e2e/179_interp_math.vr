// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, math
// @timeout: 5000
// @expected-exit: 0
//
// Interpreter e2e test: integer arithmetic edge cases, float precision,
// bitwise operations, math functions

// =============================================================================
// Integer arithmetic edge cases
// =============================================================================

fn test_int_overflow_large() {
    // Large multiplication that fits in 64-bit
    let a = 1000000;
    let b = 1000000;
    assert_eq(a * b, 1000000000000);
}

fn test_int_div_truncation() {
    // Integer division truncates toward zero
    assert_eq(7 / 2, 3);
    assert_eq(-7 / 2, -3);
    assert_eq(1 / 3, 0);
    assert_eq(99 / 100, 0);
    assert_eq(100 / 100, 1);
}

fn test_int_modulo() {
    assert_eq(10 % 3, 1);
    assert_eq(10 % 5, 0);
    assert_eq(10 % 7, 3);
    assert_eq(0 % 5, 0);
    assert_eq(1 % 1, 0);
}

fn test_int_negative_arithmetic() {
    assert_eq(-1 * -1, 1);
    assert_eq(-10 + 10, 0);
    assert_eq(-100 * 0, 0);
    assert_eq(-50 + -50, -100);
}

fn test_int_associativity() {
    let a = 10;
    let b = 20;
    let c = 30;
    // Addition is associative
    assert_eq((a + b) + c, a + (b + c));
    // Multiplication is associative
    assert_eq((a * b) * c, a * (b * c));
}

fn test_int_distributive() {
    let a = 5;
    let b = 3;
    let c = 7;
    // a * (b + c) == a*b + a*c
    assert_eq(a * (b + c), a * b + a * c);
}

// =============================================================================
// Float arithmetic
// =============================================================================

fn test_float_basic_ops() {
    assert_eq(1.0 + 2.0, 3.0);
    assert_eq(5.0 - 3.0, 2.0);
    assert_eq(2.0 * 3.0, 6.0);
    assert_eq(10.0 / 2.0, 5.0);
}

fn test_float_negative() {
    assert_eq(-1.5 + 1.5, 0.0);
    assert_eq(-2.0 * 3.0, -6.0);
    assert_eq(-6.0 / -2.0, 3.0);
}

fn test_float_fractional() {
    assert_eq(7.0 / 2.0, 3.5);
    assert_eq(1.0 / 4.0, 0.25);
    assert_eq(3.0 / 4.0, 0.75);
}

fn test_float_comparison() {
    assert(1.5 < 2.5);
    assert(3.14 > 2.71);
    assert(1.0 == 1.0);
    assert(0.0 == 0.0);
    assert(1.0 != 2.0);
}

fn test_float_special_values() {
    // Infinity
    let inf = 1.0 / 0.0;
    assert(inf > 1000000.0);
    // Negative infinity
    let neg_inf = -1.0 / 0.0;
    assert(neg_inf < -1000000.0);
}

// =============================================================================
// Bitwise operations
// =============================================================================

fn test_bitwise_and() {
    assert_eq(0xFF & 0x0F, 0x0F);
    assert_eq(0xFF & 0x00, 0x00);
    assert_eq(0xFF & 0xFF, 0xFF);
    assert_eq(6 & 3, 2);
    assert_eq(12 & 10, 8);
}

fn test_bitwise_or() {
    assert_eq(0xF0 | 0x0F, 0xFF);
    assert_eq(0x00 | 0x00, 0x00);
    assert_eq(1 | 2, 3);
    assert_eq(4 | 8, 12);
}

fn test_bitwise_xor() {
    assert_eq(0xFF ^ 0xFF, 0x00);
    assert_eq(0xFF ^ 0x00, 0xFF);
    assert_eq(5 ^ 3, 6);
    assert_eq(10 ^ 10, 0);
}

fn test_shift_left() {
    assert_eq(1 << 0, 1);
    assert_eq(1 << 1, 2);
    assert_eq(1 << 2, 4);
    assert_eq(1 << 3, 8);
    assert_eq(1 << 10, 1024);
    assert_eq(3 << 4, 48);
}

fn test_shift_right() {
    assert_eq(1024 >> 10, 1);
    assert_eq(16 >> 2, 4);
    assert_eq(255 >> 4, 15);
    assert_eq(8 >> 3, 1);
    assert_eq(1 >> 0, 1);
}

fn test_bitwise_identity() {
    let x = 42;
    // x & x == x
    assert_eq(x & x, x);
    // x | x == x
    assert_eq(x | x, x);
    // x ^ x == 0
    assert_eq(x ^ x, 0);
    // x ^ 0 == x
    assert_eq(x ^ 0, x);
}

// =============================================================================
// Math functions (intrinsics)
// =============================================================================

fn test_abs_int() {
    fn abs(x: Int) -> Int {
        if x < 0 { -x } else { x }
    }
    assert_eq(abs(5), 5);
    assert_eq(abs(-5), 5);
    assert_eq(abs(0), 0);
}

fn test_max_min() {
    fn max_val(a: Int, b: Int) -> Int {
        if a > b { a } else { b }
    }
    fn min_val(a: Int, b: Int) -> Int {
        if a < b { a } else { b }
    }
    assert_eq(max_val(3, 7), 7);
    assert_eq(max_val(10, -5), 10);
    assert_eq(min_val(3, 7), 3);
    assert_eq(min_val(10, -5), -5);
}

fn test_power_iterative() {
    fn power(base: Int, exp: Int) -> Int {
        let mut result = 1;
        let mut i = 0;
        while i < exp {
            result = result * base;
            i = i + 1;
        }
        result
    }
    assert_eq(power(2, 0), 1);
    assert_eq(power(2, 1), 2);
    assert_eq(power(2, 10), 1024);
    assert_eq(power(3, 3), 27);
    assert_eq(power(10, 3), 1000);
}

fn test_gcd() {
    fn gcd(a: Int, b: Int) -> Int {
        let mut x = a;
        let mut y = b;
        while y != 0 {
            let temp = y;
            y = x % y;
            x = temp;
        }
        x
    }
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(17, 13), 1);
    assert_eq(gcd(0, 5), 5);
}

fn test_fibonacci() {
    fn fib(n: Int) -> Int {
        let mut a = 0;
        let mut b = 1;
        let mut i = 0;
        while i < n {
            let temp = b;
            b = a + b;
            a = temp;
            i = i + 1;
        }
        a
    }
    assert_eq(fib(0), 0);
    assert_eq(fib(1), 1);
    assert_eq(fib(2), 1);
    assert_eq(fib(5), 5);
    assert_eq(fib(10), 55);
    assert_eq(fib(20), 6765);
}

fn main() -> Int {
    test_int_overflow_large();
    test_int_div_truncation();
    test_int_modulo();
    test_int_negative_arithmetic();
    test_int_associativity();
    test_int_distributive();
    test_float_basic_ops();
    test_float_negative();
    test_float_fractional();
    test_float_comparison();
    test_float_special_values();
    test_bitwise_and();
    test_bitwise_or();
    test_bitwise_xor();
    test_shift_left();
    test_shift_right();
    test_bitwise_identity();
    test_abs_int();
    test_max_min();
    test_power_iterative();
    test_gcd();
    test_fibonacci();
    print("[OK] 179_interp_math");
    0
}
