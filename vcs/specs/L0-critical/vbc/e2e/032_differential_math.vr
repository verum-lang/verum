// @test: differential
// @tier: 0
// @level: L0
// @tags: vbc, e2e, differential, interpreter-vs-aot, math, integer
// @timeout: 30000
// @expected-exit: 0
//
// Differential math test: verifies interpreter and AOT produce identical results
// for integer math operations (ipow, mod_ipow, gcd, lcm, isqrt, abs).

// Integer power: base^exp
fn ipow(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < exp {
        result = result * base;
        i = i + 1;
    }
    result
}

// Fast exponentiation by squaring
fn fast_ipow(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut b = base;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = result * b;
        }
        b = b * b;
        e = e / 2;
    }
    result
}

// Modular exponentiation: (base^exp) % modulus
fn mod_ipow(base: Int, exp: Int, modulus: Int) -> Int {
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % modulus;
        }
        b = (b * b) % modulus;
        e = e / 2;
    }
    result
}

// GCD using Euclidean algorithm (iterative)
fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y != 0 {
        let tmp = y;
        y = x % y;
        x = tmp;
    }
    x
}

// LCM using gcd
fn lcm(a: Int, b: Int) -> Int {
    if a == 0 || b == 0 { 0 }
    else { (a / gcd(a, b)) * b }
}

// Integer square root (floor)
fn isqrt(n: Int) -> Int {
    if n <= 0 { 0 }
    else {
        let mut x = n;
        let mut y = (x + 1) / 2;
        while y < x {
            x = y;
            y = (x + n / x) / 2;
        }
        x
    }
}

// Absolute value
fn abs_val(n: Int) -> Int {
    if n < 0 { 0 - n } else { n }
}

// Integer log base 2 (floor)
fn ilog2(n: Int) -> Int {
    let mut x = n;
    let mut result = 0;
    while x > 1 {
        x = x / 2;
        result = result + 1;
    }
    result
}

// Sum of digits
fn digit_sum(n: Int) -> Int {
    let mut x = n;
    let mut sum = 0;
    while x > 0 {
        sum = sum + x % 10;
        x = x / 10;
    }
    sum
}

// Number of digits
fn digit_count(n: Int) -> Int {
    if n == 0 { 1 }
    else {
        let mut x = n;
        let mut count = 0;
        while x > 0 {
            count = count + 1;
            x = x / 10;
        }
        count
    }
}

// Check coprime
fn is_coprime(a: Int, b: Int) -> Bool {
    gcd(a, b) == 1
}

fn main() -> Int {
    // --- ipow ---
    assert_eq(ipow(2, 0), 1);
    assert_eq(ipow(2, 1), 2);
    assert_eq(ipow(2, 10), 1024);
    assert_eq(ipow(3, 5), 243);
    assert_eq(ipow(5, 3), 125);
    assert_eq(ipow(7, 2), 49);
    assert_eq(ipow(1, 100), 1);
    assert_eq(ipow(10, 6), 1000000);

    // --- fast_ipow matches ipow ---
    assert_eq(fast_ipow(2, 0), ipow(2, 0));
    assert_eq(fast_ipow(2, 10), ipow(2, 10));
    assert_eq(fast_ipow(3, 5), ipow(3, 5));
    assert_eq(fast_ipow(5, 3), ipow(5, 3));
    assert_eq(fast_ipow(7, 4), ipow(7, 4));
    assert_eq(fast_ipow(10, 6), ipow(10, 6));
    assert_eq(fast_ipow(13, 3), ipow(13, 3));

    // --- mod_ipow ---
    assert_eq(mod_ipow(2, 10, 1000), 24);   // 1024 % 1000
    assert_eq(mod_ipow(3, 5, 100), 43);     // 243 % 100
    assert_eq(mod_ipow(7, 3, 13), 5);       // 343 % 13
    assert_eq(mod_ipow(2, 0, 7), 1);        // anything^0 = 1
    assert_eq(mod_ipow(5, 1, 3), 2);        // 5 % 3
    // Fermat's little theorem: a^(p-1) = 1 (mod p) for prime p
    assert_eq(mod_ipow(2, 6, 7), 1);
    assert_eq(mod_ipow(3, 12, 13), 1);
    assert_eq(mod_ipow(5, 10, 11), 1);
    assert_eq(mod_ipow(2, 16, 17), 1);

    // --- gcd ---
    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(17, 13), 1);
    assert_eq(gcd(0, 5), 5);
    assert_eq(gcd(5, 0), 5);
    assert_eq(gcd(12, 12), 12);
    assert_eq(gcd(1, 1000000), 1);
    assert_eq(gcd(36, 24), 12);
    assert_eq(gcd(270, 192), 6);
    // gcd is commutative
    assert_eq(gcd(48, 18), gcd(18, 48));
    assert_eq(gcd(100, 75), gcd(75, 100));

    // --- lcm ---
    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(3, 5), 15);
    assert_eq(lcm(12, 18), 36);
    assert_eq(lcm(7, 7), 7);
    assert_eq(lcm(1, 100), 100);
    assert_eq(lcm(0, 5), 0);
    assert_eq(lcm(5, 0), 0);
    // gcd * lcm = a * b (for positive a, b)
    assert_eq(gcd(12, 18) * lcm(12, 18), 12 * 18);
    assert_eq(gcd(4, 6) * lcm(4, 6), 4 * 6);
    assert_eq(gcd(15, 25) * lcm(15, 25), 15 * 25);

    // --- isqrt ---
    assert_eq(isqrt(0), 0);
    assert_eq(isqrt(1), 1);
    assert_eq(isqrt(4), 2);
    assert_eq(isqrt(9), 3);
    assert_eq(isqrt(16), 4);
    assert_eq(isqrt(25), 5);
    assert_eq(isqrt(100), 10);
    assert_eq(isqrt(144), 12);
    // Non-perfect squares: floor
    assert_eq(isqrt(2), 1);
    assert_eq(isqrt(3), 1);
    assert_eq(isqrt(5), 2);
    assert_eq(isqrt(8), 2);
    assert_eq(isqrt(10), 3);
    assert_eq(isqrt(99), 9);
    assert_eq(isqrt(101), 10);
    // Verify: isqrt(n)^2 <= n < (isqrt(n)+1)^2
    let mut k = 1;
    while k <= 50 {
        let s = isqrt(k);
        assert(s * s <= k);
        assert((s + 1) * (s + 1) > k);
        k = k + 1;
    }

    // --- abs_val ---
    assert_eq(abs_val(0), 0);
    assert_eq(abs_val(5), 5);
    assert_eq(abs_val(0 - 5), 5);
    assert_eq(abs_val(0 - 1), 1);
    assert_eq(abs_val(100), 100);
    assert_eq(abs_val(0 - 999), 999);

    // --- ilog2 ---
    assert_eq(ilog2(1), 0);
    assert_eq(ilog2(2), 1);
    assert_eq(ilog2(3), 1);
    assert_eq(ilog2(4), 2);
    assert_eq(ilog2(7), 2);
    assert_eq(ilog2(8), 3);
    assert_eq(ilog2(16), 4);
    assert_eq(ilog2(1024), 10);
    assert_eq(ilog2(1023), 9);

    // --- digit_sum ---
    assert_eq(digit_sum(123), 6);
    assert_eq(digit_sum(999), 27);
    assert_eq(digit_sum(1000), 1);
    assert_eq(digit_sum(12345), 15);

    // --- digit_count ---
    assert_eq(digit_count(0), 1);
    assert_eq(digit_count(5), 1);
    assert_eq(digit_count(42), 2);
    assert_eq(digit_count(999), 3);
    assert_eq(digit_count(10000), 5);

    // --- coprimality ---
    assert(is_coprime(3, 5));
    assert(is_coprime(7, 11));
    assert(is_coprime(1, 100));
    assert(!is_coprime(4, 6));
    assert(!is_coprime(12, 18));

    print("[OK] 032_differential_math");
    0
}
