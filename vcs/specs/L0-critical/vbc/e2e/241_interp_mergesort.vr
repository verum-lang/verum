// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, mergesort, sorting
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: merge sort on fixed-size record arrays

// =============================================================================
// Array type and accessors (8 elements)
// =============================================================================

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn arr_new() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

fn arr_get(arr: Arr8, idx: Int) -> Int {
    if idx == 0 { arr.a0 }
    else if idx == 1 { arr.a1 }
    else if idx == 2 { arr.a2 }
    else if idx == 3 { arr.a3 }
    else if idx == 4 { arr.a4 }
    else if idx == 5 { arr.a5 }
    else if idx == 6 { arr.a6 }
    else if idx == 7 { arr.a7 }
    else { -1 }
}

fn arr_set(arr: Arr8, idx: Int, val: Int) -> Arr8 {
    Arr8 {
        a0: if idx == 0 { val } else { arr.a0 },
        a1: if idx == 1 { val } else { arr.a1 },
        a2: if idx == 2 { val } else { arr.a2 },
        a3: if idx == 3 { val } else { arr.a3 },
        a4: if idx == 4 { val } else { arr.a4 },
        a5: if idx == 5 { val } else { arr.a5 },
        a6: if idx == 6 { val } else { arr.a6 },
        a7: if idx == 7 { val } else { arr.a7 },
    }
}

// =============================================================================
// Check if subarray [lo..hi) is sorted
// =============================================================================

fn is_sorted(arr: Arr8, lo: Int, hi: Int) -> Bool {
    let mut i = lo;
    while i < hi - 1 {
        if arr_get(arr, i) > arr_get(arr, i + 1) {
            return false;
        }
        i = i + 1;
    }
    true
}

// =============================================================================
// Merge: merge sorted halves [lo..mid) and [mid..hi) into arr
// Uses a temporary array for merging
// =============================================================================

fn merge(arr: Arr8, lo: Int, mid: Int, hi: Int) -> Arr8 {
    // Copy arr to temp
    let tmp = arr;
    let mut result = arr;
    let mut i = lo;
    let mut j = mid;
    let mut k = lo;
    while k < hi {
        if i < mid {
            if j < hi {
                if arr_get(tmp, i) <= arr_get(tmp, j) {
                    result = arr_set(result, k, arr_get(tmp, i));
                    i = i + 1;
                } else {
                    result = arr_set(result, k, arr_get(tmp, j));
                    j = j + 1;
                }
            } else {
                result = arr_set(result, k, arr_get(tmp, i));
                i = i + 1;
            }
        } else {
            result = arr_set(result, k, arr_get(tmp, j));
            j = j + 1;
        }
        k = k + 1;
    }
    result
}

// =============================================================================
// Merge sort (recursive)
// =============================================================================

@allow(unbounded_recursion)
fn mergesort(arr: Arr8, lo: Int, hi: Int) -> Arr8 {
    if hi - lo <= 1 {
        arr
    } else {
        let mid = lo + (hi - lo) / 2;
        let sorted_left = mergesort(arr, lo, mid);
        let sorted_both = mergesort(sorted_left, mid, hi);
        merge(sorted_both, lo, mid, hi)
    }
}

fn sort8(arr: Arr8) -> Arr8 {
    mergesort(arr, 0, 8)
}

// =============================================================================
// Tests
// =============================================================================

fn test_basic_sort() {
    // Reverse order
    let mut a = arr_new();
    a = arr_set(a, 0, 8);
    a = arr_set(a, 1, 7);
    a = arr_set(a, 2, 6);
    a = arr_set(a, 3, 5);
    a = arr_set(a, 4, 4);
    a = arr_set(a, 5, 3);
    a = arr_set(a, 6, 2);
    a = arr_set(a, 7, 1);
    let s = sort8(a);
    assert_eq(arr_get(s, 0), 1);
    assert_eq(arr_get(s, 1), 2);
    assert_eq(arr_get(s, 2), 3);
    assert_eq(arr_get(s, 3), 4);
    assert_eq(arr_get(s, 4), 5);
    assert_eq(arr_get(s, 5), 6);
    assert_eq(arr_get(s, 6), 7);
    assert_eq(arr_get(s, 7), 8);
    assert(is_sorted(s, 0, 8));
}

fn test_already_sorted() {
    let mut a = arr_new();
    a = arr_set(a, 0, 1);
    a = arr_set(a, 1, 2);
    a = arr_set(a, 2, 3);
    a = arr_set(a, 3, 4);
    a = arr_set(a, 4, 5);
    a = arr_set(a, 5, 6);
    a = arr_set(a, 6, 7);
    a = arr_set(a, 7, 8);
    let s = sort8(a);
    assert(is_sorted(s, 0, 8));
    assert_eq(arr_get(s, 0), 1);
    assert_eq(arr_get(s, 7), 8);
}

fn test_duplicates() {
    let mut a = arr_new();
    a = arr_set(a, 0, 3);
    a = arr_set(a, 1, 1);
    a = arr_set(a, 2, 4);
    a = arr_set(a, 3, 1);
    a = arr_set(a, 4, 5);
    a = arr_set(a, 5, 9);
    a = arr_set(a, 6, 2);
    a = arr_set(a, 7, 6);
    let s = sort8(a);
    assert(is_sorted(s, 0, 8));
    assert_eq(arr_get(s, 0), 1);
    assert_eq(arr_get(s, 1), 1);
    assert_eq(arr_get(s, 7), 9);
}

fn test_all_same() {
    let mut a = arr_new();
    let mut i = 0;
    while i < 8 {
        a = arr_set(a, i, 42);
        i = i + 1;
    }
    let s = sort8(a);
    assert(is_sorted(s, 0, 8));
    assert_eq(arr_get(s, 0), 42);
    assert_eq(arr_get(s, 7), 42);
}

fn test_negatives() {
    let mut a = arr_new();
    a = arr_set(a, 0, -5);
    a = arr_set(a, 1, 3);
    a = arr_set(a, 2, -1);
    a = arr_set(a, 3, 7);
    a = arr_set(a, 4, -3);
    a = arr_set(a, 5, 0);
    a = arr_set(a, 6, 2);
    a = arr_set(a, 7, -8);
    let s = sort8(a);
    assert(is_sorted(s, 0, 8));
    assert_eq(arr_get(s, 0), -8);
    assert_eq(arr_get(s, 1), -5);
    assert_eq(arr_get(s, 2), -3);
    assert_eq(arr_get(s, 3), -1);
    assert_eq(arr_get(s, 4), 0);
    assert_eq(arr_get(s, 5), 2);
    assert_eq(arr_get(s, 6), 3);
    assert_eq(arr_get(s, 7), 7);
}

fn test_partial_sort() {
    // Sort only part of the array [2..6)
    let mut a = arr_new();
    a = arr_set(a, 0, 99);
    a = arr_set(a, 1, 88);
    a = arr_set(a, 2, 50);
    a = arr_set(a, 3, 10);
    a = arr_set(a, 4, 40);
    a = arr_set(a, 5, 20);
    a = arr_set(a, 6, 77);
    a = arr_set(a, 7, 66);
    let s = mergesort(a, 2, 6);
    // Elements outside [2..6) remain unchanged
    assert_eq(arr_get(s, 0), 99);
    assert_eq(arr_get(s, 1), 88);
    // Elements [2..6) are sorted
    assert_eq(arr_get(s, 2), 10);
    assert_eq(arr_get(s, 3), 20);
    assert_eq(arr_get(s, 4), 40);
    assert_eq(arr_get(s, 5), 50);
    // Rest unchanged
    assert_eq(arr_get(s, 6), 77);
    assert_eq(arr_get(s, 7), 66);
}

fn main() -> Int {
    test_basic_sort();
    test_already_sorted();
    test_duplicates();
    test_all_same();
    test_negatives();
    test_partial_sort();
    print("[OK] 241_interp_mergesort");
    0
}
