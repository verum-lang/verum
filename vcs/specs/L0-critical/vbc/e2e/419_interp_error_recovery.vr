// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, error, recovery, variants
// @timeout: 15000
// @expected-exit: 0
//
// Tests error handling patterns using Result-like variants.

type Result is Ok(Int) | Err(Text);

fn result_value(r: Result) -> Int {
    match r {
        Ok(v) => v,
        Err(msg) => -1,
    }
}

fn result_is_ok(r: Result) -> Int {
    match r {
        Ok(v) => 1,
        Err(msg) => 0,
    }
}

fn safe_divide(a: Int, b: Int) -> Result {
    if b == 0 {
        Err("division by zero")
    } else {
        Ok(a / b)
    }
}

fn safe_sqrt_int(n: Int) -> Result {
    if n < 0 {
        Err("negative input")
    } else {
        // Integer square root via Newton's method
        if n == 0 { return Ok(0); }
        let mut x = n;
        let mut y = (x + 1) / 2;
        while y < x {
            x = y;
            y = (x + n / x) / 2;
        }
        Ok(x)
    }
}

fn test_safe_divide() {
    let r1 = safe_divide(10, 3);
    assert_eq(result_is_ok(r1), 1);
    assert_eq(result_value(r1), 3);

    let r2 = safe_divide(10, 0);
    assert_eq(result_is_ok(r2), 0);
    assert_eq(result_value(r2), -1);

    let r3 = safe_divide(100, 7);
    assert_eq(result_value(r3), 14);
    print("safe_divide: ok");
}

fn test_safe_sqrt() {
    let r1 = safe_sqrt_int(25);
    assert_eq(result_value(r1), 5);

    let r2 = safe_sqrt_int(100);
    assert_eq(result_value(r2), 10);

    let r3 = safe_sqrt_int(-1);
    assert_eq(result_is_ok(r3), 0);

    let r4 = safe_sqrt_int(0);
    assert_eq(result_value(r4), 0);

    let r5 = safe_sqrt_int(144);
    assert_eq(result_value(r5), 12);
    print("safe_sqrt: ok");
}

fn test_chained_operations() {
    // Chain: divide then sqrt
    let r1 = safe_divide(100, 4);
    let final_result = if result_is_ok(r1) == 1 {
        safe_sqrt_int(result_value(r1))
    } else {
        Err("upstream error")
    };
    assert_eq(result_value(final_result), 5); // sqrt(25) = 5
    print("chained_operations: ok");
}

fn test_error_accumulation() {
    // Try multiple operations, count successes and failures
    let mut successes = 0;
    let mut failures = 0;
    let divisors = [3, 0, 7, 0, 2, 0, 11, 0, 5, 1];
    let mut i = 0;
    while i < 10 {
        let r = safe_divide(100, divisors[i]);
        if result_is_ok(r) == 1 {
            successes = successes + 1;
        } else {
            failures = failures + 1;
        }
        i = i + 1;
    }
    assert_eq(successes, 6);
    assert_eq(failures, 4);
    print("error_accumulation: ok");
}

fn test_fallback_values() {
    // Use default value on error
    let results = [0, 0, 0, 0, 0];
    let mut arr = [0, 0, 0, 0, 0];
    let denominators = [2, 0, 4, 0, 5];

    let mut i = 0;
    while i < 5 {
        let r = safe_divide(100, denominators[i]);
        arr[i] = if result_is_ok(r) == 1 { result_value(r) } else { 0 };
        i = i + 1;
    }
    assert_eq(arr[0], 50);
    assert_eq(arr[1], 0);   // fallback
    assert_eq(arr[2], 25);
    assert_eq(arr[3], 0);   // fallback
    assert_eq(arr[4], 20);
    print("fallback_values: ok");
}

fn test_result_map() {
    // Map over result
    let r = safe_divide(20, 4);
    let mapped = if result_is_ok(r) == 1 {
        Ok(result_value(r) * 10)
    } else {
        r
    };
    assert_eq(result_value(mapped), 50);
    print("result_map: ok");
}

fn main() -> Int {
    test_safe_divide();
    test_safe_sqrt();
    test_chained_operations();
    test_error_accumulation();
    test_fallback_values();
    test_result_map();
    print("[OK] 419_interp_error_recovery");
    0
}
