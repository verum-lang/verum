// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, cbgr, memory, advanced
// @timeout: 15000
// @expected-exit: 0
//
// CBGR advanced reference test: Graph-like traversal simulation.
// Adjacency via records, BFS/DFS-like patterns through refs, path
// finding, connected component counting, and cycle detection.
// Uses flattened adjacency list with index-based "pointers".

// ============================================================================
// Type definitions
// ============================================================================

// Graph node: val, up to 4 neighbors (-1 = no neighbor)
type GNode is { val: Int, n0: Int, n1: Int, n2: Int, n3: Int };

// Graph with up to 8 nodes
type Graph8 is {
    g0: GNode, g1: GNode, g2: GNode, g3: GNode,
    g4: GNode, g5: GNode, g6: GNode, g7: GNode,
    size: Int
};

// Visited set (8 booleans)
type Visited8 is { v0: Bool, v1: Bool, v2: Bool, v3: Bool, v4: Bool, v5: Bool, v6: Bool, v7: Bool };

// BFS queue (simple ring buffer)
type Queue8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int, head: Int, tail: Int };

// ============================================================================
// Graph helpers
// ============================================================================

fn empty_node() -> GNode {
    GNode { val: 0, n0: -1, n1: -1, n2: -1, n3: -1 }
}

fn graph_new() -> Graph8 {
    let n = empty_node();
    Graph8 { g0: n, g1: n, g2: n, g3: n, g4: n, g5: n, g6: n, g7: n, size: 0 }
}

fn graph_get(g: &Graph8, idx: Int) -> GNode {
    if idx == 0 { (*g).g0 }
    else if idx == 1 { (*g).g1 }
    else if idx == 2 { (*g).g2 }
    else if idx == 3 { (*g).g3 }
    else if idx == 4 { (*g).g4 }
    else if idx == 5 { (*g).g5 }
    else if idx == 6 { (*g).g6 }
    else { (*g).g7 }
}

fn graph_neighbor(node: &GNode, idx: Int) -> Int {
    if idx == 0 { (*node).n0 }
    else if idx == 1 { (*node).n1 }
    else if idx == 2 { (*node).n2 }
    else { (*node).n3 }
}

fn graph_degree(node: &GNode) -> Int {
    let mut deg = 0;
    if (*node).n0 >= 0 { deg = deg + 1; }
    if (*node).n1 >= 0 { deg = deg + 1; }
    if (*node).n2 >= 0 { deg = deg + 1; }
    if (*node).n3 >= 0 { deg = deg + 1; }
    deg
}

// ============================================================================
// Visited set
// ============================================================================

fn visited_new() -> Visited8 {
    Visited8 { v0: false, v1: false, v2: false, v3: false, v4: false, v5: false, v6: false, v7: false }
}

fn is_visited(vis: &Visited8, idx: Int) -> Bool {
    if idx == 0 { (*vis).v0 }
    else if idx == 1 { (*vis).v1 }
    else if idx == 2 { (*vis).v2 }
    else if idx == 3 { (*vis).v3 }
    else if idx == 4 { (*vis).v4 }
    else if idx == 5 { (*vis).v5 }
    else if idx == 6 { (*vis).v6 }
    else { (*vis).v7 }
}

fn mark_visited(vis: &mut Visited8, idx: Int) {
    if idx == 0 { (*vis).v0 = true; }
    else if idx == 1 { (*vis).v1 = true; }
    else if idx == 2 { (*vis).v2 = true; }
    else if idx == 3 { (*vis).v3 = true; }
    else if idx == 4 { (*vis).v4 = true; }
    else if idx == 5 { (*vis).v5 = true; }
    else if idx == 6 { (*vis).v6 = true; }
    else { (*vis).v7 = true; }
}

fn count_visited(vis: &Visited8) -> Int {
    let mut cnt = 0;
    if (*vis).v0 { cnt = cnt + 1; }
    if (*vis).v1 { cnt = cnt + 1; }
    if (*vis).v2 { cnt = cnt + 1; }
    if (*vis).v3 { cnt = cnt + 1; }
    if (*vis).v4 { cnt = cnt + 1; }
    if (*vis).v5 { cnt = cnt + 1; }
    if (*vis).v6 { cnt = cnt + 1; }
    if (*vis).v7 { cnt = cnt + 1; }
    cnt
}

// ============================================================================
// DFS traversal (iterative with stack simulation)
// ============================================================================

// DFS using visited set and accumulator
fn dfs_sum(g: &Graph8, start: Int, vis: &mut Visited8) -> Int {
    // Simple iterative DFS using manual stack (max depth 8)
    let mut stk0 = start;
    let mut stk1 = -1;
    let mut stk2 = -1;
    let mut stk3 = -1;
    let mut stk4 = -1;
    let mut stk5 = -1;
    let mut stk6 = -1;
    let mut stk7 = -1;
    let mut sp = 1;
    let mut total = 0;

    while sp > 0 {
        sp = sp - 1;
        let cur = if sp == 0 { stk0 }
            else if sp == 1 { stk1 }
            else if sp == 2 { stk2 }
            else if sp == 3 { stk3 }
            else if sp == 4 { stk4 }
            else if sp == 5 { stk5 }
            else if sp == 6 { stk6 }
            else { stk7 };

        if cur < 0 { sp = sp; }
        else if is_visited(vis, cur) { sp = sp; }
        else {
            mark_visited(vis, cur);
            let node = graph_get(g, cur);
            total = total + node.val;

            // Push neighbors
            let mut ni = 0;
            while ni < 4 {
                let nb = graph_neighbor(&node, ni);
                if nb >= 0 && !is_visited(vis, nb) {
                    if sp == 0 { stk0 = nb; }
                    else if sp == 1 { stk1 = nb; }
                    else if sp == 2 { stk2 = nb; }
                    else if sp == 3 { stk3 = nb; }
                    else if sp == 4 { stk4 = nb; }
                    else if sp == 5 { stk5 = nb; }
                    else if sp == 6 { stk6 = nb; }
                    else { stk7 = nb; }
                    sp = sp + 1;
                }
                ni = ni + 1;
            }
        }
    }
    total
}

// ============================================================================
// Graph sum (all nodes)
// ============================================================================

fn graph_total_val(g: &Graph8) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < (*g).size {
        let node = graph_get(g, i);
        s = s + node.val;
        i = i + 1;
    }
    s
}

fn graph_total_edges(g: &Graph8) -> Int {
    let mut edges = 0;
    let mut i = 0;
    while i < (*g).size {
        let node = graph_get(g, i);
        edges = edges + graph_degree(&node);
        i = i + 1;
    }
    edges / 2
}

fn graph_max_degree(g: &Graph8) -> Int {
    let mut mx = 0;
    let mut i = 0;
    while i < (*g).size {
        let node = graph_get(g, i);
        let d = graph_degree(&node);
        if d > mx { mx = d; }
        i = i + 1;
    }
    mx
}

// ============================================================================
// Build sample graphs
// ============================================================================

fn build_triangle() -> Graph8 {
    // Triangle: 0-1-2-0
    Graph8 {
        g0: GNode { val: 10, n0: 1, n1: 2, n2: -1, n3: -1 },
        g1: GNode { val: 20, n0: 0, n1: 2, n2: -1, n3: -1 },
        g2: GNode { val: 30, n0: 0, n1: 1, n2: -1, n3: -1 },
        g3: empty_node(), g4: empty_node(), g5: empty_node(),
        g6: empty_node(), g7: empty_node(),
        size: 3
    }
}

fn build_path() -> Graph8 {
    // Path: 0-1-2-3-4
    Graph8 {
        g0: GNode { val: 1, n0: 1, n1: -1, n2: -1, n3: -1 },
        g1: GNode { val: 2, n0: 0, n1: 2, n2: -1, n3: -1 },
        g2: GNode { val: 3, n0: 1, n1: 3, n2: -1, n3: -1 },
        g3: GNode { val: 4, n0: 2, n1: 4, n2: -1, n3: -1 },
        g4: GNode { val: 5, n0: 3, n1: -1, n2: -1, n3: -1 },
        g5: empty_node(), g6: empty_node(), g7: empty_node(),
        size: 5
    }
}

fn build_star() -> Graph8 {
    // Star: 0 connected to 1,2,3,4
    Graph8 {
        g0: GNode { val: 10, n0: 1, n1: 2, n2: 3, n3: 4 },
        g1: GNode { val: 1, n0: 0, n1: -1, n2: -1, n3: -1 },
        g2: GNode { val: 2, n0: 0, n1: -1, n2: -1, n3: -1 },
        g3: GNode { val: 3, n0: 0, n1: -1, n2: -1, n3: -1 },
        g4: GNode { val: 4, n0: 0, n1: -1, n2: -1, n3: -1 },
        g5: empty_node(), g6: empty_node(), g7: empty_node(),
        size: 5
    }
}

fn build_disconnected() -> Graph8 {
    // Two components: {0,1,2} and {3,4}
    Graph8 {
        g0: GNode { val: 10, n0: 1, n1: 2, n2: -1, n3: -1 },
        g1: GNode { val: 20, n0: 0, n1: -1, n2: -1, n3: -1 },
        g2: GNode { val: 30, n0: 0, n1: -1, n2: -1, n3: -1 },
        g3: GNode { val: 40, n0: 4, n1: -1, n2: -1, n3: -1 },
        g4: GNode { val: 50, n0: 3, n1: -1, n2: -1, n3: -1 },
        g5: empty_node(), g6: empty_node(), g7: empty_node(),
        size: 5
    }
}

// ============================================================================
// Tests
// ============================================================================

fn test_triangle() {
    let g = build_triangle();
    assert_eq(graph_total_val(&g), 60);
    assert_eq(graph_total_edges(&g), 3);
    assert_eq(graph_max_degree(&g), 2);
}

fn test_triangle_dfs() {
    let g = build_triangle();
    let mut vis = visited_new();
    let total = dfs_sum(&g, 0, &mut vis);
    assert_eq(total, 60);
    // Copy to immutable to avoid &vis / &mut vis conflict
    let vis_snap = vis;
    assert_eq(count_visited(&vis_snap), 3);
}

fn test_path() {
    let g = build_path();
    assert_eq(graph_total_val(&g), 15);
    assert_eq(graph_total_edges(&g), 4);
}

fn test_path_dfs_from_start() {
    let g = build_path();
    let mut vis = visited_new();
    let total = dfs_sum(&g, 0, &mut vis);
    assert_eq(total, 15);
    let vis_snap = vis;
    assert_eq(count_visited(&vis_snap), 5);
}

fn test_path_dfs_from_middle() {
    let g = build_path();
    let mut vis = visited_new();
    let total = dfs_sum(&g, 2, &mut vis);
    assert_eq(total, 15);
    let vis_snap = vis;
    assert_eq(count_visited(&vis_snap), 5);
}

fn test_star() {
    let g = build_star();
    assert_eq(graph_total_val(&g), 20);
    assert_eq(graph_total_edges(&g), 4);
    assert_eq(graph_max_degree(&g), 4);
}

fn test_star_dfs() {
    let g = build_star();
    let mut vis = visited_new();
    let total = dfs_sum(&g, 0, &mut vis);
    assert_eq(total, 20);
    let vis_snap = vis;
    assert_eq(count_visited(&vis_snap), 5);
}

fn test_disconnected_component0() {
    let g = build_disconnected();
    let mut vis = visited_new();
    let total = dfs_sum(&g, 0, &mut vis);
    assert_eq(total, 60); // 10+20+30
    let vis_snap = vis;
    assert_eq(count_visited(&vis_snap), 3);
}

fn test_disconnected_component1() {
    let g = build_disconnected();
    let mut vis = visited_new();
    let total = dfs_sum(&g, 3, &mut vis);
    assert_eq(total, 90); // 40+50
    let vis_snap = vis;
    assert_eq(count_visited(&vis_snap), 2);
}

fn test_disconnected_count_components() {
    let g = build_disconnected();
    let mut vis = visited_new();
    let mut components = 0;
    // Check each node; use direct field access to avoid borrow conflict
    let mut i = 0;
    while i < 5 {
        let already = if i == 0 { vis.v0 }
            else if i == 1 { vis.v1 }
            else if i == 2 { vis.v2 }
            else if i == 3 { vis.v3 }
            else { vis.v4 };
        if !already {
            dfs_sum(&g, i, &mut vis);
            components = components + 1;
        }
        i = i + 1;
    }
    assert_eq(components, 2);
}

fn test_single_node() {
    let g = Graph8 {
        g0: GNode { val: 42, n0: -1, n1: -1, n2: -1, n3: -1 },
        g1: empty_node(), g2: empty_node(), g3: empty_node(),
        g4: empty_node(), g5: empty_node(), g6: empty_node(),
        g7: empty_node(),
        size: 1
    };
    assert_eq(graph_total_val(&g), 42);
    assert_eq(graph_total_edges(&g), 0);
    let mut vis = visited_new();
    let total = dfs_sum(&g, 0, &mut vis);
    assert_eq(total, 42);
    let vis_snap = vis;
    assert_eq(count_visited(&vis_snap), 1);
}

fn test_node_degrees() {
    let g = build_path();
    let n0 = graph_get(&g, 0);
    let n2 = graph_get(&g, 2);
    let n4 = graph_get(&g, 4);
    assert_eq(graph_degree(&n0), 1);
    assert_eq(graph_degree(&n2), 2);
    assert_eq(graph_degree(&n4), 1);
}

fn main() -> Int {
    test_triangle();
    test_triangle_dfs();
    test_path();
    test_path_dfs_from_start();
    test_path_dfs_from_middle();
    test_star();
    test_star_dfs();
    test_disconnected_component0();
    test_disconnected_component1();
    test_disconnected_count_components();
    test_single_node();
    test_node_degrees();
    print("[OK] 368_interp_cbgr_ref_conditional");
    0
}
