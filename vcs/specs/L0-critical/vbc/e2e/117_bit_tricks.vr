// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, bitwise
// @timeout: 50000
// @expected-exit: 0
// @description: Bitwise operations — popcount, leading zeros, power-of-2, bit reverse, parity

// ============================================================================
// Popcount: count number of set bits
// ============================================================================

fn popcount(n: Int) -> Int {
    let mut val = n;
    let mut count = 0;
    while val != 0 {
        // val & 1
        let bit = val - (val / 2) * 2;
        count = count + bit;
        // unsigned right shift by 1 (logical division for positive)
        val = val / 2;
    }
    count
}

// ============================================================================
// Leading zeros for 32-bit value
// ============================================================================

fn leading_zeros_32(n: Int) -> Int {
    if n == 0 { 32 }
    else {
        let mut count = 0;
        let mut mask = 2147483648;  // 1 << 31 = 2^31
        let mut found = 0;
        let mut i = 0;
        while i < 32 {
            // Check if bit at position (31-i) is set
            // mask is 2^(31-i)
            if found == 0 {
                // Check if n >= mask (bit is set) using division
                let quo = n / mask;
                let bit = quo - (quo / 2) * 2;
                if bit == 1 {
                    found = 1;
                } else {
                    count = count + 1;
                }
            }
            mask = mask / 2;
            i = i + 1;
        }
        count
    }
}

// ============================================================================
// Power of 2 checks
// ============================================================================

fn is_power_of_2(n: Int) -> Int {
    if n <= 0 { 0 }
    else {
        // n is a power of 2 if popcount(n) == 1
        if popcount(n) == 1 { 1 } else { 0 }
    }
}

fn next_power_of_2(n: Int) -> Int {
    if n <= 1 { 1 }
    else {
        let mut p = 1;
        while p < n {
            p = p * 2;
        }
        p
    }
}

// ============================================================================
// Bit reverse for 8-bit value
// ============================================================================

fn bit_reverse_8(n: Int) -> Int {
    // Extract each bit and place in reversed position
    let b0 = n - (n / 2) * 2;              // bit 0
    let b1 = (n / 2) - (n / 4) * 2;        // bit 1
    let b2 = (n / 4) - (n / 8) * 2;        // bit 2
    let b3 = (n / 8) - (n / 16) * 2;       // bit 3
    let b4 = (n / 16) - (n / 32) * 2;      // bit 4
    let b5 = (n / 32) - (n / 64) * 2;      // bit 5
    let b6 = (n / 64) - (n / 128) * 2;     // bit 6
    let b7 = (n / 128) - (n / 256) * 2;    // bit 7

    b0 * 128 + b1 * 64 + b2 * 32 + b3 * 16 + b4 * 8 + b5 * 4 + b6 * 2 + b7
}

// ============================================================================
// Parity: 1 if odd number of set bits, 0 if even
// ============================================================================

fn parity(n: Int) -> Int {
    let pc = popcount(n);
    pc - (pc / 2) * 2
}

// ============================================================================
// Test 1: Popcount
// ============================================================================

@test
fn test_popcount() {
    assert_eq(popcount(0), 0);
    assert_eq(popcount(1), 1);
    assert_eq(popcount(255), 8);      // 0xFF = 8 bits
    assert_eq(popcount(256), 1);      // 0x100 = 1 bit
    assert_eq(popcount(7), 3);        // 0b111
    assert_eq(popcount(15), 4);       // 0b1111
    assert_eq(popcount(170), 4);      // 0b10101010 = 4 bits

    print("  test_popcount: ok");
}

// ============================================================================
// Test 2: Power of 2
// ============================================================================

@test
fn test_power_of_2() {
    assert_eq(is_power_of_2(1), 1);
    assert_eq(is_power_of_2(2), 1);
    assert_eq(is_power_of_2(4), 1);
    assert_eq(is_power_of_2(16), 1);
    assert_eq(is_power_of_2(1024), 1);

    assert_eq(is_power_of_2(0), 0);
    assert_eq(is_power_of_2(3), 0);
    assert_eq(is_power_of_2(5), 0);
    assert_eq(is_power_of_2(6), 0);

    print("  test_power_of_2: ok");
}

// ============================================================================
// Test 3: Next power of 2
// ============================================================================

@test
fn test_next_power_of_2() {
    assert_eq(next_power_of_2(1), 1);
    assert_eq(next_power_of_2(2), 2);
    assert_eq(next_power_of_2(3), 4);
    assert_eq(next_power_of_2(5), 8);
    assert_eq(next_power_of_2(7), 8);
    assert_eq(next_power_of_2(9), 16);
    assert_eq(next_power_of_2(17), 32);
    assert_eq(next_power_of_2(100), 128);

    print("  test_next_power_of_2: ok");
}

// ============================================================================
// Test 4: Bit reverse 8-bit
// ============================================================================

@test
fn test_bit_reverse_8() {
    // 0b00000001 -> 0b10000000 = 128
    assert_eq(bit_reverse_8(1), 128);

    // 0b10000000 -> 0b00000001 = 1
    assert_eq(bit_reverse_8(128), 1);

    // 0b11110000 (240) -> 0b00001111 (15)
    assert_eq(bit_reverse_8(240), 15);

    // 0b00001111 (15) -> 0b11110000 (240)
    assert_eq(bit_reverse_8(15), 240);

    // 0b10101010 (170) -> 0b01010101 (85)
    assert_eq(bit_reverse_8(170), 85);

    // Double reverse = identity
    assert_eq(bit_reverse_8(bit_reverse_8(42)), 42);

    print("  test_bit_reverse_8: ok");
}

// ============================================================================
// Test 5: Parity
// ============================================================================

@test
fn test_parity() {
    // Even number of bits -> parity 0
    assert_eq(parity(0), 0);      // 0 bits
    assert_eq(parity(3), 0);      // 2 bits (0b11)
    assert_eq(parity(5), 0);      // 2 bits (0b101)
    assert_eq(parity(255), 0);    // 8 bits

    // Odd number of bits -> parity 1
    assert_eq(parity(1), 1);      // 1 bit
    assert_eq(parity(2), 1);      // 1 bit
    assert_eq(parity(7), 1);      // 3 bits (0b111)
    assert_eq(parity(128), 1);    // 1 bit

    print("  test_parity: ok");
}

// ============================================================================
// main
// ============================================================================

fn main() -> Int {
    test_popcount();
    test_power_of_2();
    test_next_power_of_2();
    test_bit_reverse_8();
    test_parity();
    print("[OK] 117_bit_tricks");
    0
}
