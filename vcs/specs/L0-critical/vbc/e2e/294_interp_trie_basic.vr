// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, trie, prefix-tree, search
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Trie (prefix tree) insert/search using flat array storage.
// We encode "strings" as arrays of small integers (0-3 alphabet, like DNA: A=0,C=1,G=2,T=3).
// Trie nodes stored in flat arrays: children[node*4 + child_idx] = next_node.
// End-of-word marker stored separately.

// =============================================================================
// Array infrastructure
// =============================================================================

type Arr16 is {
    e0: Int, e1: Int, e2: Int, e3: Int,
    e4: Int, e5: Int, e6: Int, e7: Int,
    e8: Int, e9: Int, e10: Int, e11: Int,
    e12: Int, e13: Int, e14: Int, e15: Int
};

fn arr16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else if i == 7 { a.e7 }
    else if i == 8 { a.e8 }
    else if i == 9 { a.e9 }
    else if i == 10 { a.e10 }
    else if i == 11 { a.e11 }
    else if i == 12 { a.e12 }
    else if i == 13 { a.e13 }
    else if i == 14 { a.e14 }
    else { a.e15 }
}

fn arr16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 },
        e8: if i == 8 { v } else { a.e8 },
        e9: if i == 9 { v } else { a.e9 },
        e10: if i == 10 { v } else { a.e10 },
        e11: if i == 11 { v } else { a.e11 },
        e12: if i == 12 { v } else { a.e12 },
        e13: if i == 13 { v } else { a.e13 },
        e14: if i == 14 { v } else { a.e14 },
        e15: if i == 15 { v } else { a.e15 }
    }
}

fn arr16_fill(v: Int) -> Arr16 {
    Arr16 {
        e0: v, e1: v, e2: v, e3: v,
        e4: v, e5: v, e6: v, e7: v,
        e8: v, e9: v, e10: v, e11: v,
        e12: v, e13: v, e14: v, e15: v
    }
}

// 8-element array for "strings" (sequences of 0-3)
type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

// =============================================================================
// Trie structure using flat arrays
// Up to 16 nodes. Each node has 4 children (alphabet size 4).
// children stored as: children_table[node * 4 + char] = child_node (-1 if none)
// We need 16*4 = 64 entries. We'll use 4 Arr16 arrays, one per character.
// child_c[node] = child node index for character c at given node.
// =============================================================================

type Trie is {
    child0: Arr16,  // children for char 0 (A)
    child1: Arr16,  // children for char 1 (C)
    child2: Arr16,  // children for char 2 (G)
    child3: Arr16,  // children for char 3 (T)
    is_end: Arr16,  // 1 if node marks end of word
    count: Int       // number of nodes allocated
};

fn trie_new() -> Trie {
    // Node 0 is the root
    Trie {
        child0: arr16_fill(-1),
        child1: arr16_fill(-1),
        child2: arr16_fill(-1),
        child3: arr16_fill(-1),
        is_end: arr16_fill(0),
        count: 1
    }
}

fn trie_get_child(t: Trie, node: Int, ch: Int) -> Int {
    if ch == 0 { arr16_get(t.child0, node) }
    else if ch == 1 { arr16_get(t.child1, node) }
    else if ch == 2 { arr16_get(t.child2, node) }
    else { arr16_get(t.child3, node) }
}

fn trie_set_child(t: Trie, node: Int, ch: Int, val: Int) -> Trie {
    if ch == 0 {
        Trie { child0: arr16_set(t.child0, node, val), child1: t.child1, child2: t.child2, child3: t.child3, is_end: t.is_end, count: t.count }
    } else if ch == 1 {
        Trie { child0: t.child0, child1: arr16_set(t.child1, node, val), child2: t.child2, child3: t.child3, is_end: t.is_end, count: t.count }
    } else if ch == 2 {
        Trie { child0: t.child0, child1: t.child1, child2: arr16_set(t.child2, node, val), child3: t.child3, is_end: t.is_end, count: t.count }
    } else {
        Trie { child0: t.child0, child1: t.child1, child2: t.child2, child3: arr16_set(t.child3, node, val), is_end: t.is_end, count: t.count }
    }
}

// =============================================================================
// Insert a word (array of characters with length)
// =============================================================================

fn trie_insert(t: Trie, word: Arr8, wlen: Int) -> Trie {
    let mut cur = 0;  // start at root
    let mut tr = t;
    let mut i = 0;
    while i < wlen {
        let ch = arr8_get(word, i);
        let child = trie_get_child(tr, cur, ch);
        if child == -1 {
            // Allocate new node
            let new_node = tr.count;
            if new_node >= 15 { return tr; }  // full
            tr = trie_set_child(tr, cur, ch, new_node);
            tr = Trie { child0: tr.child0, child1: tr.child1, child2: tr.child2, child3: tr.child3, is_end: tr.is_end, count: tr.count + 1 };
            cur = new_node;
        } else {
            cur = child;
        }
        i = i + 1;
    }
    // Mark end of word
    Trie { child0: tr.child0, child1: tr.child1, child2: tr.child2, child3: tr.child3, is_end: arr16_set(tr.is_end, cur, 1), count: tr.count }
}

// =============================================================================
// Search for exact word
// =============================================================================

fn trie_search(t: Trie, word: Arr8, wlen: Int) -> Int {
    let mut cur = 0;
    let mut i = 0;
    while i < wlen {
        let ch = arr8_get(word, i);
        let child = trie_get_child(t, cur, ch);
        if child == -1 { return 0; }
        cur = child;
        i = i + 1;
    }
    arr16_get(t.is_end, cur)
}

// =============================================================================
// Prefix search: does any word start with this prefix?
// =============================================================================

fn trie_starts_with(t: Trie, prefix: Arr8, plen: Int) -> Int {
    let mut cur = 0;
    let mut i = 0;
    while i < plen {
        let ch = arr8_get(prefix, i);
        let child = trie_get_child(t, cur, ch);
        if child == -1 { return 0; }
        cur = child;
        i = i + 1;
    }
    1
}

// =============================================================================
// Tests
// =============================================================================

fn test_empty_trie() {
    let t = trie_new();
    let word = Arr8 { e0: 0, e1: 1, e2: 2, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(trie_search(t, word, 3), 0);
    assert_eq(t.count, 1);
}

fn test_single_word() {
    let mut t = trie_new();
    // Insert word "ACG" = [0, 1, 2]
    let word = Arr8 { e0: 0, e1: 1, e2: 2, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, word, 3);
    assert_eq(trie_search(t, word, 3), 1);
    // Prefix "AC" should exist
    let prefix = Arr8 { e0: 0, e1: 1, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(trie_starts_with(t, prefix, 2), 1);
    // "AC" is not a complete word
    assert_eq(trie_search(t, prefix, 2), 0);
}

fn test_multiple_words() {
    let mut t = trie_new();
    // Insert "ACG" = [0, 1, 2]
    let w1 = Arr8 { e0: 0, e1: 1, e2: 2, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w1, 3);
    // Insert "ACT" = [0, 1, 3]
    let w2 = Arr8 { e0: 0, e1: 1, e2: 3, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w2, 3);
    // Insert "GAT" = [2, 0, 3]
    let w3 = Arr8 { e0: 2, e1: 0, e2: 3, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w3, 3);

    assert_eq(trie_search(t, w1, 3), 1);
    assert_eq(trie_search(t, w2, 3), 1);
    assert_eq(trie_search(t, w3, 3), 1);

    // "ACX" not present (X=0 -> "ACA")
    let w4 = Arr8 { e0: 0, e1: 1, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(trie_search(t, w4, 3), 0);
}

fn test_prefix_sharing() {
    let mut t = trie_new();
    // "ACGT" = [0,1,2,3]
    let w1 = Arr8 { e0: 0, e1: 1, e2: 2, e3: 3, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w1, 4);
    // "ACGA" = [0,1,2,0]
    let w2 = Arr8 { e0: 0, e1: 1, e2: 2, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w2, 4);

    // They share prefix "ACG" (nodes for A, C, G)
    // Root + A + C + G + T + A(second) = 6 nodes total
    // Actually: root(0) -> A(1) -> C(2) -> G(3) -> T(4) for w1
    //                                          -> A(5) for w2 (branching at G)
    assert_eq(t.count, 6);
    assert_eq(trie_search(t, w1, 4), 1);
    assert_eq(trie_search(t, w2, 4), 1);
}

fn test_word_is_prefix_of_another() {
    let mut t = trie_new();
    // Insert "AC" = [0,1]
    let w1 = Arr8 { e0: 0, e1: 1, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w1, 2);
    // Insert "ACGT" = [0,1,2,3]
    let w2 = Arr8 { e0: 0, e1: 1, e2: 2, e3: 3, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w2, 4);

    assert_eq(trie_search(t, w1, 2), 1);
    assert_eq(trie_search(t, w2, 4), 1);
    // "ACG" not a word (only prefix)
    let w3 = Arr8 { e0: 0, e1: 1, e2: 2, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    assert_eq(trie_search(t, w3, 3), 0);
    assert_eq(trie_starts_with(t, w3, 3), 1);
}

fn test_single_char_words() {
    let mut t = trie_new();
    let w0 = Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let w1 = Arr8 { e0: 1, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let w2 = Arr8 { e0: 2, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let w3 = Arr8 { e0: 3, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w0, 1);
    t = trie_insert(t, w1, 1);
    t = trie_insert(t, w2, 1);
    t = trie_insert(t, w3, 1);

    assert_eq(trie_search(t, w0, 1), 1);
    assert_eq(trie_search(t, w1, 1), 1);
    assert_eq(trie_search(t, w2, 1), 1);
    assert_eq(trie_search(t, w3, 1), 1);
    assert_eq(t.count, 5);  // root + 4 children
}

fn test_empty_word() {
    let mut t = trie_new();
    // Insert empty word (length 0) - marks root as end
    let w = Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    t = trie_insert(t, w, 0);
    assert_eq(trie_search(t, w, 0), 1);  // empty word found
    assert_eq(trie_search(t, w, 1), 0);  // "A" not found
}

fn test_longer_words() {
    let mut t = trie_new();
    // "ACGTACGT" = [0,1,2,3,0,1,2,3] length 8
    let w = Arr8 { e0: 0, e1: 1, e2: 2, e3: 3, e4: 0, e5: 1, e6: 2, e7: 3 };
    t = trie_insert(t, w, 8);
    assert_eq(trie_search(t, w, 8), 1);
    assert_eq(trie_search(t, w, 4), 0);  // "ACGT" not marked as end
    assert_eq(trie_starts_with(t, w, 4), 1);  // but it's a prefix
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_empty_trie();
    test_single_word();
    test_multiple_words();
    test_prefix_sharing();
    test_word_is_prefix_of_another();
    test_single_char_words();
    test_empty_word();
    test_longer_words();
    print("[OK] 294_interp_trie_basic");
    0
}
