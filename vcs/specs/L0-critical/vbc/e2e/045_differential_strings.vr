// @test: differential
// @tier: 0
// @level: L0
// @tags: vbc, e2e, differential, interpreter-vs-aot, strings, print, comparison
// @timeout: 10000
// @expected-exit: 0
//
// Differential strings test: verifies interpreter and AOT produce identical
// results for integer-to-string via print, string-like operations using integer
// arrays (length, comparison, equality), and print-based output comparison.

// ============================================================================
// Fixed-size character array (simulating strings as int arrays)
// ============================================================================

type Str8 is { c0: Int, c1: Int, c2: Int, c3: Int, c4: Int, c5: Int, c6: Int, c7: Int, len: Int };

fn str8_empty() -> Str8 {
    Str8 { c0: 0, c1: 0, c2: 0, c3: 0, c4: 0, c5: 0, c6: 0, c7: 0, len: 0 }
}

fn str8_get(s: Str8, i: Int) -> Int {
    if i == 0 { s.c0 }
    else if i == 1 { s.c1 }
    else if i == 2 { s.c2 }
    else if i == 3 { s.c3 }
    else if i == 4 { s.c4 }
    else if i == 5 { s.c5 }
    else if i == 6 { s.c6 }
    else { s.c7 }
}

fn str8_set(s: Str8, i: Int, val: Int) -> Str8 {
    Str8 {
        c0: if i == 0 { val } else { s.c0 },
        c1: if i == 1 { val } else { s.c1 },
        c2: if i == 2 { val } else { s.c2 },
        c3: if i == 3 { val } else { s.c3 },
        c4: if i == 4 { val } else { s.c4 },
        c5: if i == 5 { val } else { s.c5 },
        c6: if i == 6 { val } else { s.c6 },
        c7: if i == 7 { val } else { s.c7 },
        len: s.len
    }
}

fn str8_with_len(s: Str8, new_len: Int) -> Str8 {
    Str8 {
        c0: s.c0, c1: s.c1, c2: s.c2, c3: s.c3,
        c4: s.c4, c5: s.c5, c6: s.c6, c7: s.c7,
        len: new_len
    }
}

fn str8_push(s: Str8, ch: Int) -> Str8 {
    let pos = s.len;
    let updated = str8_set(s, pos, ch);
    str8_with_len(updated, pos + 1)
}

// ============================================================================
// String comparison and equality
// ============================================================================

fn str8_equals(a: Str8, b: Str8) -> Bool {
    if a.len != b.len {
        false
    } else {
        let mut i = 0;
        let mut eq = true;
        while i < a.len {
            if str8_get(a, i) != str8_get(b, i) {
                eq = false;
            }
            i = i + 1;
        }
        eq
    }
}

// Lexicographic compare: returns <0 if a<b, 0 if a==b, >0 if a>b
fn str8_compare(a: Str8, b: Str8) -> Int {
    let min_len = if a.len < b.len { a.len } else { b.len };
    let mut i = 0;
    let mut result = 0;
    let mut found = false;
    while i < min_len {
        if !found {
            let ca = str8_get(a, i);
            let cb = str8_get(b, i);
            if ca != cb {
                result = ca - cb;
                found = true;
            }
        }
        i = i + 1;
    }
    if found { result }
    else { a.len - b.len }
}

fn test_string_equality() {
    // Build "abc" = [97, 98, 99]
    let mut s1 = str8_empty();
    s1 = str8_push(s1, 97);
    s1 = str8_push(s1, 98);
    s1 = str8_push(s1, 99);

    // Same string
    let mut s2 = str8_empty();
    s2 = str8_push(s2, 97);
    s2 = str8_push(s2, 98);
    s2 = str8_push(s2, 99);

    assert(str8_equals(s1, s2));
    assert_eq(str8_compare(s1, s2), 0);

    // Different: "abd" = [97, 98, 100]
    let mut s3 = str8_empty();
    s3 = str8_push(s3, 97);
    s3 = str8_push(s3, 98);
    s3 = str8_push(s3, 100);

    assert(!str8_equals(s1, s3));
    assert(str8_compare(s1, s3) < 0); // "abc" < "abd"
    assert(str8_compare(s3, s1) > 0);

    // Different length: "ab" = [97, 98]
    let mut s4 = str8_empty();
    s4 = str8_push(s4, 97);
    s4 = str8_push(s4, 98);

    assert(!str8_equals(s1, s4));
    assert(str8_compare(s4, s1) < 0); // shorter is less

    // Empty
    assert(str8_equals(str8_empty(), str8_empty()));
    assert_eq(str8_compare(str8_empty(), str8_empty()), 0);

    print("string_equality: ok");
}

// ============================================================================
// String length and character counting
// ============================================================================

fn str8_count_char(s: Str8, ch: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < s.len {
        if str8_get(s, i) == ch {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

fn str8_count_distinct(s: Str8) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < s.len {
        let ch = str8_get(s, i);
        let mut seen = false;
        let mut j = 0;
        while j < i {
            if str8_get(s, j) == ch {
                seen = true;
            }
            j = j + 1;
        }
        if !seen {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

fn test_string_counting() {
    // "aabbc" = [97, 97, 98, 98, 99]
    let mut s = str8_empty();
    s = str8_push(s, 97);
    s = str8_push(s, 97);
    s = str8_push(s, 98);
    s = str8_push(s, 98);
    s = str8_push(s, 99);

    assert_eq(s.len, 5);
    assert_eq(str8_count_char(s, 97), 2); // 'a' appears twice
    assert_eq(str8_count_char(s, 98), 2); // 'b' appears twice
    assert_eq(str8_count_char(s, 99), 1); // 'c' appears once
    assert_eq(str8_count_char(s, 100), 0); // 'd' not found
    assert_eq(str8_count_distinct(s), 3); // a, b, c

    // All same
    let mut same = str8_empty();
    same = str8_push(same, 65);
    same = str8_push(same, 65);
    same = str8_push(same, 65);
    assert_eq(str8_count_distinct(same), 1);
    assert_eq(str8_count_char(same, 65), 3);

    // Empty
    assert_eq(str8_count_distinct(str8_empty()), 0);

    print("string_counting: ok");
}

// ============================================================================
// String reversal
// ============================================================================

fn str8_reverse(s: Str8) -> Str8 {
    let mut result = s;
    let mut i = 0;
    let half = s.len / 2;
    while i < half {
        let j = s.len - 1 - i;
        let ci = str8_get(result, i);
        let cj = str8_get(result, j);
        result = str8_set(result, i, cj);
        result = str8_set(result, j, ci);
        i = i + 1;
    }
    result
}

fn str8_is_palindrome(s: Str8) -> Bool {
    str8_equals(s, str8_reverse(s))
}

fn test_string_reverse() {
    // "abcde" = [97, 98, 99, 100, 101]
    let mut s = str8_empty();
    s = str8_push(s, 97);
    s = str8_push(s, 98);
    s = str8_push(s, 99);
    s = str8_push(s, 100);
    s = str8_push(s, 101);

    let rev = str8_reverse(s);
    assert_eq(str8_get(rev, 0), 101);
    assert_eq(str8_get(rev, 1), 100);
    assert_eq(str8_get(rev, 2), 99);
    assert_eq(str8_get(rev, 3), 98);
    assert_eq(str8_get(rev, 4), 97);
    assert_eq(rev.len, 5);

    // Double reverse = identity
    assert(str8_equals(s, str8_reverse(rev)));

    // Palindrome: "abcba" = [97, 98, 99, 98, 97]
    let mut pal = str8_empty();
    pal = str8_push(pal, 97);
    pal = str8_push(pal, 98);
    pal = str8_push(pal, 99);
    pal = str8_push(pal, 98);
    pal = str8_push(pal, 97);
    assert(str8_is_palindrome(pal));

    // Not a palindrome
    assert(!str8_is_palindrome(s));

    // Single char is palindrome
    let mut one = str8_empty();
    one = str8_push(one, 65);
    assert(str8_is_palindrome(one));

    // Empty is palindrome
    assert(str8_is_palindrome(str8_empty()));

    print("string_reverse: ok");
}

// ============================================================================
// Integer to digit array (converting integer to its decimal digit chars)
// ============================================================================

type DigitResult is { digits: Str8, num_digits: Int };

fn int_to_digits(n: Int) -> DigitResult {
    if n == 0 {
        let mut s = str8_empty();
        s = str8_push(s, 48); // '0'
        DigitResult { digits: s, num_digits: 1 }
    } else {
        let mut val = if n < 0 { 0 - n } else { n };
        // Extract digits in reverse order
        let mut temp = str8_empty();
        let mut count = 0;
        while val > 0 {
            let digit = val % 10;
            temp = str8_push(temp, 48 + digit); // '0' + digit
            val = val / 10;
            count = count + 1;
        }
        // Reverse to get correct order
        let reversed = str8_reverse(str8_with_len(temp, count));
        DigitResult { digits: reversed, num_digits: count }
    }
}

fn test_int_to_digits() {
    // 0 -> "0"
    let r0 = int_to_digits(0);
    assert_eq(r0.num_digits, 1);
    assert_eq(str8_get(r0.digits, 0), 48); // '0'

    // 5 -> "5"
    let r1 = int_to_digits(5);
    assert_eq(r1.num_digits, 1);
    assert_eq(str8_get(r1.digits, 0), 53); // '5'

    // 42 -> "42"
    let r2 = int_to_digits(42);
    assert_eq(r2.num_digits, 2);
    assert_eq(str8_get(r2.digits, 0), 52); // '4'
    assert_eq(str8_get(r2.digits, 1), 50); // '2'

    // 123 -> "123"
    let r3 = int_to_digits(123);
    assert_eq(r3.num_digits, 3);
    assert_eq(str8_get(r3.digits, 0), 49); // '1'
    assert_eq(str8_get(r3.digits, 1), 50); // '2'
    assert_eq(str8_get(r3.digits, 2), 51); // '3'

    // 9999 -> "9999"
    let r4 = int_to_digits(9999);
    assert_eq(r4.num_digits, 4);
    assert_eq(str8_get(r4.digits, 0), 57); // '9'
    assert_eq(str8_get(r4.digits, 3), 57);

    // 10000 -> "10000"
    let r5 = int_to_digits(10000);
    assert_eq(r5.num_digits, 5);
    assert_eq(str8_get(r5.digits, 0), 49); // '1'
    assert_eq(str8_get(r5.digits, 1), 48); // '0'
    assert_eq(str8_get(r5.digits, 4), 48);

    print("int_to_digits: ok");
}

// ============================================================================
// Substring operations
// ============================================================================

fn str8_starts_with(s: Str8, prefix: Str8) -> Bool {
    if prefix.len > s.len {
        false
    } else {
        let mut i = 0;
        let mut ok = true;
        while i < prefix.len {
            if str8_get(s, i) != str8_get(prefix, i) {
                ok = false;
            }
            i = i + 1;
        }
        ok
    }
}

fn str8_ends_with(s: Str8, suffix: Str8) -> Bool {
    if suffix.len > s.len {
        false
    } else {
        let offset = s.len - suffix.len;
        let mut i = 0;
        let mut ok = true;
        while i < suffix.len {
            if str8_get(s, offset + i) != str8_get(suffix, i) {
                ok = false;
            }
            i = i + 1;
        }
        ok
    }
}

// Extract substring from start to start+sublen-1
fn str8_substr(s: Str8, start: Int, sublen: Int) -> Str8 {
    let mut result = str8_empty();
    let mut i = 0;
    while i < sublen && (start + i) < s.len {
        result = str8_push(result, str8_get(s, start + i));
        i = i + 1;
    }
    result
}

fn test_substring_ops() {
    // "hello" = [104, 101, 108, 108, 111]
    let mut s = str8_empty();
    s = str8_push(s, 104); // h
    s = str8_push(s, 101); // e
    s = str8_push(s, 108); // l
    s = str8_push(s, 108); // l
    s = str8_push(s, 111); // o

    // starts_with "he"
    let mut prefix = str8_empty();
    prefix = str8_push(prefix, 104);
    prefix = str8_push(prefix, 101);
    assert(str8_starts_with(s, prefix));

    // starts_with "hi" (false)
    let mut bad_prefix = str8_empty();
    bad_prefix = str8_push(bad_prefix, 104);
    bad_prefix = str8_push(bad_prefix, 105); // 'i' != 'e'
    assert(!str8_starts_with(s, bad_prefix));

    // ends_with "lo"
    let mut suffix = str8_empty();
    suffix = str8_push(suffix, 108);
    suffix = str8_push(suffix, 111);
    assert(str8_ends_with(s, suffix));

    // ends_with "ll" (false)
    let mut bad_suffix = str8_empty();
    bad_suffix = str8_push(bad_suffix, 108);
    bad_suffix = str8_push(bad_suffix, 108);
    assert(!str8_ends_with(s, bad_suffix));

    // Substring "ell" = s[1..4]
    let sub = str8_substr(s, 1, 3);
    assert_eq(sub.len, 3);
    assert_eq(str8_get(sub, 0), 101); // e
    assert_eq(str8_get(sub, 1), 108); // l
    assert_eq(str8_get(sub, 2), 108); // l

    // Empty prefix/suffix always match
    assert(str8_starts_with(s, str8_empty()));
    assert(str8_ends_with(s, str8_empty()));

    // Full string as prefix/suffix
    assert(str8_starts_with(s, s));
    assert(str8_ends_with(s, s));

    print("substring_ops: ok");
}

// ============================================================================
// Print-based output comparison (differential tests compare stdout)
// ============================================================================

fn test_print_integers() {
    // Print known values — differential test will compare exact output
    print("val_zero=0");
    print("val_one=1");
    print("val_neg=-1");
    print("val_big=12345");
    print("val_hundred=100");

    // Computed values via print
    let a = 17;
    let b = 23;
    let sum = a + b;
    assert_eq(sum, 40);
    let product = a * b;
    assert_eq(product, 391);

    print("sum_17_23=40");
    print("product_17_23=391");

    print("print_integers: ok");
}

fn test_print_bool_results() {
    // Print boolean-based results
    let eq_check = 5 == 5;
    assert(eq_check);
    print("5==5: true");

    let neq_check = 5 == 6;
    assert(!neq_check);
    print("5==6: false");

    let gt_check = 10 > 3;
    assert(gt_check);
    print("10>3: true");

    print("print_bools: ok");
}

fn main() -> Int {
    test_string_equality();
    test_string_counting();
    test_string_reverse();
    test_int_to_digits();
    test_substring_ops();
    test_print_integers();
    test_print_bool_results();
    print("[OK] 045_differential_strings");
    0
}
