// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, cache, simulation
// @timeout: 15000
// @expected-exit: 0
//
// Tests LRU cache simulation using arrays.

fn test_lru_cache() {
    // LRU cache with capacity 4
    let cap = 4;
    let mut cache_keys = [-1, -1, -1, -1];
    let mut cache_vals = [0, 0, 0, 0];
    let mut cache_time = [0, 0, 0, 0]; // Access time for LRU
    let mut count = 0;
    let mut clock = 0;

    let mut hits = 0;
    let mut misses = 0;

    // Access sequence: key, expected_hit
    let accesses = [1, 2, 3, 4, 1, 5, 2, 3, 1, 4];
    let n = 10;

    let mut a = 0;
    while a < n {
        let key = accesses[a];
        clock = clock + 1;

        // Search for key
        let mut found = -1;
        let mut i = 0;
        while i < cap {
            if cache_keys[i] == key {
                found = i;
                i = cap; // break
            }
            i = i + 1;
        }

        if found >= 0 {
            // Hit: update access time
            cache_time[found] = clock;
            hits = hits + 1;
        } else {
            // Miss
            misses = misses + 1;

            if count < cap {
                // Still have space
                cache_keys[count] = key;
                cache_vals[count] = key * 10;
                cache_time[count] = clock;
                count = count + 1;
            } else {
                // Evict LRU (smallest time)
                let mut lru_idx = 0;
                let mut min_time = cache_time[0];
                i = 1;
                while i < cap {
                    if cache_time[i] < min_time {
                        min_time = cache_time[i];
                        lru_idx = i;
                    }
                    i = i + 1;
                }
                cache_keys[lru_idx] = key;
                cache_vals[lru_idx] = key * 10;
                cache_time[lru_idx] = clock;
            }
        }
        a = a + 1;
    }

    // Access pattern: 1,2,3,4(all miss),1(hit),5(miss,evict 2),2(miss,evict 3),3(miss,evict 4),1(hit),4(miss,evict 5)
    assert_eq(hits, 2);
    assert_eq(misses, 8);
    print("lru_cache: ok");
}

fn test_frequency_cache() {
    // Frequency-based cache: keep most accessed items
    let cap = 3;
    let mut keys = [-1, -1, -1];
    let mut freq = [0, 0, 0];
    let mut count = 0;

    let accesses = [1, 2, 1, 3, 1, 2, 4, 1, 2, 5];
    let n = 10;

    let mut hits = 0;
    let mut a = 0;
    while a < n {
        let key = accesses[a];

        // Search
        let mut found = -1;
        let mut i = 0;
        while i < cap {
            if keys[i] == key {
                found = i;
                i = cap;
            }
            i = i + 1;
        }

        if found >= 0 {
            freq[found] = freq[found] + 1;
            hits = hits + 1;
        } else {
            if count < cap {
                keys[count] = key;
                freq[count] = 1;
                count = count + 1;
            } else {
                // Evict least frequent
                let mut min_idx = 0;
                let mut min_freq = freq[0];
                i = 1;
                while i < cap {
                    if freq[i] < min_freq {
                        min_freq = freq[i];
                        min_idx = i;
                    }
                    i = i + 1;
                }
                keys[min_idx] = key;
                freq[min_idx] = 1;
            }
        }
        a = a + 1;
    }

    assert(hits > 0);
    print("frequency_cache: ok");
}

fn main() -> Int {
    test_lru_cache();
    test_frequency_cache();
    print("[OK] 437_interp_cache_simulation");
    0
}
