// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, sorting, algorithms, bubble-sort, insertion-sort
// @timeout: 50000
// @expected-exit: 0
//
// End-to-end: sorting algorithms through VBC interpreter using flat arrays

// ============================================================================
// 8-element flat array for sorting
// ============================================================================

type Arr8 is {
    e0: Int, e1: Int, e2: Int, e3: Int,
    e4: Int, e5: Int, e6: Int, e7: Int
};

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 } else if i == 1 { a.e1 }
    else if i == 2 { a.e2 } else if i == 3 { a.e3 }
    else if i == 4 { a.e4 } else if i == 5 { a.e5 }
    else if i == 6 { a.e6 } else { a.e7 }
}

fn arr8_set(a: Arr8, i: Int, val: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { val } else { a.e0 },
        e1: if i == 1 { val } else { a.e1 },
        e2: if i == 2 { val } else { a.e2 },
        e3: if i == 3 { val } else { a.e3 },
        e4: if i == 4 { val } else { a.e4 },
        e5: if i == 5 { val } else { a.e5 },
        e6: if i == 6 { val } else { a.e6 },
        e7: if i == 7 { val } else { a.e7 }
    }
}

fn arr8_swap(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = arr8_get(a, i);
    let vj = arr8_get(a, j);
    let tmp = arr8_set(a, i, vj);
    arr8_set(tmp, j, vi)
}

fn is_sorted(a: Arr8, n: Int) -> Bool {
    let mut ok = true;
    let mut i = 0;
    while i < n - 1 {
        if arr8_get(a, i) > arr8_get(a, i + 1) {
            ok = false;
        }
        i = i + 1;
    }
    ok
}

// ============================================================================
// Bubble Sort
// ============================================================================

fn bubble_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n {
        let mut j = 0;
        while j < n - 1 - i {
            if arr8_get(arr, j) > arr8_get(arr, j + 1) {
                arr = arr8_swap(arr, j, j + 1);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

fn test_bubble_sort() {
    let a = Arr8 { e0: 5, e1: 3, e2: 8, e3: 1, e4: 9, e5: 2, e6: 7, e7: 4 };
    let sorted = bubble_sort(a, 8);
    assert(is_sorted(sorted, 8));
    assert_eq(arr8_get(sorted, 0), 1);
    assert_eq(arr8_get(sorted, 7), 9);
}

fn test_bubble_sort_already_sorted() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8 };
    let sorted = bubble_sort(a, 8);
    assert(is_sorted(sorted, 8));
    assert_eq(arr8_get(sorted, 0), 1);
    assert_eq(arr8_get(sorted, 7), 8);
}

fn test_bubble_sort_reversed() {
    let a = Arr8 { e0: 8, e1: 7, e2: 6, e3: 5, e4: 4, e5: 3, e6: 2, e7: 1 };
    let sorted = bubble_sort(a, 8);
    assert(is_sorted(sorted, 8));
    assert_eq(arr8_get(sorted, 0), 1);
}

// ============================================================================
// Selection Sort
// ============================================================================

fn selection_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if arr8_get(arr, j) < arr8_get(arr, min_idx) {
                min_idx = j;
            }
            j = j + 1;
        }
        if min_idx != i {
            arr = arr8_swap(arr, i, min_idx);
        }
        i = i + 1;
    }
    arr
}

fn test_selection_sort() {
    let a = Arr8 { e0: 64, e1: 25, e2: 12, e3: 22, e4: 11, e5: 90, e6: 45, e7: 33 };
    let sorted = selection_sort(a, 8);
    assert(is_sorted(sorted, 8));
    assert_eq(arr8_get(sorted, 0), 11);
    assert_eq(arr8_get(sorted, 7), 90);
}

// ============================================================================
// Insertion Sort
// ============================================================================

fn insertion_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 1;
    while i < n {
        let key = arr8_get(arr, i);
        let mut j = i;
        let mut searching = true;
        while searching {
            if j > 0 {
                if arr8_get(arr, j - 1) > key {
                    arr = arr8_set(arr, j, arr8_get(arr, j - 1));
                    j = j - 1;
                } else {
                    searching = false;
                }
            } else {
                searching = false;
            }
        }
        arr = arr8_set(arr, j, key);
        i = i + 1;
    }
    arr
}

fn test_insertion_sort() {
    let a = Arr8 { e0: 42, e1: 17, e2: 93, e3: 5, e4: 28, e5: 71, e6: 3, e7: 56 };
    let sorted = insertion_sort(a, 8);
    assert(is_sorted(sorted, 8));
    assert_eq(arr8_get(sorted, 0), 3);
    assert_eq(arr8_get(sorted, 7), 93);
}

fn test_insertion_sort_duplicates() {
    let a = Arr8 { e0: 3, e1: 1, e2: 4, e3: 1, e4: 5, e5: 9, e6: 2, e7: 6 };
    let sorted = insertion_sort(a, 8);
    assert(is_sorted(sorted, 8));
    assert_eq(arr8_get(sorted, 0), 1);
    assert_eq(arr8_get(sorted, 1), 1);
}

// ============================================================================
// Sorting stability and comparison
// ============================================================================

fn test_all_sorts_agree() {
    let a = Arr8 { e0: 7, e1: 2, e2: 9, e3: 4, e4: 1, e5: 6, e6: 8, e7: 3 };
    let b_sorted = bubble_sort(a, 8);
    let s_sorted = selection_sort(a, 8);
    let i_sorted = insertion_sort(a, 8);

    // All three sorts should produce the same result
    let mut k = 0;
    while k < 8 {
        assert_eq(arr8_get(b_sorted, k), arr8_get(s_sorted, k));
        assert_eq(arr8_get(s_sorted, k), arr8_get(i_sorted, k));
        k = k + 1;
    }
}

fn test_sort_single_element() {
    let a = Arr8 { e0: 42, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let sorted = bubble_sort(a, 1);
    assert_eq(arr8_get(sorted, 0), 42);
}

fn test_sort_two_elements() {
    let a = Arr8 { e0: 10, e1: 5, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let sorted = bubble_sort(a, 2);
    assert_eq(arr8_get(sorted, 0), 5);
    assert_eq(arr8_get(sorted, 1), 10);
}

fn test_sort_negative_numbers() {
    let a = Arr8 { e0: -5, e1: 3, e2: -8, e3: 1, e4: -2, e5: 7, e6: 0, e7: -1 };
    let sorted = bubble_sort(a, 8);
    assert(is_sorted(sorted, 8));
    assert_eq(arr8_get(sorted, 0), -8);
    assert_eq(arr8_get(sorted, 7), 7);
}

fn main() -> Int {
    test_bubble_sort();
    test_bubble_sort_already_sorted();
    test_bubble_sort_reversed();
    test_selection_sort();
    test_insertion_sort();
    test_insertion_sort_duplicates();
    test_all_sorts_agree();
    test_sort_single_element();
    test_sort_two_elements();
    test_sort_negative_numbers();
    print("[OK] 016_sorting_algorithms");
    0
}
