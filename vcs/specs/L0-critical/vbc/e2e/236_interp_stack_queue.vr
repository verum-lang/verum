// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, stack, queue, data-structure
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: stack (LIFO) and queue (FIFO) using array storage.
// Stack: push/pop/peek from top.
// Queue: enqueue at tail, dequeue from head.

// =============================================================================
// Fixed-size array of 10 elements
// =============================================================================

type Arr10 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int,
                v5: Int, v6: Int, v7: Int, v8: Int, v9: Int };

fn arr_get(a: Arr10, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 }
    else if i == 2 { a.v2 } else if i == 3 { a.v3 }
    else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else if i == 7 { a.v7 }
    else if i == 8 { a.v8 } else { a.v9 }
}

fn arr_set(a: Arr10, i: Int, val: Int) -> Arr10 {
    Arr10 {
        v0: if i == 0 { val } else { a.v0 },
        v1: if i == 1 { val } else { a.v1 },
        v2: if i == 2 { val } else { a.v2 },
        v3: if i == 3 { val } else { a.v3 },
        v4: if i == 4 { val } else { a.v4 },
        v5: if i == 5 { val } else { a.v5 },
        v6: if i == 6 { val } else { a.v6 },
        v7: if i == 7 { val } else { a.v7 },
        v8: if i == 8 { val } else { a.v8 },
        v9: if i == 9 { val } else { a.v9 }
    }
}

fn arr_zeros() -> Arr10 {
    Arr10 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0,
            v5: 0, v6: 0, v7: 0, v8: 0, v9: 0 }
}

// =============================================================================
// Stack (LIFO) — top index tracks the next free slot
// =============================================================================

type Stack is {
    data: Arr10,
    top: Int
};

fn stack_new() -> Stack {
    Stack { data: arr_zeros(), top: 0 }
}

fn stack_is_empty(s: Stack) -> Bool {
    s.top == 0
}

fn stack_size(s: Stack) -> Int {
    s.top
}

fn stack_push(s: Stack, val: Int) -> Stack {
    let new_data = arr_set(s.data, s.top, val);
    Stack { data: new_data, top: s.top + 1 }
}

fn stack_peek(s: Stack) -> Int {
    arr_get(s.data, s.top - 1)
}

fn stack_pop(s: Stack) -> Stack {
    Stack { data: s.data, top: s.top - 1 }
}

// =============================================================================
// Queue (FIFO) — head = front, tail = back, circular
// =============================================================================

type Queue is {
    data: Arr10,
    head: Int,
    tail: Int,
    count: Int
};

fn queue_new() -> Queue {
    Queue { data: arr_zeros(), head: 0, tail: 0, count: 0 }
}

fn queue_is_empty(q: Queue) -> Bool {
    q.count == 0
}

fn queue_size(q: Queue) -> Int {
    q.count
}

fn queue_enqueue(q: Queue, val: Int) -> Queue {
    let new_data = arr_set(q.data, q.tail, val);
    let new_tail = (q.tail + 1) % 10;
    Queue { data: new_data, head: q.head, tail: new_tail, count: q.count + 1 }
}

fn queue_front(q: Queue) -> Int {
    arr_get(q.data, q.head)
}

fn queue_dequeue(q: Queue) -> Queue {
    let new_head = (q.head + 1) % 10;
    Queue { data: q.data, head: new_head, tail: q.tail, count: q.count - 1 }
}

// =============================================================================
// Stack tests
// =============================================================================

fn test_stack_empty() {
    let s = stack_new();
    assert_eq(stack_is_empty(s), true);
    assert_eq(stack_size(s), 0);
}

fn test_stack_push_pop() {
    let mut s = stack_new();
    s = stack_push(s, 10);
    s = stack_push(s, 20);
    s = stack_push(s, 30);
    assert_eq(stack_size(s), 3);
    assert_eq(stack_is_empty(s), false);

    // LIFO order
    assert_eq(stack_peek(s), 30);
    s = stack_pop(s);
    assert_eq(stack_peek(s), 20);
    s = stack_pop(s);
    assert_eq(stack_peek(s), 10);
    s = stack_pop(s);
    assert_eq(stack_is_empty(s), true);
}

fn test_stack_peek_no_modify() {
    let mut s = stack_new();
    s = stack_push(s, 42);
    assert_eq(stack_peek(s), 42);
    assert_eq(stack_peek(s), 42);  // Peek doesn't remove
    assert_eq(stack_size(s), 1);
}

fn test_stack_many() {
    let mut s = stack_new();
    let mut i = 0;
    while i < 10 {
        s = stack_push(s, i * 100);
        i = i + 1;
    }
    assert_eq(stack_size(s), 10);
    assert_eq(stack_peek(s), 900);  // Last pushed

    // Pop all, sum the values
    let mut total = 0;
    while !stack_is_empty(s) {
        total = total + stack_peek(s);
        s = stack_pop(s);
    }
    // 0+100+200+...+900 = 4500
    assert_eq(total, 4500);
}

fn test_stack_reverse_sequence() {
    // Push 1,2,3,4,5 then pop — should get 5,4,3,2,1
    let mut s = stack_new();
    s = stack_push(s, 1);
    s = stack_push(s, 2);
    s = stack_push(s, 3);
    s = stack_push(s, 4);
    s = stack_push(s, 5);

    let mut reversed_sum = 0;
    let mut factor = 10000;
    while !stack_is_empty(s) {
        reversed_sum = reversed_sum + stack_peek(s) * factor;
        s = stack_pop(s);
        factor = factor / 10;
    }
    // 5*10000 + 4*1000 + 3*100 + 2*10 + 1*1 = 54321
    assert_eq(reversed_sum, 54321);
}

// =============================================================================
// Queue tests
// =============================================================================

fn test_queue_empty() {
    let q = queue_new();
    assert_eq(queue_is_empty(q), true);
    assert_eq(queue_size(q), 0);
}

fn test_queue_enqueue_dequeue() {
    let mut q = queue_new();
    q = queue_enqueue(q, 10);
    q = queue_enqueue(q, 20);
    q = queue_enqueue(q, 30);
    assert_eq(queue_size(q), 3);
    assert_eq(queue_is_empty(q), false);

    // FIFO order
    assert_eq(queue_front(q), 10);
    q = queue_dequeue(q);
    assert_eq(queue_front(q), 20);
    q = queue_dequeue(q);
    assert_eq(queue_front(q), 30);
    q = queue_dequeue(q);
    assert_eq(queue_is_empty(q), true);
}

fn test_queue_front_no_modify() {
    let mut q = queue_new();
    q = queue_enqueue(q, 42);
    assert_eq(queue_front(q), 42);
    assert_eq(queue_front(q), 42);  // Front doesn't remove
    assert_eq(queue_size(q), 1);
}

fn test_queue_many() {
    let mut q = queue_new();
    let mut i = 0;
    while i < 8 {
        q = queue_enqueue(q, i + 1);
        i = i + 1;
    }
    assert_eq(queue_size(q), 8);
    assert_eq(queue_front(q), 1);  // First enqueued

    // Dequeue all, verify FIFO
    let mut total = 0;
    let mut expected = 1;
    while !queue_is_empty(q) {
        assert_eq(queue_front(q), expected);
        total = total + queue_front(q);
        q = queue_dequeue(q);
        expected = expected + 1;
    }
    // 1+2+3+4+5+6+7+8 = 36
    assert_eq(total, 36);
}

fn test_queue_interleaved() {
    // Interleave enqueue and dequeue
    let mut q = queue_new();
    q = queue_enqueue(q, 1);
    q = queue_enqueue(q, 2);
    assert_eq(queue_front(q), 1);
    q = queue_dequeue(q);

    q = queue_enqueue(q, 3);
    q = queue_enqueue(q, 4);
    assert_eq(queue_front(q), 2);
    q = queue_dequeue(q);
    assert_eq(queue_front(q), 3);
    q = queue_dequeue(q);
    assert_eq(queue_front(q), 4);
    q = queue_dequeue(q);
    assert_eq(queue_is_empty(q), true);
}

// =============================================================================
// Combined: use stack to reverse queue contents
// =============================================================================

fn test_reverse_queue_with_stack() {
    // Enqueue 1,2,3,4,5 into queue
    let mut q = queue_new();
    q = queue_enqueue(q, 1);
    q = queue_enqueue(q, 2);
    q = queue_enqueue(q, 3);
    q = queue_enqueue(q, 4);
    q = queue_enqueue(q, 5);

    // Transfer to stack
    let mut s = stack_new();
    while !queue_is_empty(q) {
        s = stack_push(s, queue_front(q));
        q = queue_dequeue(q);
    }

    // Transfer back to queue (reversed)
    let mut q2 = queue_new();
    while !stack_is_empty(s) {
        q2 = queue_enqueue(q2, stack_peek(s));
        s = stack_pop(s);
    }

    // Should be 5,4,3,2,1 now
    assert_eq(queue_front(q2), 5);
    q2 = queue_dequeue(q2);
    assert_eq(queue_front(q2), 4);
    q2 = queue_dequeue(q2);
    assert_eq(queue_front(q2), 3);
    q2 = queue_dequeue(q2);
    assert_eq(queue_front(q2), 2);
    q2 = queue_dequeue(q2);
    assert_eq(queue_front(q2), 1);
    q2 = queue_dequeue(q2);
    assert_eq(queue_is_empty(q2), true);
}

fn main() -> Int {
    test_stack_empty();
    test_stack_push_pop();
    test_stack_peek_no_modify();
    test_stack_many();
    test_stack_reverse_sequence();
    test_queue_empty();
    test_queue_enqueue_dequeue();
    test_queue_front_no_modify();
    test_queue_many();
    test_queue_interleaved();
    test_reverse_queue_with_stack();
    print("[OK] 236_interp_stack_queue");
    0
}
