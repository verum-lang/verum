// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, math, gcd, lcm, number-theory
// @timeout: 50000
// @expected-exit: 0
// @description: Number theory — GCD, LCM, modular exponentiation, extended GCD

// ============================================================================
// GCD using Euclidean algorithm (iterative)
// ============================================================================

fn gcd_compute(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    // Make both positive
    if x < 0 { x = 0 - x; }
    if y < 0 { y = 0 - y; }
    while y > 0 {
        let tmp = y;
        y = x - (x / y) * y;   // x mod y
        x = tmp;
    }
    x
}

// ============================================================================
// LCM = |a * b| / gcd(a, b)
// ============================================================================

fn lcm_compute(a: Int, b: Int) -> Int {
    if a == 0 {
        0
    } else if b == 0 {
        0
    } else {
        let aa = if a < 0 { 0 - a } else { a };
        let bb = if b < 0 { 0 - b } else { b };
        let g = gcd_compute(aa, bb);
        (aa / g) * bb
    }
}

// ============================================================================
// Modular exponentiation: (base^exp) mod m using repeated squaring
// ============================================================================

fn mod_exp(base: Int, exponent: Int, m: Int) -> Int {
    let mut result = 1;
    let mut b = base - (base / m) * m;  // base mod m
    let mut e = exponent;
    while e > 0 {
        // If e is odd
        let half = e / 2;
        if e - half * 2 == 1 {
            result = (result * b) - ((result * b) / m) * m;
        }
        b = (b * b) - ((b * b) / m) * m;
        e = half;
    }
    result
}

// ============================================================================
// Extended GCD: returns (gcd, x, y) such that a*x + b*y = gcd
// Encoded as a record
// ============================================================================

type ExtGcdResult is {
    g: Int,
    x: Int,
    y: Int
};

fn ext_gcd(a: Int, b: Int) -> ExtGcdResult {
    if b == 0 {
        ExtGcdResult { g: a, x: 1, y: 0 }
    } else {
        let mut old_r = a;
        let mut r = b;
        let mut old_s = 1;
        let mut s = 0;
        let mut old_t = 0;
        let mut t = 1;

        while r > 0 {
            let q = old_r / r;

            let tmp_r = r;
            r = old_r - q * r;
            old_r = tmp_r;

            let tmp_s = s;
            s = old_s - q * s;
            old_s = tmp_s;

            let tmp_t = t;
            t = old_t - q * t;
            old_t = tmp_t;
        }

        ExtGcdResult { g: old_r, x: old_s, y: old_t }
    }
}

// ============================================================================
// Coprime check: gcd(a, b) == 1
// ============================================================================

fn are_coprime(a: Int, b: Int) -> Int {
    if gcd_compute(a, b) == 1 { 1 } else { 0 }
}

// ============================================================================
// Test 1: GCD of various pairs
// ============================================================================

@test
fn test_gcd() {
    assert_eq(gcd_compute(12, 8), 4);
    assert_eq(gcd_compute(54, 24), 6);
    assert_eq(gcd_compute(7, 13), 1);     // coprime
    assert_eq(gcd_compute(100, 75), 25);
    assert_eq(gcd_compute(0, 5), 5);
    assert_eq(gcd_compute(5, 0), 5);
    assert_eq(gcd_compute(17, 17), 17);
    assert_eq(gcd_compute(48, 18), 6);
    assert_eq(gcd_compute(1, 9999), 1);

    print("  test_gcd: ok");
}

// ============================================================================
// Test 2: LCM of various pairs
// ============================================================================

@test
fn test_lcm() {
    assert_eq(lcm_compute(4, 6), 12);
    assert_eq(lcm_compute(3, 5), 15);
    assert_eq(lcm_compute(12, 8), 24);
    assert_eq(lcm_compute(7, 13), 91);    // coprime => a*b
    assert_eq(lcm_compute(0, 5), 0);
    assert_eq(lcm_compute(6, 6), 6);
    assert_eq(lcm_compute(21, 6), 42);

    print("  test_lcm: ok");
}

// ============================================================================
// Test 3: Modular exponentiation
// ============================================================================

@test
fn test_mod_exp() {
    // 2^10 mod 1000 = 1024 mod 1000 = 24
    assert_eq(mod_exp(2, 10, 1000), 24);

    // 3^4 mod 5 = 81 mod 5 = 1
    assert_eq(mod_exp(3, 4, 5), 1);

    // 2^0 mod 7 = 1
    assert_eq(mod_exp(2, 0, 7), 1);

    // 5^3 mod 13 = 125 mod 13 = 8
    assert_eq(mod_exp(5, 3, 13), 8);

    // 7^2 mod 10 = 49 mod 10 = 9
    assert_eq(mod_exp(7, 2, 10), 9);

    // 2^16 mod 100 = 65536 mod 100 = 36
    assert_eq(mod_exp(2, 16, 100), 36);

    // 10^5 mod 7 = 100000 mod 7 = 5
    assert_eq(mod_exp(10, 5, 7), 5);

    print("  test_mod_exp: ok");
}

// ============================================================================
// Test 4: Extended GCD
// ============================================================================

@test
fn test_ext_gcd() {
    // ext_gcd(35, 15): gcd=5, 35*x + 15*y = 5
    let r1 = ext_gcd(35, 15);
    assert_eq(r1.g, 5);
    assert_eq(35 * r1.x + 15 * r1.y, 5);

    // ext_gcd(12, 8): gcd=4
    let r2 = ext_gcd(12, 8);
    assert_eq(r2.g, 4);
    assert_eq(12 * r2.x + 8 * r2.y, 4);

    // ext_gcd(7, 3): gcd=1 (coprime)
    let r3 = ext_gcd(7, 3);
    assert_eq(r3.g, 1);
    assert_eq(7 * r3.x + 3 * r3.y, 1);

    // ext_gcd(99, 78): gcd=3
    let r4 = ext_gcd(99, 78);
    assert_eq(r4.g, 3);
    assert_eq(99 * r4.x + 78 * r4.y, 3);

    print("  test_ext_gcd: ok");
}

// ============================================================================
// Test 5: Coprime detection
// ============================================================================

@test
fn test_coprime() {
    assert_eq(are_coprime(7, 13), 1);    // both prime, different
    assert_eq(are_coprime(8, 15), 1);    // 8=2^3, 15=3*5
    assert_eq(are_coprime(12, 8), 0);    // gcd=4
    assert_eq(are_coprime(1, 100), 1);   // 1 is coprime with everything
    assert_eq(are_coprime(14, 21), 0);   // gcd=7
    assert_eq(are_coprime(25, 36), 1);   // 25=5^2, 36=2^2*3^2

    print("  test_coprime: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_gcd();
    test_lcm();
    test_mod_exp();
    test_ext_gcd();
    test_coprime();
    print("[OK] 108_gcd_lcm");
    0
}
