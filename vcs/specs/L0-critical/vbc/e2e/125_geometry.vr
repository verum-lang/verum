// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, geometry, computational
// @timeout: 50000
// @expected-exit: 0
// @description: Computational geometry — distance_squared, triangle area, point-in-triangle, collinearity

// ============================================================================
// Point type: Int coordinates (scaled by 100 for precision)
// ============================================================================

type Point is { x: Int, y: Int };

fn pt(x: Int, y: Int) -> Point {
    Point { x: x, y: y }
}

// ============================================================================
// Geometric operations
// ============================================================================

// Squared distance between two points (avoids sqrt)
fn dist_sq(a: Point, b: Point) -> Int {
    let dx = b.x - a.x;
    let dy = b.y - a.y;
    dx * dx + dy * dy
}

// Cross product of vectors (p1->p2) and (p1->p3)
// Returns 2x the signed area of the triangle p1,p2,p3
fn cross_prod(p1: Point, p2: Point, p3: Point) -> Int {
    (p2.x - p1.x) * (p3.y - p1.y) - (p2.y - p1.y) * (p3.x - p1.x)
}

// 2x area of triangle (absolute value of cross product)
fn triangle_area_2x(p1: Point, p2: Point, p3: Point) -> Int {
    let cp = cross_prod(p1, p2, p3);
    if cp < 0 { 0 - cp } else { cp }
}

// Check if three points are collinear (cross product = 0)
fn collinear(p1: Point, p2: Point, p3: Point) -> Int {
    if cross_prod(p1, p2, p3) == 0 { 1 } else { 0 }
}

// Sign of integer: 1, -1, or 0
fn sign_of(x: Int) -> Int {
    if x > 0 { 1 } else if x < 0 { -1 } else { 0 }
}

// Point-in-triangle test using sign of cross products
// Returns 1 if point p is inside triangle (a, b, c), 0 otherwise
fn point_in_triangle(p: Point, a: Point, b: Point, c: Point) -> Int {
    let d1 = cross_prod(a, b, p);
    let d2 = cross_prod(b, c, p);
    let d3 = cross_prod(c, a, p);
    let s1 = sign_of(d1);
    let s2 = sign_of(d2);
    let s3 = sign_of(d3);
    // Point is inside if all cross products have the same sign (or zero)
    let has_neg = if s1 < 0 { 1 } else if s2 < 0 { 1 } else if s3 < 0 { 1 } else { 0 };
    let has_pos = if s1 > 0 { 1 } else if s2 > 0 { 1 } else if s3 > 0 { 1 } else { 0 };
    // Inside if NOT (has both negative and positive)
    if has_neg == 1 {
        if has_pos == 1 { 0 } else { 1 }
    } else { 1 }
}

// ============================================================================
// Tests
// ============================================================================

@test
fn test_distance_squared() -> Int {
    // Distance between (0,0) and (300,400) scaled by 100
    // dist^2 = 300^2 + 400^2 = 90000 + 160000 = 250000
    let a = pt(0, 0);
    let b = pt(300, 400);
    assert_eq(dist_sq(a, b), 250000);
    // Distance from point to itself = 0
    assert_eq(dist_sq(a, a), 0);
    // Unit distance: (0,0) to (100,0) -> dist^2 = 10000
    let c = pt(100, 0);
    assert_eq(dist_sq(a, c), 10000);
    0
}

@test
fn test_triangle_area() -> Int {
    // Triangle (0,0), (300,0), (0,400) -> area = 0.5 * 3 * 4 = 6
    // In scaled coords: 2x area = |300*400 - 0| = 120000
    let a = pt(0, 0);
    let b = pt(300, 0);
    let c = pt(0, 400);
    assert_eq(triangle_area_2x(a, b, c), 120000);
    // Degenerate triangle (collinear) has area 0
    let d = pt(200, 0);
    assert_eq(triangle_area_2x(a, b, d), 0);
    0
}

@test
fn test_collinear() -> Int {
    // Points on x-axis are collinear
    let a = pt(0, 0);
    let b = pt(100, 0);
    let c = pt(200, 0);
    assert_eq(collinear(a, b, c), 1);
    // Points on diagonal y=x are collinear
    let d = pt(0, 0);
    let e = pt(100, 100);
    let f = pt(200, 200);
    assert_eq(collinear(d, e, f), 1);
    // Non-collinear
    let g = pt(0, 0);
    let h = pt(100, 0);
    let k = pt(0, 100);
    assert_eq(collinear(g, h, k), 0);
    0
}

@test
fn test_point_in_triangle_inside() -> Int {
    // Triangle: (0,0), (600,0), (0,600)
    let a = pt(0, 0);
    let b = pt(600, 0);
    let c = pt(0, 600);
    // Point (100,100) is inside
    let p1 = pt(100, 100);
    assert_eq(point_in_triangle(p1, a, b, c), 1);
    // Point (200,200) is inside
    let p2 = pt(200, 200);
    assert_eq(point_in_triangle(p2, a, b, c), 1);
    0
}

@test
fn test_point_in_triangle_outside() -> Int {
    // Triangle: (0,0), (600,0), (0,600)
    let a = pt(0, 0);
    let b = pt(600, 0);
    let c = pt(0, 600);
    // Point (400,400) is outside (400+400 > 600)
    let p1 = pt(400, 400);
    assert_eq(point_in_triangle(p1, a, b, c), 0);
    // Point (-100, 100) is outside (negative x)
    let p2 = pt(-100, 100);
    assert_eq(point_in_triangle(p2, a, b, c), 0);
    0
}

fn main() -> Int {
    test_distance_squared();
    test_triangle_area();
    test_collinear();
    test_point_in_triangle_inside();
    test_point_in_triangle_outside();
    print("[OK] 125_geometry");
    0
}
