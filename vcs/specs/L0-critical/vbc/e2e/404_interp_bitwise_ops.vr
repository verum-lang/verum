// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, bitwise, operators
// @timeout: 15000
// @expected-exit: 0
//
// Tests bitwise AND, OR, XOR, NOT, shift left, shift right.

fn test_bitwise_and() {
    assert_eq(0xFF & 0x0F, 0x0F);
    assert_eq(0b1010 & 0b1100, 0b1000);
    assert_eq(255 & 128, 128);
    assert_eq(0 & 0xFFFF, 0);
    print("bitwise_and: ok");
}

fn test_bitwise_or() {
    assert_eq(0xF0 | 0x0F, 0xFF);
    assert_eq(0b1010 | 0b0101, 0b1111);
    assert_eq(1 | 2 | 4 | 8, 15);
    assert_eq(0 | 0, 0);
    print("bitwise_or: ok");
}

fn test_bitwise_xor() {
    assert_eq(0xFF ^ 0xFF, 0);
    assert_eq(0xFF ^ 0x00, 0xFF);
    assert_eq(0b1010 ^ 0b1100, 0b0110);
    // XOR is self-inverse
    let x = 42;
    let key = 0xAB;
    let encrypted = x ^ key;
    let decrypted = encrypted ^ key;
    assert_eq(decrypted, 42);
    print("bitwise_xor: ok");
}

fn test_shift_left() {
    assert_eq(1 << 0, 1);
    assert_eq(1 << 1, 2);
    assert_eq(1 << 4, 16);
    assert_eq(1 << 10, 1024);
    assert_eq(3 << 4, 48);
    print("shift_left: ok");
}

fn test_shift_right() {
    assert_eq(16 >> 1, 8);
    assert_eq(16 >> 4, 1);
    assert_eq(1024 >> 10, 1);
    assert_eq(255 >> 4, 15);
    print("shift_right: ok");
}

fn test_bit_manipulation() {
    // Set bit n
    let mut flags = 0;
    flags = flags | (1 << 0);  // Set bit 0
    flags = flags | (1 << 3);  // Set bit 3
    flags = flags | (1 << 7);  // Set bit 7
    assert_eq(flags, 137);     // 1 + 8 + 128

    // Check bit n
    assert_eq((flags >> 0) & 1, 1);  // bit 0 set
    assert_eq((flags >> 1) & 1, 0);  // bit 1 not set
    assert_eq((flags >> 3) & 1, 1);  // bit 3 set
    assert_eq((flags >> 7) & 1, 1);  // bit 7 set

    // Clear bit n
    flags = flags & (0xFFFFFFFF ^ (1 << 3));  // Clear bit 3
    assert_eq((flags >> 3) & 1, 0);  // bit 3 now clear
    assert_eq(flags, 129);  // 1 + 128

    print("bit_manipulation: ok");
}

fn test_power_of_two_check() {
    // n is power of 2 if n > 0 and (n & (n-1)) == 0
    let mut i = 1;
    let mut count = 0;
    while i <= 256 {
        if (i & (i - 1)) == 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    // Powers of 2 up to 256: 1, 2, 4, 8, 16, 32, 64, 128, 256 = 9
    assert_eq(count, 9);
    print("power_of_two_check: ok");
}

fn main() -> Int {
    test_bitwise_and();
    test_bitwise_or();
    test_bitwise_xor();
    test_shift_left();
    test_shift_right();
    test_bit_manipulation();
    test_power_of_two_check();
    print("[OK] 404_interp_bitwise_ops");
    0
}
