// @test: differential
// @tier: 0
// @level: L0
// @tags: vbc, e2e, differential, interpreter-vs-aot, sorting
// @timeout: 30000
// @expected-exit: 0
//
// Differential sorting test: verifies interpreter and AOT produce identical results
// for bubble sort, selection sort, and insertion sort on flat arrays.

// Fixed-size array of 8 elements
type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 },
    }
}

fn arr8_swap(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = arr8_get(a, i);
    let vj = arr8_get(a, j);
    let tmp = arr8_set(a, i, vj);
    arr8_set(tmp, j, vi)
}

fn is_sorted(a: Arr8, n: Int) -> Bool {
    let mut i = 0;
    let mut ok = true;
    while i < n - 1 {
        if arr8_get(a, i) > arr8_get(a, i + 1) {
            ok = false;
        }
        i = i + 1;
    }
    ok
}

fn arr_sum(a: Arr8, n: Int) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < n {
        s = s + arr8_get(a, i);
        i = i + 1;
    }
    s
}

// --- Bubble Sort ---
fn bubble_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut j = 0;
        while j < n - 1 - i {
            let left = arr8_get(arr, j);
            let right = arr8_get(arr, j + 1);
            if left > right {
                arr = arr8_swap(arr, j, j + 1);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

// --- Selection Sort ---
fn selection_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if arr8_get(arr, j) < arr8_get(arr, min_idx) {
                min_idx = j;
            }
            j = j + 1;
        }
        if min_idx != i {
            arr = arr8_swap(arr, i, min_idx);
        }
        i = i + 1;
    }
    arr
}

// --- Insertion Sort ---
fn insertion_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 1;
    while i < n {
        let key = arr8_get(arr, i);
        let mut j = i - 1;
        let mut done = false;
        while j >= 0 && !done {
            if arr8_get(arr, j) > key {
                arr = arr8_set(arr, j + 1, arr8_get(arr, j));
                j = j - 1;
            } else {
                done = true;
            }
        }
        arr = arr8_set(arr, j + 1, key);
        i = i + 1;
    }
    arr
}

fn arrays_equal(a: Arr8, b: Arr8, n: Int) -> Bool {
    let mut i = 0;
    let mut eq = true;
    while i < n {
        if arr8_get(a, i) != arr8_get(b, i) {
            eq = false;
        }
        i = i + 1;
    }
    eq
}

fn main() -> Int {
    // --- Test 1: Standard unsorted array ---
    let a1 = Arr8 { e0: 5, e1: 3, e2: 8, e3: 1, e4: 7, e5: 2, e6: 6, e7: 4 };
    let sum1 = arr_sum(a1, 8);
    assert_eq(sum1, 36);

    let bs1 = bubble_sort(a1, 8);
    let ss1 = selection_sort(a1, 8);
    let is1 = insertion_sort(a1, 8);

    assert(is_sorted(bs1, 8));
    assert(is_sorted(ss1, 8));
    assert(is_sorted(is1, 8));

    // All sorts must produce identical results
    assert(arrays_equal(bs1, ss1, 8));
    assert(arrays_equal(bs1, is1, 8));

    // Sum preserved
    assert_eq(arr_sum(bs1, 8), 36);
    assert_eq(arr_sum(ss1, 8), 36);
    assert_eq(arr_sum(is1, 8), 36);

    // Check exact order
    assert_eq(arr8_get(bs1, 0), 1);
    assert_eq(arr8_get(bs1, 1), 2);
    assert_eq(arr8_get(bs1, 2), 3);
    assert_eq(arr8_get(bs1, 3), 4);
    assert_eq(arr8_get(bs1, 4), 5);
    assert_eq(arr8_get(bs1, 5), 6);
    assert_eq(arr8_get(bs1, 6), 7);
    assert_eq(arr8_get(bs1, 7), 8);

    // --- Test 2: Already sorted ---
    let a2 = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8 };
    let bs2 = bubble_sort(a2, 8);
    let ss2 = selection_sort(a2, 8);
    let is2 = insertion_sort(a2, 8);
    assert(arrays_equal(bs2, a2, 8));
    assert(arrays_equal(ss2, a2, 8));
    assert(arrays_equal(is2, a2, 8));

    // --- Test 3: Reverse sorted ---
    let a3 = Arr8 { e0: 8, e1: 7, e2: 6, e3: 5, e4: 4, e5: 3, e6: 2, e7: 1 };
    let bs3 = bubble_sort(a3, 8);
    let ss3 = selection_sort(a3, 8);
    let is3 = insertion_sort(a3, 8);
    assert(arrays_equal(bs3, ss3, 8));
    assert(arrays_equal(bs3, is3, 8));
    assert_eq(arr8_get(bs3, 0), 1);
    assert_eq(arr8_get(bs3, 7), 8);

    // --- Test 4: All same elements ---
    let a4 = Arr8 { e0: 5, e1: 5, e2: 5, e3: 5, e4: 5, e5: 5, e6: 5, e7: 5 };
    let bs4 = bubble_sort(a4, 8);
    let ss4 = selection_sort(a4, 8);
    let is4 = insertion_sort(a4, 8);
    assert(arrays_equal(bs4, a4, 8));
    assert(arrays_equal(ss4, a4, 8));
    assert(arrays_equal(is4, a4, 8));

    // --- Test 5: Two elements ---
    let a5 = Arr8 { e0: 9, e1: 1, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let bs5 = bubble_sort(a5, 2);
    let ss5 = selection_sort(a5, 2);
    let is5 = insertion_sort(a5, 2);
    assert_eq(arr8_get(bs5, 0), 1);
    assert_eq(arr8_get(bs5, 1), 9);
    assert(arrays_equal(bs5, ss5, 2));
    assert(arrays_equal(bs5, is5, 2));

    // --- Test 6: Array with duplicates ---
    let a6 = Arr8 { e0: 3, e1: 1, e2: 4, e3: 1, e4: 5, e5: 9, e6: 2, e7: 6 };
    let bs6 = bubble_sort(a6, 8);
    let ss6 = selection_sort(a6, 8);
    let is6 = insertion_sort(a6, 8);
    assert(arrays_equal(bs6, ss6, 8));
    assert(arrays_equal(bs6, is6, 8));
    assert_eq(arr8_get(bs6, 0), 1);
    assert_eq(arr8_get(bs6, 1), 1);
    assert_eq(arr8_get(bs6, 7), 9);

    // --- Test 7: Single element ---
    let a7 = Arr8 { e0: 42, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let bs7 = bubble_sort(a7, 1);
    let ss7 = selection_sort(a7, 1);
    let is7 = insertion_sort(a7, 1);
    assert_eq(arr8_get(bs7, 0), 42);
    assert_eq(arr8_get(ss7, 0), 42);
    assert_eq(arr8_get(is7, 0), 42);

    // --- Test 8: Negative numbers ---
    let a8 = Arr8 { e0: 0 - 3, e1: 7, e2: 0 - 1, e3: 4, e4: 0 - 8, e5: 2, e6: 0 - 5, e7: 9 };
    let bs8 = bubble_sort(a8, 8);
    let ss8 = selection_sort(a8, 8);
    let is8 = insertion_sort(a8, 8);
    assert(arrays_equal(bs8, ss8, 8));
    assert(arrays_equal(bs8, is8, 8));
    assert_eq(arr8_get(bs8, 0), 0 - 8);
    assert_eq(arr8_get(bs8, 1), 0 - 5);
    assert_eq(arr8_get(bs8, 2), 0 - 3);
    assert_eq(arr8_get(bs8, 3), 0 - 1);
    assert_eq(arr8_get(bs8, 7), 9);

    print("[OK] 030_differential_sorting");
    0
}
