// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, cbgr, memory, ref-variants, sum-types
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Real CBGR references with sum types and records.
// Tests references to records containing variant-like data, pattern-based
// dispatch with refs, and complex record mutation through mutable refs.

// =============================================================================
// Types
// =============================================================================

type Shape is Circle(Int) | Square(Int) | Dimensions { w: Int, h: Int };

type Canvas is { total_area: Int, shape_count: Int };
type Bounds is { min_x: Int, min_y: Int, max_x: Int, max_y: Int };
type Pos2D is { pos_x: Int, pos_y: Int, dir: Int };
type Grid is { width: Int, height: Int, cell_count: Int };

// =============================================================================
// Functions with refs and variants
// =============================================================================

fn shape_area(s: Shape) -> Int {
    match s {
        Circle(r) => r * r * 3,
        Square(side) => side * side,
        Dimensions { w, h } => w * h,
    }
}

fn canvas_add_shape(c: &mut Canvas, s: Shape) {
    (*c).total_area = (*c).total_area + shape_area(s);
    (*c).shape_count = (*c).shape_count + 1;
}

fn canvas_avg_area(c: &Canvas) -> Int {
    if (*c).shape_count == 0 { 0 } else { (*c).total_area / (*c).shape_count }
}

fn bounds_expand(b: &mut Bounds, x: Int, y: Int) {
    if x < (*b).min_x { (*b).min_x = x; }
    if y < (*b).min_y { (*b).min_y = y; }
    if x > (*b).max_x { (*b).max_x = x; }
    if y > (*b).max_y { (*b).max_y = y; }
}

fn bounds_width(b: &Bounds) -> Int {
    (*b).max_x - (*b).min_x
}

fn bounds_height(b: &Bounds) -> Int {
    (*b).max_y - (*b).min_y
}

fn bounds_area(b: &Bounds) -> Int {
    bounds_width(b) * bounds_height(b)
}

// Pos2D direction: 0=right, 1=up, 2=left, 3=down
fn cursor_turn_left(c: &mut Pos2D) {
    (*c).dir = ((*c).dir + 1) % 4;
}

fn cursor_turn_right(c: &mut Pos2D) {
    (*c).dir = ((*c).dir + 3) % 4;
}

fn cursor_forward(c: &mut Pos2D, steps: Int) {
    let d = (*c).dir;
    if d == 0 { (*c).pos_x = (*c).pos_x + steps; }
    if d == 1 { (*c).pos_y = (*c).pos_y + steps; }
    if d == 2 { (*c).pos_x = (*c).pos_x - steps; }
    if d == 3 { (*c).pos_y = (*c).pos_y - steps; }
}

fn grid_total_cells(g: &Grid) -> Int {
    (*g).width * (*g).height
}

fn grid_resize(g: &mut Grid, new_w: Int, new_h: Int) {
    (*g).width = new_w;
    (*g).height = new_h;
    (*g).cell_count = new_w * new_h;
}

// =============================================================================
// Test: Canvas with shapes
// =============================================================================

fn test_canvas_shapes() {
    let mut canvas = Canvas { total_area: 0, shape_count: 0 };
    let cr = &mut canvas;

    canvas_add_shape(cr, Circle(5));
    assert_eq(canvas.total_area, 75);
    assert_eq(canvas.shape_count, 1);

    canvas_add_shape(cr, Square(4));
    assert_eq(canvas.total_area, 91);
    assert_eq(canvas.shape_count, 2);

    canvas_add_shape(cr, Dimensions { w: 10, h: 3 });
    assert_eq(canvas.total_area, 121);
    assert_eq(canvas.shape_count, 3);

    // avg = total_area / shape_count = 121 / 3 = 40
    assert_eq(canvas.total_area / canvas.shape_count, 40);
}

// =============================================================================
// Test: Bounds tracking with refs
// =============================================================================

fn test_bounds_tracking() {
    let mut bounds = Bounds { min_x: 0, min_y: 0, max_x: 0, max_y: 0 };
    let br = &mut bounds;

    bounds_expand(br, 5, 10);
    bounds_expand(br, -3, -7);
    bounds_expand(br, 8, 4);

    assert_eq(bounds.min_x, -3);
    assert_eq(bounds.min_y, -7);
    assert_eq(bounds.max_x, 8);
    assert_eq(bounds.max_y, 10);
    // Compute dimensions directly (avoid immutable borrow while br alive)
    assert_eq(bounds.max_x - bounds.min_x, 11);
    assert_eq(bounds.max_y - bounds.min_y, 17);
    assert_eq((bounds.max_x - bounds.min_x) * (bounds.max_y - bounds.min_y), 187);
}

// =============================================================================
// Test: Pos2D movement (turtle graphics)
// =============================================================================

fn test_cursor_movement() {
    let mut cur = Pos2D { pos_x: 0, pos_y: 0, dir: 0 };
    let cr = &mut cur;

    // Draw a square: right 10, up 10, left 10, down 10
    cursor_forward(cr, 10);
    assert_eq(cur.pos_x, 10);
    assert_eq(cur.pos_y, 0);

    cursor_turn_left(cr);
    cursor_forward(cr, 10);
    assert_eq(cur.pos_x, 10);
    assert_eq(cur.pos_y, 10);

    cursor_turn_left(cr);
    cursor_forward(cr, 10);
    assert_eq(cur.pos_x, 0);
    assert_eq(cur.pos_y, 10);

    cursor_turn_left(cr);
    cursor_forward(cr, 10);
    assert_eq(cur.pos_x, 0);
    assert_eq(cur.pos_y, 0);
}

// =============================================================================
// Test: Spiral pattern with cursor
// =============================================================================

fn test_cursor_spiral() {
    let mut cur = Pos2D { pos_x: 0, pos_y: 0, dir: 0 };
    let cr = &mut cur;

    // Spiral: 1 right, 1 up, 2 left, 2 down, 3 right, 3 up, ...
    let mut side_len = 1;
    let mut sides_done = 0;

    while side_len <= 4 {
        cursor_forward(cr, side_len);
        cursor_turn_left(cr);
        sides_done = sides_done + 1;

        cursor_forward(cr, side_len);
        cursor_turn_left(cr);
        sides_done = sides_done + 1;

        side_len = side_len + 1;
    }

    assert_eq(sides_done, 8);
    // After spiral: position should be at (-2, -2)
    assert_eq(cur.pos_x, -2);
    assert_eq(cur.pos_y, -2);
}

// =============================================================================
// Test: Grid resize via mutable ref
// =============================================================================

fn test_grid_resize() {
    let mut g = Grid { width: 10, height: 10, cell_count: 100 };
    assert_eq(g.width * g.height, 100);

    grid_resize(&mut g, 20, 15);
    assert_eq(g.width, 20);
    assert_eq(g.height, 15);
    assert_eq(g.cell_count, 300);
    assert_eq(g.width * g.height, 300);

    grid_resize(&mut g, 5, 5);
    assert_eq(g.cell_count, 25);
}

// =============================================================================
// Test: Loop with variant dispatch and ref accumulation
// =============================================================================

fn test_variant_loop_accum() {
    let mut canvas = Canvas { total_area: 0, shape_count: 0 };
    let cr = &mut canvas;

    // Add circles with radius 1..10
    let mut i = 1;
    while i <= 10 {
        canvas_add_shape(cr, Circle(i));
        i = i + 1;
    }

    assert_eq(canvas.shape_count, 10);
    // sum of i^2 * 3 for i=1..10 = 3 * 385 = 1155
    assert_eq(canvas.total_area, 1155);
}

// =============================================================================
// Test: Bounds from loop-generated points
// =============================================================================

fn test_bounds_from_loop() {
    let mut bounds = Bounds { min_x: 0, min_y: 0, max_x: 0, max_y: 0 };
    let br = &mut bounds;

    // Generate points on a diamond pattern
    let mut i = -5;
    while i <= 5 {
        let abs_i = if i < 0 { -i } else { i };
        bounds_expand(br, i * 3, (5 - abs_i) * 2);
        bounds_expand(br, i * 3, -(5 - abs_i) * 2);
        i = i + 1;
    }

    assert_eq(bounds.min_x, -15);
    assert_eq(bounds.max_x, 15);
    assert_eq(bounds.min_y, -10);
    assert_eq(bounds.max_y, 10);
}

// =============================================================================
// Test: Multiple refs to different records in same scope
// =============================================================================

fn test_multiple_record_refs() {
    let mut c1 = Canvas { total_area: 0, shape_count: 0 };
    let mut c2 = Canvas { total_area: 0, shape_count: 0 };

    let r1 = &mut c1;
    let r2 = &mut c2;

    // Distribute shapes between two canvases
    let mut i = 1;
    while i <= 20 {
        if i % 2 == 0 {
            canvas_add_shape(r1, Square(i));
        } else {
            canvas_add_shape(r2, Circle(i));
        }
        i = i + 1;
    }

    assert_eq(c1.shape_count, 10); // even: 2,4,6,...,20
    assert_eq(c2.shape_count, 10); // odd: 1,3,5,...,19

    // c1 total = 4+16+36+64+100+144+196+256+324+400 = 1540
    assert_eq(c1.total_area, 1540);
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_canvas_shapes();
    test_bounds_tracking();
    test_cursor_movement();
    test_cursor_spiral();
    test_grid_resize();
    test_variant_loop_accum();
    test_bounds_from_loop();
    test_multiple_record_refs();
    print("ref_with_variants_ok");
    0
}
