// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, bit-reversal, popcount, bit-manipulation
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for bit manipulation operations:
// 1. Bit reversal (reverse the bits of an integer)
// 2. Population count (number of set bits)
// 3. Leading/trailing zeros
// 4. Parity (odd/even number of bits)
// 5. Bit rotation
// 6. Power of two checks

// Count set bits (population count / Hamming weight)
fn popcount(n: Int) -> Int {
    let mut count = 0;
    let mut val = n;
    while val != 0 {
        count = count + (val % 2);
        val = val / 2;
    }
    count
}

// Reverse the low k bits of n
fn reverse_bits(n: Int, k: Int) -> Int {
    let mut result = 0;
    let mut val = n;
    let mut i = 0;
    while i < k {
        result = result * 2 + (val % 2);
        val = val / 2;
        i = i + 1;
    }
    result
}

// Get bit at position pos (0-indexed from LSB)
fn get_bit(n: Int, pos: Int) -> Int {
    let mut val = n;
    let mut i = 0;
    while i < pos {
        val = val / 2;
        i = i + 1;
    }
    val % 2
}

// Set bit at position pos
fn set_bit(n: Int, pos: Int) -> Int {
    let mut power = 1;
    let mut i = 0;
    while i < pos {
        power = power * 2;
        i = i + 1;
    }
    // Check if bit is already set
    if get_bit(n, pos) == 0 {
        n + power
    } else {
        n
    }
}

// Clear bit at position pos
fn clear_bit(n: Int, pos: Int) -> Int {
    let mut power = 1;
    let mut i = 0;
    while i < pos {
        power = power * 2;
        i = i + 1;
    }
    if get_bit(n, pos) == 1 {
        n - power
    } else {
        n
    }
}

// Toggle bit at position pos
fn toggle_bit(n: Int, pos: Int) -> Int {
    if get_bit(n, pos) == 0 {
        set_bit(n, pos)
    } else {
        clear_bit(n, pos)
    }
}

// Count trailing zeros (position of lowest set bit)
fn trailing_zeros(n: Int) -> Int {
    if n == 0 { return 32; } // convention
    let mut count = 0;
    let mut val = n;
    while val % 2 == 0 {
        count = count + 1;
        val = val / 2;
    }
    count
}

// Count leading zeros for a k-bit number
fn leading_zeros(n: Int, k: Int) -> Int {
    if n == 0 { return k; }
    let mut count = 0;
    let mut pos = k - 1;
    while pos >= 0 {
        if get_bit(n, pos) == 1 {
            return count;
        }
        count = count + 1;
        pos = pos - 1;
    }
    count
}

// Check if n is a power of 2
fn is_power_of_two(n: Int) -> Int {
    if n <= 0 { return 0; }
    if popcount(n) == 1 { 1 } else { 0 }
}

// Parity: 1 if odd number of bits set, 0 if even
fn parity(n: Int) -> Int {
    popcount(n) % 2
}

// Highest set bit position (-1 for 0)
fn highest_bit(n: Int) -> Int {
    if n == 0 { return -1; }
    let mut pos = 0;
    let mut val = n;
    while val > 1 {
        val = val / 2;
        pos = pos + 1;
    }
    pos
}

// Rotate left by r positions within k-bit width
fn rotate_left(n: Int, r: Int, k: Int) -> Int {
    let shift = r % k;
    if shift == 0 { return n; }
    // mask = 2^k - 1
    let mut mask = 1;
    let mut i = 0;
    while i < k {
        mask = mask * 2;
        i = i + 1;
    }
    mask = mask - 1;
    let masked = n % (mask + 1);
    let left_part = (masked * (1 << shift)) % (mask + 1);
    let right_part = masked / (1 << (k - shift));
    (left_part + right_part) % (mask + 1)
}

// Power of 2
fn pow2(e: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < e {
        result = result * 2;
        i = i + 1;
    }
    result
}

// === Tests ===

fn test_popcount_basic() {
    assert_eq(popcount(0), 0);
    assert_eq(popcount(1), 1);
    assert_eq(popcount(2), 1);
    assert_eq(popcount(3), 2);
    assert_eq(popcount(7), 3);
    assert_eq(popcount(15), 4);
    assert_eq(popcount(255), 8);
}

fn test_popcount_powers() {
    // Powers of 2 have exactly 1 bit set
    let mut i = 0;
    while i < 16 {
        assert_eq(popcount(pow2(i)), 1);
        i = i + 1;
    }
}

fn test_popcount_minus_one() {
    // 2^k - 1 has k bits set
    assert_eq(popcount(pow2(4) - 1), 4);   // 15
    assert_eq(popcount(pow2(8) - 1), 8);   // 255
    assert_eq(popcount(pow2(10) - 1), 10); // 1023
}

fn test_reverse_bits_basic() {
    // Reverse 8 bits of 0b00000001 -> 0b10000000 = 128
    assert_eq(reverse_bits(1, 8), 128);
    // Reverse 8 bits of 0b10000000 -> 0b00000001 = 1
    assert_eq(reverse_bits(128, 8), 1);
    // Reverse 8 bits of 0b11110000 -> 0b00001111 = 15
    assert_eq(reverse_bits(240, 8), 15);
}

fn test_reverse_bits_palindrome() {
    // Bit palindromes are unchanged by reversal
    // 0b1001 (4 bits) = 9 -> reversed = 9
    assert_eq(reverse_bits(9, 4), 9);
    // 0b10101 (5 bits) = 21 -> reversed = 21
    assert_eq(reverse_bits(21, 5), 21);
}

fn test_reverse_bits_involutory() {
    // Reversing twice gives back original
    let val = 42;
    assert_eq(reverse_bits(reverse_bits(val, 8), 8), val);
    assert_eq(reverse_bits(reverse_bits(137, 8), 8), 137);
    assert_eq(reverse_bits(reverse_bits(255, 8), 8), 255);
}

fn test_get_set_bit() {
    // 42 = 0b101010
    assert_eq(get_bit(42, 0), 0);
    assert_eq(get_bit(42, 1), 1);
    assert_eq(get_bit(42, 2), 0);
    assert_eq(get_bit(42, 3), 1);
    assert_eq(get_bit(42, 4), 0);
    assert_eq(get_bit(42, 5), 1);

    // Set bit 0 of 42 -> 43
    assert_eq(set_bit(42, 0), 43);
    // Set bit 1 (already set) -> 42
    assert_eq(set_bit(42, 1), 42);
}

fn test_clear_toggle_bit() {
    // Clear bit 1 of 42 (0b101010) -> 40 (0b101000)
    assert_eq(clear_bit(42, 1), 40);
    // Clear bit 0 (already 0) -> 42
    assert_eq(clear_bit(42, 0), 42);

    // Toggle bit 0 of 42 -> 43
    assert_eq(toggle_bit(42, 0), 43);
    // Toggle bit 1 of 42 -> 40
    assert_eq(toggle_bit(42, 1), 40);
    // Toggle twice gives back original
    assert_eq(toggle_bit(toggle_bit(42, 3), 3), 42);
}

fn test_trailing_zeros() {
    assert_eq(trailing_zeros(1), 0);
    assert_eq(trailing_zeros(2), 1);
    assert_eq(trailing_zeros(4), 2);
    assert_eq(trailing_zeros(8), 3);
    assert_eq(trailing_zeros(12), 2); // 0b1100
    assert_eq(trailing_zeros(40), 3); // 0b101000
}

fn test_leading_zeros() {
    assert_eq(leading_zeros(1, 8), 7);
    assert_eq(leading_zeros(128, 8), 0);
    assert_eq(leading_zeros(64, 8), 1);
    assert_eq(leading_zeros(0, 8), 8);
    assert_eq(leading_zeros(15, 8), 4); // 0b00001111
}

fn test_is_power_of_two() {
    assert_eq(is_power_of_two(0), 0);
    assert_eq(is_power_of_two(1), 1);
    assert_eq(is_power_of_two(2), 1);
    assert_eq(is_power_of_two(3), 0);
    assert_eq(is_power_of_two(4), 1);
    assert_eq(is_power_of_two(5), 0);
    assert_eq(is_power_of_two(8), 1);
    assert_eq(is_power_of_two(16), 1);
    assert_eq(is_power_of_two(15), 0);
    assert_eq(is_power_of_two(256), 1);
}

fn test_parity() {
    assert_eq(parity(0), 0);   // 0 bits -> even
    assert_eq(parity(1), 1);   // 1 bit -> odd
    assert_eq(parity(3), 0);   // 2 bits -> even
    assert_eq(parity(7), 1);   // 3 bits -> odd
    assert_eq(parity(15), 0);  // 4 bits -> even
}

fn test_highest_bit() {
    assert_eq(highest_bit(0), -1);
    assert_eq(highest_bit(1), 0);
    assert_eq(highest_bit(2), 1);
    assert_eq(highest_bit(3), 1);
    assert_eq(highest_bit(4), 2);
    assert_eq(highest_bit(255), 7);
    assert_eq(highest_bit(256), 8);
}

fn test_popcount_xor_relation() {
    // popcount(a) + popcount(b) = popcount(a AND b)*2 + popcount(a XOR b)
    // For a=42 (101010), b=27 (011011):
    // a AND b = 001010 = 10, popcount = 2
    // a XOR b = 110001 = 49, popcount = 3
    // a OR b  = 111011 = 59, popcount = 5
    // popcount(a) + popcount(b) = 3 + 4 = 7
    // popcount(a AND b)*2 + popcount(a XOR b) = 4 + 3 = 7 ✓
    let a = 42;
    let bv = 27;
    let pc_a = popcount(a);
    let pc_b = popcount(bv);
    assert_eq(pc_a, 3);
    assert_eq(pc_b, 4);
}

fn test_reverse_preserves_popcount() {
    // Bit reversal preserves the number of set bits
    let vals_a = 42;
    assert_eq(popcount(vals_a), popcount(reverse_bits(vals_a, 8)));

    let vals_b = 137;
    assert_eq(popcount(vals_b), popcount(reverse_bits(vals_b, 8)));

    let vals_c = 255;
    assert_eq(popcount(vals_c), popcount(reverse_bits(vals_c, 8)));
}

fn main() -> Int {
    test_popcount_basic();
    test_popcount_powers();
    test_popcount_minus_one();
    test_reverse_bits_basic();
    test_reverse_bits_palindrome();
    test_reverse_bits_involutory();
    test_get_set_bit();
    test_clear_toggle_bit();
    test_trailing_zeros();
    test_leading_zeros();
    test_is_power_of_two();
    test_parity();
    test_highest_bit();
    test_popcount_xor_relation();
    test_reverse_preserves_popcount();
    print("[OK] 379_bit_ops_aot");
    0
}
