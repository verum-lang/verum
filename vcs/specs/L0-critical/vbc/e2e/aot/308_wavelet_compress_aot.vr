// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, wavelet, haar, compression, signal-processing
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Haar-like integer wavelet transform and compression

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 }
}

fn abs_val(x: Int) -> Int {
    if x < 0 { -x } else { x }
}

// Haar wavelet forward transform (one level)
// Input: n elements (must be even)
// Output: first n/2 are averages, last n/2 are differences
fn haar_forward_step(data: Arr8, n: Int) -> Arr8 {
    let half = n / 2;
    let mut result = a8_zero();
    let mut i = 0;
    while i < half {
        let left = a8_get(data, 2 * i);
        let right = a8_get(data, 2 * i + 1);
        // Average (integer, rounded down)
        let avg = (left + right) / 2;
        // Difference
        let diff = left - right;
        result = a8_set(result, i, avg);
        result = a8_set(result, half + i, diff);
        i = i + 1;
    }
    result
}

// Haar wavelet inverse transform (one level)
// Input: first n/2 are averages, last n/2 are differences
// Output: reconstructed signal of n elements
fn haar_inverse_step(data: Arr8, n: Int) -> Arr8 {
    let half = n / 2;
    let mut result = a8_zero();
    let mut i = 0;
    while i < half {
        let avg = a8_get(data, i);
        let diff = a8_get(data, half + i);
        // Reconstruct: left = avg + (diff+1)/2, right = avg - diff/2
        // For exact integer reconstruction with the floor-based avg:
        // left = avg + (diff + 1) / 2  (if diff is odd, round up)
        // right = avg - diff / 2       (if diff is odd, round down)
        // Actually: left + right = 2*avg + (even rounding)
        // For exact reconstruction: left = avg + ceil(diff/2), right = avg - floor(diff/2)
        // Simplify: if left-right=diff and (left+right) close to 2*avg:
        //   left = avg + (diff + (diff>=0 ? 1 : 0)) / 2  when diff is odd...
        // Easier: store as sum & diff format instead.
        // Let's use sum-based: sum = left + right, diff = left - right
        // Then left = (sum + diff) / 2, right = (sum - diff) / 2
        // But we stored avg = (left+right)/2 (integer division). This loses a bit.
        // For exact round-trip: use sum instead of avg.
        // Let's redesign to be lossless:
        let left_val = avg + (diff + 1) / 2;
        let right_val = left_val - diff;
        result = a8_set(result, 2 * i, left_val);
        result = a8_set(result, 2 * i + 1, right_val);
        i = i + 1;
    }
    result
}

// Lossless Haar: store sum and difference
fn haar_lossless_forward(data: Arr8, n: Int) -> Arr8 {
    let half = n / 2;
    let mut result = a8_zero();
    let mut i = 0;
    while i < half {
        let left = a8_get(data, 2 * i);
        let right = a8_get(data, 2 * i + 1);
        let sum = left + right;
        let diff = left - right;
        result = a8_set(result, i, sum);
        result = a8_set(result, half + i, diff);
        i = i + 1;
    }
    result
}

fn haar_lossless_inverse(data: Arr8, n: Int) -> Arr8 {
    let half = n / 2;
    let mut result = a8_zero();
    let mut i = 0;
    while i < half {
        let sum = a8_get(data, i);
        let diff = a8_get(data, half + i);
        let left = (sum + diff) / 2;
        let right = (sum - diff) / 2;
        result = a8_set(result, 2 * i, left);
        result = a8_set(result, 2 * i + 1, right);
        i = i + 1;
    }
    result
}

// Full multi-level Haar transform (powers of 2 only)
fn haar_full_forward(data: Arr8, n: Int) -> Arr8 {
    let mut result = data;
    let mut len = n;
    while len >= 2 {
        let mut temp = a8_zero();
        let half = len / 2;
        let mut i = 0;
        while i < half {
            let left = a8_get(result, 2 * i);
            let right = a8_get(result, 2 * i + 1);
            temp = a8_set(temp, i, left + right);
            temp = a8_set(temp, half + i, left - right);
            i = i + 1;
        }
        // Copy transformed part back
        let mut j = 0;
        while j < len {
            result = a8_set(result, j, a8_get(temp, j));
            j = j + 1;
        }
        len = len / 2;
    }
    result
}

fn haar_full_inverse(data: Arr8, n: Int) -> Arr8 {
    let mut result = data;
    let mut len = 2;
    while len <= n {
        let mut temp = a8_zero();
        let half = len / 2;
        let mut i = 0;
        while i < half {
            let sum = a8_get(result, i);
            let diff = a8_get(result, half + i);
            temp = a8_set(temp, 2 * i, (sum + diff) / 2);
            temp = a8_set(temp, 2 * i + 1, (sum - diff) / 2);
            i = i + 1;
        }
        let mut j = 0;
        while j < len {
            result = a8_set(result, j, a8_get(temp, j));
            j = j + 1;
        }
        len = len * 2;
    }
    result
}

// Compression: zero out detail coefficients below a threshold
fn compress(data: Arr8, n: Int, threshold: Int) -> Arr8 {
    let mut result = data;
    // The first element is the overall sum, rest are details
    let mut i = 1;
    while i < n {
        if abs_val(a8_get(result, i)) < threshold {
            result = a8_set(result, i, 0);
        }
        i = i + 1;
    }
    result
}

// Count non-zero entries (measure of sparsity)
fn count_nonzero(data: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if a8_get(data, i) != 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

// Energy (sum of squares) for measuring reconstruction quality
fn energy(data: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        let v = a8_get(data, i);
        sum = sum + v * v;
        i = i + 1;
    }
    sum
}

fn test_single_step_lossless() {
    // [10, 20, 30, 40]
    let data = Arr8 { d0: 10, d1: 20, d2: 30, d3: 40, d4: 0, d5: 0, d6: 0, d7: 0 };
    let fwd = haar_lossless_forward(data, 4);
    // sums: 10+20=30, 30+40=70
    // diffs: 10-20=-10, 30-40=-10
    assert_eq(a8_get(fwd, 0), 30);
    assert_eq(a8_get(fwd, 1), 70);
    assert_eq(a8_get(fwd, 2), -10);
    assert_eq(a8_get(fwd, 3), -10);

    // Inverse should recover original
    let inv = haar_lossless_inverse(fwd, 4);
    assert_eq(a8_get(inv, 0), 10);
    assert_eq(a8_get(inv, 1), 20);
    assert_eq(a8_get(inv, 2), 30);
    assert_eq(a8_get(inv, 3), 40);
}

fn test_constant_signal() {
    // All same values: differences should be 0
    let data = Arr8 { d0: 5, d1: 5, d2: 5, d3: 5, d4: 0, d5: 0, d6: 0, d7: 0 };
    let fwd = haar_lossless_forward(data, 4);
    // sums: 10, 10; diffs: 0, 0
    assert_eq(a8_get(fwd, 0), 10);
    assert_eq(a8_get(fwd, 1), 10);
    assert_eq(a8_get(fwd, 2), 0);
    assert_eq(a8_get(fwd, 3), 0);
}

fn test_full_transform_roundtrip() {
    // 8-element signal
    let data = Arr8 { d0: 4, d1: 6, d2: 10, d3: 12, d4: 8, d5: 6, d6: 2, d7: 4 };
    let fwd = haar_full_forward(data, 8);

    // First coefficient is overall sum
    // 4+6+10+12+8+6+2+4 = 52
    assert_eq(a8_get(fwd, 0), 52);

    // Inverse should recover original (all even values, so no rounding issues)
    let inv = haar_full_inverse(fwd, 8);
    assert_eq(a8_get(inv, 0), 4);
    assert_eq(a8_get(inv, 1), 6);
    assert_eq(a8_get(inv, 2), 10);
    assert_eq(a8_get(inv, 3), 12);
    assert_eq(a8_get(inv, 4), 8);
    assert_eq(a8_get(inv, 5), 6);
    assert_eq(a8_get(inv, 6), 2);
    assert_eq(a8_get(inv, 7), 4);
}

fn test_compression() {
    let data = Arr8 { d0: 100, d1: 102, d2: 98, d3: 103, d4: 99, d5: 101, d6: 100, d7: 97 };
    let fwd = haar_full_forward(data, 8);

    // Large threshold: zero out small details
    let compressed = compress(fwd, 8, 10);

    // Count how many coefficients survived
    let nz = count_nonzero(compressed, 8);
    // The overall sum should survive, small details zeroed
    assert_eq(a8_get(compressed, 0) != 0, true);

    // Compression should reduce non-zero count
    let orig_nz = count_nonzero(fwd, 8);
    assert_eq(nz <= orig_nz, true);
}

fn test_energy_preservation() {
    // Parseval's theorem: energy in signal domain = energy in transform domain
    // For sum/diff Haar: signal energy * 2^levels = transform energy (approximately)
    // Actually for our scaling: sum = a+b, diff = a-b
    // sum^2 + diff^2 = (a+b)^2 + (a-b)^2 = 2(a^2 + b^2)
    // So transform energy = 2 * signal energy for one level

    let data = Arr8 { d0: 3, d1: 4, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let fwd = haar_lossless_forward(data, 2);
    // signal energy: 9 + 16 = 25
    // transform: sum=7, diff=-1 => energy: 49+1 = 50 = 2*25
    assert_eq(energy(data, 2), 25);
    assert_eq(energy(fwd, 2), 50);
}

fn test_step_signal() {
    // Step function: [0, 0, 0, 0, 10, 10, 10, 10]
    let data = Arr8 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 10, d5: 10, d6: 10, d7: 10 };
    let fwd = haar_full_forward(data, 8);

    // Total sum = 40
    assert_eq(a8_get(fwd, 0), 40);

    // Level 1 detail (position 1): difference between left half sum and right half sum
    // Left: 0, Right: 40, detail should capture this contrast
    // The detail at position 1 should be non-zero (represents the step)
    assert_eq(a8_get(fwd, 1) != 0, true);

    // Fine details at positions 4-7 should be 0 (each pair is constant)
    assert_eq(a8_get(fwd, 4), 0);
    assert_eq(a8_get(fwd, 5), 0);
    assert_eq(a8_get(fwd, 6), 0);
    assert_eq(a8_get(fwd, 7), 0);
}

fn test_impulse_signal() {
    // Single spike: [0, 0, 0, 8, 0, 0, 0, 0]
    let data = Arr8 { d0: 0, d1: 0, d2: 0, d3: 8, d4: 0, d5: 0, d6: 0, d7: 0 };
    let fwd = haar_full_forward(data, 8);
    // Sum = 8
    assert_eq(a8_get(fwd, 0), 8);

    // Reconstruct
    let inv = haar_full_inverse(fwd, 8);
    assert_eq(a8_get(inv, 0), 0);
    assert_eq(a8_get(inv, 1), 0);
    assert_eq(a8_get(inv, 2), 0);
    assert_eq(a8_get(inv, 3), 8);
    assert_eq(a8_get(inv, 4), 0);
    assert_eq(a8_get(inv, 5), 0);
    assert_eq(a8_get(inv, 6), 0);
    assert_eq(a8_get(inv, 7), 0);
}

fn test_two_element() {
    let data = Arr8 { d0: 7, d1: 3, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let fwd = haar_full_forward(data, 2);
    // sum = 10, diff = 4
    assert_eq(a8_get(fwd, 0), 10);
    assert_eq(a8_get(fwd, 1), 4);

    let inv = haar_full_inverse(fwd, 2);
    assert_eq(a8_get(inv, 0), 7);
    assert_eq(a8_get(inv, 1), 3);
}

fn main() -> Int {
    test_single_step_lossless();
    test_constant_signal();
    test_full_transform_roundtrip();
    test_compression();
    test_energy_preservation();
    test_step_signal();
    test_impulse_signal();
    test_two_element();
    print("[OK] 308_wavelet_compress_aot");
    0
}
