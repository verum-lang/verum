// @test: run
// @level: L0
// @tags: aot, e2e, median, selection, statistics
// @timeout: 30000

// Selection algorithm (kth smallest element) and median finding

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn sort_arr(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 0;
    while i < n - 1 {
        let mut j = 0;
        while j < n - 1 - i {
            if get8(a, j) > get8(a, j + 1) {
                let tmp = get8(a, j);
                a = set8(a, j, get8(a, j + 1));
                a = set8(a, j + 1, tmp);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    a
}

fn kth_smallest(arr: Arr8, n: Int, k: Int) -> Int {
    let sorted = sort_arr(arr, n);
    get8(sorted, k)
}

fn find_min(arr: Arr8, n: Int) -> Int {
    let mut min_v = get8(arr, 0);
    let mut i = 1;
    while i < n {
        if get8(arr, i) < min_v { min_v = get8(arr, i); }
        i = i + 1;
    }
    min_v
}

fn find_max(arr: Arr8, n: Int) -> Int {
    let mut max_v = get8(arr, 0);
    let mut i = 1;
    while i < n {
        if get8(arr, i) > max_v { max_v = get8(arr, i); }
        i = i + 1;
    }
    max_v
}

fn median_odd(arr: Arr8, n: Int) -> Int {
    kth_smallest(arr, n, n / 2)
}

fn percentile(arr: Arr8, n: Int, pct: Int) -> Int {
    let idx = pct * (n - 1) / 100;
    kth_smallest(arr, n, idx)
}

fn count_less(arr: Arr8, n: Int, pivot: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) < pivot { count = count + 1; }
        i = i + 1;
    }
    count
}

fn count_equal(arr: Arr8, n: Int, val: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) == val { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_kth_smallest() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 9, v5: 2, v6: 7, v7: 0 };
    assert_eq(kth_smallest(arr, 7, 0), 1);
    assert_eq(kth_smallest(arr, 7, 1), 2);
    assert_eq(kth_smallest(arr, 7, 3), 5);
    assert_eq(kth_smallest(arr, 7, 6), 9);
    1
}

fn test_median() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 9, v5: 0, v6: 0, v7: 0 };
    assert_eq(median_odd(arr, 5), 5);
    let arr2 = Arr8 { v0: 10, v1: 20, v2: 30, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(median_odd(arr2, 3), 20);
    1
}

fn test_min_max() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 9, v5: 2, v6: 7, v7: 4 };
    assert_eq(find_min(arr, 8), 1);
    assert_eq(find_max(arr, 8), 9);
    // Compute range inline to avoid 9-param forwarding bug
    let mx = find_max(arr, 8);
    let mn = find_min(arr, 8);
    assert_eq(mx - mn, 8);
    // kth_smallest k=0 should be min
    let k0 = kth_smallest(arr, 8, 0);
    let mn2 = find_min(arr, 8);
    assert_eq(k0, mn2);
    // kth_smallest k=n-1 should be max
    let k7 = kth_smallest(arr, 8, 7);
    let mx2 = find_max(arr, 8);
    assert_eq(k7, mx2);
    1
}

fn test_percentile() -> Int {
    let arr = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 0, v6: 0, v7: 0 };
    assert_eq(percentile(arr, 5, 0), 10);
    assert_eq(percentile(arr, 5, 50), 30);
    assert_eq(percentile(arr, 5, 100), 50);
    1
}

fn test_count_ops() -> Int {
    let arr = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 2, v7: 6 };
    assert_eq(count_less(arr, 8, 5), 5);
    assert_eq(count_equal(arr, 8, 1), 2);
    assert_eq(count_equal(arr, 8, 7), 0);
    1
}

fn test_sorted_is_stable() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    let sorted = sort_arr(arr, 5);
    let mut i = 0;
    let mut ok = 1;
    while i < 5 {
        if get8(sorted, i) != get8(arr, i) { ok = 0; }
        i = i + 1;
    }
    assert_eq(ok, 1);
    1
}

fn main() -> Int {
    test_kth_smallest();
    test_median();
    test_min_max();
    test_percentile();
    test_count_ops();
    test_sorted_is_stable();
    print("[OK] 667_median_select_aot");
    0
}
