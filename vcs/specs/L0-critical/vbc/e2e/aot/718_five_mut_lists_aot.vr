// @test: run
// @tier: 0
// @level: L0
// @tags: aot, mutable, lists, five, aliasing
// @expected-exit: 0

fn main() -> Int {
    // Five mutable lists simultaneously
    let mut a = [1, 2, 3];
    let mut b = [4, 5, 6];
    let mut c = [7, 8, 9];
    let mut d = [10, 11, 12];
    let mut e = [13, 14, 15];

    // Cross-mutation in loop
    let mut i = 0;
    while (i < 3) {
        a[i] = a[i] * 2;
        b[i] = b[i] * 3;
        c[i] = c[i] + a[i];
        d[i] = d[i] + b[i];
        e[i] = e[i] + c[i] + d[i];
        i = i + 1;
    }

    // Verify a: [2, 4, 6]
    assert_eq(a[0], 2);
    assert_eq(a[1], 4);
    assert_eq(a[2], 6);

    // Verify b: [12, 15, 18]
    assert_eq(b[0], 12);
    assert_eq(b[1], 15);
    assert_eq(b[2], 18);

    // Verify c: [9, 12, 15]  (c[i] = original_c[i] + a[i])
    assert_eq(c[0], 9);
    assert_eq(c[1], 12);
    assert_eq(c[2], 15);

    // Verify d: [22, 26, 30]  (d[i] = original_d[i] + b[i])
    assert_eq(d[0], 22);
    assert_eq(d[1], 26);
    assert_eq(d[2], 30);

    // Verify e: [44, 52, 60]  (e[i] = original_e[i] + c[i] + d[i])
    assert_eq(e[0], 44);
    assert_eq(e[1], 52);
    assert_eq(e[2], 60);

    let total = e[0] + e[1] + e[2];
    print(total);
    assert_eq(total, 156);

    0
}
