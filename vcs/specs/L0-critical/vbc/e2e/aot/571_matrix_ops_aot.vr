// @test: run
// @level: L0
// @tags: aot, e2e, matrix, linear-algebra, operations
// @timeout: 30000

// Matrix operations on 2x2 and 3x3 matrices using Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// 2x2 matrix stored in first 4 slots: [a, b, c, d] = [[a,b],[c,d]]
// mat[i][j] = slot[i*2+j]

fn mat2_get(m: Arr8, i: Int, j: Int) -> Int { get8(m, i * 2 + j) }
fn mat2_set(m: Arr8, i: Int, j: Int, v: Int) -> Arr8 { set8(m, i * 2 + j, v) }

fn mat2_det(m: Arr8) -> Int {
    get8(m, 0) * get8(m, 3) - get8(m, 1) * get8(m, 2)
}

fn mat2_trace(m: Arr8) -> Int {
    get8(m, 0) + get8(m, 3)
}

fn mat2_add(a: Arr8, b: Arr8) -> Arr8 {
    let mut r = zeros();
    r = set8(r, 0, get8(a, 0) + get8(b, 0));
    r = set8(r, 1, get8(a, 1) + get8(b, 1));
    r = set8(r, 2, get8(a, 2) + get8(b, 2));
    r = set8(r, 3, get8(a, 3) + get8(b, 3));
    r
}

fn mat2_mul(a: Arr8, b: Arr8) -> Arr8 {
    let mut r = zeros();
    // r[0][0] = a[0][0]*b[0][0] + a[0][1]*b[1][0]
    r = set8(r, 0, get8(a, 0) * get8(b, 0) + get8(a, 1) * get8(b, 2));
    // r[0][1] = a[0][0]*b[0][1] + a[0][1]*b[1][1]
    r = set8(r, 1, get8(a, 0) * get8(b, 1) + get8(a, 1) * get8(b, 3));
    // r[1][0] = a[1][0]*b[0][0] + a[1][1]*b[1][0]
    r = set8(r, 2, get8(a, 2) * get8(b, 0) + get8(a, 3) * get8(b, 2));
    // r[1][1] = a[1][0]*b[0][1] + a[1][1]*b[1][1]
    r = set8(r, 3, get8(a, 2) * get8(b, 1) + get8(a, 3) * get8(b, 3));
    r
}

fn mat2_transpose(m: Arr8) -> Arr8 {
    let mut r = zeros();
    r = set8(r, 0, get8(m, 0));
    r = set8(r, 1, get8(m, 2));
    r = set8(r, 2, get8(m, 1));
    r = set8(r, 3, get8(m, 3));
    r
}

fn mat2_scale(m: Arr8, s: Int) -> Arr8 {
    let mut r = zeros();
    r = set8(r, 0, get8(m, 0) * s);
    r = set8(r, 1, get8(m, 1) * s);
    r = set8(r, 2, get8(m, 2) * s);
    r = set8(r, 3, get8(m, 3) * s);
    r
}

fn mat2_identity() -> Arr8 {
    Arr8 { v0: 1, v1: 0, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 }
}

// 3x3 determinant using Arr8 (indices 0-8, but only 0-7 in Arr8)
// Store [a,b,c,d,e,f,g,h] in Arr8, 9th element (mat[2][2]) passed separately
fn det3x3(m: Arr8, m22: Int) -> Int {
    let a = get8(m, 0); let b = get8(m, 1); let c = get8(m, 2);
    let d = get8(m, 3); let e = get8(m, 4); let f = get8(m, 5);
    let g = get8(m, 6); let h = get8(m, 7);
    a * (e * m22 - f * h) - b * (d * m22 - f * g) + c * (d * h - e * g)
}

fn test_identity() -> Int {
    let id = mat2_identity();
    assert_eq(mat2_get(id, 0, 0), 1);
    assert_eq(mat2_get(id, 1, 1), 1);
    assert_eq(mat2_get(id, 0, 1), 0);
    assert_eq(mat2_get(id, 1, 0), 0);
    assert_eq(mat2_det(id), 1);
    assert_eq(mat2_trace(id), 2);
    1
}

fn test_multiply_identity() -> Int {
    // A * I = A
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = mat2_mul(a, mat2_identity());
    assert_eq(get8(result, 0), 1);
    assert_eq(get8(result, 1), 2);
    assert_eq(get8(result, 2), 3);
    assert_eq(get8(result, 3), 4);
    1
}

fn test_multiply() -> Int {
    // [[1,2],[3,4]] * [[5,6],[7,8]] = [[19,22],[43,50]]
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 5, v1: 6, v2: 7, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r = mat2_mul(a, b);
    assert_eq(get8(r, 0), 19);
    assert_eq(get8(r, 1), 22);
    assert_eq(get8(r, 2), 43);
    assert_eq(get8(r, 3), 50);
    1
}

fn test_determinant() -> Int {
    // det([[1,2],[3,4]]) = 1*4 - 2*3 = -2
    let m = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(mat2_det(m), 0 - 2);

    // det([[5,0],[0,3]]) = 15
    let m2 = Arr8 { v0: 5, v1: 0, v2: 0, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(mat2_det(m2), 15);

    // Singular: det = 0
    let m3 = Arr8 { v0: 1, v1: 2, v2: 2, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(mat2_det(m3), 0);
    1
}

fn test_transpose() -> Int {
    let m = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let t = mat2_transpose(m);
    assert_eq(get8(t, 0), 1);
    assert_eq(get8(t, 1), 3);
    assert_eq(get8(t, 2), 2);
    assert_eq(get8(t, 3), 4);

    // (A^T)^T = A
    let tt = mat2_transpose(t);
    assert_eq(get8(tt, 0), 1);
    assert_eq(get8(tt, 1), 2);
    assert_eq(get8(tt, 2), 3);
    assert_eq(get8(tt, 3), 4);
    1
}

fn test_add_scale() -> Int {
    let a = Arr8 { v0: 1, v1: 0, v2: 0, v3: 2, v4: 0, v5: 0, v6: 0, v7: 0 };
    let doubled = mat2_add(a, a);
    assert_eq(get8(doubled, 0), 2);
    assert_eq(get8(doubled, 3), 4);

    let scaled = mat2_scale(a, 3);
    assert_eq(get8(scaled, 0), 3);
    assert_eq(get8(scaled, 3), 6);
    1
}

fn test_det3x3() -> Int {
    // [[1,2,3],[4,5,6],[7,8,9]] det = 0 (singular)
    let m = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    assert_eq(det3x3(m, 9), 0);

    // [[2,1,0],[0,3,1],[1,0,2]] det = 13
    let m2 = Arr8 { v0: 2, v1: 1, v2: 0, v3: 0, v4: 3, v5: 1, v6: 1, v7: 0 };
    assert_eq(det3x3(m2, 2), 13);

    // Identity 3x3: det = 1
    let id = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(det3x3(id, 1), 1);
    1
}

fn test_cayley_hamilton() -> Int {
    // Cayley-Hamilton: A^2 - trace(A)*A + det(A)*I = 0
    let a = Arr8 { v0: 3, v1: 1, v2: 2, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let a2 = mat2_mul(a, a);
    let tr = mat2_trace(a); // 3+4 = 7
    let det = mat2_det(a); // 3*4 - 1*2 = 10
    let tr_a = mat2_scale(a, tr);
    let det_i = mat2_scale(mat2_identity(), det);

    // a2 - tr*a + det*I should be zero matrix
    // a2 = [[11,7],[14,18]]
    // tr*a = [[21,7],[14,28]]
    // det*I = [[10,0],[0,10]]
    // result = [[11-21+10, 7-7+0],[14-14+0, 18-28+10]] = [[0,0],[0,0]]
    let mut i = 0;
    while i < 4 {
        let val = get8(a2, i) - get8(tr_a, i) + get8(det_i, i);
        assert_eq(val, 0);
        i = i + 1;
    }
    1
}

fn main() -> Int {
    test_identity();
    test_multiply_identity();
    test_multiply();
    test_determinant();
    test_transpose();
    test_add_scale();
    test_det3x3();
    test_cayley_hamilton();
    print("[OK] 571_matrix_ops_aot");
    0
}
