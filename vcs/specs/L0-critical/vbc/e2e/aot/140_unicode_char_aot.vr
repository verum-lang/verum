// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, unicode, char
// @timeout: 30000
// @expected-exit: 0
//
// AOT: Character classification and case conversion operations.
// Tests ASCII fast paths implemented inline in LLVM IR.

fn test_ascii_alpha() {
    // ASCII classification tests (inline LLVM IR)
    let a = 65;  // 'A'
    let z = 122; // 'z'
    let zero = 48; // '0'
    let space = 32; // ' '

    // Basic integer range checks that mirror char classification logic
    let is_upper_a = a >= 65 && a <= 90;
    assert(is_upper_a);

    let is_lower_z = z >= 97 && z <= 122;
    assert(is_lower_z);

    let is_digit_0 = zero >= 48 && zero <= 57;
    assert(is_digit_0);

    let is_space = space == 32;
    assert(is_space);
}

fn test_case_conversion_logic() {
    // Case conversion arithmetic
    let upper_a = 65;  // 'A'
    let lower_a = 97;  // 'a'

    // Uppercase to lowercase: add 32
    let converted_lower = upper_a + 32;
    assert_eq(converted_lower, lower_a);

    // Lowercase to uppercase: subtract 32
    let converted_upper = lower_a - 32;
    assert_eq(converted_upper, upper_a);

    // Non-letter should remain unchanged
    let digit = 48; // '0'
    let is_lower = digit >= 97 && digit <= 122;
    let result = if is_lower { digit - 32 } else { digit };
    assert_eq(result, 48);
}

fn test_classification_ranges() {
    // Hex digit: 0-9, A-F, a-f
    let ch_a = 97;  // 'a'
    let ch_f = 102; // 'f'
    let ch_g = 103; // 'g'

    let is_hex_a = (ch_a >= 48 && ch_a <= 57) || (ch_a >= 65 && ch_a <= 70) || (ch_a >= 97 && ch_a <= 102);
    assert(is_hex_a);

    let is_hex_f = (ch_f >= 48 && ch_f <= 57) || (ch_f >= 65 && ch_f <= 70) || (ch_f >= 97 && ch_f <= 102);
    assert(is_hex_f);

    let is_hex_g = (ch_g >= 48 && ch_g <= 57) || (ch_g >= 65 && ch_g <= 70) || (ch_g >= 97 && ch_g <= 102);
    assert(!is_hex_g);
}

fn test_control_chars() {
    // Control characters: 0x00-0x1F and 0x7F
    let nul = 0;
    let tab = 9;
    let del = 127;
    let bang = 33; // '!'

    assert(nul <= 31);
    assert(tab <= 31);
    assert(del == 127);
    assert(bang > 31 && bang != 127);
}

fn test_punctuation() {
    // ASCII punctuation ranges: 0x21-0x2F, 0x3A-0x40, 0x5B-0x60, 0x7B-0x7E
    let bang = 33;   // '!'
    let colon = 58;  // ':'
    let brace = 123; // '{'

    let is_p1 = bang >= 33 && bang <= 47;
    assert(is_p1);

    let is_p2 = colon >= 58 && colon <= 64;
    assert(is_p2);

    let is_p4 = brace >= 123 && brace <= 126;
    assert(is_p4);
}

fn main() -> Int {
    test_ascii_alpha();
    test_case_conversion_logic();
    test_classification_ranges();
    test_control_chars();
    test_punctuation();
    print("[OK] 140_unicode_char_aot");
    0
}
