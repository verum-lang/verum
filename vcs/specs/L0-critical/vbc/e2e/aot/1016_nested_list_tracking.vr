// @test: run
// List<List<T>> element access preserves inner list tracking

fn make_matrix() -> List<List<Int>> {
    let matrix = List.new();
    let row0 = List.new();
    row0.push(1); row0.push(2); row0.push(3);
    let row1 = List.new();
    row1.push(4); row1.push(5); row1.push(6); row1.push(7);
    matrix.push(row0);
    matrix.push(row1);
    matrix
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    let m = make_matrix();

    // Test 1: outer list len
    if (m.len() == 2) { passed = passed + 1; }
    else { print(f"FAIL 1: m.len()={m.len()}"); failed = failed + 1; }

    // Test 2: inner list len (element access)
    let row0 = m[0];
    if (row0.len() == 3) { passed = passed + 1; }
    else { print(f"FAIL 2: row0.len()={row0.len()}"); failed = failed + 1; }

    // Test 3: inner list element access
    if (row0[0] == 1 && row0[2] == 3) { passed = passed + 1; }
    else { print(f"FAIL 3: row0[0]={row0[0]} row0[2]={row0[2]}"); failed = failed + 1; }

    // Test 4: second inner list
    let row1 = m[1];
    if (row1.len() == 4 && row1[3] == 7) { passed = passed + 1; }
    else { print(f"FAIL 4: row1.len()={row1.len()} row1[3]={row1[3]}"); failed = failed + 1; }

    // Test 5: push to inner list
    row0.push(99);
    if (row0.len() == 4 && row0[3] == 99) { passed = passed + 1; }
    else { print(f"FAIL 5: row0.len()={row0.len()}"); failed = failed + 1; }

    if (failed > 0) {
        print(f"nested_list_tracking: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"nested_list_tracking: PASS ({passed}/{passed} tests)");
    0
}
