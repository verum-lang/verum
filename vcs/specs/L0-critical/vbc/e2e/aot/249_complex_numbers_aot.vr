// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, complex, numbers, math
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for complex number arithmetic (integer-scaled by 1000)

// Complex number with 1000x scaling for "fixed point"
type Complex is { re: Int, im: Int };

fn c_new(re: Int, im: Int) -> Complex { Complex { re: re, im: im } }
fn c_zero() -> Complex { Complex { re: 0, im: 0 } }
fn c_real(r: Int) -> Complex { Complex { re: r, im: 0 } }
fn c_imag(i: Int) -> Complex { Complex { re: 0, im: i } }

fn c_add(a: Complex, b: Complex) -> Complex {
    Complex { re: a.re + b.re, im: a.im + b.im }
}

fn c_sub(a: Complex, b: Complex) -> Complex {
    Complex { re: a.re - b.re, im: a.im - b.im }
}

fn c_mul(a: Complex, b: Complex) -> Complex {
    // (a+bi)(c+di) = (ac-bd) + (ad+bc)i
    Complex {
        re: a.re * b.re - a.im * b.im,
        im: a.re * b.im + a.im * b.re
    }
}

fn c_conj(a: Complex) -> Complex {
    Complex { re: a.re, im: -a.im }
}

fn c_norm_sq(a: Complex) -> Int {
    a.re * a.re + a.im * a.im
}

fn c_neg(a: Complex) -> Complex {
    Complex { re: -a.re, im: -a.im }
}

fn c_eq(a: Complex, b: Complex) -> Bool {
    a.re == b.re && a.im == b.im
}

// Scale by integer
fn c_scale(a: Complex, s: Int) -> Complex {
    Complex { re: a.re * s, im: a.im * s }
}

fn test_basic_ops() {
    let a = c_new(3, 4);
    let b = c_new(1, -2);

    // (3+4i) + (1-2i) = 4+2i
    let sum = c_add(a, b);
    assert_eq(sum.re, 4);
    assert_eq(sum.im, 2);

    // (3+4i) - (1-2i) = 2+6i
    let diff = c_sub(a, b);
    assert_eq(diff.re, 2);
    assert_eq(diff.im, 6);
}

fn test_multiply() {
    // (3+4i)(1-2i) = 3-6i+4i-8i^2 = 3-2i+8 = 11-2i
    let a = c_new(3, 4);
    let b = c_new(1, -2);
    let prod = c_mul(a, b);
    assert_eq(prod.re, 11);
    assert_eq(prod.im, -2);

    // i * i = -1
    let i = c_imag(1);
    let ii = c_mul(i, i);
    assert_eq(ii.re, -1);
    assert_eq(ii.im, 0);
}

fn test_conjugate() {
    let a = c_new(3, 4);
    let conj = c_conj(a);
    assert_eq(conj.re, 3);
    assert_eq(conj.im, -4);

    // a * conj(a) = |a|^2 (real)
    let prod = c_mul(a, conj);
    assert_eq(prod.re, 25);
    assert_eq(prod.im, 0);
    assert_eq(c_norm_sq(a), 25);
}

fn test_identities() {
    let a = c_new(2, 5);
    let zero = c_zero();
    let one = c_real(1);

    // a + 0 = a
    assert_eq(c_eq(c_add(a, zero), a), true);

    // a * 1 = a
    assert_eq(c_eq(c_mul(a, one), a), true);

    // a + (-a) = 0
    assert_eq(c_eq(c_add(a, c_neg(a)), zero), true);

    // a - a = 0
    assert_eq(c_eq(c_sub(a, a), zero), true);
}

fn test_power() {
    // (1+i)^2 = 2i
    let w = c_new(1, 1);
    let w2 = c_mul(w, w);
    assert_eq(w2.re, 0);
    assert_eq(w2.im, 2);

    // (1+i)^4 = -4
    let w4 = c_mul(w2, w2);
    assert_eq(w4.re, -4);
    assert_eq(w4.im, 0);

    // (1+i)^8 = 16
    let w8 = c_mul(w4, w4);
    assert_eq(w8.re, 16);
    assert_eq(w8.im, 0);
}

fn test_distributive() {
    let a = c_new(1, 2);
    let b = c_new(3, 4);
    let c = c_new(5, -1);

    // a * (b + c) = a*b + a*c
    let lhs = c_mul(a, c_add(b, c));
    let rhs = c_add(c_mul(a, b), c_mul(a, c));
    assert_eq(c_eq(lhs, rhs), true);
}

fn main() -> Int {
    test_basic_ops();
    test_multiply();
    test_conjugate();
    test_identities();
    test_power();
    test_distributive();
    print("[OK] 249_complex_numbers_aot");
    0
}
