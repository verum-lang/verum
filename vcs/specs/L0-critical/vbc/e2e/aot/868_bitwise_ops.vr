// @test: run
// @tier: 0
// @level: L0
// @tags: aot, bitwise, operations, bit-manipulation
// @expected-exit: 0

// Test: bitwise operations
// Validates AND, OR, XOR, shifts, bit counting, masks.

fn popcount(mut n: Int) -> Int {
    // Count set bits
    let mut count = 0;
    while (n != 0) {
        count = count + (n & 1);
        n = n >> 1;
    }
    count
}

fn lowest_set_bit(n: Int) -> Int {
    // Isolate lowest set bit
    n & (0 - n)
}

fn is_power_of_two(n: Int) -> Bool {
    n > 0 && (n & (n - 1)) == 0
}

fn next_power_of_two(mut n: Int) -> Int {
    if (n <= 1) { return 1; }
    n = n - 1;
    n = n | (n >> 1);
    n = n | (n >> 2);
    n = n | (n >> 4);
    n = n | (n >> 8);
    n = n | (n >> 16);
    n + 1
}

fn reverse_bits_8(mut n: Int) -> Int {
    // Reverse bottom 8 bits
    let mut result = 0;
    let mut i = 0;
    while (i < 8) {
        result = (result << 1) | (n & 1);
        n = n >> 1;
        i = i + 1;
    }
    result
}

fn swap_nibbles(n: Int) -> Int {
    // Swap upper and lower nibbles of a byte
    ((n & 0xF0) >> 4) | ((n & 0x0F) << 4)
}

fn main() -> Int {
    // Basic AND, OR, XOR
    assert_eq(0xFF & 0x0F, 0x0F);
    assert_eq(0xF0 | 0x0F, 0xFF);
    assert_eq(0xFF ^ 0x0F, 0xF0);

    // Shifts
    assert_eq(1 << 10, 1024);
    assert_eq(1024 >> 5, 32);
    assert_eq(255 << 8, 65280);

    // Popcount
    assert_eq(popcount(0), 0);
    assert_eq(popcount(1), 1);
    assert_eq(popcount(7), 3);    // 111
    assert_eq(popcount(255), 8);  // 11111111
    assert_eq(popcount(1023), 10); // 1111111111

    // Lowest set bit
    assert_eq(lowest_set_bit(12), 4);   // 1100 → 0100
    assert_eq(lowest_set_bit(8), 8);    // 1000 → 1000
    assert_eq(lowest_set_bit(6), 2);    // 110 → 010

    // Power of two check
    assert(is_power_of_two(1));
    assert(is_power_of_two(2));
    assert(is_power_of_two(64));
    assert(is_power_of_two(1024));
    assert(!is_power_of_two(0));
    assert(!is_power_of_two(3));
    assert(!is_power_of_two(100));

    // Next power of two
    assert_eq(next_power_of_two(1), 1);
    assert_eq(next_power_of_two(3), 4);
    assert_eq(next_power_of_two(5), 8);
    assert_eq(next_power_of_two(17), 32);
    assert_eq(next_power_of_two(1000), 1024);

    // Bit reversal (8-bit)
    assert_eq(reverse_bits_8(0b10000000), 1);     // 128 → 1
    assert_eq(reverse_bits_8(0b00000001), 128);   // 1 → 128
    assert_eq(reverse_bits_8(0b10101010), 0b01010101); // 170 → 85

    // Nibble swap
    assert_eq(swap_nibbles(0xAB), 0xBA);
    assert_eq(swap_nibbles(0x12), 0x21);
    assert_eq(swap_nibbles(0xF0), 0x0F);

    // XOR swap
    let mut a = 42;
    let mut b = 99;
    a = a ^ b;
    b = a ^ b;
    a = a ^ b;
    assert_eq(a, 99);
    assert_eq(b, 42);

    // Bitmask operations
    let flags = 0b10110100;
    assert_eq(flags & (1 << 2), 4);   // bit 2 set
    assert_eq(flags & (1 << 0), 0);   // bit 0 not set
    assert_eq(flags & (1 << 4), 16);  // bit 4 set

    print("bitwise_ops: PASS");
    0
}
