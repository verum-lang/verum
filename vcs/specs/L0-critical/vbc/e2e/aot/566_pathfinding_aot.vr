// @test: run
// @level: L0
// @tags: aot, e2e, pathfinding, bfs, shortest-path
// @timeout: 30000

// BFS shortest path on small graphs

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn has_bit(mask: Int, k: Int) -> Int { (mask / pow2(k)) % 2 }
fn set_bit(mask: Int, k: Int) -> Int { if has_bit(mask, k) == 1 { mask } else { mask + pow2(k) } }

// Graph: adjacency bitmasks. adj[i] = bitmask of neighbors of node i
// Max 8 nodes

// BFS: returns distance from source to all nodes (-1 = unreachable)
fn bfs(adj: Arr8, n: Int, source: Int) -> Arr8 {
    let mut dist = Arr8 { v0: -1, v1: -1, v2: -1, v3: -1, v4: -1, v5: -1, v6: -1, v7: -1 };
    dist = set8(dist, source, 0);

    // Queue: use Arr8 as circular buffer
    let mut queue = zeros();
    let mut qfront = 0;
    let mut qback = 0;
    queue = set8(queue, qback, source);
    qback = qback + 1;

    let mut safety = 0;
    while qfront < qback {
        let u = get8(queue, qfront % 8);
        qfront = qfront + 1;
        let d = get8(dist, u);
        let neighbors = get8(adj, u);

        let mut v = 0;
        while v < n {
            if has_bit(neighbors, v) == 1 {
                if get8(dist, v) == -1 {
                    dist = set8(dist, v, d + 1);
                    queue = set8(queue, qback % 8, v);
                    qback = qback + 1;
                }
            }
            v = v + 1;
        }
        safety = safety + 1;
        if safety > 20 { qfront = qback; } // safety break
    }
    dist
}

// Count reachable nodes from source
fn count_reachable(adj: Arr8, n: Int, source: Int) -> Int {
    let dist = bfs(adj, n, source);
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(dist, i) >= 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Check if graph is connected
fn is_connected(adj: Arr8, n: Int) -> Int {
    if count_reachable(adj, n, 0) == n { 1 } else { 0 }
}

// Diameter: max shortest path between any two nodes
fn graph_diameter(adj: Arr8, n: Int) -> Int {
    let mut max_dist = 0;
    let mut u = 0;
    while u < n {
        let dist = bfs(adj, n, u);
        let mut v = 0;
        while v < n {
            let d = get8(dist, v);
            if d > max_dist { max_dist = d; }
            v = v + 1;
        }
        u = u + 1;
    }
    max_dist
}

fn test_simple_path() -> Int {
    // Linear graph: 0-1-2-3
    let adj = Arr8 {
        v0: pow2(1),                    // 0→1
        v1: pow2(0) + pow2(2),          // 1→0,2
        v2: pow2(1) + pow2(3),          // 2→1,3
        v3: pow2(2),                    // 3→2
        v4: 0, v5: 0, v6: 0, v7: 0
    };
    let dist = bfs(adj, 4, 0);
    assert_eq(get8(dist, 0), 0);
    assert_eq(get8(dist, 1), 1);
    assert_eq(get8(dist, 2), 2);
    assert_eq(get8(dist, 3), 3);
    1
}

fn test_triangle() -> Int {
    // Complete graph K3: 0-1, 1-2, 0-2
    let adj = Arr8 {
        v0: pow2(1) + pow2(2),
        v1: pow2(0) + pow2(2),
        v2: pow2(0) + pow2(1),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    let dist = bfs(adj, 3, 0);
    assert_eq(get8(dist, 0), 0);
    assert_eq(get8(dist, 1), 1);
    assert_eq(get8(dist, 2), 1);
    assert_eq(is_connected(adj, 3), 1);
    assert_eq(graph_diameter(adj, 3), 1);
    1
}

fn test_disconnected() -> Int {
    // Two components: {0,1} and {2,3}
    let adj = Arr8 {
        v0: pow2(1),
        v1: pow2(0),
        v2: pow2(3),
        v3: pow2(2),
        v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(is_connected(adj, 4), 0);
    assert_eq(count_reachable(adj, 4, 0), 2);
    assert_eq(count_reachable(adj, 4, 2), 2);

    let dist = bfs(adj, 4, 0);
    assert_eq(get8(dist, 2), -1); // unreachable
    1
}

fn test_star() -> Int {
    // Star graph: 0 connected to 1,2,3,4
    let adj = Arr8 {
        v0: pow2(1) + pow2(2) + pow2(3) + pow2(4),
        v1: pow2(0),
        v2: pow2(0),
        v3: pow2(0),
        v4: pow2(0),
        v5: 0, v6: 0, v7: 0
    };
    let dist = bfs(adj, 5, 0);
    assert_eq(get8(dist, 1), 1);
    assert_eq(get8(dist, 4), 1);

    // From leaf to leaf: distance 2
    let dist2 = bfs(adj, 5, 1);
    assert_eq(get8(dist2, 2), 2);
    assert_eq(graph_diameter(adj, 5), 2);
    1
}

fn test_cycle() -> Int {
    // Cycle: 0-1-2-3-4-0
    let adj = Arr8 {
        v0: pow2(1) + pow2(4),
        v1: pow2(0) + pow2(2),
        v2: pow2(1) + pow2(3),
        v3: pow2(2) + pow2(4),
        v4: pow2(3) + pow2(0),
        v5: 0, v6: 0, v7: 0
    };
    let dist = bfs(adj, 5, 0);
    assert_eq(get8(dist, 1), 1);
    assert_eq(get8(dist, 2), 2);
    assert_eq(get8(dist, 3), 2); // via 4
    assert_eq(get8(dist, 4), 1);
    assert_eq(graph_diameter(adj, 5), 2);
    1
}

fn main() -> Int {
    test_simple_path();
    test_triangle();
    test_disconnected();
    test_star();
    test_cycle();
    print("[OK] 566_pathfinding_aot");
    0
}
