// main
// ============================================================================

fn main() -> Int {
    test_det_2x2();
    test_trace_2x2();
    test_trace_3x3();
    test_diag_2x2();
    test_diag_3x3();
    test_triu_2x2();
    test_triu_3x3();
    test_tril_2x2();
    test_tril_3x3();
    test_triu_tril_sum();
    test_dot_product();
    test_dot_commutative();
    test_outer_product();
    test_outer_symmetry();
    test_kronecker_product();
    test_kronecker_non_identity();
    test_cross_product();
    test_cross_properties();
    test_matrix_rank_proxy();
    test_inverse_adjugate();
    test_scalar_triple_product();
    print("ALL PASSED");
    0
}
