// @test: run
// @level: L0
// @tags: aot, e2e, milestone, logic, boolean
// @timeout: 30000

// Milestone 635: Boolean algebra and logic operations

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn get_bit(val: Int, pos: Int) -> Int {
    (val / pow2(pos)) % 2
}

fn set_bit(val: Int, pos: Int) -> Int {
    if get_bit(val, pos) == 1 { val }
    else { val + pow2(pos) }
}

fn clear_bit(val: Int, pos: Int) -> Int {
    if get_bit(val, pos) == 0 { val }
    else { val - pow2(pos) }
}

// Bitwise AND (up to n bits)
fn bit_and(a: Int, b: Int, n: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < n {
        if get_bit(a, i) == 1 {
            if get_bit(b, i) == 1 {
                result = result + pow2(i);
            }
        }
        i = i + 1;
    }
    result
}

// Bitwise OR
fn bit_or(a: Int, b: Int, n: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < n {
        if get_bit(a, i) == 1 {
            result = result + pow2(i);
        } else if get_bit(b, i) == 1 {
            result = result + pow2(i);
        }
        i = i + 1;
    }
    result
}

// Bitwise XOR
fn bit_xor(a: Int, b: Int, n: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < n {
        if get_bit(a, i) != get_bit(b, i) {
            result = result + pow2(i);
        }
        i = i + 1;
    }
    result
}

// Bitwise NOT (n-bit)
fn bit_not(a: Int, n: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < n {
        if get_bit(a, i) == 0 {
            result = result + pow2(i);
        }
        i = i + 1;
    }
    result
}

// Popcount
fn popcount(val: Int, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n { count = count + get_bit(val, i); i = i + 1; }
    count
}

// Majority function (1 if more 1s than 0s)
fn majority(val: Int, n: Int) -> Int {
    if popcount(val, n) * 2 > n { 1 } else { 0 }
}

// Parity (1 if odd number of 1s)
fn parity(val: Int, n: Int) -> Int {
    popcount(val, n) % 2
}

// Truth table evaluation for 2-input function
// func is a 4-bit truth table: bit i = output for input pattern i
fn eval_tt(func: Int, a: Int, b: Int) -> Int {
    let pattern = a * 2 + b;
    get_bit(func, pattern)
}

// Evaluate boolean expression: (a AND b) OR (NOT a AND c)
fn mux2(a: Int, b: Int, c: Int) -> Int {
    if a == 1 { b } else { c }
}

fn test_and() -> Int {
    assert_eq(bit_and(15, 12, 4), 12);  // 1111 & 1100 = 1100
    assert_eq(bit_and(10, 12, 4), 8);   // 1010 & 1100 = 1000
    assert_eq(bit_and(15, 15, 4), 15);  // identity
    assert_eq(bit_and(15, 0, 4), 0);    // zero
    1
}

fn test_or() -> Int {
    assert_eq(bit_or(10, 5, 4), 15);   // 1010 | 0101 = 1111
    assert_eq(bit_or(0, 0, 4), 0);
    assert_eq(bit_or(15, 0, 4), 15);
    assert_eq(bit_or(6, 3, 4), 7);     // 0110 | 0011 = 0111
    1
}

fn test_xor() -> Int {
    assert_eq(bit_xor(10, 5, 4), 15);  // 1010 ^ 0101 = 1111
    assert_eq(bit_xor(15, 15, 4), 0);  // self-inverse
    assert_eq(bit_xor(0, 0, 4), 0);
    // XOR associativity: (a ^ b) ^ b = a
    assert_eq(bit_xor(bit_xor(7, 11, 4), 11, 4), 7);
    1
}

fn test_not() -> Int {
    assert_eq(bit_not(0, 4), 15);     // ~0000 = 1111
    assert_eq(bit_not(15, 4), 0);     // ~1111 = 0000
    assert_eq(bit_not(10, 4), 5);     // ~1010 = 0101
    // Double NOT = identity
    assert_eq(bit_not(bit_not(7, 4), 4), 7);
    1
}

fn test_de_morgan() -> Int {
    // De Morgan's laws:
    // NOT(A AND B) = NOT(A) OR NOT(B)
    let a = 10; // 1010
    let b = 12; // 1100
    assert_eq(bit_not(bit_and(a, b, 4), 4), bit_or(bit_not(a, 4), bit_not(b, 4), 4));
    // NOT(A OR B) = NOT(A) AND NOT(B)
    assert_eq(bit_not(bit_or(a, b, 4), 4), bit_and(bit_not(a, 4), bit_not(b, 4), 4));
    1
}

fn test_truth_table() -> Int {
    // AND truth table: 1000 (bit 3 = 1, rest 0) = 8
    assert_eq(eval_tt(8, 0, 0), 0);
    assert_eq(eval_tt(8, 0, 1), 0);
    assert_eq(eval_tt(8, 1, 0), 0);
    assert_eq(eval_tt(8, 1, 1), 1);

    // OR truth table: 1110 = 14
    assert_eq(eval_tt(14, 0, 0), 0);
    assert_eq(eval_tt(14, 0, 1), 1);
    assert_eq(eval_tt(14, 1, 0), 1);
    assert_eq(eval_tt(14, 1, 1), 1);

    // XOR truth table: 0110 = 6
    assert_eq(eval_tt(6, 0, 0), 0);
    assert_eq(eval_tt(6, 0, 1), 1);
    assert_eq(eval_tt(6, 1, 0), 1);
    assert_eq(eval_tt(6, 1, 1), 0);
    1
}

fn test_popcount_parity() -> Int {
    assert_eq(popcount(0, 8), 0);
    assert_eq(popcount(255, 8), 8);
    assert_eq(popcount(170, 8), 4);
    assert_eq(parity(0, 8), 0);
    assert_eq(parity(1, 8), 1);
    assert_eq(parity(3, 8), 0);
    assert_eq(parity(7, 8), 1);
    1
}

fn test_majority() -> Int {
    // 4-bit majority: 1 if 3+ bits set
    assert_eq(majority(7, 4), 1);  // 0111 -> 3/4 bits
    assert_eq(majority(15, 4), 1); // 1111 -> 4/4
    assert_eq(majority(3, 4), 0);  // 0011 -> 2/4
    assert_eq(majority(0, 4), 0);
    1
}

fn test_mux() -> Int {
    // MUX: if a then b else c
    assert_eq(mux2(1, 42, 99), 42);
    assert_eq(mux2(0, 42, 99), 99);
    1
}

fn main() -> Int {
    test_and();
    test_or();
    test_xor();
    test_not();
    test_de_morgan();
    test_truth_table();
    test_popcount_parity();
    test_majority();
    test_mux();
    print("[OK] 635_milestone_aot");
    0
}
