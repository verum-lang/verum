// @test: run
// @level: L0
// @tags: aot, e2e, milestone, comprehensive, crypto-hash
// @timeout: 30000

// Milestone 595: Simple hash functions and checksums

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// Simple additive checksum
fn checksum_add(data: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        sum = sum + get8(data, i);
        i = i + 1;
    }
    sum % 256
}

// XOR checksum (simulated with modular arithmetic)
// For non-negative values < 256, XOR can be simulated
fn xor_byte(a: Int, b: Int) -> Int {
    // XOR each bit
    let mut result = 0;
    let mut pow = 1;
    let mut aa = a;
    let mut bb = b;
    let mut i = 0;
    while i < 8 {
        let bit_a = aa % 2;
        let bit_b = bb % 2;
        let xor_bit = if bit_a == bit_b { 0 } else { 1 };
        result = result + xor_bit * pow;
        pow = pow * 2;
        aa = aa / 2;
        bb = bb / 2;
        i = i + 1;
    }
    result
}

fn checksum_xor(data: Arr8, n: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < n {
        result = xor_byte(result, get8(data, i) % 256);
        i = i + 1;
    }
    result
}

// Fletcher-like checksum (simplified)
fn fletcher_check(data: Arr8, n: Int) -> Int {
    let mut sum1 = 0;
    let mut sum2 = 0;
    let mut i = 0;
    while i < n {
        sum1 = (sum1 + get8(data, i)) % 255;
        sum2 = (sum2 + sum1) % 255;
        i = i + 1;
    }
    sum2 * 256 + sum1
}

// DJB2-like hash (simplified integer version)
fn djb2_hash(data: Arr8, n: Int) -> Int {
    let mut hash_val = 5381;
    let mut i = 0;
    while i < n {
        hash_val = ((hash_val * 33) + get8(data, i)) % 65536;
        i = i + 1;
    }
    hash_val
}

// FNV-like hash (simplified)
fn fnv_hash(data: Arr8, n: Int) -> Int {
    let mut hash_val = 2166;
    let mut i = 0;
    while i < n {
        hash_val = xor_byte(hash_val % 256, get8(data, i) % 256);
        hash_val = (hash_val * 16777) % 65536;
        i = i + 1;
    }
    hash_val
}

// Polynomial rolling hash
fn poly_hash(data: Arr8, n: Int, base: Int, modulus: Int) -> Int {
    let mut hash_val = 0;
    let mut i = 0;
    while i < n {
        hash_val = (hash_val * base + get8(data, i)) % modulus;
        i = i + 1;
    }
    hash_val
}

// Luhn checksum digit
fn luhn_check(digits: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        let pos_from_right = n - 1 - i;
        let d = get8(digits, i);
        if pos_from_right % 2 == 1 {
            let doubled = d * 2;
            let dd = if doubled > 9 { doubled - 9 } else { doubled };
            sum = sum + dd;
        } else {
            sum = sum + d;
        }
        i = i + 1;
    }
    (10 - sum % 10) % 10
}

fn test_xor() -> Int {
    assert_eq(xor_byte(0, 0), 0);
    assert_eq(xor_byte(255, 0), 255);
    assert_eq(xor_byte(255, 255), 0);
    assert_eq(xor_byte(170, 85), 255); // 10101010 XOR 01010101 = 11111111
    assert_eq(xor_byte(15, 240), 255); // 00001111 XOR 11110000
    1
}

fn test_additive_checksum() -> Int {
    let data = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(checksum_add(data, 5), 15);

    let data2 = Arr8 { v0: 100, v1: 200, v2: 50, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(checksum_add(data2, 3), 94); // 350 % 256 = 94
    1
}

fn test_xor_checksum() -> Int {
    let data = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(checksum_xor(data, 4), 0);

    // XOR of same value twice = 0
    let data2 = Arr8 { v0: 42, v1: 42, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(checksum_xor(data2, 2), 0);
    1
}

fn test_fletcher() -> Int {
    // Fletcher checksum for [1, 2]
    // sum1: 0+1=1, sum2: 0+1=1; sum1: 1+2=3, sum2: 1+3=4
    let data = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let f = fletcher_check(data, 2);
    assert_eq(f % 256, 3);   // sum1
    assert_eq(f / 256, 4);   // sum2
    1
}

fn test_hash_consistency() -> Int {
    // Same input -> same hash
    let data = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 0, v5: 0, v6: 0, v7: 0 };
    let h1 = djb2_hash(data, 4);
    let h2 = djb2_hash(data, 4);
    assert_eq(h1, h2);

    // Different input -> different hash (usually)
    let data2 = Arr8 { v0: 11, v1: 20, v2: 30, v3: 40, v4: 0, v5: 0, v6: 0, v7: 0 };
    let h3 = djb2_hash(data2, 4);
    let diff = if h1 != h3 { 1 } else { 0 };
    assert_eq(diff, 1);
    1
}

fn test_poly_hash() -> Int {
    let data = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let h = poly_hash(data, 3, 31, 997);
    // h = ((0*31+1)*31+2)*31+3 = (31+2)*31+3 = 33*31+3 = 1023+3 = 1026 % 997 = 29
    assert_eq(h, 29);
    1
}

fn test_luhn() -> Int {
    // Credit card-like: [7,9,9,2,7,3,9,8] (8 digits)
    // Luhn algorithm
    let digits = Arr8 { v0: 7, v1: 9, v2: 9, v3: 2, v4: 7, v5: 3, v6: 9, v7: 8 };
    let check = luhn_check(digits, 8);
    // Verify check digit is in range 0-9
    let ok = if check >= 0 { if check <= 9 { 1 } else { 0 } } else { 0 };
    assert_eq(ok, 1);

    // Simple known: [0] -> check digit = 0 (sum=0, (10-0)%10=0)
    let simple = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(luhn_check(simple, 1), 0);
    1
}

fn main() -> Int {
    test_xor();
    test_additive_checksum();
    test_xor_checksum();
    test_fletcher();
    test_hash_consistency();
    test_poly_hash();
    test_luhn();
    print("[OK] 595_milestone_aot");
    0
}
