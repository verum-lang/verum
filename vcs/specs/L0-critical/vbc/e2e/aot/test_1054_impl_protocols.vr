// @test: run
// @level: L0
// @tier: 1
// @tags: implement, protocol, methods, dispatch
// @description: Implement blocks with method chaining and cross-type method dispatch

type Vec2 is { x: Int, y: Int };

implement Vec2 {
    fn new(x: Int, y: Int) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn add(&self, other: &Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }

    fn scale(&self, factor: Int) -> Vec2 {
        Vec2 { x: self.x * factor, y: self.y * factor }
    }

    fn dot(&self, other: &Vec2) -> Int {
        self.x * other.x + self.y * other.y
    }

    fn magnitude_sq(&self) -> Int {
        self.x * self.x + self.y * self.y
    }

    fn eq(&self, other: &Vec2) -> Bool {
        self.x == other.x && self.y == other.y
    }
}

fn test_vec2_basic() -> Int {
    let v = Vec2.new(3, 4);
    if v.x != 3 {
        print(f"FAIL vec2 x: expected 3, got {v.x}");
        return 1;
    }
    if v.magnitude_sq() != 25 {
        print(f"FAIL vec2 mag_sq: expected 25, got {v.magnitude_sq()}");
        return 1;
    }
    print("  vec2_basic: OK");
    0
}

fn test_vec2_ops() -> Int {
    let a = Vec2.new(1, 2);
    let b = Vec2.new(3, 4);
    let sum = a.add(&b);
    if sum.x != 4 {
        print(f"FAIL vec2 add x: expected 4, got {sum.x}");
        return 1;
    }
    if sum.y != 6 {
        print(f"FAIL vec2 add y: expected 6, got {sum.y}");
        return 1;
    }
    let scaled = a.scale(3);
    if scaled.x != 3 {
        print(f"FAIL vec2 scale x: expected 3, got {scaled.x}");
        return 1;
    }
    if scaled.y != 6 {
        print(f"FAIL vec2 scale y: expected 6, got {scaled.y}");
        return 1;
    }
    let d = a.dot(&b);
    // 1*3 + 2*4 = 11
    if d != 11 {
        print(f"FAIL vec2 dot: expected 11, got {d}");
        return 1;
    }
    print("  vec2_ops: OK");
    0
}

type Matrix2x2 is { a: Int, b: Int, c: Int, d: Int };

implement Matrix2x2 {
    fn identity() -> Matrix2x2 {
        Matrix2x2 { a: 1, b: 0, c: 0, d: 1 }
    }

    fn det(&self) -> Int {
        self.a * self.d - self.b * self.c
    }

    fn mul_vec(&self, v: &Vec2) -> Vec2 {
        Vec2 {
            x: self.a * v.x + self.b * v.y,
            y: self.c * v.x + self.d * v.y,
        }
    }

    fn mul(&self, other: &Matrix2x2) -> Matrix2x2 {
        Matrix2x2 {
            a: self.a * other.a + self.b * other.c,
            b: self.a * other.b + self.b * other.d,
            c: self.c * other.a + self.d * other.c,
            d: self.c * other.b + self.d * other.d,
        }
    }
}

fn test_matrix() -> Int {
    let id = Matrix2x2.identity();
    if id.det() != 1 {
        print(f"FAIL identity det: expected 1, got {id.det()}");
        return 1;
    }

    let m = Matrix2x2 { a: 2, b: 1, c: 1, d: 3 };
    if m.det() != 5 {
        print(f"FAIL matrix det: expected 5, got {m.det()}");
        return 1;
    }

    let v = Vec2.new(1, 2);
    let result = m.mul_vec(&v);
    // 2*1+1*2=4, 1*1+3*2=7
    if result.x != 4 {
        print(f"FAIL mul_vec x: expected 4, got {result.x}");
        return 1;
    }
    if result.y != 7 {
        print(f"FAIL mul_vec y: expected 7, got {result.y}");
        return 1;
    }
    print("  matrix: OK");
    0
}

fn test_matrix_mul() -> Int {
    let a = Matrix2x2 { a: 1, b: 2, c: 3, d: 4 };
    let b = Matrix2x2 { a: 5, b: 6, c: 7, d: 8 };
    let c = a.mul(&b);
    // [1*5+2*7, 1*6+2*8, 3*5+4*7, 3*6+4*8] = [19, 22, 43, 50]
    if c.a != 19 {
        print(f"FAIL mat_mul a: expected 19, got {c.a}");
        return 1;
    }
    if c.d != 50 {
        print(f"FAIL mat_mul d: expected 50, got {c.d}");
        return 1;
    }
    print("  matrix_mul: OK");
    0
}

fn main() -> Int {
    print("Implement Protocol Tests:");
    let mut failures = 0;
    failures = failures + test_vec2_basic();
    failures = failures + test_vec2_ops();
    failures = failures + test_matrix();
    failures = failures + test_matrix_mul();

    if failures == 0 {
        print("All implement protocol tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
