// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, convolution, signal-processing
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for 1D convolution (signal processing)

type Arr8 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int };
type Arr16 is {
    d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int,
    d8: Int, d9: Int, d10: Int, d11: Int, d12: Int, d13: Int, d14: Int, d15: Int
};

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else { a.d7 }
}

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else if i == 7 { a.d7 } else if i == 8 { a.d8 }
    else if i == 9 { a.d9 } else if i == 10 { a.d10 } else if i == 11 { a.d11 }
    else if i == 12 { a.d12 } else if i == 13 { a.d13 } else if i == 14 { a.d14 }
    else { a.d15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 },
        d8: if i == 8 { v } else { a.d8 }, d9: if i == 9 { v } else { a.d9 },
        d10: if i == 10 { v } else { a.d10 }, d11: if i == 11 { v } else { a.d11 },
        d12: if i == 12 { v } else { a.d12 }, d13: if i == 13 { v } else { a.d13 },
        d14: if i == 14 { v } else { a.d14 }, d15: if i == 15 { v } else { a.d15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0,
            d8: 0, d9: 0, d10: 0, d11: 0, d12: 0, d13: 0, d14: 0, d15: 0 }
}

// 1D convolution: out[i] = sum_k signal[i-k] * kernel[k]
// signal has length sig_len, kernel has length ker_len
// output has length sig_len + ker_len - 1
fn convolve(signal: Arr8, sig_len: Int, kernel: Arr8, ker_len: Int) -> Arr16 {
    let out_len = sig_len + ker_len - 1;
    let mut out = a16_zero();
    let mut i = 0;
    while i < out_len {
        let mut sum = 0;
        let mut k = 0;
        while k < ker_len {
            let si = i - k;
            if si >= 0 {
                if si < sig_len {
                    sum = sum + a8_get(signal, si) * a8_get(kernel, k);
                }
            }
            k = k + 1;
        }
        out = a16_set(out, i, sum);
        i = i + 1;
    }
    out
}

// Correlation (cross-correlation)
fn correlate(a: Arr8, b: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        sum = sum + a8_get(a, i) * a8_get(b, i);
        i = i + 1;
    }
    sum
}

fn main() -> Int {
    // Signal: [1, 2, 3, 4]
    let signal = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 0, d5: 0, d6: 0, d7: 0 };
    // Kernel: [1, 1] (moving average)
    let kernel = Arr8 { d0: 1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };

    // conv([1,2,3,4], [1,1]) = [1, 3, 5, 7, 4]
    let result = convolve(signal, 4, kernel, 2);
    assert_eq(a16_get(result, 0), 1);
    assert_eq(a16_get(result, 1), 3);
    assert_eq(a16_get(result, 2), 5);
    assert_eq(a16_get(result, 3), 7);
    assert_eq(a16_get(result, 4), 4);

    // Identity kernel [1]
    let id_kernel = Arr8 { d0: 1, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let id_result = convolve(signal, 4, id_kernel, 1);
    assert_eq(a16_get(id_result, 0), 1);
    assert_eq(a16_get(id_result, 1), 2);
    assert_eq(a16_get(id_result, 2), 3);
    assert_eq(a16_get(id_result, 3), 4);

    // Derivative kernel [-1, 1]
    let diff_kernel = Arr8 { d0: -1, d1: 1, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0 };
    let diff_result = convolve(signal, 4, diff_kernel, 2);
    // conv([1,2,3,4], [-1,1]) = [-1, -1, -1, -1, 4]
    // Actually: out[0]=1*(-1)=-1, out[1]=2*(-1)+1*1=-1, out[2]=3*(-1)+2*1=-1, out[3]=4*(-1)+3*1=-1, out[4]=4*1=4
    assert_eq(a16_get(diff_result, 0), -1);
    assert_eq(a16_get(diff_result, 1), -1);
    assert_eq(a16_get(diff_result, 2), -1);
    assert_eq(a16_get(diff_result, 3), -1);
    assert_eq(a16_get(diff_result, 4), 4);

    // Correlation (dot product)
    let a = Arr8 { d0: 1, d1: 2, d2: 3, d3: 4, d4: 0, d5: 0, d6: 0, d7: 0 };
    let b = Arr8 { d0: 4, d1: 3, d2: 2, d3: 1, d4: 0, d5: 0, d6: 0, d7: 0 };
    assert_eq(correlate(a, b, 4), 20);  // 4+6+6+4

    // Self-correlation
    assert_eq(correlate(a, a, 4), 30);  // 1+4+9+16

    print("[OK] 297_convolution_aot");
    0
}
