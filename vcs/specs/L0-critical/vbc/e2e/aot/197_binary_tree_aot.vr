// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, binary-tree, data-structures
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for binary search tree using array-based pool (15 nodes max)

// Node pool for binary tree (array-of-struct as flat record)
// Each node: key, left_idx, right_idx (-1 = null)
type TreePool is {
    k0: Int, l0: Int, r0: Int,
    k1: Int, l1: Int, r1: Int,
    k2: Int, l2: Int, r2: Int,
    k3: Int, l3: Int, r3: Int,
    k4: Int, l4: Int, r4: Int,
    k5: Int, l5: Int, r5: Int,
    k6: Int, l6: Int, r6: Int,
    k7: Int, l7: Int, r7: Int,
    k8: Int, l8: Int, r8: Int,
    k9: Int, l9: Int, r9: Int,
    next_free: Int,  // next slot to allocate
    root: Int        // root index (-1 = empty)
};

fn tp_new() -> TreePool {
    TreePool {
        k0: 0, l0: -1, r0: -1,
        k1: 0, l1: -1, r1: -1,
        k2: 0, l2: -1, r2: -1,
        k3: 0, l3: -1, r3: -1,
        k4: 0, l4: -1, r4: -1,
        k5: 0, l5: -1, r5: -1,
        k6: 0, l6: -1, r6: -1,
        k7: 0, l7: -1, r7: -1,
        k8: 0, l8: -1, r8: -1,
        k9: 0, l9: -1, r9: -1,
        next_free: 0, root: -1
    }
}

fn tp_key(t: TreePool, i: Int) -> Int {
    if i == 0 { t.k0 } else if i == 1 { t.k1 }
    else if i == 2 { t.k2 } else if i == 3 { t.k3 }
    else if i == 4 { t.k4 } else if i == 5 { t.k5 }
    else if i == 6 { t.k6 } else if i == 7 { t.k7 }
    else if i == 8 { t.k8 } else { t.k9 }
}

fn tp_left(t: TreePool, i: Int) -> Int {
    if i == 0 { t.l0 } else if i == 1 { t.l1 }
    else if i == 2 { t.l2 } else if i == 3 { t.l3 }
    else if i == 4 { t.l4 } else if i == 5 { t.l5 }
    else if i == 6 { t.l6 } else if i == 7 { t.l7 }
    else if i == 8 { t.l8 } else { t.l9 }
}

fn tp_right(t: TreePool, i: Int) -> Int {
    if i == 0 { t.r0 } else if i == 1 { t.r1 }
    else if i == 2 { t.r2 } else if i == 3 { t.r3 }
    else if i == 4 { t.r4 } else if i == 5 { t.r5 }
    else if i == 6 { t.r6 } else if i == 7 { t.r7 }
    else if i == 8 { t.r8 } else { t.r9 }
}

fn tp_set_key(t: TreePool, i: Int, v: Int) -> TreePool {
    TreePool {
        k0: if i == 0 { v } else { t.k0 }, l0: t.l0, r0: t.r0,
        k1: if i == 1 { v } else { t.k1 }, l1: t.l1, r1: t.r1,
        k2: if i == 2 { v } else { t.k2 }, l2: t.l2, r2: t.r2,
        k3: if i == 3 { v } else { t.k3 }, l3: t.l3, r3: t.r3,
        k4: if i == 4 { v } else { t.k4 }, l4: t.l4, r4: t.r4,
        k5: if i == 5 { v } else { t.k5 }, l5: t.l5, r5: t.r5,
        k6: if i == 6 { v } else { t.k6 }, l6: t.l6, r6: t.r6,
        k7: if i == 7 { v } else { t.k7 }, l7: t.l7, r7: t.r7,
        k8: if i == 8 { v } else { t.k8 }, l8: t.l8, r8: t.r8,
        k9: if i == 9 { v } else { t.k9 }, l9: t.l9, r9: t.r9,
        next_free: t.next_free, root: t.root
    }
}

fn tp_set_left(t: TreePool, i: Int, v: Int) -> TreePool {
    TreePool {
        k0: t.k0, l0: if i == 0 { v } else { t.l0 }, r0: t.r0,
        k1: t.k1, l1: if i == 1 { v } else { t.l1 }, r1: t.r1,
        k2: t.k2, l2: if i == 2 { v } else { t.l2 }, r2: t.r2,
        k3: t.k3, l3: if i == 3 { v } else { t.l3 }, r3: t.r3,
        k4: t.k4, l4: if i == 4 { v } else { t.l4 }, r4: t.r4,
        k5: t.k5, l5: if i == 5 { v } else { t.l5 }, r5: t.r5,
        k6: t.k6, l6: if i == 6 { v } else { t.l6 }, r6: t.r6,
        k7: t.k7, l7: if i == 7 { v } else { t.l7 }, r7: t.r7,
        k8: t.k8, l8: if i == 8 { v } else { t.l8 }, r8: t.r8,
        k9: t.k9, l9: if i == 9 { v } else { t.l9 }, r9: t.r9,
        next_free: t.next_free, root: t.root
    }
}

fn tp_set_right(t: TreePool, i: Int, v: Int) -> TreePool {
    TreePool {
        k0: t.k0, l0: t.l0, r0: if i == 0 { v } else { t.r0 },
        k1: t.k1, l1: t.l1, r1: if i == 1 { v } else { t.r1 },
        k2: t.k2, l2: t.l2, r2: if i == 2 { v } else { t.r2 },
        k3: t.k3, l3: t.l3, r3: if i == 3 { v } else { t.r3 },
        k4: t.k4, l4: t.l4, r4: if i == 4 { v } else { t.r4 },
        k5: t.k5, l5: t.l5, r5: if i == 5 { v } else { t.r5 },
        k6: t.k6, l6: t.l6, r6: if i == 6 { v } else { t.r6 },
        k7: t.k7, l7: t.l7, r7: if i == 7 { v } else { t.r7 },
        k8: t.k8, l8: t.l8, r8: if i == 8 { v } else { t.r8 },
        k9: t.k9, l9: t.l9, r9: if i == 9 { v } else { t.r9 },
        next_free: t.next_free, root: t.root
    }
}

fn bst_contains(t: TreePool, key: Int) -> Bool {
    let mut idx = t.root;
    while idx != -1 {
        let k = tp_key(t, idx);
        if key == k { return true; }
        if key < k {
            idx = tp_left(t, idx);
        } else {
            idx = tp_right(t, idx);
        }
    }
    false
}

@allow(unbounded_recursion)
fn bst_count(t: TreePool, idx: Int) -> Int {
    if idx == -1 { return 0; }
    1 + bst_count(t, tp_left(t, idx)) + bst_count(t, tp_right(t, idx))
}

fn bst_min(t: TreePool) -> Int {
    let mut idx = t.root;
    while tp_left(t, idx) != -1 {
        idx = tp_left(t, idx);
    }
    tp_key(t, idx)
}

fn bst_max(t: TreePool) -> Int {
    let mut idx = t.root;
    while tp_right(t, idx) != -1 {
        idx = tp_right(t, idx);
    }
    tp_key(t, idx)
}

@allow(unbounded_recursion)
fn bst_height(t: TreePool, idx: Int) -> Int {
    if idx == -1 { return 0; }
    let lh = bst_height(t, tp_left(t, idx));
    let rh = bst_height(t, tp_right(t, idx));
    1 + if lh > rh { lh } else { rh }
}

fn main() -> Int {
    // Manually build a BST:
    //        5
    //       / \
    //      3   8
    //     / \   \
    //    1   4   9
    //     \
    //      2
    let mut t = tp_new();

    // Node 0: key=5 (root)
    t = tp_set_key(t, 0, 5);
    t = tp_set_left(t, 0, 1);    // left child = node 1
    t = tp_set_right(t, 0, 2);   // right child = node 2

    // Node 1: key=3
    t = tp_set_key(t, 1, 3);
    t = tp_set_left(t, 1, 3);    // left child = node 3
    t = tp_set_right(t, 1, 4);   // right child = node 4

    // Node 2: key=8
    t = tp_set_key(t, 2, 8);
    t = tp_set_right(t, 2, 5);   // right child = node 5

    // Node 3: key=1
    t = tp_set_key(t, 3, 1);
    t = tp_set_right(t, 3, 6);   // right child = node 6

    // Node 4: key=4
    t = tp_set_key(t, 4, 4);

    // Node 5: key=9
    t = tp_set_key(t, 5, 9);

    // Node 6: key=2
    t = tp_set_key(t, 6, 2);

    // Set root
    t = TreePool {
        k0: t.k0, l0: t.l0, r0: t.r0,
        k1: t.k1, l1: t.l1, r1: t.r1,
        k2: t.k2, l2: t.l2, r2: t.r2,
        k3: t.k3, l3: t.l3, r3: t.r3,
        k4: t.k4, l4: t.l4, r4: t.r4,
        k5: t.k5, l5: t.l5, r5: t.r5,
        k6: t.k6, l6: t.l6, r6: t.r6,
        k7: t.k7, l7: t.l7, r7: t.r7,
        k8: t.k8, l8: t.l8, r8: t.r8,
        k9: t.k9, l9: t.l9, r9: t.r9,
        next_free: 7, root: 0
    };

    // Contains tests
    assert_eq(bst_contains(t, 5), true);
    assert_eq(bst_contains(t, 3), true);
    assert_eq(bst_contains(t, 8), true);
    assert_eq(bst_contains(t, 1), true);
    assert_eq(bst_contains(t, 2), true);
    assert_eq(bst_contains(t, 4), true);
    assert_eq(bst_contains(t, 9), true);
    assert_eq(bst_contains(t, 0), false);
    assert_eq(bst_contains(t, 6), false);
    assert_eq(bst_contains(t, 7), false);
    assert_eq(bst_contains(t, 10), false);

    // Count = 7 nodes
    assert_eq(bst_count(t, t.root), 7);

    // Min and max
    assert_eq(bst_min(t), 1);
    assert_eq(bst_max(t), 9);

    // Height = 4 (root -> 3 -> 1 -> 2)
    assert_eq(bst_height(t, t.root), 4);

    print("[OK] 197_binary_tree_aot");
    0
}
