// @test: run
// @level: L0
// @tags: aot, e2e, graph-coloring, greedy, chromatic
// @timeout: 30000

// Graph coloring using greedy algorithm

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn neg_ones() -> Arr8 { Arr8 { v0: 0-1, v1: 0-1, v2: 0-1, v3: 0-1, v4: 0-1, v5: 0-1, v6: 0-1, v7: 0-1 } }

// Adjacency matrix: adj[i*8+j/8] stores edges as packed bits (simulated)
// For simplicity, store adjacency as rows in separate Arr8s
// adj_row[i] stores neighbors of node i as bit flags in an Int
// bit j set means edge i->j

fn has_edge(adj: Arr8, u: Int, v: Int) -> Int {
    let row = get8(adj, u);
    let mut mask = 1;
    let mut k = 0;
    while k < v { mask = mask * 2; k = k + 1; }
    if (row / mask) % 2 == 1 { 1 } else { 0 }
}

fn add_edge(adj: Arr8, u: Int, v: Int) -> Arr8 {
    let mut mask_u = 1;
    let mut k = 0;
    while k < v { mask_u = mask_u * 2; k = k + 1; }
    let row_u = get8(adj, u);
    let new_adj = if (row_u / mask_u) % 2 == 0 {
        set8(adj, u, row_u + mask_u)
    } else { adj };
    // Also add v->u (undirected)
    let mut mask_v = 1;
    let mut k2 = 0;
    while k2 < u { mask_v = mask_v * 2; k2 = k2 + 1; }
    let row_v = get8(new_adj, v);
    if (row_v / mask_v) % 2 == 0 {
        set8(new_adj, v, row_v + mask_v)
    } else { new_adj }
}

// Greedy graph coloring: assign smallest available color to each node
fn greedy_color(adj: Arr8, n: Int) -> Arr8 {
    let mut colors = neg_ones(); // -1 = uncolored
    // Color node 0 with color 0
    colors = set8(colors, 0, 0);
    let mut node = 1;
    while node < n {
        // Find used colors among neighbors
        let mut used = zeros(); // used[c] = 1 if color c is taken by neighbor
        let mut nb = 0;
        while nb < n {
            if has_edge(adj, node, nb) == 1 {
                let c = get8(colors, nb);
                if c >= 0 {
                    used = set8(used, c, 1);
                }
            }
            nb = nb + 1;
        }
        // Find smallest unused color
        let mut c = 0;
        while c < 8 {
            if get8(used, c) == 0 {
                colors = set8(colors, node, c);
                c = 100; // break
            } else {
                c = c + 1;
            }
        }
        if c == 8 { colors = set8(colors, node, 8); } // fallback (shouldn't happen for <8 nodes)
        node = node + 1;
    }
    colors
}

fn max_color(colors: Arr8, n: Int) -> Int {
    let mut mx = 0;
    let mut i = 0;
    while i < n {
        let c = get8(colors, i);
        if c > mx { mx = c; }
        i = i + 1;
    }
    mx
}

// Verify coloring: no two adjacent nodes share a color
fn valid_coloring(adj: Arr8, colors: Arr8, n: Int) -> Int {
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if has_edge(adj, i, j) == 1 {
                if get8(colors, i) == get8(colors, j) {
                    return 0;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    1
}

fn test_triangle() -> Int {
    // Triangle: 0-1, 1-2, 0-2 (needs 3 colors)
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 0, 2);
    let colors = greedy_color(adj, 3);
    assert_eq(valid_coloring(adj, colors, 3), 1);
    assert_eq(max_color(colors, 3), 2); // 3 colors: 0,1,2
    1
}

fn test_bipartite() -> Int {
    // Complete bipartite K2,2: 0-2, 0-3, 1-2, 1-3
    let mut adj = zeros();
    adj = add_edge(adj, 0, 2);
    adj = add_edge(adj, 0, 3);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 1, 3);
    let colors = greedy_color(adj, 4);
    assert_eq(valid_coloring(adj, colors, 4), 1);
    // Bipartite needs at most 2 colors
    let mx = max_color(colors, 4);
    let ok = if mx <= 1 { 1 } else { 0 };
    assert_eq(ok, 1);
    1
}

fn test_path() -> Int {
    // Path: 0-1-2-3-4 (needs 2 colors)
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 2, 3);
    adj = add_edge(adj, 3, 4);
    let colors = greedy_color(adj, 5);
    assert_eq(valid_coloring(adj, colors, 5), 1);
    let mx = max_color(colors, 5);
    let ok = if mx <= 1 { 1 } else { 0 };
    assert_eq(ok, 1);
    1
}

fn test_star() -> Int {
    // Star: 0 connected to 1,2,3,4,5
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 0, 2);
    adj = add_edge(adj, 0, 3);
    adj = add_edge(adj, 0, 4);
    adj = add_edge(adj, 0, 5);
    let colors = greedy_color(adj, 6);
    assert_eq(valid_coloring(adj, colors, 6), 1);
    // Star needs 2 colors
    assert_eq(max_color(colors, 6), 1);
    1
}

fn test_complete4() -> Int {
    // K4: all pairs connected (needs 4 colors)
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 0, 2);
    adj = add_edge(adj, 0, 3);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 1, 3);
    adj = add_edge(adj, 2, 3);
    let colors = greedy_color(adj, 4);
    assert_eq(valid_coloring(adj, colors, 4), 1);
    assert_eq(max_color(colors, 4), 3); // colors 0,1,2,3
    1
}

fn main() -> Int {
    test_triangle();
    test_bipartite();
    test_path();
    test_star();
    test_complete4();
    print("[OK] 578_graph_coloring_aot");
    0
}
