// @test: run
// @level: L0
// @tags: aot, e2e, sparse-table, rmq, range-query
// @timeout: 30000

// Sparse table for range minimum/maximum queries

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// For 8 elements, we need sparse tables of levels 0,1,2,3
// Level k covers ranges of length 2^k
// st[k][i] = min/max of arr[i..i+2^k-1]

type SparseTable is {
    level0: Arr8,  // ranges of length 1 (original array)
    level1: Arr8,  // ranges of length 2
    level2: Arr8,  // ranges of length 4
    level3: Arr8   // ranges of length 8 (only 1 entry)
};

fn build_min_st(arr: Arr8, n: Int) -> SparseTable {
    let level0 = arr;

    // Level 1: min(arr[i], arr[i+1])
    let mut level1 = zeros();
    let mut i = 0;
    while i + 1 < n {
        level1 = set8(level1, i, min_val(get8(arr, i), get8(arr, i + 1)));
        i = i + 1;
    }

    // Level 2: min(level1[i], level1[i+2])
    let mut level2 = zeros();
    i = 0;
    while i + 3 < n {
        level2 = set8(level2, i, min_val(get8(level1, i), get8(level1, i + 2)));
        i = i + 1;
    }

    // Level 3: min(level2[i], level2[i+4])
    let mut level3 = zeros();
    i = 0;
    while i + 7 < n {
        level3 = set8(level3, i, min_val(get8(level2, i), get8(level2, i + 4)));
        i = i + 1;
    }

    SparseTable { level0: level0, level1: level1, level2: level2, level3: level3 }
}

// Log2 floor
fn log2_floor(n: Int) -> Int {
    if n <= 1 { return 0; }
    if n <= 3 { return 1; }
    if n <= 7 { return 2; }
    3
}

fn pow2(k: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < k { r = r * 2; i = i + 1; }
    r
}

// Query: min of arr[l..r] inclusive
fn query_min(st: SparseTable, l: Int, r: Int) -> Int {
    let len = r - l + 1;
    let k = log2_floor(len);
    let p = pow2(k);

    let left_min = if k == 0 { get8(st.level0, l) }
                   else if k == 1 { get8(st.level1, l) }
                   else if k == 2 { get8(st.level2, l) }
                   else { get8(st.level3, l) };

    let right_min = if k == 0 { get8(st.level0, r - p + 1) }
                    else if k == 1 { get8(st.level1, r - p + 1) }
                    else if k == 2 { get8(st.level2, r - p + 1) }
                    else { get8(st.level3, r - p + 1) };

    min_val(left_min, right_min)
}

// Brute-force range min for verification
fn brute_min(arr: Arr8, l: Int, r: Int) -> Int {
    let mut m = get8(arr, l);
    let mut i = l + 1;
    while i <= r {
        let v = get8(arr, i);
        if v < m { m = v; }
        i = i + 1;
    }
    m
}

fn brute_max(arr: Arr8, l: Int, r: Int) -> Int {
    let mut m = get8(arr, l);
    let mut i = l + 1;
    while i <= r {
        let v = get8(arr, i);
        if v > m { m = v; }
        i = i + 1;
    }
    m
}

fn test_min_queries() -> Int {
    let arr = Arr8 { v0: 5, v1: 2, v2: 8, v3: 1, v4: 9, v5: 3, v6: 7, v7: 4 };
    let st = build_min_st(arr, 8);

    // Single element queries
    assert_eq(query_min(st, 0, 0), 5);
    assert_eq(query_min(st, 3, 3), 1);

    // Two element queries
    assert_eq(query_min(st, 0, 1), 2);
    assert_eq(query_min(st, 2, 3), 1);

    // Larger ranges
    assert_eq(query_min(st, 0, 3), 1);
    assert_eq(query_min(st, 4, 7), 3);
    assert_eq(query_min(st, 0, 7), 1);

    // Verify against brute force
    assert_eq(query_min(st, 1, 5), brute_min(arr, 1, 5));
    assert_eq(query_min(st, 2, 6), brute_min(arr, 2, 6));
    assert_eq(query_min(st, 0, 4), brute_min(arr, 0, 4));
    1
}

fn test_sorted_array() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let st = build_min_st(arr, 8);

    // Min is always the left endpoint
    assert_eq(query_min(st, 0, 7), 1);
    assert_eq(query_min(st, 3, 7), 4);
    assert_eq(query_min(st, 5, 7), 6);
    1
}

fn test_reverse_sorted() -> Int {
    let arr = Arr8 { v0: 8, v1: 7, v2: 6, v3: 5, v4: 4, v5: 3, v6: 2, v7: 1 };
    let st = build_min_st(arr, 8);

    // Min is always the right endpoint
    assert_eq(query_min(st, 0, 7), 1);
    assert_eq(query_min(st, 0, 3), 5);
    assert_eq(query_min(st, 0, 0), 8);
    1
}

fn test_brute_max() -> Int {
    let arr = Arr8 { v0: 5, v1: 2, v2: 8, v3: 1, v4: 9, v5: 3, v6: 7, v7: 4 };
    assert_eq(brute_max(arr, 0, 7), 9);
    assert_eq(brute_max(arr, 0, 2), 8);
    assert_eq(brute_max(arr, 5, 7), 7);
    1
}

fn main() -> Int {
    test_min_queries();
    test_sorted_array();
    test_reverse_sorted();
    test_brute_max();
    print("[OK] 508_sparse_table_aot");
    0
}
