// @test: run
// @level: L0
// @tags: aot, e2e, polynomial, horner, evaluation
// @timeout: 30000

// Polynomial evaluation using Horner's method and related operations
// Coefficients stored in Arr8: p(x) = c0 + c1*x + c2*x^2 + ...

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Evaluate polynomial using Horner's method: p(x) = c[n-1]*x^(n-1) + ... + c[1]*x + c[0]
// Horner: ((c[n-1]*x + c[n-2])*x + c[n-3])*x + ... + c[0]
fn poly_eval(coeffs: Arr8, degree: Int, x: Int) -> Int {
    let mut result = get8(coeffs, degree);
    let mut i = degree - 1;
    while i >= 0 {
        result = result * x + get8(coeffs, i);
        i = i - 1;
    }
    result
}

// Polynomial addition: result = a + b
fn poly_add(a: Arr8, na: Int, b: Arr8, nb: Int) -> Arr8 {
    let mut result = zeros();
    let n = if na > nb { na } else { nb };
    let mut i = 0;
    while i <= n {
        let va = if i <= na { get8(a, i) } else { 0 };
        let vb = if i <= nb { get8(b, i) } else { 0 };
        result = set8(result, i, va + vb);
        i = i + 1;
    }
    result
}

// Polynomial multiplication (naive)
fn poly_mul(a: Arr8, na: Int, b: Arr8, nb: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i <= na {
        let mut j = 0;
        while j <= nb {
            let idx = i + j;
            if idx < 8 {
                result = set8(result, idx, get8(result, idx) + get8(a, i) * get8(b, j));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

// Formal derivative: d/dx(c0 + c1*x + c2*x^2 + ...) = c1 + 2*c2*x + 3*c3*x^2 + ...
fn poly_deriv(coeffs: Arr8, degree: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 1;
    while i <= degree {
        result = set8(result, i - 1, i * get8(coeffs, i));
        i = i + 1;
    }
    result
}

// Polynomial degree (highest non-zero coefficient index)
fn poly_degree(coeffs: Arr8, max_deg: Int) -> Int {
    let mut d = max_deg;
    while d > 0 {
        if get8(coeffs, d) != 0 { return d; }
        d = d - 1;
    }
    0
}

// Evaluate polynomial modulo m (for modular arithmetic)
fn poly_eval_mod(coeffs: Arr8, degree: Int, x: Int, m: Int) -> Int {
    let mut result = get8(coeffs, degree) % m;
    let mut i = degree - 1;
    while i >= 0 {
        result = (result * (x % m) + get8(coeffs, i)) % m;
        i = i - 1;
    }
    // Ensure non-negative result
    if result < 0 { result + m } else { result }
}

fn test_horner_basic() -> Int {
    // p(x) = 2 + 3x + x^2, degree 2
    let p = Arr8 { v0: 2, v1: 3, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // p(0) = 2
    assert_eq(poly_eval(p, 2, 0), 2);
    // p(1) = 2 + 3 + 1 = 6
    assert_eq(poly_eval(p, 2, 1), 6);
    // p(2) = 2 + 6 + 4 = 12
    assert_eq(poly_eval(p, 2, 2), 12);
    // p(3) = 2 + 9 + 9 = 20
    assert_eq(poly_eval(p, 2, 3), 20);
    // p(-1) = 2 - 3 + 1 = 0
    assert_eq(poly_eval(p, 2, -1), 0);
    1
}

fn test_horner_cubic() -> Int {
    // p(x) = 1 + 0x + 0x^2 + x^3 = 1 + x^3
    let p = Arr8 { v0: 1, v1: 0, v2: 0, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_eval(p, 3, 2), 9);   // 1 + 8
    assert_eq(poly_eval(p, 3, 3), 28);  // 1 + 27
    assert_eq(poly_eval(p, 3, -1), 0);  // 1 + (-1) = 0
    1
}

fn test_poly_add() -> Int {
    // a(x) = 1 + 2x + 3x^2 (degree 2)
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // b(x) = 4 + 5x (degree 1)
    let b = Arr8 { v0: 4, v1: 5, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // a+b = 5 + 7x + 3x^2
    let sum = poly_add(a, 2, b, 1);
    assert_eq(get8(sum, 0), 5);
    assert_eq(get8(sum, 1), 7);
    assert_eq(get8(sum, 2), 3);
    1
}

fn test_poly_mul() -> Int {
    // a(x) = 1 + x (degree 1)
    let a = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // b(x) = 1 - x (degree 1) → coeffs [1, -1]
    let b = Arr8 { v0: 1, v1: -1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // a*b = 1 - x^2 → coeffs [1, 0, -1]
    let prod = poly_mul(a, 1, b, 1);
    assert_eq(get8(prod, 0), 1);
    assert_eq(get8(prod, 1), 0);
    assert_eq(get8(prod, 2), -1);
    1
}

fn test_poly_mul2() -> Int {
    // (1 + x)^2 = 1 + 2x + x^2
    let a = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let sq = poly_mul(a, 1, a, 1);
    assert_eq(get8(sq, 0), 1);
    assert_eq(get8(sq, 1), 2);
    assert_eq(get8(sq, 2), 1);

    // (1 + x)^3 = 1 + 3x + 3x^2 + x^3
    let cube = poly_mul(sq, 2, a, 1);
    assert_eq(get8(cube, 0), 1);
    assert_eq(get8(cube, 1), 3);
    assert_eq(get8(cube, 2), 3);
    assert_eq(get8(cube, 3), 1);
    1
}

fn test_derivative() -> Int {
    // p(x) = 3 + 2x + 5x^2 + x^3
    let p = Arr8 { v0: 3, v1: 2, v2: 5, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    // p'(x) = 2 + 10x + 3x^2
    let dp = poly_deriv(p, 3);
    assert_eq(get8(dp, 0), 2);
    assert_eq(get8(dp, 1), 10);
    assert_eq(get8(dp, 2), 3);

    // Verify: p'(1) = 2 + 10 + 3 = 15
    assert_eq(poly_eval(dp, 2, 1), 15);
    1
}

fn test_degree() -> Int {
    let p = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_degree(p, 7), 2);

    let constant = Arr8 { v0: 5, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_degree(constant, 7), 0);
    1
}

fn test_mod_eval() -> Int {
    // p(x) = 1 + 2x + 3x^2, evaluate at x=10 mod 7
    let p = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // p(10) = 1 + 20 + 300 = 321. 321 % 7 = 321 - 45*7 = 321 - 315 = 6
    assert_eq(poly_eval_mod(p, 2, 10, 7), 6);
    1
}

fn main() -> Int {
    test_horner_basic();
    test_horner_cubic();
    test_poly_add();
    test_poly_mul();
    test_poly_mul2();
    test_derivative();
    test_degree();
    test_mod_eval();
    print("[OK] 474_polynomial_aot");
    0
}
