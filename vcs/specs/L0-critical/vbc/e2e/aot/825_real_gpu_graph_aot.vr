// @test: run
// @tier: 2
// @level: L0
// @tags: aot, gpu, real-opcode, graph
// @expected-exit: 0

// Tests REAL GPU graph capture intrinsics through AOT (LLVM) pipeline.
// Mirror of interpreter test 205. Exercises gpu_graph_create,
// gpu_graph_begin, gpu_graph_end, gpu_graph_inst, gpu_graph_destroy.

// GPU graph intrinsic declarations
fn gpu_graph_create() -> Int { @intrinsic("GPU_GRAPH_CREATE") }
fn gpu_graph_begin(stream_id: Int) -> Int { @intrinsic("GPU_GRAPH_BEGIN", stream_id) }
fn gpu_graph_end(stream_id: Int) -> Int { @intrinsic("GPU_GRAPH_END", stream_id) }
fn gpu_graph_inst(graph: Int) -> Int { @intrinsic("GPU_GRAPH_INST", graph) }
fn gpu_graph_destroy(graph: Int) -> Int { @intrinsic("GPU_GRAPH_DESTROY", graph) }
fn gpu_stream_create() -> Int { @intrinsic("GPU_STREAM_CREATE") }
fn gpu_stream_destroy(stream_id: Int) -> Int { @intrinsic("GPU_STREAM_DESTROY", stream_id) }

fn main() -> Int {
    let mut errors = 0;

    // Test 1: Create a graph
    let g = gpu_graph_create();
    if g < 0 { errors = errors + 1; }

    // Test 2: Create a stream for graph capture
    let s = gpu_stream_create();
    if s < 0 { errors = errors + 1; }

    // Test 3: Begin graph capture on stream
    let begin = gpu_graph_begin(s);
    if begin != 0 { errors = errors + 1; }

    // Test 4: End graph capture
    let end = gpu_graph_end(s);
    if end != 0 { errors = errors + 1; }

    // Test 5: Instantiate graph
    let inst = gpu_graph_inst(g);
    if inst < 0 { errors = errors + 1; }

    // Test 6: Destroy graph
    let dg = gpu_graph_destroy(g);
    if dg != 0 { errors = errors + 1; }

    // Test 7: Cleanup stream
    let ds = gpu_stream_destroy(s);
    if ds != 0 { errors = errors + 1; }

    errors
}
