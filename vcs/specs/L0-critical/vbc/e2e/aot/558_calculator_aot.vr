// @test: run
// @level: L0
// @tags: aot, e2e, calculator, rpn, computation
// @timeout: 30000

// RPN calculator with memory and multiple operations

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Calculator with stack and memory registers
// Ops: positive = push number
//  -1=ADD, -2=SUB, -3=MUL, -4=DIV, -5=MOD
//  -6=DUP, -7=SWAP, -8=ABS, -9=NEG, -10=MAX, -11=MIN
//  -12=SQR (square)

type CalcState is { stack: Arr8, sp: Int };

fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

fn calc_exec(ops: Arr8, n: Int) -> CalcState {
    let mut stack = zeros();
    let mut sp = 0;
    let mut i = 0;
    while i < n {
        let op = get8(ops, i);
        if op >= 0 {
            stack = set8(stack, sp, op);
            sp = sp + 1;
        } else if op == -1 {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a + b);
        } else if op == -2 {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a - b);
        } else if op == -3 {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a * b);
        } else if op == -4 {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a / b);
        } else if op == -5 {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a % b);
        } else if op == -6 {
            // DUP
            let a = get8(stack, sp - 1);
            stack = set8(stack, sp, a);
            sp = sp + 1;
        } else if op == -7 {
            // SWAP
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            stack = set8(stack, sp - 1, b);
            stack = set8(stack, sp - 2, a);
        } else if op == -8 {
            // ABS
            let a = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, abs_val(a));
        } else if op == -9 {
            // NEG
            let a = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, 0 - a);
        } else if op == -10 {
            // MAX
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, if a > b { a } else { b });
        } else if op == -11 {
            // MIN
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, if a < b { a } else { b });
        } else if op == -12 {
            // SQR
            let a = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, a * a);
        }
        i = i + 1;
    }
    CalcState { stack: stack, sp: sp }
}

fn calc_top(cs: CalcState) -> Int {
    get8(cs.stack, cs.sp - 1)
}

fn test_basic_arithmetic() -> Int {
    // 3 + 4 = 7
    let ops = Arr8 { v0: 3, v1: 4, v2: -1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops, 3)), 7);

    // 10 - 3 = 7
    let ops2 = Arr8 { v0: 10, v1: 3, v2: -2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops2, 3)), 7);

    // 6 * 7 = 42
    let ops3 = Arr8 { v0: 6, v1: 7, v2: -3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops3, 3)), 42);
    1
}

fn test_complex_expression() -> Int {
    // (2 + 3) * (7 - 4) = 5 * 3 = 15
    // RPN: 2 3 + 7 4 - *
    let ops = Arr8 { v0: 2, v1: 3, v2: -1, v3: 7, v4: 4, v5: -2, v6: -3, v7: 0 };
    assert_eq(calc_top(calc_exec(ops, 7)), 15);
    1
}

fn test_dup_swap() -> Int {
    // 5 DUP * → 5 5 * = 25 (square via DUP)
    let ops = Arr8 { v0: 5, v1: -6, v2: -3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops, 3)), 25);

    // 3 7 SWAP - → 7 3 - = 4 (WRONG: actually 7-3=4)
    // After SWAP: stack is [7, 3], then SUB: 7-3=4
    let ops2 = Arr8 { v0: 3, v1: 7, v2: -7, v3: -2, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops2, 4)), 4);
    1
}

fn test_abs_neg() -> Int {
    // -5 ABS = 5
    let ops = Arr8 { v0: 5, v1: -9, v2: -8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops, 3)), 5); // NEG(5)=-5, ABS(-5)=5
    1
}

fn test_max_min() -> Int {
    // MAX(3, 7) = 7
    let ops = Arr8 { v0: 3, v1: 7, v2: -10, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops, 3)), 7);

    // MIN(3, 7) = 3
    let ops2 = Arr8 { v0: 3, v1: 7, v2: -11, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops2, 3)), 3);
    1
}

fn test_sqr() -> Int {
    // 6 SQR = 36
    let ops = Arr8 { v0: 6, v1: -12, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops, 2)), 36);
    1
}

fn test_mod() -> Int {
    // 17 % 5 = 2
    let ops = Arr8 { v0: 17, v1: 5, v2: -5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(calc_top(calc_exec(ops, 3)), 2);
    1
}

fn test_stack_depth() -> Int {
    // Push 3 values, check stack pointer
    let ops = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let cs = calc_exec(ops, 3);
    assert_eq(cs.sp, 3);

    // After ADD, sp decreases by 1
    let ops2 = Arr8 { v0: 1, v1: 2, v2: -1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let cs2 = calc_exec(ops2, 3);
    assert_eq(cs2.sp, 1);
    1
}

fn main() -> Int {
    test_basic_arithmetic();
    test_complex_expression();
    test_dup_swap();
    test_abs_neg();
    test_max_min();
    test_sqr();
    test_mod();
    test_stack_depth();
    print("[OK] 558_calculator_aot");
    0
}
