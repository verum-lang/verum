// @test: run
// @level: L0
// @tags: aot, e2e, topological-sort, dag, graph
// @timeout: 30000

// Topological sort on a small DAG (up to 6 nodes)
// Adjacency stored as bit matrix in Arr8 (row i = neighbors of node i)

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn get_bit(val: Int, pos: Int) -> Int { (val / pow2(pos)) % 2 }

// Adjacency matrix: adj[i] is a bitmask of nodes that i points to
// Edge i->j means bit j is set in adj[i]

// Compute in-degree of each node
fn in_degree(adj: Arr8, n: Int, node: Int) -> Int {
    let mut deg = 0;
    let mut i = 0;
    while i < n {
        if get_bit(get8(adj, i), node) == 1 { deg = deg + 1; }
        i = i + 1;
    }
    deg
}

// Kahn's algorithm: return topological order in Arr8 (or partial if cycle)
fn topo_sort(adj: Arr8, n: Int) -> Arr8 {
    let mut result = zeros();
    let mut result_idx = 0;
    // Compute in-degrees
    let mut degrees = zeros();
    let mut i = 0;
    while i < n {
        degrees = set8(degrees, i, in_degree(adj, n, i));
        i = i + 1;
    }
    // Repeatedly find node with in-degree 0, add to result, remove edges
    let mut done = 0;
    while done == 0 {
        // Find first node with in-degree 0 that hasn't been added
        let mut found = 0 - 1;
        let mut j = 0;
        while j < n {
            if get8(degrees, j) == 0 {
                // Check not already in result (use sentinel -1)
                if found < 0 { found = j; }
            }
            j = j + 1;
        }
        if found < 0 { done = 1; } // No more zero in-degree nodes
        else {
            result = set8(result, result_idx, found);
            result_idx = result_idx + 1;
            // Mark as processed by setting degree to -1
            degrees = set8(degrees, found, 0 - 1);
            // Decrease in-degrees of neighbors
            let neighbors = get8(adj, found);
            let mut k = 0;
            while k < n {
                if get_bit(neighbors, k) == 1 {
                    let d = get8(degrees, k);
                    if d > 0 { degrees = set8(degrees, k, d - 1); }
                }
                k = k + 1;
            }
        }
    }
    result
}

// Count of nodes in topological order
fn topo_sort_len(adj: Arr8, n: Int) -> Int {
    // If topo sort produces n nodes, graph is a DAG
    let mut degrees = zeros();
    let mut i = 0;
    while i < n {
        degrees = set8(degrees, i, in_degree(adj, n, i));
        i = i + 1;
    }
    let mut count = 0;
    let mut done = 0;
    while done == 0 {
        let mut found = 0 - 1;
        let mut j = 0;
        while j < n {
            if get8(degrees, j) == 0 {
                if found < 0 { found = j; }
            }
            j = j + 1;
        }
        if found < 0 { done = 1; }
        else {
            count = count + 1;
            degrees = set8(degrees, found, 0 - 1);
            let neighbors = get8(adj, found);
            let mut k = 0;
            while k < n {
                if get_bit(neighbors, k) == 1 {
                    let d = get8(degrees, k);
                    if d > 0 { degrees = set8(degrees, k, d - 1); }
                }
                k = k + 1;
            }
        }
    }
    count
}

// Verify topological order: for every edge i->j, i appears before j
fn verify_topo(adj: Arr8, n: Int, order: Arr8) -> Int {
    // Build position map
    let mut pos = zeros();
    let mut i = 0;
    while i < n { pos = set8(pos, get8(order, i), i); i = i + 1; }
    // Check all edges
    let mut valid = 1;
    i = 0;
    while i < n {
        let neighbors = get8(adj, i);
        let mut j = 0;
        while j < n {
            if get_bit(neighbors, j) == 1 {
                if get8(pos, i) >= get8(pos, j) { valid = 0; }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    valid
}

fn test_linear_chain() -> Int {
    // 0 -> 1 -> 2 -> 3
    let adj = Arr8 { v0: 2, v1: 4, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // adj[0]=010=2 (0->1), adj[1]=100=4 (1->2), adj[2]=1000=8 (2->3)
    let order = topo_sort(adj, 4);
    assert_eq(get8(order, 0), 0);
    assert_eq(get8(order, 1), 1);
    assert_eq(get8(order, 2), 2);
    assert_eq(get8(order, 3), 3);
    assert_eq(topo_sort_len(adj, 4), 4);
    assert_eq(verify_topo(adj, 4, order), 1);
    1
}

fn test_diamond() -> Int {
    // Diamond: 0->1, 0->2, 1->3, 2->3
    // adj[0] = bit1 + bit2 = 2 + 4 = 6
    // adj[1] = bit3 = 8
    // adj[2] = bit3 = 8
    let adj = Arr8 { v0: 6, v1: 8, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let order = topo_sort(adj, 4);
    assert_eq(topo_sort_len(adj, 4), 4); // All nodes reachable
    assert_eq(verify_topo(adj, 4, order), 1);
    // 0 must be first, 3 must be last
    assert_eq(get8(order, 0), 0);
    assert_eq(get8(order, 3), 3);
    1
}

fn test_independent() -> Int {
    // No edges: all nodes are independent
    let adj = zeros();
    let order = topo_sort(adj, 4);
    assert_eq(topo_sort_len(adj, 4), 4);
    // Any order is valid for independent nodes
    assert_eq(verify_topo(adj, 4, order), 1);
    1
}

fn test_in_degree() -> Int {
    // Diamond: 0->1, 0->2, 1->3, 2->3
    let adj = Arr8 { v0: 6, v1: 8, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(in_degree(adj, 4, 0), 0); // no edges into 0
    assert_eq(in_degree(adj, 4, 1), 1); // 0->1
    assert_eq(in_degree(adj, 4, 2), 1); // 0->2
    assert_eq(in_degree(adj, 4, 3), 2); // 1->3, 2->3
    1
}

fn test_wider_dag() -> Int {
    // 0->2, 0->3, 1->3, 1->4, 2->5, 3->5, 4->5
    // adj[0] = bit2+bit3 = 4+8 = 12
    // adj[1] = bit3+bit4 = 8+16 = 24
    // adj[2] = bit5 = 32
    // adj[3] = bit5 = 32
    // adj[4] = bit5 = 32
    let adj = Arr8 { v0: 12, v1: 24, v2: 32, v3: 32, v4: 32, v5: 0, v6: 0, v7: 0 };
    assert_eq(topo_sort_len(adj, 6), 6);
    let order = topo_sort(adj, 6);
    assert_eq(verify_topo(adj, 6, order), 1);
    // Node 5 must be last (highest in-degree, no outgoing)
    assert_eq(get8(order, 5), 5);
    1
}

fn main() -> Int {
    test_linear_chain();
    test_diamond();
    test_independent();
    test_in_degree();
    test_wider_dag();
    print("[OK] 636_topological_sort_aot");
    0
}
