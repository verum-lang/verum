// @test: run
// @level: L0
// @tier: 0
// @tags: match, record-variant, field-index, destructuring, e2e
// @description: Test record variant field extraction with partial patterns (.. skip)

type Shape is
    Circle { radius: Float }
  | Rect { width: Float, height: Float, color: Int };

type Tree is Leaf(Int) | Node { val: Int, left: Heap<Tree>, right: Heap<Tree> };

implement Tree {
    fn sum(&self) -> Int {
        match self {
            Leaf(v) => v,
            Node { val, left, right } => val + left.sum() + right.sum(),
        }
    }
}

fn approx(a: Float, b: Float) -> Bool {
    let d = a - b;
    let abs = if d < 0.0 { 0.0 - d } else { d };
    abs < 0.01
}

fn main() -> Int {
    let mut f = 0;

    // Test 1: partial destructuring - skip first field
    let r = Rect { width: 3.0, height: 4.0, color: 255 };
    match r {
        Rect { height, .. } => {
            if !approx(height, 4.0) {
                print(f"FAIL 1: height = {height}");
                f = f + 1;
            }
        }
        _ => { f = f + 1; }
    }

    // Test 2: partial destructuring - skip middle field
    match r {
        Rect { width, color, .. } => {
            if !approx(width, 3.0) || color != 255 {
                print(f"FAIL 2: width={width}, color={color}");
                f = f + 1;
            }
        }
        _ => { f = f + 1; }
    }

    // Test 3: skip first field of record variant
    match r {
        Rect { color, .. } => {
            if color != 255 {
                print(f"FAIL 3: color = {color}");
                f = f + 1;
            }
        }
        _ => { f = f + 1; }
    }

    // Test 4: tree recursive method through Heap with partial destructuring
    let t = Node {
        val: 10,
        left: Heap(Node {
            val: 5,
            left: Heap(Leaf(1)),
            right: Heap(Leaf(2)),
        }),
        right: Heap(Leaf(3)),
    };
    let s = t.sum();
    if s != 21 {
        print(f"FAIL 4: sum = {s}");
        f = f + 1;
    }

    // Test 5: partial destructuring of Node - skip val
    match t {
        Node { left, .. } => {
            let ls = left.sum();
            if ls != 8 {
                print(f"FAIL 5: left sum = {ls}");
                f = f + 1;
            }
        }
        _ => { f = f + 1; }
    }

    if f == 0 {
        print("All record variant field index tests passed");
    }
    f
}
