// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, combinational, logic, circuit
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for combinational logic circuit simulation

fn bnot(x: Int) -> Int { !x }

// Basic gates (operate on bits 0/1)
fn gate_and(a: Int, b: Int) -> Int { a & b }
fn gate_or(a: Int, b: Int) -> Int { a | b }
fn gate_xor(a: Int, b: Int) -> Int { a ^ b }
fn gate_not(a: Int) -> Int { if a == 0 { 1 } else { 0 } }
fn gate_nand(a: Int, b: Int) -> Int { gate_not(gate_and(a, b)) }
fn gate_nor(a: Int, b: Int) -> Int { gate_not(gate_or(a, b)) }

// Half adder: returns (sum, carry) packed as sum*2 + carry
fn half_adder(a: Int, b: Int) -> Int {
    let sum = gate_xor(a, b);
    let carry = gate_and(a, b);
    sum * 2 + carry
}

// Full adder: returns (sum, carry_out) packed
fn full_adder(a: Int, b: Int, cin: Int) -> Int {
    let ha1 = half_adder(a, b);
    let s1 = ha1 / 2;
    let c1 = ha1 % 2;
    let ha2 = half_adder(s1, cin);
    let sum = ha2 / 2;
    let c2 = ha2 % 2;
    let carry = gate_or(c1, c2);
    sum * 2 + carry
}

// 4-bit ripple carry adder
fn add4(a: Int, b: Int) -> Int {
    let a0 = a & 1; let a1 = (a >> 1) & 1; let a2 = (a >> 2) & 1; let a3 = (a >> 3) & 1;
    let b0 = b & 1; let b1 = (b >> 1) & 1; let b2 = (b >> 2) & 1; let b3 = (b >> 3) & 1;

    let r0 = full_adder(a0, b0, 0);
    let s0 = r0 / 2; let c0 = r0 % 2;

    let r1 = full_adder(a1, b1, c0);
    let s1 = r1 / 2; let c1 = r1 % 2;

    let r2 = full_adder(a2, b2, c1);
    let s2 = r2 / 2; let c2 = r2 % 2;

    let r3 = full_adder(a3, b3, c2);
    let s3 = r3 / 2; let c3 = r3 % 2;

    s0 | (s1 << 1) | (s2 << 2) | (s3 << 3) | (c3 << 4)
}

// 2-to-1 multiplexer
fn mux2(a: Int, b: Int, sel: Int) -> Int {
    gate_or(gate_and(a, gate_not(sel)), gate_and(b, sel))
}

// 4-to-1 multiplexer
fn mux4(a: Int, b: Int, c: Int, d: Int, s0: Int, s1: Int) -> Int {
    let m0 = mux2(a, b, s0);
    let m1 = mux2(c, d, s0);
    mux2(m0, m1, s1)
}

// Decoder: 2-bit input -> 4 output lines (encoded in low 4 bits)
fn decoder2(s0: Int, s1: Int) -> Int {
    let ns0 = gate_not(s0);
    let ns1 = gate_not(s1);
    let d0 = gate_and(ns1, ns0);
    let d1 = gate_and(ns1, s0);
    let d2 = gate_and(s1, ns0);
    let d3 = gate_and(s1, s0);
    d0 | (d1 << 1) | (d2 << 2) | (d3 << 3)
}

fn test_gates() {
    assert_eq(gate_and(0, 0), 0);
    assert_eq(gate_and(1, 1), 1);
    assert_eq(gate_or(0, 1), 1);
    assert_eq(gate_xor(1, 1), 0);
    assert_eq(gate_xor(0, 1), 1);
    assert_eq(gate_nand(1, 1), 0);
    assert_eq(gate_nand(0, 1), 1);
    assert_eq(gate_nor(0, 0), 1);
    assert_eq(gate_nor(0, 1), 0);
}

fn test_half_adder() {
    let r00 = half_adder(0, 0); assert_eq(r00 / 2, 0); assert_eq(r00 % 2, 0);
    let r01 = half_adder(0, 1); assert_eq(r01 / 2, 1); assert_eq(r01 % 2, 0);
    let r10 = half_adder(1, 0); assert_eq(r10 / 2, 1); assert_eq(r10 % 2, 0);
    let r11 = half_adder(1, 1); assert_eq(r11 / 2, 0); assert_eq(r11 % 2, 1);
}

fn test_full_adder() {
    let r = full_adder(1, 1, 1);
    assert_eq(r / 2, 1);  // sum = 1
    assert_eq(r % 2, 1);  // carry = 1 (1+1+1=3=11b)
}

fn test_4bit_adder() {
    // 3 + 5 = 8
    assert_eq(add4(3, 5), 8);
    // 7 + 1 = 8
    assert_eq(add4(7, 1), 8);
    // 15 + 1 = 16 (overflow into carry)
    assert_eq(add4(15, 1), 16);
    // 0 + 0 = 0
    assert_eq(add4(0, 0), 0);
}

fn test_mux() {
    assert_eq(mux2(0, 1, 0), 0);
    assert_eq(mux2(0, 1, 1), 1);
    assert_eq(mux2(1, 0, 0), 1);

    // 4-to-1 mux
    assert_eq(mux4(1, 0, 0, 0, 0, 0), 1);  // sel=00 -> a
    assert_eq(mux4(0, 1, 0, 0, 1, 0), 1);  // sel=01 -> b
    assert_eq(mux4(0, 0, 1, 0, 0, 1), 1);  // sel=10 -> c
    assert_eq(mux4(0, 0, 0, 1, 1, 1), 1);  // sel=11 -> d
}

fn test_decoder() {
    assert_eq(decoder2(0, 0), 1);   // d0 = 1
    assert_eq(decoder2(1, 0), 2);   // d1 = 1
    assert_eq(decoder2(0, 1), 4);   // d2 = 1
    assert_eq(decoder2(1, 1), 8);   // d3 = 1
}

fn main() -> Int {
    test_gates();
    test_half_adder();
    test_full_adder();
    test_4bit_adder();
    test_mux();
    test_decoder();
    print("[OK] 274_comb_logic_aot");
    0
}
