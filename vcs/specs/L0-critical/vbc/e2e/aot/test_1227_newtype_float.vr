// @test: run
// @level: L0
// @tier: 0
// @tags: newtype, float, type-tracking, e2e
// @description: Test float type tracking through newtype .0 access

type Meters is (Float);
type Seconds is (Float);
type Kilograms is (Float);

fn speed(distance: Meters, time: Seconds) -> Float {
    distance.0 / time.0
}

fn kinetic_energy(mass: Kilograms, velocity: Float) -> Float {
    0.5 * mass.0 * velocity * velocity
}

fn approx(a: Float, b: Float) -> Bool {
    let d = a - b;
    let abs = if d < 0.0 { 0.0 - d } else { d };
    abs < 0.1
}

fn main() -> Int {
    let mut f = 0;

    // Test 1: basic newtype .0 access
    let d = Meters(100.0);
    if !approx(d.0, 100.0) {
        print(f"FAIL 1: d.0 = {d.0}");
        f = f + 1;
    }

    // Test 2: float division through newtypes
    let t = Seconds(9.58);
    let v = speed(d, t);
    if !approx(v, 10.44) {
        print(f"FAIL 2: speed = {v}");
        f = f + 1;
    }

    // Test 3: float arithmetic with newtypes
    let m = Kilograms(70.0);
    let ke = kinetic_energy(m, v);
    // KE = 0.5 * 70 * 10.44^2 ≈ 3814
    if ke < 3700.0 || ke > 3900.0 {
        print(f"FAIL 3: KE = {ke}");
        f = f + 1;
    }

    // Test 4: newtype .0 in expressions
    let d2 = Meters(50.0);
    let sum = d.0 + d2.0;
    if !approx(sum, 150.0) {
        print(f"FAIL 4: sum = {sum}");
        f = f + 1;
    }

    if f == 0 {
        print("All newtype float tests passed");
    }
    f
}
