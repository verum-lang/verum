// @test: run
// @level: L0
// @tags: aot, e2e, conway, look-say, sequence
// @timeout: 30000

// Conway's look-and-say sequence and other integer sequence operations

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Look-and-say: describe digit runs
// Input as array of digits, returns array of (count, digit) pairs flattened
type SeqResult is { data: Arr8, len: Int };

fn look_and_say(input: Arr8, n: Int) -> SeqResult {
    let mut output = zeros();
    let mut out_idx = 0;
    let mut i = 0;
    while i < n {
        let digit = get8(input, i);
        let mut run_len = 1;
        let mut done = 0;
        while i + run_len < n {
            if done == 0 {
                if get8(input, i + run_len) == digit { run_len = run_len + 1; }
                else { done = 1; }
            } else {
                run_len = run_len + n; // break trick
            }
        }
        if run_len > n { run_len = run_len - n; }
        if out_idx < 8 {
            output = set8(output, out_idx, run_len);
            out_idx = out_idx + 1;
        }
        if out_idx < 8 {
            output = set8(output, out_idx, digit);
            out_idx = out_idx + 1;
        }
        i = i + run_len;
    }
    SeqResult { data: output, len: out_idx }
}

// Recaman sequence: a(0)=0, a(n) = a(n-1)-n if positive and not already seen, else a(n-1)+n
fn recaman(n: Int) -> Arr8 {
    let mut seq = zeros();
    // seq[0] = 0
    let mut i = 1;
    while i < n {
        let prev = get8(seq, i - 1);
        let candidate = prev - i;
        // Check if candidate > 0 and not already in sequence
        let mut is_new = 1;
        if candidate <= 0 { is_new = 0; }
        if is_new == 1 {
            let mut j = 0;
            while j < i {
                if get8(seq, j) == candidate { is_new = 0; }
                j = j + 1;
            }
        }
        if is_new == 1 {
            seq = set8(seq, i, candidate);
        } else {
            seq = set8(seq, i, prev + i);
        }
        i = i + 1;
    }
    seq
}

// Van Eck sequence: a(0)=0, if a(n-1) has not appeared before: a(n)=0, else a(n)=n-1-last_index
fn van_eck(n: Int) -> Arr8 {
    let mut seq = zeros();
    let mut i = 1;
    while i < n {
        let prev = get8(seq, i - 1);
        // Find last occurrence of prev before i-1
        let mut last = -1;
        let mut j = i - 2;
        while j >= 0 {
            if get8(seq, j) == prev {
                if last < 0 { last = j; }
            }
            j = j - 1;
        }
        if last < 0 {
            seq = set8(seq, i, 0);
        } else {
            seq = set8(seq, i, i - 1 - last);
        }
        i = i + 1;
    }
    seq
}

// Stern's diatomic sequence: a(0)=0, a(1)=1
// a(2n)=a(n), a(2n+1)=a(n)+a(n+1)
fn stern_seq(n: Int) -> Arr8 {
    let mut seq = zeros();
    seq = set8(seq, 1, 1);
    let mut i = 2;
    while i < n {
        if i % 2 == 0 {
            seq = set8(seq, i, get8(seq, i / 2));
        } else {
            seq = set8(seq, i, get8(seq, i / 2) + get8(seq, i / 2 + 1));
        }
        i = i + 1;
    }
    seq
}

fn test_look_and_say_basic() -> Int {
    // "1" → "11" (one 1)
    let input = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = look_and_say(input, 1);
    assert_eq(result.len, 2);
    assert_eq(get8(result.data, 0), 1); // count = 1
    assert_eq(get8(result.data, 1), 1); // digit = 1
    1
}

fn test_look_and_say_multi() -> Int {
    // "1 1" → "2 1" (two 1s)
    let input = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = look_and_say(input, 2);
    assert_eq(result.len, 2);
    assert_eq(get8(result.data, 0), 2); // count = 2
    assert_eq(get8(result.data, 1), 1); // digit = 1
    1
}

fn test_look_and_say_mixed() -> Int {
    // "2 1" → "1 2 1 1" (one 2, one 1)
    let input = Arr8 { v0: 2, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = look_and_say(input, 2);
    assert_eq(result.len, 4);
    assert_eq(get8(result.data, 0), 1); // one
    assert_eq(get8(result.data, 1), 2); // 2
    assert_eq(get8(result.data, 2), 1); // one
    assert_eq(get8(result.data, 3), 1); // 1
    1
}

fn test_recaman() -> Int {
    // Known: 0, 1, 3, 6, 2, 7, 13, 20
    let seq = recaman(8);
    assert_eq(get8(seq, 0), 0);
    assert_eq(get8(seq, 1), 1);
    assert_eq(get8(seq, 2), 3);
    assert_eq(get8(seq, 3), 6);
    assert_eq(get8(seq, 4), 2);
    assert_eq(get8(seq, 5), 7);
    assert_eq(get8(seq, 6), 13);
    assert_eq(get8(seq, 7), 20);
    1
}

fn test_van_eck() -> Int {
    // Known: 0, 0, 1, 0, 2, 0, 2, 2
    let seq = van_eck(8);
    assert_eq(get8(seq, 0), 0);
    assert_eq(get8(seq, 1), 0);
    assert_eq(get8(seq, 2), 1);
    assert_eq(get8(seq, 3), 0);
    assert_eq(get8(seq, 4), 2);
    assert_eq(get8(seq, 5), 0);
    assert_eq(get8(seq, 6), 2);
    assert_eq(get8(seq, 7), 2);
    1
}

fn test_stern() -> Int {
    // Known: 0, 1, 1, 2, 1, 3, 2, 3
    let seq = stern_seq(8);
    assert_eq(get8(seq, 0), 0);
    assert_eq(get8(seq, 1), 1);
    assert_eq(get8(seq, 2), 1);
    assert_eq(get8(seq, 3), 2);
    assert_eq(get8(seq, 4), 1);
    assert_eq(get8(seq, 5), 3);
    assert_eq(get8(seq, 6), 2);
    assert_eq(get8(seq, 7), 3);
    1
}

fn main() -> Int {
    test_look_and_say_basic();
    test_look_and_say_multi();
    test_look_and_say_mixed();
    test_recaman();
    test_van_eck();
    test_stern();
    print("[OK] 569_conway_nums_aot");
    0
}
