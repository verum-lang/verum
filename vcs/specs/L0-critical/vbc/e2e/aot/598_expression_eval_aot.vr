// @test: run
// @level: L0
// @tags: aot, e2e, expression, evaluator, stack-machine
// @timeout: 30000

// Stack-based expression evaluator (postfix/RPN)

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// Instruction encoding:
// Positive values = push that number
// Negative values = operators:
//   -1 = add, -2 = subtract, -3 = multiply, -4 = divide
//   -5 = negate, -6 = duplicate, -7 = swap, -8 = abs
fn OP_ADD() -> Int { 0 - 1 }
fn OP_SUB() -> Int { 0 - 2 }
fn OP_MUL() -> Int { 0 - 3 }
fn OP_DIV() -> Int { 0 - 4 }
fn OP_NEG() -> Int { 0 - 5 }
fn OP_DUP() -> Int { 0 - 6 }
fn OP_SWAP() -> Int { 0 - 7 }
fn OP_ABS() -> Int { 0 - 8 }

// Stack machine: evaluate postfix expression
// Returns top of stack after evaluation
fn rpn_eval(program: Arr8, n: Int) -> Int {
    let mut stack = zeros();
    let mut sp = 0; // stack pointer
    let mut i = 0;
    while i < n {
        let instr = get8(program, i);
        if instr >= 0 {
            // Push value
            stack = set8(stack, sp, instr);
            sp = sp + 1;
        } else if instr == OP_ADD() {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a + b);
        } else if instr == OP_SUB() {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a - b);
        } else if instr == OP_MUL() {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a * b);
        } else if instr == OP_DIV() {
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a / b);
        } else if instr == OP_NEG() {
            let a = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, 0 - a);
        } else if instr == OP_DUP() {
            let a = get8(stack, sp - 1);
            stack = set8(stack, sp, a);
            sp = sp + 1;
        } else if instr == OP_SWAP() {
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            stack = set8(stack, sp - 1, b);
            stack = set8(stack, sp - 2, a);
        } else if instr == OP_ABS() {
            let a = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, abs_val(a));
        }
        i = i + 1;
    }
    if sp > 0 { get8(stack, sp - 1) } else { 0 }
}

fn test_simple_add() -> Int {
    // 3 4 + = 7
    let prog = Arr8 { v0: 3, v1: 4, v2: OP_ADD(), v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 3), 7);
    1
}

fn test_complex_expr() -> Int {
    // (3 + 4) * 2 = 14 in RPN: 3 4 + 2 *
    let prog = Arr8 { v0: 3, v1: 4, v2: OP_ADD(), v3: 2, v4: OP_MUL(), v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 5), 14);
    1
}

fn test_subtraction() -> Int {
    // 10 - 3 = 7 in RPN: 10 3 -
    let prog = Arr8 { v0: 10, v1: 3, v2: OP_SUB(), v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 3), 7);
    1
}

fn test_division() -> Int {
    // 20 / 4 = 5
    let prog = Arr8 { v0: 20, v1: 4, v2: OP_DIV(), v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 3), 5);
    1
}

fn test_negate() -> Int {
    // 5 negate = -5, then abs = 5
    let prog = Arr8 { v0: 5, v1: OP_NEG(), v2: OP_ABS(), v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 3), 5);

    // 5 negate = -5
    let prog2 = Arr8 { v0: 5, v1: OP_NEG(), v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog2, 2), 0 - 5);
    1
}

fn test_dup() -> Int {
    // 7 dup * = 7 * 7 = 49 (square)
    let prog = Arr8 { v0: 7, v1: OP_DUP(), v2: OP_MUL(), v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 3), 49);
    1
}

fn test_swap() -> Int {
    // 10 3 swap - = 3 - 10 = -7
    let prog = Arr8 { v0: 10, v1: 3, v2: OP_SWAP(), v3: OP_SUB(), v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 4), 0 - 7);
    1
}

fn test_polynomial() -> Int {
    // Evaluate 2x^2 + 3x + 1 at x=5
    // = 2*25 + 15 + 1 = 66
    // RPN: 2 5 dup * * 3 5 * + 1 + (too long for 8 slots)
    // Simplified: compute step by step
    // Step 1: 5 dup * = 25 (x^2)
    // Step 2: 2 * = 50 (2x^2)
    // Step 3: ... too many operations for 8 slots

    // Simpler: 2*5*5 + 3*5 + 1 = 50+15+1 = 66
    // RPN: 2 5 * 5 * 3 5 * + 1 + = 9 tokens (too many)

    // Even simpler: (2*5+3)*5+1 = 13*5+1 = 66 (Horner's method)
    // RPN: 2 5 * 3 + 5 * 1 + = 8 tokens, fits!
    let prog = Arr8 { v0: 2, v1: 5, v2: OP_MUL(), v3: 3, v4: OP_ADD(), v5: 5, v6: OP_MUL(), v7: 1 };
    // But we need 9 tokens: 2 5 * 3 + 5 * 1 + (the final +)
    // Let's use 7 tokens and check intermediate: 2 5 * 3 + 5 * = (2*5+3)*5 = 65
    let prog2 = Arr8 { v0: 2, v1: 5, v2: OP_MUL(), v3: 3, v4: OP_ADD(), v5: 5, v6: OP_MUL(), v7: 0 };
    assert_eq(rpn_eval(prog2, 7), 65);
    1
}

fn main() -> Int {
    test_simple_add();
    test_complex_expr();
    test_subtraction();
    test_division();
    test_negate();
    test_dup();
    test_swap();
    test_polynomial();
    print("[OK] 598_expression_eval_aot");
    0
}
