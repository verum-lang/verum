// @test: run
// @level: L0
// @tags: aot, e2e, scheduler, scheduling, optimization
// @timeout: 30000

// Job scheduling algorithms

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Shortest Job First (SJF): compute average waiting time * n
// Jobs: durations array, n = count
// Returns total waiting time (multiply by 10 for precision)
fn sjf_total_wait(durations: Arr8, n: Int) -> Int {
    // Sort durations first (selection sort)
    let mut d = durations;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if get8(d, j) < get8(d, min_idx) { min_idx = j; }
            j = j + 1;
        }
        if min_idx != i {
            let tmp = get8(d, i);
            d = set8(d, i, get8(d, min_idx));
            d = set8(d, min_idx, tmp);
        }
        i = i + 1;
    }
    // Compute waiting times: wait[0]=0, wait[i] = sum(d[0..i-1])
    let mut total_wait = 0;
    let mut cumulative = 0;
    i = 0;
    while i < n {
        total_wait = total_wait + cumulative;
        cumulative = cumulative + get8(d, i);
        i = i + 1;
    }
    total_wait
}

// Round Robin: compute total completion time
// Each job gets a quantum time slice
fn rr_completion_time(durations: Arr8, n: Int, quantum: Int) -> Int {
    let mut remaining = durations;
    let mut time = 0;
    let mut done = 0;
    let mut safety = 0;

    while done < n {
        let mut i = 0;
        while i < n {
            let rem = get8(remaining, i);
            if rem > 0 {
                if rem <= quantum {
                    time = time + rem;
                    remaining = set8(remaining, i, 0);
                    done = done + 1;
                } else {
                    time = time + quantum;
                    remaining = set8(remaining, i, rem - quantum);
                }
            }
            i = i + 1;
        }
        safety = safety + 1;
        if safety > 100 { return -1; }
    }
    time
}

// Weighted Job Scheduling: maximize profit
// Jobs: (start, end, profit) encoded as start*10000 + end*100 + profit
fn job_start(packed: Int) -> Int { packed / 10000 }
fn job_end(packed: Int) -> Int { (packed / 100) % 100 }
fn job_profit(packed: Int) -> Int { packed % 100 }
fn pack_job(s: Int, e: Int, p: Int) -> Int { s * 10000 + e * 100 + p }

// Simple greedy: select non-overlapping jobs sorted by end time for max profit
fn greedy_schedule(jobs: Arr8, n: Int) -> Int {
    // Sort by end time (selection sort)
    let mut j = jobs;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut k = i + 1;
        while k < n {
            if job_end(get8(j, k)) < job_end(get8(j, min_idx)) { min_idx = k; }
            k = k + 1;
        }
        if min_idx != i {
            let tmp = get8(j, i);
            j = set8(j, i, get8(j, min_idx));
            j = set8(j, min_idx, tmp);
        }
        i = i + 1;
    }
    // Greedy: take job if it doesn't overlap with last taken
    let mut total_profit = 0;
    let mut last_end = 0;
    i = 0;
    while i < n {
        let job = get8(j, i);
        if job_start(job) >= last_end {
            total_profit = total_profit + job_profit(job);
            last_end = job_end(job);
        }
        i = i + 1;
    }
    total_profit
}

fn test_sjf() -> Int {
    // Jobs: [6, 8, 7, 3]
    // Sorted: [3, 6, 7, 8]
    // Waiting: 0, 3, 9, 16 → total = 28
    let durations = Arr8 { v0: 6, v1: 8, v2: 7, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(sjf_total_wait(durations, 4), 28);
    1
}

fn test_sjf_sorted() -> Int {
    // Already sorted: [1, 2, 3]
    // Waiting: 0, 1, 3 → total = 4
    let durations = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(sjf_total_wait(durations, 3), 4);
    1
}

fn test_sjf_equal() -> Int {
    // All equal: [5, 5, 5]
    // Waiting: 0, 5, 10 → total = 15
    let durations = Arr8 { v0: 5, v1: 5, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(sjf_total_wait(durations, 3), 15);
    1
}

fn test_round_robin() -> Int {
    // Jobs: [10, 5, 8], quantum=3
    // Round 1: J0 runs 3 (rem=7), J1 runs 3 (rem=2), J2 runs 3 (rem=5)
    // Round 2: J0 runs 3 (rem=4), J1 runs 2 (done), J2 runs 3 (rem=2)
    // Round 3: J0 runs 3 (rem=1), J2 runs 2 (done)
    // Round 4: J0 runs 1 (done)
    // Total time = 10+5+8 = 23
    let durations = Arr8 { v0: 10, v1: 5, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rr_completion_time(durations, 3, 3), 23);
    1
}

fn test_rr_large_quantum() -> Int {
    // Quantum larger than all jobs → same as FCFS
    let durations = Arr8 { v0: 3, v1: 5, v2: 2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rr_completion_time(durations, 3, 100), 10);
    1
}

fn test_greedy_schedule() -> Int {
    // Jobs: (start, end, profit)
    // (0, 2, 10), (1, 3, 5), (3, 5, 15), (2, 6, 8)
    let jobs = Arr8 {
        v0: pack_job(0, 2, 10),  // 00210
        v1: pack_job(1, 3, 5),   // 10305
        v2: pack_job(3, 5, 15),  // 30515
        v3: pack_job(2, 6, 8),   // 20608
        v4: 0, v5: 0, v6: 0, v7: 0
    };
    // Sorted by end: (0,2,10), (1,3,5), (3,5,15), (2,6,8)
    // Take (0,2,10): last_end=2
    // (1,3,5): start=1 < 2, skip
    // (3,5,15): start=3 >= 2, take. last_end=5
    // (2,6,8): start=2 < 5, skip
    // Total: 10+15 = 25
    assert_eq(greedy_schedule(jobs, 4), 25);
    1
}

fn test_greedy_no_overlap() -> Int {
    // Non-overlapping jobs: should take all
    let jobs = Arr8 {
        v0: pack_job(0, 1, 5),
        v1: pack_job(2, 3, 10),
        v2: pack_job(4, 5, 7),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(greedy_schedule(jobs, 3), 22); // 5+10+7
    1
}

fn main() -> Int {
    test_sjf();
    test_sjf_sorted();
    test_sjf_equal();
    test_round_robin();
    test_rr_large_quantum();
    test_greedy_schedule();
    test_greedy_no_overlap();
    print("[OK] 537_scheduler_aot");
    0
}
