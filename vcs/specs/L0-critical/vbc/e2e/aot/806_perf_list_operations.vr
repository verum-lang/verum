// @test: run
// @tier: 0
// @level: L0
// @tags: aot, performance, list_operations
// @expected-exit: 0

// Performance: Push and sum 10K elements using array indexing

fn push_and_sum_test(n: Int) -> Int {
    let mut arr: List<Int> = [];

    // Push n elements
    let mut i = 0;
    while (i < n) {
        arr.push(i * 3 + 1);
        i = i + 1;
    }

    // Sum all elements via indexing
    let mut sum = 0;
    let mut j = 0;
    while (j < n) {
        sum = sum + arr[j];
        j = j + 1;
    }

    // Verify by reverse-order sum
    let mut rev_sum = 0;
    let mut k = n - 1;
    while (k >= 0) {
        rev_sum = rev_sum + arr[k];
        k = k - 1;
    }

    if (sum != rev_sum) {
        return -1;
    }

    sum
}

fn main() -> Int {
    let n = 10000;
    let result = push_and_sum_test(n);
    if (result < 0) {
        print(f"FAIL: error code {result}");
        return 1;
    }
    // Expected sum: sum(i*3+1 for i in 0..10000) = 3*sum(0..9999)+10000
    // = 3*(9999*10000/2) + 10000 = 3*49995000 + 10000 = 149995000
    let expected = 149995000;
    if (result != expected) {
        print(f"FAIL: sum={result}, expected={expected}");
        return 1;
    }
    print(f"OK: list_push_sum_10K sum={result}");
    0
}
