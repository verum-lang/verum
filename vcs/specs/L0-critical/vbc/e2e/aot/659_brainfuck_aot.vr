// @test: run
// @level: L0
// @tags: aot, e2e, brainfuck, interpreter, esoteric
// @timeout: 30000

// Simple Brainfuck-like interpreter using integer-encoded programs
// Opcodes: 1=inc, 2=dec, 3=right, 4=left, 5=loop_start, 6=loop_end, 0=halt

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Find matching bracket (loop_end for loop_start)
fn find_matching_end(prog: Arr8, prog_len: Int, start: Int) -> Int {
    let mut depth = 1;
    let mut i = start + 1;
    while depth > 0 {
        if i >= prog_len { depth = 0; } // safety
        else {
            let op = get8(prog, i);
            if op == 5 { depth = depth + 1; }
            else if op == 6 { depth = depth - 1; }
            i = i + 1;
        }
    }
    i - 1
}

// Find matching bracket (loop_start for loop_end)
fn find_matching_start(prog: Arr8, start: Int) -> Int {
    let mut depth = 1;
    let mut i = start - 1;
    while depth > 0 {
        if i < 0 { depth = 0; } // safety
        else {
            let op = get8(prog, i);
            if op == 6 { depth = depth + 1; }
            else if op == 5 { depth = depth - 1; }
            i = i - 1;
        }
    }
    i + 1
}

// Execute BF program, return final tape state
// Max 200 steps to prevent infinite loops
fn bf_run(prog: Arr8, prog_len: Int) -> Arr8 {
    let mut tape = zeros();
    let mut ptr = 0;
    let mut pc = 0;
    let mut steps = 0;
    while pc < prog_len {
        if steps > 200 { pc = prog_len; } // safety limit
        else {
            let op = get8(prog, pc);
            if op == 1 { // inc
                tape = set8(tape, ptr, get8(tape, ptr) + 1);
                pc = pc + 1;
            } else if op == 2 { // dec
                tape = set8(tape, ptr, get8(tape, ptr) - 1);
                pc = pc + 1;
            } else if op == 3 { // right
                ptr = ptr + 1;
                pc = pc + 1;
            } else if op == 4 { // left
                ptr = ptr - 1;
                pc = pc + 1;
            } else if op == 5 { // loop_start
                if get8(tape, ptr) == 0 {
                    pc = find_matching_end(prog, prog_len, pc) + 1;
                } else {
                    pc = pc + 1;
                }
            } else if op == 6 { // loop_end
                if get8(tape, ptr) != 0 {
                    pc = find_matching_start(prog, pc) + 1;
                } else {
                    pc = pc + 1;
                }
            } else {
                pc = pc + 1; // skip unknown
            }
            steps = steps + 1;
        }
    }
    tape
}

// Get pointer position after execution
fn bf_run_ptr(prog: Arr8, prog_len: Int) -> Int {
    let mut ptr = 0;
    let mut pc = 0;
    let mut tape = zeros();
    let mut steps = 0;
    while pc < prog_len {
        if steps > 200 { pc = prog_len; }
        else {
            let op = get8(prog, pc);
            if op == 1 {
                tape = set8(tape, ptr, get8(tape, ptr) + 1);
                pc = pc + 1;
            } else if op == 2 {
                tape = set8(tape, ptr, get8(tape, ptr) - 1);
                pc = pc + 1;
            } else if op == 3 {
                ptr = ptr + 1;
                pc = pc + 1;
            } else if op == 4 {
                ptr = ptr - 1;
                pc = pc + 1;
            } else if op == 5 {
                if get8(tape, ptr) == 0 {
                    pc = find_matching_end(prog, prog_len, pc) + 1;
                } else { pc = pc + 1; }
            } else if op == 6 {
                if get8(tape, ptr) != 0 {
                    pc = find_matching_start(prog, pc) + 1;
                } else { pc = pc + 1; }
            } else { pc = pc + 1; }
            steps = steps + 1;
        }
    }
    ptr
}

fn test_basic_inc_dec() -> Int {
    // +++>++>+ : cell[0]=3, cell[1]=2, cell[2]=1
    let prog = Arr8 { v0: 1, v1: 1, v2: 1, v3: 3, v4: 1, v5: 1, v6: 3, v7: 1 };
    let tape = bf_run(prog, 8);
    assert_eq(get8(tape, 0), 3);
    assert_eq(get8(tape, 1), 2);
    assert_eq(get8(tape, 2), 1);
    1
}

fn test_loop() -> Int {
    // Set cell[0]=3, then loop: dec cell[0], inc cell[1] → cell[1]=3
    // Program: +++[->+<]
    // Encoded: 1,1,1, 5, 2, 3, 1, 4, 6
    // But that's 9 > 8, so we'll use cell[0]=2
    // ++[->>+<<] is also too long. Let's do simpler:
    // ++[->+<] : 1,1, 5, 2, 3, 1, 4, 6
    let prog = Arr8 { v0: 1, v1: 1, v2: 5, v3: 2, v4: 3, v5: 1, v6: 4, v7: 6 };
    let tape = bf_run(prog, 8);
    assert_eq(get8(tape, 0), 0); // decremented to 0
    assert_eq(get8(tape, 1), 2); // incremented by 2
    1
}

fn test_skip_loop() -> Int {
    // [+] on empty cell: loop body should be skipped
    // Program: 5, 1, 6
    let prog = Arr8 { v0: 5, v1: 1, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let tape = bf_run(prog, 3);
    assert_eq(get8(tape, 0), 0); // loop was skipped
    1
}

fn test_pointer_movement() -> Int {
    // >>>: ptr should be at 3
    let prog = Arr8 { v0: 3, v1: 3, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ptr = bf_run_ptr(prog, 3);
    assert_eq(ptr, 3);
    // >>><: ptr at 2
    let prog2 = Arr8 { v0: 3, v1: 3, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ptr2 = bf_run_ptr(prog2, 4);
    assert_eq(ptr2, 2);
    1
}

fn test_bracket_matching() -> Int {
    // [+[+]+]  — nested brackets
    let prog = Arr8 { v0: 5, v1: 1, v2: 5, v3: 1, v4: 6, v5: 1, v6: 6, v7: 0 };
    // Find matching end for outer bracket at 0
    let end = find_matching_end(prog, 7, 0);
    assert_eq(end, 6);
    // Find matching end for inner bracket at 2
    let end2 = find_matching_end(prog, 7, 2);
    assert_eq(end2, 4);
    // Find matching start for outer end at 6
    let start = find_matching_start(prog, 6);
    assert_eq(start, 0);
    1
}

fn test_multiply() -> Int {
    // Multiply 3 * 2 using BF idiom:
    // Set cell[0]=3, cell[1]=2. Loop: dec cell[0], inner loop: dec cell[1], inc cell[2].
    // But that needs nested loops with >8 instructions.
    // Simpler: cell[0]=2, copy to cell[1]: ++[->+<]
    // Already tested above. Instead test: cell[0]=0 after clearing
    let prog = Arr8 { v0: 1, v1: 1, v2: 1, v3: 5, v4: 2, v5: 6, v6: 0, v7: 0 };
    // +++[-] : set to 3, then clear loop
    let tape = bf_run(prog, 6);
    assert_eq(get8(tape, 0), 0);
    1
}

fn main() -> Int {
    test_basic_inc_dec();
    test_loop();
    test_skip_loop();
    test_pointer_movement();
    test_bracket_matching();
    test_multiply();
    print("[OK] 659_brainfuck_aot");
    0
}
