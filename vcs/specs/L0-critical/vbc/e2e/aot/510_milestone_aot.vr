// @test: run
// @level: L0
// @tags: aot, e2e, milestone, calculator, shunting-yard
// @timeout: 30000

// Milestone: Shunting-yard algorithm for infix expression evaluation

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Tokens: positive = number, -1=+, -2=-, -3=*, -4=/, -5=(, -6=)
fn is_number(tok: Int) -> Int { if tok >= 0 { 1 } else { 0 } }
fn is_operator(tok: Int) -> Int {
    if tok == -1 { 1 }
    else if tok == -2 { 1 }
    else if tok == -3 { 1 }
    else if tok == -4 { 1 }
    else { 0 }
}

fn precedence(op: Int) -> Int {
    if op == -1 { 1 } // +
    else if op == -2 { 1 } // -
    else if op == -3 { 2 } // *
    else if op == -4 { 2 } // /
    else { 0 }
}

fn apply_op(op: Int, a: Int, b: Int) -> Int {
    if op == -1 { a + b }
    else if op == -2 { a - b }
    else if op == -3 { a * b }
    else if op == -4 { a / b }
    else { 0 }
}

// Evaluate infix expression using shunting-yard
// Token array, length → result
fn eval_infix(tokens: Arr8, n: Int) -> Int {
    let mut val_stack = zeros();
    let mut vsp = 0;
    let mut op_stack = zeros();
    let mut osp = 0;

    let mut i = 0;
    while i < n {
        let tok = get8(tokens, i);
        if is_number(tok) == 1 {
            val_stack = set8(val_stack, vsp, tok);
            vsp = vsp + 1;
        } else if tok == -5 {
            // Left paren
            op_stack = set8(op_stack, osp, tok);
            osp = osp + 1;
        } else if tok == -6 {
            // Right paren: pop until left paren
            let mut cont = 1;
            while cont == 1 {
                if osp == 0 { cont = 0; }
                else if get8(op_stack, osp - 1) == -5 {
                    osp = osp - 1; // pop (
                    cont = 0;
                } else {
                    let op = get8(op_stack, osp - 1);
                    osp = osp - 1;
                    let b = get8(val_stack, vsp - 1); vsp = vsp - 1;
                    let a = get8(val_stack, vsp - 1); vsp = vsp - 1;
                    val_stack = set8(val_stack, vsp, apply_op(op, a, b));
                    vsp = vsp + 1;
                }
            }
        } else if is_operator(tok) == 1 {
            // Pop operators with >= precedence
            let mut cont = 1;
            while cont == 1 {
                if osp == 0 { cont = 0; }
                else {
                    let top = get8(op_stack, osp - 1);
                    if top == -5 { cont = 0; }
                    else if precedence(top) < precedence(tok) { cont = 0; }
                    else {
                        osp = osp - 1;
                        let b = get8(val_stack, vsp - 1); vsp = vsp - 1;
                        let a = get8(val_stack, vsp - 1); vsp = vsp - 1;
                        val_stack = set8(val_stack, vsp, apply_op(top, a, b));
                        vsp = vsp + 1;
                    }
                }
            }
            op_stack = set8(op_stack, osp, tok);
            osp = osp + 1;
        }
        i = i + 1;
    }

    // Pop remaining operators
    while osp > 0 {
        let op = get8(op_stack, osp - 1);
        osp = osp - 1;
        let b = get8(val_stack, vsp - 1); vsp = vsp - 1;
        let a = get8(val_stack, vsp - 1); vsp = vsp - 1;
        val_stack = set8(val_stack, vsp, apply_op(op, a, b));
        vsp = vsp + 1;
    }

    get8(val_stack, 0)
}

fn test_simple_add() -> Int {
    // 3 + 4 = 7
    let tokens = Arr8 { v0: 3, v1: -1, v2: 4, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval_infix(tokens, 3), 7);
    1
}

fn test_precedence() -> Int {
    // 2 + 3 * 4 = 14
    let tokens = Arr8 { v0: 2, v1: -1, v2: 3, v3: -3, v4: 4, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval_infix(tokens, 5), 14);

    // 3 * 4 + 2 = 14
    let tokens2 = Arr8 { v0: 3, v1: -3, v2: 4, v3: -1, v4: 2, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval_infix(tokens2, 5), 14);
    1
}

fn test_parens() -> Int {
    // (2 + 3) * 4 = 20
    let tokens = Arr8 { v0: -5, v1: 2, v2: -1, v3: 3, v4: -6, v5: -3, v6: 4, v7: 0 };
    assert_eq(eval_infix(tokens, 7), 20);
    1
}

fn test_subtraction() -> Int {
    // 10 - 3 - 2 = 5 (left-associative)
    let tokens = Arr8 { v0: 10, v1: -2, v2: 3, v3: -2, v4: 2, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval_infix(tokens, 5), 5);
    1
}

fn test_division() -> Int {
    // 12 / 3 = 4
    let tokens = Arr8 { v0: 12, v1: -4, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval_infix(tokens, 3), 4);
    1
}

fn test_complex() -> Int {
    // 2 * (3 + 4) = 14
    let tokens = Arr8 { v0: 2, v1: -3, v2: -5, v3: 3, v4: -1, v5: 4, v6: -6, v7: 0 };
    assert_eq(eval_infix(tokens, 7), 14);
    1
}

fn test_single_number() -> Int {
    let tokens = Arr8 { v0: 42, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval_infix(tokens, 1), 42);
    1
}

fn main() -> Int {
    test_simple_add();
    test_precedence();
    test_parens();
    test_subtraction();
    test_division();
    test_complex();
    test_single_number();
    print("[OK] 510_milestone_aot");
    0
}
