// @test: run
// @level: L0
// @tags: aot, e2e, game-of-life, cellular, automaton
// @timeout: 30000

// Conway's Game of Life on a small grid

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// 6x6 grid stored as bitmask (36 bits, fits in Int)
// Cell (r,c) → bit r*6+c

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn has_bit(mask: Int, k: Int) -> Int { (mask / pow2(k)) % 2 }
fn set_bit(mask: Int, k: Int) -> Int { if has_bit(mask, k) == 1 { mask } else { mask + pow2(k) } }
fn clear_bit(mask: Int, k: Int) -> Int { if has_bit(mask, k) == 0 { mask } else { mask - pow2(k) } }

fn cell_idx(r: Int, c: Int) -> Int { r * 6 + c }

fn get_cell(grid: Int, r: Int, c: Int) -> Int {
    if r < 0 { return 0; }
    if r >= 6 { return 0; }
    if c < 0 { return 0; }
    if c >= 6 { return 0; }
    has_bit(grid, cell_idx(r, c))
}

fn count_neighbors(grid: Int, r: Int, c: Int) -> Int {
    get_cell(grid, r-1, c-1) + get_cell(grid, r-1, c) + get_cell(grid, r-1, c+1) +
    get_cell(grid, r, c-1) + get_cell(grid, r, c+1) +
    get_cell(grid, r+1, c-1) + get_cell(grid, r+1, c) + get_cell(grid, r+1, c+1)
}

fn life_step(grid: Int) -> Int {
    let mut new_grid = 0;
    let mut r = 0;
    while r < 6 {
        let mut c = 0;
        while c < 6 {
            let alive = get_cell(grid, r, c);
            let neighbors = count_neighbors(grid, r, c);
            // Rules: alive with 2 or 3 neighbors survives, dead with 3 neighbors becomes alive
            let new_state = if alive == 1 {
                if neighbors == 2 { 1 } else if neighbors == 3 { 1 } else { 0 }
            } else {
                if neighbors == 3 { 1 } else { 0 }
            };
            if new_state == 1 {
                new_grid = set_bit(new_grid, cell_idx(r, c));
            }
            c = c + 1;
        }
        r = r + 1;
    }
    new_grid
}

fn life_simulate(grid: Int, steps: Int) -> Int {
    let mut g = grid;
    let mut i = 0;
    while i < steps {
        g = life_step(g);
        i = i + 1;
    }
    g
}

fn count_alive(grid: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 36 {
        if has_bit(grid, i) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_empty_grid() -> Int {
    // Empty grid stays empty
    let result = life_step(0);
    assert_eq(result, 0);
    1
}

fn test_block() -> Int {
    // Block (2x2 still life) at (1,1)
    // ##
    // ##
    let mut grid = 0;
    grid = set_bit(grid, cell_idx(1, 1));
    grid = set_bit(grid, cell_idx(1, 2));
    grid = set_bit(grid, cell_idx(2, 1));
    grid = set_bit(grid, cell_idx(2, 2));

    let result = life_step(grid);
    assert_eq(result, grid); // still life
    assert_eq(count_alive(result), 4);
    1
}

fn test_blinker() -> Int {
    // Blinker (period 2): horizontal line of 3
    // .#.
    // .#.
    // .#.
    let mut grid = 0;
    grid = set_bit(grid, cell_idx(1, 2));
    grid = set_bit(grid, cell_idx(2, 2));
    grid = set_bit(grid, cell_idx(3, 2));

    let step1 = life_step(grid);
    // Should become horizontal:
    // ...
    // ###
    // ...
    assert_eq(get_cell(step1, 2, 1), 1);
    assert_eq(get_cell(step1, 2, 2), 1);
    assert_eq(get_cell(step1, 2, 3), 1);
    assert_eq(count_alive(step1), 3);

    // Period 2: step2 should equal original
    let step2 = life_step(step1);
    assert_eq(step2, grid);
    1
}

fn test_single_cell() -> Int {
    // Single cell dies (no neighbors)
    let mut grid = 0;
    grid = set_bit(grid, cell_idx(3, 3));
    let result = life_step(grid);
    assert_eq(result, 0);
    1
}

fn test_three_in_l() -> Int {
    // L-shape: dies except corner
    // ##
    // #.
    let mut grid = 0;
    grid = set_bit(grid, cell_idx(2, 2));
    grid = set_bit(grid, cell_idx(2, 3));
    grid = set_bit(grid, cell_idx(3, 2));

    let result = life_step(grid);
    // All three have 2 neighbors → survive
    // Cell (3,3) has 3 neighbors → born
    assert_eq(count_alive(result), 4); // becomes a block
    assert_eq(get_cell(result, 2, 2), 1);
    assert_eq(get_cell(result, 2, 3), 1);
    assert_eq(get_cell(result, 3, 2), 1);
    assert_eq(get_cell(result, 3, 3), 1);
    1
}

fn test_toad() -> Int {
    // Toad oscillator (period 2)
    // .###
    // ###.
    let mut grid = 0;
    grid = set_bit(grid, cell_idx(2, 2));
    grid = set_bit(grid, cell_idx(2, 3));
    grid = set_bit(grid, cell_idx(2, 4));
    grid = set_bit(grid, cell_idx(3, 1));
    grid = set_bit(grid, cell_idx(3, 2));
    grid = set_bit(grid, cell_idx(3, 3));

    assert_eq(count_alive(grid), 6);

    // After 2 steps should return to original (period 2)
    let step2 = life_simulate(grid, 2);
    assert_eq(step2, grid);
    1
}

fn main() -> Int {
    test_empty_grid();
    test_block();
    test_blinker();
    test_single_cell();
    test_three_in_l();
    test_toad();
    print("[OK] 562_game_of_life_aot");
    0
}
