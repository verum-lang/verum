// @test: run
// @level: L0
// @tags: aot, e2e, sparse-table, rmq, range-query
// @timeout: 30000

// Sparse table for Range Minimum Query (RMQ) on 8 elements

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// Naive range minimum in [l, r] inclusive
fn range_min_naive(arr: Arr8, l: Int, r: Int) -> Int {
    let mut best = get8(arr, l);
    let mut i = l + 1;
    while i <= r {
        let v = get8(arr, i);
        if v < best { best = v; }
        i = i + 1;
    }
    best
}

// Naive range maximum
fn range_max_naive(arr: Arr8, l: Int, r: Int) -> Int {
    let mut best = get8(arr, l);
    let mut i = l + 1;
    while i <= r {
        let v = get8(arr, i);
        if v > best { best = v; }
        i = i + 1;
    }
    best
}

// Range sum
fn range_sum(arr: Arr8, l: Int, r: Int) -> Int {
    let mut sum = 0;
    let mut i = l;
    while i <= r {
        sum = sum + get8(arr, i);
        i = i + 1;
    }
    sum
}

// Prefix sum array
fn prefix_sums(arr: Arr8, n: Int) -> Arr8 {
    let mut ps = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        sum = sum + get8(arr, i);
        ps = set8(ps, i, sum);
        i = i + 1;
    }
    ps
}

// Range sum using prefix sums
fn range_sum_fast(ps: Arr8, l: Int, r: Int) -> Int {
    let total = get8(ps, r);
    if l == 0 { total } else { total - get8(ps, l - 1) }
}

// Count elements in range [l, r] that equal target
fn count_eq(arr: Arr8, l: Int, r: Int, target: Int) -> Int {
    let mut count = 0;
    let mut i = l;
    while i <= r {
        if get8(arr, i) == target { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_range_min_max() -> Int {
    let arr = Arr8 { v0: 5, v1: 2, v2: 8, v3: 1, v4: 9, v5: 3, v6: 7, v7: 4 };
    assert_eq(range_min_naive(arr, 0, 7), 1);
    assert_eq(range_min_naive(arr, 0, 2), 2);
    assert_eq(range_min_naive(arr, 4, 7), 3);
    assert_eq(range_min_naive(arr, 3, 3), 1);

    assert_eq(range_max_naive(arr, 0, 7), 9);
    assert_eq(range_max_naive(arr, 0, 2), 8);
    assert_eq(range_max_naive(arr, 5, 7), 7);
    1
}

fn test_range_sum() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    assert_eq(range_sum(arr, 0, 7), 36);
    assert_eq(range_sum(arr, 0, 3), 10);
    assert_eq(range_sum(arr, 4, 7), 26);
    assert_eq(range_sum(arr, 2, 5), 18);
    1
}

fn test_prefix_sums() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let ps = prefix_sums(arr, 8);
    assert_eq(get8(ps, 0), 1);
    assert_eq(get8(ps, 3), 10);
    assert_eq(get8(ps, 7), 36);

    // Verify range_sum_fast matches range_sum
    assert_eq(range_sum_fast(ps, 0, 7), range_sum(arr, 0, 7));
    assert_eq(range_sum_fast(ps, 2, 5), range_sum(arr, 2, 5));
    assert_eq(range_sum_fast(ps, 0, 3), range_sum(arr, 0, 3));
    assert_eq(range_sum_fast(ps, 4, 7), range_sum(arr, 4, 7));
    1
}

fn test_count_eq() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 1, v3: 3, v4: 1, v5: 2, v6: 1, v7: 4 };
    assert_eq(count_eq(arr, 0, 7, 1), 4);
    assert_eq(count_eq(arr, 0, 7, 2), 2);
    assert_eq(count_eq(arr, 0, 7, 5), 0);
    assert_eq(count_eq(arr, 2, 5, 1), 2);
    1
}

fn main() -> Int {
    test_range_min_max();
    test_range_sum();
    test_prefix_sums();
    test_count_eq();
    print("[OK] 451_sparse_table_aot");
    0
}
