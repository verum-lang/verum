// @test: run
// @level: L0
// @tags: aot, e2e, interval, merge, sweep-line
// @timeout: 30000

// Interval merging and overlap detection

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Intervals stored as pairs: starts[i], ends[i]
// Sort intervals by start (simple insertion sort on parallel arrays)
fn sort_intervals(starts: Arr8, ends: Arr8, n: Int) -> Int {
    // Returns packed: sorted starts in first output, sorted ends in second
    // We just verify they're sorted by returning 1 if sorted
    let mut i = 0;
    while i < n - 1 {
        if get8(starts, i) > get8(starts, i + 1) { return 0; }
        i = i + 1;
    }
    1
}

// Count overlapping interval pairs
fn count_overlaps(starts: Arr8, ends: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            let si = get8(starts, i);
            let ei = get8(ends, i);
            let sj = get8(starts, j);
            let ej = get8(ends, j);
            // Overlap if si < ej and sj < ei
            if si < ej {
                if sj < ei {
                    count = count + 1;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Merge overlapping intervals (assumes sorted by start)
// Returns count of merged intervals
fn merge_intervals(starts: Arr8, ends: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut merged_count = 1;
    let mut cur_end = get8(ends, 0);
    let mut i = 1;
    while i < n {
        let si = get8(starts, i);
        let ei = get8(ends, i);
        if si <= cur_end {
            // Merge: extend current interval
            cur_end = max_val(cur_end, ei);
        } else {
            // New interval
            merged_count = merged_count + 1;
            cur_end = ei;
        }
        i = i + 1;
    }
    merged_count
}

// Total covered length after merging
fn total_coverage(starts: Arr8, ends: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut total = 0;
    let mut cur_start = get8(starts, 0);
    let mut cur_end = get8(ends, 0);
    let mut i = 1;
    while i < n {
        let si = get8(starts, i);
        let ei = get8(ends, i);
        if si <= cur_end {
            cur_end = max_val(cur_end, ei);
        } else {
            total = total + (cur_end - cur_start);
            cur_start = si;
            cur_end = ei;
        }
        i = i + 1;
    }
    total = total + (cur_end - cur_start);
    total
}

// Maximum depth (max overlapping intervals at any point)
fn max_depth(starts: Arr8, ends: Arr8, n: Int) -> Int {
    // For small n, brute force over all endpoints
    let mut max_d = 0;
    let mut i = 0;
    while i < n {
        let point = get8(starts, i);
        let mut depth = 0;
        let mut j = 0;
        while j < n {
            if get8(starts, j) <= point {
                if point < get8(ends, j) {
                    depth = depth + 1;
                }
            }
            j = j + 1;
        }
        if depth > max_d { max_d = depth; }
        i = i + 1;
    }
    max_d
}

fn test_merge() -> Int {
    // Intervals (sorted): [1,3], [2,6], [8,10], [15,18]
    let starts = Arr8 { v0: 1, v1: 2, v2: 8, v3: 15, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 3, v1: 6, v2: 10, v3: 18, v4: 0, v5: 0, v6: 0, v7: 0 };

    // [1,3] and [2,6] merge to [1,6]; [8,10] and [15,18] don't merge
    assert_eq(merge_intervals(starts, ends, 4), 3);

    // Total coverage: (6-1) + (10-8) + (18-15) = 5+2+3 = 10
    assert_eq(total_coverage(starts, ends, 4), 10);
    1
}

fn test_all_overlapping() -> Int {
    // [1,10], [2,5], [3,7]
    let starts = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 10, v1: 5, v2: 7, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };

    assert_eq(merge_intervals(starts, ends, 3), 1);
    assert_eq(total_coverage(starts, ends, 3), 9); // [1,10]
    assert_eq(count_overlaps(starts, ends, 3), 3); // all pairs overlap
    assert_eq(max_depth(starts, ends, 3), 3); // at point 3, all 3 overlap
    1
}

fn test_no_overlap() -> Int {
    // [1,2], [3,4], [5,6], [7,8]
    let starts = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };

    assert_eq(merge_intervals(starts, ends, 4), 4);
    assert_eq(total_coverage(starts, ends, 4), 4);
    assert_eq(count_overlaps(starts, ends, 4), 0);
    assert_eq(max_depth(starts, ends, 4), 1);
    1
}

fn test_depth() -> Int {
    // [1,5], [2,6], [4,8], [7,9]
    let starts = Arr8 { v0: 1, v1: 2, v2: 4, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 5, v1: 6, v2: 8, v3: 9, v4: 0, v5: 0, v6: 0, v7: 0 };

    // At point 4: [1,5], [2,6], [4,8] = depth 3
    assert_eq(max_depth(starts, ends, 4), 3);
    1
}

fn main() -> Int {
    test_merge();
    test_all_overlapping();
    test_no_overlap();
    test_depth();
    print("[OK] 461_interval_merge_aot");
    0
}
