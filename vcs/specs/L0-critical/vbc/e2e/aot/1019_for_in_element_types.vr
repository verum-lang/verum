// @test: run
// For-in loop element type propagation through typed collections

type Pair<A, B> is { first: A, second: B };

fn make_nested() -> List<List<Int>> {
    let matrix = List.new();
    let row0 = List.new();
    row0.push(10); row0.push(20);
    let row1 = List.new();
    row1.push(30); row1.push(40); row1.push(50);
    matrix.push(row0);
    matrix.push(row1);
    matrix
}

fn make_pairs() -> List<Pair<Int, Text>> {
    let pairs = List.new();
    pairs.push(Pair { first: 1, second: "hello" });
    pairs.push(Pair { first: 2, second: "world" });
    pairs
}

fn make_small_matrix() -> List<List<Int>> {
    let m = List.new();
    let r0 = List.new();
    r0.push(1); r0.push(2);
    let r1 = List.new();
    r1.push(3); r1.push(4);
    m.push(r0); m.push(r1);
    m
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    // Test 1: for-in over List<List<Int>> — inner list len
    let matrix = make_nested();
    let mut total = 0;
    for row in matrix {
        total = total + row.len();
    }
    if (total == 5) { passed = passed + 1; }
    else { print(f"FAIL 1: total={total}"); failed = failed + 1; }

    // Test 2: for-in over List<List<Int>> — inner list element access
    let matrix2 = make_nested();
    let mut sum = 0;
    for row in matrix2 {
        sum = sum + row[0];
    }
    if (sum == 40) { passed = passed + 1; }
    else { print(f"FAIL 2: sum={sum}"); failed = failed + 1; }

    // Test 3: for-in over List<Pair<Int, Text>> — struct field access
    let pairs = make_pairs();
    let mut id_sum = 0;
    for p in pairs {
        id_sum = id_sum + p.first;
    }
    if (id_sum == 3) { passed = passed + 1; }
    else { print(f"FAIL 3: id_sum={id_sum}"); failed = failed + 1; }

    // Test 4: for-in element access from function-typed list
    let m = make_small_matrix();
    let mut inner_sum = 0;
    for sub in m {
        inner_sum = inner_sum + sub[0] + sub[1];
    }
    if (inner_sum == 10) { passed = passed + 1; }
    else { print(f"FAIL 4: inner_sum={inner_sum}"); failed = failed + 1; }

    if (failed > 0) {
        print(f"for_in_element_types: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"for_in_element_types: PASS ({passed}/{passed} tests)");
    0
}
