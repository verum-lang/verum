// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, polynomial, horner, derivative, multi-eval
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for polynomial evaluation with simultaneous derivatives
// using extended Horner's method. Given p(x), compute p(x), p'(x),
// p''(x) simultaneously in a single pass.
// Also: Taylor shift, definite integral, and root bracketing.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// Polynomial: coefficients a[0..len-1], p(x) = a[0] + a[1]*x + ... + a[len-1]*x^(len-1)
type Poly is { coeffs: Arr8, len: Int };

// Evaluate polynomial using Horner's method
fn poly_eval(p: Poly, x: Int) -> Int {
    let n = p.len;
    if n == 0 { return 0; }
    let mut result = a8_get(p.coeffs, n - 1);
    let mut i = n - 2;
    while i >= 0 {
        result = result * x + a8_get(p.coeffs, i);
        i = i - 1;
    }
    result
}

// Simultaneous evaluation of p(x) and p'(x) using extended Horner
// Returns: { d0: p(x), d1: p'(x) }
type EvalResult is { val: Int, deriv1: Int };

fn poly_eval_with_deriv(p: Poly, x: Int) -> EvalResult {
    let n = p.len;
    if n == 0 { return EvalResult { val: 0, deriv1: 0 }; }
    let mut p0 = a8_get(p.coeffs, n - 1);
    let mut p1 = 0;
    let mut i = n - 2;
    while i >= 0 {
        p1 = p1 * x + p0;
        p0 = p0 * x + a8_get(p.coeffs, i);
        i = i - 1;
    }
    EvalResult { val: p0, deriv1: p1 }
}

// Compute formal derivative coefficients: p'[i] = (i+1) * p[i+1]
fn poly_formal_deriv(p: Poly) -> Poly {
    let n = p.len;
    if n <= 1 { return Poly { coeffs: a8_zero(), len: 0 }; }
    let mut result = a8_zero();
    let mut i = 0;
    while i < n - 1 {
        result = a8_set(result, i, (i + 1) * a8_get(p.coeffs, i + 1));
        i = i + 1;
    }
    Poly { coeffs: result, len: n - 1 }
}

// Compute formal second derivative
fn poly_formal_deriv2(p: Poly) -> Poly {
    poly_formal_deriv(poly_formal_deriv(p))
}

// Evaluate definite integral from a to b using integer coefficients
// integral of p(x) = sum(a[i] * x^(i+1) / (i+1)) - approximate using integer division
fn poly_integral_approx(p: Poly, a: Int, b: Int) -> Int {
    // Evaluate antiderivative at b and a
    // F(x) = sum(coeffs[i] * x^(i+1) / (i+1))
    let mut val_b = 0;
    let mut val_a = 0;
    let n = p.len;
    let mut i = 0;
    while i < n {
        let coeff = a8_get(p.coeffs, i);
        // compute coeff * x^(i+1) / (i+1)
        let mut pow_b = 1;
        let mut pow_a = 1;
        let mut j = 0;
        while j <= i {
            pow_b = pow_b * b;
            pow_a = pow_a * a;
            j = j + 1;
        }
        val_b = val_b + coeff * pow_b / (i + 1);
        val_a = val_a + coeff * pow_a / (i + 1);
        i = i + 1;
    }
    val_b - val_a
}

// Multi-point evaluation: evaluate polynomial at 0, 1, 2, ..., n-1
fn poly_multi_eval(p: Poly, n: Int) -> Arr8 {
    let mut results = a8_zero();
    let mut i = 0;
    while i < n {
        results = a8_set(results, i, poly_eval(p, i));
        i = i + 1;
    }
    results
}

// Root bracketing: find sign change between consecutive integers in [lo, hi]
// Returns the left endpoint where sign changes, or -1 if none found
fn find_root_bracket(p: Poly, lo: Int, hi: Int) -> Int {
    let mut i = lo;
    while i < hi {
        let v1 = poly_eval(p, i);
        let v2 = poly_eval(p, i + 1);
        // Check for sign change (one positive, one negative or zero)
        if v1 == 0 { return i; }
        if v2 == 0 { return i; }
        let s1 = if v1 > 0 { 1 } else { -1 };
        let s2 = if v2 > 0 { 1 } else { -1 };
        if s1 != s2 { return i; }
        i = i + 1;
    }
    -1
}

fn test_eval_with_deriv_linear() {
    // p(x) = 3 + 2x, p'(x) = 2
    let p = Poly { coeffs: Arr8 { a0: 3, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 2 };
    let r = poly_eval_with_deriv(p, 5);
    assert_eq(r.val, 13);    // 3 + 10
    assert_eq(r.deriv1, 2);  // constant derivative
}

fn test_eval_with_deriv_quadratic() {
    // p(x) = 1 + 0x + x^2 = 1 + x^2, p'(x) = 2x
    let p = Poly { coeffs: Arr8 { a0: 1, a1: 0, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    let r3 = poly_eval_with_deriv(p, 3);
    assert_eq(r3.val, 10);   // 1 + 9
    assert_eq(r3.deriv1, 6); // 2*3

    let r0 = poly_eval_with_deriv(p, 0);
    assert_eq(r0.val, 1);
    assert_eq(r0.deriv1, 0);
}

fn test_eval_with_deriv_cubic() {
    // p(x) = 2 + 3x - x^2 + x^3
    // p'(x) = 3 - 2x + 3x^2
    let p = Poly { coeffs: Arr8 { a0: 2, a1: 3, a2: -1, a3: 1, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };

    // At x=1: p(1) = 2+3-1+1 = 5, p'(1) = 3-2+3 = 4
    let r1 = poly_eval_with_deriv(p, 1);
    assert_eq(r1.val, 5);
    assert_eq(r1.deriv1, 4);

    // At x=2: p(2) = 2+6-4+8 = 12, p'(2) = 3-4+12 = 11
    let r2 = poly_eval_with_deriv(p, 2);
    assert_eq(r2.val, 12);
    assert_eq(r2.deriv1, 11);
}

fn test_deriv_matches_formal() {
    // Verify eval_with_deriv matches formal derivative evaluated separately
    let p = Poly { coeffs: Arr8 { a0: 1, a1: -2, a2: 3, a3: -1, a4: 2, a5: 0, a6: 0, a7: 0 }, len: 5 };
    let dp = poly_formal_deriv(p);

    let mut x = -3;
    while x <= 5 {
        let r = poly_eval_with_deriv(p, x);
        let d_expected = poly_eval(dp, x);
        assert_eq(r.val, poly_eval(p, x));
        assert_eq(r.deriv1, d_expected);
        x = x + 1;
    }
}

fn test_formal_deriv() {
    // p(x) = 3 + 2x + 5x^2, p'(x) = 2 + 10x
    let p = Poly { coeffs: Arr8 { a0: 3, a1: 2, a2: 5, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    let dp = poly_formal_deriv(p);
    assert_eq(dp.len, 2);
    assert_eq(a8_get(dp.coeffs, 0), 2);
    assert_eq(a8_get(dp.coeffs, 1), 10);
}

fn test_second_deriv() {
    // p(x) = x^4 + 2x^3 + x^2 + x + 1
    // p'(x) = 4x^3 + 6x^2 + 2x + 1
    // p''(x) = 12x^2 + 12x + 2
    let p = Poly { coeffs: Arr8 { a0: 1, a1: 1, a2: 1, a3: 2, a4: 1, a5: 0, a6: 0, a7: 0 }, len: 5 };
    let d2p = poly_formal_deriv2(p);
    assert_eq(d2p.len, 3);
    assert_eq(a8_get(d2p.coeffs, 0), 2);
    assert_eq(a8_get(d2p.coeffs, 1), 12);
    assert_eq(a8_get(d2p.coeffs, 2), 12);
}

fn test_multi_eval() {
    // p(x) = x^2 - 4
    let p = Poly { coeffs: Arr8 { a0: -4, a1: 0, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    let vals = poly_multi_eval(p, 6);
    assert_eq(a8_get(vals, 0), -4);  // 0-4
    assert_eq(a8_get(vals, 1), -3);  // 1-4
    assert_eq(a8_get(vals, 2), 0);   // 4-4
    assert_eq(a8_get(vals, 3), 5);   // 9-4
    assert_eq(a8_get(vals, 4), 12);  // 16-4
    assert_eq(a8_get(vals, 5), 21);  // 25-4
}

fn test_root_bracket() {
    // p(x) = x^2 - 4, roots at x=2 and x=-2
    let p = Poly { coeffs: Arr8 { a0: -4, a1: 0, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    // Sign change between x=1 (val=-3) and x=2 (val=0)
    let bracket = find_root_bracket(p, 0, 5);
    // x=2 gives p(2)=0, so bracket should be at 1 (since p(1)=-3, p(2)=0)
    assert_eq(bracket, 1);
}

fn test_root_bracket_neg() {
    // p(x) = x - 3, root at x=3
    let p = Poly { coeffs: Arr8 { a0: -3, a1: 1, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 2 };
    let bracket = find_root_bracket(p, 0, 5);
    // p(2)=-1, p(3)=0, bracket at 2
    assert_eq(bracket, 2);
}

fn test_integral_approx() {
    // p(x) = 3 (constant), integral from 0 to 4 = 12
    let p = Poly { coeffs: Arr8 { a0: 3, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 1 };
    assert_eq(poly_integral_approx(p, 0, 4), 12);

    // p(x) = x, integral from 0 to 4 = 8 (x^2/2 from 0 to 4 = 8)
    let p2 = Poly { coeffs: Arr8 { a0: 0, a1: 1, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 2 };
    assert_eq(poly_integral_approx(p2, 0, 4), 8);

    // p(x) = x^2, integral from 0 to 3 = 9 (x^3/3 from 0 to 3 = 9)
    let p3 = Poly { coeffs: Arr8 { a0: 0, a1: 0, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    assert_eq(poly_integral_approx(p3, 0, 3), 9);
}

fn test_constant_poly() {
    let p = Poly { coeffs: Arr8 { a0: 7, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 1 };
    let r = poly_eval_with_deriv(p, 100);
    assert_eq(r.val, 7);
    assert_eq(r.deriv1, 0);
    let dp = poly_formal_deriv(p);
    assert_eq(dp.len, 0);
}

fn test_zero_poly() {
    let p = Poly { coeffs: a8_zero(), len: 0 };
    assert_eq(poly_eval(p, 42), 0);
    let r = poly_eval_with_deriv(p, 42);
    assert_eq(r.val, 0);
    assert_eq(r.deriv1, 0);
}

fn main() -> Int {
    test_eval_with_deriv_linear();
    test_eval_with_deriv_quadratic();
    test_eval_with_deriv_cubic();
    test_deriv_matches_formal();
    test_formal_deriv();
    test_second_deriv();
    test_multi_eval();
    test_root_bracket();
    test_root_bracket_neg();
    test_integral_approx();
    test_constant_poly();
    test_zero_poly();
    print("[OK] 361_poly_deriv_aot");
    0
}
