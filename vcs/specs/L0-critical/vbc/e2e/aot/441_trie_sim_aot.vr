// @test: run
// @level: L0
// @tags: aot, e2e, trie, data-structure
// @timeout: 30000

// Trie (prefix tree) simulation using flat arrays
// Each node has 4 children (alphabet: 0,1,2,3) and a "word end" flag

type Trie is {
    // children[node][char] = child_node_id (-1 if none)
    // Flattened: children[node*4 + char]
    c0: Int, c1: Int, c2: Int, c3: Int, c4: Int, c5: Int, c6: Int, c7: Int,
    c8: Int, c9: Int, c10: Int, c11: Int, c12: Int, c13: Int, c14: Int, c15: Int,
    // word-end flags for nodes 0-3
    end0: Int, end1: Int, end2: Int, end3: Int,
    next_id: Int
};

fn new_trie() -> Trie {
    Trie {
        c0: -1, c1: -1, c2: -1, c3: -1, c4: -1, c5: -1, c6: -1, c7: -1,
        c8: -1, c9: -1, c10: -1, c11: -1, c12: -1, c13: -1, c14: -1, c15: -1,
        end0: 0, end1: 0, end2: 0, end3: 0,
        next_id: 1
    }
}

fn get_child(t: Trie, node: Int, ch: Int) -> Int {
    let idx = node * 4 + ch;
    if idx == 0 { t.c0 } else if idx == 1 { t.c1 } else if idx == 2 { t.c2 }
    else if idx == 3 { t.c3 } else if idx == 4 { t.c4 } else if idx == 5 { t.c5 }
    else if idx == 6 { t.c6 } else if idx == 7 { t.c7 } else if idx == 8 { t.c8 }
    else if idx == 9 { t.c9 } else if idx == 10 { t.c10 } else if idx == 11 { t.c11 }
    else if idx == 12 { t.c12 } else if idx == 13 { t.c13 } else if idx == 14 { t.c14 }
    else { t.c15 }
}

fn set_child(t: Trie, node: Int, ch: Int, val: Int) -> Trie {
    let idx = node * 4 + ch;
    Trie {
        c0: if idx == 0 { val } else { t.c0 },
        c1: if idx == 1 { val } else { t.c1 },
        c2: if idx == 2 { val } else { t.c2 },
        c3: if idx == 3 { val } else { t.c3 },
        c4: if idx == 4 { val } else { t.c4 },
        c5: if idx == 5 { val } else { t.c5 },
        c6: if idx == 6 { val } else { t.c6 },
        c7: if idx == 7 { val } else { t.c7 },
        c8: if idx == 8 { val } else { t.c8 },
        c9: if idx == 9 { val } else { t.c9 },
        c10: if idx == 10 { val } else { t.c10 },
        c11: if idx == 11 { val } else { t.c11 },
        c12: if idx == 12 { val } else { t.c12 },
        c13: if idx == 13 { val } else { t.c13 },
        c14: if idx == 14 { val } else { t.c14 },
        c15: if idx == 15 { val } else { t.c15 },
        end0: t.end0, end1: t.end1, end2: t.end2, end3: t.end3,
        next_id: t.next_id
    }
}

fn get_end(t: Trie, node: Int) -> Int {
    if node == 0 { t.end0 } else if node == 1 { t.end1 }
    else if node == 2 { t.end2 } else { t.end3 }
}

fn set_end(t: Trie, node: Int) -> Trie {
    Trie {
        c0: t.c0, c1: t.c1, c2: t.c2, c3: t.c3,
        c4: t.c4, c5: t.c5, c6: t.c6, c7: t.c7,
        c8: t.c8, c9: t.c9, c10: t.c10, c11: t.c11,
        c12: t.c12, c13: t.c13, c14: t.c14, c15: t.c15,
        end0: if node == 0 { 1 } else { t.end0 },
        end1: if node == 1 { 1 } else { t.end1 },
        end2: if node == 2 { 1 } else { t.end2 },
        end3: if node == 3 { 1 } else { t.end3 },
        next_id: t.next_id
    }
}

// Insert a 2-char "word" (ch0, ch1) into trie
fn insert2(t: Trie, ch0: Int, ch1: Int) -> Trie {
    let mut tr = t;
    let mut node = 0;
    // First char
    let c = get_child(tr, node, ch0);
    if c == -1 {
        let new_id = tr.next_id;
        tr = set_child(tr, node, ch0, new_id);
        tr = Trie {
            c0: tr.c0, c1: tr.c1, c2: tr.c2, c3: tr.c3,
            c4: tr.c4, c5: tr.c5, c6: tr.c6, c7: tr.c7,
            c8: tr.c8, c9: tr.c9, c10: tr.c10, c11: tr.c11,
            c12: tr.c12, c13: tr.c13, c14: tr.c14, c15: tr.c15,
            end0: tr.end0, end1: tr.end1, end2: tr.end2, end3: tr.end3,
            next_id: new_id + 1
        };
        node = new_id;
    } else {
        node = c;
    }
    // Second char
    let c2 = get_child(tr, node, ch1);
    if c2 == -1 {
        let new_id2 = tr.next_id;
        tr = set_child(tr, node, ch1, new_id2);
        tr = Trie {
            c0: tr.c0, c1: tr.c1, c2: tr.c2, c3: tr.c3,
            c4: tr.c4, c5: tr.c5, c6: tr.c6, c7: tr.c7,
            c8: tr.c8, c9: tr.c9, c10: tr.c10, c11: tr.c11,
            c12: tr.c12, c13: tr.c13, c14: tr.c14, c15: tr.c15,
            end0: tr.end0, end1: tr.end1, end2: tr.end2, end3: tr.end3,
            next_id: new_id2 + 1
        };
        node = new_id2;
    } else {
        node = c2;
    }
    set_end(tr, node)
}

// Search for a 2-char word
fn search2(t: Trie, ch0: Int, ch1: Int) -> Int {
    let c = get_child(t, 0, ch0);
    if c == -1 { return 0; }
    let c2 = get_child(t, c, ch1);
    if c2 == -1 { return 0; }
    get_end(t, c2)
}

// Check if prefix exists (1-char prefix)
fn has_prefix(t: Trie, ch0: Int) -> Int {
    if get_child(t, 0, ch0) != -1 { 1 } else { 0 }
}

fn test_trie() -> Int {
    let mut t = new_trie();
    // Insert 2 words sharing prefix: (0,1) and (0,2)
    // Uses nodes: 0 (root), 1 (child of root via char 0), 2 (end of word 0,1), 3 (end of word 0,2)
    t = insert2(t, 0, 1);
    t = insert2(t, 0, 2);

    // Search existing
    assert_eq(search2(t, 0, 1), 1);
    assert_eq(search2(t, 0, 2), 1);

    // Search non-existing
    assert_eq(search2(t, 0, 3), 0);
    assert_eq(search2(t, 1, 0), 0);
    assert_eq(search2(t, 2, 0), 0);

    // Prefix checks
    assert_eq(has_prefix(t, 0), 1);  // prefix '0' exists
    assert_eq(has_prefix(t, 1), 0);  // prefix '1' doesn't exist
    assert_eq(has_prefix(t, 2), 0);
    1
}

fn main() -> Int {
    test_trie();
    print("[OK] 441_trie_sim_aot");
    0
}
