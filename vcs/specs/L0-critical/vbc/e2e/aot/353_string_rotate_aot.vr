// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, string-rotation, pattern-matching, array-ops
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for string rotation detection.
// A string S2 is a rotation of S1 if S2 can be found as a substring
// of S1+S1. E.g., "erbottl" is a rotation of "bottle" because
// "bottlebottle" contains "erbottl" (not true, but "ottleb" yes).
// We simulate strings as integer arrays (character codes).

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 { Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 } }

// 16-element array for the doubled string
type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int,
    a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int,
    a12: Int, a13: Int, a14: Int, a15: Int
};

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 }
    else if i == 8 { a.a8 } else if i == 9 { a.a9 }
    else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 }
    else if i == 14 { a.a14 } else { a.a15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 },
        a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 },
        a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 },
        a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 },
        a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 },
        a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 },
        a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 },
        a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 },
        a15: if i == 15 { v } else { a.a15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
            a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0 }
}

// A "string" is an Arr8 with a length
type Str8 is { chars: Arr8, len: Int };

// Concatenate s+s into a 16-element array
fn double_str(s: Str8) -> Arr16 {
    let mut result = a16_zero();
    let mut i = 0;
    while i < s.len {
        result = a16_set(result, i, a8_get(s.chars, i));
        result = a16_set(result, i + s.len, a8_get(s.chars, i));
        i = i + 1;
    }
    result
}

// Check if needle (Str8) is a substring of haystack (Arr16) with length hlen
fn is_substring(haystack: Arr16, hlen: Int, needle: Str8) -> Int {
    if needle.len > hlen { return 0; }
    let mut start = 0;
    while start <= hlen - needle.len {
        let mut match_ok = 1;
        let mut j = 0;
        while j < needle.len {
            if a16_get(haystack, start + j) != a8_get(needle.chars, j) {
                match_ok = 0;
                j = needle.len; // break
            } else {
                j = j + 1;
            }
        }
        if match_ok == 1 { return 1; }
        start = start + 1;
    }
    0
}

// Check if s2 is a rotation of s1
fn is_rotation(s1: Str8, s2: Str8) -> Int {
    if s1.len != s2.len { return 0; }
    if s1.len == 0 { return 1; }
    let doubled = double_str(s1);
    is_substring(doubled, s1.len * 2, s2)
}

// Rotate string left by k positions
fn rotate_left_k(s: Str8, k: Int) -> Str8 {
    if s.len == 0 { return s; }
    let kk = k % s.len;
    let mut result = a8_zero();
    let mut i = 0;
    while i < s.len {
        let src = (i + kk) % s.len;
        result = a8_set(result, i, a8_get(s.chars, src));
        i = i + 1;
    }
    Str8 { chars: result, len: s.len }
}

// Compare two Str8 for equality
fn str_eq(a: Str8, bv: Str8) -> Int {
    if a.len != bv.len { return 0; }
    let mut i = 0;
    while i < a.len {
        if a8_get(a.chars, i) != a8_get(bv.chars, i) { return 0; }
        i = i + 1;
    }
    1
}

// === Tests ===

fn test_identity_rotation() {
    // A string is always a rotation of itself
    let s = Str8 { chars: Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    assert_eq(is_rotation(s, s), 1);
}

fn test_simple_rotation() {
    // "abcd" rotated left by 1 = "bcda"
    // Represented as [1,2,3,4] -> [2,3,4,1]
    let s1 = Str8 { chars: Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    let s2 = Str8 { chars: Arr8 { a0: 2, a1: 3, a2: 4, a3: 1, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    assert_eq(is_rotation(s1, s2), 1);
}

fn test_rotation_by_2() {
    // [1,2,3,4,5] rotated by 2 = [3,4,5,1,2]
    let s1 = Str8 { chars: Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 0, a6: 0, a7: 0 }, len: 5 };
    let s2 = Str8 { chars: Arr8 { a0: 3, a1: 4, a2: 5, a3: 1, a4: 2, a5: 0, a6: 0, a7: 0 }, len: 5 };
    assert_eq(is_rotation(s1, s2), 1);
}

fn test_not_rotation() {
    // [1,2,3] and [1,3,2] are NOT rotations
    let s1 = Str8 { chars: Arr8 { a0: 1, a1: 2, a2: 3, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    let s2 = Str8 { chars: Arr8 { a0: 1, a1: 3, a2: 2, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    assert_eq(is_rotation(s1, s2), 0);
}

fn test_different_lengths() {
    let s1 = Str8 { chars: Arr8 { a0: 1, a1: 2, a2: 3, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    let s2 = Str8 { chars: Arr8 { a0: 1, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 2 };
    assert_eq(is_rotation(s1, s2), 0);
}

fn test_empty_strings() {
    let s1 = Str8 { chars: a8_zero(), len: 0 };
    let s2 = Str8 { chars: a8_zero(), len: 0 };
    assert_eq(is_rotation(s1, s2), 1);
}

fn test_single_char() {
    let s1 = Str8 { chars: Arr8 { a0: 7, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 1 };
    let s2 = Str8 { chars: Arr8 { a0: 7, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 1 };
    assert_eq(is_rotation(s1, s2), 1);
    let s3 = Str8 { chars: Arr8 { a0: 8, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 1 };
    assert_eq(is_rotation(s1, s3), 0);
}

fn test_rotate_left_fn() {
    let s = Str8 { chars: Arr8 { a0: 10, a1: 20, a2: 30, a3: 40, a4: 50, a5: 0, a6: 0, a7: 0 }, len: 5 };
    let r1 = rotate_left_k(s, 1);
    assert_eq(a8_get(r1.chars, 0), 20);
    assert_eq(a8_get(r1.chars, 4), 10);
    let r3 = rotate_left_k(s, 3);
    assert_eq(a8_get(r3.chars, 0), 40);
    assert_eq(a8_get(r3.chars, 1), 50);
    assert_eq(a8_get(r3.chars, 2), 10);
}

fn test_all_rotations_detected() {
    // Every rotation of a string should be detected as a rotation
    let s = Str8 { chars: Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 0, a6: 0, a7: 0 }, len: 5 };
    let mut k = 0;
    while k < 5 {
        let rotated = rotate_left_k(s, k);
        assert_eq(is_rotation(s, rotated), 1);
        k = k + 1;
    }
}

fn test_rotation_symmetry() {
    // If A is rotation of B, then B is rotation of A
    let s1 = Str8 { chars: Arr8 { a0: 5, a1: 6, a2: 7, a3: 8, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    let s2 = rotate_left_k(s1, 2);
    assert_eq(is_rotation(s1, s2), 1);
    assert_eq(is_rotation(s2, s1), 1);
}

fn test_repeated_chars() {
    // [1,1,1,2] and [1,1,2,1] are rotations
    let s1 = Str8 { chars: Arr8 { a0: 1, a1: 1, a2: 1, a3: 2, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    let s2 = Str8 { chars: Arr8 { a0: 1, a1: 1, a2: 2, a3: 1, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    assert_eq(is_rotation(s1, s2), 1);
    // [1,1,2] and [2,2,1] are NOT
    let s3 = Str8 { chars: Arr8 { a0: 1, a1: 1, a2: 2, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    let s4 = Str8 { chars: Arr8 { a0: 2, a1: 2, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    assert_eq(is_rotation(s3, s4), 0);
}

fn test_all_same_chars() {
    // All same characters: every permutation of same length is a "rotation"
    let s1 = Str8 { chars: Arr8 { a0: 3, a1: 3, a2: 3, a3: 3, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    let s2 = Str8 { chars: Arr8 { a0: 3, a1: 3, a2: 3, a3: 3, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 4 };
    assert_eq(is_rotation(s1, s2), 1);
}

fn test_rotation_compose() {
    // Rotating by k then by m is same as rotating by (k+m)
    let s = Str8 { chars: Arr8 { a0: 10, a1: 20, a2: 30, a3: 40, a4: 50, a5: 60, a6: 0, a7: 0 }, len: 6 };
    let r2 = rotate_left_k(s, 2);
    let r3_of_r2 = rotate_left_k(r2, 3);
    let r5 = rotate_left_k(s, 5);
    assert_eq(str_eq(r3_of_r2, r5), 1);
}

fn test_full_rotation() {
    // Rotating by length gives back original
    let s = Str8 { chars: Arr8 { a0: 7, a1: 8, a2: 9, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }, len: 3 };
    let rotated = rotate_left_k(s, 3);
    assert_eq(str_eq(s, rotated), 1);
}

fn main() -> Int {
    test_identity_rotation();
    test_simple_rotation();
    test_rotation_by_2();
    test_not_rotation();
    test_different_lengths();
    test_empty_strings();
    test_single_char();
    test_rotate_left_fn();
    test_all_rotations_detected();
    test_rotation_symmetry();
    test_repeated_chars();
    test_all_same_chars();
    test_rotation_compose();
    test_full_rotation();
    print("[OK] 353_string_rotate_aot");
    0
}
