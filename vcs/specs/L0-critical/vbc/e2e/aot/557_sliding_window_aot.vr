// @test: run
// @level: L0
// @tags: aot, e2e, sliding-window, algorithms, streams
// @timeout: 30000

// Sliding window algorithms

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// 1. Maximum sum of window of size k
fn max_window_sum(arr: Arr8, n: Int, k: Int) -> Int {
    // First window
    let mut sum = 0;
    let mut i = 0;
    while i < k {
        sum = sum + get8(arr, i);
        i = i + 1;
    }
    let mut max_sum = sum;
    // Slide
    i = k;
    while i < n {
        sum = sum + get8(arr, i) - get8(arr, i - k);
        if sum > max_sum { max_sum = sum; }
        i = i + 1;
    }
    max_sum
}

// 2. Minimum in each window of size k (returns array of minimums)
type WindowResult is { data: Arr8, count: Int };

fn window_minimums(arr: Arr8, n: Int, k: Int) -> WindowResult {
    let mut result = zeros();
    let num_windows = n - k + 1;
    let mut w = 0;
    while w < num_windows {
        let mut min_v = get8(arr, w);
        let mut j = 1;
        while j < k {
            let v = get8(arr, w + j);
            if v < min_v { min_v = v; }
            j = j + 1;
        }
        result = set8(result, w, min_v);
        w = w + 1;
    }
    WindowResult { data: result, count: num_windows }
}

// 3. Count distinct elements in window of size k
fn count_distinct_window(arr: Arr8, n: Int, start: Int, k: Int) -> Int {
    let mut count = 0;
    let mut i = start;
    while i < start + k {
        // Check if arr[i] is first occurrence in window
        let mut is_first = 1;
        let mut j = start;
        while j < i {
            if get8(arr, j) == get8(arr, i) { is_first = 0; }
            j = j + 1;
        }
        count = count + is_first;
        i = i + 1;
    }
    count
}

// 4. Longest subarray with sum <= target
fn longest_subarray_sum(arr: Arr8, n: Int, target: Int) -> Int {
    let mut best = 0;
    let mut left = 0;
    let mut sum = 0;
    let mut right = 0;
    while right < n {
        sum = sum + get8(arr, right);
        while sum > target {
            sum = sum - get8(arr, left);
            left = left + 1;
        }
        let len = right - left + 1;
        if len > best { best = len; }
        right = right + 1;
    }
    best
}

// 5. Moving average (integer-scaled by window size)
fn moving_average(arr: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = zeros();
    let mut sum = 0;
    let mut i = 0;
    while i < k {
        sum = sum + get8(arr, i);
        i = i + 1;
    }
    result = set8(result, 0, sum);
    i = k;
    let mut out_idx = 1;
    while i < n {
        sum = sum + get8(arr, i) - get8(arr, i - k);
        result = set8(result, out_idx, sum);
        out_idx = out_idx + 1;
        i = i + 1;
    }
    result
}

fn test_max_window_sum() -> Int {
    let arr = Arr8 { v0: 1, v1: 4, v2: 2, v3: 10, v4: 2, v5: 3, v6: 1, v7: 0 };
    // k=3: windows [1,4,2]=7, [4,2,10]=16, [2,10,2]=14, [10,2,3]=15, [2,3,1]=6
    assert_eq(max_window_sum(arr, 7, 3), 16);

    // k=1: max element
    assert_eq(max_window_sum(arr, 7, 1), 10);

    // k=7: sum of all
    assert_eq(max_window_sum(arr, 7, 7), 23);
    1
}

fn test_window_minimums() -> Int {
    let arr = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 0, v7: 0 };
    // k=3: windows [3,1,4]=1, [1,4,1]=1, [4,1,5]=1, [1,5,9]=1
    let wm = window_minimums(arr, 6, 3);
    assert_eq(wm.count, 4);
    assert_eq(get8(wm.data, 0), 1);
    assert_eq(get8(wm.data, 1), 1);
    assert_eq(get8(wm.data, 2), 1);
    assert_eq(get8(wm.data, 3), 1);
    1
}

fn test_window_min_varied() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 7, v5: 0, v6: 0, v7: 0 };
    // k=2: [5,3]=3, [3,8]=3, [8,1]=1, [1,7]=1
    let wm = window_minimums(arr, 5, 2);
    assert_eq(wm.count, 4);
    assert_eq(get8(wm.data, 0), 3);
    assert_eq(get8(wm.data, 1), 3);
    assert_eq(get8(wm.data, 2), 1);
    assert_eq(get8(wm.data, 3), 1);
    1
}

fn test_count_distinct() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 1, v3: 3, v4: 2, v5: 3, v6: 0, v7: 0 };
    // Window [1,2,1]: distinct = 2
    assert_eq(count_distinct_window(arr, 6, 0, 3), 2);
    // Window [2,1,3]: distinct = 3
    assert_eq(count_distinct_window(arr, 6, 1, 3), 3);
    // Window [1,3,2]: distinct = 3
    assert_eq(count_distinct_window(arr, 6, 2, 3), 3);
    1
}

fn test_longest_subarray() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 1, v4: 1, v5: 1, v6: 1, v7: 0 };
    // Target=5: longest subarray with sum<=5
    // [1,2]=3, [1,2,3]=6>5 → len=2
    // [2,3]=5 → len=2
    // [3,1,1]=5 → len=3
    // [1,1,1,1]=4 → len=4
    assert_eq(longest_subarray_sum(arr, 7, 5), 4);
    1
}

fn test_moving_average() -> Int {
    let arr = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 10, v5: 0, v6: 0, v7: 0 };
    // k=3: sums [2+4+6]=12, [4+6+8]=18, [6+8+10]=24
    let ma = moving_average(arr, 5, 3);
    assert_eq(get8(ma, 0), 12);
    assert_eq(get8(ma, 1), 18);
    assert_eq(get8(ma, 2), 24);
    1
}

fn main() -> Int {
    test_max_window_sum();
    test_window_minimums();
    test_window_min_varied();
    test_count_distinct();
    test_longest_subarray();
    test_moving_average();
    print("[OK] 557_sliding_window_aot");
    0
}
