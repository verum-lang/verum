// @test: run
// @level: L0
// @tags: aot, e2e, sliding-window, array
// @timeout: 30000

// Sliding window algorithms on arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// Maximum sum subarray of length k
fn max_sum_window(arr: Arr8, n: Int, k: Int) -> Int {
    // Compute first window sum
    let mut window_sum = 0;
    let mut i = 0;
    while i < k {
        window_sum = window_sum + get8(arr, i);
        i = i + 1;
    }
    let mut best = window_sum;
    // Slide the window
    let mut j = k;
    while j < n {
        window_sum = window_sum + get8(arr, j) - get8(arr, j - k);
        if window_sum > best { best = window_sum; }
        j = j + 1;
    }
    best
}

// Minimum sum subarray of length k
fn min_sum_window(arr: Arr8, n: Int, k: Int) -> Int {
    let mut window_sum = 0;
    let mut i = 0;
    while i < k {
        window_sum = window_sum + get8(arr, i);
        i = i + 1;
    }
    let mut best = window_sum;
    let mut j = k;
    while j < n {
        window_sum = window_sum + get8(arr, j) - get8(arr, j - k);
        if window_sum < best { best = window_sum; }
        j = j + 1;
    }
    best
}

// Maximum subarray sum (Kadane's algorithm)
fn max_subarray_sum(arr: Arr8, n: Int) -> Int {
    let mut best = get8(arr, 0);
    let mut current = get8(arr, 0);
    let mut i = 1;
    while i < n {
        let v = get8(arr, i);
        if current + v > v { current = current + v; }
        else { current = v; }
        if current > best { best = current; }
        i = i + 1;
    }
    best
}

// Count distinct elements in each window of size k
// For small alphabet (values 0-7), use counting
fn count_distinct_in_window(arr: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut w = 0;
    while w + k <= n {
        // Count distinct in [w, w+k-1]
        let mut seen = 0; // bitmask
        let mut count = 0;
        let mut j = w;
        while j < w + k {
            let v = get8(arr, j);
            let mut mask = 1;
            let mut m = 0;
            while m < v { mask = mask * 2; m = m + 1; }
            if (seen / mask) % 2 == 0 {
                seen = seen + mask;
                count = count + 1;
            }
            j = j + 1;
        }
        result = set8(result, w, count);
        w = w + 1;
    }
    result
}

fn test_max_sum_window() -> Int {
    let arr = Arr8 { v0: 1, v1: 4, v2: 2, v3: 10, v4: 2, v5: 3, v6: 1, v7: 0 };
    // Window of 3: [1,4,2]=7, [4,2,10]=16, [2,10,2]=14, [10,2,3]=15, [2,3,1]=6
    assert_eq(max_sum_window(arr, 7, 3), 16);
    assert_eq(min_sum_window(arr, 7, 3), 6);

    // Window of 1 = max element
    assert_eq(max_sum_window(arr, 7, 1), 10);
    1
}

fn test_kadane() -> Int {
    let arr = Arr8 { v0: -2, v1: 1, v2: -3, v3: 4, v4: -1, v5: 2, v6: 1, v7: -5 };
    // Max subarray: [4,-1,2,1] = 6
    assert_eq(max_subarray_sum(arr, 8), 6);

    // All positive
    let arr2 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_subarray_sum(arr2, 5), 15);

    // All negative
    let arr3 = Arr8 { v0: -5, v1: -3, v2: -1, v3: -4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_subarray_sum(arr3, 4), -1);
    1
}

fn test_distinct_window() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 1, v3: 3, v4: 2, v5: 3, v6: 0, v7: 0 };
    let d = count_distinct_in_window(arr, 6, 3);
    // [1,2,1]=2 distinct, [2,1,3]=3, [1,3,2]=3, [3,2,3]=2
    assert_eq(get8(d, 0), 2);
    assert_eq(get8(d, 1), 3);
    assert_eq(get8(d, 2), 3);
    assert_eq(get8(d, 3), 2);
    1
}

fn main() -> Int {
    test_max_sum_window();
    test_kadane();
    test_distinct_window();
    print("[OK] 455_sliding_window_aot");
    0
}
