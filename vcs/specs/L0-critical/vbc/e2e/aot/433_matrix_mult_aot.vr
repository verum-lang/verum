// @test: run
// @level: L0
// @tags: aot, e2e, matrix, multiplication, linear-algebra
// @timeout: 30000

// 3x3 matrix multiplication and operations

type Mat3 is { m00: Int, m01: Int, m02: Int, m10: Int, m11: Int, m12: Int, m20: Int, m21: Int, m22: Int };

fn mat3_identity() -> Mat3 {
    Mat3 { m00: 1, m01: 0, m02: 0, m10: 0, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 }
}

fn mat3_mul(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00 * b.m00 + a.m01 * b.m10 + a.m02 * b.m20,
        m01: a.m00 * b.m01 + a.m01 * b.m11 + a.m02 * b.m21,
        m02: a.m00 * b.m02 + a.m01 * b.m12 + a.m02 * b.m22,
        m10: a.m10 * b.m00 + a.m11 * b.m10 + a.m12 * b.m20,
        m11: a.m10 * b.m01 + a.m11 * b.m11 + a.m12 * b.m21,
        m12: a.m10 * b.m02 + a.m11 * b.m12 + a.m12 * b.m22,
        m20: a.m20 * b.m00 + a.m21 * b.m10 + a.m22 * b.m20,
        m21: a.m20 * b.m01 + a.m21 * b.m11 + a.m22 * b.m21,
        m22: a.m20 * b.m02 + a.m21 * b.m12 + a.m22 * b.m22
    }
}

fn mat3_trace(m: Mat3) -> Int {
    m.m00 + m.m11 + m.m22
}

fn mat3_det(m: Mat3) -> Int {
    m.m00 * (m.m11 * m.m22 - m.m12 * m.m21) -
    m.m01 * (m.m10 * m.m22 - m.m12 * m.m20) +
    m.m02 * (m.m10 * m.m21 - m.m11 * m.m20)
}

fn mat3_transpose(m: Mat3) -> Mat3 {
    Mat3 {
        m00: m.m00, m01: m.m10, m02: m.m20,
        m10: m.m01, m11: m.m11, m12: m.m21,
        m20: m.m02, m21: m.m12, m22: m.m22
    }
}

fn mat3_scale(m: Mat3, s: Int) -> Mat3 {
    Mat3 {
        m00: m.m00 * s, m01: m.m01 * s, m02: m.m02 * s,
        m10: m.m10 * s, m11: m.m11 * s, m12: m.m12 * s,
        m20: m.m20 * s, m21: m.m21 * s, m22: m.m22 * s
    }
}

fn mat3_add(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00 + b.m00, m01: a.m01 + b.m01, m02: a.m02 + b.m02,
        m10: a.m10 + b.m10, m11: a.m11 + b.m11, m12: a.m12 + b.m12,
        m20: a.m20 + b.m20, m21: a.m21 + b.m21, m22: a.m22 + b.m22
    }
}

// Matrix power (positive integer)
fn mat3_pow(m: Mat3, n: Int) -> Mat3 {
    let mut result = mat3_identity();
    let mut i = 0;
    while i < n {
        result = mat3_mul(result, m);
        i = i + 1;
    }
    result
}

fn test_identity() -> Int {
    let i = mat3_identity();
    let m = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    let r = mat3_mul(i, m);
    assert_eq(r.m00, 1);
    assert_eq(r.m11, 5);
    assert_eq(r.m22, 9);
    1
}

fn test_mul() -> Int {
    let a = Mat3 { m00: 1, m01: 2, m02: 0, m10: 0, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 };
    let b = Mat3 { m00: 1, m01: 0, m02: 0, m10: 3, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 };
    let r = mat3_mul(a, b);
    // r[0][0] = 1*1 + 2*3 + 0*0 = 7
    assert_eq(r.m00, 7);
    assert_eq(r.m01, 2);
    assert_eq(r.m10, 3);
    assert_eq(r.m11, 1);
    1
}

fn test_det_trace() -> Int {
    let m = Mat3 { m00: 1, m01: 2, m02: 3, m10: 0, m11: 1, m12: 4, m20: 5, m21: 6, m22: 0 };
    assert_eq(mat3_trace(m), 2); // 1+1+0
    assert_eq(mat3_det(m), 1); // 1*(0-24) - 2*(0-20) + 3*(0-5) = -24+40-15 = 1
    1
}

fn test_transpose() -> Int {
    let m = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    let t = mat3_transpose(m);
    assert_eq(t.m01, 4);
    assert_eq(t.m10, 2);
    assert_eq(t.m20, 3);
    assert_eq(t.m02, 7);
    1
}

fn test_pow() -> Int {
    // [[1,1,0],[0,1,0],[0,0,1]]^3 = [[1,3,0],[0,1,0],[0,0,1]]
    let m = Mat3 { m00: 1, m01: 1, m02: 0, m10: 0, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 };
    let r = mat3_pow(m, 3);
    assert_eq(r.m00, 1);
    assert_eq(r.m01, 3);
    assert_eq(r.m11, 1);
    assert_eq(r.m10, 0);
    1
}

fn main() -> Int {
    test_identity();
    test_mul();
    test_det_trace();
    test_transpose();
    test_pow();
    print("[OK] 433_matrix_mult_aot");
    0
}
