// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, milestone, comprehensive
// @timeout: 50000
// @expected-exit: 0
//
// Milestone test #250: comprehensive feature integration test

fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }
fn max2(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min2(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// === Multi-level records ===
type Vec2 is { x: Int, y: Int };
type Rect is { origin: Vec2, size: Vec2 };

fn rect_area(r: Rect) -> Int { r.size.x * r.size.y }
fn rect_perimeter(r: Rect) -> Int { 2 * (r.size.x + r.size.y) }
fn rect_contains(r: Rect, p: Vec2) -> Bool {
    p.x >= r.origin.x && p.x < r.origin.x + r.size.x &&
    p.y >= r.origin.y && p.y < r.origin.y + r.size.y
}

// === Higher-order with closures ===
fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int { f(f(x)) }
fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int, x: Int) -> Int { f(g(x)) }

fn reduce5(a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, f: fn(Int, Int) -> Int, init: Int) -> Int {
    let mut acc = init;
    acc = f(acc, a0);
    acc = f(acc, a1);
    acc = f(acc, a2);
    acc = f(acc, a3);
    acc = f(acc, a4);
    acc
}

// === Number theory ===
fn gcd(a: Int, b: Int) -> Int {
    let mut x = abs_val(a);
    let mut y = abs_val(b);
    while y != 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

fn lcm(a: Int, b: Int) -> Int {
    if a == 0 || b == 0 { return 0; }
    abs_val(a) / gcd(a, b) * abs_val(b)
}

fn is_prime(n: Int) -> Bool {
    if n < 2 { return false; }
    let mut i = 2;
    while i * i <= n {
        if n % i == 0 { return false; }
        i = i + 1;
    }
    true
}

fn nth_prime(n: Int) -> Int {
    let mut count = 0;
    let mut candidate = 2;
    while count < n {
        if is_prime(candidate) {
            count = count + 1;
            if count == n { return candidate; }
        }
        candidate = candidate + 1;
    }
    candidate
}

// === Sorting ===
type Arr5 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int };

fn arr5_get(a: Arr5, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else { a.a4 }
}

fn arr5_set(a: Arr5, i: Int, v: Int) -> Arr5 {
    Arr5 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }
    }
}

fn bubble_sort5(a: Arr5) -> Arr5 {
    let mut arr = a;
    let mut i = 0;
    while i < 4 {
        let mut j = 0;
        while j < 4 - i {
            if arr5_get(arr, j) > arr5_get(arr, j + 1) {
                let tmp = arr5_get(arr, j);
                arr = arr5_set(arr, j, arr5_get(arr, j + 1));
                arr = arr5_set(arr, j + 1, tmp);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

fn test_records() {
    let r = Rect {
        origin: Vec2 { x: 10, y: 20 },
        size: Vec2 { x: 30, y: 40 }
    };
    assert_eq(rect_area(r), 1200);
    assert_eq(rect_perimeter(r), 140);
    assert_eq(rect_contains(r, Vec2 { x: 15, y: 25 }), true);
    assert_eq(rect_contains(r, Vec2 { x: 5, y: 25 }), false);
    assert_eq(rect_contains(r, Vec2 { x: 40, y: 60 }), false);
}

fn test_closures() {
    let double = |x: Int| -> Int { x * 2 };
    let inc = |x: Int| -> Int { x + 1 };

    assert_eq(apply_twice(double, 3), 12);  // 3->6->12
    assert_eq(apply_twice(inc, 10), 12);    // 10->11->12
    assert_eq(compose(double, inc, 5), 12); // inc(5)=6, double(6)=12
    assert_eq(compose(inc, double, 5), 11); // double(5)=10, inc(10)=11
}

fn test_reduce() {
    let add = |a: Int, b: Int| -> Int { a + b };
    let mul = |a: Int, b: Int| -> Int { a * b };
    let max_fn = |a: Int, b: Int| -> Int { if a > b { a } else { b } };

    assert_eq(reduce5(1, 2, 3, 4, 5, add, 0), 15);
    assert_eq(reduce5(1, 2, 3, 4, 5, mul, 1), 120);
    assert_eq(reduce5(3, 7, 2, 9, 1, max_fn, 0), 9);
}

fn test_number_theory() {
    assert_eq(gcd(12, 18), 6);
    assert_eq(gcd(35, 49), 7);
    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(3, 7), 21);

    assert_eq(is_prime(2), true);
    assert_eq(is_prime(97), true);
    assert_eq(is_prime(100), false);

    // First few primes
    assert_eq(nth_prime(1), 2);
    assert_eq(nth_prime(5), 11);
    assert_eq(nth_prime(10), 29);
}

fn test_sorting() {
    let a = Arr5 { a0: 5, a1: 3, a2: 1, a3: 4, a4: 2 };
    let sorted = bubble_sort5(a);
    assert_eq(arr5_get(sorted, 0), 1);
    assert_eq(arr5_get(sorted, 1), 2);
    assert_eq(arr5_get(sorted, 2), 3);
    assert_eq(arr5_get(sorted, 3), 4);
    assert_eq(arr5_get(sorted, 4), 5);
}

fn test_bitwise() {
    // Power of 2 check
    let mut i = 1;
    let mut count = 0;
    while i <= 256 {
        if (i & (i - 1)) == 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    assert_eq(count, 9);  // 1,2,4,8,16,32,64,128,256

    // XOR properties
    assert_eq(42 ^ 42, 0);
    assert_eq(42 ^ 0, 42);
    assert_eq((42 ^ 99) ^ 99, 42);
}

fn main() -> Int {
    test_records();
    test_closures();
    test_reduce();
    test_number_theory();
    test_sorting();
    test_bitwise();
    print("[OK] 250_milestone_250_aot");
    0
}
