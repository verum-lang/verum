// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, functional, closures, composition
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for functional programming patterns

fn map_int(f: fn(Int) -> Int, x: Int) -> Int {
    f(x)
}

fn compose2(f: fn(Int) -> Int, g: fn(Int) -> Int, x: Int) -> Int {
    f(g(x))
}

fn pipe3(x: Int, f: fn(Int) -> Int, g: fn(Int) -> Int, h: fn(Int) -> Int) -> Int {
    h(g(f(x)))
}

fn filter_count(start: Int, end: Int, pred: fn(Int) -> Bool) -> Int {
    let mut count = 0;
    let mut i = start;
    while i < end {
        if pred(i) { count = count + 1; }
        i = i + 1;
    }
    count
}

fn reduce(start: Int, end: Int, init: Int, f: fn(Int, Int) -> Int) -> Int {
    let mut acc = init;
    let mut i = start;
    while i < end {
        acc = f(acc, i);
        i = i + 1;
    }
    acc
}

fn find_first(start: Int, end: Int, pred: fn(Int) -> Bool) -> Int {
    let mut i = start;
    while i < end {
        if pred(i) { return i; }
        i = i + 1;
    }
    -1
}

fn all_of(start: Int, end: Int, pred: fn(Int) -> Bool) -> Bool {
    let mut i = start;
    while i < end {
        if !pred(i) { return false; }
        i = i + 1;
    }
    true
}

fn any_of(start: Int, end: Int, pred: fn(Int) -> Bool) -> Bool {
    let mut i = start;
    while i < end {
        if pred(i) { return true; }
        i = i + 1;
    }
    false
}

fn test_map_compose() {
    let double = |x: Int| -> Int { x * 2 };
    let inc = |x: Int| -> Int { x + 1 };
    let square = |x: Int| -> Int { x * x };

    assert_eq(map_int(double, 5), 10);
    assert_eq(compose2(double, inc, 5), 12);
    assert_eq(compose2(inc, double, 5), 11);
    assert_eq(pipe3(2, inc, double, square), 36);  // (2+1)*2 = 6, 6^2 = 36
}

fn test_filter_reduce() {
    let is_even = |x: Int| -> Bool { x % 2 == 0 };
    let is_positive = |x: Int| -> Bool { x > 0 };
    let add = |a: Int, b: Int| -> Int { a + b };
    let mul = |a: Int, b: Int| -> Int { a * b };

    assert_eq(filter_count(0, 10, is_even), 5);
    assert_eq(filter_count(1, 10, is_even), 4);

    assert_eq(reduce(0, 10, 0, add), 45);
    assert_eq(reduce(1, 6, 1, mul), 120);
}

fn test_find_any_all() {
    let is_even = |x: Int| -> Bool { x % 2 == 0 };
    let is_gt_100 = |x: Int| -> Bool { x > 100 };

    assert_eq(find_first(0, 10, is_even), 0);
    assert_eq(find_first(1, 10, is_even), 2);
    assert_eq(find_first(0, 10, is_gt_100), -1);

    assert_eq(any_of(0, 10, is_even), true);
    assert_eq(any_of(1, 2, is_even), false);  // Only 1, which is odd

    let all_positive = |x: Int| -> Bool { x > 0 };
    assert_eq(all_of(1, 10, all_positive), true);
    assert_eq(all_of(0, 10, all_positive), false);
}

fn main() -> Int {
    test_map_compose();
    test_filter_reduce();
    test_find_any_all();
    print("[OK] 192_functional_patterns_aot");
    0
}
