// @test: run
// List<Pair<List<Int>, Text>> element field access propagates types

type Pair<A, B> is { first: A, second: B };

fn make_pairs() -> List<Pair<List<Int>, Text>> {
    let pairs = List.new();
    let nums1 = List.new();
    nums1.push(1); nums1.push(2); nums1.push(3);
    let nums2 = List.new();
    nums2.push(10); nums2.push(20);
    pairs.push(Pair { first: nums1, second: "hello" });
    pairs.push(Pair { first: nums2, second: "world" });
    pairs
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    let pairs = make_pairs();

    // Test 1: outer list len
    if (pairs.len() == 2) { passed = passed + 1; }
    else { print(f"FAIL 1: pairs.len()={pairs.len()}"); failed = failed + 1; }

    // Test 2: element access — get a Pair
    let p0 = pairs[0];
    let list0 = p0.first;
    if (list0.len() == 3) { passed = passed + 1; }
    else { print(f"FAIL 2: list0.len()={list0.len()}"); failed = failed + 1; }

    // Test 3: inner list element access
    if (list0[0] == 1 && list0[2] == 3) { passed = passed + 1; }
    else { print(f"FAIL 3: list0[0]={list0[0]} list0[2]={list0[2]}"); failed = failed + 1; }

    // Test 4: text field from pair
    let text0 = p0.second;
    if (text0.len() == 5) { passed = passed + 1; }
    else { print(f"FAIL 4: text0.len()={text0.len()}"); failed = failed + 1; }

    // Test 5: second pair
    let p1 = pairs[1];
    let list1 = p1.first;
    let text1 = p1.second;
    if (list1.len() == 2 && list1[0] == 10 && text1 == "world") { passed = passed + 1; }
    else { print(f"FAIL 5: list1.len()={list1.len()} text1={text1}"); failed = failed + 1; }

    if (failed > 0) {
        print(f"list_of_generic_structs: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"list_of_generic_structs: PASS ({passed}/{passed} tests)");
    0
}
