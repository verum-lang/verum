// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, date, math, calendar
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for date arithmetic (all integer-based)

fn is_leap_year(year: Int) -> Bool {
    if year % 400 == 0 { return true; }
    if year % 100 == 0 { return false; }
    year % 4 == 0
}

fn days_in_month(month: Int, year: Int) -> Int {
    if month == 2 {
        if is_leap_year(year) { 29 } else { 28 }
    } else if month == 4 || month == 6 || month == 9 || month == 11 {
        30
    } else {
        31
    }
}

fn days_in_year(year: Int) -> Int {
    if is_leap_year(year) { 366 } else { 365 }
}

// Day of year (1-indexed)
fn day_of_year(day: Int, month: Int, year: Int) -> Int {
    let mut total = 0;
    let mut m = 1;
    while m < month {
        total = total + days_in_month(m, year);
        m = m + 1;
    }
    total + day
}

// Is valid date
fn is_valid_date(day: Int, month: Int, year: Int) -> Bool {
    if month < 1 || month > 12 { return false; }
    if day < 1 || day > days_in_month(month, year) { return false; }
    true
}

// Day of week using Zeller's congruence (0=Sat, 1=Sun, ..., 6=Fri)
fn zeller(day: Int, month: Int, year: Int) -> Int {
    let mut m = month;
    let mut y = year;
    if m < 3 {
        m = m + 12;
        y = y - 1;
    }
    let k = y % 100;
    let j = y / 100;
    let h = (day + (13 * (m + 1)) / 5 + k + k / 4 + j / 4 - 2 * j) % 7;
    // Normalize to 0-6
    if h < 0 { h + 7 } else { h }
}

// Days between two dates in same year
fn days_between_same_year(d1: Int, m1: Int, d2: Int, m2: Int, y: Int) -> Int {
    let doy1 = day_of_year(d1, m1, y);
    let doy2 = day_of_year(d2, m2, y);
    if doy2 >= doy1 { doy2 - doy1 } else { doy1 - doy2 }
}

fn test_leap_year() {
    assert_eq(is_leap_year(2000), true);    // Divisible by 400
    assert_eq(is_leap_year(1900), false);   // Divisible by 100 but not 400
    assert_eq(is_leap_year(2024), true);    // Divisible by 4
    assert_eq(is_leap_year(2023), false);   // Not divisible by 4
    assert_eq(is_leap_year(2100), false);
    assert_eq(is_leap_year(2400), true);
}

fn test_days_in_month() {
    assert_eq(days_in_month(1, 2024), 31);
    assert_eq(days_in_month(2, 2024), 29);   // Leap year
    assert_eq(days_in_month(2, 2023), 28);   // Non-leap
    assert_eq(days_in_month(4, 2024), 30);
    assert_eq(days_in_month(12, 2024), 31);
}

fn test_day_of_year() {
    assert_eq(day_of_year(1, 1, 2024), 1);
    assert_eq(day_of_year(31, 1, 2024), 31);
    assert_eq(day_of_year(1, 2, 2024), 32);
    assert_eq(day_of_year(29, 2, 2024), 60);   // Leap year Feb 29
    assert_eq(day_of_year(1, 3, 2024), 61);
    assert_eq(day_of_year(31, 12, 2024), 366);  // Leap year
    assert_eq(day_of_year(31, 12, 2023), 365);  // Non-leap
}

fn test_valid_dates() {
    assert_eq(is_valid_date(15, 6, 2024), true);
    assert_eq(is_valid_date(29, 2, 2024), true);   // Leap year
    assert_eq(is_valid_date(29, 2, 2023), false);  // Non-leap
    assert_eq(is_valid_date(31, 4, 2024), false);  // April has 30
    assert_eq(is_valid_date(0, 1, 2024), false);   // Day 0
    assert_eq(is_valid_date(1, 13, 2024), false);  // Month 13
}

fn test_days_between() {
    assert_eq(days_between_same_year(1, 1, 1, 1, 2024), 0);
    assert_eq(days_between_same_year(1, 1, 2, 1, 2024), 1);
    assert_eq(days_between_same_year(1, 1, 1, 2, 2024), 31);
    assert_eq(days_between_same_year(1, 1, 31, 12, 2024), 365);
}

fn test_zeller() {
    // Known day: Jan 1, 2024 was Monday
    // Zeller: h=0 Sat, 1 Sun, 2 Mon, ...
    let h = zeller(1, 1, 2024);
    assert_eq(h, 2);  // Monday = 2

    // July 4, 1776 was Thursday
    let h2 = zeller(4, 7, 1776);
    assert_eq(h2, 5);  // Thursday = 5
}

fn main() -> Int {
    test_leap_year();
    test_days_in_month();
    test_day_of_year();
    test_valid_dates();
    test_days_between();
    test_zeller();
    print("[OK] 239_date_math_aot");
    0
}
