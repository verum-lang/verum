// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, concurrency, patterns, producer-consumer, fan-out
// @timeout: 15000
// @expected-exit: 0
// @description: Concurrent data structure patterns — producer-consumer with backpressure, multi-producer single-consumer, fan-out/fan-in

fn __mutex_new_raw() -> Int { 0 }
fn __mutex_lock_raw(mtx: Int) -> Int { 0 }
fn __mutex_unlock_raw(mtx: Int) -> Int { 0 }

fn producer(out: Channel<Int>, count: Int, multiplier: Int) -> Int {
    let mut i = 0;
    while i < count {
        out.send(i * multiplier);
        i = i + 1;
    }
    0
}

fn consumer(inp: Channel<Int>, expected_count: Int, result: Channel<Int>) -> Int {
    let mut sum = 0;
    let mut received = 0;
    while received < expected_count {
        match inp.recv() {
            Some(v) => {
                sum = sum + v;
                received = received + 1;
            }
            None => {}
        }
    }
    result.send(sum);
    sum
}

fn main() -> Int {
    let mut pass = 0;

    // Test 1: Bounded channel backpressure — producer blocks when full
    let bounded = Channel.new(3);  // small capacity

    let p = spawn {
        let mut i = 0;
        while i < 10 {
            bounded.send(i);
            i = i + 1;
        }
        bounded.send(-1);  // sentinel
        0
    };

    let c = spawn {
        let mut sum = 0;
        let mut done = false;
        while !done {
            match bounded.recv() {
                Some(v) => {
                    if v == -1 { done = true; }
                    else { sum = sum + v; }
                }
                None => { done = true; }
            }
        }
        sum
    };

    p.await;
    let result = c.await;
    // 0+1+2+...+9 = 45
    if result == 45 { pass = pass + 1; } else { print(f"FAIL1: expected 45, got {result}"); }

    // Test 2: Multiple producers → single consumer
    let data_ch = Channel.new(20);
    let result_ch = Channel.new(1);

    // 3 producers, each sends 5 values
    let p1 = spawn producer(data_ch, 5, 1);    // 0,1,2,3,4
    let p2 = spawn producer(data_ch, 5, 10);   // 0,10,20,30,40
    let p3 = spawn producer(data_ch, 5, 100);  // 0,100,200,300,400

    // Consumer collects all 15 values
    let c2 = spawn consumer(data_ch, 15, result_ch);

    p1.await;
    p2.await;
    p3.await;
    c2.await;

    let mut total = 0;
    match result_ch.recv() {
        Some(v) => { total = v; }
        None => {}
    }
    // (0+1+2+3+4) + (0+10+20+30+40) + (0+100+200+300+400) = 10 + 100 + 1000 = 1110
    if total == 1110 { pass = pass + 1; } else { print(f"FAIL2: expected 1110, got {total}"); }

    // Test 3: Fan-out/fan-in with proper ordering verification
    let work = Channel.new(20);
    let r1 = Channel.new(5);
    let r2 = Channel.new(5);
    let r3 = Channel.new(5);
    let r4 = Channel.new(5);

    // Distribute work
    let mut i = 1;
    while i <= 8 {
        work.send(i);
        i = i + 1;
    }

    // 4 workers, each takes 2 items
    let w1 = spawn {
        let mut s = 0;
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        r1.send(s);
        s
    };
    let w2 = spawn {
        let mut s = 0;
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        r2.send(s);
        s
    };
    let w3 = spawn {
        let mut s = 0;
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        r3.send(s);
        s
    };
    let w4 = spawn {
        let mut s = 0;
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        match work.recv() { Some(v) => { s = s + v; } None => {} }
        r4.send(s);
        s
    };

    w1.await;
    w2.await;
    w3.await;
    w4.await;

    let mut grand = 0;
    match r1.recv() { Some(v) => { grand = grand + v; } None => {} }
    match r2.recv() { Some(v) => { grand = grand + v; } None => {} }
    match r3.recv() { Some(v) => { grand = grand + v; } None => {} }
    match r4.recv() { Some(v) => { grand = grand + v; } None => {} }

    // 1+2+3+4+5+6+7+8 = 36
    if grand == 36 { pass = pass + 1; } else { print(f"FAIL3: expected 36, got {grand}"); }

    // Test 4: Pipeline pattern — producer → transformer → consumer
    let stage1 = Channel.new(10);
    let stage2 = Channel.new(10);
    let final_ch = Channel.new(1);

    let prod = spawn {
        let mut i = 0;
        while i < 5 {
            stage1.send(i * 10);
            i = i + 1;
        }
        stage1.send(-1);
        0
    };

    let transform = spawn {
        let mut done = false;
        while !done {
            match stage1.recv() {
                Some(v) => {
                    if v == -1 {
                        stage2.send(-1);
                        done = true;
                    } else {
                        stage2.send(v + 1);
                    }
                }
                None => { done = true; }
            }
        }
        0
    };

    let cons = spawn {
        let mut sum = 0;
        let mut done = false;
        while !done {
            match stage2.recv() {
                Some(v) => {
                    if v == -1 { done = true; }
                    else { sum = sum + v; }
                }
                None => { done = true; }
            }
        }
        final_ch.send(sum);
        sum
    };

    prod.await;
    transform.await;
    cons.await;

    let mut pipeline_result = 0;
    match final_ch.recv() {
        Some(v) => { pipeline_result = v; }
        None => {}
    }
    // (0+1) + (10+1) + (20+1) + (30+1) + (40+1) = 1+11+21+31+41 = 105
    if pipeline_result == 105 { pass = pass + 1; } else { print(f"FAIL4: expected 105, got {pipeline_result}"); }

    print(f"pass = {pass}/4");
    if pass == 4 {
        print("ALL OK");
        return 0;
    }
    return 1;
}
