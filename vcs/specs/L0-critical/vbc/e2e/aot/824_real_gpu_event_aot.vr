// @test: run
// @tier: 2
// @level: L0
// @tags: aot, gpu, real-opcode, event
// @expected-exit: 0

// Tests REAL GPU event management intrinsics through AOT (LLVM) pipeline.
// Mirror of interpreter test 204. Exercises gpu_event_create,
// gpu_event_record, gpu_event_sync, gpu_event_destroy, gpu_event_elapsed.

// GPU event intrinsic declarations
fn gpu_event_create() -> Int { @intrinsic("GPU_EVENT_CREATE") }
fn gpu_event_record(event: Int, stream_id: Int) -> Int { @intrinsic("GPU_EVENT_RECORD", event, stream_id) }
fn gpu_event_sync(event: Int) -> Int { @intrinsic("GPU_EVENT_SYNC", event) }
fn gpu_event_destroy(event: Int) -> Int { @intrinsic("GPU_EVENT_DESTROY", event) }
fn gpu_event_elapsed(start_event: Int, end_event: Int) -> Int { @intrinsic("GPU_EVENT_ELAPSED", start_event, end_event) }
fn gpu_stream_create() -> Int { @intrinsic("GPU_STREAM_CREATE") }
fn gpu_stream_destroy(stream_id: Int) -> Int { @intrinsic("GPU_STREAM_DESTROY", stream_id) }

fn gpu_get_device() -> Int { @intrinsic("GPU_GET_DEVICE") }

fn main() -> Int {
    if gpu_get_device() == 0 {
        print("SKIP: No GPU device available");
        return 0;
    }

    let mut errors = 0;

    // Test 1: Create an event
    let e1 = gpu_event_create();
    if e1 < 0 { errors = errors + 1; }

    // Test 2: Create another event (different handle)
    let e2 = gpu_event_create();
    if e2 < 0 { errors = errors + 1; }
    if e1 == e2 { errors = errors + 1; }

    // Test 3: Create a stream and record event on it
    let s = gpu_stream_create();
    let rec = gpu_event_record(e1, s);
    if rec != 0 { errors = errors + 1; }

    // Test 4: Sync event
    let sync = gpu_event_sync(e1);
    if sync != 0 { errors = errors + 1; }

    // Test 5: Record second event
    let rec2 = gpu_event_record(e2, s);
    if rec2 != 0 { errors = errors + 1; }
    let sync2 = gpu_event_sync(e2);
    if sync2 != 0 { errors = errors + 1; }

    // Test 6: Elapsed time between events (should be >= 0)
    let elapsed = gpu_event_elapsed(e1, e2);
    if elapsed < 0 { errors = errors + 1; }

    // Test 7: Destroy events and stream
    let de1 = gpu_event_destroy(e1);
    if de1 != 0 { errors = errors + 1; }
    let de2 = gpu_event_destroy(e2);
    if de2 != 0 { errors = errors + 1; }
    let ds = gpu_stream_destroy(s);
    if ds != 0 { errors = errors + 1; }

    errors
}
