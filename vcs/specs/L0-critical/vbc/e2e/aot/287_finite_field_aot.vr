// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, finite-field, modular-arithmetic, polynomial
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for GF(p) arithmetic (add, sub, mul, inverse, power) and polynomial evaluation

// === GF(p) field element ===
// We use a small prime p = 97 for all operations
fn field_prime() -> Int { 97 }

// Normalize to [0, p)
fn gf_norm(a: Int) -> Int {
    let p = field_prime();
    let r = a % p;
    if r < 0 { r + p } else { r }
}

fn gf_add(a: Int, b: Int) -> Int { gf_norm(a + b) }
fn gf_sub(a: Int, b: Int) -> Int { gf_norm(a - b) }
fn gf_mul(a: Int, b: Int) -> Int { gf_norm(a * b) }
fn gf_neg(a: Int) -> Int { gf_norm(-a) }

// Modular exponentiation: a^exp mod p
fn gf_exp(base: Int, exp: Int) -> Int {
    let p = field_prime();
    let mut result = 1;
    let mut b = gf_norm(base);
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % p;
        }
        b = (b * b) % p;
        e = e / 2;
    }
    result
}

// Multiplicative inverse using Fermat's little theorem: a^(-1) = a^(p-2) mod p
fn gf_inv(a: Int) -> Int {
    let p = field_prime();
    gf_exp(a, p - 2)
}

// Division: a / b = a * b^(-1)
fn gf_div(a: Int, b: Int) -> Int {
    gf_mul(a, gf_inv(b))
}

// === Extended Euclidean Algorithm (alternative inverse) ===
// Returns gcd, but also computes inverse as side effect
fn ext_gcd_inv(a: Int) -> Int {
    let p = field_prime();
    let mut old_r = a;
    let mut r = p;
    let mut old_s = 1;
    let mut s = 0;

    while r != 0 {
        let q = old_r / r;
        let tmp_r = r;
        r = old_r - q * r;
        old_r = tmp_r;
        let tmp_s = s;
        s = old_s - q * s;
        old_s = tmp_s;
    }
    gf_norm(old_s)
}

// === Polynomial over GF(p) ===
// Coefficients stored as record fields: poly[0] + poly[1]*x + poly[2]*x^2 + ...
type Poly5 is { c0: Int, c1: Int, c2: Int, c3: Int, c4: Int, deg: Int };

fn poly_new() -> Poly5 { Poly5 { c0: 0, c1: 0, c2: 0, c3: 0, c4: 0, deg: 0 } }

fn poly_get(p: Poly5, i: Int) -> Int {
    if i == 0 { p.c0 } else if i == 1 { p.c1 }
    else if i == 2 { p.c2 } else if i == 3 { p.c3 }
    else { p.c4 }
}

fn poly_set(p: Poly5, i: Int, v: Int) -> Poly5 {
    Poly5 {
        c0: if i == 0 { v } else { p.c0 }, c1: if i == 1 { v } else { p.c1 },
        c2: if i == 2 { v } else { p.c2 }, c3: if i == 3 { v } else { p.c3 },
        c4: if i == 4 { v } else { p.c4 },
        deg: p.deg
    }
}

fn poly_set_deg(p: Poly5, d: Int) -> Poly5 {
    Poly5 { c0: p.c0, c1: p.c1, c2: p.c2, c3: p.c3, c4: p.c4, deg: d }
}

// Evaluate polynomial at x using Horner's method over GF(p)
fn poly_eval(p: Poly5, x: Int) -> Int {
    let mut result = 0;
    let mut i = p.deg;
    while i >= 0 {
        result = gf_add(gf_mul(result, x), poly_get(p, i));
        i = i - 1;
    }
    result
}

// Add two polynomials over GF(p)
fn poly_add(a: Poly5, b: Poly5) -> Poly5 {
    let max_deg = if a.deg > b.deg { a.deg } else { b.deg };
    let mut result = poly_new();
    let mut i = 0;
    while i <= max_deg && i <= 4 {
        let va = if i <= a.deg { poly_get(a, i) } else { 0 };
        let vb = if i <= b.deg { poly_get(b, i) } else { 0 };
        result = poly_set(result, i, gf_add(va, vb));
        i = i + 1;
    }
    // Compute true degree
    let mut d = max_deg;
    while d > 0 && poly_get(result, d) == 0 {
        d = d - 1;
    }
    poly_set_deg(result, d)
}

// Multiply polynomial by scalar over GF(p)
fn poly_scale(p: Poly5, s: Int) -> Poly5 {
    let mut result = poly_new();
    let mut i = 0;
    while i <= p.deg && i <= 4 {
        result = poly_set(result, i, gf_mul(poly_get(p, i), s));
        i = i + 1;
    }
    poly_set_deg(result, p.deg)
}

fn test_gf_basics() {
    let p = field_prime();  // 97
    // Addition
    assert_eq(gf_add(50, 50), 3);     // 100 mod 97 = 3
    assert_eq(gf_add(96, 1), 0);      // 97 mod 97 = 0
    assert_eq(gf_add(0, 0), 0);

    // Subtraction
    assert_eq(gf_sub(10, 5), 5);
    assert_eq(gf_sub(5, 10), 92);     // -5 mod 97 = 92
    assert_eq(gf_sub(0, 1), 96);      // -1 mod 97 = 96

    // Multiplication
    assert_eq(gf_mul(10, 10), 3);     // 100 mod 97 = 3
    assert_eq(gf_mul(50, 2), 3);      // 100 mod 97 = 3
    assert_eq(gf_mul(1, 42), 42);
    assert_eq(gf_mul(0, 42), 0);
}

fn test_gf_negation() {
    // a + (-a) = 0
    assert_eq(gf_add(42, gf_neg(42)), 0);
    assert_eq(gf_add(1, gf_neg(1)), 0);
    assert_eq(gf_add(96, gf_neg(96)), 0);
    assert_eq(gf_neg(0), 0);
}

fn test_gf_inverse() {
    // a * a^(-1) = 1
    assert_eq(gf_mul(2, gf_inv(2)), 1);
    assert_eq(gf_mul(3, gf_inv(3)), 1);
    assert_eq(gf_mul(50, gf_inv(50)), 1);
    assert_eq(gf_mul(96, gf_inv(96)), 1);  // 96 = -1 mod 97, inv = 96

    // inv(1) = 1
    assert_eq(gf_inv(1), 1);
}

fn test_gf_ext_gcd_inv() {
    // Extended GCD should give same results as Fermat
    assert_eq(ext_gcd_inv(2), gf_inv(2));
    assert_eq(ext_gcd_inv(3), gf_inv(3));
    assert_eq(ext_gcd_inv(50), gf_inv(50));
    assert_eq(ext_gcd_inv(1), 1);
}

fn test_gf_division() {
    // a / b * b = a
    let a = 42;
    let b = 13;
    assert_eq(gf_mul(gf_div(a, b), b), gf_norm(a));

    // 0 / anything = 0
    assert_eq(gf_div(0, 5), 0);
}

fn test_gf_exponentiation() {
    // Fermat's little theorem: a^(p-1) = 1 for a != 0
    let p = field_prime();
    assert_eq(gf_exp(2, p - 1), 1);
    assert_eq(gf_exp(50, p - 1), 1);
    assert_eq(gf_exp(96, p - 1), 1);

    // a^0 = 1
    assert_eq(gf_exp(42, 0), 1);

    // a^1 = a
    assert_eq(gf_exp(42, 1), 42);

    // 2^10 = 1024 mod 97 = 1024 - 10*97 = 1024 - 970 = 54
    assert_eq(gf_exp(2, 10), 54);
}

fn test_poly_eval() {
    // p(x) = 3x^2 + 2x + 1
    let mut p = poly_new();
    p = poly_set(p, 0, 1);   // constant
    p = poly_set(p, 1, 2);   // x
    p = poly_set(p, 2, 3);   // x^2
    p = poly_set_deg(p, 2);

    // p(0) = 1
    assert_eq(poly_eval(p, 0), 1);

    // p(1) = 3 + 2 + 1 = 6
    assert_eq(poly_eval(p, 1), 6);

    // p(2) = 3*4 + 2*2 + 1 = 17
    assert_eq(poly_eval(p, 2), 17);

    // p(10) = 3*100 + 2*10 + 1 = 321 mod 97 = 321 - 3*97 = 30
    assert_eq(poly_eval(p, 10), 30);
}

fn test_poly_add() {
    // p(x) = 2x + 1
    let mut p = poly_new();
    p = poly_set(p, 0, 1);
    p = poly_set(p, 1, 2);
    p = poly_set_deg(p, 1);

    // q(x) = 3x^2 + 5
    let mut q = poly_new();
    q = poly_set(q, 0, 5);
    q = poly_set(q, 2, 3);
    q = poly_set_deg(q, 2);

    // r(x) = p + q = 3x^2 + 2x + 6
    let r = poly_add(p, q);
    assert_eq(r.deg, 2);
    assert_eq(poly_get(r, 0), 6);
    assert_eq(poly_get(r, 1), 2);
    assert_eq(poly_get(r, 2), 3);

    // Verify: r(1) = 3 + 2 + 6 = 11
    assert_eq(poly_eval(r, 1), 11);
}

fn test_poly_scale() {
    // p(x) = x + 1
    let mut p = poly_new();
    p = poly_set(p, 0, 1);
    p = poly_set(p, 1, 1);
    p = poly_set_deg(p, 1);

    // 5 * p(x) = 5x + 5
    let sp = poly_scale(p, 5);
    assert_eq(poly_get(sp, 0), 5);
    assert_eq(poly_get(sp, 1), 5);
    assert_eq(poly_eval(sp, 2), 15);  // 5*2 + 5 = 15
}

fn test_lagrange_interpolation_check() {
    // Verify that p(x) = x^2 passes through (0,0), (1,1), (2,4)
    let mut p = poly_new();
    p = poly_set(p, 2, 1);
    p = poly_set_deg(p, 2);

    assert_eq(poly_eval(p, 0), 0);
    assert_eq(poly_eval(p, 1), 1);
    assert_eq(poly_eval(p, 2), 4);
    assert_eq(poly_eval(p, 5), 25);
    assert_eq(poly_eval(p, 10), 3);  // 100 mod 97 = 3
}

fn main() -> Int {
    test_gf_basics();
    test_gf_negation();
    test_gf_inverse();
    test_gf_ext_gcd_inv();
    test_gf_division();
    test_gf_exponentiation();
    test_poly_eval();
    test_poly_add();
    test_poly_scale();
    test_lagrange_interpolation_check();
    print("[OK] 287_finite_field_aot");
    0
}
