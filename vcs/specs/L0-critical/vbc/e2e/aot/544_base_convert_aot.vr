// @test: run
// @level: L0
// @tags: aot, e2e, base-conversion, radix, encoding
// @timeout: 30000

// Number base conversion algorithms

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Convert integer to digits in given base
// Returns (digits array in MSB-first order, count)
type Digits is { d: Arr8, count: Int };

fn to_base(n: Int, base: Int) -> Digits {
    if n == 0 {
        return Digits { d: set8(zeros(), 0, 0), count: 1 };
    }
    let mut result = zeros();
    let mut count = 0;
    let mut val = n;
    while val > 0 {
        result = set8(result, count, val % base);
        count = count + 1;
        val = val / base;
    }
    // Reverse to MSB-first
    let mut i = 0;
    let mut j = count - 1;
    while i < j {
        let tmp = get8(result, i);
        result = set8(result, i, get8(result, j));
        result = set8(result, j, tmp);
        i = i + 1;
        j = j - 1;
    }
    Digits { d: result, count: count }
}

// Convert digits in given base back to integer
fn from_base(digits: Arr8, count: Int, base: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < count {
        result = result * base + get8(digits, i);
        i = i + 1;
    }
    result
}

// Convert between two bases
fn convert_base(n: Int, from: Int, to: Int) -> Digits {
    // n is already a decimal integer representation of the source base
    // Actually, we take n as an integer and convert to target base
    to_base(n, to)
}

// Count digits in a given base
fn digit_count(n: Int, base: Int) -> Int {
    if n == 0 { return 1; }
    let mut count = 0;
    let mut val = n;
    while val > 0 {
        count = count + 1;
        val = val / base;
    }
    count
}

// Sum of digits in a given base
fn digit_sum(n: Int, base: Int) -> Int {
    if n == 0 { return 0; }
    let mut sum = 0;
    let mut val = n;
    while val > 0 {
        sum = sum + val % base;
        val = val / base;
    }
    sum
}

// Check if number is a palindrome in given base
fn is_palindrome_base(n: Int, base: Int) -> Int {
    let digits = to_base(n, base);
    let mut i = 0;
    let mut j = digits.count - 1;
    while i < j {
        if get8(digits.d, i) != get8(digits.d, j) { return 0; }
        i = i + 1;
        j = j - 1;
    }
    1
}

// Power function
fn pow_int(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < exp { result = result * base; i = i + 1; }
    result
}

fn test_to_binary() -> Int {
    // 13 in binary = 1101
    let d = to_base(13, 2);
    assert_eq(d.count, 4);
    assert_eq(get8(d.d, 0), 1);
    assert_eq(get8(d.d, 1), 1);
    assert_eq(get8(d.d, 2), 0);
    assert_eq(get8(d.d, 3), 1);
    1
}

fn test_to_octal() -> Int {
    // 255 in octal = 377
    let d = to_base(255, 8);
    assert_eq(d.count, 3);
    assert_eq(get8(d.d, 0), 3);
    assert_eq(get8(d.d, 1), 7);
    assert_eq(get8(d.d, 2), 7);
    1
}

fn test_to_hex() -> Int {
    // 255 in hex = FF = 15,15
    let d = to_base(255, 16);
    assert_eq(d.count, 2);
    assert_eq(get8(d.d, 0), 15);
    assert_eq(get8(d.d, 1), 15);
    1
}

fn test_roundtrip() -> Int {
    // Convert to base, then back
    let d = to_base(42, 3);
    let back = from_base(d.d, d.count, 3);
    assert_eq(back, 42);

    let d2 = to_base(1000, 7);
    let back2 = from_base(d2.d, d2.count, 7);
    assert_eq(back2, 1000);
    1
}

fn test_digit_count() -> Int {
    assert_eq(digit_count(0, 10), 1);
    assert_eq(digit_count(9, 10), 1);
    assert_eq(digit_count(10, 10), 2);
    assert_eq(digit_count(999, 10), 3);
    assert_eq(digit_count(255, 2), 8);
    assert_eq(digit_count(255, 16), 2);
    1
}

fn test_digit_sum() -> Int {
    // 123 in base 10: 1+2+3 = 6
    assert_eq(digit_sum(123, 10), 6);
    // 15 in binary (1111): 1+1+1+1 = 4
    assert_eq(digit_sum(15, 2), 4);
    // 0
    assert_eq(digit_sum(0, 10), 0);
    1
}

fn test_palindrome() -> Int {
    // 9 in binary = 1001 → palindrome
    assert_eq(is_palindrome_base(9, 2), 1);
    // 5 in binary = 101 → palindrome
    assert_eq(is_palindrome_base(5, 2), 1);
    // 6 in binary = 110 → NOT palindrome
    assert_eq(is_palindrome_base(6, 2), 0);
    // 121 in base 10 → palindrome
    assert_eq(is_palindrome_base(121, 10), 1);
    1
}

fn test_zero() -> Int {
    let d = to_base(0, 10);
    assert_eq(d.count, 1);
    assert_eq(get8(d.d, 0), 0);
    1
}

fn main() -> Int {
    test_to_binary();
    test_to_octal();
    test_to_hex();
    test_roundtrip();
    test_digit_count();
    test_digit_sum();
    test_palindrome();
    test_zero();
    print("[OK] 544_base_convert_aot");
    0
}
