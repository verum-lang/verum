// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, graph-coloring, scheduling, bitwise, combinatorics
// @timeout: 50000
// @expected-exit: 0
// @description: AOT graph coloring and chromatic analysis using adjacency bitmasks for 6-node graphs

// Graph with 6 nodes, each node's adjacency stored as a bitmask (bit i = adjacent to node i)
type Graph6 is { adj0: Int, adj1: Int, adj2: Int, adj3: Int, adj4: Int, adj5: Int };

// Coloring: color assignment for each of 6 nodes (0 = uncolored)
type Coloring6 is { c0: Int, c1: Int, c2: Int, c3: Int, c4: Int, c5: Int };

fn get_adj(g: Graph6, i: Int) -> Int {
    if i == 0 { g.adj0 }
    else if i == 1 { g.adj1 }
    else if i == 2 { g.adj2 }
    else if i == 3 { g.adj3 }
    else if i == 4 { g.adj4 }
    else { g.adj5 }
}

fn get_color(c: Coloring6, i: Int) -> Int {
    if i == 0 { c.c0 }
    else if i == 1 { c.c1 }
    else if i == 2 { c.c2 }
    else if i == 3 { c.c3 }
    else if i == 4 { c.c4 }
    else { c.c5 }
}

fn set_color(c: Coloring6, i: Int, color: Int) -> Coloring6 {
    Coloring6 {
        c0: if i == 0 { color } else { c.c0 },
        c1: if i == 1 { color } else { c.c1 },
        c2: if i == 2 { color } else { c.c2 },
        c3: if i == 3 { color } else { c.c3 },
        c4: if i == 4 { color } else { c.c4 },
        c5: if i == 5 { color } else { c.c5 },
    }
}

// Check if two nodes are adjacent
fn is_adjacent(g: Graph6, i: Int, j: Int) -> Bool {
    (get_adj(g, i) >> j) & 1 == 1
}

// Count total edges (undirected: each edge counted once)
fn count_edges(g: Graph6, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if is_adjacent(g, i, j) {
                count = count + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Degree of a node
fn node_degree(g: Graph6, node: Int, n: Int) -> Int {
    let mut deg = 0;
    let mut j = 0;
    while j < n {
        if is_adjacent(g, node, j) {
            deg = deg + 1;
        }
        j = j + 1;
    }
    deg
}

// Maximum degree in the graph
fn max_degree(g: Graph6, n: Int) -> Int {
    let mut md = 0;
    let mut i = 0;
    while i < n {
        let d = node_degree(g, i, n);
        if d > md { md = d; }
        i = i + 1;
    }
    md
}

// Greedy coloring: assign smallest available color to each node in order 0..n-1
// Returns a Coloring6 with colors starting from 1
fn greedy_color(g: Graph6, n: Int) -> Coloring6 {
    let mut c = Coloring6 { c0: 0, c1: 0, c2: 0, c3: 0, c4: 0, c5: 0 };
    let mut i = 0;
    while i < n {
        // Find used colors among neighbors
        let mut used = 0;  // bitmask of used colors
        let mut j = 0;
        while j < n {
            if is_adjacent(g, i, j) {
                let neighbor_color = get_color(c, j);
                if neighbor_color > 0 {
                    used = used | (1 << neighbor_color);
                }
            }
            j = j + 1;
        }
        // Find smallest unused color (starting from 1)
        let mut color = 1;
        while (used >> color) & 1 == 1 {
            color = color + 1;
        }
        c = set_color(c, i, color);
        i = i + 1;
    }
    c
}

// Verify coloring is valid: no two adjacent nodes share a color
fn verify_coloring(g: Graph6, c: Coloring6, n: Int) -> Bool {
    let mut valid = true;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if is_adjacent(g, i, j) {
                if get_color(c, i) == get_color(c, j) {
                    valid = false;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    valid
}

// Count distinct colors used in the coloring
fn count_colors(c: Coloring6, n: Int) -> Int {
    let mut color_set = 0;  // bitmask of seen colors
    let mut i = 0;
    while i < n {
        let col = get_color(c, i);
        if col > 0 {
            color_set = color_set | (1 << col);
        }
        i = i + 1;
    }
    // Count bits
    let mut count = 0;
    let mut bits = color_set;
    while bits != 0 {
        count = count + (bits & 1);
        bits = bits >> 1;
    }
    count
}

// Upper bound on chromatic number: max_degree + 1 (Brook's theorem bound)
fn chromatic_bound(g: Graph6, n: Int) -> Int {
    max_degree(g, n) + 1
}

// Build undirected edge: set bit in both directions
fn make_edge(g: Graph6, i: Int, j: Int) -> Graph6 {
    let ai = get_adj(g, i) | (1 << j);
    let aj = get_adj(g, j) | (1 << i);
    let mut result = g;
    // Set adj[i]
    result = Graph6 {
        adj0: if i == 0 { ai } else { result.adj0 },
        adj1: if i == 1 { ai } else { result.adj1 },
        adj2: if i == 2 { ai } else { result.adj2 },
        adj3: if i == 3 { ai } else { result.adj3 },
        adj4: if i == 4 { ai } else { result.adj4 },
        adj5: if i == 5 { ai } else { result.adj5 },
    };
    // Set adj[j]
    Graph6 {
        adj0: if j == 0 { aj } else { result.adj0 },
        adj1: if j == 1 { aj } else { result.adj1 },
        adj2: if j == 2 { aj } else { result.adj2 },
        adj3: if j == 3 { aj } else { result.adj3 },
        adj4: if j == 4 { aj } else { result.adj4 },
        adj5: if j == 5 { aj } else { result.adj5 },
    }
}

fn empty_graph() -> Graph6 {
    Graph6 { adj0: 0, adj1: 0, adj2: 0, adj3: 0, adj4: 0, adj5: 0 }
}

fn main() -> Int {
    // ========== Test 1: Cycle graph C6 ==========
    // 0-1-2-3-4-5-0
    let mut c6 = empty_graph();
    c6 = make_edge(c6, 0, 1);
    c6 = make_edge(c6, 1, 2);
    c6 = make_edge(c6, 2, 3);
    c6 = make_edge(c6, 3, 4);
    c6 = make_edge(c6, 4, 5);
    c6 = make_edge(c6, 5, 0);

    assert_eq(count_edges(c6, 6), 6);
    assert_eq(node_degree(c6, 0, 6), 2);
    assert_eq(node_degree(c6, 3, 6), 2);
    assert_eq(max_degree(c6, 6), 2);

    // Adjacency checks
    assert(is_adjacent(c6, 0, 1));
    assert(is_adjacent(c6, 5, 0));
    assert(!is_adjacent(c6, 0, 3));
    assert(!is_adjacent(c6, 1, 4));

    // Color the cycle
    let c6_coloring = greedy_color(c6, 6);
    assert(verify_coloring(c6, c6_coloring, 6));
    // C6 is bipartite (even cycle), chromatic number = 2
    // Greedy on ordered nodes gives 2 colors for even cycle
    let c6_colors = count_colors(c6_coloring, 6);
    assert_eq(c6_colors, 2);

    // Brook's bound: max_degree + 1 = 3
    assert_eq(chromatic_bound(c6, 6), 3);

    // ========== Test 2: Complete bipartite graph K_{3,3} ==========
    // Nodes {0,1,2} connected to all of {3,4,5}, no edges within groups
    let mut k33 = empty_graph();
    let mut i = 0;
    while i < 3 {
        let mut j = 3;
        while j < 6 {
            k33 = make_edge(k33, i, j);
            j = j + 1;
        }
        i = i + 1;
    }

    assert_eq(count_edges(k33, 6), 9);  // 3 * 3
    assert_eq(node_degree(k33, 0, 6), 3);
    assert_eq(node_degree(k33, 3, 6), 3);
    assert_eq(max_degree(k33, 6), 3);

    // Not adjacent within same partition
    assert(!is_adjacent(k33, 0, 1));
    assert(!is_adjacent(k33, 3, 4));
    // Adjacent across partitions
    assert(is_adjacent(k33, 0, 3));
    assert(is_adjacent(k33, 2, 5));

    // K_{3,3} is bipartite -> chromatic number = 2
    let k33_coloring = greedy_color(k33, 6);
    assert(verify_coloring(k33, k33_coloring, 6));
    let k33_colors = count_colors(k33_coloring, 6);
    assert_eq(k33_colors, 2);

    // ========== Test 3: Path graph P6 ==========
    // 0-1-2-3-4-5
    let mut p6 = empty_graph();
    p6 = make_edge(p6, 0, 1);
    p6 = make_edge(p6, 1, 2);
    p6 = make_edge(p6, 2, 3);
    p6 = make_edge(p6, 3, 4);
    p6 = make_edge(p6, 4, 5);

    assert_eq(count_edges(p6, 6), 5);
    assert_eq(node_degree(p6, 0, 6), 1);  // endpoint
    assert_eq(node_degree(p6, 2, 6), 2);  // interior
    assert_eq(node_degree(p6, 5, 6), 1);  // endpoint
    assert_eq(max_degree(p6, 6), 2);

    let p6_coloring = greedy_color(p6, 6);
    assert(verify_coloring(p6, p6_coloring, 6));
    // Path is bipartite -> 2-colorable
    assert_eq(count_colors(p6_coloring, 6), 2);

    // ========== Test 4: Star graph S5 (node 0 connected to all others) ==========
    let mut star = empty_graph();
    star = make_edge(star, 0, 1);
    star = make_edge(star, 0, 2);
    star = make_edge(star, 0, 3);
    star = make_edge(star, 0, 4);
    star = make_edge(star, 0, 5);

    assert_eq(count_edges(star, 6), 5);
    assert_eq(node_degree(star, 0, 6), 5);  // hub
    assert_eq(node_degree(star, 1, 6), 1);  // leaf
    assert_eq(max_degree(star, 6), 5);

    let star_coloring = greedy_color(star, 6);
    assert(verify_coloring(star, star_coloring, 6));
    // Star is bipartite -> 2-colorable (hub=1, leaves=2)
    assert_eq(count_colors(star_coloring, 6), 2);
    assert_eq(get_color(star_coloring, 0), 1);  // hub gets color 1

    // ========== Test 5: Triangle + triangle (two disjoint K3) ==========
    // K3 on {0,1,2} and K3 on {3,4,5}
    let mut two_k3 = empty_graph();
    two_k3 = make_edge(two_k3, 0, 1);
    two_k3 = make_edge(two_k3, 0, 2);
    two_k3 = make_edge(two_k3, 1, 2);
    two_k3 = make_edge(two_k3, 3, 4);
    two_k3 = make_edge(two_k3, 3, 5);
    two_k3 = make_edge(two_k3, 4, 5);

    assert_eq(count_edges(two_k3, 6), 6);
    assert_eq(node_degree(two_k3, 0, 6), 2);
    assert_eq(node_degree(two_k3, 3, 6), 2);

    // Not adjacent between components
    assert(!is_adjacent(two_k3, 0, 3));
    assert(!is_adjacent(two_k3, 2, 4));

    let two_k3_coloring = greedy_color(two_k3, 6);
    assert(verify_coloring(two_k3, two_k3_coloring, 6));
    // K3 needs 3 colors
    assert_eq(count_colors(two_k3_coloring, 6), 3);

    // ========== Test 6: Wheel graph W5 (hub + cycle of 5) ==========
    // Node 0 = hub, cycle 1-2-3-4-5-1
    let mut wheel = empty_graph();
    // Hub edges
    wheel = make_edge(wheel, 0, 1);
    wheel = make_edge(wheel, 0, 2);
    wheel = make_edge(wheel, 0, 3);
    wheel = make_edge(wheel, 0, 4);
    wheel = make_edge(wheel, 0, 5);
    // Cycle edges
    wheel = make_edge(wheel, 1, 2);
    wheel = make_edge(wheel, 2, 3);
    wheel = make_edge(wheel, 3, 4);
    wheel = make_edge(wheel, 4, 5);
    wheel = make_edge(wheel, 5, 1);

    assert_eq(count_edges(wheel, 6), 10);  // 5 hub + 5 cycle
    assert_eq(node_degree(wheel, 0, 6), 5);  // hub
    assert_eq(node_degree(wheel, 1, 6), 3);  // cycle node + hub

    let wheel_coloring = greedy_color(wheel, 6);
    assert(verify_coloring(wheel, wheel_coloring, 6));
    // W5 with odd cycle: chromatic number = 4
    // Greedy should use at most max_degree+1 = 6 colors, but typically fewer
    let wheel_colors = count_colors(wheel_coloring, 6);
    assert(wheel_colors >= 3);
    assert(wheel_colors <= chromatic_bound(wheel, 6));

    // ========== Test 7: Empty graph ==========
    let eg = empty_graph();
    assert_eq(count_edges(eg, 6), 0);
    assert_eq(max_degree(eg, 6), 0);

    let eg_coloring = greedy_color(eg, 6);
    assert(verify_coloring(eg, eg_coloring, 6));
    // All nodes independent -> 1 color
    assert_eq(count_colors(eg_coloring, 6), 1);

    // ========== Test 8: Petersen-like subgraph (5 nodes, dense) ==========
    // K5 minus one edge: complete on {0,1,2,3,4} minus edge 3-4
    let mut k5m = empty_graph();
    k5m = make_edge(k5m, 0, 1);
    k5m = make_edge(k5m, 0, 2);
    k5m = make_edge(k5m, 0, 3);
    k5m = make_edge(k5m, 0, 4);
    k5m = make_edge(k5m, 1, 2);
    k5m = make_edge(k5m, 1, 3);
    k5m = make_edge(k5m, 1, 4);
    k5m = make_edge(k5m, 2, 3);
    k5m = make_edge(k5m, 2, 4);
    // Missing: 3-4

    assert_eq(count_edges(k5m, 5), 9);  // C(5,2) - 1 = 9
    assert_eq(node_degree(k5m, 0, 5), 4);
    assert_eq(node_degree(k5m, 3, 5), 3);  // missing one edge
    assert_eq(node_degree(k5m, 4, 5), 3);

    let k5m_coloring = greedy_color(k5m, 5);
    assert(verify_coloring(k5m, k5m_coloring, 5));
    // K5 minus edge: chromatic number = 4 (nodes 3,4 can share a color)
    let k5m_colors = count_colors(k5m_coloring, 5);
    assert_eq(k5m_colors, 4);

    0
}
