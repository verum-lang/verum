// @test: run
// @level: L0
// @tags: aot, e2e, sparse, matrix, csr
// @timeout: 30000

// Sparse matrix in CSR-like format using parallel arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn new_arr8() -> Arr8 {
    Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
}

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// CSR: row_ptr, col_idx, values, nnz
type CSR is { row_ptr: Arr8, col: Arr8, val_arr: Arr8, nnz: Int, nrows: Int, ncols: Int };

// Get element (r, c) from CSR matrix
fn csr_get(m: CSR, r: Int, c: Int) -> Int {
    let start = get8(m.row_ptr, r);
    let end_val = get8(m.row_ptr, r + 1);
    let mut i = start;
    while i < end_val {
        if get8(m.col, i) == c {
            return get8(m.val_arr, i);
        }
        i = i + 1;
    }
    0 // default for sparse
}

// SpMV: sparse matrix-vector multiply y = A * x
fn spmv(m: CSR, x: Arr8) -> Arr8 {
    let mut y = new_arr8();
    let mut r = 0;
    while r < m.nrows {
        let mut sum_val = 0;
        let start = get8(m.row_ptr, r);
        let end_val = get8(m.row_ptr, r + 1);
        let mut i = start;
        while i < end_val {
            sum_val = sum_val + get8(m.val_arr, i) * get8(x, get8(m.col, i));
            i = i + 1;
        }
        y = set8(y, r, sum_val);
        r = r + 1;
    }
    y
}

// Count non-zeros per row
fn nnz_per_row(m: CSR, r: Int) -> Int {
    get8(m.row_ptr, r + 1) - get8(m.row_ptr, r)
}

// Trace (sum of diagonal)
fn csr_trace(m: CSR) -> Int {
    let mut tr = 0;
    let n = if m.nrows < m.ncols { m.nrows } else { m.ncols };
    let mut i = 0;
    while i < n {
        tr = tr + csr_get(m, i, i);
        i = i + 1;
    }
    tr
}

fn test_basic() -> Int {
    // 3x3 matrix:
    // [1  0  2]
    // [0  3  0]
    // [4  0  5]
    // CSR: row_ptr=[0,2,3,5], col=[0,2,1,0,2], val=[1,2,3,4,5]
    let m = CSR {
        row_ptr: Arr8 { v0: 0, v1: 2, v2: 3, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 },
        col: Arr8 { v0: 0, v1: 2, v2: 1, v3: 0, v4: 2, v5: 0, v6: 0, v7: 0 },
        val_arr: Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 },
        nnz: 5, nrows: 3, ncols: 3
    };

    assert_eq(csr_get(m, 0, 0), 1);
    assert_eq(csr_get(m, 0, 1), 0);
    assert_eq(csr_get(m, 0, 2), 2);
    assert_eq(csr_get(m, 1, 1), 3);
    assert_eq(csr_get(m, 2, 0), 4);
    assert_eq(csr_get(m, 2, 2), 5);
    1
}

fn test_spmv() -> Int {
    let m = CSR {
        row_ptr: Arr8 { v0: 0, v1: 2, v2: 3, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 },
        col: Arr8 { v0: 0, v1: 2, v2: 1, v3: 0, v4: 2, v5: 0, v6: 0, v7: 0 },
        val_arr: Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 },
        nnz: 5, nrows: 3, ncols: 3
    };
    let x = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // y[0] = 1*1 + 2*3 = 7
    // y[1] = 3*2 = 6
    // y[2] = 4*1 + 5*3 = 19
    let y = spmv(m, x);
    assert_eq(get8(y, 0), 7);
    assert_eq(get8(y, 1), 6);
    assert_eq(get8(y, 2), 19);
    1
}

fn test_trace_nnz() -> Int {
    let m = CSR {
        row_ptr: Arr8 { v0: 0, v1: 2, v2: 3, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 },
        col: Arr8 { v0: 0, v1: 2, v2: 1, v3: 0, v4: 2, v5: 0, v6: 0, v7: 0 },
        val_arr: Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 },
        nnz: 5, nrows: 3, ncols: 3
    };
    assert_eq(csr_trace(m), 9); // 1 + 3 + 5
    assert_eq(nnz_per_row(m, 0), 2);
    assert_eq(nnz_per_row(m, 1), 1);
    assert_eq(nnz_per_row(m, 2), 2);
    1
}

fn main() -> Int {
    test_basic();
    test_spmv();
    test_trace_nnz();
    print("[OK] 431_sparse_matrix_aot");
    0
}
