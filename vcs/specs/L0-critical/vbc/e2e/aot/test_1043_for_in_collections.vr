// @test: run
// @level: L0
// @tier: 1
// @tags: for-in, list, range, iteration, collection
// @description: For-in iteration over lists, ranges, and with index tracking

fn test_for_in_list() -> Int {
    let items = [10, 20, 30, 40, 50];
    let mut sum = 0;
    for item in items {
        sum = sum + item;
    }
    if sum != 150 {
        print(f"FAIL for_in_list: expected 150, got {sum}");
        return 1;
    }
    print("  for_in_list: OK");
    0
}

fn test_for_in_range() -> Int {
    let mut sum = 0;
    for i in 0..10 {
        sum = sum + i;
    }
    if sum != 45 {
        print(f"FAIL for_in_range: expected 45, got {sum}");
        return 1;
    }
    print("  for_in_range: OK");
    0
}

fn test_for_in_inclusive_range() -> Int {
    let mut sum = 0;
    for i in 1..=5 {
        sum = sum + i;
    }
    if sum != 15 {
        print(f"FAIL for_in_inclusive: expected 15, got {sum}");
        return 1;
    }
    print("  for_in_inclusive: OK");
    0
}

fn test_for_in_nested() -> Int {
    let mut total = 0;
    for i in 0..3 {
        for j in 0..3 {
            total = total + i * 3 + j;
        }
    }
    // 0,1,2,3,4,5,6,7,8 = 36
    if total != 36 {
        print(f"FAIL for_in_nested: expected 36, got {total}");
        return 1;
    }
    print("  for_in_nested: OK");
    0
}

fn test_for_in_with_break() -> Int {
    let mut sum = 0;
    for i in 0..100 {
        if i >= 5 {
            break;
        }
        sum = sum + i;
    }
    if sum != 10 {
        print(f"FAIL for_in_break: expected 10, got {sum}");
        return 1;
    }
    print("  for_in_break: OK");
    0
}

fn test_for_in_with_continue() -> Int {
    let mut sum = 0;
    for i in 0..10 {
        if i % 2 != 0 {
            continue;
        }
        sum = sum + i;
    }
    // 0+2+4+6+8 = 20
    if sum != 20 {
        print(f"FAIL for_in_continue: expected 20, got {sum}");
        return 1;
    }
    print("  for_in_continue: OK");
    0
}

fn test_for_in_dynamic_list() -> Int {
    let mut data = List.new();
    data.push(5);
    data.push(15);
    data.push(25);
    let mut sum = 0;
    for val in data {
        sum = sum + val;
    }
    if sum != 45 {
        print(f"FAIL for_in_dynamic: expected 45, got {sum}");
        return 1;
    }
    print("  for_in_dynamic: OK");
    0
}

fn main() -> Int {
    print("For-In Collection Tests:");
    let mut failures = 0;
    failures = failures + test_for_in_list();
    failures = failures + test_for_in_range();
    failures = failures + test_for_in_inclusive_range();
    failures = failures + test_for_in_nested();
    failures = failures + test_for_in_with_break();
    failures = failures + test_for_in_with_continue();
    failures = failures + test_for_in_dynamic_list();

    if failures == 0 {
        print("All for-in collection tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
