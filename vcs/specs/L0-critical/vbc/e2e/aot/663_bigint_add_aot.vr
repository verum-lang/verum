// @test: run
// @level: L0
// @tags: aot, e2e, bigint, addition, multi-precision
// @timeout: 30000

// Big integer addition using digit arrays (base 100)
// Each Arr8 element holds a "digit" 0-99

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Base for multi-precision arithmetic
fn base() -> Int { 100 }

// Number of significant digits
fn bigint_len(a: Arr8) -> Int {
    let mut len = 0;
    let mut i = 7;
    while i >= 0 {
        if get8(a, i) != 0 {
            if len == 0 { len = i + 1; }
        }
        i = i - 1;
    }
    if len == 0 { 1 } else { len } // at least 1 digit (the zero)
}

// Add two big integers
fn bigint_add(a: Arr8, b: Arr8) -> Arr8 {
    let mut result = zeros();
    let mut carry = 0;
    let mut i = 0;
    while i < 8 {
        let sum = get8(a, i) + get8(b, i) + carry;
        result = set8(result, i, sum % base());
        carry = sum / base();
        i = i + 1;
    }
    result
}

// Subtract b from a (assumes a >= b)
fn bigint_sub(a: Arr8, b: Arr8) -> Arr8 {
    let mut result = zeros();
    let mut borrow = 0;
    let mut i = 0;
    while i < 8 {
        let diff = get8(a, i) - get8(b, i) - borrow;
        if diff < 0 {
            result = set8(result, i, diff + base());
            borrow = 1;
        } else {
            result = set8(result, i, diff);
            borrow = 0;
        }
        i = i + 1;
    }
    result
}

// Multiply big integer by small integer (single digit)
fn bigint_mul_small(a: Arr8, k: Int) -> Arr8 {
    let mut result = zeros();
    let mut carry = 0;
    let mut i = 0;
    while i < 8 {
        let prod = get8(a, i) * k + carry;
        result = set8(result, i, prod % base());
        carry = prod / base();
        i = i + 1;
    }
    result
}

// Compare: -1 if a<b, 0 if a==b, 1 if a>b
fn bigint_cmp(a: Arr8, b: Arr8) -> Int {
    let mut i = 7;
    let mut result = 0;
    let mut done = 0;
    while i >= 0 {
        if done == 0 {
            if get8(a, i) > get8(b, i) { result = 1; done = 1; }
            else if get8(a, i) < get8(b, i) { result = 0 - 1; done = 1; }
        }
        i = i - 1;
    }
    result
}

// Is zero
fn bigint_is_zero(a: Arr8) -> Int {
    let mut i = 0;
    let mut all_zero = 1;
    while i < 8 {
        if get8(a, i) != 0 { all_zero = 0; }
        i = i + 1;
    }
    all_zero
}

// Convert small Int to bigint
fn from_int(n: Int) -> Arr8 {
    let mut r = zeros();
    let mut v = n;
    let mut i = 0;
    while v > 0 {
        if i < 8 {
            r = set8(r, i, v % base());
            v = v / base();
            i = i + 1;
        } else { v = 0; }
    }
    r
}

// Convert bigint back to Int (may overflow for large values)
fn to_int(a: Arr8) -> Int {
    let mut result = 0;
    let mut mul = 1;
    let mut i = 0;
    while i < 8 {
        result = result + get8(a, i) * mul;
        mul = mul * base();
        i = i + 1;
    }
    result
}

fn test_basic_add() -> Int {
    let a = from_int(123);  // [23, 1, 0, ...]
    let b = from_int(456);  // [56, 4, 0, ...]
    let sum = bigint_add(a, b);
    assert_eq(to_int(sum), 579);
    1
}

fn test_add_carry() -> Int {
    let a = from_int(99);   // [99, 0, ...]
    let b = from_int(1);    // [1, 0, ...]
    let sum = bigint_add(a, b);
    assert_eq(to_int(sum), 100); // carry propagation
    let c = from_int(9999);
    let d = from_int(1);
    let sum2 = bigint_add(c, d);
    assert_eq(to_int(sum2), 10000);
    1
}

fn test_sub() -> Int {
    let a = from_int(1000);
    let b = from_int(1);
    let diff = bigint_sub(a, b);
    assert_eq(to_int(diff), 999);
    let c = from_int(500);
    let d = from_int(123);
    assert_eq(to_int(bigint_sub(c, d)), 377);
    1
}

fn test_mul_small() -> Int {
    let a = from_int(123);
    let p = bigint_mul_small(a, 3);
    assert_eq(to_int(p), 369);
    let b = from_int(9999);
    let p2 = bigint_mul_small(b, 2);
    assert_eq(to_int(p2), 19998);
    1
}

fn test_compare() -> Int {
    let a = from_int(100);
    let b = from_int(200);
    assert_eq(bigint_cmp(a, b), 0 - 1);
    assert_eq(bigint_cmp(b, a), 1);
    assert_eq(bigint_cmp(a, a), 0);
    1
}

fn test_identity() -> Int {
    // a + 0 = a
    let a = from_int(12345);
    let z = zeros();
    assert_eq(to_int(bigint_add(a, z)), 12345);
    // a - a = 0
    assert_eq(bigint_is_zero(bigint_sub(a, a)), 1);
    // a * 1 = a
    assert_eq(to_int(bigint_mul_small(a, 1)), 12345);
    // a * 0 = 0
    assert_eq(bigint_is_zero(bigint_mul_small(a, 0)), 1);
    1
}

fn test_commutativity() -> Int {
    let a = from_int(777);
    let b = from_int(888);
    assert_eq(to_int(bigint_add(a, b)), to_int(bigint_add(b, a)));
    1
}

fn main() -> Int {
    test_basic_add();
    test_add_carry();
    test_sub();
    test_mul_small();
    test_compare();
    test_identity();
    test_commutativity();
    print("[OK] 663_bigint_add_aot");
    0
}
