// @test: run
// @level: L0
// @tags: aot, e2e, permutation, cycle, combinatorics
// @timeout: 30000

// Permutation operations: composition, inverse, cycles, fixed points

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Identity permutation of size n
fn identity(n: Int) -> Arr8 {
    let mut p = zeros();
    let mut i = 0;
    while i < n { p = set8(p, i, i); i = i + 1; }
    p
}

// Compose permutations: (p1 ∘ p2)(i) = p1(p2(i))
fn compose(p1: Arr8, p2: Arr8, n: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i < n {
        result = set8(result, i, get8(p1, get8(p2, i)));
        i = i + 1;
    }
    result
}

// Inverse permutation
fn inverse(p: Arr8, n: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i < n {
        result = set8(result, get8(p, i), i);
        i = i + 1;
    }
    result
}

// Count fixed points (p(i) == i)
fn fixed_points(p: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(p, i) == i { count = count + 1; }
        i = i + 1;
    }
    count
}

// Is identity?
fn is_identity(p: Arr8, n: Int) -> Int {
    if fixed_points(p, n) == n { 1 } else { 0 }
}

// Count inversions (i < j but p(i) > p(j))
fn inversions(p: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if get8(p, i) > get8(p, j) { count = count + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Sign of permutation: 1 if even, -1 if odd (based on inversions)
fn perm_sign(p: Arr8, n: Int) -> Int {
    if inversions(p, n) % 2 == 0 { 1 } else { 0 - 1 }
}

// Apply permutation k times
fn power(p: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = identity(n);
    let mut i = 0;
    while i < k {
        result = compose(p, result, n);
        i = i + 1;
    }
    result
}

// Order of permutation (smallest k > 0 such that p^k = identity)
fn order(p: Arr8, n: Int) -> Int {
    let mut cur = p;
    let mut k = 1;
    while is_identity(cur, n) == 0 {
        cur = compose(p, cur, n);
        k = k + 1;
        if k > 20 { k = 0 - 1; cur = identity(n); } // safety break
    }
    k
}

fn test_identity() -> Int {
    let id = identity(5);
    assert_eq(get8(id, 0), 0);
    assert_eq(get8(id, 4), 4);
    assert_eq(is_identity(id, 5), 1);
    assert_eq(fixed_points(id, 5), 5);
    assert_eq(inversions(id, 5), 0);
    assert_eq(perm_sign(id, 5), 1);
    1
}

fn test_compose() -> Int {
    // p1 = (1 0 2 3) — swap 0 and 1
    let p1 = Arr8 { v0: 1, v1: 0, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    // p2 = (0 1 3 2) — swap 2 and 3
    let p2 = Arr8 { v0: 0, v1: 1, v2: 3, v3: 2, v4: 0, v5: 0, v6: 0, v7: 0 };
    // p1 ∘ p2: (p1(p2(0))=p1(0)=1, p1(p2(1))=p1(1)=0, p1(p2(2))=p1(3)=3, p1(p2(3))=p1(2)=2)
    let comp = compose(p1, p2, 4);
    assert_eq(get8(comp, 0), 1);
    assert_eq(get8(comp, 1), 0);
    assert_eq(get8(comp, 2), 3);
    assert_eq(get8(comp, 3), 2);
    1
}

fn test_inverse() -> Int {
    // p = (1 2 0 3) — cycle (0 1 2)
    let p = Arr8 { v0: 1, v1: 2, v2: 0, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    let inv = inverse(p, 4);
    // p * inv should be identity
    let prod = compose(p, inv, 4);
    assert_eq(is_identity(prod, 4), 1);
    // inv * p should also be identity
    let prod2 = compose(inv, p, 4);
    assert_eq(is_identity(prod2, 4), 1);
    1
}

fn test_inversions() -> Int {
    // (1 0 2 3) — one inversion: (0,1) since p(0)=1 > p(1)=0
    let p = Arr8 { v0: 1, v1: 0, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(inversions(p, 4), 1);
    assert_eq(perm_sign(p, 4), 0 - 1); // odd

    // (3 2 1 0) — reverse: 6 inversions
    let rev = Arr8 { v0: 3, v1: 2, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(inversions(rev, 4), 6);
    assert_eq(perm_sign(rev, 4), 1); // even
    1
}

fn test_order() -> Int {
    // Identity has order 1
    assert_eq(order(identity(4), 4), 1);
    // Transposition (1 0 2 3) has order 2
    let swap = Arr8 { v0: 1, v1: 0, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(order(swap, 4), 2);
    // 3-cycle (1 2 0 3) has order 3
    let cyc3 = Arr8 { v0: 1, v1: 2, v2: 0, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(order(cyc3, 4), 3);
    // 4-cycle (1 2 3 0) has order 4
    let cyc4 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(order(cyc4, 4), 4);
    1
}

fn test_power() -> Int {
    // 3-cycle applied 3 times should give identity
    let cyc3 = Arr8 { v0: 1, v1: 2, v2: 0, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    let p3 = power(cyc3, 4, 3);
    assert_eq(is_identity(p3, 4), 1);
    // Applied 1 time should give original
    let p1 = power(cyc3, 4, 1);
    assert_eq(get8(p1, 0), 1);
    assert_eq(get8(p1, 1), 2);
    assert_eq(get8(p1, 2), 0);
    1
}

fn test_fixed_points() -> Int {
    let id = identity(4);
    assert_eq(fixed_points(id, 4), 4);
    // (1 0 2 3) — 2 and 3 are fixed
    let p = Arr8 { v0: 1, v1: 0, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(fixed_points(p, 4), 2);
    // (1 2 3 0) — no fixed points (derangement)
    let d = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(fixed_points(d, 4), 0);
    1
}

fn main() -> Int {
    test_identity();
    test_compose();
    test_inverse();
    test_inversions();
    test_order();
    test_power();
    test_fixed_points();
    print("[OK] 633_permutation_aot");
    0
}
