// @test: run
// @level: L0
// @tags: aot, e2e, union-find, disjoint-set, data-structure
// @timeout: 30000

// Union-Find (Disjoint Set Union) with path compression and union by rank

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Initialize: parent[i] = i, rank[i] = 0
fn uf_init(n: Int) -> Arr8 {
    Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 4, v5: 5, v6: 6, v7: 7 }
}

// Find with path compression (iterative)
// Returns (root, updated parent array) packed: root in return, parent via side effect
// Since we can't return two values easily, we'll use a find without compression
// and a separate compress step
fn uf_find(parent: Arr8, x: Int) -> Int {
    let mut p = x;
    while get8(parent, p) != p {
        p = get8(parent, p);
    }
    p
}

// Find and compress: returns new parent array with path compressed
fn uf_compress(parent: Arr8, x: Int) -> Arr8 {
    let root = uf_find(parent, x);
    let mut par = parent;
    let mut p = x;
    while p != root {
        let next = get8(par, p);
        par = set8(par, p, root);
        p = next;
    }
    par
}

// Union by rank: merge sets containing x and y
// Returns (new_parent, new_rank) - we'll return parent and manage rank separately
fn uf_union_parent(parent: Arr8, rank: Arr8, x: Int, y: Int) -> Arr8 {
    let rx = uf_find(parent, x);
    let ry = uf_find(parent, y);
    if rx == ry { return parent; }
    let rank_rx = get8(rank, rx);
    let rank_ry = get8(rank, ry);
    if rank_rx < rank_ry {
        set8(parent, rx, ry)
    } else {
        set8(parent, ry, rx)
    }
}

fn uf_union_rank(parent: Arr8, rank: Arr8, x: Int, y: Int) -> Arr8 {
    let rx = uf_find(parent, x);
    let ry = uf_find(parent, y);
    if rx == ry { return rank; }
    let rank_rx = get8(rank, rx);
    let rank_ry = get8(rank, ry);
    if rank_rx < rank_ry { rank }
    else if rank_rx > rank_ry { rank }
    else { set8(rank, rx, rank_rx + 1) }
}

// Check if x and y are in the same set
fn uf_connected(parent: Arr8, x: Int, y: Int) -> Int {
    if uf_find(parent, x) == uf_find(parent, y) { 1 } else { 0 }
}

// Count number of distinct sets
fn uf_count_sets(parent: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if uf_find(parent, i) == i { count = count + 1; }
        i = i + 1;
    }
    count
}

// Size of set containing x
fn uf_set_size(parent: Arr8, x: Int, n: Int) -> Int {
    let root = uf_find(parent, x);
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if uf_find(parent, i) == root { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_basic_union_find() -> Int {
    let n = 6;
    let mut par = uf_init(n);
    let mut rnk = zeros();

    // Initially all separate
    assert_eq(uf_count_sets(par, n), 6);
    assert_eq(uf_connected(par, 0, 1), 0);

    // Union 0 and 1
    rnk = uf_union_rank(par, rnk, 0, 1);
    par = uf_union_parent(par, rnk, 0, 1);
    assert_eq(uf_connected(par, 0, 1), 1);
    assert_eq(uf_count_sets(par, n), 5);

    // Union 2 and 3
    rnk = uf_union_rank(par, rnk, 2, 3);
    par = uf_union_parent(par, rnk, 2, 3);
    assert_eq(uf_connected(par, 2, 3), 1);
    assert_eq(uf_connected(par, 0, 2), 0);
    assert_eq(uf_count_sets(par, n), 4);

    // Union 0 and 2 (merges {0,1} and {2,3})
    rnk = uf_union_rank(par, rnk, 0, 2);
    par = uf_union_parent(par, rnk, 0, 2);
    assert_eq(uf_connected(par, 0, 3), 1);
    assert_eq(uf_connected(par, 1, 2), 1);
    assert_eq(uf_count_sets(par, n), 3);
    1
}

fn test_set_size() -> Int {
    let n = 8;
    let mut par = uf_init(n);
    let mut rnk = zeros();

    // All singletons
    assert_eq(uf_set_size(par, 0, n), 1);

    // Union 0,1,2
    rnk = uf_union_rank(par, rnk, 0, 1);
    par = uf_union_parent(par, rnk, 0, 1);
    rnk = uf_union_rank(par, rnk, 1, 2);
    par = uf_union_parent(par, rnk, 1, 2);
    assert_eq(uf_set_size(par, 0, n), 3);
    assert_eq(uf_set_size(par, 1, n), 3);
    assert_eq(uf_set_size(par, 2, n), 3);
    1
}

fn test_path_compression() -> Int {
    let n = 5;
    // Create chain: 0->1->2->3->4
    let par = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 4, v5: 5, v6: 6, v7: 7 };

    // Find root of 0 should be 4
    assert_eq(uf_find(par, 0), 4);

    // After compression, all should point directly to root
    let compressed = uf_compress(par, 0);
    assert_eq(get8(compressed, 0), 4);
    assert_eq(get8(compressed, 1), 4);
    assert_eq(get8(compressed, 2), 4);
    assert_eq(get8(compressed, 3), 4);
    1
}

fn test_all_connected() -> Int {
    let n = 6;
    let mut par = uf_init(n);
    let mut rnk = zeros();

    // Connect all
    let mut i = 0;
    while i < n - 1 {
        rnk = uf_union_rank(par, rnk, i, i + 1);
        par = uf_union_parent(par, rnk, i, i + 1);
        i = i + 1;
    }

    assert_eq(uf_count_sets(par, n), 1);
    assert_eq(uf_set_size(par, 0, n), 6);

    // All pairs connected
    assert_eq(uf_connected(par, 0, 5), 1);
    assert_eq(uf_connected(par, 1, 4), 1);
    1
}

fn test_idempotent_union() -> Int {
    let n = 4;
    let mut par = uf_init(n);
    let mut rnk = zeros();

    rnk = uf_union_rank(par, rnk, 0, 1);
    par = uf_union_parent(par, rnk, 0, 1);

    // Union same pair again should be no-op
    let rnk2 = uf_union_rank(par, rnk, 0, 1);
    let par2 = uf_union_parent(par, rnk, 0, 1);
    assert_eq(uf_count_sets(par2, n), 3);
    1
}

fn main() -> Int {
    test_basic_union_find();
    test_set_size();
    test_path_compression();
    test_all_connected();
    test_idempotent_union();
    print("[OK] 481_union_find_aot");
    0
}
