// @test: run
// @tier: 2
// @level: L0
// @tags: e2e, aot, bigint, addition, comparison, digit-array
// @timeout: 30000
// @expected-exit: 0
//
// Big integer arithmetic using digit arrays. Digits stored in Arr8,
// least significant digit first (little-endian base 10).
// Implements: add, subtract, compare, is_zero, multiply_by_small,
// and left shift (multiply by power of 10).

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// BigInt: digits array + length (number of significant digits)
// sign: 0 = non-negative, 1 = negative
type BigInt is { digits: Arr8, len: Int, sign: Int };

fn bi_zero() -> BigInt {
    BigInt { digits: a8_zero(), len: 1, sign: 0 }
}

// Create BigInt from non-negative integer
fn bi_from(val: Int) -> BigInt {
    if val == 0 { return bi_zero(); }
    let mut d = a8_zero();
    let mut v = val;
    let mut i = 0;
    while v > 0 {
        d = a8_set(d, i, v % 10);
        v = v / 10;
        i = i + 1;
    }
    BigInt { digits: d, len: i, sign: 0 }
}

// Convert BigInt back to integer (ignoring sign for simplicity)
fn bi_to_int(b: BigInt) -> Int {
    let mut result = 0;
    let mut place = 1;
    let mut i = 0;
    while i < b.len {
        result = result + a8_get(b.digits, i) * place;
        place = place * 10;
        i = i + 1;
    }
    if b.sign == 1 { 0 - result } else { result }
}

// Normalize: remove leading zeros
fn bi_norm(b: BigInt) -> BigInt {
    let mut l = b.len;
    while l > 1 {
        if a8_get(b.digits, l - 1) == 0 {
            l = l - 1;
        } else {
            return BigInt { digits: b.digits, len: l, sign: b.sign };
        }
    }
    // If length 1 and digit is 0, sign should be 0
    let s = if a8_get(b.digits, 0) == 0 { 0 } else { b.sign };
    BigInt { digits: b.digits, len: l, sign: s }
}

// Is zero
fn bi_is_zero(b: BigInt) -> Int {
    let bn = bi_norm(b);
    if bn.len == 1 {
        if a8_get(bn.digits, 0) == 0 { 1 } else { 0 }
    } else {
        0
    }
}

// Compare magnitudes (ignoring sign): returns 1 if |a|>|b|, -1 if |a|<|b|, 0 if equal
fn bi_cmp_mag(a: BigInt, b: BigInt) -> Int {
    let an = bi_norm(a);
    let bn = bi_norm(b);
    if an.len > bn.len { return 1; }
    if an.len < bn.len { return 0 - 1; }
    let mut i = an.len - 1;
    let mut done = 0;
    let mut res = 0;
    while done == 0 {
        let da = a8_get(an.digits, i);
        let db = a8_get(bn.digits, i);
        if da > db { res = 1; done = 1; }
        else if da < db { res = 0 - 1; done = 1; }
        else if i == 0 { done = 1; }
        else { i = i - 1; }
    }
    res
}

// Add magnitudes (both assumed non-negative, result non-negative)
fn bi_add_mag(a: BigInt, b: BigInt) -> BigInt {
    let mx = if a.len > b.len { a.len } else { b.len };
    let mut d = a8_zero();
    let mut carry = 0;
    let mut i = 0;
    while i < mx {
        let da = if i < a.len { a8_get(a.digits, i) } else { 0 };
        let db = if i < b.len { a8_get(b.digits, i) } else { 0 };
        let s = da + db + carry;
        d = a8_set(d, i, s % 10);
        carry = s / 10;
        i = i + 1;
    }
    let fl = if carry > 0 {
        d = a8_set(d, mx, carry);
        mx + 1
    } else {
        mx
    };
    bi_norm(BigInt { digits: d, len: fl, sign: 0 })
}

// Subtract magnitudes: |a| - |b|, assumes |a| >= |b|
fn bi_sub_mag(a: BigInt, b: BigInt) -> BigInt {
    let mut d = a8_zero();
    let mut borrow = 0;
    let mut i = 0;
    while i < a.len {
        let da = a8_get(a.digits, i);
        let db = if i < b.len { a8_get(b.digits, i) } else { 0 };
        let diff = da - db - borrow;
        if diff < 0 {
            d = a8_set(d, i, diff + 10);
            borrow = 1;
        } else {
            d = a8_set(d, i, diff);
            borrow = 0;
        }
        i = i + 1;
    }
    bi_norm(BigInt { digits: d, len: a.len, sign: 0 })
}

// Full addition with sign handling
fn bi_add(a: BigInt, b: BigInt) -> BigInt {
    if a.sign == b.sign {
        // Same sign: add magnitudes, keep sign
        let r = bi_add_mag(a, b);
        BigInt { digits: r.digits, len: r.len, sign: a.sign }
    } else {
        // Different signs: subtract smaller from larger
        let cmp = bi_cmp_mag(a, b);
        if cmp == 0 { return bi_zero(); }
        if cmp > 0 {
            let r = bi_sub_mag(a, b);
            BigInt { digits: r.digits, len: r.len, sign: a.sign }
        } else {
            let r = bi_sub_mag(b, a);
            BigInt { digits: r.digits, len: r.len, sign: b.sign }
        }
    }
}

// Multiply by single digit (0-9)
fn bi_mul_small(a: BigInt, d: Int) -> BigInt {
    if d == 0 { return bi_zero(); }
    let mut r = a8_zero();
    let mut carry = 0;
    let mut i = 0;
    while i < a.len {
        let prod = a8_get(a.digits, i) * d + carry;
        r = a8_set(r, i, prod % 10);
        carry = prod / 10;
        i = i + 1;
    }
    let fl = if carry > 0 {
        r = a8_set(r, a.len, carry);
        a.len + 1
    } else {
        a.len
    };
    bi_norm(BigInt { digits: r, len: fl, sign: a.sign })
}

// ========== Tests ==========

fn test_from_and_back() -> Int {
    assert_eq(bi_to_int(bi_from(0)), 0);
    assert_eq(bi_to_int(bi_from(1)), 1);
    assert_eq(bi_to_int(bi_from(12345)), 12345);
    assert_eq(bi_to_int(bi_from(99999999)), 99999999);
    0
}

fn test_is_zero() -> Int {
    assert_eq(bi_is_zero(bi_zero()), 1);
    assert_eq(bi_is_zero(bi_from(0)), 1);
    assert_eq(bi_is_zero(bi_from(1)), 0);
    assert_eq(bi_is_zero(bi_from(100)), 0);
    0
}

fn test_compare() -> Int {
    assert_eq(bi_cmp_mag(bi_from(100), bi_from(99)), 1);
    assert_eq(bi_cmp_mag(bi_from(99), bi_from(100)), 0 - 1);
    assert_eq(bi_cmp_mag(bi_from(100), bi_from(100)), 0);
    assert_eq(bi_cmp_mag(bi_from(0), bi_from(0)), 0);
    0
}

fn test_add_basic() -> Int {
    let a = bi_from(123);
    let b = bi_from(456);
    assert_eq(bi_to_int(bi_add(a, b)), 579);
    // Adding zero
    assert_eq(bi_to_int(bi_add(bi_from(42), bi_zero())), 42);
    assert_eq(bi_to_int(bi_add(bi_zero(), bi_from(42))), 42);
    0
}

fn test_add_carry() -> Int {
    // 999 + 1 = 1000
    assert_eq(bi_to_int(bi_add(bi_from(999), bi_from(1))), 1000);
    // 9999 + 9999 = 19998
    assert_eq(bi_to_int(bi_add(bi_from(9999), bi_from(9999))), 19998);
    // 99999 + 1 = 100000
    assert_eq(bi_to_int(bi_add(bi_from(99999), bi_from(1))), 100000);
    0
}

fn test_add_large() -> Int {
    // Numbers that overflow 32-bit but fit in 64-bit Int
    // 9999999 + 1 = 10000000 (8 digits, max for Arr8)
    let a = bi_from(9999999);
    let b = bi_from(1);
    let sum = bi_add(a, b);
    assert_eq(bi_to_int(sum), 10000000);
    assert_eq(sum.len, 8);
    0
}

fn test_subtract() -> Int {
    // 1000 - 1 = 999
    let a = bi_from(1000);
    let b = BigInt { digits: bi_from(1).digits, len: 1, sign: 1 };
    let r = bi_add(a, b);
    assert_eq(bi_to_int(r), 999);
    0
}

fn test_mul_small() -> Int {
    assert_eq(bi_to_int(bi_mul_small(bi_from(123), 4)), 492);
    assert_eq(bi_to_int(bi_mul_small(bi_from(999), 9)), 8991);
    assert_eq(bi_to_int(bi_mul_small(bi_from(100), 0)), 0);
    assert_eq(bi_to_int(bi_mul_small(bi_from(100), 1)), 100);
    0
}

fn test_associativity() -> Int {
    // (a + b) + c == a + (b + c)
    let a = bi_from(12345);
    let b = bi_from(67890);
    let c = bi_from(11111);
    let ab_c = bi_add(bi_add(a, b), c);
    let a_bc = bi_add(a, bi_add(b, c));
    assert_eq(bi_to_int(ab_c), bi_to_int(a_bc));
    assert_eq(bi_to_int(ab_c), 91346);
    0
}

fn test_commutativity() -> Int {
    let a = bi_from(54321);
    let b = bi_from(98765);
    assert_eq(bi_to_int(bi_add(a, b)), bi_to_int(bi_add(b, a)));
    assert_eq(bi_to_int(bi_add(a, b)), 153086);
    0
}

fn main() -> Int {
    test_from_and_back();
    test_is_zero();
    test_compare();
    test_add_basic();
    test_add_carry();
    test_add_large();
    test_subtract();
    test_mul_small();
    test_associativity();
    test_commutativity();
    print("[OK] 409_bigint_add_aot");
    0
}
