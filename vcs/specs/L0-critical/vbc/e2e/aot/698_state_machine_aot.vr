// @test: run
// @level: L0
// @tags: aot, e2e, state-machine, fsm, automaton
// @timeout: 30000

// Finite State Machine (FSM) simulation
// States encoded as integers, transitions as lookup functions

// FSM 1: Simple vending machine
// States: 0=idle, 1=has_quarter, 2=has_50cents, 3=dispensing
// Inputs: 1=quarter, 2=dollar, 3=select, 4=reset
fn vending_transition(state: Int, input: Int) -> Int {
    if state == 0 {
        if input == 1 { 1 }        // quarter → has_quarter
        else if input == 2 { 3 }   // dollar → dispensing
        else { 0 }                 // stay idle
    } else if state == 1 {
        if input == 1 { 2 }        // another quarter → has_50cents
        else if input == 4 { 0 }   // reset
        else { 1 }
    } else if state == 2 {
        if input == 1 { 3 }        // quarter → enough, dispensing
        else if input == 4 { 0 }
        else { 2 }
    } else { // dispensing
        0 // auto-return to idle
    }
}

fn vending_is_accept(state: Int) -> Int {
    if state == 3 { 1 } else { 0 }
}

// FSM 2: Binary divisibility by 3
// States: 0=remainder 0, 1=remainder 1, 2=remainder 2
// Input: 0 or 1 (reading binary MSB first)
fn div3_transition(state: Int, bit: Int) -> Int {
    let new_val = state * 2 + bit;
    new_val % 3
}

// Run FSM on a sequence of inputs stored as packed digits
// Packed: input = d7*10^7 + d6*10^6 + ... + d0, read left to right
fn run_fsm_packed(init_state: Int, inputs: Int, num_inputs: Int, trans_id: Int) -> Int {
    let mut state = init_state;
    let mut i = num_inputs - 1;
    while i >= 0 {
        // Extract digit at position i
        let mut divisor = 1;
        let mut j = 0;
        while j < i { divisor = divisor * 10; j = j + 1; }
        let digit = (inputs / divisor) % 10;
        if trans_id == 1 {
            state = vending_transition(state, digit);
        } else {
            state = div3_transition(state, digit);
        }
        i = i - 1;
    }
    state
}

// FSM 3: Simple regex-like matcher for pattern "ab*c"
// Matches strings like: ac, abc, abbc, abbbc, ...
// States: 0=start, 1=saw_a, 2=saw_b(s), 3=accept, 4=reject
// Chars: 1=a, 2=b, 3=c
fn regex_transition(state: Int, ch: Int) -> Int {
    if state == 0 {
        if ch == 1 { 1 }      // 'a' → saw_a
        else { 4 }            // reject
    } else if state == 1 {
        if ch == 2 { 2 }      // 'b' → saw_b
        else if ch == 3 { 3 } // 'c' → accept
        else { 4 }
    } else if state == 2 {
        if ch == 2 { 2 }      // more 'b' → stay
        else if ch == 3 { 3 } // 'c' → accept
        else { 4 }
    } else { state } // accept/reject are final
}

// DFA for counting: number of 'a' characters mod 3
// State = count mod 3; input 1='a', other=ignore
fn count_mod3_transition(state: Int, ch: Int) -> Int {
    if ch == 1 { (state + 1) % 3 }
    else { state }
}

fn test_vending() -> Int {
    // Quarter + quarter + quarter = dispensing
    let s1 = vending_transition(0, 1); // → 1
    let s2 = vending_transition(s1, 1); // → 2
    let s3 = vending_transition(s2, 1); // → 3
    assert_eq(s3, 3);
    assert_eq(vending_is_accept(s3), 1);
    // Dollar goes straight to dispensing
    assert_eq(vending_transition(0, 2), 3);
    // Reset from has_quarter
    assert_eq(vending_transition(1, 4), 0);
    // After dispensing, auto-return to idle
    assert_eq(vending_transition(3, 0), 0);
    1
}

fn test_div3() -> Int {
    // Binary 6 = 110: 0→(0*2+1=1%3=1)→(1*2+1=3%3=0)→(0*2+0=0%3=0)
    // 6 % 3 = 0
    let s1 = div3_transition(0, 1);
    let s2 = div3_transition(s1, 1);
    let s3 = div3_transition(s2, 0);
    assert_eq(s3, 0); // divisible by 3
    // Binary 7 = 111: 0→1→0→1; 7%3=1
    let t1 = div3_transition(0, 1);
    let t2 = div3_transition(t1, 1);
    let t3 = div3_transition(t2, 1);
    assert_eq(t3, 1); // remainder 1
    // Binary 5 = 101: 0→1→2→2; 5%3=2
    let u1 = div3_transition(0, 1);
    let u2 = div3_transition(u1, 0);
    let u3 = div3_transition(u2, 1);
    assert_eq(u3, 2); // remainder 2
    1
}

fn test_regex_matcher() -> Int {
    // "ac" (1,3) → accept
    let s1 = regex_transition(0, 1);
    let s2 = regex_transition(s1, 3);
    assert_eq(s2, 3); // accept
    // "abc" (1,2,3) → accept
    let t1 = regex_transition(0, 1);
    let t2 = regex_transition(t1, 2);
    let t3 = regex_transition(t2, 3);
    assert_eq(t3, 3);
    // "abbc" (1,2,2,3) → accept
    let u1 = regex_transition(0, 1);
    let u2 = regex_transition(u1, 2);
    let u3 = regex_transition(u2, 2);
    let u4 = regex_transition(u3, 3);
    assert_eq(u4, 3);
    // "bc" (2,3) → reject (no 'a' start)
    let v1 = regex_transition(0, 2);
    assert_eq(v1, 4); // reject
    // "ab" (1,2) → not accept (no 'c')
    let w1 = regex_transition(0, 1);
    let w2 = regex_transition(w1, 2);
    assert_eq(w2, 2); // still in saw_b, not accept
    1
}

fn test_count_mod3() -> Int {
    // Count 'a's mod 3: input "aaba" = [1,1,2,1] → 3 a's mod 3 = 0
    let s1 = count_mod3_transition(0, 1); // 1
    let s2 = count_mod3_transition(s1, 1); // 2
    let s3 = count_mod3_transition(s2, 2); // still 2 (not 'a')
    let s4 = count_mod3_transition(s3, 1); // 0
    assert_eq(s4, 0);
    // "aa" = [1,1] → 2 a's mod 3 = 2
    let t1 = count_mod3_transition(0, 1);
    let t2 = count_mod3_transition(t1, 1);
    assert_eq(t2, 2);
    1
}

fn main() -> Int {
    test_vending();
    test_div3();
    test_regex_matcher();
    test_count_mod3();
    print("[OK] 698_state_machine_aot");
    0
}
