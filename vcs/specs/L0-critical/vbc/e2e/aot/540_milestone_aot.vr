// @test: run
// @level: L0
// @tags: aot, e2e, milestone, comprehensive, algorithms
// @timeout: 30000

// Milestone 540: Diverse algorithm showcase

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// 1. Newton's method for integer square root (more precise)
fn isqrt(n: Int) -> Int {
    if n <= 0 { return 0; }
    if n == 1 { return 1; }
    let mut x = n;
    let mut y = (x + 1) / 2;
    while y < x {
        x = y;
        y = (x + n / x) / 2;
    }
    x
}

// 2. Dutch National Flag partition
fn dnf_partition(arr: Arr8, n: Int) -> Arr8 {
    // Partition into <1, ==1, >1
    let mut a = arr;
    let mut lo = 0;
    let mut mid = 0;
    let mut hi = n - 1;
    while mid <= hi {
        let v = get8(a, mid);
        if v < 1 {
            let tmp = get8(a, lo);
            a = set8(a, lo, get8(a, mid));
            a = set8(a, mid, tmp);
            lo = lo + 1;
            mid = mid + 1;
        } else if v > 1 {
            let tmp = get8(a, hi);
            a = set8(a, hi, get8(a, mid));
            a = set8(a, mid, tmp);
            hi = hi - 1;
        } else {
            mid = mid + 1;
        }
    }
    a
}

// 3. Kadane's algorithm: maximum subarray sum
fn max_subarray(arr: Arr8, n: Int) -> Int {
    let mut max_sum = get8(arr, 0);
    let mut cur_sum = get8(arr, 0);
    let mut i = 1;
    while i < n {
        let v = get8(arr, i);
        cur_sum = if cur_sum + v > v { cur_sum + v } else { v };
        if cur_sum > max_sum { max_sum = cur_sum; }
        i = i + 1;
    }
    max_sum
}

// 4. Boyer-Moore voting: majority element
fn majority_element(arr: Arr8, n: Int) -> Int {
    let mut candidate = get8(arr, 0);
    let mut count = 1;
    let mut i = 1;
    while i < n {
        if count == 0 {
            candidate = get8(arr, i);
            count = 1;
        } else if get8(arr, i) == candidate {
            count = count + 1;
        } else {
            count = count - 1;
        }
        i = i + 1;
    }
    // Verify
    count = 0;
    i = 0;
    while i < n {
        if get8(arr, i) == candidate { count = count + 1; }
        i = i + 1;
    }
    if count > n / 2 { candidate } else { -1 }
}

// 5. Rotate array left by k positions
fn rotate_left(arr: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i < n {
        let src = (i + k) % n;
        result = set8(result, i, get8(arr, src));
        i = i + 1;
    }
    result
}

fn test_isqrt() -> Int {
    assert_eq(isqrt(0), 0);
    assert_eq(isqrt(1), 1);
    assert_eq(isqrt(4), 2);
    assert_eq(isqrt(9), 3);
    assert_eq(isqrt(16), 4);
    assert_eq(isqrt(25), 5);
    assert_eq(isqrt(100), 10);
    assert_eq(isqrt(8), 2);  // floor(sqrt(8)) = 2
    assert_eq(isqrt(15), 3); // floor(sqrt(15)) = 3
    1
}

fn test_dnf() -> Int {
    // [2, 0, 1, 2, 0, 1] → [0, 0, 1, 1, 2, 2]
    let arr = Arr8 { v0: 2, v1: 0, v2: 1, v3: 2, v4: 0, v5: 1, v6: 0, v7: 0 };
    let result = dnf_partition(arr, 6);
    assert_eq(get8(result, 0), 0);
    assert_eq(get8(result, 1), 0);
    assert_eq(get8(result, 2), 1);
    assert_eq(get8(result, 3), 1);
    assert_eq(get8(result, 4), 2);
    assert_eq(get8(result, 5), 2);
    1
}

fn test_kadane() -> Int {
    // [-2, 1, -3, 4, -1, 2, 1, -5] → max subarray = [4,-1,2,1] = 6
    let arr = Arr8 { v0: -2, v1: 1, v2: -3, v3: 4, v4: -1, v5: 2, v6: 1, v7: -5 };
    assert_eq(max_subarray(arr, 8), 6);

    // All positive
    let pos = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_subarray(pos, 3), 6);

    // All negative: max is least negative
    let neg = Arr8 { v0: -3, v1: -5, v2: -1, v3: -4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_subarray(neg, 4), -1);
    1
}

fn test_majority() -> Int {
    // [3, 3, 4, 2, 3, 3, 3] → majority is 3
    let arr = Arr8 { v0: 3, v1: 3, v2: 4, v3: 2, v4: 3, v5: 3, v6: 3, v7: 0 };
    assert_eq(majority_element(arr, 7), 3);

    // No majority: [1, 2, 3, 4]
    let no_maj = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(majority_element(no_maj, 4), -1);
    1
}

fn test_rotate() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    let r = rotate_left(arr, 5, 2);
    assert_eq(get8(r, 0), 3);
    assert_eq(get8(r, 1), 4);
    assert_eq(get8(r, 2), 5);
    assert_eq(get8(r, 3), 1);
    assert_eq(get8(r, 4), 2);

    // Rotate by 0 = identity
    let r0 = rotate_left(arr, 5, 0);
    assert_eq(get8(r0, 0), 1);
    assert_eq(get8(r0, 4), 5);

    // Rotate by n = identity
    let rn = rotate_left(arr, 5, 5);
    assert_eq(get8(rn, 0), 1);
    1
}

fn main() -> Int {
    test_isqrt();
    test_dnf();
    test_kadane();
    test_majority();
    test_rotate();
    print("[OK] 540_milestone_aot");
    0
}
