// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, control-flow, nested-loops, complex-branching
// @timeout: 50000
// @expected-exit: 0
// @description: AOT complex control flow (nested loops, multi-way branching, early exit)

fn abs_val(x: Int) -> Int {
    if x < 0 { 0 - x } else { x }
}

fn min_val(a: Int, b: Int) -> Int {
    if a < b { a } else { b }
}

fn max_val(a: Int, b: Int) -> Int {
    if a > b { a } else { b }
}

fn clamp(x: Int, lo: Int, hi: Int) -> Int {
    if x < lo { lo }
    else if x > hi { hi }
    else { x }
}

// Nested loop: matrix element sum (simulated 4x4 matrix)
fn matrix_sum_4x4() -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < 4 {
        let mut j = 0;
        while j < 4 {
            sum = sum + (i * 4 + j + 1);  // values 1..16
            j = j + 1;
        }
        i = i + 1;
    }
    sum
}

// Triple nested loop: count pythagorean triples up to limit
fn count_pythagorean_triples(limit: Int) -> Int {
    let mut count = 0;
    let mut a = 1;
    while a < limit {
        let mut b = a;
        while b < limit {
            let c_sq = a * a + b * b;
            // Check if c_sq is a perfect square
            let mut c = b;
            while c * c < c_sq && c < limit {
                c = c + 1;
            }
            if c < limit && c * c == c_sq {
                count = count + 1;
            }
            b = b + 1;
        }
        a = a + 1;
    }
    count
}

// Collatz sequence length
fn collatz_len(n: Int) -> Int {
    let mut x = n;
    let mut steps = 0;
    while x != 1 {
        if x % 2 == 0 {
            x = x / 2;
        } else {
            x = 3 * x + 1;
        }
        steps = steps + 1;
    }
    steps
}

// Find number with longest Collatz sequence in range
fn longest_collatz(start: Int, end_val: Int) -> Int {
    let mut best = start;
    let mut best_len = 0;
    let mut i = start;
    while i < end_val {
        let cl = collatz_len(i);
        if cl > best_len {
            best_len = cl;
            best = i;
        }
        i = i + 1;
    }
    best
}

// Newton's method integer square root
fn isqrt(n: Int) -> Int {
    if n <= 1 { n }
    else {
        let mut x = n;
        let mut y = (x + 1) / 2;
        while y < x {
            x = y;
            y = (x + n / x) / 2;
        }
        x
    }
}

// Complex multi-way branching
fn classify(n: Int) -> Int {
    // Returns: 0=zero, 1=small positive, 2=medium positive, 3=large positive
    //          -1=small negative, -2=medium negative, -3=large negative
    if n == 0 { 0 }
    else if n > 0 {
        if n < 10 { 1 }
        else if n < 100 { 2 }
        else { 3 }
    } else {
        if n > -10 { -1 }
        else if n > -100 { -2 }
        else { -3 }
    }
}

fn main() -> Int {
    // Basic utils
    assert_eq(abs_val(5), 5);
    assert_eq(abs_val(-5), 5);
    assert_eq(abs_val(0), 0);
    assert_eq(min_val(3, 7), 3);
    assert_eq(max_val(3, 7), 7);
    assert_eq(clamp(5, 0, 10), 5);
    assert_eq(clamp(-5, 0, 10), 0);
    assert_eq(clamp(15, 0, 10), 10);

    // Matrix sum
    assert_eq(matrix_sum_4x4(), 136);  // sum of 1..16

    // Pythagorean triples up to 20
    // (3,4,5), (5,12,13), (6,8,10), (8,15,17), (9,12,15)
    assert_eq(count_pythagorean_triples(20), 5);

    // Collatz
    assert_eq(collatz_len(1), 0);
    assert_eq(collatz_len(2), 1);   // 2->1
    assert_eq(collatz_len(3), 7);   // 3->10->5->16->8->4->2->1
    assert_eq(collatz_len(6), 8);   // 6->3->10->5->16->8->4->2->1
    assert_eq(collatz_len(27), 111);

    // Longest Collatz in range
    assert_eq(longest_collatz(1, 10), 9);  // 9 has 19 steps

    // isqrt
    assert_eq(isqrt(0), 0);
    assert_eq(isqrt(1), 1);
    assert_eq(isqrt(4), 2);
    assert_eq(isqrt(9), 3);
    assert_eq(isqrt(16), 4);
    assert_eq(isqrt(100), 10);
    assert_eq(isqrt(99), 9);
    assert_eq(isqrt(101), 10);

    // Classification
    assert_eq(classify(0), 0);
    assert_eq(classify(5), 1);
    assert_eq(classify(50), 2);
    assert_eq(classify(500), 3);
    assert_eq(classify(-5), -1);
    assert_eq(classify(-50), -2);
    assert_eq(classify(-500), -3);

    // Complex nested: sum all (i*j) for i,j in 1..10
    let mut sum = 0;
    let mut i = 1;
    while i <= 10 {
        let mut j = 1;
        while j <= 10 {
            sum = sum + i * j;
            j = j + 1;
        }
        i = i + 1;
    }
    assert_eq(sum, 3025);  // (1+2+...+10)^2 = 55^2 = 3025

    0
}
