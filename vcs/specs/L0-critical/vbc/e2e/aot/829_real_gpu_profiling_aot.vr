// @test: run
// @tier: 2
// @level: L0
// @tags: aot, gpu, real-opcode, profiling
// @expected-exit: 0

// Tests REAL GPU profiling marker intrinsics through AOT (LLVM) pipeline.
// Mirror of interpreter test 209. Exercises gpu_marker_push, gpu_marker_pop.

// GPU profiling intrinsic declarations
fn gpu_marker_push(name: Int) -> Int { @intrinsic("GPU_MARKER_PUSH", name) }
fn gpu_marker_pop() -> Int { @intrinsic("GPU_MARKER_POP") }

fn main() -> Int {
    let mut errors = 0;

    // Test 1: Push a profiling marker
    let p1 = gpu_marker_push(1);
    if p1 != 0 { errors = errors + 1; }

    // Test 2: Pop profiling marker
    let pop1 = gpu_marker_pop();
    if pop1 != 0 { errors = errors + 1; }

    // Test 3: Nested markers
    let p2 = gpu_marker_push(2);
    let p3 = gpu_marker_push(3);
    let pop3 = gpu_marker_pop();
    let pop2 = gpu_marker_pop();
    if p2 != 0 { errors = errors + 1; }
    if p3 != 0 { errors = errors + 1; }
    if pop3 != 0 { errors = errors + 1; }
    if pop2 != 0 { errors = errors + 1; }

    // Test 4: Multiple sequential markers
    let m1 = gpu_marker_push(10);
    let m1p = gpu_marker_pop();
    let m2 = gpu_marker_push(20);
    let m2p = gpu_marker_pop();
    let m3 = gpu_marker_push(30);
    let m3p = gpu_marker_pop();
    if m1 != 0 { errors = errors + 1; }
    if m2 != 0 { errors = errors + 1; }
    if m3 != 0 { errors = errors + 1; }
    if m1p != 0 { errors = errors + 1; }
    if m2p != 0 { errors = errors + 1; }
    if m3p != 0 { errors = errors + 1; }

    errors
}
