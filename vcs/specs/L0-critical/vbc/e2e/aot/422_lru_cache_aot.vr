// @test: run
// @level: L0
// @tags: aot, e2e, lru, cache, data-structure
// @timeout: 30000

// Simplified LRU cache using arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn new_arr8() -> Arr8 {
    Arr8 { v0: -1, v1: -1, v2: -1, v3: -1, v4: -1, v5: -1, v6: -1, v7: -1 }
}

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// LRU with capacity 4: keys[], vals[], usage_order (most recent = 0)
type LRU is { keys: Arr8, vals: Arr8, ages: Arr8, cap: Int, sz: Int };

fn lru_new() -> LRU {
    LRU { keys: new_arr8(), vals: new_arr8(), ages: new_arr8(), cap: 4, sz: 0 }
}

// Find index of key, or -1
fn lru_find(cache: LRU, key: Int) -> Int {
    let mut i = 0;
    while i < cache.sz {
        if get8(cache.keys, i) == key { return i; }
        i = i + 1;
    }
    -1
}

// Age all entries (increment age)
fn age_all(ages: Arr8, sz: Int) -> Arr8 {
    let mut a = ages;
    let mut i = 0;
    while i < sz {
        a = set8(a, i, get8(a, i) + 1);
        i = i + 1;
    }
    a
}

// Find index with maximum age (least recently used)
fn find_oldest(ages: Arr8, sz: Int) -> Int {
    let mut best_idx = 0;
    let mut best_age = get8(ages, 0);
    let mut i = 1;
    while i < sz {
        if get8(ages, i) > best_age {
            best_age = get8(ages, i);
            best_idx = i;
        }
        i = i + 1;
    }
    best_idx
}

// Put key-value pair into cache
fn lru_put(cache: LRU, key: Int, val: Int) -> LRU {
    let idx = lru_find(cache, key);
    if idx >= 0 {
        // Update existing: set value, reset age
        let new_ages = age_all(cache.ages, cache.sz);
        let new_ages2 = set8(new_ages, idx, 0);
        let new_vals = set8(cache.vals, idx, val);
        return LRU { keys: cache.keys, vals: new_vals, ages: new_ages2, cap: cache.cap, sz: cache.sz };
    }

    if cache.sz < cache.cap {
        // Add new entry
        let new_ages = age_all(cache.ages, cache.sz);
        let new_keys = set8(cache.keys, cache.sz, key);
        let new_vals = set8(cache.vals, cache.sz, val);
        let new_ages2 = set8(new_ages, cache.sz, 0);
        return LRU { keys: new_keys, vals: new_vals, ages: new_ages2, cap: cache.cap, sz: cache.sz + 1 };
    }

    // Evict LRU
    let evict_idx = find_oldest(cache.ages, cache.sz);
    let new_ages = age_all(cache.ages, cache.sz);
    let new_keys = set8(cache.keys, evict_idx, key);
    let new_vals = set8(cache.vals, evict_idx, val);
    let new_ages2 = set8(new_ages, evict_idx, 0);
    LRU { keys: new_keys, vals: new_vals, ages: new_ages2, cap: cache.cap, sz: cache.sz }
}

// Get value for key, -1 if not found
fn lru_get(cache: LRU, key: Int) -> Int {
    let idx = lru_find(cache, key);
    if idx < 0 { return -1; }
    get8(cache.vals, idx)
}

fn test_basic() -> Int {
    let mut c = lru_new();
    c = lru_put(c, 1, 100);
    c = lru_put(c, 2, 200);
    c = lru_put(c, 3, 300);
    assert_eq(lru_get(c, 1), 100);
    assert_eq(lru_get(c, 2), 200);
    assert_eq(lru_get(c, 3), 300);
    assert_eq(lru_get(c, 4), -1);
    1
}

fn test_eviction() -> Int {
    let mut c = lru_new(); // capacity 4
    c = lru_put(c, 1, 10);
    c = lru_put(c, 2, 20);
    c = lru_put(c, 3, 30);
    c = lru_put(c, 4, 40);
    // Cache full: [1,2,3,4]
    // Now put 5 - should evict 1 (oldest)
    c = lru_put(c, 5, 50);
    assert_eq(lru_get(c, 1), -1); // evicted
    assert_eq(lru_get(c, 5), 50);
    assert_eq(lru_get(c, 2), 20);
    1
}

fn test_update() -> Int {
    let mut c = lru_new();
    c = lru_put(c, 1, 10);
    c = lru_put(c, 2, 20);
    // Update key 1 with new value
    c = lru_put(c, 1, 99);
    assert_eq(lru_get(c, 1), 99);
    assert_eq(c.sz, 2);
    1
}

fn main() -> Int {
    test_basic();
    test_eviction();
    test_update();
    print("[OK] 422_lru_cache_aot");
    0
}
