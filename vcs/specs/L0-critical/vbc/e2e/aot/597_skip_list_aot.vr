// @test: run
// @level: L0
// @tags: aot, e2e, skip-list, data-structure, search
// @timeout: 30000

// Sorted list operations: binary search, range queries, rank queries

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// Binary search in sorted array of n elements, returns index or -1
fn bin_search(arr: Arr8, n: Int, val: Int) -> Int {
    let mut lo = 0;
    let mut hi = n - 1;
    let mut result = 0 - 1;
    while lo <= hi {
        let mid = (lo + hi) / 2;
        let mv = get8(arr, mid);
        if mv == val { result = mid; lo = hi + 1; }
        else if mv < val { lo = mid + 1; }
        else { hi = mid - 1; }
    }
    result
}

// Linear search
fn lin_search(arr: Arr8, n: Int, val: Int) -> Int {
    let mut result = 0 - 1;
    let mut i = 0;
    while i < n {
        if result < 0 {
            if get8(arr, i) == val { result = i; }
        }
        i = i + 1;
    }
    result
}

// Range count: how many values in [lo, hi]
fn range_count(arr: Arr8, n: Int, lo: Int, hi: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let v = get8(arr, i);
        if v >= lo {
            if v <= hi { count = count + 1; }
        }
        i = i + 1;
    }
    count
}

// Rank query: how many values < val
fn rank_query(arr: Arr8, n: Int, val: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) < val { count = count + 1; }
        i = i + 1;
    }
    count
}

// Delete by shifting left (returns new array)
fn delete_at(arr: Arr8, n: Int, idx: Int) -> Arr8 {
    let mut a = arr;
    let mut i = idx;
    while i < n - 1 {
        a = set8(a, i, get8(a, i + 1));
        i = i + 1;
    }
    set8(a, n - 1, 0)
}

// Insert at position (shift right from end)
fn insert_at(arr: Arr8, n: Int, pos: Int, val: Int) -> Arr8 {
    let mut a = arr;
    let mut i = n;
    while i > pos {
        a = set8(a, i, get8(a, i - 1));
        i = i - 1;
    }
    set8(a, pos, val)
}

fn test_bin_search() -> Int {
    let arr = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 0, v6: 0, v7: 0 };
    assert_eq(bin_search(arr, 5, 10), 0);
    assert_eq(bin_search(arr, 5, 30), 2);
    assert_eq(bin_search(arr, 5, 50), 4);
    assert_eq(bin_search(arr, 5, 25), 0 - 1);
    assert_eq(bin_search(arr, 5, 5), 0 - 1);
    assert_eq(bin_search(arr, 5, 55), 0 - 1);
    1
}

fn test_lin_search() -> Int {
    let arr = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 0, v6: 0, v7: 0 };
    assert_eq(lin_search(arr, 5, 10), 0);
    assert_eq(lin_search(arr, 5, 30), 2);
    assert_eq(lin_search(arr, 5, 50), 4);
    assert_eq(lin_search(arr, 5, 25), 0 - 1);
    1
}

fn test_range() -> Int {
    let arr = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 0, v6: 0, v7: 0 };
    assert_eq(range_count(arr, 5, 20, 40), 3);
    assert_eq(range_count(arr, 5, 10, 50), 5);
    assert_eq(range_count(arr, 5, 25, 35), 1);
    assert_eq(range_count(arr, 5, 60, 70), 0);
    1
}

fn test_rank() -> Int {
    let arr = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 0, v6: 0, v7: 0 };
    assert_eq(rank_query(arr, 5, 10), 0);
    assert_eq(rank_query(arr, 5, 30), 2);
    assert_eq(rank_query(arr, 5, 60), 5);
    1
}

fn test_delete() -> Int {
    let arr = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 0, v6: 0, v7: 0 };
    let arr2 = delete_at(arr, 5, 1);
    assert_eq(get8(arr2, 0), 10);
    assert_eq(get8(arr2, 1), 30);
    assert_eq(get8(arr2, 2), 40);
    assert_eq(get8(arr2, 3), 50);
    1
}

fn test_insert() -> Int {
    let arr = Arr8 { v0: 10, v1: 30, v2: 50, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let arr2 = insert_at(arr, 3, 1, 20);
    assert_eq(get8(arr2, 0), 10);
    assert_eq(get8(arr2, 1), 20);
    assert_eq(get8(arr2, 2), 30);
    assert_eq(get8(arr2, 3), 50);
    1
}

fn test_search_consistency() -> Int {
    // Binary and linear search should agree
    let arr = Arr8 { v0: 5, v1: 15, v2: 25, v3: 35, v4: 45, v5: 55, v6: 65, v7: 75 };
    assert_eq(bin_search(arr, 8, 5), lin_search(arr, 8, 5));
    assert_eq(bin_search(arr, 8, 45), lin_search(arr, 8, 45));
    assert_eq(bin_search(arr, 8, 75), lin_search(arr, 8, 75));
    assert_eq(bin_search(arr, 8, 10), lin_search(arr, 8, 10));
    1
}

fn main() -> Int {
    test_bin_search();
    test_lin_search();
    test_range();
    test_rank();
    test_delete();
    test_insert();
    test_search_consistency();
    print("[OK] 597_skip_list_aot");
    0
}
