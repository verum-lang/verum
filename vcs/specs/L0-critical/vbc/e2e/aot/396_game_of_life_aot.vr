// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, game-of-life, cellular-automaton, grid
// @timeout: 30000
// @expected-exit: 0
//
// AOT test for Conway's Game of Life on an 8x8 grid.
// Rules:
//   - Live cell with 2-3 neighbors survives
//   - Dead cell with exactly 3 neighbors becomes alive
//   - All other cells die or stay dead
// Grid stored as 8 Ints, each representing one row as a bitmask.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// Grid: 8 rows, each stored as a bitmask (bit i = column i)
// We use the Arr8 directly: grid[row] is a bitmask for that row.

fn pow2(e: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < e {
        result = result * 2;
        i = i + 1;
    }
    result
}

// Get cell state at (row, col)
fn get_cell(grid: Arr8, row: Int, col: Int) -> Int {
    if row < 0 { return 0; }
    if row >= 8 { return 0; }
    if col < 0 { return 0; }
    if col >= 8 { return 0; }
    let row_val = a8_get(grid, row);
    // Extract bit at position col
    let mut shifted = row_val;
    let mut i = 0;
    while i < col {
        shifted = shifted / 2;
        i = i + 1;
    }
    shifted % 2
}

// Set cell state at (row, col) to 1
fn set_cell(grid: Arr8, row: Int, col: Int) -> Arr8 {
    let row_val = a8_get(grid, row);
    let p = pow2(col);
    if get_cell(grid, row, col) == 0 {
        a8_set(grid, row, row_val + p)
    } else {
        grid
    }
}

// Count live neighbors of (row, col)
fn count_neighbors(grid: Arr8, row: Int, col: Int) -> Int {
    let mut count = 0;
    // Check all 8 directions
    count = count + get_cell(grid, row - 1, col - 1);
    count = count + get_cell(grid, row - 1, col);
    count = count + get_cell(grid, row - 1, col + 1);
    count = count + get_cell(grid, row, col - 1);
    count = count + get_cell(grid, row, col + 1);
    count = count + get_cell(grid, row + 1, col - 1);
    count = count + get_cell(grid, row + 1, col);
    count = count + get_cell(grid, row + 1, col + 1);
    count
}

// Advance one generation
fn step(grid: Arr8) -> Arr8 {
    let mut next = a8_zero();
    let mut row = 0;
    while row < 8 {
        let mut row_val = 0;
        let mut col = 0;
        while col < 8 {
            let neighbors = count_neighbors(grid, row, col);
            let alive = get_cell(grid, row, col);
            let next_alive = if alive == 1 {
                if neighbors == 2 { 1 }
                else if neighbors == 3 { 1 }
                else { 0 }
            } else {
                if neighbors == 3 { 1 }
                else { 0 }
            };
            if next_alive == 1 {
                row_val = row_val + pow2(col);
            }
            col = col + 1;
        }
        next = a8_set(next, row, row_val);
        row = row + 1;
    }
    next
}

// Count total live cells
fn population(grid: Arr8) -> Int {
    let mut total = 0;
    let mut row = 0;
    while row < 8 {
        let mut col = 0;
        while col < 8 {
            total = total + get_cell(grid, row, col);
            col = col + 1;
        }
        row = row + 1;
    }
    total
}

// Check if two grids are equal
fn grids_equal(a: Arr8, b: Arr8) -> Int {
    let mut i = 0;
    while i < 8 {
        if a8_get(a, i) != a8_get(b, i) { return 0; }
        i = i + 1;
    }
    1
}

// Run n steps
fn run_steps(grid: Arr8, n: Int) -> Arr8 {
    let mut g = grid;
    let mut i = 0;
    while i < n {
        g = step(g);
        i = i + 1;
    }
    g
}

// ========== Tests ==========

fn test_empty_grid() {
    let grid = a8_zero();
    let next = step(grid);
    assert_eq(population(next), 0);
    assert_eq(grids_equal(grid, next), 1);
}

fn test_single_cell_dies() {
    // A single live cell has 0 neighbors, dies
    let grid = set_cell(a8_zero(), 3, 3);
    assert_eq(population(grid), 1);
    let next = step(grid);
    assert_eq(population(next), 0);
}

fn test_block_still_life() {
    // 2x2 block is a still life (each cell has 3 neighbors)
    //  ##
    //  ##
    let mut grid = a8_zero();
    grid = set_cell(grid, 1, 1);
    grid = set_cell(grid, 1, 2);
    grid = set_cell(grid, 2, 1);
    grid = set_cell(grid, 2, 2);
    assert_eq(population(grid), 4);
    let next = step(grid);
    assert_eq(grids_equal(grid, next), 1);
    // Still the same after 10 steps
    let later = run_steps(grid, 10);
    assert_eq(grids_equal(grid, later), 1);
}

fn test_blinker_oscillator() {
    // Blinker: period 2
    // Phase 1:       Phase 2:
    //   .#.            ...
    //   .#.            ###
    //   .#.            ...
    let mut phase1 = a8_zero();
    phase1 = set_cell(phase1, 1, 2);
    phase1 = set_cell(phase1, 2, 2);
    phase1 = set_cell(phase1, 3, 2);
    assert_eq(population(phase1), 3);

    let phase2 = step(phase1);
    assert_eq(population(phase2), 3);
    // Phase 2 should have cells at (2,1), (2,2), (2,3)
    assert_eq(get_cell(phase2, 2, 1), 1);
    assert_eq(get_cell(phase2, 2, 2), 1);
    assert_eq(get_cell(phase2, 2, 3), 1);
    assert_eq(get_cell(phase2, 1, 2), 0);
    assert_eq(get_cell(phase2, 3, 2), 0);

    // After 2 steps, should return to original
    let phase3 = step(phase2);
    assert_eq(grids_equal(phase1, phase3), 1);
}

fn test_toad_oscillator() {
    // Toad: period 2
    // Phase 1:       Phase 2:
    //   ....           ..#.
    //   .###           #..#
    //   ###.           #..#
    //   ....           .#..
    let mut phase1 = a8_zero();
    phase1 = set_cell(phase1, 2, 1);
    phase1 = set_cell(phase1, 2, 2);
    phase1 = set_cell(phase1, 2, 3);
    phase1 = set_cell(phase1, 3, 0);
    phase1 = set_cell(phase1, 3, 1);
    phase1 = set_cell(phase1, 3, 2);
    assert_eq(population(phase1), 6);

    let phase2 = step(phase1);
    assert_eq(population(phase2), 6);

    // After 2 steps returns to original
    let phase3 = step(phase2);
    assert_eq(grids_equal(phase1, phase3), 1);
}

fn test_beehive_still_life() {
    // Beehive: still life
    //  .##.
    //  #..#
    //  .##.
    let mut grid = a8_zero();
    grid = set_cell(grid, 1, 1);
    grid = set_cell(grid, 1, 2);
    grid = set_cell(grid, 2, 0);
    grid = set_cell(grid, 2, 3);
    grid = set_cell(grid, 3, 1);
    grid = set_cell(grid, 3, 2);
    assert_eq(population(grid), 6);
    let next = step(grid);
    assert_eq(grids_equal(grid, next), 1);
}

fn test_glider() {
    // Glider: moves diagonally, period 4 (shifted position)
    //  .#.
    //  ..#
    //  ###
    let mut grid = a8_zero();
    grid = set_cell(grid, 0, 1);
    grid = set_cell(grid, 1, 2);
    grid = set_cell(grid, 2, 0);
    grid = set_cell(grid, 2, 1);
    grid = set_cell(grid, 2, 2);
    assert_eq(population(grid), 5);

    // After 4 steps, glider should have moved one cell down and one right
    let g4 = run_steps(grid, 4);
    assert_eq(population(g4), 5);
    // Original position (0,1) should be dead
    assert_eq(get_cell(g4, 0, 1), 0);
    // New position should have 5 cells, shifted by (1,1)
    assert_eq(get_cell(g4, 1, 2), 1);
    assert_eq(get_cell(g4, 2, 3), 1);
    assert_eq(get_cell(g4, 3, 1), 1);
    assert_eq(get_cell(g4, 3, 2), 1);
    assert_eq(get_cell(g4, 3, 3), 1);
}

fn test_three_in_a_row_becomes_blinker() {
    // Three cells in a row -> becomes blinker (rotated)
    let mut grid = a8_zero();
    grid = set_cell(grid, 3, 2);
    grid = set_cell(grid, 3, 3);
    grid = set_cell(grid, 3, 4);
    let next = step(grid);
    assert_eq(population(next), 3);
    assert_eq(get_cell(next, 2, 3), 1);
    assert_eq(get_cell(next, 3, 3), 1);
    assert_eq(get_cell(next, 4, 3), 1);
}

fn test_diagonal_dies() {
    // Diagonal line: each cell has only 1-2 neighbors, dies
    let mut grid = a8_zero();
    grid = set_cell(grid, 0, 0);
    grid = set_cell(grid, 1, 1);
    grid = set_cell(grid, 2, 2);
    let next = step(grid);
    // Middle cell has 2 neighbors, survives. Corners have 1 each, die.
    assert_eq(population(next), 1);
    assert_eq(get_cell(next, 1, 1), 1);
    // But then the lone cell dies
    let next2 = step(next);
    assert_eq(population(next2), 0);
}

fn test_neighbor_count() {
    // Test the neighbor counting directly
    let mut grid = a8_zero();
    grid = set_cell(grid, 3, 3);
    // Cell at (3,3): no neighbors
    assert_eq(count_neighbors(grid, 3, 3), 0);
    // Neighbors of (3,3) should see 1 neighbor
    assert_eq(count_neighbors(grid, 2, 2), 1);
    assert_eq(count_neighbors(grid, 2, 3), 1);
    assert_eq(count_neighbors(grid, 4, 4), 1);
    // Non-adjacent cell should see 0
    assert_eq(count_neighbors(grid, 0, 0), 0);
}

fn test_corner_cells() {
    // Cells in corners have fewer potential neighbors
    let mut grid = a8_zero();
    grid = set_cell(grid, 0, 0);
    grid = set_cell(grid, 0, 1);
    grid = set_cell(grid, 1, 0);
    // (0,0) has neighbors: (0,1) and (1,0) = 2 neighbors -> survives
    // (0,1) has neighbors: (0,0), (1,0), (1,1)=0 = 2 neighbors -> survives
    // (1,0) has neighbors: (0,0), (0,1), (1,1)=0 = 2 neighbors -> survives
    // (1,1) has neighbors: (0,0), (0,1), (1,0) = 3 neighbors -> born!
    let next = step(grid);
    assert_eq(get_cell(next, 0, 0), 1);
    assert_eq(get_cell(next, 0, 1), 1);
    assert_eq(get_cell(next, 1, 0), 1);
    assert_eq(get_cell(next, 1, 1), 1);
    // This is a 2x2 block -> still life!
    let next2 = step(next);
    assert_eq(grids_equal(next, next2), 1);
}

fn test_overcrowding() {
    // 5 cells in a plus shape: center has 4 neighbors -> dies
    let mut grid = a8_zero();
    grid = set_cell(grid, 3, 3); // center
    grid = set_cell(grid, 2, 3); // top
    grid = set_cell(grid, 4, 3); // bottom
    grid = set_cell(grid, 3, 2); // left
    grid = set_cell(grid, 3, 4); // right
    assert_eq(count_neighbors(grid, 3, 3), 4);
    let next = step(grid);
    // Center dies (4 neighbors)
    assert_eq(get_cell(next, 3, 3), 0);
}

fn main() -> Int {
    test_empty_grid();
    test_single_cell_dies();
    test_block_still_life();
    test_blinker_oscillator();
    test_toad_oscillator();
    test_beehive_still_life();
    test_glider();
    test_three_in_a_row_becomes_blinker();
    test_diagonal_dies();
    test_neighbor_count();
    test_corner_cells();
    test_overcrowding();
    print("[OK] 396_game_of_life_aot");
    0
}
