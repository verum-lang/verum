// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, binary-heap, data-structures, array-simulation
// @timeout: 50000
// @expected-exit: 0
// @description: AOT binary min-heap using flat array with push, pop, heapify operations

// Flat array of 16 Ints + length field for heap storage
type Buf16 is {
    a0: Int, a1: Int, a2: Int, a3: Int,
    a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int,
    a12: Int, a13: Int, a14: Int, a15: Int,
    len: Int
};

fn buf_new() -> Buf16 {
    Buf16 {
        a0: 0, a1: 0, a2: 0, a3: 0,
        a4: 0, a5: 0, a6: 0, a7: 0,
        a8: 0, a9: 0, a10: 0, a11: 0,
        a12: 0, a13: 0, a14: 0, a15: 0,
        len: 0
    }
}

fn buf_get(b: Buf16, i: Int) -> Int {
    if i == 0 { b.a0 }
    else if i == 1 { b.a1 }
    else if i == 2 { b.a2 }
    else if i == 3 { b.a3 }
    else if i == 4 { b.a4 }
    else if i == 5 { b.a5 }
    else if i == 6 { b.a6 }
    else if i == 7 { b.a7 }
    else if i == 8 { b.a8 }
    else if i == 9 { b.a9 }
    else if i == 10 { b.a10 }
    else if i == 11 { b.a11 }
    else if i == 12 { b.a12 }
    else if i == 13 { b.a13 }
    else if i == 14 { b.a14 }
    else if i == 15 { b.a15 }
    else { -1 }
}

fn buf_set(b: Buf16, i: Int, v: Int) -> Buf16 {
    Buf16 {
        a0: if i == 0 { v } else { b.a0 },
        a1: if i == 1 { v } else { b.a1 },
        a2: if i == 2 { v } else { b.a2 },
        a3: if i == 3 { v } else { b.a3 },
        a4: if i == 4 { v } else { b.a4 },
        a5: if i == 5 { v } else { b.a5 },
        a6: if i == 6 { v } else { b.a6 },
        a7: if i == 7 { v } else { b.a7 },
        a8: if i == 8 { v } else { b.a8 },
        a9: if i == 9 { v } else { b.a9 },
        a10: if i == 10 { v } else { b.a10 },
        a11: if i == 11 { v } else { b.a11 },
        a12: if i == 12 { v } else { b.a12 },
        a13: if i == 13 { v } else { b.a13 },
        a14: if i == 14 { v } else { b.a14 },
        a15: if i == 15 { v } else { b.a15 },
        len: b.len
    }
}

// Swap two elements at indices i and j
fn buf_swap(b: Buf16, i: Int, j: Int) -> Buf16 {
    let vi = buf_get(b, i);
    let vj = buf_get(b, j);
    let b2 = buf_set(b, i, vj);
    buf_set(b2, j, vi)
}

// Parent index: (i - 1) / 2
fn parent(i: Int) -> Int { (i - 1) / 2 }

// Left child index: 2*i + 1
fn left_child(i: Int) -> Int { 2 * i + 1 }

// Right child index: 2*i + 2
fn right_child(i: Int) -> Int { 2 * i + 2 }

// Sift up: move element at index i up until heap property restored
fn sift_up(h: Buf16, i: Int) -> Buf16 {
    let mut heap = h;
    let mut idx = i;
    while idx > 0 {
        let p = parent(idx);
        if buf_get(heap, idx) < buf_get(heap, p) {
            heap = buf_swap(heap, idx, p);
            idx = p;
        } else {
            idx = 0;  // break
        }
    }
    heap
}

// Sift down: move element at index i down until heap property restored
fn sift_down(h: Buf16, i: Int) -> Buf16 {
    let n = h.len;
    let mut heap = h;
    let mut idx = i;
    let mut done = false;
    while !done {
        let l = left_child(idx);
        let r = right_child(idx);
        let mut smallest = idx;
        if l < n && buf_get(heap, l) < buf_get(heap, smallest) {
            smallest = l;
        }
        if r < n && buf_get(heap, r) < buf_get(heap, smallest) {
            smallest = r;
        }
        if smallest != idx {
            heap = buf_swap(heap, idx, smallest);
            idx = smallest;
        } else {
            done = true;
        }
    }
    heap
}

// Push a value onto the heap
fn heap_push(h: Buf16, val: Int) -> Buf16 {
    let n = h.len;
    if n >= 16 { h }
    else {
        let h2 = buf_set(h, n, val);
        let h3 = Buf16 {
            a0: h2.a0, a1: h2.a1, a2: h2.a2, a3: h2.a3,
            a4: h2.a4, a5: h2.a5, a6: h2.a6, a7: h2.a7,
            a8: h2.a8, a9: h2.a9, a10: h2.a10, a11: h2.a11,
            a12: h2.a12, a13: h2.a13, a14: h2.a14, a15: h2.a15,
            len: n + 1
        };
        sift_up(h3, n)
    }
}

// Peek at the minimum element (root)
fn heap_peek(h: Buf16) -> Int {
    if h.len == 0 { -1 }
    else { buf_get(h, 0) }
}

// Pop the minimum element, returning new heap
fn heap_pop(h: Buf16) -> Buf16 {
    let n = h.len;
    if n == 0 { h }
    else if n == 1 {
        Buf16 {
            a0: 0, a1: h.a1, a2: h.a2, a3: h.a3,
            a4: h.a4, a5: h.a5, a6: h.a6, a7: h.a7,
            a8: h.a8, a9: h.a9, a10: h.a10, a11: h.a11,
            a12: h.a12, a13: h.a13, a14: h.a14, a15: h.a15,
            len: 0
        }
    } else {
        // Move last element to root and sift down
        let last_val = buf_get(h, n - 1);
        let h2 = buf_set(h, 0, last_val);
        let h3 = Buf16 {
            a0: h2.a0, a1: h2.a1, a2: h2.a2, a3: h2.a3,
            a4: h2.a4, a5: h2.a5, a6: h2.a6, a7: h2.a7,
            a8: h2.a8, a9: h2.a9, a10: h2.a10, a11: h2.a11,
            a12: h2.a12, a13: h2.a13, a14: h2.a14, a15: h2.a15,
            len: n - 1
        };
        sift_down(h3, 0)
    }
}

// Check if the heap satisfies the min-heap property
fn is_valid_heap(h: Buf16) -> Bool {
    let n = h.len;
    let mut valid = true;
    let mut i = 0;
    while i < n {
        let l = left_child(i);
        let r = right_child(i);
        if l < n && buf_get(h, l) < buf_get(h, i) {
            valid = false;
        }
        if r < n && buf_get(h, r) < buf_get(h, i) {
            valid = false;
        }
        i = i + 1;
    }
    valid
}

// Heapify: build a heap from the first n elements of a buffer
fn heapify(b: Buf16) -> Buf16 {
    let n = b.len;
    if n <= 1 { b }
    else {
        let mut heap = b;
        // Start from last non-leaf and sift down
        let mut i = n / 2 - 1;
        // Can't use negative loop, so go forward and convert
        let start = n / 2 - 1;
        let mut step = 0;
        while step <= start {
            let idx = start - step;
            heap = sift_down(heap, idx);
            step = step + 1;
        }
        heap
    }
}

// Extract sorted sequence: pop all into a flat buffer
fn heap_sort_extract(h: Buf16) -> Buf16 {
    let n = h.len;
    let mut result = buf_new();
    let mut heap = h;
    let mut i = 0;
    while i < n {
        let min_val = heap_peek(heap);
        result = buf_set(result, i, min_val);
        heap = heap_pop(heap);
        i = i + 1;
    }
    Buf16 {
        a0: result.a0, a1: result.a1, a2: result.a2, a3: result.a3,
        a4: result.a4, a5: result.a5, a6: result.a6, a7: result.a7,
        a8: result.a8, a9: result.a9, a10: result.a10, a11: result.a11,
        a12: result.a12, a13: result.a13, a14: result.a14, a15: result.a15,
        len: n
    }
}

fn main() -> Int {
    // === Empty heap ===
    let h0 = buf_new();
    assert_eq(h0.len, 0);
    assert_eq(heap_peek(h0), -1);
    assert(is_valid_heap(h0));

    // === Push single element ===
    let h1 = heap_push(h0, 42);
    assert_eq(h1.len, 1);
    assert_eq(heap_peek(h1), 42);
    assert(is_valid_heap(h1));

    // === Push maintains min at root ===
    let h2 = heap_push(h1, 10);
    assert_eq(h2.len, 2);
    assert_eq(heap_peek(h2), 10);  // 10 < 42
    assert(is_valid_heap(h2));

    let h3 = heap_push(h2, 30);
    assert_eq(h3.len, 3);
    assert_eq(heap_peek(h3), 10);  // still 10
    assert(is_valid_heap(h3));

    let h4 = heap_push(h3, 5);
    assert_eq(h4.len, 4);
    assert_eq(heap_peek(h4), 5);  // 5 is new min
    assert(is_valid_heap(h4));

    // === Pop removes minimum ===
    let h5 = heap_pop(h4);
    assert_eq(h5.len, 3);
    assert_eq(heap_peek(h5), 10);  // 5 removed, 10 is next
    assert(is_valid_heap(h5));

    let h6 = heap_pop(h5);
    assert_eq(h6.len, 2);
    assert_eq(heap_peek(h6), 30);  // 10 removed, 30 is next
    assert(is_valid_heap(h6));

    let h7 = heap_pop(h6);
    assert_eq(h7.len, 1);
    assert_eq(heap_peek(h7), 42);
    assert(is_valid_heap(h7));

    let h8 = heap_pop(h7);
    assert_eq(h8.len, 0);
    assert_eq(heap_peek(h8), -1);

    // === Build heap from sequence, extract sorted ===
    let mut heap = buf_new();
    heap = heap_push(heap, 15);
    heap = heap_push(heap, 3);
    heap = heap_push(heap, 22);
    heap = heap_push(heap, 1);
    heap = heap_push(heap, 8);
    heap = heap_push(heap, 17);
    heap = heap_push(heap, 6);
    assert_eq(heap.len, 7);
    assert_eq(heap_peek(heap), 1);
    assert(is_valid_heap(heap));

    // Extract sorted
    let sorted = heap_sort_extract(heap);
    assert_eq(sorted.len, 7);
    assert_eq(buf_get(sorted, 0), 1);
    assert_eq(buf_get(sorted, 1), 3);
    assert_eq(buf_get(sorted, 2), 6);
    assert_eq(buf_get(sorted, 3), 8);
    assert_eq(buf_get(sorted, 4), 15);
    assert_eq(buf_get(sorted, 5), 17);
    assert_eq(buf_get(sorted, 6), 22);

    // === Heapify: build from unsorted buffer ===
    let mut raw = buf_new();
    raw = buf_set(raw, 0, 50);
    raw = buf_set(raw, 1, 20);
    raw = buf_set(raw, 2, 40);
    raw = buf_set(raw, 3, 10);
    raw = buf_set(raw, 4, 30);
    raw = Buf16 {
        a0: raw.a0, a1: raw.a1, a2: raw.a2, a3: raw.a3,
        a4: raw.a4, a5: raw.a5, a6: raw.a6, a7: raw.a7,
        a8: raw.a8, a9: raw.a9, a10: raw.a10, a11: raw.a11,
        a12: raw.a12, a13: raw.a13, a14: raw.a14, a15: raw.a15,
        len: 5
    };
    let heapified = heapify(raw);
    assert(is_valid_heap(heapified));
    assert_eq(heap_peek(heapified), 10);

    // Extract sorted from heapified
    let sorted2 = heap_sort_extract(heapified);
    assert_eq(buf_get(sorted2, 0), 10);
    assert_eq(buf_get(sorted2, 1), 20);
    assert_eq(buf_get(sorted2, 2), 30);
    assert_eq(buf_get(sorted2, 3), 40);
    assert_eq(buf_get(sorted2, 4), 50);

    // === Duplicate values ===
    let mut hd = buf_new();
    hd = heap_push(hd, 7);
    hd = heap_push(hd, 7);
    hd = heap_push(hd, 7);
    hd = heap_push(hd, 3);
    hd = heap_push(hd, 3);
    assert_eq(hd.len, 5);
    assert_eq(heap_peek(hd), 3);
    assert(is_valid_heap(hd));
    hd = heap_pop(hd);
    assert_eq(heap_peek(hd), 3);
    hd = heap_pop(hd);
    assert_eq(heap_peek(hd), 7);

    // === Reverse-sorted input (worst case for insertion) ===
    let mut hr = buf_new();
    hr = heap_push(hr, 10);
    hr = heap_push(hr, 9);
    hr = heap_push(hr, 8);
    hr = heap_push(hr, 7);
    hr = heap_push(hr, 6);
    hr = heap_push(hr, 5);
    hr = heap_push(hr, 4);
    hr = heap_push(hr, 3);
    assert(is_valid_heap(hr));
    assert_eq(heap_peek(hr), 3);
    assert_eq(hr.len, 8);

    let sorted3 = heap_sort_extract(hr);
    assert_eq(buf_get(sorted3, 0), 3);
    assert_eq(buf_get(sorted3, 7), 10);

    // === Pop from empty is safe ===
    let empty_pop = heap_pop(buf_new());
    assert_eq(empty_pop.len, 0);

    0
}
