// @test: run
// @tier: 1
// @level: L0
// @tags: strings, variants, lists, match, loops, byte_at
// Exercises tokenizer pattern: string scanning, variant construction, list building, match dispatch

type Token is
    Number(Int)
    | Plus
    | Minus
    | Star
    | Lparen
    | Rparen
    | Eof;

fn get_byte(s: Text, i: Int) -> Int {
    match s.byte_at(i) { Some(b) => b, None => -1, }
}

fn is_digit(c: Int) -> Int {
    if (c >= 48 && c <= 57) { 1 } else { 0 }
}

fn tokenize(input: Text) -> List<Token> {
    let mut tokens = [];
    let len = input.len();
    let mut i = 0;

    while (i < len) {
        let ch = get_byte(input, i);

        if (ch == 43) { tokens.push(Plus); i = i + 1; }
        else if (ch == 45) { tokens.push(Minus); i = i + 1; }
        else if (ch == 42) { tokens.push(Star); i = i + 1; }
        else if (ch == 40) { tokens.push(Lparen); i = i + 1; }
        else if (ch == 41) { tokens.push(Rparen); i = i + 1; }
        else if (is_digit(ch) != 0) {
            let mut num = 0;
            while (i < len) {
                let b = get_byte(input, i);
                if (is_digit(b) != 0) {
                    num = num * 10 + (b - 48);
                    i = i + 1;
                } else {
                    break;
                }
            }
            tokens.push(Number(num));
        }
        else { i = i + 1; }
    }
    tokens.push(Eof);
    tokens
}

fn main() -> Int {
    let tokens = tokenize("12+34*5");
    let count = tokens.len();
    if (count != 6) { print(f"FAIL: count={count}"); return 1; }

    match tokens[0] {
        Number(n) => { if (n != 12) { print(f"FAIL: n0={n}"); return 1; } }
        _ => { print("FAIL: expected Number(12)"); return 1; }
    }

    match tokens[1] {
        Plus => {}
        _ => { print("FAIL: expected Plus"); return 1; }
    }

    match tokens[2] {
        Number(n) => { if (n != 34) { print(f"FAIL: n2={n}"); return 1; } }
        _ => { print("FAIL: expected Number(34)"); return 1; }
    }

    match tokens[3] {
        Star => {}
        _ => { print("FAIL: expected Star"); return 1; }
    }

    match tokens[4] {
        Number(n) => { if (n != 5) { print(f"FAIL: n4={n}"); return 1; } }
        _ => { print("FAIL: expected Number(5)"); return 1; }
    }

    match tokens[5] {
        Eof => {}
        _ => { print("FAIL: expected Eof"); return 1; }
    }

    // Test with parens and spaces
    let tokens2 = tokenize("(1+2)*3");
    if (tokens2.len() != 8) { print(f"FAIL: count2={tokens2.len()}"); return 1; }

    match tokens2[0] {
        Lparen => {}
        _ => { print("FAIL: expected Lparen"); return 1; }
    }

    match tokens2[4] {
        Rparen => {}
        _ => { print("FAIL: expected Rparen"); return 1; }
    }

    print("949_tokenizer: PASS");
    0
}
