// @test: run
// @level: L0
// @tier: 2
// @tags: patterns, or-pattern, guards, match
// @description: Or-patterns and guard clauses in match expressions

type Shape is Circle(Int) | Rect(Int, Int) | Triangle(Int, Int, Int);

fn classify_number(n: Int) -> Text {
    match n {
        0 => "zero",
        1 | 2 | 3 => "small",
        4 | 5 | 6 | 7 => "medium",
        _ => "large",
    }
}

fn describe_shape(s: Shape) -> Text {
    match s {
        Circle(r) => f"circle r={r}",
        Rect(w, h) => f"rect {w}x{h}",
        Triangle(a, b, c) => f"tri {a},{b},{c}",
    }
}

fn classify_pair(a: Int, b: Int) -> Text {
    let sum = a + b;
    if (sum == 0) {
        "zero-sum"
    } else if (sum > 0) {
        "positive"
    } else {
        "negative"
    }
}

fn main() -> Int {
    // Test 1: or-patterns with literals
    if (classify_number(0) != "zero") {
        print(f"FAIL test1a: got {classify_number(0)}");
        return 1;
    }
    if (classify_number(2) != "small") {
        print(f"FAIL test1b: got {classify_number(2)}");
        return 1;
    }
    if (classify_number(5) != "medium") {
        print(f"FAIL test1c: got {classify_number(5)}");
        return 1;
    }
    if (classify_number(100) != "large") {
        print(f"FAIL test1d: got {classify_number(100)}");
        return 1;
    }

    // Test 2: variant pattern matching
    let c = Circle(5);
    let r = Rect(3, 4);
    let t = Triangle(3, 4, 5);
    if (describe_shape(c) != "circle r=5") {
        print(f"FAIL test2a: got {describe_shape(c)}");
        return 1;
    }
    if (describe_shape(r) != "rect 3x4") {
        print(f"FAIL test2b: got {describe_shape(r)}");
        return 1;
    }
    if (describe_shape(t) != "tri 3,4,5") {
        print(f"FAIL test2c: got {describe_shape(t)}");
        return 1;
    }

    // Test 3: nested match
    let values = [10, -5, 0, 7, -3];
    let mut pos_count = 0;
    let mut neg_count = 0;
    let mut zero_count = 0;
    let mut i = 0;
    while (i < 5) {
        let v = values[i];
        if (v > 0) {
            pos_count = pos_count + 1;
        } else if (v < 0) {
            neg_count = neg_count + 1;
        } else {
            zero_count = zero_count + 1;
        }
        i = i + 1;
    }
    if (pos_count != 2) {
        print(f"FAIL test3a: pos={pos_count}");
        return 1;
    }
    if (neg_count != 2) {
        print(f"FAIL test3b: neg={neg_count}");
        return 1;
    }
    if (zero_count != 1) {
        print(f"FAIL test3c: zero={zero_count}");
        return 1;
    }

    // Test 4: match with complex expressions
    let x = 42;
    let result = match x % 3 {
        0 => "divisible by 3",
        1 => "remainder 1",
        _ => "remainder 2",
    };
    if (result != "divisible by 3") {
        print(f"FAIL test4: got {result}");
        return 1;
    }

    // Test 5: classify_pair function
    if (classify_pair(3, -3) != "zero-sum") {
        print(f"FAIL test5a");
        return 1;
    }
    if (classify_pair(5, 3) != "positive") {
        print(f"FAIL test5b");
        return 1;
    }
    if (classify_pair(-5, -3) != "negative") {
        print(f"FAIL test5c");
        return 1;
    }

    print("993_or_patterns_guards: PASS");
    0
}
