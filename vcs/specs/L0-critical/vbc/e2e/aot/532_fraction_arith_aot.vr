// @test: run
// @level: L0
// @tags: aot, e2e, fractions, rational, arithmetic
// @timeout: 30000

// Exact rational arithmetic with fractions

type Frac is { num: Int, den: Int };

fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

fn gcd(a: Int, b: Int) -> Int {
    let mut x = abs_val(a);
    let mut y = abs_val(b);
    while y != 0 { let t = y; y = x % y; x = t; }
    x
}

fn frac_new(n: Int, d: Int) -> Frac {
    if d == 0 { return Frac { num: 0, den: 1 }; }
    let g = gcd(abs_val(n), abs_val(d));
    let sign = if d < 0 { -1 } else { 1 };
    Frac { num: sign * n / g, den: sign * d / g }
}

fn frac_add(a: Frac, b: Frac) -> Frac {
    frac_new(a.num * b.den + b.num * a.den, a.den * b.den)
}

fn frac_sub(a: Frac, b: Frac) -> Frac {
    frac_new(a.num * b.den - b.num * a.den, a.den * b.den)
}

fn frac_mul(a: Frac, b: Frac) -> Frac {
    frac_new(a.num * b.num, a.den * b.den)
}

fn frac_div(a: Frac, b: Frac) -> Frac {
    frac_new(a.num * b.den, a.den * b.num)
}

fn frac_eq(a: Frac, b: Frac) -> Int {
    if a.num == b.num {
        if a.den == b.den { return 1; }
    }
    0
}

fn frac_neg(a: Frac) -> Frac {
    Frac { num: 0 - a.num, den: a.den }
}

fn frac_abs(a: Frac) -> Frac {
    Frac { num: abs_val(a.num), den: a.den }
}

fn frac_is_zero(a: Frac) -> Int {
    if a.num == 0 { 1 } else { 0 }
}

// Compare: -1, 0, or 1
fn frac_cmp(a: Frac, b: Frac) -> Int {
    let diff = a.num * b.den - b.num * a.den;
    if diff > 0 { 1 }
    else if diff < 0 { -1 }
    else { 0 }
}

fn test_creation() -> Int {
    let a = frac_new(6, 4);
    assert_eq(a.num, 3);
    assert_eq(a.den, 2);

    let b = frac_new(-3, 6);
    assert_eq(b.num, -1);
    assert_eq(b.den, 2);

    let c = frac_new(0, 5);
    assert_eq(c.num, 0);
    assert_eq(c.den, 1);
    1
}

fn test_add() -> Int {
    // 1/2 + 1/3 = 5/6
    let a = frac_new(1, 2);
    let b = frac_new(1, 3);
    let sum = frac_add(a, b);
    assert_eq(sum.num, 5);
    assert_eq(sum.den, 6);

    // 1/4 + 3/4 = 1
    let c = frac_new(1, 4);
    let d = frac_new(3, 4);
    let sum2 = frac_add(c, d);
    assert_eq(sum2.num, 1);
    assert_eq(sum2.den, 1);
    1
}

fn test_sub() -> Int {
    // 3/4 - 1/4 = 1/2
    let a = frac_new(3, 4);
    let b = frac_new(1, 4);
    let diff = frac_sub(a, b);
    assert_eq(diff.num, 1);
    assert_eq(diff.den, 2);

    // 1/3 - 1/2 = -1/6
    let c = frac_new(1, 3);
    let d = frac_new(1, 2);
    let diff2 = frac_sub(c, d);
    assert_eq(diff2.num, -1);
    assert_eq(diff2.den, 6);
    1
}

fn test_mul() -> Int {
    // 2/3 * 3/4 = 1/2
    let a = frac_new(2, 3);
    let b = frac_new(3, 4);
    let prod = frac_mul(a, b);
    assert_eq(prod.num, 1);
    assert_eq(prod.den, 2);
    1
}

fn test_div() -> Int {
    // (2/3) / (4/5) = 2/3 * 5/4 = 10/12 = 5/6
    let a = frac_new(2, 3);
    let b = frac_new(4, 5);
    let quot = frac_div(a, b);
    assert_eq(quot.num, 5);
    assert_eq(quot.den, 6);
    1
}

fn test_compare() -> Int {
    let a = frac_new(1, 3);
    let b = frac_new(1, 2);
    assert_eq(frac_cmp(a, b), -1);
    assert_eq(frac_cmp(b, a), 1);
    assert_eq(frac_cmp(a, a), 0);
    1
}

fn test_harmonic_sum() -> Int {
    // H(4) = 1 + 1/2 + 1/3 + 1/4 = 12/12 + 6/12 + 4/12 + 3/12 = 25/12
    let mut sum = frac_new(0, 1);
    sum = frac_add(sum, frac_new(1, 1));
    sum = frac_add(sum, frac_new(1, 2));
    sum = frac_add(sum, frac_new(1, 3));
    sum = frac_add(sum, frac_new(1, 4));
    assert_eq(sum.num, 25);
    assert_eq(sum.den, 12);
    1
}

fn test_identities() -> Int {
    let a = frac_new(3, 7);
    let zero = frac_new(0, 1);
    let one = frac_new(1, 1);

    // a + 0 = a
    assert_eq(frac_eq(frac_add(a, zero), a), 1);
    // a * 1 = a
    assert_eq(frac_eq(frac_mul(a, one), a), 1);
    // a * 0 = 0
    assert_eq(frac_is_zero(frac_mul(a, zero)), 1);
    // a + (-a) = 0
    assert_eq(frac_is_zero(frac_add(a, frac_neg(a))), 1);
    // a / a = 1
    assert_eq(frac_eq(frac_div(a, a), one), 1);
    1
}

fn main() -> Int {
    test_creation();
    test_add();
    test_sub();
    test_mul();
    test_div();
    test_compare();
    test_harmonic_sum();
    test_identities();
    print("[OK] 532_fraction_arith_aot");
    0
}
