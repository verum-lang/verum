// @test: run
// Numeric operations — overflow, modular arithmetic, bit ops

fn abs(x: Int) -> Int {
    if (x < 0) { 0 - x } else { x }
}

fn is_palindrome(n: Int) -> Bool {
    if (n < 0) { return false; }
    let mut rev = 0;
    let mut temp = n;
    while temp > 0 {
        rev = rev * 10 + temp % 10;
        temp = temp / 10;
    }
    rev == n
}

fn digit_sum(n: Int) -> Int {
    let mut sum = 0;
    let mut x = abs(n);
    while x > 0 {
        sum = sum + x % 10;
        x = x / 10;
    }
    sum
}

fn count_digits(n: Int) -> Int {
    if (n == 0) { return 1; }
    let mut count = 0;
    let mut x = abs(n);
    while x > 0 {
        count = count + 1;
        x = x / 10;
    }
    count
}

fn main() -> Int {
    // Test 1: Palindrome detection
    if (!is_palindrome(12321)) {
        print("FAIL test1a");
        return 1;
    }
    if (is_palindrome(12345)) {
        print("FAIL test1b");
        return 1;
    }
    if (!is_palindrome(0)) {
        print("FAIL test1c");
        return 1;
    }
    print("test1 palindrome: OK");

    // Test 2: Digit sum
    if (digit_sum(12345) != 15) {
        print(f"FAIL test2a: digit_sum(12345) = {digit_sum(12345)}");
        return 1;
    }
    if (digit_sum(9999) != 36) {
        print("FAIL test2b");
        return 1;
    }
    print("test2 digit_sum: OK");

    // Test 3: Count digits
    if (count_digits(0) != 1) {
        print("FAIL test3a");
        return 1;
    }
    if (count_digits(12345) != 5) {
        print("FAIL test3b");
        return 1;
    }
    if (count_digits(1000000) != 7) {
        print("FAIL test3c");
        return 1;
    }
    print("test3 count_digits: OK");

    // Test 4: Modular arithmetic
    let a = 123456789;
    let m = 1000;
    if (a % m != 789) {
        print(f"FAIL test4a: mod = {a % m}");
        return 1;
    }
    // (a * b) mod m
    let b = 987654321;
    let ab_mod = (a % m) * (b % m) % m;
    // 789 * 321 % 1000 = 253269 % 1000 = 269
    if (ab_mod != 269) {
        print(f"FAIL test4b: ab_mod = {ab_mod}");
        return 1;
    }
    print("test4 modular: OK");

    // Test 5: Integer division edge cases
    if (7 / 2 != 3) {
        print("FAIL test5a");
        return 1;
    }
    if ((-7) / 2 != -3) {
        print(f"FAIL test5b: -7/2 = {(-7) / 2}");
        return 1;
    }
    if (1 / 3 != 0) {
        print("FAIL test5c");
        return 1;
    }
    print("test5 division: OK");

    // Test 6: Large number operations
    let big = 1000000000;
    let big_sq = big * big;
    // 10^18 - fits in 64-bit signed int
    if (big_sq / big != big) {
        print("FAIL test6: large mul/div");
        return 1;
    }
    print("test6 large numbers: OK");

    print("1035_numeric_precision: PASS");
    0
}
