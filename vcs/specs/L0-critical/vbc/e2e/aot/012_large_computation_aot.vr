// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, performance
// @timeout: 50000
// @expected-exit: 0
// @description: AOT larger computations to stress-test the pipeline

fn sieve_count(limit: Int) -> Int {
    // Count primes up to limit using trial division
    let mut count = 0;
    let mut n = 2;
    while n <= limit {
        let mut is_p = true;
        let mut d = 2;
        while d * d <= n {
            if n % d == 0 {
                is_p = false;
            }
            d = d + 1;
        }
        if is_p { count = count + 1; }
        n = n + 1;
    }
    count
}

fn euler_totient(n: Int) -> Int {
    // Count integers from 1..n coprime to n
    let mut count = 0;
    let mut i = 1;
    while i <= n {
        if gcd(i, n) == 1 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 { a } else { gcd(b, a % b) }
}

fn matrix_trace_2x2(a11: Int, a12: Int, a21: Int, a22: Int) -> Int {
    // trace = a11 + a22
    a11 + a22
}

fn matrix_det_2x2(a11: Int, a12: Int, a21: Int, a22: Int) -> Int {
    // det = a11*a22 - a12*a21
    a11 * a22 - a12 * a21
}

fn main() -> Int {
    // Prime counting
    assert_eq(sieve_count(10), 4);    // 2,3,5,7
    assert_eq(sieve_count(20), 8);    // 2,3,5,7,11,13,17,19
    assert_eq(sieve_count(100), 25);  // known: 25 primes below 100

    // Euler's totient
    assert_eq(euler_totient(1), 1);
    assert_eq(euler_totient(6), 2);   // 1, 5
    assert_eq(euler_totient(10), 4);  // 1, 3, 7, 9
    assert_eq(euler_totient(12), 4);  // 1, 5, 7, 11

    // 2x2 matrix operations
    // Identity matrix
    assert_eq(matrix_trace_2x2(1, 0, 0, 1), 2);
    assert_eq(matrix_det_2x2(1, 0, 0, 1), 1);

    // [[2, 3], [1, 4]]
    assert_eq(matrix_trace_2x2(2, 3, 1, 4), 6);
    assert_eq(matrix_det_2x2(2, 3, 1, 4), 5);  // 2*4 - 3*1 = 5

    // Singular matrix [[1, 2], [2, 4]]
    assert_eq(matrix_det_2x2(1, 2, 2, 4), 0);

    0
}
