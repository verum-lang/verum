// @test: run
// @level: L0
// @tags: aot, e2e, ackermann, recursion, computation
// @timeout: 30000

// Ackermann function and other recursive computations

// Ackermann function (small values only to avoid stack overflow)
@allow(unbounded_recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 { n + 1 }
    else if n == 0 { ackermann(m - 1, 1) }
    else { ackermann(m - 1, ackermann(m, n - 1)) }
}

// McCarthy's 91 function
@allow(unbounded_recursion)
fn mccarthy91(n: Int) -> Int {
    if n > 100 { n - 10 }
    else { mccarthy91(mccarthy91(n + 11)) }
}

// Power function (recursive)
@allow(unbounded_recursion)
fn power(base: Int, exp: Int) -> Int {
    if exp == 0 { 1 }
    else { base * power(base, exp - 1) }
}

// Fast power (recursive, O(log n))
@allow(unbounded_recursion)
fn fast_power(base: Int, exp: Int) -> Int {
    if exp == 0 { 1 }
    else if exp % 2 == 0 {
        let half = fast_power(base, exp / 2);
        half * half
    }
    else { base * fast_power(base, exp - 1) }
}

// Sum of digits (recursive)
@allow(unbounded_recursion)
fn digit_sum(n: Int) -> Int {
    if n < 10 { n }
    else { n % 10 + digit_sum(n / 10) }
}

// Digital root (repeated digit sum until single digit)
@allow(unbounded_recursion)
fn digital_root(n: Int) -> Int {
    if n < 10 { n }
    else { digital_root(digit_sum(n)) }
}

// GCD recursive
@allow(unbounded_recursion)
fn gcd_rec(a: Int, b: Int) -> Int {
    if b == 0 { a }
    else { gcd_rec(b, a % b) }
}

// Recursive binary representation: count 1-bits
@allow(unbounded_recursion)
fn count_ones(n: Int) -> Int {
    if n == 0 { 0 }
    else { n % 2 + count_ones(n / 2) }
}

fn test_ackermann() -> Int {
    // A(0, n) = n + 1
    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(0, 5), 6);
    // A(1, n) = n + 2
    assert_eq(ackermann(1, 0), 2);
    assert_eq(ackermann(1, 1), 3);
    assert_eq(ackermann(1, 5), 7);
    // A(2, n) = 2n + 3
    assert_eq(ackermann(2, 0), 3);
    assert_eq(ackermann(2, 1), 5);
    assert_eq(ackermann(2, 3), 9);
    // A(3, 0) = 5, A(3, 1) = 13
    assert_eq(ackermann(3, 0), 5);
    assert_eq(ackermann(3, 1), 13);
    1
}

fn test_mccarthy() -> Int {
    // For n <= 100: M(n) = 91
    assert_eq(mccarthy91(0), 91);
    assert_eq(mccarthy91(50), 91);
    assert_eq(mccarthy91(90), 91);
    assert_eq(mccarthy91(100), 91);
    // For n > 100: M(n) = n - 10
    assert_eq(mccarthy91(101), 91);
    assert_eq(mccarthy91(111), 101);
    assert_eq(mccarthy91(200), 190);
    1
}

fn test_power() -> Int {
    assert_eq(power(2, 0), 1);
    assert_eq(power(2, 10), 1024);
    assert_eq(power(3, 5), 243);
    // fast_power should agree
    assert_eq(fast_power(2, 10), 1024);
    assert_eq(fast_power(3, 5), 243);
    assert_eq(fast_power(5, 3), 125);
    // Both should agree for all small inputs
    assert_eq(power(7, 4), fast_power(7, 4));
    1
}

fn test_digit_sum() -> Int {
    assert_eq(digit_sum(0), 0);
    assert_eq(digit_sum(9), 9);
    assert_eq(digit_sum(123), 6);
    assert_eq(digit_sum(999), 27);
    1
}

fn test_digital_root() -> Int {
    assert_eq(digital_root(0), 0);
    assert_eq(digital_root(5), 5);
    assert_eq(digital_root(123), 6); // 1+2+3=6
    assert_eq(digital_root(999), 9); // 27 -> 9
    assert_eq(digital_root(493), 7); // 4+9+3=16, 1+6=7
    1
}

fn test_gcd_recursive() -> Int {
    assert_eq(gcd_rec(12, 8), 4);
    assert_eq(gcd_rec(17, 13), 1);
    assert_eq(gcd_rec(100, 75), 25);
    assert_eq(gcd_rec(0, 5), 5);
    assert_eq(gcd_rec(7, 7), 7);
    1
}

fn test_count_ones() -> Int {
    assert_eq(count_ones(0), 0);
    assert_eq(count_ones(1), 1);
    assert_eq(count_ones(7), 3);   // 111
    assert_eq(count_ones(255), 8); // 11111111
    assert_eq(count_ones(256), 1); // 100000000
    1
}

fn main() -> Int {
    test_ackermann();
    test_mccarthy();
    test_power();
    test_digit_sum();
    test_digital_root();
    test_gcd_recursive();
    test_count_ones();
    print("[OK] 666_ackermann_aot");
    0
}
