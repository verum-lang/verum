// @test: run
// @level: L0
// @tags: aot, e2e, quickselect, kth-element, partition
// @timeout: 30000

// Quickselect (kth smallest element) and partitioning

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn swap8(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = get8(a, i);
    let vj = get8(a, j);
    set8(set8(a, i, vj), j, vi)
}

// Partition around pivot at index pivot_idx
// Returns (new pivot position, partitioned array) packed as: pos * 100000 + checksum
// Actually, let's return the partitioned array and the position separately
// by encoding position in arr[7] (since we use only indices 0..n-1 where n<8)

// Lomuto partition: partition arr[lo..hi] around arr[hi]
// Returns packed: pivot_final_position
fn partition_lomuto(arr: Arr8, lo: Int, hi: Int) -> Int {
    let pivot = get8(arr, hi);
    let mut i = lo;
    let mut j = lo;
    let mut a = arr;
    while j < hi {
        if get8(a, j) < pivot {
            a = swap8(a, i, j);
            i = i + 1;
        }
        j = j + 1;
    }
    a = swap8(a, i, hi);
    // Return: pivot position * 10000000 + hash of array
    // For verification, return the array element at the partition point
    // Actually just return i (the pivot position) + verify later
    // Pack: i in upper bits, min of left part * 100 + max of left part in lower
    i
}

// Full quickselect to find kth smallest (0-indexed)
// Since we can't return both array and value, we'll sort and pick
fn find_kth(arr: Arr8, n: Int, k: Int) -> Int {
    // Simple selection sort to find kth
    let mut a = arr;
    let mut i = 0;
    while i <= k {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if get8(a, j) < get8(a, min_idx) { min_idx = j; }
            j = j + 1;
        }
        if min_idx != i { a = swap8(a, i, min_idx); }
        i = i + 1;
    }
    get8(a, k)
}

// Median of array (for odd n)
fn median(arr: Arr8, n: Int) -> Int {
    find_kth(arr, n, n / 2)
}

// Partition into three parts: <pivot, ==pivot, >pivot
// Returns count of elements less than pivot
fn three_way_count_less(arr: Arr8, n: Int, pivot: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) < pivot { count = count + 1; }
        i = i + 1;
    }
    count
}

fn three_way_count_equal(arr: Arr8, n: Int, pivot: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) == pivot { count = count + 1; }
        i = i + 1;
    }
    count
}

// Nth percentile (approximate for integers)
fn percentile(arr: Arr8, n: Int, p: Int) -> Int {
    let idx = (n * p) / 100;
    let clamped = if idx >= n { n - 1 } else { idx };
    find_kth(arr, n, clamped)
}

fn test_find_kth() -> Int {
    let arr = Arr8 { v0: 7, v1: 3, v2: 1, v3: 5, v4: 9, v5: 2, v6: 8, v7: 4 };
    // Sorted: [1,2,3,4,5,7,8,9]
    assert_eq(find_kth(arr, 8, 0), 1); // min
    assert_eq(find_kth(arr, 8, 7), 9); // max
    assert_eq(find_kth(arr, 8, 3), 4); // 4th smallest (0-indexed)
    assert_eq(find_kth(arr, 8, 4), 5);
    1
}

fn test_median() -> Int {
    let arr = Arr8 { v0: 7, v1: 3, v2: 1, v3: 5, v4: 9, v5: 0, v6: 0, v7: 0 };
    // Sorted of first 5: [1,3,5,7,9], median at index 2 = 5
    assert_eq(median(arr, 5), 5);

    let arr2 = Arr8 { v0: 1, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(median(arr2, 3), 1);

    let arr3 = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 60, v6: 70, v7: 0 };
    assert_eq(median(arr3, 7), 40);
    1
}

fn test_three_way() -> Int {
    let arr = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 2, v7: 6 };
    assert_eq(three_way_count_less(arr, 8, 4), 4);   // 3,1,1,2
    assert_eq(three_way_count_equal(arr, 8, 1), 2);   // two 1s
    assert_eq(three_way_count_less(arr, 8, 1), 0);    // nothing < 1
    assert_eq(three_way_count_less(arr, 8, 10), 8);   // all < 10
    1
}

fn test_percentile() -> Int {
    let arr = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 60, v6: 70, v7: 80 };
    // 25th percentile: index = 8*25/100 = 2 → value 30
    assert_eq(percentile(arr, 8, 25), 30);
    // 50th percentile: index = 4 → value 50
    assert_eq(percentile(arr, 8, 50), 50);
    // 75th percentile: index = 6 → value 70
    assert_eq(percentile(arr, 8, 75), 70);
    1
}

fn main() -> Int {
    test_find_kth();
    test_median();
    test_three_way();
    test_percentile();
    print("[OK] 464_quick_select_aot");
    0
}
