// @test: run
// @level: L0
// @tags: aot, e2e, matrix, linear-algebra, determinant
// @timeout: 30000

// Matrix operations: 3x3 matrix multiply, determinant, transpose

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// 3x3 matrix stored in first 9 values of Arr8 (only 8 fit, need different approach)
// Use separate type for 3x3 matrix
type Mat3 is { r0: Arr8, r1: Arr8, r2: Arr8 };

fn mat_get(m: Mat3, r: Int, c: Int) -> Int {
    if r == 0 { get8(m.r0, c) }
    else if r == 1 { get8(m.r1, c) }
    else { get8(m.r2, c) }
}

fn mat_set(m: Mat3, r: Int, c: Int, v: Int) -> Mat3 {
    if r == 0 { Mat3 { r0: set8(m.r0, c, v), r1: m.r1, r2: m.r2 } }
    else if r == 1 { Mat3 { r0: m.r0, r1: set8(m.r1, c, v), r2: m.r2 } }
    else { Mat3 { r0: m.r0, r1: m.r1, r2: set8(m.r2, c, v) } }
}

fn mat_zero() -> Mat3 {
    Mat3 { r0: zeros(), r1: zeros(), r2: zeros() }
}

fn mat_identity() -> Mat3 {
    let mut m = mat_zero();
    m = mat_set(m, 0, 0, 1);
    m = mat_set(m, 1, 1, 1);
    m = mat_set(m, 2, 2, 1);
    m
}

// Matrix multiply C = A * B (3x3)
fn mat_mul(a: Mat3, b: Mat3) -> Mat3 {
    let mut c = mat_zero();
    let mut i = 0;
    while i < 3 {
        let mut j = 0;
        while j < 3 {
            let mut sum = 0;
            let mut k = 0;
            while k < 3 {
                sum = sum + mat_get(a, i, k) * mat_get(b, k, j);
                k = k + 1;
            }
            c = mat_set(c, i, j, sum);
            j = j + 1;
        }
        i = i + 1;
    }
    c
}

// Matrix addition
fn mat_add(a: Mat3, b: Mat3) -> Mat3 {
    let mut c = mat_zero();
    let mut i = 0;
    while i < 3 {
        let mut j = 0;
        while j < 3 {
            c = mat_set(c, i, j, mat_get(a, i, j) + mat_get(b, i, j));
            j = j + 1;
        }
        i = i + 1;
    }
    c
}

// Transpose
fn mat_transpose(a: Mat3) -> Mat3 {
    let mut t = mat_zero();
    let mut i = 0;
    while i < 3 {
        let mut j = 0;
        while j < 3 {
            t = mat_set(t, j, i, mat_get(a, i, j));
            j = j + 1;
        }
        i = i + 1;
    }
    t
}

// Determinant of 3x3
fn mat_det(m: Mat3) -> Int {
    let a = mat_get(m, 0, 0);
    let b = mat_get(m, 0, 1);
    let c = mat_get(m, 0, 2);
    let d = mat_get(m, 1, 0);
    let e = mat_get(m, 1, 1);
    let f = mat_get(m, 1, 2);
    let g = mat_get(m, 2, 0);
    let h = mat_get(m, 2, 1);
    let k = mat_get(m, 2, 2);
    a * (e * k - f * h) - b * (d * k - f * g) + c * (d * h - e * g)
}

// Trace (sum of diagonal)
fn mat_trace(m: Mat3) -> Int {
    mat_get(m, 0, 0) + mat_get(m, 1, 1) + mat_get(m, 2, 2)
}

// Matrix-vector multiply (3-element vector as Arr8)
fn mat_vec_mul(m: Mat3, v: Arr8) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i < 3 {
        let mut sum = 0;
        let mut j = 0;
        while j < 3 {
            sum = sum + mat_get(m, i, j) * get8(v, j);
            j = j + 1;
        }
        result = set8(result, i, sum);
        i = i + 1;
    }
    result
}

fn test_identity() -> Int {
    let id = mat_identity();
    assert_eq(mat_get(id, 0, 0), 1);
    assert_eq(mat_get(id, 1, 1), 1);
    assert_eq(mat_get(id, 2, 2), 1);
    assert_eq(mat_get(id, 0, 1), 0);
    assert_eq(mat_det(id), 1);
    assert_eq(mat_trace(id), 3);
    1
}

fn test_multiply() -> Int {
    // A = [[1,2,3],[4,5,6],[7,8,9]]
    let mut a = mat_zero();
    a = mat_set(a, 0, 0, 1); a = mat_set(a, 0, 1, 2); a = mat_set(a, 0, 2, 3);
    a = mat_set(a, 1, 0, 4); a = mat_set(a, 1, 1, 5); a = mat_set(a, 1, 2, 6);
    a = mat_set(a, 2, 0, 7); a = mat_set(a, 2, 1, 8); a = mat_set(a, 2, 2, 9);

    // A * I = A
    let ai = mat_mul(a, mat_identity());
    assert_eq(mat_get(ai, 0, 0), 1);
    assert_eq(mat_get(ai, 1, 1), 5);
    assert_eq(mat_get(ai, 2, 2), 9);

    // A * A
    let aa = mat_mul(a, a);
    // (0,0): 1*1+2*4+3*7 = 1+8+21 = 30
    assert_eq(mat_get(aa, 0, 0), 30);
    // (0,1): 1*2+2*5+3*8 = 2+10+24 = 36
    assert_eq(mat_get(aa, 0, 1), 36);
    // (1,0): 4*1+5*4+6*7 = 4+20+42 = 66
    assert_eq(mat_get(aa, 1, 0), 66);
    1
}

fn test_determinant() -> Int {
    // [[2,1,1],[1,3,2],[1,0,0]]: det = 2(0-0) - 1(0-2) + 1(0-3) = 0+2-3 = -1
    let mut m = mat_zero();
    m = mat_set(m, 0, 0, 2); m = mat_set(m, 0, 1, 1); m = mat_set(m, 0, 2, 1);
    m = mat_set(m, 1, 0, 1); m = mat_set(m, 1, 1, 3); m = mat_set(m, 1, 2, 2);
    m = mat_set(m, 2, 0, 1); m = mat_set(m, 2, 1, 0); m = mat_set(m, 2, 2, 0);
    assert_eq(mat_det(m), -1);

    // Singular matrix: det = 0
    let mut s = mat_zero();
    s = mat_set(s, 0, 0, 1); s = mat_set(s, 0, 1, 2); s = mat_set(s, 0, 2, 3);
    s = mat_set(s, 1, 0, 4); s = mat_set(s, 1, 1, 5); s = mat_set(s, 1, 2, 6);
    s = mat_set(s, 2, 0, 7); s = mat_set(s, 2, 1, 8); s = mat_set(s, 2, 2, 9);
    assert_eq(mat_det(s), 0);
    1
}

fn test_transpose() -> Int {
    let mut m = mat_zero();
    m = mat_set(m, 0, 0, 1); m = mat_set(m, 0, 1, 2); m = mat_set(m, 0, 2, 3);
    m = mat_set(m, 1, 0, 4); m = mat_set(m, 1, 1, 5); m = mat_set(m, 1, 2, 6);
    m = mat_set(m, 2, 0, 7); m = mat_set(m, 2, 1, 8); m = mat_set(m, 2, 2, 9);

    let t = mat_transpose(m);
    assert_eq(mat_get(t, 0, 1), 4); // was (1,0)
    assert_eq(mat_get(t, 1, 0), 2); // was (0,1)
    assert_eq(mat_get(t, 2, 0), 3); // was (0,2)
    // Diagonal unchanged
    assert_eq(mat_get(t, 0, 0), 1);
    assert_eq(mat_get(t, 1, 1), 5);
    1
}

fn test_mat_vec() -> Int {
    let id = mat_identity();
    let v = Arr8 { v0: 3, v1: 5, v2: 7, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r = mat_vec_mul(id, v);
    assert_eq(get8(r, 0), 3);
    assert_eq(get8(r, 1), 5);
    assert_eq(get8(r, 2), 7);

    // Scale matrix
    let mut sc = mat_zero();
    sc = mat_set(sc, 0, 0, 2);
    sc = mat_set(sc, 1, 1, 3);
    sc = mat_set(sc, 2, 2, 4);
    let r2 = mat_vec_mul(sc, v);
    assert_eq(get8(r2, 0), 6);
    assert_eq(get8(r2, 1), 15);
    assert_eq(get8(r2, 2), 28);
    1
}

fn main() -> Int {
    test_identity();
    test_multiply();
    test_determinant();
    test_transpose();
    test_mat_vec();
    print("[OK] 494_matrix_ops_aot");
    0
}
