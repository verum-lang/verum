// @test: run
// @level: L0
// @tags: aot, e2e, milestone, matrix-chain, dp
// @timeout: 30000

// Milestone 685: Dynamic programming classics

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn min2(a: Int, b: Int) -> Int { if a < b { a } else { b } }
fn max2(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// Longest Increasing Subsequence length
fn lis(a: Arr8, n: Int) -> Int {
    // dp[i] = length of LIS ending at index i
    let mut dp = zeros();
    let mut max_len = 0;
    let mut i = 0;
    while i < n {
        dp = set8(dp, i, 1);
        let mut j = 0;
        while j < i {
            if get8(a, j) < get8(a, i) {
                if get8(dp, j) + 1 > get8(dp, i) {
                    dp = set8(dp, i, get8(dp, j) + 1);
                }
            }
            j = j + 1;
        }
        if get8(dp, i) > max_len { max_len = get8(dp, i); }
        i = i + 1;
    }
    max_len
}

// Longest Common Subsequence of two sequences in Arr8
// Only handles sequences of length <= 4 (dp table is 5x5 = 25, needs multiple Arr8s)
// Simplified: use O(n) space DP
fn lcs(a: Arr8, la: Int, b: Arr8, lb: Int) -> Int {
    // dp[j] = LCS length of a[0..i] and b[0..j]
    let mut dp = zeros();
    let mut i = 0;
    while i < la {
        let mut prev = 0;
        let mut j = 0;
        while j < lb {
            let old = get8(dp, j);
            if get8(a, i) == get8(b, j) {
                dp = set8(dp, j, prev + 1);
            } else {
                let above = get8(dp, j);
                let left = if j > 0 { get8(dp, j - 1) } else { 0 };
                dp = set8(dp, j, max2(above, left));
            }
            prev = old;
            j = j + 1;
        }
        i = i + 1;
    }
    get8(dp, lb - 1)
}

// Edit distance between two sequences
fn edit_dist(a: Arr8, la: Int, b: Arr8, lb: Int) -> Int {
    // dp[j] = edit distance between a[0..i] and b[0..j]
    let mut dp = zeros();
    // Initialize: dp[j] = j (insert j chars)
    let mut j = 0;
    while j <= lb {
        dp = set8(dp, j, j);
        j = j + 1;
    }
    let mut i = 1;
    while i <= la {
        let mut prev = get8(dp, 0);
        dp = set8(dp, 0, i);
        j = 1;
        while j <= lb {
            let old = get8(dp, j);
            if get8(a, i - 1) == get8(b, j - 1) {
                dp = set8(dp, j, prev);
            } else {
                let ins = get8(dp, j - 1) + 1;
                let del = get8(dp, j) + 1;
                let sub = prev + 1;
                dp = set8(dp, j, min2(ins, min2(del, sub)));
            }
            prev = old;
            j = j + 1;
        }
        i = i + 1;
    }
    get8(dp, lb)
}

// Maximum subarray sum (Kadane's)
fn max_subarray(a: Arr8, n: Int) -> Int {
    let mut max_sum = get8(a, 0);
    let mut cur_sum = get8(a, 0);
    let mut i = 1;
    while i < n {
        let val = get8(a, i);
        cur_sum = max2(val, cur_sum + val);
        max_sum = max2(max_sum, cur_sum);
        i = i + 1;
    }
    max_sum
}

// Count ways to climb n stairs (1 or 2 steps at a time) = Fibonacci
fn climb_stairs(n: Int) -> Int {
    if n <= 1 { 1 }
    else {
        let mut a = 1;
        let mut b = 1;
        let mut i = 2;
        while i <= n {
            let t = a + b;
            a = b;
            b = t;
            i = i + 1;
        }
        b
    }
}

fn test_lis() -> Int {
    // [3, 1, 4, 1, 5, 9, 2, 6]
    let a = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 2, v7: 6 };
    assert_eq(lis(a, 8), 4); // 1,4,5,9 or 1,4,5,6 or 1,2,5,9...
    // Sorted: LIS = n
    let b = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lis(b, 4), 4);
    // Reverse sorted: LIS = 1
    let c = Arr8 { v0: 4, v1: 3, v2: 2, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lis(c, 4), 1);
    1
}

fn test_lcs() -> Int {
    // a = [1,3,5,7], b = [1,2,3,4,5]
    let a = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs(a, 4, b, 5), 3); // 1,3,5
    // Same sequence: LCS = length
    assert_eq(lcs(a, 4, a, 4), 4);
    // Disjoint: LCS = 0
    let c = Arr8 { v0: 2, v1: 4, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let d = Arr8 { v0: 1, v1: 3, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs(c, 3, d, 3), 0);
    1
}

fn test_edit_dist() -> Int {
    // Same sequence: distance 0
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(edit_dist(a, 3, a, 3), 0);
    // One substitution: [1,2,3] vs [1,4,3] = 1
    let b = Arr8 { v0: 1, v1: 4, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(edit_dist(a, 3, b, 3), 1);
    // One deletion: [1,2,3] vs [1,3] = 1
    let c = Arr8 { v0: 1, v1: 3, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(edit_dist(a, 3, c, 2), 1);
    // Empty vs non-empty: distance = length
    let empty = zeros();
    assert_eq(edit_dist(a, 3, empty, 0), 3);
    1
}

fn test_kadane() -> Int {
    // [-2, 1, -3, 4, -1, 2, 1, -5] → max subarray = [4,-1,2,1] = 6
    // Encode negatives: use large positive offset? No, Verum has signed Int
    // Actually let's store directly
    let a = Arr8 { v0: 0-2, v1: 1, v2: 0-3, v3: 4, v4: 0-1, v5: 2, v6: 1, v7: 0-5 };
    assert_eq(max_subarray(a, 8), 6);
    // All positive: whole array
    let b = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_subarray(b, 3), 6);
    // All negative: max single element
    let c = Arr8 { v0: 0-5, v1: 0-3, v2: 0-1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_subarray(c, 3), 0 - 1);
    1
}

fn test_stairs() -> Int {
    assert_eq(climb_stairs(0), 1);
    assert_eq(climb_stairs(1), 1);
    assert_eq(climb_stairs(2), 2);
    assert_eq(climb_stairs(3), 3);
    assert_eq(climb_stairs(4), 5);
    assert_eq(climb_stairs(5), 8);
    // It's Fibonacci!
    assert_eq(climb_stairs(6), 13);
    1
}

fn main() -> Int {
    test_lis();
    test_lcs();
    test_edit_dist();
    test_kadane();
    test_stairs();
    print("[OK] 685_milestone_aot");
    0
}
