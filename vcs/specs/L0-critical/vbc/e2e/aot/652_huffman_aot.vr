// @test: run
// @level: L0
// @tags: aot, e2e, huffman, encoding, information-theory
// @timeout: 30000

// Huffman-like coding and entropy concepts

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Count frequency of each symbol in data[0..n]
// Symbols must be in range [0, 7]
fn count_freq(data: Arr8, n: Int) -> Arr8 {
    let mut freq = zeros();
    let mut i = 0;
    while i < n {
        let sym = get8(data, i);
        freq = set8(freq, sym, get8(freq, sym) + 1);
        i = i + 1;
    }
    freq
}

// Find minimum non-zero frequency index (returns -1 if none)
fn find_min_freq(freq: Arr8, n_sym: Int, exclude: Int) -> Int {
    let mut min_idx = 0 - 1;
    let mut min_val = 99999;
    let mut i = 0;
    while i < n_sym {
        if i != exclude {
            let f = get8(freq, i);
            if f > 0 {
                if f < min_val {
                    min_val = f;
                    min_idx = i;
                }
            }
        }
        i = i + 1;
    }
    min_idx
}

// Compute code lengths using a simplified greedy approach:
// Assign shorter codes to more frequent symbols
// Sort frequencies, assign increasing code lengths
fn assign_code_lengths(freq: Arr8, n_sym: Int) -> Arr8 {
    // Count non-zero frequencies
    let mut n_active = 0;
    let mut i = 0;
    while i < n_sym {
        if get8(freq, i) > 0 { n_active = n_active + 1; }
        i = i + 1;
    }
    if n_active <= 1 {
        // Only one symbol: code length 1
        let mut lengths = zeros();
        let mut j = 0;
        while j < n_sym {
            if get8(freq, j) > 0 { lengths = set8(lengths, j, 1); }
            j = j + 1;
        }
        lengths
    } else {
        // Sort symbols by frequency (descending) - assign lengths 1, 2, 3...
        // But this isn't a real Huffman tree, just demonstrates the concept
        // For testing: use ceil(log2(n_active)) as uniform code length
        let mut bits = 1;
        let mut cap = 2;
        while cap < n_active { bits = bits + 1; cap = cap * 2; }
        let mut lengths = zeros();
        let mut j = 0;
        while j < n_sym {
            if get8(freq, j) > 0 { lengths = set8(lengths, j, bits); }
            j = j + 1;
        }
        lengths
    }
}

// Total encoded size: sum of freq[i] * code_len[i]
fn total_encoded_bits(freq: Arr8, lengths: Arr8, n_sym: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n_sym {
        total = total + get8(freq, i) * get8(lengths, i);
        i = i + 1;
    }
    total
}

// Shannon entropy approximation (integer, scaled by 100)
// H = -sum(p * log2(p)), where p = freq/total
// For integer approximation: count unique symbols
fn count_unique(freq: Arr8, n_sym: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n_sym {
        if get8(freq, i) > 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Prefix-free code check: given code lengths, check Kraft inequality
// sum(2^(-l_i)) <= 1, equivalently sum(2^(max_len - l_i)) <= 2^max_len
fn kraft_check(lengths: Arr8, n_sym: Int) -> Int {
    let mut max_len = 0;
    let mut i = 0;
    while i < n_sym {
        let l = get8(lengths, i);
        if l > max_len { max_len = l; }
        i = i + 1;
    }
    if max_len == 0 { 1 } // no symbols
    else {
        let mut sum = 0;
        let mut pow2_max = 1;
        let mut k = 0;
        while k < max_len { pow2_max = pow2_max * 2; k = k + 1; }
        let mut j = 0;
        while j < n_sym {
            let l = get8(lengths, j);
            if l > 0 {
                let mut p = 1;
                let mut m = 0;
                while m < max_len - l { p = p * 2; m = m + 1; }
                sum = sum + p;
            }
            j = j + 1;
        }
        if sum <= pow2_max { 1 } else { 0 }
    }
}

fn test_frequency_count() -> Int {
    // [0, 1, 0, 2, 0, 1, 0, 3]
    let data = Arr8 { v0: 0, v1: 1, v2: 0, v3: 2, v4: 0, v5: 1, v6: 0, v7: 3 };
    let freq = count_freq(data, 8);
    assert_eq(get8(freq, 0), 4); // 0 appears 4 times
    assert_eq(get8(freq, 1), 2); // 1 appears 2 times
    assert_eq(get8(freq, 2), 1); // 2 appears 1 time
    assert_eq(get8(freq, 3), 1); // 3 appears 1 time
    1
}

fn test_uniform_data() -> Int {
    // All same symbol
    let data = Arr8 { v0: 5, v1: 5, v2: 5, v3: 5, v4: 5, v5: 5, v6: 5, v7: 5 };
    let freq = count_freq(data, 8);
    assert_eq(get8(freq, 5), 8);
    assert_eq(count_unique(freq, 8), 1);
    let lengths = assign_code_lengths(freq, 8);
    assert_eq(get8(lengths, 5), 1); // Single symbol gets length 1
    assert_eq(total_encoded_bits(freq, lengths, 8), 8); // 8 bits total
    1
}

fn test_two_symbols() -> Int {
    // [0, 1, 0, 1, 0, 1, 0, 1]
    let data = Arr8 { v0: 0, v1: 1, v2: 0, v3: 1, v4: 0, v5: 1, v6: 0, v7: 1 };
    let freq = count_freq(data, 8);
    assert_eq(count_unique(freq, 8), 2);
    let lengths = assign_code_lengths(freq, 8);
    // Two symbols: each gets 1-bit code
    assert_eq(get8(lengths, 0), 1);
    assert_eq(get8(lengths, 1), 1);
    assert_eq(total_encoded_bits(freq, lengths, 8), 8); // 4*1 + 4*1 = 8
    1
}

fn test_four_symbols() -> Int {
    // [0, 1, 2, 3, 0, 1, 2, 3]
    let data = Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 0, v5: 1, v6: 2, v7: 3 };
    let freq = count_freq(data, 8);
    assert_eq(count_unique(freq, 8), 4);
    let lengths = assign_code_lengths(freq, 8);
    // Four symbols: each gets 2-bit code
    assert_eq(get8(lengths, 0), 2);
    assert_eq(total_encoded_bits(freq, lengths, 8), 16); // 8 * 2 = 16
    1
}

fn test_kraft_inequality() -> Int {
    // Uniform lengths: 2 bits for 4 symbols
    let lengths = Arr8 { v0: 2, v1: 2, v2: 2, v3: 2, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(kraft_check(lengths, 4), 1); // 4 * 2^(2-2) = 4 = 2^2, tight
    // 1 bit for 2 symbols
    let lengths2 = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(kraft_check(lengths2, 2), 1);
    // Invalid: 1 bit for 3 symbols (Kraft violated)
    let lengths3 = Arr8 { v0: 1, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(kraft_check(lengths3, 3), 0); // 3 > 2^1
    1
}

fn test_min_freq() -> Int {
    let freq = Arr8 { v0: 4, v1: 2, v2: 1, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let min1 = find_min_freq(freq, 4, 0 - 1); // exclude nothing
    // min is index 2 or 3 (both have freq 1)
    assert_eq(get8(freq, min1), 1);
    1
}

fn main() -> Int {
    test_frequency_count();
    test_uniform_data();
    test_two_symbols();
    test_four_symbols();
    test_kraft_inequality();
    test_min_freq();
    print("[OK] 652_huffman_aot");
    0
}
