// @test: run
// @tier: 2
// @level: L0
// @tags: e2e, aot, trie, prefix-tree, digit-trie
// @timeout: 30000
// @expected-exit: 0
//
// Trie data structure for digit sequences (alphabet 0-9).
// Each trie node has 10 children (stored as indices into a node pool),
// a flag for "end of word", and a count of words passing through.
// Node pool stored in flat Arr32 arrays (parallel arrays for each field).

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int, a12: Int, a13: Int, a14: Int, a15: Int
};

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 } else if i == 2 { a.a2 }
    else if i == 3 { a.a3 } else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 } else if i == 8 { a.a8 }
    else if i == 9 { a.a9 } else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 } else if i == 14 { a.a14 }
    else { a.a15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 }, a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 }, a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 }, a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 }, a15: if i == 15 { v } else { a.a15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
            a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0 }
}

// Trie structure:
// We support up to 16 nodes (nodes 0-15). Node 0 is root.
// For each node we store:
//   - children[digit] as node index (0 = no child, since root is 0 we use -1 for "no child")
//     children stored in a flat Arr16 for each of 4 digit slots we actually use (digits 0-3 only
//     to keep the structure manageable). Actually, we'll limit to digits 0-3 for simplicity.
//
// Simplified: only use digits 0-3 (4-ary trie), up to 16 nodes.
// Per-node data:
//   children: 4 child indices per node, stored flat: node*4+digit in a big array
//   end_of_word: 1 per node (Arr16)
//   prefix_count: 1 per node (Arr16)
// children array: 16 nodes * 4 = 64 entries. We'll use Arr8 x 8 = 64.

type Arr32 is { b0: Arr8, b1: Arr8, b2: Arr8, b3: Arr8 };

fn a32_zero() -> Arr32 {
    Arr32 { b0: a8_zero(), b1: a8_zero(), b2: a8_zero(), b3: a8_zero() }
}

fn a32_get(a: Arr32, i: Int) -> Int {
    if i < 8 { a8_get(a.b0, i) }
    else if i < 16 { a8_get(a.b1, i - 8) }
    else if i < 24 { a8_get(a.b2, i - 16) }
    else { a8_get(a.b3, i - 24) }
}

fn a32_set(a: Arr32, i: Int, v: Int) -> Arr32 {
    if i < 8 {
        Arr32 { b0: a8_set(a.b0, i, v), b1: a.b1, b2: a.b2, b3: a.b3 }
    } else if i < 16 {
        Arr32 { b0: a.b0, b1: a8_set(a.b1, i - 8, v), b2: a.b2, b3: a.b3 }
    } else if i < 24 {
        Arr32 { b0: a.b0, b1: a.b1, b2: a8_set(a.b2, i - 16, v), b3: a.b3 }
    } else {
        Arr32 { b0: a.b0, b1: a.b1, b2: a.b2, b3: a8_set(a.b3, i - 24, v) }
    }
}

// Extended: 64-slot array using two Arr32
type Arr64 is { lo: Arr32, hi: Arr32 };

fn a64_zero() -> Arr64 {
    Arr64 { lo: a32_zero(), hi: a32_zero() }
}

fn a64_get(a: Arr64, i: Int) -> Int {
    if i < 32 { a32_get(a.lo, i) } else { a32_get(a.hi, i - 32) }
}

fn a64_set(a: Arr64, i: Int, v: Int) -> Arr64 {
    if i < 32 {
        Arr64 { lo: a32_set(a.lo, i, v), hi: a.hi }
    } else {
        Arr64 { lo: a.lo, hi: a32_set(a.hi, i - 32, v) }
    }
}

// Trie state: children (64 entries: node*4+digit), end_of_word (16), prefix_count (16), next_node
type Trie is {
    children: Arr64,
    end_word: Arr16,
    prefix_cnt: Arr16,
    next_id: Int
};

fn trie_new() -> Trie {
    // Initialize all children to -1 (no child)
    let mut ch = a64_zero();
    let mut i = 0;
    while i < 64 {
        ch = a64_set(ch, i, 0 - 1);
        i = i + 1;
    }
    Trie { children: ch, end_word: a16_zero(), prefix_cnt: a16_zero(), next_id: 1 }
}

// Insert a word (digit sequence stored in Arr8 with length n)
fn trie_insert(t: Trie, word: Arr8, n: Int) -> Trie {
    let mut cur = 0; // start at root
    let mut ch = t.children;
    let mut ew = t.end_word;
    let mut pc = t.prefix_cnt;
    let mut nid = t.next_id;
    pc = a16_set(pc, 0, a16_get(pc, 0) + 1);
    let mut i = 0;
    while i < n {
        let digit = a8_get(word, i);
        let slot = cur * 4 + digit;
        let child = a64_get(ch, slot);
        if child < 0 {
            // Allocate new node
            ch = a64_set(ch, slot, nid);
            cur = nid;
            nid = nid + 1;
        } else {
            cur = child;
        }
        pc = a16_set(pc, cur, a16_get(pc, cur) + 1);
        i = i + 1;
    }
    ew = a16_set(ew, cur, a16_get(ew, cur) + 1);
    Trie { children: ch, end_word: ew, prefix_cnt: pc, next_id: nid }
}

// Search: returns 1 if word exists, 0 otherwise
fn trie_search(t: Trie, word: Arr8, n: Int) -> Int {
    let mut cur = 0;
    let mut i = 0;
    while i < n {
        let digit = a8_get(word, i);
        let slot = cur * 4 + digit;
        let child = a64_get(t.children, slot);
        if child < 0 { return 0; }
        cur = child;
        i = i + 1;
    }
    if a16_get(t.end_word, cur) > 0 { 1 } else { 0 }
}

// Count words with given prefix
fn trie_prefix_count(t: Trie, prefix: Arr8, n: Int) -> Int {
    let mut cur = 0;
    let mut i = 0;
    while i < n {
        let digit = a8_get(prefix, i);
        let slot = cur * 4 + digit;
        let child = a64_get(t.children, slot);
        if child < 0 { return 0; }
        cur = child;
        i = i + 1;
    }
    a16_get(t.prefix_cnt, cur)
}

// ========== Tests ==========

// Words (using digits 0-3):
// word1 = [1, 2, 3]     "123"
// word2 = [1, 2, 0]     "120"
// word3 = [1, 3]        "13"
// word4 = [2, 0, 1]     "201"

fn make_word1() -> Arr8 {
    Arr8 { a0: 1, a1: 2, a2: 3, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}
fn make_word2() -> Arr8 {
    Arr8 { a0: 1, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}
fn make_word3() -> Arr8 {
    Arr8 { a0: 1, a1: 3, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}
fn make_word4() -> Arr8 {
    Arr8 { a0: 2, a1: 0, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

fn build_trie() -> Trie {
    let mut t = trie_new();
    t = trie_insert(t, make_word1(), 3);
    t = trie_insert(t, make_word2(), 3);
    t = trie_insert(t, make_word3(), 2);
    t = trie_insert(t, make_word4(), 3);
    t
}

fn test_search_present() -> Int {
    let t = build_trie();
    assert_eq(trie_search(t, make_word1(), 3), 1);
    assert_eq(trie_search(t, make_word2(), 3), 1);
    assert_eq(trie_search(t, make_word3(), 2), 1);
    assert_eq(trie_search(t, make_word4(), 3), 1);
    0
}

fn test_search_absent() -> Int {
    let t = build_trie();
    // "1" is a prefix but not a word
    let p1 = Arr8 { a0: 1, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_search(t, p1, 1), 0);
    // "12" is a prefix but not a word
    let p2 = Arr8 { a0: 1, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_search(t, p2, 2), 0);
    // "321" not inserted
    let p3 = Arr8 { a0: 3, a1: 2, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_search(t, p3, 3), 0);
    0
}

fn test_prefix_count_root() -> Int {
    let t = build_trie();
    // Prefix "1": words 123, 120, 13 => 3
    let p1 = Arr8 { a0: 1, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_prefix_count(t, p1, 1), 3);
    // Prefix "2": word 201 => 1
    let p2 = Arr8 { a0: 2, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_prefix_count(t, p2, 1), 1);
    0
}

fn test_prefix_count_deeper() -> Int {
    let t = build_trie();
    // Prefix "12": words 123, 120 => 2
    let p12 = Arr8 { a0: 1, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_prefix_count(t, p12, 2), 2);
    // Prefix "13": word 13 => 1
    let p13 = Arr8 { a0: 1, a1: 3, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_prefix_count(t, p13, 2), 1);
    // Prefix "3": no words => 0
    let p3 = Arr8 { a0: 3, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_prefix_count(t, p3, 1), 0);
    0
}

fn test_empty_trie() -> Int {
    let t = trie_new();
    let w = make_word1();
    assert_eq(trie_search(t, w, 3), 0);
    let p = Arr8 { a0: 1, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_prefix_count(t, p, 1), 0);
    0
}

fn test_duplicate_insert() -> Int {
    let mut t = trie_new();
    t = trie_insert(t, make_word1(), 3);
    t = trie_insert(t, make_word1(), 3);
    // Should still find it
    assert_eq(trie_search(t, make_word1(), 3), 1);
    // Prefix count for "1" should be 2 (inserted twice)
    let p1 = Arr8 { a0: 1, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    assert_eq(trie_prefix_count(t, p1, 1), 2);
    0
}

fn test_node_count() -> Int {
    let t = build_trie();
    // Root(0) -> node(1) for digit 1, node(?) for digit 2
    // Nodes allocated: root=0, then 1(digit1@root), 2(digit2@1), 3(digit3@2) for "123",
    // "120" shares 1,2 adds 4(digit0@2), "13" shares 1 adds 5(digit3@1),
    // "201" adds 6(digit2@root), 7(digit0@6), 8(digit1@7)
    assert_eq(t.next_id, 9);
    0
}

fn main() -> Int {
    test_search_present();
    test_search_absent();
    test_prefix_count_root();
    test_prefix_count_deeper();
    test_empty_trie();
    test_duplicate_insert();
    test_node_count();
    print("[OK] 408_trie_aot");
    0
}
