// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, variants, records, binary-tree, red-black, data-structures
// @timeout: 15000
// @expected-exit: 0
// @description: AOT red-black tree (BST with color) - insert, search, size, height, traversal

type Color is Red | Black;

type RBTree is
    RBNil
  | RBNode { color: Color, val: Int, left: RBTree, right: RBTree };

// Check if a color is red
fn is_red(c: Color) -> Bool {
    c is Red
}

// Insert into BST (no rebalancing - just assigns Red to new nodes)
fn rb_insert(tree: RBTree, v: Int) -> RBTree {
    match tree {
        RBNil => RBNode { color: Red, val: v, left: RBNil, right: RBNil },
        RBNode { color: c, val: x, left, right } => {
            if v < x {
                RBNode { color: c, val: x, left: rb_insert(left, v), right: right }
            } else if v > x {
                RBNode { color: c, val: x, left: left, right: rb_insert(right, v) }
            } else {
                tree  // duplicate, no change
            }
        },
    }
}

// Make the root black (standard RB tree invariant)
fn make_root_black(tree: RBTree) -> RBTree {
    match tree {
        RBNil => RBNil,
        RBNode { color: _, val, left, right } => {
            RBNode { color: Black, val: val, left: left, right: right }
        },
    }
}

// Insert and ensure root is black
fn rb_insert_root(tree: RBTree, v: Int) -> RBTree {
    make_root_black(rb_insert(tree, v))
}

// Check if tree contains a value
fn rb_contains(tree: RBTree, v: Int) -> Bool {
    match tree {
        RBNil => false,
        RBNode { color: _, val: x, left, right } => {
            if v == x { true }
            else if v < x { rb_contains(left, v) }
            else { rb_contains(right, v) }
        },
    }
}

// Size of the tree
fn rb_size(tree: RBTree) -> Int {
    match tree {
        RBNil => 0,
        RBNode { color: _, val: _, left, right } => 1 + rb_size(left) + rb_size(right),
    }
}

// Height of the tree
fn rb_height(tree: RBTree) -> Int {
    match tree {
        RBNil => 0,
        RBNode { color: _, val: _, left, right } => {
            let lh = rb_height(left);
            let rh = rb_height(right);
            1 + if lh > rh { lh } else { rh }
        },
    }
}

// Minimum value in tree
fn rb_min(tree: RBTree) -> Int {
    match tree {
        RBNil => 999999,
        RBNode { color: _, val: x, left, right: _ } => {
            match left {
                RBNil => x,
                _ => rb_min(left),
            }
        },
    }
}

// Maximum value in tree
fn rb_max(tree: RBTree) -> Int {
    match tree {
        RBNil => -999999,
        RBNode { color: _, val: x, left: _, right } => {
            match right {
                RBNil => x,
                _ => rb_max(right),
            }
        },
    }
}

// In-order sum of all values
fn inorder_sum(tree: RBTree) -> Int {
    match tree {
        RBNil => 0,
        RBNode { color: _, val: x, left, right } => {
            inorder_sum(left) + x + inorder_sum(right)
        },
    }
}

// Count red nodes
fn count_red(tree: RBTree) -> Int {
    match tree {
        RBNil => 0,
        RBNode { color, val: _, left, right } => {
            let self_count = if is_red(color) { 1 } else { 0 };
            self_count + count_red(left) + count_red(right)
        },
    }
}

// Count black nodes
fn count_black(tree: RBTree) -> Int {
    match tree {
        RBNil => 0,
        RBNode { color, val: _, left, right } => {
            let self_count = if is_red(color) { 0 } else { 1 };
            self_count + count_black(left) + count_black(right)
        },
    }
}

// Count leaf nodes (RBNil children of RBNode)
fn count_leaves(tree: RBTree) -> Int {
    match tree {
        RBNil => 0,
        RBNode { color: _, val: _, left, right } => {
            let l_leaves = match left {
                RBNil => 1,
                _ => count_leaves(left),
            };
            let r_leaves = match right {
                RBNil => 1,
                _ => count_leaves(right),
            };
            l_leaves + r_leaves
        },
    }
}

// Check root color
fn root_is_black(tree: RBTree) -> Bool {
    match tree {
        RBNil => true,
        RBNode { color, val: _, left: _, right: _ } => !is_red(color),
    }
}

fn main() -> Int {
    // === Empty tree ===
    let empty = RBNil;
    assert_eq(rb_size(empty), 0);
    assert_eq(rb_height(empty), 0);
    assert(!rb_contains(empty, 5));
    assert(root_is_black(empty));

    // === Single insert ===
    let t1 = rb_insert_root(RBNil, 10);
    assert_eq(rb_size(t1), 1);
    assert_eq(rb_height(t1), 1);
    assert(rb_contains(t1, 10));
    assert(!rb_contains(t1, 5));
    assert(root_is_black(t1));

    // === Insert 7 elements: 50, 30, 70, 20, 40, 60, 80 ===
    // This creates a balanced BST when inserted in this order
    let mut tree = RBNil;
    tree = rb_insert_root(tree, 50);
    tree = rb_insert_root(tree, 30);
    tree = rb_insert_root(tree, 70);
    tree = rb_insert_root(tree, 20);
    tree = rb_insert_root(tree, 40);
    tree = rb_insert_root(tree, 60);
    tree = rb_insert_root(tree, 80);

    // Size
    assert_eq(rb_size(tree), 7);

    // Contains
    assert(rb_contains(tree, 50));
    assert(rb_contains(tree, 20));
    assert(rb_contains(tree, 80));
    assert(rb_contains(tree, 40));
    assert(!rb_contains(tree, 10));
    assert(!rb_contains(tree, 55));
    assert(!rb_contains(tree, 90));

    // Min and max
    assert_eq(rb_min(tree), 20);
    assert_eq(rb_max(tree), 80);

    // Height: balanced BST => height = 3
    assert_eq(rb_height(tree), 3);

    // Sum: 20+30+40+50+60+70+80 = 350
    assert_eq(inorder_sum(tree), 350);

    // Root is black
    assert(root_is_black(tree));

    // Color counts: root is always black, children inserted as red then root forced black
    // Total = 7, red + black = 7
    let reds = count_red(tree);
    let blacks = count_black(tree);
    assert_eq(reds + blacks, 7);
    assert(blacks >= 1);  // at least root is black

    // === Duplicate insert doesn't change size ===
    let tree2 = rb_insert_root(tree, 50);
    assert_eq(rb_size(tree2), 7);
    let tree3 = rb_insert_root(tree2, 30);
    assert_eq(rb_size(tree3), 7);

    // === Skewed insertion: 1, 2, 3, 4, 5 (ascending) ===
    let mut skew = RBNil;
    skew = rb_insert_root(skew, 1);
    skew = rb_insert_root(skew, 2);
    skew = rb_insert_root(skew, 3);
    skew = rb_insert_root(skew, 4);
    skew = rb_insert_root(skew, 5);

    assert_eq(rb_size(skew), 5);
    assert_eq(rb_min(skew), 1);
    assert_eq(rb_max(skew), 5);
    assert_eq(inorder_sum(skew), 15);  // 1+2+3+4+5
    assert(root_is_black(skew));

    // Height of degenerate right-spine = 5
    assert_eq(rb_height(skew), 5);

    // === Count leaves ===
    // A single node has 2 nil children = 2 leaves
    let leaf_tree = rb_insert_root(RBNil, 42);
    assert_eq(count_leaves(leaf_tree), 2);

    // Balanced 3-node tree: root with two children, each has 2 nil children = 4 leaves
    let mut three = RBNil;
    three = rb_insert_root(three, 10);
    three = rb_insert_root(three, 5);
    three = rb_insert_root(three, 15);
    assert_eq(count_leaves(three), 4);
    assert_eq(rb_size(three), 3);

    // === Large tree: insert 1..15 in balanced order ===
    let mut big = RBNil;
    big = rb_insert_root(big, 8);
    big = rb_insert_root(big, 4);
    big = rb_insert_root(big, 12);
    big = rb_insert_root(big, 2);
    big = rb_insert_root(big, 6);
    big = rb_insert_root(big, 10);
    big = rb_insert_root(big, 14);
    big = rb_insert_root(big, 1);
    big = rb_insert_root(big, 3);
    big = rb_insert_root(big, 5);
    big = rb_insert_root(big, 7);
    big = rb_insert_root(big, 9);
    big = rb_insert_root(big, 11);
    big = rb_insert_root(big, 13);
    big = rb_insert_root(big, 15);

    assert_eq(rb_size(big), 15);
    assert_eq(rb_min(big), 1);
    assert_eq(rb_max(big), 15);
    // Sum 1..15 = 15*16/2 = 120
    assert_eq(inorder_sum(big), 120);
    // Perfectly balanced: height = 4
    assert_eq(rb_height(big), 4);
    assert(root_is_black(big));

    // Verify all values present
    assert(rb_contains(big, 1));
    assert(rb_contains(big, 8));
    assert(rb_contains(big, 15));
    assert(!rb_contains(big, 0));
    assert(!rb_contains(big, 16));

    0
}
