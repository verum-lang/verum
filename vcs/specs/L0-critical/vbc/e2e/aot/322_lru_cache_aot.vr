// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, lru-cache, data-structure, algorithm
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for LRU (Least Recently Used) cache simulation
// Fixed-size cache with access tracking via timestamps

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int, len: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

fn arr8_new(n: Int) -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: n }
}

// LRU cache: keys, values, access timestamps
// -1 in keys means empty slot
// cap: max items, count: current items, clock: monotonic timestamp
type LruCache is {
    keys: Arr8,
    vals: Arr8,
    times: Arr8,
    cap: Int,
    count: Int,
    clock: Int
};

fn lru_new(capacity: Int) -> LruCache {
    let empty_keys = Arr8 { a0: -1, a1: -1, a2: -1, a3: -1, a4: -1, a5: -1, a6: -1, a7: -1, len: capacity };
    LruCache {
        keys: empty_keys,
        vals: arr8_new(capacity),
        times: arr8_new(capacity),
        cap: capacity,
        count: 0,
        clock: 1
    }
}

// Find index of key, or -1 if not found
fn lru_find(c: LruCache, key: Int) -> Int {
    let mut i = 0;
    while i < c.cap {
        if arr8_get(c.keys, i) == key { return i; }
        i = i + 1;
    }
    -1
}

// Get value for key. Returns -1 if not found. Also updates access time.
// Returns (value, updated_cache) encoded: we return the value, caller updates cache separately.
fn lru_get_val(c: LruCache, key: Int) -> Int {
    let idx = lru_find(c, key);
    if idx == -1 { -1 } else { arr8_get(c.vals, idx) }
}

// Update access time (must be called after lru_get_val)
fn lru_touch(c: LruCache, key: Int) -> LruCache {
    let idx = lru_find(c, key);
    if idx == -1 { return c; }
    let new_times = arr8_set(c.times, idx, c.clock);
    LruCache {
        keys: c.keys, vals: c.vals, times: new_times,
        cap: c.cap, count: c.count, clock: c.clock + 1
    }
}

// Find index of least recently used entry
fn lru_find_lru_idx(c: LruCache) -> Int {
    let mut min_time = 999999999;
    let mut min_idx = 0;
    let mut i = 0;
    while i < c.cap {
        let t = arr8_get(c.times, i);
        if t < min_time {
            min_time = t;
            min_idx = i;
        }
        i = i + 1;
    }
    min_idx
}

// Put key-value pair. Evicts LRU if full.
fn lru_put(c: LruCache, key: Int, val: Int) -> LruCache {
    // Check if key already exists
    let existing = lru_find(c, key);
    if existing >= 0 {
        // Update value and access time
        let new_vals = arr8_set(c.vals, existing, val);
        let new_times = arr8_set(c.times, existing, c.clock);
        return LruCache {
            keys: c.keys, vals: new_vals, times: new_times,
            cap: c.cap, count: c.count, clock: c.clock + 1
        };
    }

    // Find a slot
    let mut slot = -1;
    if c.count < c.cap {
        // Find empty slot
        let mut i = 0;
        while i < c.cap {
            if arr8_get(c.keys, i) == -1 {
                if slot == -1 { slot = i; }
            }
            i = i + 1;
        }
    } else {
        // Evict LRU
        slot = lru_find_lru_idx(c);
    }

    let new_keys = arr8_set(c.keys, slot, key);
    let new_vals = arr8_set(c.vals, slot, val);
    let new_times = arr8_set(c.times, slot, c.clock);
    let new_count = if c.count < c.cap { c.count + 1 } else { c.count };
    LruCache {
        keys: new_keys, vals: new_vals, times: new_times,
        cap: c.cap, count: new_count, clock: c.clock + 1
    }
}

// Check if key exists
fn lru_contains(c: LruCache, key: Int) -> Int {
    if lru_find(c, key) >= 0 { 1 } else { 0 }
}

fn test_empty_cache() {
    let c = lru_new(3);
    assert_eq(lru_get_val(c, 1), -1);
    assert_eq(lru_contains(c, 1), 0);
    assert_eq(c.count, 0);
}

fn test_put_and_get() {
    let mut c = lru_new(3);
    c = lru_put(c, 1, 100);
    assert_eq(lru_get_val(c, 1), 100);
    assert_eq(lru_contains(c, 1), 1);
    assert_eq(c.count, 1);

    c = lru_put(c, 2, 200);
    c = lru_put(c, 3, 300);
    assert_eq(lru_get_val(c, 2), 200);
    assert_eq(lru_get_val(c, 3), 300);
    assert_eq(c.count, 3);
}

fn test_update_value() {
    let mut c = lru_new(3);
    c = lru_put(c, 1, 100);
    c = lru_put(c, 1, 999);
    assert_eq(lru_get_val(c, 1), 999);
    assert_eq(c.count, 1); // count should not increase
}

fn test_eviction() {
    let mut c = lru_new(3);
    c = lru_put(c, 1, 100);  // time=1
    c = lru_put(c, 2, 200);  // time=2
    c = lru_put(c, 3, 300);  // time=3
    // Full. Key 1 is LRU.

    c = lru_put(c, 4, 400);  // Evicts key 1
    assert_eq(lru_contains(c, 1), 0);
    assert_eq(lru_get_val(c, 4), 400);
    assert_eq(lru_get_val(c, 2), 200);
    assert_eq(lru_get_val(c, 3), 300);
    assert_eq(c.count, 3);
}

fn test_touch_prevents_eviction() {
    let mut c = lru_new(3);
    c = lru_put(c, 1, 100);  // time=1
    c = lru_put(c, 2, 200);  // time=2
    c = lru_put(c, 3, 300);  // time=3

    // Touch key 1, making it most recently used
    c = lru_touch(c, 1);     // time=4

    // Now key 2 is LRU (time=2)
    c = lru_put(c, 4, 400);  // Should evict key 2
    assert_eq(lru_contains(c, 2), 0);
    assert_eq(lru_contains(c, 1), 1);
    assert_eq(lru_contains(c, 3), 1);
    assert_eq(lru_contains(c, 4), 1);
}

fn test_access_order() {
    let mut c = lru_new(2);
    c = lru_put(c, 1, 10);   // time=1
    c = lru_put(c, 2, 20);   // time=2

    // Access key 1
    c = lru_touch(c, 1);     // time=3, key 1 updated

    // Insert key 3: evicts key 2 (LRU at time=2)
    c = lru_put(c, 3, 30);
    assert_eq(lru_contains(c, 1), 1);
    assert_eq(lru_contains(c, 2), 0);
    assert_eq(lru_contains(c, 3), 1);

    // Access key 3
    c = lru_touch(c, 3);

    // Insert key 4: evicts key 1 (LRU)
    c = lru_put(c, 4, 40);
    assert_eq(lru_contains(c, 1), 0);
    assert_eq(lru_contains(c, 3), 1);
    assert_eq(lru_contains(c, 4), 1);
}

fn test_capacity_one() {
    let mut c = lru_new(1);
    c = lru_put(c, 1, 100);
    assert_eq(lru_get_val(c, 1), 100);

    c = lru_put(c, 2, 200);
    assert_eq(lru_contains(c, 1), 0);
    assert_eq(lru_get_val(c, 2), 200);
}

fn test_sequential_eviction() {
    let mut c = lru_new(4);
    // Fill cache: keys 1-4
    c = lru_put(c, 1, 10);
    c = lru_put(c, 2, 20);
    c = lru_put(c, 3, 30);
    c = lru_put(c, 4, 40);

    // Insert 5,6,7,8 - should evict 1,2,3,4 in order
    c = lru_put(c, 5, 50);
    assert_eq(lru_contains(c, 1), 0);
    c = lru_put(c, 6, 60);
    assert_eq(lru_contains(c, 2), 0);
    c = lru_put(c, 7, 70);
    assert_eq(lru_contains(c, 3), 0);
    c = lru_put(c, 8, 80);
    assert_eq(lru_contains(c, 4), 0);

    // Only 5,6,7,8 should remain
    assert_eq(lru_get_val(c, 5), 50);
    assert_eq(lru_get_val(c, 6), 60);
    assert_eq(lru_get_val(c, 7), 70);
    assert_eq(lru_get_val(c, 8), 80);
}

fn test_put_updates_lru_order() {
    let mut c = lru_new(3);
    c = lru_put(c, 1, 10);   // time=1
    c = lru_put(c, 2, 20);   // time=2
    c = lru_put(c, 3, 30);   // time=3

    // Update key 1 (should refresh its time)
    c = lru_put(c, 1, 15);   // time=4

    // Now key 2 is LRU (time=2)
    c = lru_put(c, 4, 40);   // Evicts key 2
    assert_eq(lru_contains(c, 2), 0);
    assert_eq(lru_get_val(c, 1), 15);
    assert_eq(lru_contains(c, 3), 1);
    assert_eq(lru_contains(c, 4), 1);
}

fn main() -> Int {
    test_empty_cache();
    test_put_and_get();
    test_update_value();
    test_eviction();
    test_touch_prevents_eviction();
    test_access_order();
    test_capacity_one();
    test_sequential_eviction();
    test_put_updates_lru_order();
    print("[OK] 322_lru_cache_aot");
    0
}
