// @test: run
// @level: L0
// @tags: aot, e2e, edit-distance, levenshtein, dp
// @timeout: 30000

// Edit distance (Levenshtein) and related string DP problems

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }
fn min3(a: Int, b: Int, c: Int) -> Int { min_val(a, min_val(b, c)) }

// Edit distance using 1D DP array
// dp[j] = edit distance between s[0..i] and t[0..j]
// Strings represented as Arr8 of integer "characters"
fn edit_distance(s: Arr8, slen: Int, t: Arr8, tlen: Int) -> Int {
    // Initialize dp[j] = j (transforming empty string to t[0..j])
    let mut dp = zeros();
    let mut j = 0;
    while j <= tlen {
        dp = set8(dp, j, j);
        j = j + 1;
    }

    let mut i = 1;
    while i <= slen {
        let mut prev = get8(dp, 0); // dp[0] from previous row
        dp = set8(dp, 0, i); // dp[0] = i (transforming s[0..i] to empty)
        let mut j2 = 1;
        while j2 <= tlen {
            let old = get8(dp, j2);
            let cost = if get8(s, i - 1) == get8(t, j2 - 1) { 0 } else { 1 };
            let val = min3(
                get8(dp, j2) + 1,     // delete
                get8(dp, j2 - 1) + 1, // insert
                prev + cost            // replace
            );
            dp = set8(dp, j2, val);
            prev = old;
            j2 = j2 + 1;
        }
        i = i + 1;
    }
    get8(dp, tlen)
}

// Longest common subsequence length
fn lcs_length(s: Arr8, slen: Int, t: Arr8, tlen: Int) -> Int {
    let mut dp = zeros(); // dp[j] = LCS(s[0..i], t[0..j])
    let mut i = 1;
    while i <= slen {
        let mut prev = 0;
        let mut j2 = 1;
        while j2 <= tlen {
            let old = get8(dp, j2);
            if get8(s, i - 1) == get8(t, j2 - 1) {
                dp = set8(dp, j2, prev + 1);
            } else {
                let v = if get8(dp, j2) > get8(dp, j2 - 1) { get8(dp, j2) } else { get8(dp, j2 - 1) };
                dp = set8(dp, j2, v);
            }
            prev = old;
            j2 = j2 + 1;
        }
        i = i + 1;
    }
    get8(dp, tlen)
}

// Hamming distance (count differing positions)
fn hamming(a: Arr8, b: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(a, i) != get8(b, i) { count = count + 1; }
        i = i + 1;
    }
    count
}

// Check if b is a subsequence of a
fn is_subsequence(sub: Arr8, sublen: Int, seq: Arr8, seqlen: Int) -> Int {
    let mut si = 0;
    let mut qi = 0;
    while si < sublen {
        if qi >= seqlen { return 0; }
        if get8(sub, si) == get8(seq, qi) {
            si = si + 1;
        }
        qi = qi + 1;
    }
    1
}

fn test_edit_distance() -> Int {
    // "kitten" vs "sitting" as [1,2,3,3,4,5] vs [6,2,3,3,2,5,7]
    // Simplified: use small examples
    // [1,2,3] -> [1,2,3]: distance 0
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(edit_distance(a, 3, a, 3), 0);

    // [1,2,3] -> [1,2,4]: distance 1 (replace)
    let b = Arr8 { v0: 1, v1: 2, v2: 4, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(edit_distance(a, 3, b, 3), 1);

    // [1,2,3] -> [1,2]: distance 1 (delete)
    assert_eq(edit_distance(a, 3, a, 2), 1);

    // [1,2] -> [1,2,3]: distance 1 (insert)
    assert_eq(edit_distance(a, 2, a, 3), 1);

    // [1,2,3] -> [4,5,6]: distance 3 (all replace)
    let c = Arr8 { v0: 4, v1: 5, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(edit_distance(a, 3, c, 3), 3);

    // Empty to [1,2,3]: distance 3
    assert_eq(edit_distance(a, 0, a, 3), 3);
    1
}

fn test_lcs() -> Int {
    // [1,3,5,7] and [1,2,3,4,5]: LCS = [1,3,5] = 3
    let a = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs_length(a, 4, b, 5), 3);

    // Same sequences: LCS = length
    assert_eq(lcs_length(a, 4, a, 4), 4);

    // Disjoint: LCS = 0
    let c = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs_length(a, 4, c, 4), 0);
    1
}

fn test_hamming_dist() -> Int {
    // a=[1,0,1,0,1], b=[1,1,1,1,0]
    // pos 0: same, pos 1: diff, pos 2: same, pos 3: diff, pos 4: diff => 3
    let a = Arr8 { v0: 1, v1: 0, v2: 1, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 1, v1: 1, v2: 1, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(hamming(a, b, 5), 3);
    // Same arrays: distance 0
    assert_eq(hamming(a, a, 5), 0);
    1
}

fn test_subsequence() -> Int {
    let sub = Arr8 { v0: 1, v1: 3, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let seq = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 0, v7: 0 };
    assert_eq(is_subsequence(sub, 3, seq, 6), 1);

    // Not a subsequence
    let bad = Arr8 { v0: 5, v1: 3, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_subsequence(bad, 3, seq, 6), 0);

    // Empty is always a subsequence
    assert_eq(is_subsequence(sub, 0, seq, 6), 1);
    1
}

fn test_triangle_inequality() -> Int {
    // Edit distance satisfies triangle inequality: d(a,c) <= d(a,b) + d(b,c)
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 1, v1: 4, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let c = Arr8 { v0: 5, v1: 4, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let dab = edit_distance(a, 3, b, 3);
    let dbc = edit_distance(b, 3, c, 3);
    let dac = edit_distance(a, 3, c, 3);
    let holds = if dac <= dab + dbc { 1 } else { 0 };
    assert_eq(holds, 1);
    // Also d(a,b) = d(b,a) (symmetry)
    let dba = edit_distance(b, 3, a, 3);
    assert_eq(dab, dba);
    1
}

fn main() -> Int {
    test_edit_distance();
    test_lcs();
    test_hamming_dist();
    test_subsequence();
    test_triangle_inequality();
    print("[OK] 584_edit_distance_aot");
    0
}
