// @test: run
// Higher-order functions: closures returning closures, composition

fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int) -> fn(Int) -> Int {
    |x: Int| -> Int { f(g(x)) }
}

fn make_multiplier(factor: Int) -> fn(Int) -> Int {
    |x: Int| -> Int { x * factor }
}

fn apply_list(items: List<Int>, f: fn(Int) -> Int) -> List<Int> {
    let mut result = List.new();
    let mut i = 0;
    while (i < items.len()) {
        result.push(f(items[i]));
        i = i + 1;
    }
    result
}

fn sum_list(items: List<Int>) -> Int {
    let mut total = 0;
    let mut i = 0;
    while (i < items.len()) {
        total = total + items[i];
        i = i + 1;
    }
    total
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    // Test 1: compose two functions
    let inc = |x: Int| -> Int { x + 1 };
    let double = |x: Int| -> Int { x * 2 };
    let inc_then_double = compose(double, inc);
    if (inc_then_double(5) == 12) { passed = passed + 1; }
    else { print(f"FAIL 1: {inc_then_double(5)}"); failed = failed + 1; }

    // Test 2: compose in other order
    let double_then_inc = compose(inc, double);
    if (double_then_inc(5) == 11) { passed = passed + 1; }
    else { print(f"FAIL 2: {double_then_inc(5)}"); failed = failed + 1; }

    // Test 3: closure factory
    let times3 = make_multiplier(3);
    let times5 = make_multiplier(5);
    if (times3(4) == 12 && times5(4) == 20) { passed = passed + 1; }
    else { print("FAIL 3"); failed = failed + 1; }

    // Test 4: apply_list with closure
    let nums = List.new();
    nums.push(1); nums.push(2); nums.push(3);
    let doubled = apply_list(nums, double);
    if (sum_list(doubled) == 12) { passed = passed + 1; }
    else { print(f"FAIL 4: sum={sum_list(doubled)}"); failed = failed + 1; }

    // Test 5: compose + apply_list
    let triple_inc = compose(inc, make_multiplier(3));
    let result = apply_list(nums, triple_inc);
    // [1*3+1, 2*3+1, 3*3+1] = [4, 7, 10]
    if (result.len() == 3 && result[0] == 4 && result[1] == 7 && result[2] == 10) { passed = passed + 1; }
    else { print(f"FAIL 5: [{result[0]},{result[1]},{result[2]}]"); failed = failed + 1; }

    if (failed > 0) {
        print(f"higher_order: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"higher_order: PASS ({passed}/{passed} tests)");
    0
}
