// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, activity-selection, greedy, scheduling, weighted
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for activity selection problem variants:
// 1. Classic greedy (maximize number of non-overlapping activities)
// 2. Weighted activity selection (maximize total weight via DP)
// 3. Minimum platforms needed (peak overlap count)
// Activities stored as parallel arrays of start, end, and weight.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int, len: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

fn a8_new(n: Int) -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: n }
}

fn a8_swap(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = a8_get(a, i);
    let vj = a8_get(a, j);
    a8_set(a8_set(a, i, vj), j, vi)
}

type Activities is { starts: Arr8, ends: Arr8, weights: Arr8, count: Int };

// Selection sort all arrays by end time
fn sort_by_end(act: Activities) -> Activities {
    let mut s = act.starts;
    let mut e = act.ends;
    let mut w = act.weights;
    let n = act.count;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if a8_get(e, j) < a8_get(e, min_idx) { min_idx = j; }
            j = j + 1;
        }
        if min_idx != i {
            s = a8_swap(s, i, min_idx);
            e = a8_swap(e, i, min_idx);
            w = a8_swap(w, i, min_idx);
        }
        i = i + 1;
    }
    Activities { starts: s, ends: e, weights: w, count: n }
}

// Classic greedy: maximize count of non-overlapping activities
fn greedy_select_count(act: Activities) -> Int {
    let sorted = sort_by_end(act);
    let n = sorted.count;
    if n == 0 { return 0; }
    let mut count = 1;
    let mut last_end = a8_get(sorted.ends, 0);
    let mut i = 1;
    while i < n {
        if a8_get(sorted.starts, i) >= last_end {
            count = count + 1;
            last_end = a8_get(sorted.ends, i);
        }
        i = i + 1;
    }
    count
}

// Return bitmask of selected activities (after sorting by end)
fn greedy_select_mask(act: Activities) -> Int {
    let sorted = sort_by_end(act);
    let n = sorted.count;
    if n == 0 { return 0; }
    let mut mask = 1; // select first
    let mut last_end = a8_get(sorted.ends, 0);
    let mut i = 1;
    while i < n {
        if a8_get(sorted.starts, i) >= last_end {
            let mut bit = 1;
            let mut p = 0;
            while p < i { bit = bit * 2; p = p + 1; }
            mask = mask + bit;
            last_end = a8_get(sorted.ends, i);
        }
        i = i + 1;
    }
    mask
}

// Find latest non-conflicting activity for activity i (sorted by end time)
// Returns index of latest activity that ends <= start of i, or -1
fn latest_non_conflict(sorted: Activities, i: Int) -> Int {
    let si = a8_get(sorted.starts, i);
    let mut best = -1;
    let mut j = i - 1;
    while j >= 0 {
        if a8_get(sorted.ends, j) <= si {
            best = j;
            j = -1; // break (since sorted, first found from right is latest)
        } else {
            j = j - 1;
        }
    }
    best
}

// Weighted activity selection via DP (sorted by end time)
// dp[i] = max weight using activities 0..i
fn weighted_select(act: Activities) -> Int {
    let sorted = sort_by_end(act);
    let n = sorted.count;
    if n == 0 { return 0; }
    let mut dp = a8_new(n);
    dp = a8_set(dp, 0, a8_get(sorted.weights, 0));
    let mut i = 1;
    while i < n {
        let include_weight = a8_get(sorted.weights, i);
        let p = latest_non_conflict(sorted, i);
        let include_total = if p == -1 { include_weight } else { include_weight + a8_get(dp, p) };
        let exclude_total = a8_get(dp, i - 1);
        let best = if include_total > exclude_total { include_total } else { exclude_total };
        dp = a8_set(dp, i, best);
        i = i + 1;
    }
    a8_get(dp, n - 1)
}

// Minimum platforms: count max overlap at any point
// Simple O(n^2) approach: for each time point (start or end), count active activities
fn min_platforms(act: Activities) -> Int {
    let n = act.count;
    let mut max_overlap = 0;
    // Check at each start time
    let mut i = 0;
    while i < n {
        let t = a8_get(act.starts, i);
        let mut overlap = 0;
        let mut j = 0;
        while j < n {
            let sj = a8_get(act.starts, j);
            let ej = a8_get(act.ends, j);
            if sj <= t {
                if ej > t { overlap = overlap + 1; }
            }
            j = j + 1;
        }
        if overlap > max_overlap { max_overlap = overlap; }
        i = i + 1;
    }
    max_overlap
}

fn test_classic_greedy() {
    // Activities: (1,3), (2,5), (4,7), (1,8), (5,9), (8,10)
    let s = Arr8 { a0: 1, a1: 2, a2: 4, a3: 1, a4: 5, a5: 8, a6: 0, a7: 0, len: 6 };
    let e = Arr8 { a0: 3, a1: 5, a2: 7, a3: 8, a4: 9, a5: 10, a6: 0, a7: 0, len: 6 };
    let w = Arr8 { a0: 1, a1: 1, a2: 1, a3: 1, a4: 1, a5: 1, a6: 0, a7: 0, len: 6 };
    let act = Activities { starts: s, ends: e, weights: w, count: 6 };
    // Optimal: (1,3), (4,7), (8,10) = 3
    assert_eq(greedy_select_count(act), 3);
}

fn test_all_disjoint() {
    // (0,1), (2,3), (4,5), (6,7)
    let s = Arr8 { a0: 0, a1: 2, a2: 4, a3: 6, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let e = Arr8 { a0: 1, a1: 3, a2: 5, a3: 7, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let w = Arr8 { a0: 1, a1: 1, a2: 1, a3: 1, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let act = Activities { starts: s, ends: e, weights: w, count: 4 };
    assert_eq(greedy_select_count(act), 4);
}

fn test_all_overlap() {
    // (0,10), (1,9), (2,8), (3,7)
    let s = Arr8 { a0: 0, a1: 1, a2: 2, a3: 3, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let e = Arr8 { a0: 10, a1: 9, a2: 8, a3: 7, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let w = Arr8 { a0: 1, a1: 1, a2: 1, a3: 1, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let act = Activities { starts: s, ends: e, weights: w, count: 4 };
    assert_eq(greedy_select_count(act), 1);
}

fn test_weighted_selection() {
    // Activities sorted by end: (1,3,w=5), (2,5,w=6), (4,7,w=5), (6,9,w=4), (8,10,w=11)
    // Greedy picks (1,3), (4,7), (8,10) = 3 activities, total weight 5+5+11=21
    // Weighted DP: (1,3,5) + (4,7,5) + (8,10,11) = 21
    // Or: (2,5,6) + (6,9,4) = 10 — worse
    // Or: (1,3,5) + (6,9,4) + skip = 9 — worse
    // Best is 21
    let s = Arr8 { a0: 1, a1: 2, a2: 4, a3: 6, a4: 8, a5: 0, a6: 0, a7: 0, len: 5 };
    let e = Arr8 { a0: 3, a1: 5, a2: 7, a3: 9, a4: 10, a5: 0, a6: 0, a7: 0, len: 5 };
    let w = Arr8 { a0: 5, a1: 6, a2: 5, a3: 4, a4: 11, a5: 0, a6: 0, a7: 0, len: 5 };
    let act = Activities { starts: s, ends: e, weights: w, count: 5 };
    assert_eq(weighted_select(act), 21);
}

fn test_weighted_prefer_heavy() {
    // (0,5,w=100), (1,3,w=10), (4,6,w=10)
    // Greedy count: (1,3) + (4,6) = 2 items, weight 20
    // Weighted: (0,5,100) alone = 100 > 20
    let s = Arr8 { a0: 0, a1: 1, a2: 4, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let e = Arr8 { a0: 5, a1: 3, a2: 6, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let w = Arr8 { a0: 100, a1: 10, a2: 10, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let act = Activities { starts: s, ends: e, weights: w, count: 3 };
    assert_eq(greedy_select_count(act), 2); // greedy picks 2 light ones
    assert_eq(weighted_select(act), 100);   // DP picks the heavy one
}

fn test_min_platforms() {
    // Trains: (1,3), (2,5), (4,7)
    // At t=2: trains (1,3) and (2,5) overlap -> 2 platforms
    let s = Arr8 { a0: 1, a1: 2, a2: 4, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let e = Arr8 { a0: 3, a1: 5, a2: 7, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let w = a8_new(3);
    let act = Activities { starts: s, ends: e, weights: w, count: 3 };
    assert_eq(min_platforms(act), 2);
}

fn test_min_platforms_all_overlap() {
    // (0,10), (0,10), (0,10), (0,10) -> need 4 platforms
    let s = Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let e = Arr8 { a0: 10, a1: 10, a2: 10, a3: 10, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let w = a8_new(4);
    let act = Activities { starts: s, ends: e, weights: w, count: 4 };
    assert_eq(min_platforms(act), 4);
}

fn test_selection_mask() {
    // (1,3), (2,5), (4,7), (8,10)
    // Sorted by end: same order. Greedy picks: (1,3), (4,7), (8,10) -> indices 0,2,3
    let s = Arr8 { a0: 1, a1: 2, a2: 4, a3: 8, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let e = Arr8 { a0: 3, a1: 5, a2: 7, a3: 10, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let w = a8_new(4);
    let act = Activities { starts: s, ends: e, weights: w, count: 4 };
    let mask = greedy_select_mask(act);
    // Bit 0 set (1), bit 2 set (4), bit 3 set (8) -> 1 + 4 + 8 = 13
    assert_eq(mask, 13);
}

fn test_single_activity() {
    let s = Arr8 { a0: 5, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 1 };
    let e = Arr8 { a0: 10, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 1 };
    let w = Arr8 { a0: 42, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 1 };
    let act = Activities { starts: s, ends: e, weights: w, count: 1 };
    assert_eq(greedy_select_count(act), 1);
    assert_eq(weighted_select(act), 42);
    assert_eq(min_platforms(act), 1);
}

fn main() -> Int {
    test_classic_greedy();
    test_all_disjoint();
    test_all_overlap();
    test_weighted_selection();
    test_weighted_prefer_heavy();
    test_min_platforms();
    test_min_platforms_all_overlap();
    test_selection_mask();
    test_single_activity();
    print("[OK] 336_activity_select_aot");
    0
}
