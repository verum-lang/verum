// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, bitwise, operators, bit-manipulation
// @timeout: 50000
// @expected-exit: 0
// @description: AOT bitwise operations and bit manipulation algorithms

fn count_ones(n: Int) -> Int {
    let mut x = n;
    let mut count = 0;
    while x != 0 {
        count = count + (x & 1);
        x = x >> 1;
    }
    count
}

fn is_power_of_2(n: Int) -> Bool {
    n > 0 && (n & (n - 1)) == 0
}

fn next_power_of_2(n: Int) -> Int {
    let mut p = 1;
    while p < n {
        p = p << 1;
    }
    p
}

fn highest_bit(n: Int) -> Int {
    let mut x = n;
    let mut pos = 0;
    while x > 1 {
        x = x >> 1;
        pos = pos + 1;
    }
    pos
}

fn reverse_bits_8(n: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    let mut x = n;
    while i < 8 {
        result = (result << 1) | (x & 1);
        x = x >> 1;
        i = i + 1;
    }
    result
}

fn swap_nibbles(n: Int) -> Int {
    // Swap upper and lower 4 bits of an 8-bit value
    ((n & 0xF0) >> 4) | ((n & 0x0F) << 4)
}

fn parity(n: Int) -> Int {
    // 0 if even number of 1-bits, 1 if odd
    count_ones(n) % 2
}

fn main() -> Int {
    // Basic bitwise
    assert_eq(5 & 3, 1);     // 101 & 011 = 001
    assert_eq(5 | 3, 7);     // 101 | 011 = 111
    assert_eq(5 ^ 3, 6);     // 101 ^ 011 = 110
    assert_eq(1 << 3, 8);    // 1 << 3 = 8
    assert_eq(16 >> 2, 4);   // 10000 >> 2 = 100

    // Count ones (popcount)
    assert_eq(count_ones(0), 0);
    assert_eq(count_ones(1), 1);
    assert_eq(count_ones(7), 3);     // 111
    assert_eq(count_ones(255), 8);   // 11111111
    assert_eq(count_ones(1023), 10); // 1111111111
    assert_eq(count_ones(170), 4);   // 10101010

    // Power of 2 checks
    assert(is_power_of_2(1));
    assert(is_power_of_2(2));
    assert(is_power_of_2(4));
    assert(is_power_of_2(8));
    assert(is_power_of_2(64));
    assert(is_power_of_2(1024));
    assert(!is_power_of_2(0));
    assert(!is_power_of_2(3));
    assert(!is_power_of_2(6));
    assert(!is_power_of_2(100));

    // Next power of 2
    assert_eq(next_power_of_2(1), 1);
    assert_eq(next_power_of_2(3), 4);
    assert_eq(next_power_of_2(5), 8);
    assert_eq(next_power_of_2(7), 8);
    assert_eq(next_power_of_2(9), 16);
    assert_eq(next_power_of_2(100), 128);

    // Highest bit position
    assert_eq(highest_bit(1), 0);
    assert_eq(highest_bit(2), 1);
    assert_eq(highest_bit(4), 2);
    assert_eq(highest_bit(8), 3);
    assert_eq(highest_bit(255), 7);
    assert_eq(highest_bit(1024), 10);

    // Reverse 8 bits
    assert_eq(reverse_bits_8(0), 0);
    assert_eq(reverse_bits_8(1), 128);   // 00000001 -> 10000000
    assert_eq(reverse_bits_8(128), 1);   // 10000000 -> 00000001
    assert_eq(reverse_bits_8(0xAA), 0x55);  // 10101010 -> 01010101
    assert_eq(reverse_bits_8(255), 255); // 11111111 -> 11111111

    // Swap nibbles
    assert_eq(swap_nibbles(0xAB), 0xBA);  // 0xAB=171, 0xBA=186
    assert_eq(swap_nibbles(0x12), 0x21);  // 0x12=18, 0x21=33
    assert_eq(swap_nibbles(0), 0);
    assert_eq(swap_nibbles(0xFF), 0xFF);  // FF -> FF

    // Parity
    assert_eq(parity(0), 0);
    assert_eq(parity(1), 1);
    assert_eq(parity(3), 0);     // 11 -> 2 ones -> even
    assert_eq(parity(7), 1);     // 111 -> 3 ones -> odd
    assert_eq(parity(255), 0);   // 8 ones -> even

    // XOR swap pattern
    let mut a = 42;
    let mut b = 99;
    a = a ^ b;
    b = a ^ b;
    a = a ^ b;
    assert_eq(a, 99);
    assert_eq(b, 42);

    // Bit mask operations
    let flags = 0b10110;  // bits 1, 2, 4 set
    assert_eq(flags & (1 << 1), 2);   // bit 1 set
    assert_eq(flags & (1 << 2), 4);   // bit 2 set
    assert_eq(flags & (1 << 3), 0);   // bit 3 not set
    assert_eq(flags & (1 << 4), 16);  // bit 4 set

    0
}
