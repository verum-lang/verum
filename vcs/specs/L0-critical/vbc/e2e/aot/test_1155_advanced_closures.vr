// @test: run
// @level: L0
// @tier: 1
// @tags: closure, higher-order, capture, functional
// @description: Test advanced closure patterns - returning closures, closure composition

fn make_adder_fn(base: Int) -> fn(Int) -> Int {
    |x: Int| -> Int { x + base }
}

fn test_closure_factory() -> Int {
    let add5 = make_adder_fn(5);
    let add10 = make_adder_fn(10);
    let a = add5(3);
    let b = add10(3);
    if a != 8 || b != 13 {
        print(f"FAIL factory: {a}, {b}");
        return 1;
    }
    print("  closure_factory: OK");
    0
}

fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int {
    f(f(x))
}

fn test_apply_twice() -> Int {
    let double = |x: Int| -> Int { x * 2 };
    let result = apply_twice(double, 3);
    // 3 -> 6 -> 12
    if result != 12 {
        print(f"FAIL apply_twice: {result}, expected 12");
        return 1;
    }
    print("  apply_twice: OK");
    0
}

fn fold(items: List<Int>, init: Int, f: fn(Int, Int) -> Int) -> Int {
    let mut acc = init;
    let mut i = 0;
    while i < items.len() {
        acc = f(acc, items[i]);
        i = i + 1;
    }
    acc
}

fn test_fold() -> Int {
    let mut nums = List.new();
    nums.push(1);
    nums.push(2);
    nums.push(3);
    nums.push(4);
    nums.push(5);

    let sum = fold(nums, 0, |a: Int, b: Int| -> Int { a + b });
    if sum != 15 {
        print(f"FAIL fold_sum: {sum}, expected 15");
        return 1;
    }
    print("  fold: OK");
    0
}

fn test_closure_capture_val() -> Int {
    let multiplier = 10;
    let mul = |x: Int| -> Int { x * multiplier };
    let result = mul(7);
    if result != 70 {
        print(f"FAIL capture_val: {result}, expected 70");
        return 1;
    }
    print("  closure_capture: OK");
    0
}

fn main() -> Int {
    print("Advanced Closure Tests:");
    let mut failures = 0;
    failures = failures + test_closure_factory();
    failures = failures + test_apply_twice();
    failures = failures + test_fold();
    failures = failures + test_closure_capture_val();

    if failures == 0 {
        print("All advanced closure tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
