// @test: run
// @level: L0
// @tags: aot, e2e, crc, checksum, hash
// @timeout: 30000

// CRC and checksum algorithms

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

// Simple checksum: sum of all bytes
fn checksum_sum(data: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        sum = sum + get8(data, i);
        i = i + 1;
    }
    sum
}

// XOR checksum
fn checksum_xor(data: Arr8, n: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < n {
        let v = get8(data, i);
        // XOR using: a^b = (a+b) - 2*(a AND b)
        // For simplicity, use bit-by-bit XOR
        let mut xor = 0;
        let mut bit = 1;
        let mut rr = result;
        let mut vv = v;
        let mut b_count = 0;
        while b_count < 16 {
            let rb = rr % 2;
            let vb = vv % 2;
            if rb != vb { xor = xor + bit; }
            bit = bit * 2;
            rr = rr / 2;
            vv = vv / 2;
            b_count = b_count + 1;
        }
        result = xor;
        i = i + 1;
    }
    result
}

// Fletcher-16 style checksum (simplified, mod 255)
fn fletcher16(data: Arr8, n: Int) -> Int {
    let mut sum1 = 0;
    let mut sum2 = 0;
    let mut i = 0;
    while i < n {
        sum1 = (sum1 + get8(data, i)) % 255;
        sum2 = (sum2 + sum1) % 255;
        i = i + 1;
    }
    sum2 * 256 + sum1
}

// Adler-32 style (simplified, mod 65521)
fn adler32(data: Arr8, n: Int) -> Int {
    let mut a = 1;
    let mut b = 0;
    let mut i = 0;
    while i < n {
        a = (a + get8(data, i)) % 65521;
        b = (b + a) % 65521;
        i = i + 1;
    }
    b * 65536 + a
}

// Simple polynomial hash
fn poly_hash(data: Arr8, n: Int, base: Int, modulus: Int) -> Int {
    let mut hash = 0;
    let mut i = 0;
    while i < n {
        hash = (hash * base + get8(data, i)) % modulus;
        i = i + 1;
    }
    hash
}

// Luhn algorithm (credit card check digit)
fn luhn_check(digits: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut alt = 0;
    let mut i = n - 1;
    while i >= 0 {
        let mut d = get8(digits, i);
        if alt == 1 {
            d = d * 2;
            if d > 9 { d = d - 9; }
        }
        sum = sum + d;
        alt = 1 - alt;
        i = i - 1;
    }
    if sum % 10 == 0 { 1 } else { 0 }
}

fn test_checksum() -> Int {
    let data = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(checksum_sum(data, 5), 15);

    // XOR: 1^2^3^4^5 = 1^2=3, 3^3=0, 0^4=4, 4^5=1
    assert_eq(checksum_xor(data, 5), 1);

    // All zeros
    let z = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(checksum_sum(z, 8), 0);
    assert_eq(checksum_xor(z, 8), 0);
    1
}

fn test_fletcher() -> Int {
    let data = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // sum1: 1, 3, 6
    // sum2: 1, 4, 10
    let f = fletcher16(data, 3);
    assert_eq(f % 256, 6);   // sum1
    assert_eq(f / 256, 10);  // sum2

    // Different data should give different checksum
    let data2 = Arr8 { v0: 3, v1: 2, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let f2 = fletcher16(data2, 3);
    // sum1: 3, 5, 6 -> same sum1!
    // sum2: 3, 8, 14 -> different sum2
    assert_eq(f2 % 256, 6);
    assert_eq(f2 / 256, 14);
    1
}

fn test_poly_hash() -> Int {
    let data = Arr8 { v0: 72, v1: 101, v2: 108, v3: 108, v4: 111, v5: 0, v6: 0, v7: 0 };
    let h1 = poly_hash(data, 5, 31, 1000000007);
    let h2 = poly_hash(data, 5, 37, 1000000007);
    // Different bases should give different hashes
    assert(h1 != h2);

    // Same data, same params = same hash
    let h3 = poly_hash(data, 5, 31, 1000000007);
    assert_eq(h1, h3);
    1
}

fn test_luhn() -> Int {
    // Valid: 4 9 9 2 7 3 9 8 (Luhn check passes)
    // Let's compute manually: from right:
    // 8,9*2=9,3,7*2=5,2,9*2=9,9,4*2=8
    // Wait, let me use a known example
    // Number: 7 9 9 2 7 3 9 8 7 1 → we only have 8 elements
    // Let's use: 0 (check digit placeholder)
    // Simple: 1 7 8 →
    // Actually let's just verify: 0 digits
    // Use known: [4,5,3,9,1,4,8,0] — manually compute
    // i=7: d=0, alt=0, sum=0
    // i=6: d=8, alt=1, d=16->7, sum=7
    // i=5: d=4, alt=0, sum=11
    // i=4: d=1, alt=1, d=2, sum=13
    // i=3: d=9, alt=0, sum=22
    // i=2: d=3, alt=1, d=6, sum=28
    // i=1: d=5, alt=0, sum=33
    // i=0: d=4, alt=1, d=8, sum=41
    // 41 % 10 = 1, not valid

    // Let me use a sequence that sums to 0 mod 10
    // [7, 9, 9, 2, 7, 3, 9, 8] — compute:
    // i=7: 8, alt=0, sum=8
    // i=6: 9, alt=1, 18->9, sum=17
    // i=5: 3, alt=0, sum=20
    // i=4: 7, alt=1, 14->5, sum=25
    // i=3: 2, alt=0, sum=27
    // i=2: 9, alt=1, 18->9, sum=36
    // i=1: 9, alt=0, sum=45
    // i=0: 7, alt=1, 14->5, sum=50
    // 50 % 10 = 0, valid!
    let valid = Arr8 { v0: 7, v1: 9, v2: 9, v3: 2, v4: 7, v5: 3, v6: 9, v7: 8 };
    assert_eq(luhn_check(valid, 8), 1);

    // Change one digit: should fail
    let invalid = Arr8 { v0: 7, v1: 9, v2: 9, v3: 2, v4: 7, v5: 3, v6: 9, v7: 9 };
    assert_eq(luhn_check(invalid, 8), 0);
    1
}

fn main() -> Int {
    test_checksum();
    test_fletcher();
    test_poly_hash();
    test_luhn();
    print("[OK] 463_crc_checksum_aot");
    0
}
