// @test: run
// @level: L0
// @tags: aot, e2e, milestone, comprehensive, statistics
// @timeout: 30000

// Milestone 590: Basic statistics and data analysis

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// Sort array (insertion sort)
fn sort_arr(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 1;
    while i < n {
        let key = get8(a, i);
        let mut j = i - 1;
        while j >= 0 {
            if get8(a, j) > key {
                a = set8(a, j + 1, get8(a, j));
                j = j - 1;
            } else {
                j = j - 100; // break
            }
        }
        if j < 0 - 1 { j = j + 100; }
        a = set8(a, j + 1, key);
        i = i + 1;
    }
    a
}

// Sum of array
fn arr_sum(arr: Arr8, n: Int) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < n { s = s + get8(arr, i); i = i + 1; }
    s
}

// Mean * n (to avoid division rounding)
fn arr_mean_n(arr: Arr8, n: Int) -> Int {
    arr_sum(arr, n)
}

// Median (for sorted array)
fn arr_median_2x(sorted: Arr8, n: Int) -> Int {
    // Return 2*median to avoid fractions
    if n % 2 == 1 {
        2 * get8(sorted, n / 2)
    } else {
        get8(sorted, n / 2 - 1) + get8(sorted, n / 2)
    }
}

// Mode (most frequent value) — assumes sorted
fn arr_mode(sorted: Arr8, n: Int) -> Int {
    let mut best_val = get8(sorted, 0);
    let mut best_count = 1;
    let mut cur_val = get8(sorted, 0);
    let mut cur_count = 1;
    let mut i = 1;
    while i < n {
        if get8(sorted, i) == cur_val {
            cur_count = cur_count + 1;
        } else {
            if cur_count > best_count {
                best_val = cur_val;
                best_count = cur_count;
            }
            cur_val = get8(sorted, i);
            cur_count = 1;
        }
        i = i + 1;
    }
    if cur_count > best_count { cur_val } else { best_val }
}

// Min and max
fn arr_min(arr: Arr8, n: Int) -> Int {
    let mut m = get8(arr, 0);
    let mut i = 1;
    while i < n {
        if get8(arr, i) < m { m = get8(arr, i); }
        i = i + 1;
    }
    m
}

fn arr_max(arr: Arr8, n: Int) -> Int {
    let mut m = get8(arr, 0);
    let mut i = 1;
    while i < n {
        if get8(arr, i) > m { m = get8(arr, i); }
        i = i + 1;
    }
    m
}

// Variance * n^2 (to stay in integers)
// Var = sum((x_i - mean)^2) / n = (n*sum(x_i^2) - (sum(x_i))^2) / n^2
fn arr_var_n2(arr: Arr8, n: Int) -> Int {
    let mut sum_sq = 0;
    let mut sum1 = 0;
    let mut i = 0;
    while i < n {
        let v = get8(arr, i);
        sum_sq = sum_sq + v * v;
        sum1 = sum1 + v;
        i = i + 1;
    }
    n * sum_sq - sum1 * sum1
}

// Mean absolute deviation * n (to stay in integers)
fn arr_mad_n(arr: Arr8, n: Int) -> Int {
    let sum1 = arr_sum(arr, n);
    // mean = sum/n, so |x_i - mean|*n = |x_i*n - sum|
    let mut total = 0;
    let mut i = 0;
    while i < n {
        total = total + abs_val(get8(arr, i) * n - sum1);
        i = i + 1;
    }
    total
}

// Percentile rank of value in sorted array
fn percentile_rank(sorted: Arr8, n: Int, val: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(sorted, i) < val { count = count + 1; }
        i = i + 1;
    }
    // Return count * 100 / n (percentage, integer)
    count * 100 / n
}

fn test_sum_mean() -> Int {
    let data = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 0, v6: 0, v7: 0 };
    assert_eq(arr_sum(data, 5), 150);
    // Mean = 150/5 = 30
    assert_eq(arr_sum(data, 5) / 5, 30);
    1
}

fn test_median() -> Int {
    // Odd count: [1, 3, 5, 7, 9] -> median = 5
    let odd = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 9, v5: 0, v6: 0, v7: 0 };
    assert_eq(arr_median_2x(odd, 5), 10); // 2*5

    // Even count: [1, 3, 5, 7] -> median = (3+5)/2 = 4, 2x = 8
    let even = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(arr_median_2x(even, 4), 8);
    1
}

fn test_mode() -> Int {
    // [1, 2, 2, 3, 3, 3, 4] -> mode = 3
    let data = Arr8 { v0: 1, v1: 2, v2: 2, v3: 3, v4: 3, v5: 3, v6: 4, v7: 0 };
    assert_eq(arr_mode(data, 7), 3);

    // [5, 5, 5, 5] -> mode = 5
    let all5 = Arr8 { v0: 5, v1: 5, v2: 5, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(arr_mode(all5, 4), 5);
    1
}

fn test_min_max() -> Int {
    let data = Arr8 { v0: 30, v1: 10, v2: 50, v3: 20, v4: 40, v5: 0, v6: 0, v7: 0 };
    assert_eq(arr_min(data, 5), 10);
    assert_eq(arr_max(data, 5), 50);
    // Range = max - min
    assert_eq(arr_max(data, 5) - arr_min(data, 5), 40);
    1
}

fn test_variance() -> Int {
    // [2, 4, 4, 4, 5, 5, 7, 9] -> mean = 5, var = 4
    let data = Arr8 { v0: 2, v1: 4, v2: 4, v3: 4, v4: 5, v5: 5, v6: 7, v7: 9 };
    // n=8, sum=40, sum_sq=232
    // var*n^2 = 8*232 - 40^2 = 1856 - 1600 = 256
    assert_eq(arr_var_n2(data, 8), 256);
    // var = 256/64 = 4
    assert_eq(arr_var_n2(data, 8) / (8 * 8), 4);
    1
}

fn test_sort_and_stats() -> Int {
    let data = Arr8 { v0: 50, v1: 10, v2: 40, v3: 30, v4: 20, v5: 0, v6: 0, v7: 0 };
    let sorted = sort_arr(data, 5);
    assert_eq(get8(sorted, 0), 10);
    assert_eq(get8(sorted, 4), 50);
    // Median of sorted [10, 20, 30, 40, 50] = 30
    assert_eq(arr_median_2x(sorted, 5), 60); // 2*30
    1
}

fn test_percentile() -> Int {
    let sorted = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 50, v5: 60, v6: 70, v7: 80 };
    // 25 is above 10 and 20 -> 2 out of 8 -> 25%
    assert_eq(percentile_rank(sorted, 8, 25), 25);
    // 55 is above 5 values -> 5/8*100 = 62%
    assert_eq(percentile_rank(sorted, 8, 55), 62);
    // 5 is above 0 values -> 0%
    assert_eq(percentile_rank(sorted, 8, 5), 0);
    1
}

fn main() -> Int {
    test_sum_mean();
    test_median();
    test_mode();
    test_min_max();
    test_variance();
    test_sort_and_stats();
    test_percentile();
    print("[OK] 590_milestone_aot");
    0
}
