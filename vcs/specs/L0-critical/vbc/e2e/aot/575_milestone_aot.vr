// @test: run
// @level: L0
// @tags: aot, e2e, milestone, comprehensive, geometry
// @timeout: 30000

// Milestone 575: Computational geometry and distance functions

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Integer square root
fn isqrt(n: Int) -> Int {
    if n <= 0 { return 0; }
    let mut x = n;
    let mut y = (x + 1) / 2;
    while y < x { x = y; y = (x + n / x) / 2; }
    x
}

// Points stored as packed x*1000 + y
fn pt_x(p: Int) -> Int { p / 1000 }
fn pt_y(p: Int) -> Int { p % 1000 }
fn make_pt(x: Int, y: Int) -> Int { x * 1000 + y }

// Manhattan distance
fn manhattan(p1: Int, p2: Int) -> Int {
    abs_val(pt_x(p1) - pt_x(p2)) + abs_val(pt_y(p1) - pt_y(p2))
}

// Euclidean distance squared (to avoid sqrt)
fn dist_sq(p1: Int, p2: Int) -> Int {
    let dx = pt_x(p1) - pt_x(p2);
    let dy = pt_y(p1) - pt_y(p2);
    dx * dx + dy * dy
}

// Chebyshev distance (max of |dx|, |dy|)
fn chebyshev(p1: Int, p2: Int) -> Int {
    max_val(abs_val(pt_x(p1) - pt_x(p2)), abs_val(pt_y(p1) - pt_y(p2)))
}

// Cross product of vectors (p1→p2) x (p1→p3)
fn cross_product(p1: Int, p2: Int, p3: Int) -> Int {
    (pt_x(p2) - pt_x(p1)) * (pt_y(p3) - pt_y(p1)) -
    (pt_y(p2) - pt_y(p1)) * (pt_x(p3) - pt_x(p1))
}

// Check if point is inside triangle (using cross products)
fn point_in_triangle(p: Int, a: Int, b: Int, c: Int) -> Int {
    let d1 = cross_product(a, b, p);
    let d2 = cross_product(b, c, p);
    let d3 = cross_product(c, a, p);
    let has_neg = if d1 < 0 { 1 } else if d2 < 0 { 1 } else if d3 < 0 { 1 } else { 0 };
    let has_pos = if d1 > 0 { 1 } else if d2 > 0 { 1 } else if d3 > 0 { 1 } else { 0 };
    if has_neg == 1 {
        if has_pos == 1 { 0 } else { 1 }
    } else { 1 }
}

// Polygon area (Shoelace formula) * 2 (to stay in integers)
fn polygon_area_2x(points: Arr8, n: Int) -> Int {
    let mut area = 0;
    let mut i = 0;
    while i < n {
        let j = (i + 1) % n;
        let pi = get8(points, i);
        let pj = get8(points, j);
        area = area + pt_x(pi) * pt_y(pj) - pt_x(pj) * pt_y(pi);
        i = i + 1;
    }
    abs_val(area)
}

// Closest pair of points (brute force, returns distance squared)
fn closest_pair_sq(points: Arr8, n: Int) -> Int {
    let mut best = 999999;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            let d = dist_sq(get8(points, i), get8(points, j));
            if d < best { best = d; }
            j = j + 1;
        }
        i = i + 1;
    }
    best
}

fn test_distances() -> Int {
    let p1 = make_pt(0, 0);
    let p2 = make_pt(3, 4);
    assert_eq(manhattan(p1, p2), 7);   // |3|+|4|
    assert_eq(dist_sq(p1, p2), 25);    // 9+16
    assert_eq(chebyshev(p1, p2), 4);   // max(3,4)

    let p3 = make_pt(1, 1);
    let p4 = make_pt(4, 5);
    assert_eq(manhattan(p3, p4), 7);
    assert_eq(dist_sq(p3, p4), 25);
    1
}

fn test_cross_product() -> Int {
    let origin = make_pt(0, 0);
    let px = make_pt(1, 0);
    let py = make_pt(0, 1);

    // Cross product of (1,0) x (0,1) = 1 (counterclockwise)
    assert_eq(cross_product(origin, px, py), 1);
    // Cross product of (0,1) x (1,0) = -1 (clockwise)
    assert_eq(cross_product(origin, py, px), 0 - 1);

    // Collinear points: cross = 0
    let p2 = make_pt(2, 0);
    assert_eq(cross_product(origin, px, p2), 0);
    1
}

fn test_triangle() -> Int {
    let a = make_pt(0, 0);
    let b = make_pt(10, 0);
    let c = make_pt(0, 10);

    // Point inside triangle
    assert_eq(point_in_triangle(make_pt(2, 2), a, b, c), 1);
    // Point outside triangle
    assert_eq(point_in_triangle(make_pt(10, 10), a, b, c), 0);
    // Point on vertex
    assert_eq(point_in_triangle(a, a, b, c), 1);
    1
}

fn test_polygon_area() -> Int {
    // Square: (0,0), (4,0), (4,4), (0,4) → area = 16, 2x = 32
    let sq = Arr8 { v0: 0, v1: make_pt(4, 0), v2: make_pt(4, 4), v3: make_pt(0, 4),
                    v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(polygon_area_2x(sq, 4), 32);

    // Triangle: (0,0), (6,0), (0,8) → area = 24, 2x = 48
    let tri = Arr8 { v0: 0, v1: make_pt(6, 0), v2: make_pt(0, 8), v3: 0,
                     v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(polygon_area_2x(tri, 3), 48);
    1
}

fn test_closest_pair() -> Int {
    // Points: (0,0), (3,4), (1,0), (10,10)
    let pts = Arr8 { v0: make_pt(0, 0), v1: make_pt(3, 4), v2: make_pt(1, 0), v3: make_pt(10, 10),
                     v4: 0, v5: 0, v6: 0, v7: 0 };
    // Closest: (0,0)-(1,0) = distance^2 = 1
    assert_eq(closest_pair_sq(pts, 4), 1);
    1
}

fn main() -> Int {
    test_distances();
    test_cross_product();
    test_triangle();
    test_polygon_area();
    test_closest_pair();
    print("[OK] 575_milestone_aot");
    0
}
