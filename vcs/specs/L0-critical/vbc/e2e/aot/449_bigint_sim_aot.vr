// @test: run
// @level: L0
// @tags: aot, e2e, bigint, arithmetic
// @timeout: 30000

// Big integer simulation: store numbers as base-1000 digits (max 4 digits = 12 decimal digits)

type BigInt4 is { d0: Int, d1: Int, d2: Int, d3: Int };
// Number = d0 + d1*1000 + d2*1000000 + d3*1000000000

fn bigint_from(n: Int) -> BigInt4 {
    BigInt4 {
        d0: n % 1000,
        d1: (n / 1000) % 1000,
        d2: (n / 1000000) % 1000,
        d3: (n / 1000000000) % 1000
    }
}

fn bigint_to(b: BigInt4) -> Int {
    b.d0 + b.d1 * 1000 + b.d2 * 1000000 + b.d3 * 1000000000
}

fn bigint_add(a: BigInt4, b: BigInt4) -> BigInt4 {
    let s0 = a.d0 + b.d0;
    let c0 = s0 / 1000;
    let r0 = s0 % 1000;

    let s1 = a.d1 + b.d1 + c0;
    let c1 = s1 / 1000;
    let r1 = s1 % 1000;

    let s2 = a.d2 + b.d2 + c1;
    let c2 = s2 / 1000;
    let r2 = s2 % 1000;

    let s3 = a.d3 + b.d3 + c2;
    let r3 = s3 % 1000;

    BigInt4 { d0: r0, d1: r1, d2: r2, d3: r3 }
}

fn bigint_sub(a: BigInt4, b: BigInt4) -> BigInt4 {
    let mut borrow = 0;
    let s0 = a.d0 - b.d0 - borrow;
    let mut r0 = s0;
    if r0 < 0 { r0 = r0 + 1000; borrow = 1; } else { borrow = 0; }

    let s1 = a.d1 - b.d1 - borrow;
    let mut r1 = s1;
    if r1 < 0 { r1 = r1 + 1000; borrow = 1; } else { borrow = 0; }

    let s2 = a.d2 - b.d2 - borrow;
    let mut r2 = s2;
    if r2 < 0 { r2 = r2 + 1000; borrow = 1; } else { borrow = 0; }

    let s3 = a.d3 - b.d3 - borrow;
    let mut r3 = s3;
    if r3 < 0 { r3 = r3 + 1000; } // underflow

    BigInt4 { d0: r0, d1: r1, d2: r2, d3: r3 }
}

// Multiply by small constant (single digit)
fn bigint_mul_small(a: BigInt4, k: Int) -> BigInt4 {
    let s0 = a.d0 * k;
    let c0 = s0 / 1000;
    let r0 = s0 % 1000;

    let s1 = a.d1 * k + c0;
    let c1 = s1 / 1000;
    let r1 = s1 % 1000;

    let s2 = a.d2 * k + c1;
    let c2 = s2 / 1000;
    let r2 = s2 % 1000;

    let s3 = a.d3 * k + c2;
    let r3 = s3 % 1000;

    BigInt4 { d0: r0, d1: r1, d2: r2, d3: r3 }
}

fn bigint_is_zero(a: BigInt4) -> Int {
    if a.d0 == 0 {
        if a.d1 == 0 {
            if a.d2 == 0 {
                if a.d3 == 0 { 1 } else { 0 }
            } else { 0 }
        } else { 0 }
    } else { 0 }
}

fn bigint_eq(a: BigInt4, b: BigInt4) -> Int {
    if a.d0 == b.d0 {
        if a.d1 == b.d1 {
            if a.d2 == b.d2 {
                if a.d3 == b.d3 { 1 } else { 0 }
            } else { 0 }
        } else { 0 }
    } else { 0 }
}

fn test_roundtrip() -> Int {
    assert_eq(bigint_to(bigint_from(0)), 0);
    assert_eq(bigint_to(bigint_from(42)), 42);
    assert_eq(bigint_to(bigint_from(999)), 999);
    assert_eq(bigint_to(bigint_from(1000)), 1000);
    assert_eq(bigint_to(bigint_from(123456)), 123456);
    assert_eq(bigint_to(bigint_from(999999999)), 999999999);
    1
}

fn test_add() -> Int {
    let a = bigint_from(999);
    let b = bigint_from(1);
    assert_eq(bigint_to(bigint_add(a, b)), 1000);

    let c = bigint_from(999999);
    let d = bigint_from(1);
    assert_eq(bigint_to(bigint_add(c, d)), 1000000);

    let e = bigint_from(123456);
    let f = bigint_from(654321);
    assert_eq(bigint_to(bigint_add(e, f)), 777777);
    1
}

fn test_sub() -> Int {
    let a = bigint_from(1000);
    let b = bigint_from(1);
    assert_eq(bigint_to(bigint_sub(a, b)), 999);

    let c = bigint_from(1000000);
    let d = bigint_from(1);
    assert_eq(bigint_to(bigint_sub(c, d)), 999999);
    1
}

fn test_mul_small() -> Int {
    let a = bigint_from(333);
    assert_eq(bigint_to(bigint_mul_small(a, 3)), 999);

    let b = bigint_from(123456);
    assert_eq(bigint_to(bigint_mul_small(b, 2)), 246912);

    let c = bigint_from(500000);
    assert_eq(bigint_to(bigint_mul_small(c, 2)), 1000000);
    1
}

fn test_eq_zero() -> Int {
    assert_eq(bigint_is_zero(bigint_from(0)), 1);
    assert_eq(bigint_is_zero(bigint_from(1)), 0);
    assert_eq(bigint_eq(bigint_from(42), bigint_from(42)), 1);
    assert_eq(bigint_eq(bigint_from(42), bigint_from(43)), 0);
    1
}

fn main() -> Int {
    test_roundtrip();
    test_add();
    test_sub();
    test_mul_small();
    test_eq_zero();
    print("[OK] 449_bigint_sim_aot");
    0
}
