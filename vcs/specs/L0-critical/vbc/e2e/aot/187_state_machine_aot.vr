// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, state-machine, enum, variants
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for state machine pattern using sum types

// Traffic light state machine
fn next_light(state: Int) -> Int {
    // 0=Red, 1=Green, 2=Yellow
    if state == 0 { 1 }       // Red -> Green
    else if state == 1 { 2 }  // Green -> Yellow
    else { 0 }                // Yellow -> Red
}

fn run_traffic(steps: Int) -> Int {
    let mut state = 0;  // Start at Red
    let mut i = 0;
    while i < steps {
        state = next_light(state);
        i = i + 1;
    }
    state
}

// Simple stack machine (RPN calculator)
fn stack_push(s0: Int, s1: Int, s2: Int, s3: Int, sp: Int, val: Int) -> Int {
    // Returns new sp; caller must track stack values
    sp + 1
}

fn rpn_eval() -> Int {
    // Evaluate: 3 4 + 2 * = (3+4)*2 = 14
    // Using explicit stack variables
    let mut s0 = 0; let mut s1 = 0; let mut s2 = 0; let mut s3 = 0;
    let mut sp = 0;

    // Push 3
    s0 = 3; sp = 1;
    // Push 4
    s1 = 4; sp = 2;
    // Add: pop two, push sum
    s0 = s0 + s1; sp = 1;
    // Push 2
    s1 = 2; sp = 2;
    // Multiply: pop two, push product
    s0 = s0 * s1; sp = 1;

    s0
}

fn rpn_eval2() -> Int {
    // Evaluate: 5 1 2 + 4 * + 3 - = 5 + ((1+2)*4) - 3 = 14
    let mut s0 = 0; let mut s1 = 0; let mut s2 = 0; let mut sp = 0;

    // Push 5
    s0 = 5; sp = 1;
    // Push 1
    s1 = 1; sp = 2;
    // Push 2
    s2 = 2; sp = 3;
    // Add: pop s2 and s1
    s1 = s1 + s2; sp = 2;
    // Push 4
    s2 = 4; sp = 3;
    // Mul: pop s2 and s1
    s1 = s1 * s2; sp = 2;
    // Add: pop s1 and s0
    s0 = s0 + s1; sp = 1;
    // Push 3
    s1 = 3; sp = 2;
    // Sub: pop s1 from s0
    s0 = s0 - s1; sp = 1;

    s0
}

// Simple counter with modes
fn counter_step(value: Int, mode: Int) -> Int {
    // mode: 0=increment, 1=decrement, 2=double, 3=reset
    if mode == 0 { value + 1 }
    else if mode == 1 { value - 1 }
    else if mode == 2 { value * 2 }
    else { 0 }
}

fn main() -> Int {
    // Traffic light
    assert_eq(run_traffic(0), 0);   // Still Red
    assert_eq(run_traffic(1), 1);   // Green
    assert_eq(run_traffic(2), 2);   // Yellow
    assert_eq(run_traffic(3), 0);   // Red (full cycle)
    assert_eq(run_traffic(6), 0);   // Red (2 full cycles)
    assert_eq(run_traffic(7), 1);   // Green

    // RPN calculator
    assert_eq(rpn_eval(), 14);
    assert_eq(rpn_eval2(), 14);

    // Counter modes
    assert_eq(counter_step(5, 0), 6);   // increment
    assert_eq(counter_step(5, 1), 4);   // decrement
    assert_eq(counter_step(5, 2), 10);  // double
    assert_eq(counter_step(5, 3), 0);   // reset

    // Sequential counter operations
    let mut v = 0;
    v = counter_step(v, 0);  // 1
    v = counter_step(v, 0);  // 2
    v = counter_step(v, 2);  // 4
    v = counter_step(v, 0);  // 5
    v = counter_step(v, 2);  // 10
    v = counter_step(v, 1);  // 9
    assert_eq(v, 9);

    print("[OK] 187_state_machine_aot");
    0
}
