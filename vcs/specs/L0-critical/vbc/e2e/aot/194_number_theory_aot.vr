// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, math, number-theory
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for number theory algorithms

fn abs(x: Int) -> Int {
    if x < 0 { -x } else { x }
}

fn gcd(a: Int, b: Int) -> Int {
    let mut x = abs(a);
    let mut y = abs(b);
    while y != 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

fn lcm(a: Int, b: Int) -> Int {
    if a == 0 { return 0; }
    if b == 0 { return 0; }
    abs(a) / gcd(a, b) * abs(b)
}

fn is_prime(n: Int) -> Bool {
    if n < 2 { return false; }
    if n < 4 { return true; }
    if n % 2 == 0 { return false; }
    if n % 3 == 0 { return false; }
    let mut i = 5;
    while i * i <= n {
        if n % i == 0 { return false; }
        if n % (i + 2) == 0 { return false; }
        i = i + 6;
    }
    true
}

fn count_divisors(n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i * i <= n {
        if n % i == 0 {
            count = count + 1;
            if i != n / i { count = count + 1; }
        }
        i = i + 1;
    }
    count
}

fn sum_divisors(n: Int) -> Int {
    let mut sum = 0;
    let mut i = 1;
    while i * i <= n {
        if n % i == 0 {
            sum = sum + i;
            if i != n / i { sum = sum + n / i; }
        }
        i = i + 1;
    }
    sum
}

fn is_perfect(n: Int) -> Bool {
    if n < 2 { return false; }
    sum_divisors(n) - n == n
}

fn fibonacci(n: Int) -> Int {
    if n <= 1 { return n; }
    let mut a = 0;
    let mut b = 1;
    let mut i = 2;
    while i <= n {
        let t = a + b;
        a = b;
        b = t;
        i = i + 1;
    }
    b
}

fn modpow(base: Int, exp: Int, modulus: Int) -> Int {
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % modulus;
        }
        e = e / 2;
        b = (b * b) % modulus;
    }
    result
}

fn test_gcd_lcm() {
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(54, 24), 6);
    assert_eq(gcd(17, 13), 1);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(0, 5), 5);
    assert_eq(gcd(7, 0), 7);

    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(3, 5), 15);
    assert_eq(lcm(12, 18), 36);
    assert_eq(lcm(0, 5), 0);
}

fn test_primes() {
    assert_eq(is_prime(2), true);
    assert_eq(is_prime(3), true);
    assert_eq(is_prime(5), true);
    assert_eq(is_prime(7), true);
    assert_eq(is_prime(11), true);
    assert_eq(is_prime(13), true);
    assert_eq(is_prime(4), false);
    assert_eq(is_prime(9), false);
    assert_eq(is_prime(15), false);
    assert_eq(is_prime(1), false);
    assert_eq(is_prime(0), false);
    assert_eq(is_prime(97), true);
    assert_eq(is_prime(100), false);
}

fn test_divisors() {
    assert_eq(count_divisors(1), 1);
    assert_eq(count_divisors(6), 4);     // 1,2,3,6
    assert_eq(count_divisors(12), 6);    // 1,2,3,4,6,12
    assert_eq(count_divisors(7), 2);     // 1,7 (prime)
    assert_eq(count_divisors(36), 9);    // 1,2,3,4,6,9,12,18,36

    assert_eq(sum_divisors(6), 12);      // 1+2+3+6
    assert_eq(sum_divisors(12), 28);     // 1+2+3+4+6+12
    assert_eq(sum_divisors(1), 1);
}

fn test_perfect_numbers() {
    assert_eq(is_perfect(6), true);      // 1+2+3 = 6
    assert_eq(is_perfect(28), true);     // 1+2+4+7+14 = 28
    assert_eq(is_perfect(12), false);
    assert_eq(is_perfect(496), true);
}

fn test_fibonacci() {
    assert_eq(fibonacci(0), 0);
    assert_eq(fibonacci(1), 1);
    assert_eq(fibonacci(2), 1);
    assert_eq(fibonacci(5), 5);
    assert_eq(fibonacci(10), 55);
    assert_eq(fibonacci(20), 6765);
}

fn test_modpow() {
    assert_eq(modpow(2, 10, 1000), 24);     // 1024 % 1000
    assert_eq(modpow(3, 5, 100), 43);       // 243 % 100
    assert_eq(modpow(2, 0, 100), 1);
    assert_eq(modpow(7, 2, 50), 49);        // 49 % 50
    assert_eq(modpow(5, 3, 13), 8);         // 125 % 13
}

fn main() -> Int {
    test_gcd_lcm();
    test_primes();
    test_divisors();
    test_perfect_numbers();
    test_fibonacci();
    test_modpow();
    print("[OK] 194_number_theory_aot");
    0
}
