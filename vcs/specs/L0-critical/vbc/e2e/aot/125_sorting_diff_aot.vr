// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, differential, sorting
// @timeout: 50000
// @expected-exit: 0
// @description: AOT sorting algorithms — mirror of interpreter test for differential comparison

type Arr8 is {
    e0: Int, e1: Int, e2: Int, e3: Int,
    e4: Int, e5: Int, e6: Int, e7: Int
};

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 } else if i == 1 { a.e1 }
    else if i == 2 { a.e2 } else if i == 3 { a.e3 }
    else if i == 4 { a.e4 } else if i == 5 { a.e5 }
    else if i == 6 { a.e6 } else { a.e7 }
}

fn arr8_set(a: Arr8, i: Int, val: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { val } else { a.e0 },
        e1: if i == 1 { val } else { a.e1 },
        e2: if i == 2 { val } else { a.e2 },
        e3: if i == 3 { val } else { a.e3 },
        e4: if i == 4 { val } else { a.e4 },
        e5: if i == 5 { val } else { a.e5 },
        e6: if i == 6 { val } else { a.e6 },
        e7: if i == 7 { val } else { a.e7 }
    }
}

fn arr8_swap(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = arr8_get(a, i);
    let vj = arr8_get(a, j);
    arr8_set(arr8_set(a, i, vj), j, vi)
}

fn is_sorted(a: Arr8, n: Int) -> Bool {
    let mut ok = true;
    let mut i = 0;
    while i < n - 1 {
        if arr8_get(a, i) > arr8_get(a, i + 1) { ok = false; }
        i = i + 1;
    }
    ok
}

fn bubble_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n {
        let mut j = 0;
        while j < n - 1 - i {
            if arr8_get(arr, j) > arr8_get(arr, j + 1) {
                arr = arr8_swap(arr, j, j + 1);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

fn selection_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if arr8_get(arr, j) < arr8_get(arr, min_idx) { min_idx = j; }
            j = j + 1;
        }
        if min_idx != i { arr = arr8_swap(arr, i, min_idx); }
        i = i + 1;
    }
    arr
}

fn test_sorting() -> Int {
    let a = Arr8 { e0: 5, e1: 3, e2: 8, e3: 1, e4: 9, e5: 2, e6: 7, e7: 4 };

    let b_sorted = bubble_sort(a, 8);
    assert(is_sorted(b_sorted, 8));
    assert_eq(arr8_get(b_sorted, 0), 1);
    assert_eq(arr8_get(b_sorted, 7), 9);

    let s_sorted = selection_sort(a, 8);
    assert(is_sorted(s_sorted, 8));
    assert_eq(arr8_get(s_sorted, 0), 1);
    assert_eq(arr8_get(s_sorted, 7), 9);

    // Both produce same result
    let mut k = 0;
    while k < 8 {
        assert_eq(arr8_get(b_sorted, k), arr8_get(s_sorted, k));
        k = k + 1;
    }

    // Reversed input
    let rev = Arr8 { e0: 8, e1: 7, e2: 6, e3: 5, e4: 4, e5: 3, e6: 2, e7: 1 };
    let rev_sorted = bubble_sort(rev, 8);
    assert(is_sorted(rev_sorted, 8));

    // Negative numbers
    let neg = Arr8 { e0: -5, e1: 3, e2: -8, e3: 1, e4: -2, e5: 7, e6: 0, e7: -1 };
    let neg_sorted = bubble_sort(neg, 8);
    assert(is_sorted(neg_sorted, 8));
    assert_eq(arr8_get(neg_sorted, 0), -8);
    assert_eq(arr8_get(neg_sorted, 7), 7);

    0
}

fn main() -> Int {
    test_sorting();
    print("[OK] 125_sorting_diff_aot");
    0
}
