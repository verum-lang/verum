// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, vector, operations, math
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for vector operations (integer vectors)

fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }

// 4D integer vector
type Vec4 is { x: Int, y: Int, z: Int, w: Int };

fn vec4_add(a: Vec4, b: Vec4) -> Vec4 {
    Vec4 { x: a.x + b.x, y: a.y + b.y, z: a.z + b.z, w: a.w + b.w }
}

fn vec4_sub(a: Vec4, b: Vec4) -> Vec4 {
    Vec4 { x: a.x - b.x, y: a.y - b.y, z: a.z - b.z, w: a.w - b.w }
}

fn vec4_scale(v: Vec4, s: Int) -> Vec4 {
    Vec4 { x: v.x * s, y: v.y * s, z: v.z * s, w: v.w * s }
}

fn vec4_dot(a: Vec4, b: Vec4) -> Int {
    a.x * b.x + a.y * b.y + a.z * b.z + a.w * b.w
}

fn vec4_norm_sq(v: Vec4) -> Int {
    vec4_dot(v, v)
}

fn vec4_eq(a: Vec4, b: Vec4) -> Bool {
    a.x == b.x && a.y == b.y && a.z == b.z && a.w == b.w
}

fn vec4_zero() -> Vec4 { Vec4 { x: 0, y: 0, z: 0, w: 0 } }

fn vec4_neg(v: Vec4) -> Vec4 {
    Vec4 { x: -v.x, y: -v.y, z: -v.z, w: -v.w }
}

// Manhattan distance (L1 norm)
fn vec4_l1(v: Vec4) -> Int {
    abs_val(v.x) + abs_val(v.y) + abs_val(v.z) + abs_val(v.w)
}

// Infinity norm (max component)
fn vec4_linf(v: Vec4) -> Int {
    let mut m = abs_val(v.x);
    let ay = abs_val(v.y);
    let az = abs_val(v.z);
    let aw = abs_val(v.w);
    if ay > m { m = ay; }
    if az > m { m = az; }
    if aw > m { m = aw; }
    m
}

fn test_basic_ops() {
    let a = Vec4 { x: 1, y: 2, z: 3, w: 4 };
    let b = Vec4 { x: 5, y: 6, z: 7, w: 8 };

    let sum = vec4_add(a, b);
    assert_eq(sum.x, 6);
    assert_eq(sum.y, 8);
    assert_eq(sum.z, 10);
    assert_eq(sum.w, 12);

    let diff = vec4_sub(a, b);
    assert_eq(diff.x, -4);
    assert_eq(diff.y, -4);

    let scaled = vec4_scale(a, 3);
    assert_eq(scaled.x, 3);
    assert_eq(scaled.w, 12);
}

fn test_dot_product() {
    let a = Vec4 { x: 1, y: 2, z: 3, w: 4 };
    let b = Vec4 { x: 5, y: 6, z: 7, w: 8 };
    // 1*5 + 2*6 + 3*7 + 4*8 = 5+12+21+32 = 70
    assert_eq(vec4_dot(a, b), 70);

    // Orthogonal vectors have dot = 0
    let u = Vec4 { x: 1, y: 0, z: 0, w: 0 };
    let v = Vec4 { x: 0, y: 1, z: 0, w: 0 };
    assert_eq(vec4_dot(u, v), 0);

    // Norm squared
    assert_eq(vec4_norm_sq(a), 30);  // 1+4+9+16
}

fn test_identities() {
    let a = Vec4 { x: 3, y: -7, z: 11, w: -2 };
    let zero = vec4_zero();

    // a + 0 = a
    assert_eq(vec4_eq(vec4_add(a, zero), a), true);

    // a - a = 0
    assert_eq(vec4_eq(vec4_sub(a, a), zero), true);

    // a + (-a) = 0
    assert_eq(vec4_eq(vec4_add(a, vec4_neg(a)), zero), true);

    // 1 * a = a
    assert_eq(vec4_eq(vec4_scale(a, 1), a), true);

    // 0 * a = 0
    assert_eq(vec4_eq(vec4_scale(a, 0), zero), true);
}

fn test_norms() {
    let v = Vec4 { x: 3, y: -4, z: 0, w: 0 };
    assert_eq(vec4_norm_sq(v), 25);  // 9+16
    assert_eq(vec4_l1(v), 7);       // 3+4
    assert_eq(vec4_linf(v), 4);     // max(3,4)

    let w = Vec4 { x: -1, y: -2, z: -3, w: -4 };
    assert_eq(vec4_l1(w), 10);
    assert_eq(vec4_linf(w), 4);
}

fn test_distributive() {
    let a = Vec4 { x: 2, y: 3, z: 4, w: 5 };
    let b = Vec4 { x: 1, y: 1, z: 1, w: 1 };

    // dot(a, b) = sum of a components
    assert_eq(vec4_dot(a, b), 14);

    // scale(a+b, 2) = scale(a,2) + scale(b,2)
    let lhs = vec4_scale(vec4_add(a, b), 2);
    let rhs = vec4_add(vec4_scale(a, 2), vec4_scale(b, 2));
    assert_eq(vec4_eq(lhs, rhs), true);
}

fn main() -> Int {
    test_basic_ops();
    test_dot_product();
    test_identities();
    test_norms();
    test_distributive();
    print("[OK] 238_vector_ops_aot");
    0
}
