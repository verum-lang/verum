// @test: run
// @level: L0
// @tags: aot, e2e, sparse, vector, dot-product
// @timeout: 30000

// Sparse vector operations using (index, value) pairs

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Sparse vector: entries stored as (index*100 + value)
// Max 4 entries per vector
type SparseVec is { entries: Arr8, count: Int };

fn entry_idx(packed: Int) -> Int { packed / 100 }
fn entry_val(packed: Int) -> Int { packed % 100 }
fn pack_entry(idx: Int, val: Int) -> Int { idx * 100 + val }

fn new_sparse() -> SparseVec { SparseVec { entries: zeros(), count: 0 } }

fn sparse_set(sv: SparseVec, idx: Int, val: Int) -> SparseVec {
    // Check if index already exists
    let mut i = 0;
    while i < sv.count {
        if entry_idx(get8(sv.entries, i)) == idx {
            let new_entries = set8(sv.entries, i, pack_entry(idx, val));
            return SparseVec { entries: new_entries, count: sv.count };
        }
        i = i + 1;
    }
    // Add new entry
    let new_entries = set8(sv.entries, sv.count, pack_entry(idx, val));
    SparseVec { entries: new_entries, count: sv.count + 1 }
}

fn sparse_get(sv: SparseVec, idx: Int) -> Int {
    let mut i = 0;
    while i < sv.count {
        if entry_idx(get8(sv.entries, i)) == idx {
            return entry_val(get8(sv.entries, i));
        }
        i = i + 1;
    }
    0 // default for missing entries
}

// Dot product of two sparse vectors
fn sparse_dot(a: SparseVec, b: SparseVec) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < a.count {
        let a_idx = entry_idx(get8(a.entries, i));
        let a_val = entry_val(get8(a.entries, i));
        let mut j = 0;
        while j < b.count {
            if entry_idx(get8(b.entries, j)) == a_idx {
                result = result + a_val * entry_val(get8(b.entries, j));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

// Add two sparse vectors
fn sparse_add(a: SparseVec, b: SparseVec) -> SparseVec {
    let mut result = a;
    let mut i = 0;
    while i < b.count {
        let b_idx = entry_idx(get8(b.entries, i));
        let b_val = entry_val(get8(b.entries, i));
        let existing = sparse_get(result, b_idx);
        result = sparse_set(result, b_idx, existing + b_val);
        i = i + 1;
    }
    result
}

// Scalar multiply
fn sparse_scale(sv: SparseVec, scalar: Int) -> SparseVec {
    let mut result = sv;
    let mut i = 0;
    while i < sv.count {
        let idx = entry_idx(get8(sv.entries, i));
        let val = entry_val(get8(sv.entries, i));
        result = SparseVec { entries: set8(result.entries, i, pack_entry(idx, val * scalar)), count: result.count };
        i = i + 1;
    }
    result
}

// L1 norm (sum of absolute values)
fn sparse_l1(sv: SparseVec) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < sv.count {
        let val = entry_val(get8(sv.entries, i));
        sum = sum + (if val < 0 { 0 - val } else { val });
        i = i + 1;
    }
    sum
}

fn test_basic_ops() -> Int {
    let mut sv = new_sparse();
    sv = sparse_set(sv, 0, 5);
    sv = sparse_set(sv, 3, 10);
    sv = sparse_set(sv, 7, 2);
    assert_eq(sparse_get(sv, 0), 5);
    assert_eq(sparse_get(sv, 3), 10);
    assert_eq(sparse_get(sv, 7), 2);
    assert_eq(sparse_get(sv, 1), 0); // missing → 0
    assert_eq(sv.count, 3);
    1
}

fn test_update() -> Int {
    let mut sv = new_sparse();
    sv = sparse_set(sv, 2, 5);
    sv = sparse_set(sv, 2, 8); // update
    assert_eq(sparse_get(sv, 2), 8);
    assert_eq(sv.count, 1); // count unchanged
    1
}

fn test_dot_product() -> Int {
    // a = {0: 3, 2: 5}
    // b = {0: 2, 2: 4, 5: 7}
    // dot = 3*2 + 5*4 = 6 + 20 = 26
    let mut a = new_sparse();
    a = sparse_set(a, 0, 3);
    a = sparse_set(a, 2, 5);

    let mut b = new_sparse();
    b = sparse_set(b, 0, 2);
    b = sparse_set(b, 2, 4);
    b = sparse_set(b, 5, 7);

    assert_eq(sparse_dot(a, b), 26);
    1
}

fn test_dot_no_overlap() -> Int {
    let mut a = new_sparse();
    a = sparse_set(a, 0, 5);

    let mut b = new_sparse();
    b = sparse_set(b, 1, 3);

    assert_eq(sparse_dot(a, b), 0);
    1
}

fn test_add() -> Int {
    let mut a = new_sparse();
    a = sparse_set(a, 0, 3);
    a = sparse_set(a, 2, 5);

    let mut b = new_sparse();
    b = sparse_set(b, 0, 1);
    b = sparse_set(b, 3, 4);

    let c = sparse_add(a, b);
    assert_eq(sparse_get(c, 0), 4); // 3+1
    assert_eq(sparse_get(c, 2), 5); // unchanged
    assert_eq(sparse_get(c, 3), 4); // new
    1
}

fn test_scale() -> Int {
    let mut sv = new_sparse();
    sv = sparse_set(sv, 1, 3);
    sv = sparse_set(sv, 4, 5);
    let scaled = sparse_scale(sv, 3);
    assert_eq(sparse_get(scaled, 1), 9);
    assert_eq(sparse_get(scaled, 4), 15);
    1
}

fn test_l1_norm() -> Int {
    let mut sv = new_sparse();
    sv = sparse_set(sv, 0, 3);
    sv = sparse_set(sv, 1, 7);
    sv = sparse_set(sv, 2, 1);
    assert_eq(sparse_l1(sv), 11);
    1
}

fn main() -> Int {
    test_basic_ops();
    test_update();
    test_dot_product();
    test_dot_no_overlap();
    test_add();
    test_scale();
    test_l1_norm();
    print("[OK] 542_sparse_vector_aot");
    0
}
