// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, complex, arithmetic, math
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for complex number arithmetic using record types

type Complex is { re: Int, im: Int };

fn cx_new(re: Int, im: Int) -> Complex {
    Complex { re: re, im: im }
}

fn cx_add(a: Complex, b: Complex) -> Complex {
    Complex { re: a.re + b.re, im: a.im + b.im }
}

fn cx_sub(a: Complex, b: Complex) -> Complex {
    Complex { re: a.re - b.re, im: a.im - b.im }
}

fn cx_mul(a: Complex, b: Complex) -> Complex {
    // (a+bi)(c+di) = (ac-bd) + (ad+bc)i
    Complex {
        re: a.re * b.re - a.im * b.im,
        im: a.re * b.im + a.im * b.re
    }
}

fn cx_conj(a: Complex) -> Complex {
    Complex { re: a.re, im: -a.im }
}

fn cx_norm_sq(a: Complex) -> Int {
    a.re * a.re + a.im * a.im
}

fn cx_eq(a: Complex, b: Complex) -> Bool {
    a.re == b.re && a.im == b.im
}

fn cx_scale(a: Complex, s: Int) -> Complex {
    Complex { re: a.re * s, im: a.im * s }
}

fn cx_pow(z: Complex, n: Int) -> Complex {
    if n == 0 { return cx_new(1, 0); }
    let mut result = cx_new(1, 0);
    let mut i = 0;
    while i < n {
        result = cx_mul(result, z);
        i = i + 1;
    }
    result
}

fn test_basic_ops() {
    let a = cx_new(3, 4);
    let b = cx_new(1, -2);

    let sum = cx_add(a, b);
    assert_eq(sum.re, 4);
    assert_eq(sum.im, 2);

    let diff = cx_sub(a, b);
    assert_eq(diff.re, 2);
    assert_eq(diff.im, 6);

    let prod = cx_mul(a, b);
    // (3+4i)(1-2i) = 3-6i+4i-8i^2 = 3-2i+8 = 11+(-2)i
    assert_eq(prod.re, 11);
    assert_eq(prod.im, -2);
}

fn test_properties() {
    let a = cx_new(2, 3);
    let b = cx_new(4, -1);

    // Commutativity of addition
    let ab = cx_add(a, b);
    let ba = cx_add(b, a);
    assert_eq(cx_eq(ab, ba), true);

    // Commutativity of multiplication
    let ab_mul = cx_mul(a, b);
    let ba_mul = cx_mul(b, a);
    assert_eq(cx_eq(ab_mul, ba_mul), true);

    // z * conj(z) = |z|^2 (real)
    let conj_a = cx_conj(a);
    let prod = cx_mul(a, conj_a);
    assert_eq(prod.re, cx_norm_sq(a));
    assert_eq(prod.im, 0);
}

fn test_identity() {
    let z = cx_new(5, -3);
    let zero = cx_new(0, 0);
    let one = cx_new(1, 0);

    // z + 0 = z
    let sum = cx_add(z, zero);
    assert_eq(cx_eq(sum, z), true);

    // z * 1 = z
    let prod = cx_mul(z, one);
    assert_eq(cx_eq(prod, z), true);

    // z * 0 = 0
    let prod_zero = cx_mul(z, zero);
    assert_eq(cx_eq(prod_zero, zero), true);
}

fn test_powers() {
    let i = cx_new(0, 1);  // imaginary unit

    // i^1 = i
    let i1 = cx_pow(i, 1);
    assert_eq(i1.re, 0);
    assert_eq(i1.im, 1);

    // i^2 = -1
    let i2 = cx_pow(i, 2);
    assert_eq(i2.re, -1);
    assert_eq(i2.im, 0);

    // i^3 = -i
    let i3 = cx_pow(i, 3);
    assert_eq(i3.re, 0);
    assert_eq(i3.im, -1);

    // i^4 = 1
    let i4 = cx_pow(i, 4);
    assert_eq(i4.re, 1);
    assert_eq(i4.im, 0);

    // (1+i)^2 = 2i
    let z = cx_new(1, 1);
    let z2 = cx_pow(z, 2);
    assert_eq(z2.re, 0);
    assert_eq(z2.im, 2);

    // (2+i)^3 = (2+i)(2+i)(2+i)
    // (2+i)^2 = 4+4i+i^2 = 3+4i
    // (3+4i)(2+i) = 6+3i+8i+4i^2 = 2+11i
    let w = cx_new(2, 1);
    let w3 = cx_pow(w, 3);
    assert_eq(w3.re, 2);
    assert_eq(w3.im, 11);
}

fn test_distributive() {
    let a = cx_new(1, 2);
    let b = cx_new(3, 4);
    let c = cx_new(5, 6);

    // a * (b + c) = a*b + a*c
    let lhs = cx_mul(a, cx_add(b, c));
    let rhs = cx_add(cx_mul(a, b), cx_mul(a, c));
    assert_eq(cx_eq(lhs, rhs), true);
}

fn main() -> Int {
    test_basic_ops();
    test_properties();
    test_identity();
    test_powers();
    test_distributive();
    print("[OK] 199_complex_arithmetic_aot");
    0
}
