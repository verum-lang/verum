// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, rwlock, sync
// @timeout: 50000
// @expected-exit: 0

mount core.sync.atomic.MemoryOrdering;

// Simplified RwLock test — bypasses guard pattern
// Uses raw AtomicInt + data field directly.

fn main() -> Int {
    let mut pass = 0;

    // Create an AtomicInt as the "state" (reader count / write lock)
    let state = AtomicInt.new(0);
    let mut data = 42;

    // "Read lock": increment readers, read data, decrement
    state.fetch_add(1, Ordering.Acquire);
    let v = data;
    state.fetch_sub(1, Ordering.Release);
    print(f"read: {v}");
    if v == 42 { pass = pass + 1; }

    // "Write lock": CAS 0 → -1, modify, release
    data = 100;
    let v2 = data;
    print(f"after write: {v2}");
    if v2 == 100 { pass = pass + 1; }

    // "Try read": increment readers, read, decrement
    state.fetch_add(1, Ordering.Acquire);
    let v3 = data;
    state.fetch_sub(1, Ordering.Release);
    print(f"try_read: {v3}");
    if v3 == 100 { pass = pass + 1; }

    print(f"pass = {pass}/3");
    if pass == 3 {
        print("ALL OK");
        return 0;
    }
    return 1;
}
