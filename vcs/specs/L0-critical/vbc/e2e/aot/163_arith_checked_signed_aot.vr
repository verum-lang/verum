// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, arith, checked, overflow
// @timeout: 15000
// @expected-exit: 0
// @description: AOT checked signed arithmetic — overflow detection for add, sub, mul

// ============================================================================
// Checked arithmetic using 32-bit range simulation
// We simulate Int32 range: -2147483648 to 2147483647
// ============================================================================

fn i32_max() -> Int { 2147483647 }
fn i32_min() -> Int { 0 - 2147483648 }

// Returns 1 if addition would overflow 32-bit signed range, 0 otherwise
fn checked_add_overflows(a: Int, b: Int) -> Int {
    let result = a + b;
    if result > i32_max() { 1 }
    else if result < i32_min() { 1 }
    else { 0 }
}

// Returns 1 if subtraction would overflow 32-bit signed range, 0 otherwise
fn checked_sub_overflows(a: Int, b: Int) -> Int {
    let result = a - b;
    if result > i32_max() { 1 }
    else if result < i32_min() { 1 }
    else { 0 }
}

// Returns 1 if multiplication would overflow 32-bit signed range, 0 otherwise
fn checked_mul_overflows(a: Int, b: Int) -> Int {
    let result = a * b;
    if result > i32_max() { 1 }
    else if result < i32_min() { 1 }
    else { 0 }
}

// Saturating add: clamp to [i32_min, i32_max]
fn saturating_add(a: Int, b: Int) -> Int {
    let result = a + b;
    if result > i32_max() { i32_max() }
    else if result < i32_min() { i32_min() }
    else { result }
}

// Saturating sub: clamp to [i32_min, i32_max]
fn saturating_sub(a: Int, b: Int) -> Int {
    let result = a - b;
    if result > i32_max() { i32_max() }
    else if result < i32_min() { i32_min() }
    else { result }
}

// ============================================================================
// Test 1: Checked addition overflow detection
// ============================================================================

fn test_checked_add() {
    // Normal addition: no overflow
    assert_eq(checked_add_overflows(100, 200), 0);
    assert_eq(checked_add_overflows(-100, 50), 0);
    assert_eq(checked_add_overflows(0, 0), 0);

    // Positive overflow: max + 1
    assert_eq(checked_add_overflows(i32_max(), 1), 1);
    assert_eq(checked_add_overflows(2000000000, 200000000), 1);

    // Negative overflow: min - 1
    assert_eq(checked_add_overflows(i32_min(), -1), 1);
    assert_eq(checked_add_overflows(-2000000000, -200000000), 1);

    // Edge: max + 0 = ok
    assert_eq(checked_add_overflows(i32_max(), 0), 0);
    assert_eq(checked_add_overflows(i32_min(), 0), 0);

    // Opposite signs never overflow
    assert_eq(checked_add_overflows(i32_max(), -1), 0);
    assert_eq(checked_add_overflows(i32_min(), 1), 0);

    print("test_checked_add passed");
}

// ============================================================================
// Test 2: Checked subtraction overflow detection
// ============================================================================

fn test_checked_sub() {
    // Normal subtraction
    assert_eq(checked_sub_overflows(200, 100), 0);
    assert_eq(checked_sub_overflows(-50, -100), 0);

    // Positive overflow: max - (-1)
    assert_eq(checked_sub_overflows(i32_max(), -1), 1);

    // Negative overflow: min - 1
    assert_eq(checked_sub_overflows(i32_min(), 1), 1);

    // No overflow when subtracting same sign
    assert_eq(checked_sub_overflows(1000000, 500000), 0);
    assert_eq(checked_sub_overflows(-1000000, -500000), 0);

    // Edge: subtracting zero never overflows
    assert_eq(checked_sub_overflows(i32_max(), 0), 0);
    assert_eq(checked_sub_overflows(i32_min(), 0), 0);

    print("test_checked_sub passed");
}

// ============================================================================
// Test 3: Checked multiplication overflow detection
// ============================================================================

fn test_checked_mul() {
    // Normal multiplication
    assert_eq(checked_mul_overflows(100, 200), 0);
    assert_eq(checked_mul_overflows(-10, 5), 0);
    assert_eq(checked_mul_overflows(0, i32_max()), 0);

    // Overflow cases
    assert_eq(checked_mul_overflows(i32_max(), 2), 1);
    assert_eq(checked_mul_overflows(100000, 100000), 1);

    // Negative overflow
    assert_eq(checked_mul_overflows(i32_min(), 2), 1);
    assert_eq(checked_mul_overflows(-100000, 100000), 1);

    // Multiply by 1 never overflows
    assert_eq(checked_mul_overflows(i32_max(), 1), 0);
    assert_eq(checked_mul_overflows(i32_min(), 1), 0);

    // Multiply by 0 never overflows
    assert_eq(checked_mul_overflows(i32_max(), 0), 0);

    print("test_checked_mul passed");
}

// ============================================================================
// Test 4: Saturating arithmetic
// ============================================================================

fn test_saturating() {
    // Normal cases: no clamping
    assert_eq(saturating_add(100, 200), 300);
    assert_eq(saturating_sub(200, 100), 100);

    // Positive saturation
    assert_eq(saturating_add(i32_max(), 1), i32_max());
    assert_eq(saturating_add(2000000000, 200000000), i32_max());

    // Negative saturation
    assert_eq(saturating_add(i32_min(), -1), i32_min());
    assert_eq(saturating_sub(i32_min(), 1), i32_min());

    // Subtraction saturation
    assert_eq(saturating_sub(i32_max(), -1), i32_max());

    // No saturation needed
    assert_eq(saturating_add(0, 0), 0);
    assert_eq(saturating_sub(0, 0), 0);

    print("test_saturating passed");
}

fn main() -> Int {
    test_checked_add();
    test_checked_sub();
    test_checked_mul();
    test_saturating();
    print("ALL PASSED");
    0
}
