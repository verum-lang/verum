// @test: run
// @level: L0
// @tags: aot, e2e, stack-machine, vm, interpreter
// @timeout: 30000

// Stack-based virtual machine with arithmetic and comparison operations
// Stack stored in Arr8, program in another Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Instruction encoding: op * 1000 + arg
// Opcodes:
// 1 = PUSH arg       - push arg onto stack
// 2 = ADD            - pop 2, push sum
// 3 = SUB            - pop 2, push difference (second - first)
// 4 = MUL            - pop 2, push product
// 5 = DIV            - pop 2, push quotient (second / first)
// 6 = DUP            - duplicate top of stack
// 7 = SWAP           - swap top two
// 8 = NEG            - negate top
// 9 = MOD            - pop 2, push second % first

fn make_op(op: Int, arg: Int) -> Int { op * 1000 + arg }
fn op_code(instr: Int) -> Int { instr / 1000 }
fn op_arg(instr: Int) -> Int { instr % 1000 }

// Run program, return top of stack
// Returns packed: top_value * 100 + stack_size
fn vm_run(prog: Arr8, plen: Int) -> Int {
    let mut stack = zeros();
    let mut sp = 0; // stack pointer (next free slot)
    let mut pc = 0;
    while pc < plen {
        let instr = get8(prog, pc);
        let op = op_code(instr);
        let arg = op_arg(instr);
        if op == 1 {
            // PUSH
            stack = set8(stack, sp, arg);
            sp = sp + 1;
        } else if op == 2 {
            // ADD
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, b + a);
        } else if op == 3 {
            // SUB
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, b - a);
        } else if op == 4 {
            // MUL
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, b * a);
        } else if op == 5 {
            // DIV
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            sp = sp - 1;
            if a == 0 { stack = set8(stack, sp - 1, 0); }
            else { stack = set8(stack, sp - 1, b / a); }
        } else if op == 6 {
            // DUP
            let top = get8(stack, sp - 1);
            stack = set8(stack, sp, top);
            sp = sp + 1;
        } else if op == 7 {
            // SWAP
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            stack = set8(stack, sp - 1, b);
            stack = set8(stack, sp - 2, a);
        } else if op == 8 {
            // NEG
            let top = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, 0 - top);
        } else if op == 9 {
            // MOD
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            sp = sp - 1;
            if a == 0 { stack = set8(stack, sp - 1, 0); }
            else { stack = set8(stack, sp - 1, b % a); }
        }
        pc = pc + 1;
    }
    if sp == 0 { 0 }
    else { get8(stack, sp - 1) }
}

// Get stack size after running program
fn vm_stack_size(prog: Arr8, plen: Int) -> Int {
    let mut sp = 0;
    let mut pc = 0;
    while pc < plen {
        let op = op_code(get8(prog, pc));
        if op == 1 { sp = sp + 1; }
        else if op == 6 { sp = sp + 1; } // DUP
        else if op == 7 { } // SWAP: no change
        else if op == 8 { } // NEG: no change
        else { sp = sp - 1; } // binary ops consume one
        pc = pc + 1;
    }
    sp
}

fn test_basic_push() -> Int {
    // PUSH 42
    let prog = Arr8 { v0: make_op(1, 42), v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(vm_run(prog, 1), 42);
    assert_eq(vm_stack_size(prog, 1), 1);
    1
}

fn test_add() -> Int {
    // PUSH 3, PUSH 4, ADD => 7
    let prog = Arr8 {
        v0: make_op(1, 3),
        v1: make_op(1, 4),
        v2: make_op(2, 0),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog, 3), 7);
    assert_eq(vm_stack_size(prog, 3), 1);
    1
}

fn test_sub_mul() -> Int {
    // PUSH 10, PUSH 3, SUB => 7
    let prog = Arr8 {
        v0: make_op(1, 10),
        v1: make_op(1, 3),
        v2: make_op(3, 0),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog, 3), 7);

    // PUSH 5, PUSH 6, MUL => 30
    let prog2 = Arr8 {
        v0: make_op(1, 5),
        v1: make_op(1, 6),
        v2: make_op(4, 0),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog2, 3), 30);
    1
}

fn test_dup_swap() -> Int {
    // PUSH 5, DUP, ADD => 10
    let prog = Arr8 {
        v0: make_op(1, 5),
        v1: make_op(6, 0),
        v2: make_op(2, 0),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog, 3), 10);

    // PUSH 3, PUSH 7, SWAP, SUB => 3 - 7 = -4... wait
    // SUB pops a=top=3, b=second=7, pushes b-a = 7-3 = 4
    let prog2 = Arr8 {
        v0: make_op(1, 3),
        v1: make_op(1, 7),
        v2: make_op(7, 0),
        v3: make_op(3, 0),
        v4: 0, v5: 0, v6: 0, v7: 0
    };
    // After SWAP: stack is [7, 3], SUB: b=7, a=3, result=7-3=4
    // Wait, after PUSH 3 PUSH 7: stack = [3, 7]
    // After SWAP: stack = [7, 3]
    // SUB: a=top=3, b=second=7, result=7-3=4
    assert_eq(vm_run(prog2, 4), 4);
    1
}

fn test_complex_expr() -> Int {
    // Compute (3 + 4) * (5 - 2) = 7 * 3 = 21
    // PUSH 3, PUSH 4, ADD, PUSH 5, PUSH 2, SUB, MUL
    let prog = Arr8 {
        v0: make_op(1, 3),
        v1: make_op(1, 4),
        v2: make_op(2, 0),
        v3: make_op(1, 5),
        v4: make_op(1, 2),
        v5: make_op(3, 0),
        v6: make_op(4, 0),
        v7: 0
    };
    assert_eq(vm_run(prog, 7), 21);
    assert_eq(vm_stack_size(prog, 7), 1);
    1
}

fn test_neg() -> Int {
    // PUSH 5, NEG => -5
    let prog = Arr8 {
        v0: make_op(1, 5),
        v1: make_op(8, 0),
        v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog, 2), 0 - 5);
    // PUSH 5, NEG, NEG => 5
    let prog2 = Arr8 {
        v0: make_op(1, 5),
        v1: make_op(8, 0),
        v2: make_op(8, 0),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog2, 3), 5);
    1
}

fn test_mod_div() -> Int {
    // PUSH 17, PUSH 5, DIV => 3
    let prog = Arr8 {
        v0: make_op(1, 17),
        v1: make_op(1, 5),
        v2: make_op(5, 0),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog, 3), 3);
    // PUSH 17, PUSH 5, MOD => 2
    let prog2 = Arr8 {
        v0: make_op(1, 17),
        v1: make_op(1, 5),
        v2: make_op(9, 0),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(vm_run(prog2, 3), 2);
    1
}

fn main() -> Int {
    test_basic_push();
    test_add();
    test_sub_mul();
    test_dup_swap();
    test_complex_expr();
    test_neg();
    test_mod_div();
    print("[OK] 627_stack_machine_aot");
    0
}
