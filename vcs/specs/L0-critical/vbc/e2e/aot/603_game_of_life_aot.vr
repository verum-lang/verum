// @test: run
// @level: L0
// @tags: aot, e2e, cellular-automata, game-of-life, simulation
// @timeout: 30000

// Conway's Game of Life on a 4x4 grid (bit-packed in a single Int)

// Grid: 4x4 = 16 bits packed in an Int
// Bit i = cell at (row i/4, col i%4)

fn get_cell(grid: Int, r: Int, c: Int) -> Int {
    if r < 0 { 0 }
    else if r >= 4 { 0 }
    else if c < 0 { 0 }
    else if c >= 4 { 0 }
    else {
        let bit = r * 4 + c;
        (grid / pow2(bit)) % 2
    }
}

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn set_bit(grid: Int, r: Int, c: Int) -> Int {
    let bit = r * 4 + c;
    grid + pow2(bit)
}

fn count_neighbors(grid: Int, r: Int, c: Int) -> Int {
    get_cell(grid, r - 1, c - 1) + get_cell(grid, r - 1, c) + get_cell(grid, r - 1, c + 1) +
    get_cell(grid, r, c - 1) + get_cell(grid, r, c + 1) +
    get_cell(grid, r + 1, c - 1) + get_cell(grid, r + 1, c) + get_cell(grid, r + 1, c + 1)
}

fn step(grid: Int) -> Int {
    let mut next = 0;
    let mut r = 0;
    while r < 4 {
        let mut c = 0;
        while c < 4 {
            let alive = get_cell(grid, r, c);
            let n = count_neighbors(grid, r, c);
            // Rules: alive with 2-3 neighbors survives, dead with 3 neighbors born
            let new_state = if alive == 1 {
                if n == 2 { 1 } else if n == 3 { 1 } else { 0 }
            } else {
                if n == 3 { 1 } else { 0 }
            };
            if new_state == 1 {
                next = set_bit(next, r, c);
            }
            c = c + 1;
        }
        r = r + 1;
    }
    next
}

fn population(grid: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 16 {
        count = count + (grid / pow2(i)) % 2;
        i = i + 1;
    }
    count
}

fn test_empty() -> Int {
    // Empty grid stays empty
    assert_eq(step(0), 0);
    assert_eq(population(0), 0);
    1
}

fn test_single_cell() -> Int {
    // Single cell dies (no neighbors)
    let grid = set_bit(0, 1, 1);
    assert_eq(population(grid), 1);
    assert_eq(population(step(grid)), 0);
    1
}

fn test_block() -> Int {
    // Block (still life): 2x2 square
    // ##
    // ##
    let mut grid = 0;
    grid = set_bit(grid, 0, 0);
    grid = set_bit(grid, 0, 1);
    grid = set_bit(grid, 1, 0);
    grid = set_bit(grid, 1, 1);
    assert_eq(population(grid), 4);
    let next = step(grid);
    assert_eq(next, grid); // Still life
    1
}

fn test_blinker() -> Int {
    // Blinker (period 2 oscillator):
    // .#.     ...
    // .#.  -> ### -> back
    // .#.     ...
    let mut grid = 0;
    grid = set_bit(grid, 0, 1);
    grid = set_bit(grid, 1, 1);
    grid = set_bit(grid, 2, 1);
    assert_eq(population(grid), 3);

    let gen1 = step(grid);
    assert_eq(population(gen1), 3);
    // Should be horizontal: row 1, cols 0,1,2
    assert_eq(get_cell(gen1, 1, 0), 1);
    assert_eq(get_cell(gen1, 1, 1), 1);
    assert_eq(get_cell(gen1, 1, 2), 1);
    assert_eq(get_cell(gen1, 0, 1), 0);
    assert_eq(get_cell(gen1, 2, 1), 0);

    let gen2 = step(gen1);
    assert_eq(gen2, grid); // Period 2
    1
}

fn test_tub() -> Int {
    // Tub (still life):
    // .#.
    // #.#
    // .#.
    let mut grid = 0;
    grid = set_bit(grid, 0, 1);
    grid = set_bit(grid, 1, 0);
    grid = set_bit(grid, 1, 2);
    grid = set_bit(grid, 2, 1);
    assert_eq(population(grid), 4);
    assert_eq(step(grid), grid); // Still life
    1
}

fn test_three_generations() -> Int {
    // Run blinker for 3 generations
    let mut grid = 0;
    grid = set_bit(grid, 0, 1);
    grid = set_bit(grid, 1, 1);
    grid = set_bit(grid, 2, 1);
    let original = grid;

    grid = step(grid);
    grid = step(grid);
    assert_eq(grid, original); // Back to start after 2

    grid = step(grid);
    let one_step = step(original);
    assert_eq(grid, one_step); // gen3 = gen1
    1
}

fn main() -> Int {
    test_empty();
    test_single_cell();
    test_block();
    test_blinker();
    test_tub();
    test_three_generations();
    print("[OK] 603_game_of_life_aot");
    0
}
