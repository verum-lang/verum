// @test: run
// @level: L0
// @tier: 2
// @tags: for-in, range, list, iteration
// @description: For-in loops over ranges, lists, and with custom iterators

fn sum_range(start: Int, end: Int) -> Int {
    let mut total = 0;
    for i in start..end {
        total = total + i;
    }
    total
}

fn sum_inclusive(start: Int, end: Int) -> Int {
    let mut total = 0;
    for i in start..=end {
        total = total + i;
    }
    total
}

fn sum_list(items: List<Int>) -> Int {
    let mut total = 0;
    for item in items {
        total = total + item;
    }
    total
}

fn count_positives(items: List<Int>) -> Int {
    let mut count = 0;
    for item in items {
        if (item > 0) {
            count = count + 1;
        }
    }
    count
}

fn main() -> Int {
    // Test 1: range (exclusive)
    let s1 = sum_range(1, 6);
    // 1+2+3+4+5 = 15
    if (s1 != 15) {
        print(f"FAIL test1: sum_range={s1}");
        return 1;
    }

    // Test 2: inclusive range
    let s2 = sum_inclusive(1, 5);
    // 1+2+3+4+5 = 15
    if (s2 != 15) {
        print(f"FAIL test2: sum_inclusive={s2}");
        return 1;
    }

    // Test 3: for-in over list
    let nums = [10, 20, 30, 40, 50];
    let s3 = sum_list(nums);
    if (s3 != 150) {
        print(f"FAIL test3: sum_list={s3}");
        return 1;
    }

    // Test 4: count positives
    let mixed = [5, -3, 0, 7, -1, 2, -4, 8];
    let pos = count_positives(mixed);
    if (pos != 4) {
        print(f"FAIL test4: positives={pos}");
        return 1;
    }

    // Test 5: nested for loops
    let mut total = 0;
    for i in 0..3 {
        for j in 0..3 {
            total = total + (i * 3 + j);
        }
    }
    // 0+1+2+3+4+5+6+7+8 = 36
    if (total != 36) {
        print(f"FAIL test5: nested={total}");
        return 1;
    }

    // Test 6: for-in with early break (using while)
    let data = [1, 2, 3, -1, 5, 6];
    let mut sum_before_neg = 0;
    let mut idx = 0;
    let len = data.len();
    while (idx < len) {
        if (data[idx] < 0) {
            idx = len; // break
        } else {
            sum_before_neg = sum_before_neg + data[idx];
            idx = idx + 1;
        }
    }
    // 1+2+3 = 6
    if (sum_before_neg != 6) {
        print(f"FAIL test6: sum={sum_before_neg}");
        return 1;
    }

    // Test 7: range with computed bounds
    let start = 5;
    let end = 10;
    let s7 = sum_range(start, end);
    // 5+6+7+8+9 = 35
    if (s7 != 35) {
        print(f"FAIL test7: computed_range={s7}");
        return 1;
    }

    // Test 8: build list from range
    let mut squares = [];
    for i in 1..=5 {
        squares.push(i * i);
    }
    if (squares.len() != 5) {
        print(f"FAIL test8a: len={squares.len()}");
        return 1;
    }
    // 1, 4, 9, 16, 25
    if (squares[0] != 1 || squares[4] != 25) {
        print(f"FAIL test8b: squares[0]={squares[0]}, squares[4]={squares[4]}");
        return 1;
    }

    print("996_for_in_collections: PASS");
    0
}
