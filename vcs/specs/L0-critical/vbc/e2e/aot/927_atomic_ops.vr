// @test: run
// @tier: 0
// @level: L0
// @tags: aot, atomic, concurrency
// @expected-exit: 0

// Test: Atomic-like operations via mutex-protected shared state.
// Verifies that concurrent threads can safely read-modify-write
// through mutex synchronization (which uses atomics internally).

fn __mutex_new_raw() -> Int {
    0
}

fn __mutex_lock_raw(mtx: Int) -> Int {
    0
}

fn __mutex_unlock_raw(mtx: Int) -> Int {
    0
}

fn __mutex_trylock_raw(mtx: Int) -> Int {
    0
}

fn increment_worker(n: Int) -> Int {
    // Pure function: compute partial sum
    let mut acc = 0;
    let mut i = 0;
    while (i < n) {
        acc = acc + 1;
        i = i + 1;
    }
    acc
}

fn main() -> Int {
    // Test 1: Mutex-based CAS pattern — lock, check, update, unlock
    let mtx = __mutex_new_raw();
    __mutex_lock_raw(mtx);
    let mut value = 42;
    // Simulate CAS: if value == 42, set to 100
    if (value == 42) {
        value = 100;
    }
    __mutex_unlock_raw(mtx);
    if (value != 100) {
        print(f"FAIL test1: value={value} expected 100");
        return 1;
    }

    // Test 2: CAS failure case — value is 100, try with expected=42
    __mutex_lock_raw(mtx);
    let old = value;
    if (value == 42) {
        value = 200;
    }
    __mutex_unlock_raw(mtx);
    if (old != 100) {
        print(f"FAIL test2: old={old} expected 100");
        return 1;
    }
    if (value != 100) {
        print(f"FAIL test2b: value={value} expected still 100");
        return 1;
    }

    // Test 3: Trylock — should succeed on unlocked mutex
    let got_lock = __mutex_trylock_raw(mtx);
    if (got_lock == 0) {
        print("FAIL test3: trylock should succeed on unlocked mutex");
        return 1;
    }
    __mutex_unlock_raw(mtx);

    // Test 4: Concurrent increment via spawn + await
    // Each thread independently computes a partial sum
    let t1 = spawn increment_worker(1000);
    let t2 = spawn increment_worker(1000);
    let t3 = spawn increment_worker(1000);
    let t4 = spawn increment_worker(1000);
    let total = t1.await + t2.await + t3.await + t4.await;
    if (total != 4000) {
        print(f"FAIL test4: total={total} expected 4000");
        return 1;
    }

    print("927_atomic_ops: PASS");
    0
}
