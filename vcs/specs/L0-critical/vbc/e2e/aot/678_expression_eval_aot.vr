// @test: run
// @level: L0
// @tags: aot, e2e, expression, evaluator, stack-machine
// @timeout: 30000

// Expression evaluator for postfix (RPN) expressions using stack

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Instruction encoding: op * 1000 + operand
// op: 0 = push value, 1 = add, 2 = sub, 3 = mul, 4 = div, 5 = dup, 6 = swap, 7 = neg
fn make_push(val: Int) -> Int { val } // op=0, value=val (val < 1000)
fn make_op(op: Int) -> Int { op * 1000 }
fn get_op(instr: Int) -> Int { instr / 1000 }
fn get_val(instr: Int) -> Int { instr % 1000 }

// Execute a single instruction on stack
// Returns: new_sp * 100000 + result (packed)
// We'll use separate stack array and sp tracking

fn exec_program(prog: Arr8, prog_len: Int) -> Int {
    let mut stack = zeros();
    let mut sp = 0;
    let mut ip = 0;
    while ip < prog_len {
        let instr = get8(prog, ip);
        let op = get_op(instr);
        if op == 0 {
            // Push
            stack = set8(stack, sp, get_val(instr));
            sp = sp + 1;
        } else if op == 1 {
            // Add
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a + b);
        } else if op == 2 {
            // Sub
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a - b);
        } else if op == 3 {
            // Mul
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a * b);
        } else if op == 4 {
            // Div
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a / b);
        } else if op == 5 {
            // Dup
            let val = get8(stack, sp - 1);
            stack = set8(stack, sp, val);
            sp = sp + 1;
        } else if op == 6 {
            // Swap
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            stack = set8(stack, sp - 1, b);
            stack = set8(stack, sp - 2, a);
        } else if op == 7 {
            // Neg
            let val = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, 0 - val);
        }
        ip = ip + 1;
    }
    get8(stack, sp - 1) // return top of stack
}

fn test_simple_add() -> Int {
    // 3 + 4 in RPN: 3 4 +
    let mut prog = zeros();
    prog = set8(prog, 0, make_push(3));
    prog = set8(prog, 1, make_push(4));
    prog = set8(prog, 2, make_op(1)); // add
    assert_eq(exec_program(prog, 3), 7);
    1
}

fn test_complex_expr() -> Int {
    // (2 + 3) * 4 in RPN: 2 3 + 4 *
    let mut prog = zeros();
    prog = set8(prog, 0, make_push(2));
    prog = set8(prog, 1, make_push(3));
    prog = set8(prog, 2, make_op(1)); // add → 5
    prog = set8(prog, 3, make_push(4));
    prog = set8(prog, 4, make_op(3)); // mul → 20
    assert_eq(exec_program(prog, 5), 20);
    1
}

fn test_sub_div() -> Int {
    // (10 - 4) / 2 in RPN: 10 4 - 2 /
    let mut prog = zeros();
    prog = set8(prog, 0, make_push(10));
    prog = set8(prog, 1, make_push(4));
    prog = set8(prog, 2, make_op(2)); // sub → 6
    prog = set8(prog, 3, make_push(2));
    prog = set8(prog, 4, make_op(4)); // div → 3
    assert_eq(exec_program(prog, 5), 3);
    1
}

fn test_dup_and_mul() -> Int {
    // 5^2 using dup: 5 dup *
    let mut prog = zeros();
    prog = set8(prog, 0, make_push(5));
    prog = set8(prog, 1, make_op(5)); // dup → 5 5
    prog = set8(prog, 2, make_op(3)); // mul → 25
    assert_eq(exec_program(prog, 3), 25);
    1
}

fn test_swap() -> Int {
    // 10 3 swap - = 3 - 10 = -7
    let mut prog = zeros();
    prog = set8(prog, 0, make_push(10));
    prog = set8(prog, 1, make_push(3));
    prog = set8(prog, 2, make_op(6)); // swap → 3 10
    prog = set8(prog, 3, make_op(2)); // sub → 3-10 = -7
    assert_eq(exec_program(prog, 4), 0 - 7);
    1
}

fn test_neg() -> Int {
    // 5 neg = -5
    let mut prog = zeros();
    prog = set8(prog, 0, make_push(5));
    prog = set8(prog, 1, make_op(7)); // neg → -5
    assert_eq(exec_program(prog, 2), 0 - 5);
    1
}

fn test_longer_expr() -> Int {
    // (3 + 4) * (5 - 2) = 7 * 3 = 21
    // RPN: 3 4 + 5 2 - *
    let mut prog = zeros();
    prog = set8(prog, 0, make_push(3));
    prog = set8(prog, 1, make_push(4));
    prog = set8(prog, 2, make_op(1)); // add → 7
    prog = set8(prog, 3, make_push(5));
    prog = set8(prog, 4, make_push(2));
    prog = set8(prog, 5, make_op(2)); // sub → 3
    prog = set8(prog, 6, make_op(3)); // mul → 21
    assert_eq(exec_program(prog, 7), 21);
    1
}

fn main() -> Int {
    test_simple_add();
    test_complex_expr();
    test_sub_div();
    test_dup_and_mul();
    test_swap();
    test_neg();
    test_longer_expr();
    print("[OK] 678_expression_eval_aot");
    0
}
