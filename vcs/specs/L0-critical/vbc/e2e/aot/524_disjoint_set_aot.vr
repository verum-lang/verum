// @test: run
// @level: L0
// @tags: aot, e2e, disjoint-set, union-find, data-structure
// @timeout: 30000

// Disjoint set (Union-Find) with path compression and union by rank

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Union-Find: parent[i] = parent of i. If parent[i] == i, it's a root.
// rank[i] = rank of tree rooted at i.
type UF is { parent: Arr8, rank: Arr8, n: Int };

fn uf_new(n: Int) -> UF {
    // Each element is its own parent initially
    let mut par = zeros();
    let mut i = 0;
    while i < n {
        par = set8(par, i, i);
        i = i + 1;
    }
    UF { parent: par, rank: zeros(), n: n }
}

// Find root with path compression (iterative)
fn uf_find(uf: UF, x: Int) -> Int {
    let mut cur = x;
    while get8(uf.parent, cur) != cur {
        cur = get8(uf.parent, cur);
    }
    cur
}

// Find with path compression (returns updated UF)
fn uf_find_compress(uf: UF, x: Int) -> UF {
    let root = uf_find(uf, x);
    // Path compression: set all nodes on path to point to root
    let mut cur = x;
    let mut u = uf;
    while cur != root {
        let next = get8(u.parent, cur);
        u = UF { parent: set8(u.parent, cur, root), rank: u.rank, n: u.n };
        cur = next;
    }
    u
}

// Union by rank
fn uf_union(uf: UF, x: Int, y: Int) -> UF {
    let rx = uf_find(uf, x);
    let ry = uf_find(uf, y);
    if rx == ry { return uf; }

    let rank_rx = get8(uf.rank, rx);
    let rank_ry = get8(uf.rank, ry);

    if rank_rx < rank_ry {
        UF { parent: set8(uf.parent, rx, ry), rank: uf.rank, n: uf.n }
    } else if rank_rx > rank_ry {
        UF { parent: set8(uf.parent, ry, rx), rank: uf.rank, n: uf.n }
    } else {
        let p = set8(uf.parent, ry, rx);
        let r = set8(uf.rank, rx, rank_rx + 1);
        UF { parent: p, rank: r, n: uf.n }
    }
}

// Check if x and y are in the same component
fn uf_connected(uf: UF, x: Int, y: Int) -> Int {
    if uf_find(uf, x) == uf_find(uf, y) { 1 } else { 0 }
}

// Count number of distinct components
fn uf_components(uf: UF) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < uf.n {
        if uf_find(uf, i) == i { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_initial() -> Int {
    let uf = uf_new(5);
    // Each element in its own set
    assert_eq(uf_components(uf), 5);
    assert_eq(uf_connected(uf, 0, 1), 0);
    assert_eq(uf_connected(uf, 0, 0), 1);
    1
}

fn test_union_basic() -> Int {
    let mut uf = uf_new(5);
    uf = uf_union(uf, 0, 1);
    assert_eq(uf_connected(uf, 0, 1), 1);
    assert_eq(uf_connected(uf, 0, 2), 0);
    assert_eq(uf_components(uf), 4);

    uf = uf_union(uf, 2, 3);
    assert_eq(uf_components(uf), 3);

    uf = uf_union(uf, 0, 2);
    assert_eq(uf_connected(uf, 0, 3), 1);
    assert_eq(uf_connected(uf, 1, 2), 1);
    assert_eq(uf_components(uf), 2);
    1
}

fn test_union_all() -> Int {
    let mut uf = uf_new(6);
    uf = uf_union(uf, 0, 1);
    uf = uf_union(uf, 2, 3);
    uf = uf_union(uf, 4, 5);
    assert_eq(uf_components(uf), 3);

    uf = uf_union(uf, 0, 2);
    uf = uf_union(uf, 4, 0);
    assert_eq(uf_components(uf), 1);
    1
}

fn test_redundant_union() -> Int {
    let mut uf = uf_new(4);
    uf = uf_union(uf, 0, 1);
    uf = uf_union(uf, 0, 1); // redundant
    assert_eq(uf_components(uf), 3);
    1
}

fn test_path_compression() -> Int {
    let mut uf = uf_new(5);
    // Create chain: 0→1→2→3→4
    uf = uf_union(uf, 3, 4);
    uf = uf_union(uf, 2, 3);
    uf = uf_union(uf, 1, 2);
    uf = uf_union(uf, 0, 1);

    // All connected
    assert_eq(uf_connected(uf, 0, 4), 1);

    // Path compression
    uf = uf_find_compress(uf, 0);
    // After compression, 0 should point more directly to root
    assert_eq(uf_connected(uf, 0, 4), 1);
    1
}

fn test_transitive() -> Int {
    let mut uf = uf_new(4);
    uf = uf_union(uf, 0, 1);
    uf = uf_union(uf, 1, 2);
    // 0-1-2 are connected by transitivity
    assert_eq(uf_connected(uf, 0, 2), 1);
    // 3 is separate
    assert_eq(uf_connected(uf, 0, 3), 0);
    1
}

fn main() -> Int {
    test_initial();
    test_union_basic();
    test_union_all();
    test_redundant_union();
    test_path_compression();
    test_transitive();
    print("[OK] 524_disjoint_set_aot");
    0
}
