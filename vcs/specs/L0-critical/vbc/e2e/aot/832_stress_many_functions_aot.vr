// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, stress
// @timeout: 60000
// @expected-exit: 0

// Many functions stress: 100+ small functions calling each other in chains

// Chain A: each adds 1 (20 functions)
fn a01(x: Int) -> Int { x + 1 }
fn a02(x: Int) -> Int { a01(x) + 1 }
fn a03(x: Int) -> Int { a02(x) + 1 }
fn a04(x: Int) -> Int { a03(x) + 1 }
fn a05(x: Int) -> Int { a04(x) + 1 }
fn a06(x: Int) -> Int { a05(x) + 1 }
fn a07(x: Int) -> Int { a06(x) + 1 }
fn a08(x: Int) -> Int { a07(x) + 1 }
fn a09(x: Int) -> Int { a08(x) + 1 }
fn a10(x: Int) -> Int { a09(x) + 1 }
fn a11(x: Int) -> Int { a10(x) + 1 }
fn a12(x: Int) -> Int { a11(x) + 1 }
fn a13(x: Int) -> Int { a12(x) + 1 }
fn a14(x: Int) -> Int { a13(x) + 1 }
fn a15(x: Int) -> Int { a14(x) + 1 }
fn a16(x: Int) -> Int { a15(x) + 1 }
fn a17(x: Int) -> Int { a16(x) + 1 }
fn a18(x: Int) -> Int { a17(x) + 1 }
fn a19(x: Int) -> Int { a18(x) + 1 }
fn a20(x: Int) -> Int { a19(x) + 1 }

// Chain B: multiply-based (20 functions)
fn b01(x: Int) -> Int { x * 2 }
fn b02(x: Int) -> Int { b01(x) + 1 }
fn b03(x: Int) -> Int { b02(x) + 1 }
fn b04(x: Int) -> Int { b03(x) + 1 }
fn b05(x: Int) -> Int { b04(x) + 1 }
fn b06(x: Int) -> Int { b05(x) + 1 }
fn b07(x: Int) -> Int { b06(x) + 1 }
fn b08(x: Int) -> Int { b07(x) + 1 }
fn b09(x: Int) -> Int { b08(x) + 1 }
fn b10(x: Int) -> Int { b09(x) + 1 }
fn b11(x: Int) -> Int { b10(x) + 1 }
fn b12(x: Int) -> Int { b11(x) + 1 }
fn b13(x: Int) -> Int { b12(x) + 1 }
fn b14(x: Int) -> Int { b13(x) + 1 }
fn b15(x: Int) -> Int { b14(x) + 1 }
fn b16(x: Int) -> Int { b15(x) + 1 }
fn b17(x: Int) -> Int { b16(x) + 1 }
fn b18(x: Int) -> Int { b17(x) + 1 }
fn b19(x: Int) -> Int { b18(x) + 1 }
fn b20(x: Int) -> Int { b19(x) + 1 }

// Chain C: mixed ops (15 functions)
fn c01(x: Int) -> Int { x + 3 }
fn c02(x: Int) -> Int { c01(x) * 2 }
fn c03(x: Int) -> Int { c02(x) - 1 }
fn c04(x: Int) -> Int { c03(x) + 5 }
fn c05(x: Int) -> Int { c04(x) * 2 }
fn c06(x: Int) -> Int { c05(x) - 3 }
fn c07(x: Int) -> Int { c06(x) + 7 }
fn c08(x: Int) -> Int { c07(x) * 2 }
fn c09(x: Int) -> Int { c08(x) - 5 }
fn c10(x: Int) -> Int { c09(x) + 11 }
fn c11(x: Int) -> Int { c10(x) * 2 }
fn c12(x: Int) -> Int { c11(x) - 7 }
fn c13(x: Int) -> Int { c12(x) + 13 }
fn c14(x: Int) -> Int { c13(x) * 2 }
fn c15(x: Int) -> Int { c14(x) - 9 }

// Cross-chain combinators
fn cross01(x: Int) -> Int { a10(x) + b10(x) }
fn cross02(x: Int) -> Int { a20(x) + b20(x) }
fn cross03(x: Int) -> Int { a10(x) + b10(x) + c10(x) }
fn cross04(x: Int) -> Int { cross01(x) + cross02(x) }
fn cross05(x: Int) -> Int { cross03(x) + cross04(x) }

// Utility functions (20+)
fn abs_v(x: Int) -> Int { if (x < 0) { 0 - x } else { x } }
fn max_v(a: Int, b: Int) -> Int { if (a > b) { a } else { b } }
fn min_v(a: Int, b: Int) -> Int { if (a < b) { a } else { b } }
fn clamp_v(val: Int, lo: Int, hi: Int) -> Int { max_v(lo, min_v(val, hi)) }
fn sign_v(x: Int) -> Int { if (x > 0) { 1 } else { if (x < 0) { -1 } else { 0 } } }
fn is_pos(x: Int) -> Int { if (x > 0) { 1 } else { 0 } }
fn is_neg(x: Int) -> Int { if (x < 0) { 1 } else { 0 } }
fn sq(x: Int) -> Int { x * x }
fn cube(x: Int) -> Int { x * x * x }
fn add3v(a: Int, b: Int, c: Int) -> Int { a + b + c }
fn mul3v(a: Int, b: Int, c: Int) -> Int { a * b * c }
fn sum4(a: Int, b: Int, c: Int, d: Int) -> Int { a + b + c + d }
fn sum5(a: Int, b: Int, c: Int, d: Int, e: Int) -> Int { a + b + c + d + e }
fn sum6(a: Int, b: Int, c: Int, d: Int, e: Int, f: Int) -> Int { a + b + c + d + e + f }

// Composition: doubling tower
fn dbl1(x: Int) -> Int { x * 2 }
fn dbl2(x: Int) -> Int { dbl1(dbl1(x)) }
fn dbl3(x: Int) -> Int { dbl2(dbl1(x)) }
fn dbl4(x: Int) -> Int { dbl2(dbl2(x)) }
fn dbl5(x: Int) -> Int { dbl3(dbl2(x)) }

// Identity chain (10 deep)
fn id01(x: Int) -> Int { x }
fn id02(x: Int) -> Int { id01(x) }
fn id03(x: Int) -> Int { id02(x) }
fn id04(x: Int) -> Int { id03(x) }
fn id05(x: Int) -> Int { id04(x) }
fn id06(x: Int) -> Int { id05(x) }
fn id07(x: Int) -> Int { id06(x) }
fn id08(x: Int) -> Int { id07(x) }
fn id09(x: Int) -> Int { id08(x) }
fn id10(x: Int) -> Int { id09(x) }

// Predicate chain
fn divides(a: Int, b: Int) -> Int { if (b % a == 0) { 1 } else { 0 } }
fn is_even_v(x: Int) -> Int { divides(2, x) }
fn is_mult3(x: Int) -> Int { divides(3, x) }
fn is_mult5(x: Int) -> Int { divides(5, x) }
fn is_mult15(x: Int) -> Int { if (is_mult3(x) == 1) { if (is_mult5(x) == 1) { 1 } else { 0 } } else { 0 } }

fn main() -> Int {
    // Chain A: a20(0) = 20, a20(100) = 120
    assert_eq(a20(0), 20);
    assert_eq(a20(100), 120);
    assert_eq(a10(0), 10);

    // Chain B: b01 doubles, b02..b20 each +1 (19 additions)
    // b20(5) = 5*2 + 19 = 29
    assert_eq(b20(5), 29);
    assert_eq(b20(0), 19);
    assert_eq(b10(0), 9);

    // Chain C: c01(1) = 4, c02(1) = 8, ..., manually trace c10(1)
    // c01(1)=4, c02(1)=8, c03(1)=7, c04(1)=12, c05(1)=24
    // c06(1)=21, c07(1)=28, c08(1)=56, c09(1)=51, c10(1)=62
    assert_eq(c01(1), 4);
    assert_eq(c02(1), 8);
    assert_eq(c10(1), 62);

    // c10(0): c01(0)=3, c02(0)=6, c03(0)=5, c04(0)=10, c05(0)=20
    // c06(0)=17, c07(0)=24, c08(0)=48, c09(0)=43, c10(0)=54
    assert_eq(c10(0), 54);

    // c15(0): c11(0)=108, c12(0)=101, c13(0)=114, c14(0)=228, c15(0)=219
    assert_eq(c15(0), 219);

    // Cross-chain
    // cross01(0) = a10(0) + b10(0) = 10 + 9 = 19
    assert_eq(cross01(0), 19);
    // cross02(0) = a20(0) + b20(0) = 20 + 19 = 39
    assert_eq(cross02(0), 39);
    // cross03(0) = 10 + 9 + 54 = 73
    assert_eq(cross03(0), 73);

    // Utility functions
    assert_eq(abs_v(-42), 42);
    assert_eq(abs_v(42), 42);
    assert_eq(max_v(10, 20), 20);
    assert_eq(min_v(10, 20), 10);
    assert_eq(clamp_v(50, 0, 100), 50);
    assert_eq(clamp_v(-5, 0, 100), 0);
    assert_eq(clamp_v(150, 0, 100), 100);
    assert_eq(sign_v(10), 1);
    assert_eq(sign_v(-10), -1);
    assert_eq(sign_v(0), 0);
    assert_eq(sq(7), 49);
    assert_eq(cube(3), 27);
    assert_eq(add3v(10, 20, 30), 60);
    assert_eq(mul3v(2, 3, 4), 24);
    assert_eq(sum4(1, 2, 3, 4), 10);
    assert_eq(sum5(1, 2, 3, 4, 5), 15);
    assert_eq(sum6(1, 2, 3, 4, 5, 6), 21);

    // Doubling tower: dbl1(1)=2, dbl2(1)=4, dbl3(1)=8, dbl4(1)=16, dbl5(1)=32
    assert_eq(dbl1(1), 2);
    assert_eq(dbl2(1), 4);
    assert_eq(dbl3(1), 8);
    assert_eq(dbl4(1), 16);
    assert_eq(dbl5(1), 32);

    // Identity chain
    assert_eq(id10(42), 42);
    assert_eq(id10(0), 0);
    assert_eq(id10(-99), -99);

    // Predicates
    assert_eq(is_even_v(10), 1);
    assert_eq(is_even_v(11), 0);
    assert_eq(is_mult3(9), 1);
    assert_eq(is_mult3(10), 0);
    assert_eq(is_mult15(30), 1);
    assert_eq(is_mult15(10), 0);

    // Stress: call many functions in a loop
    let mut total = 0;
    let mut i = 0;
    while (i < 100) {
        total = total + a20(i) + b10(i);
        i = i + 1;
    }
    // a20(i) = i+20, b10(i) = i*2+9
    // total = sum(3i + 29 for i in 0..99) = 3*4950 + 2900 = 14850 + 2900 = 17750
    assert_eq(total, 17750);

    print("832_stress_many_functions: PASS");
    0
}
