// @test: run
// @tier: 2
// @level: L0
// @tags: e2e, aot, graph, bfs, shortest-path, reachability
// @timeout: 30000
// @expected-exit: 0
//
// BFS on a directed graph. Adjacency list stored flat in Arr16.
// Queue simulated with Arr16 (circular buffer with front/rear pointers).
// Find shortest distance from source, count reachable vertices.
//
// Graph representation:
//   adj_start[v] = starting index in adj_list for vertex v's neighbors
//   adj_count[v] = number of neighbors for vertex v
//   adj_list[i] = neighbor vertex id

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int, a12: Int, a13: Int, a14: Int, a15: Int
};

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 } else if i == 2 { a.a2 }
    else if i == 3 { a.a3 } else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 } else if i == 8 { a.a8 }
    else if i == 9 { a.a9 } else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 } else if i == 14 { a.a14 }
    else { a.a15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 }, a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 }, a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 }, a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 }, a15: if i == 15 { v } else { a.a15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
            a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0 }
}

// Graph: up to 8 vertices (0-7), adjacency stored in flat arrays
type Graph is {
    adj_start: Arr8,  // adj_start[v] = start index in adj_list
    adj_count: Arr8,  // adj_count[v] = number of neighbors
    adj_list: Arr16,  // flattened neighbor list
    num_verts: Int
};

// BFS result: distances from source (-1 if unreachable)
type BfsResult is { dist: Arr8 };

fn bfs(g: Graph, src: Int) -> BfsResult {
    let mut dist = a8_zero();
    // Initialize all distances to -1
    let mut i = 0;
    while i < g.num_verts {
        dist = a8_set(dist, i, 0 - 1);
        i = i + 1;
    }
    dist = a8_set(dist, src, 0);

    // Queue: use Arr16 as circular buffer
    let mut queue = a16_zero();
    let mut front = 0;
    let mut rear = 0;
    queue = a16_set(queue, rear, src);
    rear = rear + 1;

    while front < rear {
        let u = a16_get(queue, front);
        front = front + 1;
        let d_u = a8_get(dist, u);
        let start = a8_get(g.adj_start, u);
        let cnt = a8_get(g.adj_count, u);
        let mut j = 0;
        while j < cnt {
            let v = a16_get(g.adj_list, start + j);
            if a8_get(dist, v) < 0 {
                dist = a8_set(dist, v, d_u + 1);
                queue = a16_set(queue, rear, v);
                rear = rear + 1;
            }
            j = j + 1;
        }
    }
    BfsResult { dist: dist }
}

fn count_reachable(br: BfsResult, n: Int) -> Int {
    let mut cnt = 0;
    let mut i = 0;
    while i < n {
        if a8_get(br.dist, i) >= 0 { cnt = cnt + 1; }
        i = i + 1;
    }
    cnt
}

// ========== Build Test Graphs ==========
//
// Graph 1: Linear chain 0->1->2->3->4
//   adj_list: [1, 2, 3, 4]
//   adj_start: [0, 1, 2, 3, 4, ...]
//   adj_count: [1, 1, 1, 1, 0, ...]
fn make_chain() -> Graph {
    let mut astart = a8_zero();
    let mut acount = a8_zero();
    let mut alist = a16_zero();
    astart = a8_set(astart, 0, 0);
    astart = a8_set(astart, 1, 1);
    astart = a8_set(astart, 2, 2);
    astart = a8_set(astart, 3, 3);
    astart = a8_set(astart, 4, 4);
    acount = a8_set(acount, 0, 1);
    acount = a8_set(acount, 1, 1);
    acount = a8_set(acount, 2, 1);
    acount = a8_set(acount, 3, 1);
    acount = a8_set(acount, 4, 0);
    alist = a16_set(alist, 0, 1);
    alist = a16_set(alist, 1, 2);
    alist = a16_set(alist, 2, 3);
    alist = a16_set(alist, 3, 4);
    Graph { adj_start: astart, adj_count: acount, adj_list: alist, num_verts: 5 }
}

// Graph 2: Star from 0: 0->1, 0->2, 0->3, 0->4
fn make_star() -> Graph {
    let mut astart = a8_zero();
    let mut acount = a8_zero();
    let mut alist = a16_zero();
    astart = a8_set(astart, 0, 0);
    acount = a8_set(acount, 0, 4);
    alist = a16_set(alist, 0, 1);
    alist = a16_set(alist, 1, 2);
    alist = a16_set(alist, 2, 3);
    alist = a16_set(alist, 3, 4);
    astart = a8_set(astart, 1, 4);
    astart = a8_set(astart, 2, 4);
    astart = a8_set(astart, 3, 4);
    astart = a8_set(astart, 4, 4);
    Graph { adj_start: astart, adj_count: acount, adj_list: alist, num_verts: 5 }
}

// Graph 3: Diamond: 0->1, 0->2, 1->3, 2->3, 3->4
fn make_diamond() -> Graph {
    let mut astart = a8_zero();
    let mut acount = a8_zero();
    let mut alist = a16_zero();
    // Vertex 0: edges to 1, 2
    astart = a8_set(astart, 0, 0);
    acount = a8_set(acount, 0, 2);
    alist = a16_set(alist, 0, 1);
    alist = a16_set(alist, 1, 2);
    // Vertex 1: edge to 3
    astart = a8_set(astart, 1, 2);
    acount = a8_set(acount, 1, 1);
    alist = a16_set(alist, 2, 3);
    // Vertex 2: edge to 3
    astart = a8_set(astart, 2, 3);
    acount = a8_set(acount, 2, 1);
    alist = a16_set(alist, 3, 3);
    // Vertex 3: edge to 4
    astart = a8_set(astart, 3, 4);
    acount = a8_set(acount, 3, 1);
    alist = a16_set(alist, 4, 4);
    // Vertex 4: no edges
    astart = a8_set(astart, 4, 5);
    acount = a8_set(acount, 4, 0);
    Graph { adj_start: astart, adj_count: acount, adj_list: alist, num_verts: 5 }
}

// Graph 4: Disconnected: 0->1, 2->3 (no edge from {0,1} to {2,3})
fn make_disconnected() -> Graph {
    let mut astart = a8_zero();
    let mut acount = a8_zero();
    let mut alist = a16_zero();
    astart = a8_set(astart, 0, 0);
    acount = a8_set(acount, 0, 1);
    alist = a16_set(alist, 0, 1);
    astart = a8_set(astart, 1, 1);
    astart = a8_set(astart, 2, 1);
    acount = a8_set(acount, 2, 1);
    alist = a16_set(alist, 1, 3);
    astart = a8_set(astart, 3, 2);
    Graph { adj_start: astart, adj_count: acount, adj_list: alist, num_verts: 4 }
}

// ========== Tests ==========

fn test_chain_bfs() -> Int {
    let g = make_chain();
    let r = bfs(g, 0);
    assert_eq(a8_get(r.dist, 0), 0);
    assert_eq(a8_get(r.dist, 1), 1);
    assert_eq(a8_get(r.dist, 2), 2);
    assert_eq(a8_get(r.dist, 3), 3);
    assert_eq(a8_get(r.dist, 4), 4);
    0
}

fn test_chain_reachable() -> Int {
    let g = make_chain();
    let r = bfs(g, 0);
    assert_eq(count_reachable(r, 5), 5);
    // BFS from vertex 3: only 3 and 4 reachable
    let r2 = bfs(g, 3);
    assert_eq(count_reachable(r2, 5), 2);
    assert_eq(a8_get(r2.dist, 3), 0);
    assert_eq(a8_get(r2.dist, 4), 1);
    0
}

fn test_star_bfs() -> Int {
    let g = make_star();
    let r = bfs(g, 0);
    assert_eq(a8_get(r.dist, 0), 0);
    assert_eq(a8_get(r.dist, 1), 1);
    assert_eq(a8_get(r.dist, 2), 1);
    assert_eq(a8_get(r.dist, 3), 1);
    assert_eq(a8_get(r.dist, 4), 1);
    assert_eq(count_reachable(r, 5), 5);
    0
}

fn test_star_from_leaf() -> Int {
    let g = make_star();
    // BFS from leaf 2: only vertex 2 reachable (directed graph, no back edges)
    let r = bfs(g, 2);
    assert_eq(count_reachable(r, 5), 1);
    assert_eq(a8_get(r.dist, 2), 0);
    0
}

fn test_diamond_bfs() -> Int {
    let g = make_diamond();
    let r = bfs(g, 0);
    assert_eq(a8_get(r.dist, 0), 0);
    assert_eq(a8_get(r.dist, 1), 1);
    assert_eq(a8_get(r.dist, 2), 1);
    // Vertex 3 reachable via 0->1->3 or 0->2->3, both length 2
    assert_eq(a8_get(r.dist, 3), 2);
    assert_eq(a8_get(r.dist, 4), 3);
    0
}

fn test_disconnected_bfs() -> Int {
    let g = make_disconnected();
    let r = bfs(g, 0);
    assert_eq(a8_get(r.dist, 0), 0);
    assert_eq(a8_get(r.dist, 1), 1);
    // Vertices 2 and 3 unreachable from 0
    assert_eq(a8_get(r.dist, 2), 0 - 1);
    assert_eq(a8_get(r.dist, 3), 0 - 1);
    assert_eq(count_reachable(r, 4), 2);
    0
}

fn test_disconnected_other_component() -> Int {
    let g = make_disconnected();
    let r = bfs(g, 2);
    assert_eq(a8_get(r.dist, 2), 0);
    assert_eq(a8_get(r.dist, 3), 1);
    assert_eq(a8_get(r.dist, 0), 0 - 1);
    assert_eq(a8_get(r.dist, 1), 0 - 1);
    assert_eq(count_reachable(r, 4), 2);
    0
}

fn test_single_vertex() -> Int {
    // Graph with 1 vertex, no edges
    let g = Graph {
        adj_start: a8_zero(),
        adj_count: a8_zero(),
        adj_list: a16_zero(),
        num_verts: 1
    };
    let r = bfs(g, 0);
    assert_eq(a8_get(r.dist, 0), 0);
    assert_eq(count_reachable(r, 1), 1);
    0
}

fn main() -> Int {
    test_chain_bfs();
    test_chain_reachable();
    test_star_bfs();
    test_star_from_leaf();
    test_diamond_bfs();
    test_disconnected_bfs();
    test_disconnected_other_component();
    test_single_vertex();
    print("[OK] 413_graph_bfs_aot");
    0
}
