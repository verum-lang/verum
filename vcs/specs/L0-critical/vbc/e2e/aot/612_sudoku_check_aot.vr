// @test: run
// @level: L0
// @tags: aot, e2e, sudoku, validation, constraint
// @timeout: 30000

// Sudoku board validation on a 4x4 mini-sudoku (values 1-4)
// Board stored as 2 Arr8s (rows 0-1 in first, rows 2-3 in second)

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

// Get cell (r,c) from 4x4 board split across two Arr8s
fn cell(top: Arr8, bot: Arr8, r: Int, c: Int) -> Int {
    let idx = r * 4 + c;
    if idx < 8 { get8(top, idx) }
    else { get8(bot, idx - 8) }
}

// Check if row r has no duplicates among values 1-4
fn valid_row(top: Arr8, bot: Arr8, r: Int) -> Int {
    let a = cell(top, bot, r, 0);
    let b = cell(top, bot, r, 1);
    let c = cell(top, bot, r, 2);
    let d = cell(top, bot, r, 3);
    // All must be 1-4 and all different: sum = 10, product would too but let's use sum + uniqueness
    let sum = a + b + c + d;
    if sum != 10 { 0 }
    else {
        // Check all different
        if a == b { 0 }
        else if a == c { 0 }
        else if a == d { 0 }
        else if b == c { 0 }
        else if b == d { 0 }
        else if c == d { 0 }
        else { 1 }
    }
}

// Check if column c has no duplicates
fn valid_col(top: Arr8, bot: Arr8, c: Int) -> Int {
    let a = cell(top, bot, 0, c);
    let b = cell(top, bot, 1, c);
    let cv = cell(top, bot, 2, c);
    let d = cell(top, bot, 3, c);
    let sum = a + b + cv + d;
    if sum != 10 { 0 }
    else {
        if a == b { 0 }
        else if a == cv { 0 }
        else if a == d { 0 }
        else if b == cv { 0 }
        else if b == d { 0 }
        else if cv == d { 0 }
        else { 1 }
    }
}

// Check 2x2 box starting at (r,c)
fn valid_box(top: Arr8, bot: Arr8, r: Int, c: Int) -> Int {
    let a = cell(top, bot, r, c);
    let b = cell(top, bot, r, c + 1);
    let cv = cell(top, bot, r + 1, c);
    let d = cell(top, bot, r + 1, c + 1);
    let sum = a + b + cv + d;
    if sum != 10 { 0 }
    else {
        if a == b { 0 }
        else if a == cv { 0 }
        else if a == d { 0 }
        else if b == cv { 0 }
        else if b == d { 0 }
        else if cv == d { 0 }
        else { 1 }
    }
}

// Full validation of 4x4 board
fn valid_board(top: Arr8, bot: Arr8) -> Int {
    let mut ok = 1;
    // Check rows
    let mut r = 0;
    while r < 4 {
        if valid_row(top, bot, r) == 0 { ok = 0; }
        r = r + 1;
    }
    // Check columns
    let mut c = 0;
    while c < 4 {
        if valid_col(top, bot, c) == 0 { ok = 0; }
        c = c + 1;
    }
    // Check 2x2 boxes
    if valid_box(top, bot, 0, 0) == 0 { ok = 0; }
    if valid_box(top, bot, 0, 2) == 0 { ok = 0; }
    if valid_box(top, bot, 2, 0) == 0 { ok = 0; }
    if valid_box(top, bot, 2, 2) == 0 { ok = 0; }
    ok
}

fn test_valid_board() -> Int {
    // Valid 4x4 sudoku:
    // 1 2 3 4
    // 3 4 1 2
    // 2 1 4 3
    // 4 3 2 1
    let top = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 3, v5: 4, v6: 1, v7: 2 };
    let bot = Arr8 { v0: 2, v1: 1, v2: 4, v3: 3, v4: 4, v5: 3, v6: 2, v7: 1 };
    assert_eq(valid_board(top, bot), 1);
    1
}

fn test_invalid_row() -> Int {
    // Invalid: row 0 has duplicate 1
    // 1 1 3 4
    // 3 4 1 2
    // 2 1 4 3
    // 4 3 2 1
    let top = Arr8 { v0: 1, v1: 1, v2: 3, v3: 4, v4: 3, v5: 4, v6: 1, v7: 2 };
    let bot = Arr8 { v0: 2, v1: 1, v2: 4, v3: 3, v4: 4, v5: 3, v6: 2, v7: 1 };
    assert_eq(valid_row(top, bot, 0), 0);
    assert_eq(valid_board(top, bot), 0);
    1
}

fn test_invalid_col() -> Int {
    // Invalid: col 0 has duplicate (1,1,2,4)
    // 1 2 3 4
    // 1 4 2 3
    // 2 3 4 1
    // 4 1 1 2
    let top = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 1, v5: 4, v6: 2, v7: 3 };
    let bot = Arr8 { v0: 2, v1: 3, v2: 4, v3: 1, v4: 4, v5: 1, v6: 1, v7: 2 };
    assert_eq(valid_col(top, bot, 0), 0);
    1
}

fn test_valid_rows() -> Int {
    let top = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 3, v5: 4, v6: 1, v7: 2 };
    let bot = Arr8 { v0: 2, v1: 1, v2: 4, v3: 3, v4: 4, v5: 3, v6: 2, v7: 1 };
    assert_eq(valid_row(top, bot, 0), 1);
    assert_eq(valid_row(top, bot, 1), 1);
    assert_eq(valid_row(top, bot, 2), 1);
    assert_eq(valid_row(top, bot, 3), 1);
    1
}

fn test_valid_boxes() -> Int {
    let top = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 3, v5: 4, v6: 1, v7: 2 };
    let bot = Arr8 { v0: 2, v1: 1, v2: 4, v3: 3, v4: 4, v5: 3, v6: 2, v7: 1 };
    assert_eq(valid_box(top, bot, 0, 0), 1);
    assert_eq(valid_box(top, bot, 0, 2), 1);
    assert_eq(valid_box(top, bot, 2, 0), 1);
    assert_eq(valid_box(top, bot, 2, 2), 1);
    1
}

fn main() -> Int {
    test_valid_board();
    test_invalid_row();
    test_invalid_col();
    test_valid_rows();
    test_valid_boxes();
    print("[OK] 612_sudoku_check_aot");
    0
}
