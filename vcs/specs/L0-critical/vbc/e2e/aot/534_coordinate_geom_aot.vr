// @test: run
// @level: L0
// @tags: aot, e2e, geometry, coordinate, distance
// @timeout: 30000

// Coordinate geometry with integer-scaled computations

type Pt is { x: Int, y: Int };

fn pt(x: Int, y: Int) -> Pt { Pt { x: x, y: y } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// Distance squared (avoids sqrt)
fn dist_sq(a: Pt, b: Pt) -> Int {
    let dx = a.x - b.x;
    let dy = a.y - b.y;
    dx * dx + dy * dy
}

// Manhattan distance
fn manhattan(a: Pt, b: Pt) -> Int {
    abs_val(a.x - b.x) + abs_val(a.y - b.y)
}

// Cross product of vectors (p1-p0) x (p2-p0)
fn cross(p0: Pt, p1: Pt, p2: Pt) -> Int {
    (p1.x - p0.x) * (p2.y - p0.y) - (p1.y - p0.y) * (p2.x - p0.x)
}

// Dot product of vectors (p1-p0) · (p2-p0)
fn dot(p0: Pt, p1: Pt, p2: Pt) -> Int {
    (p1.x - p0.x) * (p2.x - p0.x) + (p1.y - p0.y) * (p2.y - p0.y)
}

// Area of triangle * 2 (signed)
fn triangle_area2(a: Pt, b: Pt, c: Pt) -> Int { cross(a, b, c) }

// Check if point is on segment (assuming collinear)
fn on_segment(p: Pt, a: Pt, b: Pt) -> Int {
    let min_x = if a.x < b.x { a.x } else { b.x };
    let max_x = if a.x > b.x { a.x } else { b.x };
    let min_y = if a.y < b.y { a.y } else { b.y };
    let max_y = if a.y > b.y { a.y } else { b.y };
    if p.x >= min_x {
        if p.x <= max_x {
            if p.y >= min_y {
                if p.y <= max_y { return 1; }
            }
        }
    }
    0
}

// Orientation: 0=collinear, 1=CW, 2=CCW
fn orientation(p: Pt, q: Pt, r: Pt) -> Int {
    let v = cross(p, q, r);
    if v == 0 { 0 }
    else if v > 0 { 2 }
    else { 1 }
}

// Line intersection test: do segments (p1,q1) and (p2,q2) intersect?
fn segments_intersect(p1: Pt, q1: Pt, p2: Pt, q2: Pt) -> Int {
    let o1 = orientation(p1, q1, p2);
    let o2 = orientation(p1, q1, q2);
    let o3 = orientation(p2, q2, p1);
    let o4 = orientation(p2, q2, q1);

    if o1 != o2 {
        if o3 != o4 { return 1; }
    }
    // Collinear special cases
    if o1 == 0 { if on_segment(p2, p1, q1) == 1 { return 1; } }
    if o2 == 0 { if on_segment(q2, p1, q1) == 1 { return 1; } }
    if o3 == 0 { if on_segment(p1, p2, q2) == 1 { return 1; } }
    if o4 == 0 { if on_segment(q1, p2, q2) == 1 { return 1; } }
    0
}

// Point inside triangle (using area method)
fn point_in_triangle(p: Pt, a: Pt, b: Pt, c: Pt) -> Int {
    let d1 = cross(a, b, p);
    let d2 = cross(b, c, p);
    let d3 = cross(c, a, p);
    let has_neg = if d1 < 0 { 1 } else if d2 < 0 { 1 } else if d3 < 0 { 1 } else { 0 };
    let has_pos = if d1 > 0 { 1 } else if d2 > 0 { 1 } else if d3 > 0 { 1 } else { 0 };
    // Inside if all same sign
    if has_neg == 1 {
        if has_pos == 1 { return 0; }
    }
    1
}

fn test_distances() -> Int {
    let a = pt(0, 0);
    let b = pt(3, 4);
    assert_eq(dist_sq(a, b), 25); // 3^2 + 4^2
    assert_eq(manhattan(a, b), 7); // 3 + 4

    let c = pt(1, 1);
    let d = pt(4, 5);
    assert_eq(dist_sq(c, d), 25); // 3^2 + 4^2
    assert_eq(manhattan(c, d), 7);
    1
}

fn test_cross_product() -> Int {
    let o = pt(0, 0);
    let a = pt(1, 0);
    let b = pt(0, 1);
    // (1,0) x (0,1) = 1 (CCW)
    assert_eq(cross(o, a, b), 1);
    // (0,1) x (1,0) = -1 (CW)
    assert_eq(cross(o, b, a), -1);
    // Collinear
    let c = pt(2, 0);
    assert_eq(cross(o, a, c), 0);
    1
}

fn test_triangle_area() -> Int {
    let a = pt(0, 0);
    let b = pt(4, 0);
    let c = pt(0, 3);
    // Area = 6 (half of 4*3), area*2 = 12
    let area2 = abs_val(triangle_area2(a, b, c));
    assert_eq(area2, 12);
    1
}

fn test_orientation() -> Int {
    let p = pt(0, 0);
    let q = pt(4, 4);
    let r1 = pt(1, 2); // left of line → CCW
    assert_eq(orientation(p, q, r1), 2);
    let r2 = pt(2, 1); // right of line → CW
    assert_eq(orientation(p, q, r2), 1);
    let r3 = pt(2, 2); // on line → collinear
    assert_eq(orientation(p, q, r3), 0);
    1
}

fn test_segment_intersection() -> Int {
    // Crossing segments
    let p1 = pt(0, 0);
    let q1 = pt(4, 4);
    let p2 = pt(0, 4);
    let q2 = pt(4, 0);
    assert_eq(segments_intersect(p1, q1, p2, q2), 1);

    // Parallel non-intersecting
    let p3 = pt(0, 0);
    let q3 = pt(4, 0);
    let p4 = pt(0, 2);
    let q4 = pt(4, 2);
    assert_eq(segments_intersect(p3, q3, p4, q4), 0);

    // T-junction (endpoint touching)
    let p5 = pt(0, 0);
    let q5 = pt(4, 0);
    let p6 = pt(2, 0);
    let q6 = pt(2, 4);
    assert_eq(segments_intersect(p5, q5, p6, q6), 1);
    1
}

fn test_point_in_triangle() -> Int {
    let a = pt(0, 0);
    let b = pt(10, 0);
    let c = pt(0, 10);

    let inside = pt(2, 2);
    assert_eq(point_in_triangle(inside, a, b, c), 1);

    let outside = pt(6, 6);
    assert_eq(point_in_triangle(outside, a, b, c), 0);

    let on_edge = pt(5, 0);
    assert_eq(point_in_triangle(on_edge, a, b, c), 1);

    let vertex = pt(0, 0);
    assert_eq(point_in_triangle(vertex, a, b, c), 1);
    1
}

fn test_dot_product() -> Int {
    let o = pt(0, 0);
    let a = pt(3, 0);
    let b = pt(0, 4);
    // (3,0) · (0,4) = 0 (perpendicular)
    assert_eq(dot(o, a, b), 0);

    let c = pt(1, 1);
    // (3,0) · (1,1) = 3
    assert_eq(dot(o, a, c), 3);
    1
}

fn main() -> Int {
    test_distances();
    test_cross_product();
    test_triangle_area();
    test_orientation();
    test_segment_intersection();
    test_point_in_triangle();
    test_dot_product();
    print("[OK] 534_coordinate_geom_aot");
    0
}
