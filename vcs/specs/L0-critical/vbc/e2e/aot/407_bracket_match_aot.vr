// @test: run
// @tier: 2
// @level: L0
// @tags: e2e, aot, bracket-matching, stack, nesting, validation
// @timeout: 30000
// @expected-exit: 0
//
// Bracket matching/validation using a stack-based approach.
// Brackets encoded as integers:
//   1 = '(', 2 = ')', 3 = '[', 4 = ']', 5 = '{', 6 = '}'
// Stack stored in Arr16. Supports: validate, max nesting depth, find mismatch.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int, a12: Int, a13: Int, a14: Int, a15: Int
};

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 } else if i == 2 { a.a2 }
    else if i == 3 { a.a3 } else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 } else if i == 8 { a.a8 }
    else if i == 9 { a.a9 } else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 } else if i == 14 { a.a14 }
    else { a.a15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 }, a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 }, a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 }, a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 }, a15: if i == 15 { v } else { a.a15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
            a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0 }
}

// Bracket encoding:
// 1 = '(', 2 = ')', 3 = '[', 4 = ']', 5 = '{', 6 = '}'

fn is_open(ch: Int) -> Int {
    if ch == 1 { 1 } else if ch == 3 { 1 } else if ch == 5 { 1 } else { 0 }
}

fn is_close(ch: Int) -> Int {
    if ch == 2 { 1 } else if ch == 4 { 1 } else if ch == 6 { 1 } else { 0 }
}

// Get matching open bracket for a close bracket
fn matching_open(close_ch: Int) -> Int {
    if close_ch == 2 { 1 }       // ')' matches '('
    else if close_ch == 4 { 3 }  // ']' matches '['
    else if close_ch == 6 { 5 }  // '}' matches '{'
    else { 0 }
}

// Validate bracket sequence stored in Arr16 with length n.
// Returns 1 if valid, 0 if invalid.
fn validate(seq: Arr16, n: Int) -> Int {
    let mut stack = a16_zero();
    let mut top = 0;  // stack pointer (top points to next free slot)
    let mut i = 0;
    while i < n {
        let ch = a16_get(seq, i);
        if is_open(ch) == 1 {
            stack = a16_set(stack, top, ch);
            top = top + 1;
        } else if is_close(ch) == 1 {
            if top == 0 { return 0; }  // Unmatched close
            top = top - 1;
            let expected = matching_open(ch);
            if a16_get(stack, top) != expected { return 0; }
        }
        i = i + 1;
    }
    if top == 0 { 1 } else { 0 }
}

// Compute maximum nesting depth
fn max_depth(seq: Arr16, n: Int) -> Int {
    let mut depth = 0;
    let mut best = 0;
    let mut i = 0;
    while i < n {
        let ch = a16_get(seq, i);
        if is_open(ch) == 1 {
            depth = depth + 1;
            if depth > best { best = depth; }
        } else if is_close(ch) == 1 {
            depth = depth - 1;
        }
        i = i + 1;
    }
    best
}

// Find index of first mismatch (0-indexed), or -1 if valid
fn find_mismatch(seq: Arr16, n: Int) -> Int {
    let mut stack = a16_zero();     // stores open bracket type
    let mut stack_pos = a16_zero(); // stores position of open bracket
    let mut top = 0;
    let mut i = 0;
    while i < n {
        let ch = a16_get(seq, i);
        if is_open(ch) == 1 {
            stack = a16_set(stack, top, ch);
            stack_pos = a16_set(stack_pos, top, i);
            top = top + 1;
        } else if is_close(ch) == 1 {
            if top == 0 { return i; }
            top = top - 1;
            let expected = matching_open(ch);
            if a16_get(stack, top) != expected {
                return i;
            }
        }
        i = i + 1;
    }
    if top > 0 {
        // Unclosed bracket - return position of first unclosed
        a16_get(stack_pos, 0)
    } else {
        0 - 1
    }
}

// Count total pairs of matched brackets
fn count_pairs(seq: Arr16, n: Int) -> Int {
    let mut stack_top = 0;
    let mut pairs = 0;
    let mut i = 0;
    while i < n {
        let ch = a16_get(seq, i);
        if is_open(ch) == 1 {
            stack_top = stack_top + 1;
        } else if is_close(ch) == 1 {
            if stack_top > 0 {
                stack_top = stack_top - 1;
                pairs = pairs + 1;
            }
        }
        i = i + 1;
    }
    pairs
}

// ========== Tests ==========

fn test_empty() -> Int {
    let seq = a16_zero();
    assert_eq(validate(seq, 0), 1);
    assert_eq(max_depth(seq, 0), 0);
    assert_eq(find_mismatch(seq, 0), 0 - 1);
    0
}

fn test_simple_parens() -> Int {
    // ()
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 1);  // (
    seq = a16_set(seq, 1, 2);  // )
    assert_eq(validate(seq, 2), 1);
    assert_eq(max_depth(seq, 2), 1);
    assert_eq(find_mismatch(seq, 2), 0 - 1);
    assert_eq(count_pairs(seq, 2), 1);
    0
}

fn test_nested() -> Int {
    // (())
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 1);  // (
    seq = a16_set(seq, 1, 1);  // (
    seq = a16_set(seq, 2, 2);  // )
    seq = a16_set(seq, 3, 2);  // )
    assert_eq(validate(seq, 4), 1);
    assert_eq(max_depth(seq, 4), 2);
    assert_eq(count_pairs(seq, 4), 2);
    0
}

fn test_mixed_brackets() -> Int {
    // ([])
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 1);  // (
    seq = a16_set(seq, 1, 3);  // [
    seq = a16_set(seq, 2, 4);  // ]
    seq = a16_set(seq, 3, 2);  // )
    assert_eq(validate(seq, 4), 1);
    assert_eq(max_depth(seq, 4), 2);
    0
}

fn test_sequential() -> Int {
    // ()[]{}
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 1);  // (
    seq = a16_set(seq, 1, 2);  // )
    seq = a16_set(seq, 2, 3);  // [
    seq = a16_set(seq, 3, 4);  // ]
    seq = a16_set(seq, 4, 5);  // {
    seq = a16_set(seq, 5, 6);  // }
    assert_eq(validate(seq, 6), 1);
    assert_eq(max_depth(seq, 6), 1);
    assert_eq(count_pairs(seq, 6), 3);
    0
}

fn test_mismatch_type() -> Int {
    // (] - type mismatch
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 1);  // (
    seq = a16_set(seq, 1, 4);  // ]
    assert_eq(validate(seq, 2), 0);
    assert_eq(find_mismatch(seq, 2), 1);
    0
}

fn test_unmatched_open() -> Int {
    // ((
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 1);  // (
    seq = a16_set(seq, 1, 1);  // (
    assert_eq(validate(seq, 2), 0);
    assert_eq(find_mismatch(seq, 2), 0);  // First unclosed at index 0
    0
}

fn test_unmatched_close() -> Int {
    // )
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 2);  // )
    assert_eq(validate(seq, 1), 0);
    assert_eq(find_mismatch(seq, 1), 0);
    0
}

fn test_deep_nesting() -> Int {
    // ({[({[]})]})
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 1);   // (
    seq = a16_set(seq, 1, 5);   // {
    seq = a16_set(seq, 2, 3);   // [
    seq = a16_set(seq, 3, 1);   // (
    seq = a16_set(seq, 4, 5);   // {
    seq = a16_set(seq, 5, 3);   // [
    seq = a16_set(seq, 6, 4);   // ]
    seq = a16_set(seq, 7, 6);   // }
    seq = a16_set(seq, 8, 2);   // )
    seq = a16_set(seq, 9, 4);   // ]
    seq = a16_set(seq, 10, 6);  // }
    seq = a16_set(seq, 11, 2);  // )
    assert_eq(validate(seq, 12), 1);
    assert_eq(max_depth(seq, 12), 6);
    assert_eq(count_pairs(seq, 12), 6);
    0
}

fn test_wrong_order() -> Int {
    // )(
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 2);  // )
    seq = a16_set(seq, 1, 1);  // (
    assert_eq(validate(seq, 2), 0);
    assert_eq(find_mismatch(seq, 2), 0);  // First ) at index 0 is mismatch
    0
}

fn test_complex_valid() -> Int {
    // {()}[()]
    let mut seq = a16_zero();
    seq = a16_set(seq, 0, 5);  // {
    seq = a16_set(seq, 1, 1);  // (
    seq = a16_set(seq, 2, 2);  // )
    seq = a16_set(seq, 3, 6);  // }
    seq = a16_set(seq, 4, 3);  // [
    seq = a16_set(seq, 5, 1);  // (
    seq = a16_set(seq, 6, 2);  // )
    seq = a16_set(seq, 7, 4);  // ]
    assert_eq(validate(seq, 8), 1);
    assert_eq(max_depth(seq, 8), 2);
    assert_eq(count_pairs(seq, 8), 4);
    assert_eq(find_mismatch(seq, 8), 0 - 1);
    0
}

fn main() -> Int {
    test_empty();
    test_simple_parens();
    test_nested();
    test_mixed_brackets();
    test_sequential();
    test_mismatch_type();
    test_unmatched_open();
    test_unmatched_close();
    test_deep_nesting();
    test_wrong_order();
    test_complex_valid();
    print("[OK] 407_bracket_match_aot");
    0
}
