// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, ackermann, recursion, math
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Ackermann-like function (iterative with stack)

// Ackermann function computed iteratively
// A(0, n) = n + 1
// A(m, 0) = A(m-1, 1)
// A(m, n) = A(m-1, A(m, n-1))

type Stack32 is {
    s0: Int, s1: Int, s2: Int, s3: Int,
    s4: Int, s5: Int, s6: Int, s7: Int,
    s8: Int, s9: Int, s10: Int, s11: Int,
    s12: Int, s13: Int, s14: Int, s15: Int,
    s16: Int, s17: Int, s18: Int, s19: Int,
    s20: Int, s21: Int, s22: Int, s23: Int,
    s24: Int, s25: Int, s26: Int, s27: Int,
    s28: Int, s29: Int, s30: Int, s31: Int,
    top: Int
};

fn stack_new() -> Stack32 {
    Stack32 {
        s0: 0, s1: 0, s2: 0, s3: 0, s4: 0, s5: 0, s6: 0, s7: 0,
        s8: 0, s9: 0, s10: 0, s11: 0, s12: 0, s13: 0, s14: 0, s15: 0,
        s16: 0, s17: 0, s18: 0, s19: 0, s20: 0, s21: 0, s22: 0, s23: 0,
        s24: 0, s25: 0, s26: 0, s27: 0, s28: 0, s29: 0, s30: 0, s31: 0,
        top: 0
    }
}

fn stack_get(s: Stack32, i: Int) -> Int {
    if i == 0 { s.s0 } else if i == 1 { s.s1 }
    else if i == 2 { s.s2 } else if i == 3 { s.s3 }
    else if i == 4 { s.s4 } else if i == 5 { s.s5 }
    else if i == 6 { s.s6 } else if i == 7 { s.s7 }
    else if i == 8 { s.s8 } else if i == 9 { s.s9 }
    else if i == 10 { s.s10 } else if i == 11 { s.s11 }
    else if i == 12 { s.s12 } else if i == 13 { s.s13 }
    else if i == 14 { s.s14 } else if i == 15 { s.s15 }
    else if i == 16 { s.s16 } else if i == 17 { s.s17 }
    else if i == 18 { s.s18 } else if i == 19 { s.s19 }
    else if i == 20 { s.s20 } else if i == 21 { s.s21 }
    else if i == 22 { s.s22 } else if i == 23 { s.s23 }
    else if i == 24 { s.s24 } else if i == 25 { s.s25 }
    else if i == 26 { s.s26 } else if i == 27 { s.s27 }
    else if i == 28 { s.s28 } else if i == 29 { s.s29 }
    else if i == 30 { s.s30 } else { s.s31 }
}

fn stack_set(s: Stack32, i: Int, v: Int) -> Stack32 {
    Stack32 {
        s0: if i == 0 { v } else { s.s0 }, s1: if i == 1 { v } else { s.s1 },
        s2: if i == 2 { v } else { s.s2 }, s3: if i == 3 { v } else { s.s3 },
        s4: if i == 4 { v } else { s.s4 }, s5: if i == 5 { v } else { s.s5 },
        s6: if i == 6 { v } else { s.s6 }, s7: if i == 7 { v } else { s.s7 },
        s8: if i == 8 { v } else { s.s8 }, s9: if i == 9 { v } else { s.s9 },
        s10: if i == 10 { v } else { s.s10 }, s11: if i == 11 { v } else { s.s11 },
        s12: if i == 12 { v } else { s.s12 }, s13: if i == 13 { v } else { s.s13 },
        s14: if i == 14 { v } else { s.s14 }, s15: if i == 15 { v } else { s.s15 },
        s16: if i == 16 { v } else { s.s16 }, s17: if i == 17 { v } else { s.s17 },
        s18: if i == 18 { v } else { s.s18 }, s19: if i == 19 { v } else { s.s19 },
        s20: if i == 20 { v } else { s.s20 }, s21: if i == 21 { v } else { s.s21 },
        s22: if i == 22 { v } else { s.s22 }, s23: if i == 23 { v } else { s.s23 },
        s24: if i == 24 { v } else { s.s24 }, s25: if i == 25 { v } else { s.s25 },
        s26: if i == 26 { v } else { s.s26 }, s27: if i == 27 { v } else { s.s27 },
        s28: if i == 28 { v } else { s.s28 }, s29: if i == 29 { v } else { s.s29 },
        s30: if i == 30 { v } else { s.s30 }, s31: if i == 31 { v } else { s.s31 },
        top: s.top
    }
}

fn stack_push(s: Stack32, v: Int) -> Stack32 {
    let s2 = stack_set(s, s.top, v);
    Stack32 {
        s0: s2.s0, s1: s2.s1, s2: s2.s2, s3: s2.s3,
        s4: s2.s4, s5: s2.s5, s6: s2.s6, s7: s2.s7,
        s8: s2.s8, s9: s2.s9, s10: s2.s10, s11: s2.s11,
        s12: s2.s12, s13: s2.s13, s14: s2.s14, s15: s2.s15,
        s16: s2.s16, s17: s2.s17, s18: s2.s18, s19: s2.s19,
        s20: s2.s20, s21: s2.s21, s22: s2.s22, s23: s2.s23,
        s24: s2.s24, s25: s2.s25, s26: s2.s26, s27: s2.s27,
        s28: s2.s28, s29: s2.s29, s30: s2.s30, s31: s2.s31,
        top: s.top + 1
    }
}

fn stack_peek(s: Stack32) -> Int { stack_get(s, s.top - 1) }

fn stack_pop(s: Stack32) -> Stack32 {
    Stack32 {
        s0: s.s0, s1: s.s1, s2: s.s2, s3: s.s3,
        s4: s.s4, s5: s.s5, s6: s.s6, s7: s.s7,
        s8: s.s8, s9: s.s9, s10: s.s10, s11: s.s11,
        s12: s.s12, s13: s.s13, s14: s.s14, s15: s.s15,
        s16: s.s16, s17: s.s17, s18: s.s18, s19: s.s19,
        s20: s.s20, s21: s.s21, s22: s.s22, s23: s.s23,
        s24: s.s24, s25: s.s25, s26: s.s26, s27: s.s27,
        s28: s.s28, s29: s.s29, s30: s.s30, s31: s.s31,
        top: s.top - 1
    }
}

// Iterative Ackermann using explicit stack
fn ackermann(m: Int, n: Int) -> Int {
    let mut stk = stack_new();
    stk = stack_push(stk, m);
    let mut result = n;

    while stk.top > 0 {
        let cur_m = stack_peek(stk);
        stk = stack_pop(stk);

        if cur_m == 0 {
            result = result + 1;
        } else if result == 0 {
            stk = stack_push(stk, cur_m - 1);
            result = 1;
        } else {
            stk = stack_push(stk, cur_m - 1);
            stk = stack_push(stk, cur_m);
            result = result - 1;
        }
    }
    result
}

fn test_base_cases() {
    // A(0, n) = n + 1
    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(0, 1), 2);
    assert_eq(ackermann(0, 5), 6);
}

fn test_m1() {
    // A(1, n) = n + 2
    assert_eq(ackermann(1, 0), 2);
    assert_eq(ackermann(1, 1), 3);
    assert_eq(ackermann(1, 5), 7);
    assert_eq(ackermann(1, 10), 12);
}

fn test_m2() {
    // A(2, n) = 2n + 3
    assert_eq(ackermann(2, 0), 3);
    assert_eq(ackermann(2, 1), 5);
    assert_eq(ackermann(2, 2), 7);
    assert_eq(ackermann(2, 5), 13);
}

fn test_m3() {
    // A(3, n) = 2^(n+3) - 3
    assert_eq(ackermann(3, 0), 5);    // 2^3 - 3 = 5
    assert_eq(ackermann(3, 1), 13);   // 2^4 - 3 = 13
    // A(3, 2) and higher need very deep stack, skip
}

fn main() -> Int {
    test_base_cases();
    test_m1();
    test_m2();
    test_m3();
    print("[OK] 272_ackermann_aot");
    0
}
