// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, scc, kosaraju, graph, strongly-connected-components
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Kosaraju's algorithm to find strongly connected components
// on a 6-node directed graph. Uses two DFS passes:
// 1. Forward DFS to compute finish order
// 2. Reverse DFS in reverse finish order to find SCCs
// Iterative DFS with explicit work stack encoding visit/finish phases.

type Arr6 is { d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int };

fn a6_get(a: Arr6, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 }
    else if i == 2 { a.d2 } else if i == 3 { a.d3 }
    else if i == 4 { a.d4 } else { a.d5 }
}

fn a6_set(a: Arr6, i: Int, v: Int) -> Arr6 {
    Arr6 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 }
    }
}

fn a6_zero() -> Arr6 {
    Arr6 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0 }
}

fn a6_fill(v: Int) -> Arr6 {
    Arr6 { d0: v, d1: v, d2: v, d3: v, d4: v, d5: v }
}

// 6x6 adjacency matrix for directed graph
type Graph6 is { r0: Arr6, r1: Arr6, r2: Arr6, r3: Arr6, r4: Arr6, r5: Arr6 };

fn g6_row(g: Graph6, r: Int) -> Arr6 {
    if r == 0 { g.r0 } else if r == 1 { g.r1 }
    else if r == 2 { g.r2 } else if r == 3 { g.r3 }
    else if r == 4 { g.r4 } else { g.r5 }
}

fn g6_edge(g: Graph6, from: Int, to: Int) -> Int {
    a6_get(g6_row(g, from), to)
}

// Transpose: reverse all edges
fn g6_transpose(g: Graph6) -> Graph6 {
    let z = a6_zero();
    let mut t0 = z;
    let mut t1 = z;
    let mut t2 = z;
    let mut t3 = z;
    let mut t4 = z;
    let mut t5 = z;
    let mut i = 0;
    while i < 6 {
        let mut j = 0;
        while j < 6 {
            if g6_edge(g, i, j) == 1 {
                if j == 0 { t0 = a6_set(t0, i, 1); }
                else if j == 1 { t1 = a6_set(t1, i, 1); }
                else if j == 2 { t2 = a6_set(t2, i, 1); }
                else if j == 3 { t3 = a6_set(t3, i, 1); }
                else if j == 4 { t4 = a6_set(t4, i, 1); }
                else { t5 = a6_set(t5, i, 1); }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    Graph6 { r0: t0, r1: t1, r2: t2, r3: t3, r4: t4, r5: t5 }
}

// 18-slot work stack for iterative DFS
// Each item encodes: node * 10 + phase (phase: 0=explore, 1=finish)
type Stk18 is { s0: Int, s1: Int, s2: Int, s3: Int, s4: Int, s5: Int,
                s6: Int, s7: Int, s8: Int, s9: Int, s10: Int, s11: Int,
                s12: Int, s13: Int, s14: Int, s15: Int, s16: Int, s17: Int,
                len: Int };

fn stk_get(s: Stk18, i: Int) -> Int {
    if i == 0 { s.s0 } else if i == 1 { s.s1 }
    else if i == 2 { s.s2 } else if i == 3 { s.s3 }
    else if i == 4 { s.s4 } else if i == 5 { s.s5 }
    else if i == 6 { s.s6 } else if i == 7 { s.s7 }
    else if i == 8 { s.s8 } else if i == 9 { s.s9 }
    else if i == 10 { s.s10 } else if i == 11 { s.s11 }
    else if i == 12 { s.s12 } else if i == 13 { s.s13 }
    else if i == 14 { s.s14 } else if i == 15 { s.s15 }
    else if i == 16 { s.s16 } else { s.s17 }
}

fn stk_set(s: Stk18, i: Int, v: Int) -> Stk18 {
    Stk18 {
        s0: if i == 0 { v } else { s.s0 }, s1: if i == 1 { v } else { s.s1 },
        s2: if i == 2 { v } else { s.s2 }, s3: if i == 3 { v } else { s.s3 },
        s4: if i == 4 { v } else { s.s4 }, s5: if i == 5 { v } else { s.s5 },
        s6: if i == 6 { v } else { s.s6 }, s7: if i == 7 { v } else { s.s7 },
        s8: if i == 8 { v } else { s.s8 }, s9: if i == 9 { v } else { s.s9 },
        s10: if i == 10 { v } else { s.s10 }, s11: if i == 11 { v } else { s.s11 },
        s12: if i == 12 { v } else { s.s12 }, s13: if i == 13 { v } else { s.s13 },
        s14: if i == 14 { v } else { s.s14 }, s15: if i == 15 { v } else { s.s15 },
        s16: if i == 16 { v } else { s.s16 }, s17: if i == 17 { v } else { s.s17 },
        len: s.len
    }
}

fn stk_new() -> Stk18 {
    Stk18 { s0: 0, s1: 0, s2: 0, s3: 0, s4: 0, s5: 0,
            s6: 0, s7: 0, s8: 0, s9: 0, s10: 0, s11: 0,
            s12: 0, s13: 0, s14: 0, s15: 0, s16: 0, s17: 0, len: 0 }
}

// DFS result for pass 1
type Pass1Out is { visited: Arr6, finish_order: Arr6, finish_count: Int };

// Iterative DFS pass 1: compute finish order for one connected component
fn dfs1_from(g: Graph6, start: Int, vis: Arr6, forder: Arr6, fcount: Int) -> Pass1Out {
    let mut visited = vis;
    let mut fo = forder;
    let mut fc = fcount;

    // Work stack: encode as node*2 + phase (0=enter, 1=finish)
    let mut stk = stk_new();
    // Push finish marker first, then explore marker (LIFO)
    stk = stk_set(stk, 0, start * 2 + 1); // finish
    stk = stk_set(stk, 1, start * 2);      // explore
    stk = Stk18 { s0: stk.s0, s1: stk.s1, s2: stk.s2, s3: stk.s3,
                  s4: stk.s4, s5: stk.s5, s6: stk.s6, s7: stk.s7,
                  s8: stk.s8, s9: stk.s9, s10: stk.s10, s11: stk.s11,
                  s12: stk.s12, s13: stk.s13, s14: stk.s14, s15: stk.s15,
                  s16: stk.s16, s17: stk.s17, len: 2 };
    visited = a6_set(visited, start, 1);

    while stk.len > 0 {
        let top = stk_get(stk, stk.len - 1);
        stk = Stk18 { s0: stk.s0, s1: stk.s1, s2: stk.s2, s3: stk.s3,
                      s4: stk.s4, s5: stk.s5, s6: stk.s6, s7: stk.s7,
                      s8: stk.s8, s9: stk.s9, s10: stk.s10, s11: stk.s11,
                      s12: stk.s12, s13: stk.s13, s14: stk.s14, s15: stk.s15,
                      s16: stk.s16, s17: stk.s17, len: stk.len - 1 };
        let node = top / 2;
        let phase = top - node * 2;

        if phase == 1 {
            // Finish: record in finish order
            fo = a6_set(fo, fc, node);
            fc = fc + 1;
        } else {
            // Explore: push children (with their finish+explore pairs)
            let mut j = 5;
            while j >= 0 {
                if g6_edge(g, node, j) == 1 {
                    if a6_get(visited, j) == 0 {
                        visited = a6_set(visited, j, 1);
                        // Push finish then explore for child
                        let fmark = j * 2 + 1;
                        let emark = j * 2;
                        stk = stk_set(stk, stk.len, fmark);
                        stk = stk_set(stk, stk.len + 1, emark);
                        stk = Stk18 { s0: stk.s0, s1: stk.s1, s2: stk.s2, s3: stk.s3,
                                      s4: stk.s4, s5: stk.s5, s6: stk.s6, s7: stk.s7,
                                      s8: stk.s8, s9: stk.s9, s10: stk.s10, s11: stk.s11,
                                      s12: stk.s12, s13: stk.s13, s14: stk.s14, s15: stk.s15,
                                      s16: stk.s16, s17: stk.s17, len: stk.len + 2 };
                    }
                }
                j = j - 1;
            }
        }
    }

    Pass1Out { visited: visited, finish_order: fo, finish_count: fc }
}

// DFS pass 2 on transposed graph: flood-fill component id
fn dfs2_from(gt: Graph6, start: Int, vis: Arr6, comp: Arr6, cid: Int) -> Pass1Out {
    let mut visited = vis;
    let mut components = comp;

    let mut stk = stk_new();
    stk = stk_set(stk, 0, start);
    stk = Stk18 { s0: stk.s0, s1: stk.s1, s2: stk.s2, s3: stk.s3,
                  s4: stk.s4, s5: stk.s5, s6: stk.s6, s7: stk.s7,
                  s8: stk.s8, s9: stk.s9, s10: stk.s10, s11: stk.s11,
                  s12: stk.s12, s13: stk.s13, s14: stk.s14, s15: stk.s15,
                  s16: stk.s16, s17: stk.s17, len: 1 };
    visited = a6_set(visited, start, 1);
    components = a6_set(components, start, cid);

    while stk.len > 0 {
        let node = stk_get(stk, stk.len - 1);
        stk = Stk18 { s0: stk.s0, s1: stk.s1, s2: stk.s2, s3: stk.s3,
                      s4: stk.s4, s5: stk.s5, s6: stk.s6, s7: stk.s7,
                      s8: stk.s8, s9: stk.s9, s10: stk.s10, s11: stk.s11,
                      s12: stk.s12, s13: stk.s13, s14: stk.s14, s15: stk.s15,
                      s16: stk.s16, s17: stk.s17, len: stk.len - 1 };

        let mut j = 0;
        while j < 6 {
            if g6_edge(gt, node, j) == 1 {
                if a6_get(visited, j) == 0 {
                    visited = a6_set(visited, j, 1);
                    components = a6_set(components, j, cid);
                    stk = stk_set(stk, stk.len, j);
                    stk = Stk18 { s0: stk.s0, s1: stk.s1, s2: stk.s2, s3: stk.s3,
                                  s4: stk.s4, s5: stk.s5, s6: stk.s6, s7: stk.s7,
                                  s8: stk.s8, s9: stk.s9, s10: stk.s10, s11: stk.s11,
                                  s12: stk.s12, s13: stk.s13, s14: stk.s14, s15: stk.s15,
                                  s16: stk.s16, s17: stk.s17, len: stk.len + 1 };
                }
            }
            j = j + 1;
        }
    }

    Pass1Out { visited: visited, finish_order: components, finish_count: cid }
}

// Full Kosaraju: returns Arr6 of component IDs
fn kosaraju(g: Graph6, n: Int) -> Arr6 {
    // Pass 1: forward DFS, compute finish order
    let mut visited = a6_zero();
    let mut forder = a6_zero();
    let mut fcount = 0;

    let mut i = 0;
    while i < n {
        if a6_get(visited, i) == 0 {
            let r = dfs1_from(g, i, visited, forder, fcount);
            visited = r.visited;
            forder = r.finish_order;
            fcount = r.finish_count;
        }
        i = i + 1;
    }

    // Pass 2: reverse DFS in reverse finish order on transposed graph
    let gt = g6_transpose(g);
    let mut vis2 = a6_zero();
    let mut comp = a6_fill(-1);
    let mut cid = 0;

    let mut k = fcount - 1;
    while k >= 0 {
        let node = a6_get(forder, k);
        if a6_get(vis2, node) == 0 {
            let r2 = dfs2_from(gt, node, vis2, comp, cid);
            vis2 = r2.visited;
            comp = r2.finish_order;
            cid = cid + 1;
        }
        k = k - 1;
    }

    comp
}

fn count_sccs(comp: Arr6, n: Int) -> Int {
    let mut max_id = -1;
    let mut i = 0;
    while i < n {
        let c = a6_get(comp, i);
        if c > max_id { max_id = c; }
        i = i + 1;
    }
    max_id + 1
}

fn same_comp(comp: Arr6, a: Int, b: Int) -> Int {
    if a6_get(comp, a) == a6_get(comp, b) { 1 } else { 0 }
}

fn test_two_sccs() {
    // 0->1->2->0 (cycle), 3->4->5->3 (cycle), 2->3 (bridge)
    let z = a6_zero();
    let r0 = a6_set(z, 1, 1);
    let r1 = a6_set(z, 2, 1);
    let r2 = a6_set(a6_set(z, 0, 1), 3, 1);
    let r3 = a6_set(z, 4, 1);
    let r4 = a6_set(z, 5, 1);
    let r5 = a6_set(z, 3, 1);
    let g = Graph6 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4, r5: r5 };

    let comp = kosaraju(g, 6);
    assert_eq(count_sccs(comp, 6), 2);
    assert_eq(same_comp(comp, 0, 1), 1);
    assert_eq(same_comp(comp, 0, 2), 1);
    assert_eq(same_comp(comp, 3, 4), 1);
    assert_eq(same_comp(comp, 3, 5), 1);
    assert_eq(same_comp(comp, 0, 3), 0);
}

fn test_single_scc() {
    // Complete cycle: 0->1->2->3->4->5->0
    let z = a6_zero();
    let r0 = a6_set(z, 1, 1);
    let r1 = a6_set(z, 2, 1);
    let r2 = a6_set(z, 3, 1);
    let r3 = a6_set(z, 4, 1);
    let r4 = a6_set(z, 5, 1);
    let r5 = a6_set(z, 0, 1);
    let g = Graph6 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4, r5: r5 };

    let comp = kosaraju(g, 6);
    assert_eq(count_sccs(comp, 6), 1);
    assert_eq(same_comp(comp, 0, 5), 1);
    assert_eq(same_comp(comp, 2, 4), 1);
}

fn test_all_singletons() {
    // DAG: 0->1->2->3->4->5 (no cycles)
    let z = a6_zero();
    let r0 = a6_set(z, 1, 1);
    let r1 = a6_set(z, 2, 1);
    let r2 = a6_set(z, 3, 1);
    let r3 = a6_set(z, 4, 1);
    let r4 = a6_set(z, 5, 1);
    let g = Graph6 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4, r5: z };

    let comp = kosaraju(g, 6);
    assert_eq(count_sccs(comp, 6), 6);
    assert_eq(same_comp(comp, 0, 1), 0);
    assert_eq(same_comp(comp, 1, 2), 0);
}

fn test_three_sccs() {
    // SCC1: {0,1}, SCC2: {2,3}, SCC3: {4,5}
    let z = a6_zero();
    let r0 = a6_set(z, 1, 1);
    let r1 = a6_set(a6_set(z, 0, 1), 2, 1);
    let r2 = a6_set(z, 3, 1);
    let r3 = a6_set(a6_set(z, 2, 1), 4, 1);
    let r4 = a6_set(z, 5, 1);
    let r5 = a6_set(z, 4, 1);
    let g = Graph6 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4, r5: r5 };

    let comp = kosaraju(g, 6);
    assert_eq(count_sccs(comp, 6), 3);
    assert_eq(same_comp(comp, 0, 1), 1);
    assert_eq(same_comp(comp, 2, 3), 1);
    assert_eq(same_comp(comp, 4, 5), 1);
    assert_eq(same_comp(comp, 0, 2), 0);
    assert_eq(same_comp(comp, 2, 4), 0);
}

fn test_no_edges() {
    let z = a6_zero();
    let g = Graph6 { r0: z, r1: z, r2: z, r3: z, r4: z, r5: z };
    let comp = kosaraju(g, 6);
    assert_eq(count_sccs(comp, 6), 6);
}

fn test_self_loops() {
    // 0<->1 (mutual edges = SCC), rest isolated with self-loops
    let z = a6_zero();
    let r0 = a6_set(a6_set(z, 0, 1), 1, 1);
    let r1 = a6_set(a6_set(z, 1, 1), 0, 1);
    let r2 = a6_set(z, 2, 1);
    let r3 = a6_set(z, 3, 1);
    let r4 = a6_set(z, 4, 1);
    let r5 = a6_set(z, 5, 1);
    let g = Graph6 { r0: r0, r1: r1, r2: r2, r3: r3, r4: r4, r5: r5 };

    let comp = kosaraju(g, 6);
    assert_eq(count_sccs(comp, 6), 5);
    assert_eq(same_comp(comp, 0, 1), 1);
}

fn main() -> Int {
    test_two_sccs();
    test_single_scc();
    test_all_singletons();
    test_three_sccs();
    test_no_edges();
    test_self_loops();
    print("[OK] 341_scc_kosaraju_aot");
    0
}
