// @test: run
// @level: L0
// @tags: aot, e2e, milestone, comprehensive, number-theory
// @timeout: 30000

// Milestone 550: Number theory and combinatorics

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// 1. Euler's totient function
fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y != 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

fn euler_totient(n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i < n {
        if gcd(i, n) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

// 2. Catalan numbers: C(n) = C(2n, n) / (n+1)
fn factorial(n: Int) -> Int {
    let mut result = 1;
    let mut i = 2;
    while i <= n { result = result * i; i = i + 1; }
    result
}

fn catalan(n: Int) -> Int {
    // C(n) = (2n)! / ((n+1)! * n!)
    factorial(2 * n) / (factorial(n + 1) * factorial(n))
}

// 3. Modular exponentiation
fn mod_pow(base: Int, exp: Int, modulus: Int) -> Int {
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % modulus;
        }
        e = e / 2;
        b = (b * b) % modulus;
    }
    result
}

// 4. Extended GCD: returns (gcd, x, y) packed as gcd*10000 + (x+500)*100 + (y+500)
// ax + by = gcd(a, b)
type ExtGcdResult is { g: Int, x: Int, y: Int };

@allow(unbounded_recursion)
fn ext_gcd(a: Int, b: Int) -> ExtGcdResult {
    if b == 0 {
        return ExtGcdResult { g: a, x: 1, y: 0 };
    }
    let r = ext_gcd(b, a % b);
    ExtGcdResult { g: r.g, x: r.y, y: r.x - (a / b) * r.y }
}

// 5. Combination C(n, k)
@allow(unbounded_recursion)
fn comb(n: Int, k: Int) -> Int {
    if k > n { return 0; }
    if k == 0 { return 1; }
    if k > n - k {
        return comb(n, n - k);
    }
    let mut result = 1;
    let mut i = 0;
    while i < k {
        result = result * (n - i) / (i + 1);
        i = i + 1;
    }
    result
}

// 6. Stirling numbers of the second kind S(n, k) - partitions of n items into k groups
@allow(unbounded_recursion)
fn stirling2(n: Int, k: Int) -> Int {
    if n == 0 { if k == 0 { return 1; } else { return 0; } }
    if k == 0 { return 0; }
    if k == 1 { return 1; }
    if k == n { return 1; }
    k * stirling2(n - 1, k) + stirling2(n - 1, k - 1)
}

// 7. Digit root (repeated digital sum until single digit)
fn digit_root(n: Int) -> Int {
    let mut val = n;
    while val >= 10 {
        let mut sum = 0;
        let mut tmp = val;
        while tmp > 0 {
            sum = sum + tmp % 10;
            tmp = tmp / 10;
        }
        val = sum;
    }
    val
}

fn test_totient() -> Int {
    assert_eq(euler_totient(1), 0); // no number < 1
    assert_eq(euler_totient(2), 1); // {1}
    assert_eq(euler_totient(6), 2); // {1, 5}
    assert_eq(euler_totient(7), 6); // prime → p-1
    assert_eq(euler_totient(10), 4); // {1, 3, 7, 9}
    assert_eq(euler_totient(12), 4); // {1, 5, 7, 11}
    1
}

fn test_catalan() -> Int {
    assert_eq(catalan(0), 1);
    assert_eq(catalan(1), 1);
    assert_eq(catalan(2), 2);
    assert_eq(catalan(3), 5);
    assert_eq(catalan(4), 14);
    assert_eq(catalan(5), 42);
    1
}

fn test_mod_pow() -> Int {
    assert_eq(mod_pow(2, 10, 1000), 24); // 1024 % 1000 = 24
    assert_eq(mod_pow(3, 5, 100), 43);   // 243 % 100 = 43
    assert_eq(mod_pow(2, 0, 100), 1);
    assert_eq(mod_pow(5, 3, 13), 8);     // 125 % 13 = 8
    1
}

fn test_ext_gcd() -> Int {
    // gcd(35, 15) = 5
    let r = ext_gcd(35, 15);
    assert_eq(r.g, 5);
    // Verify: 35*x + 15*y = 5
    assert_eq(35 * r.x + 15 * r.y, 5);

    // gcd(120, 23) = 1
    let r2 = ext_gcd(120, 23);
    assert_eq(r2.g, 1);
    assert_eq(120 * r2.x + 23 * r2.y, 1);
    1
}

fn test_combinations() -> Int {
    assert_eq(comb(5, 0), 1);
    assert_eq(comb(5, 1), 5);
    assert_eq(comb(5, 2), 10);
    assert_eq(comb(5, 3), 10);
    assert_eq(comb(5, 5), 1);
    assert_eq(comb(10, 3), 120);
    1
}

fn test_stirling() -> Int {
    assert_eq(stirling2(0, 0), 1);
    assert_eq(stirling2(3, 1), 1);
    assert_eq(stirling2(3, 2), 3);
    assert_eq(stirling2(3, 3), 1);
    assert_eq(stirling2(4, 2), 7);
    assert_eq(stirling2(5, 3), 25);
    1
}

fn test_digit_root() -> Int {
    assert_eq(digit_root(0), 0);
    assert_eq(digit_root(5), 5);
    assert_eq(digit_root(123), 6);  // 1+2+3=6
    assert_eq(digit_root(999), 9);  // 9+9+9=27, 2+7=9
    assert_eq(digit_root(493), 7);  // 4+9+3=16, 1+6=7
    1
}

fn main() -> Int {
    test_totient();
    test_catalan();
    test_mod_pow();
    test_ext_gcd();
    test_combinations();
    test_stirling();
    test_digit_root();
    print("[OK] 550_milestone_aot");
    0
}
