// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, interval, arithmetic, math, abstract-interpretation
// @timeout: 50000
// @expected-exit: 0
// @description: AOT interval arithmetic with add, sub, mul, intersection, union, containment, and properties

type Interval is { lo: Int, hi: Int };

fn iv_new(lo: Int, hi: Int) -> Interval {
    Interval { lo: lo, hi: hi }
}

fn iv_is_empty(iv: Interval) -> Bool {
    iv.lo > iv.hi
}

fn iv_width(iv: Interval) -> Int {
    if iv_is_empty(iv) { 0 }
    else { iv.hi - iv.lo }
}

fn iv_midpoint(iv: Interval) -> Int {
    (iv.lo + iv.hi) / 2
}

fn iv_contains(iv: Interval, x: Int) -> Bool {
    if iv_is_empty(iv) { false }
    else { x >= iv.lo && x <= iv.hi }
}

fn iv_contains_iv(outer: Interval, inner: Interval) -> Bool {
    if iv_is_empty(inner) { true }
    else if iv_is_empty(outer) { false }
    else { outer.lo <= inner.lo && outer.hi >= inner.hi }
}

fn iv_overlaps(a: Interval, b: Interval) -> Bool {
    if iv_is_empty(a) || iv_is_empty(b) { false }
    else { a.lo <= b.hi && b.lo <= a.hi }
}

// Interval addition: [a,b] + [c,d] = [a+c, b+d]
fn iv_add(a: Interval, b: Interval) -> Interval {
    iv_new(a.lo + b.lo, a.hi + b.hi)
}

// Interval subtraction: [a,b] - [c,d] = [a-d, b-c]
fn iv_sub(a: Interval, b: Interval) -> Interval {
    iv_new(a.lo - b.hi, a.hi - b.lo)
}

// Interval multiplication (integer): compute all 4 products, take min/max
fn min4(a: Int, b: Int, c: Int, d: Int) -> Int {
    let m1 = if a < b { a } else { b };
    let m2 = if c < d { c } else { d };
    if m1 < m2 { m1 } else { m2 }
}

fn max4(a: Int, b: Int, c: Int, d: Int) -> Int {
    let m1 = if a > b { a } else { b };
    let m2 = if c > d { c } else { d };
    if m1 > m2 { m1 } else { m2 }
}

fn iv_mul(a: Interval, b: Interval) -> Interval {
    let p1 = a.lo * b.lo;
    let p2 = a.lo * b.hi;
    let p3 = a.hi * b.lo;
    let p4 = a.hi * b.hi;
    iv_new(min4(p1, p2, p3, p4), max4(p1, p2, p3, p4))
}

// Intersection: max of lows, min of highs
fn iv_intersect(a: Interval, b: Interval) -> Interval {
    let lo = if a.lo > b.lo { a.lo } else { b.lo };
    let hi = if a.hi < b.hi { a.hi } else { b.hi };
    iv_new(lo, hi)
}

// Union (hull): min of lows, max of highs
fn iv_union(a: Interval, b: Interval) -> Interval {
    if iv_is_empty(a) {
        b
    } else if iv_is_empty(b) {
        a
    } else {
        let lo = if a.lo < b.lo { a.lo } else { b.lo };
        let hi = if a.hi > b.hi { a.hi } else { b.hi };
        iv_new(lo, hi)
    }
}

// Negate: -[a,b] = [-b, -a]
fn iv_neg(iv: Interval) -> Interval {
    iv_new(0 - iv.hi, 0 - iv.lo)
}

// Absolute value: if interval crosses zero, lo=0
fn iv_abs(iv: Interval) -> Interval {
    if iv.lo >= 0 {
        iv
    } else if iv.hi <= 0 {
        iv_new(0 - iv.hi, 0 - iv.lo)
    } else {
        // Crosses zero
        let max_abs = if (0 - iv.lo) > iv.hi { 0 - iv.lo } else { iv.hi };
        iv_new(0, max_abs)
    }
}

// Scale interval by constant
fn iv_scale(iv: Interval, k: Int) -> Interval {
    if k >= 0 {
        iv_new(iv.lo * k, iv.hi * k)
    } else {
        iv_new(iv.hi * k, iv.lo * k)
    }
}

fn main() -> Int {
    // === Basic construction and properties ===
    let a = iv_new(2, 8);
    assert_eq(a.lo, 2);
    assert_eq(a.hi, 8);
    assert_eq(iv_width(a), 6);
    assert_eq(iv_midpoint(a), 5);
    assert(!iv_is_empty(a));

    // === Singleton interval ===
    let s = iv_new(5, 5);
    assert_eq(iv_width(s), 0);
    assert_eq(iv_midpoint(s), 5);
    assert(iv_contains(s, 5));
    assert(!iv_contains(s, 4));
    assert(!iv_is_empty(s));

    // === Empty interval ===
    let e = iv_new(10, 3);
    assert(iv_is_empty(e));
    assert_eq(iv_width(e), 0);
    assert(!iv_contains(e, 5));

    // === Containment ===
    assert(iv_contains(a, 2));
    assert(iv_contains(a, 5));
    assert(iv_contains(a, 8));
    assert(!iv_contains(a, 1));
    assert(!iv_contains(a, 9));

    // === Addition: [2,8] + [1,3] = [3,11] ===
    let b = iv_new(1, 3);
    let sum = iv_add(a, b);
    assert_eq(sum.lo, 3);
    assert_eq(sum.hi, 11);
    assert_eq(iv_width(sum), 8);

    // === Subtraction: [2,8] - [1,3] = [2-3, 8-1] = [-1, 7] ===
    let diff = iv_sub(a, b);
    assert_eq(diff.lo, -1);
    assert_eq(diff.hi, 7);
    assert_eq(iv_width(diff), 8);

    // === Multiplication: [2,8] * [1,3] ===
    // Products: 2*1=2, 2*3=6, 8*1=8, 8*3=24 => [2, 24]
    let prod = iv_mul(a, b);
    assert_eq(prod.lo, 2);
    assert_eq(prod.hi, 24);

    // === Multiplication with negatives: [-3,2] * [1,4] ===
    // Products: -3*1=-3, -3*4=-12, 2*1=2, 2*4=8 => [-12, 8]
    let neg_iv = iv_new(-3, 2);
    let pos_iv = iv_new(1, 4);
    let neg_prod = iv_mul(neg_iv, pos_iv);
    assert_eq(neg_prod.lo, -12);
    assert_eq(neg_prod.hi, 8);

    // === Intersection: [2,8] & [5,12] = [5,8] ===
    let c = iv_new(5, 12);
    let inter = iv_intersect(a, c);
    assert_eq(inter.lo, 5);
    assert_eq(inter.hi, 8);
    assert_eq(iv_width(inter), 3);

    // === Empty intersection: [2,4] & [6,8] ===
    let d = iv_new(2, 4);
    let f = iv_new(6, 8);
    let empty_inter = iv_intersect(d, f);
    assert(iv_is_empty(empty_inter));

    // === Union (hull): [2,5] | [8,12] = [2,12] ===
    let u1 = iv_new(2, 5);
    let u2 = iv_new(8, 12);
    let hull = iv_union(u1, u2);
    assert_eq(hull.lo, 2);
    assert_eq(hull.hi, 12);

    // === Overlapping union: [2,8] | [5,12] = [2,12] ===
    let hull2 = iv_union(a, c);
    assert_eq(hull2.lo, 2);
    assert_eq(hull2.hi, 12);

    // === Overlap tests ===
    assert(iv_overlaps(a, c));       // [2,8] & [5,12] overlap
    assert(!iv_overlaps(d, f));      // [2,4] & [6,8] don't overlap
    assert(iv_overlaps(a, b));       // [2,8] & [1,3] overlap

    // === Containment of intervals ===
    let big = iv_new(0, 100);
    assert(iv_contains_iv(big, a));      // [0,100] contains [2,8]
    assert(!iv_contains_iv(a, big));     // [2,8] does not contain [0,100]
    assert(iv_contains_iv(a, iv_new(3, 7)));  // [2,8] contains [3,7]

    // === Negation: -[2,8] = [-8,-2] ===
    let neg_a = iv_neg(a);
    assert_eq(neg_a.lo, -8);
    assert_eq(neg_a.hi, -2);

    // === Absolute value ===
    let abs1 = iv_abs(iv_new(3, 7));
    assert_eq(abs1.lo, 3);
    assert_eq(abs1.hi, 7);

    let abs2 = iv_abs(iv_new(-5, -2));
    assert_eq(abs2.lo, 2);
    assert_eq(abs2.hi, 5);

    let abs3 = iv_abs(iv_new(-4, 6));
    assert_eq(abs3.lo, 0);
    assert_eq(abs3.hi, 6);

    let abs4 = iv_abs(iv_new(-10, 3));
    assert_eq(abs4.lo, 0);
    assert_eq(abs4.hi, 10);

    // === Scale ===
    let sc1 = iv_scale(iv_new(2, 5), 3);
    assert_eq(sc1.lo, 6);
    assert_eq(sc1.hi, 15);

    let sc2 = iv_scale(iv_new(2, 5), -2);
    assert_eq(sc2.lo, -10);
    assert_eq(sc2.hi, -4);

    // === Algebraic properties ===
    // a + b == b + a (commutativity of addition)
    let ab = iv_add(a, b);
    let ba = iv_add(b, a);
    assert_eq(ab.lo, ba.lo);
    assert_eq(ab.hi, ba.hi);

    // a * b == b * a (commutativity of multiplication)
    let ab_mul = iv_mul(a, b);
    let ba_mul = iv_mul(b, a);
    assert_eq(ab_mul.lo, ba_mul.lo);
    assert_eq(ab_mul.hi, ba_mul.hi);

    // a + (-a) contains 0
    let a_plus_neg_a = iv_add(a, iv_neg(a));
    // [2,8] + [-8,-2] = [-6, 6]
    assert_eq(a_plus_neg_a.lo, -6);
    assert_eq(a_plus_neg_a.hi, 6);
    assert(iv_contains(a_plus_neg_a, 0));

    // Union with empty returns the other interval
    let union_empty = iv_union(a, iv_new(100, 50));
    assert_eq(union_empty.lo, 2);
    assert_eq(union_empty.hi, 8);

    // Intersection is contained in both operands
    let inter2 = iv_intersect(a, c);
    assert(iv_contains_iv(a, inter2));
    assert(iv_contains_iv(c, inter2));

    // Both operands are contained in their union
    let hull3 = iv_union(a, c);
    assert(iv_contains_iv(hull3, a));
    assert(iv_contains_iv(hull3, c));

    0
}
