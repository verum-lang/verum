// @test: run
// @level: L0
// @tags: aot, e2e, merge-sort, sorting
// @timeout: 30000

// Bottom-up merge sort on 8-element arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Merge arr[l..m] and arr[m+1..r] into result
fn merge(arr: Arr8, l: Int, m: Int, r: Int) -> Arr8 {
    let mut result = arr;
    // Copy to temp arrays
    let mut left = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut right = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let n1 = m - l + 1;
    let n2 = r - m;
    let mut i = 0;
    while i < n1 {
        left = set8(left, i, get8(arr, l + i));
        i = i + 1;
    }
    i = 0;
    while i < n2 {
        right = set8(right, i, get8(arr, m + 1 + i));
        i = i + 1;
    }
    // Merge back
    let mut li = 0;
    let mut ri = 0;
    let mut k = l;
    while li < n1 {
        if ri >= n2 {
            result = set8(result, k, get8(left, li));
            li = li + 1;
            k = k + 1;
        } else if get8(left, li) <= get8(right, ri) {
            result = set8(result, k, get8(left, li));
            li = li + 1;
            k = k + 1;
        } else {
            result = set8(result, k, get8(right, ri));
            ri = ri + 1;
            k = k + 1;
        }
    }
    while ri < n2 {
        result = set8(result, k, get8(right, ri));
        ri = ri + 1;
        k = k + 1;
    }
    result
}

// Bottom-up merge sort
fn merge_sort(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut width = 1;
    while width < n {
        let mut i = 0;
        while i < n {
            let l = i;
            let m = min_val(i + width - 1, n - 1);
            let r = min_val(i + 2 * width - 1, n - 1);
            if m < r {
                a = merge(a, l, m, r);
            }
            i = i + 2 * width;
        }
        width = width * 2;
    }
    a
}

// Check if array is sorted
fn is_sorted(arr: Arr8, n: Int) -> Int {
    let mut i = 0;
    while i < n - 1 {
        if get8(arr, i) > get8(arr, i + 1) { return 0; }
        i = i + 1;
    }
    1
}

// Count inversions using merge sort
fn count_inversions_merge(arr: Arr8, l: Int, m: Int, r: Int) -> Int {
    let mut count = 0;
    let n1 = m - l + 1;
    let n2 = r - m;
    let mut left = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut right = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 0;
    while i < n1 {
        left = set8(left, i, get8(arr, l + i));
        i = i + 1;
    }
    i = 0;
    while i < n2 {
        right = set8(right, i, get8(arr, m + 1 + i));
        i = i + 1;
    }
    let mut li = 0;
    let mut ri = 0;
    while li < n1 {
        if ri >= n2 {
            li = li + 1;
        } else if get8(left, li) <= get8(right, ri) {
            li = li + 1;
        } else {
            count = count + (n1 - li);
            ri = ri + 1;
        }
    }
    count
}

fn test_merge_sort() -> Int {
    let arr = Arr8 { v0: 38, v1: 27, v2: 43, v3: 3, v4: 9, v5: 82, v6: 10, v7: 1 };
    let sorted = merge_sort(arr, 8);
    assert_eq(is_sorted(sorted, 8), 1);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 1), 3);
    assert_eq(get8(sorted, 7), 82);

    // Already sorted
    let arr2 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let sorted2 = merge_sort(arr2, 8);
    assert_eq(is_sorted(sorted2, 8), 1);
    assert_eq(get8(sorted2, 0), 1);

    // Reverse sorted
    let arr3 = Arr8 { v0: 8, v1: 7, v2: 6, v3: 5, v4: 4, v5: 3, v6: 2, v7: 1 };
    let sorted3 = merge_sort(arr3, 8);
    assert_eq(is_sorted(sorted3, 8), 1);
    assert_eq(get8(sorted3, 0), 1);
    assert_eq(get8(sorted3, 7), 8);
    1
}

fn test_stability() -> Int {
    // All same elements
    let arr = Arr8 { v0: 5, v1: 5, v2: 5, v3: 5, v4: 5, v5: 5, v6: 5, v7: 5 };
    let sorted = merge_sort(arr, 8);
    assert_eq(get8(sorted, 0), 5);
    assert_eq(get8(sorted, 7), 5);

    // Two distinct values
    let arr2 = Arr8 { v0: 2, v1: 1, v2: 2, v3: 1, v4: 2, v5: 1, v6: 2, v7: 1 };
    let sorted2 = merge_sort(arr2, 8);
    assert_eq(is_sorted(sorted2, 8), 1);
    assert_eq(get8(sorted2, 0), 1);
    assert_eq(get8(sorted2, 3), 1);
    assert_eq(get8(sorted2, 4), 2);
    1
}

fn test_small() -> Int {
    // Sort of size 1
    let arr = Arr8 { v0: 42, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let sorted = merge_sort(arr, 1);
    assert_eq(get8(sorted, 0), 42);

    // Sort of size 2
    let arr2 = Arr8 { v0: 5, v1: 3, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let sorted2 = merge_sort(arr2, 2);
    assert_eq(get8(sorted2, 0), 3);
    assert_eq(get8(sorted2, 1), 5);
    1
}

fn main() -> Int {
    test_merge_sort();
    test_stability();
    test_small();
    print("[OK] 457_merge_sort_aot");
    0
}
