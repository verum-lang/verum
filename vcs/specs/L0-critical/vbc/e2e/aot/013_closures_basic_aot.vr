// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, closures
// @timeout: 5000
// @expected-exit: 0
// @description: AOT closure support: capture, higher-order, composition, factories

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
    f(x)
}

fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int {
    f(f(x))
}

fn apply2(f: fn(Int, Int) -> Int, a: Int, b: Int) -> Int {
    f(a, b)
}

fn make_adder(n: Int) -> fn(Int) -> Int {
    |x| x + n
}

fn make_multiplier(n: Int) -> fn(Int) -> Int {
    |x| x * n
}

fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int) -> fn(Int) -> Int {
    |x| f(g(x))
}

fn main() -> Int {
    // === No-capture closures ===
    let double = |x: Int| -> Int { x * 2 };
    assert_eq(double(5), 10);
    assert_eq(double(0), 0);
    assert_eq(double(-3), -6);

    let add_one = |x: Int| -> Int { x + 1 };
    assert_eq(add_one(0), 1);
    assert_eq(add_one(-1), 0);

    // === Single capture ===
    let offset = 100;
    let add_offset = |x: Int| -> Int { x + offset };
    assert_eq(add_offset(5), 105);
    assert_eq(add_offset(0), 100);

    // === Multiple captures ===
    let a = 2;
    let b = 3;
    let combine = |x: Int| -> Int { x * a + b };
    assert_eq(combine(5), 13);
    assert_eq(combine(0), 3);

    // === Multi-param closure ===
    let mul = |a: Int, b: Int| -> Int { a * b };
    assert_eq(mul(3, 4), 12);
    assert_eq(mul(0, 100), 0);
    assert_eq(mul(-2, 5), -10);

    // === Higher-order: pass closure to function ===
    assert_eq(apply(double, 7), 14);
    assert_eq(apply(add_offset, 50), 150);
    assert_eq(apply(add_one, 99), 100);
    assert_eq(apply2(mul, 6, 7), 42);

    // === Apply twice ===
    assert_eq(apply_twice(double, 3), 12);
    assert_eq(apply_twice(add_one, 10), 12);

    // === Closure factory (returning closure from function) ===
    let add5 = make_adder(5);
    assert_eq(add5(10), 15);
    assert_eq(add5(0), 5);

    let add100 = make_adder(100);
    assert_eq(add100(1), 101);

    let times3 = make_multiplier(3);
    assert_eq(times3(4), 12);

    let times5 = make_multiplier(5);
    assert_eq(times5(4), 20);

    // === Closure composition ===
    let double_then_inc = compose(add_one, double);
    assert_eq(double_then_inc(3), 7);  // add_one(double(3)) = add_one(6) = 7

    let inc_then_double = compose(double, add_one);
    assert_eq(inc_then_double(3), 8);  // double(add_one(3)) = double(4) = 8

    // === Closure capturing mutable state ===
    let mut sum = 0;
    let mut i = 0;
    while i < 5 {
        let adder = |x: Int| -> Int { x + i };
        sum = sum + adder(0);
        i = i + 1;
    }
    assert_eq(sum, 10);  // 0+1+2+3+4

    // === Conditional closure selection ===
    let x = 10;
    let f = if x > 5 {
        |n: Int| -> Int { n * 2 }
    } else {
        |n: Int| -> Int { n * 3 }
    };
    assert_eq(f(4), 8);

    0
}
