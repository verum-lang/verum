// @test: run
// @tier: 2
// @level: L0
// @tags: e2e, aot, segment-tree, range-sum, point-update
// @timeout: 30000
// @expected-exit: 0
//
// Segment tree for range sum queries stored in a flat Arr32 array.
// Tree uses 1-indexed layout: root at 1, left=2*i, right=2*i+1.
// Supports build from array, range sum query, and point update.
// Max 8 elements => tree needs at most 32 nodes (4*8=32).

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// Arr32: 32 integer slots
type Arr32 is { b0: Arr8, b1: Arr8, b2: Arr8, b3: Arr8 };

fn a32_zero() -> Arr32 {
    Arr32 { b0: a8_zero(), b1: a8_zero(), b2: a8_zero(), b3: a8_zero() }
}

fn a32_get(a: Arr32, i: Int) -> Int {
    if i < 8 { a8_get(a.b0, i) }
    else if i < 16 { a8_get(a.b1, i - 8) }
    else if i < 24 { a8_get(a.b2, i - 16) }
    else { a8_get(a.b3, i - 24) }
}

fn a32_set(a: Arr32, i: Int, v: Int) -> Arr32 {
    if i < 8 {
        Arr32 { b0: a8_set(a.b0, i, v), b1: a.b1, b2: a.b2, b3: a.b3 }
    } else if i < 16 {
        Arr32 { b0: a.b0, b1: a8_set(a.b1, i - 8, v), b2: a.b2, b3: a.b3 }
    } else if i < 24 {
        Arr32 { b0: a.b0, b1: a.b1, b2: a8_set(a.b2, i - 16, v), b3: a.b3 }
    } else {
        Arr32 { b0: a.b0, b1: a.b1, b2: a.b2, b3: a8_set(a.b3, i - 24, v) }
    }
}

// Segment tree stored in Arr32 (1-indexed, max 32 nodes)
// For n elements, tree[1] = root, tree[2*i] = left child, tree[2*i+1] = right child
// Leaves are at positions n..2n-1 (when n is power of 2)

type SegTree is { tree: Arr32, n: Int };

// Build segment tree bottom-up for n elements from arr (0-indexed)
// We use a fixed size of 8 for simplicity (n up to 8)
fn seg_build(arr: Arr8, n: Int) -> SegTree {
    let mut tree = a32_zero();
    // Place leaves at positions n..2n-1 (1-indexed)
    let mut i = 0;
    while i < n {
        tree = a32_set(tree, n + i, a8_get(arr, i));
        i = i + 1;
    }
    // Build internal nodes bottom-up
    i = n - 1;
    while i >= 1 {
        let left = a32_get(tree, 2 * i);
        let right = a32_get(tree, 2 * i + 1);
        tree = a32_set(tree, i, left + right);
        i = i - 1;
    }
    SegTree { tree: tree, n: n }
}

// Point update: set arr[pos] += delta (0-indexed position)
fn seg_update(st: SegTree, pos: Int, delta: Int) -> SegTree {
    let mut tree = st.tree;
    let mut i = st.n + pos;  // leaf position
    tree = a32_set(tree, i, a32_get(tree, i) + delta);
    i = i / 2;
    while i >= 1 {
        let left = a32_get(tree, 2 * i);
        let right = a32_get(tree, 2 * i + 1);
        tree = a32_set(tree, i, left + right);
        i = i / 2;
    }
    SegTree { tree: tree, n: st.n }
}

// Range sum query [ql, qr) (0-indexed, half-open)
// Convert to 1-indexed: l = ql + n, r = qr + n
fn seg_query(st: SegTree, ql: Int, qr: Int) -> Int {
    let mut sum = 0;
    let mut l = ql + st.n;
    let mut r = qr + st.n;
    while l < r {
        if l % 2 == 1 {
            sum = sum + a32_get(st.tree, l);
            l = l + 1;
        }
        if r % 2 == 1 {
            r = r - 1;
            sum = sum + a32_get(st.tree, r);
        }
        l = l / 2;
        r = r / 2;
    }
    sum
}

// Point set (absolute): set arr[pos] = val
fn seg_set(st: SegTree, pos: Int, val: Int) -> SegTree {
    let cur = a32_get(st.tree, st.n + pos);
    let delta = val - cur;
    seg_update(st, pos, delta)
}

// ========== Tests ==========

fn test_build_query_all() -> Int {
    // Array: [1, 2, 3, 4, 5, 6, 7, 8]
    let arr = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 6, a6: 7, a7: 8 };
    let st = seg_build(arr, 8);
    // Total sum [0,8) = 36
    assert_eq(seg_query(st, 0, 8), 36);
    // Root should hold total sum
    assert_eq(a32_get(st.tree, 1), 36);
    0
}

fn test_query_ranges() -> Int {
    let arr = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 6, a6: 7, a7: 8 };
    let st = seg_build(arr, 8);
    // [0,1) = 1
    assert_eq(seg_query(st, 0, 1), 1);
    // [0,2) = 3
    assert_eq(seg_query(st, 0, 2), 3);
    // [0,4) = 10
    assert_eq(seg_query(st, 0, 4), 10);
    // [4,8) = 26
    assert_eq(seg_query(st, 4, 8), 26);
    0
}

fn test_query_subranges() -> Int {
    let arr = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 6, a6: 7, a7: 8 };
    let st = seg_build(arr, 8);
    // [2,5) = 3+4+5 = 12
    assert_eq(seg_query(st, 2, 5), 12);
    // [1,7) = 2+3+4+5+6+7 = 27
    assert_eq(seg_query(st, 1, 7), 27);
    // [3,6) = 4+5+6 = 15
    assert_eq(seg_query(st, 3, 6), 15);
    0
}

fn test_point_update() -> Int {
    let arr = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 6, a6: 7, a7: 8 };
    let mut st = seg_build(arr, 8);
    // Add 10 to position 3 (value 4 -> 14)
    st = seg_update(st, 3, 10);
    assert_eq(seg_query(st, 3, 4), 14);
    assert_eq(seg_query(st, 0, 8), 46);
    // Subtract 5 from position 0 (value 1 -> -4)
    st = seg_update(st, 0, 0-5);
    assert_eq(seg_query(st, 0, 1), 0-4);
    assert_eq(seg_query(st, 0, 8), 41);
    0
}

fn test_point_set() -> Int {
    let arr = Arr8 { a0: 10, a1: 20, a2: 30, a3: 40, a4: 0, a5: 0, a6: 0, a7: 0 };
    let mut st = seg_build(arr, 8);
    // Set position 2 to 100 (was 30)
    st = seg_set(st, 2, 100);
    assert_eq(seg_query(st, 2, 3), 100);
    assert_eq(seg_query(st, 0, 4), 10 + 20 + 100 + 40);
    0
}

fn test_multiple_updates() -> Int {
    let arr = Arr8 { a0: 1, a1: 1, a2: 1, a3: 1, a4: 1, a5: 1, a6: 1, a7: 1 };
    let mut st = seg_build(arr, 8);
    assert_eq(seg_query(st, 0, 8), 8);
    // Double each element: add 1 to each position
    let mut i = 0;
    while i < 8 {
        st = seg_update(st, i, 1);
        i = i + 1;
    }
    assert_eq(seg_query(st, 0, 8), 16);
    0
}

fn test_single_element_ranges() -> Int {
    let arr = Arr8 { a0: 5, a1: 3, a2: 7, a3: 2, a4: 8, a5: 1, a6: 4, a7: 6 };
    let st = seg_build(arr, 8);
    assert_eq(seg_query(st, 0, 1), 5);
    assert_eq(seg_query(st, 1, 2), 3);
    assert_eq(seg_query(st, 4, 5), 8);
    assert_eq(seg_query(st, 7, 8), 6);
    0
}

fn test_consecutive_queries() -> Int {
    let arr = Arr8 { a0: 10, a1: 20, a2: 30, a3: 40, a4: 50, a5: 60, a6: 70, a7: 80 };
    let st = seg_build(arr, 8);
    // Verify sum of consecutive pairs
    assert_eq(seg_query(st, 0, 2), 30);
    assert_eq(seg_query(st, 2, 4), 70);
    assert_eq(seg_query(st, 4, 6), 110);
    assert_eq(seg_query(st, 6, 8), 150);
    // Sum of all pairs = total
    let total = 30 + 70 + 110 + 150;
    assert_eq(seg_query(st, 0, 8), total);
    0
}

fn test_update_then_query() -> Int {
    let arr = Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 };
    let mut st = seg_build(arr, 8);
    // Build up from zeros
    st = seg_set(st, 0, 100);
    st = seg_set(st, 7, 200);
    assert_eq(seg_query(st, 0, 8), 300);
    assert_eq(seg_query(st, 0, 1), 100);
    assert_eq(seg_query(st, 7, 8), 200);
    assert_eq(seg_query(st, 1, 7), 0);
    0
}

fn main() -> Int {
    test_build_query_all();
    test_query_ranges();
    test_query_subranges();
    test_point_update();
    test_point_set();
    test_multiple_updates();
    test_single_element_ranges();
    test_consecutive_queries();
    test_update_then_query();
    print("[OK] 404_segment_tree_aot");
    0
}
