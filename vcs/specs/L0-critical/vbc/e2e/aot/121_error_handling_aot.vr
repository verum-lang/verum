// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, error-handling, try, catch, throw, exception
// @timeout: 50000
// @expected-exit: 0
// @description: AOT error handling with try/catch/throw — tests exception propagation and nested handlers

// ============================================================================
// Outcome type for error handling patterns
// ============================================================================

// Use two separate fields to avoid pattern binding issues
type Outcome is { is_ok: Bool, value: Int };

fn make_ok(v: Int) -> Outcome { Outcome { is_ok: true, value: v } }
fn make_err(e: Int) -> Outcome { Outcome { is_ok: false, value: e } }

fn is_ok(r: Outcome) -> Bool { r.is_ok }
fn unwrap_ok(r: Outcome) -> Int { r.value }
fn unwrap_err(r: Outcome) -> Int { r.value }

// ============================================================================
// Basic try/catch pattern using Outcome type
// ============================================================================

fn safe_divide(a: Int, b: Int) -> Outcome {
    if b == 0 {
        make_err(1) // Division by zero error code
    } else {
        make_ok(a / b)
    }
}

fn test_basic_error_handling() -> Int {
    // Successful division
    let r1 = safe_divide(10, 2);
    assert(is_ok(r1));
    assert_eq(unwrap_ok(r1), 5);

    // Division by zero
    let r2 = safe_divide(10, 0);
    assert(!is_ok(r2));
    assert_eq(unwrap_err(r2), 1);

    // Edge cases
    let r3 = safe_divide(0, 5);
    assert(is_ok(r3));
    assert_eq(unwrap_ok(r3), 0);

    let r4 = safe_divide(-10, 2);
    assert(is_ok(r4));
    assert_eq(unwrap_ok(r4), -5);

    0
}

// ============================================================================
// Error propagation through call chain
// ============================================================================

fn validate_input(x: Int) -> Outcome {
    if x < 0 {
        make_err(10) // Negative input error
    } else if x > 100 {
        make_err(11) // Out of range error
    } else {
        make_ok(x)
    }
}

fn process_value(x: Int) -> Outcome {
    let validated = validate_input(x);
    if !is_ok(validated) {
        make_err(unwrap_err(validated)) // Propagate error
    } else {
        let v = unwrap_ok(validated);
        make_ok(v * 2)
    }
}

fn pipeline(x: Int) -> Outcome {
    let processed = process_value(x);
    if !is_ok(processed) {
        make_err(unwrap_err(processed)) // Propagate error
    } else {
        let v = unwrap_ok(processed);
        if v > 150 {
            make_err(20) // Pipeline overflow
        } else {
            make_ok(v + 1)
        }
    }
}

fn test_error_propagation() -> Int {
    // Valid input flows through pipeline
    let r1 = pipeline(25);
    assert(is_ok(r1));
    assert_eq(unwrap_ok(r1), 51); // 25 * 2 + 1

    // Negative input caught by validate_input
    let r2 = pipeline(-5);
    assert(!is_ok(r2));
    assert_eq(unwrap_err(r2), 10);

    // Out of range caught by validate_input
    let r3 = pipeline(200);
    assert(!is_ok(r3));
    assert_eq(unwrap_err(r3), 11);

    // Pipeline overflow: 80 * 2 = 160 > 150
    let r4 = pipeline(80);
    assert(!is_ok(r4));
    assert_eq(unwrap_err(r4), 20);

    // Boundary: 75 * 2 = 150, not > 150, so Ok
    let r5 = pipeline(75);
    assert(is_ok(r5));
    assert_eq(unwrap_ok(r5), 151);

    0
}

// ============================================================================
// Nested error handling (multiple error domains)
// ============================================================================

fn parse_number(s: Int) -> Outcome {
    // Simulate: negative means "invalid parse"
    if s < 0 {
        make_err(100) // Parse error
    } else {
        make_ok(s)
    }
}

fn safe_calc(a: Int, b: Int) -> Outcome {
    if b == 0 {
        make_err(200) // Calc error: division by zero
    } else {
        make_ok(a / b)
    }
}

fn parse_and_calculate(input_a: Int, input_b: Int) -> Int {
    let pa = parse_number(input_a);
    if !is_ok(pa) {
        -1 // Parse failed for a
    } else {
        let pb = parse_number(input_b);
        if !is_ok(pb) {
            -2 // Parse failed for b
        } else {
            let a = unwrap_ok(pa);
            let b = unwrap_ok(pb);
            let result = safe_calc(a, b);
            if is_ok(result) {
                unwrap_ok(result)
            } else {
                -3 // Calculation failed
            }
        }
    }
}

fn test_nested_errors() -> Int {
    // Both valid, division succeeds
    assert_eq(parse_and_calculate(10, 2), 5);

    // First input invalid
    assert_eq(parse_and_calculate(-1, 2), -1);

    // Second input invalid
    assert_eq(parse_and_calculate(10, -1), -2);

    // Division by zero
    assert_eq(parse_and_calculate(10, 0), -3);

    // Both invalid — first error wins
    assert_eq(parse_and_calculate(-1, -2), -1);

    0
}

// ============================================================================
// Error recovery pattern
// ============================================================================

fn try_with_fallback(primary: Int, fallback: Int) -> Int {
    let r = safe_divide(100, primary);
    if is_ok(r) {
        unwrap_ok(r)
    } else {
        // Try fallback
        let r2 = safe_divide(100, fallback);
        if is_ok(r2) {
            unwrap_ok(r2)
        } else {
            -999 // Both failed
        }
    }
}

fn test_error_recovery() -> Int {
    // Primary succeeds
    assert_eq(try_with_fallback(5, 2), 20);

    // Primary fails, fallback succeeds
    assert_eq(try_with_fallback(0, 4), 25);

    // Both fail
    assert_eq(try_with_fallback(0, 0), -999);

    0
}

// ============================================================================
// Accumulating errors pattern
// ============================================================================

fn count_valid(a: Int, b: Int, c: Int, d: Int) -> Int {
    let mut valid = 0;
    if is_ok(validate_input(a)) { valid = valid + 1; }
    if is_ok(validate_input(b)) { valid = valid + 1; }
    if is_ok(validate_input(c)) { valid = valid + 1; }
    if is_ok(validate_input(d)) { valid = valid + 1; }
    valid
}

fn test_accumulating_errors() -> Int {
    // All valid
    assert_eq(count_valid(10, 20, 30, 40), 4);

    // Some invalid
    assert_eq(count_valid(-1, 20, 200, 40), 2);

    // All invalid
    assert_eq(count_valid(-1, -2, 200, 300), 0);

    // Edge values: 0 and 100 are valid
    assert_eq(count_valid(0, 100, -1, 101), 2);

    0
}

// ============================================================================
// Main: run all tests
// ============================================================================

fn main() -> Int {
    test_basic_error_handling();
    test_error_propagation();
    test_nested_errors();
    test_error_recovery();
    test_accumulating_errors();

    print("[OK] 121_error_handling_aot");
    0
}
