// @test: run
// @level: L0
// @tier: 0
// @tags: iterator, protocol, for-in, e2e
// @description: Test custom iterator protocol with has_next/next and while-loop consumption

type MyRange is {
    current: Int,
    end_val: Int,
    step: Int,
};

implement MyRange {
    fn new(start: Int, end_val: Int) -> MyRange {
        MyRange { current: start, end_val: end_val, step: 1 }
    }

    fn with_step(start: Int, end_val: Int, step: Int) -> MyRange {
        MyRange { current: start, end_val: end_val, step: step }
    }

    fn has_next(&self) -> Bool {
        self.current < self.end_val
    }

    fn value(&self) -> Int {
        self.current
    }
}

fn range_next(r: MyRange) -> MyRange {
    MyRange { current: r.current + r.step, end_val: r.end_val, step: r.step }
}

type FibIter is {
    a: Int,
    b: Int,
    count: Int,
    limit: Int,
};

implement FibIter {
    fn new(limit: Int) -> FibIter {
        FibIter { a: 0, b: 1, count: 0, limit: limit }
    }

    fn has_next(&self) -> Bool {
        self.count < self.limit
    }

    fn value(&self) -> Int {
        self.a
    }
}

fn fib_next(f: FibIter) -> FibIter {
    FibIter { a: f.b, b: f.a + f.b, count: f.count + 1, limit: f.limit }
}

fn main() -> Int {
    let mut failures = 0;

    // Test 1: Custom range iterator
    let mut r = MyRange.new(1, 6);
    let mut sum = 0;
    while r.has_next() {
        sum = sum + r.value();
        r = range_next(r);
    }
    if sum != 15 {
        print(f"FAIL: range sum expected 15, got {sum}");
        failures = failures + 1;
    } else {
        print("  range_iter: OK");
    }

    // Test 2: Range with step
    let mut r2 = MyRange.with_step(0, 10, 2);
    let mut evens = 0;
    while r2.has_next() {
        evens = evens + r2.value();
        r2 = range_next(r2);
    }
    if evens != 20 {
        print(f"FAIL: even sum expected 20, got {evens}");
        failures = failures + 1;
    } else {
        print("  step_iter: OK");
    }

    // Test 3: Fibonacci iterator
    let mut fib = FibIter.new(8);
    let mut fib_sum = 0;
    while fib.has_next() {
        fib_sum = fib_sum + fib.value();
        fib = fib_next(fib);
    }
    // 0+1+1+2+3+5+8+13 = 33
    if fib_sum != 33 {
        print(f"FAIL: fib sum expected 33, got {fib_sum}");
        failures = failures + 1;
    } else {
        print("  fib_iter: OK");
    }

    // Test 4: for-in on built-in range
    let mut range_sum = 0;
    for val in 1..6 {
        range_sum = range_sum + val;
    }
    if range_sum != 15 {
        print(f"FAIL: builtin range sum expected 15, got {range_sum}");
        failures = failures + 1;
    } else {
        print("  builtin_range: OK");
    }

    // Test 5: for-in on list
    let data = [10, 20, 30, 40, 50];
    let mut list_sum = 0;
    for item in data {
        list_sum = list_sum + item;
    }
    if list_sum != 150 {
        print(f"FAIL: list sum expected 150, got {list_sum}");
        failures = failures + 1;
    } else {
        print("  list_forin: OK");
    }

    if failures == 0 {
        print("All iterator protocol tests passed");
    }
    failures
}
