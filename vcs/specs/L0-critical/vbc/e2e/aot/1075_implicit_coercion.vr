// @test: run
// @tier: 0
// @level: L0
// @tags: coercion, int_float, implicit
// @expect: pass

// Test implicit Int→Float coercion.

fn process_float(x: Float) -> Float {
    x * 2.0
}

fn add_floats(a: Float, b: Float) -> Float {
    a + b
}

fn main() -> Int {
    // Test 1: Explicit cast (known working)
    let f1 = process_float(5 as Float);
    if (f1 as Int) != 10 {
        print(f"FAIL: explicit cast = {f1 as Int}");
        return 1;
    }

    // Test 2: Float literal
    let f2 = process_float(5.0);
    if (f2 as Int) != 10 {
        print(f"FAIL: float literal = {f2 as Int}");
        return 1;
    }

    // Test 3: Mixed arithmetic with explicit cast
    let sum = add_floats(3.0, (4 as Float));
    if (sum as Int) != 7 {
        print(f"FAIL: mixed = {sum as Int}");
        return 1;
    }

    print("PASS: numeric coercion works");
    0
}
