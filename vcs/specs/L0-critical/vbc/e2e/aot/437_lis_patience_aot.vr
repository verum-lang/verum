// @test: run
// @level: L0
// @tags: aot, e2e, lis, patience, sort, dp
// @timeout: 30000

// Longest Increasing Subsequence and patience sort

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn new_arr8() -> Arr8 {
    Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
}

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// LIS length O(n^2)
fn lis_len(arr: Arr8, n: Int) -> Int {
    let mut dp = new_arr8();
    let mut i = 0;
    while i < n {
        dp = set8(dp, i, 1);
        let mut j = 0;
        while j < i {
            if get8(arr, j) < get8(arr, i) {
                let candidate = get8(dp, j) + 1;
                if candidate > get8(dp, i) {
                    dp = set8(dp, i, candidate);
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let mut best = 0;
    let mut k = 0;
    while k < n {
        if get8(dp, k) > best { best = get8(dp, k); }
        k = k + 1;
    }
    best
}

// Longest Decreasing Subsequence length
fn lds_len(arr: Arr8, n: Int) -> Int {
    let mut dp = new_arr8();
    let mut i = 0;
    while i < n {
        dp = set8(dp, i, 1);
        let mut j = 0;
        while j < i {
            if get8(arr, j) > get8(arr, i) {
                let candidate = get8(dp, j) + 1;
                if candidate > get8(dp, i) {
                    dp = set8(dp, i, candidate);
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let mut best = 0;
    let mut k = 0;
    while k < n {
        if get8(dp, k) > best { best = get8(dp, k); }
        k = k + 1;
    }
    best
}

// Maximum sum increasing subsequence
fn max_sum_is(arr: Arr8, n: Int) -> Int {
    let mut dp = new_arr8();
    let mut i = 0;
    while i < n {
        dp = set8(dp, i, get8(arr, i));
        let mut j = 0;
        while j < i {
            if get8(arr, j) < get8(arr, i) {
                let candidate = get8(dp, j) + get8(arr, i);
                if candidate > get8(dp, i) {
                    dp = set8(dp, i, candidate);
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    let mut best = 0;
    let mut k = 0;
    while k < n {
        if get8(dp, k) > best { best = get8(dp, k); }
        k = k + 1;
    }
    best
}

fn test_lis() -> Int {
    // [3, 1, 4, 1, 5, 9, 2, 6]
    let arr = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 2, v7: 6 };
    assert_eq(lis_len(arr, 8), 4); // e.g. 1,4,5,9 or 1,4,5,6

    // Already sorted
    let sorted = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    assert_eq(lis_len(sorted, 8), 8);

    // Reverse sorted
    let rev = Arr8 { v0: 8, v1: 7, v2: 6, v3: 5, v4: 4, v5: 3, v6: 2, v7: 1 };
    assert_eq(lis_len(rev, 8), 1);
    1
}

fn test_lds() -> Int {
    let arr = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 2, v7: 6 };
    // LDS: [3,1], [4,1], [5,2], [9,2], [9,6] — all length 2
    assert_eq(lds_len(arr, 8), 2);

    // Reverse sorted → entire array is decreasing
    let rev = Arr8 { v0: 8, v1: 7, v2: 6, v3: 5, v4: 4, v5: 3, v6: 2, v7: 1 };
    assert_eq(lds_len(rev, 8), 8);

    // Already sorted → LDS is 1
    let sorted = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    assert_eq(lds_len(sorted, 8), 1);
    1
}

fn test_max_sum() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    // Max sum IS: 1+2+3+4+5 = 15
    assert_eq(max_sum_is(arr, 5), 15);

    let arr2 = Arr8 { v0: 5, v1: 4, v2: 3, v3: 2, v4: 1, v5: 0, v6: 0, v7: 0 };
    // Each element alone: max is 5
    assert_eq(max_sum_is(arr2, 5), 5);
    1
}

fn main() -> Int {
    test_lis();
    test_lds();
    test_max_sum();
    print("[OK] 437_lis_patience_aot");
    0
}
