// @test: run
// @level: L0
// @tags: aot, e2e, milestone, geometry, distance
// @timeout: 30000

// Milestone 630: Integer geometry - Manhattan/Chebyshev distance, convex hull basics, area

fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Point encoding: x * 10000 + y (both non-negative, < 10000)
fn pt_x(p: Int) -> Int { p / 10000 }
fn pt_y(p: Int) -> Int { p % 10000 }
fn make_pt(x: Int, y: Int) -> Int { x * 10000 + y }

// Manhattan distance
fn manhattan(p1: Int, p2: Int) -> Int {
    abs_val(pt_x(p1) - pt_x(p2)) + abs_val(pt_y(p1) - pt_y(p2))
}

// Chebyshev distance (max of dx, dy)
fn chebyshev(p1: Int, p2: Int) -> Int {
    max_val(abs_val(pt_x(p1) - pt_x(p2)), abs_val(pt_y(p1) - pt_y(p2)))
}

// Squared Euclidean distance (avoids sqrt)
fn dist_sq(p1: Int, p2: Int) -> Int {
    let dx = pt_x(p1) - pt_x(p2);
    let dy = pt_y(p1) - pt_y(p2);
    dx * dx + dy * dy
}

// Cross product of vectors (p2-p1) x (p3-p1) — 2x signed area
fn cross(p1: Int, p2: Int, p3: Int) -> Int {
    let x1 = pt_x(p2) - pt_x(p1);
    let y1 = pt_y(p2) - pt_y(p1);
    let x2 = pt_x(p3) - pt_x(p1);
    let y2 = pt_y(p3) - pt_y(p1);
    x1 * y2 - y1 * x2
}

// Orientation: positive = CCW, negative = CW, 0 = collinear
fn orientation(p1: Int, p2: Int, p3: Int) -> Int {
    let c = cross(p1, p2, p3);
    if c > 0 { 1 }
    else if c < 0 { 0 - 1 }
    else { 0 }
}

// 2x area of triangle (unsigned)
fn triangle_area2(p1: Int, p2: Int, p3: Int) -> Int {
    abs_val(cross(p1, p2, p3))
}

// Is point inside triangle? (using area method)
fn point_in_triangle(p: Int, a: Int, b: Int, c: Int) -> Int {
    let total = triangle_area2(a, b, c);
    let a1 = triangle_area2(p, b, c);
    let a2 = triangle_area2(a, p, c);
    let a3 = triangle_area2(a, b, p);
    if a1 + a2 + a3 == total { 1 } else { 0 }
}

// Bounding box area of a set of points
fn bbox_area(p1: Int, p2: Int, p3: Int, p4: Int) -> Int {
    let minx = min_val(min_val(pt_x(p1), pt_x(p2)), min_val(pt_x(p3), pt_x(p4)));
    let maxx = max_val(max_val(pt_x(p1), pt_x(p2)), max_val(pt_x(p3), pt_x(p4)));
    let miny = min_val(min_val(pt_y(p1), pt_y(p2)), min_val(pt_y(p3), pt_y(p4)));
    let maxy = max_val(max_val(pt_y(p1), pt_y(p2)), max_val(pt_y(p3), pt_y(p4)));
    (maxx - minx) * (maxy - miny)
}

// Dot product of vectors (p2-p1) . (p3-p1)
fn dot(p1: Int, p2: Int, p3: Int) -> Int {
    let x1 = pt_x(p2) - pt_x(p1);
    let y1 = pt_y(p2) - pt_y(p1);
    let x2 = pt_x(p3) - pt_x(p1);
    let y2 = pt_y(p3) - pt_y(p1);
    x1 * x2 + y1 * y2
}

// Is angle at p2 (in path p1-p2-p3) a right angle?
fn is_right_angle(p1: Int, p2: Int, p3: Int) -> Int {
    let x1 = pt_x(p1) - pt_x(p2);
    let y1 = pt_y(p1) - pt_y(p2);
    let x2 = pt_x(p3) - pt_x(p2);
    let y2 = pt_y(p3) - pt_y(p2);
    if x1 * x2 + y1 * y2 == 0 { 1 } else { 0 }
}

fn test_distances() -> Int {
    let a = make_pt(0, 0);
    let b = make_pt(3, 4);
    assert_eq(manhattan(a, b), 7);
    assert_eq(chebyshev(a, b), 4);
    assert_eq(dist_sq(a, b), 25); // 3^2 + 4^2

    let c = make_pt(1, 1);
    let d = make_pt(4, 5);
    assert_eq(manhattan(c, d), 7);
    assert_eq(chebyshev(c, d), 4);
    assert_eq(dist_sq(c, d), 25);

    // Self distance = 0
    assert_eq(manhattan(a, a), 0);
    assert_eq(chebyshev(a, a), 0);
    assert_eq(dist_sq(a, a), 0);
    1
}

fn test_orientation() -> Int {
    let a = make_pt(0, 0);
    let b = make_pt(4, 0);
    let c = make_pt(4, 3);
    // a -> b -> c is CCW
    assert_eq(orientation(a, b, c), 1);
    // a -> c -> b is CW
    assert_eq(orientation(a, c, b), 0 - 1);
    // Collinear
    let d = make_pt(2, 0);
    assert_eq(orientation(a, d, b), 0);
    1
}

fn test_triangle_area() -> Int {
    // Right triangle with legs 3, 4 => area = 6, 2x area = 12
    let a = make_pt(0, 0);
    let b = make_pt(3, 0);
    let c = make_pt(0, 4);
    assert_eq(triangle_area2(a, b, c), 12);

    // Degenerate triangle (collinear) => area = 0
    let d = make_pt(2, 0);
    assert_eq(triangle_area2(a, d, b), 0);
    1
}

fn test_point_in_triangle() -> Int {
    let a = make_pt(0, 0);
    let b = make_pt(6, 0);
    let c = make_pt(3, 6);

    // Center should be inside
    let center = make_pt(3, 2);
    assert_eq(point_in_triangle(center, a, b, c), 1);

    // Vertex is inside (on boundary)
    assert_eq(point_in_triangle(a, a, b, c), 1);

    // Far away point
    let outside = make_pt(10, 10);
    assert_eq(point_in_triangle(outside, a, b, c), 0);
    1
}

fn test_bbox() -> Int {
    let a = make_pt(1, 2);
    let b = make_pt(5, 8);
    let c = make_pt(3, 3);
    let d = make_pt(7, 5);
    // bbox: x=[1,7], y=[2,8], area = 6*6 = 36
    assert_eq(bbox_area(a, b, c, d), 36);
    1
}

fn test_right_angle() -> Int {
    let a = make_pt(0, 0);
    let b = make_pt(3, 0);
    let c = make_pt(3, 4);
    // Angle at b (between a-b and b-c) is 90 degrees
    assert_eq(is_right_angle(a, b, c), 1);
    // Angle at a is not 90
    assert_eq(is_right_angle(b, a, c), 0);
    1
}

fn test_dot_product() -> Int {
    let o = make_pt(0, 0);
    let a = make_pt(3, 0);
    let b = make_pt(0, 4);
    // (3,0) . (0,4) = 0 (perpendicular)
    assert_eq(dot(o, a, b), 0);

    let c = make_pt(3, 4);
    // (3,0) . (3,4) = 9
    assert_eq(dot(o, a, c), 9);
    1
}

fn main() -> Int {
    test_distances();
    test_orientation();
    test_triangle_area();
    test_point_in_triangle();
    test_bbox();
    test_right_angle();
    test_dot_product();
    print("[OK] 630_milestone_aot");
    0
}
