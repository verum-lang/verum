// @test: run
// @level: L0
// @tags: aot, e2e, milestone, vm, assembler
// @timeout: 30000

// Milestone: Simple assembler VM with labels and jumps

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// VM instructions encoded as: opcode * 10000 + arg1 * 100 + arg2
// Opcodes:
// 1 = MOV reg, imm (reg=arg1, imm=arg2)
// 2 = ADD reg1, reg2 (reg1 += reg2)
// 3 = SUB reg1, reg2
// 4 = MUL reg1, reg2
// 5 = CMP reg1, reg2 (set flag: 0=eq, 1=gt, -1=lt) → store in reg 7
// 6 = JMP addr (unconditional)
// 7 = JEQ addr (jump if flag==0)
// 8 = JNE addr (jump if flag!=0)
// 9 = HALT

type VMResult is { regs: Arr8, flag: Int };

fn vm_run(prog: Arr8, prog_len: Int) -> VMResult {
    let mut regs = zeros();
    let mut flag = 0;
    let mut pc = 0;
    let mut steps = 0;
    while pc < prog_len {
        let instr = get8(prog, pc);
        let op = instr / 10000;
        let a1 = (instr / 100) % 100;
        let a2 = instr % 100;

        if op == 1 {
            // MOV reg, imm
            regs = set8(regs, a1, a2);
            pc = pc + 1;
        } else if op == 2 {
            // ADD reg1, reg2
            regs = set8(regs, a1, get8(regs, a1) + get8(regs, a2));
            pc = pc + 1;
        } else if op == 3 {
            // SUB reg1, reg2
            regs = set8(regs, a1, get8(regs, a1) - get8(regs, a2));
            pc = pc + 1;
        } else if op == 4 {
            // MUL reg1, reg2
            regs = set8(regs, a1, get8(regs, a1) * get8(regs, a2));
            pc = pc + 1;
        } else if op == 5 {
            // CMP
            let v1 = get8(regs, a1);
            let v2 = get8(regs, a2);
            if v1 == v2 { flag = 0; }
            else if v1 > v2 { flag = 1; }
            else { flag = -1; }
            pc = pc + 1;
        } else if op == 6 {
            // JMP
            pc = a1;
        } else if op == 7 {
            // JEQ
            if flag == 0 { pc = a1; }
            else { pc = pc + 1; }
        } else if op == 8 {
            // JNE
            if flag != 0 { pc = a1; }
            else { pc = pc + 1; }
        } else if op == 9 {
            pc = prog_len; // halt
            pc = pc - 1;
        } else {
            pc = pc + 1;
        }

        steps = steps + 1;
        if steps > 200 { pc = prog_len; } // safety limit
    }
    VMResult { regs: regs, flag: flag }
}

fn test_simple_mov_add() -> Int {
    // MOV r0, 5; MOV r1, 3; ADD r0, r1; HALT
    // 10005, 10103, 20001, 90000
    let prog = Arr8 { v0: 10005, v1: 10103, v2: 20001, v3: 90000, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = vm_run(prog, 4);
    assert_eq(get8(result.regs, 0), 8); // 5+3
    assert_eq(get8(result.regs, 1), 3);
    1
}

fn test_multiply() -> Int {
    // MOV r0, 7; MOV r1, 6; MUL r0, r1; HALT
    let prog = Arr8 { v0: 10007, v1: 10106, v2: 40001, v3: 90000, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = vm_run(prog, 4);
    assert_eq(get8(result.regs, 0), 42);
    1
}

fn test_loop_countdown() -> Int {
    // Count down from 5 to 0, adding to r1 each iteration
    // 0: MOV r0, 5     → 10005
    // 1: MOV r1, 0     → 10100
    // 2: MOV r2, 1     → 10201
    // 3: ADD r1, r0    → 20100    (loop start)
    // 4: SUB r0, r2    → 30002
    // 5: MOV r3, 0     → 10300
    // 6: CMP r0, r3    → 50003
    // 7: JNE 3         → 80300    (back to loop start)
    let prog = Arr8 { v0: 10005, v1: 10100, v2: 10201, v3: 20100, v4: 30002, v5: 10300, v6: 50003, v7: 80300 };
    let result = vm_run(prog, 8);
    assert_eq(get8(result.regs, 0), 0);  // counter = 0
    assert_eq(get8(result.regs, 1), 15); // 5+4+3+2+1 = 15
    1
}

fn test_conditional() -> Int {
    // If r0 == r1, set r2=1, else set r2=2
    // 0: MOV r0, 5     → 10005
    // 1: MOV r1, 5     → 10105
    // 2: CMP r0, r1    → 50001
    // 3: JNE 6         → 80600
    // 4: MOV r2, 1     → 10201    (equal path)
    // 5: JMP 7         → 60700
    // 6: MOV r2, 2     → 10202    (not-equal path)
    // 7: HALT          (not in prog since prog_len=7, just falls off)
    let prog = Arr8 { v0: 10005, v1: 10105, v2: 50001, v3: 80600, v4: 10201, v5: 60700, v6: 10202, v7: 0 };
    let result = vm_run(prog, 7);
    assert_eq(get8(result.regs, 2), 1); // equal → r2=1
    1
}

fn test_conditional_ne() -> Int {
    // Same but r0 != r1
    let prog = Arr8 { v0: 10005, v1: 10103, v2: 50001, v3: 80600, v4: 10201, v5: 60700, v6: 10202, v7: 0 };
    let result = vm_run(prog, 7);
    assert_eq(get8(result.regs, 2), 2); // not equal → r2=2
    1
}

fn test_factorial_vm() -> Int {
    // Compute 5! = 120
    // r0 = n (counter), r1 = result, r2 = 1 (constant)
    // 0: MOV r0, 5     → 10005
    // 1: MOV r1, 1     → 10101
    // 2: MOV r2, 1     → 10201
    // 3: MUL r1, r0    → 40100    (loop: result *= n)
    // 4: SUB r0, r2    → 30002    (n--)
    // 5: MOV r3, 1     → 10301
    // 6: CMP r0, r3    → 50003    (compare n with 1)
    // 7: JNE 3         → 80300    (if n!=1, continue)
    let prog = Arr8 { v0: 10005, v1: 10101, v2: 10201, v3: 40100, v4: 30002, v5: 10301, v6: 50003, v7: 80300 };
    let result = vm_run(prog, 8);
    assert_eq(get8(result.regs, 0), 1);   // counter ended at 1
    assert_eq(get8(result.regs, 1), 120); // 5! = 120
    1
}

fn main() -> Int {
    test_simple_mov_add();
    test_multiply();
    test_loop_countdown();
    test_conditional();
    test_conditional_ne();
    test_factorial_vm();
    print("[OK] 505_milestone_aot");
    0
}
