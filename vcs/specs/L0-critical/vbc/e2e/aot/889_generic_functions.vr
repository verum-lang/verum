// @test: run
// @tier: 0
// @level: L0
// @tags: aot, generics, monomorphization, type-params
// @expected-exit: 0

// Test: generic functions and type parameters.

fn identity<T>(x: T) -> T {
    x
}

fn first<A, B>(a: A, b: B) -> A {
    a
}

fn second<A, B>(a: A, b: B) -> B {
    b
}

type Pair<T> is {
    fst: T,
    snd: T,
};

fn make_pair<T>(a: T, b: T) -> Pair<T> {
    Pair { fst: a, snd: b }
}

fn swap_pair<T>(p: Pair<T>) -> Pair<T> {
    Pair { fst: p.snd, snd: p.fst }
}

fn main() -> Int {
    // Test 1: identity with Int
    let r1 = identity(42);
    if (r1 != 42) {
        print(f"FAIL test1: identity(42)={r1}");
        return 1;
    }

    // Test 2: first/second selectors
    let r2 = first(10, 20);
    if (r2 != 10) {
        print(f"FAIL test2: first(10,20)={r2}");
        return 1;
    }
    let r3 = second(10, 20);
    if (r3 != 20) {
        print(f"FAIL test3: second(10,20)={r3}");
        return 1;
    }

    // Test 3: generic record type
    let p = make_pair(3, 7);
    if (p.fst != 3) {
        print(f"FAIL test3a: p.fst={p.fst}");
        return 1;
    }
    if (p.snd != 7) {
        print(f"FAIL test3b: p.snd={p.snd}");
        return 1;
    }

    // Test 4: generic function on record
    let swapped = swap_pair(p);
    if (swapped.fst != 7) {
        print(f"FAIL test4a: swapped.fst={swapped.fst}");
        return 1;
    }
    if (swapped.snd != 3) {
        print(f"FAIL test4b: swapped.snd={swapped.snd}");
        return 1;
    }

    // Test 5: chained generic calls
    let r5 = identity(identity(identity(99)));
    if (r5 != 99) {
        print(f"FAIL test5: triple identity={r5}");
        return 1;
    }

    print("889_generic_functions: PASS");
    0
}
