// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, option, result, error-handling, variants
// @timeout: 50000
// @expected-exit: 0
// @description: AOT Option and Result types with chaining

type Maybe is Nothing | Just(Int);
type Outcome is Ok(Int) | Err(Int);

fn maybe_map(m: Maybe, f: fn(Int) -> Int) -> Maybe {
    match m {
        Nothing => Nothing,
        Just(x) => Just(f(x)),
    }
}

fn maybe_flat_map(m: Maybe, f: fn(Int) -> Maybe) -> Maybe {
    match m {
        Nothing => Nothing,
        Just(x) => f(x),
    }
}

fn maybe_unwrap_or(m: Maybe, default: Int) -> Int {
    match m {
        Nothing => default,
        Just(x) => x,
    }
}

fn maybe_is_just(m: Maybe) -> Bool {
    m is Just
}

fn outcome_map(r: Outcome, f: fn(Int) -> Int) -> Outcome {
    match r {
        Ok(x) => Ok(f(x)),
        Err(e) => Err(e),
    }
}

fn outcome_flat_map(r: Outcome, f: fn(Int) -> Outcome) -> Outcome {
    match r {
        Ok(x) => f(x),
        Err(e) => Err(e),
    }
}

fn outcome_unwrap_or(r: Outcome, default: Int) -> Int {
    match r {
        Ok(x) => x,
        Err(_) => default,
    }
}

fn outcome_is_ok(r: Outcome) -> Bool {
    r is Ok
}

fn safe_div(a: Int, b: Int) -> Outcome {
    if b == 0 { Err(-1) }
    else { Ok(a / b) }
}

fn safe_sqrt(n: Int) -> Maybe {
    if n < 0 { Nothing }
    else {
        // Integer square root
        let mut r = 0;
        while (r + 1) * (r + 1) <= n {
            r = r + 1;
        }
        Just(r)
    }
}

fn main() -> Int {
    // Maybe basics
    let j = Just(42);
    let n = Nothing;
    assert(maybe_is_just(j));
    assert(!maybe_is_just(n));
    assert_eq(maybe_unwrap_or(j, 0), 42);
    assert_eq(maybe_unwrap_or(n, -1), -1);

    // Maybe map
    let doubled = maybe_map(j, |x| x * 2);
    assert_eq(maybe_unwrap_or(doubled, 0), 84);
    let still_nothing = maybe_map(n, |x| x * 2);
    assert(!maybe_is_just(still_nothing));

    // Maybe flat_map
    let sqrt_result = maybe_flat_map(Just(16), |x| safe_sqrt(x));
    assert_eq(maybe_unwrap_or(sqrt_result, -1), 4);
    let neg_result = maybe_flat_map(Just(-5), |x| safe_sqrt(x));
    assert(!maybe_is_just(neg_result));
    let chain_nothing = maybe_flat_map(Nothing, |x| safe_sqrt(x));
    assert(!maybe_is_just(chain_nothing));

    // Outcome basics
    let ok_val = Ok(100);
    let err_val = Err(42);
    assert(outcome_is_ok(ok_val));
    assert(!outcome_is_ok(err_val));
    assert_eq(outcome_unwrap_or(ok_val, 0), 100);
    assert_eq(outcome_unwrap_or(err_val, 0), 0);

    // Outcome map
    let doubled_ok = outcome_map(ok_val, |x| x * 2);
    assert_eq(outcome_unwrap_or(doubled_ok, 0), 200);
    let doubled_err = outcome_map(err_val, |x| x * 2);
    assert(!outcome_is_ok(doubled_err));

    // Safe division
    assert_eq(outcome_unwrap_or(safe_div(10, 2), -1), 5);
    assert_eq(outcome_unwrap_or(safe_div(10, 3), -1), 3);
    assert(!outcome_is_ok(safe_div(10, 0)));

    // Chain safe operations
    let chain = outcome_flat_map(
        safe_div(100, 5),
        |x| safe_div(x, 2)
    );
    assert_eq(outcome_unwrap_or(chain, -1), 10);  // 100/5=20, 20/2=10

    let chain_err = outcome_flat_map(
        safe_div(100, 0),
        |x| safe_div(x, 2)
    );
    assert(!outcome_is_ok(chain_err));

    // Safe sqrt chaining
    assert_eq(maybe_unwrap_or(safe_sqrt(0), -1), 0);
    assert_eq(maybe_unwrap_or(safe_sqrt(1), -1), 1);
    assert_eq(maybe_unwrap_or(safe_sqrt(4), -1), 2);
    assert_eq(maybe_unwrap_or(safe_sqrt(9), -1), 3);
    assert_eq(maybe_unwrap_or(safe_sqrt(100), -1), 10);
    assert(!maybe_is_just(safe_sqrt(-1)));

    // Complex chain: divide then sqrt
    let complex = outcome_flat_map(
        safe_div(200, 2),
        |x| {
            match safe_sqrt(x) {
                Just(r) => Ok(r),
                Nothing => Err(-2),
            }
        }
    );
    assert_eq(outcome_unwrap_or(complex, -1), 10);  // 200/2=100, sqrt(100)=10

    0
}
