// @test: run
// @level: L0
// @tags: aot, e2e, roman-numerals, conversion, encoding
// @timeout: 30000

// Roman numeral encoding using integer representation
// Encode: M=1000, D=500, C=100, L=50, X=10, V=5, I=1
// Store a "roman numeral" as sequence of digit codes in Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Roman digit values: codes 1-7 for I, V, X, L, C, D, M
fn roman_val(code: Int) -> Int {
    if code == 1 { 1 }
    else if code == 2 { 5 }
    else if code == 3 { 10 }
    else if code == 4 { 50 }
    else if code == 5 { 100 }
    else if code == 6 { 500 }
    else if code == 7 { 1000 }
    else { 0 }
}

// Evaluate roman numeral from Arr8 of codes (0 = end)
fn roman_to_int(codes: Arr8, n: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        let cur = roman_val(get8(codes, i));
        if i + 1 < n {
            let next = roman_val(get8(codes, i + 1));
            if cur < next {
                // Subtractive: IV=4, IX=9, etc.
                total = total + next - cur;
                i = i + 2;
            } else {
                total = total + cur;
                i = i + 1;
            }
        } else {
            total = total + cur;
            i = i + 1;
        }
    }
    total
}

// Convert integer to roman numeral codes (simplified, returns length)
// Store result in result Arr8
fn int_to_roman_len(n: Int) -> Int {
    let mut val = n;
    let mut len = 0;
    // M (1000)
    while val >= 1000 { len = len + 1; val = val - 1000; }
    // CM (900)
    if val >= 900 { len = len + 2; val = val - 900; }
    // D (500)
    if val >= 500 { len = len + 1; val = val - 500; }
    // CD (400)
    if val >= 400 { len = len + 2; val = val - 400; }
    // C (100)
    while val >= 100 { len = len + 1; val = val - 100; }
    // XC (90)
    if val >= 90 { len = len + 2; val = val - 90; }
    // L (50)
    if val >= 50 { len = len + 1; val = val - 50; }
    // XL (40)
    if val >= 40 { len = len + 2; val = val - 40; }
    // X (10)
    while val >= 10 { len = len + 1; val = val - 10; }
    // IX (9)
    if val >= 9 { len = len + 2; val = val - 9; }
    // V (5)
    if val >= 5 { len = len + 1; val = val - 5; }
    // IV (4)
    if val >= 4 { len = len + 2; val = val - 4; }
    // I (1)
    while val >= 1 { len = len + 1; val = val - 1; }
    len
}

fn int_to_roman(n: Int) -> Arr8 {
    let mut val = n;
    let mut result = zeros();
    let mut pos = 0;
    while val >= 1000 { result = set8(result, pos, 7); pos = pos + 1; val = val - 1000; }
    if val >= 900 { result = set8(result, pos, 5); result = set8(result, pos + 1, 7); pos = pos + 2; val = val - 900; }
    if val >= 500 { result = set8(result, pos, 6); pos = pos + 1; val = val - 500; }
    if val >= 400 { result = set8(result, pos, 5); result = set8(result, pos + 1, 6); pos = pos + 2; val = val - 400; }
    while val >= 100 { result = set8(result, pos, 5); pos = pos + 1; val = val - 100; }
    if val >= 90 { result = set8(result, pos, 3); result = set8(result, pos + 1, 5); pos = pos + 2; val = val - 90; }
    if val >= 50 { result = set8(result, pos, 4); pos = pos + 1; val = val - 50; }
    if val >= 40 { result = set8(result, pos, 3); result = set8(result, pos + 1, 4); pos = pos + 2; val = val - 40; }
    while val >= 10 { result = set8(result, pos, 3); pos = pos + 1; val = val - 10; }
    if val >= 9 { result = set8(result, pos, 1); result = set8(result, pos + 1, 3); pos = pos + 2; val = val - 9; }
    if val >= 5 { result = set8(result, pos, 2); pos = pos + 1; val = val - 5; }
    if val >= 4 { result = set8(result, pos, 1); result = set8(result, pos + 1, 2); pos = pos + 2; val = val - 4; }
    while val >= 1 { result = set8(result, pos, 1); pos = pos + 1; val = val - 1; }
    result
}

fn test_basic_values() -> Int {
    // I = 1
    let i_r = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(i_r, 1), 1);
    // V = 5
    let v_r = Arr8 { v0: 2, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(v_r, 1), 5);
    // X = 10
    let x_r = Arr8 { v0: 3, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(x_r, 1), 10);
    1
}

fn test_subtractive() -> Int {
    // IV = 4
    let iv = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(iv, 2), 4);
    // IX = 9
    let ix = Arr8 { v0: 1, v1: 3, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(ix, 2), 9);
    // XL = 40
    let xl = Arr8 { v0: 3, v1: 4, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(xl, 2), 40);
    // XC = 90
    let xc = Arr8 { v0: 3, v1: 5, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(xc, 2), 90);
    1
}

fn test_roundtrip() -> Int {
    // Convert int → roman → int, should get back same value
    // 14: XIV
    let r14 = int_to_roman(14);
    let len14 = int_to_roman_len(14);
    assert_eq(roman_to_int(r14, len14), 14);
    // 42: XLII
    let r42 = int_to_roman(42);
    let len42 = int_to_roman_len(42);
    assert_eq(roman_to_int(r42, len42), 42);
    // 99: XCIX
    let r99 = int_to_roman(99);
    let len99 = int_to_roman_len(99);
    assert_eq(roman_to_int(r99, len99), 99);
    1
}

fn test_compound() -> Int {
    // XXIII = 23
    let xxiii = Arr8 { v0: 3, v1: 3, v2: 1, v3: 1, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(xxiii, 5), 23);
    // LVIII = 58
    let lviii = Arr8 { v0: 4, v1: 2, v2: 1, v3: 1, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_to_int(lviii, 5), 58);
    1
}

fn test_lengths() -> Int {
    assert_eq(int_to_roman_len(1), 1);    // I
    assert_eq(int_to_roman_len(3), 3);    // III
    assert_eq(int_to_roman_len(4), 2);    // IV
    assert_eq(int_to_roman_len(8), 4);    // VIII
    assert_eq(int_to_roman_len(9), 2);    // IX
    1
}

fn main() -> Int {
    test_basic_values();
    test_subtractive();
    test_roundtrip();
    test_compound();
    test_lengths();
    print("[OK] 694_roman_numerals_aot");
    0
}
