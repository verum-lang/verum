// @test: run
// @tier: 0
// @level: L0
// @tags: aot, impl, methods, self, protocols
// @expected-exit: 0

// Test: implement blocks, method calls, self, protocol-like dispatch.

type Vec2 is {
    x: Int,
    y: Int,
};

implement Vec2 {
    fn new(x: Int, y: Int) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn dot(&self, other: &Vec2) -> Int {
        self.x * other.x + self.y * other.y
    }

    fn magnitude_sq(&self) -> Int {
        self.x * self.x + self.y * self.y
    }

    fn add(&self, other: &Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }

    fn scale(&self, factor: Int) -> Vec2 {
        Vec2 { x: self.x * factor, y: self.y * factor }
    }
}

type Counter is {
    count: Int,
    step: Int,
};

implement Counter {
    fn new(step: Int) -> Counter {
        Counter { count: 0, step: step }
    }

    fn increment(&mut self) {
        self.count = self.count + self.step;
    }

    fn get(&self) -> Int {
        self.count
    }

    fn reset(&mut self) {
        self.count = 0;
    }
}

type Stack is {
    data: List<Int>,
    size: Int,
};

implement Stack {
    fn new() -> Stack {
        Stack { data: [], size: 0 }
    }

    fn push(&mut self, val: Int) {
        self.data.push(val);
        self.size = self.size + 1;
    }

    fn peek(&self) -> Int {
        if (self.size == 0) { return 0; }
        self.data[self.size - 1]
    }

    fn len(&self) -> Int {
        self.size
    }
}

fn main() -> Int {
    // Test 1: Vec2 methods
    let a = Vec2.new(3, 4);
    let b = Vec2.new(1, 2);

    let dot_ab = a.dot(&b);
    // 3*1 + 4*2 = 11
    if (dot_ab != 11) {
        print(f"FAIL test1a: dot={dot_ab}");
        return 1;
    }

    let mag = a.magnitude_sq();
    // 3*3 + 4*4 = 25
    if (mag != 25) {
        print(f"FAIL test1b: mag_sq={mag}");
        return 1;
    }

    let sum = a.add(&b);
    if (sum.x != 4) {
        print(f"FAIL test1c: sum.x={sum.x}");
        return 1;
    }
    if (sum.y != 6) {
        print(f"FAIL test1d: sum.y={sum.y}");
        return 1;
    }

    let scaled = a.scale(3);
    if (scaled.x != 9) {
        print(f"FAIL test1e: scaled.x={scaled.x}");
        return 1;
    }

    // Test 2: mutable self methods
    let mut c = Counter.new(5);
    c.increment();
    c.increment();
    c.increment();
    let count = c.get();
    if (count != 15) {
        print(f"FAIL test2a: count={count}");
        return 1;
    }
    c.reset();
    if (c.get() != 0) {
        print(f"FAIL test2b: after reset={c.get()}");
        return 1;
    }

    // Test 3: Stack with list operations
    let mut s = Stack.new();
    s.push(10);
    s.push(20);
    s.push(30);
    if (s.len() != 3) {
        print(f"FAIL test3a: len={s.len()}");
        return 1;
    }
    if (s.peek() != 30) {
        print(f"FAIL test3b: peek={s.peek()}");
        return 1;
    }

    print("891_impl_methods: PASS");
    0
}
