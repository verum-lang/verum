// @test: run
// @level: L0
// @tags: aot, e2e, milestone, sorting, comparison
// @timeout: 30000

// Milestone 675: Sorting algorithms comparison

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn is_sorted(a: Arr8, n: Int) -> Int {
    let mut ok = 1;
    let mut i = 0;
    while i < n - 1 {
        if get8(a, i) > get8(a, i + 1) { ok = 0; }
        i = i + 1;
    }
    ok
}

fn swap8(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = get8(a, i);
    let vj = get8(a, j);
    let tmp = set8(a, i, vj);
    set8(tmp, j, vi)
}

// Bubble sort
fn bubble_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut j = 0;
        while j < n - 1 - i {
            if get8(arr, j) > get8(arr, j + 1) {
                arr = swap8(arr, j, j + 1);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

// Selection sort
fn selection_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if get8(arr, j) < get8(arr, min_idx) { min_idx = j; }
            j = j + 1;
        }
        if min_idx != i {
            arr = swap8(arr, i, min_idx);
        }
        i = i + 1;
    }
    arr
}

// Insertion sort
fn insertion_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 1;
    while i < n {
        let key = get8(arr, i);
        let mut j = i;
        let mut pos = i;
        while j > 0 {
            if get8(arr, j - 1) > key {
                arr = set8(arr, j, get8(arr, j - 1));
                j = j - 1;
                pos = j;
            } else {
                j = 0;
            }
        }
        arr = set8(arr, pos, key);
        i = i + 1;
    }
    arr
}

// Shell sort (gaps: 4, 2, 1)
fn shell_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut gap = 4;
    while gap >= 1 {
        let mut i = gap;
        while i < n {
            let key = get8(arr, i);
            let mut j = i;
            let mut pos = i;
            while j >= gap {
                if get8(arr, j - gap) > key {
                    arr = set8(arr, j, get8(arr, j - gap));
                    j = j - gap;
                    pos = j;
                } else {
                    j = 0;
                }
            }
            arr = set8(arr, pos, key);
            i = i + 1;
        }
        gap = gap / 2;
    }
    arr
}

// Counting sort for values 0-7
fn counting_sort(a: Arr8, n: Int) -> Arr8 {
    // Count occurrences
    let mut counts = zeros();
    let mut i = 0;
    while i < n {
        let v = get8(a, i);
        counts = set8(counts, v, get8(counts, v) + 1);
        i = i + 1;
    }
    // Build sorted output
    let mut result = zeros();
    let mut pos = 0;
    let mut v = 0;
    while v < 8 {
        let mut c = 0;
        while c < get8(counts, v) {
            result = set8(result, pos, v);
            pos = pos + 1;
            c = c + 1;
        }
        v = v + 1;
    }
    result
}

fn test_data() -> Arr8 {
    Arr8 { v0: 5, v1: 2, v2: 7, v3: 1, v4: 4, v5: 6, v6: 3, v7: 0 }
}

fn test_bubble() -> Int {
    let sorted = bubble_sort(test_data(), 8);
    assert_eq(is_sorted(sorted, 8), 1);
    assert_eq(get8(sorted, 0), 0);
    assert_eq(get8(sorted, 7), 7);
    1
}

fn test_selection() -> Int {
    let sorted = selection_sort(test_data(), 8);
    assert_eq(is_sorted(sorted, 8), 1);
    assert_eq(get8(sorted, 0), 0);
    assert_eq(get8(sorted, 7), 7);
    1
}

fn test_insertion() -> Int {
    let sorted = insertion_sort(test_data(), 8);
    assert_eq(is_sorted(sorted, 8), 1);
    assert_eq(get8(sorted, 0), 0);
    assert_eq(get8(sorted, 7), 7);
    1
}

fn test_shell() -> Int {
    let sorted = shell_sort(test_data(), 8);
    assert_eq(is_sorted(sorted, 8), 1);
    assert_eq(get8(sorted, 0), 0);
    assert_eq(get8(sorted, 7), 7);
    1
}

fn test_counting() -> Int {
    let sorted = counting_sort(test_data(), 8);
    assert_eq(is_sorted(sorted, 8), 1);
    assert_eq(get8(sorted, 0), 0);
    assert_eq(get8(sorted, 7), 7);
    1
}

fn test_already_sorted() -> Int {
    let data = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 0 };
    // Actually not sorted (0 at end), fix:
    let sorted_data = Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 4, v5: 5, v6: 6, v7: 7 };
    assert_eq(is_sorted(bubble_sort(sorted_data, 8), 8), 1);
    assert_eq(is_sorted(selection_sort(sorted_data, 8), 8), 1);
    assert_eq(is_sorted(insertion_sort(sorted_data, 8), 8), 1);
    1
}

fn test_reverse() -> Int {
    let rev = Arr8 { v0: 7, v1: 6, v2: 5, v3: 4, v4: 3, v5: 2, v6: 1, v7: 0 };
    let bs = bubble_sort(rev, 8);
    let ss = selection_sort(rev, 8);
    let ins = insertion_sort(rev, 8);
    assert_eq(is_sorted(bs, 8), 1);
    assert_eq(is_sorted(ss, 8), 1);
    assert_eq(is_sorted(ins, 8), 1);
    // All produce same result
    let mut same = 1;
    let mut i = 0;
    while i < 8 {
        if get8(bs, i) != get8(ss, i) { same = 0; }
        if get8(bs, i) != get8(ins, i) { same = 0; }
        i = i + 1;
    }
    assert_eq(same, 1);
    1
}

fn main() -> Int {
    test_bubble();
    test_selection();
    test_insertion();
    test_shell();
    test_counting();
    test_already_sorted();
    test_reverse();
    print("[OK] 675_milestone_aot");
    0
}
