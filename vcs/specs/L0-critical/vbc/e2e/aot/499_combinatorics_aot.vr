// @test: run
// @level: L0
// @tags: aot, e2e, combinatorics, counting, pascal
// @timeout: 30000

// Combinatorics: binomial coefficients, Catalan numbers, permutations

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Factorial
fn factorial(n: Int) -> Int {
    let mut r = 1;
    let mut i = 2;
    while i <= n { r = r * i; i = i + 1; }
    r
}

// Binomial coefficient using Pascal's triangle row
// C(n, k) using rolling row
fn binomial(n: Int, k: Int) -> Int {
    if k > n { return 0; }
    if k == 0 { return 1; }
    if k == n { return 1; }
    // Use Pascal's recurrence with single row
    let mut row = zeros();
    row = set8(row, 0, 1);
    let mut i = 1;
    while i <= n {
        let mut j = if i < 7 { i } else { 7 };
        while j >= 1 {
            row = set8(row, j, get8(row, j) + get8(row, j - 1));
            j = j - 1;
        }
        i = i + 1;
    }
    get8(row, k)
}

// Catalan number: C(n) = C(2n,n) / (n+1)
fn catalan(n: Int) -> Int {
    binomial(2 * n, n) / (n + 1)
}

// Derangements: D(n) = (n-1) * (D(n-1) + D(n-2))
fn derangements(n: Int) -> Int {
    if n == 0 { return 1; }
    if n == 1 { return 0; }
    let mut prev2 = 1; // D(0)
    let mut prev1 = 0; // D(1)
    let mut i = 2;
    while i <= n {
        let cur = (i - 1) * (prev1 + prev2);
        prev2 = prev1;
        prev1 = cur;
        i = i + 1;
    }
    prev1
}

// Stirling numbers of the second kind S(n,k): ways to partition n items into k non-empty subsets
// S(n,k) = k*S(n-1,k) + S(n-1,k-1)
fn stirling2(n: Int, k: Int) -> Int {
    if n == 0 {
        if k == 0 { return 1; }
        return 0;
    }
    if k == 0 { return 0; }
    if k == 1 { return 1; }
    if k == n { return 1; }
    if k > n { return 0; }
    // Use DP with row for each k
    let mut prev = zeros();
    let mut cur = zeros();
    // Base: S(i, 1) = 1 for i >= 1
    let mut i = 1;
    while i <= n {
        prev = set8(prev, i, 1);
        i = i + 1;
    }
    // Fill for each k from 2 to target k
    let mut kk = 2;
    while kk <= k {
        cur = zeros();
        i = kk;
        while i <= n {
            cur = set8(cur, i, kk * get8(cur, i - 1) + get8(prev, i - 1));
            i = i + 1;
        }
        prev = cur;
        kk = kk + 1;
    }
    get8(prev, n)
}

// Bell number B(n): total partitions = sum of S(n,k) for k=0..n
fn bell(n: Int) -> Int {
    let mut sum = 0;
    let mut k = 0;
    while k <= n {
        sum = sum + stirling2(n, k);
        k = k + 1;
    }
    sum
}

// Number of permutations P(n,k) = n! / (n-k)!
fn permutations(n: Int, k: Int) -> Int {
    let mut r = 1;
    let mut i = n - k + 1;
    while i <= n { r = r * i; i = i + 1; }
    r
}

fn test_factorial() -> Int {
    assert_eq(factorial(0), 1);
    assert_eq(factorial(1), 1);
    assert_eq(factorial(5), 120);
    assert_eq(factorial(6), 720);
    assert_eq(factorial(7), 5040);
    1
}

fn test_binomial() -> Int {
    assert_eq(binomial(0, 0), 1);
    assert_eq(binomial(5, 0), 1);
    assert_eq(binomial(5, 5), 1);
    assert_eq(binomial(5, 2), 10);
    assert_eq(binomial(6, 3), 20);
    assert_eq(binomial(7, 3), 35);
    // Pascal's rule: C(n,k) = C(n-1,k-1) + C(n-1,k)
    assert_eq(binomial(6, 3), binomial(5, 2) + binomial(5, 3));
    // Symmetry: C(n,k) = C(n,n-k)
    assert_eq(binomial(7, 2), binomial(7, 5));
    1
}

fn test_catalan() -> Int {
    // Catalan sequence: 1, 1, 2, 5, 14, 42, ...
    assert_eq(catalan(0), 1);
    assert_eq(catalan(1), 1);
    assert_eq(catalan(2), 2);
    assert_eq(catalan(3), 5);
    assert_eq(catalan(4), 14);
    assert_eq(catalan(5), 42);
    1
}

fn test_derangements() -> Int {
    // D(0)=1, D(1)=0, D(2)=1, D(3)=2, D(4)=9, D(5)=44
    assert_eq(derangements(0), 1);
    assert_eq(derangements(1), 0);
    assert_eq(derangements(2), 1);
    assert_eq(derangements(3), 2);
    assert_eq(derangements(4), 9);
    assert_eq(derangements(5), 44);
    1
}

fn test_stirling() -> Int {
    assert_eq(stirling2(0, 0), 1);
    assert_eq(stirling2(3, 1), 1);
    assert_eq(stirling2(3, 2), 3);
    assert_eq(stirling2(3, 3), 1);
    assert_eq(stirling2(4, 2), 7);
    1
}

fn test_bell() -> Int {
    // Bell numbers: 1, 1, 2, 5, 15, 52
    assert_eq(bell(0), 1);
    assert_eq(bell(1), 1);
    assert_eq(bell(2), 2);
    assert_eq(bell(3), 5);
    assert_eq(bell(4), 15);
    assert_eq(bell(5), 52);
    1
}

fn test_permutations() -> Int {
    assert_eq(permutations(5, 0), 1);
    assert_eq(permutations(5, 1), 5);
    assert_eq(permutations(5, 2), 20);
    assert_eq(permutations(5, 5), 120);
    // P(n,n) = n!
    assert_eq(permutations(6, 6), factorial(6));
    1
}

fn main() -> Int {
    test_factorial();
    test_binomial();
    test_catalan();
    test_derangements();
    test_stirling();
    test_bell();
    test_permutations();
    print("[OK] 499_combinatorics_aot");
    0
}
