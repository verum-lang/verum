// @test: run
// @level: L0
// @tags: aot, e2e, tic-tac-toe, game, board
// @timeout: 30000

// Tic-Tac-Toe game logic

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Board: 3x3 grid stored in first 9 positions of Arr8 (index 0-7 + one overflow)
// But Arr8 only has 8 slots! Use indices 0-8 with index 8 mapping to v7
// Actually, Arr8 only goes 0-7. For 9 cells, pack: row*3+col
// Workaround: use a type with 2 Arr8s, or just use the 9th cell as second Arr8's v0
// Simpler: encode board as bitmask. X positions and O positions as separate bitmasks.
// Bit i = cell i (row*3 + col)

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn has_bit(mask: Int, k: Int) -> Int { (mask / pow2(k)) % 2 }
fn set_bit(mask: Int, k: Int) -> Int { if has_bit(mask, k) == 1 { mask } else { mask + pow2(k) } }

type Board is { x_mask: Int, o_mask: Int };

fn empty_board() -> Board { Board { x_mask: 0, o_mask: 0 } }

fn cell_at(b: Board, pos: Int) -> Int {
    if has_bit(b.x_mask, pos) == 1 { return 1; }  // X
    if has_bit(b.o_mask, pos) == 1 { return 2; }  // O
    0  // empty
}

fn place(b: Board, pos: Int, player: Int) -> Board {
    if player == 1 {
        Board { x_mask: set_bit(b.x_mask, pos), o_mask: b.o_mask }
    } else {
        Board { x_mask: b.x_mask, o_mask: set_bit(b.o_mask, pos) }
    }
}

fn is_empty(b: Board, pos: Int) -> Int {
    if cell_at(b, pos) == 0 { 1 } else { 0 }
}

// Check win lines (8 possible: 3 rows, 3 cols, 2 diags)
// Win masks for 3x3:
// Row 0: 0,1,2 = 7 (0b111)
// Row 1: 3,4,5 = 56 (0b111000)
// Row 2: 6,7,8 = 448 (0b111000000)
// Col 0: 0,3,6 = 73 (0b001001001)
// Col 1: 1,4,7 = 146
// Col 2: 2,5,8 = 292
// Diag: 0,4,8 = 273
// Anti: 2,4,6 = 84

fn check_win_mask(player_mask: Int, win_mask: Int) -> Int {
    // All bits of win_mask set in player_mask?
    let mut mask = win_mask;
    let mut k = 0;
    while k < 9 {
        if has_bit(mask, k) == 1 {
            if has_bit(player_mask, k) == 0 { return 0; }
        }
        k = k + 1;
    }
    1
}

fn has_won(b: Board, player: Int) -> Int {
    let mask = if player == 1 { b.x_mask } else { b.o_mask };
    if check_win_mask(mask, 7) == 1 { return 1; }
    if check_win_mask(mask, 56) == 1 { return 1; }
    if check_win_mask(mask, 448) == 1 { return 1; }
    if check_win_mask(mask, 73) == 1 { return 1; }
    if check_win_mask(mask, 146) == 1 { return 1; }
    if check_win_mask(mask, 292) == 1 { return 1; }
    if check_win_mask(mask, 273) == 1 { return 1; }
    if check_win_mask(mask, 84) == 1 { return 1; }
    0
}

fn is_draw(b: Board) -> Int {
    if has_won(b, 1) == 1 { return 0; }
    if has_won(b, 2) == 1 { return 0; }
    // All 9 cells filled?
    let mut i = 0;
    while i < 9 {
        if is_empty(b, i) == 1 { return 0; }
        i = i + 1;
    }
    1
}

fn count_moves(b: Board) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 9 {
        if is_empty(b, i) == 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_empty_board() -> Int {
    let b = empty_board();
    assert_eq(has_won(b, 1), 0);
    assert_eq(has_won(b, 2), 0);
    assert_eq(is_draw(b), 0);
    assert_eq(count_moves(b), 0);
    1
}

fn test_x_wins_row() -> Int {
    // X wins top row: 0,1,2
    let mut b = empty_board();
    b = place(b, 0, 1); // X
    b = place(b, 3, 2); // O
    b = place(b, 1, 1); // X
    b = place(b, 4, 2); // O
    b = place(b, 2, 1); // X wins
    assert_eq(has_won(b, 1), 1);
    assert_eq(has_won(b, 2), 0);
    1
}

fn test_o_wins_col() -> Int {
    // O wins column 2: positions 2, 5, 8
    let mut b = empty_board();
    b = place(b, 0, 1);
    b = place(b, 2, 2);
    b = place(b, 1, 1);
    b = place(b, 5, 2);
    b = place(b, 3, 1);
    b = place(b, 8, 2); // O wins
    assert_eq(has_won(b, 2), 1);
    assert_eq(has_won(b, 1), 0);
    1
}

fn test_x_wins_diag() -> Int {
    // X wins diagonal: 0, 4, 8
    let mut b = empty_board();
    b = place(b, 0, 1);
    b = place(b, 1, 2);
    b = place(b, 4, 1);
    b = place(b, 2, 2);
    b = place(b, 8, 1); // X wins
    assert_eq(has_won(b, 1), 1);
    1
}

fn test_draw() -> Int {
    // Classic draw:
    // X O X
    // X X O
    // O X O
    // Positions: X=0,2,3,4,7  O=1,5,6,8
    let mut b = empty_board();
    b = place(b, 0, 1);
    b = place(b, 1, 2);
    b = place(b, 2, 1);
    b = place(b, 5, 2);
    b = place(b, 3, 1);
    b = place(b, 6, 2);
    b = place(b, 4, 1);
    b = place(b, 8, 2);
    b = place(b, 7, 1);
    assert_eq(has_won(b, 1), 0);
    assert_eq(has_won(b, 2), 0);
    assert_eq(is_draw(b), 1);
    assert_eq(count_moves(b), 9);
    1
}

fn test_anti_diagonal() -> Int {
    // X wins anti-diagonal: 2, 4, 6
    let mut b = empty_board();
    b = place(b, 2, 1);
    b = place(b, 0, 2);
    b = place(b, 4, 1);
    b = place(b, 1, 2);
    b = place(b, 6, 1); // X wins
    assert_eq(has_won(b, 1), 1);
    1
}

fn main() -> Int {
    test_empty_board();
    test_x_wins_row();
    test_o_wins_col();
    test_x_wins_diag();
    test_draw();
    test_anti_diagonal();
    print("[OK] 538_tictactoe_aot");
    0
}
