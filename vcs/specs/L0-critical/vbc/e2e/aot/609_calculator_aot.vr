// @test: run
// @level: L0
// @tags: aot, e2e, calculator, arithmetic, stack-machine
// @timeout: 30000

// Multi-operation calculator with memory and chaining

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// Operations encoded as: op*1000000 + arg
// op: 1=add, 2=sub, 3=mul, 4=div, 5=mod, 6=abs, 7=neg, 8=set
fn op_code(instr: Int) -> Int { instr / 1000000 }
fn op_arg(instr: Int) -> Int { instr % 1000000 }

fn make_instr(op: Int, arg: Int) -> Int { op * 1000000 + arg }

fn calc_step(acc: Int, instr: Int) -> Int {
    let op = op_code(instr);
    let arg = op_arg(instr);
    if op == 1 { acc + arg }        // add
    else if op == 2 { acc - arg }   // sub
    else if op == 3 { acc * arg }   // mul
    else if op == 4 {               // div
        if arg == 0 { 0 } else { acc / arg }
    }
    else if op == 5 {               // mod
        if arg == 0 { 0 } else { acc % arg }
    }
    else if op == 6 { abs_val(acc) } // abs
    else if op == 7 { 0 - acc }      // neg
    else if op == 8 { arg }          // set
    else { acc }
}

// Run a program of instructions
fn calc_run(prog: Arr8, plen: Int) -> Int {
    let mut acc = 0;
    let mut i = 0;
    while i < plen {
        acc = calc_step(acc, get8(prog, i));
        i = i + 1;
    }
    acc
}

// Integer power using repeated squaring
fn ipow(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut b = base;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 { result = result * b; }
        b = b * b;
        e = e / 2;
    }
    result
}

// Fibonacci
fn fib(n: Int) -> Int {
    let mut a = 0;
    let mut b = 1;
    let mut i = 0;
    while i < n {
        let t = a + b;
        a = b;
        b = t;
        i = i + 1;
    }
    a
}

// Factorial
fn fact(n: Int) -> Int {
    let mut r = 1;
    let mut i = 2;
    while i <= n { r = r * i; i = i + 1; }
    r
}

fn test_basic_calc() -> Int {
    // 0 + 10 = 10
    let mut prog = zeros();
    prog = set8(prog, 0, make_instr(1, 10)); // add 10
    assert_eq(calc_run(prog, 1), 10);

    // set 100, sub 30, mul 2 = (100-30)*2 = 140
    prog = set8(prog, 0, make_instr(8, 100)); // set 100
    prog = set8(prog, 1, make_instr(2, 30));  // sub 30
    prog = set8(prog, 2, make_instr(3, 2));   // mul 2
    assert_eq(calc_run(prog, 3), 140);
    1
}

fn test_div_mod() -> Int {
    let mut prog = zeros();
    // set 17, div 5 = 3
    prog = set8(prog, 0, make_instr(8, 17));
    prog = set8(prog, 1, make_instr(4, 5));
    assert_eq(calc_run(prog, 2), 3);

    // set 17, mod 5 = 2
    prog = set8(prog, 0, make_instr(8, 17));
    prog = set8(prog, 1, make_instr(5, 5));
    assert_eq(calc_run(prog, 2), 2);

    // div by 0 returns 0
    prog = set8(prog, 0, make_instr(8, 42));
    prog = set8(prog, 1, make_instr(4, 0));
    assert_eq(calc_run(prog, 2), 0);
    1
}

fn test_abs_neg() -> Int {
    let mut prog = zeros();
    // set 5, neg = -5
    prog = set8(prog, 0, make_instr(8, 5));
    prog = set8(prog, 1, make_instr(7, 0)); // neg
    assert_eq(calc_run(prog, 2), 0 - 5);

    // set 5, neg, abs = 5
    prog = set8(prog, 2, make_instr(6, 0)); // abs
    assert_eq(calc_run(prog, 3), 5);
    1
}

fn test_chain() -> Int {
    // (((2 + 3) * 4) - 7) = 13
    let mut prog = zeros();
    prog = set8(prog, 0, make_instr(8, 2));  // set 2
    prog = set8(prog, 1, make_instr(1, 3));  // add 3 = 5
    prog = set8(prog, 2, make_instr(3, 4));  // mul 4 = 20
    prog = set8(prog, 3, make_instr(2, 7));  // sub 7 = 13
    assert_eq(calc_run(prog, 4), 13);
    1
}

fn test_ipow() -> Int {
    assert_eq(ipow(2, 0), 1);
    assert_eq(ipow(2, 1), 2);
    assert_eq(ipow(2, 10), 1024);
    assert_eq(ipow(3, 5), 243);
    assert_eq(ipow(5, 3), 125);
    assert_eq(ipow(1, 100), 1);
    1
}

fn test_fib() -> Int {
    assert_eq(fib(0), 0);
    assert_eq(fib(1), 1);
    assert_eq(fib(2), 1);
    assert_eq(fib(5), 5);
    assert_eq(fib(10), 55);
    assert_eq(fib(15), 610);
    1
}

fn test_fact() -> Int {
    assert_eq(fact(0), 1);
    assert_eq(fact(1), 1);
    assert_eq(fact(5), 120);
    assert_eq(fact(7), 5040);
    assert_eq(fact(10), 3628800);
    1
}

fn main() -> Int {
    test_basic_calc();
    test_div_mod();
    test_abs_neg();
    test_chain();
    test_ipow();
    test_fib();
    test_fact();
    print("[OK] 609_calculator_aot");
    0
}
