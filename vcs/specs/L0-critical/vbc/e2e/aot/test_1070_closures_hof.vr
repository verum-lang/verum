// @test: run
// @level: L0
// @tier: 1
// @tags: closures, higher-order-functions, lambda
// @description: Test closures, captures, and higher-order function patterns

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
    f(x)
}

fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int, x: Int) -> Int {
    f(g(x))
}

fn test_basic_closure() -> Int {
    let add5 = |x: Int| -> Int { x + 5 };
    let result = add5(10);
    if result != 15 {
        print(f"FAIL basic_closure: {result}, expected 15");
        return 1;
    }
    print("  basic_closure: OK");
    0
}

fn test_closure_capture() -> Int {
    let offset = 100;
    let add_offset = |x: Int| -> Int { x + offset };
    let result = add_offset(42);
    if result != 142 {
        print(f"FAIL capture: {result}, expected 142");
        return 1;
    }
    print("  capture: OK");
    0
}

fn test_hof_apply() -> Int {
    let double = |x: Int| -> Int { x * 2 };
    let result = apply(double, 21);
    if result != 42 {
        print(f"FAIL hof_apply: {result}, expected 42");
        return 1;
    }
    print("  hof_apply: OK");
    0
}

fn test_hof_compose() -> Int {
    let add1 = |x: Int| -> Int { x + 1 };
    let mul3 = |x: Int| -> Int { x * 3 };
    // compose(add1, mul3, 5) = add1(mul3(5)) = add1(15) = 16
    let result = compose(add1, mul3, 5);
    if result != 16 {
        print(f"FAIL compose: {result}, expected 16");
        return 1;
    }
    print("  compose: OK");
    0
}

fn test_closure_in_loop() -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < 5 {
        let adder = |x: Int| -> Int { x + i };
        sum = sum + adder(10);
        i = i + 1;
    }
    // sum = (10+0) + (10+1) + (10+2) + (10+3) + (10+4) = 60
    if sum != 60 {
        print(f"FAIL closure_loop: sum={sum}, expected 60");
        return 1;
    }
    print("  closure_loop: OK");
    0
}

fn test_returning_closure() -> Int {
    let make_adder = |n: Int| -> fn(Int) -> Int {
        |x: Int| -> Int { x + n }
    };
    let add10 = make_adder(10);
    let add20 = make_adder(20);
    let r1 = add10(5);
    let r2 = add20(5);
    if r1 != 15 {
        print(f"FAIL return_closure: add10(5)={r1}, expected 15");
        return 1;
    }
    if r2 != 25 {
        print(f"FAIL return_closure: add20(5)={r2}, expected 25");
        return 1;
    }
    print("  return_closure: OK");
    0
}

fn test_list_map_filter() -> Int {
    // Manual map: apply function to each element
    let nums = [1, 2, 3, 4, 5];
    let mut doubled = List.new();
    let mut i = 0;
    while i < nums.len() {
        doubled.push(nums[i] * 2);
        i = i + 1;
    }
    if doubled[2] != 6 {
        print(f"FAIL list_map: doubled[2]={doubled[2]}, expected 6");
        return 1;
    }

    // Manual filter: keep elements matching predicate
    let mut evens = List.new();
    i = 0;
    while i < nums.len() {
        if nums[i] % 2 == 0 {
            evens.push(nums[i]);
        }
        i = i + 1;
    }
    if evens.len() != 2 {
        print(f"FAIL list_filter: evens.len={evens.len()}, expected 2");
        return 1;
    }
    if evens[0] != 2 || evens[1] != 4 {
        print(f"FAIL list_filter: evens=[{evens[0]},{evens[1]}]");
        return 1;
    }

    // Manual reduce: fold elements with accumulator
    let mut total = 0;
    i = 0;
    while i < nums.len() {
        total = total + nums[i];
        i = i + 1;
    }
    if total != 15 {
        print(f"FAIL list_reduce: total={total}, expected 15");
        return 1;
    }
    print("  list_map_filter: OK");
    0
}

fn main() -> Int {
    print("Closures & HOF Tests:");
    let mut failures = 0;
    failures = failures + test_basic_closure();
    failures = failures + test_closure_capture();
    failures = failures + test_hof_apply();
    failures = failures + test_hof_compose();
    failures = failures + test_closure_in_loop();
    failures = failures + test_returning_closure();
    failures = failures + test_list_map_filter();

    if failures == 0 {
        print("All closures & HOF tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
