// @test: run
// @level: L0
// @tags: aot, e2e, huffman, encoding, compression
// @timeout: 30000

// Huffman-like encoding/decoding with fixed code table

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Fixed Huffman-like code table for symbols 0-7:
// Symbol | Code (binary) | Length
//   0    |   0           |  1
//   1    |   10          |  2
//   2    |   110         |  3
//   3    |   1110        |  4
//   4    |   11110       |  5
//   5    |   111110      |  6
//   6    |   1111110     |  7
//   7    |   1111111     |  7

// Code values stored as integers (MSB first)
fn code_for(sym: Int) -> Int {
    if sym == 0 { 0 }        // 0
    else if sym == 1 { 2 }   // 10
    else if sym == 2 { 6 }   // 110
    else if sym == 3 { 14 }  // 1110
    else if sym == 4 { 30 }  // 11110
    else if sym == 5 { 62 }  // 111110
    else if sym == 6 { 126 } // 1111110
    else { 127 }             // 1111111
}

fn code_len(sym: Int) -> Int {
    if sym == 0 { 1 }
    else if sym == 1 { 2 }
    else if sym == 2 { 3 }
    else if sym == 3 { 4 }
    else if sym == 4 { 5 }
    else if sym == 5 { 6 }
    else if sym == 6 { 7 }
    else { 7 }
}

// Calculate total encoded bit length
fn total_bits(symbols: Arr8, n: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        total = total + code_len(get8(symbols, i));
        i = i + 1;
    }
    total
}

// Encode: pack codes into a bit stream stored as integers
// Returns packed bit value (limited to ~60 bits)
fn encode_bits(symbols: Arr8, n: Int) -> Int {
    let mut bits = 0;
    let mut pos = 0;
    let mut i = 0;
    while i < n {
        let sym = get8(symbols, i);
        let code = code_for(sym);
        let len = code_len(sym);
        // Shift code to position and OR in
        let mut j = 0;
        while j < len {
            let bit = (code / pow2(len - 1 - j)) % 2;
            if bit == 1 {
                bits = bits + pow2(pos);
            }
            pos = pos + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    bits
}

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn get_bit(val: Int, pos: Int) -> Int {
    (val / pow2(pos)) % 2
}

// Decode bit stream back to symbols
// Returns count of decoded symbols
fn decode_count(bits: Int, total_bit_len: Int) -> Int {
    let mut pos = 0;
    let mut count = 0;
    while pos < total_bit_len {
        // Read bits until we find a valid code
        if get_bit(bits, pos) == 0 {
            // Symbol 0 (code: 0, len 1)
            count = count + 1;
            pos = pos + 1;
        } else {
            // Count consecutive 1s
            let mut ones = 0;
            while pos + ones < total_bit_len {
                if get_bit(bits, pos + ones) == 1 {
                    ones = ones + 1;
                } else {
                    ones = ones + 100; // break
                }
            }
            if ones > 50 { ones = ones - 100; }
            // ones consecutive 1s followed by 0 => symbol = ones
            // except 7 ones (no trailing 0) => symbol 7
            if ones >= 7 {
                count = count + 1;
                pos = pos + 7;
            } else {
                count = count + 1;
                pos = pos + ones + 1; // ones + trailing 0
            }
        }
    }
    count
}

// Decode into array
fn decode_syms(bits: Int, total_bit_len: Int) -> Arr8 {
    let mut result = zeros();
    let mut pos = 0;
    let mut idx = 0;
    while pos < total_bit_len {
        if get_bit(bits, pos) == 0 {
            result = set8(result, idx, 0);
            idx = idx + 1;
            pos = pos + 1;
        } else {
            let mut ones = 0;
            while pos + ones < total_bit_len {
                if get_bit(bits, pos + ones) == 1 {
                    ones = ones + 1;
                } else {
                    ones = ones + 100; // break
                }
            }
            if ones > 50 { ones = ones - 100; }
            if ones >= 7 {
                result = set8(result, idx, 7);
                idx = idx + 1;
                pos = pos + 7;
            } else {
                result = set8(result, idx, ones);
                idx = idx + 1;
                pos = pos + ones + 1;
            }
        }
    }
    result
}

// Frequency counter
fn count_freq(symbols: Arr8, n: Int) -> Arr8 {
    let mut freq = zeros();
    let mut i = 0;
    while i < n {
        let s = get8(symbols, i);
        freq = set8(freq, s, get8(freq, s) + 1);
        i = i + 1;
    }
    freq
}

// Weighted path length (sum of freq * code_length)
fn weighted_path_len(freq: Arr8, n_symbols: Int) -> Int {
    let mut wpl = 0;
    let mut i = 0;
    while i < n_symbols {
        wpl = wpl + get8(freq, i) * code_len(i);
        i = i + 1;
    }
    wpl
}

fn test_code_lengths() -> Int {
    assert_eq(code_len(0), 1);
    assert_eq(code_len(1), 2);
    assert_eq(code_len(7), 7);
    // Total bits for [0,0,0] should be 3
    let all_zeros = zeros();
    assert_eq(total_bits(all_zeros, 3), 3);
    1
}

fn test_encode_decode() -> Int {
    // Encode [0, 1, 0] -> bits: 0, 10, 0 = 010,0 = bit positions 0=0,1=1,2=0,3=0
    let syms = Arr8 { v0: 0, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let nbits = total_bits(syms, 3);
    assert_eq(nbits, 4); // 1+2+1
    let bits = encode_bits(syms, 3);
    let decoded = decode_syms(bits, nbits);
    assert_eq(get8(decoded, 0), 0);
    assert_eq(get8(decoded, 1), 1);
    assert_eq(get8(decoded, 2), 0);
    assert_eq(decode_count(bits, nbits), 3);
    1
}

fn test_encode_decode_varied() -> Int {
    // Encode [0, 2, 1, 0]
    let syms = Arr8 { v0: 0, v1: 2, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let nbits = total_bits(syms, 4);
    assert_eq(nbits, 7); // 1+3+2+1
    let bits = encode_bits(syms, 4);
    let decoded = decode_syms(bits, nbits);
    assert_eq(get8(decoded, 0), 0);
    assert_eq(get8(decoded, 1), 2);
    assert_eq(get8(decoded, 2), 1);
    assert_eq(get8(decoded, 3), 0);
    1
}

fn test_frequency() -> Int {
    let syms = Arr8 { v0: 0, v1: 1, v2: 0, v3: 2, v4: 0, v5: 1, v6: 3, v7: 0 };
    let freq = count_freq(syms, 8);
    assert_eq(get8(freq, 0), 4); // symbol 0 appears 4 times
    assert_eq(get8(freq, 1), 2); // symbol 1 appears 2 times
    assert_eq(get8(freq, 2), 1);
    assert_eq(get8(freq, 3), 1);

    // WPL = 4*1 + 2*2 + 1*3 + 1*4 = 4+4+3+4 = 15
    assert_eq(weighted_path_len(freq, 4), 15);
    1
}

fn test_compression_ratio() -> Int {
    // 8 symbols with fixed 3-bit encoding = 24 bits
    // With Huffman-like encoding, frequent symbols use fewer bits
    let syms = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 1, v6: 0, v7: 0 };
    let fixed_bits = 8 * 3; // 3 bits per symbol
    let huffman_bits = total_bits(syms, 8); // 7*1 + 1*2 = 9
    assert_eq(huffman_bits, 9);
    // Compression ratio: 9 < 24
    let compressed = if huffman_bits < fixed_bits { 1 } else { 0 };
    assert_eq(compressed, 1);
    1
}

fn main() -> Int {
    test_code_lengths();
    test_encode_decode();
    test_encode_decode_varied();
    test_frequency();
    test_compression_ratio();
    print("[OK] 583_huffman_aot");
    0
}
