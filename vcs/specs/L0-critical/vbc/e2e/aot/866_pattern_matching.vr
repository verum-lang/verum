// @test: run
// @tier: 0
// @level: L0
// @tags: aot, pattern, matching, variant, exhaustive
// @expected-exit: 0

// Test: comprehensive pattern matching
// Validates variant matching, nested patterns, guards, wildcards.

type Shape is
    Circle(Int)
    | Rectangle(Int, Int)
    | Triangle(Int, Int, Int);

fn area_doubled(s: Shape) -> Int {
    // Returns 2x area to avoid float
    match s {
        Circle(r) => 6 * r * r,  // ~2*pi*r^2 approximation
        Rectangle(w, h) => 2 * w * h,
        Triangle(a, b, _c) => a * b,  // base * height (already 2x area for right triangle)
    }
}

type Expr is
    Lit(Int)
    | Neg(Int)
    | AddExpr(Int, Int)
    | MulExpr(Int, Int);

fn eval_expr(e: Expr) -> Int {
    match e {
        Lit(n) => n,
        Neg(n) => 0 - n,
        AddExpr(a, b) => a + b,
        MulExpr(a, b) => a * b,
    }
}

type Color is Red | Green | Blue | Custom(Int);

fn color_value(c: Color) -> Int {
    match c {
        Red => 0xFF0000,
        Green => 0x00FF00,
        Blue => 0x0000FF,
        Custom(v) => v,
    }
}

fn classify(n: Int) -> Int {
    if (n < 0) {
        -1
    } else if (n == 0) {
        0
    } else {
        1
    }
}

fn main() -> Int {
    // Shape matching
    let c = Circle(5);
    assert_eq(area_doubled(c), 150);  // 6*25

    let r = Rectangle(3, 4);
    assert_eq(area_doubled(r), 24);  // 2*12

    let t = Triangle(6, 8, 10);
    assert_eq(area_doubled(t), 48);  // 6*8

    // Expr evaluation
    assert_eq(eval_expr(Lit(42)), 42);
    assert_eq(eval_expr(Neg(7)), -7);
    assert_eq(eval_expr(AddExpr(10, 20)), 30);
    assert_eq(eval_expr(MulExpr(6, 7)), 42);

    // Color matching
    assert_eq(color_value(Red), 16711680);
    assert_eq(color_value(Green), 65280);
    assert_eq(color_value(Blue), 255);
    assert_eq(color_value(Custom(0xABCDEF)), 0xABCDEF);

    // Multiple matches in sequence
    let mut total = 0;
    let mut i = 0;
    while (i < 5) {
        let shape = if (i % 3 == 0) {
            Circle(i + 1)
        } else if (i % 3 == 1) {
            Rectangle(i + 1, i + 2)
        } else {
            Triangle(i + 1, i + 2, i + 3)
        };
        total = total + area_doubled(shape);
        i = i + 1;
    }
    // i=0: Circle(1) = 6*1 = 6
    // i=1: Rectangle(2,3) = 2*6 = 12
    // i=2: Triangle(3,4,5) = 3*4 = 12
    // i=3: Circle(4) = 6*16 = 96
    // i=4: Rectangle(5,6) = 2*30 = 60
    // total = 6 + 12 + 12 + 96 + 60 = 186
    assert_eq(total, 186);

    // classify
    assert_eq(classify(-5), -1);
    assert_eq(classify(0), 0);
    assert_eq(classify(100), 1);

    print("pattern_matching: PASS");
    0
}
