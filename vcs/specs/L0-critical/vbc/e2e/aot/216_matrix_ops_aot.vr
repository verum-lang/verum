// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, matrix, linear-algebra
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for matrix operations (3x3 integer matrices)

// 3x3 matrix stored as flat record
type Mat3 is {
    m00: Int, m01: Int, m02: Int,
    m10: Int, m11: Int, m12: Int,
    m20: Int, m21: Int, m22: Int
};

fn mat3_get(m: Mat3, r: Int, c: Int) -> Int {
    if r == 0 {
        if c == 0 { m.m00 } else if c == 1 { m.m01 } else { m.m02 }
    } else if r == 1 {
        if c == 0 { m.m10 } else if c == 1 { m.m11 } else { m.m12 }
    } else {
        if c == 0 { m.m20 } else if c == 1 { m.m21 } else { m.m22 }
    }
}

fn mat3_zero() -> Mat3 {
    Mat3 { m00: 0, m01: 0, m02: 0, m10: 0, m11: 0, m12: 0, m20: 0, m21: 0, m22: 0 }
}

fn mat3_identity() -> Mat3 {
    Mat3 { m00: 1, m01: 0, m02: 0, m10: 0, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 }
}

fn mat3_add(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00 + b.m00, m01: a.m01 + b.m01, m02: a.m02 + b.m02,
        m10: a.m10 + b.m10, m11: a.m11 + b.m11, m12: a.m12 + b.m12,
        m20: a.m20 + b.m20, m21: a.m21 + b.m21, m22: a.m22 + b.m22
    }
}

fn mat3_scale(a: Mat3, s: Int) -> Mat3 {
    Mat3 {
        m00: a.m00 * s, m01: a.m01 * s, m02: a.m02 * s,
        m10: a.m10 * s, m11: a.m11 * s, m12: a.m12 * s,
        m20: a.m20 * s, m21: a.m21 * s, m22: a.m22 * s
    }
}

// Matrix multiply: compute one element
fn mat3_mul_elem(a: Mat3, b: Mat3, r: Int, c: Int) -> Int {
    mat3_get(a, r, 0) * mat3_get(b, 0, c) +
    mat3_get(a, r, 1) * mat3_get(b, 1, c) +
    mat3_get(a, r, 2) * mat3_get(b, 2, c)
}

fn mat3_mul(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        m00: mat3_mul_elem(a, b, 0, 0), m01: mat3_mul_elem(a, b, 0, 1), m02: mat3_mul_elem(a, b, 0, 2),
        m10: mat3_mul_elem(a, b, 1, 0), m11: mat3_mul_elem(a, b, 1, 1), m12: mat3_mul_elem(a, b, 1, 2),
        m20: mat3_mul_elem(a, b, 2, 0), m21: mat3_mul_elem(a, b, 2, 1), m22: mat3_mul_elem(a, b, 2, 2)
    }
}

fn mat3_transpose(a: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00, m01: a.m10, m02: a.m20,
        m10: a.m01, m11: a.m11, m12: a.m21,
        m20: a.m02, m21: a.m12, m22: a.m22
    }
}

fn mat3_trace(a: Mat3) -> Int {
    a.m00 + a.m11 + a.m22
}

fn mat3_det(a: Mat3) -> Int {
    a.m00 * (a.m11 * a.m22 - a.m12 * a.m21) -
    a.m01 * (a.m10 * a.m22 - a.m12 * a.m20) +
    a.m02 * (a.m10 * a.m21 - a.m11 * a.m20)
}

fn mat3_eq(a: Mat3, b: Mat3) -> Bool {
    a.m00 == b.m00 && a.m01 == b.m01 && a.m02 == b.m02 &&
    a.m10 == b.m10 && a.m11 == b.m11 && a.m12 == b.m12 &&
    a.m20 == b.m20 && a.m21 == b.m21 && a.m22 == b.m22
}

fn test_identity() {
    let id = mat3_identity();
    assert_eq(mat3_trace(id), 3);
    assert_eq(mat3_det(id), 1);

    let a = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    // A * I = A
    assert_eq(mat3_eq(mat3_mul(a, id), a), true);
    // I * A = A
    assert_eq(mat3_eq(mat3_mul(id, a), a), true);
}

fn test_add_scale() {
    let a = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    let b = Mat3 { m00: 9, m01: 8, m02: 7, m10: 6, m11: 5, m12: 4, m20: 3, m21: 2, m22: 1 };
    let c = mat3_add(a, b);
    // Each element should be 10
    assert_eq(c.m00, 10);
    assert_eq(c.m11, 10);
    assert_eq(c.m22, 10);

    let s = mat3_scale(a, 2);
    assert_eq(s.m00, 2);
    assert_eq(s.m11, 10);
    assert_eq(s.m22, 18);
}

fn test_multiply() {
    let a = Mat3 { m00: 1, m01: 2, m02: 0, m10: 0, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 };
    let b = Mat3 { m00: 1, m01: 0, m02: 0, m10: 3, m11: 1, m12: 0, m20: 0, m21: 0, m22: 1 };
    let c = mat3_mul(a, b);
    // Row 0: [1*1+2*3+0*0, 1*0+2*1+0*0, 1*0+2*0+0*1] = [7, 2, 0]
    assert_eq(c.m00, 7);
    assert_eq(c.m01, 2);
    assert_eq(c.m02, 0);
    // Row 1: [0+3+0, 0+1+0, 0+0+0] = [3, 1, 0]
    assert_eq(c.m10, 3);
    assert_eq(c.m11, 1);
}

fn test_transpose() {
    let a = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 7, m21: 8, m22: 9 };
    let t = mat3_transpose(a);
    assert_eq(t.m01, 4);
    assert_eq(t.m10, 2);
    assert_eq(t.m02, 7);
    assert_eq(t.m20, 3);
    // Diagonal unchanged
    assert_eq(t.m00, 1);
    assert_eq(t.m11, 5);
    assert_eq(t.m22, 9);
    // Transpose of transpose = original
    assert_eq(mat3_eq(mat3_transpose(t), a), true);
}

fn test_determinant() {
    let id = mat3_identity();
    assert_eq(mat3_det(id), 1);

    let zero = mat3_zero();
    assert_eq(mat3_det(zero), 0);

    // Singular matrix (row 3 = row 1 + row 2)
    let sing = Mat3 { m00: 1, m01: 2, m02: 3, m10: 4, m11: 5, m12: 6, m20: 5, m21: 7, m22: 9 };
    assert_eq(mat3_det(sing), 0);

    // Known determinant
    let a = Mat3 { m00: 2, m01: 0, m02: 1, m10: 3, m11: 1, m12: 0, m20: 1, m21: 0, m22: 2 };
    // det = 2(2-0) - 0(6-0) + 1(0-1) = 4 - 0 - 1 = 3
    assert_eq(mat3_det(a), 3);
}

fn main() -> Int {
    test_identity();
    test_add_scale();
    test_multiply();
    test_transpose();
    test_determinant();
    print("[OK] 216_matrix_ops_aot");
    0
}
