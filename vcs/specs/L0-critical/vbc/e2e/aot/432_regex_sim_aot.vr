// @test: run
// @level: L0
// @tags: aot, e2e, regex, simulation, nfa
// @timeout: 30000

// Simplified regex matching using direct pattern matching

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

// Match exact pattern at position pos in text
fn match_exact(text: Arr8, tlen: Int, pat: Arr8, plen: Int, pos: Int) -> Int {
    if pos + plen > tlen { return 0; }
    let mut i = 0;
    while i < plen {
        if get8(text, pos + i) != get8(pat, i) { return 0; }
        i = i + 1;
    }
    1
}

// Match with '?' wildcard (0 = wildcard, matches any)
fn match_wildcard(text: Arr8, tlen: Int, pat: Arr8, plen: Int, pos: Int) -> Int {
    if pos + plen > tlen { return 0; }
    let mut i = 0;
    while i < plen {
        let p = get8(pat, i);
        if p != 0 {
            if get8(text, pos + i) != p { return 0; }
        }
        i = i + 1;
    }
    1
}

// Find first match position, -1 if not found
fn find_first(text: Arr8, tlen: Int, pat: Arr8, plen: Int) -> Int {
    let mut pos = 0;
    while pos <= tlen - plen {
        if match_exact(text, tlen, pat, plen, pos) == 1 { return pos; }
        pos = pos + 1;
    }
    -1
}

// Count all matches
fn count_all_matches(text: Arr8, tlen: Int, pat: Arr8, plen: Int) -> Int {
    let mut count = 0;
    let mut pos = 0;
    while pos <= tlen - plen {
        if match_exact(text, tlen, pat, plen, pos) == 1 { count = count + 1; }
        pos = pos + 1;
    }
    count
}

// Match character class: value in range [lo, hi]
fn match_range(val: Int, lo: Int, hi: Int) -> Int {
    if val >= lo {
        if val <= hi { 1 } else { 0 }
    } else { 0 }
}

// Glob match: pattern with -1 = match any single, -2 = match zero or more
fn glob_match(text: Arr8, tlen: Int, pat: Arr8, plen: Int) -> Int {
    // Simple implementation without star (star needs recursion)
    // Just handle single-char wildcard (-1)
    if tlen != plen { return 0; }
    let mut i = 0;
    while i < plen {
        let p = get8(pat, i);
        if p != -1 {
            if get8(text, i) != p { return 0; }
        }
        i = i + 1;
    }
    1
}

fn test_exact() -> Int {
    let text = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let pat = Arr8 { v0: 3, v1: 4, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(match_exact(text, 8, pat, 3, 2), 1);
    assert_eq(match_exact(text, 8, pat, 3, 0), 0);
    assert_eq(find_first(text, 8, pat, 3), 2);
    1
}

fn test_wildcard() -> Int {
    let text = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    // Pattern: [1, ?, 3] where 0=wildcard
    let pat = Arr8 { v0: 1, v1: 0, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(match_wildcard(text, 5, pat, 3, 0), 1);
    1
}

fn test_count() -> Int {
    // text = [1,2,1,2,1,2,1,2]
    let text = Arr8 { v0: 1, v1: 2, v2: 1, v3: 2, v4: 1, v5: 2, v6: 1, v7: 2 };
    let pat = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_all_matches(text, 8, pat, 2), 4);
    1
}

fn test_glob() -> Int {
    let text = Arr8 { v0: 5, v1: 6, v2: 7, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Pattern: [5, -1, 7, 8] — second position matches anything
    let pat = Arr8 { v0: 5, v1: -1, v2: 7, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(glob_match(text, 4, pat, 4), 1);
    1
}

fn test_range() -> Int {
    assert_eq(match_range(5, 1, 10), 1);
    assert_eq(match_range(0, 1, 10), 0);
    assert_eq(match_range(11, 1, 10), 0);
    1
}

fn main() -> Int {
    test_exact();
    test_wildcard();
    test_count();
    test_glob();
    test_range();
    print("[OK] 432_regex_sim_aot");
    0
}
