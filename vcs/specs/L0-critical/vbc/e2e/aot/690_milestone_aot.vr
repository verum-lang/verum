// @test: run
// @level: L0
// @tags: aot, e2e, milestone, graph-algorithms, traversal
// @timeout: 30000

// Milestone 690: Graph algorithms on small graphs

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn min2(a: Int, b: Int) -> Int { if a < b { a } else { b } }

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}
fn get_bit(val: Int, pos: Int) -> Int { (val / pow2(pos)) % 2 }
fn set_bit_val(val: Int, pos: Int) -> Int {
    if get_bit(val, pos) == 0 { val + pow2(pos) } else { val }
}

// Adjacency matrix: adj[i] is bitset of neighbors
// Graph with up to 6 nodes

// Add undirected edge
fn add_edge(adj: Arr8, u: Int, v: Int) -> Arr8 {
    let au = set_bit_val(get8(adj, u), v);
    let av = set_bit_val(get8(adj, v), u);
    let tmp = set8(adj, u, au);
    set8(tmp, v, av)
}

// BFS: returns visited bitset and distances in Arr8
fn bfs_visited(adj: Arr8, n: Int, start: Int) -> Int {
    let mut visited = pow2(start);
    let mut queue = zeros(); // use as circular buffer
    queue = set8(queue, 0, start);
    let mut front = 0;
    let mut back = 1;
    while front < back {
        let node = get8(queue, front % 8);
        front = front + 1;
        let mut j = 0;
        while j < n {
            if get_bit(get8(adj, node), j) == 1 {
                if get_bit(visited, j) == 0 {
                    visited = set_bit_val(visited, j);
                    queue = set8(queue, back % 8, j);
                    back = back + 1;
                }
            }
            j = j + 1;
        }
    }
    visited
}

// Count connected components
fn count_components(adj: Arr8, n: Int) -> Int {
    let mut visited = 0;
    let mut components = 0;
    let mut i = 0;
    while i < n {
        if get_bit(visited, i) == 0 {
            // BFS from i
            let reach = bfs_visited(adj, n, i);
            // Union visited with reach
            let mut j = 0;
            while j < n {
                if get_bit(reach, j) == 1 {
                    visited = set_bit_val(visited, j);
                }
                j = j + 1;
            }
            components = components + 1;
        }
        i = i + 1;
    }
    components
}

// Count edges
fn count_edges(adj: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if get_bit(get8(adj, i), j) == 1 { count = count + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Degree of a node
fn degree(adj: Arr8, node: Int, n: Int) -> Int {
    let bits = get8(adj, node);
    let mut count = 0;
    let mut i = 0;
    while i < n { count = count + get_bit(bits, i); i = i + 1; }
    count
}

// Check if graph is bipartite (2-colorable via BFS)
fn is_bipartite(adj: Arr8, n: Int) -> Int {
    // color[i]: 0 or 1, -1 = uncolored
    let mut color = Arr8 { v0: 0-1, v1: 0-1, v2: 0-1, v3: 0-1, v4: 0-1, v5: 0-1, v6: 0-1, v7: 0-1 };
    let mut ok = 1;
    let mut start = 0;
    while start < n {
        if get8(color, start) == (0 - 1) {
            color = set8(color, start, 0);
            let mut queue = zeros();
            queue = set8(queue, 0, start);
            let mut front = 0;
            let mut back = 1;
            while front < back {
                let node = get8(queue, front % 8);
                front = front + 1;
                let c = get8(color, node);
                let mut j = 0;
                while j < n {
                    if get_bit(get8(adj, node), j) == 1 {
                        if get8(color, j) == (0 - 1) {
                            color = set8(color, j, 1 - c);
                            queue = set8(queue, back % 8, j);
                            back = back + 1;
                        } else if get8(color, j) == c {
                            ok = 0;
                        }
                    }
                    j = j + 1;
                }
            }
        }
        start = start + 1;
    }
    ok
}

fn test_connected() -> Int {
    // Path: 0-1-2-3-4
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 2, 3);
    adj = add_edge(adj, 3, 4);
    assert_eq(count_components(adj, 5), 1);
    assert_eq(count_edges(adj, 5), 4);
    // BFS from 0 reaches all
    let v = bfs_visited(adj, 5, 0);
    let mut all = 1;
    let mut i = 0;
    while i < 5 { if get_bit(v, i) == 0 { all = 0; } i = i + 1; }
    assert_eq(all, 1);
    1
}

fn test_disconnected() -> Int {
    // Two components: 0-1-2 and 3-4
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 3, 4);
    assert_eq(count_components(adj, 5), 2);
    assert_eq(count_edges(adj, 5), 3);
    1
}

fn test_complete_graph() -> Int {
    // K4: complete graph on 4 nodes
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 0, 2);
    adj = add_edge(adj, 0, 3);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 1, 3);
    adj = add_edge(adj, 2, 3);
    assert_eq(count_edges(adj, 4), 6);
    assert_eq(degree(adj, 0, 4), 3);
    assert_eq(count_components(adj, 4), 1);
    1
}

fn test_bipartite_check() -> Int {
    // Path is bipartite
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 1, 2);
    adj = add_edge(adj, 2, 3);
    assert_eq(is_bipartite(adj, 4), 1);
    // Even cycle is bipartite
    adj = add_edge(adj, 3, 0);
    assert_eq(is_bipartite(adj, 4), 1);
    // Triangle is NOT bipartite
    let mut tri = zeros();
    tri = add_edge(tri, 0, 1);
    tri = add_edge(tri, 1, 2);
    tri = add_edge(tri, 2, 0);
    assert_eq(is_bipartite(tri, 3), 0);
    1
}

fn test_euler() -> Int {
    // Handshaking lemma: sum of degrees = 2 * edges
    let mut adj = zeros();
    adj = add_edge(adj, 0, 1);
    adj = add_edge(adj, 0, 2);
    adj = add_edge(adj, 1, 3);
    adj = add_edge(adj, 2, 3);
    adj = add_edge(adj, 2, 4);
    let edges = count_edges(adj, 5);
    let mut deg_sum = 0;
    let mut i = 0;
    while i < 5 { deg_sum = deg_sum + degree(adj, i, 5); i = i + 1; }
    assert_eq(deg_sum, 2 * edges);
    1
}

fn main() -> Int {
    test_connected();
    test_disconnected();
    test_complete_graph();
    test_bipartite_check();
    test_euler();
    print("[OK] 690_milestone_aot");
    0
}
