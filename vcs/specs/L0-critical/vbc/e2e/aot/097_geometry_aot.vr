// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, geometry, 2d, cross-product, polygon, area
// @timeout: 50000
// @expected-exit: 0
// @description: AOT 2D computational geometry with integer coordinates

type Point is { x: Int, y: Int };

fn pt(x: Int, y: Int) -> Point { Point { x: x, y: y } }

fn abs_val(n: Int) -> Int { if n < 0 { 0 - n } else { n } }

// Cross product of vectors (B-A) x (C-A)
// Positive = CCW, Negative = CW, Zero = collinear
fn cross(a: Point, b: Point, c: Point) -> Int {
    (b.x - a.x) * (c.y - a.y) - (b.y - a.y) * (c.x - a.x)
}

// Dot product of vectors (B-A) . (C-A)
fn dot(a: Point, b: Point, c: Point) -> Int {
    (b.x - a.x) * (c.x - a.x) + (b.y - a.y) * (c.y - a.y)
}

// Distance squared
fn dist_sq(a: Point, b: Point) -> Int {
    let dx = b.x - a.x;
    let dy = b.y - a.y;
    dx * dx + dy * dy
}

// Point in triangle test using sign of cross products
// Returns true if P is inside or on the boundary of triangle ABC
fn point_in_triangle(p: Point, a: Point, b: Point, c: Point) -> Bool {
    let d1 = cross(a, b, p);
    let d2 = cross(b, c, p);
    let d3 = cross(c, a, p);
    let has_neg = (d1 < 0) || (d2 < 0) || (d3 < 0);
    let has_pos = (d1 > 0) || (d2 > 0) || (d3 > 0);
    !(has_neg && has_pos)
}

// Triangle area * 2 (always positive)
fn triangle_area_2x(a: Point, b: Point, c: Point) -> Int {
    abs_val(cross(a, b, c))
}

// Polygon with up to 8 vertices (parallel x/y arrays)
type Poly8 is {
    x0: Int, x1: Int, x2: Int, x3: Int,
    x4: Int, x5: Int, x6: Int, x7: Int,
    y0: Int, y1: Int, y2: Int, y3: Int,
    y4: Int, y5: Int, y6: Int, y7: Int,
    n: Int
};

fn poly_x(p: Poly8, i: Int) -> Int {
    if i == 0 { p.x0 } else if i == 1 { p.x1 } else if i == 2 { p.x2 }
    else if i == 3 { p.x3 } else if i == 4 { p.x4 } else if i == 5 { p.x5 }
    else if i == 6 { p.x6 } else { p.x7 }
}

fn poly_y(p: Poly8, i: Int) -> Int {
    if i == 0 { p.y0 } else if i == 1 { p.y1 } else if i == 2 { p.y2 }
    else if i == 3 { p.y3 } else if i == 4 { p.y4 } else if i == 5 { p.y5 }
    else if i == 6 { p.y6 } else { p.y7 }
}

// Shoelace formula for polygon area * 2
fn polygon_area_2x(p: Poly8) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < p.n {
        let j = (i + 1) % p.n;
        s = s + poly_x(p, i) * poly_y(p, j) - poly_x(p, j) * poly_y(p, i);
        i = i + 1;
    }
    abs_val(s)
}

// Check if polygon is convex (all consecutive cross products same sign)
fn polygon_is_convex(p: Poly8) -> Bool {
    let mut pos = 0;
    let mut neg = 0;
    let mut i = 0;
    while i < p.n {
        let j = (i + 1) % p.n;
        let k = (i + 2) % p.n;
        let cx = (poly_x(p, j) - poly_x(p, i)) * (poly_y(p, k) - poly_y(p, j))
               - (poly_y(p, j) - poly_y(p, i)) * (poly_x(p, k) - poly_x(p, j));
        if cx > 0 { pos = pos + 1; }
        if cx < 0 { neg = neg + 1; }
        i = i + 1;
    }
    pos == 0 || neg == 0
}

// Manhattan distance
fn manhattan(a: Point, b: Point) -> Int {
    abs_val(b.x - a.x) + abs_val(b.y - a.y)
}

// Check collinearity
fn is_collinear(a: Point, b: Point, c: Point) -> Bool {
    cross(a, b, c) == 0
}

// Perimeter as sum of squared edge lengths (since we can't do sqrt)
fn perimeter_sq_sum(p: Poly8) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < p.n {
        let j = (i + 1) % p.n;
        let dx = poly_x(p, j) - poly_x(p, i);
        let dy = poly_y(p, j) - poly_y(p, i);
        s = s + dx * dx + dy * dy;
        i = i + 1;
    }
    s
}

// Segment intersection test: do segments AB and CD intersect?
// Uses orientation tests
fn sign(x: Int) -> Int {
    if x > 0 { 1 } else if x < 0 { -1 } else { 0 }
}

fn on_segment(p: Point, q: Point, r: Point) -> Bool {
    // Check if q lies on segment pr (given that p,q,r are collinear)
    let min_x = if p.x < r.x { p.x } else { r.x };
    let max_x = if p.x > r.x { p.x } else { r.x };
    let min_y = if p.y < r.y { p.y } else { r.y };
    let max_y = if p.y > r.y { p.y } else { r.y };
    q.x >= min_x && q.x <= max_x && q.y >= min_y && q.y <= max_y
}

fn segments_intersect(a: Point, b: Point, c: Point, d: Point) -> Bool {
    let d1 = sign(cross(c, d, a));
    let d2 = sign(cross(c, d, b));
    let d3 = sign(cross(a, b, c));
    let d4 = sign(cross(a, b, d));

    if d1 * d2 < 0 && d3 * d4 < 0 { true }
    else if d1 == 0 && on_segment(c, a, d) { true }
    else if d2 == 0 && on_segment(c, b, d) { true }
    else if d3 == 0 && on_segment(a, c, b) { true }
    else if d4 == 0 && on_segment(a, d, b) { true }
    else { false }
}

fn main() -> Int {
    // === Test 1: Cross product basics ===
    // CCW triangle
    assert(cross(pt(0, 0), pt(1, 0), pt(0, 1)) > 0);
    // CW triangle
    assert(cross(pt(0, 0), pt(0, 1), pt(1, 0)) < 0);
    // Collinear
    assert_eq(cross(pt(0, 0), pt(1, 1), pt(2, 2)), 0);
    assert_eq(cross(pt(0, 0), pt(3, 0), pt(7, 0)), 0);

    // Cross product value: (1,0)x(0,1) = 1*1 - 0*0 = 1
    assert_eq(cross(pt(0, 0), pt(1, 0), pt(0, 1)), 1);
    // (3,0)x(0,4) = 3*4 - 0*0 = 12
    assert_eq(cross(pt(0, 0), pt(3, 0), pt(0, 4)), 12);

    // === Test 2: Dot product ===
    // Perpendicular: dot = 0
    assert_eq(dot(pt(0, 0), pt(1, 0), pt(0, 1)), 0);
    // Parallel same direction
    assert_eq(dot(pt(0, 0), pt(3, 0), pt(5, 0)), 15);
    // Opposite direction
    assert_eq(dot(pt(5, 0), pt(8, 0), pt(2, 0)), -9);
    // General: (1,2).(3,4) = 3+8 = 11
    assert_eq(dot(pt(0, 0), pt(1, 2), pt(3, 4)), 11);

    // === Test 3: Distance squared ===
    assert_eq(dist_sq(pt(0, 0), pt(3, 4)), 25);   // 3-4-5
    assert_eq(dist_sq(pt(0, 0), pt(5, 12)), 169);  // 5-12-13
    assert_eq(dist_sq(pt(0, 0), pt(0, 0)), 0);
    assert_eq(dist_sq(pt(1, 1), pt(4, 5)), 25);
    // Symmetric
    assert_eq(dist_sq(pt(1, 2), pt(4, 6)), dist_sq(pt(4, 6), pt(1, 2)));

    // === Test 4: Point in triangle ===
    let ta = pt(0, 0);
    let tb = pt(10, 0);
    let tc = pt(0, 10);
    // Inside
    assert(point_in_triangle(pt(2, 2), ta, tb, tc));
    assert(point_in_triangle(pt(1, 1), ta, tb, tc));
    assert(point_in_triangle(pt(3, 3), ta, tb, tc));
    // On edge
    assert(point_in_triangle(pt(5, 0), ta, tb, tc));
    assert(point_in_triangle(pt(0, 5), ta, tb, tc));
    assert(point_in_triangle(pt(5, 5), ta, tb, tc));
    // On vertex
    assert(point_in_triangle(pt(0, 0), ta, tb, tc));
    assert(point_in_triangle(pt(10, 0), ta, tb, tc));
    // Outside
    assert(!point_in_triangle(pt(6, 6), ta, tb, tc));
    assert(!point_in_triangle(pt(-1, -1), ta, tb, tc));
    assert(!point_in_triangle(pt(11, 0), ta, tb, tc));

    // === Test 5: Triangle area ===
    // Right triangle legs 3,4: area=6, 2*area=12
    assert_eq(triangle_area_2x(pt(0, 0), pt(3, 0), pt(0, 4)), 12);
    // Unit triangle: 2*area=1
    assert_eq(triangle_area_2x(pt(0, 0), pt(1, 0), pt(0, 1)), 1);
    // Degenerate (collinear): area=0
    assert_eq(triangle_area_2x(pt(0, 0), pt(1, 1), pt(2, 2)), 0);
    // Larger: legs 10,20: 2*area=200
    assert_eq(triangle_area_2x(pt(0, 0), pt(10, 0), pt(0, 20)), 200);

    // === Test 6: Polygon area - square ===
    // Square (0,0),(4,0),(4,4),(0,4): area=16, 2*area=32
    let square = Poly8 {
        x0: 0, x1: 4, x2: 4, x3: 0, x4: 0, x5: 0, x6: 0, x7: 0,
        y0: 0, y1: 0, y2: 4, y3: 4, y4: 0, y5: 0, y6: 0, y7: 0,
        n: 4
    };
    assert_eq(polygon_area_2x(square), 32);

    // === Test 7: Polygon area - rectangle ===
    // 5x3 rectangle: area=15, 2*area=30
    let rect = Poly8 {
        x0: 0, x1: 5, x2: 5, x3: 0, x4: 0, x5: 0, x6: 0, x7: 0,
        y0: 0, y1: 0, y2: 3, y3: 3, y4: 0, y5: 0, y6: 0, y7: 0,
        n: 4
    };
    assert_eq(polygon_area_2x(rect), 30);

    // === Test 8: Polygon area - triangle ===
    let tri = Poly8 {
        x0: 0, x1: 6, x2: 0, x3: 0, x4: 0, x5: 0, x6: 0, x7: 0,
        y0: 0, y1: 0, y2: 8, y3: 0, y4: 0, y5: 0, y6: 0, y7: 0,
        n: 3
    };
    assert_eq(polygon_area_2x(tri), 48);

    // === Test 9: Convexity ===
    assert(polygon_is_convex(square));
    assert(polygon_is_convex(rect));

    // L-shaped polygon (non-convex): (0,0),(2,0),(2,1),(1,1),(1,2),(0,2)
    let l_shape = Poly8 {
        x0: 0, x1: 2, x2: 2, x3: 1, x4: 1, x5: 0, x6: 0, x7: 0,
        y0: 0, y1: 0, y2: 1, y3: 1, y4: 2, y5: 2, y6: 0, y7: 0,
        n: 6
    };
    assert(!polygon_is_convex(l_shape));
    // L-shape area: 3 square units, 2*area=6
    assert_eq(polygon_area_2x(l_shape), 6);

    // Pentagon (convex): (2,0),(4,3),(3,5),(1,5),(0,3)
    let pentagon = Poly8 {
        x0: 2, x1: 4, x2: 3, x3: 1, x4: 0, x5: 0, x6: 0, x7: 0,
        y0: 0, y1: 3, y2: 5, y3: 5, y4: 3, y5: 0, y6: 0, y7: 0,
        n: 5
    };
    assert(polygon_is_convex(pentagon));
    // Shoelace: (2*3-4*0)+(4*5-3*3)+(3*5-1*5)+(1*3-0*5)+(0*0-2*3) = 6+11+10+3-6 = 24
    assert_eq(polygon_area_2x(pentagon), 24);

    // === Test 10: Collinearity ===
    assert(is_collinear(pt(0, 0), pt(1, 1), pt(2, 2)));
    assert(is_collinear(pt(0, 0), pt(5, 0), pt(10, 0)));
    assert(!is_collinear(pt(0, 0), pt(1, 0), pt(0, 1)));

    // === Test 11: Manhattan distance ===
    assert_eq(manhattan(pt(0, 0), pt(3, 4)), 7);
    assert_eq(manhattan(pt(1, 1), pt(4, 5)), 7);
    assert_eq(manhattan(pt(0, 0), pt(0, 0)), 0);
    assert_eq(manhattan(pt(-3, -4), pt(3, 4)), 14);

    // === Test 12: Perimeter ===
    // Square side 4: each edge dist_sq=16, 4 edges -> 64
    assert_eq(perimeter_sq_sum(square), 64);
    // Rectangle 5x3: edges 25+9+25+9 = 68
    assert_eq(perimeter_sq_sum(rect), 68);

    // === Test 13: Segment intersection ===
    // Crossing segments: (0,0)-(4,4) and (0,4)-(4,0)
    assert(segments_intersect(pt(0, 0), pt(4, 4), pt(0, 4), pt(4, 0)));
    // Parallel non-intersecting: (0,0)-(4,0) and (0,1)-(4,1)
    assert(!segments_intersect(pt(0, 0), pt(4, 0), pt(0, 1), pt(4, 1)));
    // T-intersection: (0,0)-(4,0) and (2,0)-(2,3) -- endpoint touches
    assert(segments_intersect(pt(0, 0), pt(4, 0), pt(2, 0), pt(2, 3)));
    // Disjoint: (0,0)-(1,0) and (3,0)-(4,0)
    assert(!segments_intersect(pt(0, 0), pt(1, 0), pt(3, 0), pt(4, 0)));
    // Overlapping collinear: (0,0)-(3,0) and (2,0)-(5,0)
    assert(segments_intersect(pt(0, 0), pt(3, 0), pt(2, 0), pt(5, 0)));
    // Same endpoint: (0,0)-(1,1) and (1,1)-(2,0)
    assert(segments_intersect(pt(0, 0), pt(1, 1), pt(1, 1), pt(2, 0)));

    // === Test 14: Pick's theorem verification ===
    // For lattice polygon: A = I + B/2 - 1, where I=interior, B=boundary points
    // Square (0,0)-(4,0)-(4,4)-(0,4): area=16
    // Boundary: 4*4=16 points, Interior: 3*3=9 points
    // Check: 9 + 16/2 - 1 = 9 + 8 - 1 = 16. Correct!
    // 2*A = 32 (already verified above)
    // We verify 2*A = 2*I + B - 2
    assert_eq(32, 2 * 9 + 16 - 2);

    0
}
