// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, polynomial, lagrange, interpolation, math
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Lagrange polynomial interpolation at integer points
// Uses scaled integer arithmetic to avoid floating point

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int, len: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

fn arr8_new(n: Int) -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: n }
}

fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }

// Lagrange interpolation at integer x values
// Given points (xs[i], ys[i]) for i = 0..n-1, evaluate the polynomial at target_x
// Returns (numerator, denominator) as a pair to represent exact rational result
type Rational is { num: Int, den: Int };

// Compute product of (target_x - xs[j]) for all j != i
fn lagrange_basis_num(xs: Arr8, n: Int, i: Int, target_x: Int) -> Int {
    let mut prod = 1;
    let mut j = 0;
    while j < n {
        if j != i {
            prod = prod * (target_x - arr8_get(xs, j));
        }
        j = j + 1;
    }
    prod
}

// Compute product of (xs[i] - xs[j]) for all j != i
fn lagrange_basis_den(xs: Arr8, n: Int, i: Int) -> Int {
    let mut prod = 1;
    let mut j = 0;
    while j < n {
        if j != i {
            prod = prod * (arr8_get(xs, i) - arr8_get(xs, j));
        }
        j = j + 1;
    }
    prod
}

// GCD for simplifying fractions
fn gcd(a: Int, b_val: Int) -> Int {
    let mut x = abs_val(a);
    let mut y = abs_val(b_val);
    while y != 0 { let t = y; y = x % y; x = t; }
    x
}

fn simplify(r: Rational) -> Rational {
    if r.num == 0 { return Rational { num: 0, den: 1 }; }
    let g = gcd(abs_val(r.num), abs_val(r.den));
    let mut sn = r.num / g;
    let mut sd = r.den / g;
    if sd < 0 { sn = -sn; sd = -sd; }
    Rational { num: sn, den: sd }
}

// Full Lagrange interpolation: sum of y_i * L_i(x) where L_i is the i-th basis polynomial
// Returns exact rational result
fn lagrange_eval(xs: Arr8, ys: Arr8, n: Int, target_x: Int) -> Rational {
    // To add fractions, find common denominator
    // Result = sum(ys[i] * basis_num_i / basis_den_i)

    // Common denominator = product of all basis denominators
    // But this can overflow for large n, so we'll use a step-by-step approach

    // For small n (<=8), compute numerator and denominator directly
    // Each term: ys[i] * product(target_x - xs[j], j!=i) / product(xs[i] - xs[j], j!=i)

    // To sum fractions a/b + c/d = (a*d + c*b) / (b*d), but we do it iteratively
    let mut result_num = 0;
    let mut result_den = 1;

    let mut i = 0;
    while i < n {
        let bnum = lagrange_basis_num(xs, n, i, target_x);
        let bden = lagrange_basis_den(xs, n, i);
        let yi = arr8_get(ys, i);

        // term = yi * bnum / bden
        // result = result_num/result_den + yi*bnum/bden
        //        = (result_num * bden + yi * bnum * result_den) / (result_den * bden)
        result_num = result_num * bden + yi * bnum * result_den;
        result_den = result_den * bden;

        // Simplify to prevent overflow
        let g = gcd(abs_val(result_num), abs_val(result_den));
        if g > 1 {
            result_num = result_num / g;
            result_den = result_den / g;
        }

        i = i + 1;
    }

    simplify(Rational { num: result_num, den: result_den })
}

// Convenience: evaluate when result is known to be integer
fn lagrange_eval_int(xs: Arr8, ys: Arr8, n: Int, target_x: Int) -> Int {
    let r = lagrange_eval(xs, ys, n, target_x);
    r.num / r.den
}

fn test_linear() {
    // Points: (1, 3), (2, 5) -> line y = 2x + 1
    let xs = Arr8 { a0: 1, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };
    let ys = Arr8 { a0: 3, a1: 5, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };

    assert_eq(lagrange_eval_int(xs, ys, 2, 0), 1);   // 2*0+1 = 1
    assert_eq(lagrange_eval_int(xs, ys, 2, 3), 7);   // 2*3+1 = 7
    assert_eq(lagrange_eval_int(xs, ys, 2, 5), 11);  // 2*5+1 = 11
    assert_eq(lagrange_eval_int(xs, ys, 2, -1), -1);  // 2*(-1)+1 = -1
}

fn test_quadratic() {
    // Points: (0, 1), (1, 0), (2, 1) -> y = x^2 - 2x + 1 = (x-1)^2
    let xs = Arr8 { a0: 0, a1: 1, a2: 2, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let ys = Arr8 { a0: 1, a1: 0, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };

    assert_eq(lagrange_eval_int(xs, ys, 3, 0), 1);
    assert_eq(lagrange_eval_int(xs, ys, 3, 1), 0);
    assert_eq(lagrange_eval_int(xs, ys, 3, 2), 1);
    assert_eq(lagrange_eval_int(xs, ys, 3, 3), 4);   // (3-1)^2 = 4
    assert_eq(lagrange_eval_int(xs, ys, 3, -1), 4);  // (-1-1)^2 = 4
    assert_eq(lagrange_eval_int(xs, ys, 3, 5), 16);  // (5-1)^2 = 16
}

fn test_cubic() {
    // Points: (0, 0), (1, 1), (2, 8), (3, 27) -> y = x^3
    let xs = Arr8 { a0: 0, a1: 1, a2: 2, a3: 3, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let ys = Arr8 { a0: 0, a1: 1, a2: 8, a3: 27, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };

    assert_eq(lagrange_eval_int(xs, ys, 4, 4), 64);   // 4^3
    assert_eq(lagrange_eval_int(xs, ys, 4, 5), 125);  // 5^3
    assert_eq(lagrange_eval_int(xs, ys, 4, -1), -1);  // (-1)^3
}

fn test_interpolate_at_known_points() {
    // Interpolating at known points should return exact values
    let xs = Arr8 { a0: 10, a1: 20, a2: 30, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let ys = Arr8 { a0: 100, a1: 400, a2: 900, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };

    assert_eq(lagrange_eval_int(xs, ys, 3, 10), 100);
    assert_eq(lagrange_eval_int(xs, ys, 3, 20), 400);
    assert_eq(lagrange_eval_int(xs, ys, 3, 30), 900);
}

fn test_constant_poly() {
    // All y values the same -> constant polynomial
    let xs = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    let ys = Arr8 { a0: 7, a1: 7, a2: 7, a3: 7, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };

    assert_eq(lagrange_eval_int(xs, ys, 4, 0), 7);
    assert_eq(lagrange_eval_int(xs, ys, 4, 100), 7);
    assert_eq(lagrange_eval_int(xs, ys, 4, -50), 7);
}

fn test_basis_polynomial() {
    // Test individual basis polynomial properties
    // For 3 points at x=0,1,2: L_0(0)=1, L_0(1)=0, L_0(2)=0
    let xs = Arr8 { a0: 0, a1: 1, a2: 2, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };

    // basis_num for i=0 at x=0: (0-1)*(0-2) = 2
    let bn0 = lagrange_basis_num(xs, 3, 0, 0);
    assert_eq(bn0, 2);

    // basis_den for i=0: (0-1)*(0-2) = 2
    let bd0 = lagrange_basis_den(xs, 3, 0);
    assert_eq(bd0, 2);

    // So L_0(0) = bn0/bd0 = 2/2 = 1 (correct!)

    // basis_num for i=0 at x=1: (1-1)*(1-2) = 0
    let bn0_at1 = lagrange_basis_num(xs, 3, 0, 1);
    assert_eq(bn0_at1, 0);  // L_0(1) = 0 (correct!)
}

fn test_negative_x_values() {
    // Points at negative x: (-2, 4), (-1, 1), (0, 0), (1, 1), (2, 4) -> y = x^2
    let xs = Arr8 { a0: -2, a1: -1, a2: 0, a3: 1, a4: 2, a5: 0, a6: 0, a7: 0, len: 5 };
    let ys = Arr8 { a0: 4, a1: 1, a2: 0, a3: 1, a4: 4, a5: 0, a6: 0, a7: 0, len: 5 };

    // With 5 points, degree-4 polynomial, but since data is x^2, higher terms vanish
    assert_eq(lagrange_eval_int(xs, ys, 5, 3), 9);
    assert_eq(lagrange_eval_int(xs, ys, 5, -3), 9);
}

fn test_rational_result() {
    // Points that give a non-integer result at target
    // (0, 0), (2, 4) -> y = 2x
    let xs = Arr8 { a0: 0, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };
    let ys = Arr8 { a0: 0, a1: 4, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };

    // At x=1, y should be 2 (exact integer)
    let r = lagrange_eval(xs, ys, 2, 1);
    assert_eq(r.num, 2);
    assert_eq(r.den, 1);

    // At x=3, y should be 6
    let r2 = lagrange_eval(xs, ys, 2, 3);
    assert_eq(r2.num, 6);
    assert_eq(r2.den, 1);
}

fn test_simplify() {
    let r1 = simplify(Rational { num: 6, den: 4 });
    assert_eq(r1.num, 3);
    assert_eq(r1.den, 2);

    let r2 = simplify(Rational { num: -10, den: 5 });
    assert_eq(r2.num, -2);
    assert_eq(r2.den, 1);

    let r3 = simplify(Rational { num: 0, den: 100 });
    assert_eq(r3.num, 0);
    assert_eq(r3.den, 1);

    let r4 = simplify(Rational { num: 7, den: -3 });
    assert_eq(r4.num, -7);
    assert_eq(r4.den, 3);
}

fn main() -> Int {
    test_linear();
    test_quadratic();
    test_cubic();
    test_interpolate_at_known_points();
    test_constant_poly();
    test_basis_polynomial();
    test_negative_x_values();
    test_rational_result();
    test_simplify();
    print("[OK] 294_lagrange_interp_aot");
    0
}
