// @test: run
// @level: L0
// @tags: aot, e2e, string, algorithm, hash
// @timeout: 30000

// String algorithm operations using integer arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn new_arr8() -> Arr8 {
    Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
}

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// Polynomial rolling hash of array[0..n)
fn rolling_hash(arr: Arr8, n: Int) -> Int {
    let base = 31;
    let modulus = 1000000007;
    let mut h = 0;
    let mut i = 0;
    while i < n {
        h = (h * base + get8(arr, i)) % modulus;
        i = i + 1;
    }
    h
}

// Check if array is palindrome
fn is_palindrome(arr: Arr8, n: Int) -> Int {
    let mut lo = 0;
    let mut hi = n - 1;
    while lo < hi {
        if get8(arr, lo) != get8(arr, hi) { return 0; }
        lo = lo + 1;
        hi = hi - 1;
    }
    1
}

// Reverse array into new Arr8
fn reverse_arr(arr: Arr8, n: Int) -> Arr8 {
    let mut result = new_arr8();
    let mut i = 0;
    while i < n {
        result = set8(result, i, get8(arr, n - 1 - i));
        i = i + 1;
    }
    result
}

// Count distinct elements
fn count_distinct(arr: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut found = 0;
        let mut j = 0;
        while j < i {
            if get8(arr, j) == get8(arr, i) { found = 1; j = i; }
            j = j + 1;
        }
        if found == 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Most frequent element
fn most_frequent(arr: Arr8, n: Int) -> Int {
    let mut best_val = get8(arr, 0);
    let mut best_count = 0;
    let mut i = 0;
    while i < n {
        let mut cnt = 0;
        let mut j = 0;
        while j < n {
            if get8(arr, j) == get8(arr, i) { cnt = cnt + 1; }
            j = j + 1;
        }
        if cnt > best_count {
            best_count = cnt;
            best_val = get8(arr, i);
        }
        i = i + 1;
    }
    best_val
}

fn test_hash() -> Int {
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let c = Arr8 { v0: 4, v1: 3, v2: 2, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Same arrays -> same hash
    assert_eq(rolling_hash(a, 4), rolling_hash(b, 4));
    // Different arrays -> (very likely) different hash
    let ha = rolling_hash(a, 4);
    let hc = rolling_hash(c, 4);
    // They should differ
    if ha == hc { assert_eq(0, 1); } // force fail if collision
    1
}

fn test_palindrome() -> Int {
    let p = Arr8 { v0: 1, v1: 2, v2: 3, v3: 2, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_palindrome(p, 5), 1);
    let np = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_palindrome(np, 5), 0);
    1
}

fn test_reverse() -> Int {
    let a = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r = reverse_arr(a, 4);
    assert_eq(get8(r, 0), 40);
    assert_eq(get8(r, 1), 30);
    assert_eq(get8(r, 2), 20);
    assert_eq(get8(r, 3), 10);
    1
}

fn test_distinct_freq() -> Int {
    let a = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 9, v6: 2, v7: 6 };
    assert_eq(count_distinct(a, 8), 7); // all distinct except 1 appears twice
    assert_eq(most_frequent(a, 8), 1);  // 1 appears twice
    1
}

fn main() -> Int {
    test_hash();
    test_palindrome();
    test_reverse();
    test_distinct_freq();
    print("[OK] 426_string_algo_aot");
    0
}
