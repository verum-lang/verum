// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, string, builder, format
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for integer-to-string conversion and number formatting

fn count_digits(n: Int) -> Int {
    if n == 0 { return 1; }
    let mut x = if n < 0 { -n } else { n };
    let mut count = 0;
    while x > 0 {
        count = count + 1;
        x = x / 10;
    }
    count
}

fn digit_sum(n: Int) -> Int {
    let mut x = if n < 0 { -n } else { n };
    let mut sum = 0;
    while x > 0 {
        sum = sum + x % 10;
        x = x / 10;
    }
    sum
}

fn reverse_number(n: Int) -> Int {
    let mut x = if n < 0 { -n } else { n };
    let mut rev = 0;
    while x > 0 {
        rev = rev * 10 + x % 10;
        x = x / 10;
    }
    if n < 0 { -rev } else { rev }
}

fn is_palindrome_num(n: Int) -> Bool {
    if n < 0 { return false; }
    n == reverse_number(n)
}

fn nth_digit(n: Int, pos: Int) -> Int {
    // Get the digit at position pos (0 = least significant)
    let mut x = if n < 0 { -n } else { n };
    let mut i = 0;
    while i < pos {
        x = x / 10;
        i = i + 1;
    }
    x % 10
}

fn to_base(n: Int, base: Int) -> Int {
    // Returns a decimal representation of n in given base
    // e.g., to_base(10, 2) = 1010 (decimal reading of binary)
    if n == 0 { return 0; }
    let mut x = if n < 0 { -n } else { n };
    let mut result = 0;
    let mut place = 1;
    while x > 0 {
        let digit = x % base;
        result = result + digit * place;
        x = x / base;
        place = place * 10;
    }
    result
}

fn from_base(digits: Int, base: Int) -> Int {
    // Interpret a decimal number as base-N digits
    // e.g., from_base(1010, 2) = 10
    let mut x = digits;
    let mut result = 0;
    let mut multiplier = 1;
    while x > 0 {
        let d = x % 10;
        result = result + d * multiplier;
        x = x / 10;
        multiplier = multiplier * base;
    }
    result
}

fn test_digit_ops() {
    assert_eq(count_digits(0), 1);
    assert_eq(count_digits(1), 1);
    assert_eq(count_digits(42), 2);
    assert_eq(count_digits(100), 3);
    assert_eq(count_digits(99999), 5);
    assert_eq(count_digits(-42), 2);

    assert_eq(digit_sum(123), 6);
    assert_eq(digit_sum(999), 27);
    assert_eq(digit_sum(100), 1);
    assert_eq(digit_sum(0), 0);
}

fn test_reverse() {
    assert_eq(reverse_number(123), 321);
    assert_eq(reverse_number(100), 1);
    assert_eq(reverse_number(12345), 54321);
    assert_eq(reverse_number(0), 0);
    assert_eq(reverse_number(-123), -321);
}

fn test_palindrome() {
    assert_eq(is_palindrome_num(121), true);
    assert_eq(is_palindrome_num(12321), true);
    assert_eq(is_palindrome_num(1), true);
    assert_eq(is_palindrome_num(0), true);
    assert_eq(is_palindrome_num(123), false);
    assert_eq(is_palindrome_num(10), false);
    assert_eq(is_palindrome_num(-121), false);
}

fn test_nth_digit() {
    assert_eq(nth_digit(12345, 0), 5);
    assert_eq(nth_digit(12345, 1), 4);
    assert_eq(nth_digit(12345, 2), 3);
    assert_eq(nth_digit(12345, 3), 2);
    assert_eq(nth_digit(12345, 4), 1);
}

fn test_base_conversion() {
    // Decimal 10 in binary = 1010
    assert_eq(to_base(10, 2), 1010);
    assert_eq(to_base(255, 2), 11111111);
    assert_eq(to_base(8, 2), 1000);

    // Binary 1010 to decimal = 10
    assert_eq(from_base(1010, 2), 10);
    assert_eq(from_base(1000, 2), 8);
    assert_eq(from_base(11111111, 2), 255);

    // Roundtrip
    assert_eq(from_base(to_base(42, 2), 2), 42);
    assert_eq(from_base(to_base(100, 2), 2), 100);
}

fn main() -> Int {
    test_digit_ops();
    test_reverse();
    test_palindrome();
    test_nth_digit();
    test_base_conversion();
    print("[OK] 195_string_builder_aot");
    0
}
