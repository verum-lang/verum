// @test: run
// @level: L0
// @expected-exit: 0

fn main() -> Int {
    let s = "ABCDE";
    let bytes = s.as_bytes();
    let n = bytes.len();
    print(f"n={n}");

    let mut count = 0;
    for j in range(0, n) {
        count = count + 1;
    }
    print(f"count={count}");

    // Same with hardcoded 5
    let mut count2 = 0;
    for j in range(0, 5) {
        count2 = count2 + 1;
    }
    print(f"count2={count2}");

    0
}
