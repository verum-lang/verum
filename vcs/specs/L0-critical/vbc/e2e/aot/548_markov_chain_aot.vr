// @test: run
// @level: L0
// @tags: aot, e2e, markov, chain, probability
// @timeout: 30000

// Markov chain simulation (integer-scaled probabilities)

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Transition matrix for N states stored as flat array
// T[i][j] = probability * SCALE of going from state i to state j
// Row i starts at index i*N
// Using 3 states, SCALE = 100 (probabilities as percentages)

type Grid3 is { r0: Arr8, r1: Arr8, r2: Arr8 };

fn grid_get(g: Grid3, row: Int, col: Int) -> Int {
    if row == 0 { get8(g.r0, col) }
    else if row == 1 { get8(g.r1, col) }
    else { get8(g.r2, col) }
}

// Matrix-vector multiply (probabilities): p_new[j] = sum_i(p[i] * T[i][j]) / SCALE
fn mat_vec_mul(trans: Grid3, prob: Arr8, n: Int, scale: Int) -> Arr8 {
    let mut result = zeros();
    let mut j = 0;
    while j < n {
        let mut sum = 0;
        let mut i = 0;
        while i < n {
            sum = sum + get8(prob, i) * grid_get(trans, i, j);
            i = i + 1;
        }
        result = set8(result, j, sum / scale);
        j = j + 1;
    }
    result
}

// Run Markov chain for k steps
fn markov_step(trans: Grid3, init: Arr8, n: Int, scale: Int, steps: Int) -> Arr8 {
    let mut prob = init;
    let mut k = 0;
    while k < steps {
        prob = mat_vec_mul(trans, prob, n, scale);
        k = k + 1;
    }
    prob
}

// Check if probabilities sum to scale (conservation)
fn prob_sum(prob: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n { sum = sum + get8(prob, i); i = i + 1; }
    sum
}

// Absorbing chain: check if state is absorbing (self-loop probability = scale)
fn is_absorbing(trans: Grid3, state: Int, n: Int, scale: Int) -> Int {
    if grid_get(trans, state, state) == scale { 1 } else { 0 }
}

// Count absorbing states
fn count_absorbing(trans: Grid3, n: Int, scale: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if is_absorbing(trans, i, n, scale) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_identity_chain() -> Int {
    // Identity matrix: no transitions, state stays same
    let trans = Grid3 {
        r0: Arr8 { v0: 100, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r1: Arr8 { v0: 0, v1: 100, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r2: Arr8 { v0: 0, v1: 0, v2: 100, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
    };
    let init = Arr8 { v0: 100, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = markov_step(trans, init, 3, 100, 5);
    assert_eq(get8(result, 0), 100);
    assert_eq(get8(result, 1), 0);
    assert_eq(get8(result, 2), 0);
    1
}

fn test_uniform_chain() -> Int {
    // Each state goes uniformly to all states (33% each, scaled so rows sum to 99 ≈ 100)
    // Using 33+33+34=100
    let trans = Grid3 {
        r0: Arr8 { v0: 33, v1: 33, v2: 34, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r1: Arr8 { v0: 33, v1: 33, v2: 34, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r2: Arr8 { v0: 33, v1: 33, v2: 34, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
    };
    // Start at state 0
    let init = Arr8 { v0: 100, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = markov_step(trans, init, 3, 100, 1);
    // After 1 step: [33, 33, 34]
    assert_eq(get8(result, 0), 33);
    assert_eq(get8(result, 1), 33);
    assert_eq(get8(result, 2), 34);
    1
}

fn test_absorbing_chain() -> Int {
    // State 2 is absorbing: stays in state 2 forever
    // State 0 → state 1 (100%)
    // State 1 → state 2 (100%)
    // State 2 → state 2 (100%)
    let trans = Grid3 {
        r0: Arr8 { v0: 0, v1: 100, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r1: Arr8 { v0: 0, v1: 0, v2: 100, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r2: Arr8 { v0: 0, v1: 0, v2: 100, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
    };
    assert_eq(is_absorbing(trans, 2, 3, 100), 1);
    assert_eq(is_absorbing(trans, 0, 3, 100), 0);
    assert_eq(count_absorbing(trans, 3, 100), 1);

    let init = Arr8 { v0: 100, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r1 = markov_step(trans, init, 3, 100, 1);
    assert_eq(get8(r1, 1), 100); // all in state 1

    let r2 = markov_step(trans, init, 3, 100, 2);
    assert_eq(get8(r2, 2), 100); // all in state 2

    let r5 = markov_step(trans, init, 3, 100, 5);
    assert_eq(get8(r5, 2), 100); // still in state 2
    1
}

fn test_prob_conservation() -> Int {
    let trans = Grid3 {
        r0: Arr8 { v0: 50, v1: 30, v2: 20, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r1: Arr8 { v0: 10, v1: 70, v2: 20, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r2: Arr8 { v0: 30, v1: 30, v2: 40, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 }
    };
    let init = Arr8 { v0: 100, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(prob_sum(init, 3), 100);

    let r1 = markov_step(trans, init, 3, 100, 1);
    assert_eq(prob_sum(r1, 3), 100);
    1
}

fn test_two_state() -> Int {
    // Simple 2-state chain: probability of switching = 50%
    let trans = Grid3 {
        r0: Arr8 { v0: 50, v1: 50, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r1: Arr8 { v0: 50, v1: 50, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 },
        r2: zeros()
    };
    let init = Arr8 { v0: 100, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r1 = markov_step(trans, init, 2, 100, 1);
    assert_eq(get8(r1, 0), 50);
    assert_eq(get8(r1, 1), 50);

    // After another step: 50/50 stays 50/50
    let r2 = markov_step(trans, init, 2, 100, 2);
    assert_eq(get8(r2, 0), 50);
    assert_eq(get8(r2, 1), 50);
    1
}

fn main() -> Int {
    test_identity_chain();
    test_uniform_chain();
    test_absorbing_chain();
    test_prob_conservation();
    test_two_state();
    print("[OK] 548_markov_chain_aot");
    0
}
