// @test: run
// @level: L0
// @tags: aot, e2e, milestone, 500, comprehensive
// @timeout: 30000

// Milestone 500: Comprehensive test combining multiple algorithm categories
// Tests: fibonacci variants, sorting, searching, hashing, bit ops, math

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// === Fibonacci with matrix exponentiation ===
// [F(n+1), F(n)] = [[1,1],[1,0]]^n * [1, 0]
// Using 2x2 matrix stored as 4 values

fn mat2_mul(a0: Int, a1: Int, a2: Int, a3: Int,
            b0: Int, b1: Int, b2: Int, b3: Int) -> Arr8 {
    Arr8 {
        v0: a0 * b0 + a1 * b2,
        v1: a0 * b1 + a1 * b3,
        v2: a2 * b0 + a3 * b2,
        v3: a2 * b1 + a3 * b3,
        v4: 0, v5: 0, v6: 0, v7: 0
    }
}

fn fib_matrix(n: Int) -> Int {
    if n <= 0 { return 0; }
    if n == 1 { return 1; }
    // Start with identity
    let mut r0 = 1; let mut r1 = 0; let mut r2 = 0; let mut r3 = 1;
    // Base matrix [[1,1],[1,0]]
    let mut b0 = 1; let mut b1 = 1; let mut b2 = 1; let mut b3 = 0;
    let mut p = n - 1;
    while p > 0 {
        if p % 2 == 1 {
            let m = mat2_mul(r0, r1, r2, r3, b0, b1, b2, b3);
            r0 = get8(m, 0); r1 = get8(m, 1); r2 = get8(m, 2); r3 = get8(m, 3);
        }
        let m2 = mat2_mul(b0, b1, b2, b3, b0, b1, b2, b3);
        b0 = get8(m2, 0); b1 = get8(m2, 1); b2 = get8(m2, 2); b3 = get8(m2, 3);
        p = p / 2;
    }
    r0
}

// === Insertion sort ===
fn insertion_sort(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 1;
    while i < n {
        let key = get8(a, i);
        let mut j = i - 1;
        let mut cont = 1;
        while cont == 1 {
            if j < 0 { cont = 0; }
            else if get8(a, j) <= key { cont = 0; }
            else {
                a = set8(a, j + 1, get8(a, j));
                j = j - 1;
            }
        }
        a = set8(a, j + 1, key);
        i = i + 1;
    }
    a
}

// === Power function ===
fn power(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut b = base;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 { result = result * b; }
        b = b * b;
        e = e / 2;
    }
    result
}

// === GCD ===
fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y != 0 { let t = y; y = x % y; x = t; }
    x
}

fn lcm(a: Int, b: Int) -> Int {
    a / gcd(a, b) * b
}

// === Popcount ===
fn popcount(n: Int) -> Int {
    let mut x = n;
    let mut c = 0;
    while x > 0 { c = c + x % 2; x = x / 2; }
    c
}

// === Hash ===
fn hash_combine(h: Int, val: Int) -> Int {
    let mixed = h * 31 + val;
    let mask = 1073741823; // 2^30 - 1
    mixed % mask
}

fn test_fibonacci_matrix() -> Int {
    assert_eq(fib_matrix(0), 0);
    assert_eq(fib_matrix(1), 1);
    assert_eq(fib_matrix(2), 1);
    assert_eq(fib_matrix(3), 2);
    assert_eq(fib_matrix(5), 5);
    assert_eq(fib_matrix(10), 55);
    assert_eq(fib_matrix(15), 610);
    assert_eq(fib_matrix(20), 6765);
    1
}

fn test_sorting() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 9, v5: 2, v6: 7, v7: 4 };
    let sorted = insertion_sort(arr, 8);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 1), 2);
    assert_eq(get8(sorted, 2), 3);
    assert_eq(get8(sorted, 3), 4);
    assert_eq(get8(sorted, 4), 5);
    assert_eq(get8(sorted, 5), 7);
    assert_eq(get8(sorted, 6), 8);
    assert_eq(get8(sorted, 7), 9);
    1
}

fn test_power() -> Int {
    assert_eq(power(2, 0), 1);
    assert_eq(power(2, 10), 1024);
    assert_eq(power(3, 5), 243);
    assert_eq(power(5, 3), 125);
    1
}

fn test_gcd_lcm() -> Int {
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(17, 13), 1);
    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(7, 5), 35);
    // LCM identity: lcm(a,b) * gcd(a,b) = a * b
    assert_eq(lcm(12, 8) * gcd(12, 8), 12 * 8);
    1
}

fn test_popcount_power2() -> Int {
    // Powers of 2 have exactly 1 bit set
    assert_eq(popcount(1), 1);
    assert_eq(popcount(2), 1);
    assert_eq(popcount(4), 1);
    assert_eq(popcount(8), 1);
    assert_eq(popcount(256), 1);
    // Others
    assert_eq(popcount(7), 3);
    assert_eq(popcount(255), 8);
    assert_eq(popcount(0), 0);
    1
}

fn test_hash_consistency() -> Int {
    // Same sequence → same hash
    let h1 = hash_combine(hash_combine(hash_combine(0, 1), 2), 3);
    let h2 = hash_combine(hash_combine(hash_combine(0, 1), 2), 3);
    assert_eq(h1, h2);
    // Different sequence → different hash (usually)
    let h3 = hash_combine(hash_combine(hash_combine(0, 3), 2), 1);
    assert(h1 != h3);
    1
}

fn test_combined() -> Int {
    // Fibonacci is related to golden ratio: F(n) * F(n) approximately = F(n-1) * F(n+1) ± 1
    // Cassini's identity: F(n-1)*F(n+1) - F(n)^2 = (-1)^n
    let f9 = fib_matrix(9);   // 34
    let f10 = fib_matrix(10); // 55
    let f11 = fib_matrix(11); // 89
    // Cassini's identity: F(n-1)*F(n+1) - F(n)^2 = (-1)^n
    // For n=10: F(9)*F(11) - F(10)^2 = 34*89 - 55*55 = 3026 - 3025 = 1
    assert_eq(f9 * f11 - f10 * f10, 1);

    // Sort fibonacci sequence and verify
    let fibs = Arr8 { v0: fib_matrix(7), v1: fib_matrix(3), v2: fib_matrix(5), v3: fib_matrix(1),
                      v4: fib_matrix(6), v5: fib_matrix(2), v6: fib_matrix(4), v7: fib_matrix(0) };
    let sorted = insertion_sort(fibs, 8);
    assert_eq(get8(sorted, 0), 0);  // fib(0)
    assert_eq(get8(sorted, 1), 1);  // fib(1)
    assert_eq(get8(sorted, 2), 1);  // fib(2)
    assert_eq(get8(sorted, 3), 2);  // fib(3)
    assert_eq(get8(sorted, 4), 3);  // fib(4)
    assert_eq(get8(sorted, 5), 5);  // fib(5)
    assert_eq(get8(sorted, 6), 8);  // fib(6)
    assert_eq(get8(sorted, 7), 13); // fib(7)
    1
}

fn main() -> Int {
    test_fibonacci_matrix();
    test_sorting();
    test_power();
    test_gcd_lcm();
    test_popcount_power2();
    test_hash_consistency();
    test_combined();
    print("[OK] 500_milestone_aot");
    0
}
