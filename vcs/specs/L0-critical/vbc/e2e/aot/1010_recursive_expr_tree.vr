// @test: run
// Recursive data structures with methods

type Expr is
    Num(Int)
  | Add { left: Heap<Expr>, right: Heap<Expr> }
  | Mul { left: Heap<Expr>, right: Heap<Expr> };

implement Expr {
    @allow(unbounded_recursion)
    fn eval(&self) -> Int {
        match self {
            Num(n) => n,
            Add { left, right } => left.eval() + right.eval(),
            Mul { left, right } => left.eval() * right.eval(),
        }
    }

    @allow(unbounded_recursion)
    fn size(&self) -> Int {
        match self {
            Num(_) => 1,
            Add { left, right } => 1 + left.size() + right.size(),
            Mul { left, right } => 1 + left.size() + right.size(),
        }
    }
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    // Test 1: Simple number
    let e1 = Num(42);
    if (e1.eval() == 42) { passed = passed + 1; }
    else { print(f"FAIL 1: eval={e1.eval()}"); failed = failed + 1; }

    // Test 2: Addition: 3 + 4 = 7
    let e2 = Add { left: Heap(Num(3)), right: Heap(Num(4)) };
    if (e2.eval() == 7) { passed = passed + 1; }
    else { print(f"FAIL 2: eval={e2.eval()}"); failed = failed + 1; }

    // Test 3: Multiplication: 5 * 6 = 30
    let e3 = Mul { left: Heap(Num(5)), right: Heap(Num(6)) };
    if (e3.eval() == 30) { passed = passed + 1; }
    else { print(f"FAIL 3: eval={e3.eval()}"); failed = failed + 1; }

    // Test 4: Nested: (2 + 3) * 4 = 20
    let e4 = Mul {
        left: Heap(Add { left: Heap(Num(2)), right: Heap(Num(3)) }),
        right: Heap(Num(4)),
    };
    if (e4.eval() == 20) { passed = passed + 1; }
    else { print(f"FAIL 4: eval={e4.eval()}"); failed = failed + 1; }

    // Test 5: Size counting
    if (e4.size() == 5) { passed = passed + 1; }
    else { print(f"FAIL 5: size={e4.size()}"); failed = failed + 1; }

    // Test 6: Deep nesting: ((1 + 2) * (3 + 4)) = 21
    let e5 = Mul {
        left: Heap(Add { left: Heap(Num(1)), right: Heap(Num(2)) }),
        right: Heap(Add { left: Heap(Num(3)), right: Heap(Num(4)) }),
    };
    if (e5.eval() == 21) { passed = passed + 1; }
    else { print(f"FAIL 6: eval={e5.eval()}"); failed = failed + 1; }

    if (failed > 0) {
        print(f"recursive_data: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"recursive_data: PASS ({passed}/{passed} tests)");
    0
}
