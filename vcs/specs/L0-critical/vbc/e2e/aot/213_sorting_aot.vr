// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, sorting, algorithms
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for sorting algorithms using flat record arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int, len: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 }
    else if i == 2 { a.v2 } else if i == 3 { a.v3 }
    else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 },
        len: a.len
    }
}

fn is_sorted(a: Arr8) -> Bool {
    let mut i = 0;
    while i < a.len - 1 {
        if arr8_get(a, i) > arr8_get(a, i + 1) { return false; }
        i = i + 1;
    }
    true
}

// Bubble sort
fn bubble_sort(a: Arr8) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < arr.len {
        let mut j = 0;
        while j < arr.len - 1 - i {
            let curr = arr8_get(arr, j);
            let next = arr8_get(arr, j + 1);
            if curr > next {
                arr = arr8_set(arr, j, next);
                arr = arr8_set(arr, j + 1, curr);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

// Selection sort
fn selection_sort(a: Arr8) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < arr.len - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < arr.len {
            if arr8_get(arr, j) < arr8_get(arr, min_idx) {
                min_idx = j;
            }
            j = j + 1;
        }
        if min_idx != i {
            let tmp = arr8_get(arr, i);
            arr = arr8_set(arr, i, arr8_get(arr, min_idx));
            arr = arr8_set(arr, min_idx, tmp);
        }
        i = i + 1;
    }
    arr
}

// Insertion sort
fn insertion_sort(a: Arr8) -> Arr8 {
    let mut arr = a;
    let mut i = 1;
    while i < arr.len {
        let key = arr8_get(arr, i);
        let mut j = i - 1;
        while j >= 0 && arr8_get(arr, j) > key {
            arr = arr8_set(arr, j + 1, arr8_get(arr, j));
            j = j - 1;
        }
        arr = arr8_set(arr, j + 1, key);
        i = i + 1;
    }
    arr
}

fn test_bubble_sort() {
    let a = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 9, v5: 2, v6: 7, v7: 4, len: 8 };
    let sorted = bubble_sort(a);
    assert_eq(is_sorted(sorted), true);
    assert_eq(arr8_get(sorted, 0), 1);
    assert_eq(arr8_get(sorted, 7), 9);

    // Already sorted
    let b = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0, len: 3 };
    let sb = bubble_sort(b);
    assert_eq(arr8_get(sb, 0), 1);
    assert_eq(arr8_get(sb, 2), 3);
}

fn test_selection_sort() {
    let a = Arr8 { v0: 64, v1: 25, v2: 12, v3: 22, v4: 11, v5: 0, v6: 0, v7: 0, len: 5 };
    let sorted = selection_sort(a);
    assert_eq(is_sorted(sorted), true);
    assert_eq(arr8_get(sorted, 0), 11);
    assert_eq(arr8_get(sorted, 4), 64);
}

fn test_insertion_sort() {
    let a = Arr8 { v0: 9, v1: 7, v2: 5, v3: 3, v4: 1, v5: 0, v6: 0, v7: 0, len: 5 };
    let sorted = insertion_sort(a);
    assert_eq(is_sorted(sorted), true);
    assert_eq(arr8_get(sorted, 0), 1);
    assert_eq(arr8_get(sorted, 4), 9);

    // Single element
    let s = Arr8 { v0: 42, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0, len: 1 };
    assert_eq(is_sorted(insertion_sort(s)), true);
}

fn test_sort_stability() {
    // All same values
    let a = Arr8 { v0: 5, v1: 5, v2: 5, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0, len: 4 };
    let sorted = bubble_sort(a);
    assert_eq(arr8_get(sorted, 0), 5);
    assert_eq(arr8_get(sorted, 3), 5);

    // Two elements reversed
    let b = Arr8 { v0: 2, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0, len: 2 };
    let sb = insertion_sort(b);
    assert_eq(arr8_get(sb, 0), 1);
    assert_eq(arr8_get(sb, 1), 2);
}

fn main() -> Int {
    test_bubble_sort();
    test_selection_sort();
    test_insertion_sort();
    test_sort_stability();
    print("[OK] 213_sorting_aot");
    0
}
