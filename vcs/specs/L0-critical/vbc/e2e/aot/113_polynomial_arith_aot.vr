// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, polynomial, arithmetic, flat-array, algebra
// @timeout: 50000
// @expected-exit: 0
// @description: AOT polynomial arithmetic (add, multiply, evaluate, derivative) using coefficient arrays

// Polynomial stored as coefficients: a0 + a1*x + a2*x^2 + ... + a15*x^15
// len = degree + 1 (number of coefficients)
type Poly is {
    c0: Int, c1: Int, c2: Int, c3: Int,
    c4: Int, c5: Int, c6: Int, c7: Int,
    c8: Int, c9: Int, c10: Int, c11: Int,
    c12: Int, c13: Int, c14: Int, c15: Int,
    len: Int
};

fn poly_zero() -> Poly {
    Poly {
        c0: 0, c1: 0, c2: 0, c3: 0,
        c4: 0, c5: 0, c6: 0, c7: 0,
        c8: 0, c9: 0, c10: 0, c11: 0,
        c12: 0, c13: 0, c14: 0, c15: 0,
        len: 0
    }
}

fn poly_get(p: Poly, i: Int) -> Int {
    if i == 0 { p.c0 } else if i == 1 { p.c1 }
    else if i == 2 { p.c2 } else if i == 3 { p.c3 }
    else if i == 4 { p.c4 } else if i == 5 { p.c5 }
    else if i == 6 { p.c6 } else if i == 7 { p.c7 }
    else if i == 8 { p.c8 } else if i == 9 { p.c9 }
    else if i == 10 { p.c10 } else if i == 11 { p.c11 }
    else if i == 12 { p.c12 } else if i == 13 { p.c13 }
    else if i == 14 { p.c14 } else { p.c15 }
}

fn poly_set(p: Poly, i: Int, v: Int) -> Poly {
    Poly {
        c0: if i == 0 { v } else { p.c0 },
        c1: if i == 1 { v } else { p.c1 },
        c2: if i == 2 { v } else { p.c2 },
        c3: if i == 3 { v } else { p.c3 },
        c4: if i == 4 { v } else { p.c4 },
        c5: if i == 5 { v } else { p.c5 },
        c6: if i == 6 { v } else { p.c6 },
        c7: if i == 7 { v } else { p.c7 },
        c8: if i == 8 { v } else { p.c8 },
        c9: if i == 9 { v } else { p.c9 },
        c10: if i == 10 { v } else { p.c10 },
        c11: if i == 11 { v } else { p.c11 },
        c12: if i == 12 { v } else { p.c12 },
        c13: if i == 13 { v } else { p.c13 },
        c14: if i == 14 { v } else { p.c14 },
        c15: if i == 15 { v } else { p.c15 },
        len: p.len
    }
}

fn poly_set_len(p: Poly, l: Int) -> Poly {
    Poly {
        c0: p.c0, c1: p.c1, c2: p.c2, c3: p.c3,
        c4: p.c4, c5: p.c5, c6: p.c6, c7: p.c7,
        c8: p.c8, c9: p.c9, c10: p.c10, c11: p.c11,
        c12: p.c12, c13: p.c13, c14: p.c14, c15: p.c15,
        len: l
    }
}

fn max_val(a: Int, b: Int) -> Int {
    if a > b { a } else { b }
}

// Construct a polynomial from 1 coefficient (constant)
fn poly_const(a: Int) -> Poly {
    let mut p = poly_zero();
    p = poly_set(p, 0, a);
    poly_set_len(p, 1)
}

// Construct from 2 coefficients: a + b*x
fn poly_linear(a: Int, b: Int) -> Poly {
    let mut p = poly_zero();
    p = poly_set(p, 0, a);
    p = poly_set(p, 1, b);
    poly_set_len(p, 2)
}

// Construct from 3 coefficients: a + b*x + c*x^2
fn poly_quadratic(a: Int, b: Int, c: Int) -> Poly {
    let mut p = poly_zero();
    p = poly_set(p, 0, a);
    p = poly_set(p, 1, b);
    p = poly_set(p, 2, c);
    poly_set_len(p, 3)
}

// Degree (highest non-zero coefficient index), -1 for zero polynomial
fn poly_degree(p: Poly) -> Int {
    let mut d = p.len - 1;
    while d > 0 && poly_get(p, d) == 0 {
        d = d - 1;
    }
    if d == 0 && poly_get(p, 0) == 0 { -1 }
    else { d }
}

// Normalize: trim trailing zeros
fn poly_normalize(p: Poly) -> Poly {
    let d = poly_degree(p);
    if d < 0 { poly_zero() }
    else { poly_set_len(p, d + 1) }
}

// Evaluate polynomial at x using Horner's method
fn poly_eval(p: Poly, x: Int) -> Int {
    if p.len == 0 { 0 }
    else {
        let mut result = poly_get(p, p.len - 1);
        let mut i = p.len - 2;
        while i >= 0 {
            result = result * x + poly_get(p, i);
            i = i - 1;
        }
        result
    }
}

// Add two polynomials
fn poly_add(a: Poly, b: Poly) -> Poly {
    let new_len = max_val(a.len, b.len);
    let mut result = poly_zero();
    let mut i = 0;
    while i < new_len {
        let ai = if i < a.len { poly_get(a, i) } else { 0 };
        let bi = if i < b.len { poly_get(b, i) } else { 0 };
        result = poly_set(result, i, ai + bi);
        i = i + 1;
    }
    poly_normalize(poly_set_len(result, new_len))
}

// Subtract: a - b
fn poly_sub(a: Poly, b: Poly) -> Poly {
    let new_len = max_val(a.len, b.len);
    let mut result = poly_zero();
    let mut i = 0;
    while i < new_len {
        let ai = if i < a.len { poly_get(a, i) } else { 0 };
        let bi = if i < b.len { poly_get(b, i) } else { 0 };
        result = poly_set(result, i, ai - bi);
        i = i + 1;
    }
    poly_normalize(poly_set_len(result, new_len))
}

// Multiply two polynomials
fn poly_mul(a: Poly, b: Poly) -> Poly {
    if a.len == 0 || b.len == 0 { poly_zero() }
    else {
        let new_len = a.len + b.len - 1;
        let mut result = poly_zero();
        let mut i = 0;
        while i < a.len {
            let mut j = 0;
            while j < b.len {
                let idx = i + j;
                if idx < 16 {
                    let old = poly_get(result, idx);
                    result = poly_set(result, idx, old + poly_get(a, i) * poly_get(b, j));
                }
                j = j + 1;
            }
            i = i + 1;
        }
        let final_len = if new_len > 16 { 16 } else { new_len };
        poly_normalize(poly_set_len(result, final_len))
    }
}

// Scalar multiply
fn poly_scale(p: Poly, s: Int) -> Poly {
    if s == 0 { poly_zero() }
    else {
        let mut result = poly_zero();
        let mut i = 0;
        while i < p.len {
            result = poly_set(result, i, poly_get(p, i) * s);
            i = i + 1;
        }
        poly_set_len(result, p.len)
    }
}

// Derivative: d/dx(a0 + a1*x + a2*x^2 + ...) = a1 + 2*a2*x + 3*a3*x^2 + ...
fn poly_derivative(p: Poly) -> Poly {
    if p.len <= 1 { poly_zero() }
    else {
        let mut result = poly_zero();
        let mut i = 1;
        while i < p.len {
            result = poly_set(result, i - 1, i * poly_get(p, i));
            i = i + 1;
        }
        poly_normalize(poly_set_len(result, p.len - 1))
    }
}

// Check if two polynomials are equal
fn poly_eq(a: Poly, b: Poly) -> Bool {
    let an = poly_normalize(a);
    let bn = poly_normalize(b);
    if an.len != bn.len { false }
    else {
        let mut eq = true;
        let mut i = 0;
        while i < an.len {
            if poly_get(an, i) != poly_get(bn, i) {
                eq = false;
            }
            i = i + 1;
        }
        eq
    }
}

// Sum of coefficients
fn poly_coeff_sum(p: Poly) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < p.len {
        s = s + poly_get(p, i);
        i = i + 1;
    }
    s
}

fn main() -> Int {
    // === Test 1: Zero polynomial ===
    let z = poly_zero();
    assert_eq(z.len, 0);
    assert_eq(poly_degree(z), -1);
    assert_eq(poly_eval(z, 5), 0);

    // === Test 2: Constant polynomial ===
    let c = poly_const(7);
    assert_eq(c.len, 1);
    assert_eq(poly_degree(c), 0);
    assert_eq(poly_eval(c, 0), 7);
    assert_eq(poly_eval(c, 100), 7);

    // === Test 3: Linear polynomial 3 + 2x ===
    let lin = poly_linear(3, 2);
    assert_eq(poly_degree(lin), 1);
    assert_eq(poly_eval(lin, 0), 3);
    assert_eq(poly_eval(lin, 1), 5);
    assert_eq(poly_eval(lin, 2), 7);
    assert_eq(poly_eval(lin, 5), 13);

    // === Test 4: Quadratic 1 + 0x + 1x^2 = 1 + x^2 ===
    let quad = poly_quadratic(1, 0, 1);
    assert_eq(poly_degree(quad), 2);
    assert_eq(poly_eval(quad, 0), 1);
    assert_eq(poly_eval(quad, 1), 2);
    assert_eq(poly_eval(quad, 2), 5);  // 1 + 4
    assert_eq(poly_eval(quad, 3), 10); // 1 + 9

    // === Test 5: Addition ===
    // (3 + 2x) + (1 + 0x + x^2) = 4 + 2x + x^2
    let sum = poly_add(lin, quad);
    assert_eq(poly_degree(sum), 2);
    assert_eq(poly_get(sum, 0), 4);
    assert_eq(poly_get(sum, 1), 2);
    assert_eq(poly_get(sum, 2), 1);
    assert_eq(poly_eval(sum, 0), 4);
    assert_eq(poly_eval(sum, 1), 7);   // 4 + 2 + 1
    assert_eq(poly_eval(sum, 2), 12);  // 4 + 4 + 4

    // === Test 6: Subtraction ===
    // (4 + 2x + x^2) - (3 + 2x) = 1 + x^2
    let diff = poly_sub(sum, lin);
    assert(poly_eq(diff, quad));

    // === Test 7: Self-subtraction = zero ===
    let self_sub = poly_sub(lin, lin);
    assert_eq(poly_degree(self_sub), -1);

    // === Test 8: Multiplication of linears ===
    // (1 + x) * (1 + x) = 1 + 2x + x^2
    let one_plus_x = poly_linear(1, 1);
    let squared = poly_mul(one_plus_x, one_plus_x);
    assert_eq(poly_degree(squared), 2);
    assert_eq(poly_get(squared, 0), 1);
    assert_eq(poly_get(squared, 1), 2);
    assert_eq(poly_get(squared, 2), 1);
    assert_eq(poly_eval(squared, 2), 9);  // (1+2)^2

    // === Test 9: (x-1)(x+1) = x^2 - 1 ===
    let x_minus_1 = poly_linear(-1, 1);
    let x_plus_1 = poly_linear(1, 1);
    let diff_of_sq = poly_mul(x_minus_1, x_plus_1);
    assert_eq(poly_get(diff_of_sq, 0), -1);
    assert_eq(poly_get(diff_of_sq, 1), 0);
    assert_eq(poly_get(diff_of_sq, 2), 1);
    assert_eq(poly_eval(diff_of_sq, 3), 8);  // 9-1

    // === Test 10: Multiply by zero ===
    let mul_zero = poly_mul(lin, poly_zero());
    assert_eq(mul_zero.len, 0);

    // === Test 11: Multiply by constant ===
    // (3 + 2x) * 5 = 15 + 10x
    let scaled = poly_scale(lin, 5);
    assert_eq(poly_get(scaled, 0), 15);
    assert_eq(poly_get(scaled, 1), 10);

    // === Test 12: Derivative of constant = 0 ===
    let dc = poly_derivative(c);
    assert_eq(poly_degree(dc), -1);

    // === Test 13: Derivative of 3 + 2x = 2 ===
    let dlin = poly_derivative(lin);
    assert_eq(poly_degree(dlin), 0);
    assert_eq(poly_get(dlin, 0), 2);

    // === Test 14: Derivative of 1 + x^2 = 2x ===
    let dquad = poly_derivative(quad);
    assert_eq(poly_degree(dquad), 1);
    assert_eq(poly_get(dquad, 0), 0);
    assert_eq(poly_get(dquad, 1), 2);

    // === Test 15: Derivative of 1 + 2x + 3x^2 + 4x^3 ===
    let mut cubic = poly_zero();
    cubic = poly_set(cubic, 0, 1);
    cubic = poly_set(cubic, 1, 2);
    cubic = poly_set(cubic, 2, 3);
    cubic = poly_set(cubic, 3, 4);
    cubic = poly_set_len(cubic, 4);
    let dcubic = poly_derivative(cubic);
    assert_eq(poly_get(dcubic, 0), 2);   // 1*2
    assert_eq(poly_get(dcubic, 1), 6);   // 2*3
    assert_eq(poly_get(dcubic, 2), 12);  // 3*4

    // === Test 16: Second derivative ===
    let d2cubic = poly_derivative(dcubic);
    assert_eq(poly_get(d2cubic, 0), 6);   // 1*6
    assert_eq(poly_get(d2cubic, 1), 24);  // 2*12

    // === Test 17: Polynomial evaluation at negative values ===
    assert_eq(poly_eval(lin, -1), 1);     // 3 + 2*(-1) = 1
    assert_eq(poly_eval(quad, -2), 5);    // 1 + 4 = 5
    assert_eq(poly_eval(cubic, -1), -2);  // 1 - 2 + 3 - 4

    // === Test 18: Multiply linear * quadratic ===
    // (1 + x)(1 + x^2) = 1 + x + x^2 + x^3
    let prod = poly_mul(one_plus_x, quad);
    assert_eq(poly_degree(prod), 3);
    assert_eq(poly_get(prod, 0), 1);
    assert_eq(poly_get(prod, 1), 1);
    assert_eq(poly_get(prod, 2), 1);
    assert_eq(poly_get(prod, 3), 1);
    // eval at 2: 1+2+4+8 = 15 = 3*5 = (1+2)(1+4)
    assert_eq(poly_eval(prod, 2), 15);

    // === Test 19: Commutativity of addition ===
    assert(poly_eq(poly_add(lin, quad), poly_add(quad, lin)));

    // === Test 20: Commutativity of multiplication ===
    assert(poly_eq(poly_mul(lin, quad), poly_mul(quad, lin)));

    // === Test 21: Distributivity: a*(b+c) = a*b + a*c ===
    let ab = poly_mul(one_plus_x, lin);
    let ac = poly_mul(one_plus_x, quad);
    let ab_plus_ac = poly_add(ab, ac);
    let a_bc = poly_mul(one_plus_x, poly_add(lin, quad));
    assert(poly_eq(ab_plus_ac, a_bc));

    // === Test 22: Additive identity ===
    assert(poly_eq(poly_add(lin, poly_zero()), lin));

    // === Test 23: Multiplicative identity ===
    let one = poly_const(1);
    assert(poly_eq(poly_mul(lin, one), lin));

    // === Test 24: p(0) = constant term ===
    assert_eq(poly_eval(cubic, 0), poly_get(cubic, 0));

    // === Test 25: p(1) = sum of coefficients ===
    assert_eq(poly_eval(cubic, 1), poly_coeff_sum(cubic));

    0
}
