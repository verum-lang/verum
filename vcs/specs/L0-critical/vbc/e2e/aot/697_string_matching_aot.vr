// @test: run
// @level: L0
// @tags: aot, e2e, string-matching, pattern, search
// @timeout: 30000

// String matching algorithms using integer-encoded "strings"
// Each "character" is an integer 0-9, stored in Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Brute force string search: find pattern in text
// Returns index of first match, or -1 if not found
fn brute_search(text: Arr8, tlen: Int, pat: Arr8, plen: Int) -> Int {
    let mut i = 0;
    let mut result = 0 - 1;
    while i <= tlen - plen {
        let mut j = 0;
        let mut match_ok = 1;
        while j < plen {
            if get8(text, i + j) != get8(pat, j) {
                match_ok = 0;
                j = plen; // break
            } else {
                j = j + 1;
            }
        }
        if match_ok == 1 {
            if result < 0 { result = i; }
            i = tlen; // break
        } else {
            i = i + 1;
        }
    }
    result
}

// Count occurrences of pattern in text
fn count_matches(text: Arr8, tlen: Int, pat: Arr8, plen: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i <= tlen - plen {
        let mut j = 0;
        let mut match_ok = 1;
        while j < plen {
            if get8(text, i + j) != get8(pat, j) {
                match_ok = 0;
                j = plen;
            } else {
                j = j + 1;
            }
        }
        if match_ok == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Simple hash for a window of characters (rolling hash base)
fn simple_hash(arr: Arr8, start: Int, len: Int) -> Int {
    let mut h = 0;
    let mut i = 0;
    while i < len {
        h = h * 31 + get8(arr, start + i) + 1;
        i = i + 1;
    }
    h
}

// Rabin-Karp search using rolling hash
fn rk_search(text: Arr8, tlen: Int, pat: Arr8, plen: Int) -> Int {
    let pat_hash = simple_hash(pat, 0, plen);
    let mut i = 0;
    let mut result = 0 - 1;
    while i <= tlen - plen {
        let win_hash = simple_hash(text, i, plen);
        if win_hash == pat_hash {
            // Verify match
            let mut j = 0;
            let mut ok = 1;
            while j < plen {
                if get8(text, i + j) != get8(pat, j) { ok = 0; j = plen; }
                else { j = j + 1; }
            }
            if ok == 1 {
                if result < 0 { result = i; }
                i = tlen; // break
            } else {
                i = i + 1;
            }
        } else {
            i = i + 1;
        }
    }
    result
}

// Check if text is a palindrome
fn is_palindrome(arr: Arr8, len: Int) -> Int {
    let mut left = 0;
    let mut right = len - 1;
    let mut result = 1;
    while left < right {
        if get8(arr, left) != get8(arr, right) {
            result = 0;
            left = right; // break
        } else {
            left = left + 1;
            right = right - 1;
        }
    }
    result
}

// Find longest common prefix length of two arrays
fn lcp_length(a: Arr8, alen: Int, b: Arr8, blen: Int) -> Int {
    let mut result = 0;
    let limit = if alen < blen { alen } else { blen };
    let mut i = 0;
    let mut done = 0;
    while i < limit {
        if done == 0 {
            if get8(a, i) != get8(b, i) {
                result = i;
                done = 1;
            }
        }
        i = i + 1;
    }
    if done == 1 { result } else { limit }
}

fn test_brute_search() -> Int {
    // text: [1,2,3,4,5,6,7,8], pat: [3,4,5]
    let text = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let pat = Arr8 { v0: 3, v1: 4, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(brute_search(text, 8, pat, 3), 2);
    // Pattern at start
    let pat2 = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(brute_search(text, 8, pat2, 2), 0);
    // Pattern at end
    let pat3 = Arr8 { v0: 7, v1: 8, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(brute_search(text, 8, pat3, 2), 6);
    // No match
    let pat4 = Arr8 { v0: 9, v1: 9, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(brute_search(text, 8, pat4, 2), 0 - 1);
    1
}

fn test_count_matches() -> Int {
    // [1,2,1,2,1,2,1,2] - pattern [1,2] appears 4 times
    let text = Arr8 { v0: 1, v1: 2, v2: 1, v3: 2, v4: 1, v5: 2, v6: 1, v7: 2 };
    let pat = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_matches(text, 8, pat, 2), 4);
    // Single char pattern
    let pat1 = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_matches(text, 8, pat1, 1), 4);
    1
}

fn test_rk_search() -> Int {
    let text = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let pat = Arr8 { v0: 3, v1: 4, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Should find same result as brute force
    assert_eq(rk_search(text, 8, pat, 3), 2);
    assert_eq(rk_search(text, 8, pat, 3), brute_search(text, 8, pat, 3));
    // No match
    let pat2 = Arr8 { v0: 9, v1: 9, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rk_search(text, 8, pat2, 2), 0 - 1);
    1
}

fn test_palindrome() -> Int {
    // [1,2,3,2,1] is a palindrome
    let pal = Arr8 { v0: 1, v1: 2, v2: 3, v3: 2, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_palindrome(pal, 5), 1);
    // [1,2,3,4] is not
    let notpal = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_palindrome(notpal, 4), 0);
    // Single element is palindrome
    assert_eq(is_palindrome(pal, 1), 1);
    // Even length palindrome [1,2,2,1]
    let pal2 = Arr8 { v0: 1, v1: 2, v2: 2, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_palindrome(pal2, 4), 1);
    1
}

fn test_lcp() -> Int {
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 1, v1: 2, v2: 5, v3: 6, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcp_length(a, 4, b, 4), 2);
    // Same arrays
    assert_eq(lcp_length(a, 4, a, 4), 4);
    // No common prefix
    let c = Arr8 { v0: 9, v1: 8, v2: 7, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcp_length(a, 4, c, 3), 0);
    1
}

fn main() -> Int {
    test_brute_search();
    test_count_matches();
    test_rk_search();
    test_palindrome();
    test_lcp();
    print("[OK] 697_string_matching_aot");
    0
}
