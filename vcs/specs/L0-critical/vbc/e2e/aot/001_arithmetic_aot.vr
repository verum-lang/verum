// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, arithmetic
// @timeout: 5000
// @expected-exit: 0
// @description: AOT arithmetic operations through full pipeline

fn main() -> Int {
    // Integer addition
    assert_eq(1 + 2, 3);
    assert_eq(0 + 0, 0);
    assert_eq(-5 + 3, -2);
    assert_eq(100 + 200, 300);

    // Integer subtraction
    assert_eq(5 - 3, 2);
    assert_eq(3 - 5, -2);
    assert_eq(0 - 0, 0);

    // Integer multiplication
    assert_eq(3 * 4, 12);
    assert_eq(-2 * 3, -6);
    assert_eq(-3 * -4, 12);
    assert_eq(0 * 999, 0);

    // Integer division
    assert_eq(10 / 2, 5);
    assert_eq(7 / 2, 3);
    assert_eq(-7 / 2, -3);

    // Modulo
    assert_eq(10 % 3, 1);
    assert_eq(7 % 2, 1);
    assert_eq(8 % 4, 0);

    // Precedence
    assert_eq(2 + 3 * 4, 14);
    assert_eq((2 + 3) * 4, 20);

    // Comparisons
    assert(1 < 2);
    assert(2 > 1);
    assert(3 <= 3);
    assert(3 >= 3);
    assert(5 == 5);
    assert(5 != 6);

    0
}
