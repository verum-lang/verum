// @test: run
// @level: L0
// @tags: aot, e2e, rational, arithmetic, fractions
// @timeout: 30000

// Rational number arithmetic using packed encoding
// Rational = numerator + denominator * 10000 (both positive, denominator > 0)
// Supports fractions with |num| < 5000 and 0 < den < 10000

fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    if x < 0 { x = 0 - x; }
    if y < 0 { y = 0 - y; }
    while y != 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

fn abs_val(a: Int) -> Int { if a < 0 { 0 - a } else { a } }

fn rat_new(num: Int, den: Int) -> Int {
    // Normalize: reduce and ensure den > 0
    let g = gcd(abs_val(num), abs_val(den));
    let mut n = num / g;
    let mut d = den / g;
    if d < 0 { n = 0 - n; d = 0 - d; }
    // Pack: (n + 5000) + d * 10000
    (n + 5000) + d * 10000
}

fn rat_num(r: Int) -> Int {
    r % 10000 - 5000
}

fn rat_den(r: Int) -> Int {
    r / 10000
}

fn rat_add(a: Int, b: Int) -> Int {
    let an = rat_num(a);
    let ad = rat_den(a);
    let bn = rat_num(b);
    let bd = rat_den(b);
    rat_new(an * bd + bn * ad, ad * bd)
}

fn rat_sub(a: Int, b: Int) -> Int {
    let an = rat_num(a);
    let ad = rat_den(a);
    let bn = rat_num(b);
    let bd = rat_den(b);
    rat_new(an * bd - bn * ad, ad * bd)
}

fn rat_mul(a: Int, b: Int) -> Int {
    rat_new(rat_num(a) * rat_num(b), rat_den(a) * rat_den(b))
}

fn rat_div(a: Int, b: Int) -> Int {
    rat_new(rat_num(a) * rat_den(b), rat_den(a) * rat_num(b))
}

fn rat_eq(a: Int, b: Int) -> Int {
    if rat_num(a) == rat_num(b) {
        if rat_den(a) == rat_den(b) { 1 } else { 0 }
    } else { 0 }
}

fn rat_neg(a: Int) -> Int {
    rat_new(0 - rat_num(a), rat_den(a))
}

fn test_basic() -> Int {
    let half = rat_new(1, 2);
    assert_eq(rat_num(half), 1);
    assert_eq(rat_den(half), 2);

    // Normalization: 2/4 = 1/2
    let two_fourths = rat_new(2, 4);
    assert_eq(rat_num(two_fourths), 1);
    assert_eq(rat_den(two_fourths), 2);
    assert_eq(rat_eq(half, two_fourths), 1);

    // 6/3 = 2/1
    let six_thirds = rat_new(6, 3);
    assert_eq(rat_num(six_thirds), 2);
    assert_eq(rat_den(six_thirds), 1);

    // Negative: -3/4
    let neg = rat_new(-3, 4);
    assert_eq(rat_num(neg), -3);
    assert_eq(rat_den(neg), 4);

    // Negative denominator: 3/(-4) = -3/4
    let neg2 = rat_new(3, -4);
    assert_eq(rat_num(neg2), -3);
    assert_eq(rat_den(neg2), 4);
    1
}

fn test_arithmetic() -> Int {
    let half = rat_new(1, 2);
    let third = rat_new(1, 3);

    // 1/2 + 1/3 = 5/6
    let sum = rat_add(half, third);
    assert_eq(rat_num(sum), 5);
    assert_eq(rat_den(sum), 6);

    // 1/2 - 1/3 = 1/6
    let diff = rat_sub(half, third);
    assert_eq(rat_num(diff), 1);
    assert_eq(rat_den(diff), 6);

    // 1/2 * 1/3 = 1/6
    let prod = rat_mul(half, third);
    assert_eq(rat_num(prod), 1);
    assert_eq(rat_den(prod), 6);

    // 1/2 / 1/3 = 3/2
    let quot = rat_div(half, third);
    assert_eq(rat_num(quot), 3);
    assert_eq(rat_den(quot), 2);
    1
}

fn test_properties() -> Int {
    let a = rat_new(2, 3);
    let b = rat_new(3, 5);

    // Commutativity of addition
    let ab = rat_add(a, b);
    let ba = rat_add(b, a);
    assert_eq(rat_eq(ab, ba), 1);

    // Commutativity of multiplication
    let ab_m = rat_mul(a, b);
    let ba_m = rat_mul(b, a);
    assert_eq(rat_eq(ab_m, ba_m), 1);

    // a - a = 0
    let zero = rat_sub(a, a);
    assert_eq(rat_num(zero), 0);

    // a * (1/a) = 1  (multiplicative inverse)
    let inv = rat_div(rat_new(1, 1), a); // 1 / (2/3) = 3/2
    let prod = rat_mul(a, inv); // (2/3) * (3/2) = 1
    assert_eq(rat_num(prod), 1);
    assert_eq(rat_den(prod), 1);

    // Negation
    let neg = rat_neg(a);
    assert_eq(rat_num(neg), -2);
    assert_eq(rat_den(neg), 3);
    let sum = rat_add(a, neg);
    assert_eq(rat_num(sum), 0);
    1
}

fn test_fractions() -> Int {
    // Egyptian fraction: 1 = 1/2 + 1/3 + 1/6
    let half = rat_new(1, 2);
    let third = rat_new(1, 3);
    let sixth = rat_new(1, 6);
    let sum = rat_add(rat_add(half, third), sixth);
    assert_eq(rat_num(sum), 1);
    assert_eq(rat_den(sum), 1);

    // 7/12 + 5/12 = 1
    let a = rat_new(7, 12);
    let b = rat_new(5, 12);
    let s = rat_add(a, b);
    assert_eq(rat_num(s), 1);
    assert_eq(rat_den(s), 1);
    1
}

fn main() -> Int {
    test_basic();
    test_arithmetic();
    test_properties();
    test_fractions();
    print("[OK] 466_rational_arith_aot");
    0
}
