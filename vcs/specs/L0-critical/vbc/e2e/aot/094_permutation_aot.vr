// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, permutation, composition, inverse, cycles
// @timeout: 50000
// @expected-exit: 0
// @description: AOT permutation operations on 8-element arrays: composition, inverse, cycle detection

type Arr8 is {
    a0: Int, a1: Int, a2: Int, a3: Int,
    a4: Int, a5: Int, a6: Int, a7: Int,
    len: Int
};

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 }
    else if i == 1 { a.a1 }
    else if i == 2 { a.a2 }
    else if i == 3 { a.a3 }
    else if i == 4 { a.a4 }
    else if i == 5 { a.a5 }
    else if i == 6 { a.a6 }
    else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 },
        a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 },
        a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 },
        a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 },
        a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

fn a8_new(n: Int) -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: n }
}

// Identity permutation of size n: [0, 1, 2, ..., n-1]
fn perm_identity(n: Int) -> Arr8 {
    let mut p = a8_new(n);
    let mut i = 0;
    while i < n {
        p = a8_set(p, i, i);
        i = i + 1;
    }
    p
}

// Compose two permutations: result[i] = b[a[i]]
fn perm_compose(a: Arr8, b: Arr8) -> Arr8 {
    let n = a.len;
    let mut result = a8_new(n);
    let mut i = 0;
    while i < n {
        result = a8_set(result, i, a8_get(b, a8_get(a, i)));
        i = i + 1;
    }
    result
}

// Inverse permutation: if p[i] = j, then inv[j] = i
fn perm_inverse(p: Arr8) -> Arr8 {
    let n = p.len;
    let mut inv = a8_new(n);
    let mut i = 0;
    while i < n {
        inv = a8_set(inv, a8_get(p, i), i);
        i = i + 1;
    }
    inv
}

// Check if array is a valid permutation of [0..n-1]
fn perm_is_valid(p: Arr8) -> Bool {
    let n = p.len;
    let mut valid = true;
    let mut v = 0;
    while v < n {
        let mut count = 0;
        let mut i = 0;
        while i < n {
            if a8_get(p, i) == v { count = count + 1; }
            i = i + 1;
        }
        if count != 1 { valid = false; }
        v = v + 1;
    }
    valid
}

// Check equality of two permutations
fn perm_eq(a: Arr8, b: Arr8) -> Bool {
    if a.len != b.len { false }
    else {
        let mut ok = true;
        let mut i = 0;
        while i < a.len {
            if a8_get(a, i) != a8_get(b, i) { ok = false; }
            i = i + 1;
        }
        ok
    }
}

// Check if permutation is the identity
fn perm_is_identity(p: Arr8) -> Bool {
    let mut ok = true;
    let mut i = 0;
    while i < p.len {
        if a8_get(p, i) != i { ok = false; }
        i = i + 1;
    }
    ok
}

// Count cycles in a permutation
fn perm_cycle_count(p: Arr8) -> Int {
    let n = p.len;
    let mut visited = a8_new(n);
    let mut cycles = 0;
    let mut i = 0;
    while i < n {
        if a8_get(visited, i) == 0 {
            cycles = cycles + 1;
            let mut j = i;
            let mut loop_guard = 0;
            while a8_get(visited, j) == 0 && loop_guard < n {
                visited = a8_set(visited, j, 1);
                j = a8_get(p, j);
                loop_guard = loop_guard + 1;
            }
        }
        i = i + 1;
    }
    cycles
}

// Compute the length of the cycle containing element k
fn perm_cycle_len(p: Arr8, k: Int) -> Int {
    let mut j = a8_get(p, k);
    let mut length = 1;
    while j != k {
        j = a8_get(p, j);
        length = length + 1;
    }
    length
}

// Apply permutation k times: p^k
fn perm_power(p: Arr8, k: Int) -> Arr8 {
    let n = p.len;
    let mut result = perm_identity(n);
    let mut i = 0;
    while i < k {
        result = perm_compose(result, p);
        i = i + 1;
    }
    result
}

// Count fixed points: elements where p[i] = i
fn perm_fixed_points(p: Arr8) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < p.len {
        if a8_get(p, i) == i { count = count + 1; }
        i = i + 1;
    }
    count
}

// Count inversions: pairs (i,j) where i < j but p[i] > p[j]
fn perm_inversions(p: Arr8) -> Int {
    let n = p.len;
    let mut inv = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            if a8_get(p, i) > a8_get(p, j) { inv = inv + 1; }
            j = j + 1;
        }
        i = i + 1;
    }
    inv
}

fn main() -> Int {
    // === Test 1: Identity permutation ===
    let id5 = perm_identity(5);
    assert(perm_is_valid(id5));
    assert(perm_is_identity(id5));
    assert_eq(perm_cycle_count(id5), 5);
    assert_eq(perm_fixed_points(id5), 5);
    assert_eq(perm_inversions(id5), 0);

    // === Test 2: Simple rotation [1,2,3,4,0] ===
    let mut rot5 = a8_new(5);
    rot5 = a8_set(rot5, 0, 1);
    rot5 = a8_set(rot5, 1, 2);
    rot5 = a8_set(rot5, 2, 3);
    rot5 = a8_set(rot5, 3, 4);
    rot5 = a8_set(rot5, 4, 0);
    assert(perm_is_valid(rot5));
    assert_eq(perm_cycle_count(rot5), 1);
    assert_eq(perm_fixed_points(rot5), 0);
    // Inversions in [1,2,3,4,0]: pairs where left > right
    // (1,0),(2,0),(3,0),(4,0) = 4
    assert_eq(perm_inversions(rot5), 4);

    // === Test 3: Composition with identity ===
    let comp_id = perm_compose(rot5, id5);
    assert(perm_eq(comp_id, rot5));
    let comp_id2 = perm_compose(id5, rot5);
    assert(perm_eq(comp_id2, rot5));

    // === Test 4: Inverse ===
    let rot5_inv = perm_inverse(rot5);
    assert(perm_is_valid(rot5_inv));
    // Inverse of [1,2,3,4,0]: inv[1]=0, inv[2]=1, inv[3]=2, inv[4]=3, inv[0]=4
    // = [4,0,1,2,3]
    assert_eq(a8_get(rot5_inv, 0), 4);
    assert_eq(a8_get(rot5_inv, 1), 0);
    assert_eq(a8_get(rot5_inv, 2), 1);
    assert_eq(a8_get(rot5_inv, 3), 2);
    assert_eq(a8_get(rot5_inv, 4), 3);

    // p * p^-1 = identity
    let comp_inv = perm_compose(rot5, rot5_inv);
    assert(perm_is_identity(comp_inv));
    // p^-1 * p = identity
    let comp_inv2 = perm_compose(rot5_inv, rot5);
    assert(perm_is_identity(comp_inv2));

    // === Test 5: Transposition (swap) [1,0,2,3,4] ===
    let mut swap01 = perm_identity(5);
    swap01 = a8_set(swap01, 0, 1);
    swap01 = a8_set(swap01, 1, 0);
    assert(perm_is_valid(swap01));
    assert_eq(perm_cycle_count(swap01), 4);  // one 2-cycle + three 1-cycles
    assert_eq(perm_fixed_points(swap01), 3);
    assert_eq(perm_inversions(swap01), 1);

    // Swap is its own inverse
    let swap_inv = perm_inverse(swap01);
    assert(perm_eq(swap_inv, swap01));

    // Swap squared = identity
    let swap_sq = perm_compose(swap01, swap01);
    assert(perm_is_identity(swap_sq));

    // === Test 6: Composition of compositions ===
    // rot5^5 should be identity (5-cycle applied 5 times)
    let rot5_5 = perm_power(rot5, 5);
    assert(perm_is_identity(rot5_5));

    // rot5^2 = [2,3,4,0,1]
    let rot5_2 = perm_power(rot5, 2);
    assert_eq(a8_get(rot5_2, 0), 2);
    assert_eq(a8_get(rot5_2, 1), 3);
    assert_eq(a8_get(rot5_2, 2), 4);
    assert_eq(a8_get(rot5_2, 3), 0);
    assert_eq(a8_get(rot5_2, 4), 1);

    // rot5^3 = [3,4,0,1,2]
    let rot5_3 = perm_power(rot5, 3);
    assert_eq(a8_get(rot5_3, 0), 3);
    assert_eq(a8_get(rot5_3, 1), 4);
    assert_eq(a8_get(rot5_3, 2), 0);
    assert_eq(a8_get(rot5_3, 3), 1);
    assert_eq(a8_get(rot5_3, 4), 2);

    // === Test 7: 8-element permutation with four 2-cycles ===
    // p = [1,0,3,2,5,4,7,6] = (0 1)(2 3)(4 5)(6 7)
    let mut multi = a8_new(8);
    multi = a8_set(multi, 0, 1);
    multi = a8_set(multi, 1, 0);
    multi = a8_set(multi, 2, 3);
    multi = a8_set(multi, 3, 2);
    multi = a8_set(multi, 4, 5);
    multi = a8_set(multi, 5, 4);
    multi = a8_set(multi, 6, 7);
    multi = a8_set(multi, 7, 6);
    assert(perm_is_valid(multi));
    assert_eq(perm_cycle_count(multi), 4);
    assert_eq(perm_fixed_points(multi), 0);
    // Each 2-cycle contributes 1 inversion: 4 total
    assert_eq(perm_inversions(multi), 4);
    // Squared = identity (all 2-cycles)
    let multi_sq = perm_compose(multi, multi);
    assert(perm_is_identity(multi_sq));

    // === Test 8: Cycle lengths ===
    // rot5 = single 5-cycle
    assert_eq(perm_cycle_len(rot5, 0), 5);
    assert_eq(perm_cycle_len(rot5, 3), 5);

    // multi: each element has cycle length 2
    assert_eq(perm_cycle_len(multi, 0), 2);
    assert_eq(perm_cycle_len(multi, 5), 2);

    // identity: each element has cycle length 1
    assert_eq(perm_cycle_len(id5, 0), 1);
    assert_eq(perm_cycle_len(id5, 4), 1);

    // === Test 9: Mixed cycles [1,2,0,4,3,5,6,7] ===
    // Cycles: (0 1 2)(3 4)(5)(6)(7) = 5 cycles total
    let mut mixed = a8_new(8);
    mixed = a8_set(mixed, 0, 1);
    mixed = a8_set(mixed, 1, 2);
    mixed = a8_set(mixed, 2, 0);
    mixed = a8_set(mixed, 3, 4);
    mixed = a8_set(mixed, 4, 3);
    mixed = a8_set(mixed, 5, 5);
    mixed = a8_set(mixed, 6, 6);
    mixed = a8_set(mixed, 7, 7);
    assert(perm_is_valid(mixed));
    assert_eq(perm_cycle_count(mixed), 5);
    assert_eq(perm_fixed_points(mixed), 3);

    // Cycle lengths
    assert_eq(perm_cycle_len(mixed, 0), 3);
    assert_eq(perm_cycle_len(mixed, 1), 3);
    assert_eq(perm_cycle_len(mixed, 2), 3);
    assert_eq(perm_cycle_len(mixed, 3), 2);
    assert_eq(perm_cycle_len(mixed, 4), 2);
    assert_eq(perm_cycle_len(mixed, 5), 1);

    // Order of mixed = lcm(3,2,1) = 6
    let mixed_6 = perm_power(mixed, 6);
    assert(perm_is_identity(mixed_6));
    // mixed^3: the 3-cycle returns, but 2-cycle (3 4) applied 3 times = (3 4)
    let mixed_3 = perm_power(mixed, 3);
    assert(!perm_is_identity(mixed_3));
    assert_eq(a8_get(mixed_3, 0), 0);
    assert_eq(a8_get(mixed_3, 1), 1);
    assert_eq(a8_get(mixed_3, 2), 2);
    assert_eq(a8_get(mixed_3, 3), 4);
    assert_eq(a8_get(mixed_3, 4), 3);

    // === Test 10: Inverse of inverse is original ===
    let mixed_inv = perm_inverse(mixed);
    let mixed_inv_inv = perm_inverse(mixed_inv);
    assert(perm_eq(mixed_inv_inv, mixed));

    // === Test 11: Reversed permutation [5,4,3,2,1,0] ===
    // C(6,2) = 15 inversions
    let mut rev6 = a8_new(6);
    rev6 = a8_set(rev6, 0, 5);
    rev6 = a8_set(rev6, 1, 4);
    rev6 = a8_set(rev6, 2, 3);
    rev6 = a8_set(rev6, 3, 2);
    rev6 = a8_set(rev6, 4, 1);
    rev6 = a8_set(rev6, 5, 0);
    assert_eq(perm_inversions(rev6), 15);
    // Cycles: (0 5)(1 4)(2 3) = 3 cycles
    assert_eq(perm_cycle_count(rev6), 3);

    // === Test 12: Composition is not commutative ===
    // swap01=[1,0,2,3,4], rot5=[1,2,3,4,0]
    // swap01 * rot5: result[i] = rot5[swap01[i]]
    // [rot5[1],rot5[0],rot5[2],rot5[3],rot5[4]] = [2,1,3,4,0]
    let comp_sr = perm_compose(swap01, rot5);
    assert_eq(a8_get(comp_sr, 0), 2);
    assert_eq(a8_get(comp_sr, 1), 1);
    assert_eq(a8_get(comp_sr, 2), 3);
    assert_eq(a8_get(comp_sr, 3), 4);
    assert_eq(a8_get(comp_sr, 4), 0);
    assert(perm_is_valid(comp_sr));

    // rot5 * swap01: result[i] = swap01[rot5[i]]
    // [swap01[1],swap01[2],swap01[3],swap01[4],swap01[0]] = [0,2,3,4,1]
    let comp_rs = perm_compose(rot5, swap01);
    assert_eq(a8_get(comp_rs, 0), 0);
    assert_eq(a8_get(comp_rs, 1), 2);
    assert_eq(a8_get(comp_rs, 2), 3);
    assert_eq(a8_get(comp_rs, 3), 4);
    assert_eq(a8_get(comp_rs, 4), 1);
    assert(perm_is_valid(comp_rs));

    // Not commutative
    assert(!perm_eq(comp_sr, comp_rs));

    0
}
