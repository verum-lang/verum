// @test: run
// @tier: 0
// @level: L0
// @tags: aot, timer, sleep, monotonic
// @expected-exit: 0

// Test: monotonic timer and sleep.
// Gets time, sleeps 10ms, verifies elapsed >= 5ms.

fn __time_monotonic_nanos_raw() -> Int {
    @intrinsic("time_monotonic_nanos")
}

fn __time_sleep_nanos_raw(nanos: Int) -> Int {
    @intrinsic("time_sleep_nanos")
}

fn main() -> Int {
    // Test 1: monotonic time is positive
    let t0 = __time_monotonic_nanos_raw();
    if (t0 <= 0) {
        print(f"FAIL: monotonic time={t0}, expected > 0");
        return 1;
    }

    // Test 2: time is monotonically increasing
    let t1 = __time_monotonic_nanos_raw();
    if (t1 < t0) {
        print(f"FAIL: time went backwards: t0={t0}, t1={t1}");
        return 1;
    }

    // Test 3: sleep 10ms, verify elapsed >= 5ms
    let before = __time_monotonic_nanos_raw();
    __time_sleep_nanos_raw(10000000); // 10ms = 10,000,000 ns
    let after = __time_monotonic_nanos_raw();
    let elapsed = after - before;

    // Should have elapsed at least 5ms (5,000,000 ns)
    if (elapsed < 5000000) {
        print(f"FAIL: sleep elapsed={elapsed}ns, expected >= 5000000ns");
        return 1;
    }

    // Test 4: sleep 1ms
    let before2 = __time_monotonic_nanos_raw();
    __time_sleep_nanos_raw(1000000); // 1ms
    let after2 = __time_monotonic_nanos_raw();
    let elapsed2 = after2 - before2;
    if (elapsed2 < 500000) { // at least 0.5ms
        print(f"FAIL: short sleep elapsed={elapsed2}ns, expected >= 500000ns");
        return 1;
    }

    print("882_time_sleep: PASS");
    0
}
