// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, minimax, game, tree
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for minimax algorithm on game tree (tic-tac-toe evaluation)

fn max2(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min2(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// 3x3 tic-tac-toe board packed in 9 fields
// Values: 0=empty, 1=X, 2=O
type Board is { c0: Int, c1: Int, c2: Int, c3: Int, c4: Int, c5: Int, c6: Int, c7: Int, c8: Int };

fn empty_board() -> Board {
    Board { c0: 0, c1: 0, c2: 0, c3: 0, c4: 0, c5: 0, c6: 0, c7: 0, c8: 0 }
}

fn board_get(b: Board, i: Int) -> Int {
    if i == 0 { b.c0 } else if i == 1 { b.c1 }
    else if i == 2 { b.c2 } else if i == 3 { b.c3 }
    else if i == 4 { b.c4 } else if i == 5 { b.c5 }
    else if i == 6 { b.c6 } else if i == 7 { b.c7 }
    else { b.c8 }
}

fn board_set(b: Board, i: Int, v: Int) -> Board {
    Board {
        c0: if i == 0 { v } else { b.c0 }, c1: if i == 1 { v } else { b.c1 },
        c2: if i == 2 { v } else { b.c2 }, c3: if i == 3 { v } else { b.c3 },
        c4: if i == 4 { v } else { b.c4 }, c5: if i == 5 { v } else { b.c5 },
        c6: if i == 6 { v } else { b.c6 }, c7: if i == 7 { v } else { b.c7 },
        c8: if i == 8 { v } else { b.c8 }
    }
}

// Check if player has won
fn has_won(b: Board, player: Int) -> Bool {
    let p = player;
    // Rows
    if board_get(b, 0) == p && board_get(b, 1) == p && board_get(b, 2) == p { return true; }
    if board_get(b, 3) == p && board_get(b, 4) == p && board_get(b, 5) == p { return true; }
    if board_get(b, 6) == p && board_get(b, 7) == p && board_get(b, 8) == p { return true; }
    // Columns
    if board_get(b, 0) == p && board_get(b, 3) == p && board_get(b, 6) == p { return true; }
    if board_get(b, 1) == p && board_get(b, 4) == p && board_get(b, 7) == p { return true; }
    if board_get(b, 2) == p && board_get(b, 5) == p && board_get(b, 8) == p { return true; }
    // Diagonals
    if board_get(b, 0) == p && board_get(b, 4) == p && board_get(b, 8) == p { return true; }
    if board_get(b, 2) == p && board_get(b, 4) == p && board_get(b, 6) == p { return true; }
    false
}

fn count_empty(b: Board) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 9 {
        if board_get(b, i) == 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Static evaluation (simple: +10 for X win, -10 for O win, 0 for draw)
fn evaluate(b: Board) -> Int {
    if has_won(b, 1) { return 10; }
    if has_won(b, 2) { return -10; }
    0
}

// Minimax (depth-limited to avoid stack overflow)
fn minimax(b: Board, is_max: Int, depth: Int) -> Int {
    let score = evaluate(b);
    if score == 10 { return score + depth; }
    if score == -10 { return score - depth; }
    if count_empty(b) == 0 || depth == 0 { return 0; }

    if is_max == 1 {
        let mut best = -100;
        let mut i = 0;
        while i < 9 {
            if board_get(b, i) == 0 {
                let b2 = board_set(b, i, 1);
                let val = minimax(b2, 0, depth - 1);
                best = max2(best, val);
            }
            i = i + 1;
        }
        best
    } else {
        let mut best = 100;
        let mut i = 0;
        while i < 9 {
            if board_get(b, i) == 0 {
                let b2 = board_set(b, i, 2);
                let val = minimax(b2, 1, depth - 1);
                best = min2(best, val);
            }
            i = i + 1;
        }
        best
    }
}

@allow(unbounded_recursion)
fn test_x_wins() {
    // X has won
    let b = Board { c0: 1, c1: 1, c2: 1, c3: 0, c4: 2, c5: 2, c6: 0, c7: 0, c8: 0 };
    assert_eq(has_won(b, 1), true);
    assert_eq(has_won(b, 2), false);
    assert_eq(evaluate(b), 10);
}

@allow(unbounded_recursion)
fn test_o_wins() {
    // O wins on diagonal
    let b = Board { c0: 2, c1: 1, c2: 1, c3: 0, c4: 2, c5: 0, c6: 1, c7: 0, c8: 2 };
    assert_eq(has_won(b, 2), true);
    assert_eq(evaluate(b), -10);
}

@allow(unbounded_recursion)
fn test_draw() {
    // Full board, no winner
    let b = Board { c0: 1, c1: 2, c2: 1, c3: 1, c4: 1, c5: 2, c6: 2, c7: 1, c8: 2 };
    assert_eq(has_won(b, 1), false);
    assert_eq(has_won(b, 2), false);
    assert_eq(evaluate(b), 0);
}

@allow(unbounded_recursion)
fn test_minimax_winning() {
    // X can win in one move (position 2)
    let b = Board { c0: 1, c1: 1, c2: 0, c3: 2, c4: 2, c5: 0, c6: 0, c7: 0, c8: 0 };
    let score = minimax(b, 1, 3);
    assert_eq(score > 0, true);  // X should find winning move
}

@allow(unbounded_recursion)
fn test_empty_board_depth2() {
    // Empty board, depth limited to 2
    let b = empty_board();
    let score = minimax(b, 1, 2);
    // Should be 0 (can't win in 2 half-moves)
    assert_eq(score, 0);
}

fn main() -> Int {
    test_x_wins();
    test_o_wins();
    test_draw();
    test_minimax_winning();
    test_empty_board_depth2();
    print("[OK] 275_minimax_aot");
    0
}
