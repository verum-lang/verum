// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, algorithms, sorting, bubble-sort
// @timeout: 50000
// @expected-exit: 0
// @description: AOT sorting algorithms using mutable arrays simulated with records

// Simulated fixed-size array of 8 elements using a record
type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 },
    }
}

fn bubble_sort(a: Arr8, n: Int) -> Arr8 {
    let mut arr = a;
    let mut i = 0;
    while i < n - 1 {
        let mut j = 0;
        while j < n - 1 - i {
            let left = arr8_get(arr, j);
            let right = arr8_get(arr, j + 1);
            if left > right {
                arr = arr8_set(arr, j, right);
                arr = arr8_set(arr, j + 1, left);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

fn is_sorted(a: Arr8, n: Int) -> Bool {
    let mut i = 0;
    let mut sorted = true;
    while i < n - 1 {
        if arr8_get(a, i) > arr8_get(a, i + 1) {
            sorted = false;
        }
        i = i + 1;
    }
    sorted
}

fn arr_sum(a: Arr8, n: Int) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < n {
        s = s + arr8_get(a, i);
        i = i + 1;
    }
    s
}

fn main() -> Int {
    // Create unsorted array
    let unsorted = Arr8 { e0: 5, e1: 3, e2: 8, e3: 1, e4: 7, e5: 2, e6: 6, e7: 4 };

    // Verify access
    assert_eq(arr8_get(unsorted, 0), 5);
    assert_eq(arr8_get(unsorted, 3), 1);
    assert_eq(arr8_get(unsorted, 7), 4);

    // Sum before sort
    let sum_before = arr_sum(unsorted, 8);
    assert_eq(sum_before, 36);  // 1+2+3+4+5+6+7+8

    // Sort
    let sorted = bubble_sort(unsorted, 8);
    assert(is_sorted(sorted, 8));

    // Elements should be 1,2,3,4,5,6,7,8
    assert_eq(arr8_get(sorted, 0), 1);
    assert_eq(arr8_get(sorted, 1), 2);
    assert_eq(arr8_get(sorted, 2), 3);
    assert_eq(arr8_get(sorted, 3), 4);
    assert_eq(arr8_get(sorted, 7), 8);

    // Sum preserved after sort
    let sum_after = arr_sum(sorted, 8);
    assert_eq(sum_after, 36);

    // Already sorted
    let resorted = bubble_sort(sorted, 8);
    assert(is_sorted(resorted, 8));
    assert_eq(arr8_get(resorted, 0), 1);

    // Reverse sorted input
    let reverse = Arr8 { e0: 8, e1: 7, e2: 6, e3: 5, e4: 4, e5: 3, e6: 2, e7: 1 };
    let sorted_rev = bubble_sort(reverse, 8);
    assert(is_sorted(sorted_rev, 8));
    assert_eq(arr8_get(sorted_rev, 0), 1);
    assert_eq(arr8_get(sorted_rev, 7), 8);

    0
}
