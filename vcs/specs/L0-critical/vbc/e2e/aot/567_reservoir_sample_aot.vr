// @test: run
// @level: L0
// @tags: aot, e2e, reservoir-sampling, statistics, random
// @timeout: 30000

// Statistical algorithms (deterministic variants for testing)

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// 1. Mean (scaled by n to stay in integers: returns sum)
fn mean_sum(arr: Arr8, n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n { sum = sum + get8(arr, i); i = i + 1; }
    sum
}

// 2. Variance * n^2 (to stay in integers)
fn variance_scaled(arr: Arr8, n: Int) -> Int {
    let sum = mean_sum(arr, n);
    // var*n^2 = n * sum(x^2) - sum^2
    let mut sum_sq = 0;
    let mut i = 0;
    while i < n {
        let v = get8(arr, i);
        sum_sq = sum_sq + v * v;
        i = i + 1;
    }
    n * sum_sq - sum * sum
}

// 3. Median (of sorted array)
fn median_of_sorted(arr: Arr8, n: Int) -> Int {
    if n % 2 == 1 {
        get8(arr, n / 2)
    } else {
        (get8(arr, n / 2 - 1) + get8(arr, n / 2)) / 2
    }
}

// 4. Mode (most frequent element)
fn mode(arr: Arr8, n: Int) -> Int {
    let mut best_val = get8(arr, 0);
    let mut best_count = 0;
    let mut i = 0;
    while i < n {
        let v = get8(arr, i);
        let mut count = 0;
        let mut j = 0;
        while j < n {
            if get8(arr, j) == v { count = count + 1; }
            j = j + 1;
        }
        if count > best_count {
            best_count = count;
            best_val = v;
        }
        i = i + 1;
    }
    best_val
}

// 5. Range (max - min)
fn arr_range(arr: Arr8, n: Int) -> Int {
    let mut min_v = get8(arr, 0);
    let mut max_v = get8(arr, 0);
    let mut i = 1;
    while i < n {
        let v = get8(arr, i);
        if v < min_v { min_v = v; }
        if v > max_v { max_v = v; }
        i = i + 1;
    }
    max_v - min_v
}

// 6. Percentile (k-th smallest, 0-indexed)
fn kth_smallest(arr: Arr8, n: Int, k: Int) -> Int {
    // Simple: sort then index
    let mut a = arr;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if get8(a, j) < get8(a, min_idx) { min_idx = j; }
            j = j + 1;
        }
        if min_idx != i {
            let tmp = get8(a, i);
            a = set8(a, i, get8(a, min_idx));
            a = set8(a, min_idx, tmp);
        }
        i = i + 1;
    }
    get8(a, k)
}

// 7. Mean Absolute Deviation (MAD) * n (to stay in integers)
fn mad_scaled(arr: Arr8, n: Int) -> Int {
    let sum = mean_sum(arr, n);
    let mean_n = sum; // mean * n = sum
    let mut mad = 0;
    let mut i = 0;
    while i < n {
        // |x_i - mean| * n = |x_i * n - sum|
        mad = mad + abs_val(get8(arr, i) * n - sum);
        i = i + 1;
    }
    mad // this is MAD * n * n
}

fn test_mean() -> Int {
    let arr = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(mean_sum(arr, 4), 20); // mean = 20/4 = 5
    1
}

fn test_variance() -> Int {
    // [2, 4, 6, 8]: mean=5, var = (9+1+1+9)/4 = 5
    // var*n^2 = 4*(4+16+36+64) - 20^2 = 4*120 - 400 = 480 - 400 = 80
    let arr = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(variance_scaled(arr, 4), 80);

    // Constant array: variance = 0
    let arr2 = Arr8 { v0: 5, v1: 5, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(variance_scaled(arr2, 3), 0);
    1
}

fn test_median() -> Int {
    // Odd: [1, 3, 5] → median = 3
    let arr = Arr8 { v0: 1, v1: 3, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(median_of_sorted(arr, 3), 3);

    // Even: [1, 3, 5, 7] → median = (3+5)/2 = 4
    let arr2 = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(median_of_sorted(arr2, 4), 4);
    1
}

fn test_mode() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 2, v3: 3, v4: 2, v5: 0, v6: 0, v7: 0 };
    assert_eq(mode(arr, 5), 2);
    1
}

fn test_range() -> Int {
    let arr = Arr8 { v0: 3, v1: 7, v2: 1, v3: 9, v4: 4, v5: 0, v6: 0, v7: 0 };
    assert_eq(arr_range(arr, 5), 8); // 9-1
    1
}

fn test_kth_smallest() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 7, v5: 0, v6: 0, v7: 0 };
    assert_eq(kth_smallest(arr, 5, 0), 1); // smallest
    assert_eq(kth_smallest(arr, 5, 2), 5); // median
    assert_eq(kth_smallest(arr, 5, 4), 8); // largest
    1
}

fn test_mad() -> Int {
    // [2, 4, 6, 8]: mean=5, MAD = (3+1+1+3)/4 = 2
    // MAD * n^2 = sum of |xi*n - sum| = |8-20|+|16-20|+|24-20|+|32-20| = 12+4+4+12 = 32
    let arr = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(mad_scaled(arr, 4), 32);
    1
}

fn main() -> Int {
    test_mean();
    test_variance();
    test_median();
    test_mode();
    test_range();
    test_kth_smallest();
    test_mad();
    print("[OK] 567_reservoir_sample_aot");
    0
}
