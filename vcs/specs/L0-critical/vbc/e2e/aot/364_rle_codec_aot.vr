// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, rle, run-length-encoding, compression
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for run-length encoding/decoding.
// Encodes a sequence of integers as (value, count) pairs.
// Tests: encode, decode, roundtrip, compression ratio, edge cases.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// Sequence: up to 8 elements with length
type Seq is { data: Arr8, len: Int };

fn seq_new() -> Seq {
    Seq { data: a8_zero(), len: 0 }
}

fn seq_push(s: Seq, val: Int) -> Seq {
    let d = a8_set(s.data, s.len, val);
    Seq { data: d, len: s.len + 1 }
}

fn seq_get(s: Seq, i: Int) -> Int {
    a8_get(s.data, i)
}

// Encoded RLE: pairs of (value, count) stored flat: [v0, c0, v1, c1, ...]
// Max 4 runs in 8 elements
type RLE is { data: Arr8, num_runs: Int };

fn rle_new() -> RLE {
    RLE { data: a8_zero(), num_runs: 0 }
}

fn rle_get_val(r: RLE, run_idx: Int) -> Int {
    a8_get(r.data, run_idx * 2)
}

fn rle_get_count(r: RLE, run_idx: Int) -> Int {
    a8_get(r.data, run_idx * 2 + 1)
}

fn rle_push_run(r: RLE, val: Int, count: Int) -> RLE {
    let idx = r.num_runs * 2;
    let d1 = a8_set(r.data, idx, val);
    let d2 = a8_set(d1, idx + 1, count);
    RLE { data: d2, num_runs: r.num_runs + 1 }
}

// Encode a sequence into RLE
fn rle_encode(s: Seq) -> RLE {
    if s.len == 0 { return rle_new(); }

    let mut result = rle_new();
    let mut cur_val = seq_get(s, 0);
    let mut cur_count = 1;
    let mut i = 1;

    while i < s.len {
        let v = seq_get(s, i);
        if v == cur_val {
            cur_count = cur_count + 1;
        } else {
            result = rle_push_run(result, cur_val, cur_count);
            cur_val = v;
            cur_count = 1;
        }
        i = i + 1;
    }
    result = rle_push_run(result, cur_val, cur_count);
    result
}

// Decode RLE back to sequence
fn rle_decode(r: RLE) -> Seq {
    let mut result = seq_new();
    let mut i = 0;
    while i < r.num_runs {
        let val = rle_get_val(r, i);
        let count = rle_get_count(r, i);
        let mut j = 0;
        while j < count {
            result = seq_push(result, val);
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

// Total decoded length
fn rle_decoded_len(r: RLE) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < r.num_runs {
        total = total + rle_get_count(r, i);
        i = i + 1;
    }
    total
}

// Encoded size (number of pairs * 2)
fn rle_encoded_size(r: RLE) -> Int {
    r.num_runs * 2
}

// Check if two sequences are equal
fn seq_equal(a: Seq, b: Seq) -> Int {
    if a.len != b.len { return 0; }
    let mut i = 0;
    while i < a.len {
        if seq_get(a, i) != seq_get(b, i) { return 0; }
        i = i + 1;
    }
    1
}

fn test_all_same() {
    // [5, 5, 5, 5, 5] -> 1 run: (5, 5)
    let mut s = seq_new();
    s = seq_push(s, 5);
    s = seq_push(s, 5);
    s = seq_push(s, 5);
    s = seq_push(s, 5);
    s = seq_push(s, 5);

    let r = rle_encode(s);
    assert_eq(r.num_runs, 1);
    assert_eq(rle_get_val(r, 0), 5);
    assert_eq(rle_get_count(r, 0), 5);
    assert_eq(rle_decoded_len(r), 5);
}

fn test_all_different() {
    // [1, 2, 3, 4] -> 4 runs of length 1
    let mut s = seq_new();
    s = seq_push(s, 1);
    s = seq_push(s, 2);
    s = seq_push(s, 3);
    s = seq_push(s, 4);

    let r = rle_encode(s);
    assert_eq(r.num_runs, 4);
    assert_eq(rle_get_count(r, 0), 1);
    assert_eq(rle_get_count(r, 1), 1);
    assert_eq(rle_get_count(r, 2), 1);
    assert_eq(rle_get_count(r, 3), 1);
}

fn test_mixed_runs() {
    // [1, 1, 1, 2, 2, 3] -> 3 runs: (1,3), (2,2), (3,1)
    let mut s = seq_new();
    s = seq_push(s, 1);
    s = seq_push(s, 1);
    s = seq_push(s, 1);
    s = seq_push(s, 2);
    s = seq_push(s, 2);
    s = seq_push(s, 3);

    let r = rle_encode(s);
    assert_eq(r.num_runs, 3);
    assert_eq(rle_get_val(r, 0), 1);
    assert_eq(rle_get_count(r, 0), 3);
    assert_eq(rle_get_val(r, 1), 2);
    assert_eq(rle_get_count(r, 1), 2);
    assert_eq(rle_get_val(r, 2), 3);
    assert_eq(rle_get_count(r, 2), 1);
}

fn test_roundtrip_same() {
    let mut s = seq_new();
    s = seq_push(s, 7);
    s = seq_push(s, 7);
    s = seq_push(s, 7);
    let r = rle_encode(s);
    let d = rle_decode(r);
    assert_eq(seq_equal(s, d), 1);
}

fn test_roundtrip_mixed() {
    let mut s = seq_new();
    s = seq_push(s, 1);
    s = seq_push(s, 1);
    s = seq_push(s, 2);
    s = seq_push(s, 3);
    s = seq_push(s, 3);
    s = seq_push(s, 3);
    let r = rle_encode(s);
    let d = rle_decode(r);
    assert_eq(seq_equal(s, d), 1);
}

fn test_roundtrip_single() {
    let mut s = seq_new();
    s = seq_push(s, 42);
    let r = rle_encode(s);
    let d = rle_decode(r);
    assert_eq(seq_equal(s, d), 1);
    assert_eq(r.num_runs, 1);
}

fn test_empty() {
    let s = seq_new();
    let r = rle_encode(s);
    assert_eq(r.num_runs, 0);
    let d = rle_decode(r);
    assert_eq(d.len, 0);
}

fn test_compression_good() {
    // All same: 8 elements -> 1 run (2 values) = 75% compression
    let mut s = seq_new();
    s = seq_push(s, 9);
    s = seq_push(s, 9);
    s = seq_push(s, 9);
    s = seq_push(s, 9);
    s = seq_push(s, 9);
    s = seq_push(s, 9);
    s = seq_push(s, 9);
    s = seq_push(s, 9);

    let r = rle_encode(s);
    assert_eq(rle_encoded_size(r), 2);
    assert_eq(rle_decoded_len(r), 8);
    // encoded_size < original_len means compression happened
    assert_eq(rle_encoded_size(r) < s.len, true);
}

fn test_compression_bad() {
    // All different: 4 elements -> 4 runs (8 values) = expansion
    let mut s = seq_new();
    s = seq_push(s, 1);
    s = seq_push(s, 2);
    s = seq_push(s, 3);
    s = seq_push(s, 4);

    let r = rle_encode(s);
    assert_eq(rle_encoded_size(r), 8);
    // encoded_size >= original_len means no compression
    assert_eq(rle_encoded_size(r) >= s.len, true);
}

fn test_alternating() {
    // [1, 2, 1, 2] -> 4 runs: worst case for RLE
    let mut s = seq_new();
    s = seq_push(s, 1);
    s = seq_push(s, 2);
    s = seq_push(s, 1);
    s = seq_push(s, 2);

    let r = rle_encode(s);
    assert_eq(r.num_runs, 4);
    let d = rle_decode(r);
    assert_eq(seq_equal(s, d), 1);
}

fn test_zero_values() {
    let mut s = seq_new();
    s = seq_push(s, 0);
    s = seq_push(s, 0);
    s = seq_push(s, 0);
    let r = rle_encode(s);
    assert_eq(r.num_runs, 1);
    assert_eq(rle_get_val(r, 0), 0);
    assert_eq(rle_get_count(r, 0), 3);
    let d = rle_decode(r);
    assert_eq(seq_equal(s, d), 1);
}

fn test_negative_values() {
    let mut s = seq_new();
    s = seq_push(s, -1);
    s = seq_push(s, -1);
    s = seq_push(s, -2);
    s = seq_push(s, -2);
    s = seq_push(s, -2);
    let r = rle_encode(s);
    assert_eq(r.num_runs, 2);
    assert_eq(rle_get_val(r, 0), -1);
    assert_eq(rle_get_count(r, 0), 2);
    assert_eq(rle_get_val(r, 1), -2);
    assert_eq(rle_get_count(r, 1), 3);
    let d = rle_decode(r);
    assert_eq(seq_equal(s, d), 1);
}

fn test_back_and_forth() {
    // [3, 3, 1, 3, 3] -> 3 runs: (3,2), (1,1), (3,2)
    let mut s = seq_new();
    s = seq_push(s, 3);
    s = seq_push(s, 3);
    s = seq_push(s, 1);
    s = seq_push(s, 3);
    s = seq_push(s, 3);
    let r = rle_encode(s);
    assert_eq(r.num_runs, 3);
    assert_eq(rle_get_val(r, 0), 3);
    assert_eq(rle_get_count(r, 0), 2);
    assert_eq(rle_get_val(r, 1), 1);
    assert_eq(rle_get_count(r, 1), 1);
    assert_eq(rle_get_val(r, 2), 3);
    assert_eq(rle_get_count(r, 2), 2);
    let d = rle_decode(r);
    assert_eq(seq_equal(s, d), 1);
}

fn main() -> Int {
    test_all_same();
    test_all_different();
    test_mixed_runs();
    test_roundtrip_same();
    test_roundtrip_mixed();
    test_roundtrip_single();
    test_empty();
    test_compression_good();
    test_compression_bad();
    test_alternating();
    test_zero_values();
    test_negative_values();
    test_back_and_forth();
    print("[OK] 364_rle_codec_aot");
    0
}
