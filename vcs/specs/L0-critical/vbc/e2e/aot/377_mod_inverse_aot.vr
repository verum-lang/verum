// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, modular-inverse, extended-euclidean, number-theory
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for modular multiplicative inverse using the extended Euclidean algorithm.
// Also tests modular exponentiation, Fermat's little theorem verification,
// and modular arithmetic identities.

// Extended Euclidean algorithm result: gcd, x, y such that a*x + b*y = gcd
type ExtGcdResult is { gcd_val: Int, coeff_x: Int, coeff_y: Int };

// Iterative extended GCD
fn ext_gcd(a: Int, bv: Int) -> ExtGcdResult {
    let mut old_r = a;
    let mut r = bv;
    let mut old_s = 1;
    let mut s = 0;
    let mut old_t = 0;
    let mut t = 1;

    while r != 0 {
        let q = old_r / r;

        let tmp_r = r;
        r = old_r - q * r;
        old_r = tmp_r;

        let tmp_s = s;
        s = old_s - q * s;
        old_s = tmp_s;

        let tmp_t = t;
        t = old_t - q * t;
        old_t = tmp_t;
    }

    ExtGcdResult { gcd_val: old_r, coeff_x: old_s, coeff_y: old_t }
}

// Simple GCD
fn gcd_simple(a: Int, bv: Int) -> Int {
    let mut x = a;
    let mut y = bv;
    while y != 0 {
        let tmp = y;
        y = x % y;
        x = tmp;
    }
    x
}

// Modular inverse: find x such that (a * x) % m = 1
// Returns -1 if no inverse exists (gcd(a, m) != 1)
fn mod_inverse(a: Int, m: Int) -> Int {
    let res = ext_gcd(a, m);
    if res.gcd_val != 1 {
        return -1; // no inverse
    }
    // Normalize to positive
    let inv = res.coeff_x % m;
    if inv < 0 { inv + m } else { inv }
}

// Modular exponentiation: (base^exp) % modulus
fn mod_exp(base: Int, exp: Int, modulus: Int) -> Int {
    if modulus == 1 { return 0; }
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % modulus;
        }
        e = e / 2;
        b = (b * b) % modulus;
    }
    result
}

// Euler's totient for prime p: phi(p) = p - 1
// For general n with small prime factors, compute iteratively
fn euler_totient(n: Int) -> Int {
    if n <= 1 { return 0; }
    let mut result = n;
    let mut num = n;
    let mut p = 2;
    while p * p <= num {
        if num % p == 0 {
            while num % p == 0 {
                num = num / p;
            }
            result = result - result / p;
        }
        p = p + 1;
    }
    if num > 1 {
        result = result - result / num;
    }
    result
}

// === Tests ===

fn test_ext_gcd_basic() {
    // gcd(12, 8) = 4, 12*(-1) + 8*(2) = 4
    let r = ext_gcd(12, 8);
    assert_eq(r.gcd_val, 4);
    assert_eq(12 * r.coeff_x + 8 * r.coeff_y, 4);
}

fn test_ext_gcd_coprime() {
    let r = ext_gcd(7, 13);
    assert_eq(r.gcd_val, 1);
    assert_eq(7 * r.coeff_x + 13 * r.coeff_y, 1);
}

fn test_ext_gcd_identity() {
    // For any a,b: a*x + b*y = gcd(a,b)
    let r1 = ext_gcd(35, 15);
    assert_eq(35 * r1.coeff_x + 15 * r1.coeff_y, r1.gcd_val);
    assert_eq(r1.gcd_val, 5);

    let r2 = ext_gcd(99, 78);
    assert_eq(99 * r2.coeff_x + 78 * r2.coeff_y, r2.gcd_val);
    assert_eq(r2.gcd_val, 3);
}

fn test_mod_inverse_prime() {
    // 3 * x ≡ 1 (mod 7) -> x = 5 (3*5=15, 15%7=1)
    let inv = mod_inverse(3, 7);
    assert_eq(inv, 5);
    assert_eq((3 * inv) % 7, 1);
}

fn test_mod_inverse_various_primes() {
    // Inverses mod 11
    let inv2 = mod_inverse(2, 11);
    assert_eq((2 * inv2) % 11, 1);

    let inv3 = mod_inverse(3, 11);
    assert_eq((3 * inv3) % 11, 1);

    let inv5 = mod_inverse(5, 11);
    assert_eq((5 * inv5) % 11, 1);

    let inv7 = mod_inverse(7, 11);
    assert_eq((7 * inv7) % 11, 1);
}

fn test_mod_inverse_no_inverse() {
    // gcd(6, 9) = 3, no inverse
    assert_eq(mod_inverse(6, 9), -1);
    assert_eq(mod_inverse(4, 8), -1);
}

fn test_mod_inverse_one() {
    // 1 is always its own inverse
    assert_eq(mod_inverse(1, 7), 1);
    assert_eq(mod_inverse(1, 13), 1);
}

fn test_mod_inverse_self_inverse() {
    // inv(inv(a)) = a
    let p = 13;
    let a = 5;
    let inv_a = mod_inverse(a, p);
    let inv_inv_a = mod_inverse(inv_a, p);
    assert_eq(inv_inv_a, a);
}

fn test_mod_exp_basic() {
    assert_eq(mod_exp(2, 10, 1000), 24);
    assert_eq(mod_exp(3, 5, 100), 43); // 243 % 100 = 43
    assert_eq(mod_exp(2, 0, 7), 1);
    assert_eq(mod_exp(5, 1, 13), 5);
}

fn test_mod_exp_large() {
    // 2^20 = 1048576, mod 1000 = 576
    assert_eq(mod_exp(2, 20, 1000), 576);
    // 7^7 = 823543, mod 100 = 43
    assert_eq(mod_exp(7, 7, 100), 43);
}

fn test_fermat_little_theorem() {
    // For prime p and gcd(a,p)=1: a^(p-1) ≡ 1 (mod p)
    let p = 13;
    assert_eq(mod_exp(2, p - 1, p), 1);
    assert_eq(mod_exp(3, p - 1, p), 1);
    assert_eq(mod_exp(5, p - 1, p), 1);
    assert_eq(mod_exp(7, p - 1, p), 1);
    assert_eq(mod_exp(11, p - 1, p), 1);
}

fn test_fermat_inverse() {
    // For prime p: a^(p-2) ≡ a^(-1) (mod p)
    let p = 17;
    let a = 5;
    let fermat_inv = mod_exp(a, p - 2, p);
    let ext_inv = mod_inverse(a, p);
    assert_eq(fermat_inv, ext_inv);
    assert_eq((a * fermat_inv) % p, 1);
}

fn test_euler_totient_prime() {
    // phi(p) = p - 1 for prime p
    assert_eq(euler_totient(2), 1);
    assert_eq(euler_totient(3), 2);
    assert_eq(euler_totient(5), 4);
    assert_eq(euler_totient(7), 6);
    assert_eq(euler_totient(11), 10);
    assert_eq(euler_totient(13), 12);
}

fn test_euler_totient_composite() {
    // phi(6) = 2 (coprime: 1, 5)
    assert_eq(euler_totient(6), 2);
    // phi(8) = 4 (coprime: 1, 3, 5, 7)
    assert_eq(euler_totient(8), 4);
    // phi(12) = 4 (coprime: 1, 5, 7, 11)
    assert_eq(euler_totient(12), 4);
}

fn test_euler_theorem() {
    // a^phi(n) ≡ 1 (mod n) when gcd(a,n)=1
    let n = 12;
    let phi = euler_totient(n); // 4
    assert_eq(mod_exp(5, phi, n), 1);
    assert_eq(mod_exp(7, phi, n), 1);
    assert_eq(mod_exp(11, phi, n), 1);
}

fn test_mod_inverse_all_coprime() {
    // All coprime elements mod 7 have inverses
    let p = 7;
    let mut a = 1;
    while a < p {
        let inv = mod_inverse(a, p);
        assert(inv >= 1);
        assert_eq((a * inv) % p, 1);
        a = a + 1;
    }
}

fn test_inverse_product() {
    // inv(a*b) = inv(a) * inv(b) mod p
    let p = 13;
    let a = 3;
    let bv = 5;
    let ab = (a * bv) % p;
    let inv_ab = mod_inverse(ab, p);
    let inv_a = mod_inverse(a, p);
    let inv_b = mod_inverse(bv, p);
    let product_inv = (inv_a * inv_b) % p;
    assert_eq(inv_ab, product_inv);
}

fn main() -> Int {
    test_ext_gcd_basic();
    test_ext_gcd_coprime();
    test_ext_gcd_identity();
    test_mod_inverse_prime();
    test_mod_inverse_various_primes();
    test_mod_inverse_no_inverse();
    test_mod_inverse_one();
    test_mod_inverse_self_inverse();
    test_mod_exp_basic();
    test_mod_exp_large();
    test_fermat_little_theorem();
    test_fermat_inverse();
    test_euler_totient_prime();
    test_euler_totient_composite();
    test_euler_theorem();
    test_mod_inverse_all_coprime();
    test_inverse_product();
    print("[OK] 377_mod_inverse_aot");
    0
}
