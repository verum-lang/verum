// @test: run
// @level: L0
// @tags: aot, e2e, flood-fill, grid, bfs
// @timeout: 30000

// Flood fill on a small grid (4x4 using 2 Arr8s)

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// 4x4 grid stored in a single Arr8 (indices 0-7 unused, we only use 0-7)
// Wait, 4x4 = 16 cells. Use packed: each Arr8 element holds 4 bits (one row)
// Simpler: use direct indexing, grid[r][c] = get8(row_r, c) for 4 cols
// But we only have 1 Arr8 with 8 slots. Let's use a 4x2 grid (4 rows, 2 cols)
// or pack a 3x3 grid into 8+1 slots

// Actually, let's use bit-packed rows for a 4x4 grid
// Row i is stored as get8(grid, i), with bit j set = cell (i,j) is colored
fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn grid_get(grid: Arr8, row: Int, col: Int) -> Int {
    (get8(grid, row) / pow2(col)) % 2
}

fn grid_set(grid: Arr8, row: Int, col: Int, val: Int) -> Arr8 {
    let cur = grid_get(grid, row, col);
    if cur == val { grid }
    else if val == 1 { set8(grid, row, get8(grid, row) + pow2(col)) }
    else { set8(grid, row, get8(grid, row) - pow2(col)) }
}

fn on_grid(r: Int, c: Int, rows: Int, cols: Int) -> Int {
    if r >= 0 {
        if r < rows {
            if c >= 0 {
                if c < cols { 1 } else { 0 }
            } else { 0 }
        } else { 0 }
    } else { 0 }
}

// Iterative flood fill using a queue
// Fill connected region of old_color with new_color starting from (sr, sc)
// Grid is rows x cols where rows <= 8, cols <= 8
fn flood_fill(grid: Arr8, sr: Int, sc: Int, new_color: Int, rows: Int, cols: Int) -> Arr8 {
    let old_color = grid_get(grid, sr, sc);
    if old_color == new_color { grid }
    else {
        let mut g = grid_set(grid, sr, sc, new_color);
        // BFS queue: store positions as r*cols+c, max 64 entries but we use Arr8 as ring buffer
        let mut queue = zeros();
        let mut front = 0;
        let mut back = 0;
        queue = set8(queue, back, sr * cols + sc);
        back = back + 1;
        let mut iters = 0;
        while front < back {
            let pos = get8(queue, front % 8);
            front = front + 1;
            let r = pos / cols;
            let c = pos % cols;
            // Check 4 neighbors
            // Up
            let nr0 = r - 1;
            if on_grid(nr0, c, rows, cols) == 1 {
                if grid_get(g, nr0, c) == old_color {
                    g = grid_set(g, nr0, c, new_color);
                    if back - front < 8 {
                        queue = set8(queue, back % 8, nr0 * cols + c);
                        back = back + 1;
                    }
                }
            }
            // Down
            let nr1 = r + 1;
            if on_grid(nr1, c, rows, cols) == 1 {
                if grid_get(g, nr1, c) == old_color {
                    g = grid_set(g, nr1, c, new_color);
                    if back - front < 8 {
                        queue = set8(queue, back % 8, nr1 * cols + c);
                        back = back + 1;
                    }
                }
            }
            // Left
            let nc0 = c - 1;
            if on_grid(r, nc0, rows, cols) == 1 {
                if grid_get(g, r, nc0) == old_color {
                    g = grid_set(g, r, nc0, new_color);
                    if back - front < 8 {
                        queue = set8(queue, back % 8, r * cols + nc0);
                        back = back + 1;
                    }
                }
            }
            // Right
            let nc1 = c + 1;
            if on_grid(r, nc1, rows, cols) == 1 {
                if grid_get(g, r, nc1) == old_color {
                    g = grid_set(g, r, nc1, new_color);
                    if back - front < 8 {
                        queue = set8(queue, back % 8, r * cols + nc1);
                        back = back + 1;
                    }
                }
            }
            iters = iters + 1;
            if iters > 30 { front = back; } // safety
        }
        g
    }
}

// Count cells of given color
fn count_color(grid: Arr8, color: Int, rows: Int, cols: Int) -> Int {
    let mut count = 0;
    let mut r = 0;
    while r < rows {
        let mut c = 0;
        while c < cols {
            if grid_get(grid, r, c) == color { count = count + 1; }
            c = c + 1;
        }
        r = r + 1;
    }
    count
}

fn test_empty_fill() -> Int {
    // 4x4 grid all 0s, fill (0,0) with 1 -> all become 1
    let grid = zeros();
    let filled = flood_fill(grid, 0, 0, 1, 4, 4);
    assert_eq(count_color(filled, 1, 4, 4), 16);
    assert_eq(count_color(filled, 0, 4, 4), 0);
    1
}

fn test_partial_fill() -> Int {
    // Grid with barrier:
    // 0 0 1 0
    // 0 0 1 0
    // 0 0 0 0
    // Row 0 = 0100 (bit 2 set) = 4
    // Row 1 = 0100 = 4
    // Row 2 = 0000 = 0
    // Row 3 = 0000 = 0
    let grid = Arr8 { v0: 4, v1: 4, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Verify barrier
    assert_eq(grid_get(grid, 0, 2), 1);
    assert_eq(grid_get(grid, 0, 0), 0);
    // Fill from (0,0) with 1 — should fill left side but not cross barrier
    // Actually the barrier is only 2 cells, bottom is open, so fill goes around
    let filled = flood_fill(grid, 0, 0, 1, 3, 4);
    // The fill should reach everywhere except the barrier cells (0,2) and (1,2)
    // which are already 1
    assert_eq(count_color(filled, 1, 3, 4), 12); // all 12 cells colored 1
    1
}

fn test_no_fill_same_color() -> Int {
    // Fill with same color -> no change
    let grid = zeros();
    let filled = flood_fill(grid, 0, 0, 0, 4, 4);
    assert_eq(count_color(filled, 0, 4, 4), 16);
    1
}

fn test_single_cell() -> Int {
    // 1x1 grid
    let grid = zeros();
    let filled = flood_fill(grid, 0, 0, 1, 1, 1);
    assert_eq(grid_get(filled, 0, 0), 1);
    1
}

fn test_grid_operations() -> Int {
    // Test grid get/set
    let mut g = zeros();
    g = grid_set(g, 2, 3, 1);
    assert_eq(grid_get(g, 2, 3), 1);
    assert_eq(grid_get(g, 2, 2), 0);
    assert_eq(grid_get(g, 0, 0), 0);
    g = grid_set(g, 0, 0, 1);
    assert_eq(grid_get(g, 0, 0), 1);
    g = grid_set(g, 0, 0, 0);
    assert_eq(grid_get(g, 0, 0), 0);
    1
}

fn main() -> Int {
    test_grid_operations();
    test_single_cell();
    test_no_fill_same_color();
    test_empty_fill();
    test_partial_fill();
    print("[OK] 596_flood_fill_aot");
    0
}
