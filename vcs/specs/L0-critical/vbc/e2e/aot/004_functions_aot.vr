// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, functions
// @timeout: 5000
// @expected-exit: 0
// @description: AOT function calls, multiple parameters, return values

fn add(a: Int, b: Int) -> Int {
    a + b
}

fn sub(a: Int, b: Int) -> Int {
    a - b
}

fn mul(a: Int, b: Int) -> Int {
    a * b
}

fn square(x: Int) -> Int {
    mul(x, x)
}

fn cube(x: Int) -> Int {
    mul(mul(x, x), x)
}

@allow(unbounded_recursion)
fn power(base: Int, exp: Int) -> Int {
    if exp == 0 {
        1
    } else if exp == 1 {
        base
    } else {
        base * power(base, exp - 1)
    }
}

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 {
        a
    } else {
        gcd(b, a % b)
    }
}

fn is_even(n: Int) -> Bool {
    n % 2 == 0
}

@allow(unbounded_recursion)
fn sum_to(n: Int) -> Int {
    if n <= 0 { 0 } else { n + sum_to(n - 1) }
}

fn main() -> Int {
    // Basic function calls
    assert_eq(add(3, 4), 7);
    assert_eq(sub(10, 3), 7);
    assert_eq(mul(6, 7), 42);

    // Nested calls
    assert_eq(add(mul(3, 4), mul(5, 6)), 42);
    assert_eq(square(7), 49);
    assert_eq(cube(3), 27);

    // Recursive functions
    assert_eq(power(2, 10), 1024);
    assert_eq(power(3, 5), 243);
    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 75), 25);

    // Boolean-returning functions
    assert(is_even(4));
    assert(!is_even(7));

    // Sum
    assert_eq(sum_to(10), 55);
    assert_eq(sum_to(100), 5050);

    0
}
