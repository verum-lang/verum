// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, perfect-numbers, amicable-numbers, number-theory
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for perfect numbers and amicable numbers.
// Perfect number: n where sum of proper divisors = n (e.g. 6, 28, 496).
// Amicable pair: (a, b) where s(a) = b and s(b) = a, a != b.
// First amicable pair: (220, 284).
// Also tests: abundant, deficient classification.

// Sum of proper divisors of n (divisors of n excluding n itself)
fn sum_divisors(n: Int) -> Int {
    if n <= 1 { return 0; }
    let mut sum = 1; // 1 always divides n
    let mut d = 2;
    while d * d <= n {
        if n % d == 0 {
            sum = sum + d;
            let other = n / d;
            if other != d {
                sum = sum + other;
            }
        }
        d = d + 1;
    }
    sum
}

// Check if n is a perfect number
fn is_perfect(n: Int) -> Int {
    if n < 2 { return 0; }
    if sum_divisors(n) == n { 1 } else { 0 }
}

// Check if n is abundant (sum of proper divisors > n)
fn is_abundant(n: Int) -> Int {
    if n < 2 { return 0; }
    if sum_divisors(n) > n { 1 } else { 0 }
}

// Check if n is deficient (sum of proper divisors < n)
fn is_deficient(n: Int) -> Int {
    if n < 2 { return 0; }
    if sum_divisors(n) < n { 1 } else { 0 }
}

// Check if (a, b) is an amicable pair
fn is_amicable_pair(a: Int, b_val: Int) -> Int {
    if a == b_val { return 0; } // must be distinct
    let sa = sum_divisors(a);
    let sb = sum_divisors(b_val);
    if sa == b_val {
        if sb == a { return 1; }
    }
    0
}

// Number of divisors
fn count_divisors(n: Int) -> Int {
    if n <= 0 { return 0; }
    if n == 1 { return 1; }
    let mut count = 0;
    let mut d = 1;
    while d * d <= n {
        if n % d == 0 {
            count = count + 1;
            let other = n / d;
            if other != d {
                count = count + 1;
            }
        }
        d = d + 1;
    }
    count
}

// --- Tests ---

fn test_sum_divisors_basic() {
    assert_eq(sum_divisors(1), 0);
    assert_eq(sum_divisors(2), 1);
    assert_eq(sum_divisors(3), 1);
    assert_eq(sum_divisors(4), 3);    // 1 + 2
    assert_eq(sum_divisors(6), 6);    // 1 + 2 + 3
    assert_eq(sum_divisors(10), 8);   // 1 + 2 + 5
    assert_eq(sum_divisors(12), 16);  // 1 + 2 + 3 + 4 + 6
}

fn test_perfect_numbers() {
    // First three perfect numbers: 6, 28, 496
    assert_eq(is_perfect(6), 1);
    assert_eq(is_perfect(28), 1);
    assert_eq(is_perfect(496), 1);

    // Non-perfect numbers
    assert_eq(is_perfect(1), 0);
    assert_eq(is_perfect(5), 0);
    assert_eq(is_perfect(10), 0);
    assert_eq(is_perfect(27), 0);
    assert_eq(is_perfect(100), 0);
}

fn test_perfect_6() {
    // 6 = 1 + 2 + 3
    assert_eq(sum_divisors(6), 6);
    // 6 = 2^1 * (2^2 - 1) = 2 * 3
    assert_eq(count_divisors(6), 4); // 1, 2, 3, 6
}

fn test_perfect_28() {
    // 28 = 1 + 2 + 4 + 7 + 14
    assert_eq(sum_divisors(28), 28);
    // 28 = 2^2 * (2^3 - 1) = 4 * 7
    assert_eq(count_divisors(28), 6); // 1, 2, 4, 7, 14, 28
}

fn test_perfect_496() {
    // 496 = 2^4 * (2^5 - 1) = 16 * 31
    assert_eq(sum_divisors(496), 496);
}

fn test_amicable_220_284() {
    // The smallest amicable pair
    assert_eq(sum_divisors(220), 284);
    assert_eq(sum_divisors(284), 220);
    assert_eq(is_amicable_pair(220, 284), 1);
    assert_eq(is_amicable_pair(284, 220), 1);
}

fn test_not_amicable() {
    // Perfect numbers are NOT amicable (s(n) = n, need a != b)
    assert_eq(is_amicable_pair(6, 6), 0);
    assert_eq(is_amicable_pair(28, 28), 0);

    // Random non-amicable pairs
    assert_eq(is_amicable_pair(10, 20), 0);
    assert_eq(is_amicable_pair(100, 200), 0);
}

fn test_abundant_numbers() {
    // First few abundant numbers: 12, 18, 20, 24, 30
    assert_eq(is_abundant(12), 1);   // s(12) = 16 > 12
    assert_eq(is_abundant(18), 1);   // s(18) = 21 > 18
    assert_eq(is_abundant(20), 1);   // s(20) = 22 > 20
    assert_eq(is_abundant(24), 1);   // s(24) = 36 > 24
    assert_eq(is_abundant(30), 1);   // s(30) = 42 > 30

    // Non-abundant
    assert_eq(is_abundant(1), 0);
    assert_eq(is_abundant(2), 0);
    assert_eq(is_abundant(6), 0);  // 6 is perfect, not abundant
    assert_eq(is_abundant(7), 0);
}

fn test_deficient_numbers() {
    // Most primes are deficient (s(p) = 1 < p for prime p)
    assert_eq(is_deficient(2), 1);
    assert_eq(is_deficient(3), 1);
    assert_eq(is_deficient(5), 1);
    assert_eq(is_deficient(7), 1);
    assert_eq(is_deficient(11), 1);

    // Powers of 2 are deficient: s(2^k) = 2^k - 1 < 2^k
    assert_eq(is_deficient(4), 1);   // s(4) = 3
    assert_eq(is_deficient(8), 1);   // s(8) = 7
    assert_eq(is_deficient(16), 1);  // s(16) = 15
}

fn test_classification_complete() {
    // Every integer >= 2 is exactly one of: perfect, abundant, or deficient
    let mut n = 2;
    while n <= 100 {
        let p = is_perfect(n);
        let a = is_abundant(n);
        let d = is_deficient(n);
        // Exactly one should be 1
        assert_eq(p + a + d, 1);
        n = n + 1;
    }
}

fn test_mersenne_euclid_formula() {
    // Even perfect numbers have the form 2^(p-1) * (2^p - 1) where 2^p - 1 is prime
    // p=2: 2^1 * 3 = 6
    // p=3: 2^2 * 7 = 28
    // p=5: 2^4 * 31 = 496
    assert_eq(2 * 3, 6);
    assert_eq(is_perfect(6), 1);
    assert_eq(4 * 7, 28);
    assert_eq(is_perfect(28), 1);
    assert_eq(16 * 31, 496);
    assert_eq(is_perfect(496), 1);
}

fn test_count_divisors() {
    assert_eq(count_divisors(1), 1);
    assert_eq(count_divisors(2), 2);
    assert_eq(count_divisors(6), 4);
    assert_eq(count_divisors(12), 6);
    assert_eq(count_divisors(60), 12);
}

fn test_amicable_pair_symmetry() {
    // s(220) = 284, s(284) = 220
    // Also verify individual divisor sums
    assert_eq(sum_divisors(220), 284);
    assert_eq(sum_divisors(284), 220);
    // s(s(220)) = s(284) = 220
    assert_eq(sum_divisors(sum_divisors(220)), 220);
    assert_eq(sum_divisors(sum_divisors(284)), 284);
}

fn main() -> Int {
    test_sum_divisors_basic();
    test_perfect_numbers();
    test_perfect_6();
    test_perfect_28();
    test_perfect_496();
    test_amicable_220_284();
    test_not_amicable();
    test_abundant_numbers();
    test_deficient_numbers();
    test_classification_complete();
    test_mersenne_euclid_formula();
    test_count_divisors();
    test_amicable_pair_symmetry();
    print("[OK] 368_perfect_amicable_aot");
    0
}
