// @test: run
// @level: L0
// @tags: aot, e2e, expression, evaluation, tree
// @timeout: 30000

// Expression tree evaluation using integer-encoded nodes
// Each node: type*10000000 + left*10000 + right_or_val
// Types: 1=literal, 2=add, 3=sub, 4=mul, 5=div
// For literals: value stored in right_or_val field
// For operators: left and right are indices into node array

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn node_type(node: Int) -> Int { node / 10000000 }
fn node_left(node: Int) -> Int { (node / 10000) % 1000 }
fn node_right(node: Int) -> Int { node % 10000 }

fn make_lit(val: Int) -> Int { 1 * 10000000 + val }
fn make_add(l: Int, r: Int) -> Int { 2 * 10000000 + l * 10000 + r }
fn make_sub(l: Int, r: Int) -> Int { 3 * 10000000 + l * 10000 + r }
fn make_mul(l: Int, r: Int) -> Int { 4 * 10000000 + l * 10000 + r }
fn make_div(l: Int, r: Int) -> Int { 5 * 10000000 + l * 10000 + r }

// Evaluate expression tree rooted at index `idx`
@allow(unbounded_recursion)
fn eval(nodes: Arr8, idx: Int) -> Int {
    let node = get8(nodes, idx);
    let nt = node_type(node);
    if nt == 1 {
        node_right(node) // literal value
    } else {
        let left_val = eval(nodes, node_left(node));
        let right_val = eval(nodes, node_right(node));
        if nt == 2 { left_val + right_val }
        else if nt == 3 { left_val - right_val }
        else if nt == 4 { left_val * right_val }
        else if nt == 5 {
            if right_val == 0 { 0 }
            else { left_val / right_val }
        }
        else { 0 }
    }
}

// Count nodes in tree
@allow(unbounded_recursion)
fn count_nodes(nodes: Arr8, idx: Int) -> Int {
    let node = get8(nodes, idx);
    let nt = node_type(node);
    if nt == 1 { 1 }
    else {
        1 + count_nodes(nodes, node_left(node)) + count_nodes(nodes, node_right(node))
    }
}

// Tree depth
@allow(unbounded_recursion)
fn tree_depth(nodes: Arr8, idx: Int) -> Int {
    let node = get8(nodes, idx);
    let nt = node_type(node);
    if nt == 1 { 1 }
    else {
        let ld = tree_depth(nodes, node_left(node));
        let rd = tree_depth(nodes, node_right(node));
        1 + if ld > rd { ld } else { rd }
    }
}

fn test_literal() -> Int {
    let nodes = Arr8 { v0: make_lit(42), v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(eval(nodes, 0), 42);
    assert_eq(count_nodes(nodes, 0), 1);
    assert_eq(tree_depth(nodes, 0), 1);
    1
}

fn test_simple_add() -> Int {
    // 3 + 5 = 8
    // Node 0: lit(3), Node 1: lit(5), Node 2: add(0, 1)
    let nodes = Arr8 {
        v0: make_lit(3),
        v1: make_lit(5),
        v2: make_add(0, 1),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(eval(nodes, 2), 8);
    assert_eq(count_nodes(nodes, 2), 3);
    assert_eq(tree_depth(nodes, 2), 2);
    1
}

fn test_nested_expr() -> Int {
    // (3 + 5) * 2 = 16
    // Node 0: lit(3), Node 1: lit(5), Node 2: add(0,1), Node 3: lit(2), Node 4: mul(2,3)
    let nodes = Arr8 {
        v0: make_lit(3),
        v1: make_lit(5),
        v2: make_add(0, 1),
        v3: make_lit(2),
        v4: make_mul(2, 3),
        v5: 0, v6: 0, v7: 0
    };
    assert_eq(eval(nodes, 4), 16);
    assert_eq(count_nodes(nodes, 4), 5);
    assert_eq(tree_depth(nodes, 4), 3);
    1
}

fn test_subtraction() -> Int {
    // 10 - 3 = 7
    let nodes = Arr8 {
        v0: make_lit(10),
        v1: make_lit(3),
        v2: make_sub(0, 1),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(eval(nodes, 2), 7);
    1
}

fn test_division() -> Int {
    // 20 / 4 = 5
    let nodes = Arr8 {
        v0: make_lit(20),
        v1: make_lit(4),
        v2: make_div(0, 1),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(eval(nodes, 2), 5);
    // Division by zero returns 0
    let nodes2 = Arr8 {
        v0: make_lit(20),
        v1: make_lit(0),
        v2: make_div(0, 1),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(eval(nodes2, 2), 0);
    1
}

fn test_complex_tree() -> Int {
    // (2 + 3) * (10 - 4) = 5 * 6 = 30
    // 0: lit(2), 1: lit(3), 2: add(0,1), 3: lit(10), 4: lit(4), 5: sub(3,4), 6: mul(2,5)
    let nodes = Arr8 {
        v0: make_lit(2),
        v1: make_lit(3),
        v2: make_add(0, 1),
        v3: make_lit(10),
        v4: make_lit(4),
        v5: make_sub(3, 4),
        v6: make_mul(2, 5),
        v7: 0
    };
    assert_eq(eval(nodes, 6), 30);
    assert_eq(count_nodes(nodes, 6), 7);
    assert_eq(tree_depth(nodes, 6), 3);
    1
}

fn test_left_heavy() -> Int {
    // ((5 + 3) + 2) + 1 = 11
    // 0: lit(5), 1: lit(3), 2: add(0,1), 3: lit(2), 4: add(2,3), 5: lit(1), 6: add(4,5)
    let nodes = Arr8 {
        v0: make_lit(5),
        v1: make_lit(3),
        v2: make_add(0, 1),
        v3: make_lit(2),
        v4: make_add(2, 3),
        v5: make_lit(1),
        v6: make_add(4, 5),
        v7: 0
    };
    assert_eq(eval(nodes, 6), 11);
    assert_eq(tree_depth(nodes, 6), 4); // Left-heavy tree
    1
}

fn main() -> Int {
    test_literal();
    test_simple_add();
    test_nested_expr();
    test_subtraction();
    test_division();
    test_complex_tree();
    test_left_heavy();
    print("[OK] 629_expression_eval_aot");
    0
}
