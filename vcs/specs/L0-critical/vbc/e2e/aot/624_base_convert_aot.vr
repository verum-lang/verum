// @test: run
// @level: L0
// @tags: aot, e2e, base-conversion, number-system, encoding
// @timeout: 30000

// Number base conversion and digit manipulation

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Convert number to base, store digits in Arr8 (least significant first)
// Returns number of digits
fn to_base(num: Int, base: Int) -> Int {
    if num == 0 { 1 } // "0" has 1 digit
    else {
        let mut n = num;
        let mut count = 0;
        while n > 0 {
            count = count + 1;
            n = n / base;
        }
        count
    }
}

// Get digits of num in given base, stored in Arr8 (LSB first)
fn get_digits(num: Int, base: Int) -> Arr8 {
    let mut result = zeros();
    if num == 0 {
        result
    } else {
        let mut n = num;
        let mut i = 0;
        while n > 0 {
            if i < 8 {
                result = set8(result, i, n % base);
            }
            n = n / base;
            i = i + 1;
        }
        result
    }
}

// Convert digits in Arr8 back to number
fn from_digits(digits: Arr8, n_digits: Int, base: Int) -> Int {
    let mut result = 0;
    let mut power = 1;
    let mut i = 0;
    while i < n_digits {
        result = result + get8(digits, i) * power;
        power = power * base;
        i = i + 1;
    }
    result
}

// Sum of digits in given base
fn digit_sum(num: Int, base: Int) -> Int {
    let mut sum = 0;
    let mut n = num;
    if n == 0 { 0 }
    else {
        while n > 0 {
            sum = sum + n % base;
            n = n / base;
        }
        sum
    }
}

// Digital root: repeated digit sum until single digit
fn digital_root(num: Int, base: Int) -> Int {
    let mut n = num;
    while n >= base {
        n = digit_sum(n, base);
    }
    n
}

// Is palindrome in given base?
fn is_palindrome_base(num: Int, base: Int) -> Int {
    let digits = get_digits(num, base);
    let n = to_base(num, base);
    let mut is_pal = 1;
    let mut i = 0;
    while i < n / 2 {
        if get8(digits, i) != get8(digits, n - 1 - i) {
            is_pal = 0;
        }
        i = i + 1;
    }
    is_pal
}

// Reverse digits of number in given base
fn reverse_in_base(num: Int, base: Int) -> Int {
    let digits = get_digits(num, base);
    let n = to_base(num, base);
    let mut result = 0;
    let mut power = 1;
    let mut i = 0;
    while i < n {
        result = result + get8(digits, n - 1 - i) * power;
        power = power * base;
        i = i + 1;
    }
    result
}

// Count digits in base
fn count_digits(num: Int, base: Int) -> Int {
    to_base(num, base)
}

fn test_binary() -> Int {
    // 13 in binary: 1101
    let digits = get_digits(13, 2);
    assert_eq(get8(digits, 0), 1); // LSB
    assert_eq(get8(digits, 1), 0);
    assert_eq(get8(digits, 2), 1);
    assert_eq(get8(digits, 3), 1); // MSB
    assert_eq(to_base(13, 2), 4);  // 4 binary digits
    assert_eq(from_digits(digits, 4, 2), 13);
    1
}

fn test_octal() -> Int {
    // 255 in octal: 377
    let digits = get_digits(255, 8);
    assert_eq(get8(digits, 0), 7); // LSB
    assert_eq(get8(digits, 1), 7);
    assert_eq(get8(digits, 2), 3); // MSB
    assert_eq(to_base(255, 8), 3);
    assert_eq(from_digits(digits, 3, 8), 255);
    1
}

fn test_hex() -> Int {
    // 255 in hex: FF (15, 15)
    let digits = get_digits(255, 16);
    assert_eq(get8(digits, 0), 15);
    assert_eq(get8(digits, 1), 15);
    assert_eq(to_base(255, 16), 2);
    assert_eq(from_digits(digits, 2, 16), 255);

    // 256 in hex: 100 (0, 0, 1)
    let d2 = get_digits(256, 16);
    assert_eq(get8(d2, 0), 0);
    assert_eq(get8(d2, 1), 0);
    assert_eq(get8(d2, 2), 1);
    assert_eq(from_digits(d2, 3, 16), 256);
    1
}

fn test_digit_sum() -> Int {
    // 123 in base 10: 1+2+3 = 6
    assert_eq(digit_sum(123, 10), 6);
    // 999 in base 10: 9+9+9 = 27
    assert_eq(digit_sum(999, 10), 27);
    // 255 in base 2: 1+1+1+1+1+1+1+1 = 8
    assert_eq(digit_sum(255, 2), 8);
    // 0
    assert_eq(digit_sum(0, 10), 0);
    1
}

fn test_digital_root() -> Int {
    // Digital root of 9875 (base 10): 9+8+7+5=29 -> 2+9=11 -> 1+1=2
    assert_eq(digital_root(9875, 10), 2);
    // Digital root of 123: 1+2+3=6
    assert_eq(digital_root(123, 10), 6);
    // Digital root of 0: 0
    assert_eq(digital_root(0, 10), 0);
    // Digital root of 9: 9
    assert_eq(digital_root(9, 10), 9);
    1
}

fn test_palindrome() -> Int {
    // 121 is palindrome in base 10
    assert_eq(is_palindrome_base(121, 10), 1);
    // 123 is not
    assert_eq(is_palindrome_base(123, 10), 0);
    // 7 in binary is 111 — palindrome
    assert_eq(is_palindrome_base(7, 2), 1);
    // 9 in binary is 1001 — palindrome
    assert_eq(is_palindrome_base(9, 2), 1);
    // 10 in binary is 1010 — not palindrome
    assert_eq(is_palindrome_base(10, 2), 0);
    // 5 in base 2: 101 — palindrome
    assert_eq(is_palindrome_base(5, 2), 1);
    1
}

fn test_reverse() -> Int {
    // Reverse 123 in base 10 = 321
    assert_eq(reverse_in_base(123, 10), 321);
    // Reverse 100 in base 10 = 001 = 1
    assert_eq(reverse_in_base(100, 10), 1);
    // Reverse 13 (1101) in binary = 1011 = 11
    assert_eq(reverse_in_base(13, 2), 11);
    1
}

fn test_roundtrip() -> Int {
    // Convert to base and back should give original
    // Note: Arr8 only holds 8 digits, so values must fit
    let num = 12345;
    let d10 = get_digits(num, 10);
    let n10 = to_base(num, 10);
    assert_eq(from_digits(d10, n10, 10), num); // 5 digits, fits

    // Base 2: use small number (255 = 8 binary digits, max for Arr8)
    let num2 = 255;
    let d2 = get_digits(num2, 2);
    let n2 = to_base(num2, 2);
    assert_eq(from_digits(d2, n2, 2), num2);

    // Base 16: 12345 is 4 hex digits, fits fine
    let d16 = get_digits(num, 16);
    let n16 = to_base(num, 16);
    assert_eq(from_digits(d16, n16, 16), num);
    1
}

fn main() -> Int {
    test_binary();
    test_octal();
    test_hex();
    test_digit_sum();
    test_digital_root();
    test_palindrome();
    test_reverse();
    test_roundtrip();
    print("[OK] 624_base_convert_aot");
    0
}
