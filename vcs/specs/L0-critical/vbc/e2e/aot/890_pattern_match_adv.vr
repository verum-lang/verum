// @test: run
// @tier: 0
// @level: L0
// @tags: aot, pattern-matching, variants, nested, heap
// @expected-exit: 0

// Test: pattern matching on sum types including heap-allocated recursive types.

type Shape is Circle(Int) | Rectangle(Int, Int);

fn area(s: Shape) -> Int {
    match s {
        Circle(r) => r * r * 3,
        Rectangle(w, h) => w * h,
    }
}

type Color is Red | Green | Blue | Custom(Int);

fn color_value(c: Color) -> Int {
    match c {
        Red => 1,
        Green => 2,
        Blue => 3,
        Custom(v) => v,
    }
}

type Direction is North | South | East | West;

fn dir_code(d: Direction) -> Int {
    match d {
        North => 0,
        South => 1,
        East => 2,
        West => 3,
    }
}

// Recursive sum type with Heap
type Expr is
    Num(Int)
    | Add(Heap<Expr>, Heap<Expr>);

@allow(unbounded_recursion)
fn eval(e: Expr) -> Int {
    match e {
        Num(n) => n,
        Add(left, right) => eval(*left) + eval(*right),
    }
}

fn classify(n: Int) -> Int {
    if (n > 0) { 1 }
    else if (n < 0) { 0 - 1 }
    else { 0 }
}

fn main() -> Int {
    // Test 1: tuple variant matching
    let c = Circle(5);
    let ac = area(c);
    if (ac != 75) {
        print(f"FAIL test1a: circle area={ac}");
        return 1;
    }

    let r = Rectangle(4, 6);
    let ar = area(r);
    if (ar != 24) {
        print(f"FAIL test1b: rect area={ar}");
        return 1;
    }

    // Test 2: unit + tuple variants
    let r2a = color_value(Red);
    let r2b = color_value(Custom(42));
    if (r2a != 1) {
        print(f"FAIL test2a: Red={r2a}");
        return 1;
    }
    if (r2b != 42) {
        print(f"FAIL test2b: Custom={r2b}");
        return 1;
    }

    // Test 3: four unit variants
    let d1 = dir_code(North);
    let d2 = dir_code(South);
    let d3 = dir_code(East);
    let d4 = dir_code(West);
    if (d1 + d2 + d3 + d4 != 6) {
        print(f"FAIL test3: sum={d1 + d2 + d3 + d4}");
        return 1;
    }

    // Test 4: classify with if-else
    let c1 = classify(42);
    let c2 = classify(0 - 5);
    let c3 = classify(0);
    if (c1 != 1) {
        print(f"FAIL test4a: classify(42)={c1}");
        return 1;
    }
    if (c2 != 0 - 1) {
        print(f"FAIL test4b: classify(-5)={c2}");
        return 1;
    }
    if (c3 != 0) {
        print(f"FAIL test4c: classify(0)={c3}");
        return 1;
    }

    // Test 5: recursive expression tree with Heap
    // (1 + 2) + 3 = 6
    let e = Add(
        Heap(Add(Heap(Num(1)), Heap(Num(2)))),
        Heap(Num(3))
    );
    let result = eval(e);
    if (result != 6) {
        print(f"FAIL test5: eval((1+2)+3)={result}");
        return 1;
    }

    print("890_pattern_match_adv: PASS");
    0
}
