// @test: run
// @tier: 0
// @level: L0
// @tags: aot, autodiff, gradient, scalar
// @expected-exit: 0

// Tests scalar gradient computation properties.
// Verifies analytical gradients match finite difference approximations.
// Uses integer-scaled arithmetic to avoid floating-point precision issues.

fn abs_val(x: Int) -> Int {
    if (x < 0) { 0 - x } else { x }
}

// Finite difference gradient approximation: f'(x) ≈ (f(x+h) - f(x-h)) / (2h)
// Using h=1 and scaling by 1000 for integer arithmetic

// f(x) = x^2, f'(x) = 2x
fn f_square(x: Int) -> Int {
    x * x
}

fn grad_square(x: Int) -> Int {
    2 * x
}

fn fd_grad_square(x: Int) -> Int {
    // (f(x+1) - f(x-1)) / 2
    (f_square(x + 1) - f_square(x - 1)) / 2
}

// f(x) = x^3, f'(x) = 3x^2
fn f_cube(x: Int) -> Int {
    x * x * x
}

fn grad_cube(x: Int) -> Int {
    3 * x * x
}

fn fd_grad_cube(x: Int) -> Int {
    (f_cube(x + 1) - f_cube(x - 1)) / 2
}

// f(x) = 5x + 3, f'(x) = 5
fn f_linear(x: Int) -> Int {
    5 * x + 3
}

fn fd_grad_linear(x: Int) -> Int {
    (f_linear(x + 1) - f_linear(x - 1)) / 2
}

// Chain rule: f(g(x)), f'(g(x)) * g'(x)
// f(x) = (2x+1)^2, let g(x) = 2x+1, f(u) = u^2
// f'(x) = 2*(2x+1)*2 = 4*(2x+1)
fn f_chain(x: Int) -> Int {
    let u = 2 * x + 1;
    u * u
}

fn grad_chain(x: Int) -> Int {
    4 * (2 * x + 1)
}

fn fd_grad_chain(x: Int) -> Int {
    (f_chain(x + 1) - f_chain(x - 1)) / 2
}

// Product rule: (f*g)' = f'*g + f*g'
// h(x) = x^2 * (3x + 1)
// h'(x) = 2x*(3x+1) + x^2*3 = 6x^2 + 2x + 3x^2 = 9x^2 + 2x
fn f_product(x: Int) -> Int {
    x * x * (3 * x + 1)
}

fn grad_product(x: Int) -> Int {
    9 * x * x + 2 * x
}

fn fd_grad_product(x: Int) -> Int {
    (f_product(x + 1) - f_product(x - 1)) / 2
}

// Second derivative: f''(x)
// f(x) = x^3 - 2x^2 + x
// f'(x) = 3x^2 - 4x + 1
// f''(x) = 6x - 4
fn f_poly(x: Int) -> Int {
    x * x * x - 2 * x * x + x
}

fn grad_poly(x: Int) -> Int {
    3 * x * x - 4 * x + 1
}

fn grad2_poly(x: Int) -> Int {
    6 * x - 4
}

fn fd_grad2_poly(x: Int) -> Int {
    // f''(x) ≈ (f'(x+1) - f'(x-1)) / 2
    (grad_poly(x + 1) - grad_poly(x - 1)) / 2
}

fn main() -> Int {
    // Test 1: Gradient of x^2
    // f'(3) = 6, finite diff = (16 - 4) / 2 = 6
    assert_eq(grad_square(3), 6);
    assert_eq(fd_grad_square(3), 6);
    assert_eq(grad_square(5), 10);
    assert_eq(fd_grad_square(5), 10);

    // Test 2: Gradient of x^3
    // f'(2) = 12, finite diff = (27 - 1) / 2 = 13 (off by 1 due to integer h=1)
    assert_eq(grad_cube(2), 12);
    // For x^3, fd with h=1: ((x+1)^3 - (x-1)^3)/2 = 3x^2 + 1
    assert_eq(fd_grad_cube(2), 13); // 3*4 + 1 = 13

    // Test 3: Gradient of linear function
    assert_eq(fd_grad_linear(0), 5);
    assert_eq(fd_grad_linear(10), 5);
    assert_eq(fd_grad_linear(100), 5);

    // Test 4: Chain rule
    // f'(2) = 4*(2*2+1) = 20
    assert_eq(grad_chain(2), 20);
    assert_eq(fd_grad_chain(2), 20);
    assert_eq(grad_chain(0), 4);
    assert_eq(fd_grad_chain(0), 4);

    // Test 5: Product rule
    // h'(2) = 9*4 + 4 = 40
    assert_eq(grad_product(2), 40);
    // FD for cubic: fd = f'(x) + f'''(x)/6 = (9x^2+2x) + 18/6 = 9x^2+2x+3
    assert_eq(fd_grad_product(2), 43);  // 40 + 3
    assert_eq(grad_product(1), 11);
    assert_eq(fd_grad_product(1), 14);  // 11 + 3

    // Test 6: Second derivative
    // f''(3) = 6*3 - 4 = 14
    assert_eq(grad2_poly(3), 14);
    assert_eq(fd_grad2_poly(3), 14);

    // Test 7: Gradient linearity: grad(a*f + b*g) = a*grad(f) + b*grad(g)
    let x = 3;
    let a = 2;
    let b = 5;
    // grad(a*x^2 + b*x^3) = a*2x + b*3x^2 = 2*2*3 + 5*3*9 = 12 + 135 = 147
    let combined_grad = a * grad_square(x) + b * grad_cube(x);
    assert_eq(combined_grad, 147);

    // Test 8: Gradient at critical points
    // f(x) = x^2 - 4x + 4 = (x-2)^2, f'(x) = 2x - 4, f'(2) = 0
    let crit_grad = 2 * 2 - 4;
    assert_eq(crit_grad, 0);

    // Test 9: Gradient sign indicates direction of increase
    // f(x) = x^2, f'(x) = 2x
    // f'(-3) = -6 (decreasing), f'(3) = 6 (increasing)
    assert(grad_square(-3) < 0);
    assert(grad_square(3) > 0);
    assert_eq(grad_square(0), 0);

    // Test 10: Mean value theorem: f(b) - f(a) = f'(c) * (b - a) for some c in (a,b)
    // For f(x) = x^2 on [1,3]: f(3)-f(1) = 8, f'(c)*(3-1) = 2c*2 = 4c
    // So c = 2, which is in (1,3) ✓
    let mvt_diff = f_square(3) - f_square(1);
    let mvt_c = 2;
    assert_eq(mvt_diff, grad_square(mvt_c) * (3 - 1));

    print("Autodiff scalar grad: PASS");
    0
}
