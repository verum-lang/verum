// @test: run
// @level: L0
// @tags: aot, e2e, matrix-chain, dp
// @timeout: 30000

// Matrix chain multiplication: find minimum number of scalar multiplications
// Using flat 2D array stored in Arr16

type Arr16 is {
    v0: Int, v1: Int, v2: Int, v3: Int,
    v4: Int, v5: Int, v6: Int, v7: Int,
    v8: Int, v9: Int, v10: Int, v11: Int,
    v12: Int, v13: Int, v14: Int, v15: Int
};

fn get16(a: Arr16, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else if i == 7 { a.v7 } else if i == 8 { a.v8 }
    else if i == 9 { a.v9 } else if i == 10 { a.v10 } else if i == 11 { a.v11 }
    else if i == 12 { a.v12 } else if i == 13 { a.v13 } else if i == 14 { a.v14 }
    else { a.v15 }
}

fn set16(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 },
        v8: if i == 8 { v } else { a.v8 },
        v9: if i == 9 { v } else { a.v9 },
        v10: if i == 10 { v } else { a.v10 },
        v11: if i == 11 { v } else { a.v11 },
        v12: if i == 12 { v } else { a.v12 },
        v13: if i == 13 { v } else { a.v13 },
        v14: if i == 14 { v } else { a.v14 },
        v15: if i == 15 { v } else { a.v15 }
    }
}

fn zeros16() -> Arr16 {
    Arr16 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0,
            v8: 0, v9: 0, v10: 0, v11: 0, v12: 0, v13: 0, v14: 0, v15: 0 }
}

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Matrix chain multiplication
// dims[0..n] are dimensions: matrix i is dims[i] x dims[i+1]
// n = number of matrices, so dims has n+1 elements
// Returns minimum number of scalar multiplications
// Uses dp[i*4+j] for 2D indexing (max 4 matrices)
fn matrix_chain_order(dims: Arr8, n: Int) -> Int {
    // dp[i][j] = min cost to multiply matrices i..j
    let mut dp = zeros16();
    // length 1: dp[i][i] = 0 (already zero)

    let mut len = 2;
    while len <= n {
        let mut i = 0;
        while i <= n - len {
            let j = i + len - 1;
            dp = set16(dp, i * 4 + j, 999999999);
            let mut k = i;
            while k < j {
                let cost = get16(dp, i * 4 + k) + get16(dp, (k + 1) * 4 + j)
                         + get8(dims, i) * get8(dims, k + 1) * get8(dims, j + 1);
                let current = get16(dp, i * 4 + j);
                if cost < current {
                    dp = set16(dp, i * 4 + j, cost);
                }
                k = k + 1;
            }
            i = i + 1;
        }
        len = len + 1;
    }
    get16(dp, 0 * 4 + n - 1)
}

fn test_two_matrices() -> Int {
    // A1: 10x30, A2: 30x5
    // dims = [10, 30, 5]
    // Cost = 10 * 30 * 5 = 1500
    let dims = Arr8 { v0: 10, v1: 30, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(matrix_chain_order(dims, 2), 1500);
    1
}

fn test_three_matrices() -> Int {
    // A1: 10x30, A2: 30x5, A3: 5x60
    // dims = [10, 30, 5, 60]
    // (A1*A2)*A3: 10*30*5 + 10*5*60 = 1500 + 3000 = 4500
    // A1*(A2*A3): 30*5*60 + 10*30*60 = 9000 + 18000 = 27000
    // Best: 4500
    let dims = Arr8 { v0: 10, v1: 30, v2: 5, v3: 60, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(matrix_chain_order(dims, 3), 4500);
    1
}

fn test_four_matrices() -> Int {
    // Classic example: dims = [40, 20, 30, 10, 30]
    // 4 matrices: 40x20, 20x30, 30x10, 10x30
    // Optimal: 26000
    let dims = Arr8 { v0: 40, v1: 20, v2: 30, v3: 10, v4: 30, v5: 0, v6: 0, v7: 0 };
    assert_eq(matrix_chain_order(dims, 4), 26000);
    1
}

fn test_single_matrix() -> Int {
    // Single matrix: no multiplication needed
    let dims = Arr8 { v0: 10, v1: 20, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(matrix_chain_order(dims, 1), 0);
    1
}

fn test_equal_dims() -> Int {
    // All square matrices: 5x5 * 5x5 * 5x5
    // dims = [5, 5, 5, 5]
    // Any order: 5*5*5 + 5*5*5 = 250
    let dims = Arr8 { v0: 5, v1: 5, v2: 5, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(matrix_chain_order(dims, 3), 250);
    1
}

fn main() -> Int {
    test_two_matrices();
    test_three_matrices();
    test_four_matrices();
    test_single_matrix();
    test_equal_dims();
    print("[OK] 471_matrix_chain_aot");
    0
}
