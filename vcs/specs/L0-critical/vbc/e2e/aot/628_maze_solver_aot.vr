// @test: run
// @level: L0
// @tags: aot, e2e, maze, pathfinding, bfs
// @timeout: 30000

// Maze solver on a 4x4 grid using BFS
// Grid stored as 16-bit packed (1=wall, 0=open)

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

// Get bit at position (r,c) in 4x4 grid
fn grid_bit(grid: Int, r: Int, c: Int) -> Int {
    let pos = r * 4 + c;
    (grid / pow2(pos)) % 2
}

// Set bit at position (r,c)
fn grid_set_bit(grid: Int, r: Int, c: Int) -> Int {
    let pos = r * 4 + c;
    if grid_bit(grid, r, c) == 1 { grid }
    else { grid + pow2(pos) }
}

fn valid(r: Int, c: Int) -> Int {
    if r < 0 { 0 }
    else if r >= 4 { 0 }
    else if c < 0 { 0 }
    else if c >= 4 { 0 }
    else { 1 }
}

// BFS shortest path from (sr,sc) to (er,ec)
// Returns distance or -1 if unreachable
// Uses iterative BFS with visited set (16-bit) and distance array
fn bfs_dist(walls: Int, sr: Int, sc: Int, er: Int, ec: Int) -> Int {
    if grid_bit(walls, sr, sc) == 1 { 0 - 1 }
    else if grid_bit(walls, er, ec) == 1 { 0 - 1 }
    else if sr == er {
        if sc == ec { 0 }
        else { bfs_impl(walls, sr, sc, er, ec) }
    } else { bfs_impl(walls, sr, sc, er, ec) }
}

fn bfs_impl(walls: Int, sr: Int, sc: Int, er: Int, ec: Int) -> Int {
    let mut visited = grid_set_bit(0, sr, sc);
    let mut found = 0;
    let mut dist = 0;
    let mut current = grid_set_bit(0, sr, sc); // current frontier as bit set
    let mut result = 0 - 1;

    while found == 0 {
        if current == 0 { found = 1; } // No more cells to explore
        else {
            dist = dist + 1;
            let mut next_frontier = 0;
            // Scan all cells in current frontier
            let mut r = 0;
            while r < 4 {
                let mut c = 0;
                while c < 4 {
                    if grid_bit(current, r, c) == 1 {
                        // Try 4 neighbors
                        let mut dir = 0;
                        while dir < 4 {
                            let nr = r + if dir == 0 { 0 - 1 } else if dir == 1 { 1 } else { 0 };
                            let nc = c + if dir == 2 { 0 - 1 } else if dir == 3 { 1 } else { 0 };
                            if valid(nr, nc) == 1 {
                                if grid_bit(walls, nr, nc) == 0 {
                                    if grid_bit(visited, nr, nc) == 0 {
                                        visited = grid_set_bit(visited, nr, nc);
                                        next_frontier = grid_set_bit(next_frontier, nr, nc);
                                        if nr == er {
                                            if nc == ec {
                                                result = dist;
                                                found = 1;
                                            }
                                        }
                                    }
                                }
                            }
                            dir = dir + 1;
                        }
                    }
                    c = c + 1;
                }
                r = r + 1;
            }
            current = next_frontier;
            if dist > 16 { found = 1; } // Safety: max 16 cells
        }
    }
    result
}

// Count reachable cells from (sr, sc)
fn reachable_count(walls: Int, sr: Int, sc: Int) -> Int {
    if grid_bit(walls, sr, sc) == 1 { 0 }
    else {
        let mut visited = grid_set_bit(0, sr, sc);
        let mut changed = 1;
        while changed == 1 {
            changed = 0;
            let mut r = 0;
            while r < 4 {
                let mut c = 0;
                while c < 4 {
                    if grid_bit(visited, r, c) == 1 {
                        if valid(r - 1, c) == 1 {
                            if grid_bit(walls, r - 1, c) == 0 {
                                if grid_bit(visited, r - 1, c) == 0 {
                                    visited = grid_set_bit(visited, r - 1, c);
                                    changed = 1;
                                }
                            }
                        }
                        if valid(r + 1, c) == 1 {
                            if grid_bit(walls, r + 1, c) == 0 {
                                if grid_bit(visited, r + 1, c) == 0 {
                                    visited = grid_set_bit(visited, r + 1, c);
                                    changed = 1;
                                }
                            }
                        }
                        if valid(r, c - 1) == 1 {
                            if grid_bit(walls, r, c - 1) == 0 {
                                if grid_bit(visited, r, c - 1) == 0 {
                                    visited = grid_set_bit(visited, r, c - 1);
                                    changed = 1;
                                }
                            }
                        }
                        if valid(r, c + 1) == 1 {
                            if grid_bit(walls, r, c + 1) == 0 {
                                if grid_bit(visited, r, c + 1) == 0 {
                                    visited = grid_set_bit(visited, r, c + 1);
                                    changed = 1;
                                }
                            }
                        }
                    }
                    c = c + 1;
                }
                r = r + 1;
            }
        }
        // Count bits in visited
        let mut count = 0;
        let mut i = 0;
        while i < 16 {
            if (visited / pow2(i)) % 2 == 1 { count = count + 1; }
            i = i + 1;
        }
        count
    }
}

fn test_open_grid() -> Int {
    // No walls: distance from (0,0) to (3,3) = 6 (Manhattan distance)
    let walls = 0;
    assert_eq(bfs_dist(walls, 0, 0, 3, 3), 6);
    assert_eq(bfs_dist(walls, 0, 0, 0, 0), 0);
    assert_eq(bfs_dist(walls, 0, 0, 0, 1), 1);
    assert_eq(bfs_dist(walls, 0, 0, 1, 1), 2);
    1
}

fn test_wall_barrier() -> Int {
    // Wall across row 1 except (1,3):
    // . . . .
    // # # # .
    // . . . .
    // . . . .
    let mut walls = 0;
    walls = grid_set_bit(walls, 1, 0);
    walls = grid_set_bit(walls, 1, 1);
    walls = grid_set_bit(walls, 1, 2);
    // Path must go around via (0,3) -> (1,3) -> (2,3) -> ...
    let d = bfs_dist(walls, 0, 0, 2, 0);
    // Shortest: (0,0)->(0,1)->(0,2)->(0,3)->(1,3)->(2,3)->(2,2)->(2,1)->(2,0) = 8
    assert_eq(d, 8);
    1
}

fn test_unreachable() -> Int {
    // Wall completely blocks:
    // . # . .
    // . # . .
    // . # . .
    // . # . .
    let mut walls = 0;
    walls = grid_set_bit(walls, 0, 1);
    walls = grid_set_bit(walls, 1, 1);
    walls = grid_set_bit(walls, 2, 1);
    walls = grid_set_bit(walls, 3, 1);
    // (0,0) cannot reach (0,2)
    assert_eq(bfs_dist(walls, 0, 0, 0, 2), 0 - 1);
    1
}

fn test_reachable() -> Int {
    // Open grid: all 16 cells reachable
    assert_eq(reachable_count(0, 0, 0), 16);
    // Completely walled off: just 1 cell
    let mut walls = 0;
    walls = grid_set_bit(walls, 0, 1);
    walls = grid_set_bit(walls, 1, 0);
    // (0,0) only reachable cell (neighbors are wall or out of bounds)
    assert_eq(reachable_count(walls, 0, 0), 1);
    1
}

fn test_start_is_wall() -> Int {
    let walls = grid_set_bit(0, 0, 0);
    assert_eq(bfs_dist(walls, 0, 0, 3, 3), 0 - 1);
    assert_eq(reachable_count(walls, 0, 0), 0);
    1
}

fn test_adjacent() -> Int {
    // Adjacent cells should have distance 1
    assert_eq(bfs_dist(0, 0, 0, 0, 1), 1);
    assert_eq(bfs_dist(0, 0, 0, 1, 0), 1);
    assert_eq(bfs_dist(0, 2, 2, 2, 3), 1);
    assert_eq(bfs_dist(0, 2, 2, 3, 2), 1);
    1
}

fn main() -> Int {
    test_open_grid();
    test_wall_barrier();
    test_unreachable();
    test_reachable();
    test_start_is_wall();
    test_adjacent();
    print("[OK] 628_maze_solver_aot");
    0
}
