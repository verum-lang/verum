// @test: run
// @level: L0
// @tags: aot, e2e, game-of-life, cellular-automaton, simulation
// @timeout: 30000

// Conway's Game of Life on an 8x8 grid
// Grid stored as 8 rows, each row an Int bitmask (bits 0-7)

type Grid is { r0: Int, r1: Int, r2: Int, r3: Int, r4: Int, r5: Int, r6: Int, r7: Int };

fn get_row(g: Grid, r: Int) -> Int {
    if r == 0 { g.r0 } else if r == 1 { g.r1 } else if r == 2 { g.r2 }
    else if r == 3 { g.r3 } else if r == 4 { g.r4 } else if r == 5 { g.r5 }
    else if r == 6 { g.r6 } else { g.r7 }
}

fn set_row(g: Grid, r: Int, v: Int) -> Grid {
    Grid {
        r0: if r == 0 { v } else { g.r0 },
        r1: if r == 1 { v } else { g.r1 },
        r2: if r == 2 { v } else { g.r2 },
        r3: if r == 3 { v } else { g.r3 },
        r4: if r == 4 { v } else { g.r4 },
        r5: if r == 5 { v } else { g.r5 },
        r6: if r == 6 { v } else { g.r6 },
        r7: if r == 7 { v } else { g.r7 }
    }
}

fn empty_grid() -> Grid {
    Grid { r0: 0, r1: 0, r2: 0, r3: 0, r4: 0, r5: 0, r6: 0, r7: 0 }
}

// Get cell value at (row, col)
fn get_cell(g: Grid, row: Int, col: Int) -> Int {
    if row < 0 { return 0; }
    if row > 7 { return 0; }
    if col < 0 { return 0; }
    if col > 7 { return 0; }
    let r = get_row(g, row);
    // Extract bit at position col
    let mut mask = 1;
    let mut i = 0;
    while i < col { mask = mask * 2; i = i + 1; }
    if (r / mask) % 2 == 1 { 1 } else { 0 }
}

// Set cell at (row, col) to 1
fn set_cell(g: Grid, row: Int, col: Int) -> Grid {
    let r = get_row(g, row);
    let mut mask = 1;
    let mut i = 0;
    while i < col { mask = mask * 2; i = i + 1; }
    set_row(g, row, r + mask)
}

// Count live neighbors
fn count_neighbors(g: Grid, row: Int, col: Int) -> Int {
    get_cell(g, row - 1, col - 1) + get_cell(g, row - 1, col) + get_cell(g, row - 1, col + 1) +
    get_cell(g, row, col - 1) + get_cell(g, row, col + 1) +
    get_cell(g, row + 1, col - 1) + get_cell(g, row + 1, col) + get_cell(g, row + 1, col + 1)
}

// One step of Game of Life
fn step(g: Grid) -> Grid {
    let mut next = empty_grid();
    let mut row = 0;
    while row < 8 {
        let mut new_row = 0;
        let mut col = 0;
        while col < 8 {
            let alive = get_cell(g, row, col);
            let neighbors = count_neighbors(g, row, col);
            let mut lives = 0;
            if alive == 1 {
                if neighbors == 2 { lives = 1; }
                if neighbors == 3 { lives = 1; }
            } else {
                if neighbors == 3 { lives = 1; }
            }
            if lives == 1 {
                let mut mask = 1;
                let mut i = 0;
                while i < col { mask = mask * 2; i = i + 1; }
                new_row = new_row + mask;
            }
            col = col + 1;
        }
        next = set_row(next, row, new_row);
        row = row + 1;
    }
    next
}

// Count total live cells
fn population(g: Grid) -> Int {
    let mut count = 0;
    let mut row = 0;
    while row < 8 {
        let mut col = 0;
        while col < 8 {
            count = count + get_cell(g, row, col);
            col = col + 1;
        }
        row = row + 1;
    }
    count
}

fn test_blinker() -> Int {
    // Blinker: period-2 oscillator
    // Step 0:    Step 1:
    //  .X.        ...
    //  .X.        XXX
    //  .X.        ...
    let mut g = empty_grid();
    g = set_cell(g, 1, 2);
    g = set_cell(g, 2, 2);
    g = set_cell(g, 3, 2);
    assert_eq(population(g), 3);

    let g1 = step(g);
    assert_eq(population(g1), 3);
    // Should be horizontal: row 2, cols 1,2,3
    assert_eq(get_cell(g1, 2, 1), 1);
    assert_eq(get_cell(g1, 2, 2), 1);
    assert_eq(get_cell(g1, 2, 3), 1);
    assert_eq(get_cell(g1, 1, 2), 0);
    assert_eq(get_cell(g1, 3, 2), 0);

    // Step 2 should return to original
    let g2 = step(g1);
    assert_eq(get_cell(g2, 1, 2), 1);
    assert_eq(get_cell(g2, 2, 2), 1);
    assert_eq(get_cell(g2, 3, 2), 1);
    assert_eq(get_cell(g2, 2, 1), 0);
    1
}

fn test_block() -> Int {
    // Block: still life (period 1)
    // XX
    // XX
    let mut g = empty_grid();
    g = set_cell(g, 1, 1);
    g = set_cell(g, 1, 2);
    g = set_cell(g, 2, 1);
    g = set_cell(g, 2, 2);
    assert_eq(population(g), 4);

    let g1 = step(g);
    assert_eq(population(g1), 4);
    assert_eq(get_cell(g1, 1, 1), 1);
    assert_eq(get_cell(g1, 1, 2), 1);
    assert_eq(get_cell(g1, 2, 1), 1);
    assert_eq(get_cell(g1, 2, 2), 1);
    1
}

fn test_glider() -> Int {
    // Glider moves diagonally
    // .X.
    // ..X
    // XXX
    let mut g = empty_grid();
    g = set_cell(g, 0, 1);
    g = set_cell(g, 1, 2);
    g = set_cell(g, 2, 0);
    g = set_cell(g, 2, 1);
    g = set_cell(g, 2, 2);
    assert_eq(population(g), 5);

    // After 4 steps, glider should still have 5 cells
    let mut current = g;
    let mut s = 0;
    while s < 4 {
        current = step(current);
        s = s + 1;
    }
    assert_eq(population(current), 5);
    1
}

fn main() -> Int {
    test_blinker();
    test_block();
    test_glider();
    print("[OK] 458_game_of_life_aot");
    0
}
