// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, rational, arithmetic, math
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for rational number arithmetic (fraction type)

fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }

fn gcd(a: Int, b: Int) -> Int {
    let mut x = abs_val(a);
    let mut y = abs_val(b);
    while y != 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

// Rational number as (numerator, denominator), always in reduced form
type Rat is { num: Int, den: Int };

fn rat_new(n: Int, d: Int) -> Rat {
    if d == 0 { return Rat { num: 0, den: 1 }; }
    let sign = if (n < 0 && d > 0) || (n > 0 && d < 0) { -1 } else { 1 };
    let an = abs_val(n);
    let ad = abs_val(d);
    let g = gcd(an, ad);
    Rat { num: sign * (an / g), den: ad / g }
}

fn rat_add(a: Rat, b: Rat) -> Rat {
    rat_new(a.num * b.den + b.num * a.den, a.den * b.den)
}

fn rat_sub(a: Rat, b: Rat) -> Rat {
    rat_new(a.num * b.den - b.num * a.den, a.den * b.den)
}

fn rat_mul(a: Rat, b: Rat) -> Rat {
    rat_new(a.num * b.num, a.den * b.den)
}

fn rat_div(a: Rat, b: Rat) -> Rat {
    rat_new(a.num * b.den, a.den * b.num)
}

fn rat_eq(a: Rat, b: Rat) -> Bool {
    a.num == b.num && a.den == b.den
}

fn rat_neg(a: Rat) -> Rat {
    Rat { num: -a.num, den: a.den }
}

fn rat_is_zero(a: Rat) -> Bool {
    a.num == 0
}

fn rat_is_pos(a: Rat) -> Bool {
    a.num > 0
}

fn rat_cmp(a: Rat, b: Rat) -> Int {
    // Returns -1, 0, 1
    let diff = a.num * b.den - b.num * a.den;
    if diff < 0 { -1 }
    else if diff > 0 { 1 }
    else { 0 }
}

fn test_creation() {
    let half = rat_new(1, 2);
    assert_eq(half.num, 1);
    assert_eq(half.den, 2);

    // Auto-reduction: 2/4 = 1/2
    let two_fourths = rat_new(2, 4);
    assert_eq(rat_eq(two_fourths, half), true);

    // Negative: -3/6 = -1/2
    let neg = rat_new(-3, 6);
    assert_eq(neg.num, -1);
    assert_eq(neg.den, 2);

    // Zero
    let zero = rat_new(0, 5);
    assert_eq(zero.num, 0);
    assert_eq(zero.den, 1);
}

fn test_add() {
    let half = rat_new(1, 2);
    let third = rat_new(1, 3);

    // 1/2 + 1/3 = 5/6
    let sum = rat_add(half, third);
    assert_eq(sum.num, 5);
    assert_eq(sum.den, 6);

    // 1/2 + 1/2 = 1
    let one = rat_add(half, half);
    assert_eq(one.num, 1);
    assert_eq(one.den, 1);

    // 1/3 + 2/3 = 1
    let two_thirds = rat_new(2, 3);
    let one2 = rat_add(third, two_thirds);
    assert_eq(one2.num, 1);
    assert_eq(one2.den, 1);
}

fn test_subtract() {
    let half = rat_new(1, 2);
    let third = rat_new(1, 3);

    // 1/2 - 1/3 = 1/6
    let diff = rat_sub(half, third);
    assert_eq(diff.num, 1);
    assert_eq(diff.den, 6);

    // 1/3 - 1/2 = -1/6
    let diff2 = rat_sub(third, half);
    assert_eq(diff2.num, -1);
    assert_eq(diff2.den, 6);

    // x - x = 0
    assert_eq(rat_is_zero(rat_sub(half, half)), true);
}

fn test_multiply() {
    let half = rat_new(1, 2);
    let third = rat_new(1, 3);

    // 1/2 * 1/3 = 1/6
    let prod = rat_mul(half, third);
    assert_eq(prod.num, 1);
    assert_eq(prod.den, 6);

    // 2/3 * 3/4 = 1/2
    let a = rat_new(2, 3);
    let b = rat_new(3, 4);
    let c = rat_mul(a, b);
    assert_eq(c.num, 1);
    assert_eq(c.den, 2);
}

fn test_divide() {
    let half = rat_new(1, 2);
    let third = rat_new(1, 3);

    // (1/2) / (1/3) = 3/2
    let q = rat_div(half, third);
    assert_eq(q.num, 3);
    assert_eq(q.den, 2);

    // x / x = 1
    let one = rat_div(half, half);
    assert_eq(one.num, 1);
    assert_eq(one.den, 1);
}

fn test_comparison() {
    let half = rat_new(1, 2);
    let third = rat_new(1, 3);
    let two_fourths = rat_new(2, 4);

    assert_eq(rat_cmp(half, third), 1);    // 1/2 > 1/3
    assert_eq(rat_cmp(third, half), -1);   // 1/3 < 1/2
    assert_eq(rat_cmp(half, two_fourths), 0);  // Equal
}

fn test_identities() {
    let a = rat_new(3, 7);
    let b = rat_new(5, 11);

    // a + b = b + a (commutativity)
    assert_eq(rat_eq(rat_add(a, b), rat_add(b, a)), true);

    // a * b = b * a (commutativity)
    assert_eq(rat_eq(rat_mul(a, b), rat_mul(b, a)), true);

    // a + (-a) = 0
    assert_eq(rat_is_zero(rat_add(a, rat_neg(a))), true);

    // a * (1/a) = 1
    let inv = rat_div(rat_new(1, 1), a);
    let prod = rat_mul(a, inv);
    assert_eq(prod.num, 1);
    assert_eq(prod.den, 1);
}

fn main() -> Int {
    test_creation();
    test_add();
    test_subtract();
    test_multiply();
    test_divide();
    test_comparison();
    test_identities();
    print("[OK] 226_rational_arithmetic_aot");
    0
}
