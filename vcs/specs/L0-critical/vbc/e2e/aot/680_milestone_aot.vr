// @test: run
// @level: L0
// @tags: aot, e2e, milestone, hash-table, open-addressing
// @timeout: 30000

// Milestone 680: Hash table with open addressing (linear probing)

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// Hash table with 8 slots using open addressing
// Keys stored in Arr8, values in another Arr8
// Empty slot marker: key = -1
// Tombstone marker: key = -2

fn empty_keys() -> Arr8 {
    Arr8 { v0: 0-1, v1: 0-1, v2: 0-1, v3: 0-1, v4: 0-1, v5: 0-1, v6: 0-1, v7: 0-1 }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Simple hash function
fn hash_key(key: Int) -> Int { abs_val(key * 2654435769 / 100000) % 8 }

// Insert: returns new keys array
fn ht_insert_keys(keys: Arr8, key: Int) -> Arr8 {
    let h = hash_key(key);
    let mut i = 0;
    let mut pos = h;
    let mut found = 0;
    while i < 8 {
        if found == 0 {
            let k = get8(keys, pos);
            if k == (0 - 1) {
                found = 1; // empty slot
            } else if k == (0 - 2) {
                found = 1; // tombstone
            } else if k == key {
                found = 1; // already exists, overwrite
            } else {
                pos = (pos + 1) % 8;
                i = i + 1;
            }
        } else {
            i = 8; // break
        }
    }
    if found == 1 { set8(keys, pos, key) }
    else { keys } // table full
}

// Insert: returns new values array
fn ht_insert_vals(keys: Arr8, vals: Arr8, key: Int, val: Int) -> Arr8 {
    let h = hash_key(key);
    let mut i = 0;
    let mut pos = h;
    let mut found = 0;
    while i < 8 {
        if found == 0 {
            let k = get8(keys, pos);
            if k == (0 - 1) { found = 1; }
            else if k == (0 - 2) { found = 1; }
            else if k == key { found = 1; }
            else { pos = (pos + 1) % 8; i = i + 1; }
        } else { i = 8; }
    }
    if found == 1 { set8(vals, pos, val) }
    else { vals }
}

// Lookup: returns value or -1 if not found
fn ht_get(keys: Arr8, vals: Arr8, key: Int) -> Int {
    let h = hash_key(key);
    let mut i = 0;
    let mut pos = h;
    let mut result = 0 - 1;
    let mut done = 0;
    while i < 8 {
        if done == 0 {
            let k = get8(keys, pos);
            if k == (0 - 1) {
                done = 1; // empty: not found
            } else if k == key {
                result = get8(vals, pos);
                done = 1;
            } else {
                pos = (pos + 1) % 8;
                i = i + 1;
            }
        } else { i = 8; }
    }
    result
}

// Contains: returns 1 if key exists
fn ht_contains(keys: Arr8, key: Int) -> Int {
    let h = hash_key(key);
    let mut i = 0;
    let mut pos = h;
    let mut found = 0;
    let mut done = 0;
    while i < 8 {
        if done == 0 {
            let k = get8(keys, pos);
            if k == (0 - 1) { done = 1; }
            else if k == key { found = 1; done = 1; }
            else { pos = (pos + 1) % 8; i = i + 1; }
        } else { i = 8; }
    }
    found
}

// Delete: mark as tombstone
fn ht_delete(keys: Arr8, key: Int) -> Arr8 {
    let h = hash_key(key);
    let mut i = 0;
    let mut pos = h;
    let mut done = 0;
    let mut k_out = keys;
    while i < 8 {
        if done == 0 {
            let k = get8(keys, pos);
            if k == (0 - 1) { done = 1; }
            else if k == key { k_out = set8(keys, pos, 0 - 2); done = 1; }
            else { pos = (pos + 1) % 8; i = i + 1; }
        } else { i = 8; }
    }
    k_out
}

// Count entries
fn ht_count(keys: Arr8) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 8 {
        let k = get8(keys, i);
        if k != (0 - 1) {
            if k != (0 - 2) { count = count + 1; }
        }
        i = i + 1;
    }
    count
}

fn test_basic() -> Int {
    let mut keys = empty_keys();
    let mut vals = zeros();
    assert_eq(ht_count(keys), 0);

    // Insert (10, 100), (20, 200), (30, 300)
    vals = ht_insert_vals(keys, vals, 10, 100);
    keys = ht_insert_keys(keys, 10);
    vals = ht_insert_vals(keys, vals, 20, 200);
    keys = ht_insert_keys(keys, 20);
    vals = ht_insert_vals(keys, vals, 30, 300);
    keys = ht_insert_keys(keys, 30);

    assert_eq(ht_count(keys), 3);
    assert_eq(ht_get(keys, vals, 10), 100);
    assert_eq(ht_get(keys, vals, 20), 200);
    assert_eq(ht_get(keys, vals, 30), 300);
    assert_eq(ht_get(keys, vals, 99), 0 - 1); // not found
    1
}

fn test_contains() -> Int {
    let mut keys = empty_keys();
    let mut vals = zeros();
    vals = ht_insert_vals(keys, vals, 5, 50);
    keys = ht_insert_keys(keys, 5);
    vals = ht_insert_vals(keys, vals, 15, 150);
    keys = ht_insert_keys(keys, 15);

    assert_eq(ht_contains(keys, 5), 1);
    assert_eq(ht_contains(keys, 15), 1);
    assert_eq(ht_contains(keys, 25), 0);
    1
}

fn test_delete() -> Int {
    let mut keys = empty_keys();
    let mut vals = zeros();
    vals = ht_insert_vals(keys, vals, 10, 100);
    keys = ht_insert_keys(keys, 10);
    vals = ht_insert_vals(keys, vals, 20, 200);
    keys = ht_insert_keys(keys, 20);
    vals = ht_insert_vals(keys, vals, 30, 300);
    keys = ht_insert_keys(keys, 30);

    assert_eq(ht_count(keys), 3);
    keys = ht_delete(keys, 20);
    assert_eq(ht_count(keys), 2);
    assert_eq(ht_contains(keys, 20), 0);
    // Other keys still accessible
    assert_eq(ht_get(keys, vals, 10), 100);
    assert_eq(ht_get(keys, vals, 30), 300);
    1
}

fn test_overwrite() -> Int {
    let mut keys = empty_keys();
    let mut vals = zeros();
    vals = ht_insert_vals(keys, vals, 42, 100);
    keys = ht_insert_keys(keys, 42);
    assert_eq(ht_get(keys, vals, 42), 100);

    // Overwrite with new value
    vals = ht_insert_vals(keys, vals, 42, 999);
    keys = ht_insert_keys(keys, 42);
    assert_eq(ht_get(keys, vals, 42), 999);
    assert_eq(ht_count(keys), 1); // still just one entry
    1
}

fn test_collision_chain() -> Int {
    // Insert multiple keys that may collide
    let mut keys = empty_keys();
    let mut vals = zeros();
    let mut i = 0;
    while i < 5 {
        let key = i * 8 + 3; // keys: 3, 11, 19, 27, 35
        vals = ht_insert_vals(keys, vals, key, key * 10);
        keys = ht_insert_keys(keys, key);
        i = i + 1;
    }
    assert_eq(ht_count(keys), 5);
    // Verify all retrievable
    assert_eq(ht_get(keys, vals, 3), 30);
    assert_eq(ht_get(keys, vals, 11), 110);
    assert_eq(ht_get(keys, vals, 19), 190);
    assert_eq(ht_get(keys, vals, 27), 270);
    assert_eq(ht_get(keys, vals, 35), 350);
    1
}

fn main() -> Int {
    test_basic();
    test_contains();
    test_delete();
    test_overwrite();
    test_collision_chain();
    print("[OK] 680_milestone_aot");
    0
}
