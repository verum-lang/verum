// @test: run
// @level: L0
// @tags: aot, e2e, roman-numerals, conversion, encoding
// @timeout: 30000

// Roman numeral encoding/decoding using integer-encoded symbols
// I=1, V=5, X=10, L=50, C=100, D=500, M=1000
// Store as array of symbol values

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Decode roman numeral array to integer
// Uses subtractive rule: if current < next, subtract current
fn roman_decode(symbols: Arr8, n: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        let cur = get8(symbols, i);
        if i + 1 < n {
            let next = get8(symbols, i + 1);
            if cur < next {
                total = total - cur;
            } else {
                total = total + cur;
            }
        } else {
            total = total + cur;
        }
        i = i + 1;
    }
    total
}

// Encode integer to roman numeral array (returns length)
fn roman_encode_len(num: Int) -> Int {
    let mut n = num;
    let mut count = 0;
    // M = 1000
    while n >= 1000 { count = count + 1; n = n - 1000; }
    // CM = 900
    if n >= 900 { count = count + 2; n = n - 900; }
    // D = 500
    if n >= 500 { count = count + 1; n = n - 500; }
    // CD = 400
    if n >= 400 { count = count + 2; n = n - 400; }
    // C = 100
    while n >= 100 { count = count + 1; n = n - 100; }
    // XC = 90
    if n >= 90 { count = count + 2; n = n - 90; }
    // L = 50
    if n >= 50 { count = count + 1; n = n - 50; }
    // XL = 40
    if n >= 40 { count = count + 2; n = n - 40; }
    // X = 10
    while n >= 10 { count = count + 1; n = n - 10; }
    // IX = 9
    if n >= 9 { count = count + 2; n = n - 9; }
    // V = 5
    if n >= 5 { count = count + 1; n = n - 5; }
    // IV = 4
    if n >= 4 { count = count + 2; n = n - 4; }
    // I = 1
    while n >= 1 { count = count + 1; n = n - 1; }
    count
}

fn roman_encode(num: Int) -> Arr8 {
    let mut result = zeros();
    let mut n = num;
    let mut idx = 0;
    while n >= 1000 { result = set8(result, idx, 1000); idx = idx + 1; n = n - 1000; }
    if n >= 900 { result = set8(result, idx, 100); idx = idx + 1; result = set8(result, idx, 1000); idx = idx + 1; n = n - 900; }
    if n >= 500 { result = set8(result, idx, 500); idx = idx + 1; n = n - 500; }
    if n >= 400 { result = set8(result, idx, 100); idx = idx + 1; result = set8(result, idx, 500); idx = idx + 1; n = n - 400; }
    while n >= 100 { result = set8(result, idx, 100); idx = idx + 1; n = n - 100; }
    if n >= 90 { result = set8(result, idx, 10); idx = idx + 1; result = set8(result, idx, 100); idx = idx + 1; n = n - 90; }
    if n >= 50 { result = set8(result, idx, 50); idx = idx + 1; n = n - 50; }
    if n >= 40 { result = set8(result, idx, 10); idx = idx + 1; result = set8(result, idx, 50); idx = idx + 1; n = n - 40; }
    while n >= 10 { result = set8(result, idx, 10); idx = idx + 1; n = n - 10; }
    if n >= 9 { result = set8(result, idx, 1); idx = idx + 1; result = set8(result, idx, 10); idx = idx + 1; n = n - 9; }
    if n >= 5 { result = set8(result, idx, 5); idx = idx + 1; n = n - 5; }
    if n >= 4 { result = set8(result, idx, 1); idx = idx + 1; result = set8(result, idx, 5); idx = idx + 1; n = n - 4; }
    while n >= 1 { result = set8(result, idx, 1); idx = idx + 1; n = n - 1; }
    result
}

fn test_decode_simple() -> Int {
    // III = 3
    let three = Arr8 { v0: 1, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(three, 3), 3);
    // VII = 7
    let seven = Arr8 { v0: 5, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(seven, 3), 7);
    // XII = 12
    let twelve = Arr8 { v0: 10, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(twelve, 3), 12);
    1
}

fn test_decode_subtractive() -> Int {
    // IV = 4
    let four = Arr8 { v0: 1, v1: 5, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(four, 2), 4);
    // IX = 9
    let nine = Arr8 { v0: 1, v1: 10, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(nine, 2), 9);
    // XL = 40
    let forty = Arr8 { v0: 10, v1: 50, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(forty, 2), 40);
    // XC = 90
    let ninety = Arr8 { v0: 10, v1: 100, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(ninety, 2), 90);
    // CD = 400
    let fourhundred = Arr8 { v0: 100, v1: 500, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(fourhundred, 2), 400);
    // CM = 900
    let ninehundred = Arr8 { v0: 100, v1: 1000, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(roman_decode(ninehundred, 2), 900);
    1
}

fn test_encode_decode() -> Int {
    // Encode then decode should give original
    // 4 = IV
    let enc4 = roman_encode(4);
    let len4 = roman_encode_len(4);
    assert_eq(len4, 2);
    assert_eq(roman_decode(enc4, len4), 4);
    // 9 = IX
    let enc9 = roman_encode(9);
    let len9 = roman_encode_len(9);
    assert_eq(roman_decode(enc9, len9), 9);
    // 14 = XIV
    let enc14 = roman_encode(14);
    let len14 = roman_encode_len(14);
    assert_eq(roman_decode(enc14, len14), 14);
    // 42 = XLII
    let enc42 = roman_encode(42);
    let len42 = roman_encode_len(42);
    assert_eq(roman_decode(enc42, len42), 42);
    1
}

fn test_encode_structure() -> Int {
    // 4 = IV: [1, 5]
    let enc = roman_encode(4);
    assert_eq(get8(enc, 0), 1);
    assert_eq(get8(enc, 1), 5);
    // 9 = IX: [1, 10]
    let enc9 = roman_encode(9);
    assert_eq(get8(enc9, 0), 1);
    assert_eq(get8(enc9, 1), 10);
    // 3 = III: [1, 1, 1]
    let enc3 = roman_encode(3);
    assert_eq(get8(enc3, 0), 1);
    assert_eq(get8(enc3, 1), 1);
    assert_eq(get8(enc3, 2), 1);
    assert_eq(roman_encode_len(3), 3);
    1
}

fn test_larger_numbers() -> Int {
    // 99 = XCIX = [10, 100, 1, 10] -> 4 symbols
    let enc99 = roman_encode(99);
    let len99 = roman_encode_len(99);
    assert_eq(len99, 4);
    assert_eq(roman_decode(enc99, len99), 99);
    // 58 = LVIII = [50, 5, 1, 1, 1] -> 5 symbols
    // Wait: 58 = L(50) + V(5) + III = LVIII = [50, 5, 1, 1, 1]
    let enc58 = roman_encode(58);
    let len58 = roman_encode_len(58);
    assert_eq(len58, 5);
    assert_eq(roman_decode(enc58, len58), 58);
    1
}

fn test_single_symbol() -> Int {
    assert_eq(roman_encode_len(1), 1);
    assert_eq(roman_encode_len(5), 1);
    assert_eq(roman_encode_len(10), 1);
    assert_eq(roman_encode_len(50), 1);
    assert_eq(roman_encode_len(100), 1);
    assert_eq(roman_encode_len(500), 1);
    assert_eq(roman_encode_len(1000), 1);
    1
}

fn main() -> Int {
    test_decode_simple();
    test_decode_subtractive();
    test_encode_decode();
    test_encode_structure();
    test_larger_numbers();
    test_single_symbol();
    print("[OK] 626_roman_numerals_aot");
    0
}
