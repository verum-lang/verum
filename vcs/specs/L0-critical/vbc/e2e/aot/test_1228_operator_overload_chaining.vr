// @test: run
// @level: L0
// @tier: 0
// @tags: operator-overloading, chaining, method-dispatch, e2e
// @description: Test chained operator overloading where result of one op is receiver for next

type Vec2 is { x: Float, y: Float };

implement Vec2 {
    fn new(x: Float, y: Float) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn add(&self, other: Vec2) -> Vec2 {
        Vec2.new(self.x + other.x, self.y + other.y)
    }

    fn sub(&self, other: Vec2) -> Vec2 {
        Vec2.new(self.x - other.x, self.y - other.y)
    }

    fn mul(&self, other: Vec2) -> Vec2 {
        Vec2.new(self.x * other.x, self.y * other.y)
    }

    fn dot(&self, other: Vec2) -> Float {
        self.x * other.x + self.y * other.y
    }
}

fn approx(a: Float, b: Float) -> Bool {
    let d = a - b;
    let abs = if d < 0.0 { 0.0 - d } else { d };
    abs < 0.01
}

fn main() -> Int {
    let mut f = 0;
    let a = Vec2.new(1.0, 2.0);
    let b = Vec2.new(3.0, 4.0);
    let c = Vec2.new(2.0, 2.0);

    // Test 1: basic operator overload
    let sum = a + b;
    if !approx(sum.x, 4.0) || !approx(sum.y, 6.0) {
        print(f"FAIL 1: ({sum.x}, {sum.y})");
        f = f + 1;
    }

    // Test 2: chained operators via let binding
    let result = a + b - c;
    if !approx(result.x, 2.0) || !approx(result.y, 4.0) {
        print(f"FAIL 2: ({result.x}, {result.y})");
        f = f + 1;
    }

    // Test 3: operator result used as method receiver
    let d = (a + b).dot(c);
    if !approx(d, 20.0) {
        print(f"FAIL 3: dot = {d}");
        f = f + 1;
    }

    // Test 4: three chained operators
    let r2 = a + b + c;
    if !approx(r2.x, 6.0) || !approx(r2.y, 8.0) {
        print(f"FAIL 4: ({r2.x}, {r2.y})");
        f = f + 1;
    }

    // Test 5: mixed operators
    let r3 = a * c + b;
    if !approx(r3.x, 5.0) || !approx(r3.y, 8.0) {
        print(f"FAIL 5: ({r3.x}, {r3.y})");
        f = f + 1;
    }

    if f == 0 {
        print("All operator overload chaining tests passed");
    }
    f
}
