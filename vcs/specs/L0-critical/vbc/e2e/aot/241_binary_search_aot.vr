// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, binary, search, algorithm
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for binary search on sorted arrays

type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int,
    a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int,
    a12: Int, a13: Int, a14: Int, a15: Int,
    len: Int
};

fn arr16_new() -> Arr16 {
    Arr16 {
        a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
        a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0,
        len: 0
    }
}

fn arr16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 }
    else if i == 8 { a.a8 } else if i == 9 { a.a9 }
    else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 }
    else if i == 14 { a.a14 } else if i == 15 { a.a15 }
    else { 0 }
}

fn arr16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 }, a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 }, a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 }, a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 }, a15: if i == 15 { v } else { a.a15 },
        len: a.len
    }
}

// Binary search: returns index or -1
fn binary_search(a: Arr16, target: Int) -> Int {
    let mut lo = 0;
    let mut hi = a.len - 1;
    while lo <= hi {
        let mid = lo + (hi - lo) / 2;
        let val = arr16_get(a, mid);
        if val == target {
            return mid;
        } else if val < target {
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    -1
}

// Lower bound: first index where arr[i] >= target
fn lower_bound(a: Arr16, target: Int) -> Int {
    let mut lo = 0;
    let mut hi = a.len;
    while lo < hi {
        let mid = lo + (hi - lo) / 2;
        if arr16_get(a, mid) < target {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    lo
}

// Upper bound: first index where arr[i] > target
fn upper_bound(a: Arr16, target: Int) -> Int {
    let mut lo = 0;
    let mut hi = a.len;
    while lo < hi {
        let mid = lo + (hi - lo) / 2;
        if arr16_get(a, mid) <= target {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    lo
}

// Count occurrences of target in sorted array
fn count_of(a: Arr16, target: Int) -> Int {
    upper_bound(a, target) - lower_bound(a, target)
}

fn make_sorted_10() -> Arr16 {
    let mut a = arr16_new();
    // [2, 5, 8, 11, 14, 17, 20, 23, 26, 29]
    a = arr16_set(a, 0, 2);
    a = arr16_set(a, 1, 5);
    a = arr16_set(a, 2, 8);
    a = arr16_set(a, 3, 11);
    a = arr16_set(a, 4, 14);
    a = arr16_set(a, 5, 17);
    a = arr16_set(a, 6, 20);
    a = arr16_set(a, 7, 23);
    a = arr16_set(a, 8, 26);
    a = arr16_set(a, 9, 29);
    Arr16 {
        a0: a.a0, a1: a.a1, a2: a.a2, a3: a.a3,
        a4: a.a4, a5: a.a5, a6: a.a6, a7: a.a7,
        a8: a.a8, a9: a.a9, a10: a.a10, a11: a.a11,
        a12: a.a12, a13: a.a13, a14: a.a14, a15: a.a15,
        len: 10
    }
}

fn test_basic_search() {
    let a = make_sorted_10();
    assert_eq(binary_search(a, 2), 0);
    assert_eq(binary_search(a, 14), 4);
    assert_eq(binary_search(a, 29), 9);
    assert_eq(binary_search(a, 1), -1);
    assert_eq(binary_search(a, 30), -1);
    assert_eq(binary_search(a, 10), -1);
}

fn test_bounds() {
    let a = make_sorted_10();
    // Lower bound of existing element
    assert_eq(lower_bound(a, 8), 2);
    assert_eq(lower_bound(a, 2), 0);
    assert_eq(lower_bound(a, 29), 9);
    // Lower bound of non-existing - insertion point
    assert_eq(lower_bound(a, 1), 0);
    assert_eq(lower_bound(a, 10), 3);
    assert_eq(lower_bound(a, 30), 10);
    // Upper bound
    assert_eq(upper_bound(a, 8), 3);
    assert_eq(upper_bound(a, 2), 1);
    assert_eq(upper_bound(a, 29), 10);
}

fn test_duplicates() {
    // [1, 3, 3, 3, 5, 7, 7, 9]
    let mut a = arr16_new();
    a = arr16_set(a, 0, 1);
    a = arr16_set(a, 1, 3);
    a = arr16_set(a, 2, 3);
    a = arr16_set(a, 3, 3);
    a = arr16_set(a, 4, 5);
    a = arr16_set(a, 5, 7);
    a = arr16_set(a, 6, 7);
    a = arr16_set(a, 7, 9);
    let a = Arr16 {
        a0: a.a0, a1: a.a1, a2: a.a2, a3: a.a3,
        a4: a.a4, a5: a.a5, a6: a.a6, a7: a.a7,
        a8: a.a8, a9: a.a9, a10: a.a10, a11: a.a11,
        a12: a.a12, a13: a.a13, a14: a.a14, a15: a.a15,
        len: 8
    };

    assert_eq(count_of(a, 3), 3);
    assert_eq(count_of(a, 7), 2);
    assert_eq(count_of(a, 1), 1);
    assert_eq(count_of(a, 4), 0);

    assert_eq(lower_bound(a, 3), 1);
    assert_eq(upper_bound(a, 3), 4);
}

fn test_single_element() {
    let mut a = arr16_new();
    a = arr16_set(a, 0, 42);
    let a = Arr16 {
        a0: a.a0, a1: a.a1, a2: a.a2, a3: a.a3,
        a4: a.a4, a5: a.a5, a6: a.a6, a7: a.a7,
        a8: a.a8, a9: a.a9, a10: a.a10, a11: a.a11,
        a12: a.a12, a13: a.a13, a14: a.a14, a15: a.a15,
        len: 1
    };
    assert_eq(binary_search(a, 42), 0);
    assert_eq(binary_search(a, 0), -1);
    assert_eq(lower_bound(a, 42), 0);
    assert_eq(upper_bound(a, 42), 1);
}

fn main() -> Int {
    test_basic_search();
    test_bounds();
    test_duplicates();
    test_single_element();
    print("[OK] 241_binary_search_aot");
    0
}
