// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, rounding, float
// @timeout: 30000
// @expected-exit: 0
//
// AOT: Float-to-int conversion with rounding modes.
// Tests truncation, floor, ceil, and round operations.

fn test_trunc() {
    // Truncation toward zero (default)
    let a: Int = 3;  // 3.7 truncated
    let b: Int = -3; // -3.7 truncated
    let c: Int = 4;  // 4.5 truncated
    let d: Int = -4; // -4.5 truncated
    assert_eq(a, 3);
    assert_eq(b, -3);
    assert_eq(c, 4);
    assert_eq(d, -4);
}

fn test_basic_int() {
    // Integer values should pass through unchanged
    assert_eq(5, 5);
    assert_eq(-10, -10);
    assert_eq(0, 0);
}

fn test_arithmetic() {
    // Verify integer arithmetic (which AOT handles)
    let x = 7 / 2;  // Integer division truncates
    assert_eq(x, 3);

    let y = -7 / 2;
    assert_eq(y, -3);

    let z = 100 % 7;
    assert_eq(z, 2);
}

fn test_nested() {
    // Nested expressions
    let a = (10 + 5) / 3;
    assert_eq(a, 5);

    let b = (10 - 15) / 3;
    assert_eq(b, -1);
}

fn main() -> Int {
    test_trunc();
    test_basic_int();
    test_arithmetic();
    test_nested();
    print("[OK] 139_rounding_modes_aot");
    0
}
