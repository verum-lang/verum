// @test: run
// @level: L0
// @tags: aot, e2e, interval, tree, overlap
// @timeout: 30000

// Interval operations using parallel arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

// Check if intervals [a_lo, a_hi] and [b_lo, b_hi] overlap
fn overlaps(a_lo: Int, a_hi: Int, b_lo: Int, b_hi: Int) -> Int {
    if a_lo <= b_hi {
        if b_lo <= a_hi { 1 } else { 0 }
    } else { 0 }
}

// Count overlapping pairs among n intervals
fn count_overlaps(lo: Arr8, hi: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        let mut j = i + 1;
        while j < n {
            count = count + overlaps(get8(lo, i), get8(hi, i), get8(lo, j), get8(hi, j));
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Total coverage: merge intervals and sum lengths
// Simple O(n^2) sweep approach
fn total_coverage(lo: Arr8, hi: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    // Find range
    let mut lo_min = get8(lo, 0);
    let mut hi_max = get8(hi, 0);
    let mut i = 1;
    while i < n {
        if get8(lo, i) < lo_min { lo_min = get8(lo, i); }
        if get8(hi, i) > hi_max { hi_max = get8(hi, i); }
        i = i + 1;
    }

    // Count each point covered by at least one interval
    let mut coverage = 0;
    let mut pt = lo_min;
    while pt <= hi_max {
        let mut covered = 0;
        let mut j = 0;
        while j < n {
            if pt >= get8(lo, j) {
                if pt <= get8(hi, j) {
                    covered = 1;
                    j = n; // break
                }
            }
            j = j + 1;
        }
        coverage = coverage + covered;
        pt = pt + 1;
    }
    coverage
}

// Maximum depth (max number of overlapping intervals at any point)
fn max_depth(lo: Arr8, hi: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut lo_min = get8(lo, 0);
    let mut hi_max = get8(hi, 0);
    let mut i = 1;
    while i < n {
        if get8(lo, i) < lo_min { lo_min = get8(lo, i); }
        if get8(hi, i) > hi_max { hi_max = get8(hi, i); }
        i = i + 1;
    }

    let mut best = 0;
    let mut pt = lo_min;
    while pt <= hi_max {
        let mut depth = 0;
        let mut j = 0;
        while j < n {
            if pt >= get8(lo, j) {
                if pt <= get8(hi, j) { depth = depth + 1; }
            }
            j = j + 1;
        }
        if depth > best { best = depth; }
        pt = pt + 1;
    }
    best
}

fn test_overlaps() -> Int {
    assert_eq(overlaps(1, 5, 3, 7), 1);
    assert_eq(overlaps(1, 3, 5, 7), 0);
    assert_eq(overlaps(1, 5, 5, 7), 1); // touching
    1
}

fn test_count_pairs() -> Int {
    // Intervals: [1,5], [3,7], [6,10], [12,15]
    let lo = Arr8 { v0: 1, v1: 3, v2: 6, v3: 12, v4: 0, v5: 0, v6: 0, v7: 0 };
    let hi = Arr8 { v0: 5, v1: 7, v2: 10, v3: 15, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Pairs: (0,1)=[1,5]&[3,7]=yes, (0,2)=[1,5]&[6,10]=no, (0,3)=no
    // (1,2)=[3,7]&[6,10]=yes, (1,3)=no, (2,3)=no
    assert_eq(count_overlaps(lo, hi, 4), 2);
    1
}

fn test_coverage() -> Int {
    // Intervals: [1,3], [2,5], [8,10]
    // Coverage: 1,2,3,4,5,8,9,10 = 8 points
    let lo = Arr8 { v0: 1, v1: 2, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let hi = Arr8 { v0: 3, v1: 5, v2: 10, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(total_coverage(lo, hi, 3), 8);
    1
}

fn test_max_depth() -> Int {
    // Intervals: [1,5], [2,6], [4,8]
    // At point 4 or 5: all three overlap -> depth 3
    let lo = Arr8 { v0: 1, v1: 2, v2: 4, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let hi = Arr8 { v0: 5, v1: 6, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_depth(lo, hi, 3), 3);
    1
}

fn main() -> Int {
    test_overlaps();
    test_count_pairs();
    test_coverage();
    test_max_depth();
    print("[OK] 424_interval_tree_aot");
    0
}
