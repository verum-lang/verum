// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, sparse-table, rmq, range-minimum-query
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Sparse Table (Range Minimum Query).
// Build: O(n log n) preprocessing.
// Query: O(1) minimum over any subrange.
// For n=8, log2(8)=3, so we need 4 levels (0,1,2,3).
// table[k][i] = min of arr[i..i+2^k-1]

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 { Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 } }
fn a8_fill(v: Int) -> Arr8 { Arr8 { a0: v, a1: v, a2: v, a3: v, a4: v, a5: v, a6: v, a7: v } }

fn min_val(a: Int, bv: Int) -> Int {
    if a < bv { a } else { bv }
}

// Sparse table: 4 levels (k=0,1,2,3) each with 8 entries
// table[k] = Arr8 where table[k][i] = min(arr[i..i+2^k])
type SparseTable is { lv0: Arr8, lv1: Arr8, lv2: Arr8, lv3: Arr8, n: Int };

fn st_level(st: SparseTable, k: Int) -> Arr8 {
    if k == 0 { st.lv0 }
    else if k == 1 { st.lv1 }
    else if k == 2 { st.lv2 }
    else { st.lv3 }
}

fn st_get(st: SparseTable, k: Int, i: Int) -> Int {
    a8_get(st_level(st, k), i)
}

// Build sparse table from array of size n (max 8)
fn st_build(arr: Arr8, n: Int) -> SparseTable {
    // Level 0: table[0][i] = arr[i]
    let lv0 = arr;

    // Level 1: table[1][i] = min(table[0][i], table[0][i+1])
    let mut lv1 = a8_fill(999999);
    let mut i = 0;
    while i + 1 < n {
        lv1 = a8_set(lv1, i, min_val(a8_get(lv0, i), a8_get(lv0, i + 1)));
        i = i + 1;
    }

    // Level 2: table[2][i] = min(table[1][i], table[1][i+2])
    let mut lv2 = a8_fill(999999);
    i = 0;
    while i + 3 < n {
        lv2 = a8_set(lv2, i, min_val(a8_get(lv1, i), a8_get(lv1, i + 2)));
        i = i + 1;
    }

    // Level 3: table[3][i] = min(table[2][i], table[2][i+4])
    let mut lv3 = a8_fill(999999);
    i = 0;
    while i + 7 < n {
        lv3 = a8_set(lv3, i, min_val(a8_get(lv2, i), a8_get(lv2, i + 4)));
        i = i + 1;
    }

    SparseTable { lv0: lv0, lv1: lv1, lv2: lv2, lv3: lv3, n: n }
}

// Floor of log2 for values 1-8
fn log2_floor(x: Int) -> Int {
    if x >= 8 { 3 }
    else if x >= 4 { 2 }
    else if x >= 2 { 1 }
    else { 0 }
}

// Power of 2
fn pow2(k: Int) -> Int {
    if k == 0 { 1 }
    else if k == 1 { 2 }
    else if k == 2 { 4 }
    else { 8 }
}

// Range minimum query: min of arr[lo..hi] (inclusive)
fn rmq(st: SparseTable, lo: Int, hi: Int) -> Int {
    let range_len = hi - lo + 1;
    let k = log2_floor(range_len);
    let pk = pow2(k);
    min_val(st_get(st, k, lo), st_get(st, k, hi - pk + 1))
}

// Naive range minimum for verification
fn naive_rmq(arr: Arr8, lo: Int, hi: Int) -> Int {
    let mut result = a8_get(arr, lo);
    let mut i = lo + 1;
    while i <= hi {
        result = min_val(result, a8_get(arr, i));
        i = i + 1;
    }
    result
}

// === Tests ===

fn test_build_level0() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    // Level 0 should be the array itself
    let mut i = 0;
    while i < 8 {
        assert_eq(st_get(st, 0, i), a8_get(arr, i));
        i = i + 1;
    }
}

fn test_build_level1() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    // Level 1: min of pairs
    assert_eq(st_get(st, 1, 0), 2); // min(5,2)
    assert_eq(st_get(st, 1, 1), 2); // min(2,8)
    assert_eq(st_get(st, 1, 2), 1); // min(8,1)
    assert_eq(st_get(st, 1, 3), 1); // min(1,4)
    assert_eq(st_get(st, 1, 4), 4); // min(4,7)
    assert_eq(st_get(st, 1, 5), 3); // min(7,3)
    assert_eq(st_get(st, 1, 6), 3); // min(3,6)
}

fn test_build_level2() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    // Level 2: min of 4 elements
    assert_eq(st_get(st, 2, 0), 1); // min(5,2,8,1)
    assert_eq(st_get(st, 2, 1), 1); // min(2,8,1,4)
    assert_eq(st_get(st, 2, 2), 1); // min(8,1,4,7)
    assert_eq(st_get(st, 2, 3), 1); // min(1,4,7,3)
    assert_eq(st_get(st, 2, 4), 3); // min(4,7,3,6)
}

fn test_build_level3() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    // Level 3: min of all 8 elements
    assert_eq(st_get(st, 3, 0), 1);
}

fn test_rmq_single_element() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    // Single element queries
    assert_eq(rmq(st, 0, 0), 5);
    assert_eq(rmq(st, 1, 1), 2);
    assert_eq(rmq(st, 3, 3), 1);
    assert_eq(rmq(st, 7, 7), 6);
}

fn test_rmq_pairs() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    assert_eq(rmq(st, 0, 1), 2);
    assert_eq(rmq(st, 2, 3), 1);
    assert_eq(rmq(st, 6, 7), 3);
}

fn test_rmq_full_range() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    assert_eq(rmq(st, 0, 7), 1);
}

fn test_rmq_various_ranges() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    // Range [0, 3] = min(5,2,8,1) = 1
    assert_eq(rmq(st, 0, 3), 1);
    // Range [4, 7] = min(4,7,3,6) = 3
    assert_eq(rmq(st, 4, 7), 3);
    // Range [1, 5] = min(2,8,1,4,7) = 1
    assert_eq(rmq(st, 1, 5), 1);
    // Range [2, 6] = min(8,1,4,7,3) = 1
    assert_eq(rmq(st, 2, 6), 1);
    // Range [4, 6] = min(4,7,3) = 3
    assert_eq(rmq(st, 4, 6), 3);
    // Range [5, 7] = min(7,3,6) = 3
    assert_eq(rmq(st, 5, 7), 3);
}

fn test_rmq_matches_naive() {
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let st = st_build(arr, 8);
    // Test all ranges
    let mut lo = 0;
    while lo < 8 {
        let mut hi = lo;
        while hi < 8 {
            assert_eq(rmq(st, lo, hi), naive_rmq(arr, lo, hi));
            hi = hi + 1;
        }
        lo = lo + 1;
    }
}

fn test_sorted_array() {
    let arr = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 6, a6: 7, a7: 8 };
    let st = st_build(arr, 8);
    // In a sorted array, min of any range is the leftmost element
    assert_eq(rmq(st, 0, 7), 1);
    assert_eq(rmq(st, 3, 7), 4);
    assert_eq(rmq(st, 5, 7), 6);
}

fn test_reverse_sorted() {
    let arr = Arr8 { a0: 8, a1: 7, a2: 6, a3: 5, a4: 4, a5: 3, a6: 2, a7: 1 };
    let st = st_build(arr, 8);
    // Min of range is rightmost element
    assert_eq(rmq(st, 0, 7), 1);
    assert_eq(rmq(st, 0, 3), 5);
    assert_eq(rmq(st, 0, 0), 8);
}

fn test_all_same() {
    let arr = a8_fill(42);
    let st = st_build(arr, 8);
    assert_eq(rmq(st, 0, 7), 42);
    assert_eq(rmq(st, 2, 5), 42);
    assert_eq(rmq(st, 4, 4), 42);
}

fn test_smaller_array() {
    // Only 4 elements
    let arr = Arr8 { a0: 10, a1: 3, a2: 7, a3: 5, a4: 0, a5: 0, a6: 0, a7: 0 };
    let st = st_build(arr, 4);
    assert_eq(rmq(st, 0, 3), 3);
    assert_eq(rmq(st, 0, 1), 3);
    assert_eq(rmq(st, 2, 3), 5);
    assert_eq(rmq(st, 1, 2), 3);
}

fn test_log2_floor() {
    assert_eq(log2_floor(1), 0);
    assert_eq(log2_floor(2), 1);
    assert_eq(log2_floor(3), 1);
    assert_eq(log2_floor(4), 2);
    assert_eq(log2_floor(5), 2);
    assert_eq(log2_floor(6), 2);
    assert_eq(log2_floor(7), 2);
    assert_eq(log2_floor(8), 3);
}

fn test_negative_values() {
    let arr = Arr8 { a0: -5, a1: -2, a2: -8, a3: -1, a4: -4, a5: -7, a6: -3, a7: -6 };
    let st = st_build(arr, 8);
    assert_eq(rmq(st, 0, 7), -8);
    assert_eq(rmq(st, 0, 1), -5);
    assert_eq(rmq(st, 3, 5), -7);
}

fn main() -> Int {
    test_build_level0();
    test_build_level1();
    test_build_level2();
    test_build_level3();
    test_rmq_single_element();
    test_rmq_pairs();
    test_rmq_full_range();
    test_rmq_various_ranges();
    test_rmq_matches_naive();
    test_sorted_array();
    test_reverse_sorted();
    test_all_same();
    test_smaller_array();
    test_log2_floor();
    test_negative_values();
    print("[OK] 355_sparse_table_aot");
    0
}
