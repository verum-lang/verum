// @test: run
// @level: L0
// @tags: aot, e2e, codec, encoding, decoding
// @timeout: 30000

// Various encoding/decoding schemes

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// VarInt encoding: 7 bits per byte, high bit = continuation
// Encode a number into VarInt format, return number of bytes used
fn varint_encode_len(n: Int) -> Int {
    if n < 128 { return 1; }
    if n < 16384 { return 2; }
    if n < 2097152 { return 3; }
    if n < 268435456 { return 4; }
    5
}

// Encode VarInt into array (each element is one byte 0-255)
fn varint_encode(n: Int, out: Arr8) -> Arr8 {
    let mut val = n;
    let mut result = out;
    let mut i = 0;
    while val >= 128 {
        result = set8(result, i, (val % 128) + 128); // low 7 bits + continuation
        val = val / 128;
        i = i + 1;
    }
    result = set8(result, i, val);
    result
}

// Decode VarInt from array, return the number
fn varint_decode(data: Arr8) -> Int {
    let mut result = 0;
    let mut shift = 1;
    let mut i = 0;
    let mut cont = 1;
    while cont == 1 {
        let b = get8(data, i);
        result = result + (b % 128) * shift;
        shift = shift * 128;
        if b < 128 { cont = 0; }
        i = i + 1;
        if i >= 8 { cont = 0; }
    }
    result
}

// Delta encoding: store differences between consecutive values
fn delta_encode(data: Arr8, n: Int) -> Arr8 {
    let mut result = zeros();
    result = set8(result, 0, get8(data, 0)); // first value as-is
    let mut i = 1;
    while i < n {
        result = set8(result, i, get8(data, i) - get8(data, i - 1));
        i = i + 1;
    }
    result
}

fn delta_decode(encoded: Arr8, n: Int) -> Arr8 {
    let mut result = zeros();
    result = set8(result, 0, get8(encoded, 0));
    let mut i = 1;
    while i < n {
        result = set8(result, i, get8(result, i - 1) + get8(encoded, i));
        i = i + 1;
    }
    result
}

// XOR-based simple cipher
fn xor_cipher(data: Arr8, n: Int, key: Int) -> Arr8 {
    // Simulate XOR using bit operations
    let mut result = zeros();
    let mut i = 0;
    while i < n {
        let val = get8(data, i);
        // XOR val with key bit by bit
        let mut xored = 0;
        let mut mask = 1;
        let mut k = 0;
        while k < 16 {
            let bit_v = (val / mask) % 2;
            let bit_k = (key / mask) % 2;
            if bit_v != bit_k { xored = xored + mask; }
            mask = mask * 2;
            k = k + 1;
        }
        result = set8(result, i, xored);
        i = i + 1;
    }
    result
}

// Zigzag encoding: maps signed integers to unsigned
// 0→0, -1→1, 1→2, -2→3, 2→4, ...
fn zigzag_encode(n: Int) -> Int {
    if n >= 0 { n * 2 }
    else { (0 - n) * 2 - 1 }
}

fn zigzag_decode(n: Int) -> Int {
    if n % 2 == 0 { n / 2 }
    else { 0 - (n + 1) / 2 }
}

fn test_varint() -> Int {
    assert_eq(varint_encode_len(0), 1);
    assert_eq(varint_encode_len(127), 1);
    assert_eq(varint_encode_len(128), 2);
    assert_eq(varint_encode_len(300), 2);
    assert_eq(varint_encode_len(16383), 2);
    assert_eq(varint_encode_len(16384), 3);

    // Roundtrip
    let buf = zeros();
    let enc = varint_encode(300, buf);
    assert_eq(varint_decode(enc), 300);

    let enc2 = varint_encode(12345, buf);
    assert_eq(varint_decode(enc2), 12345);

    let enc3 = varint_encode(0, buf);
    assert_eq(varint_decode(enc3), 0);

    let enc4 = varint_encode(127, buf);
    assert_eq(varint_decode(enc4), 127);
    1
}

fn test_delta_roundtrip() -> Int {
    let data = Arr8 { v0: 10, v1: 12, v2: 15, v3: 20, v4: 22, v5: 0, v6: 0, v7: 0 };
    let enc = delta_encode(data, 5);
    // Deltas: [10, 2, 3, 5, 2]
    assert_eq(get8(enc, 0), 10);
    assert_eq(get8(enc, 1), 2);
    assert_eq(get8(enc, 2), 3);
    assert_eq(get8(enc, 3), 5);
    assert_eq(get8(enc, 4), 2);

    let dec = delta_decode(enc, 5);
    assert_eq(get8(dec, 0), 10);
    assert_eq(get8(dec, 1), 12);
    assert_eq(get8(dec, 2), 15);
    assert_eq(get8(dec, 3), 20);
    assert_eq(get8(dec, 4), 22);
    1
}

fn test_delta_decreasing() -> Int {
    let data = Arr8 { v0: 100, v1: 90, v2: 85, v3: 70, v4: 0, v5: 0, v6: 0, v7: 0 };
    let enc = delta_encode(data, 4);
    assert_eq(get8(enc, 1), -10);
    assert_eq(get8(enc, 2), -5);
    let dec = delta_decode(enc, 4);
    assert_eq(get8(dec, 3), 70);
    1
}

fn test_xor_cipher() -> Int {
    let data = Arr8 { v0: 42, v1: 100, v2: 255, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let key = 123;
    let encrypted = xor_cipher(data, 3, key);
    // XOR is self-inverse: encrypt(encrypt(data)) = data
    let decrypted = xor_cipher(encrypted, 3, key);
    assert_eq(get8(decrypted, 0), 42);
    assert_eq(get8(decrypted, 1), 100);
    assert_eq(get8(decrypted, 2), 255);
    1
}

fn test_zigzag() -> Int {
    assert_eq(zigzag_encode(0), 0);
    assert_eq(zigzag_encode(-1), 1);
    assert_eq(zigzag_encode(1), 2);
    assert_eq(zigzag_encode(-2), 3);
    assert_eq(zigzag_encode(2), 4);

    // Roundtrip
    assert_eq(zigzag_decode(zigzag_encode(0)), 0);
    assert_eq(zigzag_decode(zigzag_encode(-1)), -1);
    assert_eq(zigzag_decode(zigzag_encode(42)), 42);
    assert_eq(zigzag_decode(zigzag_encode(-99)), -99);
    1
}

fn main() -> Int {
    test_varint();
    test_delta_roundtrip();
    test_delta_decreasing();
    test_xor_cipher();
    test_zigzag();
    print("[OK] 528_codec_aot");
    0
}
