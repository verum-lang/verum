// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, state-machine, automaton
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for finite state machine simulation

// States: 0=IDLE, 1=RUNNING, 2=PAUSED, 3=STOPPED, 4=ERROR
// Events: 0=START, 1=PAUSE, 2=RESUME, 3=STOP, 4=RESET, 5=FAIL

fn transition(state: Int, event: Int) -> Int {
    if state == 0 {
        // IDLE
        if event == 0 { 1 }        // START -> RUNNING
        else if event == 3 { 3 }   // STOP -> STOPPED
        else { state }
    } else if state == 1 {
        // RUNNING
        if event == 1 { 2 }        // PAUSE -> PAUSED
        else if event == 3 { 3 }   // STOP -> STOPPED
        else if event == 5 { 4 }   // FAIL -> ERROR
        else { state }
    } else if state == 2 {
        // PAUSED
        if event == 2 { 1 }        // RESUME -> RUNNING
        else if event == 3 { 3 }   // STOP -> STOPPED
        else { state }
    } else if state == 3 {
        // STOPPED
        if event == 4 { 0 }        // RESET -> IDLE
        else { state }
    } else {
        // ERROR (4)
        if event == 4 { 0 }        // RESET -> IDLE
        else { state }
    }
}

fn is_terminal(state: Int) -> Bool {
    state == 3 || state == 4
}

fn state_name(state: Int) -> Int {
    // Return state ID for assertions
    state
}

// Run a sequence of events from initial state
// Events packed in record
type EventSeq is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, len: Int };

fn run_machine(init: Int, seq: EventSeq) -> Int {
    let mut state = init;
    let mut i = 0;
    while i < seq.len {
        let event = if i == 0 { seq.e0 }
                    else if i == 1 { seq.e1 }
                    else if i == 2 { seq.e2 }
                    else if i == 3 { seq.e3 }
                    else { seq.e4 };
        state = transition(state, event);
        i = i + 1;
    }
    state
}

fn test_basic_transitions() {
    // IDLE -START-> RUNNING
    assert_eq(transition(0, 0), 1);
    // RUNNING -PAUSE-> PAUSED
    assert_eq(transition(1, 1), 2);
    // PAUSED -RESUME-> RUNNING
    assert_eq(transition(2, 2), 1);
    // RUNNING -STOP-> STOPPED
    assert_eq(transition(1, 3), 3);
    // RUNNING -FAIL-> ERROR
    assert_eq(transition(1, 5), 4);
    // STOPPED -RESET-> IDLE
    assert_eq(transition(3, 4), 0);
    // ERROR -RESET-> IDLE
    assert_eq(transition(4, 4), 0);
}

fn test_invalid_transitions() {
    // IDLE -PAUSE-> IDLE (no change)
    assert_eq(transition(0, 1), 0);
    // IDLE -RESUME-> IDLE (no change)
    assert_eq(transition(0, 2), 0);
    // STOPPED -START-> STOPPED (no change)
    assert_eq(transition(3, 0), 3);
    // ERROR -START-> ERROR (no change)
    assert_eq(transition(4, 0), 4);
}

fn test_sequence() {
    // IDLE -> START -> PAUSE -> RESUME -> STOP
    let seq = EventSeq { e0: 0, e1: 1, e2: 2, e3: 3, e4: 0, len: 4 };
    assert_eq(run_machine(0, seq), 3);  // STOPPED

    // IDLE -> START -> FAIL -> RESET
    let seq2 = EventSeq { e0: 0, e1: 5, e2: 4, e3: 0, e4: 0, len: 3 };
    assert_eq(run_machine(0, seq2), 0);  // Back to IDLE
}

fn test_terminal_states() {
    assert_eq(is_terminal(0), false);  // IDLE
    assert_eq(is_terminal(1), false);  // RUNNING
    assert_eq(is_terminal(2), false);  // PAUSED
    assert_eq(is_terminal(3), true);   // STOPPED
    assert_eq(is_terminal(4), true);   // ERROR
}

fn test_cycle() {
    // Can we cycle: IDLE -> RUNNING -> PAUSED -> RUNNING -> STOPPED -> IDLE
    let mut s = 0;
    s = transition(s, 0);  // RUNNING
    assert_eq(s, 1);
    s = transition(s, 1);  // PAUSED
    assert_eq(s, 2);
    s = transition(s, 2);  // RUNNING
    assert_eq(s, 1);
    s = transition(s, 3);  // STOPPED
    assert_eq(s, 3);
    s = transition(s, 4);  // IDLE
    assert_eq(s, 0);
}

fn main() -> Int {
    test_basic_transitions();
    test_invalid_transitions();
    test_sequence();
    test_terminal_states();
    test_cycle();
    print("[OK] 215_state_machine_aot");
    0
}
