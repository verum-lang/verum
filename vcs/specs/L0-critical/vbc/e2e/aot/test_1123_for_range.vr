// @test: run
// @level: L0
// @tier: 1
// @tags: for-in, range, iteration, loop
// @description: Test for-in loop with range and list iteration

fn test_for_range() -> Int {
    let mut sum = 0;
    for i in 0..10 {
        sum = sum + i;
    }
    // 0+1+2+...+9 = 45
    if sum != 45 {
        print(f"FAIL for_range: sum={sum}, expected 45");
        return 1;
    }
    print("  for_range: OK");
    0
}

fn test_for_range_inclusive() -> Int {
    let mut sum = 0;
    for i in 1..=10 {
        sum = sum + i;
    }
    // 1+2+...+10 = 55
    if sum != 55 {
        print(f"FAIL for_range_inclusive: sum={sum}, expected 55");
        return 1;
    }
    print("  for_range_inclusive: OK");
    0
}

fn test_for_list() -> Int {
    let mut nums = List.new();
    nums.push(10);
    nums.push(20);
    nums.push(30);
    nums.push(40);

    let mut total = 0;
    let mut idx = 0;
    while idx < nums.len() {
        total = total + nums[idx];
        idx = idx + 1;
    }
    if total != 100 {
        print(f"FAIL for_list: total={total}, expected 100");
        return 1;
    }
    print("  for_list: OK");
    0
}

fn test_nested_for() -> Int {
    let mut count = 0;
    for i in 0..5 {
        for j in 0..5 {
            if i + j == 4 {
                count = count + 1;
            }
        }
    }
    // (0,4), (1,3), (2,2), (3,1), (4,0) = 5
    if count != 5 {
        print(f"FAIL nested_for: count={count}, expected 5");
        return 1;
    }
    print("  nested_for: OK");
    0
}

fn test_for_accumulate() -> Int {
    // Compute sum of squares
    let mut sum_sq = 0;
    for i in 1..=5 {
        sum_sq = sum_sq + i * i;
    }
    // 1+4+9+16+25 = 55
    if sum_sq != 55 {
        print(f"FAIL sum_squares: {sum_sq}, expected 55");
        return 1;
    }
    print("  for_accumulate: OK");
    0
}

fn test_for_with_condition() -> Int {
    let mut evens = List.new();
    for i in 0..20 {
        if i % 2 == 0 {
            evens.push(i);
        }
    }
    if evens.len() != 10 {
        print(f"FAIL for_condition: len={evens.len()}, expected 10");
        return 1;
    }
    if evens[0] != 0 || evens[9] != 18 {
        print("FAIL for_condition values");
        return 1;
    }
    print("  for_with_condition: OK");
    0
}

fn main() -> Int {
    print("For Range Tests:");
    let mut failures = 0;
    failures = failures + test_for_range();
    failures = failures + test_for_range_inclusive();
    failures = failures + test_for_list();
    failures = failures + test_nested_for();
    failures = failures + test_for_accumulate();
    failures = failures + test_for_with_condition();

    if failures == 0 {
        print("All for range tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
