// @test: run
// @level: L0
// @tags: aot, e2e, lcs, subsequence, dp
// @timeout: 30000

// Longest Common Subsequence using DP

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// LCS length of s1[0..n1] and s2[0..n2] using two-row DP
// Max string length 7 (indices 0..7 in Arr8 for columns 0..n2)
fn lcs_len(s1: Arr8, n1: Int, s2: Arr8, n2: Int) -> Int {
    let mut prev = zeros(); // row for i-1, all zeros initially
    let mut i = 1;
    while i <= n1 {
        let mut curr = zeros();
        let mut j = 1;
        while j <= n2 {
            if get8(s1, i - 1) == get8(s2, j - 1) {
                curr = set8(curr, j, get8(prev, j - 1) + 1);
            } else {
                curr = set8(curr, j, max_val(get8(prev, j), get8(curr, j - 1)));
            }
            j = j + 1;
        }
        prev = curr;
        i = i + 1;
    }
    get8(prev, n2)
}

// Longest Common Substring (contiguous) using two-row DP
fn lc_substring_len(s1: Arr8, n1: Int, s2: Arr8, n2: Int) -> Int {
    let mut prev = zeros();
    let mut best = 0;
    let mut i = 1;
    while i <= n1 {
        let mut curr = zeros();
        let mut j = 1;
        while j <= n2 {
            if get8(s1, i - 1) == get8(s2, j - 1) {
                let val = get8(prev, j - 1) + 1;
                curr = set8(curr, j, val);
                if val > best { best = val; }
            }
            // else curr[j] stays 0
            j = j + 1;
        }
        prev = curr;
        i = i + 1;
    }
    best
}

// Check if s2 is a subsequence of s1
fn is_subsequence(s1: Arr8, n1: Int, s2: Arr8, n2: Int) -> Int {
    let mut j = 0;
    let mut i = 0;
    while i < n1 {
        if j < n2 {
            if get8(s1, i) == get8(s2, j) { j = j + 1; }
        }
        i = i + 1;
    }
    if j == n2 { 1 } else { 0 }
}

fn test_identical() -> Int {
    let s = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs_len(s, 4, s, 4), 4);
    assert_eq(lc_substring_len(s, 4, s, 4), 4);
    1
}

fn test_empty() -> Int {
    let s = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let e = zeros();
    assert_eq(lcs_len(s, 3, e, 0), 0);
    assert_eq(lcs_len(e, 0, s, 3), 0);
    1
}

fn test_no_common() -> Int {
    let s1 = Arr8 { v0: 1, v1: 3, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let s2 = Arr8 { v0: 2, v1: 4, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs_len(s1, 3, s2, 3), 0);
    assert_eq(lc_substring_len(s1, 3, s2, 3), 0);
    1
}

fn test_lcs_basic() -> Int {
    // s1 = [1,3,5,7], s2 = [1,2,3,4,5]
    // LCS = [1,3,5] = 3
    let s1 = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    let s2 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs_len(s1, 4, s2, 5), 3);
    1
}

fn test_substring() -> Int {
    // s1 = [1,2,3,4,5], s2 = [8,2,3,4,9]
    // Longest common substring = [2,3,4] = 3
    let s1 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    let s2 = Arr8 { v0: 8, v1: 2, v2: 3, v3: 4, v4: 9, v5: 0, v6: 0, v7: 0 };
    assert_eq(lc_substring_len(s1, 5, s2, 5), 3);
    1
}

fn test_subsequence() -> Int {
    let s1 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    let s2 = Arr8 { v0: 1, v1: 3, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_subsequence(s1, 5, s2, 3), 1);
    let s3 = Arr8 { v0: 3, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_subsequence(s1, 5, s3, 2), 0); // order matters
    let s4 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(is_subsequence(s1, 5, s4, 5), 1); // full match
    1
}

fn test_symmetry() -> Int {
    // LCS is symmetric
    let s1 = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    let s2 = Arr8 { v0: 2, v1: 3, v2: 6, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(lcs_len(s1, 4, s2, 4), lcs_len(s2, 4, s1, 4));
    1
}

fn main() -> Int {
    test_identical();
    test_empty();
    test_no_common();
    test_lcs_basic();
    test_substring();
    test_subsequence();
    test_symmetry();
    print("[OK] 646_lcs_aot");
    0
}
