// @test: run
// @level: L0
// @tier: 2
// @tags: variant-collision, method-dispatch, sum-type, state-machine
// @description: Methods on sum types with variant names that collide with stdlib variants

// "Done" collides with OnceState.Done in core/sync/once.vr
type State is Idle | Running(Int) | Paused(Int) | Done(Int);

implement State {
    fn step(&self) -> State {
        match self {
            Idle => Running(0),
            Running(n) => {
                if (n >= 10) { Done(n) }
                else { Running(n + 1) }
            }
            Paused(n) => Running(n),
            Done(n) => Done(n),
        }
    }
    fn is_done(&self) -> Bool {
        self is Done
    }
    fn value(&self) -> Int {
        match self {
            Idle => 0,
            Running(n) => n,
            Paused(n) => n,
            Done(n) => n,
        }
    }
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    // Test 1: Direct construction + method call on collided variant
    let d = Done(42);
    if (d.value() == 42) { passed = passed + 1; }
    else { print(f"FAIL 1: value={d.value()}"); failed = failed + 1; }

    // Test 2: State machine transitions
    let mut state = Idle;
    state = state.step(); // Idle -> Running(0)
    state = state.step(); // Running(0) -> Running(1)
    state = state.step(); // Running(1) -> Running(2)
    if (state.value() == 2 && !state.is_done()) { passed = passed + 1; }
    else { print(f"FAIL 2: val={state.value()}"); failed = failed + 1; }

    // Test 3: Run to completion
    while (!state.is_done()) {
        state = state.step();
    }
    if (state.value() == 10 && state.is_done()) { passed = passed + 1; }
    else { print(f"FAIL 3: val={state.value()}"); failed = failed + 1; }

    // Test 4: Pause and resume
    let paused = Paused(5);
    let resumed = paused.step();
    if (resumed.value() == 5) { passed = passed + 1; }
    else { print(f"FAIL 4: resumed={resumed.value()}"); failed = failed + 1; }

    // Test 5: Done state is terminal (method returns Done(n))
    let d2 = Done(99);
    let d3 = d2.step();
    if (d3.value() == 99 && d3.is_done()) { passed = passed + 1; }
    else { print(f"FAIL 5: val={d3.value()}"); failed = failed + 1; }

    // Test 6: is_done on non-Done variant
    let r = Running(7);
    if (!r.is_done()) { passed = passed + 1; }
    else { print("FAIL 6: Running should not be done"); failed = failed + 1; }

    if (failed > 0) {
        print(f"1008_variant_collision_methods: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"1008_variant_collision_methods: PASS ({passed}/{passed} tests)");
    0
}
