// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, fsm, lexer, state-machine
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for FSM-based lexer (tokenizes integer sequences)

// Character classes: 0=DIGIT, 1=ALPHA, 2=SPACE, 3=OP, 4=OTHER, 5=EOF
fn char_class(ch: Int) -> Int {
    if ch >= 48 && ch <= 57 { 0 }        // '0'-'9'
    else if ch >= 65 && ch <= 90 { 1 }   // 'A'-'Z'
    else if ch >= 97 && ch <= 122 { 1 }  // 'a'-'z'
    else if ch == 32 { 2 }               // space
    else if ch == 43 || ch == 45 || ch == 42 || ch == 47 { 3 } // +-*/
    else if ch == 0 { 5 }                // EOF
    else { 4 }
}

// Token types: 0=NUMBER, 1=IDENT, 2=OP, 3=SPACE, 4=ERROR, 5=EOF
type Token is { kind: Int, start: Int, end: Int };

// Input: up to 16 characters stored as integers
type Input16 is {
    c0: Int, c1: Int, c2: Int, c3: Int,
    c4: Int, c5: Int, c6: Int, c7: Int,
    c8: Int, c9: Int, c10: Int, c11: Int,
    c12: Int, c13: Int, c14: Int, c15: Int,
    len: Int
};

fn inp_get(inp: Input16, i: Int) -> Int {
    if i >= inp.len { return 0; }
    if i == 0 { inp.c0 } else if i == 1 { inp.c1 }
    else if i == 2 { inp.c2 } else if i == 3 { inp.c3 }
    else if i == 4 { inp.c4 } else if i == 5 { inp.c5 }
    else if i == 6 { inp.c6 } else if i == 7 { inp.c7 }
    else if i == 8 { inp.c8 } else if i == 9 { inp.c9 }
    else if i == 10 { inp.c10 } else if i == 11 { inp.c11 }
    else if i == 12 { inp.c12 } else if i == 13 { inp.c13 }
    else if i == 14 { inp.c14 } else { inp.c15 }
}

// Token output (up to 8 tokens)
type Tokens8 is {
    t0: Token, t1: Token, t2: Token, t3: Token,
    t4: Token, t5: Token, t6: Token, t7: Token,
    count: Int
};

fn empty_token() -> Token { Token { kind: 5, start: 0, end: 0 } }

fn tokens_new() -> Tokens8 {
    let e = empty_token();
    Tokens8 { t0: e, t1: e, t2: e, t3: e, t4: e, t5: e, t6: e, t7: e, count: 0 }
}

fn tokens_push(ts: Tokens8, t: Token) -> Tokens8 {
    let i = ts.count;
    Tokens8 {
        t0: if i == 0 { t } else { ts.t0 }, t1: if i == 1 { t } else { ts.t1 },
        t2: if i == 2 { t } else { ts.t2 }, t3: if i == 3 { t } else { ts.t3 },
        t4: if i == 4 { t } else { ts.t4 }, t5: if i == 5 { t } else { ts.t5 },
        t6: if i == 6 { t } else { ts.t6 }, t7: if i == 7 { t } else { ts.t7 },
        count: if i < 8 { i + 1 } else { ts.count }
    }
}

fn tokens_get(ts: Tokens8, i: Int) -> Token {
    if i == 0 { ts.t0 } else if i == 1 { ts.t1 }
    else if i == 2 { ts.t2 } else if i == 3 { ts.t3 }
    else if i == 4 { ts.t4 } else if i == 5 { ts.t5 }
    else if i == 6 { ts.t6 } else { ts.t7 }
}

// FSM-based tokenizer
fn tokenize(inp: Input16) -> Tokens8 {
    let mut tokens = tokens_new();
    let mut pos = 0;

    while pos < inp.len && tokens.count < 8 {
        let ch = inp_get(inp, pos);
        let cls = char_class(ch);

        if cls == 2 {
            // Skip spaces
            pos = pos + 1;
        } else if cls == 0 {
            // Number: consume digits
            let start = pos;
            while pos < inp.len && char_class(inp_get(inp, pos)) == 0 {
                pos = pos + 1;
            }
            tokens = tokens_push(tokens, Token { kind: 0, start: start, end: pos });
        } else if cls == 1 {
            // Identifier: consume alphanumerics
            let start = pos;
            while pos < inp.len {
                let c = char_class(inp_get(inp, pos));
                if c != 1 && c != 0 {
                    pos = pos; // break
                    let mut dummy = 0;
                    dummy = 1; // force break by setting pos explicitly
                    pos = pos; // keep pos, exit by condition below
                    let c2 = char_class(inp_get(inp, pos));
                    if c2 != 1 && c2 != 0 {
                        tokens = tokens_push(tokens, Token { kind: 1, start: start, end: pos });
                        // exit inner while by adjusting pos to trigger outer while
                        // use a trick: set pos to len to break
                        let mut break_val = 1;
                        while break_val == 1 { break_val = 0; }
                        // Actually, we need to break. Let's restructure.
                        pos = pos; // break handled below
                        return tokenize_ident_helper(inp, tokens, start, pos);
                    }
                }
                pos = pos + 1;
            }
            tokens = tokens_push(tokens, Token { kind: 1, start: start, end: pos });
        } else if cls == 3 {
            tokens = tokens_push(tokens, Token { kind: 2, start: pos, end: pos + 1 });
            pos = pos + 1;
        } else {
            tokens = tokens_push(tokens, Token { kind: 4, start: pos, end: pos + 1 });
            pos = pos + 1;
        }
    }
    tokens
}

// Helper: avoids complex break logic
fn tokenize_ident_helper(inp: Input16, tokens: Tokens8, start: Int, pos_in: Int) -> Tokens8 {
    // We already consumed into the non-alpha char.
    // Reparse from start with simple approach
    let mut result = tokens;
    let mut p = start;
    while p < inp.len && (char_class(inp_get(inp, p)) == 1 || char_class(inp_get(inp, p)) == 0) {
        p = p + 1;
    }
    result = tokens_push(result, Token { kind: 1, start: start, end: p });
    // Continue tokenizing the rest
    let mut rest_tokens = result;
    while p < inp.len && rest_tokens.count < 8 {
        let ch = inp_get(inp, p);
        let cls = char_class(ch);
        if cls == 2 { p = p + 1; }
        else if cls == 0 {
            let s = p;
            while p < inp.len && char_class(inp_get(inp, p)) == 0 { p = p + 1; }
            rest_tokens = tokens_push(rest_tokens, Token { kind: 0, start: s, end: p });
        } else if cls == 3 {
            rest_tokens = tokens_push(rest_tokens, Token { kind: 2, start: p, end: p + 1 });
            p = p + 1;
        } else {
            rest_tokens = tokens_push(rest_tokens, Token { kind: 4, start: p, end: p + 1 });
            p = p + 1;
        }
    }
    rest_tokens
}

fn test_number_only() {
    // "42" -> [52, 50] (ASCII '4'=52, '2'=50)
    let inp = Input16 {
        c0: 52, c1: 50, c2: 0, c3: 0, c4: 0, c5: 0, c6: 0, c7: 0,
        c8: 0, c9: 0, c10: 0, c11: 0, c12: 0, c13: 0, c14: 0, c15: 0,
        len: 2
    };
    let ts = tokenize(inp);
    assert_eq(ts.count, 1);
    assert_eq(tokens_get(ts, 0).kind, 0);
    assert_eq(tokens_get(ts, 0).start, 0);
    assert_eq(tokens_get(ts, 0).end, 2);
}

fn test_expression() {
    // "1+2" -> [49, 43, 50]
    let inp = Input16 {
        c0: 49, c1: 43, c2: 50, c3: 0, c4: 0, c5: 0, c6: 0, c7: 0,
        c8: 0, c9: 0, c10: 0, c11: 0, c12: 0, c13: 0, c14: 0, c15: 0,
        len: 3
    };
    let ts = tokenize(inp);
    assert_eq(ts.count, 3);
    assert_eq(tokens_get(ts, 0).kind, 0);  // NUMBER "1"
    assert_eq(tokens_get(ts, 1).kind, 2);  // OP "+"
    assert_eq(tokens_get(ts, 2).kind, 0);  // NUMBER "2"
}

fn test_with_spaces() {
    // "1 + 2" -> [49, 32, 43, 32, 50]
    let inp = Input16 {
        c0: 49, c1: 32, c2: 43, c3: 32, c4: 50, c5: 0, c6: 0, c7: 0,
        c8: 0, c9: 0, c10: 0, c11: 0, c12: 0, c13: 0, c14: 0, c15: 0,
        len: 5
    };
    let ts = tokenize(inp);
    assert_eq(ts.count, 3);  // Spaces skipped
}

fn test_char_class() {
    assert_eq(char_class(48), 0);  // '0' = digit
    assert_eq(char_class(57), 0);  // '9' = digit
    assert_eq(char_class(65), 1);  // 'A' = alpha
    assert_eq(char_class(97), 1);  // 'a' = alpha
    assert_eq(char_class(32), 2);  // space
    assert_eq(char_class(43), 3);  // '+'
    assert_eq(char_class(0), 5);   // EOF
}

fn main() -> Int {
    test_number_only();
    test_expression();
    test_with_spaces();
    test_char_class();
    print("[OK] 270_fsm_lexer_aot");
    0
}
