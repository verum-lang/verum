// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, red-black-tree, bst, invariants
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for red-black tree property verification.
// Builds a valid RB tree (hardcoded) and verifies BST + RB invariants iteratively.
// Uses explicit stack for tree traversal to avoid deep recursion issues.
//
// Tree structure (7 nodes):
//          10(B)
//         /     \
//       3(R)    18(R)
//      /   \   /    \
//     1(B) 7(B) 14(B) 22(B)

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int, len: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

// Node data accessed by index (0-6)
fn tree_key(i: Int) -> Int {
    if i == 0 { 10 } else if i == 1 { 3 } else if i == 2 { 18 }
    else if i == 3 { 1 } else if i == 4 { 7 } else if i == 5 { 14 }
    else { 22 }
}

// Color: 0=black, 1=red
fn tree_color(i: Int) -> Int {
    if i == 0 { 0 }       // 10: black (root)
    else if i == 1 { 1 }  // 3: red
    else if i == 2 { 1 }  // 18: red
    else { 0 }            // 1,7,14,22: all black
}

fn tree_left(i: Int) -> Int {
    if i == 0 { 1 } else if i == 1 { 3 } else if i == 2 { 5 }
    else { -1 }
}

fn tree_right(i: Int) -> Int {
    if i == 0 { 2 } else if i == 1 { 4 } else if i == 2 { 6 }
    else { -1 }
}

fn tree_parent(i: Int) -> Int {
    if i == 0 { -1 }      // root
    else if i == 1 { 0 }  // 3's parent = 10
    else if i == 2 { 0 }  // 18's parent = 10
    else if i == 3 { 1 }  // 1's parent = 3
    else if i == 4 { 1 }  // 7's parent = 3
    else if i == 5 { 2 }  // 14's parent = 18
    else { 2 }            // 22's parent = 18
}

// === Property 1: BST property ===
// Check each node: if it has a left child, left key < node key
//                  if it has a right child, right key > node key
// Also check parent-child consistency
fn check_bst_local() -> Int {
    let mut i = 0;
    while i < 7 {
        let k = tree_key(i);
        let lc = tree_left(i);
        let rc = tree_right(i);
        if lc != -1 {
            if tree_key(lc) >= k { return 0; }
        }
        if rc != -1 {
            if tree_key(rc) <= k { return 0; }
        }
        i = i + 1;
    }
    1
}

// Full BST check: verify in-order traversal gives sorted keys
// Use iterative in-order with a stack
fn check_inorder_sorted() -> Int {
    let mut stack = Arr8 { a0: -1, a1: -1, a2: -1, a3: -1, a4: -1, a5: -1, a6: -1, a7: -1, len: 0 };
    let mut sp = 0;  // stack pointer
    let mut cur = 0;  // start at root
    let mut last_key = -99999;
    let mut done = 0;
    let mut count = 0;

    while done == 0 {
        // Push all left children
        while cur != -1 {
            stack = arr8_set(stack, sp, cur);
            sp = sp + 1;
            cur = tree_left(cur);
        }

        if sp == 0 {
            done = 1;
        } else {
            // Pop
            sp = sp - 1;
            cur = arr8_get(stack, sp);
            let k = tree_key(cur);
            if k <= last_key { return 0; }  // Not sorted!
            last_key = k;
            count = count + 1;
            cur = tree_right(cur);
        }
    }
    // Should have visited all 7 nodes
    if count != 7 { return 0; }
    1
}

// === Property 2: Root is black ===
fn check_root_black() -> Int {
    if tree_color(0) == 0 { 1 } else { 0 }
}

// === Property 3: No red-red parent-child ===
fn check_no_red_red() -> Int {
    let mut i = 0;
    while i < 7 {
        if tree_color(i) == 1 {
            // Red node: check children are black
            let lc = tree_left(i);
            let rc = tree_right(i);
            if lc != -1 {
                if tree_color(lc) == 1 { return 0; }
            }
            if rc != -1 {
                if tree_color(rc) == 1 { return 0; }
            }
        }
        i = i + 1;
    }
    1
}

// === Property 4: Equal black height on all root-to-leaf paths ===
// For each leaf (node with no children), count black nodes on path to root
fn black_depth(node: Int) -> Int {
    let mut depth = 0;
    let mut cur = node;
    while cur != -1 {
        if tree_color(cur) == 0 { depth = depth + 1; }
        cur = tree_parent(cur);
    }
    depth
}

fn check_equal_black_height() -> Int {
    // Find all leaves and check their black depths are equal
    let mut expected = -1;
    let mut i = 0;
    while i < 7 {
        let lc = tree_left(i);
        let rc = tree_right(i);
        // A "leaf" for black height purposes is a node with at least one NIL child
        if lc == -1 {
            let bd = black_depth(i);
            if expected == -1 { expected = bd; }
            else if bd != expected { return 0; }
        }
        if rc == -1 {
            let bd = black_depth(i);
            if expected == -1 { expected = bd; }
            else if bd != expected { return 0; }
        }
        i = i + 1;
    }
    1
}

// === Property 5: Parent-child consistency ===
fn check_parent_child() -> Int {
    let mut i = 0;
    while i < 7 {
        let lc = tree_left(i);
        let rc = tree_right(i);
        if lc != -1 {
            if tree_parent(lc) != i { return 0; }
        }
        if rc != -1 {
            if tree_parent(rc) != i { return 0; }
        }
        i = i + 1;
    }
    // Root has no parent
    if tree_parent(0) != -1 { return 0; }
    1
}

// === Count helpers ===
fn count_black_nodes() -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 7 {
        if tree_color(i) == 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn count_red_nodes() -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 7 {
        if tree_color(i) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

// === Invalid tree checks (for negative testing) ===
// Tree with red root
fn invalid_root_check() -> Int {
    // If root were red, check_root_black would return 0
    // We test this by directly checking
    if 1 == 0 { 1 } else { 0 }  // Always 0, simulating red root check
}

fn test_bst_property() {
    assert_eq(check_bst_local(), 1);
    assert_eq(check_inorder_sorted(), 1);
}

fn test_root_is_black() {
    assert_eq(check_root_black(), 1);
}

fn test_no_red_red_violations() {
    assert_eq(check_no_red_red(), 1);
}

fn test_equal_black_height() {
    assert_eq(check_equal_black_height(), 1);
}

fn test_parent_child_consistency() {
    assert_eq(check_parent_child(), 1);
}

fn test_node_counts() {
    // 5 black nodes: 10, 1, 7, 14, 22
    assert_eq(count_black_nodes(), 5);
    // 2 red nodes: 3, 18
    assert_eq(count_red_nodes(), 2);
    // Total: 7
    assert_eq(count_black_nodes() + count_red_nodes(), 7);
}

fn test_specific_keys() {
    // Verify key assignments
    assert_eq(tree_key(0), 10);
    assert_eq(tree_key(1), 3);
    assert_eq(tree_key(2), 18);
    assert_eq(tree_key(3), 1);
    assert_eq(tree_key(4), 7);
    assert_eq(tree_key(5), 14);
    assert_eq(tree_key(6), 22);
}

fn test_black_depths() {
    // All leaves at depth 2 from root
    // Leaves: 3(idx 3, key 1), 4(key 7), 5(key 14), 6(key 22)
    // Black depth of node 3 (key=1): 1(B) + path 1->3->root: 1(B) + 3(R->skip) + 10(B) = 2 black
    let bd3 = black_depth(3);
    let bd4 = black_depth(4);
    let bd5 = black_depth(5);
    let bd6 = black_depth(6);
    // All should be equal
    assert_eq(bd3, bd4);
    assert_eq(bd4, bd5);
    assert_eq(bd5, bd6);
    // Black depth should be 2 (node itself is black, root is black, parent is red)
    assert_eq(bd3, 2);
}

fn test_tree_height() {
    // Height of tree (longest path from root to leaf): 2 edges
    // Root(0) -> 3(1) -> 1(3): depth 2
    // All leaves are at same depth from root
    let mut max_depth = 0;
    let mut i = 0;
    while i < 7 {
        if tree_left(i) == -1 {
            // Count depth to root
            let mut depth = 0;
            let mut cur = i;
            while tree_parent(cur) != -1 {
                depth = depth + 1;
                cur = tree_parent(cur);
            }
            if depth > max_depth { max_depth = depth; }
        }
        i = i + 1;
    }
    assert_eq(max_depth, 2);
}

fn main() -> Int {
    test_bst_property();
    test_root_is_black();
    test_no_red_red_violations();
    test_equal_black_height();
    test_parent_child_consistency();
    test_node_counts();
    test_specific_keys();
    test_black_depths();
    test_tree_height();
    print("[OK] 329_rbtree_props_aot");
    0
}
