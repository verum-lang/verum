// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, loops, while, control-flow
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for while loops and iteration patterns

fn sum_range(start: Int, end: Int) -> Int {
    let mut total = 0;
    let mut i = start;
    while i < end {
        total = total + i;
        i = i + 1;
    }
    total
}

fn count_divisors(n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i <= n {
        if n % i == 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn collatz_steps(n: Int) -> Int {
    let mut val = n;
    let mut steps = 0;
    while val > 1 {
        if val % 2 == 0 {
            val = val / 2;
        } else {
            val = val * 3 + 1;
        }
        steps = steps + 1;
    }
    steps
}

fn binary_search(target: Int) -> Int {
    // Search for target in 0..100
    let mut lo = 0;
    let mut hi = 100;
    while lo < hi {
        let mid = (lo + hi) / 2;
        if mid < target {
            lo = mid + 1;
        } else {
            hi = mid;
        }
    }
    lo
}

fn nested_loop_sum(n: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        let mut j = 0;
        while j <= i {
            total = total + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    total
}

fn main() -> Int {
    // Sum range
    assert_eq(sum_range(0, 10), 45);
    assert_eq(sum_range(1, 6), 15);
    assert_eq(sum_range(5, 5), 0);
    assert_eq(sum_range(0, 1), 0);

    // Count divisors
    assert_eq(count_divisors(1), 1);
    assert_eq(count_divisors(6), 4);    // 1,2,3,6
    assert_eq(count_divisors(12), 6);   // 1,2,3,4,6,12
    assert_eq(count_divisors(7), 2);    // 1,7 (prime)
    assert_eq(count_divisors(36), 9);   // 1,2,3,4,6,9,12,18,36

    // Collatz sequence
    assert_eq(collatz_steps(1), 0);
    assert_eq(collatz_steps(2), 1);
    assert_eq(collatz_steps(4), 2);
    assert_eq(collatz_steps(27), 111);

    // Binary search
    assert_eq(binary_search(0), 0);
    assert_eq(binary_search(50), 50);
    assert_eq(binary_search(99), 99);
    assert_eq(binary_search(42), 42);

    // Nested loops: sum of 1+2+3+...+n = n*(n+1)/2
    assert_eq(nested_loop_sum(0), 0);
    assert_eq(nested_loop_sum(1), 1);
    assert_eq(nested_loop_sum(5), 15);
    assert_eq(nested_loop_sum(10), 55);

    print("[OK] 183_while_loops_aot");
    0
}
