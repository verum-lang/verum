// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, longest-nondecreasing-subsequence, dp, patience-sort
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for longest non-decreasing subsequence (LNDS) and related problems.
// Uses O(n^2) DP and also patience-sorting style approach.
// Also tests longest strictly increasing subsequence (LIS) for comparison.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int, len: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

fn a8_new(n: Int) -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: n }
}

// Longest Non-Decreasing Subsequence (LNDS) via O(n^2) DP
// dp[i] = length of LNDS ending at index i
fn lnds(arr: Arr8) -> Int {
    let n = arr.len;
    if n == 0 { return 0; }
    let mut dp = a8_new(n);
    let mut i = 0;
    while i < n {
        dp = a8_set(dp, i, 1);
        i = i + 1;
    }
    let mut i2 = 1;
    while i2 < n {
        let mut j = 0;
        while j < i2 {
            if a8_get(arr, j) <= a8_get(arr, i2) {
                let candidate = a8_get(dp, j) + 1;
                if candidate > a8_get(dp, i2) {
                    dp = a8_set(dp, i2, candidate);
                }
            }
            j = j + 1;
        }
        i2 = i2 + 1;
    }
    // Find max in dp
    let mut max_val = 0;
    let mut k = 0;
    while k < n {
        if a8_get(dp, k) > max_val { max_val = a8_get(dp, k); }
        k = k + 1;
    }
    max_val
}

// Longest Strictly Increasing Subsequence (LIS) via O(n^2) DP
fn lis(arr: Arr8) -> Int {
    let n = arr.len;
    if n == 0 { return 0; }
    let mut dp = a8_new(n);
    let mut i = 0;
    while i < n {
        dp = a8_set(dp, i, 1);
        i = i + 1;
    }
    let mut i2 = 1;
    while i2 < n {
        let mut j = 0;
        while j < i2 {
            if a8_get(arr, j) < a8_get(arr, i2) {
                let candidate = a8_get(dp, j) + 1;
                if candidate > a8_get(dp, i2) {
                    dp = a8_set(dp, i2, candidate);
                }
            }
            j = j + 1;
        }
        i2 = i2 + 1;
    }
    let mut max_val = 0;
    let mut k = 0;
    while k < n {
        if a8_get(dp, k) > max_val { max_val = a8_get(dp, k); }
        k = k + 1;
    }
    max_val
}

// Longest Non-Increasing Subsequence (reverse problem)
fn lnis(arr: Arr8) -> Int {
    let n = arr.len;
    if n == 0 { return 0; }
    let mut dp = a8_new(n);
    let mut i = 0;
    while i < n {
        dp = a8_set(dp, i, 1);
        i = i + 1;
    }
    let mut i2 = 1;
    while i2 < n {
        let mut j = 0;
        while j < i2 {
            if a8_get(arr, j) >= a8_get(arr, i2) {
                let candidate = a8_get(dp, j) + 1;
                if candidate > a8_get(dp, i2) {
                    dp = a8_set(dp, i2, candidate);
                }
            }
            j = j + 1;
        }
        i2 = i2 + 1;
    }
    let mut max_val = 0;
    let mut k = 0;
    while k < n {
        if a8_get(dp, k) > max_val { max_val = a8_get(dp, k); }
        k = k + 1;
    }
    max_val
}

// Count number of LNDS of maximum length (count optimal subsequences)
fn count_lnds(arr: Arr8) -> Int {
    let n = arr.len;
    if n == 0 { return 0; }
    let mut dp_len = a8_new(n);
    let mut dp_cnt = a8_new(n);
    let mut i = 0;
    while i < n {
        dp_len = a8_set(dp_len, i, 1);
        dp_cnt = a8_set(dp_cnt, i, 1);
        i = i + 1;
    }
    let mut i2 = 1;
    while i2 < n {
        let mut j = 0;
        while j < i2 {
            if a8_get(arr, j) <= a8_get(arr, i2) {
                let new_len = a8_get(dp_len, j) + 1;
                let cur_len = a8_get(dp_len, i2);
                if new_len > cur_len {
                    dp_len = a8_set(dp_len, i2, new_len);
                    dp_cnt = a8_set(dp_cnt, i2, a8_get(dp_cnt, j));
                } else if new_len == cur_len {
                    dp_cnt = a8_set(dp_cnt, i2, a8_get(dp_cnt, i2) + a8_get(dp_cnt, j));
                }
            }
            j = j + 1;
        }
        i2 = i2 + 1;
    }
    // Find the max length and sum counts at that length
    let max_len = lnds(arr);
    let mut total = 0;
    let mut k = 0;
    while k < n {
        if a8_get(dp_len, k) == max_len {
            total = total + a8_get(dp_cnt, k);
        }
        k = k + 1;
    }
    total
}

fn test_basic_lnds() {
    // [3, 1, 2, 2, 4] -> LNDS: [1, 2, 2, 4] = 4
    let arr = Arr8 { a0: 3, a1: 1, a2: 2, a3: 2, a4: 4, a5: 0, a6: 0, a7: 0, len: 5 };
    assert_eq(lnds(arr), 4);
}

fn test_all_equal() {
    // [5, 5, 5, 5, 5] -> LNDS: all 5 elements (non-decreasing)
    let arr = Arr8 { a0: 5, a1: 5, a2: 5, a3: 5, a4: 5, a5: 0, a6: 0, a7: 0, len: 5 };
    assert_eq(lnds(arr), 5);
    // LIS: [5] = 1 (strictly increasing requires strict)
    assert_eq(lis(arr), 1);
}

fn test_strictly_decreasing() {
    // [8, 6, 4, 2] -> LNDS: any single element = 1
    let arr = Arr8 { a0: 8, a1: 6, a2: 4, a3: 2, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    assert_eq(lnds(arr), 1);
    assert_eq(lis(arr), 1);
}

fn test_sorted_array() {
    // [1, 2, 3, 4, 5, 6] -> LNDS = 6 (entire array)
    let arr = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 6, a6: 0, a7: 0, len: 6 };
    assert_eq(lnds(arr), 6);
    assert_eq(lis(arr), 6);
}

fn test_lnds_vs_lis() {
    // [3, 1, 2, 2, 3] -> LNDS: [1, 2, 2, 3] = 4, LIS: [1, 2, 3] = 3
    let arr = Arr8 { a0: 3, a1: 1, a2: 2, a3: 2, a4: 3, a5: 0, a6: 0, a7: 0, len: 5 };
    assert_eq(lnds(arr), 4);
    assert_eq(lis(arr), 3);
}

fn test_non_increasing() {
    // [5, 4, 3, 3, 2, 1] -> LNIS = 6 (entire array is non-increasing)
    let arr = Arr8 { a0: 5, a1: 4, a2: 3, a3: 3, a4: 2, a5: 1, a6: 0, a7: 0, len: 6 };
    assert_eq(lnis(arr), 6);
    assert_eq(lnds(arr), 2); // [3, 3]
}

fn test_alternating() {
    // [1, 3, 1, 3, 1, 3] -> LNDS: [1, 1, 1, 3] or [1, 3, 3, 3] = 4
    let arr = Arr8 { a0: 1, a1: 3, a2: 1, a3: 3, a4: 1, a5: 3, a6: 0, a7: 0, len: 6 };
    assert_eq(lnds(arr), 4);
}

fn test_count_optimal() {
    // [1, 2, 3] -> Only 1 LNDS of length 3
    let arr1 = Arr8 { a0: 1, a1: 2, a2: 3, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    assert_eq(count_lnds(arr1), 1);

    // [1, 2, 1, 2] -> LNDS length 3: [1, 1, 2] = 2 ways (pick first or third 1, then either 2)
    let arr2 = Arr8 { a0: 1, a1: 2, a2: 1, a3: 2, a4: 0, a5: 0, a6: 0, a7: 0, len: 4 };
    assert_eq(lnds(arr2), 3);
    // [1, 1, 2]: first-1 + third-1 + fourth-2 -> count depends on which path
    assert_eq(count_lnds(arr2), 2);
}

fn test_single_element() {
    let arr = Arr8 { a0: 42, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 1 };
    assert_eq(lnds(arr), 1);
    assert_eq(lis(arr), 1);
    assert_eq(lnis(arr), 1);
}

fn test_erdos_szekeres() {
    // Erdos-Szekeres theorem: any sequence of length > r*s has either
    // an increasing subsequence of length r+1 or a non-increasing of length s+1
    // For length 5 (> 2*2): must have LIS >= 3 or LNIS >= 3
    // [2, 4, 1, 3, 5] -> LIS = [2, 3, 5] = 3 (verified)
    let arr = Arr8 { a0: 2, a1: 4, a2: 1, a3: 3, a4: 5, a5: 0, a6: 0, a7: 0, len: 5 };
    let l = lis(arr);
    let d = lnis(arr);
    // At least one of them should be >= 3
    assert_eq(l >= 3, true);
}

fn main() -> Int {
    test_basic_lnds();
    test_all_equal();
    test_strictly_decreasing();
    test_sorted_array();
    test_lnds_vs_lis();
    test_non_increasing();
    test_alternating();
    test_count_optimal();
    test_single_element();
    test_erdos_szekeres();
    print("[OK] 338_longest_nondec_aot");
    0
}
