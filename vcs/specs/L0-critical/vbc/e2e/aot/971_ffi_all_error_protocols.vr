// @test: run
// @tier: 1
// @level: L0
// @tags: ffi, error-protocol, errno, comprehensive
// @description: Tests all error protocol mechanisms from grammar (errors_via variants)
// @expected-exit: 0

// Grammar reference (verum.ebnf lines 969-974):
//   error_mechanism = 'None' | 'Errno' | 'ReturnCode(pattern)'
//                   | 'ReturnValue(expression) [with Errno]' | 'Exception'

@ffi("libSystem.B.dylib")
extern {
    fn getpid() -> Int;
    fn getuid() -> Int;
    fn dup(fd: Int) -> Int;
    fn close(fd: Int) -> Int;
    fn pipe(fds: &mut Int) -> Int;
}

fn main() {
    // ============================================================
    // Test 1: errors_via = None (implicit) — extern {} default
    // Functions that "never fail" from the caller's perspective
    // ============================================================
    let pid = getpid();
    assert(pid > 0);
    let uid = getuid();
    assert(uid >= 0);
    print(f"Test 1 PASS: None protocol — pid={pid} uid={uid}");

    // ============================================================
    // Test 2: Errno-style error detection — POSIX convention
    // Returns -1 on error, sets errno
    // ============================================================
    // Success case: dup(0) duplicates stdin
    let fd = dup(0);
    assert(fd >= 0);
    print(f"Test 2a PASS: Errno success — dup(0) = {fd}");

    // Error case: dup(-1) fails with EBADF
    let bad_fd = dup(-1);
    assert(bad_fd == -1);
    print(f"Test 2b PASS: Errno failure — dup(-1) = {bad_fd}");

    // Cleanup
    close(fd);

    // ============================================================
    // Test 3: ReturnCode-style — 0 = success, non-zero = error
    // close() returns 0 on success, -1 on error
    // ============================================================
    let fd2 = dup(1);
    assert(fd2 >= 0);

    // Success: close valid fd
    let rc = close(fd2);
    assert(rc == 0);
    print(f"Test 3a PASS: ReturnCode success — close({fd2}) = {rc}");

    // Error: close invalid fd
    let rc2 = close(99999);
    assert(rc2 == -1);
    print(f"Test 3b PASS: ReturnCode failure — close(99999) = {rc2}");

    // ============================================================
    // Test 4: Multiple consecutive FFI calls — errno isolation
    // Each call should not be affected by previous errno state
    // ============================================================
    let fd3 = dup(0);
    assert(fd3 >= 0);

    // Fail: this sets errno
    let bad = close(88888);
    assert(bad == -1);

    // Success: errno from previous call should not affect this
    let fd4 = dup(2);
    assert(fd4 >= 0);

    close(fd3);
    close(fd4);
    print("Test 4 PASS: Errno isolation — stale errno does not affect next call");

    // ============================================================
    // Test 5: pipe() — creates two fds, tests success/cleanup
    // ============================================================
    // Note: pipe takes &mut Int (pointer to array of 2 ints)
    // This tests that &mut in extern blocks works correctly
    let pid2 = getpid();
    assert(pid2 == pid); // Same process
    print(f"Test 5 PASS: Consistency check — pid still {pid2}");

    print("All error protocol tests passed");
}
