// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, sliding-window, maximum, monotonic-deque
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for sliding window maximum using a monotonic deque.
// Given an array and window size k, find the maximum in each window.
// Uses a deque (double-ended queue) that maintains indices in
// decreasing order of their values (monotonic decreasing).
// O(n) time complexity.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// Deque implemented as circular buffer using Arr8 (max 8 elements)
// Stores indices into the original array
type Deque is { data: Arr8, front: Int, back: Int, size: Int };

fn deque_new() -> Deque {
    Deque { data: a8_zero(), front: 0, back: 0, size: 0 }
}

fn deque_is_empty(dq: Deque) -> Int {
    if dq.size == 0 { 1 } else { 0 }
}

fn deque_push_back(dq: Deque, val: Int) -> Deque {
    let new_data = a8_set(dq.data, dq.back, val);
    let new_back = (dq.back + 1) % 8;
    Deque { data: new_data, front: dq.front, back: new_back, size: dq.size + 1 }
}

fn deque_pop_front(dq: Deque) -> Deque {
    let new_front = (dq.front + 1) % 8;
    Deque { data: dq.data, front: new_front, back: dq.back, size: dq.size - 1 }
}

fn deque_pop_back(dq: Deque) -> Deque {
    let new_back = (dq.back - 1 + 8) % 8;
    Deque { data: dq.data, front: dq.front, back: new_back, size: dq.size - 1 }
}

fn deque_front(dq: Deque) -> Int {
    a8_get(dq.data, dq.front)
}

fn deque_back_val(dq: Deque) -> Int {
    let idx = (dq.back - 1 + 8) % 8;
    a8_get(dq.data, idx)
}

// Sliding window maximum using monotonic deque
// arr: input array of size n
// k: window size
// Returns array of maximums (n - k + 1 elements)
fn sliding_max(arr: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = a8_zero();
    let mut dq = deque_new();
    let mut ri = 0; // result index

    let mut i = 0;
    while i < n {
        // Remove elements outside the window from front
        while deque_is_empty(dq) == 0 {
            if deque_front(dq) <= i - k {
                dq = deque_pop_front(dq);
            } else {
                // break simulation: set condition to fail
                // use a flag approach
                dq = dq; // no-op, handled below
                i = i; // no-op to break
                // Actually we need a different approach since we can't break
                // Let's restructure:
                dq = dq;
                i = i;
                // Force exit
                let dummy = 999;
                let dummy2 = dummy;
                i = i; // placeholders - restructure below
            }
        }

        i = i; // This approach won't work. Let me restructure.
        i = i + 1;
    }

    // Reset and use a cleaner approach
    result
}

// Cleaner version: single pass with explicit front-check
fn sliding_max_v2(arr: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = a8_zero();
    let mut dq = deque_new();
    let mut ri = 0;

    let mut i = 0;
    while i < n {
        // Remove elements outside the window from front
        if deque_is_empty(dq) == 0 {
            if deque_front(dq) <= i - k {
                dq = deque_pop_front(dq);
            }
        }

        // Remove smaller elements from back (maintain decreasing order)
        // We can only remove one per iteration, but we loop
        let mut removing = 1;
        while removing == 1 {
            if deque_is_empty(dq) == 0 {
                if a8_get(arr, deque_back_val(dq)) <= a8_get(arr, i) {
                    dq = deque_pop_back(dq);
                } else {
                    removing = 0;
                }
            } else {
                removing = 0;
            }
        }

        // Add current index
        dq = deque_push_back(dq, i);

        // If we've processed at least k elements, record the maximum
        if i >= k - 1 {
            result = a8_set(result, ri, a8_get(arr, deque_front(dq)));
            ri = ri + 1;
        }

        i = i + 1;
    }

    result
}

// Naive sliding window maximum for verification
fn naive_sliding_max(arr: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = a8_zero();
    let mut ri = 0;
    let mut i = 0;
    while i <= n - k {
        let mut mx = a8_get(arr, i);
        let mut j = i + 1;
        while j < i + k {
            let v = a8_get(arr, j);
            if v > mx { mx = v; }
            j = j + 1;
        }
        result = a8_set(result, ri, mx);
        ri = ri + 1;
        i = i + 1;
    }
    result
}

// Also implement sliding window minimum
fn sliding_min_v2(arr: Arr8, n: Int, k: Int) -> Arr8 {
    let mut result = a8_zero();
    let mut dq = deque_new();
    let mut ri = 0;

    let mut i = 0;
    while i < n {
        if deque_is_empty(dq) == 0 {
            if deque_front(dq) <= i - k {
                dq = deque_pop_front(dq);
            }
        }

        let mut removing = 1;
        while removing == 1 {
            if deque_is_empty(dq) == 0 {
                if a8_get(arr, deque_back_val(dq)) >= a8_get(arr, i) {
                    dq = deque_pop_back(dq);
                } else {
                    removing = 0;
                }
            } else {
                removing = 0;
            }
        }

        dq = deque_push_back(dq, i);

        if i >= k - 1 {
            result = a8_set(result, ri, a8_get(arr, deque_front(dq)));
            ri = ri + 1;
        }

        i = i + 1;
    }

    result
}

// --- Tests ---

fn test_basic_sliding_max() {
    // arr = [1, 3, -1, -3, 5, 3, 6, 7], k = 3
    let arr = Arr8 { a0: 1, a1: 3, a2: -1, a3: -3, a4: 5, a5: 3, a6: 6, a7: 7 };
    let result = sliding_max_v2(arr, 8, 3);
    // Windows: [1,3,-1]=3, [3,-1,-3]=3, [-1,-3,5]=5, [-3,5,3]=5, [5,3,6]=6, [3,6,7]=7
    assert_eq(a8_get(result, 0), 3);
    assert_eq(a8_get(result, 1), 3);
    assert_eq(a8_get(result, 2), 5);
    assert_eq(a8_get(result, 3), 5);
    assert_eq(a8_get(result, 4), 6);
    assert_eq(a8_get(result, 5), 7);
}

fn test_matches_naive() {
    let arr = Arr8 { a0: 1, a1: 3, a2: -1, a3: -3, a4: 5, a5: 3, a6: 6, a7: 7 };
    let r1 = sliding_max_v2(arr, 8, 3);
    let r2 = naive_sliding_max(arr, 8, 3);
    let mut i = 0;
    while i < 6 {
        assert_eq(a8_get(r1, i), a8_get(r2, i));
        i = i + 1;
    }
}

fn test_window_size_1() {
    // k=1: each element is its own maximum
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let result = sliding_max_v2(arr, 8, 1);
    let mut i = 0;
    while i < 8 {
        assert_eq(a8_get(result, i), a8_get(arr, i));
        i = i + 1;
    }
}

fn test_window_size_n() {
    // k=n: single window, result is global maximum
    let arr = Arr8 { a0: 5, a1: 2, a2: 8, a3: 1, a4: 4, a5: 7, a6: 3, a7: 6 };
    let result = sliding_max_v2(arr, 8, 8);
    assert_eq(a8_get(result, 0), 8);
}

fn test_sorted_ascending() {
    let arr = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 6, a6: 7, a7: 8 };
    let result = sliding_max_v2(arr, 8, 3);
    // In ascending order, max of window is always the rightmost
    assert_eq(a8_get(result, 0), 3);
    assert_eq(a8_get(result, 1), 4);
    assert_eq(a8_get(result, 2), 5);
    assert_eq(a8_get(result, 3), 6);
    assert_eq(a8_get(result, 4), 7);
    assert_eq(a8_get(result, 5), 8);
}

fn test_sorted_descending() {
    let arr = Arr8 { a0: 8, a1: 7, a2: 6, a3: 5, a4: 4, a5: 3, a6: 2, a7: 1 };
    let result = sliding_max_v2(arr, 8, 3);
    // In descending order, max is always the leftmost
    assert_eq(a8_get(result, 0), 8);
    assert_eq(a8_get(result, 1), 7);
    assert_eq(a8_get(result, 2), 6);
    assert_eq(a8_get(result, 3), 5);
    assert_eq(a8_get(result, 4), 4);
    assert_eq(a8_get(result, 5), 3);
}

fn test_all_same() {
    let arr = Arr8 { a0: 5, a1: 5, a2: 5, a3: 5, a4: 5, a5: 5, a6: 5, a7: 5 };
    let result = sliding_max_v2(arr, 8, 4);
    let mut i = 0;
    while i < 5 {
        assert_eq(a8_get(result, i), 5);
        i = i + 1;
    }
}

fn test_sliding_min() {
    let arr = Arr8 { a0: 1, a1: 3, a2: -1, a3: -3, a4: 5, a5: 3, a6: 6, a7: 7 };
    let result = sliding_min_v2(arr, 8, 3);
    // Windows: [1,3,-1]=-1, [3,-1,-3]=-3, [-1,-3,5]=-3, [-3,5,3]=-3, [5,3,6]=3, [3,6,7]=3
    assert_eq(a8_get(result, 0), -1);
    assert_eq(a8_get(result, 1), -3);
    assert_eq(a8_get(result, 2), -3);
    assert_eq(a8_get(result, 3), -3);
    assert_eq(a8_get(result, 4), 3);
    assert_eq(a8_get(result, 5), 3);
}

fn test_deque_operations() {
    let mut dq = deque_new();
    assert_eq(deque_is_empty(dq), 1);
    dq = deque_push_back(dq, 10);
    assert_eq(deque_is_empty(dq), 0);
    assert_eq(deque_front(dq), 10);
    assert_eq(deque_back_val(dq), 10);
    dq = deque_push_back(dq, 20);
    assert_eq(deque_front(dq), 10);
    assert_eq(deque_back_val(dq), 20);
    dq = deque_pop_front(dq);
    assert_eq(deque_front(dq), 20);
    dq = deque_pop_back(dq);
    assert_eq(deque_is_empty(dq), 1);
}

fn test_window_size_2() {
    let arr = Arr8 { a0: 3, a1: 1, a2: 4, a3: 1, a4: 5, a5: 9, a6: 2, a7: 6 };
    let result = sliding_max_v2(arr, 8, 2);
    // [3,1]=3, [1,4]=4, [4,1]=4, [1,5]=5, [5,9]=9, [9,2]=9, [2,6]=6
    assert_eq(a8_get(result, 0), 3);
    assert_eq(a8_get(result, 1), 4);
    assert_eq(a8_get(result, 2), 4);
    assert_eq(a8_get(result, 3), 5);
    assert_eq(a8_get(result, 4), 9);
    assert_eq(a8_get(result, 5), 9);
    assert_eq(a8_get(result, 6), 6);
}

fn main() -> Int {
    test_basic_sliding_max();
    test_matches_naive();
    test_window_size_1();
    test_window_size_n();
    test_sorted_ascending();
    test_sorted_descending();
    test_all_same();
    test_sliding_min();
    test_deque_operations();
    test_window_size_2();
    print("[OK] 371_sliding_max_aot");
    0
}
