// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, markov-chain, probability, matrix
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Markov chain: transition matrix multiply, steady-state approximation
// Uses scaled integers (x1000) for fixed-point probability arithmetic
//
// Convention: M[i][j] = probability of going FROM state j TO state i
// So M * v gives the next state vector. Columns sum to 1000.

type Mat3 is {
    m00: Int, m01: Int, m02: Int,
    m10: Int, m11: Int, m12: Int,
    m20: Int, m21: Int, m22: Int
};

type Vec3 is { v0: Int, v1: Int, v2: Int };

fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }

// Matrix-vector multiply: result[i] = sum_j(mat[i][j] * vec[j]) / SCALE
fn mat_vec_mul(m: Mat3, v: Vec3) -> Vec3 {
    let r0 = (m.m00 * v.v0 + m.m01 * v.v1 + m.m02 * v.v2) / 1000;
    let r1 = (m.m10 * v.v0 + m.m11 * v.v1 + m.m12 * v.v2) / 1000;
    let r2 = (m.m20 * v.v0 + m.m21 * v.v1 + m.m22 * v.v2) / 1000;
    Vec3 { v0: r0, v1: r1, v2: r2 }
}

// Matrix-matrix multiply (both scaled x1000)
fn mat_mul(a: Mat3, b: Mat3) -> Mat3 {
    let c00 = (a.m00*b.m00 + a.m01*b.m10 + a.m02*b.m20) / 1000;
    let c01 = (a.m00*b.m01 + a.m01*b.m11 + a.m02*b.m21) / 1000;
    let c02 = (a.m00*b.m02 + a.m01*b.m12 + a.m02*b.m22) / 1000;
    let c10 = (a.m10*b.m00 + a.m11*b.m10 + a.m12*b.m20) / 1000;
    let c11 = (a.m10*b.m01 + a.m11*b.m11 + a.m12*b.m21) / 1000;
    let c12 = (a.m10*b.m02 + a.m11*b.m12 + a.m12*b.m22) / 1000;
    let c20 = (a.m20*b.m00 + a.m21*b.m10 + a.m22*b.m20) / 1000;
    let c21 = (a.m20*b.m01 + a.m21*b.m11 + a.m22*b.m21) / 1000;
    let c22 = (a.m20*b.m02 + a.m21*b.m12 + a.m22*b.m22) / 1000;
    Mat3 {
        m00: c00, m01: c01, m02: c02,
        m10: c10, m11: c11, m12: c12,
        m20: c20, m21: c21, m22: c22
    }
}

// Iterate: multiply state vector by transition matrix n times
fn iterate_chain(trans: Mat3, state: Vec3, steps: Int) -> Vec3 {
    let mut s = state;
    let mut i = 0;
    while i < steps {
        s = mat_vec_mul(trans, s);
        i = i + 1;
    }
    s
}

// Matrix power: square-and-multiply
fn mat_pow(m: Mat3, n: Int) -> Mat3 {
    let mut result = Mat3 {
        m00: 1000, m01: 0, m02: 0,
        m10: 0, m11: 1000, m12: 0,
        m20: 0, m21: 0, m22: 1000
    };
    let mut base = m;
    let mut exp = n;
    while exp > 0 {
        if exp % 2 == 1 {
            result = mat_mul(result, base);
        }
        base = mat_mul(base, base);
        exp = exp / 2;
    }
    result
}

// Helper to assert val < threshold without assert_eq(bool, true)
fn check_lt(val: Int, threshold: Int) {
    if val >= threshold {
        assert_eq(val, threshold - 1);
    }
}

fn test_mat_vec_identity() {
    let ident = Mat3 { m00: 1000, m01: 0, m02: 0, m10: 0, m11: 1000, m12: 0, m20: 0, m21: 0, m22: 1000 };
    let v = Vec3 { v0: 250, v1: 250, v2: 250 };
    let r = mat_vec_mul(ident, v);
    assert_eq(r.v0, 250);
    assert_eq(r.v1, 250);
    assert_eq(r.v2, 250);
}

fn test_simple_transition() {
    // 2-state symmetric chain: each state goes 50/50 to either state
    // Col 0: [500, 500, 0] = from 0: 50% stay, 50% to 1
    // Col 1: [500, 500, 0] = from 1: 50% to 0, 50% stay
    let trans = Mat3 { m00: 500, m01: 500, m02: 0, m10: 500, m11: 500, m12: 0, m20: 0, m21: 0, m22: 0 };

    let start = Vec3 { v0: 1000, v1: 0, v2: 0 };
    let after1 = mat_vec_mul(trans, start);
    assert_eq(after1.v0, 500);
    assert_eq(after1.v1, 500);

    let steady = iterate_chain(trans, start, 20);
    assert_eq(steady.v0, 500);
    assert_eq(steady.v1, 500);
}

fn test_absorbing_state() {
    // State 0 -> State 1 always, State 1 absorbing
    // Col 0: [0, 1000, 0] = from state 0, all goes to state 1
    // Col 1: [0, 1000, 0] = from state 1, stays at state 1
    let trans = Mat3 { m00: 0, m01: 0, m02: 0, m10: 1000, m11: 1000, m12: 0, m20: 0, m21: 0, m22: 0 };
    let start = Vec3 { v0: 1000, v1: 0, v2: 0 };
    let after1 = mat_vec_mul(trans, start);
    assert_eq(after1.v0, 0);
    assert_eq(after1.v1, 1000);

    let after5 = iterate_chain(trans, start, 5);
    assert_eq(after5.v0, 0);
    assert_eq(after5.v1, 1000);
}

fn test_cyclic_chain() {
    // Deterministic cycle: 0->1->2->0
    // Col 0: [0, 1000, 0] = from 0 -> to 1
    // Col 1: [0, 0, 1000] = from 1 -> to 2
    // Col 2: [1000, 0, 0] = from 2 -> to 0
    let trans = Mat3 { m00: 0, m01: 0, m02: 1000, m10: 1000, m11: 0, m12: 0, m20: 0, m21: 1000, m22: 0 };
    let start = Vec3 { v0: 1000, v1: 0, v2: 0 };

    let step1 = mat_vec_mul(trans, start);
    assert_eq(step1.v0, 0);
    assert_eq(step1.v1, 1000);
    assert_eq(step1.v2, 0);

    let step2 = mat_vec_mul(trans, step1);
    assert_eq(step2.v0, 0);
    assert_eq(step2.v1, 0);
    assert_eq(step2.v2, 1000);

    // Back to state 0 after 3 steps
    let step3 = mat_vec_mul(trans, step2);
    assert_eq(step3.v0, 1000);
    assert_eq(step3.v1, 0);
    assert_eq(step3.v2, 0);
}

fn test_steady_state() {
    // 3-state ergodic chain (column-stochastic):
    // Col 0: [200, 500, 300] = from 0: 20% stay, 50% to 1, 30% to 2
    // Col 1: [300, 400, 300] = from 1: 30% to 0, 40% stay, 30% to 2
    // Col 2: [500, 100, 400] = from 2: 50% to 0, 10% to 1, 40% stay
    let trans = Mat3 { m00: 200, m01: 300, m02: 500, m10: 500, m11: 400, m12: 100, m20: 300, m21: 300, m22: 400 };

    let start = Vec3 { v0: 1000, v1: 0, v2: 0 };
    let s20 = iterate_chain(trans, start, 20);
    let s30 = iterate_chain(trans, start, 30);

    // Convergence check
    check_lt(abs_val(s20.v0 - s30.v0), 5);
    check_lt(abs_val(s20.v1 - s30.v1), 5);
    check_lt(abs_val(s20.v2 - s30.v2), 5);

    // Sum should be ~1000
    let total = s30.v0 + s30.v1 + s30.v2;
    check_lt(abs_val(total - 1000), 10);
}

fn test_mat_mul_identity() {
    let ident = Mat3 { m00: 1000, m01: 0, m02: 0, m10: 0, m11: 1000, m12: 0, m20: 0, m21: 0, m22: 1000 };
    let a = Mat3 { m00: 100, m01: 200, m02: 300, m10: 400, m11: 500, m12: 600, m20: 700, m21: 800, m22: 900 };
    let r = mat_mul(ident, a);
    assert_eq(r.m00, 100);
    assert_eq(r.m11, 500);
    assert_eq(r.m22, 900);
    assert_eq(r.m01, 200);
}

fn test_mat_power() {
    let ident = Mat3 { m00: 1000, m01: 0, m02: 0, m10: 0, m11: 1000, m12: 0, m20: 0, m21: 0, m22: 1000 };
    let ip = mat_pow(ident, 10);
    assert_eq(ip.m00, 1000);
    assert_eq(ip.m11, 1000);
    assert_eq(ip.m01, 0);
}

fn test_column_stochastic() {
    let trans = Mat3 { m00: 200, m01: 300, m02: 500, m10: 500, m11: 400, m12: 100, m20: 300, m21: 300, m22: 400 };
    // Column sums = 1000
    assert_eq(trans.m00 + trans.m10 + trans.m20, 1000);
    assert_eq(trans.m01 + trans.m11 + trans.m21, 1000);
    assert_eq(trans.m02 + trans.m12 + trans.m22, 1000);
}

fn test_different_starts() {
    let trans = Mat3 { m00: 200, m01: 300, m02: 500, m10: 500, m11: 400, m12: 100, m20: 300, m21: 300, m22: 400 };
    let sa = iterate_chain(trans, Vec3 { v0: 1000, v1: 0, v2: 0 }, 30);
    let sb = iterate_chain(trans, Vec3 { v0: 0, v1: 1000, v2: 0 }, 30);
    check_lt(abs_val(sa.v0 - sb.v0), 5);
    check_lt(abs_val(sa.v1 - sb.v1), 5);
    check_lt(abs_val(sa.v2 - sb.v2), 5);
}

fn main() -> Int {
    test_mat_vec_identity();
    test_simple_transition();
    test_absorbing_state();
    test_cyclic_chain();
    test_steady_state();
    test_mat_mul_identity();
    test_mat_power();
    test_column_stochastic();
    test_different_starts();
    print("[OK] 309_markov_chain_aot");
    0
}
