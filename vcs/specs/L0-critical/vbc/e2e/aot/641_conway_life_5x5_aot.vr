// @test: run
// @level: L0
// @tags: aot, e2e, conway, game-of-life, 5x5
// @timeout: 30000

// Conway's Game of Life on a 5x5 grid (25 bits packed in Int)

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn get_cell(grid: Int, r: Int, c: Int) -> Int {
    if r < 0 { 0 }
    else if r >= 5 { 0 }
    else if c < 0 { 0 }
    else if c >= 5 { 0 }
    else { (grid / pow2(r * 5 + c)) % 2 }
}

fn set_cell(grid: Int, r: Int, c: Int, val: Int) -> Int {
    let pos = r * 5 + c;
    let cur = get_cell(grid, r, c);
    if cur == val { grid }
    else if val == 1 { grid + pow2(pos) }
    else { grid - pow2(pos) }
}

// Count live neighbors of cell (r,c)
fn count_neighbors(grid: Int, r: Int, c: Int) -> Int {
    get_cell(grid, r - 1, c - 1) + get_cell(grid, r - 1, c) + get_cell(grid, r - 1, c + 1) +
    get_cell(grid, r, c - 1) + get_cell(grid, r, c + 1) +
    get_cell(grid, r + 1, c - 1) + get_cell(grid, r + 1, c) + get_cell(grid, r + 1, c + 1)
}

// One generation step
fn life_step(grid: Int) -> Int {
    let mut next = 0;
    let mut r = 0;
    while r < 5 {
        let mut c = 0;
        while c < 5 {
            let alive = get_cell(grid, r, c);
            let neighbors = count_neighbors(grid, r, c);
            // Rules: alive with 2-3 neighbors survives, dead with 3 neighbors born
            if alive == 1 {
                if neighbors == 2 { next = set_cell(next, r, c, 1); }
                else if neighbors == 3 { next = set_cell(next, r, c, 1); }
            } else {
                if neighbors == 3 { next = set_cell(next, r, c, 1); }
            }
            c = c + 1;
        }
        r = r + 1;
    }
    next
}

// Run for n generations
fn life_run(grid: Int, n: Int) -> Int {
    let mut g = grid;
    let mut i = 0;
    while i < n { g = life_step(g); i = i + 1; }
    g
}

// Count total live cells
fn population(grid: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 25 {
        count = count + (grid / pow2(i)) % 2;
        i = i + 1;
    }
    count
}

fn test_empty() -> Int {
    // Empty grid stays empty
    assert_eq(life_step(0), 0);
    assert_eq(population(0), 0);
    1
}

fn test_single_cell_dies() -> Int {
    // Single cell at (2,2) dies (no neighbors)
    let grid = set_cell(0, 2, 2, 1);
    assert_eq(population(grid), 1);
    let next = life_step(grid);
    assert_eq(population(next), 0);
    1
}

fn test_block_still_life() -> Int {
    // Block (2x2 square) at (1,1)-(2,2)
    let mut grid = 0;
    grid = set_cell(grid, 1, 1, 1);
    grid = set_cell(grid, 1, 2, 1);
    grid = set_cell(grid, 2, 1, 1);
    grid = set_cell(grid, 2, 2, 1);
    assert_eq(population(grid), 4);
    // Block is stable
    let next = life_step(grid);
    assert_eq(next, grid);
    // Still stable after multiple generations
    assert_eq(life_run(grid, 10), grid);
    1
}

fn test_blinker() -> Int {
    // Blinker: horizontal line at row 2, cols 1-3
    let mut grid = 0;
    grid = set_cell(grid, 2, 1, 1);
    grid = set_cell(grid, 2, 2, 1);
    grid = set_cell(grid, 2, 3, 1);
    assert_eq(population(grid), 3);
    // Step 1: becomes vertical at col 2, rows 1-3
    let step1 = life_step(grid);
    assert_eq(get_cell(step1, 1, 2), 1);
    assert_eq(get_cell(step1, 2, 2), 1);
    assert_eq(get_cell(step1, 3, 2), 1);
    assert_eq(population(step1), 3);
    // Step 2: back to horizontal (period 2)
    let step2 = life_step(step1);
    assert_eq(step2, grid);
    1
}

fn test_glider() -> Int {
    // Glider pattern (moves diagonally)
    //   .X.
    //   ..X
    //   XXX
    let mut grid = 0;
    grid = set_cell(grid, 0, 1, 1);
    grid = set_cell(grid, 1, 2, 1);
    grid = set_cell(grid, 2, 0, 1);
    grid = set_cell(grid, 2, 1, 1);
    grid = set_cell(grid, 2, 2, 1);
    assert_eq(population(grid), 5);
    // After 1 step
    let step1 = life_step(grid);
    assert_eq(population(step1), 5); // Population preserved
    // After 4 steps, glider should have moved 1 cell diagonally
    let step4 = life_run(grid, 4);
    assert_eq(population(step4), 5);
    1
}

fn test_tub_still_life() -> Int {
    // Tub pattern:
    //  .X.
    //  X.X
    //  .X.
    let mut grid = 0;
    grid = set_cell(grid, 1, 2, 1);
    grid = set_cell(grid, 2, 1, 1);
    grid = set_cell(grid, 2, 3, 1);
    grid = set_cell(grid, 3, 2, 1);
    assert_eq(population(grid), 4);
    // Tub is a still life
    assert_eq(life_step(grid), grid);
    1
}

fn test_cell_access() -> Int {
    let mut g = 0;
    g = set_cell(g, 0, 0, 1);
    assert_eq(get_cell(g, 0, 0), 1);
    assert_eq(get_cell(g, 0, 1), 0);
    g = set_cell(g, 4, 4, 1);
    assert_eq(get_cell(g, 4, 4), 1);
    // Out of bounds returns 0
    assert_eq(get_cell(g, 5, 0), 0);
    assert_eq(get_cell(g, 0, 5), 0);
    1
}

fn main() -> Int {
    test_empty();
    test_single_cell_dies();
    test_block_still_life();
    test_blinker();
    test_glider();
    test_tub_still_life();
    test_cell_access();
    print("[OK] 641_conway_life_5x5_aot");
    0
}
