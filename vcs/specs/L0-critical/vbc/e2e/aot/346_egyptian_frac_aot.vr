// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, egyptian-fractions, greedy-algorithm, unit-fractions
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Egyptian fraction decomposition (greedy algorithm):
// Express any fraction p/q as a sum of distinct unit fractions 1/d1 + 1/d2 + ...
// Uses the greedy algorithm: at each step, find the smallest d such that 1/d <= p/q,
// then subtract 1/d from p/q and repeat.
// Stores denominators in a fixed-size array.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// GCD using Euclidean algorithm
fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    if x < 0 { x = 0 - x; }
    if y < 0 { y = 0 - y; }
    while y > 0 {
        let t = y;
        y = x % y;
        x = t;
    }
    x
}

// Ceiling division: ceil(a/b) for positive a, b
fn ceil_div(a: Int, b: Int) -> Int {
    (a + b - 1) / b
}

// Egyptian fraction result: array of denominators and count
type EgyptFrac is { denoms: Arr8, count: Int };

// Greedy Egyptian fraction decomposition of p/q
// Returns denominators of unit fractions: p/q = 1/d[0] + 1/d[1] + ...
fn egyptian(p_in: Int, q_in: Int) -> EgyptFrac {
    let mut p = p_in;
    let mut q = q_in;
    let mut denoms = a8_zero();
    let mut count = 0;

    // Reduce fraction first
    let g0 = gcd(p, q);
    p = p / g0;
    q = q / g0;

    while p > 0 {
        if count >= 8 { p = 0; } // safety limit
        else {
            if p == 1 {
                // Already a unit fraction
                denoms = a8_set(denoms, count, q);
                count = count + 1;
                p = 0;
            } else {
                // Find smallest d such that 1/d <= p/q, i.e., d >= q/p => d = ceil(q/p)
                let d = ceil_div(q, p);
                denoms = a8_set(denoms, count, d);
                count = count + 1;
                // Subtract 1/d from p/q: p/q - 1/d = (p*d - q) / (q*d)
                let new_p = p * d - q;
                let new_q = q * d;
                let g = gcd(new_p, new_q);
                if g > 0 {
                    p = new_p / g;
                    q = new_q / g;
                } else {
                    p = 0; // done
                }
            }
        }
    }

    EgyptFrac { denoms: denoms, count: count }
}

// Verify: sum of 1/d[i] should equal p/q
// We compute sum as a fraction and compare
fn verify_sum(ef: EgyptFrac, p: Int, q: Int) -> Int {
    // Start with sum = 0/1
    let mut sn = 0; // sum numerator
    let mut sd = 1; // sum denominator

    let mut i = 0;
    while i < ef.count {
        let d = a8_get(ef.denoms, i);
        // Add 1/d to sn/sd: sn/sd + 1/d = (sn*d + sd) / (sd*d)
        sn = sn * d + sd;
        sd = sd * d;
        let g = gcd(sn, sd);
        if g > 0 {
            sn = sn / g;
            sd = sd / g;
        }
        i = i + 1;
    }

    // Compare sn/sd == p/q
    let gp = gcd(p, q);
    let rp = p / gp;
    let rq = q / gp;
    if sn == rp {
        if sd == rq { 1 } else { 0 }
    } else { 0 }
}

// Check all denominators are distinct
fn all_distinct(ef: EgyptFrac) -> Int {
    let mut ok = 1;
    let mut i = 0;
    while i < ef.count {
        let mut j = i + 1;
        while j < ef.count {
            if a8_get(ef.denoms, i) == a8_get(ef.denoms, j) { ok = 0; }
            j = j + 1;
        }
        i = i + 1;
    }
    ok
}

// Check denominators are in increasing order
fn is_increasing(ef: EgyptFrac) -> Int {
    let mut ok = 1;
    let mut i = 1;
    while i < ef.count {
        if a8_get(ef.denoms, i) <= a8_get(ef.denoms, i - 1) { ok = 0; }
        i = i + 1;
    }
    ok
}

fn test_unit_fraction() {
    // 1/5 = 1/5 (already unit)
    let ef = egyptian(1, 5);
    assert_eq(ef.count, 1);
    assert_eq(a8_get(ef.denoms, 0), 5);
    assert_eq(verify_sum(ef, 1, 5), 1);
}

fn test_two_thirds() {
    // 2/3: ceil(3/2) = 2, so first term 1/2
    // Remainder: 2/3 - 1/2 = 1/6
    // Result: 1/2 + 1/6
    let ef = egyptian(2, 3);
    assert_eq(ef.count, 2);
    assert_eq(a8_get(ef.denoms, 0), 2);
    assert_eq(a8_get(ef.denoms, 1), 6);
    assert_eq(verify_sum(ef, 2, 3), 1);
    assert_eq(all_distinct(ef), 1);
}

fn test_three_quarters() {
    // 3/4: ceil(4/3) = 2, first term 1/2
    // Remainder: 3/4 - 1/2 = 1/4
    // Result: 1/2 + 1/4
    let ef = egyptian(3, 4);
    assert_eq(ef.count, 2);
    assert_eq(a8_get(ef.denoms, 0), 2);
    assert_eq(a8_get(ef.denoms, 1), 4);
    assert_eq(verify_sum(ef, 3, 4), 1);
}

fn test_two_fifths() {
    // 2/5: ceil(5/2) = 3, first term 1/3
    // Remainder: 2/5 - 1/3 = (6-5)/15 = 1/15
    // Result: 1/3 + 1/15
    let ef = egyptian(2, 5);
    assert_eq(ef.count, 2);
    assert_eq(a8_get(ef.denoms, 0), 3);
    assert_eq(a8_get(ef.denoms, 1), 15);
    assert_eq(verify_sum(ef, 2, 5), 1);
}

fn test_four_sevenths() {
    // 4/7: ceil(7/4) = 2, first term 1/2
    // Remainder: 4/7 - 1/2 = (8-7)/14 = 1/14
    // Result: 1/2 + 1/14
    let ef = egyptian(4, 7);
    assert_eq(ef.count, 2);
    assert_eq(a8_get(ef.denoms, 0), 2);
    assert_eq(a8_get(ef.denoms, 1), 14);
    assert_eq(verify_sum(ef, 4, 7), 1);
}

fn test_five_sixths() {
    // 5/6: ceil(6/5) = 2, first term 1/2
    // Remainder: 5/6 - 1/2 = 2/6 = 1/3
    // Result: 1/2 + 1/3
    let ef = egyptian(5, 6);
    assert_eq(ef.count, 2);
    assert_eq(a8_get(ef.denoms, 0), 2);
    assert_eq(a8_get(ef.denoms, 1), 3);
    assert_eq(verify_sum(ef, 5, 6), 1);
}

fn test_three_sevenths() {
    // 3/7: ceil(7/3) = 3, first term 1/3
    // Remainder: 3/7 - 1/3 = (9-7)/21 = 2/21
    // 2/21: ceil(21/2) = 11, first term 1/11
    // Remainder: 2/21 - 1/11 = (22-21)/231 = 1/231
    // Result: 1/3 + 1/11 + 1/231
    let ef = egyptian(3, 7);
    assert_eq(ef.count, 3);
    assert_eq(a8_get(ef.denoms, 0), 3);
    assert_eq(a8_get(ef.denoms, 1), 11);
    assert_eq(a8_get(ef.denoms, 2), 231);
    assert_eq(verify_sum(ef, 3, 7), 1);
    assert_eq(all_distinct(ef), 1);
    assert_eq(is_increasing(ef), 1);
}

fn test_reducible_fraction() {
    // 4/6 = 2/3 after reduction
    let ef = egyptian(4, 6);
    assert_eq(verify_sum(ef, 4, 6), 1);
    assert_eq(ef.count, 2);
}

fn test_whole_number() {
    // 3/3 = 1/1
    let ef = egyptian(3, 3);
    assert_eq(ef.count, 1);
    assert_eq(a8_get(ef.denoms, 0), 1);
    assert_eq(verify_sum(ef, 3, 3), 1);
}

fn test_gcd() {
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(7, 13), 1);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(1, 1), 1);
    assert_eq(gcd(0, 5), 5);
}

fn test_ceil_div_fn() {
    assert_eq(ceil_div(7, 3), 3);
    assert_eq(ceil_div(6, 3), 2);
    assert_eq(ceil_div(1, 1), 1);
    assert_eq(ceil_div(10, 3), 4);
}

fn main() -> Int {
    test_unit_fraction();
    test_two_thirds();
    test_three_quarters();
    test_two_fifths();
    test_four_sevenths();
    test_five_sixths();
    test_three_sevenths();
    test_reducible_fraction();
    test_whole_number();
    test_gcd();
    test_ceil_div_fn();
    print("[OK] 346_egyptian_frac_aot");
    0
}
