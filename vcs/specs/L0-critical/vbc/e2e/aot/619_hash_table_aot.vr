// @test: run
// @level: L0
// @tags: aot, e2e, hash-table, data-structure, lookup
// @timeout: 30000

// Simple hash table with linear probing using Arr8s
// Keys in one Arr8, values in another, 0 = empty slot

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Simple hash: key mod table_size
fn hash_fn(key: Int, size: Int) -> Int {
    let k = if key < 0 { 0 - key } else { key };
    k % size
}

// Find slot for key using linear probing (returns slot index or -1 if full)
fn find_slot(keys: Arr8, size: Int, key: Int) -> Int {
    let start = hash_fn(key, size);
    let mut i = 0;
    let mut result = 0 - 1;
    while i < size {
        let idx = (start + i) % size;
        let k = get8(keys, idx);
        if k == 0 {
            if result < 0 { result = idx; }
            i = size; // break
        } else if k == key {
            result = idx;
            i = size; // break
        } else {
            i = i + 1;
        }
    }
    result
}

// Lookup key, return value or -1
fn ht_get(keys: Arr8, vals: Arr8, size: Int, key: Int) -> Int {
    let start = hash_fn(key, size);
    let mut i = 0;
    let mut result = 0 - 1;
    while i < size {
        let idx = (start + i) % size;
        let k = get8(keys, idx);
        if k == 0 {
            i = size; // break, not found
        } else if k == key {
            result = get8(vals, idx);
            i = size; // break
        } else {
            i = i + 1;
        }
    }
    result
}

// Count non-empty slots
fn ht_count(keys: Arr8, size: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < size {
        if get8(keys, i) != 0 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Check if key exists
fn ht_contains(keys: Arr8, size: Int, key: Int) -> Int {
    let start = hash_fn(key, size);
    let mut i = 0;
    let mut found = 0;
    while i < size {
        let idx = (start + i) % size;
        let k = get8(keys, idx);
        if k == 0 {
            i = size;
        } else if k == key {
            found = 1;
            i = size;
        } else {
            i = i + 1;
        }
    }
    found
}

fn test_basic_insert_lookup() -> Int {
    // Pre-built hash table with keys 10,20,30 mapped to values 100,200,300
    // hash_fn(10, 8) = 2, hash_fn(20, 8) = 4, hash_fn(30, 8) = 6
    let keys = Arr8 { v0: 0, v1: 0, v2: 10, v3: 0, v4: 20, v5: 0, v6: 30, v7: 0 };
    let vals = Arr8 { v0: 0, v1: 0, v2: 100, v3: 0, v4: 200, v5: 0, v6: 300, v7: 0 };
    assert_eq(ht_get(keys, vals, 8, 10), 100);
    assert_eq(ht_get(keys, vals, 8, 20), 200);
    assert_eq(ht_get(keys, vals, 8, 30), 300);
    assert_eq(ht_get(keys, vals, 8, 40), 0 - 1); // not found
    1
}

fn test_contains() -> Int {
    let keys = Arr8 { v0: 0, v1: 0, v2: 10, v3: 0, v4: 20, v5: 0, v6: 30, v7: 0 };
    assert_eq(ht_contains(keys, 8, 10), 1);
    assert_eq(ht_contains(keys, 8, 20), 1);
    assert_eq(ht_contains(keys, 8, 30), 1);
    assert_eq(ht_contains(keys, 8, 40), 0);
    assert_eq(ht_contains(keys, 8, 5), 0);
    1
}

fn test_count() -> Int {
    let empty = zeros();
    assert_eq(ht_count(empty, 8), 0);
    let keys = Arr8 { v0: 0, v1: 0, v2: 10, v3: 0, v4: 20, v5: 0, v6: 30, v7: 0 };
    assert_eq(ht_count(keys, 8), 3);
    let full = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    assert_eq(ht_count(full, 8), 8);
    1
}

fn test_collision() -> Int {
    // Keys 2 and 10 both hash to slot 2 (mod 8)
    // 2 goes to slot 2, 10 probes to slot 3
    let keys = Arr8 { v0: 0, v1: 0, v2: 2, v3: 10, v4: 0, v5: 0, v6: 0, v7: 0 };
    let vals = Arr8 { v0: 0, v1: 0, v2: 22, v3: 110, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(ht_get(keys, vals, 8, 2), 22);
    assert_eq(ht_get(keys, vals, 8, 10), 110);
    assert_eq(ht_contains(keys, 8, 2), 1);
    assert_eq(ht_contains(keys, 8, 10), 1);
    1
}

fn test_find_slot() -> Int {
    let empty = zeros();
    // In empty table, find_slot returns hash position
    assert_eq(find_slot(empty, 8, 10), 2); // 10 % 8 = 2
    assert_eq(find_slot(empty, 8, 20), 4); // 20 % 8 = 4

    // With collision: key 2 at slot 2, finding slot for 10 should give 3
    let keys = Arr8 { v0: 0, v1: 0, v2: 2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(find_slot(keys, 8, 10), 3); // 10%8=2 occupied, probe to 3
    1
}

fn test_hash_fn() -> Int {
    assert_eq(hash_fn(0, 8), 0);
    assert_eq(hash_fn(1, 8), 1);
    assert_eq(hash_fn(8, 8), 0);
    assert_eq(hash_fn(9, 8), 1);
    assert_eq(hash_fn(15, 8), 7);
    assert_eq(hash_fn(16, 8), 0);
    1
}

fn main() -> Int {
    test_basic_insert_lookup();
    test_contains();
    test_count();
    test_collision();
    test_find_slot();
    test_hash_fn();
    print("[OK] 619_hash_table_aot");
    0
}
