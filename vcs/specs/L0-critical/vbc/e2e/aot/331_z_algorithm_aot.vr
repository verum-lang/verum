// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, z-algorithm, string-matching, algorithm
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Z-algorithm: string matching using Z-array.
// The Z-array for a string S: Z[i] = length of longest substring starting
// at i that matches a prefix of S.
// Pattern matching: concatenate pattern + sentinel + text, compute Z-array,
// positions where Z[i] == |pattern| are matches.
//
// Since AOT doesn't support actual strings well, we simulate with integer arrays
// where each element represents a character code.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int, len: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

// 16-element array for larger strings
type Arr16 is {
    d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int,
    d8: Int, d9: Int, d10: Int, d11: Int, d12: Int, d13: Int, d14: Int, d15: Int,
    len: Int
};

fn a16_zero(n: Int) -> Arr16 {
    Arr16 { d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0,
            d8: 0, d9: 0, d10: 0, d11: 0, d12: 0, d13: 0, d14: 0, d15: 0, len: n }
}

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 } else if i == 3 { a.d3 }
    else if i == 4 { a.d4 } else if i == 5 { a.d5 } else if i == 6 { a.d6 } else if i == 7 { a.d7 }
    else if i == 8 { a.d8 } else if i == 9 { a.d9 } else if i == 10 { a.d10 } else if i == 11 { a.d11 }
    else if i == 12 { a.d12 } else if i == 13 { a.d13 } else if i == 14 { a.d14 } else { a.d15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 },
        d8: if i == 8 { v } else { a.d8 }, d9: if i == 9 { v } else { a.d9 },
        d10: if i == 10 { v } else { a.d10 }, d11: if i == 11 { v } else { a.d11 },
        d12: if i == 12 { v } else { a.d12 }, d13: if i == 13 { v } else { a.d13 },
        d14: if i == 14 { v } else { a.d14 }, d15: if i == 15 { v } else { a.d15 },
        len: a.len
    }
}

fn min2(a: Int, b_val: Int) -> Int { if a < b_val { a } else { b_val } }

// Compute Z-array for string s of length n
// Z[0] is undefined (often set to 0 or n)
fn compute_z(s: Arr16, n: Int) -> Arr16 {
    let mut z = a16_zero(n);
    let mut left = 0;
    let mut right = 0;
    let mut i = 1;
    while i < n {
        if i < right {
            let zi = min2(a16_get(z, i - left), right - i);
            z = a16_set(z, i, zi);
        }
        // Try to extend
        let mut cur_z = a16_get(z, i);
        while i + cur_z < n {
            if a16_get(s, cur_z) == a16_get(s, i + cur_z) {
                cur_z = cur_z + 1;
            } else {
                // break simulation
                i = i + n;  // will exit inner loop
            }
            if i + cur_z >= n {
                i = i + n;  // will exit inner loop
            }
        }
        // Undo the i modification if we used it to break
        if i >= n {
            i = i - n;
        }
        z = a16_set(z, i, cur_z);
        if i + cur_z > right {
            left = i;
            right = i + cur_z;
        }
        i = i + 1;
    }
    z
}

// Actually let me redo compute_z more carefully to avoid the break hack
fn compute_z_v2(s: Arr16, n: Int) -> Arr16 {
    let mut z = a16_zero(n);
    let mut left = 0;
    let mut right = 0;
    let mut i = 1;
    while i < n {
        let mut cur_z = 0;
        if i < right {
            cur_z = min2(a16_get(z, i - left), right - i);
        }
        // Extend match
        let mut extending = 1;
        while extending == 1 {
            if i + cur_z < n {
                if a16_get(s, cur_z) == a16_get(s, i + cur_z) {
                    cur_z = cur_z + 1;
                } else {
                    extending = 0;
                }
            } else {
                extending = 0;
            }
        }
        z = a16_set(z, i, cur_z);
        if i + cur_z > right {
            left = i;
            right = i + cur_z;
        }
        i = i + 1;
    }
    z
}

// Pattern matching: find occurrences of pattern in text
// Constructs combined = pattern + sentinel(-1) + text, computes Z-array
// Returns count of matches and first match position (encoded)
fn z_search_count(pattern: Arr8, plen: Int, text: Arr8, tlen: Int) -> Int {
    // Build combined string: pattern + sentinel + text
    let total = plen + 1 + tlen;
    let mut combined = a16_zero(total);
    let mut i = 0;
    while i < plen {
        combined = a16_set(combined, i, arr8_get(pattern, i));
        i = i + 1;
    }
    combined = a16_set(combined, plen, -1);  // sentinel
    i = 0;
    while i < tlen {
        combined = a16_set(combined, plen + 1 + i, arr8_get(text, i));
        i = i + 1;
    }

    let z = compute_z_v2(combined, total);

    // Count positions where Z[i] == plen (match found)
    let mut count = 0;
    i = plen + 1;
    while i < total {
        if a16_get(z, i) == plen {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

// Find first match position in text (or -1 if not found)
fn z_search_first(pattern: Arr8, plen: Int, text: Arr8, tlen: Int) -> Int {
    let total = plen + 1 + tlen;
    let mut combined = a16_zero(total);
    let mut i = 0;
    while i < plen {
        combined = a16_set(combined, i, arr8_get(pattern, i));
        i = i + 1;
    }
    combined = a16_set(combined, plen, -1);
    i = 0;
    while i < tlen {
        combined = a16_set(combined, plen + 1 + i, arr8_get(text, i));
        i = i + 1;
    }

    let z = compute_z_v2(combined, total);

    i = plen + 1;
    while i < total {
        if a16_get(z, i) == plen {
            return i - plen - 1;  // Position in original text
        }
        i = i + 1;
    }
    -1
}

fn test_z_array_basic() {
    // String: "aabxaa" = [1,1,2,24,1,1]
    // Z-array: Z[0]=undef, Z[1]=1, Z[2]=0, Z[3]=0, Z[4]=2, Z[5]=1
    let s = a16_zero(6);
    let mut ss = s;
    ss = a16_set(ss, 0, 1);  // a
    ss = a16_set(ss, 1, 1);  // a
    ss = a16_set(ss, 2, 2);  // b
    ss = a16_set(ss, 3, 24); // x
    ss = a16_set(ss, 4, 1);  // a
    ss = a16_set(ss, 5, 1);  // a

    let z = compute_z_v2(ss, 6);
    assert_eq(a16_get(z, 1), 1);   // "a" matches prefix "a"
    assert_eq(a16_get(z, 2), 0);   // "bxaa" doesn't match prefix "aa..."
    assert_eq(a16_get(z, 3), 0);   // "xaa" doesn't match
    assert_eq(a16_get(z, 4), 2);   // "aa" matches prefix "aa"
    assert_eq(a16_get(z, 5), 1);   // "a" matches prefix "a"
}

fn test_z_array_all_same() {
    // String: "aaaa" = [1,1,1,1]
    // Z: Z[1]=3, Z[2]=2, Z[3]=1
    let mut s = a16_zero(4);
    s = a16_set(s, 0, 5);
    s = a16_set(s, 1, 5);
    s = a16_set(s, 2, 5);
    s = a16_set(s, 3, 5);

    let z = compute_z_v2(s, 4);
    assert_eq(a16_get(z, 1), 3);
    assert_eq(a16_get(z, 2), 2);
    assert_eq(a16_get(z, 3), 1);
}

fn test_z_array_no_match() {
    // String: "abcd" - all different
    let mut s = a16_zero(4);
    s = a16_set(s, 0, 1);
    s = a16_set(s, 1, 2);
    s = a16_set(s, 2, 3);
    s = a16_set(s, 3, 4);

    let z = compute_z_v2(s, 4);
    assert_eq(a16_get(z, 1), 0);
    assert_eq(a16_get(z, 2), 0);
    assert_eq(a16_get(z, 3), 0);
}

fn test_pattern_match_simple() {
    // Pattern: [1, 2] ("ab"), Text: [1, 2, 3, 1, 2]
    // Matches at positions 0 and 3
    let pat = Arr8 { a0: 1, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };
    let txt = Arr8 { a0: 1, a1: 2, a2: 3, a3: 1, a4: 2, a5: 0, a6: 0, a7: 0, len: 5 };

    assert_eq(z_search_count(pat, 2, txt, 5), 2);
    assert_eq(z_search_first(pat, 2, txt, 5), 0);
}

fn test_pattern_match_single() {
    // Pattern: [3], Text: [1, 2, 3, 4, 5]
    let pat = Arr8 { a0: 3, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 1 };
    let txt = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 0, a6: 0, a7: 0, len: 5 };

    assert_eq(z_search_count(pat, 1, txt, 5), 1);
    assert_eq(z_search_first(pat, 1, txt, 5), 2);
}

fn test_pattern_not_found() {
    // Pattern: [9, 9], Text: [1, 2, 3, 4, 5]
    let pat = Arr8 { a0: 9, a1: 9, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };
    let txt = Arr8 { a0: 1, a1: 2, a2: 3, a3: 4, a4: 5, a5: 0, a6: 0, a7: 0, len: 5 };

    assert_eq(z_search_count(pat, 2, txt, 5), 0);
    assert_eq(z_search_first(pat, 2, txt, 5), -1);
}

fn test_pattern_match_overlapping() {
    // Pattern: [1, 1], Text: [1, 1, 1] -- overlapping matches at positions 0 and 1
    let pat = Arr8 { a0: 1, a1: 1, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };
    let txt = Arr8 { a0: 1, a1: 1, a2: 1, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };

    assert_eq(z_search_count(pat, 2, txt, 3), 2);
    assert_eq(z_search_first(pat, 2, txt, 3), 0);
}

fn test_pattern_equals_text() {
    // Pattern and text are the same: match at position 0 only
    let pat = Arr8 { a0: 1, a1: 2, a2: 3, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };
    let txt = Arr8 { a0: 1, a1: 2, a2: 3, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 3 };

    assert_eq(z_search_count(pat, 3, txt, 3), 1);
    assert_eq(z_search_first(pat, 3, txt, 3), 0);
}

fn test_repeated_pattern() {
    // Pattern: [1, 2], Text: [1, 2, 1, 2, 1, 2] -- matches at 0, 2, 4
    let pat = Arr8 { a0: 1, a1: 2, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 2 };
    let txt = Arr8 { a0: 1, a1: 2, a2: 1, a3: 2, a4: 1, a5: 2, a6: 0, a7: 0, len: 6 };

    assert_eq(z_search_count(pat, 2, txt, 6), 3);
}

fn main() -> Int {
    test_z_array_basic();
    test_z_array_all_same();
    test_z_array_no_match();
    test_pattern_match_simple();
    test_pattern_match_single();
    test_pattern_not_found();
    test_pattern_match_overlapping();
    test_pattern_equals_text();
    test_repeated_pattern();
    print("[OK] 331_z_algorithm_aot");
    0
}
