// @test: run
// @level: L0
// @tier: 1
// @tags: comprehension, list, functional
// @description: Test list comprehension syntax

fn test_basic_comprehension() -> Int {
    // [x * 2 for x in 0..5]
    let doubled = [x * 2 for x in 0..5];
    if doubled.len() != 5 {
        print(f"FAIL basic: len={doubled.len()}, expected 5");
        return 1;
    }
    if doubled[0] != 0 || doubled[1] != 2 || doubled[4] != 8 {
        print(f"FAIL basic values: [{doubled[0]}, {doubled[1]}, ..., {doubled[4]}]");
        return 1;
    }
    print("  basic_comprehension: OK");
    0
}

fn test_filtered_comprehension() -> Int {
    // [x for x in 0..10 if x % 2 == 0]
    let evens = [x for x in 0..10 if x % 2 == 0];
    if evens.len() != 5 {
        print(f"FAIL filtered: len={evens.len()}, expected 5");
        return 1;
    }
    if evens[0] != 0 || evens[4] != 8 {
        print("FAIL filtered values");
        return 1;
    }
    print("  filtered_comprehension: OK");
    0
}

fn test_transform_comprehension() -> Int {
    // [x * x for x in 1..=5]
    let squares = [x * x for x in 1..=5];
    // [1, 4, 9, 16, 25]
    if squares.len() != 5 {
        print(f"FAIL transform: len={squares.len()}");
        return 1;
    }
    let mut sum = 0;
    let mut i = 0;
    while i < squares.len() {
        sum = sum + squares[i];
        i = i + 1;
    }
    // 1+4+9+16+25 = 55
    if sum != 55 {
        print(f"FAIL transform sum: {sum}, expected 55");
        return 1;
    }
    print("  transform_comprehension: OK");
    0
}

fn main() -> Int {
    print("Comprehension Tests:");
    let mut failures = 0;
    failures = failures + test_basic_comprehension();
    failures = failures + test_filtered_comprehension();
    failures = failures + test_transform_comprehension();

    if failures == 0 {
        print("All comprehension tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
