// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, zigzag, encoding, string-pattern
// @timeout: 30000
// @expected-exit: 0
//
// AOT test for zigzag pattern encoding/decoding.
// Given a string and n rows, arrange characters in a zigzag pattern
// and read off row-by-row. Also decode back to original.
//
// Example: "PAYPALISHIRING" with 3 rows:
// P   A   H   N
// A P L S I I G
// Y   I   R
// -> "PAHNAPLSIIGYIR"

// Fixed-size char array (store ASCII codes)
type Arr32 is {
    a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int, a12: Int, a13: Int, a14: Int, a15: Int,
    a16: Int, a17: Int, a18: Int, a19: Int, a20: Int, a21: Int, a22: Int, a23: Int,
    a24: Int, a25: Int, a26: Int, a27: Int, a28: Int, a29: Int, a30: Int, a31: Int
};

fn a32_zero() -> Arr32 {
    Arr32 {
        a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
        a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0,
        a16: 0, a17: 0, a18: 0, a19: 0, a20: 0, a21: 0, a22: 0, a23: 0,
        a24: 0, a25: 0, a26: 0, a27: 0, a28: 0, a29: 0, a30: 0, a31: 0
    }
}

fn a32_get(a: Arr32, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 } else if i == 2 { a.a2 }
    else if i == 3 { a.a3 } else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 } else if i == 8 { a.a8 }
    else if i == 9 { a.a9 } else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 } else if i == 14 { a.a14 }
    else if i == 15 { a.a15 } else if i == 16 { a.a16 } else if i == 17 { a.a17 }
    else if i == 18 { a.a18 } else if i == 19 { a.a19 } else if i == 20 { a.a20 }
    else if i == 21 { a.a21 } else if i == 22 { a.a22 } else if i == 23 { a.a23 }
    else if i == 24 { a.a24 } else if i == 25 { a.a25 } else if i == 26 { a.a26 }
    else if i == 27 { a.a27 } else if i == 28 { a.a28 } else if i == 29 { a.a29 }
    else if i == 30 { a.a30 } else { a.a31 }
}

fn a32_set(a: Arr32, i: Int, v: Int) -> Arr32 {
    Arr32 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 }, a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 }, a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 }, a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 }, a15: if i == 15 { v } else { a.a15 },
        a16: if i == 16 { v } else { a.a16 }, a17: if i == 17 { v } else { a.a17 },
        a18: if i == 18 { v } else { a.a18 }, a19: if i == 19 { v } else { a.a19 },
        a20: if i == 20 { v } else { a.a20 }, a21: if i == 21 { v } else { a.a21 },
        a22: if i == 22 { v } else { a.a22 }, a23: if i == 23 { v } else { a.a23 },
        a24: if i == 24 { v } else { a.a24 }, a25: if i == 25 { v } else { a.a25 },
        a26: if i == 26 { v } else { a.a26 }, a27: if i == 27 { v } else { a.a27 },
        a28: if i == 28 { v } else { a.a28 }, a29: if i == 29 { v } else { a.a29 },
        a30: if i == 30 { v } else { a.a30 }, a31: if i == 31 { v } else { a.a31 }
    }
}

// Determine which row a character at position idx belongs to in zigzag with num_rows
fn zigzag_row(idx: Int, num_rows: Int) -> Int {
    if num_rows <= 1 { return 0; }
    let cycle = 2 * (num_rows - 1);
    let pos = idx % cycle;
    if pos < num_rows {
        pos
    } else {
        cycle - pos
    }
}

// Zigzag encode: rearrange chars by reading rows top to bottom
fn zigzag_encode(input: Arr32, len: Int, num_rows: Int) -> Arr32 {
    let mut output = a32_zero();
    let mut out_idx = 0;
    let mut row = 0;
    while row < num_rows {
        let mut i = 0;
        while i < len {
            if zigzag_row(i, num_rows) == row {
                output = a32_set(output, out_idx, a32_get(input, i));
                out_idx = out_idx + 1;
            }
            i = i + 1;
        }
        row = row + 1;
    }
    output
}

// Zigzag decode: given encoded chars, recover original ordering
fn zigzag_decode(encoded: Arr32, len: Int, num_rows: Int) -> Arr32 {
    let mut output = a32_zero();
    // Count chars in each row
    let mut row_counts = a32_zero();
    let mut i = 0;
    while i < len {
        let r = zigzag_row(i, num_rows);
        row_counts = a32_set(row_counts, r, a32_get(row_counts, r) + 1);
        i = i + 1;
    }
    // Starting index of each row in encoded array
    let mut row_starts = a32_zero();
    let mut cumul = 0;
    let mut r = 0;
    while r < num_rows {
        row_starts = a32_set(row_starts, r, cumul);
        cumul = cumul + a32_get(row_counts, r);
        r = r + 1;
    }
    // Decode: for each original position, pick next char from its row
    let mut row_offsets = a32_zero();
    i = 0;
    while i < len {
        let row = zigzag_row(i, num_rows);
        let enc_idx = a32_get(row_starts, row) + a32_get(row_offsets, row);
        output = a32_set(output, i, a32_get(encoded, enc_idx));
        row_offsets = a32_set(row_offsets, row, a32_get(row_offsets, row) + 1);
        i = i + 1;
    }
    output
}

fn arrays_equal(a: Arr32, b: Arr32, len: Int) -> Int {
    let mut i = 0;
    while i < len {
        if a32_get(a, i) != a32_get(b, i) { return 0; }
        i = i + 1;
    }
    1
}

// ---- Tests ----

fn test_zigzag_row_assignment() {
    // 3 rows: 0,1,2,1,0,1,2,1,0,...
    assert_eq(zigzag_row(0, 3), 0);
    assert_eq(zigzag_row(1, 3), 1);
    assert_eq(zigzag_row(2, 3), 2);
    assert_eq(zigzag_row(3, 3), 1);
    assert_eq(zigzag_row(4, 3), 0);
    assert_eq(zigzag_row(5, 3), 1);
    assert_eq(zigzag_row(6, 3), 2);
    assert_eq(zigzag_row(7, 3), 1);
}

fn test_zigzag_row_4rows() {
    // 4 rows: 0,1,2,3,2,1,0,1,2,3,...
    assert_eq(zigzag_row(0, 4), 0);
    assert_eq(zigzag_row(1, 4), 1);
    assert_eq(zigzag_row(2, 4), 2);
    assert_eq(zigzag_row(3, 4), 3);
    assert_eq(zigzag_row(4, 4), 2);
    assert_eq(zigzag_row(5, 4), 1);
    assert_eq(zigzag_row(6, 4), 0);
}

fn test_encode_3rows() {
    // "PAYPALISHIRING" (len=14), 3 rows
    // Row 0: P(0) A(4) H(8) N(12)
    // Row 1: A(1) P(3) L(5) S(7) I(9) I(11) G(13)
    // Row 2: Y(2) I(6) R(10)
    let mut input = a32_zero();
    input = a32_set(input, 0, 80);  // P
    input = a32_set(input, 1, 65);  // A
    input = a32_set(input, 2, 89);  // Y
    input = a32_set(input, 3, 80);  // P
    input = a32_set(input, 4, 65);  // A
    input = a32_set(input, 5, 76);  // L
    input = a32_set(input, 6, 73);  // I
    input = a32_set(input, 7, 83);  // S
    input = a32_set(input, 8, 72);  // H
    input = a32_set(input, 9, 73);  // I
    input = a32_set(input, 10, 82); // R
    input = a32_set(input, 11, 73); // I
    input = a32_set(input, 12, 78); // N
    input = a32_set(input, 13, 71); // G

    let enc = zigzag_encode(input, 14, 3);
    assert_eq(a32_get(enc, 0), 80);  // P
    assert_eq(a32_get(enc, 1), 65);  // A
    assert_eq(a32_get(enc, 2), 72);  // H
    assert_eq(a32_get(enc, 3), 78);  // N
    assert_eq(a32_get(enc, 4), 65);  // A
    assert_eq(a32_get(enc, 5), 80);  // P
    assert_eq(a32_get(enc, 6), 76);  // L
    assert_eq(a32_get(enc, 7), 83);  // S
    assert_eq(a32_get(enc, 8), 73);  // I
    assert_eq(a32_get(enc, 9), 73);  // I
    assert_eq(a32_get(enc, 10), 71); // G
    assert_eq(a32_get(enc, 11), 89); // Y
    assert_eq(a32_get(enc, 12), 73); // I
    assert_eq(a32_get(enc, 13), 82); // R
}

fn test_encode_1row() {
    let mut input = a32_zero();
    input = a32_set(input, 0, 1);
    input = a32_set(input, 1, 2);
    input = a32_set(input, 2, 3);
    input = a32_set(input, 3, 4);
    let enc = zigzag_encode(input, 4, 1);
    assert_eq(arrays_equal(input, enc, 4), 1);
}

fn test_encode_nrows_equals_len() {
    let mut input = a32_zero();
    input = a32_set(input, 0, 10);
    input = a32_set(input, 1, 20);
    input = a32_set(input, 2, 30);
    let enc = zigzag_encode(input, 3, 3);
    assert_eq(arrays_equal(input, enc, 3), 1);
}

fn test_roundtrip_3rows() {
    let mut input = a32_zero();
    let mut i = 0;
    while i < 14 {
        input = a32_set(input, i, 65 + i);
        i = i + 1;
    }
    let enc = zigzag_encode(input, 14, 3);
    let dec = zigzag_decode(enc, 14, 3);
    assert_eq(arrays_equal(input, dec, 14), 1);
}

fn test_roundtrip_4rows() {
    let mut input = a32_zero();
    let mut i = 0;
    while i < 16 {
        input = a32_set(input, i, 100 + i);
        i = i + 1;
    }
    let enc = zigzag_encode(input, 16, 4);
    let dec = zigzag_decode(enc, 16, 4);
    assert_eq(arrays_equal(input, dec, 16), 1);
}

fn test_roundtrip_2rows() {
    let mut input = a32_zero();
    let mut i = 0;
    while i < 10 {
        input = a32_set(input, i, 50 + i * 3);
        i = i + 1;
    }
    let enc = zigzag_encode(input, 10, 2);
    let dec = zigzag_decode(enc, 10, 2);
    assert_eq(arrays_equal(input, dec, 10), 1);
}

fn test_encode_2rows() {
    // "ABCDEF" with 2 rows: Row0=ACE, Row1=BDF
    let mut input = a32_zero();
    input = a32_set(input, 0, 65);
    input = a32_set(input, 1, 66);
    input = a32_set(input, 2, 67);
    input = a32_set(input, 3, 68);
    input = a32_set(input, 4, 69);
    input = a32_set(input, 5, 70);
    let enc = zigzag_encode(input, 6, 2);
    assert_eq(a32_get(enc, 0), 65); // A
    assert_eq(a32_get(enc, 1), 67); // C
    assert_eq(a32_get(enc, 2), 69); // E
    assert_eq(a32_get(enc, 3), 66); // B
    assert_eq(a32_get(enc, 4), 68); // D
    assert_eq(a32_get(enc, 5), 70); // F
}

fn test_single_char() {
    let mut input = a32_zero();
    input = a32_set(input, 0, 42);
    let enc = zigzag_encode(input, 1, 3);
    assert_eq(a32_get(enc, 0), 42);
    let dec = zigzag_decode(enc, 1, 3);
    assert_eq(a32_get(dec, 0), 42);
}

fn test_roundtrip_5rows() {
    let mut input = a32_zero();
    let mut i = 0;
    while i < 20 {
        input = a32_set(input, i, 200 + i);
        i = i + 1;
    }
    let enc = zigzag_encode(input, 20, 5);
    let dec = zigzag_decode(enc, 20, 5);
    assert_eq(arrays_equal(input, dec, 20), 1);
}

fn main() -> Int {
    test_zigzag_row_assignment();
    test_zigzag_row_4rows();
    test_encode_3rows();
    test_encode_1row();
    test_encode_nrows_equals_len();
    test_roundtrip_3rows();
    test_roundtrip_4rows();
    test_roundtrip_2rows();
    test_encode_2rows();
    test_single_char();
    test_roundtrip_5rows();
    print("[OK] 381_zigzag_conversion_aot");
    0
}
