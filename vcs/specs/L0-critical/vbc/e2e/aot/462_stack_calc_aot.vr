// @test: run
// @level: L0
// @tags: aot, e2e, stack, calculator, rpn
// @timeout: 30000

// Stack-based RPN calculator simulation

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Operations encoded as: positive = push value, negatives = operators
// -1 = add, -2 = sub, -3 = mul, -4 = div, -5 = dup, -6 = swap, -7 = neg

// Stack state: (stack: Arr8, sp: Int) -> we encode sp in the result
// For simplicity, functions take stack + sp and return new sp

fn rpn_eval(program: Arr8, prog_len: Int) -> Int {
    let mut stack = zeros();
    let mut sp = 0;
    let mut pc = 0;
    while pc < prog_len {
        let op = get8(program, pc);
        if op >= 0 {
            // Push value
            stack = set8(stack, sp, op);
            sp = sp + 1;
        } else if op == -1 {
            // Add
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a + b);
        } else if op == -2 {
            // Sub
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a - b);
        } else if op == -3 {
            // Mul
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a * b);
        } else if op == -4 {
            // Div
            let b = get8(stack, sp - 1);
            let a = get8(stack, sp - 2);
            sp = sp - 1;
            stack = set8(stack, sp - 1, a / b);
        } else if op == -5 {
            // Dup
            let v = get8(stack, sp - 1);
            stack = set8(stack, sp, v);
            sp = sp + 1;
        } else if op == -6 {
            // Swap
            let a = get8(stack, sp - 1);
            let b = get8(stack, sp - 2);
            stack = set8(stack, sp - 1, b);
            stack = set8(stack, sp - 2, a);
        } else if op == -7 {
            // Neg
            let v = get8(stack, sp - 1);
            stack = set8(stack, sp - 1, 0 - v);
        }
        pc = pc + 1;
    }
    get8(stack, sp - 1)
}

fn test_basic_rpn() -> Int {
    // 3 4 + = 7
    let prog = Arr8 { v0: 3, v1: 4, v2: -1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 3), 7);

    // 10 3 - = 7
    let prog2 = Arr8 { v0: 10, v1: 3, v2: -2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog2, 3), 7);

    // 6 7 * = 42
    let prog3 = Arr8 { v0: 6, v1: 7, v2: -3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog3, 3), 42);

    // 20 4 / = 5
    let prog4 = Arr8 { v0: 20, v1: 4, v2: -4, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog4, 3), 5);
    1
}

fn test_compound_rpn() -> Int {
    // (3 + 4) * 2 = 3 4 + 2 *
    let prog = Arr8 { v0: 3, v1: 4, v2: -1, v3: 2, v4: -3, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 5), 14);

    // 3 + 4 * 2 = 3 4 2 * + = 11
    let prog2 = Arr8 { v0: 3, v1: 4, v2: 2, v3: -3, v4: -1, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog2, 5), 11);

    // (5 - 3) * (8 + 2) = 5 3 - 8 2 + *
    let prog3 = Arr8 { v0: 5, v1: 3, v2: -2, v3: 8, v4: 2, v5: -1, v6: -3, v7: 0 };
    assert_eq(rpn_eval(prog3, 7), 20);
    1
}

fn test_dup_swap() -> Int {
    // 5 dup * = 25 (square using dup)
    let prog = Arr8 { v0: 5, v1: -5, v2: -3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog, 3), 25);

    // 3 5 swap - = 5 - 3 = 2
    let prog2 = Arr8 { v0: 3, v1: 5, v2: -6, v3: -2, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog2, 4), 2);

    // 7 neg = -7, then 3 + = -4
    let prog3 = Arr8 { v0: 7, v1: -7, v2: 3, v3: -1, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(rpn_eval(prog3, 4), -4);
    1
}

fn test_fibonacci_rpn() -> Int {
    // Compute fib(6) using stack: push 0, push 1, then 5x: dup rot + swap
    // Simplified: just test a complex expression
    // ((2 + 3) * (7 - 4)) / 5 = 5*3/5 = 3
    let prog = Arr8 { v0: 2, v1: 3, v2: -1, v3: 7, v4: 4, v5: -2, v6: -3, v7: 5 };
    // This is: 2 3 + 7 4 - * 5, but we need / at the end
    // Actually let's do a different test since we need 9 elements
    // Just test: 2 3 + 7 4 - * = 5*3 = 15
    let prog2 = Arr8 { v0: 2, v1: 3, v2: -1, v3: 7, v4: 4, v5: -2, v6: -3, v7: 0 };
    assert_eq(rpn_eval(prog2, 7), 15);
    1
}

fn main() -> Int {
    test_basic_rpn();
    test_compound_rpn();
    test_dup_swap();
    test_fibonacci_rpn();
    print("[OK] 462_stack_calc_aot");
    0
}
