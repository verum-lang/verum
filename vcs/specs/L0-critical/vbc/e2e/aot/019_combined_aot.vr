// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, combined, integration
// @timeout: 5000
// @expected-exit: 0
// @description: AOT combined test exercising records, variants, closures, methods, and higher-order patterns

// --- Type definitions ---

type Vec2 is { x: Int, y: Int };

implement Vec2 {
    fn new(x: Int, y: Int) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn plus(self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }

    fn scale(self, factor: Int) -> Vec2 {
        Vec2 { x: self.x * factor, y: self.y * factor }
    }

    fn dot(self, other: Vec2) -> Int {
        self.x * other.x + self.y * other.y
    }

    fn magnitude_sq(self) -> Int {
        self.dot(self)
    }
}

type Result is Ok(Int) | Err(Int);

fn map_result(r: Result, f: fn(Int) -> Int) -> Result {
    match r {
        Ok(v) => Ok(f(v)),
        Err(e) => Err(e),
    }
}

fn unwrap_result(r: Result, default: Int) -> Int {
    match r {
        Ok(v) => v,
        Err(_) => default,
    }
}

fn is_ok(r: Result) -> Bool {
    r is Ok
}

// Higher-order utilities
fn apply_n(init: Int, n: Int, f: fn(Int) -> Int) -> Int {
    let mut result = init;
    let mut i = 0;
    while i < n {
        result = f(result);
        i = i + 1;
    }
    result
}

fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int) -> fn(Int) -> Int {
    |x| f(g(x))
}

// --- Main test ---

fn main() -> Int {
    // Vec2 operations
    let v1 = Vec2.new(3, 4);
    let v2 = Vec2.new(1, 2);

    let v3 = v1.plus(v2);
    assert_eq(v3.x, 4);
    assert_eq(v3.y, 6);

    let v4 = v1.scale(3);
    assert_eq(v4.x, 9);
    assert_eq(v4.y, 12);

    assert_eq(v1.dot(v2), 11);  // 3*1 + 4*2
    assert_eq(v1.magnitude_sq(), 25);  // 3*3 + 4*4

    // Result type with closures
    let ok_val = Ok(10);
    let err_val = Err(42);

    let doubled = map_result(ok_val, |x| x * 2);
    assert_eq(unwrap_result(doubled, 0), 20);

    let err_doubled = map_result(err_val, |x| x * 2);
    assert_eq(unwrap_result(err_doubled, -1), -1);

    assert(is_ok(ok_val));
    assert(!is_ok(err_val));

    // Higher-order: apply_n
    let result = apply_n(1, 10, |x| x + 1);
    assert_eq(result, 11);  // 1 + 10*1

    let powers = apply_n(1, 5, |x| x * 2);
    assert_eq(powers, 32);  // 2^5

    // Function composition
    let add_one = |x: Int| -> Int { x + 1 };
    let double = |x: Int| -> Int { x * 2 };
    let double_then_add = compose(add_one, double);
    assert_eq(double_then_add(5), 11);  // (5 * 2) + 1

    let add_then_double = compose(double, add_one);
    assert_eq(add_then_double(5), 12);  // (5 + 1) * 2

    // Combined: Vec2 with closures
    let transform = |v: Vec2| -> Vec2 { v.scale(2).plus(Vec2.new(1, 1)) };
    let result = transform(v1);
    assert_eq(result.x, 7);   // 3*2 + 1
    assert_eq(result.y, 9);   // 4*2 + 1

    0
}
