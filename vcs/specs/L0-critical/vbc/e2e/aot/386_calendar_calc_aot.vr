// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, calendar, date-math, leap-year
// @timeout: 30000
// @expected-exit: 0
//
// AOT test for calendar calculations:
// 1. Leap year detection
// 2. Days in month
// 3. Day of year
// 4. Day of week (Zeller's formula / Tomohiko Sakamoto)
// 5. Days between two dates
// 6. Date validation

// Is year a leap year?
fn is_leap(year: Int) -> Int {
    if year % 400 == 0 { return 1; }
    if year % 100 == 0 { return 0; }
    if year % 4 == 0 { return 1; }
    0
}

// Days in a given month (1-indexed). month: 1=Jan, 12=Dec
fn days_in_month(year: Int, month: Int) -> Int {
    if month == 2 {
        if is_leap(year) == 1 { 29 } else { 28 }
    } else if month == 4 { 30 }
    else if month == 6 { 30 }
    else if month == 9 { 30 }
    else if month == 11 { 30 }
    else { 31 }
}

// Day of year (1-indexed): Jan 1 = 1, Dec 31 = 365 or 366
fn day_of_year(year: Int, month: Int, day: Int) -> Int {
    let mut total = 0;
    let mut m = 1;
    while m < month {
        total = total + days_in_month(year, m);
        m = m + 1;
    }
    total + day
}

// Days from year 1 to start of given year
fn days_before_year(year: Int) -> Int {
    let y = year - 1;
    y * 365 + y / 4 - y / 100 + y / 400
}

// Absolute day number (days since year 0, day 0)
fn abs_day(year: Int, month: Int, day: Int) -> Int {
    days_before_year(year) + day_of_year(year, month, day)
}

// Days between two dates (date2 - date1), can be negative
fn days_between(y1: Int, m1: Int, d1: Int, y2: Int, m2: Int, d2: Int) -> Int {
    abs_day(y2, m2, d2) - abs_day(y1, m1, d1)
}

// Day of week using Tomohiko Sakamoto's algorithm
// Returns 0=Sunday, 1=Monday, ..., 6=Saturday
fn day_of_week(year: Int, month: Int, day: Int) -> Int {
    // Sakamoto's method: adjust year for Jan/Feb
    let mut y = year;
    if month < 3 { y = y - 1; }
    // Month offset table: Jan=0,Feb=3,Mar=2,Apr=5,May=0,Jun=3,Jul=5,Aug=1,Sep=4,Oct=6,Nov=2,Dec=4
    let t = if month == 1 { 0 } else if month == 2 { 3 }
            else if month == 3 { 2 } else if month == 4 { 5 }
            else if month == 5 { 0 } else if month == 6 { 3 }
            else if month == 7 { 5 } else if month == 8 { 1 }
            else if month == 9 { 4 } else if month == 10 { 6 }
            else if month == 11 { 2 } else { 4 };
    (y + y / 4 - y / 100 + y / 400 + t + day) % 7
}

// Is a date valid?
fn is_valid_date(year: Int, month: Int, day: Int) -> Int {
    if year < 1 { return 0; }
    if month < 1 { return 0; }
    if month > 12 { return 0; }
    if day < 1 { return 0; }
    if day > days_in_month(year, month) { return 0; }
    1
}

// Days in a year
fn days_in_year(year: Int) -> Int {
    if is_leap(year) == 1 { 366 } else { 365 }
}

// ---- Tests ----

fn test_leap_year() {
    assert_eq(is_leap(2000), 1);  // divisible by 400
    assert_eq(is_leap(1900), 0);  // divisible by 100 but not 400
    assert_eq(is_leap(2024), 1);  // divisible by 4
    assert_eq(is_leap(2023), 0);  // not divisible by 4
    assert_eq(is_leap(1600), 1);
    assert_eq(is_leap(1700), 0);
    assert_eq(is_leap(1800), 0);
    assert_eq(is_leap(2400), 1);
    assert_eq(is_leap(2100), 0);
}

fn test_days_in_month_regular() {
    assert_eq(days_in_month(2023, 1), 31);
    assert_eq(days_in_month(2023, 2), 28);
    assert_eq(days_in_month(2023, 3), 31);
    assert_eq(days_in_month(2023, 4), 30);
    assert_eq(days_in_month(2023, 5), 31);
    assert_eq(days_in_month(2023, 6), 30);
    assert_eq(days_in_month(2023, 7), 31);
    assert_eq(days_in_month(2023, 8), 31);
    assert_eq(days_in_month(2023, 9), 30);
    assert_eq(days_in_month(2023, 10), 31);
    assert_eq(days_in_month(2023, 11), 30);
    assert_eq(days_in_month(2023, 12), 31);
}

fn test_days_in_month_leap() {
    assert_eq(days_in_month(2024, 2), 29);
    assert_eq(days_in_month(2000, 2), 29);
    assert_eq(days_in_month(1900, 2), 28);
}

fn test_day_of_year() {
    assert_eq(day_of_year(2023, 1, 1), 1);
    assert_eq(day_of_year(2023, 12, 31), 365);
    assert_eq(day_of_year(2024, 12, 31), 366); // leap year
    assert_eq(day_of_year(2023, 3, 1), 60);    // 31 + 28 + 1
    assert_eq(day_of_year(2024, 3, 1), 61);    // 31 + 29 + 1
}

fn test_day_of_week_known_dates() {
    // 2024-01-01 was Monday (1)
    assert_eq(day_of_week(2024, 1, 1), 1);
    // 2023-12-25 was Monday (1)
    assert_eq(day_of_week(2023, 12, 25), 1);
    // 2000-01-01 was Saturday (6)
    assert_eq(day_of_week(2000, 1, 1), 6);
    // 1969-07-20 (Moon landing) was Sunday (0)
    assert_eq(day_of_week(1969, 7, 20), 0);
    // 2026-02-27 (today) is Friday (5)
    assert_eq(day_of_week(2026, 2, 27), 5);
}

fn test_day_of_week_consecutive() {
    // 7 consecutive days should cover all days of week
    // 2024-01-01 (Mon) through 2024-01-07 (Sun)
    assert_eq(day_of_week(2024, 1, 1), 1); // Mon
    assert_eq(day_of_week(2024, 1, 2), 2); // Tue
    assert_eq(day_of_week(2024, 1, 3), 3); // Wed
    assert_eq(day_of_week(2024, 1, 4), 4); // Thu
    assert_eq(day_of_week(2024, 1, 5), 5); // Fri
    assert_eq(day_of_week(2024, 1, 6), 6); // Sat
    assert_eq(day_of_week(2024, 1, 7), 0); // Sun
}

fn test_days_between_same() {
    assert_eq(days_between(2024, 1, 1, 2024, 1, 1), 0);
}

fn test_days_between_one_day() {
    assert_eq(days_between(2024, 1, 1, 2024, 1, 2), 1);
    assert_eq(days_between(2024, 1, 2, 2024, 1, 1), -1);
}

fn test_days_between_month() {
    // Jan to Feb in non-leap year
    assert_eq(days_between(2023, 1, 1, 2023, 2, 1), 31);
    // Jan to Mar in leap year
    assert_eq(days_between(2024, 1, 1, 2024, 3, 1), 60); // 31 + 29
}

fn test_days_between_year() {
    // Full year
    assert_eq(days_between(2023, 1, 1, 2024, 1, 1), 365);
    assert_eq(days_between(2024, 1, 1, 2025, 1, 1), 366); // 2024 is leap
}

fn test_days_between_century() {
    // 100 years from 1900 to 2000
    // 24 leap years in [1901..2000] (1904,1908,...,2000) but 1900 is not leap
    // Actually: leap years: 1904,1908,...,1996,2000 = 25 leap years
    // Wait: we're counting from 1900-01-01 to 2000-01-01
    // Leap years in 1900-1999: 1904,...,1996 = 24 (1900 not leap)
    // Total = 24*366 + 76*365 = 8784 + 27740 = 36524
    assert_eq(days_between(1900, 1, 1, 2000, 1, 1), 36524);
}

fn test_is_valid_date() {
    assert_eq(is_valid_date(2024, 1, 1), 1);
    assert_eq(is_valid_date(2024, 2, 29), 1);  // leap year
    assert_eq(is_valid_date(2023, 2, 29), 0);  // not leap year
    assert_eq(is_valid_date(2024, 13, 1), 0);  // invalid month
    assert_eq(is_valid_date(2024, 0, 1), 0);   // invalid month
    assert_eq(is_valid_date(2024, 1, 0), 0);   // invalid day
    assert_eq(is_valid_date(2024, 1, 32), 0);  // invalid day
    assert_eq(is_valid_date(2024, 4, 31), 0);  // April has 30 days
}

fn test_days_in_year_fn() {
    assert_eq(days_in_year(2024), 366);
    assert_eq(days_in_year(2023), 365);
    assert_eq(days_in_year(2000), 366);
    assert_eq(days_in_year(1900), 365);
}

fn test_epoch_day_of_week() {
    // 1970-01-01 was Thursday (4)
    assert_eq(day_of_week(1970, 1, 1), 4);
}

fn main() -> Int {
    test_leap_year();
    test_days_in_month_regular();
    test_days_in_month_leap();
    test_day_of_year();
    test_day_of_week_known_dates();
    test_day_of_week_consecutive();
    test_days_between_same();
    test_days_between_one_day();
    test_days_between_month();
    test_days_between_year();
    test_days_between_century();
    test_is_valid_date();
    test_days_in_year_fn();
    test_epoch_day_of_week();
    print("[OK] 386_calendar_calc_aot");
    0
}
