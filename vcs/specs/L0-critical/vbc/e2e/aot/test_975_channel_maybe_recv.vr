// @test: run
// @level: L0
// @tier: 1
// @tags: channel, maybe, recv, pattern-matching
// @description: Test Channel.recv() with proper Maybe unwrapping

fn unwrap_recv(ch: &Channel<Int>) -> Int {
    match ch.recv() {
        Some(v) => v,
        None => -1,
    }
}

fn test_basic_recv() -> Int {
    let ch = Channel.new(4);
    ch.send(42);
    let v = match ch.recv() {
        Some(x) => x,
        None => -1,
    };
    if v != 42 {
        print(f"FAIL basic_recv: expected 42, got {v}");
        return 1;
    }
    print("  basic_recv: OK");
    0
}

fn test_multi_recv() -> Int {
    let ch = Channel.new(8);
    ch.send(10);
    ch.send(20);
    ch.send(30);
    let a = match ch.recv() { Some(x) => x, None => 0 };
    let b = match ch.recv() { Some(x) => x, None => 0 };
    let c = match ch.recv() { Some(x) => x, None => 0 };
    let total = a + b + c;
    if total != 60 {
        print(f"FAIL multi_recv: expected 60, got {total}");
        return 1;
    }
    print("  multi_recv: OK");
    0
}

fn test_recv_in_spawn() -> Int {
    let ch = Channel.new(4);
    ch.send(100);

    let h = spawn {
        let v = match ch.recv() {
            Some(x) => x,
            None => 0,
        };
        v * 2
    };
    let result = h.await;
    if result != 200 {
        print(f"FAIL recv_in_spawn: expected 200, got {result}");
        return 1;
    }
    print("  recv_in_spawn: OK");
    0
}

fn main() -> Int {
    print("Channel Maybe Recv Tests:");
    let mut failures = 0;
    failures = failures + test_basic_recv();
    failures = failures + test_multi_recv();
    failures = failures + test_recv_in_spawn();

    if failures == 0 {
        print("All channel maybe recv tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
