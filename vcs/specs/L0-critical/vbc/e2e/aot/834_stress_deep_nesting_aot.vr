// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, stress
// @timeout: 60000
// @expected-exit: 0

// Deep nesting stress: 15+ levels of if/while nesting

fn abs_v(x: Int) -> Int { if (x < 0) { 0 - x } else { x } }

// 15 nested ifs: classify magnitude
fn classify_magnitude(x: Int) -> Int {
    if (x > 0) {
        if (x > 1) {
            if (x > 10) {
                if (x > 100) {
                    if (x > 1000) {
                        if (x > 10000) {
                            if (x > 100000) {
                                if (x > 1000000) {
                                    if (x > 10000000) {
                                        if (x > 100000000) {
                                            if (x > 1000000000) {
                                                if (x > 2000000000) {
                                                    if (x > 3000000000) {
                                                        if (x > 4000000000) {
                                                            if (x > 5000000000) {
                                                                15
                                                            } else { 14 }
                                                        } else { 13 }
                                                    } else { 12 }
                                                } else { 11 }
                                            } else { 10 }
                                        } else { 9 }
                                    } else { 8 }
                                } else { 7 }
                            } else { 6 }
                        } else { 5 }
                    } else { 4 }
                } else { 3 }
            } else { 2 }
        } else { 1 }
    } else { 0 }
}

// 5-deep nested while loops: counting iterations
fn nested_loops_5() -> Int {
    let mut total = 0;
    let mut i = 0;
    while (i < 8) {
        let mut j = 0;
        while (j < 6) {
            let mut k = 0;
            while (k < 5) {
                let mut m = 0;
                while (m < 4) {
                    let mut n = 0;
                    while (n < 3) {
                        total = total + 1;
                        n = n + 1;
                    }
                    m = m + 1;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    total
}

// Mixed nesting: loops with conditions inside, 8+ levels deep
fn mixed_nesting() -> Int {
    let mut count = 0;
    let mut i = 0;
    while (i < 20) {
        if (i % 2 == 0) {
            let mut j = 0;
            while (j < 15) {
                if (j % 3 == 0) {
                    if (i + j < 25) {
                        let mut k = 0;
                        while (k < 5) {
                            if (k % 2 == 0) {
                                if (i + j + k < 30) {
                                    if (i * j > 0) {
                                        if (k > 0) {
                                            count = count + 1;
                                        }
                                    }
                                }
                            }
                            k = k + 1;
                        }
                    }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    count
}

// Diamond nesting: each branch goes deep and converges
fn diamond_nesting(x: Int) -> Int {
    let a = if (x > 50) {
        if (x > 75) {
            if (x > 90) { 4 } else { 3 }
        } else {
            if (x > 60) { 2 } else { 1 }
        }
    } else {
        if (x > 25) {
            if (x > 40) { -1 } else { -2 }
        } else {
            if (x > 10) { -3 } else { -4 }
        }
    };

    let b = if (a > 0) {
        if (a > 2) {
            if (a > 3) { 100 } else { 75 }
        } else {
            if (a > 1) { 50 } else { 25 }
        }
    } else {
        if (a > -3) {
            if (a > -2) { -25 } else { -50 }
        } else {
            if (a > -4) { -75 } else { -100 }
        }
    };
    b
}

// Nested while with flag-based "break": find Pythagorean-like i^2 + j^2 = target
fn nested_search(target: Int) -> Int {
    let mut found_i = -1;
    let mut found_j = -1;
    let mut i = 0;
    while (i < 20) {
        if (found_i < 0) {
            let mut j = 0;
            while (j < 20) {
                if (found_j < 0) {
                    if (i * i + j * j == target) {
                        found_i = i;
                        found_j = j;
                    }
                }
                j = j + 1;
            }
        }
        i = i + 1;
    }
    found_i * 100 + found_j
}

// Deeply nested conditional accumulation with 8 conditions
fn nested_accumulate() -> Int {
    let mut sum = 0;
    let mut a = 0;
    while (a < 10) {
        let mut b = 0;
        while (b < 10) {
            if (a != b) {
                if (a + b < 15) {
                    if (abs_v(a - b) > 1) {
                        if (a * b > 2) {
                            if ((a + b) % 2 == 0) {
                                if (a < 8) {
                                    if (b < 8) {
                                        if (a + b > 3) {
                                            sum = sum + a * 10 + b;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            b = b + 1;
        }
        a = a + 1;
    }
    sum
}

// Triple nested loop with predicate tower: 5 conditions per inner iteration
fn predicate_tower() -> Int {
    let mut count = 0;
    let mut x = 1;
    while (x <= 20) {
        let mut y = 1;
        while (y <= 20) {
            let mut z = 1;
            while (z <= 10) {
                if (x + y + z < 30) {
                    if (x * y > z) {
                        if (x != y) {
                            if (y != z) {
                                if (x != z) {
                                    count = count + 1;
                                }
                            }
                        }
                    }
                }
                z = z + 1;
            }
            y = y + 1;
        }
        x = x + 1;
    }
    count
}

// Deeply nested with early returns
fn classify_3d(a: Int, b: Int, c: Int) -> Int {
    if (a > 0) {
        if (b > 0) {
            if (c > 0) {
                return a + b + c;
            } else {
                if (c == 0) {
                    return a + b;
                } else {
                    return a + b - abs_v(c);
                }
            }
        } else {
            if (c > 0) {
                return a + c - abs_v(b);
            } else {
                return a;
            }
        }
    } else {
        if (b > 0) {
            if (c > 0) {
                return b + c;
            } else {
                return b;
            }
        } else {
            if (c > 0) {
                return c;
            } else {
                return 0;
            }
        }
    }
}

fn main() -> Int {
    // Test nested magnitude classification
    assert_eq(classify_magnitude(0), 0);
    assert_eq(classify_magnitude(-5), 0);
    assert_eq(classify_magnitude(1), 1);
    assert_eq(classify_magnitude(5), 2);
    assert_eq(classify_magnitude(50), 3);
    assert_eq(classify_magnitude(500), 4);
    assert_eq(classify_magnitude(5000), 5);
    assert_eq(classify_magnitude(50000), 6);
    assert_eq(classify_magnitude(500000), 7);
    assert_eq(classify_magnitude(5000000), 8);
    assert_eq(classify_magnitude(50000000), 9);
    assert_eq(classify_magnitude(500000000), 10);
    assert_eq(classify_magnitude(1500000000), 11);
    assert_eq(classify_magnitude(2500000000), 12);
    assert_eq(classify_magnitude(3500000000), 13);
    assert_eq(classify_magnitude(4500000000), 14);
    assert_eq(classify_magnitude(5500000000), 15);

    // Test 5-deep nested loops: 8*6*5*4*3 = 2880
    assert_eq(nested_loops_5(), 2880);

    // Test mixed nesting (deterministic)
    let mc = mixed_nesting();
    assert(mc > 0);
    let mc2 = mixed_nesting();
    assert_eq(mc, mc2);

    // Test diamond nesting
    assert_eq(diamond_nesting(95), 100);
    assert_eq(diamond_nesting(80), 75);
    assert_eq(diamond_nesting(65), 50);
    assert_eq(diamond_nesting(55), 25);
    assert_eq(diamond_nesting(45), -25);
    assert_eq(diamond_nesting(30), -50);
    assert_eq(diamond_nesting(15), -75);
    assert_eq(diamond_nesting(5), -100);

    // Test nested search: 137 = 4^2 + 11^2 = 16 + 121
    assert_eq(nested_search(137), 411);
    // 25 = 0^2 + 5^2 (found first at i=0, j=5)
    assert_eq(nested_search(25), 5);
    // 5 = 1^2 + 2^2
    assert_eq(nested_search(5), 102);

    // Test nested accumulate (deterministic)
    let na = nested_accumulate();
    assert(na > 0);
    let na2 = nested_accumulate();
    assert_eq(na, na2);

    // Test predicate tower (deterministic)
    let pt = predicate_tower();
    assert(pt > 0);
    let pt2 = predicate_tower();
    assert_eq(pt, pt2);

    // Test 3D classification (all octants)
    assert_eq(classify_3d(1, 2, 3), 6);     // +++
    assert_eq(classify_3d(1, 2, 0), 3);     // ++0
    assert_eq(classify_3d(1, 2, -1), 2);    // ++-
    assert_eq(classify_3d(1, -2, 3), 2);    // +-+
    assert_eq(classify_3d(1, -2, -3), 1);   // +--
    assert_eq(classify_3d(-1, 2, 3), 5);    // -++
    assert_eq(classify_3d(-1, 2, -3), 2);   // -+-
    assert_eq(classify_3d(-1, -2, 3), 3);   // --+
    assert_eq(classify_3d(-1, -2, -3), 0);  // ---

    // Stress: nested loop with many computations
    let mut stress_sum = 0;
    let mut si = 0;
    while (si < 50) {
        let mut sj = 0;
        while (sj < 50) {
            if (si + sj < 60) {
                if (si * sj > 100) {
                    stress_sum = stress_sum + 1;
                }
            }
            sj = sj + 1;
        }
        si = si + 1;
    }
    assert(stress_sum > 0);

    print("834_stress_deep_nesting: PASS");
    0
}
