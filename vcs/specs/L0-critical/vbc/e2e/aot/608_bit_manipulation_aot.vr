// @test: run
// @level: L0
// @tags: aot, e2e, bit-manipulation, bitwise, tricks
// @timeout: 30000

// Bit manipulation tricks and algorithms

fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

// Get bit at position
fn get_bit(x: Int, pos: Int) -> Int {
    (x / pow2(pos)) % 2
}

// Set bit at position
fn set_bit(x: Int, pos: Int) -> Int {
    if get_bit(x, pos) == 0 { x + pow2(pos) }
    else { x }
}

// Clear bit at position
fn clear_bit(x: Int, pos: Int) -> Int {
    if get_bit(x, pos) == 1 { x - pow2(pos) }
    else { x }
}

// Toggle bit at position
fn toggle_bit(x: Int, pos: Int) -> Int {
    if get_bit(x, pos) == 1 { x - pow2(pos) }
    else { x + pow2(pos) }
}

// Population count (number of 1-bits) for values < 2^16
fn popcount(x: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 16 {
        count = count + get_bit(x, i);
        i = i + 1;
    }
    count
}

// Highest set bit position (0-indexed), -1 for 0
fn highest_bit(x: Int) -> Int {
    if x <= 0 { 0 - 1 }
    else {
        let mut pos = 0;
        let mut v = x;
        while v > 1 {
            v = v / 2;
            pos = pos + 1;
        }
        pos
    }
}

// Lowest set bit position (0-indexed), -1 for 0
fn lowest_bit(x: Int) -> Int {
    if x <= 0 { 0 - 1 }
    else {
        let mut pos = 0;
        let mut v = x;
        let mut done = 0;
        while done == 0 {
            if v % 2 == 1 { done = 1; }
            else { v = v / 2; pos = pos + 1; }
        }
        pos
    }
}

// Is power of 2?
fn is_pow2(x: Int) -> Int {
    if x <= 0 { 0 }
    else {
        if popcount(x) == 1 { 1 } else { 0 }
    }
}

// Next power of 2 >= x
fn next_pow2(x: Int) -> Int {
    if x <= 1 { 1 }
    else {
        let mut p = 1;
        while p < x { p = p * 2; }
        p
    }
}

// Reverse bits of a value (within width bits)
fn reverse_bits(x: Int, width: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < width {
        if get_bit(x, i) == 1 {
            result = set_bit(result, width - 1 - i);
        }
        i = i + 1;
    }
    result
}

// Gray code: n XOR (n >> 1), simulated
fn to_gray(n: Int) -> Int {
    let half = n / 2;
    // XOR: bit-by-bit
    let mut result = 0;
    let mut i = 0;
    while i < 16 {
        let b1 = get_bit(n, i);
        let b2 = get_bit(half, i);
        if b1 != b2 { result = set_bit(result, i); }
        i = i + 1;
    }
    result
}

// XOR two values
fn xor(a: Int, b: Int) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < 16 {
        let b1 = get_bit(a, i);
        let b2 = get_bit(b, i);
        if b1 != b2 { result = set_bit(result, i); }
        i = i + 1;
    }
    result
}

fn test_get_set_clear() -> Int {
    assert_eq(get_bit(5, 0), 1);  // 5 = 101, bit 0 = 1
    assert_eq(get_bit(5, 1), 0);  // bit 1 = 0
    assert_eq(get_bit(5, 2), 1);  // bit 2 = 1
    assert_eq(set_bit(5, 1), 7);  // 101 | 010 = 111 = 7
    assert_eq(set_bit(5, 0), 5);  // already set
    assert_eq(clear_bit(5, 0), 4); // 101 -> 100 = 4
    assert_eq(clear_bit(5, 1), 5); // already clear
    assert_eq(toggle_bit(5, 0), 4); // 101 -> 100
    assert_eq(toggle_bit(5, 1), 7); // 101 -> 111
    1
}

fn test_popcount() -> Int {
    assert_eq(popcount(0), 0);
    assert_eq(popcount(1), 1);
    assert_eq(popcount(7), 3);    // 111
    assert_eq(popcount(255), 8);  // 11111111
    assert_eq(popcount(1024), 1); // 10000000000
    assert_eq(popcount(170), 4);  // 10101010
    1
}

fn test_highest_lowest() -> Int {
    assert_eq(highest_bit(1), 0);
    assert_eq(highest_bit(8), 3);
    assert_eq(highest_bit(255), 7);
    assert_eq(highest_bit(0), 0 - 1);
    assert_eq(lowest_bit(12), 2);  // 1100, lowest = bit 2
    assert_eq(lowest_bit(8), 3);
    assert_eq(lowest_bit(1), 0);
    assert_eq(lowest_bit(0), 0 - 1);
    1
}

fn test_pow2_ops() -> Int {
    assert_eq(is_pow2(1), 1);
    assert_eq(is_pow2(2), 1);
    assert_eq(is_pow2(4), 1);
    assert_eq(is_pow2(8), 1);
    assert_eq(is_pow2(3), 0);
    assert_eq(is_pow2(6), 0);
    assert_eq(is_pow2(0), 0);
    assert_eq(next_pow2(1), 1);
    assert_eq(next_pow2(3), 4);
    assert_eq(next_pow2(5), 8);
    assert_eq(next_pow2(8), 8);
    assert_eq(next_pow2(9), 16);
    1
}

fn test_reverse_bits() -> Int {
    // Reverse 5 (101) in 3 bits = 5 (101) - palindrome
    assert_eq(reverse_bits(5, 3), 5);
    // Reverse 1 (001) in 3 bits = 4 (100)
    assert_eq(reverse_bits(1, 3), 4);
    // Reverse 6 (110) in 3 bits = 3 (011)
    assert_eq(reverse_bits(6, 3), 3);
    // Reverse 11 (1011) in 4 bits = 13 (1101)
    assert_eq(reverse_bits(11, 4), 13);
    1
}

fn test_gray_code() -> Int {
    assert_eq(to_gray(0), 0);
    assert_eq(to_gray(1), 1);
    assert_eq(to_gray(2), 3);  // 10 XOR 01 = 11
    assert_eq(to_gray(3), 2);  // 11 XOR 01 = 10
    assert_eq(to_gray(4), 6);  // 100 XOR 010 = 110
    // Adjacent Gray codes differ by exactly 1 bit
    let mut i = 0;
    while i < 7 {
        let diff = xor(to_gray(i), to_gray(i + 1));
        assert_eq(popcount(diff), 1);
        i = i + 1;
    }
    1
}

fn test_xor_properties() -> Int {
    // Self-inverse
    assert_eq(xor(42, 0), 42);
    assert_eq(xor(42, 42), 0);
    // Commutative
    assert_eq(xor(13, 7), xor(7, 13));
    // Find missing number: XOR of 0-4 XOR of [0,1,3,4] = 2
    let full = xor(xor(xor(xor(0, 1), 2), 3), 4);
    let missing = xor(xor(xor(0, 1), 3), 4);
    assert_eq(xor(full, missing), 2);
    1
}

fn main() -> Int {
    test_get_set_clear();
    test_popcount();
    test_highest_lowest();
    test_pow2_ops();
    test_reverse_bits();
    test_gray_code();
    test_xor_properties();
    print("[OK] 608_bit_manipulation_aot");
    0
}
