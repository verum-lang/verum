// @test: run
// @level: L0
// @tags: aot, e2e, complex-numbers, arithmetic
// @timeout: 30000

// Complex number arithmetic using packed representation

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Complex number: packed as real * 10000 + imag (works for |imag| < 5000, |real| reasonable)
// Use separate components for clarity
type Complex is { re: Int, im: Int };

fn c_new(re: Int, im: Int) -> Complex { Complex { re: re, im: im } }
fn c_zero() -> Complex { Complex { re: 0, im: 0 } }
fn c_one() -> Complex { Complex { re: 1, im: 0 } }
fn c_i() -> Complex { Complex { re: 0, im: 1 } }

fn c_add(a: Complex, b: Complex) -> Complex {
    Complex { re: a.re + b.re, im: a.im + b.im }
}

fn c_sub(a: Complex, b: Complex) -> Complex {
    Complex { re: a.re - b.re, im: a.im - b.im }
}

fn c_mul(a: Complex, b: Complex) -> Complex {
    // (a+bi)(c+di) = (ac-bd) + (ad+bc)i
    Complex {
        re: a.re * b.re - a.im * b.im,
        im: a.re * b.im + a.im * b.re
    }
}

fn c_conj(a: Complex) -> Complex {
    Complex { re: a.re, im: 0 - a.im }
}

// |z|^2 = re^2 + im^2
fn c_norm_sq(a: Complex) -> Int {
    a.re * a.re + a.im * a.im
}

fn c_scale(a: Complex, k: Int) -> Complex {
    Complex { re: a.re * k, im: a.im * k }
}

fn c_eq(a: Complex, b: Complex) -> Int {
    if a.re == b.re {
        if a.im == b.im { return 1; }
    }
    0
}

// Power: z^n (for non-negative n)
fn c_pow(z: Complex, n: Int) -> Complex {
    if n == 0 { return c_one(); }
    let mut result = c_one();
    let mut base = z;
    let mut exp = n;
    while exp > 0 {
        if exp % 2 == 1 {
            result = c_mul(result, base);
        }
        base = c_mul(base, base);
        exp = exp / 2;
    }
    result
}

fn test_basic_ops() -> Int {
    let a = c_new(3, 4);
    let b = c_new(1, -2);

    let sum = c_add(a, b);
    assert_eq(sum.re, 4);
    assert_eq(sum.im, 2);

    let diff = c_sub(a, b);
    assert_eq(diff.re, 2);
    assert_eq(diff.im, 6);
    1
}

fn test_multiply() -> Int {
    // (3+4i)(1-2i) = 3-6i+4i-8i^2 = 3-2i+8 = 11-2i
    let a = c_new(3, 4);
    let b = c_new(1, -2);
    let prod = c_mul(a, b);
    assert_eq(prod.re, 11);
    assert_eq(prod.im, -2);
    1
}

fn test_conjugate() -> Int {
    let a = c_new(3, 4);
    let conj = c_conj(a);
    assert_eq(conj.re, 3);
    assert_eq(conj.im, -4);

    // z * conj(z) = |z|^2 (real)
    let prod = c_mul(a, conj);
    assert_eq(prod.re, 25); // 9+16
    assert_eq(prod.im, 0);
    assert_eq(c_norm_sq(a), 25);
    1
}

fn test_i_squared() -> Int {
    // i^2 = -1
    let i = c_i();
    let i2 = c_mul(i, i);
    assert_eq(i2.re, -1);
    assert_eq(i2.im, 0);

    // i^4 = 1
    let i4 = c_mul(i2, i2);
    assert_eq(i4.re, 1);
    assert_eq(i4.im, 0);
    1
}

fn test_power() -> Int {
    // (1+i)^2 = 2i
    let z = c_new(1, 1);
    let z2 = c_pow(z, 2);
    assert_eq(z2.re, 0);
    assert_eq(z2.im, 2);

    // (1+i)^4 = -4
    let z4 = c_pow(z, 4);
    assert_eq(z4.re, -4);
    assert_eq(z4.im, 0);

    // z^0 = 1
    assert_eq(c_eq(c_pow(z, 0), c_one()), 1);

    // z^1 = z
    assert_eq(c_eq(c_pow(z, 1), z), 1);
    1
}

fn test_distributive() -> Int {
    // a*(b+c) = a*b + a*c
    let a = c_new(2, 3);
    let b = c_new(1, 1);
    let c = c_new(4, -1);

    let lhs = c_mul(a, c_add(b, c));
    let rhs = c_add(c_mul(a, b), c_mul(a, c));
    assert_eq(c_eq(lhs, rhs), 1);
    1
}

fn test_zero_one() -> Int {
    let z = c_new(5, -3);
    // z + 0 = z
    assert_eq(c_eq(c_add(z, c_zero()), z), 1);
    // z * 1 = z
    assert_eq(c_eq(c_mul(z, c_one()), z), 1);
    // z * 0 = 0
    assert_eq(c_eq(c_mul(z, c_zero()), c_zero()), 1);
    1
}

fn test_gaussian_integers() -> Int {
    // Gaussian integer norm: N(a+bi) = a^2 + b^2
    // N(z*w) = N(z)*N(w)
    let z = c_new(3, 1);
    let w = c_new(2, -1);
    let prod = c_mul(z, w);
    assert_eq(c_norm_sq(prod), c_norm_sq(z) * c_norm_sq(w));
    // N(3+i) = 10, N(2-i) = 5, N(prod) = 50
    assert_eq(c_norm_sq(z), 10);
    assert_eq(c_norm_sq(w), 5);
    assert_eq(c_norm_sq(prod), 50);
    1
}

fn main() -> Int {
    test_basic_ops();
    test_multiply();
    test_conjugate();
    test_i_squared();
    test_power();
    test_distributive();
    test_zero_one();
    test_gaussian_integers();
    print("[OK] 531_complex_arith_aot");
    0
}
