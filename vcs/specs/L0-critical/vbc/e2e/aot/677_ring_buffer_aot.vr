// @test: run
// @level: L0
// @tags: aot, e2e, ring-buffer, circular, queue
// @timeout: 30000

// Ring buffer (circular buffer) implementation using Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Ring buffer state: data in Arr8, head/tail/size packed
// State = head * 10000 + tail * 100 + size
// capacity is always 8
fn rb_new() -> Int { 0 } // head=0, tail=0, size=0
fn rb_head(state: Int) -> Int { state / 10000 }
fn rb_tail(state: Int) -> Int { (state / 100) % 100 }
fn rb_size(state: Int) -> Int { state % 100 }
fn rb_make(head: Int, tail: Int, size: Int) -> Int { head * 10000 + tail * 100 + size }

fn rb_is_empty(state: Int) -> Int { if rb_size(state) == 0 { 1 } else { 0 } }
fn rb_is_full(state: Int) -> Int { if rb_size(state) == 8 { 1 } else { 0 } }

// Push to tail (enqueue), returns new state (-1 if full)
fn rb_push(data: Arr8, state: Int, val: Int) -> Int {
    if rb_is_full(state) == 1 { 0 - 1 }
    else {
        let tail = rb_tail(state);
        let new_tail = (tail + 1) % 8;
        rb_make(rb_head(state), new_tail, rb_size(state) + 1)
    }
}

// Push modifies data
fn rb_push_data(data: Arr8, state: Int, val: Int) -> Arr8 {
    set8(data, rb_tail(state), val)
}

// Pop from head (dequeue), returns new state (-1 if empty)
fn rb_pop(state: Int) -> Int {
    if rb_is_empty(state) == 1 { 0 - 1 }
    else {
        let head = rb_head(state);
        let new_head = (head + 1) % 8;
        rb_make(new_head, rb_tail(state), rb_size(state) - 1)
    }
}

// Peek at head
fn rb_peek(data: Arr8, state: Int) -> Int {
    get8(data, rb_head(state))
}

// Peek at position (0-indexed from head)
fn rb_at(data: Arr8, state: Int, idx: Int) -> Int {
    get8(data, (rb_head(state) + idx) % 8)
}

fn test_basic_ops() -> Int {
    let mut data = zeros();
    let mut state = rb_new();
    assert_eq(rb_is_empty(state), 1);
    assert_eq(rb_size(state), 0);

    // Push 10, 20, 30
    data = rb_push_data(data, state, 10);
    state = rb_push(data, state, 10);
    data = rb_push_data(data, state, 20);
    state = rb_push(data, state, 20);
    data = rb_push_data(data, state, 30);
    state = rb_push(data, state, 30);

    assert_eq(rb_size(state), 3);
    assert_eq(rb_is_empty(state), 0);
    assert_eq(rb_peek(data, state), 10); // head

    // Pop: should get 10
    let val1 = rb_peek(data, state);
    state = rb_pop(state);
    assert_eq(val1, 10);
    assert_eq(rb_size(state), 2);

    // Pop: should get 20
    let val2 = rb_peek(data, state);
    state = rb_pop(state);
    assert_eq(val2, 20);

    // Pop: should get 30
    let val3 = rb_peek(data, state);
    state = rb_pop(state);
    assert_eq(val3, 30);
    assert_eq(rb_is_empty(state), 1);
    1
}

fn test_wrap_around() -> Int {
    let mut data = zeros();
    let mut state = rb_new();

    // Fill 6 elements
    let mut i = 0;
    while i < 6 {
        data = rb_push_data(data, state, (i + 1) * 10);
        state = rb_push(data, state, (i + 1) * 10);
        i = i + 1;
    }
    assert_eq(rb_size(state), 6);

    // Pop 4 elements
    i = 0;
    while i < 4 {
        state = rb_pop(state);
        i = i + 1;
    }
    assert_eq(rb_size(state), 2);
    // Head should be at 4

    // Push 4 more (wraps around)
    i = 0;
    while i < 4 {
        data = rb_push_data(data, state, 100 + i);
        state = rb_push(data, state, 100 + i);
        i = i + 1;
    }
    assert_eq(rb_size(state), 6);
    // The tail has wrapped around past index 7 back to low indices
    1
}

fn test_full_buffer() -> Int {
    let mut data = zeros();
    let mut state = rb_new();

    // Fill to capacity
    let mut i = 0;
    while i < 8 {
        data = rb_push_data(data, state, i * 10);
        state = rb_push(data, state, i * 10);
        i = i + 1;
    }
    assert_eq(rb_is_full(state), 1);
    assert_eq(rb_size(state), 8);
    // Push when full should fail
    assert_eq(rb_push(data, state, 99), 0 - 1);

    // Pop one, then push should work
    state = rb_pop(state);
    assert_eq(rb_size(state), 7);
    assert_eq(rb_is_full(state), 0);
    1
}

fn test_at_index() -> Int {
    let mut data = zeros();
    let mut state = rb_new();

    // Push 10, 20, 30, 40, 50
    let mut i = 0;
    while i < 5 {
        data = rb_push_data(data, state, (i + 1) * 10);
        state = rb_push(data, state, (i + 1) * 10);
        i = i + 1;
    }

    assert_eq(rb_at(data, state, 0), 10);
    assert_eq(rb_at(data, state, 1), 20);
    assert_eq(rb_at(data, state, 2), 30);
    assert_eq(rb_at(data, state, 4), 50);
    1
}

fn test_fifo_order() -> Int {
    let mut data = zeros();
    let mut state = rb_new();

    // Interleave pushes and pops to verify FIFO
    data = rb_push_data(data, state, 1);
    state = rb_push(data, state, 1);
    data = rb_push_data(data, state, 2);
    state = rb_push(data, state, 2);

    // Pop 1
    assert_eq(rb_peek(data, state), 1);
    state = rb_pop(state);

    // Push 3
    data = rb_push_data(data, state, 3);
    state = rb_push(data, state, 3);

    // Pop 2
    assert_eq(rb_peek(data, state), 2);
    state = rb_pop(state);

    // Pop 3
    assert_eq(rb_peek(data, state), 3);
    state = rb_pop(state);

    assert_eq(rb_is_empty(state), 1);
    1
}

fn main() -> Int {
    test_basic_ops();
    test_wrap_around();
    test_full_buffer();
    test_at_index();
    test_fifo_order();
    print("[OK] 677_ring_buffer_aot");
    0
}
