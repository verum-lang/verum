// @test: run
// @level: L0
// @tier: 1
// @tags: list, map, collections, operations
// @description: Test collection operations - list manipulation, map usage

fn test_list_ops() -> Int {
    let mut items = List.new();
    items.push(10);
    items.push(20);
    items.push(30);
    items.push(40);
    items.push(50);

    if items.len() != 5 {
        print(f"FAIL list_ops: len={items.len()}, expected 5");
        return 1;
    }
    if items[0] != 10 || items[4] != 50 {
        print("FAIL list_ops: wrong values");
        return 1;
    }

    // Sum all elements
    let mut sum = 0;
    let mut i = 0;
    while i < items.len() {
        sum = sum + items[i];
        i = i + 1;
    }
    if sum != 150 {
        print(f"FAIL list_ops: sum={sum}, expected 150");
        return 1;
    }
    print("  list_ops: OK");
    0
}

fn test_list_build() -> Int {
    // Build list from range
    let mut squares = List.new();
    let mut i = 1;
    while i <= 10 {
        squares.push(i * i);
        i = i + 1;
    }
    if squares.len() != 10 {
        print(f"FAIL list_build: len={squares.len()}");
        return 1;
    }
    if squares[0] != 1 || squares[9] != 100 {
        print("FAIL list_build: wrong values");
        return 1;
    }
    print("  list_build: OK");
    0
}

fn test_list_literal() -> Int {
    let items = [5, 10, 15, 20, 25];
    if items.len() != 5 {
        print(f"FAIL literal: len={items.len()}");
        return 1;
    }
    // Find max
    let mut max_val = items[0];
    let mut i = 1;
    while i < items.len() {
        if items[i] > max_val {
            max_val = items[i];
        }
        i = i + 1;
    }
    if max_val != 25 {
        print(f"FAIL literal: max={max_val}, expected 25");
        return 1;
    }
    print("  list_literal: OK");
    0
}

fn test_map_basic() -> Int {
    let mut m = Map.new();
    m.insert(1, 100);
    m.insert(2, 200);
    m.insert(3, 300);

    if m.len() != 3 {
        print(f"FAIL map_basic: len={m.len()}, expected 3");
        return 1;
    }

    let v = m.get(2);
    if v != 200 {
        print(f"FAIL map_basic: get(2)={v}, expected 200");
        return 1;
    }
    print("  map_basic: OK");
    0
}

fn test_map_update() -> Int {
    let mut m = Map.new();
    m.insert(1, 10);
    m.insert(1, 20); // overwrite
    let v = m.get(1);
    if v != 20 {
        print(f"FAIL map_update: v={v}, expected 20");
        return 1;
    }
    print("  map_update: OK");
    0
}

fn test_nested_list() -> Int {
    let mut matrix = List.new();
    let mut i = 0;
    while i < 3 {
        let mut row = List.new();
        let mut j = 0;
        while j < 3 {
            row.push(i * 3 + j);
            j = j + 1;
        }
        matrix.push(row);
        i = i + 1;
    }

    // matrix[1][2] = 1*3+2 = 5
    let row1 = matrix[1];
    if row1[2] != 5 {
        print(f"FAIL nested: matrix[1][2]={row1[2]}, expected 5");
        return 1;
    }
    print("  nested_list: OK");
    0
}

fn main() -> Int {
    print("Collection Operations Tests:");
    let mut failures = 0;
    failures = failures + test_list_ops();
    failures = failures + test_list_build();
    failures = failures + test_list_literal();
    failures = failures + test_map_basic();
    failures = failures + test_map_update();
    failures = failures + test_nested_list();

    if failures == 0 {
        print("All collection operations tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
