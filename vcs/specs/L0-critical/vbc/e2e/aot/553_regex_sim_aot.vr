// @test: run
// @level: L0
// @tags: aot, e2e, regex, pattern, matching
// @timeout: 30000

// Simple regex matching simulation

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Pattern tokens: positive = literal char (as int), negative = special
// -1 = . (any char)
// -2 = * (zero or more of previous)
// -3 = + (one or more of previous)
// -4 = ? (zero or one of previous)

// Simple pattern match (no backtracking, greedy)
// Returns 1 if text matches pattern entirely

@allow(unbounded_recursion)
fn match_helper(pat: Arr8, plen: Int, pi: Int, txt: Arr8, tlen: Int, ti: Int) -> Int {
    if pi == plen {
        // Pattern exhausted: match iff text exhausted too
        if ti == tlen { return 1; } else { return 0; }
    }

    let pc = get8(pat, pi);

    // Check if next pattern token is a quantifier
    let has_quant = if pi + 1 < plen {
        let next = get8(pat, pi + 1);
        if next == -2 { 1 }      // *
        else if next == -4 { 1 } // ?
        else { 0 }
    } else { 0 };

    if has_quant == 1 {
        let quant = get8(pat, pi + 1);
        if quant == -2 {
            // * : try matching 0 copies first (lazy for simplicity)
            if match_helper(pat, plen, pi + 2, txt, tlen, ti) == 1 { return 1; }
            // Try consuming one char and repeating
            let mut j = ti;
            while j < tlen {
                let matches = if pc == -1 { 1 } else if pc == get8(txt, j) { 1 } else { 0 };
                if matches == 0 { return 0; }
                j = j + 1;
                if match_helper(pat, plen, pi + 2, txt, tlen, j) == 1 { return 1; }
            }
            return 0;
        }
        if quant == -4 {
            // ? : try 0 copies
            if match_helper(pat, plen, pi + 2, txt, tlen, ti) == 1 { return 1; }
            // Try 1 copy
            if ti < tlen {
                let matches = if pc == -1 { 1 } else if pc == get8(txt, ti) { 1 } else { 0 };
                if matches == 1 {
                    return match_helper(pat, plen, pi + 2, txt, tlen, ti + 1);
                }
            }
            return 0;
        }
    }

    // No quantifier: match single char
    if ti >= tlen { return 0; }
    let matches = if pc == -1 { 1 } else if pc == get8(txt, ti) { 1 } else { 0 };
    if matches == 1 {
        return match_helper(pat, plen, pi + 1, txt, tlen, ti + 1);
    }
    0
}

fn regex_match(pat: Arr8, plen: Int, txt: Arr8, tlen: Int) -> Int {
    match_helper(pat, plen, 0, txt, tlen, 0)
}

fn test_literal_match() -> Int {
    // Pattern "abc" (1,2,3), text "abc" (1,2,3) → match
    let pat = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let txt = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, txt, 3), 1);

    // Different text → no match
    let txt2 = Arr8 { v0: 1, v1: 2, v2: 4, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, txt2, 3), 0);
    1
}

fn test_dot_wildcard() -> Int {
    // Pattern "a.c" (1,-1,3)
    let pat = Arr8 { v0: 1, v1: -1, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Text "abc" (1,2,3) → match
    let txt1 = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, txt1, 3), 1);
    // Text "axc" (1,9,3) → match
    let txt2 = Arr8 { v0: 1, v1: 9, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, txt2, 3), 1);
    // Text "ac" (1,3) → no match (too short)
    let txt3 = Arr8 { v0: 1, v1: 3, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, txt3, 2), 0);
    1
}

fn test_star() -> Int {
    // Pattern "a*b" (1,-2,2): zero or more 'a' followed by 'b'
    let pat = Arr8 { v0: 1, v1: -2, v2: 2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // "b" → match (zero a's)
    let t1 = Arr8 { v0: 2, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, t1, 1), 1);
    // "ab" → match
    let t2 = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, t2, 2), 1);
    // "aab" → match
    let t3 = Arr8 { v0: 1, v1: 1, v2: 2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, t3, 3), 1);
    // "c" → no match
    let t4 = Arr8 { v0: 3, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, t4, 1), 0);
    1
}

fn test_question_mark() -> Int {
    // Pattern "a?b" (1,-4,2): zero or one 'a' followed by 'b'
    let pat = Arr8 { v0: 1, v1: -4, v2: 2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // "b" → match
    let t1 = Arr8 { v0: 2, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, t1, 1), 1);
    // "ab" → match
    let t2 = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, t2, 2), 1);
    // "aab" → no match (only 0 or 1 a's)
    let t3 = Arr8 { v0: 1, v1: 1, v2: 2, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 3, t3, 3), 0);
    1
}

fn test_dot_star() -> Int {
    // Pattern ".*" (-1,-2): match anything
    let pat = Arr8 { v0: -1, v1: -2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Empty → match
    assert_eq(regex_match(pat, 2, zeros(), 0), 1);
    // "abc" → match
    let txt = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(pat, 2, txt, 3), 1);
    1
}

fn test_empty() -> Int {
    // Empty pattern matches empty text
    assert_eq(regex_match(zeros(), 0, zeros(), 0), 1);
    // Empty pattern doesn't match non-empty text
    let txt = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(regex_match(zeros(), 0, txt, 1), 0);
    1
}

fn main() -> Int {
    test_literal_match();
    test_dot_wildcard();
    test_star();
    test_question_mark();
    test_dot_star();
    test_empty();
    print("[OK] 553_regex_sim_aot");
    0
}
