// @test: run
// @tier: 0
// @level: L0
// @tags: aot, autodiff, gradient, multivariate, partial-derivative
// @expected-exit: 0

// Tests multivariate gradient computation (partial derivatives).
// Verifies Jacobian properties, gradient descent direction, and Hessian.

fn abs_val(x: Int) -> Int {
    if (x < 0) { 0 - x } else { x }
}

// f(x,y) = x*y, âˆ‚f/âˆ‚x = y, âˆ‚f/âˆ‚y = x
fn f_xy(x: Int, y: Int) -> Int {
    x * y
}

// f(x,y) = x^2 + y^2, âˆ‚f/âˆ‚x = 2x, âˆ‚f/âˆ‚y = 2y
fn f_sphere(x: Int, y: Int) -> Int {
    x * x + y * y
}

// f(x,y) = x^2*y + x*y^2, âˆ‚f/âˆ‚x = 2xy + y^2, âˆ‚f/âˆ‚y = x^2 + 2xy
fn f_mixed(x: Int, y: Int) -> Int {
    x * x * y + x * y * y
}

fn df_mixed_dx(x: Int, y: Int) -> Int {
    2 * x * y + y * y
}

fn df_mixed_dy(x: Int, y: Int) -> Int {
    x * x + 2 * x * y
}

// f(x,y,z) = x*y*z, âˆ‚f/âˆ‚x = yz, âˆ‚f/âˆ‚y = xz, âˆ‚f/âˆ‚z = xy
fn f_xyz(x: Int, y: Int, z: Int) -> Int {
    x * y * z
}

// Rosenbrock: f(x,y) = (a-x)^2 + b*(y-x^2)^2
// For a=1, b=1: f(x,y) = (1-x)^2 + (y-x^2)^2
fn rosenbrock(x: Int, y: Int) -> Int {
    let t1 = 1 - x;
    let t2 = y - x * x;
    t1 * t1 + t2 * t2
}

// âˆ‚f/âˆ‚x = -2(1-x) - 4x(y-x^2) = 2x - 2 - 4xy + 4x^3
fn drosen_dx(x: Int, y: Int) -> Int {
    2 * x - 2 - 4 * x * y + 4 * x * x * x
}

// âˆ‚f/âˆ‚y = 2(y-x^2)
fn drosen_dy(x: Int, y: Int) -> Int {
    2 * (y - x * x)
}

fn main() -> Int {
    // Test 1: Partial derivatives of f(x,y) = x*y
    assert_eq(f_xy(3, 5), 15);
    // âˆ‚f/âˆ‚x at (3,5) = 5 (holding y constant, gradient wrt x)
    let fd_dx = (f_xy(4, 5) - f_xy(2, 5)) / 2;
    assert_eq(fd_dx, 5);
    // âˆ‚f/âˆ‚y at (3,5) = 3
    let fd_dy = (f_xy(3, 6) - f_xy(3, 4)) / 2;
    assert_eq(fd_dy, 3);

    // Test 2: Gradient of sphere: âˆ‡f = (2x, 2y)
    // At (3, 4): gradient = (6, 8), magnitude^2 = 100
    let gx = 2 * 3;
    let gy = 2 * 4;
    assert_eq(gx, 6);
    assert_eq(gy, 8);
    let grad_mag_sq = gx * gx + gy * gy;
    assert_eq(grad_mag_sq, 100);

    // Test 3: Mixed partial derivatives (Schwarz's theorem)
    // f(x,y) = x^2*y + x*y^2
    // âˆ‚Â²f/âˆ‚xâˆ‚y should equal âˆ‚Â²f/âˆ‚yâˆ‚x
    // âˆ‚f/âˆ‚x = 2xy + y^2, âˆ‚Â²f/âˆ‚yâˆ‚x = 2x + 2y
    // âˆ‚f/âˆ‚y = x^2 + 2xy, âˆ‚Â²f/âˆ‚xâˆ‚y = 2x + 2y
    let x = 3;
    let y = 4;
    let d2f_dxdy = 2 * x + 2 * y;
    let d2f_dydx = 2 * x + 2 * y;
    assert_eq(d2f_dxdy, d2f_dydx);  // Symmetry of mixed partials
    assert_eq(d2f_dxdy, 14);

    // Test 4: Verify analytical vs finite-difference for mixed function
    assert_eq(df_mixed_dx(3, 4), 40);  // 2*3*4 + 16 = 40
    assert_eq(df_mixed_dy(3, 4), 33);  // 9 + 24 = 33
    let fd_mixed_dx = (f_mixed(4, 4) - f_mixed(2, 4)) / 2;
    assert_eq(fd_mixed_dx, 40);
    let fd_mixed_dy = (f_mixed(3, 5) - f_mixed(3, 3)) / 2;
    assert_eq(fd_mixed_dy, 33);

    // Test 5: Three-variable partial derivatives
    // f(x,y,z) = xyz at (2,3,5)
    assert_eq(f_xyz(2, 3, 5), 30);
    // âˆ‚f/âˆ‚x = yz = 15
    let fd_x = (f_xyz(3, 3, 5) - f_xyz(1, 3, 5)) / 2;
    assert_eq(fd_x, 15);
    // âˆ‚f/âˆ‚y = xz = 10
    let fd_y = (f_xyz(2, 4, 5) - f_xyz(2, 2, 5)) / 2;
    assert_eq(fd_y, 10);
    // âˆ‚f/âˆ‚z = xy = 6
    let fd_z = (f_xyz(2, 3, 6) - f_xyz(2, 3, 4)) / 2;
    assert_eq(fd_z, 6);

    // Test 6: Rosenbrock function gradient at known points
    // At (1,1): minimum, gradient = (0, 0)
    assert_eq(rosenbrock(1, 1), 0);
    assert_eq(drosen_dx(1, 1), 0);
    assert_eq(drosen_dy(1, 1), 0);

    // At (0,0): f = 1, âˆ‚f/âˆ‚x = -2, âˆ‚f/âˆ‚y = 0
    assert_eq(rosenbrock(0, 0), 1);
    assert_eq(drosen_dx(0, 0), -2);
    assert_eq(drosen_dy(0, 0), 0);

    // Test 7: Gradient descent direction
    // At (0,0), gradient is (-2, 0), so descent direction is (2, 0)
    // Moving in gradient descent direction should decrease f
    let step = 1;  // Small step
    let f_before = rosenbrock(0, 0);
    let f_after = rosenbrock(0 + step, 0); // Move in -grad direction â†’ (+2, 0)
    // f(1, 0) = 0 + 1 = 1, same as f(0,0). Step too large.
    // Use (0,0) â†’ (1,1) which is the minimum
    let f_min = rosenbrock(1, 1);
    assert(f_min <= f_before);

    // Test 8: Directional derivative
    // D_v f(x,y) = âˆ‡f Â· v (dot product of gradient with direction)
    // f = x^2 + y^2, âˆ‡f at (3,4) = (6, 8)
    // Direction v = (3, 4) (not normalized, just testing dot product)
    let dir_deriv = 6 * 3 + 8 * 4;  // 18 + 32 = 50
    assert_eq(dir_deriv, 50);

    // Test 9: Hessian matrix determinant
    // f(x,y) = x^2*y + x*y^2
    // H = [[2y, 2x+2y], [2x+2y, 2x]]
    // det(H) = 2y*2x - (2x+2y)^2 = 4xy - 4x^2 - 8xy - 4y^2 = -4x^2 - 4xy - 4y^2
    // At (1,1): det = -4 - 4 - 4 = -12 (saddle point)
    let hxx = 2 * 1;  // 2y at y=1
    let hxy = 2 * 1 + 2 * 1;  // 2x + 2y at (1,1)
    let hyy = 2 * 1;  // 2x at x=1
    let det_h = hxx * hyy - hxy * hxy;
    assert_eq(det_h, -12);

    // Test 10: Euler's theorem for homogeneous functions
    // If f is homogeneous of degree n: x*âˆ‚f/âˆ‚x + y*âˆ‚f/âˆ‚y = n*f(x,y)
    // f(x,y) = x^2*y + x*y^2 is degree 3
    // x*âˆ‚f/âˆ‚x + y*âˆ‚f/âˆ‚y = x*(2xy+y^2) + y*(x^2+2xy) = 2x^2y + xy^2 + x^2y + 2xy^2
    // = 3x^2y + 3xy^2 = 3*(x^2y + xy^2) = 3*f(x,y) âœ“
    let xv = 2;
    let yv = 3;
    let euler_lhs = xv * df_mixed_dx(xv, yv) + yv * df_mixed_dy(xv, yv);
    let euler_rhs = 3 * f_mixed(xv, yv);
    assert_eq(euler_lhs, euler_rhs);

    print("Autodiff multivar: PASS");
    0
}
