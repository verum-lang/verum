// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, math
// @timeout: 5000
// @expected-exit: 0
// @description: AOT complex integer math, bit operations, overflow behavior

@allow(unbounded_recursion)
fn ipow(base: Int, exp: Int) -> Int {
    if exp == 0 { 1 }
    else if exp == 1 { base }
    else if exp % 2 == 0 {
        let half = ipow(base, exp / 2);
        half * half
    } else {
        base * ipow(base, exp - 1)
    }
}

fn int_sqrt(n: Int) -> Int {
    if n < 0 { -1 }
    else if n == 0 { 0 }
    else {
        let mut x = n;
        let mut y = (x + 1) / 2;
        while y < x {
            x = y;
            y = (x + n / x) / 2;
        }
        x
    }
}

@allow(unbounded_recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 { n + 1 }
    else if n == 0 { ackermann(m - 1, 1) }
    else { ackermann(m - 1, ackermann(m, n - 1)) }
}

fn div_mod_test(a: Int, b: Int) -> Int {
    let q = a / b;
    let r = a % b;
    // a = q*b + r should hold
    if q * b + r == a { 0 } else { 1 }
}

fn main() -> Int {
    // Fast exponentiation
    assert_eq(ipow(2, 0), 1);
    assert_eq(ipow(2, 10), 1024);
    assert_eq(ipow(3, 7), 2187);
    assert_eq(ipow(5, 5), 3125);

    // Integer square root
    assert_eq(int_sqrt(0), 0);
    assert_eq(int_sqrt(1), 1);
    assert_eq(int_sqrt(4), 2);
    assert_eq(int_sqrt(9), 3);
    assert_eq(int_sqrt(100), 10);
    assert_eq(int_sqrt(1000000), 1000);

    // Ackermann (small values)
    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(1, 1), 3);
    assert_eq(ackermann(2, 2), 7);
    assert_eq(ackermann(3, 3), 61);

    // Division/modulo consistency
    assert_eq(div_mod_test(17, 5), 0);
    assert_eq(div_mod_test(100, 7), 0);
    assert_eq(div_mod_test(1000, 13), 0);

    0
}
