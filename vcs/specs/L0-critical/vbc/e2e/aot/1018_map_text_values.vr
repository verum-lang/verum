// @test: run
// Map<Text, List<Int>> — text keys and list values through map operations

fn build_groups() -> Map<Text, List<Int>> {
    let mut groups = Map.new();
    let evens = List.new();
    evens.push(2); evens.push(4); evens.push(6);
    groups.insert("even", evens);
    groups
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    let groups = build_groups();

    // Test 1: Map len
    if (groups.len() == 1) { passed = passed + 1; }
    else { print(f"FAIL 1: groups.len()={groups.len()}"); failed = failed + 1; }

    // Test 2: Get list value and check len
    let evens = groups.get("even");
    if (evens.len() == 3) { passed = passed + 1; }
    else { print(f"FAIL 2: evens.len()={evens.len()}"); failed = failed + 1; }

    // Test 3: Get list element
    if (evens[0] == 2 && evens[2] == 6) { passed = passed + 1; }
    else { print(f"FAIL 3: evens[0]={evens[0]} evens[2]={evens[2]}"); failed = failed + 1; }

    // Test 4: contains_key
    if (groups.contains_key("even") && !groups.contains_key("prime")) { passed = passed + 1; }
    else { print("FAIL 4: contains_key wrong"); failed = failed + 1; }

    // Test 5: Insert and get more
    let primes = List.new();
    primes.push(2); primes.push(3); primes.push(5); primes.push(7);
    groups.insert("prime", primes);
    if (groups.len() == 2) { passed = passed + 1; }
    else { print(f"FAIL 5: groups.len()={groups.len()}"); failed = failed + 1; }

    if (failed > 0) {
        print(f"map_text_values: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"map_text_values: PASS ({passed}/{passed} tests)");
    0
}
