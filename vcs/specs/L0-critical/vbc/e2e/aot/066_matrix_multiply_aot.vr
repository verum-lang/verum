// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, matrix, linear-algebra, arithmetic
// @timeout: 50000
// @expected-exit: 0
// @description: AOT 3x3 matrix operations: add, multiply, trace, determinant

type Mat3 is {
    m00: Int, m01: Int, m02: Int,
    m10: Int, m11: Int, m12: Int,
    m20: Int, m21: Int, m22: Int,
};

fn mat_zero() -> Mat3 {
    Mat3 {
        m00: 0, m01: 0, m02: 0,
        m10: 0, m11: 0, m12: 0,
        m20: 0, m21: 0, m22: 0,
    }
}

fn mat_identity() -> Mat3 {
    Mat3 {
        m00: 1, m01: 0, m02: 0,
        m10: 0, m11: 1, m12: 0,
        m20: 0, m21: 0, m22: 1,
    }
}

fn mat_add(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00 + b.m00, m01: a.m01 + b.m01, m02: a.m02 + b.m02,
        m10: a.m10 + b.m10, m11: a.m11 + b.m11, m12: a.m12 + b.m12,
        m20: a.m20 + b.m20, m21: a.m21 + b.m21, m22: a.m22 + b.m22,
    }
}

fn mat_scale(a: Mat3, k: Int) -> Mat3 {
    Mat3 {
        m00: a.m00 * k, m01: a.m01 * k, m02: a.m02 * k,
        m10: a.m10 * k, m11: a.m11 * k, m12: a.m12 * k,
        m20: a.m20 * k, m21: a.m21 * k, m22: a.m22 * k,
    }
}

fn mat_mul(a: Mat3, b: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00 * b.m00 + a.m01 * b.m10 + a.m02 * b.m20,
        m01: a.m00 * b.m01 + a.m01 * b.m11 + a.m02 * b.m21,
        m02: a.m00 * b.m02 + a.m01 * b.m12 + a.m02 * b.m22,
        m10: a.m10 * b.m00 + a.m11 * b.m10 + a.m12 * b.m20,
        m11: a.m10 * b.m01 + a.m11 * b.m11 + a.m12 * b.m21,
        m12: a.m10 * b.m02 + a.m11 * b.m12 + a.m12 * b.m22,
        m20: a.m20 * b.m00 + a.m21 * b.m10 + a.m22 * b.m20,
        m21: a.m20 * b.m01 + a.m21 * b.m11 + a.m22 * b.m21,
        m22: a.m20 * b.m02 + a.m21 * b.m12 + a.m22 * b.m22,
    }
}

fn mat_trace(a: Mat3) -> Int {
    a.m00 + a.m11 + a.m22
}

fn mat_determinant(a: Mat3) -> Int {
    a.m00 * (a.m11 * a.m22 - a.m12 * a.m21)
    - a.m01 * (a.m10 * a.m22 - a.m12 * a.m20)
    + a.m02 * (a.m10 * a.m21 - a.m11 * a.m20)
}

fn mat_transpose(a: Mat3) -> Mat3 {
    Mat3 {
        m00: a.m00, m01: a.m10, m02: a.m20,
        m10: a.m01, m11: a.m11, m12: a.m21,
        m20: a.m02, m21: a.m12, m22: a.m22,
    }
}

fn mat_eq(a: Mat3, b: Mat3) -> Bool {
    a.m00 == b.m00 && a.m01 == b.m01 && a.m02 == b.m02
    && a.m10 == b.m10 && a.m11 == b.m11 && a.m12 == b.m12
    && a.m20 == b.m20 && a.m21 == b.m21 && a.m22 == b.m22
}

fn main() -> Int {
    let zero = mat_zero();
    let id = mat_identity();

    // === Identity properties ===
    assert_eq(mat_trace(id), 3);
    assert_eq(mat_determinant(id), 1);
    assert_eq(mat_trace(zero), 0);
    assert_eq(mat_determinant(zero), 0);

    // === A concrete matrix ===
    // A = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
    let a = Mat3 {
        m00: 1, m01: 2, m02: 3,
        m10: 4, m11: 5, m12: 6,
        m20: 7, m21: 8, m22: 9,
    };

    assert_eq(mat_trace(a), 15);
    // det(A) = 1*(45-48) - 2*(36-42) + 3*(32-35) = -3 + 12 - 9 = 0
    assert_eq(mat_determinant(a), 0);

    // === Identity * A = A ===
    let id_times_a = mat_mul(id, a);
    assert(mat_eq(id_times_a, a));

    // === A * Identity = A ===
    let a_times_id = mat_mul(a, id);
    assert(mat_eq(a_times_id, a));

    // === Zero * A = Zero ===
    let zero_times_a = mat_mul(zero, a);
    assert(mat_eq(zero_times_a, zero));

    // === A + Zero = A ===
    let a_plus_zero = mat_add(a, zero);
    assert(mat_eq(a_plus_zero, a));

    // === Matrix with nonzero determinant ===
    // B = [[2, 1, 0], [0, 3, 1], [1, 0, 2]]
    let b = Mat3 {
        m00: 2, m01: 1, m02: 0,
        m10: 0, m11: 3, m12: 1,
        m20: 1, m21: 0, m22: 2,
    };

    assert_eq(mat_trace(b), 7);
    // det(B) = 2*(6-0) - 1*(0-1) + 0 = 12 + 1 = 13
    assert_eq(mat_determinant(b), 13);

    // === B * B ===
    // B^2 = [[4, 5, 1], [1, 9, 5], [4, 1, 4]]
    let b2 = mat_mul(b, b);
    assert_eq(b2.m00, 4);
    assert_eq(b2.m01, 5);
    assert_eq(b2.m02, 1);
    assert_eq(b2.m10, 1);
    assert_eq(b2.m11, 9);
    assert_eq(b2.m12, 5);
    assert_eq(b2.m20, 4);
    assert_eq(b2.m21, 1);
    assert_eq(b2.m22, 4);

    // trace(B^2) = 4 + 9 + 4 = 17
    assert_eq(mat_trace(b2), 17);
    // det(B^2) = det(B)^2 = 169
    assert_eq(mat_determinant(b2), 169);

    // === Addition and scaling ===
    let a_plus_b = mat_add(a, b);
    assert_eq(a_plus_b.m00, 3);
    assert_eq(a_plus_b.m11, 8);
    assert_eq(a_plus_b.m22, 11);
    assert_eq(mat_trace(a_plus_b), 22);

    let scaled = mat_scale(b, 3);
    assert_eq(scaled.m00, 6);
    assert_eq(scaled.m11, 9);
    assert_eq(scaled.m22, 6);
    assert_eq(mat_trace(scaled), 21);

    // scale(B, 3) determinant = 3^3 * det(B) = 27 * 13 = 351
    assert_eq(mat_determinant(scaled), 351);

    // === Transpose ===
    let bt = mat_transpose(b);
    assert_eq(bt.m00, 2);
    assert_eq(bt.m01, 0);
    assert_eq(bt.m02, 1);
    assert_eq(bt.m10, 1);
    assert_eq(bt.m11, 3);
    assert_eq(bt.m12, 0);
    assert_eq(bt.m20, 0);
    assert_eq(bt.m21, 1);
    assert_eq(bt.m22, 2);
    // Trace is invariant under transpose
    assert_eq(mat_trace(bt), mat_trace(b));
    // Determinant is invariant under transpose
    assert_eq(mat_determinant(bt), mat_determinant(b));

    // === Double transpose = original ===
    let btt = mat_transpose(bt);
    assert(mat_eq(btt, b));

    // === Diagonal matrix ===
    let diag = Mat3 {
        m00: 3, m01: 0, m02: 0,
        m10: 0, m11: 5, m12: 0,
        m20: 0, m21: 0, m22: 7,
    };
    assert_eq(mat_trace(diag), 15);
    assert_eq(mat_determinant(diag), 105);  // 3 * 5 * 7

    // Diagonal * Diagonal = diagonal with squared entries
    let diag2 = mat_mul(diag, diag);
    assert_eq(diag2.m00, 9);
    assert_eq(diag2.m11, 25);
    assert_eq(diag2.m22, 49);
    assert_eq(diag2.m01, 0);
    assert_eq(diag2.m10, 0);

    // === Commutativity check: A*B vs B*A (should differ for non-diagonal) ===
    let ab = mat_mul(a, b);
    let ba = mat_mul(b, a);
    // A*B and B*A should generally not be equal
    let commutes = mat_eq(ab, ba);
    assert(!commutes);

    // But trace of products is the same: tr(AB) = tr(BA)
    assert_eq(mat_trace(ab), mat_trace(ba));

    0
}
