// @test: run
// @level: L0
// @tier: 0
// @tags: set, comprehension, e2e
// @description: Test set creation and operations

fn main() -> Int {
    let mut f = 0;

    // Test 1: Basic Set creation and insert
    let mut s = Set.new();
    s.insert(1);
    s.insert(2);
    s.insert(3);
    s.insert(2);  // duplicate

    if s.len() != 3 {
        print(f"FAIL 1: set len = {s.len()}, expected 3");
        f = f + 1;
    } else {
        print("  set_insert: OK");
    }

    // Test 2: Set.contains
    if !s.contains(2) {
        print("FAIL 2: set should contain 2");
        f = f + 1;
    } else {
        print("  set_contains: OK");
    }

    if s.contains(99) {
        print("FAIL 2b: set should not contain 99");
        f = f + 1;
    }

    // Test 3: Set.remove
    s.remove(2);
    if s.contains(2) {
        print("FAIL 3: set should not contain 2 after remove");
        f = f + 1;
    }
    if s.len() != 2 {
        print(f"FAIL 3b: set len = {s.len()}, expected 2");
        f = f + 1;
    } else {
        print("  set_remove: OK");
    }

    // Test 4: Empty set
    let empty = Set.new();
    if empty.len() != 0 {
        print("FAIL 4: empty set len != 0");
        f = f + 1;
    } else {
        print("  set_empty: OK");
    }

    if f == 0 {
        print("All set tests passed");
    }
    f
}
