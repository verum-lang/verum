// @test: run
// @level: L0
// @tags: aot, e2e, trie, prefix-tree, data-structure
// @timeout: 30000

// Trie (prefix tree) simulation using bitmask representation
// Each node: children bitmask (bits 0-7 for symbols 0-7) + is_word flag

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn bit(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn has_bit(mask: Int, n: Int) -> Int {
    (mask / bit(n)) % 2
}

// Trie with max 8 nodes. Each node stores:
// - children bitmask (which symbols have children)
// - is_word flag
// Packed as: children_mask * 2 + is_word
// Node indices: 0 = root, 1-7 = allocated nodes
// Child mapping: separate array maps (parent, symbol) → child index

type Trie is {
    nodes: Arr8,     // packed node data (children_mask * 2 + is_word)
    next_id: Int,    // next available node id
    // Child index storage: node*8+symbol → child_id (flat)
    // But we can't store 64 entries. Use simpler approach:
    // Store child relationships as (parent*10+symbol, child_id) pairs
    children: Arr8   // child_id for each (allocated sequentially)
};

// Simpler trie: just track which "words" (encoded as int) exist
// Word = sequence of symbols packed as: sym0 + sym1*10 + sym2*100
// Max 3 symbols per word

fn encode_word(s0: Int, s1: Int, s2: Int, len: Int) -> Int {
    if len == 1 { s0 }
    else if len == 2 { s0 + s1 * 10 }
    else { s0 + s1 * 10 + s2 * 100 }
}

// Set-based trie: just store which word codes are present (up to 8)
type SimpleSet is { vals: Arr8, size: Int };

fn set_new() -> SimpleSet {
    SimpleSet { vals: zeros(), size: 0 }
}

fn set_contains(s: SimpleSet, val: Int) -> Int {
    let mut i = 0;
    while i < s.size {
        if get8(s.vals, i) == val { return 1; }
        i = i + 1;
    }
    0
}

fn set_insert(s: SimpleSet, val: Int) -> SimpleSet {
    if set_contains(s, val) == 1 { return s; }
    if s.size >= 8 { return s; }
    SimpleSet { vals: set8(s.vals, s.size, val), size: s.size + 1 }
}

// Check if any word in set starts with given prefix
fn has_prefix(s: SimpleSet, prefix: Int, prefix_len: Int) -> Int {
    let mut i = 0;
    while i < s.size {
        let word = get8(s.vals, i);
        // Check if word starts with prefix
        let mut match_ok = 1;
        let mut w = word;
        let mut p = prefix;
        let mut j = 0;
        while j < prefix_len {
            if w % 10 != p % 10 { match_ok = 0; }
            w = w / 10;
            p = p / 10;
            j = j + 1;
        }
        if match_ok == 1 { return 1; }
        i = i + 1;
    }
    0
}

// Count words with given prefix
fn count_prefix(s: SimpleSet, prefix: Int, prefix_len: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < s.size {
        let word = get8(s.vals, i);
        let mut match_ok = 1;
        let mut w = word;
        let mut p = prefix;
        let mut j = 0;
        while j < prefix_len {
            if w % 10 != p % 10 { match_ok = 0; }
            w = w / 10;
            p = p / 10;
            j = j + 1;
        }
        if match_ok == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_basic_set() -> Int {
    let mut s = set_new();
    s = set_insert(s, 123);
    s = set_insert(s, 456);
    s = set_insert(s, 789);
    assert_eq(s.size, 3);
    assert_eq(set_contains(s, 123), 1);
    assert_eq(set_contains(s, 456), 1);
    assert_eq(set_contains(s, 789), 1);
    assert_eq(set_contains(s, 999), 0);

    // Duplicate insert
    s = set_insert(s, 123);
    assert_eq(s.size, 3);
    1
}

fn test_word_encoding() -> Int {
    // Word "abc" as [1,2,3] → 1 + 2*10 + 3*100 = 321
    assert_eq(encode_word(1, 2, 3, 3), 321);
    // Word "ab" → 1 + 2*10 = 21
    assert_eq(encode_word(1, 2, 0, 2), 21);
    // Word "a" → 1
    assert_eq(encode_word(1, 0, 0, 1), 1);
    1
}

fn test_prefix_search() -> Int {
    let mut s = set_new();
    // Insert words: [1,2,3]=321, [1,2,4]=421, [1,3,5]=531, [2,3,4]=432
    s = set_insert(s, 321);
    s = set_insert(s, 421);
    s = set_insert(s, 531);
    s = set_insert(s, 432);

    // Prefix [1] = 1: matches 321, 421, 531 (all start with digit 1)
    assert_eq(count_prefix(s, 1, 1), 3);

    // Prefix [1,2] = 21: matches 321, 421
    assert_eq(count_prefix(s, 21, 2), 2);

    // Prefix [1,3] = 31: matches 531
    assert_eq(count_prefix(s, 31, 2), 1);

    // Prefix [2] = 2: matches 432
    assert_eq(count_prefix(s, 2, 1), 1);

    // Prefix [3] = 3: no match
    assert_eq(count_prefix(s, 3, 1), 0);
    1
}

fn test_has_prefix() -> Int {
    let mut s = set_new();
    s = set_insert(s, 321);
    s = set_insert(s, 421);

    assert_eq(has_prefix(s, 1, 1), 1);
    assert_eq(has_prefix(s, 21, 2), 1);
    assert_eq(has_prefix(s, 31, 2), 0);
    assert_eq(has_prefix(s, 321, 3), 1);
    1
}

fn test_empty_set() -> Int {
    let s = set_new();
    assert_eq(s.size, 0);
    assert_eq(set_contains(s, 1), 0);
    assert_eq(has_prefix(s, 1, 1), 0);
    assert_eq(count_prefix(s, 1, 1), 0);
    1
}

fn main() -> Int {
    test_basic_set();
    test_word_encoding();
    test_prefix_search();
    test_has_prefix();
    test_empty_set();
    print("[OK] 504_trie_ops_aot");
    0
}
