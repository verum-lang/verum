// @test: run
// @level: L0
// @tags: aot, e2e, milestone, sequences, recurrence
// @timeout: 30000

// Milestone 650: Integer sequences and recurrences

// Fibonacci
fn fib(n: Int) -> Int {
    let mut a = 0;
    let mut b = 1;
    let mut i = 0;
    while i < n { let t = a + b; a = b; b = t; i = i + 1; }
    a
}

// Lucas numbers: L(0)=2, L(1)=1, L(n)=L(n-1)+L(n-2)
fn lucas(n: Int) -> Int {
    let mut a = 2;
    let mut b = 1;
    let mut i = 0;
    while i < n { let t = a + b; a = b; b = t; i = i + 1; }
    a
}

// Tribonacci: T(0)=0, T(1)=0, T(2)=1, T(n)=T(n-1)+T(n-2)+T(n-3)
fn tribonacci(n: Int) -> Int {
    if n == 0 { 0 }
    else if n == 1 { 0 }
    else if n == 2 { 1 }
    else {
        let mut a = 0;
        let mut b = 0;
        let mut c = 1;
        let mut i = 3;
        while i <= n {
            let t = a + b + c;
            a = b;
            b = c;
            c = t;
            i = i + 1;
        }
        c
    }
}

// Padovan: P(0)=1, P(1)=1, P(2)=1, P(n)=P(n-2)+P(n-3)
fn padovan(n: Int) -> Int {
    if n <= 2 { 1 }
    else {
        let mut a = 1;
        let mut b = 1;
        let mut c = 1;
        let mut i = 3;
        while i <= n {
            let t = a + b;
            a = b;
            b = c;
            c = t;
            i = i + 1;
        }
        c
    }
}

// Pell numbers: P(0)=0, P(1)=1, P(n)=2*P(n-1)+P(n-2)
fn pell(n: Int) -> Int {
    let mut a = 0;
    let mut b = 1;
    let mut i = 0;
    while i < n { let t = 2 * b + a; a = b; b = t; i = i + 1; }
    a
}

// Triangular numbers: T(n) = n*(n+1)/2
fn triangular(n: Int) -> Int { n * (n + 1) / 2 }

// Pentagonal numbers: P(n) = n*(3n-1)/2
fn pentagonal(n: Int) -> Int { n * (3 * n - 1) / 2 }

// Tetrahedral numbers: T(n) = n*(n+1)*(n+2)/6
fn tetrahedral(n: Int) -> Int { n * (n + 1) * (n + 2) / 6 }

// Catalan numbers (iterative)
fn catalan(n: Int) -> Int {
    if n <= 1 { 1 }
    else {
        let mut c = 1;
        let mut i = 0;
        while i < n {
            c = c * 2 * (2 * i + 1) / (i + 2);
            i = i + 1;
        }
        c
    }
}

// Collatz sequence length
fn collatz_len(n: Int) -> Int {
    let mut x = n;
    let mut steps = 0;
    while x != 1 {
        if x % 2 == 0 { x = x / 2; }
        else { x = 3 * x + 1; }
        steps = steps + 1;
    }
    steps
}

fn test_fibonacci() -> Int {
    assert_eq(fib(0), 0);
    assert_eq(fib(1), 1);
    assert_eq(fib(2), 1);
    assert_eq(fib(5), 5);
    assert_eq(fib(10), 55);
    assert_eq(fib(15), 610);
    // Property: fib(n)^2 + fib(n+1)^2 = fib(2n+1)
    assert_eq(fib(4) * fib(4) + fib(5) * fib(5), fib(9));
    1
}

fn test_lucas() -> Int {
    assert_eq(lucas(0), 2);
    assert_eq(lucas(1), 1);
    assert_eq(lucas(2), 3);
    assert_eq(lucas(5), 11);
    assert_eq(lucas(10), 123);
    // Identity: L(n) = F(n-1) + F(n+1)
    assert_eq(lucas(5), fib(4) + fib(6));
    assert_eq(lucas(8), fib(7) + fib(9));
    1
}

fn test_tribonacci() -> Int {
    assert_eq(tribonacci(0), 0);
    assert_eq(tribonacci(1), 0);
    assert_eq(tribonacci(2), 1);
    assert_eq(tribonacci(3), 1);
    assert_eq(tribonacci(4), 2);
    assert_eq(tribonacci(5), 4);
    assert_eq(tribonacci(6), 7);
    assert_eq(tribonacci(7), 13);
    1
}

fn test_padovan() -> Int {
    // P: 1, 1, 1, 2, 2, 3, 4, 5, 7, 9, 12
    assert_eq(padovan(0), 1);
    assert_eq(padovan(3), 2);
    assert_eq(padovan(5), 3);
    assert_eq(padovan(7), 5);
    assert_eq(padovan(10), 12);
    1
}

fn test_pell() -> Int {
    // 0, 1, 2, 5, 12, 29, 70, 169
    assert_eq(pell(0), 0);
    assert_eq(pell(1), 1);
    assert_eq(pell(2), 2);
    assert_eq(pell(3), 5);
    assert_eq(pell(4), 12);
    assert_eq(pell(5), 29);
    assert_eq(pell(6), 70);
    1
}

fn test_figurate() -> Int {
    // Triangular: 0, 1, 3, 6, 10, 15, 21
    assert_eq(triangular(0), 0);
    assert_eq(triangular(4), 10);
    assert_eq(triangular(7), 28);
    // Pentagonal: 0, 1, 5, 12, 22, 35, 51
    assert_eq(pentagonal(0), 0);
    assert_eq(pentagonal(1), 1);
    assert_eq(pentagonal(2), 5);
    assert_eq(pentagonal(3), 12);
    assert_eq(pentagonal(5), 35);
    // Tetrahedral: 0, 1, 4, 10, 20, 35
    assert_eq(tetrahedral(0), 0);
    assert_eq(tetrahedral(1), 1);
    assert_eq(tetrahedral(2), 4);
    assert_eq(tetrahedral(3), 10);
    assert_eq(tetrahedral(4), 20);
    1
}

fn test_catalan() -> Int {
    // 1, 1, 2, 5, 14, 42, 132
    assert_eq(catalan(0), 1);
    assert_eq(catalan(1), 1);
    assert_eq(catalan(2), 2);
    assert_eq(catalan(3), 5);
    assert_eq(catalan(4), 14);
    assert_eq(catalan(5), 42);
    1
}

fn test_collatz() -> Int {
    assert_eq(collatz_len(1), 0);
    assert_eq(collatz_len(2), 1);
    assert_eq(collatz_len(3), 7);
    assert_eq(collatz_len(6), 8);
    assert_eq(collatz_len(27), 111);
    1
}

fn main() -> Int {
    test_fibonacci();
    test_lucas();
    test_tribonacci();
    test_padovan();
    test_pell();
    test_figurate();
    test_catalan();
    test_collatz();
    print("[OK] 650_milestone_aot");
    0
}
