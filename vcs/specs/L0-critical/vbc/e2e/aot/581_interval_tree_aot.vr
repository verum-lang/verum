// @test: run
// @level: L0
// @tags: aot, e2e, interval, overlap, scheduling
// @timeout: 30000

// Interval operations: overlap detection, merging, scheduling

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// Intervals stored as packed: start*100 + end
// (assuming start, end in 0..99)
fn make_iv(start: Int, end: Int) -> Int { start * 100 + end }
fn iv_start(iv: Int) -> Int { iv / 100 }
fn iv_end(iv: Int) -> Int { iv % 100 }

// Check if two intervals overlap
fn overlaps(a: Int, b: Int) -> Int {
    let as1 = iv_start(a);
    let ae = iv_end(a);
    let bs = iv_start(b);
    let be = iv_end(b);
    if as1 < be {
        if bs < ae { 1 } else { 0 }
    } else { 0 }
}

// Merge two overlapping intervals
fn merge_iv(a: Int, b: Int) -> Int {
    make_iv(min_val(iv_start(a), iv_start(b)), max_val(iv_end(a), iv_end(b)))
}

// Check if point is in interval
fn contains_pt(iv: Int, pt: Int) -> Int {
    if pt >= iv_start(iv) {
        if pt < iv_end(iv) { 1 } else { 0 }
    } else { 0 }
}

// Interval length
fn iv_length(iv: Int) -> Int { iv_end(iv) - iv_start(iv) }

// Sort intervals by start time (insertion sort)
fn sort_intervals(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 1;
    while i < n {
        let key = get8(a, i);
        let mut j = i - 1;
        while j >= 0 {
            if iv_start(get8(a, j)) > iv_start(key) {
                a = set8(a, j + 1, get8(a, j));
                j = j - 1;
            } else {
                j = j - 100; // break trick
            }
        }
        if j < 0 - 1 { j = j + 100; }
        a = set8(a, j + 1, key);
        i = i + 1;
    }
    a
}

// Merge overlapping intervals, return count of merged intervals
fn merge_all_count(sorted: Arr8, n: Int) -> Int {
    if n == 0 { return 0; }
    let mut count = 1;
    let mut cur = get8(sorted, 0);
    let mut i = 1;
    while i < n {
        let next = get8(sorted, i);
        if overlaps(cur, next) == 1 {
            cur = merge_iv(cur, next);
        } else {
            count = count + 1;
            cur = next;
        }
        i = i + 1;
    }
    count
}

// Merge overlapping intervals, return merged array
fn merge_all(sorted: Arr8, n: Int) -> Arr8 {
    if n == 0 { return zeros(); }
    let mut result = zeros();
    let mut count = 0;
    let mut cur = get8(sorted, 0);
    let mut i = 1;
    while i < n {
        let next = get8(sorted, i);
        if overlaps(cur, next) == 1 {
            cur = merge_iv(cur, next);
        } else {
            result = set8(result, count, cur);
            count = count + 1;
            cur = next;
        }
        i = i + 1;
    }
    result = set8(result, count, cur);
    result
}

// Activity selection: max non-overlapping intervals (greedy by end time)
// Sort by end time first
fn sort_by_end(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 1;
    while i < n {
        let key = get8(a, i);
        let mut j = i - 1;
        while j >= 0 {
            if iv_end(get8(a, j)) > iv_end(key) {
                a = set8(a, j + 1, get8(a, j));
                j = j - 1;
            } else {
                j = j - 100; // break trick
            }
        }
        if j < 0 - 1 { j = j + 100; }
        a = set8(a, j + 1, key);
        i = i + 1;
    }
    a
}

fn activity_selection(arr: Arr8, n: Int) -> Int {
    let sorted = sort_by_end(arr, n);
    let mut count = 1;
    let mut last_end = iv_end(get8(sorted, 0));
    let mut i = 1;
    while i < n {
        let s = iv_start(get8(sorted, i));
        if s >= last_end {
            count = count + 1;
            last_end = iv_end(get8(sorted, i));
        }
        i = i + 1;
    }
    count
}

fn test_overlap() -> Int {
    let a = make_iv(1, 5);
    let b = make_iv(3, 8);
    let c = make_iv(6, 10);
    assert_eq(overlaps(a, b), 1); // [1,5) and [3,8) overlap
    assert_eq(overlaps(a, c), 0); // [1,5) and [6,10) don't
    assert_eq(overlaps(b, c), 1); // [3,8) and [6,10) overlap
    // Same interval
    assert_eq(overlaps(a, a), 1);
    // Adjacent (non-overlapping with half-open)
    let d = make_iv(5, 10);
    assert_eq(overlaps(a, d), 0); // [1,5) and [5,10) — 5 not in [1,5)
    1
}

fn test_merge() -> Int {
    let a = make_iv(1, 5);
    let b = make_iv(3, 8);
    let m = merge_iv(a, b);
    assert_eq(iv_start(m), 1);
    assert_eq(iv_end(m), 8);
    1
}

fn test_contains() -> Int {
    let iv = make_iv(3, 7);
    assert_eq(contains_pt(iv, 3), 1);
    assert_eq(contains_pt(iv, 5), 1);
    assert_eq(contains_pt(iv, 6), 1);
    assert_eq(contains_pt(iv, 7), 0); // half-open
    assert_eq(contains_pt(iv, 2), 0);
    assert_eq(iv_length(iv), 4);
    1
}

fn test_merge_all() -> Int {
    // Intervals: [1,3), [2,6), [8,10), [15,18)
    let mut ivs = zeros();
    ivs = set8(ivs, 0, make_iv(1, 3));
    ivs = set8(ivs, 1, make_iv(2, 6));
    ivs = set8(ivs, 2, make_iv(8, 10));
    ivs = set8(ivs, 3, make_iv(15, 18));
    let sorted = sort_intervals(ivs, 4);
    assert_eq(merge_all_count(sorted, 4), 3); // [1,6), [8,10), [15,18)

    let merged = merge_all(sorted, 4);
    assert_eq(iv_start(get8(merged, 0)), 1);
    assert_eq(iv_end(get8(merged, 0)), 6);
    assert_eq(iv_start(get8(merged, 1)), 8);
    assert_eq(iv_end(get8(merged, 1)), 10);
    1
}

fn test_activity_selection() -> Int {
    // Activities: [1,4), [3,5), [0,6), [5,7), [3,8), [5,9), [6,10), [8,11)
    let mut acts = zeros();
    acts = set8(acts, 0, make_iv(1, 4));
    acts = set8(acts, 1, make_iv(3, 5));
    acts = set8(acts, 2, make_iv(0, 6));
    acts = set8(acts, 3, make_iv(5, 7));
    acts = set8(acts, 4, make_iv(3, 8));
    acts = set8(acts, 5, make_iv(5, 9));
    acts = set8(acts, 6, make_iv(6, 10));
    acts = set8(acts, 7, make_iv(8, 11));
    // Greedy by end: [1,4), [5,7), [8,11) = 3 non-overlapping
    assert_eq(activity_selection(acts, 8), 3);
    1
}

fn main() -> Int {
    test_overlap();
    test_merge();
    test_contains();
    test_merge_all();
    test_activity_selection();
    print("[OK] 581_interval_tree_aot");
    0
}
