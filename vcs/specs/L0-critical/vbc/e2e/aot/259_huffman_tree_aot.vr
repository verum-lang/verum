// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, huffman, tree, encoding
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for simplified Huffman-like encoding (frequency-based bit assignment)

// Symbol with frequency
type SymFreq is { symbol: Int, freq: Int };

// Arr8 of SymFreq
type FreqTable is {
    s0: SymFreq, s1: SymFreq, s2: SymFreq, s3: SymFreq,
    s4: SymFreq, s5: SymFreq, s6: SymFreq, s7: SymFreq,
    len: Int
};

fn ft_get(t: FreqTable, i: Int) -> SymFreq {
    if i == 0 { t.s0 } else if i == 1 { t.s1 }
    else if i == 2 { t.s2 } else if i == 3 { t.s3 }
    else if i == 4 { t.s4 } else if i == 5 { t.s5 }
    else if i == 6 { t.s6 } else { t.s7 }
}

fn ft_set(t: FreqTable, i: Int, v: SymFreq) -> FreqTable {
    FreqTable {
        s0: if i == 0 { v } else { t.s0 }, s1: if i == 1 { v } else { t.s1 },
        s2: if i == 2 { v } else { t.s2 }, s3: if i == 3 { v } else { t.s3 },
        s4: if i == 4 { v } else { t.s4 }, s5: if i == 5 { v } else { t.s5 },
        s6: if i == 6 { v } else { t.s6 }, s7: if i == 7 { v } else { t.s7 },
        len: t.len
    }
}

// Sort by frequency (bubble sort)
fn sort_by_freq(t: FreqTable) -> FreqTable {
    let mut arr = t;
    let mut i = 0;
    while i < arr.len - 1 {
        let mut j = 0;
        while j < arr.len - 1 - i {
            let a = ft_get(arr, j);
            let b = ft_get(arr, j + 1);
            if a.freq > b.freq {
                arr = ft_set(arr, j, b);
                arr = ft_set(arr, j + 1, a);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

// Compute total frequency
fn total_freq(t: FreqTable) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < t.len {
        sum = sum + ft_get(t, i).freq;
        i = i + 1;
    }
    sum
}

// Assign bit lengths based on sorted frequency
// Simple scheme: most frequent gets shortest code
// Code lengths: [n-1, n-1, n-2, n-3, ...] (simplified)
// For n symbols, just assign increasing lengths to less frequent symbols
fn compute_weighted_bits(t: FreqTable) -> Int {
    let sorted = sort_by_freq(t);
    // Most frequent = least bits. Simple model:
    // assign bit_length = index + 1 for sorted (ascending freq) order
    let mut total_bits = 0;
    let mut i = 0;
    while i < sorted.len {
        let sf = ft_get(sorted, i);
        let bit_len = sorted.len - i;  // higher freq = fewer bits
        total_bits = total_bits + sf.freq * bit_len;
        i = i + 1;
    }
    total_bits
}

// Shannon entropy approximation: sum(freq * ceil(log2(total/freq)))
// We approximate log2 with integer log2
fn int_log2(n: Int) -> Int {
    let mut x = n;
    let mut bits = 0;
    while x > 1 {
        bits = bits + 1;
        x = x / 2;
    }
    bits
}

fn test_sort_by_freq() {
    let empty = SymFreq { symbol: 0, freq: 0 };
    let mut t = FreqTable {
        s0: SymFreq { symbol: 65, freq: 10 },
        s1: SymFreq { symbol: 66, freq: 5 },
        s2: SymFreq { symbol: 67, freq: 15 },
        s3: SymFreq { symbol: 68, freq: 3 },
        s4: empty, s5: empty, s6: empty, s7: empty,
        len: 4
    };
    let sorted = sort_by_freq(t);
    // Should be: D(3), B(5), A(10), C(15)
    assert_eq(ft_get(sorted, 0).freq, 3);
    assert_eq(ft_get(sorted, 1).freq, 5);
    assert_eq(ft_get(sorted, 2).freq, 10);
    assert_eq(ft_get(sorted, 3).freq, 15);
}

fn test_total_freq() {
    let empty = SymFreq { symbol: 0, freq: 0 };
    let t = FreqTable {
        s0: SymFreq { symbol: 65, freq: 10 },
        s1: SymFreq { symbol: 66, freq: 5 },
        s2: SymFreq { symbol: 67, freq: 15 },
        s3: empty, s4: empty, s5: empty, s6: empty, s7: empty,
        len: 3
    };
    assert_eq(total_freq(t), 30);
}

fn test_weighted_bits() {
    let empty = SymFreq { symbol: 0, freq: 0 };
    // 2 symbols: A(freq=10), B(freq=5)
    // Sorted ascending: B(5), A(10)
    // B gets len 2, A gets len 1
    // Total bits: 5*2 + 10*1 = 20
    let t = FreqTable {
        s0: SymFreq { symbol: 65, freq: 10 },
        s1: SymFreq { symbol: 66, freq: 5 },
        s2: empty, s3: empty, s4: empty, s5: empty, s6: empty, s7: empty,
        len: 2
    };
    assert_eq(compute_weighted_bits(t), 20);
}

fn test_uniform_freq() {
    // All equal frequencies
    let empty = SymFreq { symbol: 0, freq: 0 };
    let t = FreqTable {
        s0: SymFreq { symbol: 0, freq: 10 },
        s1: SymFreq { symbol: 1, freq: 10 },
        s2: SymFreq { symbol: 2, freq: 10 },
        s3: SymFreq { symbol: 3, freq: 10 },
        s4: empty, s5: empty, s6: empty, s7: empty,
        len: 4
    };
    // Sorted: all same. Assigned: 4,3,2,1 bits
    // Total: 10*4 + 10*3 + 10*2 + 10*1 = 100
    assert_eq(compute_weighted_bits(t), 100);
}

fn test_log2() {
    assert_eq(int_log2(1), 0);
    assert_eq(int_log2(2), 1);
    assert_eq(int_log2(4), 2);
    assert_eq(int_log2(8), 3);
    assert_eq(int_log2(16), 4);
    assert_eq(int_log2(1024), 10);
    assert_eq(int_log2(7), 2);  // floor(log2(7))
}

fn main() -> Int {
    test_sort_by_freq();
    test_total_freq();
    test_weighted_bits();
    test_uniform_freq();
    test_log2();
    print("[OK] 259_huffman_tree_aot");
    0
}
