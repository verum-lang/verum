// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, catalan, dp, combinatorics
// @timeout: 30000
// @expected-exit: 0
//
// AOT test for Catalan numbers via dynamic programming.
// Covers: DP recurrence, ballot problem, full binary trees count,
// valid parenthesizations, and triangulation of polygons.

type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int, a12: Int, a13: Int, a14: Int, a15: Int
};

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 } else if i == 2 { a.a2 }
    else if i == 3 { a.a3 } else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 } else if i == 8 { a.a8 }
    else if i == 9 { a.a9 } else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 } else if i == 14 { a.a14 }
    else { a.a15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 }, a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 }, a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 }, a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 }, a15: if i == 15 { v } else { a.a15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
            a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0 }
}

// ========== Catalan Numbers via DP ==========
// C(0) = 1, C(n) = sum(C(i) * C(n-1-i)) for i in 0..n
// First 11: 1, 1, 2, 5, 14, 42, 132, 429, 1430, 4862, 16796

fn catalan_dp() -> Arr16 {
    let mut c = a16_zero();
    c = a16_set(c, 0, 1);
    let mut n = 1;
    while n <= 10 {
        let mut val = 0;
        let mut i = 0;
        while i < n {
            val = val + a16_get(c, i) * a16_get(c, n - 1 - i);
            i = i + 1;
        }
        c = a16_set(c, n, val);
        n = n + 1;
    }
    c
}

fn test_catalan_values() -> Int {
    let c = catalan_dp();
    assert_eq(a16_get(c, 0), 1);
    assert_eq(a16_get(c, 1), 1);
    assert_eq(a16_get(c, 2), 2);
    assert_eq(a16_get(c, 3), 5);
    assert_eq(a16_get(c, 4), 14);
    assert_eq(a16_get(c, 5), 42);
    0
}

fn test_catalan_larger() -> Int {
    let c = catalan_dp();
    assert_eq(a16_get(c, 6), 132);
    assert_eq(a16_get(c, 7), 429);
    assert_eq(a16_get(c, 8), 1430);
    assert_eq(a16_get(c, 9), 4862);
    assert_eq(a16_get(c, 10), 16796);
    0
}

// ========== Ballot Problem ==========
// ballot(a, b) = (a - b) / (a + b) * C(a+b, a) when a > b

fn binomial(n: Int, k: Int) -> Int {
    if k > n { return 0; }
    if k == 0 { return 1; }
    let kk = if k > n - k { n - k } else { k };
    let mut r = 1;
    let mut i = 0;
    while i < kk {
        r = r * (n - i);
        r = r / (i + 1);
        i = i + 1;
    }
    r
}

fn ballot_count(a: Int, bv: Int) -> Int {
    (a - bv) * binomial(a + bv, a) / (a + bv)
}

fn test_ballot_problem() -> Int {
    assert_eq(ballot_count(3, 1), 2);
    assert_eq(ballot_count(4, 2), 5);
    assert_eq(ballot_count(5, 1), 4);
    assert_eq(ballot_count(2, 0), 1);
    0
}

// ========== Full Binary Trees ==========
// Number of full binary trees with n internal nodes = C(n)

fn test_full_binary_trees() -> Int {
    let c = catalan_dp();
    assert_eq(a16_get(c, 0), 1);
    assert_eq(a16_get(c, 1), 1);
    assert_eq(a16_get(c, 2), 2);
    assert_eq(a16_get(c, 3), 5);
    assert_eq(a16_get(c, 4), 14);
    0
}

// ========== Valid Parenthesizations ==========
// Count via DP: dp[open_used][close_used]
// Flatten 2D index into Arr16 (max n=3 => 4x4=16)

fn count_parenthesizations(n: Int) -> Int {
    let cols = n + 1;
    let mut dp = a16_zero();
    dp = a16_set(dp, 0, 1);  // dp[0][0] = 1
    let total_steps = 2 * n;
    let mut step = 0;
    while step < total_steps {
        let mut new_dp = a16_zero();
        let mut oi = 0;
        while oi <= n {
            let mut ci = 0;
            while ci <= oi {
                let ways = a16_get(dp, oi * cols + ci);
                if ways > 0 {
                    if oi < n {
                        let idx = (oi + 1) * cols + ci;
                        let cur = a16_get(new_dp, idx);
                        new_dp = a16_set(new_dp, idx, cur + ways);
                    }
                    if ci < oi {
                        let idx = oi * cols + ci + 1;
                        let cur = a16_get(new_dp, idx);
                        new_dp = a16_set(new_dp, idx, cur + ways);
                    }
                }
                ci = ci + 1;
            }
            oi = oi + 1;
        }
        dp = new_dp;
        step = step + 1;
    }
    a16_get(dp, n * cols + n)
}

fn test_parenthesizations() -> Int {
    assert_eq(count_parenthesizations(0), 1);
    assert_eq(count_parenthesizations(1), 1);
    assert_eq(count_parenthesizations(2), 2);
    assert_eq(count_parenthesizations(3), 5);
    0
}

// ========== Triangulation of Convex Polygon ==========
// triangulate(s sides) = C(s-2)

fn test_triangulation() -> Int {
    let c = catalan_dp();
    assert_eq(a16_get(c, 1), 1);   // triangle: 3 sides, C(1)=1
    assert_eq(a16_get(c, 2), 2);   // square: 4 sides, C(2)=2
    assert_eq(a16_get(c, 3), 5);   // pentagon: C(3)=5
    assert_eq(a16_get(c, 4), 14);  // hexagon: C(4)=14
    assert_eq(a16_get(c, 5), 42);  // heptagon: C(5)=42
    0
}

// ========== Catalan Recurrence Verification ==========
// C(n+1) = 2*(2n+1)/(n+2) * C(n)

fn test_catalan_recurrence() -> Int {
    let c = catalan_dp();
    assert_eq(a16_get(c, 1), 2 * 1 * a16_get(c, 0) / 2);
    assert_eq(a16_get(c, 2), 2 * 3 * a16_get(c, 1) / 3);
    assert_eq(a16_get(c, 3), 2 * 5 * a16_get(c, 2) / 4);
    assert_eq(a16_get(c, 4), 2 * 7 * a16_get(c, 3) / 5);
    0
}

fn main() -> Int {
    test_catalan_values();
    test_catalan_larger();
    test_ballot_problem();
    test_full_binary_trees();
    test_parenthesizations();
    test_triangulation();
    test_catalan_recurrence();
    print("All Catalan number tests passed!");
    0
}
