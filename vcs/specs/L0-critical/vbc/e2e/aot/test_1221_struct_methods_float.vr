// @test: run
// @level: L0
// @tier: 0
// @tags: struct, implement, float, method-call, e2e
// @description: Test struct methods with float fields, including self-referential operations

type Vec2 is { x: Float, y: Float };

implement Vec2 {
    fn new(x: Float, y: Float) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn add(&self, other: Vec2) -> Vec2 {
        Vec2.new(self.x + other.x, self.y + other.y)
    }

    fn scale(&self, factor: Float) -> Vec2 {
        Vec2.new(self.x * factor, self.y * factor)
    }

    fn dot(&self, other: Vec2) -> Float {
        self.x * other.x + self.y * other.y
    }

    fn length_sq(&self) -> Float {
        self.x * self.x + self.y * self.y
    }

    fn negate(&self) -> Vec2 {
        Vec2.new(0.0 - self.x, 0.0 - self.y)
    }
}

fn approx_eq(a: Float, b: Float) -> Bool {
    let diff = a - b;
    let abs_diff = if diff < 0.0 { 0.0 - diff } else { diff };
    abs_diff < 0.01
}

fn main() -> Int {
    let mut f = 0;
    let a = Vec2.new(3.0, 4.0);
    let b = Vec2.new(1.0, 2.0);

    // Test 1: add
    let c = a.add(b);
    if !approx_eq(c.x, 4.0) || !approx_eq(c.y, 6.0) {
        print(f"FAIL 1: add = ({c.x}, {c.y})");
        f = f + 1;
    }

    // Test 2: scale
    let d = a.scale(2.5);
    if !approx_eq(d.x, 7.5) || !approx_eq(d.y, 10.0) {
        print(f"FAIL 2: scale = ({d.x}, {d.y})");
        f = f + 1;
    }

    // Test 3: dot product 3*1 + 4*2 = 11
    if !approx_eq(a.dot(b), 11.0) {
        print(f"FAIL 3: dot = {a.dot(b)}");
        f = f + 1;
    }

    // Test 4: length squared 3^2 + 4^2 = 25
    if !approx_eq(a.length_sq(), 25.0) {
        print(f"FAIL 4: length_sq = {a.length_sq()}");
        f = f + 1;
    }

    // Test 5: negate
    let neg = a.negate();
    if !approx_eq(neg.x, -3.0) || !approx_eq(neg.y, -4.0) {
        print(f"FAIL 5: negate = ({neg.x}, {neg.y})");
        f = f + 1;
    }

    // Test 6: chained operations: (a + b).scale(0.5)
    let mid = a.add(b).scale(0.5);
    if !approx_eq(mid.x, 2.0) || !approx_eq(mid.y, 3.0) {
        print(f"FAIL 6: midpoint = ({mid.x}, {mid.y})");
        f = f + 1;
    }

    if f == 0 {
        print("All Vec2 method tests passed");
    }
    f
}
