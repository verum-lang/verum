// @test: run
// @level: L0
// @tags: aot, e2e, priority-queue, heap, data-structure
// @timeout: 30000

// Min-heap priority queue using Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Heap operations (0-indexed, children of i are 2i+1 and 2i+2)
fn parent(i: Int) -> Int { (i - 1) / 2 }
fn left_child(i: Int) -> Int { 2 * i + 1 }
fn right_child(i: Int) -> Int { 2 * i + 2 }

// Swap elements at indices i and j
fn swap8(a: Arr8, i: Int, j: Int) -> Arr8 {
    let vi = get8(a, i);
    let vj = get8(a, j);
    let tmp = set8(a, i, vj);
    set8(tmp, j, vi)
}

// Sift up (for insert)
fn sift_up(heap: Arr8, idx: Int) -> Arr8 {
    let mut h = heap;
    let mut i = idx;
    while i > 0 {
        let p = parent(i);
        if get8(h, i) < get8(h, p) {
            h = swap8(h, i, p);
            i = p;
        } else {
            i = 0; // break
        }
    }
    h
}

// Sift down (for extract-min)
fn sift_down(heap: Arr8, size: Int) -> Arr8 {
    let mut h = heap;
    let mut i = 0;
    let mut done = 0;
    while done == 0 {
        let l = left_child(i);
        let r = right_child(i);
        let mut smallest = i;
        if l < size {
            if get8(h, l) < get8(h, smallest) { smallest = l; }
        }
        if r < size {
            if get8(h, r) < get8(h, smallest) { smallest = r; }
        }
        if smallest != i {
            h = swap8(h, i, smallest);
            i = smallest;
        } else {
            done = 1;
        }
    }
    h
}

// Insert into heap, returns new heap (size is managed externally)
fn heap_insert(heap: Arr8, size: Int, val: Int) -> Arr8 {
    let h = set8(heap, size, val);
    sift_up(h, size)
}

// Extract min: moves last element to root, sifts down
// Returns min value
fn heap_min(heap: Arr8) -> Int { get8(heap, 0) }

// Extract min: returns new heap with min removed
fn heap_extract(heap: Arr8, size: Int) -> Arr8 {
    let h = set8(heap, 0, get8(heap, size - 1));
    sift_down(h, size - 1)
}

// Check heap property
fn is_min_heap(heap: Arr8, size: Int) -> Int {
    let mut ok = 1;
    let mut i = 0;
    while i < size {
        let l = left_child(i);
        let r = right_child(i);
        if l < size {
            if get8(heap, l) < get8(heap, i) { ok = 0; }
        }
        if r < size {
            if get8(heap, r) < get8(heap, i) { ok = 0; }
        }
        i = i + 1;
    }
    ok
}

fn test_insert_extract() -> Int {
    let mut h = zeros();
    let mut size = 0;
    // Insert: 5, 3, 7, 1
    h = heap_insert(h, size, 5); size = size + 1;
    assert_eq(is_min_heap(h, size), 1);
    h = heap_insert(h, size, 3); size = size + 1;
    assert_eq(is_min_heap(h, size), 1);
    h = heap_insert(h, size, 7); size = size + 1;
    assert_eq(is_min_heap(h, size), 1);
    h = heap_insert(h, size, 1); size = size + 1;
    assert_eq(is_min_heap(h, size), 1);
    // Min should be 1
    assert_eq(heap_min(h), 1);
    // Extract min
    h = heap_extract(h, size); size = size - 1;
    assert_eq(is_min_heap(h, size), 1);
    assert_eq(heap_min(h), 3);
    // Extract min again
    h = heap_extract(h, size); size = size - 1;
    assert_eq(heap_min(h), 5);
    1
}

fn test_sorted_extraction() -> Int {
    let mut h = zeros();
    let mut size = 0;
    // Insert values in random order
    h = heap_insert(h, size, 4); size = size + 1;
    h = heap_insert(h, size, 2); size = size + 1;
    h = heap_insert(h, size, 6); size = size + 1;
    h = heap_insert(h, size, 1); size = size + 1;
    h = heap_insert(h, size, 3); size = size + 1;
    h = heap_insert(h, size, 5); size = size + 1;
    // Extract all: should come out sorted
    let mut prev = 0;
    let mut sorted_ok = 1;
    while size > 0 {
        let val = heap_min(h);
        if val < prev { sorted_ok = 0; }
        prev = val;
        h = heap_extract(h, size);
        size = size - 1;
    }
    assert_eq(sorted_ok, 1);
    1
}

fn test_duplicates() -> Int {
    let mut h = zeros();
    let mut size = 0;
    h = heap_insert(h, size, 3); size = size + 1;
    h = heap_insert(h, size, 3); size = size + 1;
    h = heap_insert(h, size, 1); size = size + 1;
    h = heap_insert(h, size, 1); size = size + 1;
    assert_eq(heap_min(h), 1);
    h = heap_extract(h, size); size = size - 1;
    assert_eq(heap_min(h), 1);
    h = heap_extract(h, size); size = size - 1;
    assert_eq(heap_min(h), 3);
    1
}

fn test_ascending_insert() -> Int {
    let mut h = zeros();
    let mut size = 0;
    h = heap_insert(h, size, 1); size = size + 1;
    h = heap_insert(h, size, 2); size = size + 1;
    h = heap_insert(h, size, 3); size = size + 1;
    h = heap_insert(h, size, 4); size = size + 1;
    assert_eq(is_min_heap(h, size), 1);
    assert_eq(heap_min(h), 1);
    1
}

fn test_descending_insert() -> Int {
    let mut h = zeros();
    let mut size = 0;
    h = heap_insert(h, size, 8); size = size + 1;
    h = heap_insert(h, size, 6); size = size + 1;
    h = heap_insert(h, size, 4); size = size + 1;
    h = heap_insert(h, size, 2); size = size + 1;
    assert_eq(is_min_heap(h, size), 1);
    assert_eq(heap_min(h), 2);
    1
}

fn main() -> Int {
    test_insert_extract();
    test_sorted_extraction();
    test_duplicates();
    test_ascending_insert();
    test_descending_insert();
    print("[OK] 656_priority_queue_aot");
    0
}
