// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, checksum, crc, hash
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for checksum and hash algorithms

fn bnot(x: Int) -> Int { !x }
fn abs_val(x: Int) -> Int { if x < 0 { -x } else { x } }

// Simple additive checksum
fn checksum_add(data: Int, len: Int) -> Int {
    // Treat data as packed bytes (4 bytes max)
    let mut sum = 0;
    let mut x = data;
    let mut i = 0;
    while i < len {
        sum = sum + (x & 255);
        x = x >> 8;
        i = i + 1;
    }
    sum & 255  // Return byte
}

// XOR checksum
fn checksum_xor(data: Int, len: Int) -> Int {
    let mut result = 0;
    let mut x = data;
    let mut i = 0;
    while i < len {
        result = result ^ (x & 255);
        x = x >> 8;
        i = i + 1;
    }
    result & 255
}

// Fletcher-16 like checksum
fn fletcher16(a: Int, b: Int, c: Int, d: Int) -> Int {
    let mut sum1 = 0;
    let mut sum2 = 0;

    sum1 = (sum1 + a) % 255;
    sum2 = (sum2 + sum1) % 255;

    sum1 = (sum1 + b) % 255;
    sum2 = (sum2 + sum1) % 255;

    sum1 = (sum1 + c) % 255;
    sum2 = (sum2 + sum1) % 255;

    sum1 = (sum1 + d) % 255;
    sum2 = (sum2 + sum1) % 255;

    sum2 * 256 + sum1
}

// Simple CRC-like (polynomial division simulation)
fn crc8(data: Int, len: Int) -> Int {
    let poly = 0x07;  // CRC-8 polynomial
    let mut crc = 0;
    let mut x = data;
    let mut byte_idx = 0;

    while byte_idx < len {
        let b = (x >> (byte_idx * 8)) & 255;
        crc = crc ^ b;
        let mut bit = 0;
        while bit < 8 {
            if (crc & 128) != 0 {
                crc = ((crc << 1) ^ poly) & 255;
            } else {
                crc = (crc << 1) & 255;
            }
            bit = bit + 1;
        }
        byte_idx = byte_idx + 1;
    }
    crc
}

// Adler-32 like checksum
fn adler_like(a: Int, b: Int, c: Int) -> Int {
    let mod_val = 65521;
    let mut s1 = 1;
    let mut s2 = 0;

    s1 = (s1 + a) % mod_val;
    s2 = (s2 + s1) % mod_val;

    s1 = (s1 + b) % mod_val;
    s2 = (s2 + s1) % mod_val;

    s1 = (s1 + c) % mod_val;
    s2 = (s2 + s1) % mod_val;

    s2 * 65536 + s1
}

fn test_additive() {
    // Data: [0x01, 0x02, 0x03, 0x04] packed
    let data = 0x04030201;
    assert_eq(checksum_add(data, 4), (1 + 2 + 3 + 4) & 255);
    assert_eq(checksum_add(data, 4), 10);

    // All zeros
    assert_eq(checksum_add(0, 4), 0);

    // All 0xFF
    let ff = 0xFFFFFFFF;
    assert_eq(checksum_add(ff, 4), (255 * 4) & 255);
}

fn test_xor_checksum() {
    let data = 0x04030201;
    // 1 ^ 2 ^ 3 ^ 4 = 4
    assert_eq(checksum_xor(data, 4), 4);

    // XOR of identical bytes = 0
    let same = 0x05050505;
    assert_eq(checksum_xor(same, 4), 0);
}

fn test_fletcher() {
    let f1 = fletcher16(1, 2, 3, 4);
    let f2 = fletcher16(1, 2, 3, 4);
    assert_eq(f1, f2);  // Deterministic

    // Order matters
    let f3 = fletcher16(4, 3, 2, 1);
    // f1 and f3 should differ (different order)
    // f1: s1=1,s2=1; s1=3,s2=4; s1=6,s2=10; s1=10,s2=20 -> 20*256+10 = 5130
    assert_eq(f1, 5130);
}

fn test_crc8() {
    // CRC of 0 = 0
    assert_eq(crc8(0, 1), 0);

    // CRC is deterministic
    let c1 = crc8(0x0102, 2);
    let c2 = crc8(0x0102, 2);
    assert_eq(c1, c2);

    // Different data, different CRC (usually)
    let c3 = crc8(0x0103, 2);
    // Just verify they compute something
    assert_eq(c1 >= 0, true);
    assert_eq(c1 <= 255, true);
}

fn test_adler() {
    let a1 = adler_like(1, 2, 3);
    let a2 = adler_like(1, 2, 3);
    assert_eq(a1, a2);

    // Known value:
    // s1: 1+1=2, s2: 0+2=2
    // s1: 2+2=4, s2: 2+4=6
    // s1: 4+3=7, s2: 6+7=13
    // Result: 13 * 65536 + 7 = 851975
    assert_eq(a1, 851975);
}

fn main() -> Int {
    test_additive();
    test_xor_checksum();
    test_fletcher();
    test_crc8();
    test_adler();
    print("[OK] 236_checksum_aot");
    0
}
