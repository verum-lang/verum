// @test: run
// @level: L0
// @tags: aot, e2e, election, voting, algorithm
// @timeout: 30000

// Voting algorithms: plurality, majority (Boyer-Moore), Borda count

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Count occurrences of val in array
fn count_val(arr: Arr8, n: Int, val: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if get8(arr, i) == val { count = count + 1; }
        i = i + 1;
    }
    count
}

// Plurality winner: candidate with most votes
// Candidates are integers 0-7
fn plurality(votes: Arr8, n: Int, num_candidates: Int) -> Int {
    let mut best = 0;
    let mut best_count = 0;
    let mut c = 0;
    while c < num_candidates {
        let cnt = count_val(votes, n, c);
        if cnt > best_count {
            best = c;
            best_count = cnt;
        }
        c = c + 1;
    }
    best
}

// Boyer-Moore majority vote algorithm
// Returns candidate that appears > n/2 times, or -1 if none
fn majority_vote(votes: Arr8, n: Int) -> Int {
    // Phase 1: Find candidate
    let mut candidate = get8(votes, 0);
    let mut count = 1;
    let mut i = 1;
    while i < n {
        if count == 0 {
            candidate = get8(votes, i);
            count = 1;
        } else if get8(votes, i) == candidate {
            count = count + 1;
        } else {
            count = count - 1;
        }
        i = i + 1;
    }
    // Phase 2: Verify
    let actual_count = count_val(votes, n, candidate);
    if actual_count * 2 > n { candidate } else { 0 - 1 }
}

// Borda count: with num_candidates, rank 0 gets num_candidates-1 points, etc.
// votes[i] = winner of voter i's first choice (simplified: only first choice)
fn borda_simple(votes: Arr8, n: Int, num_candidates: Int) -> Int {
    // In simplified version, first choice gets num_candidates-1 points
    // This reduces to plurality with weighted votes
    // Actually let's just do plurality since we only have first-choice data
    plurality(votes, n, num_candidates)
}

// Condorcet winner: candidate that beats all others in pairwise comparison
// Returns winner or -1 if no Condorcet winner
// votes is pairwise preference matrix: votes[i*num+j] = number who prefer i over j
// Simplified: we compare counts directly
fn condorcet_check(votes: Arr8, n: Int, candidate: Int, num_candidates: Int) -> Int {
    // Check if candidate beats all others
    let mut beats_all = 1;
    let mut c = 0;
    while c < num_candidates {
        if c != candidate {
            let pref_candidate = count_val(votes, n, candidate);
            let pref_other = count_val(votes, n, c);
            if pref_candidate <= pref_other { beats_all = 0; }
        }
        c = c + 1;
    }
    beats_all
}

// Runoff: top two go to second round
fn runoff_top_two(votes: Arr8, n: Int, num_candidates: Int) -> Int {
    // Find top 2
    let mut first = 0;
    let mut first_count = 0;
    let mut second = 0;
    let mut second_count = 0;
    let mut c = 0;
    while c < num_candidates {
        let cnt = count_val(votes, n, c);
        if cnt > first_count {
            second = first;
            second_count = first_count;
            first = c;
            first_count = cnt;
        } else if cnt > second_count {
            second = c;
            second_count = cnt;
        }
        c = c + 1;
    }
    // In runoff, all non-top-2 votes go to their preferred of top 2
    // Simplified: just return plurality winner (first round decisive with our data)
    first
}

fn test_plurality() -> Int {
    // 3 candidates, 7 voters: 0,0,0,1,1,2,2 -> candidate 0 wins with 3
    let votes = Arr8 { v0: 0, v1: 0, v2: 0, v3: 1, v4: 1, v5: 2, v6: 2, v7: 0 };
    assert_eq(plurality(votes, 7, 3), 0);
    // Unanimous
    let votes2 = Arr8 { v0: 1, v1: 1, v2: 1, v3: 1, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(plurality(votes2, 5, 3), 1);
    1
}

fn test_majority() -> Int {
    // 0,0,0,0,1,1,2 -> 0 has majority (4/7 > 3.5)
    let votes = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 1, v5: 1, v6: 2, v7: 0 };
    assert_eq(majority_vote(votes, 7), 0);
    // No majority: 0,0,1,1,2,2,3 -> no one > 3.5
    let votes2 = Arr8 { v0: 0, v1: 0, v2: 1, v3: 1, v4: 2, v5: 2, v6: 3, v7: 0 };
    assert_eq(majority_vote(votes2, 7), 0 - 1);
    // All same: 5,5,5,5,5 -> 5 is majority
    let votes3 = Arr8 { v0: 5, v1: 5, v2: 5, v3: 5, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(majority_vote(votes3, 5), 5);
    1
}

fn test_count() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 1, v3: 3, v4: 1, v5: 2, v6: 3, v7: 1 };
    assert_eq(count_val(arr, 8, 1), 4);
    assert_eq(count_val(arr, 8, 2), 2);
    assert_eq(count_val(arr, 8, 3), 2);
    assert_eq(count_val(arr, 8, 4), 0);
    1
}

fn test_tie() -> Int {
    // Tie: 0,0,1,1 -> plurality returns first found (0)
    let votes = Arr8 { v0: 0, v1: 0, v2: 1, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let winner = plurality(votes, 4, 2);
    // Both have count 2, first found wins
    assert_eq(winner, 0);
    1
}

fn test_single_voter() -> Int {
    let votes = Arr8 { v0: 3, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(plurality(votes, 1, 5), 3);
    assert_eq(majority_vote(votes, 1), 3);
    1
}

fn test_runoff() -> Int {
    // 5 candidates, 8 voters
    let votes = Arr8 { v0: 0, v1: 0, v2: 0, v3: 1, v4: 1, v5: 2, v6: 3, v7: 4 };
    // Candidate 0: 3, candidate 1: 2, others: 1 each
    assert_eq(runoff_top_two(votes, 8, 5), 0);
    1
}

fn main() -> Int {
    test_plurality();
    test_majority();
    test_count();
    test_tie();
    test_single_voter();
    test_runoff();
    print("[OK] 638_election_aot");
    0
}
