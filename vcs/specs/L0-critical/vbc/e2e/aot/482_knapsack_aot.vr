// @test: run
// @level: L0
// @tags: aot, e2e, knapsack, dynamic-programming
// @timeout: 30000

// 0/1 Knapsack and variants using DP

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// 0/1 Knapsack: n items, capacity W (max 7)
// dp[w] = max value achievable with capacity w
// Process each item, update dp array right-to-left
fn knapsack01(weights: Arr8, values: Arr8, n: Int, capacity: Int) -> Int {
    let mut dp = zeros();
    let mut i = 0;
    while i < n {
        let wi = get8(weights, i);
        let vi = get8(values, i);
        // Process right-to-left to avoid using same item twice
        let mut w = capacity;
        while w >= wi {
            let new_val = get8(dp, w - wi) + vi;
            let old_val = get8(dp, w);
            if new_val > old_val {
                dp = set8(dp, w, new_val);
            }
            w = w - 1;
        }
        i = i + 1;
    }
    get8(dp, capacity)
}

// Unbounded knapsack: items can be used multiple times
fn knapsack_unbounded(weights: Arr8, values: Arr8, n: Int, capacity: Int) -> Int {
    let mut dp = zeros();
    let mut w = 1;
    while w <= capacity {
        let mut i = 0;
        while i < n {
            let wi = get8(weights, i);
            if wi <= w {
                let new_val = get8(dp, w - wi) + get8(values, i);
                let old_val = get8(dp, w);
                if new_val > old_val {
                    dp = set8(dp, w, new_val);
                }
            }
            i = i + 1;
        }
        w = w + 1;
    }
    get8(dp, capacity)
}

// Subset sum: can we make exactly target from items?
// Returns 1 if yes, 0 if no
fn subset_sum(weights: Arr8, n: Int, target: Int) -> Int {
    // dp[w] = 1 if sum w is achievable
    let mut dp = zeros();
    dp = set8(dp, 0, 1); // empty set sums to 0
    let mut i = 0;
    while i < n {
        let wi = get8(weights, i);
        let mut w = target;
        while w >= wi {
            if get8(dp, w - wi) == 1 {
                dp = set8(dp, w, 1);
            }
            w = w - 1;
        }
        i = i + 1;
    }
    get8(dp, target)
}

// Count number of ways to make target (order doesn't matter)
fn count_subsets(weights: Arr8, n: Int, target: Int) -> Int {
    let mut dp = zeros();
    dp = set8(dp, 0, 1);
    let mut i = 0;
    while i < n {
        let wi = get8(weights, i);
        let mut w = wi;
        while w <= target {
            dp = set8(dp, w, get8(dp, w) + get8(dp, w - wi));
            w = w + 1;
        }
        i = i + 1;
    }
    get8(dp, target)
}

fn test_knapsack_basic() -> Int {
    // Items: (weight, value) = (2,3), (3,4), (4,5), (5,6)
    // Capacity = 7
    let weights = Arr8 { v0: 2, v1: 3, v2: 4, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 };
    let values = Arr8 { v0: 3, v1: 4, v2: 5, v3: 6, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Best: items 0+1 (weight 5, value 7) or item 0+2 (weight 6, value 8)
    // Actually: w=2,v=3 + w=3,v=4 = w=5,v=7. w=2,v=3 + w=4,v=5 = w=6,v=8.
    // w=3,v=4 + w=4,v=5 = w=7,v=9. That's the best!
    assert_eq(knapsack01(weights, values, 4, 7), 9);
    1
}

fn test_knapsack_small() -> Int {
    // Single item fits
    let w = Arr8 { v0: 3, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let v = Arr8 { v0: 10, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(knapsack01(w, v, 1, 5), 10);
    assert_eq(knapsack01(w, v, 1, 2), 0); // doesn't fit
    1
}

fn test_unbounded() -> Int {
    // Items: (1,1), (2,5), (3,8)
    let w = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let v = Arr8 { v0: 1, v1: 5, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Capacity 6: best is 2x(3,8) = value 16
    assert_eq(knapsack_unbounded(w, v, 3, 6), 16);
    // Capacity 7: 1x(3,8) + 2x(2,5) = 18
    assert_eq(knapsack_unbounded(w, v, 3, 7), 18);
    1
}

fn test_subset_sum() -> Int {
    let w = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Can make 4 = 1+3? Yes
    assert_eq(subset_sum(w, 4, 4), 1);
    // Can make 6 = 1+5? Yes
    assert_eq(subset_sum(w, 4, 6), 1);
    // Can make 2? No (smallest items are 1 and 3)
    assert_eq(subset_sum(w, 4, 2), 0);
    // Can make 0? Yes (empty set)
    assert_eq(subset_sum(w, 4, 0), 1);
    1
}

fn test_count_subsets() -> Int {
    // How many ways to make 4 from {1, 2, 3}?
    // Using unbounded: 1+1+1+1, 1+1+2, 2+2, 1+3 = 4 ways
    let w = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_subsets(w, 3, 4), 4);

    // Ways to make 5: 1+1+1+1+1, 1+1+1+2, 1+2+2, 1+1+3, 2+3 = 5 ways
    assert_eq(count_subsets(w, 3, 5), 5);
    1
}

fn test_knapsack_all_fit() -> Int {
    // All items fit
    let w = Arr8 { v0: 1, v1: 1, v2: 1, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let v = Arr8 { v0: 10, v1: 20, v2: 30, v3: 40, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(knapsack01(w, v, 4, 7), 100);
    1
}

fn main() -> Int {
    test_knapsack_basic();
    test_knapsack_small();
    test_unbounded();
    test_subset_sum();
    test_count_subsets();
    test_knapsack_all_fit();
    print("[OK] 482_knapsack_aot");
    0
}
