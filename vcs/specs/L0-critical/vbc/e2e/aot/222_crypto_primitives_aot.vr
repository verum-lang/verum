// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, crypto, hash, cipher
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for basic cryptographic primitive simulations

fn bnot(x: Int) -> Int { !x }

// Simple hash function (DJB2-like, operating on small ints)
fn djb2_step(hash: Int, ch: Int) -> Int {
    // hash * 33 + ch, kept in manageable range
    ((hash << 5) + hash + ch) % 1000000007
}

fn hash_3(a: Int, b: Int, c: Int) -> Int {
    let mut h = 5381;
    h = djb2_step(h, a);
    h = djb2_step(h, b);
    h = djb2_step(h, c);
    h
}

// XOR cipher
fn xor_encrypt(data: Int, key: Int) -> Int {
    data ^ key
}

fn xor_decrypt(cipher: Int, key: Int) -> Int {
    cipher ^ key  // XOR is its own inverse
}

// Simple rotate left (32-bit simulation with mask)
fn rotate_left(x: Int, n: Int) -> Int {
    let mask = (1 << 16) - 1;  // 16-bit for safety
    let masked = x & mask;
    ((masked << n) | (masked >> (16 - n))) & mask
}

// Simple rotate right (16-bit)
fn rotate_right(x: Int, n: Int) -> Int {
    let mask = (1 << 16) - 1;
    let masked = x & mask;
    ((masked >> n) | (masked << (16 - n))) & mask
}

// Feistel round: split data into L/R, apply round function
fn feistel_round(left: Int, right: Int, key: Int) -> Int {
    // Returns new_left (new_right = old_left)
    left ^ ((right * key + 13) % 256)
}

fn test_xor_cipher() {
    let key = 42;
    let data = 100;
    let encrypted = xor_encrypt(data, key);
    let decrypted = xor_decrypt(encrypted, key);
    assert_eq(decrypted, data);

    // XOR properties
    assert_eq(xor_encrypt(0, key), key);
    assert_eq(xor_encrypt(key, key), 0);

    // Different keys give different ciphertexts
    let e1 = xor_encrypt(data, 10);
    let e2 = xor_encrypt(data, 20);
    // 100^10=110, 100^20=112 — verify they differ
    assert_eq(e1, 110);
    assert_eq(e2, 112);
}

fn test_hash() {
    // Same inputs give same hash
    let h1 = hash_3(1, 2, 3);
    let h2 = hash_3(1, 2, 3);
    assert_eq(h1, h2);

    // Different inputs give different hashes
    let h3 = hash_3(1, 2, 4);
    // Just verify they compute consistently (don't compare booleans)
    let h1_check = hash_3(1, 2, 3);
    assert_eq(h1, h1_check);  // Deterministic
    // h3 differs from h1 because input differs
    let h4 = hash_3(3, 2, 1);
}

fn test_rotate() {
    // Rotate left then right = identity
    let x = 0b1010110011001100;
    assert_eq(rotate_right(rotate_left(x, 3), 3), x & ((1 << 16) - 1));
    assert_eq(rotate_right(rotate_left(x, 7), 7), x & ((1 << 16) - 1));

    // Rotate by 0 = identity
    assert_eq(rotate_left(x, 0), x & ((1 << 16) - 1));

    // Full rotation = identity
    assert_eq(rotate_left(x, 16), x & ((1 << 16) - 1));
}

fn test_feistel() {
    // Standard Feistel round: L'=R, R'=L^f(R,K)
    // Our feistel_round computes: left ^ f(right, key)
    let l0 = 100;
    let r0 = 200;
    let key = 7;

    // One round: L1=R0, R1=L0^f(R0,key)
    let l1 = r0;
    let r1 = feistel_round(l0, r0, key);

    // Decrypt: L0=R1^f(L1,key), R0=L1
    let dec_r0 = l1;
    let dec_l0 = feistel_round(r1, l1, key);

    assert_eq(dec_l0, l0);
    assert_eq(dec_r0, r0);

    // Two rounds
    let l2 = r1;
    let r2 = feistel_round(l1, r1, 13);

    // Decrypt round 2 first: L1=R2^f(L2,k2), R1=L2
    let d_r1 = l2;
    let d_l1 = feistel_round(r2, l2, 13);
    assert_eq(d_l1, l1);
    assert_eq(d_r1, r1);
}

fn test_xor_stream() {
    // Simulate stream cipher: XOR sequence of data with key stream
    let mut data0 = 10;
    let mut data1 = 20;
    let mut data2 = 30;
    let key_base = 42;

    // Encrypt
    data0 = data0 ^ key_base;
    data1 = data1 ^ (key_base + 1);
    data2 = data2 ^ (key_base + 2);

    // Verify encrypted != plaintext: 10 ^ 42 = 32
    assert_eq(data0, 32);

    // Decrypt
    data0 = data0 ^ key_base;
    data1 = data1 ^ (key_base + 1);
    data2 = data2 ^ (key_base + 2);

    assert_eq(data0, 10);
    assert_eq(data1, 20);
    assert_eq(data2, 30);
}

fn main() -> Int {
    test_xor_cipher();
    test_hash();
    test_rotate();
    test_feistel();
    test_xor_stream();
    print("[OK] 222_crypto_primitives_aot");
    0
}
