// @test: run
// @level: L0
// @tags: aot, e2e, polynomial, evaluation, algebra
// @timeout: 30000

// Polynomial operations using coefficient arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Evaluate polynomial p(x) = p[0] + p[1]*x + p[2]*x^2 + ... using Horner's method
fn poly_eval(coeffs: Arr8, degree: Int, x: Int) -> Int {
    let mut result = get8(coeffs, degree);
    let mut i = degree - 1;
    while i >= 0 {
        result = result * x + get8(coeffs, i);
        i = i - 1;
    }
    result
}

// Add two polynomials
fn poly_add(a: Arr8, deg_a: Int, b: Arr8, deg_b: Int) -> Arr8 {
    let max_deg = if deg_a > deg_b { deg_a } else { deg_b };
    let mut result = zeros();
    let mut i = 0;
    while i <= max_deg {
        let va = if i <= deg_a { get8(a, i) } else { 0 };
        let vb = if i <= deg_b { get8(b, i) } else { 0 };
        result = set8(result, i, va + vb);
        i = i + 1;
    }
    result
}

// Multiply two polynomials (result degree = deg_a + deg_b, must fit in 8)
fn poly_mul(a: Arr8, deg_a: Int, b: Arr8, deg_b: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i <= deg_a {
        let mut j = 0;
        while j <= deg_b {
            if i + j < 8 {
                let cur = get8(result, i + j);
                result = set8(result, i + j, cur + get8(a, i) * get8(b, j));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

// Derivative: d/dx p(x) = p[1] + 2*p[2]*x + 3*p[3]*x^2 + ...
fn poly_deriv(coeffs: Arr8, degree: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 1;
    while i <= degree {
        result = set8(result, i - 1, i * get8(coeffs, i));
        i = i + 1;
    }
    result
}

// Degree of polynomial (highest non-zero coefficient)
fn poly_degree(coeffs: Arr8, max_deg: Int) -> Int {
    let mut deg = 0;
    let mut i = 0;
    while i <= max_deg {
        if get8(coeffs, i) != 0 { deg = i; }
        i = i + 1;
    }
    deg
}

// Scale polynomial by constant
fn poly_scale(coeffs: Arr8, degree: Int, c: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i <= degree {
        result = set8(result, i, get8(coeffs, i) * c);
        i = i + 1;
    }
    result
}

fn test_eval() -> Int {
    // p(x) = 3 + 2x + x^2 = (1, 2, 3 reversed -> coeffs[0]=3, coeffs[1]=2, coeffs[2]=1)
    let p = Arr8 { v0: 3, v1: 2, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_eval(p, 2, 0), 3);   // p(0) = 3
    assert_eq(poly_eval(p, 2, 1), 6);   // p(1) = 3+2+1 = 6
    assert_eq(poly_eval(p, 2, 2), 11);  // p(2) = 3+4+4 = 11
    assert_eq(poly_eval(p, 2, 3), 18);  // p(3) = 3+6+9 = 18
    // Constant polynomial
    let c = Arr8 { v0: 42, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_eval(c, 0, 100), 42);
    1
}

fn test_add() -> Int {
    // (1 + 2x) + (3 + x^2) = 4 + 2x + x^2
    let a = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 3, v1: 0, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let sum = poly_add(a, 1, b, 2);
    assert_eq(get8(sum, 0), 4);
    assert_eq(get8(sum, 1), 2);
    assert_eq(get8(sum, 2), 1);
    // Verify by evaluation: sum(2) = 4+4+4 = 12
    assert_eq(poly_eval(sum, 2, 2), 12);
    1
}

fn test_mul() -> Int {
    // (1 + x) * (1 + x) = 1 + 2x + x^2
    let a = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let prod = poly_mul(a, 1, a, 1);
    assert_eq(get8(prod, 0), 1);
    assert_eq(get8(prod, 1), 2);
    assert_eq(get8(prod, 2), 1);
    // (1 + x) * (1 - x) would need negative, test (2 + 3x) * (1 + x)
    let b = Arr8 { v0: 2, v1: 3, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let c = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let prod2 = poly_mul(b, 1, c, 1);
    // = 2 + 2x + 3x + 3x^2 = 2 + 5x + 3x^2
    assert_eq(get8(prod2, 0), 2);
    assert_eq(get8(prod2, 1), 5);
    assert_eq(get8(prod2, 2), 3);
    1
}

fn test_deriv() -> Int {
    // d/dx (3 + 2x + x^2) = 2 + 2x
    let p = Arr8 { v0: 3, v1: 2, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let dp = poly_deriv(p, 2);
    assert_eq(get8(dp, 0), 2);
    assert_eq(get8(dp, 1), 2);
    assert_eq(get8(dp, 2), 0);
    // d/dx (5x^3 + 2x) = 15x^2 + 2
    let q = Arr8 { v0: 0, v1: 2, v2: 0, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 };
    let dq = poly_deriv(q, 3);
    assert_eq(get8(dq, 0), 2);
    assert_eq(get8(dq, 1), 0);
    assert_eq(get8(dq, 2), 15);
    1
}

fn test_scale() -> Int {
    // 3 * (1 + 2x + x^2) = 3 + 6x + 3x^2
    let p = Arr8 { v0: 1, v1: 2, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let sp = poly_scale(p, 2, 3);
    assert_eq(get8(sp, 0), 3);
    assert_eq(get8(sp, 1), 6);
    assert_eq(get8(sp, 2), 3);
    1
}

fn test_eval_mul_property() -> Int {
    // p(x)*q(x) evaluated at a point = p(a)*q(a)
    let p = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let q = Arr8 { v0: 3, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let pq = poly_mul(p, 1, q, 1);
    let x = 4;
    assert_eq(poly_eval(pq, 2, x), poly_eval(p, 1, x) * poly_eval(q, 1, x));
    1
}

fn test_degree() -> Int {
    let p = Arr8 { v0: 1, v1: 0, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_degree(p, 7), 2);
    let c = Arr8 { v0: 5, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_degree(c, 7), 0);
    1
}

fn main() -> Int {
    test_eval();
    test_add();
    test_mul();
    test_deriv();
    test_scale();
    test_eval_mul_property();
    test_degree();
    print("[OK] 654_polynomial_aot");
    0
}
