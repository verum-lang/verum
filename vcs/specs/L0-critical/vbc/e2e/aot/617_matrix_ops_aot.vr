// @test: run
// @level: L0
// @tags: aot, e2e, matrix, linear-algebra, arithmetic
// @timeout: 30000

// 3x3 matrix operations using Arr8 (9 elements: indices 0-7 in main Arr8, index 8 in overflow)
// Layout: m[r][c] = element at index r*3+c
// Indices 0-7 in the Arr8, index 8 stored separately via a packed result pattern.
// To keep things simple, we use two Arr8s: first 8 elements + the 9th.

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// A 3x3 matrix is represented as (Arr8, Int) where:
//   Arr8 holds elements at indices 0..7
//   Int holds element at index 8 (i.e., m[2][2])
// Access: m[r][c] -> index = r*3 + c

fn mat_get(m: Arr8, m8: Int, idx: Int) -> Int {
    if idx < 8 { get8(m, idx) } else { m8 }
}

fn mat_cell(m: Arr8, m8: Int, r: Int, c: Int) -> Int {
    mat_get(m, m8, r * 3 + c)
}

// Matrix addition: C = A + B. Returns (Arr8, Int)
// We return the overflow (element 8) separately.
fn mat_add(a: Arr8, a8: Int, b: Arr8, b8: Int) -> Arr8 {
    let mut c = zeros();
    let mut i = 0;
    while i < 8 {
        c = set8(c, i, get8(a, i) + get8(b, i));
        i = i + 1;
    }
    c
}

fn mat_add8(a8: Int, b8: Int) -> Int { a8 + b8 }

// Matrix multiply element (r,c) of A*B
fn mat_mul_elem(a: Arr8, a8: Int, b: Arr8, b8: Int, r: Int, c: Int) -> Int {
    let mut sum = 0;
    let mut k = 0;
    while k < 3 {
        sum = sum + mat_cell(a, a8, r, k) * mat_cell(b, b8, k, c);
        k = k + 1;
    }
    sum
}

// Matrix multiply: returns Arr8 part (indices 0-7) of result
fn mat_mul(a: Arr8, a8: Int, b: Arr8, b8: Int) -> Arr8 {
    let mut c = zeros();
    let mut r = 0;
    while r < 3 {
        let mut col = 0;
        while col < 3 {
            let idx = r * 3 + col;
            if idx < 8 {
                c = set8(c, idx, mat_mul_elem(a, a8, b, b8, r, col));
            }
            col = col + 1;
        }
        r = r + 1;
    }
    c
}

// Element 8 of A*B (which is result[2][2])
fn mat_mul8(a: Arr8, a8: Int, b: Arr8, b8: Int) -> Int {
    mat_mul_elem(a, a8, b, b8, 2, 2)
}

// Determinant of 3x3 matrix
fn mat_det(m: Arr8, m8: Int) -> Int {
    let a = mat_cell(m, m8, 0, 0);
    let b = mat_cell(m, m8, 0, 1);
    let c = mat_cell(m, m8, 0, 2);
    let d = mat_cell(m, m8, 1, 0);
    let e = mat_cell(m, m8, 1, 1);
    let f = mat_cell(m, m8, 1, 2);
    let g = mat_cell(m, m8, 2, 0);
    let h = mat_cell(m, m8, 2, 1);
    let ii = mat_cell(m, m8, 2, 2);
    a * (e * ii - f * h) - b * (d * ii - f * g) + c * (d * h - e * g)
}

// Transpose: swap m[r][c] and m[c][r]
fn mat_transpose(m: Arr8, m8: Int) -> Arr8 {
    let mut t = zeros();
    let mut r = 0;
    while r < 3 {
        let mut c = 0;
        while c < 3 {
            let src = mat_cell(m, m8, r, c);
            let dst_idx = c * 3 + r;
            if dst_idx < 8 {
                t = set8(t, dst_idx, src);
            }
            c = c + 1;
        }
        r = r + 1;
    }
    t
}

fn mat_transpose8(m: Arr8, m8: Int) -> Int {
    // Element [2][2] of transpose = element [2][2] of original
    m8
}

// Trace: sum of diagonal elements
fn mat_trace(m: Arr8, m8: Int) -> Int {
    mat_cell(m, m8, 0, 0) + mat_cell(m, m8, 1, 1) + mat_cell(m, m8, 2, 2)
}

// Check if matrix is identity
fn mat_is_identity(m: Arr8, m8: Int) -> Int {
    let mut ok = 1;
    let mut r = 0;
    while r < 3 {
        let mut c = 0;
        while c < 3 {
            let expected = if r == c { 1 } else { 0 };
            if ok == 1 {
                if mat_cell(m, m8, r, c) != expected { ok = 0; }
            }
            c = c + 1;
        }
        r = r + 1;
    }
    ok
}

fn test_add() -> Int {
    // A = [[1,2,3],[4,5,6],[7,8,9]]
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let a8 = 9;
    // B = [[9,8,7],[6,5,4],[3,2,1]]
    let b = Arr8 { v0: 9, v1: 8, v2: 7, v3: 6, v4: 5, v5: 4, v6: 3, v7: 2 };
    let b8 = 1;
    // C = A + B = [[10,10,10],[10,10,10],[10,10,10]]
    let c = mat_add(a, a8, b, b8);
    let c8 = mat_add8(a8, b8);
    assert_eq(mat_cell(c, c8, 0, 0), 10);
    assert_eq(mat_cell(c, c8, 0, 1), 10);
    assert_eq(mat_cell(c, c8, 1, 1), 10);
    assert_eq(mat_cell(c, c8, 2, 2), 10);
    assert_eq(mat_cell(c, c8, 2, 0), 10);
    1
}

fn test_multiply_identity() -> Int {
    // A * I = A
    // A = [[1,2,3],[4,5,6],[7,8,9]]
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let a8 = 9;
    // I = [[1,0,0],[0,1,0],[0,0,1]]
    let id = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    let id8 = 1;
    let r = mat_mul(a, a8, id, id8);
    let r8 = mat_mul8(a, a8, id, id8);
    assert_eq(mat_cell(r, r8, 0, 0), 1);
    assert_eq(mat_cell(r, r8, 0, 1), 2);
    assert_eq(mat_cell(r, r8, 0, 2), 3);
    assert_eq(mat_cell(r, r8, 1, 0), 4);
    assert_eq(mat_cell(r, r8, 1, 1), 5);
    assert_eq(mat_cell(r, r8, 1, 2), 6);
    assert_eq(mat_cell(r, r8, 2, 0), 7);
    assert_eq(mat_cell(r, r8, 2, 1), 8);
    assert_eq(mat_cell(r, r8, 2, 2), 9);
    1
}

fn test_multiply() -> Int {
    // A = [[1,2,0],[0,1,2],[2,0,1]]
    let a = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 1, v5: 2, v6: 2, v7: 0 };
    let a8 = 1;
    // B = [[1,0,2],[0,1,0],[2,0,1]]
    let b = Arr8 { v0: 1, v1: 0, v2: 2, v3: 0, v4: 1, v5: 0, v6: 2, v7: 0 };
    let b8 = 1;
    // C = A*B:
    // C[0][0] = 1*1+2*0+0*2 = 1
    // C[0][1] = 1*0+2*1+0*0 = 2
    // C[0][2] = 1*2+2*0+0*1 = 2
    // C[1][0] = 0*1+1*0+2*2 = 4
    // C[1][1] = 0*0+1*1+2*0 = 1
    // C[1][2] = 0*2+1*0+2*1 = 2
    // C[2][0] = 2*1+0*0+1*2 = 4
    // C[2][1] = 2*0+0*1+1*0 = 0
    // C[2][2] = 2*2+0*0+1*1 = 5
    let c = mat_mul(a, a8, b, b8);
    let c8 = mat_mul8(a, a8, b, b8);
    assert_eq(mat_cell(c, c8, 0, 0), 1);
    assert_eq(mat_cell(c, c8, 0, 1), 2);
    assert_eq(mat_cell(c, c8, 0, 2), 2);
    assert_eq(mat_cell(c, c8, 1, 0), 4);
    assert_eq(mat_cell(c, c8, 1, 1), 1);
    assert_eq(mat_cell(c, c8, 1, 2), 2);
    assert_eq(mat_cell(c, c8, 2, 0), 4);
    assert_eq(mat_cell(c, c8, 2, 1), 0);
    assert_eq(mat_cell(c, c8, 2, 2), 5);
    1
}

fn test_determinant() -> Int {
    // Identity: det = 1
    let id = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    let id8 = 1;
    assert_eq(mat_det(id, id8), 1);
    // A = [[1,2,3],[0,1,4],[5,6,0]]
    // det = 1*(0-24) - 2*(0-20) + 3*(0-5) = -24 + 40 - 15 = 1
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 1, v5: 4, v6: 5, v7: 6 };
    let a8 = 0;
    assert_eq(mat_det(a, a8), 1);
    // B = [[2,0,0],[0,3,0],[0,0,4]] (diagonal) -> det = 24
    let b = Arr8 { v0: 2, v1: 0, v2: 0, v3: 0, v4: 3, v5: 0, v6: 0, v7: 0 };
    let b8 = 4;
    assert_eq(mat_det(b, b8), 24);
    // Singular: [[1,2,3],[4,5,6],[7,8,9]] -> det = 0
    let s = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let s8 = 9;
    assert_eq(mat_det(s, s8), 0);
    1
}

fn test_transpose() -> Int {
    // A = [[1,2,3],[4,5,6],[7,8,9]]
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let a8 = 9;
    let t = mat_transpose(a, a8);
    let t8 = mat_transpose8(a, a8);
    // T = [[1,4,7],[2,5,8],[3,6,9]]
    assert_eq(mat_cell(t, t8, 0, 0), 1);
    assert_eq(mat_cell(t, t8, 0, 1), 4);
    assert_eq(mat_cell(t, t8, 0, 2), 7);
    assert_eq(mat_cell(t, t8, 1, 0), 2);
    assert_eq(mat_cell(t, t8, 1, 1), 5);
    assert_eq(mat_cell(t, t8, 1, 2), 8);
    assert_eq(mat_cell(t, t8, 2, 0), 3);
    assert_eq(mat_cell(t, t8, 2, 1), 6);
    assert_eq(mat_cell(t, t8, 2, 2), 9);
    // Symmetric matrix: transpose = self
    // S = [[1,2,3],[2,5,6],[3,6,9]]
    let s = Arr8 { v0: 1, v1: 2, v2: 3, v3: 2, v4: 5, v5: 6, v6: 3, v7: 6 };
    let s8 = 9;
    let st = mat_transpose(s, s8);
    let st8 = mat_transpose8(s, s8);
    assert_eq(mat_cell(st, st8, 0, 1), 2);
    assert_eq(mat_cell(st, st8, 1, 0), 2);
    assert_eq(mat_cell(st, st8, 0, 2), 3);
    assert_eq(mat_cell(st, st8, 2, 0), 3);
    1
}

fn test_trace() -> Int {
    // A = [[1,2,3],[4,5,6],[7,8,9]], trace = 1+5+9 = 15
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let a8 = 9;
    assert_eq(mat_trace(a, a8), 15);
    // Identity: trace = 3
    let id = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    let id8 = 1;
    assert_eq(mat_trace(id, id8), 3);
    // Diagonal: trace = 2+3+4 = 9
    let d = Arr8 { v0: 2, v1: 0, v2: 0, v3: 0, v4: 3, v5: 0, v6: 0, v7: 0 };
    let d8 = 4;
    assert_eq(mat_trace(d, d8), 9);
    1
}

fn test_identity_check() -> Int {
    let id = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 0 };
    let id8 = 1;
    assert_eq(mat_is_identity(id, id8), 1);
    // Not identity
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8 };
    let a8 = 9;
    assert_eq(mat_is_identity(a, a8), 0);
    // Almost identity (off by one element)
    let almost = Arr8 { v0: 1, v1: 0, v2: 0, v3: 0, v4: 1, v5: 0, v6: 0, v7: 1 };
    let almost8 = 1;
    assert_eq(mat_is_identity(almost, almost8), 0);
    1
}

fn test_det_properties() -> Int {
    // det(A*B) = det(A) * det(B)
    let a = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 1, v5: 2, v6: 2, v7: 0 };
    let a8 = 1;
    let b = Arr8 { v0: 1, v1: 0, v2: 2, v3: 0, v4: 1, v5: 0, v6: 2, v7: 0 };
    let b8 = 1;
    let ab = mat_mul(a, a8, b, b8);
    let ab8 = mat_mul8(a, a8, b, b8);
    let det_a = mat_det(a, a8);
    let det_b = mat_det(b, b8);
    let det_ab = mat_det(ab, ab8);
    assert_eq(det_ab, det_a * det_b);
    // det(transpose(A)) = det(A)
    let at = mat_transpose(a, a8);
    let at8 = mat_transpose8(a, a8);
    assert_eq(mat_det(at, at8), det_a);
    1
}

fn main() -> Int {
    test_add();
    test_multiply_identity();
    test_multiply();
    test_determinant();
    test_transpose();
    test_trace();
    test_identity_check();
    test_det_properties();
    print("[OK] 617_matrix_ops_aot");
    0
}
