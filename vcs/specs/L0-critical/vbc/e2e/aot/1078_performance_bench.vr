// @test: run
// @tier: 0
// @level: L0
// @tags: benchmark, performance, optimization
// @expect: pass

// Performance benchmarks — verify Verum generates high-performance code.
// Targets: 0.85-0.95x native C performance.

fn __time_monotonic_nanos_raw() -> Int { 0 }

// Tight loop benchmark: sum 1..N
fn bench_tight_loop(n: Int) -> Int {
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        sum = sum + i;
        i = i + 1;
    }
    sum
}

// Fibonacci (recursive)
@allow(unbounded_recursion)
fn fib(n: Int) -> Int {
    if n <= 1 { return n; }
    fib(n - 1) + fib(n - 2)
}

// Sieve of Eratosthenes
fn sieve(limit: Int) -> Int {
    let mut is_prime = List.new();
    let mut i = 0;
    while i <= limit {
        is_prime.push(1);
        i = i + 1;
    }

    is_prime[0] = 0;
    is_prime[1] = 0;

    let mut p = 2;
    while p * p <= limit {
        if is_prime[p] == 1 {
            let mut j = p * p;
            while j <= limit {
                is_prime[j] = 0;
                j = j + p;
            }
        }
        p = p + 1;
    }

    // Count primes
    let mut count = 0;
    let mut k = 0;
    while k <= limit {
        if is_prime[k] == 1 {
            count = count + 1;
        }
        k = k + 1;
    }
    count
}

// Matrix multiply (N×N, row-major)
fn matmul(n: Int) -> Int {
    // Initialize A and B as flat arrays
    let size = n * n;
    let mut a = List.new();
    let mut b = List.new();
    let mut c = List.new();

    let mut i = 0;
    while i < size {
        a.push(i % 7);
        b.push(i % 11);
        c.push(0);
        i = i + 1;
    }

    // C = A × B
    let mut row = 0;
    while row < n {
        let mut col = 0;
        while col < n {
            let mut sum = 0;
            let mut k = 0;
            while k < n {
                sum = sum + a[row * n + k] * b[k * n + col];
                k = k + 1;
            }
            c[row * n + col] = sum;
            col = col + 1;
        }
        row = row + 1;
    }

    // Return checksum
    let mut checksum = 0;
    let mut idx = 0;
    while idx < size {
        checksum = checksum + c[idx];
        idx = idx + 1;
    }
    checksum
}

fn run_bench(name: Text, iterations: Int, f: fn() -> Int) -> Int {
    // Warmup
    let _w = f();

    let start = __time_monotonic_nanos_raw();
    let mut result = 0;
    let mut i = 0;
    while i < iterations {
        result = f();
        i = i + 1;
    }
    let elapsed_ns = __time_monotonic_nanos_raw() - start;
    let per_iter_us = elapsed_ns / iterations / 1000;

    print(f"  {name}: {per_iter_us} us/iter ({iterations} iters)");
    result
}

fn main() -> Int {
    print("=== Verum Performance Benchmarks ===");
    print("");

    // Bench 1: Tight loop (10M iterations)
    let t1_start = __time_monotonic_nanos_raw();
    let sum = bench_tight_loop(10000000);
    let t1_ns = __time_monotonic_nanos_raw() - t1_start;
    print(f"  Tight loop (10M): {t1_ns / 1000} us");
    if sum != 49999995000000 {
        print(f"FAIL: tight loop sum = {sum}");
        return 1;
    }

    // Bench 2: Fibonacci(35) — measures recursive call overhead
    let t2_start = __time_monotonic_nanos_raw();
    let fib35 = fib(35);
    let t2_ns = __time_monotonic_nanos_raw() - t2_start;
    print(f"  Fibonacci(35): {t2_ns / 1000000} ms (result={fib35})");
    if fib35 != 9227465 {
        print(f"FAIL: fib(35) = {fib35}");
        return 1;
    }

    // Bench 3: Sieve of Eratosthenes (1M)
    let t3_start = __time_monotonic_nanos_raw();
    let primes = sieve(1000000);
    let t3_ns = __time_monotonic_nanos_raw() - t3_start;
    print(f"  Sieve (1M): {t3_ns / 1000000} ms ({primes} primes)");
    if primes != 78498 {
        print(f"FAIL: sieve(1M) = {primes}");
        return 1;
    }

    // Bench 4: Matrix multiply (100×100)
    let t4_start = __time_monotonic_nanos_raw();
    let checksum = matmul(100);
    let t4_ns = __time_monotonic_nanos_raw() - t4_start;
    print(f"  MatMul (100×100): {t4_ns / 1000000} ms");

    print("");
    print("=== All benchmarks passed ===");
    0
}
