// @test: run
// @level: L0
// @tags: aot, e2e, knapsack, dynamic-programming, optimization
// @timeout: 30000

// 0/1 Knapsack problem using dynamic programming
// Items stored as weight*100+value pairs in Arr8

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

fn item_weight(item: Int) -> Int { item / 100 }
fn item_value(item: Int) -> Int { item % 100 }
fn make_item(w: Int, v: Int) -> Int { w * 100 + v }

fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }

// Knapsack with capacity up to 8, items up to 4
// DP table: dp[w] = max value with capacity w
// We use Arr8 for the DP table (indices 0-7 = capacities 0-7)
fn knapsack(items: Arr8, n: Int, capacity: Int) -> Int {
    let mut dp = zeros(); // dp[w] = max value with capacity w
    let mut i = 0;
    while i < n {
        let w = item_weight(get8(items, i));
        let v = item_value(get8(items, i));
        // Process backwards to avoid using same item twice
        let mut c = capacity;
        while c >= w {
            let without = get8(dp, c);
            let with_item = get8(dp, c - w) + v;
            if with_item > without {
                dp = set8(dp, c, with_item);
            }
            c = c - 1;
        }
        i = i + 1;
    }
    if capacity < 8 { get8(dp, capacity) }
    else { get8(dp, 7) }
}

// Total weight of items in a selection bitmask
fn selection_weight(items: Arr8, n: Int, mask: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        if (mask / pow2(i)) % 2 == 1 {
            total = total + item_weight(get8(items, i));
        }
        i = i + 1;
    }
    total
}

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

// Total value of items in selection
fn selection_value(items: Arr8, n: Int, mask: Int) -> Int {
    let mut total = 0;
    let mut i = 0;
    while i < n {
        if (mask / pow2(i)) % 2 == 1 {
            total = total + item_value(get8(items, i));
        }
        i = i + 1;
    }
    total
}

// Brute force knapsack (for verification)
fn knapsack_brute(items: Arr8, n: Int, capacity: Int) -> Int {
    let total_masks = pow2(n);
    let mut best = 0;
    let mut mask = 0;
    while mask < total_masks {
        let w = selection_weight(items, n, mask);
        if w <= capacity {
            let v = selection_value(items, n, mask);
            if v > best { best = v; }
        }
        mask = mask + 1;
    }
    best
}

fn test_basic() -> Int {
    // Items: (weight=2, value=3), (weight=3, value=4), (weight=4, value=5)
    let items = Arr8 {
        v0: make_item(2, 3),
        v1: make_item(3, 4),
        v2: make_item(4, 5),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    // Capacity 5: take items 0+1 (w=5, v=7) or item 2 (w=4, v=5) -> best is 7
    assert_eq(knapsack(items, 3, 5), 7);
    1
}

fn test_all_fit() -> Int {
    // All items fit: (1,10), (1,20), (1,30)
    let items = Arr8 {
        v0: make_item(1, 10),
        v1: make_item(1, 20),
        v2: make_item(1, 30),
        v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    // Capacity 3: take all, value = 60
    assert_eq(knapsack(items, 3, 3), 60);
    1
}

fn test_none_fit() -> Int {
    // All items too heavy
    let items = Arr8 {
        v0: make_item(5, 10),
        v1: make_item(6, 20),
        v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    // Capacity 4: nothing fits
    assert_eq(knapsack(items, 2, 4), 0);
    1
}

fn test_single_item() -> Int {
    let items = Arr8 {
        v0: make_item(3, 10),
        v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(knapsack(items, 1, 3), 10); // fits
    assert_eq(knapsack(items, 1, 2), 0);  // doesn't fit
    1
}

fn test_dp_vs_brute() -> Int {
    // Verify DP matches brute force
    let items = Arr8 {
        v0: make_item(2, 6),
        v1: make_item(3, 8),
        v2: make_item(1, 3),
        v3: make_item(4, 9),
        v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(knapsack(items, 4, 7), knapsack_brute(items, 4, 7));
    assert_eq(knapsack(items, 4, 5), knapsack_brute(items, 4, 5));
    assert_eq(knapsack(items, 4, 3), knapsack_brute(items, 4, 3));
    1
}

fn test_zero_capacity() -> Int {
    let items = Arr8 {
        v0: make_item(1, 10),
        v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0
    };
    assert_eq(knapsack(items, 1, 0), 0);
    1
}

fn main() -> Int {
    test_basic();
    test_all_fit();
    test_none_fit();
    test_single_item();
    test_dp_vs_brute();
    test_zero_capacity();
    print("[OK] 643_knapsack_aot");
    0
}
