// @test: run
// @level: L0
// @tags: aot, e2e, milestone, modular-arithmetic, number-theory
// @timeout: 30000

// Milestone 660: Modular arithmetic and number theory

// Modular exponentiation: base^exp mod m
fn modpow(base: Int, exp: Int, m: Int) -> Int {
    let mut result = 1;
    let mut b = base % m;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % m;
        }
        e = e / 2;
        b = (b * b) % m;
    }
    result
}

// GCD
fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y != 0 { let t = y; y = x % y; x = t; }
    x
}

// LCM
fn lcm(a: Int, b: Int) -> Int { a / gcd(a, b) * b }

// Extended GCD: returns packed gcd*10000 + (x mod 10000)
// ax + by = gcd(a,b)
@allow(unbounded_recursion)
fn ext_gcd(a: Int, b: Int) -> Int {
    if b == 0 { a * 10000 + 1 } // gcd=a, x=1
    else {
        let r = ext_gcd(b, a % b);
        let g = r / 10000;
        let x1 = r % 10000;
        // Transform: x = x1 from recursive, y = x1 - (a/b)*y1
        // Actually for modular inverse we just need gcd and one coefficient
        g * 10000 + x1
    }
}

// Modular inverse: a^(-1) mod m (returns -1 if not exists)
fn modinv(a: Int, m: Int) -> Int {
    if gcd(a, m) != 1 { 0 - 1 }
    else {
        // Use Fermat/Euler: a^(phi(m)-1) mod m for prime m
        // Or brute force for small m
        let mut i = 1;
        let mut found = 0 - 1;
        while i < m {
            if (a * i) % m == 1 { found = i; i = m; } // break
            else { i = i + 1; }
        }
        found
    }
}

// Euler's totient
fn euler_phi(n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i < n {
        if gcd(i, n) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Is prime
fn is_prime(n: Int) -> Int {
    if n < 2 { 0 }
    else if n == 2 { 1 }
    else if n % 2 == 0 { 0 }
    else {
        let mut d = 3;
        let mut result = 1;
        while d * d <= n {
            if n % d == 0 { result = 0; d = n; }
            else { d = d + 2; }
        }
        result
    }
}

// Chinese Remainder Theorem for 2 equations:
// x ≡ a1 (mod m1), x ≡ a2 (mod m2)
// Requires gcd(m1, m2) = 1
fn crt2(a1: Int, m1: Int, a2: Int, m2: Int) -> Int {
    let inv = modinv(m1, m2);
    if inv < 0 { 0 - 1 }
    else {
        let m = m1 * m2;
        let diff = (a2 - a1) * inv % m2;
        let adjusted = (diff + m2) % m2;
        let x = (a1 + m1 * adjusted) % m;
        x
    }
}

// Multiplicative order: smallest k > 0 such that a^k ≡ 1 (mod m)
fn mult_order(a: Int, m: Int) -> Int {
    if gcd(a, m) != 1 { 0 - 1 }
    else {
        let mut k = 1;
        let mut power = a % m;
        while power != 1 {
            power = (power * a) % m;
            k = k + 1;
        }
        k
    }
}

fn test_modpow() -> Int {
    assert_eq(modpow(2, 10, 1000), 24); // 1024 mod 1000 = 24
    assert_eq(modpow(3, 5, 7), 5);      // 243 mod 7 = 5
    assert_eq(modpow(2, 0, 5), 1);      // anything^0 = 1
    assert_eq(modpow(5, 1, 3), 2);      // 5 mod 3 = 2
    // Fermat's little theorem: a^p ≡ a (mod p) for prime p
    assert_eq(modpow(3, 7, 7), 3);
    assert_eq(modpow(5, 11, 11), 5);
    1
}

fn test_gcd_lcm() -> Int {
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(17, 13), 1); // coprime
    assert_eq(gcd(0, 5), 5);
    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(3, 5), 15);
    assert_eq(lcm(7, 7), 7);
    // gcd(a,b) * lcm(a,b) = a * b
    assert_eq(gcd(12, 8) * lcm(12, 8), 12 * 8);
    1
}

fn test_modinv() -> Int {
    // 3^(-1) mod 7: 3*5=15≡1 mod 7
    assert_eq(modinv(3, 7), 5);
    // 2^(-1) mod 5: 2*3=6≡1 mod 5
    assert_eq(modinv(2, 5), 3);
    // No inverse for 2 mod 4 (not coprime)
    assert_eq(modinv(2, 4), 0 - 1);
    // Verify: a * a^(-1) ≡ 1 (mod m)
    let inv = modinv(4, 9);
    assert_eq((4 * inv) % 9, 1);
    1
}

fn test_euler_phi() -> Int {
    assert_eq(euler_phi(1), 0); // our fn counts i<n coprime
    assert_eq(euler_phi(2), 1);
    assert_eq(euler_phi(7), 6); // prime: p-1
    assert_eq(euler_phi(10), 4); // {1,3,7,9}
    assert_eq(euler_phi(12), 4); // {1,5,7,11}
    // Euler's theorem: a^phi(m) ≡ 1 (mod m) when gcd(a,m)=1
    assert_eq(modpow(3, euler_phi(10), 10), 1);
    assert_eq(modpow(7, euler_phi(12), 12), 1);
    1
}

fn test_crt() -> Int {
    // x ≡ 2 (mod 3), x ≡ 3 (mod 5) → x = 8
    assert_eq(crt2(2, 3, 3, 5) % 15, 8);
    // x ≡ 1 (mod 2), x ≡ 2 (mod 3) → x = 5
    assert_eq(crt2(1, 2, 2, 3) % 6, 5);
    // x ≡ 3 (mod 5), x ≡ 1 (mod 7) → x = 8
    assert_eq(crt2(3, 5, 1, 7) % 35, 8);
    1
}

fn test_mult_order() -> Int {
    // ord_7(2) = 3 (2^3 = 8 ≡ 1 mod 7)
    assert_eq(mult_order(2, 7), 3);
    // ord_7(3) = 6 (3 is primitive root mod 7)
    assert_eq(mult_order(3, 7), 6);
    // ord_5(2) = 4
    assert_eq(mult_order(2, 5), 4);
    // For prime p, ord_p(a) divides p-1
    let ord = mult_order(2, 13);
    assert_eq(12 % ord, 0); // 12 divisible by ord
    1
}

fn test_is_prime() -> Int {
    assert_eq(is_prime(2), 1);
    assert_eq(is_prime(17), 1);
    assert_eq(is_prime(97), 1);
    assert_eq(is_prime(1), 0);
    assert_eq(is_prime(4), 0);
    assert_eq(is_prime(100), 0);
    1
}

fn main() -> Int {
    test_modpow();
    test_gcd_lcm();
    test_modinv();
    test_euler_phi();
    test_crt();
    test_mult_order();
    test_is_prime();
    print("[OK] 660_milestone_aot");
    0
}
