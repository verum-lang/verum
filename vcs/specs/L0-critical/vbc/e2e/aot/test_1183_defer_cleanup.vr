// @test: run
// @level: L0
// @tier: 0
// @tags: defer, cleanup, resource, e2e
// @description: Test defer statements for resource cleanup

fn test_defer_order() -> Int {
    let mut result = 0;
    defer { result = result + 1; }
    defer { result = result * 10; }
    // defer runs in reverse: first *10, then +1
    // But result is returned before defer runs in AOT
    result
}

fn counted_operation() -> Int {
    let mut ops = 0;
    ops = ops + 10;
    ops = ops + 1;
    ops  // should return 11
}

fn main() -> Int {
    let mut failures = 0;

    // Test 1: Simple defer
    let mut x = 0;
    {
        x = 10;
        defer { x = x + 5; }
        x = x + 1;
    }
    // After block: x should be 10 + 1 + 5 = 16
    if x != 16 {
        print(f"FAIL: defer expected 16, got {x}");
        failures = failures + 1;
    } else {
        print("  simple_defer: OK");
    }

    // Test 2: Multiple defers (LIFO)
    let mut order = List.new();
    {
        defer { order.push(3); }
        defer { order.push(2); }
        defer { order.push(1); }
    }
    // LIFO: push 1, then 2, then 3
    if order.len() != 3 {
        print(f"FAIL: order len expected 3, got {order.len()}");
        failures = failures + 1;
    }
    if order[0] != 1 {
        print(f"FAIL: order[0] expected 1, got {order[0]}");
        failures = failures + 1;
    }
    if order[1] != 2 {
        print(f"FAIL: order[1] expected 2, got {order[1]}");
        failures = failures + 1;
    }
    if order[2] != 3 {
        print(f"FAIL: order[2] expected 3, got {order[2]}");
        failures = failures + 1;
    }
    if failures == 0 {
        print("  lifo_defer: OK");
    }

    // Test 3: Defer with counters
    let mut counter = 0;
    let mut i = 0;
    while i < 5 {
        counter = counter + 1;
        i = i + 1;
    }
    if counter != 5 {
        print(f"FAIL: counter expected 5, got {counter}");
        failures = failures + 1;
    } else {
        print("  counter: OK");
    }

    // Test 4: counted operation
    let result = counted_operation();
    if result != 11 {
        print(f"FAIL: counted op expected 11, got {result}");
        failures = failures + 1;
    } else {
        print("  counted_op: OK");
    }

    if failures == 0 {
        print("All defer cleanup tests passed");
    }
    failures
}
