// @test: run
// Closure patterns — capture, higher-order, composition

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
    f(x)
}

fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int {
    f(f(x))
}

fn compose(f: fn(Int) -> Int, g: fn(Int) -> Int, x: Int) -> Int {
    f(g(x))
}

fn add5(x: Int) -> Int { x + 5 }
fn mul3(x: Int) -> Int { x * 3 }
fn mul7(x: Int) -> Int { x * 7 }

fn main() -> Int {
    // Test 1: Simple function passing
    fn double(x: Int) -> Int { x * 2 }
    fn inc(x: Int) -> Int { x + 1 }

    let r1 = apply(double, 5);
    if (r1 != 10) {
        print(f"FAIL test1: apply(double, 5) = {r1}");
        return 1;
    }
    print("test1 apply: OK");

    // Test 2: Apply twice
    let r2 = apply_twice(double, 3);
    // double(double(3)) = double(6) = 12
    if (r2 != 12) {
        print(f"FAIL test2: apply_twice(double, 3) = {r2}");
        return 1;
    }
    print("test2 apply_twice: OK");

    // Test 3: Compose
    let r3 = compose(double, inc, 4);
    // double(inc(4)) = double(5) = 10
    if (r3 != 10) {
        print(f"FAIL test3: compose(double, inc, 4) = {r3}");
        return 1;
    }
    print("test3 compose: OK");

    // Test 4: Named function as value
    let r4 = apply(add5, 10);
    if (r4 != 15) {
        print(f"FAIL test4: add5(10) = {r4}");
        return 1;
    }
    print("test4 fn value: OK");

    // Test 5: Multiple function values
    let r5a = apply(mul3, 4);
    let r5b = apply(mul7, 4);
    if (r5a != 12 || r5b != 28) {
        print(f"FAIL test5: mul3(4)={r5a}, mul7(4)={r5b}");
        return 1;
    }
    print("test5 multiple fns: OK");

    // Test 6: Closure as accumulator
    let data = [3, 1, 4, 1, 5, 9, 2, 6];
    let mut max_val = 0;
    let mut i = 0;
    while i < data.len() {
        if (data[i] > max_val) {
            max_val = data[i];
        }
        i = i + 1;
    }
    if (max_val != 9) {
        print(f"FAIL test6: max = {max_val}");
        return 1;
    }
    print("test6 accumulator: OK");

    print("1027_closure_patterns: PASS");
    0
}
