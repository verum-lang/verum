// @test: run
// @level: L0
// @tags: aot, e2e, intervals, scheduling, merge
// @timeout: 30000

// Interval operations: overlap check, merge, max overlap count

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn max_val(a: Int, b: Int) -> Int { if a > b { a } else { b } }
fn min_val(a: Int, b: Int) -> Int { if a < b { a } else { b } }

// Intervals stored as pairs: starts[i], ends[i]

// Check if two intervals overlap (exclusive endpoints)
fn overlaps(s1: Int, e1: Int, s2: Int, e2: Int) -> Int {
    if s1 < e2 {
        if s2 < e1 { 1 } else { 0 }
    } else { 0 }
}

// Check if interval [s1,e1) contains point p
fn contains_point(s: Int, e: Int, p: Int) -> Int {
    if p >= s {
        if p < e { 1 } else { 0 }
    } else { 0 }
}

// Length of interval
fn interval_len(s: Int, e: Int) -> Int { e - s }

// Intersection of two intervals (returns 0,0 if no intersection)
fn intersect_start(s1: Int, e1: Int, s2: Int, e2: Int) -> Int {
    if overlaps(s1, e1, s2, e2) == 0 { return 0; }
    max_val(s1, s2)
}

fn intersect_end(s1: Int, e1: Int, s2: Int, e2: Int) -> Int {
    if overlaps(s1, e1, s2, e2) == 0 { return 0; }
    min_val(e1, e2)
}

// Count how many intervals a point is in
fn point_coverage(starts: Arr8, ends: Arr8, n: Int, p: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if contains_point(get8(starts, i), get8(ends, i), p) == 1 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

// Maximum concurrent intervals (sweep line on small range)
fn max_overlap(starts: Arr8, ends: Arr8, n: Int, range_end: Int) -> Int {
    let mut max_count = 0;
    let mut t = 0;
    while t < range_end {
        let c = point_coverage(starts, ends, n, t);
        if c > max_count { max_count = c; }
        t = t + 1;
    }
    max_count
}

// Count non-overlapping intervals (greedy: sort by end, pick earliest)
// Assumes intervals sorted by end time
fn count_non_overlapping(starts: Arr8, ends: Arr8, n: Int) -> Int {
    let mut count = 1;
    let mut last_end = get8(ends, 0);
    let mut i = 1;
    while i < n {
        if get8(starts, i) >= last_end {
            count = count + 1;
            last_end = get8(ends, i);
        }
        i = i + 1;
    }
    count
}

// Total coverage (union of all intervals, in small range)
fn total_coverage(starts: Arr8, ends: Arr8, n: Int, range_end: Int) -> Int {
    let mut covered = 0;
    let mut t = 0;
    while t < range_end {
        if point_coverage(starts, ends, n, t) > 0 {
            covered = covered + 1;
        }
        t = t + 1;
    }
    covered
}

fn test_overlap() -> Int {
    // [1,5) and [3,7): overlap
    assert_eq(overlaps(1, 5, 3, 7), 1);
    // [1,3) and [3,5): no overlap (endpoints exclusive)
    assert_eq(overlaps(1, 3, 3, 5), 0);
    // [1,5) and [6,8): no overlap
    assert_eq(overlaps(1, 5, 6, 8), 0);
    // [1,5) and [2,3): contained
    assert_eq(overlaps(1, 5, 2, 3), 1);
    // Same interval
    assert_eq(overlaps(2, 5, 2, 5), 1);
    1
}

fn test_intersection() -> Int {
    // [1,5) ∩ [3,7) = [3,5)
    assert_eq(intersect_start(1, 5, 3, 7), 3);
    assert_eq(intersect_end(1, 5, 3, 7), 5);

    // [0,10) ∩ [3,7) = [3,7)
    assert_eq(intersect_start(0, 10, 3, 7), 3);
    assert_eq(intersect_end(0, 10, 3, 7), 7);
    1
}

fn test_point_coverage() -> Int {
    // Intervals: [1,4), [2,6), [5,8)
    let starts = Arr8 { v0: 1, v1: 2, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 4, v1: 6, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(point_coverage(starts, ends, 3, 0), 0);
    assert_eq(point_coverage(starts, ends, 3, 1), 1);
    assert_eq(point_coverage(starts, ends, 3, 2), 2);
    assert_eq(point_coverage(starts, ends, 3, 3), 2);
    assert_eq(point_coverage(starts, ends, 3, 4), 1);
    assert_eq(point_coverage(starts, ends, 3, 5), 2);
    assert_eq(point_coverage(starts, ends, 3, 7), 1);
    assert_eq(point_coverage(starts, ends, 3, 8), 0);
    1
}

fn test_max_overlap() -> Int {
    // Intervals: [1,4), [2,6), [5,8)
    let starts = Arr8 { v0: 1, v1: 2, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 4, v1: 6, v2: 8, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_overlap(starts, ends, 3, 10), 2);

    // All overlap: [0,5), [1,6), [2,7), [3,8)
    let s2 = Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    let e2 = Arr8 { v0: 5, v1: 6, v2: 7, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(max_overlap(s2, e2, 4, 10), 4);
    1
}

fn test_non_overlapping() -> Int {
    // Sorted by end: [1,3), [2,5), [4,7), [6,9)
    let starts = Arr8 { v0: 1, v1: 2, v2: 4, v3: 6, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 3, v1: 5, v2: 7, v3: 9, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Greedy: pick [1,3), skip [2,5) (overlaps), pick [4,7), skip... wait
    // [1,3) end=3, next [2,5) start=2 < 3 skip, [4,7) start=4 >= 3 pick, [6,9) start=6 < 7 skip
    assert_eq(count_non_overlapping(starts, ends, 4), 2);

    // Non-overlapping: [1,2), [3,4), [5,6)
    let s2 = Arr8 { v0: 1, v1: 3, v2: 5, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let e2 = Arr8 { v0: 2, v1: 4, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(count_non_overlapping(s2, e2, 3), 3);
    1
}

fn test_total_coverage() -> Int {
    // [1,4) and [3,6): union covers [1,6) = 5 units
    let starts = Arr8 { v0: 1, v1: 3, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let ends = Arr8 { v0: 4, v1: 6, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(total_coverage(starts, ends, 2, 10), 5);

    // Disjoint: [1,3) and [5,7): coverage = 4
    let s2 = Arr8 { v0: 1, v1: 5, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let e2 = Arr8 { v0: 3, v1: 7, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(total_coverage(s2, e2, 2, 10), 4);
    1
}

fn main() -> Int {
    test_overlap();
    test_intersection();
    test_point_coverage();
    test_max_overlap();
    test_non_overlapping();
    test_total_coverage();
    print("[OK] 493_interval_ops_aot");
    0
}
