// @test: run
// @level: L0
// @tier: 1
// @tags: for-in, iterator, range, list
// @description: Test for-in loops over various collection types

fn test_for_range() -> Int {
    let mut sum = 0;
    for i in 0..10 {
        sum = sum + i;
    }
    // 0+1+2+...+9 = 45
    if sum != 45 {
        print(f"FAIL for_range: {sum}, expected 45");
        return 1;
    }
    print("  for_range: OK");
    0
}

fn test_for_inclusive() -> Int {
    let mut sum = 0;
    for i in 1..=10 {
        sum = sum + i;
    }
    // 1+2+...+10 = 55
    if sum != 55 {
        print(f"FAIL for_inclusive: {sum}, expected 55");
        return 1;
    }
    print("  for_inclusive: OK");
    0
}

fn test_for_nested_range() -> Int {
    let mut count = 0;
    for i in 0..5 {
        for j in 0..5 {
            if i < j {
                count = count + 1;
            }
        }
    }
    // Pairs where i < j: (0,1)(0,2)(0,3)(0,4)(1,2)(1,3)(1,4)(2,3)(2,4)(3,4) = 10
    if count != 10 {
        print(f"FAIL nested_range: {count}, expected 10");
        return 1;
    }
    print("  for_nested_range: OK");
    0
}

fn test_for_range_step() -> Int {
    // Simulate step with range + filter
    let mut evens = List.new();
    for i in 0..20 {
        if i % 2 == 0 {
            evens.push(i);
        }
    }
    if evens.len() != 10 {
        print(f"FAIL range_step_len: {evens.len()}");
        return 1;
    }
    if evens[0] != 0 || evens[9] != 18 {
        print(f"FAIL range_step_vals");
        return 1;
    }
    print("  for_range_step: OK");
    0
}

fn test_for_empty_range() -> Int {
    let mut count = 0;
    for i in 5..5 {
        count = count + 1;
    }
    if count != 0 {
        print(f"FAIL empty_range: {count}");
        return 1;
    }
    print("  for_empty_range: OK");
    0
}

fn main() -> Int {
    print("For-In Collection Tests:");
    let mut failures = 0;
    failures = failures + test_for_range();
    failures = failures + test_for_inclusive();
    failures = failures + test_for_nested_range();
    failures = failures + test_for_range_step();
    failures = failures + test_for_empty_range();

    if failures == 0 {
        print("All for-in tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
