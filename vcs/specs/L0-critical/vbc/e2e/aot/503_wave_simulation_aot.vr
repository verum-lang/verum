// @test: run
// @level: L0
// @tags: aot, e2e, simulation, wave, physics
// @timeout: 30000

// 1D wave equation simulation and signal processing

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// 1D diffusion step (scaled by 100 to avoid floats)
// u'[i] = u[i] + c * (u[i-1] - 2*u[i] + u[i+1]) / 100
fn diffusion_step(u: Arr8, n: Int, c: Int) -> Arr8 {
    let mut next = zeros();
    next = set8(next, 0, get8(u, 0)); // boundary
    let mut i = 1;
    while i < n - 1 {
        let laplacian = get8(u, i - 1) - 2 * get8(u, i) + get8(u, i + 1);
        let new_val = get8(u, i) + c * laplacian / 100;
        next = set8(next, i, new_val);
        i = i + 1;
    }
    next = set8(next, n - 1, get8(u, n - 1)); // boundary
    next
}

// Moving average filter (window size 3)
fn moving_avg3(signal: Arr8, n: Int) -> Arr8 {
    let mut result = zeros();
    result = set8(result, 0, get8(signal, 0));
    let mut i = 1;
    while i < n - 1 {
        let avg = (get8(signal, i - 1) + get8(signal, i) + get8(signal, i + 1)) / 3;
        result = set8(result, i, avg);
        i = i + 1;
    }
    if n > 1 { result = set8(result, n - 1, get8(signal, n - 1)); }
    result
}

// Convolution of signal with kernel (both Arr8)
// output[i] = sum(signal[i-j] * kernel[j]) for valid positions
fn convolve(signal: Arr8, sig_len: Int, kernel: Arr8, ker_len: Int) -> Arr8 {
    let mut result = zeros();
    let out_len = sig_len - ker_len + 1;
    let mut i = 0;
    while i < out_len {
        let mut sum = 0;
        let mut j = 0;
        while j < ker_len {
            sum = sum + get8(signal, i + j) * get8(kernel, j);
            j = j + 1;
        }
        if i < 8 { result = set8(result, i, sum); }
        i = i + 1;
    }
    result
}

// Energy of signal (sum of squares)
fn signal_energy(signal: Arr8, n: Int) -> Int {
    let mut energy = 0;
    let mut i = 0;
    while i < n {
        let v = get8(signal, i);
        energy = energy + v * v;
        i = i + 1;
    }
    energy
}

// Max absolute value
fn signal_peak(signal: Arr8, n: Int) -> Int {
    let mut peak = 0;
    let mut i = 0;
    while i < n {
        let v = abs_val(get8(signal, i));
        if v > peak { peak = v; }
        i = i + 1;
    }
    peak
}

// Zero crossings count
fn zero_crossings(signal: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i < n {
        let prev = get8(signal, i - 1);
        let cur = get8(signal, i);
        if prev > 0 {
            if cur <= 0 { count = count + 1; }
        } else if prev < 0 {
            if cur >= 0 { count = count + 1; }
        }
        i = i + 1;
    }
    count
}

fn test_diffusion() -> Int {
    // Initial: spike in center
    // [0, 0, 0, 100, 0, 0, 0, 0] with c=50
    let u = Arr8 { v0: 0, v1: 0, v2: 0, v3: 100, v4: 0, v5: 0, v6: 0, v7: 0 };
    let u1 = diffusion_step(u, 7, 50);
    // At i=3: 100 + 50*(0-200+0)/100 = 100 - 100 = 0
    assert_eq(get8(u1, 3), 0);
    // At i=2: 0 + 50*(0-0+100)/100 = 50
    assert_eq(get8(u1, 2), 50);
    // At i=4: 0 + 50*(100-0+0)/100 = 50
    assert_eq(get8(u1, 4), 50);

    // Total energy should decrease or stay same (diffusion)
    let mut total0 = 0;
    let mut total1 = 0;
    let mut i = 0;
    while i < 7 {
        total0 = total0 + get8(u, i);
        total1 = total1 + get8(u1, i);
        i = i + 1;
    }
    assert_eq(total0, total1); // mass conservation
    1
}

fn test_moving_average() -> Int {
    let signal = Arr8 { v0: 10, v1: 20, v2: 30, v3: 20, v4: 10, v5: 0, v6: 0, v7: 0 };
    let avg = moving_avg3(signal, 5);
    // avg[1] = (10+20+30)/3 = 20
    assert_eq(get8(avg, 1), 20);
    // avg[2] = (20+30+20)/3 = 23
    assert_eq(get8(avg, 2), 23);
    // avg[3] = (30+20+10)/3 = 20
    assert_eq(get8(avg, 3), 20);
    1
}

fn test_convolution() -> Int {
    // Signal [1,2,3,4,5], Kernel [1,1] → [3,5,7,9]
    let signal = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    let kernel = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let result = convolve(signal, 5, kernel, 2);
    assert_eq(get8(result, 0), 3); // 1*1 + 2*1
    assert_eq(get8(result, 1), 5); // 2*1 + 3*1
    assert_eq(get8(result, 2), 7); // 3*1 + 4*1
    assert_eq(get8(result, 3), 9); // 4*1 + 5*1

    // Edge detection kernel [-1, 2, -1]
    let signal2 = Arr8 { v0: 5, v1: 5, v2: 10, v3: 5, v4: 5, v5: 0, v6: 0, v7: 0 };
    let edge = Arr8 { v0: -1, v1: 2, v2: -1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r2 = convolve(signal2, 5, edge, 3);
    // [0]: -1*5 + 2*5 + -1*10 = -5+10-10 = -5
    assert_eq(get8(r2, 0), -5);
    // [1]: -1*5 + 2*10 + -1*5 = -5+20-5 = 10
    assert_eq(get8(r2, 1), 10);
    // [2]: -1*10 + 2*5 + -1*5 = -10+10-5 = -5
    assert_eq(get8(r2, 2), -5);
    1
}

fn test_signal_properties() -> Int {
    let signal = Arr8 { v0: 3, v1: -2, v2: 5, v3: -4, v4: 1, v5: 0, v6: 0, v7: 0 };
    assert_eq(signal_energy(signal, 5), 9 + 4 + 25 + 16 + 1);
    assert_eq(signal_peak(signal, 5), 5);
    // Zero crossings: 3→-2 (1), -2→5 (2), 5→-4 (3), -4→1 (4)
    assert_eq(zero_crossings(signal, 5), 4);
    1
}

fn main() -> Int {
    test_diffusion();
    test_moving_average();
    test_convolution();
    test_signal_properties();
    print("[OK] 503_wave_simulation_aot");
    0
}
