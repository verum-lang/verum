// @test: run
// @level: L0
// @tier: 1
// @tags: labeled-break, loop, control-flow
// @description: Test labeled break and continue in nested loops

fn test_labeled_break() -> Int {
    // Find first pair (i,j) where i*j == 12
    let mut found_i = 0;
    let mut found_j = 0;
    'outer: while found_i < 10 {
        let mut j = 1;
        while j < 10 {
            if found_i * j == 12 {
                found_j = j;
                break 'outer;
            }
            j = j + 1;
        }
        found_i = found_i + 1;
    }
    // First pair: i=2, j=6 (2*6=12)
    if found_i != 2 || found_j != 6 {
        print(f"FAIL labeled_break: i={found_i}, j={found_j}");
        return 1;
    }
    print("  labeled_break: OK");
    0
}

fn test_labeled_continue() -> Int {
    // Sum products where i != j, skipping entire inner loop when i == 3
    let mut total = 0;
    let mut i = 0;
    'outer: while i < 5 {
        if i == 3 {
            i = i + 1;
            continue 'outer;
        }
        let mut j = 0;
        while j < 5 {
            if i != j {
                total = total + i * j;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    // i=0: 0*(1+2+3+4)=0
    // i=1: 1*(0+2+3+4)=9
    // i=2: 2*(0+1+3+4)=16
    // i=3: skipped
    // i=4: 4*(0+1+2+3)=24
    // total = 0+9+16+24 = 49
    if total != 49 {
        print(f"FAIL labeled_continue: total={total}, expected 49");
        return 1;
    }
    print("  labeled_continue: OK");
    0
}

fn test_break_value() -> Int {
    // loop with break returning a value
    let mut n = 1;
    let result = loop {
        if n * n > 50 {
            break n;
        }
        n = n + 1;
    };
    // 8*8 = 64 > 50, so result should be 8
    if result != 8 {
        print(f"FAIL break_value: result={result}, expected 8");
        return 1;
    }
    print("  break_value: OK");
    0
}

fn test_nested_labeled() -> Int {
    // Triple nested with labeled break to middle
    let mut count = 0;
    let mut i = 0;
    while i < 3 {
        let mut j = 0;
        'mid: while j < 3 {
            let mut k = 0;
            while k < 3 {
                count = count + 1;
                if k == 1 {
                    break 'mid;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    // Each outer iteration: k=0 (count+1), k=1 (count+1, break 'mid)
    // 3 outer iterations * 2 counts = 6
    if count != 6 {
        print(f"FAIL nested_labeled: count={count}, expected 6");
        return 1;
    }
    print("  nested_labeled: OK");
    0
}

fn main() -> Int {
    print("Labeled Break/Continue Tests:");
    let mut failures = 0;
    failures = failures + test_labeled_break();
    failures = failures + test_labeled_continue();
    failures = failures + test_break_value();
    failures = failures + test_nested_labeled();

    if failures == 0 {
        print("All labeled break tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
