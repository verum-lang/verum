// @test: run
// @level: L0
// @tags: aot, e2e, game-of-life, cellular-automaton, simulation
// @timeout: 30000

// Conway's Game of Life on an 8x8 grid using bitmask rows

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Grid is Arr8 where each element is a bitmask row (8 bits)
// Cell (r, c) is alive if (grid[r] >> c) & 1 == 1

fn bit(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn get_cell(grid: Arr8, r: Int, c: Int) -> Int {
    if r < 0 { return 0; }
    if r >= 8 { return 0; }
    if c < 0 { return 0; }
    if c >= 8 { return 0; }
    (get8(grid, r) / bit(c)) % 2
}

fn set_cell(grid: Arr8, r: Int, c: Int) -> Arr8 {
    set8(grid, r, get8(grid, r) + bit(c))
}

// Count live neighbors
fn count_neighbors(grid: Arr8, r: Int, c: Int) -> Int {
    let mut count = 0;
    let mut dr = -1;
    while dr <= 1 {
        let mut dc = -1;
        while dc <= 1 {
            if dr != 0 {
                count = count + get_cell(grid, r + dr, c + dc);
            } else if dc != 0 {
                count = count + get_cell(grid, r + dr, c + dc);
            }
            dc = dc + 1;
        }
        dr = dr + 1;
    }
    count
}

// Step the Game of Life
fn gol_step(grid: Arr8) -> Arr8 {
    let mut next = zeros();
    let mut r = 0;
    while r < 8 {
        let mut row = 0;
        let mut c = 0;
        while c < 8 {
            let alive = get_cell(grid, r, c);
            let neighbors = count_neighbors(grid, r, c);
            let mut new_alive = 0;
            if alive == 1 {
                // Survive with 2 or 3 neighbors
                if neighbors == 2 { new_alive = 1; }
                if neighbors == 3 { new_alive = 1; }
            } else {
                // Birth with exactly 3 neighbors
                if neighbors == 3 { new_alive = 1; }
            }
            if new_alive == 1 {
                row = row + bit(c);
            }
            c = c + 1;
        }
        next = set8(next, r, row);
        r = r + 1;
    }
    next
}

// Count total live cells
fn total_alive(grid: Arr8) -> Int {
    let mut count = 0;
    let mut r = 0;
    while r < 8 {
        let mut row = get8(grid, r);
        while row > 0 {
            count = count + row % 2;
            row = row / 2;
        }
        r = r + 1;
    }
    count
}

fn test_blinker() -> Int {
    // Blinker (period 2):
    // Step 0:      Step 1:
    //  .#.          ...
    //  .#.          ###
    //  .#.          ...
    let mut g0 = zeros();
    g0 = set8(g0, 1, bit(1)); // row 1, col 1
    g0 = set8(g0, 2, bit(1)); // row 2, col 1
    g0 = set8(g0, 3, bit(1)); // row 3, col 1

    assert_eq(total_alive(g0), 3);

    let g1 = gol_step(g0);
    // Should be horizontal: row 2, cols 0,1,2
    assert_eq(get_cell(g1, 2, 0), 1);
    assert_eq(get_cell(g1, 2, 1), 1);
    assert_eq(get_cell(g1, 2, 2), 1);
    assert_eq(get_cell(g1, 1, 1), 0); // vertical died
    assert_eq(total_alive(g1), 3);

    // Step 2 should return to original
    let g2 = gol_step(g1);
    assert_eq(get_cell(g2, 1, 1), 1);
    assert_eq(get_cell(g2, 2, 1), 1);
    assert_eq(get_cell(g2, 3, 1), 1);
    assert_eq(total_alive(g2), 3);
    1
}

fn test_block() -> Int {
    // Block (still life):
    // ##
    // ##
    let mut g0 = zeros();
    g0 = set8(g0, 1, bit(1) + bit(2)); // row 1: cols 1,2
    g0 = set8(g0, 2, bit(1) + bit(2)); // row 2: cols 1,2

    let g1 = gol_step(g0);
    // Block should not change
    assert_eq(get8(g1, 1), get8(g0, 1));
    assert_eq(get8(g1, 2), get8(g0, 2));
    assert_eq(total_alive(g1), 4);
    1
}

fn test_glider_steps() -> Int {
    // Glider:
    //  .#.
    //  ..#
    //  ###
    let mut g0 = zeros();
    g0 = set8(g0, 0, bit(1));           // row 0: col 1
    g0 = set8(g0, 1, bit(2));           // row 1: col 2
    g0 = set8(g0, 2, bit(0) + bit(1) + bit(2)); // row 2: cols 0,1,2

    assert_eq(total_alive(g0), 5);

    // After 4 steps, glider moves diagonally
    let g1 = gol_step(g0);
    let g2 = gol_step(g1);
    let g3 = gol_step(g2);
    let g4 = gol_step(g3);

    // After 4 generations, glider moves 1 right, 1 down (same shape)
    assert_eq(total_alive(g4), 5);
    assert_eq(get_cell(g4, 1, 2), 1); // shifted pattern
    1
}

fn test_empty() -> Int {
    let g0 = zeros();
    let g1 = gol_step(g0);
    assert_eq(total_alive(g1), 0);
    1
}

fn test_overcrowding() -> Int {
    // A cell with >3 neighbors dies
    // Plus pattern:
    //  .#.
    //  ###
    //  .#.
    let mut g0 = zeros();
    g0 = set8(g0, 0, bit(1));
    g0 = set8(g0, 1, bit(0) + bit(1) + bit(2));
    g0 = set8(g0, 2, bit(1));

    let g1 = gol_step(g0);
    // Center cell (1,1) has 4 neighbors → dies
    assert_eq(get_cell(g1, 1, 1), 0);
    // Corners (0,0), (0,2), (2,0), (2,2) each have 2 neighbors → birth with 2 → NO, need 3
    // Actually, let's check (0,0): neighbors are (0,1)=1, (1,0)=1, (1,1)=1 → 3 → birth!
    assert_eq(get_cell(g1, 0, 0), 1);
    assert_eq(get_cell(g1, 0, 2), 1);
    1
}

fn main() -> Int {
    test_blinker();
    test_block();
    test_glider_steps();
    test_empty();
    test_overcrowding();
    print("[OK] 506_game_of_life_aot");
    0
}
