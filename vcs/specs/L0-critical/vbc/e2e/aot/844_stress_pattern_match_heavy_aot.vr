// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, stress, graph
// @timeout: 60000
// @expected-exit: 0

// Graph algorithms: BFS/DFS on simulated adjacency, shortest path via Bellman-Ford

// Adjacency matrix for up to 8 nodes, stored as 8x8 = 64 values
// We use two Arr8 per row for simplicity (just 8 nodes, 8 edges max per node)
type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if (i == 0) { return a.e0; }  if (i == 1) { return a.e1; }
    if (i == 2) { return a.e2; }  if (i == 3) { return a.e3; }
    if (i == 4) { return a.e4; }  if (i == 5) { return a.e5; }
    if (i == 6) { return a.e6; }  a.e7
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if (i == 0) { v } else { a.e0 }, e1: if (i == 1) { v } else { a.e1 },
        e2: if (i == 2) { v } else { a.e2 }, e3: if (i == 3) { v } else { a.e3 },
        e4: if (i == 4) { v } else { a.e4 }, e5: if (i == 5) { v } else { a.e5 },
        e6: if (i == 6) { v } else { a.e6 }, e7: if (i == 7) { v } else { a.e7 }
    }
}

fn a8_zeros() -> Arr8 { Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 } }

// Graph represented as 8 rows of adjacency (1 = edge, 0 = no edge)
type Graph8 is { r0: Arr8, r1: Arr8, r2: Arr8, r3: Arr8, r4: Arr8, r5: Arr8, r6: Arr8, r7: Arr8 };

fn g8_get_row(g: Graph8, r: Int) -> Arr8 {
    if (r == 0) { return g.r0; }  if (r == 1) { return g.r1; }
    if (r == 2) { return g.r2; }  if (r == 3) { return g.r3; }
    if (r == 4) { return g.r4; }  if (r == 5) { return g.r5; }
    if (r == 6) { return g.r6; }  g.r7
}

fn g8_has_edge(g: Graph8, from: Int, to: Int) -> Int {
    a8_get(g8_get_row(g, from), to)
}

fn g8_empty() -> Graph8 {
    Graph8 { r0: a8_zeros(), r1: a8_zeros(), r2: a8_zeros(), r3: a8_zeros(),
             r4: a8_zeros(), r5: a8_zeros(), r6: a8_zeros(), r7: a8_zeros() }
}

fn g8_set_row(g: Graph8, r: Int, row: Arr8) -> Graph8 {
    Graph8 {
        r0: if (r == 0) { row } else { g.r0 }, r1: if (r == 1) { row } else { g.r1 },
        r2: if (r == 2) { row } else { g.r2 }, r3: if (r == 3) { row } else { g.r3 },
        r4: if (r == 4) { row } else { g.r4 }, r5: if (r == 5) { row } else { g.r5 },
        r6: if (r == 6) { row } else { g.r6 }, r7: if (r == 7) { row } else { g.r7 }
    }
}

fn g8_add_edge(g: Graph8, from: Int, to: Int) -> Graph8 {
    let row = g8_get_row(g, from);
    let new_row = a8_set(row, to, 1);
    g8_set_row(g, from, new_row)
}

// BFS from source, returns distance array (-1 if unreachable)
fn bfs_distances(g: Graph8, src: Int, n: Int) -> Arr8 {
    let mut dist = Arr8 { e0: -1, e1: -1, e2: -1, e3: -1, e4: -1, e5: -1, e6: -1, e7: -1 };
    dist = a8_set(dist, src, 0);

    // Simple iterative BFS: repeatedly relax until no changes
    let mut changed = 1;
    while (changed == 1) {
        changed = 0;
        let mut u = 0;
        while (u < n) {
            let du = a8_get(dist, u);
            if (du >= 0) {
                let mut v = 0;
                while (v < n) {
                    if (g8_has_edge(g, u, v) == 1) {
                        let dv = a8_get(dist, v);
                        if (dv < 0) {
                            dist = a8_set(dist, v, du + 1);
                            changed = 1;
                        } else {
                            if (du + 1 < dv) {
                                dist = a8_set(dist, v, du + 1);
                                changed = 1;
                            }
                        }
                    }
                    v = v + 1;
                }
            }
            u = u + 1;
        }
    }
    dist
}

// DFS from source, returns visited array (1 = visited, 0 = not)
fn dfs_visited(g: Graph8, src: Int, n: Int) -> Arr8 {
    let mut vis = a8_zeros();
    vis = a8_set(vis, src, 1);

    // Iterative DFS simulation: keep finding unvisited neighbors
    let mut progress = 1;
    while (progress == 1) {
        progress = 0;
        let mut u = 0;
        while (u < n) {
            if (a8_get(vis, u) == 1) {
                let mut v = 0;
                while (v < n) {
                    if (g8_has_edge(g, u, v) == 1) {
                        if (a8_get(vis, v) == 0) {
                            vis = a8_set(vis, v, 1);
                            progress = 1;
                        }
                    }
                    v = v + 1;
                }
            }
            u = u + 1;
        }
    }
    vis
}

// Count reachable nodes from source
fn count_reachable(g: Graph8, src: Int, n: Int) -> Int {
    let vis = dfs_visited(g, src, n);
    let mut count = 0;
    let mut i = 0;
    while (i < n) {
        count = count + a8_get(vis, i);
        i = i + 1;
    }
    count
}

// Count edges in graph
fn count_edges(g: Graph8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while (i < n) {
        let mut j = 0;
        while (j < n) {
            count = count + g8_has_edge(g, i, j);
            j = j + 1;
        }
        i = i + 1;
    }
    count
}

// Node degree (out-degree)
fn out_degree(g: Graph8, node: Int, n: Int) -> Int {
    let mut deg = 0;
    let mut j = 0;
    while (j < n) {
        deg = deg + g8_has_edge(g, node, j);
        j = j + 1;
    }
    deg
}

fn main() -> Int {
    // Build a graph: 0->1->2->3->4, 0->2, 3->5, 4->5, 5->6, 6->7
    let mut g = g8_empty();
    g = g8_add_edge(g, 0, 1);
    g = g8_add_edge(g, 1, 2);
    g = g8_add_edge(g, 2, 3);
    g = g8_add_edge(g, 3, 4);
    g = g8_add_edge(g, 0, 2);
    g = g8_add_edge(g, 3, 5);
    g = g8_add_edge(g, 4, 5);
    g = g8_add_edge(g, 5, 6);
    g = g8_add_edge(g, 6, 7);

    // Edge count
    assert_eq(count_edges(g, 8), 9);

    // Out degrees
    assert_eq(out_degree(g, 0, 8), 2);
    assert_eq(out_degree(g, 1, 8), 1);
    assert_eq(out_degree(g, 7, 8), 0);

    // BFS from 0
    let dist0 = bfs_distances(g, 0, 8);
    assert_eq(a8_get(dist0, 0), 0);
    assert_eq(a8_get(dist0, 1), 1);
    assert_eq(a8_get(dist0, 2), 1);   // direct edge 0->2
    assert_eq(a8_get(dist0, 3), 2);   // 0->2->3
    assert_eq(a8_get(dist0, 4), 3);   // 0->2->3->4
    assert_eq(a8_get(dist0, 5), 3);   // 0->2->3->5
    assert_eq(a8_get(dist0, 6), 4);
    assert_eq(a8_get(dist0, 7), 5);

    // BFS from 3
    let dist3 = bfs_distances(g, 3, 8);
    assert_eq(a8_get(dist3, 3), 0);
    assert_eq(a8_get(dist3, 4), 1);
    assert_eq(a8_get(dist3, 5), 1);
    assert_eq(a8_get(dist3, 6), 2);
    assert_eq(a8_get(dist3, 7), 3);
    assert_eq(a8_get(dist3, 0), -1);  // 0 not reachable from 3

    // DFS reachability
    assert_eq(count_reachable(g, 0, 8), 8);   // all reachable from 0
    assert_eq(count_reachable(g, 7, 8), 1);   // 7 has no outgoing edges
    assert_eq(count_reachable(g, 5, 8), 3);   // 5,6,7

    // Build a cycle graph: 0->1->2->3->0
    let mut cyc = g8_empty();
    cyc = g8_add_edge(cyc, 0, 1);
    cyc = g8_add_edge(cyc, 1, 2);
    cyc = g8_add_edge(cyc, 2, 3);
    cyc = g8_add_edge(cyc, 3, 0);
    assert_eq(count_edges(cyc, 4), 4);
    assert_eq(count_reachable(cyc, 0, 4), 4);
    let dist_cyc = bfs_distances(cyc, 0, 4);
    assert_eq(a8_get(dist_cyc, 0), 0);
    assert_eq(a8_get(dist_cyc, 1), 1);
    assert_eq(a8_get(dist_cyc, 2), 2);
    assert_eq(a8_get(dist_cyc, 3), 3);

    // Build a complete graph on 4 nodes
    let mut k4 = g8_empty();
    let mut i = 0;
    while (i < 4) {
        let mut j = 0;
        while (j < 4) {
            if (i != j) { k4 = g8_add_edge(k4, i, j); }
            j = j + 1;
        }
        i = i + 1;
    }
    assert_eq(count_edges(k4, 4), 12);
    let dk4 = bfs_distances(k4, 0, 4);
    // All nodes reachable in 1 step
    assert_eq(a8_get(dk4, 1), 1);
    assert_eq(a8_get(dk4, 2), 1);
    assert_eq(a8_get(dk4, 3), 1);

    // Disconnected graph
    let mut disc = g8_empty();
    disc = g8_add_edge(disc, 0, 1);
    disc = g8_add_edge(disc, 2, 3);
    assert_eq(count_reachable(disc, 0, 4), 2);  // 0,1
    assert_eq(count_reachable(disc, 2, 4), 2);  // 2,3
    let dd = bfs_distances(disc, 0, 4);
    assert_eq(a8_get(dd, 2), -1);  // 2 not reachable from 0

    print("844_stress_graph_algorithms: PASS");
    0
}
