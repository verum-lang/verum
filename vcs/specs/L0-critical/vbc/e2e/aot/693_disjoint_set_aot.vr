// @test: run
// @level: L0
// @tags: aot, e2e, union-find, disjoint-set, graph
// @timeout: 30000

// Union-Find (Disjoint Set Union) data structure

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// Initialize: parent[i] = i (each element is its own root)
fn dsu_init(n: Int) -> Arr8 {
    let mut parent = Arr8 { v0: 0, v1: 1, v2: 2, v3: 3, v4: 4, v5: 5, v6: 6, v7: 7 };
    parent
}

// Find root (with path compression via iterative chase)
fn dsu_find(parent: Arr8, x: Int) -> Int {
    let mut p = x;
    while get8(parent, p) != p {
        p = get8(parent, p);
    }
    p
}

// Find with path compression (returns new parent array)
fn dsu_find_compress(parent: Arr8, x: Int) -> Arr8 {
    let root = dsu_find(parent, x);
    // Path compression: set all nodes on path to point directly to root
    let mut p = parent;
    let mut cur = x;
    while cur != root {
        let next = get8(p, cur);
        p = set8(p, cur, root);
        cur = next;
    }
    p
}

// Union two sets (union by rank approximation: always attach smaller root to larger)
fn dsu_union(parent: Arr8, rank: Arr8, x: Int, y: Int) -> Arr8 {
    let rx = dsu_find(parent, x);
    let ry = dsu_find(parent, y);
    if rx == ry { parent }
    else {
        if get8(rank, rx) < get8(rank, ry) {
            set8(parent, rx, ry)
        } else {
            set8(parent, ry, rx)
        }
    }
}

// Update rank after union
fn dsu_union_rank(parent: Arr8, rank: Arr8, x: Int, y: Int) -> Arr8 {
    let rx = dsu_find(parent, x);
    let ry = dsu_find(parent, y);
    if rx == ry { rank }
    else {
        if get8(rank, rx) == get8(rank, ry) {
            set8(rank, rx, get8(rank, rx) + 1)
        } else { rank }
    }
}

// Check if two elements are in the same set
fn dsu_connected(parent: Arr8, x: Int, y: Int) -> Int {
    if dsu_find(parent, x) == dsu_find(parent, y) { 1 } else { 0 }
}

// Count distinct sets
fn dsu_count(parent: Arr8, n: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if dsu_find(parent, i) == i { count = count + 1; }
        i = i + 1;
    }
    count
}

// Size of set containing x
fn dsu_set_size(parent: Arr8, n: Int, x: Int) -> Int {
    let root = dsu_find(parent, x);
    let mut count = 0;
    let mut i = 0;
    while i < n {
        if dsu_find(parent, i) == root { count = count + 1; }
        i = i + 1;
    }
    count
}

fn test_init() -> Int {
    let p = dsu_init(6);
    // Each element is its own root
    assert_eq(dsu_count(p, 6), 6);
    assert_eq(dsu_find(p, 0), 0);
    assert_eq(dsu_find(p, 3), 3);
    assert_eq(dsu_connected(p, 0, 1), 0);
    1
}

fn test_union() -> Int {
    let mut p = dsu_init(6);
    let mut r = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Union 0 and 1
    r = dsu_union_rank(p, r, 0, 1);
    p = dsu_union(p, r, 0, 1);
    assert_eq(dsu_connected(p, 0, 1), 1);
    assert_eq(dsu_count(p, 6), 5);
    // Union 2 and 3
    r = dsu_union_rank(p, r, 2, 3);
    p = dsu_union(p, r, 2, 3);
    assert_eq(dsu_connected(p, 2, 3), 1);
    assert_eq(dsu_count(p, 6), 4);
    // Union 0 and 2 (merges {0,1} and {2,3})
    r = dsu_union_rank(p, r, 0, 2);
    p = dsu_union(p, r, 0, 2);
    assert_eq(dsu_connected(p, 0, 3), 1);
    assert_eq(dsu_connected(p, 1, 2), 1);
    assert_eq(dsu_count(p, 6), 3);
    assert_eq(dsu_set_size(p, 6, 0), 4);
    1
}

fn test_idempotent() -> Int {
    let mut p = dsu_init(4);
    let mut r = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    r = dsu_union_rank(p, r, 0, 1);
    p = dsu_union(p, r, 0, 1);
    let count1 = dsu_count(p, 4);
    // Union same pair again: no change
    r = dsu_union_rank(p, r, 0, 1);
    p = dsu_union(p, r, 0, 1);
    assert_eq(dsu_count(p, 4), count1);
    1
}

fn test_chain() -> Int {
    let mut p = dsu_init(5);
    let mut r = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    // Chain: 0-1, 1-2, 2-3, 3-4
    r = dsu_union_rank(p, r, 0, 1); p = dsu_union(p, r, 0, 1);
    r = dsu_union_rank(p, r, 1, 2); p = dsu_union(p, r, 1, 2);
    r = dsu_union_rank(p, r, 2, 3); p = dsu_union(p, r, 2, 3);
    r = dsu_union_rank(p, r, 3, 4); p = dsu_union(p, r, 3, 4);
    // All connected
    assert_eq(dsu_count(p, 5), 1);
    assert_eq(dsu_connected(p, 0, 4), 1);
    assert_eq(dsu_set_size(p, 5, 2), 5);
    1
}

fn test_path_compression() -> Int {
    let mut p = dsu_init(4);
    // Create chain: 3->2->1->0
    p = set8(p, 3, 2);
    p = set8(p, 2, 1);
    p = set8(p, 1, 0);
    // Find should follow chain
    assert_eq(dsu_find(p, 3), 0);
    // After compression, 3 should point directly to 0
    p = dsu_find_compress(p, 3);
    assert_eq(get8(p, 3), 0);
    assert_eq(get8(p, 2), 0);
    assert_eq(get8(p, 1), 0);
    1
}

fn main() -> Int {
    test_init();
    test_union();
    test_idempotent();
    test_chain();
    test_path_compression();
    print("[OK] 693_disjoint_set_aot");
    0
}
