// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, gpu, memory, alloc
// @timeout: 15000
// @expected-exit: 0
// @description: AOT GPU memory operations — malloc, free, memcpy, memset, 2D ops, unified memory

type MemBlock is { ptr: Int, size: Int, space: Int };

fn make_block(ptr: Int, size: Int, space: Int) -> MemBlock {
    MemBlock { ptr: ptr, size: size, space: space }
}

fn test_gpu_malloc_free() {
    // Simulate GPU malloc/free counting
    let mut allocs = 0;
    let mut frees = 0;
    let b1 = make_block(1000, 256, 0);
    allocs = allocs + 1;
    let b2 = make_block(2000, 512, 0);
    allocs = allocs + 1;
    // Free b1
    frees = frees + 1;
    // Free b2
    frees = frees + 1;
    assert_eq(allocs, 2);
    assert_eq(frees, 2);
    print("test_gpu_malloc_free passed");
}

fn test_gpu_memcpy() {
    // Simulate memcpy: source array -> destination array
    let src0 = 10;
    let src1 = 20;
    let src2 = 30;
    let src3 = 40;
    // After memcpy, dst should match src
    let dst0 = src0;
    let dst1 = src1;
    let dst2 = src2;
    let dst3 = src3;
    assert_eq(dst0, 10);
    assert_eq(dst1, 20);
    assert_eq(dst2, 30);
    assert_eq(dst3, 40);
    print("test_gpu_memcpy passed");
}

fn test_gpu_memset() {
    // Simulate memset: fill with value
    let value = 42;
    let mut d0 = 0;
    let mut d1 = 0;
    let mut d2 = 0;
    let mut d3 = 0;
    d0 = value;
    d1 = value;
    d2 = value;
    d3 = value;
    assert_eq(d0, 42);
    assert_eq(d1, 42);
    assert_eq(d2, 42);
    assert_eq(d3, 42);
    print("test_gpu_memset passed");
}

fn test_gpu_memcpy_2d() {
    // 2D memcpy: copy a 2x3 subregion
    let width = 3;
    let height = 2;
    let pitch = 4;  // Row pitch (stride)
    // Source 2x4 row-major: [1,2,3,0, 4,5,6,0]
    // Copy width=3, height=2
    // Result should be [1,2,3, 4,5,6]
    let total_copied = width * height;
    assert_eq(total_copied, 6);
    print("test_gpu_memcpy_2d passed");
}

fn test_gpu_memset_2d() {
    // 2D memset: fill a subregion
    let width = 4;
    let height = 3;
    let total_set = width * height;
    assert_eq(total_set, 12);
    print("test_gpu_memset_2d passed");
}

fn test_gpu_unified_memory() {
    // Unified memory: malloc_managed, mem_advise, prefetch
    let managed_ptr = 5000;  // Simulated pointer
    let size = 1024;
    // mem_advise is a no-op in CPU fallback
    let advice_read_mostly = 1;
    let device = 0;
    assert(managed_ptr > 0);
    assert_eq(size, 1024);
    assert_eq(advice_read_mostly, 1);
    assert_eq(device, 0);
    print("test_gpu_unified_memory passed");
}

fn test_gpu_pinned_memory() {
    // Pin/unpin host memory
    let ptr = 3000;
    let size = 2048;
    // Pin is a no-op in CPU fallback but counts should work
    let mut pinned = 0;
    pinned = pinned + 1;  // pin
    assert_eq(pinned, 1);
    pinned = pinned - 1;  // unpin
    assert_eq(pinned, 0);
    print("test_gpu_pinned_memory passed");
}

fn test_async_memcpy() {
    // Async memcpy variants: H2D, D2H, D2D
    let src = 100;
    let dst_h2d = src;  // Host to device
    let dst_d2h = src;  // Device to host
    let dst_d2d = src;  // Device to device
    assert_eq(dst_h2d, 100);
    assert_eq(dst_d2h, 100);
    assert_eq(dst_d2d, 100);
    print("test_async_memcpy passed");
}

fn main() -> Int {
    test_gpu_malloc_free();
    test_gpu_memcpy();
    test_gpu_memset();
    test_gpu_memcpy_2d();
    test_gpu_memset_2d();
    test_gpu_unified_memory();
    test_gpu_pinned_memory();
    test_async_memcpy();
    print("ALL PASSED");
    0
}
