// @test: run
// Generic struct field access preserves type tracking

type Pair<A, B> is { first: A, second: B };

fn make_list_text_pair() -> Pair<List<Int>, Text> {
    let nums = List.new();
    nums.push(10);
    nums.push(20);
    Pair { first: nums, second: "hello" }
}

fn make_text_list_pair() -> Pair<Text, List<Int>> {
    let nums = List.new();
    nums.push(1);
    nums.push(2);
    nums.push(3);
    Pair { first: "world", second: nums }
}

fn main() -> Int {
    let mut passed = 0;
    let mut failed = 0;

    // Test 1: List field from generic struct
    let p1 = make_list_text_pair();
    let list1 = p1.first;
    if (list1.len() == 2) { passed = passed + 1; }
    else { print(f"FAIL 1: list1.len()={list1.len()}"); failed = failed + 1; }

    // Test 2: Text field from generic struct
    let text1 = p1.second;
    if (text1.len() == 5) { passed = passed + 1; }
    else { print(f"FAIL 2: text1.len()={text1.len()}"); failed = failed + 1; }

    // Test 3: Reversed order — Text first, List second
    let p2 = make_text_list_pair();
    let text2 = p2.first;
    if (text2.len() == 5) { passed = passed + 1; }
    else { print(f"FAIL 3: text2.len()={text2.len()}"); failed = failed + 1; }

    // Test 4: List in second position
    let list2 = p2.second;
    if (list2.len() == 3) { passed = passed + 1; }
    else { print(f"FAIL 4: list2.len()={list2.len()}"); failed = failed + 1; }

    // Test 5: Push to list from generic field
    let p3 = make_list_text_pair();
    let mut items = p3.first;
    items.push(30);
    if (items.len() == 3) { passed = passed + 1; }
    else { print(f"FAIL 5: items.len()={items.len()}"); failed = failed + 1; }

    if (failed > 0) {
        print(f"generic_field_tracking: {passed}/{passed + failed} passed");
        return 1;
    }
    print(f"generic_field_tracking: PASS ({passed}/{passed} tests)");
    0
}
