// @test: run
// @tier: 2
// @level: L0
// @tags: e2e, aot, topological-sort, kahn, dag, graph
// @timeout: 30000
// @expected-exit: 0
//
// Topological sort via Kahn's algorithm on a small DAG.
// Adjacency list stored flat in Arr16. Compute in-degrees,
// process zero-degree vertices, verify all visited and ordering.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int, a12: Int, a13: Int, a14: Int, a15: Int
};

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 } else if i == 2 { a.a2 }
    else if i == 3 { a.a3 } else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 } else if i == 8 { a.a8 }
    else if i == 9 { a.a9 } else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 } else if i == 14 { a.a14 }
    else { a.a15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 }, a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 }, a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 }, a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 }, a15: if i == 15 { v } else { a.a15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
            a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0 }
}

// Graph: adjacency matrix stored in Arr16 (up to 4x4 = 16 slots)
// adj[i*n+j] = 1 if edge from i to j

// Kahn's algorithm result
type TopoResult is { order: Arr8, count: Int };

fn topo_sort(adj: Arr16, n: Int) -> TopoResult {
    // Step 1: Compute in-degrees
    let mut indeg = a8_zero();
    let mut j = 0;
    while j < n {
        let mut cnt = 0;
        let mut i = 0;
        while i < n {
            cnt = cnt + a16_get(adj, i * n + j);
            i = i + 1;
        }
        indeg = a8_set(indeg, j, cnt);
        j = j + 1;
    }

    // Step 2: Initialize queue with zero in-degree vertices
    let mut queue = a8_zero();
    let mut qhead = 0;
    let mut qtail = 0;
    let mut i = 0;
    while i < n {
        if a8_get(indeg, i) == 0 {
            queue = a8_set(queue, qtail, i);
            qtail = qtail + 1;
        }
        i = i + 1;
    }

    // Step 3: Process queue
    let mut order = a8_zero();
    let mut count = 0;
    while qhead < qtail {
        let u = a8_get(queue, qhead);
        qhead = qhead + 1;
        order = a8_set(order, count, u);
        count = count + 1;
        // For each neighbor v of u, decrement in-degree
        let mut v = 0;
        while v < n {
            if a16_get(adj, u * n + v) == 1 {
                let new_deg = a8_get(indeg, v) - 1;
                indeg = a8_set(indeg, v, new_deg);
                if new_deg == 0 {
                    queue = a8_set(queue, qtail, v);
                    qtail = qtail + 1;
                }
            }
            v = v + 1;
        }
    }
    TopoResult { order: order, count: count }
}

// Check that ordering is valid: for every edge u->v, u appears before v in order
fn is_valid_topo(adj: Arr16, n: Int, result: TopoResult) -> Int {
    // Build position map: pos[vertex] = index in order
    let mut pos = a8_zero();
    let mut i = 0;
    while i < result.count {
        let vertex = a8_get(result.order, i);
        pos = a8_set(pos, vertex, i);
        i = i + 1;
    }
    // Check every edge
    let mut u = 0;
    while u < n {
        let mut v = 0;
        while v < n {
            if a16_get(adj, u * n + v) == 1 {
                // u must come before v in topological order
                if a8_get(pos, u) >= a8_get(pos, v) {
                    return 0;
                }
            }
            v = v + 1;
        }
        u = u + 1;
    }
    1
}

// ========== Tests ==========

fn test_linear_dag() -> Int {
    // DAG: 0 -> 1 -> 2 -> 3
    let mut adj = a16_zero();
    adj = a16_set(adj, 0 * 4 + 1, 1);
    adj = a16_set(adj, 1 * 4 + 2, 1);
    adj = a16_set(adj, 2 * 4 + 3, 1);
    let result = topo_sort(adj, 4);
    assert_eq(result.count, 4);
    assert_eq(is_valid_topo(adj, 4, result), 1);
    // Only valid order is 0,1,2,3
    assert_eq(a8_get(result.order, 0), 0);
    assert_eq(a8_get(result.order, 1), 1);
    0
}

fn test_linear_tail() -> Int {
    let mut adj = a16_zero();
    adj = a16_set(adj, 0 * 4 + 1, 1);
    adj = a16_set(adj, 1 * 4 + 2, 1);
    adj = a16_set(adj, 2 * 4 + 3, 1);
    let result = topo_sort(adj, 4);
    assert_eq(a8_get(result.order, 2), 2);
    assert_eq(a8_get(result.order, 3), 3);
    0
}

fn test_diamond_dag() -> Int {
    // DAG: 0 -> 1, 0 -> 2, 1 -> 3, 2 -> 3
    let mut adj = a16_zero();
    adj = a16_set(adj, 0 * 4 + 1, 1);
    adj = a16_set(adj, 0 * 4 + 2, 1);
    adj = a16_set(adj, 1 * 4 + 3, 1);
    adj = a16_set(adj, 2 * 4 + 3, 1);
    let result = topo_sort(adj, 4);
    assert_eq(result.count, 4);
    assert_eq(is_valid_topo(adj, 4, result), 1);
    // 0 must be first, 3 must be last
    assert_eq(a8_get(result.order, 0), 0);
    assert_eq(a8_get(result.order, 3), 3);
    0
}

fn test_disconnected() -> Int {
    // No edges: all vertices are independent
    let adj = a16_zero();
    let result = topo_sort(adj, 4);
    assert_eq(result.count, 4);
    assert_eq(is_valid_topo(adj, 4, result), 1);
    0
}

fn test_two_sources() -> Int {
    // 0 -> 2, 1 -> 2, 2 -> 3
    let mut adj = a16_zero();
    adj = a16_set(adj, 0 * 4 + 2, 1);
    adj = a16_set(adj, 1 * 4 + 2, 1);
    adj = a16_set(adj, 2 * 4 + 3, 1);
    let result = topo_sort(adj, 4);
    assert_eq(result.count, 4);
    assert_eq(is_valid_topo(adj, 4, result), 1);
    // 3 must be last
    assert_eq(a8_get(result.order, 3), 3);
    0
}

fn test_fan_out() -> Int {
    // 0 -> 1, 0 -> 2, 0 -> 3
    let mut adj = a16_zero();
    adj = a16_set(adj, 0 * 4 + 1, 1);
    adj = a16_set(adj, 0 * 4 + 2, 1);
    adj = a16_set(adj, 0 * 4 + 3, 1);
    let result = topo_sort(adj, 4);
    assert_eq(result.count, 4);
    assert_eq(is_valid_topo(adj, 4, result), 1);
    assert_eq(a8_get(result.order, 0), 0);
    0
}

fn test_complex_dag() -> Int {
    // 0->1, 0->2, 1->3, 2->3, 1->2
    let mut adj = a16_zero();
    adj = a16_set(adj, 0 * 4 + 1, 1);
    adj = a16_set(adj, 0 * 4 + 2, 1);
    adj = a16_set(adj, 1 * 4 + 3, 1);
    adj = a16_set(adj, 2 * 4 + 3, 1);
    adj = a16_set(adj, 1 * 4 + 2, 1);
    let result = topo_sort(adj, 4);
    assert_eq(result.count, 4);
    assert_eq(is_valid_topo(adj, 4, result), 1);
    0
}

fn test_single_vertex() -> Int {
    let adj = a16_zero();
    let result = topo_sort(adj, 1);
    assert_eq(result.count, 1);
    assert_eq(a8_get(result.order, 0), 0);
    0
}

fn test_two_vertices() -> Int {
    let mut adj = a16_zero();
    adj = a16_set(adj, 0 * 2 + 1, 1);
    let result = topo_sort(adj, 2);
    assert_eq(result.count, 2);
    assert_eq(a8_get(result.order, 0), 0);
    assert_eq(a8_get(result.order, 1), 1);
    0
}

fn main() -> Int {
    test_linear_dag();
    test_linear_tail();
    test_diamond_dag();
    test_disconnected();
    test_two_sources();
    test_fan_out();
    test_complex_dag();
    test_single_vertex();
    test_two_vertices();
    print("[OK] 402_topological_sort_aot");
    0
}
