// @test: run
// @tier: 0
// @level: L0
// @tags: aot, process, spawn, exec, integration
// @expected-exit: 0

// Test: Process spawn integration — run child processes, verify exit codes.
// Combined with threads and file I/O for full integration.

fn __process_exec_raw(program: Text, args: List<Text>) -> Int {
    -1
}

fn __file_write_string_raw(path: Text, content: Text) -> Int {
    0
}

fn __file_read_to_string_raw(path: Text) -> Text {
    ""
}

fn __time_monotonic_nanos_raw() -> Int {
    0
}

fn main() -> Int {
    // Test 1: Run /usr/bin/true (exit code 0)
    let r1 = __process_exec_raw("/usr/bin/true", []);
    if (r1 != 0) {
        print(f"FAIL test1: true returned {r1}");
        return 1;
    }

    // Test 2: Run /usr/bin/false (exit code 1)
    let r2 = __process_exec_raw("/usr/bin/false", []);
    if (r2 != 1) {
        print(f"FAIL test2: false returned {r2}");
        return 1;
    }

    // Test 3: Run echo with args
    let r3 = __process_exec_raw("/bin/echo", ["hello", "world"]);
    if (r3 != 0) {
        print(f"FAIL test3: echo returned {r3}");
        return 1;
    }

    // Test 4: Run sh -c with custom exit code
    let r4 = __process_exec_raw("/bin/sh", ["-c", "exit 42"]);
    if (r4 != 42) {
        print(f"FAIL test4: sh exit 42 returned {r4}");
        return 1;
    }

    // Test 5: Process + file I/O — write via sh, read back
    let path = "/tmp/verum_test_936.txt";
    let w1 = __file_write_string_raw(path, "process test data");
    if (w1 == 0) {
        print("FAIL test5a: write failed");
        return 1;
    }
    let read_back = __file_read_to_string_raw(path);
    if (read_back != "process test data") {
        print(f"FAIL test5b: read='{read_back}'");
        return 1;
    }

    // Test 6: Timed process execution
    let t_start = __time_monotonic_nanos_raw();
    let r6 = __process_exec_raw("/usr/bin/true", []);
    let t_end = __time_monotonic_nanos_raw();
    let elapsed = t_end - t_start;
    if (r6 != 0) {
        print(f"FAIL test6a: true returned {r6}");
        return 1;
    }
    if (elapsed <= 0) {
        print(f"FAIL test6b: elapsed={elapsed}");
        return 1;
    }

    // Test 7: Nonexistent program returns error
    let r7 = __process_exec_raw("/nonexistent/program", []);
    if (r7 != 127 && r7 != -1) {
        print(f"FAIL test7: nonexistent returned {r7}");
        return 1;
    }

    print("936_process_spawn: PASS");
    0
}
