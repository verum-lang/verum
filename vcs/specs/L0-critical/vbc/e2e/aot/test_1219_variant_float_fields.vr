// @test: run
// @level: L0
// @tier: 0
// @tags: variant, float, match, multi-field, regression, e2e
// @description: Test float fields in variant destructuring — regression for payload type resolution

type Shape is Circle(Float) | Rect(Float, Float) | Triangle(Float, Float, Float);

fn area(s: Shape) -> Float {
    match s {
        Shape.Circle(r) => 3.14159 * r * r,
        Shape.Rect(w, h) => w * h,
        Shape.Triangle(a, b, c) => {
            // Heron's formula
            let s = (a + b + c) / 2.0;
            let sq = s * (s - a) * (s - b) * (s - c);
            // sqrt approximation via Newton's method (3 iterations)
            let mut x = sq / 2.0;
            x = (x + sq / x) / 2.0;
            x = (x + sq / x) / 2.0;
            x = (x + sq / x) / 2.0;
            x
        },
    }
}

type Val is Num(Float) | None;

fn double(v: Val) -> Float {
    match v {
        Val.Num(x) => x * 2.0,
        Val.None => 0.0,
    }
}

type Pair is P(Float, Float);

fn sum_pair(p: Pair) -> Float {
    match p {
        Pair.P(a, b) => a + b,
    }
}

fn main() -> Int {
    let mut f = 0;

    // Test 1: Circle area
    let ca = area(Shape.Circle(5.0));
    if ca < 78.5 || ca > 78.6 {
        print(f"FAIL 1: circle area = {ca}");
        f = f + 1;
    }

    // Test 2: Rect area (multi-field float)
    let ra = area(Shape.Rect(3.0, 4.0));
    if ra < 11.9 || ra > 12.1 {
        print(f"FAIL 2: rect area = {ra}");
        f = f + 1;
    }

    // Test 3: Triangle area (3 float fields)
    let ta = area(Shape.Triangle(3.0, 4.0, 5.0));
    if ta < 5.9 || ta > 6.1 {
        print(f"FAIL 3: triangle area = {ta}");
        f = f + 1;
    }

    // Test 4: Float variant x*x (single field self-multiply)
    let v = Val.Num(7.5);
    let d = double(v);
    if d < 14.9 || d > 15.1 {
        print(f"FAIL 4: double(7.5) = {d}");
        f = f + 1;
    }

    // Test 5: Pair sum (2 float fields)
    let ps = sum_pair(Pair.P(1.5, 2.5));
    if ps < 3.9 || ps > 4.1 {
        print(f"FAIL 5: sum_pair(1.5, 2.5) = {ps}");
        f = f + 1;
    }

    // Test 6: Direct match in same scope
    let direct = match Shape.Rect(2.5, 3.5) {
        Shape.Circle(r) => r,
        Shape.Rect(w, h) => w * h,
        Shape.Triangle(_, _, _) => 0.0,
    };
    if direct < 8.7 || direct > 8.8 {
        print(f"FAIL 6: direct rect = {direct}");
        f = f + 1;
    }

    if f == 0 {
        print("All variant float field tests passed");
    }
    f
}
