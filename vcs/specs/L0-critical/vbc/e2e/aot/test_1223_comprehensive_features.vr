// @test: run
// @level: L0
// @tier: 0
// @tags: comprehensive, closures, generics, variants, result, e2e
// @description: Comprehensive test combining closures, generics, variants, Result, match, structs

// === Generic Maybe operations ===
fn map_maybe(m: Maybe<Int>, f: fn(Int) -> Int) -> Maybe<Int> {
    match m {
        Some(v) => Some(f(v)),
        None => None,
    }
}

fn unwrap_or(m: Maybe<Int>, default: Int) -> Int {
    match m {
        Some(v) => v,
        None => default,
    }
}

// === Error handling ===
fn safe_divide(a: Int, b: Int) -> Result<Int, Text> {
    if b == 0 {
        Err("division by zero")
    } else {
        Ok(a / b)
    }
}

fn chain_divide(a: Int, b: Int, c: Int) -> Result<Int, Text> {
    let r1 = safe_divide(a, b)?;
    let r2 = safe_divide(r1, c)?;
    Ok(r2)
}

// === Closures and HOF ===
fn fold(list: List<Int>, init: Int, f: fn(Int, Int) -> Int) -> Int {
    let mut acc = init;
    for item in list {
        acc = f(acc, item);
    }
    acc
}

fn make_counter(start: Int) -> fn() -> Int {
    let mut count = start;
    || {
        count = count + 1;
        count
    }
}

// === Sum types ===
type Shape is
    Circle { radius: Float } |
    Rectangle { width: Float, height: Float };

implement Shape {
    fn area(&self) -> Float {
        match self {
            Shape.Circle { radius } => 3.14159 * radius * radius,
            Shape.Rectangle { width, height } => width * height,
        }
    }
}

fn main() -> Int {
    let mut f = 0;

    // Test 1: Maybe map
    let m = map_maybe(Some(10), |x| x * 3);
    if unwrap_or(m, 0) != 30 {
        print(f"FAIL 1: map_maybe = {unwrap_or(m, 0)}");
        f = f + 1;
    }

    // Test 2: Maybe None
    let n = map_maybe(None, |x| x * 3);
    if unwrap_or(n, -1) != -1 {
        print(f"FAIL 2: None map should be -1");
        f = f + 1;
    }

    // Test 3: Error propagation
    match chain_divide(100, 5, 4) {
        Ok(v) => {
            if v != 5 {
                print(f"FAIL 3: chain = {v}");
                f = f + 1;
            }
        },
        Err(e) => {
            print(f"FAIL 3: error {e}");
            f = f + 1;
        },
    }

    // Test 4: Error propagation failure
    match chain_divide(100, 0, 4) {
        Ok(_) => {
            print("FAIL 4: should error");
            f = f + 1;
        },
        Err(e) => {
            if e != "division by zero" {
                print(f"FAIL 4: wrong error: {e}");
                f = f + 1;
            }
        },
    }

    // Test 5: Fold over list
    let nums = [1, 2, 3, 4, 5];
    let sum = fold(nums, 0, |acc, x| acc + x);
    if sum != 15 {
        print(f"FAIL 5: sum = {sum}");
        f = f + 1;
    }

    // Test 6: Fold product
    let product = fold([2, 3, 4], 1, |acc, x| acc * x);
    if product != 24 {
        print(f"FAIL 6: product = {product}");
        f = f + 1;
    }

    // Test 7: Mutable closure counter
    let counter = make_counter(0);
    let c1 = counter();
    let c2 = counter();
    let c3 = counter();
    if c1 != 1 || c2 != 2 || c3 != 3 {
        print(f"FAIL 7: counter = {c1}, {c2}, {c3}");
        f = f + 1;
    }

    // Test 8: Shape area
    let circle = Shape.Circle { radius: 5.0 };
    let rect = Shape.Rectangle { width: 3.0, height: 4.0 };
    let ca = circle.area();
    let ra = rect.area();
    if ca < 78.5 || ca > 78.6 {
        print(f"FAIL 8a: circle area = {ca}");
        f = f + 1;
    }
    if ra < 11.9 || ra > 12.1 {
        print(f"FAIL 8b: rect area = {ra}");
        f = f + 1;
    }

    if f == 0 {
        print("All comprehensive tests passed");
    }
    f
}
