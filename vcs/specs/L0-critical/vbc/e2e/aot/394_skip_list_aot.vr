// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, skip-list, sorted, probabilistic
// @timeout: 30000
// @expected-exit: 0
//
// AOT test for a skip list simulation with fixed levels.
// A skip list is a sorted linked list with multiple levels for O(log n) search.
// We simulate it using arrays: level 0 is the full sorted data,
// level 1 has every 2nd element, level 2 has every 4th element.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int };

fn a8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn a8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 }
    }
}

fn a8_zero() -> Arr8 {
    Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0 }
}

// Skip list with 3 levels:
// Level 0: full sorted data (up to 8 elements)
// Level 1: every 2nd element from level 0
// Level 2: every 4th element from level 0
type SkipList is {
    level0: Arr8, len0: Int,
    level1: Arr8, len1: Int,
    level2: Arr8, len2: Int
};

fn skip_new() -> SkipList {
    SkipList {
        level0: a8_zero(), len0: 0,
        level1: a8_zero(), len1: 0,
        level2: a8_zero(), len2: 0
    }
}

// Rebuild higher levels from level 0
fn skip_rebuild_levels(sl: SkipList) -> SkipList {
    let mut l1 = a8_zero();
    let mut l1_len = 0;
    let mut l2 = a8_zero();
    let mut l2_len = 0;
    let mut i = 0;
    while i < sl.len0 {
        if i % 2 == 0 {
            l1 = a8_set(l1, l1_len, a8_get(sl.level0, i));
            l1_len = l1_len + 1;
        }
        if i % 4 == 0 {
            l2 = a8_set(l2, l2_len, a8_get(sl.level0, i));
            l2_len = l2_len + 1;
        }
        i = i + 1;
    }
    SkipList {
        level0: sl.level0, len0: sl.len0,
        level1: l1, len1: l1_len,
        level2: l2, len2: l2_len
    }
}

// Insert a value into the skip list (maintains sorted order)
fn skip_insert(sl: SkipList, val: Int) -> SkipList {
    if sl.len0 >= 8 { return sl; } // full
    // Find insertion position in level 0
    let mut pos = 0;
    let mut found = 0;
    while found == 0 {
        if pos >= sl.len0 {
            found = 1;
        } else if a8_get(sl.level0, pos) >= val {
            found = 1;
        } else {
            pos = pos + 1;
        }
    }
    // Shift elements right
    let mut new_l0 = sl.level0;
    let mut j = sl.len0;
    while j > pos {
        new_l0 = a8_set(new_l0, j, a8_get(new_l0, j - 1));
        j = j - 1;
    }
    new_l0 = a8_set(new_l0, pos, val);
    let new_sl = SkipList {
        level0: new_l0, len0: sl.len0 + 1,
        level1: sl.level1, len1: sl.len1,
        level2: sl.level2, len2: sl.len2
    };
    skip_rebuild_levels(new_sl)
}

// Search using skip list levels (simulated multi-level search)
// Returns 1 if found, 0 if not found
fn skip_search(sl: SkipList, val: Int) -> Int {
    // Start at highest level, narrow down
    // Level 2: find the interval
    let mut start = 0;
    if sl.len2 > 0 {
        let mut i = 0;
        let mut found_start = 0;
        while i < sl.len2 {
            if a8_get(sl.level2, i) == val { return 1; }
            if a8_get(sl.level2, i) > val {
                if i > 0 {
                    // start searching from index corresponding to previous level2 entry
                    start = (i - 1) * 4;
                }
                found_start = 1;
                i = sl.len2; // exit loop
            } else {
                i = i + 1;
            }
        }
        if found_start == 0 {
            // val is larger than all level2 entries
            if sl.len2 > 0 {
                start = (sl.len2 - 1) * 4;
            }
        }
    }
    // Scan level 0 from start
    let mut i = start;
    while i < sl.len0 {
        if a8_get(sl.level0, i) == val { return 1; }
        if a8_get(sl.level0, i) > val { return 0; }
        i = i + 1;
    }
    0
}

// Delete a value from the skip list
fn skip_delete(sl: SkipList, val: Int) -> SkipList {
    // Find in level 0
    let mut pos = -1;
    let mut i = 0;
    while i < sl.len0 {
        if a8_get(sl.level0, i) == val {
            pos = i;
            i = sl.len0; // exit
        } else {
            i = i + 1;
        }
    }
    if pos == -1 { return sl; } // not found
    // Shift elements left
    let mut new_l0 = sl.level0;
    let mut j = pos;
    while j < sl.len0 - 1 {
        new_l0 = a8_set(new_l0, j, a8_get(new_l0, j + 1));
        j = j + 1;
    }
    new_l0 = a8_set(new_l0, sl.len0 - 1, 0);
    let new_sl = SkipList {
        level0: new_l0, len0: sl.len0 - 1,
        level1: sl.level1, len1: sl.len1,
        level2: sl.level2, len2: sl.len2
    };
    skip_rebuild_levels(new_sl)
}

// Get min and max
fn skip_min(sl: SkipList) -> Int {
    a8_get(sl.level0, 0)
}

fn skip_max(sl: SkipList) -> Int {
    a8_get(sl.level0, sl.len0 - 1)
}

// Count elements in range [lo, hi] inclusive
fn skip_range_count(sl: SkipList, lo: Int, hi: Int) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < sl.len0 {
        let v = a8_get(sl.level0, i);
        if v >= lo {
            if v <= hi {
                count = count + 1;
            }
        }
        i = i + 1;
    }
    count
}

// ========== Tests ==========

fn test_insert_sorted() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 30);
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 50);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 40);
    // Should be sorted: 10, 20, 30, 40, 50
    assert_eq(sl.len0, 5);
    assert_eq(a8_get(sl.level0, 0), 10);
    assert_eq(a8_get(sl.level0, 1), 20);
    assert_eq(a8_get(sl.level0, 2), 30);
    assert_eq(a8_get(sl.level0, 3), 40);
    assert_eq(a8_get(sl.level0, 4), 50);
}

fn test_levels_built() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 30);
    sl = skip_insert(sl, 40);
    sl = skip_insert(sl, 50);
    sl = skip_insert(sl, 60);
    sl = skip_insert(sl, 70);
    sl = skip_insert(sl, 80);
    // Level 0: [10,20,30,40,50,60,70,80] len=8
    assert_eq(sl.len0, 8);
    // Level 1: every 2nd = [10,30,50,70] len=4
    assert_eq(sl.len1, 4);
    assert_eq(a8_get(sl.level1, 0), 10);
    assert_eq(a8_get(sl.level1, 1), 30);
    assert_eq(a8_get(sl.level1, 2), 50);
    assert_eq(a8_get(sl.level1, 3), 70);
    // Level 2: every 4th = [10,50] len=2
    assert_eq(sl.len2, 2);
    assert_eq(a8_get(sl.level2, 0), 10);
    assert_eq(a8_get(sl.level2, 1), 50);
}

fn test_search_found() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 30);
    sl = skip_insert(sl, 40);
    sl = skip_insert(sl, 50);
    assert_eq(skip_search(sl, 10), 1);
    assert_eq(skip_search(sl, 30), 1);
    assert_eq(skip_search(sl, 50), 1);
}

fn test_search_not_found() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 30);
    assert_eq(skip_search(sl, 5), 0);
    assert_eq(skip_search(sl, 15), 0);
    assert_eq(skip_search(sl, 35), 0);
}

fn test_delete() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 30);
    sl = skip_insert(sl, 40);
    sl = skip_insert(sl, 50);
    assert_eq(sl.len0, 5);
    sl = skip_delete(sl, 30);
    assert_eq(sl.len0, 4);
    assert_eq(skip_search(sl, 30), 0);
    assert_eq(skip_search(sl, 20), 1);
    assert_eq(skip_search(sl, 40), 1);
    // Verify order: 10, 20, 40, 50
    assert_eq(a8_get(sl.level0, 0), 10);
    assert_eq(a8_get(sl.level0, 1), 20);
    assert_eq(a8_get(sl.level0, 2), 40);
    assert_eq(a8_get(sl.level0, 3), 50);
}

fn test_delete_first() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 30);
    sl = skip_delete(sl, 10);
    assert_eq(sl.len0, 2);
    assert_eq(a8_get(sl.level0, 0), 20);
    assert_eq(a8_get(sl.level0, 1), 30);
}

fn test_delete_last() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 30);
    sl = skip_delete(sl, 30);
    assert_eq(sl.len0, 2);
    assert_eq(a8_get(sl.level0, 0), 10);
    assert_eq(a8_get(sl.level0, 1), 20);
}

fn test_delete_nonexistent() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_delete(sl, 99);
    assert_eq(sl.len0, 2);
}

fn test_min_max() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 50);
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 30);
    sl = skip_insert(sl, 80);
    sl = skip_insert(sl, 20);
    assert_eq(skip_min(sl), 10);
    assert_eq(skip_max(sl), 80);
}

fn test_range_count() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 20);
    sl = skip_insert(sl, 30);
    sl = skip_insert(sl, 40);
    sl = skip_insert(sl, 50);
    sl = skip_insert(sl, 60);
    assert_eq(skip_range_count(sl, 20, 50), 4);
    assert_eq(skip_range_count(sl, 25, 45), 2);
    assert_eq(skip_range_count(sl, 10, 60), 6);
    assert_eq(skip_range_count(sl, 100, 200), 0);
}

fn test_insert_duplicates() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 10);
    sl = skip_insert(sl, 10);
    assert_eq(sl.len0, 3);
    assert_eq(a8_get(sl.level0, 0), 10);
    assert_eq(a8_get(sl.level0, 1), 10);
    assert_eq(a8_get(sl.level0, 2), 10);
    assert_eq(skip_search(sl, 10), 1);
}

fn test_empty_search() {
    let sl = skip_new();
    assert_eq(skip_search(sl, 42), 0);
}

fn test_single_element() {
    let mut sl = skip_new();
    sl = skip_insert(sl, 42);
    assert_eq(sl.len0, 1);
    assert_eq(skip_search(sl, 42), 1);
    assert_eq(skip_search(sl, 41), 0);
    assert_eq(skip_min(sl), 42);
    assert_eq(skip_max(sl), 42);
}

fn main() -> Int {
    test_insert_sorted();
    test_levels_built();
    test_search_found();
    test_search_not_found();
    test_delete();
    test_delete_first();
    test_delete_last();
    test_delete_nonexistent();
    test_min_max();
    test_range_count();
    test_insert_duplicates();
    test_empty_search();
    test_single_element();
    print("[OK] 394_skip_list_aot");
    0
}
