// @test: run
// @level: L0
// @tier: 1
// @tags: recursion, mutual, even-odd
// @description: Test mutual recursion patterns

@allow(unbounded_recursion)
fn is_even_rec(n: Int) -> Bool {
    if n == 0 {
        return true;
    }
    is_odd_rec(n - 1)
}

@allow(unbounded_recursion)
fn is_odd_rec(n: Int) -> Bool {
    if n == 0 {
        return false;
    }
    is_even_rec(n - 1)
}

fn test_even_odd() -> Int {
    if !is_even_rec(0) {
        print("FAIL: 0 should be even");
        return 1;
    }
    if !is_odd_rec(1) {
        print("FAIL: 1 should be odd");
        return 1;
    }
    if !is_even_rec(10) {
        print("FAIL: 10 should be even");
        return 1;
    }
    if !is_odd_rec(7) {
        print("FAIL: 7 should be odd");
        return 1;
    }
    if is_even_rec(3) {
        print("FAIL: 3 should not be even");
        return 1;
    }
    print("  even_odd: OK");
    0
}

// Mutual recursion with accumulator
@allow(unbounded_recursion)
fn ping(n: Int, acc: Int) -> Int {
    if n <= 0 {
        return acc;
    }
    pong(n - 1, acc + n)
}

@allow(unbounded_recursion)
fn pong(n: Int, acc: Int) -> Int {
    if n <= 0 {
        return acc;
    }
    ping(n - 1, acc + n)
}

fn test_ping_pong() -> Int {
    let result = ping(10, 0);
    // Sum of 1..10 = 55
    if result != 55 {
        print(f"FAIL ping_pong: {result}, expected 55");
        return 1;
    }
    print("  ping_pong: OK");
    0
}

// Simple recursive descent: count digits
@allow(unbounded_recursion)
fn count_digits(n: Int) -> Int {
    if n < 10 {
        return 1;
    }
    1 + count_digits(n / 10)
}

fn test_count_digits() -> Int {
    if count_digits(0) != 1 {
        print("FAIL: count_digits(0)");
        return 1;
    }
    if count_digits(9) != 1 {
        print("FAIL: count_digits(9)");
        return 1;
    }
    if count_digits(42) != 2 {
        print("FAIL: count_digits(42)");
        return 1;
    }
    if count_digits(12345) != 5 {
        print("FAIL: count_digits(12345)");
        return 1;
    }
    print("  count_digits: OK");
    0
}

// Ackermann function (limited inputs)
@allow(unbounded_recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 {
        return n + 1;
    }
    if n == 0 {
        return ackermann(m - 1, 1);
    }
    ackermann(m - 1, ackermann(m, n - 1))
}

fn test_ackermann() -> Int {
    // A(0,0) = 1
    if ackermann(0, 0) != 1 {
        print("FAIL: A(0,0)");
        return 1;
    }
    // A(1,1) = 3
    if ackermann(1, 1) != 3 {
        print("FAIL: A(1,1)");
        return 1;
    }
    // A(2,2) = 7
    if ackermann(2, 2) != 7 {
        print("FAIL: A(2,2)");
        return 1;
    }
    // A(3,2) = 29
    if ackermann(3, 2) != 29 {
        print("FAIL: A(3,2)");
        return 1;
    }
    print("  ackermann: OK");
    0
}

fn main() -> Int {
    print("Mutual Recursion Tests:");
    let mut failures = 0;
    failures = failures + test_even_odd();
    failures = failures + test_ping_pong();
    failures = failures + test_count_digits();
    failures = failures + test_ackermann();

    if failures == 0 {
        print("All mutual recursion tests passed!");
    } else {
        print(f"{failures} test(s) failed");
    }
    failures
}
