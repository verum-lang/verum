// @test: run
// @tier: 0
// @level: L0
// @tags: aot, recursion, deep, stack
// @expected-exit: 0

// Test: deep recursion patterns
// Validates recursive algorithms, mutual recursion, tree structures.

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if (b == 0) { a } else { gcd(b, a % b) }
}

@allow(unbounded_recursion)
fn power(base: Int, exp: Int) -> Int {
    if (exp == 0) { return 1; }
    if (exp % 2 == 0) {
        let half = power(base, exp / 2);
        half * half
    } else {
        base * power(base, exp - 1)
    }
}

@allow(unbounded_recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if (m == 0) {
        n + 1
    } else if (n == 0) {
        ackermann(m - 1, 1)
    } else {
        ackermann(m - 1, ackermann(m, n - 1))
    }
}

@allow(unbounded_recursion)
fn binary_search(arr: List<Int>, target: Int, lo: Int, hi: Int) -> Int {
    if (lo > hi) { return -1; }
    let mid = lo + (hi - lo) / 2;
    if (arr[mid] == target) {
        mid
    } else if (arr[mid] < target) {
        binary_search(arr, target, mid + 1, hi)
    } else {
        binary_search(arr, target, lo, mid - 1)
    }
}

@allow(unbounded_recursion)
fn count_ways(n: Int) -> Int {
    // Count ways to climb n stairs (1 or 2 steps at a time)
    if (n <= 0) { return 1; }
    if (n == 1) { return 1; }
    count_ways(n - 1) + count_ways(n - 2)
}

fn main() -> Int {
    // GCD
    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(17, 13), 1);
    assert_eq(gcd(0, 5), 5);
    assert_eq(gcd(12, 12), 12);

    // Fast power
    assert_eq(power(2, 10), 1024);
    assert_eq(power(3, 5), 243);
    assert_eq(power(5, 0), 1);
    assert_eq(power(7, 1), 7);
    assert_eq(power(2, 20), 1048576);

    // Ackermann (small values — grows super-exponentially)
    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(1, 1), 3);
    assert_eq(ackermann(2, 2), 7);
    assert_eq(ackermann(3, 2), 29);
    assert_eq(ackermann(3, 3), 61);

    // Binary search
    let mut sorted: List<Int> = [];
    let mut i = 0;
    while (i < 20) {
        sorted.push(i * 3);  // [0, 3, 6, 9, ..., 57]
        i = i + 1;
    }
    assert_eq(binary_search(sorted, 0, 0, 19), 0);
    assert_eq(binary_search(sorted, 9, 0, 19), 3);
    assert_eq(binary_search(sorted, 57, 0, 19), 19);
    assert_eq(binary_search(sorted, 7, 0, 19), -1); // not found

    // Stair climbing (Fibonacci-like)
    assert_eq(count_ways(1), 1);
    assert_eq(count_ways(2), 2);
    assert_eq(count_ways(5), 8);
    assert_eq(count_ways(10), 89);

    print("recursion_deep: PASS");
    0
}
