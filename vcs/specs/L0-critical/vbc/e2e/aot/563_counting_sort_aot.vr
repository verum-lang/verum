// @test: run
// @level: L0
// @tags: aot, e2e, counting-sort, selection-sort, sorting
// @timeout: 30000

// Sorting algorithm implementations and comparison

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Counting sort for values 0-7
fn counting_sort(arr: Arr8, n: Int) -> Arr8 {
    let mut counts = zeros();
    let mut i = 0;
    while i < n {
        let v = get8(arr, i);
        counts = set8(counts, v, get8(counts, v) + 1);
        i = i + 1;
    }
    let mut result = zeros();
    let mut out_idx = 0;
    let mut bucket = 0;
    while bucket < 8 {
        let mut j = 0;
        while j < get8(counts, bucket) {
            result = set8(result, out_idx, bucket);
            out_idx = out_idx + 1;
            j = j + 1;
        }
        bucket = bucket + 1;
    }
    result
}

// Selection sort
fn selection_sort(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 0;
    while i < n - 1 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            if get8(a, j) < get8(a, min_idx) { min_idx = j; }
            j = j + 1;
        }
        if min_idx != i {
            let tmp = get8(a, i);
            a = set8(a, i, get8(a, min_idx));
            a = set8(a, min_idx, tmp);
        }
        i = i + 1;
    }
    a
}

// Insertion sort
fn insertion_sort(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 1;
    while i < n {
        let key = get8(a, i);
        let mut j = i - 1;
        while j >= 0 {
            if get8(a, j) > key {
                a = set8(a, j + 1, get8(a, j));
                j = j - 1;
            } else {
                j = j - 100; // break trick: encode j and exit
            }
        }
        if j < -1 { j = j + 100; } // restore j from break trick
        a = set8(a, j + 1, key);
        i = i + 1;
    }
    a
}

// Check if sorted
fn check_sorted(arr: Arr8, n: Int) -> Int {
    let mut i = 0;
    while i < n - 1 {
        if get8(arr, i) > get8(arr, i + 1) { return 0; }
        i = i + 1;
    }
    1
}

fn test_counting_sort() -> Int {
    let arr = Arr8 { v0: 3, v1: 1, v2: 4, v3: 1, v4: 5, v5: 2, v6: 0, v7: 0 };
    let sorted = counting_sort(arr, 6);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 1), 1);
    assert_eq(get8(sorted, 2), 2);
    assert_eq(get8(sorted, 3), 3);
    assert_eq(get8(sorted, 4), 4);
    assert_eq(get8(sorted, 5), 5);
    1
}

fn test_selection_sort() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 2, v5: 0, v6: 0, v7: 0 };
    let sorted = selection_sort(arr, 5);
    assert_eq(check_sorted(sorted, 5), 1);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 4), 8);
    1
}

fn test_insertion_sort() -> Int {
    let arr = Arr8 { v0: 7, v1: 2, v2: 5, v3: 1, v4: 3, v5: 0, v6: 0, v7: 0 };
    let sorted = insertion_sort(arr, 5);
    assert_eq(check_sorted(sorted, 5), 1);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 4), 7);
    1
}

fn test_sorts_agree() -> Int {
    let arr = Arr8 { v0: 4, v1: 2, v2: 7, v3: 1, v4: 3, v5: 5, v6: 0, v7: 0 };
    let cs = counting_sort(arr, 6);
    let ss = selection_sort(arr, 6);
    let ins = insertion_sort(arr, 6);
    // Compare element by element
    let mut i = 0;
    let mut all_eq = 1;
    while i < 6 {
        if get8(cs, i) != get8(ss, i) { all_eq = 0; }
        if get8(cs, i) != get8(ins, i) { all_eq = 0; }
        i = i + 1;
    }
    assert_eq(all_eq, 1);
    1
}

fn test_already_sorted() -> Int {
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(check_sorted(arr, 5), 1);
    let cs = counting_sort(arr, 5);
    assert_eq(get8(cs, 0), 1);
    assert_eq(get8(cs, 4), 5);
    1
}

fn test_reverse() -> Int {
    let arr = Arr8 { v0: 5, v1: 4, v2: 3, v3: 2, v4: 1, v5: 0, v6: 0, v7: 0 };
    let sorted = insertion_sort(arr, 5);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 4), 5);
    1
}

fn test_duplicates() -> Int {
    let arr = Arr8 { v0: 3, v1: 1, v2: 3, v3: 1, v4: 2, v5: 2, v6: 0, v7: 0 };
    let sorted = counting_sort(arr, 6);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 1), 1);
    assert_eq(get8(sorted, 2), 2);
    assert_eq(get8(sorted, 3), 2);
    assert_eq(get8(sorted, 4), 3);
    assert_eq(get8(sorted, 5), 3);
    1
}

fn main() -> Int {
    test_counting_sort();
    test_selection_sort();
    test_insertion_sort();
    test_sorts_agree();
    test_already_sorted();
    test_reverse();
    test_duplicates();
    print("[OK] 563_counting_sort_aot");
    0
}
