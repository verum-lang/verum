// @test: run
// @level: L0
// @tags: aot, e2e, polynomial, algebra, evaluation
// @timeout: 30000

// Polynomial operations using coefficient arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// Evaluate polynomial p(x) = a0 + a1*x + a2*x^2 + ... using Horner's method
fn poly_eval(coeffs: Arr8, degree: Int, x: Int) -> Int {
    let mut result = get8(coeffs, degree);
    let mut i = degree - 1;
    while i >= 0 {
        result = result * x + get8(coeffs, i);
        i = i - 1;
    }
    result
}

// Add two polynomials
fn poly_add(a: Arr8, da: Int, b: Arr8, db: Int) -> Arr8 {
    let max_d = if da > db { da } else { db };
    let mut result = zeros();
    let mut i = 0;
    while i <= max_d {
        let av = if i <= da { get8(a, i) } else { 0 };
        let bv = if i <= db { get8(b, i) } else { 0 };
        result = set8(result, i, av + bv);
        i = i + 1;
    }
    result
}

// Multiply two polynomials (result degree = da + db, must fit in 8)
fn poly_mul(a: Arr8, da: Int, b: Arr8, db: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 0;
    while i <= da {
        let mut j = 0;
        while j <= db {
            if i + j < 8 {
                let cur = get8(result, i + j);
                result = set8(result, i + j, cur + get8(a, i) * get8(b, j));
            }
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

// Derivative of polynomial
fn poly_deriv(coeffs: Arr8, degree: Int) -> Arr8 {
    let mut result = zeros();
    let mut i = 1;
    while i <= degree {
        result = set8(result, i - 1, i * get8(coeffs, i));
        i = i + 1;
    }
    result
}

// Degree of result polynomial after multiplication
fn poly_mul_degree(da: Int, db: Int) -> Int {
    da + db
}

fn test_eval() -> Int {
    // p(x) = 3x^2 + 2x + 1
    let p = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_eval(p, 2, 0), 1);   // p(0) = 1
    assert_eq(poly_eval(p, 2, 1), 6);   // p(1) = 1+2+3 = 6
    assert_eq(poly_eval(p, 2, 2), 17);  // p(2) = 1+4+12 = 17
    assert_eq(poly_eval(p, 2, 3), 34);  // p(3) = 1+6+27 = 34
    // Constant polynomial
    let c = Arr8 { v0: 5, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(poly_eval(c, 0, 100), 5);
    1
}

fn test_add() -> Int {
    // (3x^2 + 2x + 1) + (x^2 - x + 4) = 4x^2 + x + 5
    let a = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 4, v1: 0 - 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let sum = poly_add(a, 2, b, 2);
    assert_eq(get8(sum, 0), 5);
    assert_eq(get8(sum, 1), 1);
    assert_eq(get8(sum, 2), 4);
    // Verify by evaluation
    assert_eq(poly_eval(sum, 2, 2), 5 + 2 + 16); // 23
    1
}

fn test_multiply() -> Int {
    // (x + 1) * (x - 1) = x^2 - 1
    let a = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 0 - 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let prod = poly_mul(a, 1, b, 1);
    assert_eq(get8(prod, 0), 0 - 1);
    assert_eq(get8(prod, 1), 0);
    assert_eq(get8(prod, 2), 1);
    // (x + 2) * (x + 3) = x^2 + 5x + 6
    let c = Arr8 { v0: 2, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let d = Arr8 { v0: 3, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let prod2 = poly_mul(c, 1, d, 1);
    assert_eq(get8(prod2, 0), 6);
    assert_eq(get8(prod2, 1), 5);
    assert_eq(get8(prod2, 2), 1);
    1
}

fn test_derivative() -> Int {
    // d/dx (3x^3 + 2x^2 + x + 5) = 9x^2 + 4x + 1
    let p = Arr8 { v0: 5, v1: 1, v2: 2, v3: 3, v4: 0, v5: 0, v6: 0, v7: 0 };
    let dp = poly_deriv(p, 3);
    assert_eq(get8(dp, 0), 1);  // 1*1
    assert_eq(get8(dp, 1), 4);  // 2*2
    assert_eq(get8(dp, 2), 9);  // 3*3
    // Verify: dp(2) = 1 + 8 + 36 = 45
    assert_eq(poly_eval(dp, 2, 2), 45);
    1
}

fn test_composition() -> Int {
    // Multiply then evaluate should equal evaluating separately and multiplying
    // p = x+1, q = x+2
    let p = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let q = Arr8 { v0: 2, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let pq = poly_mul(p, 1, q, 1);
    // At x=3: p(3)=4, q(3)=5, pq(3) should be 20
    assert_eq(poly_eval(p, 1, 3) * poly_eval(q, 1, 3), poly_eval(pq, 2, 3));
    // At x=5: p(5)=6, q(5)=7, pq(5)=42
    assert_eq(poly_eval(p, 1, 5) * poly_eval(q, 1, 5), poly_eval(pq, 2, 5));
    1
}

fn test_power_poly() -> Int {
    // (x+1)^3 = x^3 + 3x^2 + 3x + 1
    let p = Arr8 { v0: 1, v1: 1, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let p2 = poly_mul(p, 1, p, 1); // (x+1)^2 = x^2+2x+1
    let p3 = poly_mul(p2, 2, p, 1); // (x+1)^3
    assert_eq(get8(p3, 0), 1);
    assert_eq(get8(p3, 1), 3);
    assert_eq(get8(p3, 2), 3);
    assert_eq(get8(p3, 3), 1);
    // p3(2) = 27 = 3^3
    assert_eq(poly_eval(p3, 3, 2), 27);
    1
}

fn main() -> Int {
    test_eval();
    test_add();
    test_multiply();
    test_derivative();
    test_composition();
    test_power_poly();
    print("[OK] 604_polynomial_aot");
    0
}
