// @test: run
// @level: L0
// @tags: aot, e2e, polynomial, evaluation, math
// @timeout: 30000

// Polynomial evaluation and operations

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 }
    else if i == 1 { a.v1 }
    else if i == 2 { a.v2 }
    else if i == 3 { a.v3 }
    else if i == 4 { a.v4 }
    else if i == 5 { a.v5 }
    else if i == 6 { a.v6 }
    else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

// Horner's method: evaluate p(x) = coeffs[0] + coeffs[1]*x + ... + coeffs[n-1]*x^(n-1)
fn horner(coeffs: Arr8, n: Int, x: Int) -> Int {
    let mut result = get8(coeffs, n - 1);
    let mut i = n - 2;
    while i >= 0 {
        result = result * x + get8(coeffs, i);
        i = i - 1;
    }
    result
}

// Add two polynomials
fn poly_add(a: Arr8, alen: Int, b: Arr8, blen: Int) -> Arr8 {
    let n = if alen > blen { alen } else { blen };
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 0;
    while i < n {
        let va = if i < alen { get8(a, i) } else { 0 };
        let vb = if i < blen { get8(b, i) } else { 0 };
        result = set8(result, i, va + vb);
        i = i + 1;
    }
    result
}

// Derivative: d/dx(a0 + a1*x + a2*x^2 + ...) = a1 + 2*a2*x + 3*a3*x^2 + ...
fn poly_derivative(coeffs: Arr8, n: Int) -> Arr8 {
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 1;
    while i < n {
        result = set8(result, i - 1, i * get8(coeffs, i));
        i = i + 1;
    }
    result
}

// Scale polynomial by constant
fn poly_scale(coeffs: Arr8, n: Int, c: Int) -> Arr8 {
    let mut result = Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let mut i = 0;
    while i < n {
        result = set8(result, i, get8(coeffs, i) * c);
        i = i + 1;
    }
    result
}

fn test_horner() -> Int {
    // p(x) = 2 + 3x + x^2 = [2, 3, 1]
    let p = Arr8 { v0: 2, v1: 3, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(horner(p, 3, 0), 2);
    assert_eq(horner(p, 3, 1), 6);   // 2+3+1
    assert_eq(horner(p, 3, 2), 12);  // 2+6+4
    assert_eq(horner(p, 3, 3), 20);  // 2+9+9
    assert_eq(horner(p, 3, -1), 0);  // 2-3+1
    1
}

fn test_add() -> Int {
    // (1 + 2x) + (3 + x + x^2) = (4 + 3x + x^2)
    let a = Arr8 { v0: 1, v1: 2, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let b = Arr8 { v0: 3, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let r = poly_add(a, 2, b, 3);
    assert_eq(get8(r, 0), 4);
    assert_eq(get8(r, 1), 3);
    assert_eq(get8(r, 2), 1);
    1
}

fn test_derivative() -> Int {
    // d/dx(2 + 3x + 5x^2 + x^3) = 3 + 10x + 3x^2
    let p = Arr8 { v0: 2, v1: 3, v2: 5, v3: 1, v4: 0, v5: 0, v6: 0, v7: 0 };
    let d = poly_derivative(p, 4);
    assert_eq(get8(d, 0), 3);
    assert_eq(get8(d, 1), 10);
    assert_eq(get8(d, 2), 3);
    // Evaluate derivative at x=1: 3+10+3 = 16
    assert_eq(horner(d, 3, 1), 16);
    1
}

fn test_scale() -> Int {
    let p = Arr8 { v0: 1, v1: 2, v2: 3, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    let s = poly_scale(p, 3, 5);
    assert_eq(get8(s, 0), 5);
    assert_eq(get8(s, 1), 10);
    assert_eq(get8(s, 2), 15);
    1
}

fn main() -> Int {
    test_horner();
    test_add();
    test_derivative();
    test_scale();
    print("[OK] 438_polynomial_aot");
    0
}
