// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, max-flow, ford-fulkerson, graph, algorithm
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for Ford-Fulkerson maximum flow on a small network (6 nodes).
// Uses BFS (Edmonds-Karp variant) to find augmenting paths.
// Adjacency/capacity stored as a 6x6 matrix in a flat 36-element array.

type Arr8 is { a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int, a6: Int, a7: Int, len: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else { a.a7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        a0: if i == 0 { v } else { a.a0 }, a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 }, a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 }, a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 }, a7: if i == 7 { v } else { a.a7 },
        len: a.len
    }
}

// 36-element array for 6x6 matrix
type Arr36 is {
    d0: Int, d1: Int, d2: Int, d3: Int, d4: Int, d5: Int, d6: Int, d7: Int,
    d8: Int, d9: Int, d10: Int, d11: Int, d12: Int, d13: Int, d14: Int, d15: Int,
    d16: Int, d17: Int, d18: Int, d19: Int, d20: Int, d21: Int, d22: Int, d23: Int,
    d24: Int, d25: Int, d26: Int, d27: Int, d28: Int, d29: Int, d30: Int, d31: Int,
    d32: Int, d33: Int, d34: Int, d35: Int
};

fn a36_zero() -> Arr36 {
    Arr36 {
        d0: 0, d1: 0, d2: 0, d3: 0, d4: 0, d5: 0, d6: 0, d7: 0,
        d8: 0, d9: 0, d10: 0, d11: 0, d12: 0, d13: 0, d14: 0, d15: 0,
        d16: 0, d17: 0, d18: 0, d19: 0, d20: 0, d21: 0, d22: 0, d23: 0,
        d24: 0, d25: 0, d26: 0, d27: 0, d28: 0, d29: 0, d30: 0, d31: 0,
        d32: 0, d33: 0, d34: 0, d35: 0
    }
}

fn a36_get(a: Arr36, i: Int) -> Int {
    if i == 0 { a.d0 } else if i == 1 { a.d1 } else if i == 2 { a.d2 }
    else if i == 3 { a.d3 } else if i == 4 { a.d4 } else if i == 5 { a.d5 }
    else if i == 6 { a.d6 } else if i == 7 { a.d7 } else if i == 8 { a.d8 }
    else if i == 9 { a.d9 } else if i == 10 { a.d10 } else if i == 11 { a.d11 }
    else if i == 12 { a.d12 } else if i == 13 { a.d13 } else if i == 14 { a.d14 }
    else if i == 15 { a.d15 } else if i == 16 { a.d16 } else if i == 17 { a.d17 }
    else if i == 18 { a.d18 } else if i == 19 { a.d19 } else if i == 20 { a.d20 }
    else if i == 21 { a.d21 } else if i == 22 { a.d22 } else if i == 23 { a.d23 }
    else if i == 24 { a.d24 } else if i == 25 { a.d25 } else if i == 26 { a.d26 }
    else if i == 27 { a.d27 } else if i == 28 { a.d28 } else if i == 29 { a.d29 }
    else if i == 30 { a.d30 } else if i == 31 { a.d31 } else if i == 32 { a.d32 }
    else if i == 33 { a.d33 } else if i == 34 { a.d34 } else { a.d35 }
}

fn a36_set(a: Arr36, i: Int, v: Int) -> Arr36 {
    Arr36 {
        d0: if i == 0 { v } else { a.d0 }, d1: if i == 1 { v } else { a.d1 },
        d2: if i == 2 { v } else { a.d2 }, d3: if i == 3 { v } else { a.d3 },
        d4: if i == 4 { v } else { a.d4 }, d5: if i == 5 { v } else { a.d5 },
        d6: if i == 6 { v } else { a.d6 }, d7: if i == 7 { v } else { a.d7 },
        d8: if i == 8 { v } else { a.d8 }, d9: if i == 9 { v } else { a.d9 },
        d10: if i == 10 { v } else { a.d10 }, d11: if i == 11 { v } else { a.d11 },
        d12: if i == 12 { v } else { a.d12 }, d13: if i == 13 { v } else { a.d13 },
        d14: if i == 14 { v } else { a.d14 }, d15: if i == 15 { v } else { a.d15 },
        d16: if i == 16 { v } else { a.d16 }, d17: if i == 17 { v } else { a.d17 },
        d18: if i == 18 { v } else { a.d18 }, d19: if i == 19 { v } else { a.d19 },
        d20: if i == 20 { v } else { a.d20 }, d21: if i == 21 { v } else { a.d21 },
        d22: if i == 22 { v } else { a.d22 }, d23: if i == 23 { v } else { a.d23 },
        d24: if i == 24 { v } else { a.d24 }, d25: if i == 25 { v } else { a.d25 },
        d26: if i == 26 { v } else { a.d26 }, d27: if i == 27 { v } else { a.d27 },
        d28: if i == 28 { v } else { a.d28 }, d29: if i == 29 { v } else { a.d29 },
        d30: if i == 30 { v } else { a.d30 }, d31: if i == 31 { v } else { a.d31 },
        d32: if i == 32 { v } else { a.d32 }, d33: if i == 33 { v } else { a.d33 },
        d34: if i == 34 { v } else { a.d34 }, d35: if i == 35 { v } else { a.d35 }
    }
}

fn min2(a: Int, b_val: Int) -> Int { if a < b_val { a } else { b_val } }

// Matrix access: cap[from][to] at index from*6+to
fn mat_get(cap: Arr36, from: Int, to: Int) -> Int {
    a36_get(cap, from * 6 + to)
}

fn mat_set(cap: Arr36, from: Int, to: Int, v: Int) -> Arr36 {
    a36_set(cap, from * 6 + to, v)
}

// BFS to find augmenting path from source to sink in residual graph.
// Returns: parent array where parent[i] = predecessor on path (-1 if not visited).
// If sink is reachable, parent[sink] != -1.
fn bfs_path(residual: Arr36, source: Int, sink: Int, n: Int) -> Arr8 {
    let mut parent = Arr8 { a0: -1, a1: -1, a2: -1, a3: -1, a4: -1, a5: -1, a6: -1, a7: -1, len: n };
    let mut visited = Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: n };
    // BFS queue
    let mut queue = Arr8 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0, len: 0 };
    let mut qfront = 0;
    let mut qback = 0;

    // Enqueue source
    visited = arr8_set(visited, source, 1);
    parent = arr8_set(parent, source, source);  // Mark source as its own parent
    queue = arr8_set(queue, qback, source);
    qback = qback + 1;

    while qfront < qback {
        let u = arr8_get(queue, qfront);
        qfront = qfront + 1;

        let mut v = 0;
        while v < n {
            if arr8_get(visited, v) == 0 {
                let cap_uv = mat_get(residual, u, v);
                if cap_uv > 0 {
                    visited = arr8_set(visited, v, 1);
                    parent = arr8_set(parent, v, u);
                    queue = arr8_set(queue, qback, v);
                    qback = qback + 1;
                }
            }
            v = v + 1;
        }
    }
    parent
}

// Ford-Fulkerson (Edmonds-Karp) max flow
fn max_flow(cap: Arr36, source: Int, sink: Int, n: Int) -> Int {
    // Initialize residual graph = capacity graph
    let mut residual = cap;
    let mut total_flow = 0;
    let mut iteration = 0;

    let mut done = 0;
    while done == 0 {
        iteration = iteration + 1;
        if iteration > 50 { done = 1; }  // Safety limit
        else {
            // Find augmenting path via BFS
            let parent = bfs_path(residual, source, sink, n);

            // Check if sink was reached
            if arr8_get(parent, sink) == -1 {
                done = 1;
            } else {
                // Find bottleneck (minimum residual capacity along path)
                let mut bottleneck = 99999;
                let mut v = sink;
                while v != source {
                    let u = arr8_get(parent, v);
                    let cap_uv = mat_get(residual, u, v);
                    bottleneck = min2(bottleneck, cap_uv);
                    v = u;
                }

                // Update residual graph along path
                v = sink;
                while v != source {
                    let u = arr8_get(parent, v);
                    let fwd = mat_get(residual, u, v);
                    residual = mat_set(residual, u, v, fwd - bottleneck);
                    let bck = mat_get(residual, v, u);
                    residual = mat_set(residual, v, u, bck + bottleneck);
                    v = u;
                }

                total_flow = total_flow + bottleneck;
            }
        }
    }
    total_flow
}

fn test_simple_network() {
    // Simple network: source=0, sink=5
    //   0 --16--> 1 --12--> 3 --20--> 5
    //   0 --13--> 2 --14--> 4 --4---> 5
    //   1 --4---> 2
    //   3 --9---> 2
    //   2 --7---> 3
    //   4 --7---> 3
    // This is the classic Ford-Fulkerson example
    let mut cap = a36_zero();
    cap = mat_set(cap, 0, 1, 16);
    cap = mat_set(cap, 0, 2, 13);
    cap = mat_set(cap, 1, 2, 4);
    cap = mat_set(cap, 1, 3, 12);
    cap = mat_set(cap, 2, 1, 0);
    cap = mat_set(cap, 2, 4, 14);
    cap = mat_set(cap, 3, 2, 9);
    cap = mat_set(cap, 3, 5, 20);
    cap = mat_set(cap, 4, 3, 7);
    cap = mat_set(cap, 4, 5, 4);

    let flow = max_flow(cap, 0, 5, 6);
    // Max flow = 23
    assert_eq(flow, 23);
}

fn test_single_path() {
    // Linear path: 0 --5--> 1 --3--> 2
    // Max flow = min(5, 3) = 3
    let mut cap = a36_zero();
    cap = mat_set(cap, 0, 1, 5);
    cap = mat_set(cap, 1, 2, 3);

    let flow = max_flow(cap, 0, 2, 3);
    assert_eq(flow, 3);
}

fn test_parallel_paths() {
    // Two parallel paths: 0-->1-->3 (cap 5) and 0-->2-->3 (cap 7)
    let mut cap = a36_zero();
    cap = mat_set(cap, 0, 1, 5);
    cap = mat_set(cap, 0, 2, 7);
    cap = mat_set(cap, 1, 3, 5);
    cap = mat_set(cap, 2, 3, 7);

    let flow = max_flow(cap, 0, 3, 4);
    // Max flow = 5 + 7 = 12
    assert_eq(flow, 12);
}

fn test_bottleneck() {
    // Diamond: 0-->1 (10), 0-->2 (10), 1-->3 (1), 2-->3 (1)
    // Bottleneck at 1-->3 and 2-->3
    let mut cap = a36_zero();
    cap = mat_set(cap, 0, 1, 10);
    cap = mat_set(cap, 0, 2, 10);
    cap = mat_set(cap, 1, 3, 1);
    cap = mat_set(cap, 2, 3, 1);

    let flow = max_flow(cap, 0, 3, 4);
    assert_eq(flow, 2);  // 1 + 1
}

fn test_no_path() {
    // No edge from 0 to 1
    let cap = a36_zero();
    let flow = max_flow(cap, 0, 1, 2);
    assert_eq(flow, 0);
}

fn test_direct_edge() {
    // Direct edge: 0 --42--> 1
    let mut cap = a36_zero();
    cap = mat_set(cap, 0, 1, 42);

    let flow = max_flow(cap, 0, 1, 2);
    assert_eq(flow, 42);
}

fn test_flow_conservation() {
    // Network where we can verify flow conservation
    // 0 --10--> 1 --5--> 3
    // 0 --10--> 2 --5--> 3
    // 1 --3--> 2
    let mut cap = a36_zero();
    cap = mat_set(cap, 0, 1, 10);
    cap = mat_set(cap, 0, 2, 10);
    cap = mat_set(cap, 1, 3, 5);
    cap = mat_set(cap, 2, 3, 5);
    cap = mat_set(cap, 1, 2, 3);

    let flow = max_flow(cap, 0, 3, 4);
    // Path 1: 0->1->3 (5), Path 2: 0->2->3 (5), Path 3: 0->1->2->3 (3 but 2->3 full)
    // Actually: 0->1->3 (5), 0->2->3 (5), 0->1->2 (3 but 2->3 at cap 5 already used)
    // Max = 10
    assert_eq(flow, 10);
}

fn test_symmetric_network() {
    // Symmetric diamond: equal capacities everywhere
    // 0 --5--> 1, 0 --5--> 2, 1 --5--> 3, 2 --5--> 3
    let mut cap = a36_zero();
    cap = mat_set(cap, 0, 1, 5);
    cap = mat_set(cap, 0, 2, 5);
    cap = mat_set(cap, 1, 3, 5);
    cap = mat_set(cap, 2, 3, 5);

    let flow = max_flow(cap, 0, 3, 4);
    assert_eq(flow, 10);
}

fn main() -> Int {
    test_simple_network();
    test_single_path();
    test_parallel_paths();
    test_bottleneck();
    test_no_path();
    test_direct_edge();
    test_flow_conservation();
    test_symmetric_network();
    print("[OK] 332_max_flow_aot");
    0
}
