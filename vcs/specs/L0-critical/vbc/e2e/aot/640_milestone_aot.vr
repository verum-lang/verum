// @test: run
// @level: L0
// @tags: aot, e2e, milestone, statistics, math
// @timeout: 30000

// Milestone 640: Basic statistics on integer arrays

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }
fn abs_val(x: Int) -> Int { if x < 0 { 0 - x } else { x } }

// Sum
fn sum(arr: Arr8, n: Int) -> Int {
    let mut s = 0;
    let mut i = 0;
    while i < n { s = s + get8(arr, i); i = i + 1; }
    s
}

// Mean (integer division)
fn mean(arr: Arr8, n: Int) -> Int {
    if n == 0 { 0 } else { sum(arr, n) / n }
}

// Min
fn arr_min(arr: Arr8, n: Int) -> Int {
    let mut m = get8(arr, 0);
    let mut i = 1;
    while i < n {
        let v = get8(arr, i);
        if v < m { m = v; }
        i = i + 1;
    }
    m
}

// Max
fn arr_max(arr: Arr8, n: Int) -> Int {
    let mut m = get8(arr, 0);
    let mut i = 1;
    while i < n {
        let v = get8(arr, i);
        if v > m { m = v; }
        i = i + 1;
    }
    m
}

// Range
fn arr_range(arr: Arr8, n: Int) -> Int {
    arr_max(arr, n) - arr_min(arr, n)
}

// Variance * n (to avoid float: sum of (x - mean)^2)
fn variance_n(arr: Arr8, n: Int) -> Int {
    let m = mean(arr, n);
    let mut s = 0;
    let mut i = 0;
    while i < n {
        let d = get8(arr, i) - m;
        s = s + d * d;
        i = i + 1;
    }
    s
}

// Median (for sorted array)
fn median_sorted(arr: Arr8, n: Int) -> Int {
    if n % 2 == 1 { get8(arr, n / 2) }
    else { (get8(arr, n / 2 - 1) + get8(arr, n / 2)) / 2 }
}

// Mode (most frequent value)
fn mode(arr: Arr8, n: Int) -> Int {
    let mut best = get8(arr, 0);
    let mut best_count = 0;
    let mut i = 0;
    while i < n {
        let val = get8(arr, i);
        let mut count = 0;
        let mut j = 0;
        while j < n {
            if get8(arr, j) == val { count = count + 1; }
            j = j + 1;
        }
        if count > best_count {
            best_count = count;
            best = val;
        }
        i = i + 1;
    }
    best
}

// Bubble sort (for median computation)
fn sort(arr: Arr8, n: Int) -> Arr8 {
    let mut a = arr;
    let mut i = 0;
    while i < n - 1 {
        let mut j = 0;
        while j < n - 1 - i {
            if get8(a, j) > get8(a, j + 1) {
                let tmp = get8(a, j);
                a = set8(a, j, get8(a, j + 1));
                a = set8(a, j + 1, tmp);
            }
            j = j + 1;
        }
        i = i + 1;
    }
    a
}

// Mean absolute deviation
fn mad(arr: Arr8, n: Int) -> Int {
    let m = mean(arr, n);
    let mut s = 0;
    let mut i = 0;
    while i < n {
        s = s + abs_val(get8(arr, i) - m);
        i = i + 1;
    }
    s / n
}

fn test_basic_stats() -> Int {
    let arr = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 10, v5: 0, v6: 0, v7: 0 };
    assert_eq(sum(arr, 5), 30);
    assert_eq(mean(arr, 5), 6);
    assert_eq(arr_min(arr, 5), 2);
    assert_eq(arr_max(arr, 5), 10);
    assert_eq(arr_range(arr, 5), 8);
    1
}

fn test_single_element() -> Int {
    let arr = Arr8 { v0: 42, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(sum(arr, 1), 42);
    assert_eq(mean(arr, 1), 42);
    assert_eq(arr_min(arr, 1), 42);
    assert_eq(arr_max(arr, 1), 42);
    assert_eq(arr_range(arr, 1), 0);
    1
}

fn test_variance() -> Int {
    // [1, 2, 3, 4, 5], mean=3
    // deviations: -2, -1, 0, 1, 2
    // squared: 4, 1, 0, 1, 4 = 10
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(variance_n(arr, 5), 10);
    // All same: variance = 0
    let arr2 = Arr8 { v0: 5, v1: 5, v2: 5, v3: 5, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(variance_n(arr2, 4), 0);
    1
}

fn test_median() -> Int {
    // Odd count: [1, 3, 5, 7, 9] -> median = 5
    let sorted_odd = Arr8 { v0: 1, v1: 3, v2: 5, v3: 7, v4: 9, v5: 0, v6: 0, v7: 0 };
    assert_eq(median_sorted(sorted_odd, 5), 5);
    // Even count: [2, 4, 6, 8] -> median = (4+6)/2 = 5
    let sorted_even = Arr8 { v0: 2, v1: 4, v2: 6, v3: 8, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(median_sorted(sorted_even, 4), 5);
    1
}

fn test_mode() -> Int {
    // [1, 2, 2, 3, 3, 3, 4] -> mode = 3
    let arr = Arr8 { v0: 1, v1: 2, v2: 2, v3: 3, v4: 3, v5: 3, v6: 4, v7: 0 };
    assert_eq(mode(arr, 7), 3);
    // All same -> that value
    let arr2 = Arr8 { v0: 7, v1: 7, v2: 7, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(mode(arr2, 3), 7);
    1
}

fn test_sort() -> Int {
    let arr = Arr8 { v0: 5, v1: 3, v2: 8, v3: 1, v4: 4, v5: 0, v6: 0, v7: 0 };
    let sorted = sort(arr, 5);
    assert_eq(get8(sorted, 0), 1);
    assert_eq(get8(sorted, 1), 3);
    assert_eq(get8(sorted, 2), 4);
    assert_eq(get8(sorted, 3), 5);
    assert_eq(get8(sorted, 4), 8);
    1
}

fn test_mad() -> Int {
    // [1, 2, 3, 4, 5], mean=3
    // |1-3|+|2-3|+|3-3|+|4-3|+|5-3| = 2+1+0+1+2 = 6
    // MAD = 6/5 = 1 (integer div)
    let arr = Arr8 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 0, v6: 0, v7: 0 };
    assert_eq(mad(arr, 5), 1);
    1
}

fn test_sort_then_median() -> Int {
    // Unsorted: [7, 1, 5, 3, 9]
    let arr = Arr8 { v0: 7, v1: 1, v2: 5, v3: 3, v4: 9, v5: 0, v6: 0, v7: 0 };
    let sorted = sort(arr, 5);
    // Sorted: [1, 3, 5, 7, 9]
    assert_eq(median_sorted(sorted, 5), 5);
    1
}

fn main() -> Int {
    test_basic_stats();
    test_single_element();
    test_variance();
    test_median();
    test_mode();
    test_sort();
    test_mad();
    test_sort_then_median();
    print("[OK] 640_milestone_aot");
    0
}
