// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, algorithms, number-theory, iterative
// @timeout: 30000
// @expected-exit: 0
// @description: AOT number theory and iterative algorithms

// Sieve-like prime counting using trial division
fn is_prime(n: Int) -> Bool {
    if n < 2 { false }
    else if n < 4 { true }
    else if n % 2 == 0 { false }
    else {
        let mut d = 3;
        let mut result = true;
        while d * d <= n {
            if n % d == 0 {
                result = false;
            }
            d = d + 2;
        }
        result
    }
}

fn count_primes(limit: Int) -> Int {
    let mut count = 0;
    let mut n = 2;
    while n < limit {
        if is_prime(n) {
            count = count + 1;
        }
        n = n + 1;
    }
    count
}

// Nth prime
fn nth_prime(n: Int) -> Int {
    let mut count = 0;
    let mut candidate = 2;
    while count < n {
        if is_prime(candidate) {
            count = count + 1;
        }
        if count < n {
            candidate = candidate + 1;
        }
    }
    candidate
}

// Euler's totient function
fn euler_totient(n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i < n {
        if gcd(i, n) == 1 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y != 0 {
        let tmp = y;
        y = x % y;
        x = tmp;
    }
    x
}

// Integer exponentiation by squaring
fn pow_mod(base: Int, exp: Int, modulus: Int) -> Int {
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % modulus;
        }
        e = e / 2;
        b = (b * b) % modulus;
    }
    result
}

// Sum of divisors
fn sum_divisors(n: Int) -> Int {
    let mut sum = 0;
    let mut d = 1;
    while d * d <= n {
        if n % d == 0 {
            sum = sum + d;
            if d != n / d {
                sum = sum + n / d;
            }
        }
        d = d + 1;
    }
    sum
}

// Check if perfect number
fn is_perfect(n: Int) -> Bool {
    n > 1 && sum_divisors(n) == 2 * n
}

// Digital root: repeatedly sum digits until single digit
fn digit_sum(n: Int) -> Int {
    let mut x = n;
    let mut sum = 0;
    while x > 0 {
        sum = sum + x % 10;
        x = x / 10;
    }
    sum
}

fn digital_root(n: Int) -> Int {
    let mut x = n;
    while x >= 10 {
        x = digit_sum(x);
    }
    x
}

fn main() -> Int {
    // Primality
    assert(!is_prime(0));
    assert(!is_prime(1));
    assert(is_prime(2));
    assert(is_prime(3));
    assert(!is_prime(4));
    assert(is_prime(5));
    assert(is_prime(7));
    assert(!is_prime(9));
    assert(is_prime(11));
    assert(is_prime(13));
    assert(!is_prime(15));
    assert(is_prime(97));
    assert(!is_prime(100));

    // Prime counting (pi(n))
    assert_eq(count_primes(10), 4);    // 2,3,5,7
    assert_eq(count_primes(20), 8);    // + 11,13,17,19
    assert_eq(count_primes(100), 25);

    // Nth prime
    assert_eq(nth_prime(1), 2);
    assert_eq(nth_prime(2), 3);
    assert_eq(nth_prime(5), 11);
    assert_eq(nth_prime(10), 29);
    assert_eq(nth_prime(25), 97);

    // Euler's totient
    assert_eq(euler_totient(1), 0);  // loop 1..0 is empty
    assert_eq(euler_totient(2), 1);
    assert_eq(euler_totient(6), 2);    // 1, 5
    assert_eq(euler_totient(10), 4);   // 1, 3, 7, 9
    assert_eq(euler_totient(12), 4);   // 1, 5, 7, 11

    // For prime p: totient(p) = p-1
    assert_eq(euler_totient(7), 6);
    assert_eq(euler_totient(13), 12);

    // Modular exponentiation
    assert_eq(pow_mod(2, 10, 1000), 24);  // 1024 mod 1000
    assert_eq(pow_mod(3, 5, 100), 43);    // 243 mod 100
    assert_eq(pow_mod(7, 3, 13), 5);      // 343 mod 13

    // Fermat's little theorem: a^(p-1) ≡ 1 (mod p) for prime p
    assert_eq(pow_mod(2, 6, 7), 1);
    assert_eq(pow_mod(3, 12, 13), 1);

    // Sum of divisors
    assert_eq(sum_divisors(1), 1);
    assert_eq(sum_divisors(6), 12);    // 1+2+3+6
    assert_eq(sum_divisors(12), 28);   // 1+2+3+4+6+12
    assert_eq(sum_divisors(28), 56);   // perfect: 1+2+4+7+14+28

    // Perfect numbers
    assert(is_perfect(6));
    assert(is_perfect(28));
    assert(!is_perfect(12));

    // Digital root
    assert_eq(digit_sum(123), 6);
    assert_eq(digit_sum(9999), 36);
    assert_eq(digital_root(123), 6);
    assert_eq(digital_root(9999), 9);
    assert_eq(digital_root(493), 7);  // 4+9+3=16, 1+6=7

    0
}
