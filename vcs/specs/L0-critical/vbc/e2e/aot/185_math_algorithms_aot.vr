// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, e2e, aot, math, algorithms
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for mathematical algorithms

fn abs_val(x: Int) -> Int {
    if x < 0 { -x } else { x }
}

fn max_val(a: Int, b: Int) -> Int {
    if a > b { a } else { b }
}

fn min_val(a: Int, b: Int) -> Int {
    if a < b { a } else { b }
}

fn clamp(val: Int, lo: Int, hi: Int) -> Int {
    if val < lo { lo } else if val > hi { hi } else { val }
}

fn is_prime(n: Int) -> Bool {
    if n < 2 { return false; }
    if n < 4 { return true; }
    if n % 2 == 0 { return false; }
    let mut d = 3;
    while d * d <= n {
        if n % d == 0 { return false; }
        d = d + 2;
    }
    true
}

fn nth_prime(n: Int) -> Int {
    let mut count = 0;
    let mut candidate = 2;
    while count < n {
        if is_prime(candidate) {
            count = count + 1;
            if count == n { return candidate; }
        }
        candidate = candidate + 1;
    }
    candidate
}

fn isqrt(n: Int) -> Int {
    if n <= 0 { return 0; }
    let mut x = n;
    let mut y = (x + 1) / 2;
    while y < x {
        x = y;
        y = (x + n / x) / 2;
    }
    x
}

fn euler_totient(n: Int) -> Int {
    // Count numbers 1..n that are coprime with n
    let mut count = 0;
    let mut i = 1;
    while i <= n {
        // GCD
        let mut a = i;
        let mut b = n;
        while b > 0 {
            let t = b;
            b = a % b;
            a = t;
        }
        if a == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

fn main() -> Int {
    // abs, min, max, clamp
    assert_eq(abs_val(5), 5);
    assert_eq(abs_val(-5), 5);
    assert_eq(abs_val(0), 0);
    assert_eq(max_val(3, 7), 7);
    assert_eq(min_val(3, 7), 3);
    assert_eq(clamp(-5, 0, 10), 0);
    assert_eq(clamp(5, 0, 10), 5);
    assert_eq(clamp(15, 0, 10), 10);

    // Primality
    assert_eq(is_prime(2), true);
    assert_eq(is_prime(3), true);
    assert_eq(is_prime(4), false);
    assert_eq(is_prime(17), true);
    assert_eq(is_prime(100), false);
    assert_eq(is_prime(97), true);

    // Nth prime
    assert_eq(nth_prime(1), 2);
    assert_eq(nth_prime(5), 11);
    assert_eq(nth_prime(10), 29);
    assert_eq(nth_prime(25), 97);

    // Integer square root
    assert_eq(isqrt(0), 0);
    assert_eq(isqrt(1), 1);
    assert_eq(isqrt(4), 2);
    assert_eq(isqrt(9), 3);
    assert_eq(isqrt(100), 10);
    assert_eq(isqrt(99), 9);
    assert_eq(isqrt(101), 10);

    // Euler totient
    assert_eq(euler_totient(1), 1);
    assert_eq(euler_totient(6), 2);   // 1, 5
    assert_eq(euler_totient(10), 4);  // 1, 3, 7, 9
    assert_eq(euler_totient(12), 4);  // 1, 5, 7, 11
    assert_eq(euler_totient(7), 6);   // prime: all except 7

    print("[OK] 185_math_algorithms_aot");
    0
}
