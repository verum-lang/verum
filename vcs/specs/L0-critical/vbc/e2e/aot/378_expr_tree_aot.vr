// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, expression-tree, evaluation, tree-structure
// @timeout: 50000
// @expected-exit: 0
//
// AOT test for expression tree evaluation.
// Since AOT doesn't support heap-allocated tree nodes, we encode expression
// trees using a flat array representation (implicit binary tree).
// Nodes are stored in array indices where children of node i are at 2*i+1 and 2*i+2.
// Node types: 0=empty, 1=number(value), 2=add, 3=sub, 4=mul, 5=div

type Arr16 is {
    a0: Int, a1: Int, a2: Int, a3: Int,
    a4: Int, a5: Int, a6: Int, a7: Int,
    a8: Int, a9: Int, a10: Int, a11: Int,
    a12: Int, a13: Int, a14: Int, a15: Int
};

fn a16_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.a0 } else if i == 1 { a.a1 }
    else if i == 2 { a.a2 } else if i == 3 { a.a3 }
    else if i == 4 { a.a4 } else if i == 5 { a.a5 }
    else if i == 6 { a.a6 } else if i == 7 { a.a7 }
    else if i == 8 { a.a8 } else if i == 9 { a.a9 }
    else if i == 10 { a.a10 } else if i == 11 { a.a11 }
    else if i == 12 { a.a12 } else if i == 13 { a.a13 }
    else if i == 14 { a.a14 } else { a.a15 }
}

fn a16_set(a: Arr16, i: Int, v: Int) -> Arr16 {
    Arr16 {
        a0: if i == 0 { v } else { a.a0 },
        a1: if i == 1 { v } else { a.a1 },
        a2: if i == 2 { v } else { a.a2 },
        a3: if i == 3 { v } else { a.a3 },
        a4: if i == 4 { v } else { a.a4 },
        a5: if i == 5 { v } else { a.a5 },
        a6: if i == 6 { v } else { a.a6 },
        a7: if i == 7 { v } else { a.a7 },
        a8: if i == 8 { v } else { a.a8 },
        a9: if i == 9 { v } else { a.a9 },
        a10: if i == 10 { v } else { a.a10 },
        a11: if i == 11 { v } else { a.a11 },
        a12: if i == 12 { v } else { a.a12 },
        a13: if i == 13 { v } else { a.a13 },
        a14: if i == 14 { v } else { a.a14 },
        a15: if i == 15 { v } else { a.a15 }
    }
}

fn a16_zero() -> Arr16 {
    Arr16 { a0: 0, a1: 0, a2: 0, a3: 0, a4: 0, a5: 0, a6: 0, a7: 0,
            a8: 0, a9: 0, a10: 0, a11: 0, a12: 0, a13: 0, a14: 0, a15: 0 }
}

// Expression tree: two parallel arrays for node types and values
// types[i]: 0=empty, 1=number, 2=add, 3=sub, 4=mul, 5=div
// vals[i]: the numeric value (only meaningful when types[i]==1)
type ExprTree is { types: Arr16, vals: Arr16 };

fn expr_empty() -> ExprTree {
    ExprTree { types: a16_zero(), vals: a16_zero() }
}

// Build a number node at position i
fn expr_num(tree: ExprTree, pos: Int, val: Int) -> ExprTree {
    let types = a16_set(tree.types, pos, 1);
    let vals = a16_set(tree.vals, pos, val);
    ExprTree { types: types, vals: vals }
}

// Build an operator node at position i (children at 2*i+1, 2*i+2)
fn expr_op(tree: ExprTree, pos: Int, op: Int) -> ExprTree {
    let types = a16_set(tree.types, pos, op);
    ExprTree { types: types, vals: tree.vals }
}

// Evaluate expression tree iteratively (post-order using stack simulation)
// For a complete binary tree up to depth 3 (max 15 nodes, indices 0-14):
// Evaluate bottom-up: process leaves first, then parents.
// Since tree is stored as array, we evaluate from high indices to low.
fn eval_tree(tree: ExprTree) -> Int {
    // Results array: evaluated value for each node
    let mut results = a16_zero();

    // Process from bottom (index 14) to top (index 0)
    let mut i = 14;
    while i >= 0 {
        let node_type = a16_get(tree.types, i);
        if node_type == 0 {
            // empty
            results = a16_set(results, i, 0);
        } else if node_type == 1 {
            // number literal
            results = a16_set(results, i, a16_get(tree.vals, i));
        } else {
            // operator: get children results
            let left_child = 2 * i + 1;
            let right_child = 2 * i + 2;
            let lv = if left_child <= 14 { a16_get(results, left_child) } else { 0 };
            let rv = if right_child <= 14 { a16_get(results, right_child) } else { 0 };

            let val = if node_type == 2 { lv + rv }       // add
                      else if node_type == 3 { lv - rv }  // sub
                      else if node_type == 4 { lv * rv }  // mul
                      else if node_type == 5 {             // div
                          if rv != 0 { lv / rv } else { 0 }
                      } else { 0 };
            results = a16_set(results, i, val);
        }
        i = i - 1;
    }

    a16_get(results, 0)
}

// Count nodes in the tree
fn count_nodes(tree: ExprTree) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 15 {
        if a16_get(tree.types, i) != 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

// Count leaf nodes (numbers)
fn count_leaves(tree: ExprTree) -> Int {
    let mut count = 0;
    let mut i = 0;
    while i < 15 {
        if a16_get(tree.types, i) == 1 {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

// Tree depth (max level with non-empty nodes)
fn tree_depth(tree: ExprTree) -> Int {
    let mut depth = 0;
    // Level 0: index 0
    // Level 1: indices 1-2
    // Level 2: indices 3-6
    // Level 3: indices 7-14
    if a16_get(tree.types, 0) != 0 { depth = 1; }
    let mut i = 1;
    while i <= 2 {
        if a16_get(tree.types, i) != 0 { depth = 2; }
        i = i + 1;
    }
    i = 3;
    while i <= 6 {
        if a16_get(tree.types, i) != 0 { depth = 3; }
        i = i + 1;
    }
    i = 7;
    while i <= 14 {
        if a16_get(tree.types, i) != 0 { depth = 4; }
        i = i + 1;
    }
    depth
}

// === Tests ===

fn test_single_number() {
    // Tree: just the number 42
    let mut t = expr_empty();
    t = expr_num(t, 0, 42);
    assert_eq(eval_tree(t), 42);
}

fn test_simple_add() {
    // Tree: 3 + 5
    //     [+]       (index 0, type=2)
    //    /   \
    //  [3]   [5]    (index 1,2, type=1)
    let mut t = expr_empty();
    t = expr_op(t, 0, 2);     // add at root
    t = expr_num(t, 1, 3);    // left child = 3
    t = expr_num(t, 2, 5);    // right child = 5
    assert_eq(eval_tree(t), 8);
}

fn test_simple_sub() {
    // 10 - 3 = 7
    let mut t = expr_empty();
    t = expr_op(t, 0, 3);     // sub
    t = expr_num(t, 1, 10);
    t = expr_num(t, 2, 3);
    assert_eq(eval_tree(t), 7);
}

fn test_simple_mul() {
    // 4 * 7 = 28
    let mut t = expr_empty();
    t = expr_op(t, 0, 4);     // mul
    t = expr_num(t, 1, 4);
    t = expr_num(t, 2, 7);
    assert_eq(eval_tree(t), 28);
}

fn test_simple_div() {
    // 20 / 4 = 5
    let mut t = expr_empty();
    t = expr_op(t, 0, 5);     // div
    t = expr_num(t, 1, 20);
    t = expr_num(t, 2, 4);
    assert_eq(eval_tree(t), 5);
}

fn test_nested_expression() {
    // (3 + 5) * (10 - 2) = 8 * 8 = 64
    //         [*]           (index 0)
    //        /   \
    //      [+]   [-]        (index 1, 2)
    //     / \   / \
    //   [3][5][10][2]       (index 3,4,5,6)
    let mut t = expr_empty();
    t = expr_op(t, 0, 4);     // mul at root
    t = expr_op(t, 1, 2);     // add at left
    t = expr_op(t, 2, 3);     // sub at right
    t = expr_num(t, 3, 3);    // 3
    t = expr_num(t, 4, 5);    // 5
    t = expr_num(t, 5, 10);   // 10
    t = expr_num(t, 6, 2);    // 2
    assert_eq(eval_tree(t), 64);
}

fn test_deep_expression() {
    // ((2 + 3) * (4 - 1)) + ((6 / 2) * 5)
    // = (5 * 3) + (3 * 5) = 15 + 15 = 30
    //              [+]                  (0)
    //            /     \
    //          [*]     [*]              (1, 2)
    //         / \     / \
    //       [+][-]  [/] [5]             (3,4,5,6)
    //      / \ / \  / \
    //    [2][3][4][1][6][2]             (7,8,9,10,11,12)
    let mut t = expr_empty();
    t = expr_op(t, 0, 2);     // + root
    t = expr_op(t, 1, 4);     // * left
    t = expr_op(t, 2, 4);     // * right
    t = expr_op(t, 3, 2);     // + (left of left *)
    t = expr_op(t, 4, 3);     // - (right of left *)
    t = expr_op(t, 5, 5);     // / (left of right *)
    t = expr_num(t, 6, 5);    // 5 (right of right *)
    t = expr_num(t, 7, 2);    // 2
    t = expr_num(t, 8, 3);    // 3
    t = expr_num(t, 9, 4);    // 4
    t = expr_num(t, 10, 1);   // 1
    t = expr_num(t, 11, 6);   // 6
    t = expr_num(t, 12, 2);   // 2
    assert_eq(eval_tree(t), 30);
}

fn test_division_by_zero() {
    // 10 / 0 = 0 (our convention)
    let mut t = expr_empty();
    t = expr_op(t, 0, 5);
    t = expr_num(t, 1, 10);
    t = expr_num(t, 2, 0);
    assert_eq(eval_tree(t), 0);
}

fn test_negative_result() {
    // 3 - 10 = -7
    let mut t = expr_empty();
    t = expr_op(t, 0, 3);
    t = expr_num(t, 1, 3);
    t = expr_num(t, 2, 10);
    assert_eq(eval_tree(t), -7);
}

fn test_count_nodes_simple() {
    let mut t = expr_empty();
    t = expr_op(t, 0, 2);
    t = expr_num(t, 1, 3);
    t = expr_num(t, 2, 5);
    assert_eq(count_nodes(t), 3);
    assert_eq(count_leaves(t), 2);
}

fn test_count_nodes_deep() {
    let mut t = expr_empty();
    t = expr_op(t, 0, 2);
    t = expr_op(t, 1, 4);
    t = expr_op(t, 2, 3);
    t = expr_num(t, 3, 3);
    t = expr_num(t, 4, 5);
    t = expr_num(t, 5, 10);
    t = expr_num(t, 6, 2);
    assert_eq(count_nodes(t), 7);
    assert_eq(count_leaves(t), 4);
}

fn test_tree_depth_values() {
    // Single node
    let mut t1 = expr_empty();
    t1 = expr_num(t1, 0, 5);
    assert_eq(tree_depth(t1), 1);

    // Two levels
    let mut t2 = expr_empty();
    t2 = expr_op(t2, 0, 2);
    t2 = expr_num(t2, 1, 3);
    t2 = expr_num(t2, 2, 5);
    assert_eq(tree_depth(t2), 2);
}

fn test_left_heavy() {
    // ((5 + 3) - 2) = 6
    //       [-]         (0)
    //      /   \
    //    [+]   [2]      (1, 2)
    //   / \
    //  [5] [3]          (3, 4)
    let mut t = expr_empty();
    t = expr_op(t, 0, 3);     // sub
    t = expr_op(t, 1, 2);     // add
    t = expr_num(t, 2, 2);    // 2
    t = expr_num(t, 3, 5);    // 5
    t = expr_num(t, 4, 3);    // 3
    assert_eq(eval_tree(t), 6);
}

fn test_associativity() {
    // (2 + (3 + 4)) should equal ((2 + 3) + 4) = 9
    // Right-heavy:  +       Left-heavy:   +
    //              / \                    / \
    //            [2] [+]               [+]  [4]
    //                / \              / \
    //              [3] [4]          [2] [3]
    let mut t_right = expr_empty();
    t_right = expr_op(t_right, 0, 2);
    t_right = expr_num(t_right, 1, 2);
    t_right = expr_op(t_right, 2, 2);
    t_right = expr_num(t_right, 5, 3);
    t_right = expr_num(t_right, 6, 4);

    let mut t_left = expr_empty();
    t_left = expr_op(t_left, 0, 2);
    t_left = expr_op(t_left, 1, 2);
    t_left = expr_num(t_left, 2, 4);
    t_left = expr_num(t_left, 3, 2);
    t_left = expr_num(t_left, 4, 3);

    assert_eq(eval_tree(t_right), eval_tree(t_left));
    assert_eq(eval_tree(t_right), 9);
}

fn test_multiply_zero() {
    // 0 * anything = 0
    let mut t = expr_empty();
    t = expr_op(t, 0, 4);
    t = expr_num(t, 1, 0);
    t = expr_num(t, 2, 999);
    assert_eq(eval_tree(t), 0);
}

fn test_identity_operations() {
    // x + 0 = x, x * 1 = x
    let mut t_add = expr_empty();
    t_add = expr_op(t_add, 0, 2);
    t_add = expr_num(t_add, 1, 42);
    t_add = expr_num(t_add, 2, 0);
    assert_eq(eval_tree(t_add), 42);

    let mut t_mul = expr_empty();
    t_mul = expr_op(t_mul, 0, 4);
    t_mul = expr_num(t_mul, 1, 42);
    t_mul = expr_num(t_mul, 2, 1);
    assert_eq(eval_tree(t_mul), 42);
}

fn main() -> Int {
    test_single_number();
    test_simple_add();
    test_simple_sub();
    test_simple_mul();
    test_simple_div();
    test_nested_expression();
    test_deep_expression();
    test_division_by_zero();
    test_negative_result();
    test_count_nodes_simple();
    test_count_nodes_deep();
    test_tree_depth_values();
    test_left_heavy();
    test_associativity();
    test_multiply_zero();
    test_identity_operations();
    print("[OK] 378_expr_tree_aot");
    0
}
