// @test: run
// @tier: 1
// @level: L0
// @tags: vbc, e2e, aot, cellular-automaton, rule30, rule110, simulation
// @timeout: 50000
// @expected-exit: 0
// @description: AOT 1D cellular automaton (Rule 30, Rule 110) on a 16-cell grid, multi-generation simulation

// Grid of 16 cells, each 0 or 1, stored as individual Int fields
type Grid16 is {
    c0: Int, c1: Int, c2: Int, c3: Int,
    c4: Int, c5: Int, c6: Int, c7: Int,
    c8: Int, c9: Int, c10: Int, c11: Int,
    c12: Int, c13: Int, c14: Int, c15: Int
};

fn grid_new() -> Grid16 {
    Grid16 {
        c0: 0, c1: 0, c2: 0, c3: 0,
        c4: 0, c5: 0, c6: 0, c7: 0,
        c8: 0, c9: 0, c10: 0, c11: 0,
        c12: 0, c13: 0, c14: 0, c15: 0
    }
}

fn grid_get(g: Grid16, i: Int) -> Int {
    if i == 0 { g.c0 } else if i == 1 { g.c1 }
    else if i == 2 { g.c2 } else if i == 3 { g.c3 }
    else if i == 4 { g.c4 } else if i == 5 { g.c5 }
    else if i == 6 { g.c6 } else if i == 7 { g.c7 }
    else if i == 8 { g.c8 } else if i == 9 { g.c9 }
    else if i == 10 { g.c10 } else if i == 11 { g.c11 }
    else if i == 12 { g.c12 } else if i == 13 { g.c13 }
    else if i == 14 { g.c14 } else if i == 15 { g.c15 }
    else { 0 }
}

fn grid_set(g: Grid16, i: Int, v: Int) -> Grid16 {
    Grid16 {
        c0: if i == 0 { v } else { g.c0 },
        c1: if i == 1 { v } else { g.c1 },
        c2: if i == 2 { v } else { g.c2 },
        c3: if i == 3 { v } else { g.c3 },
        c4: if i == 4 { v } else { g.c4 },
        c5: if i == 5 { v } else { g.c5 },
        c6: if i == 6 { v } else { g.c6 },
        c7: if i == 7 { v } else { g.c7 },
        c8: if i == 8 { v } else { g.c8 },
        c9: if i == 9 { v } else { g.c9 },
        c10: if i == 10 { v } else { g.c10 },
        c11: if i == 11 { v } else { g.c11 },
        c12: if i == 12 { v } else { g.c12 },
        c13: if i == 13 { v } else { g.c13 },
        c14: if i == 14 { v } else { g.c14 },
        c15: if i == 15 { v } else { g.c15 }
    }
}

// Count total live cells
fn grid_population(g: Grid16) -> Int {
    g.c0 + g.c1 + g.c2 + g.c3 + g.c4 + g.c5 + g.c6 + g.c7
    + g.c8 + g.c9 + g.c10 + g.c11 + g.c12 + g.c13 + g.c14 + g.c15
}

// Check equality of two grids
fn grid_eq(a: Grid16, b: Grid16) -> Bool {
    a.c0 == b.c0 && a.c1 == b.c1 && a.c2 == b.c2 && a.c3 == b.c3
    && a.c4 == b.c4 && a.c5 == b.c5 && a.c6 == b.c6 && a.c7 == b.c7
    && a.c8 == b.c8 && a.c9 == b.c9 && a.c10 == b.c10 && a.c11 == b.c11
    && a.c12 == b.c12 && a.c13 == b.c13 && a.c14 == b.c14 && a.c15 == b.c15
}

// Get cell with boundary conditions (cells outside grid are 0)
fn safe_get(g: Grid16, i: Int) -> Int {
    if i < 0 || i > 15 { 0 } else { grid_get(g, i) }
}

// Apply a rule number (0-255) to a neighborhood (left, center, right)
// The rule number is an 8-bit lookup table indexed by the 3-bit pattern LCR
fn apply_rule(rule: Int, left: Int, center: Int, right: Int) -> Int {
    let pattern = left * 4 + center * 2 + right;
    (rule >> pattern) & 1
}

// Advance the grid one generation using the given rule
fn step(g: Grid16, rule: Int) -> Grid16 {
    let mut next = grid_new();
    let mut i = 0;
    while i < 16 {
        let left = safe_get(g, i - 1);
        let center = grid_get(g, i);
        let right = safe_get(g, i + 1);
        let new_val = apply_rule(rule, left, center, right);
        next = grid_set(next, i, new_val);
        i = i + 1;
    }
    next
}

// Run for n generations
fn run_n(g: Grid16, rule: Int, n: Int) -> Grid16 {
    let mut current = g;
    let mut gen = 0;
    while gen < n {
        current = step(current, rule);
        gen = gen + 1;
    }
    current
}

// Encode grid as an integer (bit packing for comparison)
fn grid_to_int(g: Grid16) -> Int {
    let mut result = 0;
    let mut i = 0;
    while i < 16 {
        result = result | (grid_get(g, i) << i);
        i = i + 1;
    }
    result
}

// Create a grid with a single cell set at position
fn single_cell(pos: Int) -> Grid16 {
    grid_set(grid_new(), pos, 1)
}

fn main() -> Int {
    // ===== Rule 30 Tests =====
    // Rule 30 in binary: 00011110
    // Pattern:  111 110 101 100 011 010 001 000
    // Result:    0   0   0   1   1   1   1   0
    let rule30 = 30;

    // === Test 1: apply_rule for Rule 30 ===
    assert_eq(apply_rule(rule30, 0, 0, 0), 0);
    assert_eq(apply_rule(rule30, 0, 0, 1), 1);
    assert_eq(apply_rule(rule30, 0, 1, 0), 1);
    assert_eq(apply_rule(rule30, 0, 1, 1), 1);
    assert_eq(apply_rule(rule30, 1, 0, 0), 1);
    assert_eq(apply_rule(rule30, 1, 0, 1), 0);
    assert_eq(apply_rule(rule30, 1, 1, 0), 0);
    assert_eq(apply_rule(rule30, 1, 1, 1), 0);

    // === Test 2: Single cell in center, Rule 30, generation 1 ===
    // Start: ...0001000...  (cell 8 = 1)
    let start30 = single_cell(8);
    assert_eq(grid_population(start30), 1);
    assert_eq(grid_get(start30, 8), 1);

    let gen1_30 = step(start30, rule30);
    // Neighborhood of cell 7: (0,0,1) -> 1
    // Neighborhood of cell 8: (0,1,0) -> 1
    // Neighborhood of cell 9: (1,0,0) -> 1
    assert_eq(grid_get(gen1_30, 7), 1);
    assert_eq(grid_get(gen1_30, 8), 1);
    assert_eq(grid_get(gen1_30, 9), 1);
    assert_eq(grid_population(gen1_30), 3);

    // === Test 3: Rule 30, generation 2 ===
    let gen2_30 = step(gen1_30, rule30);
    // Cell 6: (0,0,1) -> 1
    // Cell 7: (0,1,1) -> 1
    // Cell 8: (1,1,1) -> 0
    // Cell 9: (1,1,0) -> 0
    // Cell 10: (1,0,0) -> 1
    assert_eq(grid_get(gen2_30, 6), 1);
    assert_eq(grid_get(gen2_30, 7), 1);
    assert_eq(grid_get(gen2_30, 8), 0);
    assert_eq(grid_get(gen2_30, 9), 0);
    assert_eq(grid_get(gen2_30, 10), 1);
    assert_eq(grid_population(gen2_30), 3);

    // === Test 4: Rule 30, generation 3 ===
    let gen3_30 = step(gen2_30, rule30);
    // Cell 5: (0,0,1) -> 1
    // Cell 6: (0,1,1) -> 1
    // Cell 7: (1,1,0) -> 0
    // Cell 8: (1,0,0) -> 1
    // Cell 9: (0,0,1) -> 1
    // Cell 10: (0,1,0) -> 1
    // Cell 11: (1,0,0) -> 1
    assert_eq(grid_get(gen3_30, 5), 1);
    assert_eq(grid_get(gen3_30, 6), 1);
    assert_eq(grid_get(gen3_30, 7), 0);
    assert_eq(grid_get(gen3_30, 8), 1);
    assert_eq(grid_get(gen3_30, 9), 1);
    assert_eq(grid_get(gen3_30, 10), 1);
    assert_eq(grid_get(gen3_30, 11), 1);

    // === Test 5: run_n matches manual stepping ===
    let gen3_auto = run_n(start30, rule30, 3);
    assert(grid_eq(gen3_30, gen3_auto));

    // ===== Rule 110 Tests =====
    // Rule 110 in binary: 01101110
    // Pattern:  111 110 101 100 011 010 001 000
    // Result:    0   1   1   0   1   1   1   0
    let rule110 = 110;

    // === Test 6: apply_rule for Rule 110 ===
    assert_eq(apply_rule(rule110, 0, 0, 0), 0);
    assert_eq(apply_rule(rule110, 0, 0, 1), 1);
    assert_eq(apply_rule(rule110, 0, 1, 0), 1);
    assert_eq(apply_rule(rule110, 0, 1, 1), 1);
    assert_eq(apply_rule(rule110, 1, 0, 0), 0);
    assert_eq(apply_rule(rule110, 1, 0, 1), 1);
    assert_eq(apply_rule(rule110, 1, 1, 0), 1);
    assert_eq(apply_rule(rule110, 1, 1, 1), 0);

    // === Test 7: Rule 110, single cell ===
    let start110 = single_cell(8);
    let gen1_110 = step(start110, rule110);
    // Neighborhood of cell 7: (0,0,1) -> 1
    // Neighborhood of cell 8: (0,1,0) -> 1
    // Neighborhood of cell 9: (1,0,0) -> 0
    assert_eq(grid_get(gen1_110, 7), 1);
    assert_eq(grid_get(gen1_110, 8), 1);
    assert_eq(grid_get(gen1_110, 9), 0);
    assert_eq(grid_population(gen1_110), 2);

    // === Test 8: Rule 110, generation 2 ===
    let gen2_110 = step(gen1_110, rule110);
    // Cell 6: (0,0,1) -> 1
    // Cell 7: (0,1,1) -> 1
    // Cell 8: (1,1,0) -> 1
    // Cell 9: (1,0,0) -> 0
    assert_eq(grid_get(gen2_110, 6), 1);
    assert_eq(grid_get(gen2_110, 7), 1);
    assert_eq(grid_get(gen2_110, 8), 1);
    assert_eq(grid_get(gen2_110, 9), 0);

    // === Test 9: Rule 110, multiple generations ===
    let gen5_110 = run_n(start110, rule110, 5);
    // Just verify it didn't die out and has reasonable population
    assert(grid_population(gen5_110) > 0);

    // ===== Rule 0 Tests (all die) =====
    let rule0 = 0;

    // === Test 10: Rule 0 kills everything ===
    let alive = single_cell(8);
    let dead = step(alive, rule0);
    assert_eq(grid_population(dead), 0);

    // ===== Rule 255 Tests (all live) =====
    let rule255 = 255;

    // === Test 11: Rule 255 with any neighborhood gives 1 ===
    assert_eq(apply_rule(rule255, 0, 0, 0), 1);
    assert_eq(apply_rule(rule255, 1, 1, 1), 1);

    // Rule 255 on single cell: after one step, the whole grid is 1
    // (since even 000 -> 1)
    let full = step(single_cell(8), rule255);
    assert_eq(grid_population(full), 16);

    // ===== Pattern Analysis =====

    // === Test 12: grid_to_int encoding ===
    let g_test = grid_set(grid_set(grid_new(), 0, 1), 3, 1);
    assert_eq(grid_to_int(g_test), 9);  // bit 0 + bit 3 = 1 + 8

    // === Test 13: All zeros encodes to 0 ===
    assert_eq(grid_to_int(grid_new()), 0);

    // === Test 14: Single cell at position i ===
    assert_eq(grid_to_int(single_cell(0)), 1);
    assert_eq(grid_to_int(single_cell(1)), 2);
    assert_eq(grid_to_int(single_cell(4)), 16);

    // === Test 15: Empty grid stays empty for any rule ===
    let empty = grid_new();
    // Rule 30: 000 -> 0, so empty stays empty
    assert_eq(grid_population(step(empty, rule30)), 0);
    // Rule 110: 000 -> 0, so empty stays empty
    assert_eq(grid_population(step(empty, rule110)), 0);

    // === Test 16: Alternating pattern ===
    let mut alt = grid_new();
    let mut idx = 0;
    while idx < 16 {
        alt = grid_set(alt, idx, idx % 2);
        idx = idx + 1;
    }
    assert_eq(grid_population(alt), 8);
    // One step of Rule 30 on alternating
    let alt_next = step(alt, rule30);
    assert(grid_population(alt_next) > 0);

    // === Test 17: Rule 30 population over multiple generations ===
    let mut g30 = single_cell(8);
    let mut gen = 0;
    while gen < 6 {
        g30 = step(g30, rule30);
        assert(grid_population(g30) > 0);
        gen = gen + 1;
    }

    // === Test 18: Rule 110 Turing-completeness indicator ===
    // Rule 110 is known to be Turing-complete. Test that complex patterns persist.
    let mut g110 = grid_new();
    g110 = grid_set(g110, 12, 1);
    g110 = grid_set(g110, 13, 1);
    g110 = grid_set(g110, 14, 1);
    g110 = grid_set(g110, 15, 1);
    let g110_10 = run_n(g110, rule110, 10);
    assert(grid_population(g110_10) > 0);

    // === Test 19: Two different starting configs produce different results ===
    let start_a = single_cell(7);
    let start_b = single_cell(9);
    let end_a = run_n(start_a, rule30, 3);
    let end_b = run_n(start_b, rule30, 3);
    assert(!grid_eq(end_a, end_b));

    0
}
