// @test: run
// @level: L0
// @tags: aot, e2e, brainfuck, interpreter, esoteric
// @timeout: 30000

// Brainfuck interpreter using integer instruction encoding

type Arr8 is { v0: Int, v1: Int, v2: Int, v3: Int, v4: Int, v5: Int, v6: Int, v7: Int };

fn get8(a: Arr8, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 } else if i == 2 { a.v2 }
    else if i == 3 { a.v3 } else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else { a.v7 }
}

fn set8(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        v0: if i == 0 { v } else { a.v0 },
        v1: if i == 1 { v } else { a.v1 },
        v2: if i == 2 { v } else { a.v2 },
        v3: if i == 3 { v } else { a.v3 },
        v4: if i == 4 { v } else { a.v4 },
        v5: if i == 5 { v } else { a.v5 },
        v6: if i == 6 { v } else { a.v6 },
        v7: if i == 7 { v } else { a.v7 }
    }
}

fn zeros() -> Arr8 { Arr8 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 } }

// BF instructions encoded as integers:
// 1 = + (increment), 2 = - (decrement)
// 3 = > (move right), 4 = < (move left)
// 5 = [ (loop start), 6 = ] (loop end)
// 7 = output (we capture to output array)
fn BF_INC() -> Int { 1 }
fn BF_DEC() -> Int { 2 }
fn BF_RIGHT() -> Int { 3 }
fn BF_LEFT() -> Int { 4 }
fn BF_OPEN() -> Int { 5 }
fn BF_CLOSE() -> Int { 6 }
fn BF_OUT() -> Int { 7 }

// Find matching bracket (forward)
fn find_matching_close(prog: Arr8, plen: Int, pos: Int) -> Int {
    let mut depth = 1;
    let mut p = pos + 1;
    while p < plen {
        let instr = get8(prog, p);
        if instr == BF_OPEN() { depth = depth + 1; }
        else if instr == BF_CLOSE() {
            depth = depth - 1;
            if depth == 0 { p = plen + p; } // break with value
        }
        if p < plen { p = p + 1; }
    }
    if p >= plen {
        if p > plen { p - plen - 1 } // decode from break
        else { plen } // not found (error)
    } else { p }
}

// Find matching bracket (backward)
fn find_matching_open(prog: Arr8, pos: Int) -> Int {
    let mut depth = 1;
    let mut p = pos - 1;
    while p >= 0 {
        let instr = get8(prog, p);
        if instr == BF_CLOSE() { depth = depth + 1; }
        else if instr == BF_OPEN() {
            depth = depth - 1;
            if depth == 0 { p = 0 - p - 100; } // break with value (add 100 offset)
        }
        if p >= 0 { p = p - 1; }
    }
    if p < 0 {
        if p < 0 - 100 { 0 - p - 100 } // decode from break
        else { 0 } // not found
    } else { p }
}

// Run BF program, return final state of cell 0
fn bf_run_cell0(prog: Arr8, plen: Int) -> Int {
    let mut tape = zeros();
    let mut dp = 0; // data pointer
    let mut ip = 0; // instruction pointer
    let mut steps = 0;
    while ip < plen {
        let instr = get8(prog, ip);
        if instr == BF_INC() {
            tape = set8(tape, dp, get8(tape, dp) + 1);
        } else if instr == BF_DEC() {
            tape = set8(tape, dp, get8(tape, dp) - 1);
        } else if instr == BF_RIGHT() {
            if dp < 7 { dp = dp + 1; }
        } else if instr == BF_LEFT() {
            if dp > 0 { dp = dp - 1; }
        } else if instr == BF_OPEN() {
            if get8(tape, dp) == 0 {
                ip = find_matching_close(prog, plen, ip);
            }
        } else if instr == BF_CLOSE() {
            if get8(tape, dp) != 0 {
                ip = find_matching_open(prog, ip);
            }
        }
        ip = ip + 1;
        steps = steps + 1;
        if steps > 200 { ip = plen; } // safety
    }
    get8(tape, 0)
}

// Return tape cell at given index
fn bf_run_cell(prog: Arr8, plen: Int, cell: Int) -> Int {
    let mut tape = zeros();
    let mut dp = 0;
    let mut ip = 0;
    let mut steps = 0;
    while ip < plen {
        let instr = get8(prog, ip);
        if instr == BF_INC() {
            tape = set8(tape, dp, get8(tape, dp) + 1);
        } else if instr == BF_DEC() {
            tape = set8(tape, dp, get8(tape, dp) - 1);
        } else if instr == BF_RIGHT() {
            if dp < 7 { dp = dp + 1; }
        } else if instr == BF_LEFT() {
            if dp > 0 { dp = dp - 1; }
        } else if instr == BF_OPEN() {
            if get8(tape, dp) == 0 {
                ip = find_matching_close(prog, plen, ip);
            }
        } else if instr == BF_CLOSE() {
            if get8(tape, dp) != 0 {
                ip = find_matching_open(prog, ip);
            }
        }
        ip = ip + 1;
        steps = steps + 1;
        if steps > 200 { ip = plen; }
    }
    get8(tape, cell)
}

fn test_increment() -> Int {
    // +++ = cell0 = 3
    let prog = Arr8 { v0: 1, v1: 1, v2: 1, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(bf_run_cell0(prog, 3), 3);
    1
}

fn test_move_and_inc() -> Int {
    // +++>++< = cell0=3, cell1=2, dp back to 0
    let prog = Arr8 { v0: 1, v1: 1, v2: 1, v3: 3, v4: 1, v5: 1, v6: 4, v7: 0 };
    assert_eq(bf_run_cell(prog, 7, 0), 3);
    assert_eq(bf_run_cell(prog, 7, 1), 2);
    1
}

fn test_simple_loop() -> Int {
    // +++[-] = set to 3, then loop decrement to 0
    let prog = Arr8 { v0: 1, v1: 1, v2: 1, v3: 5, v4: 2, v5: 6, v6: 0, v7: 0 };
    assert_eq(bf_run_cell0(prog, 6), 0);
    1
}

fn test_copy_cell() -> Int {
    // Copy cell0 to cell1: +++[->+<] = cell0=0, cell1=3
    let prog = Arr8 { v0: 1, v1: 1, v2: 1, v3: 5, v4: 2, v5: 3, v6: 1, v7: 4 };
    // This is 8 instructions: +++[->{+<] but we need ] too which is 9
    // Too long, simplify: ++[->{+<}] = ++[->{+<}]
    // Let's do a simpler version: set cell0=2, transfer to cell1
    // ++[->{+<}]  = instructions: 1,1, 5,2,3,1,4, 6
    let prog2 = Arr8 { v0: 1, v1: 1, v2: 5, v3: 2, v4: 3, v5: 1, v6: 4, v7: 6 };
    assert_eq(bf_run_cell(prog2, 8, 0), 0);
    assert_eq(bf_run_cell(prog2, 8, 1), 2);
    1
}

fn test_skip_loop() -> Int {
    // [+] on zero cell = skip entirely, cell stays 0
    let prog = Arr8 { v0: 5, v1: 1, v2: 6, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0 };
    assert_eq(bf_run_cell0(prog, 3), 0);
    1
}

fn test_decrement() -> Int {
    // +++-- = 3-2 = 1
    let prog = Arr8 { v0: 1, v1: 1, v2: 1, v3: 2, v4: 2, v5: 0, v6: 0, v7: 0 };
    assert_eq(bf_run_cell0(prog, 5), 1);
    1
}

fn main() -> Int {
    test_increment();
    test_move_and_inc();
    test_simple_loop();
    test_copy_cell();
    test_skip_loop();
    test_decrement();
    print("[OK] 601_brainfuck_aot");
    0
}
