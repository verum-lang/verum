// @test: run
// @tier: 2
// @level: L0
// @tags: vbc, e2e, aot, binaryheap, collections
// @timeout: 50000
// @expected-exit: 0
//
// E2E test for stdlib BinaryHeap API (max-heap).

fn main() -> Int {
    let mut pass = 0;

    let mut h = BinaryHeap.new();
    h.push(30);
    h.push(50);
    h.push(10);
    h.push(40);
    h.push(20);
    if h.len() == 5 { pass = pass + 1; }

    // pop returns max element
    match h.pop() {
        Some(v) => {
            if v == 50 { pass = pass + 1; }
        },
        None => {},
    }

    match h.pop() {
        Some(v) => {
            if v == 40 { pass = pass + 1; }
        },
        None => {},
    }

    match h.pop() {
        Some(v) => {
            if v == 30 { pass = pass + 1; }
        },
        None => {},
    }

    if h.len() == 2 { pass = pass + 1; }

    // pop remaining
    match h.pop() {
        Some(v) => {
            if v == 20 { pass = pass + 1; }
        },
        None => {},
    }

    match h.pop() {
        Some(v) => {
            if v == 10 { pass = pass + 1; }
        },
        None => {},
    }

    // empty heap pop
    match h.pop() {
        Some(_) => {},
        None => { pass = pass + 1; },
    }

    if h.len() == 0 { pass = pass + 1; }

    print(f"pass = {pass}/9");
    if pass == 9 {
        print("ALL OK");
        return 0;
    }
    return 1;
}
