// @test: run
// @level: L0
// @tags: aot, e2e, milestone, primes, sieve
// @timeout: 30000

// Milestone 645: Prime numbers and sieve

fn pow2(n: Int) -> Int {
    let mut r = 1;
    let mut i = 0;
    while i < n { r = r * 2; i = i + 1; }
    r
}

fn get_bit(val: Int, pos: Int) -> Int { (val / pow2(pos)) % 2 }

// Primality test by trial division
fn is_prime(n: Int) -> Int {
    if n < 2 { 0 }
    else if n == 2 { 1 }
    else if n % 2 == 0 { 0 }
    else {
        let mut d = 3;
        let mut result = 1;
        while d * d <= n {
            if n % d == 0 { result = 0; d = n; } // break
            else { d = d + 2; }
        }
        result
    }
}

// Count primes up to n
fn count_primes(n: Int) -> Int {
    let mut count = 0;
    let mut i = 2;
    while i <= n {
        if is_prime(i) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Next prime >= n
fn next_prime(n: Int) -> Int {
    let mut p = n;
    if p < 2 { p = 2; }
    let mut found = 0;
    while found == 0 {
        if is_prime(p) == 1 { found = 1; }
        else { p = p + 1; }
    }
    p
}

// nth prime (0-indexed: prime(0)=2)
fn nth_prime(n: Int) -> Int {
    let mut count = 0;
    let mut p = 2;
    while count < n {
        p = p + 1;
        if is_prime(p) == 1 { count = count + 1; }
    }
    p
}

// GCD
fn gcd(a: Int, b: Int) -> Int {
    let mut x = a;
    let mut y = b;
    while y != 0 { let t = y; y = x % y; x = t; }
    x
}

// Euler's totient for small n
fn euler_totient(n: Int) -> Int {
    let mut count = 0;
    let mut i = 1;
    while i < n {
        if gcd(i, n) == 1 { count = count + 1; }
        i = i + 1;
    }
    count
}

// Sum of prime factors (with multiplicity)
fn prime_factor_sum(n: Int) -> Int {
    let mut sum = 0;
    let mut num = n;
    let mut d = 2;
    while d * d <= num {
        while num % d == 0 {
            sum = sum + d;
            num = num / d;
        }
        d = d + 1;
    }
    if num > 1 { sum = sum + num; }
    sum
}

// Count distinct prime factors
fn distinct_prime_factors(n: Int) -> Int {
    let mut count = 0;
    let mut num = n;
    let mut d = 2;
    while d * d <= num {
        if num % d == 0 {
            count = count + 1;
            while num % d == 0 { num = num / d; }
        }
        d = d + 1;
    }
    if num > 1 { count = count + 1; }
    count
}

fn test_primality() -> Int {
    assert_eq(is_prime(0), 0);
    assert_eq(is_prime(1), 0);
    assert_eq(is_prime(2), 1);
    assert_eq(is_prime(3), 1);
    assert_eq(is_prime(4), 0);
    assert_eq(is_prime(5), 1);
    assert_eq(is_prime(7), 1);
    assert_eq(is_prime(9), 0);
    assert_eq(is_prime(11), 1);
    assert_eq(is_prime(13), 1);
    assert_eq(is_prime(15), 0);
    assert_eq(is_prime(17), 1);
    assert_eq(is_prime(97), 1);
    assert_eq(is_prime(100), 0);
    1
}

fn test_count_primes() -> Int {
    assert_eq(count_primes(1), 0);
    assert_eq(count_primes(2), 1);
    assert_eq(count_primes(10), 4);  // 2,3,5,7
    assert_eq(count_primes(20), 8);  // 2,3,5,7,11,13,17,19
    assert_eq(count_primes(30), 10); // +23,29
    1
}

fn test_next_prime() -> Int {
    assert_eq(next_prime(1), 2);
    assert_eq(next_prime(2), 2);
    assert_eq(next_prime(3), 3);
    assert_eq(next_prime(4), 5);
    assert_eq(next_prime(8), 11);
    assert_eq(next_prime(14), 17);
    1
}

fn test_nth_prime() -> Int {
    assert_eq(nth_prime(0), 2);
    assert_eq(nth_prime(1), 3);
    assert_eq(nth_prime(2), 5);
    assert_eq(nth_prime(3), 7);
    assert_eq(nth_prime(4), 11);
    assert_eq(nth_prime(9), 29);
    1
}

fn test_totient() -> Int {
    // phi(1)=1 (by convention, but our fn counts i<n coprime, so phi(1)=0 for i<1)
    assert_eq(euler_totient(2), 1);   // {1}
    assert_eq(euler_totient(6), 2);   // {1, 5}
    assert_eq(euler_totient(7), 6);   // all 1-6 (7 is prime)
    assert_eq(euler_totient(10), 4);  // {1, 3, 7, 9}
    assert_eq(euler_totient(12), 4);  // {1, 5, 7, 11}
    // For prime p: phi(p) = p-1
    assert_eq(euler_totient(13), 12);
    1
}

fn test_factorization() -> Int {
    // 12 = 2*2*3
    assert_eq(prime_factor_sum(12), 7); // 2+2+3
    assert_eq(distinct_prime_factors(12), 2); // {2, 3}
    // 30 = 2*3*5
    assert_eq(prime_factor_sum(30), 10);
    assert_eq(distinct_prime_factors(30), 3);
    // Prime: single factor
    assert_eq(prime_factor_sum(17), 17);
    assert_eq(distinct_prime_factors(17), 1);
    // 1: no factors
    assert_eq(prime_factor_sum(1), 0);
    assert_eq(distinct_prime_factors(1), 0);
    1
}

fn test_goldbach() -> Int {
    // Goldbach's conjecture: every even number > 2 is sum of two primes
    // Test for small even numbers
    let mut n = 4;
    let mut all_ok = 1;
    while n <= 30 {
        let mut found = 0;
        let mut p = 2;
        while p <= n / 2 {
            if is_prime(p) == 1 {
                if is_prime(n - p) == 1 { found = 1; }
            }
            p = p + 1;
        }
        if found == 0 { all_ok = 0; }
        n = n + 2;
    }
    assert_eq(all_ok, 1);
    1
}

fn main() -> Int {
    test_primality();
    test_count_primes();
    test_next_prime();
    test_nth_prime();
    test_totient();
    test_factorization();
    test_goldbach();
    print("[OK] 645_milestone_aot");
    0
}
