// @test: run
// @level: L0
// @tier: 0
// @tags: contracts, verify, precondition, postcondition, assert
// @description: Contract annotations — pre/post conditions via assert, function contracts pattern

fn safe_sqrt_int(n: Int) -> Int {
    // Precondition: n must be non-negative
    assert(n >= 0);
    if n == 0 { return 0; }
    if n == 1 { return 1; }

    let mut low = 1;
    let mut high = n;
    let mut result = 0;

    while low <= high {
        let mid = low + (high - low) / 2;
        if mid <= n / mid {
            result = mid;
            low = mid + 1;
        } else {
            high = mid - 1;
        }
    }
    // Postcondition: result * result <= n < (result+1) * (result+1)
    assert(result * result <= n);
    assert((result + 1) * (result + 1) > n);
    result
}

fn binary_search(arr: List<Int>, target: Int) -> Int {
    // Precondition: array must not be empty
    assert(arr.len() > 0);

    let mut low = 0;
    let mut high = arr.len() - 1;

    while low <= high {
        let mid = low + (high - low) / 2;
        if arr[mid] == target {
            // Postcondition: found element matches target
            assert(arr[mid] == target);
            return mid;
        } else if arr[mid] < target {
            low = mid + 1;
        } else {
            if mid == 0 { break; }
            high = mid - 1;
        }
    }
    -1
}

fn clamp(value: Int, min_val: Int, max_val: Int) -> Int {
    // Precondition
    assert(min_val <= max_val);

    let result = if value < min_val {
        min_val
    } else if value > max_val {
        max_val
    } else {
        value
    };

    // Postcondition
    assert(result >= min_val);
    assert(result <= max_val);
    result
}

fn gcd(a: Int, b: Int) -> Int {
    // Preconditions
    assert(a > 0);
    assert(b > 0);

    let mut x = a;
    let mut y = b;
    while y != 0 {
        let temp = y;
        y = x % y;
        x = temp;
    }

    // Postconditions: result divides both a and b
    assert(a % x == 0);
    assert(b % x == 0);
    assert(x > 0);
    x
}

fn test_sqrt_contracts() -> Int {
    let inputs = [0, 1, 4, 9, 16, 25, 100, 144];
    let answers = [0, 1, 2, 3, 4, 5, 10, 12];

    let mut i = 0;
    while i < inputs.len() {
        let result = safe_sqrt_int(inputs[i]);
        if result != answers[i] {
            print(f"FAIL sqrt({inputs[i]}): expected {answers[i]}, got {result}");
            return 1;
        }
        i = i + 1;
    }

    // Non-perfect squares
    let r = safe_sqrt_int(10);
    if r != 3 {
        print(f"FAIL sqrt(10): expected 3, got {r}");
        return 1;
    }
    print("  sqrt_contracts: OK");
    0
}

fn test_binary_search_contracts() -> Int {
    let arr = [1, 3, 5, 7, 9, 11, 13, 15];

    let idx = binary_search(arr, 7);
    if idx != 3 {
        print(f"FAIL search(7): expected 3, got {idx}");
        return 1;
    }

    let idx2 = binary_search(arr, 1);
    if idx2 != 0 {
        print(f"FAIL search(1): expected 0, got {idx2}");
        return 1;
    }

    let idx3 = binary_search(arr, 15);
    if idx3 != 7 {
        print(f"FAIL search(15): expected 7, got {idx3}");
        return 1;
    }

    let idx4 = binary_search(arr, 6);
    if idx4 != -1 {
        print(f"FAIL search(6): expected -1, got {idx4}");
        return 1;
    }

    print("  binary_search_contracts: OK");
    0
}

fn test_clamp_contracts() -> Int {
    let r1 = clamp(5, 0, 10);
    if r1 != 5 {
        print(f"FAIL clamp(5,0,10): expected 5, got {r1}");
        return 1;
    }

    let r2 = clamp(-5, 0, 10);
    if r2 != 0 {
        print(f"FAIL clamp(-5,0,10): expected 0, got {r2}");
        return 1;
    }

    let r3 = clamp(15, 0, 10);
    if r3 != 10 {
        print(f"FAIL clamp(15,0,10): expected 10, got {r3}");
        return 1;
    }

    let r4 = clamp(5, 5, 5);
    if r4 != 5 {
        print(f"FAIL clamp(5,5,5): expected 5, got {r4}");
        return 1;
    }

    print("  clamp_contracts: OK");
    0
}

fn test_gcd_contracts() -> Int {
    let r1 = gcd(12, 8);
    if r1 != 4 {
        print(f"FAIL gcd(12,8): expected 4, got {r1}");
        return 1;
    }

    let r2 = gcd(17, 13);
    if r2 != 1 {
        print(f"FAIL gcd(17,13): expected 1, got {r2}");
        return 1;
    }

    let r3 = gcd(100, 75);
    if r3 != 25 {
        print(f"FAIL gcd(100,75): expected 25, got {r3}");
        return 1;
    }

    let r4 = gcd(7, 7);
    if r4 != 7 {
        print(f"FAIL gcd(7,7): expected 7, got {r4}");
        return 1;
    }

    print("  gcd_contracts: OK");
    0
}

fn main() -> Int {
    let mut failures = 0;
    failures = failures + test_sqrt_contracts();
    failures = failures + test_binary_search_contracts();
    failures = failures + test_clamp_contracts();
    failures = failures + test_gcd_contracts();

    if failures == 0 {
        print("All verification contract tests passed");
    }
    failures
}
