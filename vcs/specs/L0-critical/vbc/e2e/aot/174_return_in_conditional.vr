// @test: unit
// @tier: 0
// @level: L0
// @tags: aot, codegen, return, conditional, regression
// @expect: pass
// Bug 3 reproducer: return inside if/else should not produce invalid LLVM IR.

fn abs_val(x: Int) -> Int {
    if x < 0 {
        return -x;
    }
    return x;
}

fn classify(n: Int) -> Int {
    if n < 0 {
        return 0;
    }
    if n == 0 {
        return 1;
    }
    if n < 10 {
        return 2;
    }
    return 3;
}

fn early_return_loop(n: Int) -> Int {
    let mut i = 0;
    while i < n {
        if i == 5 {
            return 100;
        }
        i = i + 1;
    }
    return 0;
}

fn main() -> Int {
    assert_eq(abs_val(-42), 42);
    assert_eq(abs_val(7), 7);
    assert_eq(abs_val(0), 0);

    assert_eq(classify(-5), 0);
    assert_eq(classify(0), 1);
    assert_eq(classify(3), 2);
    assert_eq(classify(99), 3);

    assert_eq(early_return_loop(3), 0);
    assert_eq(early_return_loop(10), 100);

    0
}
