// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, collections
// @timeout: 5000
// @expected-exit: 0
//
// Interpreter e2e test: List operations with literals and indexing

fn test_list_literal() {
    let lst = [1, 2, 3, 4, 5];
    assert_eq(lst[0], 1);
    assert_eq(lst[1], 2);
    assert_eq(lst[2], 3);
    assert_eq(lst[3], 4);
    assert_eq(lst[4], 5);
}

fn test_list_sum_loop() {
    let lst = [10, 20, 30, 40, 50];
    let mut sum = 0;
    let mut i = 0;
    while i < 5 {
        sum = sum + lst[i];
        i = i + 1;
    }
    assert_eq(sum, 150);
}

fn test_list_squares() {
    let squares = [0, 1, 4, 9, 16, 25, 36, 49, 64, 81];
    let mut i = 0;
    while i < 10 {
        assert_eq(squares[i], i * i);
        i = i + 1;
    }
}

fn test_list_text() {
    let words = ["hello", "world", "foo"];
    assert_eq(words[0], "hello");
    assert_eq(words[1], "world");
    assert_eq(words[2], "foo");
}

fn test_list_bool() {
    let flags = [true, false, true, true, false];
    assert_eq(flags[0], true);
    assert_eq(flags[1], false);
    assert_eq(flags[2], true);
    assert_eq(flags[3], true);
    assert_eq(flags[4], false);
}

fn test_list_negative() {
    let vals = [-5, -3, -1, 0, 1, 3, 5];
    assert_eq(vals[0], -5);
    assert_eq(vals[3], 0);
    assert_eq(vals[6], 5);
    // Sum should be 0
    let mut sum = 0;
    let mut i = 0;
    while i < 7 {
        sum = sum + vals[i];
        i = i + 1;
    }
    assert_eq(sum, 0);
}

fn test_list_search() {
    let data = [5, 12, 3, 8, 1, 7, 15, 2, 9, 4];
    // Find max via loop
    let mut max_val = data[0];
    let mut i = 1;
    while i < 10 {
        if data[i] > max_val {
            max_val = data[i];
        }
        i = i + 1;
    }
    assert_eq(max_val, 15);

    // Find min
    let mut min_val = data[0];
    let mut j = 1;
    while j < 10 {
        if data[j] < min_val {
            min_val = data[j];
        }
        j = j + 1;
    }
    assert_eq(min_val, 1);
}

fn test_list_reverse_copy() {
    let src = [1, 2, 3, 4, 5];
    // Manual reverse into new array
    let rev = [src[4], src[3], src[2], src[1], src[0]];
    assert_eq(rev[0], 5);
    assert_eq(rev[1], 4);
    assert_eq(rev[2], 3);
    assert_eq(rev[3], 2);
    assert_eq(rev[4], 1);
}

fn test_list_two_arrays() {
    let a = [1, 2, 3];
    let b = [10, 20, 30];
    // Pairwise sum
    assert_eq(a[0] + b[0], 11);
    assert_eq(a[1] + b[1], 22);
    assert_eq(a[2] + b[2], 33);
    // Dot product
    let dot = a[0] * b[0] + a[1] * b[1] + a[2] * b[2];
    assert_eq(dot, 140);
}

fn main() -> Int {
    test_list_literal();
    test_list_sum_loop();
    test_list_squares();
    test_list_text();
    test_list_bool();
    test_list_negative();
    test_list_search();
    test_list_reverse_copy();
    test_list_two_arrays();
    print("[OK] 178_interp_collections");
    0
}
