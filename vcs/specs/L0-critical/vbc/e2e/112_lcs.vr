        r79: if idx == 79 { val } else { g.r79 },
        r80: if idx == 80 { val } else { g.r80 }
    }
}

// ============================================================================
// LCS length: standard DP
// dp[i][j] = LCS length of a[0..i) and b[0..j)
// Stored at index i * (len_b + 1) + j
// ============================================================================

fn lcs_length(a: Arr8, b: Arr8) -> Int {
    let m = a.len;
    let n = b.len;
    let cols = n + 1;
    let mut dp = grid_new();
    // Row 0 and column 0 are already 0

    let mut i = 1;
    while i <= m {
        let mut j = 1;
        while j <= n {
            let ai = arr_get(a, i - 1);
            let bj = arr_get(b, j - 1);
            if ai == bj {
                let diag = grid_get(dp, (i - 1) * cols + (j - 1));
                dp = grid_set(dp, i * cols + j, diag + 1);
            } else {
                let top = grid_get(dp, (i - 1) * cols + j);
                let left = grid_get(dp, i * cols + (j - 1));
                if top > left {
                    dp = grid_set(dp, i * cols + j, top);
                } else {
                    dp = grid_set(dp, i * cols + j, left);
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }

    grid_get(dp, m * cols + n)
}

// ============================================================================
// Test 1: Classic LCS example
// "ABCBDAB" vs "BDCAB" encoded as ints (A=1,B=2,C=3,D=4)
// LCS = "BCAB" = length 4
// ============================================================================

@test
fn test_classic_lcs() {
    // A=1, B=2, C=3, D=4
    let a = arr_from7(1, 2, 3, 2, 4, 1, 2);    // ABCBDAB
    let b = arr_from5(2, 4, 3, 1, 2);            // BDCAB
    let result = lcs_length(a, b);
    assert_eq(result, 4);

    print("  test_classic_lcs: ok");
}

// ============================================================================
// Test 2: Identical sequences
// ============================================================================

@test
fn test_identical_sequences() {
    let a = arr_from5(1, 2, 3, 4, 5);
    let b = arr_from5(1, 2, 3, 4, 5);
    assert_eq(lcs_length(a, b), 5);

    let c = arr_from3(10, 20, 30);
    let d = arr_from3(10, 20, 30);
    assert_eq(lcs_length(c, d), 3);

    print("  test_identical_sequences: ok");
}

// ============================================================================
// Test 3: No common elements
// ============================================================================

@test
fn test_no_common() {
    let a = arr_from4(1, 2, 3, 4);
    let b = arr_from4(5, 6, 7, 8);
    assert_eq(lcs_length(a, b), 0);

    print("  test_no_common: ok");
}

// ============================================================================
// Test 4: One empty sequence
// ============================================================================

@test
fn test_empty_sequence() {
    let a = arr_from5(1, 2, 3, 4, 5);
    let b = arr_empty();
    assert_eq(lcs_length(a, b), 0);
    assert_eq(lcs_length(b, a), 0);

    // Both empty
    let c = arr_empty();
    let d = arr_empty();
    assert_eq(lcs_length(c, d), 0);

    print("  test_empty_sequence: ok");
}

// ============================================================================
// Test 5: Subsequence patterns
// ============================================================================

@test
fn test_subsequence_patterns() {
    // a is a subsequence of b
    let a = arr_from3(2, 4, 6);
    let b = arr_from7(1, 2, 3, 4, 5, 6, 7);
    assert_eq(lcs_length(a, b), 3);

    // Single common element
    let c = arr_from4(1, 2, 3, 4);
    let d = arr_from4(5, 6, 3, 7);
    assert_eq(lcs_length(c, d), 1);

    // Repeated elements: a=[1,1,1,1], b=[1,1]
    let e = arr_from4(1, 1, 1, 1);
    let f = Arr8 { e0: 1, e1: 1, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0, len: 2 };
    assert_eq(lcs_length(e, f), 2);

    // Interleaved: a=[1,3,5,7], b=[2,3,6,7] => LCS=[3,7]=2
    let g = arr_from4(1, 3, 5, 7);
    let h = arr_from4(2, 3, 6, 7);
    assert_eq(lcs_length(g, h), 2);

    print("  test_subsequence_patterns: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_classic_lcs();
    test_identical_sequences();
    test_no_common();
    test_empty_sequence();
    test_subsequence_patterns();
    print("[OK] 112_lcs");
    0
}
