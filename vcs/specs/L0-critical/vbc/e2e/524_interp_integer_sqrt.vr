// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, integer_sqrt, newton_method, binary_search, number_theory
// @timeout: 15000
// @expected-exit: 0
//
// Integer square root: floor(sqrt(n)) computed by two methods.
// Method A: Newton's method (iterative refinement using x_{n+1} = (x_n + n/x_n) / 2).
// Method B: Binary search over [0, n].

// Newton's method integer square root.
fn isqrt_newton(n: Int) -> Int {
    if n < 0 { return 0; }
    if n == 0 { return 0; }
    if n == 1 { return 1; }
    let mut x = n / 2;
    let mut prev = 0;
    // Iterate until convergence (x stops decreasing).
    let mut iter = 0;
    while iter < 100 {
        let nx = (x + n / x) / 2;
        if nx >= x { return x; }
        prev = x;
        x = nx;
        iter = iter + 1;
    }
    x
}

// Binary search integer square root.
fn isqrt_bsearch(n: Int) -> Int {
    if n < 0 { return 0; }
    if n == 0 { return 0; }
    let mut lo = 0;
    let mut hi = n;
    // hi can be capped at n/2+1 for large n, but for test inputs this is fine.
    // Cap hi at 100000 to keep iterations bounded.
    if hi > 100000 { hi = 100000; }
    let mut result = 0;
    while lo <= hi {
        let mid = (lo + hi) / 2;
        let sq = mid * mid;
        if sq == n {
            return mid;
        } else if sq < n {
            result = mid;
            lo = mid + 1;
        } else {
            hi = mid - 1;
        }
    }
    result
}

fn isqrt_verify(n: Int, r: Int) -> Int {
    // r = floor(sqrt(n)) iff r*r <= n < (r+1)*(r+1)
    let r1 = r + 1;
    if r * r <= n && n < r1 * r1 { 1 } else { 0 }
}

fn test_perfect_squares() {
    assert_eq(isqrt_newton(0), 0);
    assert_eq(isqrt_newton(1), 1);
    assert_eq(isqrt_newton(4), 2);
    assert_eq(isqrt_newton(9), 3);
    assert_eq(isqrt_newton(16), 4);
    assert_eq(isqrt_newton(25), 5);
    assert_eq(isqrt_newton(100), 10);
    assert_eq(isqrt_newton(10000), 100);
    assert_eq(isqrt_verify(100, isqrt_newton(100)), 1);
    print("perfect_squares: ok");
}

fn test_non_perfect_squares() {
    // floor(sqrt(2)) = 1
    assert_eq(isqrt_newton(2), 1);
    assert_eq(isqrt_verify(2, 1), 1);
    // floor(sqrt(10)) = 3
    assert_eq(isqrt_newton(10), 3);
    assert_eq(isqrt_verify(10, 3), 1);
    // floor(sqrt(99)) = 9
    assert_eq(isqrt_newton(99), 9);
    assert_eq(isqrt_verify(99, 9), 1);
    // floor(sqrt(200)) = 14
    assert_eq(isqrt_newton(200), 14);
    assert_eq(isqrt_verify(200, 14), 1);
    print("non_perfect_squares: ok");
}

fn test_bsearch_matches_newton() {
    // Both methods must agree on all test cases.
    assert_eq(isqrt_bsearch(0),   isqrt_newton(0));
    assert_eq(isqrt_bsearch(1),   isqrt_newton(1));
    assert_eq(isqrt_bsearch(4),   isqrt_newton(4));
    assert_eq(isqrt_bsearch(9),   isqrt_newton(9));
    assert_eq(isqrt_bsearch(15),  isqrt_newton(15));
    assert_eq(isqrt_bsearch(16),  isqrt_newton(16));
    assert_eq(isqrt_bsearch(17),  isqrt_newton(17));
    assert_eq(isqrt_bsearch(100), isqrt_newton(100));
    assert_eq(isqrt_bsearch(999), isqrt_newton(999));
    print("bsearch_matches_newton: ok");
}

fn test_boundary_values() {
    // n = r^2 - 1: just below a perfect square.
    assert_eq(isqrt_newton(3),  1);   // 2^2-1=3, floor=1
    assert_eq(isqrt_newton(8),  2);   // 3^2-1=8, floor=2
    assert_eq(isqrt_newton(24), 4);   // 5^2-1=24, floor=4
    assert_eq(isqrt_newton(35), 5);   // 6^2-1=35, floor=5
    // Verify all are correct.
    assert_eq(isqrt_verify(3,  isqrt_newton(3)),  1);
    assert_eq(isqrt_verify(24, isqrt_newton(24)), 1);
    assert_eq(isqrt_verify(35, isqrt_newton(35)), 1);
    print("boundary_values: ok");
}

fn test_large_values() {
    // isqrt(9801) = 99
    assert_eq(isqrt_newton(9801), 99);
    assert_eq(isqrt_verify(9801, 99), 1);
    // isqrt(9999) = 99
    assert_eq(isqrt_newton(9999), 99);
    assert_eq(isqrt_verify(9999, 99), 1);
    // isqrt(10000) = 100
    assert_eq(isqrt_newton(10000), 100);
    print("large_values: ok");
}

fn main() -> Int {
    test_perfect_squares();
    test_non_perfect_squares();
    test_bsearch_matches_newton();
    test_boundary_values();
    test_large_values();
    print("[OK] 524_interp_integer_sqrt");
    0
}
