// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, interval, merge
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Merge overlapping intervals. Given a list of (start, end)
// pairs, merge overlapping ones. Test various overlap patterns.

// =============================================================================
// Intervals stored as pairs: starts[i], ends[i]
// =============================================================================

type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn arr8_new() -> Arr8 {
    Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 }
}

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 }
    }
}

type Intervals is { starts: Arr8, ends: Arr8, len: Int };

// =============================================================================
// Sort intervals by start time (insertion sort)
// =============================================================================

fn sort_intervals(iv: Intervals) -> Intervals {
    let mut starts = iv.starts;
    let mut ends = iv.ends;
    let n = iv.len;

    let mut i = 1;
    while i < n {
        let key_s = arr8_get(starts, i);
        let key_e = arr8_get(ends, i);
        let mut j = i - 1;
        let mut done = 0;
        while j >= 0 && done == 0 {
            if arr8_get(starts, j) > key_s {
                starts = arr8_set(starts, j + 1, arr8_get(starts, j));
                ends = arr8_set(ends, j + 1, arr8_get(ends, j));
                j = j - 1;
            } else {
                done = 1;
            }
        }
        starts = arr8_set(starts, j + 1, key_s);
        ends = arr8_set(ends, j + 1, key_e);
        i = i + 1;
    }

    Intervals { starts: starts, ends: ends, len: n }
}

// =============================================================================
// Merge overlapping intervals
// =============================================================================

fn max_val(a: Int, b: Int) -> Int {
    if a > b { a } else { b }
}

fn merge_intervals(iv: Intervals) -> Intervals {
    if iv.len <= 0 {
        return iv;
    }

    // First sort by start
    let sorted = sort_intervals(iv);

    let mut out_starts = arr8_new();
    let mut out_ends = arr8_new();
    let mut out_len = 0;

    // Start with first interval
    let mut cur_start = arr8_get(sorted.starts, 0);
    let mut cur_end = arr8_get(sorted.ends, 0);

    let mut i = 1;
    while i < sorted.len {
        let next_start = arr8_get(sorted.starts, i);
        let next_end = arr8_get(sorted.ends, i);

        if next_start <= cur_end {
            // Overlapping or adjacent — extend current
            cur_end = max_val(cur_end, next_end);
        } else {
            // No overlap — emit current, start new
            out_starts = arr8_set(out_starts, out_len, cur_start);
            out_ends = arr8_set(out_ends, out_len, cur_end);
            out_len = out_len + 1;
            cur_start = next_start;
            cur_end = next_end;
        }
        i = i + 1;
    }

    // Emit last interval
    out_starts = arr8_set(out_starts, out_len, cur_start);
    out_ends = arr8_set(out_ends, out_len, cur_end);
    out_len = out_len + 1;

    Intervals { starts: out_starts, ends: out_ends, len: out_len }
}

// =============================================================================
// Test: no overlap
// [1,3], [5,7], [9,11]
// =============================================================================

fn test_no_overlap() {
    let starts = Arr8 { e0: 1, e1: 5, e2: 9, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 3, e1: 7, e2: 11, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 3 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 3);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 3);
    assert_eq(arr8_get(merged.starts, 1), 5);
    assert_eq(arr8_get(merged.ends, 1), 7);
    assert_eq(arr8_get(merged.starts, 2), 9);
    assert_eq(arr8_get(merged.ends, 2), 11);
}

// =============================================================================
// Test: all overlap into one
// [1,10], [2,5], [3,8]
// =============================================================================

fn test_all_overlap() {
    let starts = Arr8 { e0: 1, e1: 2, e2: 3, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 10, e1: 5, e2: 8, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 3 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 1);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 10);
}

// =============================================================================
// Test: partial overlap
// [1,3], [2,6], [8,10], [15,18]
// => [1,6], [8,10], [15,18]
// =============================================================================

fn test_partial_overlap() {
    let starts = Arr8 { e0: 1, e1: 2, e2: 8, e3: 15, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 3, e1: 6, e2: 10, e3: 18, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 4 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 3);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 6);
    assert_eq(arr8_get(merged.starts, 1), 8);
    assert_eq(arr8_get(merged.ends, 1), 10);
    assert_eq(arr8_get(merged.starts, 2), 15);
    assert_eq(arr8_get(merged.ends, 2), 18);
}

// =============================================================================
// Test: unsorted input
// [6,8], [1,3], [2,4], [10,12]
// After sort: [1,3], [2,4], [6,8], [10,12]
// Merged: [1,4], [6,8], [10,12]
// =============================================================================

fn test_unsorted_input() {
    let starts = Arr8 { e0: 6, e1: 1, e2: 2, e3: 10, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 8, e1: 3, e2: 4, e3: 12, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 4 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 3);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 4);
    assert_eq(arr8_get(merged.starts, 1), 6);
    assert_eq(arr8_get(merged.ends, 1), 8);
    assert_eq(arr8_get(merged.starts, 2), 10);
    assert_eq(arr8_get(merged.ends, 2), 12);
}

// =============================================================================
// Test: adjacent intervals (touching but not overlapping)
// [1,5], [5,10] — these touch at 5, should merge
// =============================================================================

fn test_adjacent() {
    let starts = Arr8 { e0: 1, e1: 5, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 5, e1: 10, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 2 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 1);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 10);
}

// =============================================================================
// Test: single interval
// =============================================================================

fn test_single_interval() {
    let starts = Arr8 { e0: 5, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 10, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 1 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 1);
    assert_eq(arr8_get(merged.starts, 0), 5);
    assert_eq(arr8_get(merged.ends, 0), 10);
}

// =============================================================================
// Test: nested intervals
// [1,10], [2,3], [4,5], [6,7]
// All nested inside [1,10]
// =============================================================================

fn test_nested() {
    let starts = Arr8 { e0: 1, e1: 2, e2: 4, e3: 6, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 10, e1: 3, e2: 5, e3: 7, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 4 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 1);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 10);
}

// =============================================================================
// Test: chain of overlapping intervals
// [1,3], [2,5], [4,7], [6,9]
// => [1,9]
// =============================================================================

fn test_chain_overlap() {
    let starts = Arr8 { e0: 1, e1: 2, e2: 4, e3: 6, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 3, e1: 5, e2: 7, e3: 9, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 4 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 1);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 9);
}

// =============================================================================
// Test: duplicate intervals
// [1,5], [1,5], [1,5]
// =============================================================================

fn test_duplicates() {
    let starts = Arr8 { e0: 1, e1: 1, e2: 1, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let ends = Arr8 { e0: 5, e1: 5, e2: 5, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 };
    let iv = Intervals { starts: starts, ends: ends, len: 3 };
    let merged = merge_intervals(iv);

    assert_eq(merged.len, 1);
    assert_eq(arr8_get(merged.starts, 0), 1);
    assert_eq(arr8_get(merged.ends, 0), 5);
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_no_overlap();
    test_all_overlap();
    test_partial_overlap();
    test_unsorted_input();
    test_adjacent();
    test_single_interval();
    test_nested();
    test_chain_overlap();
    test_duplicates();
    print("[OK] 278_interp_interval_merge");
    0
}
