// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, boolean, logic
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: boolean AND, OR, NOT, short-circuit evaluation,
// bool-to-int coercion

// =============================================================================
// Boolean AND
// =============================================================================

fn test_and_basic() {
    assert_eq(true && true, true);
    assert_eq(true && false, false);
    assert_eq(false && true, false);
    assert_eq(false && false, false);
}

fn test_and_with_expressions() {
    assert_eq(1 > 0 && 2 > 1, true);
    assert_eq(1 > 0 && 2 < 1, false);
    assert_eq(1 < 0 && 2 > 1, false);
    assert_eq(1 < 0 && 2 < 1, false);
}

// =============================================================================
// Boolean OR
// =============================================================================

fn test_or_basic() {
    assert_eq(true || true, true);
    assert_eq(true || false, true);
    assert_eq(false || true, true);
    assert_eq(false || false, false);
}

fn test_or_with_expressions() {
    assert_eq(1 > 0 || 2 > 1, true);
    assert_eq(1 > 0 || 2 < 1, true);
    assert_eq(1 < 0 || 2 > 1, true);
    assert_eq(1 < 0 || 2 < 1, false);
}

// =============================================================================
// Boolean NOT
// =============================================================================

fn test_not_basic() {
    assert_eq(!true, false);
    assert_eq(!false, true);
    assert_eq(!!true, true);
    assert_eq(!!false, false);
}

fn test_not_with_comparisons() {
    assert_eq(!(1 > 2), true);
    assert_eq(!(1 < 2), false);
    assert_eq(!(5 == 5), false);
    assert_eq(!(5 != 5), true);
}

// =============================================================================
// Short-circuit evaluation
// =============================================================================

fn always_true() -> Bool {
    true
}

fn always_false() -> Bool {
    false
}

fn test_short_circuit_and() {
    // In `false && expr`, expr should not matter
    let result = false && always_true();
    assert_eq(result, false);
}

fn test_short_circuit_or() {
    // In `true || expr`, expr should not matter
    let result = true || always_false();
    assert_eq(result, true);
}

fn test_short_circuit_chain() {
    // Short circuit in chains
    assert_eq(true && true && true, true);
    assert_eq(true && false && true, false);
    assert_eq(false || false || true, true);
    assert_eq(false || false || false, false);
}

// =============================================================================
// Boolean in conditionals
// =============================================================================

fn test_bool_in_if() {
    let x = true;
    let result = if x { 1 } else { 0 };
    assert_eq(result, 1);

    let y = false;
    let result2 = if y { 1 } else { 0 };
    assert_eq(result2, 0);
}

fn test_bool_complex_condition() {
    let a = 10;
    let b = 20;
    let c = 30;
    // a < b AND b < c
    assert(a < b && b < c);
    // NOT (a > c)
    assert(!(a > c));
    // a < b OR b > c
    assert(a < b || b > c);
}

// =============================================================================
// Bool-to-int coercion
// =============================================================================

fn test_bool_int_comparison() {
    // true coerces to 1, false to 0 in comparisons
    assert_eq(true, 1);
    assert_eq(false, 0);
    assert_eq(1 > 0, true);
    assert_eq(0 > 1, false);
}

fn main() -> Int {
    test_and_basic();
    test_and_with_expressions();
    test_or_basic();
    test_or_with_expressions();
    test_not_basic();
    test_not_with_comparisons();
    test_short_circuit_and();
    test_short_circuit_or();
    test_short_circuit_chain();
    test_bool_in_if();
    test_bool_complex_condition();
    test_bool_int_comparison();
    print("[OK] 213_interp_boolean_ops");
    0
}
