// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, recursion, algorithms, fibonacci, gcd, towers
// @timeout: 50000
// @expected-exit: 0
//
// End-to-end: recursive algorithms through VBC interpreter

// ============================================================================
// Basic recursion
// ============================================================================

@allow(unbounded_recursion)
fn factorial(n: Int) -> Int {
    if n <= 1 { 1 }
    else { n * factorial(n - 1) }
}

fn test_factorial() {
    assert_eq(factorial(0), 1);
    assert_eq(factorial(1), 1);
    assert_eq(factorial(5), 120);
    assert_eq(factorial(10), 3628800);
    assert_eq(factorial(12), 479001600);
}

@allow(unbounded_recursion)
fn fibonacci(n: Int) -> Int {
    if n <= 0 { 0 }
    else if n == 1 { 1 }
    else { fibonacci(n - 1) + fibonacci(n - 2) }
}

fn test_fibonacci() {
    assert_eq(fibonacci(0), 0);
    assert_eq(fibonacci(1), 1);
    assert_eq(fibonacci(2), 1);
    assert_eq(fibonacci(5), 5);
    assert_eq(fibonacci(10), 55);
    assert_eq(fibonacci(15), 610);
}

// ============================================================================
// Tail-recursive patterns
// ============================================================================

@allow(unbounded_recursion)
fn fib_tail(n: Int, a: Int, b: Int) -> Int {
    if n == 0 { a }
    else { fib_tail(n - 1, b, a + b) }
}

fn test_fibonacci_tail() {
    assert_eq(fib_tail(0, 0, 1), 0);
    assert_eq(fib_tail(1, 0, 1), 1);
    assert_eq(fib_tail(10, 0, 1), 55);
    assert_eq(fib_tail(20, 0, 1), 6765);
    assert_eq(fib_tail(30, 0, 1), 832040);
}

@allow(unbounded_recursion)
fn fact_tail(n: Int, acc: Int) -> Int {
    if n <= 1 { acc }
    else { fact_tail(n - 1, n * acc) }
}

fn test_factorial_tail() {
    assert_eq(fact_tail(0, 1), 1);
    assert_eq(fact_tail(1, 1), 1);
    assert_eq(fact_tail(5, 1), 120);
    assert_eq(fact_tail(10, 1), 3628800);
}

// ============================================================================
// GCD and LCM
// ============================================================================

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 { a }
    else { gcd(b, a % b) }
}

fn lcm(a: Int, b: Int) -> Int {
    a / gcd(a, b) * b
}

fn test_gcd() {
    assert_eq(gcd(12, 8), 4);
    assert_eq(gcd(17, 13), 1);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(48, 36), 12);
    assert_eq(gcd(0, 5), 5);
    assert_eq(gcd(7, 0), 7);
}

fn test_lcm() {
    assert_eq(lcm(4, 6), 12);
    assert_eq(lcm(3, 5), 15);
    assert_eq(lcm(12, 18), 36);
    assert_eq(lcm(7, 11), 77);
}

// ============================================================================
// Power and binary operations
// ============================================================================

@allow(unbounded_recursion)
fn power_rec(base: Int, exp: Int) -> Int {
    if exp == 0 { 1 }
    else if exp % 2 == 0 {
        let half = power_rec(base, exp / 2);
        half * half
    } else {
        base * power_rec(base, exp - 1)
    }
}

fn test_power() {
    assert_eq(power_rec(2, 0), 1);
    assert_eq(power_rec(2, 1), 2);
    assert_eq(power_rec(2, 10), 1024);
    assert_eq(power_rec(3, 5), 243);
    assert_eq(power_rec(5, 3), 125);
    assert_eq(power_rec(10, 6), 1000000);
}

// ============================================================================
// Ackermann function (deeply recursive)
// ============================================================================

@allow(unbounded_recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 { n + 1 }
    else if n == 0 { ackermann(m - 1, 1) }
    else { ackermann(m - 1, ackermann(m, n - 1)) }
}

fn test_ackermann() {
    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(1, 1), 3);
    assert_eq(ackermann(2, 2), 7);
    assert_eq(ackermann(3, 3), 61);
    // ackermann(3,4) = 125 — still feasible
    assert_eq(ackermann(3, 4), 125);
}

// ============================================================================
// Mutual recursion
// ============================================================================

@allow(unbounded_recursion)
fn is_even_rec(n: Int) -> Bool {
    if n == 0 { true }
    else { is_odd_rec(n - 1) }
}

@allow(unbounded_recursion)
fn is_odd_rec(n: Int) -> Bool {
    if n == 0 { false }
    else { is_even_rec(n - 1) }
}

fn test_mutual_recursion() {
    assert(is_even_rec(0));
    assert(!is_odd_rec(0));
    assert(!is_even_rec(1));
    assert(is_odd_rec(1));
    assert(is_even_rec(10));
    assert(!is_odd_rec(10));
    assert(!is_even_rec(15));
    assert(is_odd_rec(15));
}

// ============================================================================
// Tower of Hanoi (count moves)
// ============================================================================

@allow(unbounded_recursion)
fn hanoi_moves(n: Int) -> Int {
    if n <= 0 { 0 }
    else { 2 * hanoi_moves(n - 1) + 1 }
}

fn test_hanoi() {
    assert_eq(hanoi_moves(1), 1);
    assert_eq(hanoi_moves(2), 3);
    assert_eq(hanoi_moves(3), 7);
    assert_eq(hanoi_moves(4), 15);
    assert_eq(hanoi_moves(10), 1023);
    assert_eq(hanoi_moves(20), 1048575);
}

// ============================================================================
// Binary search (recursive)
// ============================================================================

// Simulate sorted array with function
fn sorted_arr(i: Int) -> Int {
    i * 3 + 1 // 1, 4, 7, 10, 13, 16, 19, 22, 25, 28
}

@allow(unbounded_recursion)
fn binary_search(target: Int, lo: Int, hi: Int) -> Int {
    if lo > hi { -1 }
    else {
        let mid = (lo + hi) / 2;
        let val = sorted_arr(mid);
        if val == target { mid }
        else if val < target { binary_search(target, mid + 1, hi) }
        else { binary_search(target, lo, mid - 1) }
    }
}

fn test_binary_search() {
    // Array: [1, 4, 7, 10, 13, 16, 19, 22, 25, 28]
    assert_eq(binary_search(1, 0, 9), 0);
    assert_eq(binary_search(10, 0, 9), 3);
    assert_eq(binary_search(28, 0, 9), 9);
    assert_eq(binary_search(7, 0, 9), 2);
    assert_eq(binary_search(5, 0, 9), -1);  // Not found
    assert_eq(binary_search(30, 0, 9), -1); // Not found
}

// ============================================================================
// Catalan numbers
// ============================================================================

@allow(unbounded_recursion)
fn catalan(n: Int) -> Int {
    if n <= 1 { 1 }
    else {
        let mut result = 0;
        let mut i = 0;
        while i < n {
            result = result + catalan(i) * catalan(n - 1 - i);
            i = i + 1;
        }
        result
    }
}

fn test_catalan() {
    assert_eq(catalan(0), 1);
    assert_eq(catalan(1), 1);
    assert_eq(catalan(2), 2);
    assert_eq(catalan(3), 5);
    assert_eq(catalan(4), 14);
    assert_eq(catalan(5), 42);
}

fn main() -> Int {
    test_factorial();
    test_fibonacci();
    test_fibonacci_tail();
    test_factorial_tail();
    test_gcd();
    test_lcm();
    test_power();
    test_ackermann();
    test_mutual_recursion();
    test_hanoi();
    test_binary_search();
    test_catalan();
    print("[OK] 014_recursion_algorithms");
    0
}
