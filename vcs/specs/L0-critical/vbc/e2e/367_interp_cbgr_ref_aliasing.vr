// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, cbgr, memory, advanced
// @timeout: 15000
// @expected-exit: 0
//
// CBGR advanced reference test: Matrix operations via refs.
// 3x3 matrix transpose, multiply, determinant, trace, and other
// matrix operations implemented through ref-based functions.

// ============================================================================
// Type definitions
// ============================================================================

type Row3 is { c0: Int, c1: Int, c2: Int };
type Mat3 is { r0: Row3, r1: Row3, r2: Row3 };

// ============================================================================
// Matrix construction and access
// ============================================================================

fn mat3_zero() -> Mat3 {
    let z = Row3 { c0: 0, c1: 0, c2: 0 };
    Mat3 { r0: z, r1: z, r2: z }
}

fn mat3_identity() -> Mat3 {
    Mat3 {
        r0: Row3 { c0: 1, c1: 0, c2: 0 },
        r1: Row3 { c0: 0, c1: 1, c2: 0 },
        r2: Row3 { c0: 0, c1: 0, c2: 1 }
    }
}

fn row3_get(r: &Row3, col: Int) -> Int {
    if col == 0 { (*r).c0 }
    else if col == 1 { (*r).c1 }
    else { (*r).c2 }
}

fn row3_set(r: &mut Row3, col: Int, val: Int) {
    if col == 0 { (*r).c0 = val; }
    else if col == 1 { (*r).c1 = val; }
    else { (*r).c2 = val; }
}

fn mat3_get_row(m: &Mat3, row: Int) -> Row3 {
    if row == 0 { (*m).r0 }
    else if row == 1 { (*m).r1 }
    else { (*m).r2 }
}

fn mat3_get(m: &Mat3, row: Int, col: Int) -> Int {
    let r = mat3_get_row(m, row);
    row3_get(&r, col)
}

fn mat3_set(m: &mut Mat3, row: Int, col: Int, val: Int) {
    if row == 0 { row3_set(&mut (*m).r0, col, val); }
    else if row == 1 { row3_set(&mut (*m).r1, col, val); }
    else { row3_set(&mut (*m).r2, col, val); }
}

// ============================================================================
// Matrix operations via references
// ============================================================================

fn mat3_trace(m: &Mat3) -> Int {
    mat3_get(m, 0, 0) + mat3_get(m, 1, 1) + mat3_get(m, 2, 2)
}

fn mat3_sum_all(m: &Mat3) -> Int {
    let mut total = 0;
    let mut r = 0;
    while r < 3 {
        let mut c = 0;
        while c < 3 {
            total = total + mat3_get(m, r, c);
            c = c + 1;
        }
        r = r + 1;
    }
    total
}

fn mat3_row_sum(m: &Mat3, row: Int) -> Int {
    mat3_get(m, row, 0) + mat3_get(m, row, 1) + mat3_get(m, row, 2)
}

fn mat3_col_sum(m: &Mat3, col: Int) -> Int {
    mat3_get(m, 0, col) + mat3_get(m, 1, col) + mat3_get(m, 2, col)
}

fn mat3_transpose(src: &Mat3, dst: &mut Mat3) {
    let mut r = 0;
    while r < 3 {
        let mut c = 0;
        while c < 3 {
            mat3_set(dst, c, r, mat3_get(src, r, c));
            c = c + 1;
        }
        r = r + 1;
    }
}

fn mat3_add(a: &Mat3, b: &Mat3, out: &mut Mat3) {
    let mut r = 0;
    while r < 3 {
        let mut c = 0;
        while c < 3 {
            mat3_set(out, r, c, mat3_get(a, r, c) + mat3_get(b, r, c));
            c = c + 1;
        }
        r = r + 1;
    }
}

fn mat3_scale(m: &mut Mat3, factor: Int) {
    let mut r = 0;
    while r < 3 {
        let mut c = 0;
        while c < 3 {
            mat3_set(m, r, c, mat3_get(m, r, c) * factor);
            c = c + 1;
        }
        r = r + 1;
    }
}

fn mat3_multiply(a: &Mat3, b: &Mat3, out: &mut Mat3) {
    let mut r = 0;
    while r < 3 {
        let mut c = 0;
        while c < 3 {
            let mut sum = 0;
            let mut k = 0;
            while k < 3 {
                sum = sum + mat3_get(a, r, k) * mat3_get(b, k, c);
                k = k + 1;
            }
            mat3_set(out, r, c, sum);
            c = c + 1;
        }
        r = r + 1;
    }
}

fn mat3_determinant(m: &Mat3) -> Int {
    let a = mat3_get(m, 0, 0);
    let b = mat3_get(m, 0, 1);
    let c = mat3_get(m, 0, 2);
    let d = mat3_get(m, 1, 0);
    let e = mat3_get(m, 1, 1);
    let f = mat3_get(m, 1, 2);
    let g = mat3_get(m, 2, 0);
    let h = mat3_get(m, 2, 1);
    let k = mat3_get(m, 2, 2);
    a * (e * k - f * h) - b * (d * k - f * g) + c * (d * h - e * g)
}

fn mat3_is_symmetric(m: &Mat3) -> Bool {
    mat3_get(m, 0, 1) == mat3_get(m, 1, 0) &&
    mat3_get(m, 0, 2) == mat3_get(m, 2, 0) &&
    mat3_get(m, 1, 2) == mat3_get(m, 2, 1)
}

// ============================================================================
// Tests
// ============================================================================

fn test_identity() {
    let id = mat3_identity();
    assert_eq(mat3_trace(&id), 3);
    assert_eq(mat3_sum_all(&id), 3);
    assert_eq(mat3_determinant(&id), 1);
    assert_eq(mat3_is_symmetric(&id), true);
}

fn test_zero() {
    let z = mat3_zero();
    assert_eq(mat3_trace(&z), 0);
    assert_eq(mat3_sum_all(&z), 0);
    assert_eq(mat3_determinant(&z), 0);
}

fn test_transpose() {
    let m = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 3 },
        r1: Row3 { c0: 4, c1: 5, c2: 6 },
        r2: Row3 { c0: 7, c1: 8, c2: 9 }
    };
    let mut t = mat3_zero();
    mat3_transpose(&m, &mut t);
    // Copy to immutable to avoid &t / &mut t conflict
    let result = t;
    assert_eq(mat3_get(&result, 0, 0), 1);
    assert_eq(mat3_get(&result, 0, 1), 4);
    assert_eq(mat3_get(&result, 0, 2), 7);
    assert_eq(mat3_get(&result, 1, 0), 2);
    assert_eq(mat3_get(&result, 1, 1), 5);
    assert_eq(mat3_get(&result, 2, 2), 9);
}

fn test_transpose_symmetric() {
    let m = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 3 },
        r1: Row3 { c0: 2, c1: 5, c2: 6 },
        r2: Row3 { c0: 3, c1: 6, c2: 9 }
    };
    assert_eq(mat3_is_symmetric(&m), true);
    let mut t = mat3_zero();
    mat3_transpose(&m, &mut t);
    // Copy to immutable to avoid &t / &mut t conflict
    let result = t;
    // Symmetric matrix: transpose = original
    assert_eq(mat3_get(&result, 0, 1), 2);
    assert_eq(mat3_get(&result, 1, 0), 2);
}

fn test_add() {
    let a = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 3 },
        r1: Row3 { c0: 4, c1: 5, c2: 6 },
        r2: Row3 { c0: 7, c1: 8, c2: 9 }
    };
    let b = Mat3 {
        r0: Row3 { c0: 9, c1: 8, c2: 7 },
        r1: Row3 { c0: 6, c1: 5, c2: 4 },
        r2: Row3 { c0: 3, c1: 2, c2: 1 }
    };
    let mut out = mat3_zero();
    mat3_add(&a, &b, &mut out);
    // Copy to immutable to avoid &out / &mut out conflict
    let result = out;
    // Every element should be 10
    assert_eq(mat3_get(&result, 0, 0), 10);
    assert_eq(mat3_get(&result, 1, 1), 10);
    assert_eq(mat3_get(&result, 2, 2), 10);
    assert_eq(mat3_sum_all(&result), 90);
}

fn test_scale() {
    let mut m = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 3 },
        r1: Row3 { c0: 4, c1: 5, c2: 6 },
        r2: Row3 { c0: 7, c1: 8, c2: 9 }
    };
    mat3_scale(&mut m, 3);
    // Copy to immutable to avoid &m / &mut m conflict
    let result = m;
    assert_eq(mat3_get(&result, 0, 0), 3);
    assert_eq(mat3_get(&result, 1, 1), 15);
    assert_eq(mat3_get(&result, 2, 2), 27);
    assert_eq(mat3_sum_all(&result), 135); // 45*3
}

fn test_multiply_identity() {
    let a = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 3 },
        r1: Row3 { c0: 4, c1: 5, c2: 6 },
        r2: Row3 { c0: 7, c1: 8, c2: 9 }
    };
    let id = mat3_identity();
    let mut out = mat3_zero();
    mat3_multiply(&a, &id, &mut out);
    // Copy to immutable to avoid &out / &mut out conflict
    let result = out;
    assert_eq(mat3_get(&result, 0, 0), 1);
    assert_eq(mat3_get(&result, 0, 1), 2);
    assert_eq(mat3_get(&result, 1, 1), 5);
    assert_eq(mat3_get(&result, 2, 2), 9);
}

fn test_multiply_general() {
    let a = Mat3 {
        r0: Row3 { c0: 1, c1: 0, c2: 2 },
        r1: Row3 { c0: 0, c1: 1, c2: 0 },
        r2: Row3 { c0: 3, c1: 0, c2: 1 }
    };
    let b = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 0 },
        r1: Row3 { c0: 0, c1: 1, c2: 1 },
        r2: Row3 { c0: 1, c1: 0, c2: 1 }
    };
    let mut out = mat3_zero();
    mat3_multiply(&a, &b, &mut out);
    // Copy to immutable to avoid &out / &mut out conflict
    let result = out;
    // Row 0: [1*1+0*0+2*1, 1*2+0*1+2*0, 1*0+0*1+2*1] = [3, 2, 2]
    assert_eq(mat3_get(&result, 0, 0), 3);
    assert_eq(mat3_get(&result, 0, 1), 2);
    assert_eq(mat3_get(&result, 0, 2), 2);
    // Row 1: [0,1,1]
    assert_eq(mat3_get(&result, 1, 0), 0);
    assert_eq(mat3_get(&result, 1, 1), 1);
    assert_eq(mat3_get(&result, 1, 2), 1);
    // Row 2: [3*1+0+1*1, 3*2+0+0, 3*0+0+1*1] = [4, 6, 1]
    assert_eq(mat3_get(&result, 2, 0), 4);
    assert_eq(mat3_get(&result, 2, 1), 6);
    assert_eq(mat3_get(&result, 2, 2), 1);
}

fn test_determinant() {
    let m = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 3 },
        r1: Row3 { c0: 4, c1: 5, c2: 6 },
        r2: Row3 { c0: 7, c1: 8, c2: 9 }
    };
    // det = 1*(45-48) - 2*(36-42) + 3*(32-35) = -3+12-9 = 0
    assert_eq(mat3_determinant(&m), 0);
}

fn test_determinant_nonzero() {
    let m = Mat3 {
        r0: Row3 { c0: 2, c1: 1, c2: 0 },
        r1: Row3 { c0: 0, c1: 3, c2: 1 },
        r2: Row3 { c0: 1, c1: 0, c2: 2 }
    };
    // det = 2*(6-0) - 1*(0-1) + 0*(0-3) = 12+1+0 = 13
    assert_eq(mat3_determinant(&m), 13);
}

fn test_row_col_sums() {
    let m = Mat3 {
        r0: Row3 { c0: 1, c1: 2, c2: 3 },
        r1: Row3 { c0: 4, c1: 5, c2: 6 },
        r2: Row3 { c0: 7, c1: 8, c2: 9 }
    };
    assert_eq(mat3_row_sum(&m, 0), 6);
    assert_eq(mat3_row_sum(&m, 1), 15);
    assert_eq(mat3_row_sum(&m, 2), 24);
    assert_eq(mat3_col_sum(&m, 0), 12);
    assert_eq(mat3_col_sum(&m, 1), 15);
    assert_eq(mat3_col_sum(&m, 2), 18);
}

fn test_set_and_read() {
    let mut m = mat3_zero();
    mat3_set(&mut m, 0, 0, 1);
    mat3_set(&mut m, 1, 1, 2);
    mat3_set(&mut m, 2, 2, 3);
    // Copy to immutable to avoid &m / &mut m conflict
    let result = m;
    assert_eq(mat3_trace(&result), 6);
    assert_eq(mat3_sum_all(&result), 6);
}

fn main() -> Int {
    test_identity();
    test_zero();
    test_transpose();
    test_transpose_symmetric();
    test_add();
    test_scale();
    test_multiply_identity();
    test_multiply_general();
    test_determinant();
    test_determinant_nonzero();
    test_row_col_sums();
    test_set_and_read();
    print("[OK] 367_interp_cbgr_ref_aliasing");
    0
}
