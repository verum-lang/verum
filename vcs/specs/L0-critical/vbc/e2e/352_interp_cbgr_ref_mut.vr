// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, cbgr, memory, mutable-references
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: CBGR mutable reference operations.
// Tests Tier 0 mutable references (&mut x), write-through (*ref = val),
// and sequential mutable borrow patterns.

// =============================================================================
// Helper functions taking mutable references
// =============================================================================

fn increment(r: &mut Int) {
    *r = *r + 1;
}

fn decrement(r: &mut Int) {
    *r = *r - 1;
}

fn add_to(r: &mut Int, val: Int) {
    *r = *r + val;
}

fn multiply_by(r: &mut Int, factor: Int) {
    *r = *r * factor;
}

fn set_to_zero(r: &mut Int) {
    *r = 0;
}

fn negate(r: &mut Int) {
    *r = 0 - *r;
}

// =============================================================================
// Test: Basic mutable reference and write-through
// =============================================================================

fn test_basic_mut_ref() {
    let mut x = 0;
    let r = &mut x;
    *r = 42;
    assert_eq(x, 42);
}

fn test_mut_ref_overwrite() {
    let mut x = 100;
    let r = &mut x;
    *r = 200;
    assert_eq(x, 200);
    *r = 300;
    assert_eq(x, 300);
}

fn test_mut_ref_read_then_write() {
    let mut x = 50;
    let r = &mut x;
    let old = *r;
    *r = old + 10;
    assert_eq(x, 60);
}

// =============================================================================
// Test: Increment/decrement through mutable references
// =============================================================================

fn test_increment() {
    let mut x = 0;
    increment(&mut x);
    assert_eq(x, 1);
    increment(&mut x);
    assert_eq(x, 2);
    increment(&mut x);
    assert_eq(x, 3);
}

fn test_decrement() {
    let mut x = 10;
    decrement(&mut x);
    assert_eq(x, 9);
    decrement(&mut x);
    assert_eq(x, 8);
}

fn test_increment_in_loop() {
    let mut counter = 0;
    let mut i = 0;
    while i < 10 {
        increment(&mut counter);
        i = i + 1;
    }
    assert_eq(counter, 10);
}

// =============================================================================
// Test: add_to and multiply_by through mutable refs
// =============================================================================

fn test_add_to() {
    let mut x = 5;
    add_to(&mut x, 10);
    assert_eq(x, 15);
    add_to(&mut x, 25);
    assert_eq(x, 40);
}

fn test_multiply_by() {
    let mut x = 3;
    multiply_by(&mut x, 4);
    assert_eq(x, 12);
    multiply_by(&mut x, 5);
    assert_eq(x, 60);
}

fn test_set_to_zero() {
    let mut x = 999;
    set_to_zero(&mut x);
    assert_eq(x, 0);
}

fn test_negate() {
    let mut x = 42;
    negate(&mut x);
    assert_eq(x, -42);
    negate(&mut x);
    assert_eq(x, 42);
}

// =============================================================================
// Test: Sequential mutable borrows
// =============================================================================

fn test_sequential_mut_borrows() {
    let mut x = 0;
    // First mutable borrow
    let r1 = &mut x;
    *r1 = 10;
    assert_eq(x, 10);
    // Second mutable borrow (r1 released)
    let r2 = &mut x;
    *r2 = 20;
    assert_eq(x, 20);
    // Third mutable borrow
    let r3 = &mut x;
    *r3 = 30;
    assert_eq(x, 30);
}

fn test_mut_borrow_accumulate() {
    let mut sum = 0;
    let mut i = 0;
    while i < 10 {
        let r = &mut sum;
        *r = *r + i;
        i = i + 1;
    }
    // 0+1+2+...+9 = 45
    assert_eq(sum, 45);
}

fn test_mut_borrow_factorial_loop() {
    let mut result = 1;
    let mut i = 1;
    while i <= 6 {
        let r = &mut result;
        *r = *r * i;
        i = i + 1;
    }
    // 6! = 720
    assert_eq(result, 720);
}

// =============================================================================
// Test: Swap operation through mutable references
// =============================================================================

fn swap_values(a: &mut Int, b: &mut Int) {
    let tmp = *a;
    *a = *b;
    *b = tmp;
}

fn test_swap() {
    let mut x = 10;
    let mut y = 20;
    swap_values(&mut x, &mut y);
    assert_eq(x, 20);
    assert_eq(y, 10);
}

fn test_swap_same_value() {
    let mut x = 42;
    let mut y = 42;
    swap_values(&mut x, &mut y);
    assert_eq(x, 42);
    assert_eq(y, 42);
}

fn test_swap_negative() {
    let mut x = -5;
    let mut y = 5;
    swap_values(&mut x, &mut y);
    assert_eq(x, 5);
    assert_eq(y, -5);
}

// =============================================================================
// Test: Multiple mutable variables in sequence
// =============================================================================

fn test_rotate_three_vars() {
    let mut a = 1;
    let mut b = 2;
    let mut c = 3;
    // Rotate: a->b->c->a using mutable refs
    let tmp = a;
    let ra = &mut a;
    *ra = b;
    let rb = &mut b;
    *rb = c;
    let rc = &mut c;
    *rc = tmp;
    assert_eq(a, 2);
    assert_eq(b, 3);
    assert_eq(c, 1);
}

// =============================================================================
// Test: Bool mutable references
// =============================================================================

fn toggle(flag: &mut Bool) {
    if *flag {
        *flag = false;
    } else {
        *flag = true;
    }
}

fn test_toggle_bool() {
    let mut flag = false;
    toggle(&mut flag);
    assert(flag);
    toggle(&mut flag);
    assert(!flag);
    toggle(&mut flag);
    assert(flag);
}

fn test_bool_mut_ref_direct() {
    let mut b = true;
    let r = &mut b;
    *r = false;
    assert(!b);
    *r = true;
    assert(b);
}

// =============================================================================
// Test: Complex mutation sequences
// =============================================================================

fn test_counting_loop_with_mut_ref() {
    let mut count = 0;
    let mut i = 0;
    while i < 100 {
        if i % 3 == 0 {
            increment(&mut count);
        }
        i = i + 1;
    }
    // Numbers 0-99 divisible by 3: 0,3,6,...,99 = 34 numbers
    assert_eq(count, 34);
}

fn test_alternating_add_subtract() {
    let mut val = 0;
    let mut i = 0;
    while i < 10 {
        if i % 2 == 0 {
            add_to(&mut val, 10);
        } else {
            add_to(&mut val, -3);
        }
        i = i + 1;
    }
    // 5 adds of 10 = 50, 5 adds of -3 = -15, total = 35
    assert_eq(val, 35);
}

fn test_conditional_mutation() {
    let mut x = 0;
    let mut i = 1;
    while i <= 10 {
        let r = &mut x;
        if i * i > 50 {
            *r = *r + i;
        }
        i = i + 1;
    }
    // i*i > 50 for i=8,9,10 -> x = 8+9+10 = 27
    assert_eq(x, 27);
}

fn main() -> Int {
    test_basic_mut_ref();
    test_mut_ref_overwrite();
    test_mut_ref_read_then_write();
    test_increment();
    test_decrement();
    test_increment_in_loop();
    test_add_to();
    test_multiply_by();
    test_set_to_zero();
    test_negate();
    test_sequential_mut_borrows();
    test_mut_borrow_accumulate();
    test_mut_borrow_factorial_loop();
    test_swap();
    test_swap_same_value();
    test_swap_negative();
    test_rotate_three_vars();
    test_toggle_bool();
    test_bool_mut_ref_direct();
    test_counting_loop_with_mut_ref();
    test_alternating_add_subtract();
    test_conditional_mutation();
    print("[OK] 352_interp_cbgr_ref_mut");
    0
}
