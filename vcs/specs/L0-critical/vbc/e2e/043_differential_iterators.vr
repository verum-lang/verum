// @test: differential
// @tier: 0
// @level: L0
// @tags: vbc, e2e, differential, interpreter-vs-aot, iterators, transform, filter, fold
// @timeout: 10000
// @expected-exit: 0
//
// Differential iterators test: verifies interpreter and AOT produce identical
// results for manual iteration over flat arrays, map-like transforms,
// filter-like selection, fold/reduce accumulation, and chained operations.

// ============================================================================
// Fixed-size array of 8 elements
// ============================================================================

type Arr8 is { e0: Int, e1: Int, e2: Int, e3: Int, e4: Int, e5: Int, e6: Int, e7: Int };

fn arr8_get(a: Arr8, i: Int) -> Int {
    if i == 0 { a.e0 }
    else if i == 1 { a.e1 }
    else if i == 2 { a.e2 }
    else if i == 3 { a.e3 }
    else if i == 4 { a.e4 }
    else if i == 5 { a.e5 }
    else if i == 6 { a.e6 }
    else { a.e7 }
}

fn arr8_set(a: Arr8, i: Int, v: Int) -> Arr8 {
    Arr8 {
        e0: if i == 0 { v } else { a.e0 },
        e1: if i == 1 { v } else { a.e1 },
        e2: if i == 2 { v } else { a.e2 },
        e3: if i == 3 { v } else { a.e3 },
        e4: if i == 4 { v } else { a.e4 },
        e5: if i == 5 { v } else { a.e5 },
        e6: if i == 6 { v } else { a.e6 },
        e7: if i == 7 { v } else { a.e7 },
    }
}

fn arr8_zero() -> Arr8 {
    Arr8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0 }
}

// ============================================================================
// Manual "map" — apply a transform to each element
// ============================================================================

// Double each element
fn map_double(a: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut i = 0;
    while i < n {
        result = arr8_set(result, i, arr8_get(a, i) * 2);
        i = i + 1;
    }
    result
}

// Square each element
fn map_square(a: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut i = 0;
    while i < n {
        let v = arr8_get(a, i);
        result = arr8_set(result, i, v * v);
        i = i + 1;
    }
    result
}

// Add constant to each element
fn map_add_const(a: Arr8, n: Int, c: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut i = 0;
    while i < n {
        result = arr8_set(result, i, arr8_get(a, i) + c);
        i = i + 1;
    }
    result
}

// Negate each element
fn map_negate(a: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut i = 0;
    while i < n {
        result = arr8_set(result, i, 0 - arr8_get(a, i));
        i = i + 1;
    }
    result
}

// Absolute value of each element
fn map_abs(a: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut i = 0;
    while i < n {
        let v = arr8_get(a, i);
        result = arr8_set(result, i, if v < 0 { 0 - v } else { v });
        i = i + 1;
    }
    result
}

fn test_map_transforms() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8 };

    // Double
    let doubled = map_double(a, 8);
    assert_eq(arr8_get(doubled, 0), 2);
    assert_eq(arr8_get(doubled, 3), 8);
    assert_eq(arr8_get(doubled, 7), 16);

    // Square
    let squared = map_square(a, 8);
    assert_eq(arr8_get(squared, 0), 1);
    assert_eq(arr8_get(squared, 1), 4);
    assert_eq(arr8_get(squared, 2), 9);
    assert_eq(arr8_get(squared, 7), 64);

    // Add constant
    let added = map_add_const(a, 8, 10);
    assert_eq(arr8_get(added, 0), 11);
    assert_eq(arr8_get(added, 7), 18);

    // Negate and abs
    let neg = map_negate(a, 8);
    assert_eq(arr8_get(neg, 0), 0 - 1);
    assert_eq(arr8_get(neg, 4), 0 - 5);
    let abs_neg = map_abs(neg, 8);
    assert_eq(arr8_get(abs_neg, 0), 1);
    assert_eq(arr8_get(abs_neg, 4), 5);

    print("map_transforms: ok");
}

// ============================================================================
// Manual "filter" — collect elements matching a predicate
// Returns (result_array, count)
// ============================================================================

type FilterResult is { data: Arr8, count: Int };

// Filter: keep only even elements
fn filter_even(a: Arr8, n: Int) -> FilterResult {
    let mut result = arr8_zero();
    let mut out = 0;
    let mut i = 0;
    while i < n {
        let v = arr8_get(a, i);
        if v % 2 == 0 {
            result = arr8_set(result, out, v);
            out = out + 1;
        }
        i = i + 1;
    }
    FilterResult { data: result, count: out }
}

// Filter: keep only odd elements
fn filter_odd(a: Arr8, n: Int) -> FilterResult {
    let mut result = arr8_zero();
    let mut out = 0;
    let mut i = 0;
    while i < n {
        let v = arr8_get(a, i);
        if v % 2 == 1 {
            result = arr8_set(result, out, v);
            out = out + 1;
        }
        i = i + 1;
    }
    FilterResult { data: result, count: out }
}

// Filter: keep elements > threshold
fn filter_gt(a: Arr8, n: Int, threshold: Int) -> FilterResult {
    let mut result = arr8_zero();
    let mut out = 0;
    let mut i = 0;
    while i < n {
        let v = arr8_get(a, i);
        if v > threshold {
            result = arr8_set(result, out, v);
            out = out + 1;
        }
        i = i + 1;
    }
    FilterResult { data: result, count: out }
}

// Filter: keep positive elements
fn filter_positive(a: Arr8, n: Int) -> FilterResult {
    let mut result = arr8_zero();
    let mut out = 0;
    let mut i = 0;
    while i < n {
        let v = arr8_get(a, i);
        if v > 0 {
            result = arr8_set(result, out, v);
            out = out + 1;
        }
        i = i + 1;
    }
    FilterResult { data: result, count: out }
}

fn test_filter_ops() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8 };

    // Even: 2, 4, 6, 8
    let evens = filter_even(a, 8);
    assert_eq(evens.count, 4);
    assert_eq(arr8_get(evens.data, 0), 2);
    assert_eq(arr8_get(evens.data, 1), 4);
    assert_eq(arr8_get(evens.data, 2), 6);
    assert_eq(arr8_get(evens.data, 3), 8);

    // Odd: 1, 3, 5, 7
    let odds = filter_odd(a, 8);
    assert_eq(odds.count, 4);
    assert_eq(arr8_get(odds.data, 0), 1);
    assert_eq(arr8_get(odds.data, 1), 3);
    assert_eq(arr8_get(odds.data, 2), 5);
    assert_eq(arr8_get(odds.data, 3), 7);

    // evens + odds = total count
    assert_eq(evens.count + odds.count, 8);

    // Greater than 5: 6, 7, 8
    let gt5 = filter_gt(a, 8, 5);
    assert_eq(gt5.count, 3);
    assert_eq(arr8_get(gt5.data, 0), 6);
    assert_eq(arr8_get(gt5.data, 1), 7);
    assert_eq(arr8_get(gt5.data, 2), 8);

    // Mixed with negatives
    let mixed = Arr8 { e0: 0 - 3, e1: 5, e2: 0 - 1, e3: 7, e4: 0, e5: 2, e6: 0 - 4, e7: 9 };
    let pos = filter_positive(mixed, 8);
    assert_eq(pos.count, 4); // 5, 7, 2, 9
    assert_eq(arr8_get(pos.data, 0), 5);
    assert_eq(arr8_get(pos.data, 1), 7);
    assert_eq(arr8_get(pos.data, 2), 2);
    assert_eq(arr8_get(pos.data, 3), 9);

    print("filter_ops: ok");
}

// ============================================================================
// Manual "fold" / "reduce" — accumulate values
// ============================================================================

// Sum all elements
fn fold_sum(a: Arr8, n: Int) -> Int {
    let mut acc = 0;
    let mut i = 0;
    while i < n {
        acc = acc + arr8_get(a, i);
        i = i + 1;
    }
    acc
}

// Product of all elements
fn fold_product(a: Arr8, n: Int) -> Int {
    let mut acc = 1;
    let mut i = 0;
    while i < n {
        acc = acc * arr8_get(a, i);
        i = i + 1;
    }
    acc
}

// Min element
fn fold_min(a: Arr8, n: Int) -> Int {
    let mut m = arr8_get(a, 0);
    let mut i = 1;
    while i < n {
        let v = arr8_get(a, i);
        if v < m {
            m = v;
        }
        i = i + 1;
    }
    m
}

// Max element
fn fold_max(a: Arr8, n: Int) -> Int {
    let mut m = arr8_get(a, 0);
    let mut i = 1;
    while i < n {
        let v = arr8_get(a, i);
        if v > m {
            m = v;
        }
        i = i + 1;
    }
    m
}

// Count elements matching a condition (== target)
fn fold_count_eq(a: Arr8, n: Int, target: Int) -> Int {
    let mut cnt = 0;
    let mut i = 0;
    while i < n {
        if arr8_get(a, i) == target {
            cnt = cnt + 1;
        }
        i = i + 1;
    }
    cnt
}

fn test_fold_ops() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8 };

    assert_eq(fold_sum(a, 8), 36);
    assert_eq(fold_product(a, 8), 40320); // 8!
    assert_eq(fold_min(a, 8), 1);
    assert_eq(fold_max(a, 8), 8);

    // Partial folds
    assert_eq(fold_sum(a, 4), 10);     // 1+2+3+4
    assert_eq(fold_product(a, 4), 24); // 4!
    assert_eq(fold_sum(a, 1), 1);
    assert_eq(fold_product(a, 1), 1);

    // Count
    let b = Arr8 { e0: 3, e1: 1, e2: 3, e3: 3, e4: 2, e5: 3, e6: 1, e7: 2 };
    assert_eq(fold_count_eq(b, 8, 3), 4);
    assert_eq(fold_count_eq(b, 8, 1), 2);
    assert_eq(fold_count_eq(b, 8, 2), 2);
    assert_eq(fold_count_eq(b, 8, 5), 0);

    print("fold_ops: ok");
}

// ============================================================================
// Chained operations: filter then fold, map then fold, etc.
// ============================================================================

fn test_chained_ops() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 5, e5: 6, e6: 7, e7: 8 };

    // Sum of evens (filter even, then sum)
    let evens = filter_even(a, 8);
    let sum_evens = fold_sum(evens.data, evens.count);
    assert_eq(sum_evens, 20); // 2+4+6+8

    // Sum of odds
    let odds = filter_odd(a, 8);
    let sum_odds = fold_sum(odds.data, odds.count);
    assert_eq(sum_odds, 16); // 1+3+5+7

    // Total = sum_evens + sum_odds
    assert_eq(sum_evens + sum_odds, 36);

    // Sum of squares (map square then fold sum)
    let sq = map_square(a, 8);
    let sum_sq = fold_sum(sq, 8);
    assert_eq(sum_sq, 204); // 1+4+9+16+25+36+49+64

    // Product of doubled values (first 4 elements)
    let dbl = map_double(a, 4);
    let prod_dbl = fold_product(dbl, 4);
    assert_eq(prod_dbl, 384); // 2*4*6*8

    // Max of squares
    assert_eq(fold_max(sq, 8), 64);
    // Min of squares
    assert_eq(fold_min(sq, 8), 1);

    // Filter > 4, then sum
    let gt4 = filter_gt(a, 8, 4);
    let sum_gt4 = fold_sum(gt4.data, gt4.count);
    assert_eq(sum_gt4, 26); // 5+6+7+8

    print("chained_ops: ok");
}

// ============================================================================
// Zip-like operation: combine two arrays element-wise
// ============================================================================

fn zip_add(a: Arr8, b: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut i = 0;
    while i < n {
        result = arr8_set(result, i, arr8_get(a, i) + arr8_get(b, i));
        i = i + 1;
    }
    result
}

fn zip_mul(a: Arr8, b: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut i = 0;
    while i < n {
        result = arr8_set(result, i, arr8_get(a, i) * arr8_get(b, i));
        i = i + 1;
    }
    result
}

// Dot product: sum of element-wise products
fn dot_product(a: Arr8, b: Arr8, n: Int) -> Int {
    let products = zip_mul(a, b, n);
    fold_sum(products, n)
}

fn test_zip_ops() {
    let a = Arr8 { e0: 1, e1: 2, e2: 3, e3: 4, e4: 0, e5: 0, e6: 0, e7: 0 };
    let b = Arr8 { e0: 10, e1: 20, e2: 30, e3: 40, e4: 0, e5: 0, e6: 0, e7: 0 };

    let added = zip_add(a, b, 4);
    assert_eq(arr8_get(added, 0), 11);
    assert_eq(arr8_get(added, 1), 22);
    assert_eq(arr8_get(added, 2), 33);
    assert_eq(arr8_get(added, 3), 44);

    let multiplied = zip_mul(a, b, 4);
    assert_eq(arr8_get(multiplied, 0), 10);
    assert_eq(arr8_get(multiplied, 1), 40);
    assert_eq(arr8_get(multiplied, 2), 90);
    assert_eq(arr8_get(multiplied, 3), 160);

    // Dot product
    assert_eq(dot_product(a, b, 4), 300); // 10+40+90+160

    // Dot product of a with itself
    assert_eq(dot_product(a, a, 4), 30); // 1+4+9+16

    // Zero vector dot product
    let z = arr8_zero();
    assert_eq(dot_product(a, z, 4), 0);

    print("zip_ops: ok");
}

// ============================================================================
// Scan (prefix application of an operation)
// ============================================================================

fn scan_sum(a: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut running = 0;
    let mut i = 0;
    while i < n {
        running = running + arr8_get(a, i);
        result = arr8_set(result, i, running);
        i = i + 1;
    }
    result
}

fn scan_max(a: Arr8, n: Int) -> Arr8 {
    let mut result = arr8_zero();
    let mut best = arr8_get(a, 0);
    result = arr8_set(result, 0, best);
    let mut i = 1;
    while i < n {
        let v = arr8_get(a, i);
        if v > best {
            best = v;
        }
        result = arr8_set(result, i, best);
        i = i + 1;
    }
    result
}

fn test_scan_ops() {
    let a = Arr8 { e0: 3, e1: 1, e2: 4, e3: 1, e4: 5, e5: 9, e6: 2, e7: 6 };

    // Prefix sums
    let ps = scan_sum(a, 8);
    assert_eq(arr8_get(ps, 0), 3);
    assert_eq(arr8_get(ps, 1), 4);   // 3+1
    assert_eq(arr8_get(ps, 2), 8);   // 3+1+4
    assert_eq(arr8_get(ps, 3), 9);   // 3+1+4+1
    assert_eq(arr8_get(ps, 7), 31);  // total sum

    // Running max
    let rm = scan_max(a, 8);
    assert_eq(arr8_get(rm, 0), 3);
    assert_eq(arr8_get(rm, 1), 3);   // max(3,1) = 3
    assert_eq(arr8_get(rm, 2), 4);   // max(3,4) = 4
    assert_eq(arr8_get(rm, 4), 5);   // max(4,5) = 5
    assert_eq(arr8_get(rm, 5), 9);   // max(5,9) = 9
    assert_eq(arr8_get(rm, 7), 9);   // still 9

    print("scan_ops: ok");
}

fn main() -> Int {
    test_map_transforms();
    test_filter_ops();
    test_fold_ops();
    test_chained_ops();
    test_zip_ops();
    test_scan_ops();
    print("[OK] 043_differential_iterators");
    0
}
