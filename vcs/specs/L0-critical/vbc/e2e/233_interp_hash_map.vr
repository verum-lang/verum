// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, hash-map, data-structure
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: simple hash map with open addressing and linear probing.
// Fixed-size array of 16 slots, each has (key, value, occupied) fields.

// =============================================================================
// Hash map storage: parallel arrays for keys, values, and occupied flags
// =============================================================================

type Arr16 is { v0: Int, v1: Int, v2: Int, v3: Int,
                v4: Int, v5: Int, v6: Int, v7: Int,
                v8: Int, v9: Int, v10: Int, v11: Int,
                v12: Int, v13: Int, v14: Int, v15: Int };

fn arr_get(a: Arr16, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 }
    else if i == 2 { a.v2 } else if i == 3 { a.v3 }
    else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else if i == 7 { a.v7 }
    else if i == 8 { a.v8 } else if i == 9 { a.v9 }
    else if i == 10 { a.v10 } else if i == 11 { a.v11 }
    else if i == 12 { a.v12 } else if i == 13 { a.v13 }
    else if i == 14 { a.v14 } else { a.v15 }
}

fn arr_set(a: Arr16, i: Int, val: Int) -> Arr16 {
    Arr16 {
        v0: if i == 0 { val } else { a.v0 },
        v1: if i == 1 { val } else { a.v1 },
        v2: if i == 2 { val } else { a.v2 },
        v3: if i == 3 { val } else { a.v3 },
        v4: if i == 4 { val } else { a.v4 },
        v5: if i == 5 { val } else { a.v5 },
        v6: if i == 6 { val } else { a.v6 },
        v7: if i == 7 { val } else { a.v7 },
        v8: if i == 8 { val } else { a.v8 },
        v9: if i == 9 { val } else { a.v9 },
        v10: if i == 10 { val } else { a.v10 },
        v11: if i == 11 { val } else { a.v11 },
        v12: if i == 12 { val } else { a.v12 },
        v13: if i == 13 { val } else { a.v13 },
        v14: if i == 14 { val } else { a.v14 },
        v15: if i == 15 { val } else { a.v15 }
    }
}

fn arr_zeros() -> Arr16 {
    Arr16 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0,
            v8: 0, v9: 0, v10: 0, v11: 0, v12: 0, v13: 0, v14: 0, v15: 0 }
}

type HashMap is {
    keys: Arr16,
    values: Arr16,
    occupied: Arr16,
    sz: Int
};

fn map_new() -> HashMap {
    HashMap { keys: arr_zeros(), values: arr_zeros(), occupied: arr_zeros(), sz: 0 }
}

// Simple hash function: key mod 16 (always positive)
fn hash_fn(key: Int) -> Int {
    let h = key % 16;
    if h < 0 { h + 16 } else { h }
}

// Insert key-value pair (updates if key exists)
fn map_insert(m: HashMap, key: Int, val: Int) -> HashMap {
    let start = hash_fn(key);
    let mut idx = start;
    let mut probes = 0;
    let mut result = m;
    let mut done = false;

    while !done {
        let occ = arr_get(result.occupied, idx);
        if occ == 0 {
            // Empty slot, insert here
            let new_keys = arr_set(result.keys, idx, key);
            let new_vals = arr_set(result.values, idx, val);
            let new_occ = arr_set(result.occupied, idx, 1);
            result = HashMap { keys: new_keys, values: new_vals, occupied: new_occ, sz: result.sz + 1 };
            done = true;
        } else if arr_get(result.keys, idx) == key {
            // Key exists, update value
            let new_vals = arr_set(result.values, idx, val);
            result = HashMap { keys: result.keys, values: new_vals, occupied: result.occupied, sz: result.sz };
            done = true;
        } else {
            // Collision, linear probe
            idx = (idx + 1) % 16;
            probes = probes + 1;
            if probes >= 16 {
                done = true;  // Table full
            }
        }
    }
    result
}

// Get value for key, returns -1 if not found
fn map_get(m: HashMap, key: Int) -> Int {
    let start = hash_fn(key);
    let mut idx = start;
    let mut probes = 0;

    while probes < 16 {
        if arr_get(m.occupied, idx) == 0 {
            return -1;  // Empty slot, key not found
        }
        if arr_get(m.keys, idx) == key {
            return arr_get(m.values, idx);
        }
        idx = (idx + 1) % 16;
        probes = probes + 1;
    }
    -1
}

// Check if key exists
fn map_contains(m: HashMap, key: Int) -> Bool {
    let start = hash_fn(key);
    let mut idx = start;
    let mut probes = 0;

    while probes < 16 {
        if arr_get(m.occupied, idx) == 0 {
            return false;
        }
        if arr_get(m.keys, idx) == key {
            return true;
        }
        idx = (idx + 1) % 16;
        probes = probes + 1;
    }
    false
}

// =============================================================================
// Tests
// =============================================================================

fn test_empty_map() {
    let m = map_new();
    assert_eq(m.sz, 0);
    assert_eq(map_contains(m, 1), false);
    assert_eq(map_get(m, 1), -1);
}

fn test_single_insert() {
    let m = map_insert(map_new(), 5, 100);
    assert_eq(m.sz, 1);
    assert_eq(map_get(m, 5), 100);
    assert_eq(map_contains(m, 5), true);
    assert_eq(map_contains(m, 6), false);
}

fn test_multiple_inserts() {
    let mut m = map_new();
    m = map_insert(m, 1, 10);
    m = map_insert(m, 2, 20);
    m = map_insert(m, 3, 30);
    assert_eq(m.sz, 3);
    assert_eq(map_get(m, 1), 10);
    assert_eq(map_get(m, 2), 20);
    assert_eq(map_get(m, 3), 30);
}

fn test_update_value() {
    let mut m = map_new();
    m = map_insert(m, 5, 100);
    assert_eq(map_get(m, 5), 100);
    m = map_insert(m, 5, 200);
    assert_eq(map_get(m, 5), 200);
    assert_eq(m.sz, 1);  // Size didn't change
}

fn test_collision_handling() {
    // Keys 0 and 16 hash to same slot (0 mod 16 = 0, 16 mod 16 = 0)
    let mut m = map_new();
    m = map_insert(m, 0, 100);
    m = map_insert(m, 16, 200);
    assert_eq(m.sz, 2);
    assert_eq(map_get(m, 0), 100);
    assert_eq(map_get(m, 16), 200);

    // Keys 1 and 17 also collide
    m = map_insert(m, 1, 300);
    m = map_insert(m, 17, 400);
    assert_eq(m.sz, 4);
    assert_eq(map_get(m, 1), 300);
    assert_eq(map_get(m, 17), 400);
}

fn test_many_entries() {
    let mut m = map_new();
    // Insert 10 entries
    m = map_insert(m, 10, 100);
    m = map_insert(m, 20, 200);
    m = map_insert(m, 30, 300);
    m = map_insert(m, 40, 400);
    m = map_insert(m, 50, 500);
    m = map_insert(m, 60, 600);
    m = map_insert(m, 70, 700);
    m = map_insert(m, 80, 800);
    m = map_insert(m, 90, 900);
    m = map_insert(m, 100, 1000);
    assert_eq(m.sz, 10);
    assert_eq(map_get(m, 10), 100);
    assert_eq(map_get(m, 50), 500);
    assert_eq(map_get(m, 100), 1000);
    assert_eq(map_contains(m, 55), false);
}

fn test_negative_keys() {
    let mut m = map_new();
    m = map_insert(m, -5, 50);
    m = map_insert(m, -10, 100);
    assert_eq(map_get(m, -5), 50);
    assert_eq(map_get(m, -10), 100);
    assert_eq(map_contains(m, -5), true);
    assert_eq(map_contains(m, -1), false);
}

fn test_sum_of_values() {
    let mut m = map_new();
    m = map_insert(m, 1, 10);
    m = map_insert(m, 2, 20);
    m = map_insert(m, 3, 30);
    m = map_insert(m, 4, 40);
    // Sum values by querying each key
    let total = map_get(m, 1) + map_get(m, 2) + map_get(m, 3) + map_get(m, 4);
    assert_eq(total, 100);
}

fn main() -> Int {
    test_empty_map();
    test_single_insert();
    test_multiple_inserts();
    test_update_value();
    test_collision_handling();
    test_many_entries();
    test_negative_keys();
    test_sum_of_values();
    print("[OK] 233_interp_hash_map");
    0
}
