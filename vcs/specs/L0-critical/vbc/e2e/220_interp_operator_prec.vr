// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, operator-precedence, expressions
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: operator precedence — mul/div over add/sub,
// parenthesized grouping, mixed arithmetic and logical

// =============================================================================
// Multiplication and division before addition and subtraction
// =============================================================================

fn test_mul_before_add() {
    assert_eq(2 + 3 * 4, 14);
    assert_eq(3 * 4 + 2, 14);
    assert_eq(1 + 2 * 3 + 4, 11);
    assert_eq(10 - 2 * 3, 4);
    assert_eq(2 * 3 - 10, -4);
}

fn test_div_before_sub() {
    assert_eq(10 - 6 / 2, 7);
    assert_eq(20 / 4 - 3, 2);
    assert_eq(100 / 10 + 5, 15);
    assert_eq(5 + 100 / 10, 15);
}

fn test_mod_precedence() {
    assert_eq(2 + 10 % 3, 3);
    assert_eq(10 % 3 + 2, 3);
    assert_eq(10 - 7 % 3, 9);
}

// =============================================================================
// Parenthesized grouping
// =============================================================================

fn test_parens_override() {
    assert_eq((2 + 3) * 4, 20);
    assert_eq(2 * (3 + 4), 14);
    assert_eq((10 - 6) / 2, 2);
    assert_eq(10 / (2 + 3), 2);
}

fn test_nested_parens() {
    assert_eq(((1 + 2) * (3 + 4)), 21);
    assert_eq((2 * (3 + (4 * 5))), 46);
    assert_eq(((10 - 5) * (8 - 3)), 25);
    assert_eq((((1 + 1) + 1) + 1), 4);
}

fn test_deeply_nested_parens() {
    let result = (((2 + 3) * 4) - ((1 + 2) * 3)) + 1;
    // (5*4) - (3*3) + 1 = 20 - 9 + 1 = 12
    assert_eq(result, 12);
}

// =============================================================================
// Mixed arithmetic precedence
// =============================================================================

fn test_complex_expression() {
    let a = 10;
    let b = 3;
    let c = 7;
    // a + b * c = 10 + 21 = 31
    assert_eq(a + b * c, 31);
    // a * b + c = 30 + 7 = 37
    assert_eq(a * b + c, 37);
    // a * b - c = 30 - 7 = 23
    assert_eq(a * b - c, 23);
    // a - b * c = 10 - 21 = -11
    assert_eq(a - b * c, -11);
}

fn test_multiple_mul_div() {
    // Left-to-right for same precedence
    assert_eq(100 / 10 / 2, 5);
    assert_eq(2 * 3 * 4, 24);
    assert_eq(100 / 5 * 2, 40);
    assert_eq(60 / 3 / 4, 5);
}

fn test_add_sub_left_to_right() {
    assert_eq(10 - 5 - 3, 2);
    assert_eq(10 - 5 + 3, 8);
    assert_eq(10 + 5 - 3, 12);
    assert_eq(1 - 2 + 3 - 4 + 5, 3);
}

// =============================================================================
// Comparison operator precedence
// =============================================================================

fn test_comparison_with_arithmetic() {
    // Arithmetic binds tighter than comparison
    assert(2 + 3 > 4);
    assert(2 * 3 == 6);
    assert(10 - 3 != 8);
    assert(10 / 2 >= 5);
    assert(10 % 3 <= 1);
}

// =============================================================================
// Unary minus precedence
// =============================================================================

fn test_unary_minus() {
    let x = 5;
    assert_eq(-x * 2, -10);
    assert_eq(-(x * 2), -10);
    assert_eq(-x + 10, 5);
    assert_eq(10 + -x, 5);
}

fn test_double_negation() {
    let x = 42;
    assert_eq(-(-x), 42);
    assert_eq(-1 * -1, 1);
    assert_eq(-1 * -1 * -1, -1);
}

fn main() -> Int {
    test_mul_before_add();
    test_div_before_sub();
    test_mod_precedence();
    test_parens_override();
    test_nested_parens();
    test_deeply_nested_parens();
    test_complex_expression();
    test_multiple_mul_div();
    test_add_sub_left_to_right();
    test_comparison_with_arithmetic();
    test_unary_minus();
    test_double_negation();
    print("[OK] 220_interp_operator_prec");
    0
}
