// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, bit_manipulation, popcount, power_of_two, bit_reverse, parity
// @timeout: 15000
// @expected-exit: 0
//
// Bit manipulation tricks:
//   - Count set bits (popcount) via Brian Kernighan's algorithm
//   - Next power of 2 (smallest power of 2 >= n)
//   - Reverse bits of a 16-bit integer
//   - Parity (XOR of all bits: 1 if odd number of set bits)
// All values treated as non-negative integers.

// Count set bits using Brian Kernighan's method: n &= (n-1) clears lowest set bit.
fn popcount(n: Int) -> Int {
    let mut x = n;
    let mut count = 0;
    while x > 0 {
        x = x & (x - 1);
        count = count + 1;
    }
    count
}

// Next power of 2 >= n (for n >= 1).
// If n is already a power of 2, returns n.
fn next_pow2(n: Int) -> Int {
    if n <= 1 { return 1; }
    let mut p = 1;
    while p < n { p = p * 2; }
    p
}

// Reverse the low 16 bits of n.
// Processes bit by bit: collect reversed bits one at a time.
fn reverse_bits16(n: Int) -> Int {
    let mut x = n & 65535;  // mask to 16 bits
    let mut result = 0;
    let mut i = 0;
    while i < 16 {
        result = result * 2 + (x & 1);
        x = x / 2;
        i = i + 1;
    }
    result
}

// Parity of n: 1 if odd number of set bits, 0 if even.
fn parity(n: Int) -> Int {
    let mut x = n;
    let mut p = 0;
    while x > 0 {
        p = p + 1;
        x = x & (x - 1);
    }
    p % 2
}

// Check if n is a power of 2 (n > 0 and exactly one bit set).
fn is_pow2(n: Int) -> Int {
    if n <= 0 { return 0; }
    if n & (n - 1) == 0 { 1 } else { 0 }
}

fn test_popcount() {
    // popcount(0) = 0
    assert_eq(popcount(0), 0);
    // popcount(1) = 1  (binary 1)
    assert_eq(popcount(1), 1);
    // popcount(7) = 3  (binary 111)
    assert_eq(popcount(7), 3);
    // popcount(255) = 8 (binary 11111111)
    assert_eq(popcount(255), 8);
    // popcount(256) = 1 (binary 100000000)
    assert_eq(popcount(256), 1);
    // popcount(15) = 4 (binary 1111)
    assert_eq(popcount(15), 4);
    print("popcount: ok");
}

fn test_next_pow2() {
    assert_eq(next_pow2(1),  1);
    assert_eq(next_pow2(2),  2);
    assert_eq(next_pow2(3),  4);
    assert_eq(next_pow2(4),  4);
    assert_eq(next_pow2(5),  8);
    assert_eq(next_pow2(16), 16);
    assert_eq(next_pow2(17), 32);
    assert_eq(next_pow2(100), 128);
    print("next_pow2: ok");
}

fn test_reverse_bits16() {
    // reverse16(1)  = 1000 0000 0000 0000 binary = 32768
    assert_eq(reverse_bits16(1), 32768);
    // reverse16(32768) = 1 (bit 15 becomes bit 0)
    assert_eq(reverse_bits16(32768), 1);
    // reverse16(0) = 0
    assert_eq(reverse_bits16(0), 0);
    // reverse16(65535) = 65535 (all 16 bits set)
    assert_eq(reverse_bits16(65535), 65535);
    // reverse16(3) = 0b0000000000000011 reversed = 0b1100000000000000 = 49152
    assert_eq(reverse_bits16(3), 49152);
    print("reverse_bits16: ok");
}

fn test_parity() {
    // parity(0) = 0 (no bits set — even count)
    assert_eq(parity(0), 0);
    // parity(1) = 1 (1 bit set)
    assert_eq(parity(1), 1);
    // parity(3) = 0  (2 bits set: 11 binary)
    assert_eq(parity(3), 0);
    // parity(7) = 1  (3 bits set: 111 binary)
    assert_eq(parity(7), 1);
    // parity(255) = 0 (8 bits set — even)
    assert_eq(parity(255), 0);
    // parity(170) = 0  (binary 10101010: 4 bits set)
    assert_eq(parity(170), 0);
    print("parity: ok");
}

fn test_is_pow2_and_combinations() {
    assert_eq(is_pow2(1),   1);
    assert_eq(is_pow2(2),   1);
    assert_eq(is_pow2(4),   1);
    assert_eq(is_pow2(64),  1);
    assert_eq(is_pow2(3),   0);
    assert_eq(is_pow2(6),   0);
    assert_eq(is_pow2(0),   0);

    // Verify: popcount(power_of_2) == 1 for a few values
    assert_eq(popcount(next_pow2(100)), 1);
    assert_eq(popcount(next_pow2(7)),   1);

    // reverse_bits16 is its own inverse
    let x = 12345;
    assert_eq(reverse_bits16(reverse_bits16(x)), x & 65535);
    print("is_pow2_and_combinations: ok");
}

fn main() -> Int {
    test_popcount();
    test_next_pow2();
    test_reverse_bits16();
    test_parity();
    test_is_pow2_and_combinations();
    print("[OK] 556_interp_bit_tricks");
    0
}
