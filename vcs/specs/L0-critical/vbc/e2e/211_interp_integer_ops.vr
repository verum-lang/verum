// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, integer, arithmetic
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: integer arithmetic — add, sub, mul, div, mod, negation,
// mixed operations, identity laws, operator combinations, large values

// =============================================================================
// Basic arithmetic operations
// =============================================================================

fn test_addition() {
    assert_eq(0 + 0, 0);
    assert_eq(1 + 2, 3);
    assert_eq(100 + 200, 300);
    assert_eq(-1 + 1, 0);
    assert_eq(-5 + -3, -8);
    assert_eq(999 + 1, 1000);
    assert_eq(-999 + -1, -1000);
}

fn test_subtraction() {
    assert_eq(5 - 3, 2);
    assert_eq(3 - 5, -2);
    assert_eq(0 - 0, 0);
    assert_eq(-10 - -4, -6);
    assert_eq(100 - 100, 0);
    assert_eq(1000 - 1, 999);
}

fn test_multiplication() {
    assert_eq(3 * 4, 12);
    assert_eq(-2 * 3, -6);
    assert_eq(-3 * -4, 12);
    assert_eq(0 * 999, 0);
    assert_eq(1 * 42, 42);
    assert_eq(100 * 100, 10000);
    assert_eq(7 * 11, 77);
}

fn test_division() {
    assert_eq(10 / 2, 5);
    assert_eq(7 / 2, 3);
    assert_eq(-7 / 2, -3);
    assert_eq(100 / 10, 10);
    assert_eq(1 / 1, 1);
    assert_eq(99 / 100, 0);
    assert_eq(1000000 / 1000, 1000);
}

fn test_modulo() {
    assert_eq(10 % 3, 1);
    assert_eq(10 % 5, 0);
    assert_eq(10 % 7, 3);
    assert_eq(0 % 5, 0);
    assert_eq(1 % 1, 0);
    assert_eq(17 % 5, 2);
    assert_eq(100 % 10, 0);
}

// =============================================================================
// Negation
// =============================================================================

fn test_negation() {
    let x = 42;
    assert_eq(-x, -42);
    assert_eq(-(-x), 42);
    let y = -100;
    assert_eq(-y, 100);
    assert_eq(-0, 0);
    assert_eq(-1 * -1, 1);
}

// =============================================================================
// Identity and algebraic laws
// =============================================================================

fn test_identity_laws() {
    let x = 42;
    // Additive identity
    assert_eq(x + 0, x);
    assert_eq(0 + x, x);
    // Multiplicative identity
    assert_eq(x * 1, x);
    assert_eq(1 * x, x);
    // Multiplicative zero
    assert_eq(x * 0, 0);
    assert_eq(0 * x, 0);
    // Subtraction of self
    assert_eq(x - x, 0);
}

fn test_commutativity() {
    let a = 17;
    let b = 23;
    assert_eq(a + b, b + a);
    assert_eq(a * b, b * a);
}

fn test_associativity() {
    let a = 10;
    let b = 20;
    let c = 30;
    assert_eq((a + b) + c, a + (b + c));
    assert_eq((a * b) * c, a * (b * c));
}

fn test_distributive() {
    let a = 5;
    let b = 3;
    let c = 7;
    assert_eq(a * (b + c), a * b + a * c);
    assert_eq(a * (b - c), a * b - a * c);
}

// =============================================================================
// Mixed operations and operator combinations
// =============================================================================

fn test_mixed_operations() {
    assert_eq(2 + 3 * 4, 14);
    assert_eq((2 + 3) * 4, 20);
    assert_eq(100 - 10 * 5, 50);
    assert_eq((100 - 10) * 5, 450);
    let x = 100;
    let y = x / 3;
    let z = x % 3;
    assert_eq(y * 3 + z, x);
}

fn test_chained_operations() {
    let a = 1;
    let b = a + 2;
    let c = b * 3;
    let d = c - 4;
    let e = d / 5;
    assert_eq(e, 1);
}

// =============================================================================
// Large values
// =============================================================================

fn test_large_values() {
    assert_eq(1000000 * 1000000, 1000000000000);
    assert_eq(999999999 + 1, 1000000000);
    let large = 1000000000;
    assert_eq(large * 1000, 1000000000000);
    assert_eq(large / large, 1);
    assert_eq(large % large, 0);
}

fn main() -> Int {
    test_addition();
    test_subtraction();
    test_multiplication();
    test_division();
    test_modulo();
    test_negation();
    test_identity_laws();
    test_commutativity();
    test_associativity();
    test_distributive();
    test_mixed_operations();
    test_chained_operations();
    test_large_values();
    print("[OK] 211_interp_integer_ops");
    0
}
