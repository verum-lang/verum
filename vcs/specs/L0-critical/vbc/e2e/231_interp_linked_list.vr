// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, linked-list, data-structure
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: array-based singly linked list.
// Each slot stores (value, next_index). -1 means null/end.

// =============================================================================
// Array-based linked list storage: 16 slots, each has value and next pointer
// =============================================================================

type Vals16 is { v0: Int, v1: Int, v2: Int, v3: Int,
                 v4: Int, v5: Int, v6: Int, v7: Int,
                 v8: Int, v9: Int, v10: Int, v11: Int,
                 v12: Int, v13: Int, v14: Int, v15: Int };

fn vals_get(a: Vals16, i: Int) -> Int {
    if i == 0 { a.v0 } else if i == 1 { a.v1 }
    else if i == 2 { a.v2 } else if i == 3 { a.v3 }
    else if i == 4 { a.v4 } else if i == 5 { a.v5 }
    else if i == 6 { a.v6 } else if i == 7 { a.v7 }
    else if i == 8 { a.v8 } else if i == 9 { a.v9 }
    else if i == 10 { a.v10 } else if i == 11 { a.v11 }
    else if i == 12 { a.v12 } else if i == 13 { a.v13 }
    else if i == 14 { a.v14 } else { a.v15 }
}

fn vals_set(a: Vals16, i: Int, val: Int) -> Vals16 {
    Vals16 {
        v0: if i == 0 { val } else { a.v0 },
        v1: if i == 1 { val } else { a.v1 },
        v2: if i == 2 { val } else { a.v2 },
        v3: if i == 3 { val } else { a.v3 },
        v4: if i == 4 { val } else { a.v4 },
        v5: if i == 5 { val } else { a.v5 },
        v6: if i == 6 { val } else { a.v6 },
        v7: if i == 7 { val } else { a.v7 },
        v8: if i == 8 { val } else { a.v8 },
        v9: if i == 9 { val } else { a.v9 },
        v10: if i == 10 { val } else { a.v10 },
        v11: if i == 11 { val } else { a.v11 },
        v12: if i == 12 { val } else { a.v12 },
        v13: if i == 13 { val } else { a.v13 },
        v14: if i == 14 { val } else { a.v14 },
        v15: if i == 15 { val } else { a.v15 }
    }
}

// Linked list: values array, next-pointers array, head index, size, free index
type LinkedList is {
    vals: Vals16,
    nexts: Vals16,
    head: Int,
    sz: Int,
    free: Int
};

fn list_new() -> LinkedList {
    // Initialize free list: each slot points to the next
    let z = Vals16 { v0: 0, v1: 0, v2: 0, v3: 0, v4: 0, v5: 0, v6: 0, v7: 0,
                     v8: 0, v9: 0, v10: 0, v11: 0, v12: 0, v13: 0, v14: 0, v15: 0 };
    let n = Vals16 { v0: 1, v1: 2, v2: 3, v3: 4, v4: 5, v5: 6, v6: 7, v7: 8,
                     v8: 9, v9: 10, v10: 11, v11: 12, v12: 13, v13: 14, v14: 15, v15: -1 };
    LinkedList { vals: z, nexts: n, head: -1, sz: 0, free: 0 }
}

// Prepend a value to the front of the list
fn list_prepend(lst: LinkedList, val: Int) -> LinkedList {
    let slot = lst.free;
    let new_free = vals_get(lst.nexts, slot);
    let new_vals = vals_set(lst.vals, slot, val);
    let new_nexts = vals_set(lst.nexts, slot, lst.head);
    LinkedList { vals: new_vals, nexts: new_nexts, head: slot, sz: lst.sz + 1, free: new_free }
}

// Append a value to the end of the list
fn list_append(lst: LinkedList, val: Int) -> LinkedList {
    let slot = lst.free;
    let new_free = vals_get(lst.nexts, slot);
    let new_vals = vals_set(lst.vals, slot, val);
    let new_nexts = vals_set(lst.nexts, slot, -1);

    if lst.head == -1 {
        // Empty list, new node is head
        LinkedList { vals: new_vals, nexts: new_nexts, head: slot, sz: 1, free: new_free }
    } else {
        // Walk to end of list
        let mut cur = lst.head;
        let mut prev = -1;
        let mut steps = 0;
        while vals_get(lst.nexts, cur) != -1 {
            prev = cur;
            cur = vals_get(lst.nexts, cur);
            steps = steps + 1;
        }
        // cur is last node, set its next to slot
        let final_nexts = vals_set(new_nexts, cur, slot);
        LinkedList { vals: new_vals, nexts: final_nexts, head: lst.head, sz: lst.sz + 1, free: new_free }
    }
}

// Get value at index (0-based position in traversal order)
fn list_get(lst: LinkedList, idx: Int) -> Int {
    let mut cur = lst.head;
    let mut i = 0;
    while i < idx {
        cur = vals_get(lst.nexts, cur);
        i = i + 1;
    }
    vals_get(lst.vals, cur)
}

// Count all elements by traversal
fn list_count(lst: LinkedList) -> Int {
    let mut cur = lst.head;
    let mut cnt = 0;
    while cur != -1 {
        cnt = cnt + 1;
        cur = vals_get(lst.nexts, cur);
        if cnt > 16 { return cnt; }
    }
    cnt
}

// Sum all elements
fn list_sum(lst: LinkedList) -> Int {
    let mut cur = lst.head;
    let mut total = 0;
    let mut steps = 0;
    while cur != -1 {
        total = total + vals_get(lst.vals, cur);
        cur = vals_get(lst.nexts, cur);
        steps = steps + 1;
        if steps > 16 { return total; }
    }
    total
}

// Check if value exists
fn list_contains(lst: LinkedList, val: Int) -> Bool {
    let mut cur = lst.head;
    let mut steps = 0;
    while cur != -1 {
        if vals_get(lst.vals, cur) == val {
            return true;
        }
        cur = vals_get(lst.nexts, cur);
        steps = steps + 1;
        if steps > 16 { return false; }
    }
    false
}

// =============================================================================
// Tests
// =============================================================================

fn test_empty_list() {
    let lst = list_new();
    assert_eq(lst.sz, 0);
    assert_eq(lst.head, -1);
    assert_eq(list_count(lst), 0);
}

fn test_prepend() {
    let mut lst = list_new();
    lst = list_prepend(lst, 10);
    assert_eq(lst.sz, 1);
    assert_eq(list_get(lst, 0), 10);

    lst = list_prepend(lst, 20);
    assert_eq(lst.sz, 2);
    assert_eq(list_get(lst, 0), 20);  // 20 is now at front
    assert_eq(list_get(lst, 1), 10);

    lst = list_prepend(lst, 30);
    assert_eq(lst.sz, 3);
    assert_eq(list_get(lst, 0), 30);
    assert_eq(list_get(lst, 1), 20);
    assert_eq(list_get(lst, 2), 10);
}

fn test_append() {
    let mut lst = list_new();
    lst = list_append(lst, 10);
    assert_eq(lst.sz, 1);
    assert_eq(list_get(lst, 0), 10);

    lst = list_append(lst, 20);
    assert_eq(lst.sz, 2);
    assert_eq(list_get(lst, 0), 10);
    assert_eq(list_get(lst, 1), 20);

    lst = list_append(lst, 30);
    assert_eq(lst.sz, 3);
    assert_eq(list_get(lst, 0), 10);
    assert_eq(list_get(lst, 1), 20);
    assert_eq(list_get(lst, 2), 30);
}

fn test_count_and_sum() {
    let mut lst = list_new();
    lst = list_prepend(lst, 5);
    lst = list_prepend(lst, 3);
    lst = list_prepend(lst, 1);
    // List: 1 -> 3 -> 5
    assert_eq(list_count(lst), 3);
    assert_eq(list_sum(lst), 9);
}

fn test_contains() {
    let mut lst = list_new();
    lst = list_prepend(lst, 42);
    lst = list_prepend(lst, 17);
    lst = list_prepend(lst, 99);
    assert_eq(list_contains(lst, 42), true);
    assert_eq(list_contains(lst, 17), true);
    assert_eq(list_contains(lst, 99), true);
    assert_eq(list_contains(lst, 0), false);
    assert_eq(list_contains(lst, 100), false);
}

fn test_many_elements() {
    let mut lst = list_new();
    // Prepend 10 elements: 9, 8, 7, ..., 0
    let mut i = 0;
    while i < 10 {
        lst = list_prepend(lst, i);
        i = i + 1;
    }
    assert_eq(list_count(lst), 10);
    // Sum: 0+1+2+...+9 = 45
    assert_eq(list_sum(lst), 45);
    // First element should be 9 (last prepended)
    assert_eq(list_get(lst, 0), 9);
    // Last element should be 0 (first prepended)
    assert_eq(list_get(lst, 9), 0);
}

fn test_mixed_operations() {
    let mut lst = list_new();
    lst = list_prepend(lst, 100);
    lst = list_append(lst, 200);
    lst = list_prepend(lst, 50);
    // Order: 50 -> 100 -> 200
    assert_eq(list_count(lst), 3);
    assert_eq(list_get(lst, 0), 50);
    assert_eq(list_get(lst, 1), 100);
    assert_eq(list_get(lst, 2), 200);
    assert_eq(list_sum(lst), 350);
}

fn main() -> Int {
    test_empty_list();
    test_prepend();
    test_append();
    test_count_and_sum();
    test_contains();
    test_many_elements();
    test_mixed_operations();
    print("[OK] 231_interp_linked_list");
    0
}
