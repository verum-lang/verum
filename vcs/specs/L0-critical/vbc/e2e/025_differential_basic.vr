// @test: differential
// @tier: 0
// @level: L0
// @tags: vbc, e2e, differential, interpreter-vs-aot
// @timeout: 30000
// @expected-exit: 0
//
// Basic differential test: verifies interpreter and AOT produce identical results
// for fundamental operations.

@allow(unbounded_recursion)
fn fib(n: Int) -> Int {
    if n <= 1 { n }
    else { fib(n - 1) + fib(n - 2) }
}

@allow(unbounded_recursion)
fn factorial(n: Int) -> Int {
    if n <= 1 { 1 }
    else { n * factorial(n - 1) }
}

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 { a }
    else { gcd(b, a % b) }
}

fn is_prime(n: Int) -> Bool {
    if n < 2 { false }
    else {
        let mut i = 2;
        let mut result = true;
        while i * i <= n {
            if n % i == 0 {
                result = false;
            }
            i = i + 1;
        }
        result
    }
}

fn main() -> Int {
    // Fibonacci
    assert_eq(fib(0), 0);
    assert_eq(fib(1), 1);
    assert_eq(fib(10), 55);
    assert_eq(fib(15), 610);

    // Factorial
    assert_eq(factorial(0), 1);
    assert_eq(factorial(5), 120);
    assert_eq(factorial(10), 3628800);

    // GCD
    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(17, 13), 1);

    // Primes
    assert(is_prime(2));
    assert(is_prime(17));
    assert(is_prime(97));
    assert(!is_prime(1));
    assert(!is_prime(100));

    // Arithmetic
    assert_eq(2 + 3, 5);
    assert_eq(100 - 37, 63);
    assert_eq(7 * 8, 56);
    assert_eq(100 / 7, 14);
    assert_eq(100 % 7, 2);
    assert_eq(-42, 0 - 42);

    print("[OK] 025_differential_basic");
    0
}
