// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, cbgr, references, mutation, pipeline
// @timeout: 5000
// @expected-exit: 0
//
// End-to-end pipeline test: .vr source -> parse -> typecheck -> VBC codegen -> interpreter
// Verifies reference operations and mutation through the full pipeline
// NOTE: Heap<T> deref (*h) has a known type checker limitation — testing refs instead

// =============================================================================
// Type definitions
// =============================================================================

type Point is { x: Int, y: Int };
type Rect is { top_left: Point, width: Int, height: Int };

// =============================================================================
// Immutable references
// =============================================================================

fn read_ref(r: &Int) -> Int {
    *r
}

fn test_immutable_ref_basic() {
    let x = 100;
    let r = &x;
    assert_eq(*r, 100);
}

fn test_immutable_ref_function() {
    let x = 42;
    assert_eq(read_ref(&x), 42);
}

fn add_via_refs(a: &Int, blk_b: &Int) -> Int {
    *a + *blk_b
}

fn test_multiple_refs() {
    let a = 10;
    let b = 20;
    assert_eq(add_via_refs(&a, &b), 30);
}

// =============================================================================
// Mutable references
// =============================================================================

fn increment(r: &mut Int) {
    *r = *r + 1;
}

fn test_mutable_ref_basic() {
    let mut x = 0;
    let r = &mut x;
    *r = 42;
    assert_eq(x, 42);
}

fn test_mutable_ref_function() {
    let mut x = 0;
    increment(&mut x);
    increment(&mut x);
    increment(&mut x);
    assert_eq(x, 3);
}

fn test_mutable_ref_accumulate() {
    let mut sum = 0;
    let mut i = 0;
    while i < 10 {
        let r = &mut sum;
        *r = *r + i;
        i = i + 1;
    }
    // 0+1+2+...+9 = 45
    assert_eq(sum, 45);
}

// =============================================================================
// Records and references
// =============================================================================

fn point_sum(p: Point) -> Int {
    p.x + p.y
}

fn test_record_creation() {
    let p = Point { x: 10, y: 20 };
    assert_eq(p.x, 10);
    assert_eq(p.y, 20);
}

fn test_record_function() {
    let p = Point { x: 3, y: 4 };
    assert_eq(point_sum(p), 7);
}

fn test_nested_record() {
    let r = Rect {
        top_left: Point { x: 1, y: 2 },
        width: 10,
        height: 20
    };
    assert_eq(r.top_left.x, 1);
    assert_eq(r.top_left.y, 2);
    assert_eq(r.width, 10);
    assert_eq(r.height, 20);
}

fn rect_area(r: Rect) -> Int {
    r.width * r.height
}

fn test_record_method_call() {
    let r = Rect {
        top_left: Point { x: 0, y: 0 },
        width: 5,
        height: 8
    };
    assert_eq(rect_area(r), 40);
}

// =============================================================================
// Multiple mutations
// =============================================================================

fn swap_values(a: &mut Int, blk_b: &mut Int) {
    let tmp = *a;
    *a = *blk_b;
    *blk_b = tmp;
}

fn test_swap() {
    let mut x = 10;
    let mut y = 20;
    swap_values(&mut x, &mut y);
    assert_eq(x, 20);
    assert_eq(y, 10);
}

fn test_ref_chain() {
    let mut a = 1;
    let mut b = 2;
    let mut c = 3;

    // Rotate values: a->b->c->a
    let tmp = a;
    a = b;
    b = c;
    c = tmp;

    assert_eq(a, 2);
    assert_eq(b, 3);
    assert_eq(c, 1);
}

// =============================================================================
// Bool references
// =============================================================================

fn toggle(flag: &mut Bool) {
    if *flag {
        *flag = false;
    } else {
        *flag = true;
    }
}

fn test_bool_ref() {
    let mut flag = false;
    toggle(&mut flag);
    assert(flag);
    toggle(&mut flag);
    assert(!flag);
}

fn main() -> Int {
    test_immutable_ref_basic();
    test_immutable_ref_function();
    test_multiple_refs();
    test_mutable_ref_basic();
    test_mutable_ref_function();
    test_mutable_ref_accumulate();
    test_record_creation();
    test_record_function();
    test_nested_record();
    test_record_method_call();
    test_swap();
    test_ref_chain();
    test_bool_ref();
    print("[OK] 011_cbgr");
    0
}
