// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, matrix
// @timeout: 50000
// @expected-exit: 0
// @description: Matrix operations — 2x2 and 3x3 multiply, transpose, determinant

// ============================================================================
// Mat2: 2x2 matrix stored as flat fields (row-major)
//   | a b |
//   | c d |
// ============================================================================

type Mat2 is { a: Int, b: Int, c: Int, d: Int };

fn mat2_new(a: Int, b: Int, c: Int, d: Int) -> Mat2 {
    Mat2 { a: a, b: b, c: c, d: d }
}

fn mat2_identity() -> Mat2 {
    Mat2 { a: 1, b: 0, c: 0, d: 1 }
}

fn mat2_mul(m: Mat2, n: Mat2) -> Mat2 {
    Mat2 {
        a: m.a * n.a + m.b * n.c,
        b: m.a * n.b + m.b * n.d,
        c: m.c * n.a + m.d * n.c,
        d: m.c * n.b + m.d * n.d
    }
}

fn mat2_det(m: Mat2) -> Int {
    m.a * m.d - m.b * m.c
}

fn mat2_transpose(m: Mat2) -> Mat2 {
    Mat2 { a: m.a, b: m.c, c: m.b, d: m.d }
}

fn mat2_eq(m: Mat2, n: Mat2) -> Int {
    if m.a == n.a {
        if m.b == n.b {
            if m.c == n.c {
                if m.d == n.d { 1 } else { 0 }
            } else { 0 }
        } else { 0 }
    } else { 0 }
}

// ============================================================================
// Mat3: 3x3 matrix stored as flat fields (row-major)
//   | r0c0 r0c1 r0c2 |
//   | r1c0 r1c1 r1c2 |
//   | r2c0 r2c1 r2c2 |
// ============================================================================

type Mat3 is {
    r0c0: Int, r0c1: Int, r0c2: Int,
    r1c0: Int, r1c1: Int, r1c2: Int,
    r2c0: Int, r2c1: Int, r2c2: Int
};

fn mat3_new(
    a: Int, b: Int, c: Int,
    d: Int, e: Int, f: Int,
    g: Int, h: Int, k: Int
) -> Mat3 {
    Mat3 { r0c0: a, r0c1: b, r0c2: c, r1c0: d, r1c1: e, r1c2: f, r2c0: g, r2c1: h, r2c2: k }
}

fn mat3_identity() -> Mat3 {
    Mat3 {
        r0c0: 1, r0c1: 0, r0c2: 0,
        r1c0: 0, r1c1: 1, r1c2: 0,
        r2c0: 0, r2c1: 0, r2c2: 1
    }
}

fn mat3_transpose(m: Mat3) -> Mat3 {
    Mat3 {
        r0c0: m.r0c0, r0c1: m.r1c0, r0c2: m.r2c0,
        r1c0: m.r0c1, r1c1: m.r1c1, r1c2: m.r2c1,
        r2c0: m.r0c2, r2c1: m.r1c2, r2c2: m.r2c2
    }
}

fn mat3_det(m: Mat3) -> Int {
    let pos1 = m.r0c0 * m.r1c1 * m.r2c2;
    let pos2 = m.r0c1 * m.r1c2 * m.r2c0;
    let pos3 = m.r0c2 * m.r1c0 * m.r2c1;
    let neg1 = m.r0c2 * m.r1c1 * m.r2c0;
    let neg2 = m.r0c1 * m.r1c0 * m.r2c2;
    let neg3 = m.r0c0 * m.r1c2 * m.r2c1;
    pos1 + pos2 + pos3 - neg1 - neg2 - neg3
}

fn mat3_mul(m: Mat3, n: Mat3) -> Mat3 {
    Mat3 {
        r0c0: m.r0c0 * n.r0c0 + m.r0c1 * n.r1c0 + m.r0c2 * n.r2c0,
        r0c1: m.r0c0 * n.r0c1 + m.r0c1 * n.r1c1 + m.r0c2 * n.r2c1,
        r0c2: m.r0c0 * n.r0c2 + m.r0c1 * n.r1c2 + m.r0c2 * n.r2c2,
        r1c0: m.r1c0 * n.r0c0 + m.r1c1 * n.r1c0 + m.r1c2 * n.r2c0,
        r1c1: m.r1c0 * n.r0c1 + m.r1c1 * n.r1c1 + m.r1c2 * n.r2c1,
        r1c2: m.r1c0 * n.r0c2 + m.r1c1 * n.r1c2 + m.r1c2 * n.r2c2,
        r2c0: m.r2c0 * n.r0c0 + m.r2c1 * n.r1c0 + m.r2c2 * n.r2c0,
        r2c1: m.r2c0 * n.r0c1 + m.r2c1 * n.r1c1 + m.r2c2 * n.r2c1,
        r2c2: m.r2c0 * n.r0c2 + m.r2c1 * n.r1c2 + m.r2c2 * n.r2c2
    }
}

fn mat3_eq(m: Mat3, n: Mat3) -> Int {
    if m.r0c0 == n.r0c0 {
        if m.r0c1 == n.r0c1 {
            if m.r0c2 == n.r0c2 {
                if m.r1c0 == n.r1c0 {
                    if m.r1c1 == n.r1c1 {
                        if m.r1c2 == n.r1c2 {
                            if m.r2c0 == n.r2c0 {
                                if m.r2c1 == n.r2c1 {
                                    if m.r2c2 == n.r2c2 { 1 } else { 0 }
                                } else { 0 }
                            } else { 0 }
                        } else { 0 }
                    } else { 0 }
                } else { 0 }
            } else { 0 }
        } else { 0 }
    } else { 0 }
}

// ============================================================================
// Test 1: 2x2 identity multiply
// ============================================================================

@test
fn test_mat2_identity_multiply() {
    let id = mat2_identity();
    let m = mat2_new(2, 3, 5, 7);

    // M * I = M
    let r1 = mat2_mul(m, id);
    assert_eq(mat2_eq(r1, m), 1);

    // I * M = M
    let r2 = mat2_mul(id, m);
    assert_eq(mat2_eq(r2, m), 1);

    // I * I = I
    let r3 = mat2_mul(id, id);
    assert_eq(mat2_eq(r3, id), 1);

    print("  test_mat2_identity_multiply: ok");
}

// ============================================================================
// Test 2: 2x2 known multiplication and determinant
// ============================================================================

@test
fn test_mat2_multiply_and_det() {
    // | 1 2 |   | 5 6 |   | 1*5+2*7  1*6+2*8 |   | 19 22 |
    // | 3 4 | * | 7 8 | = | 3*5+4*7  3*6+4*8 | = | 43 50 |
    let a = mat2_new(1, 2, 3, 4);
    let b = mat2_new(5, 6, 7, 8);
    let c = mat2_mul(a, b);
    assert_eq(c.a, 19);
    assert_eq(c.b, 22);
    assert_eq(c.c, 43);
    assert_eq(c.d, 50);

    // det(a) = 1*4 - 2*3 = -2
    assert_eq(mat2_det(a), -2);

    // det(b) = 5*8 - 6*7 = -2
    assert_eq(mat2_det(b), -2);

    // det(a*b) = det(a) * det(b) = 4
    assert_eq(mat2_det(c), 4);

    print("  test_mat2_multiply_and_det: ok");
}

// ============================================================================
// Test 3: 3x3 transpose of transpose = original
// ============================================================================

@test
fn test_mat3_transpose_involution() {
    let m = mat3_new(1, 2, 3, 4, 5, 6, 7, 8, 9);
    let t = mat3_transpose(m);

    // Check transpose swaps correctly
    assert_eq(t.r0c0, 1);
    assert_eq(t.r0c1, 4);
    assert_eq(t.r0c2, 7);
    assert_eq(t.r1c0, 2);
    assert_eq(t.r1c1, 5);
    assert_eq(t.r1c2, 8);
    assert_eq(t.r2c0, 3);
    assert_eq(t.r2c1, 6);
    assert_eq(t.r2c2, 9);

    // Transpose of transpose = original
    let tt = mat3_transpose(t);
    assert_eq(mat3_eq(tt, m), 1);

    print("  test_mat3_transpose_involution: ok");
}

// ============================================================================
// Test 4: 3x3 determinant
// ============================================================================

@test
fn test_mat3_determinant() {
    // Identity det = 1
    let id = mat3_identity();
    assert_eq(mat3_det(id), 1);

    // det(| 1 2 3 | | 4 5 6 | | 7 8 9 |) = 0 (singular)
    let singular = mat3_new(1, 2, 3, 4, 5, 6, 7, 8, 9);
    assert_eq(mat3_det(singular), 0);

    // det(| 2 0 1 | | 3 1 0 | | 1 0 2 |)
    // = 2*(1*2 - 0*0) - 0*(3*2 - 0*1) + 1*(3*0 - 1*1) = 4 - 0 - 1 = 3
    let m = mat3_new(2, 0, 1, 3, 1, 0, 1, 0, 2);
    assert_eq(mat3_det(m), 3);

    print("  test_mat3_determinant: ok");
}

// ============================================================================
// Test 5: 3x3 identity multiply
// ============================================================================

@test
fn test_mat3_identity_multiply() {
    let id = mat3_identity();
    let m = mat3_new(2, 0, 1, 3, 1, 0, 1, 0, 2);

    let r1 = mat3_mul(m, id);
    assert_eq(mat3_eq(r1, m), 1);

    let r2 = mat3_mul(id, m);
    assert_eq(mat3_eq(r2, m), 1);

    print("  test_mat3_identity_multiply: ok");
}

// ============================================================================
// main
// ============================================================================

fn main() -> Int {
    test_mat2_identity_multiply();
    test_mat2_multiply_and_det();
    test_mat3_transpose_involution();
    test_mat3_determinant();
    test_mat3_identity_multiply();
    print("[OK] 113_matrix_ops");
    0
}
