// @test: differential
// @tier: 0
// @level: L0
// @tags: vbc, e2e, differential, interpreter-vs-aot, bitwise, bit-manipulation
// @timeout: 30000
// @expected-exit: 0
//
// Differential bitwise test: verifies interpreter and AOT produce identical results
// for bitwise operations (and, or, xor, shifts, popcount, bit tricks).

// Population count (number of set bits)
fn popcount(n: Int) -> Int {
    let mut x = n;
    let mut count = 0;
    while x != 0 {
        count = count + (x & 1);
        x = x >> 1;
    }
    count
}

// Check if power of 2
fn is_pow2(n: Int) -> Bool {
    n > 0 && (n & (n - 1)) == 0
}

// Highest set bit position (0-indexed from LSB), returns -1 for 0
fn highest_bit(n: Int) -> Int {
    if n == 0 { 0 - 1 }
    else {
        let mut x = n;
        let mut pos = 0;
        while x > 1 {
            x = x >> 1;
            pos = pos + 1;
        }
        pos
    }
}

// Lowest set bit position (0-indexed from LSB), returns -1 for 0
fn lowest_bit(n: Int) -> Int {
    if n == 0 { 0 - 1 }
    else {
        let mut x = n;
        let mut pos = 0;
        while (x & 1) == 0 {
            x = x >> 1;
            pos = pos + 1;
        }
        pos
    }
}

// Reverse the lower 8 bits
fn reverse_bits_8(n: Int) -> Int {
    let mut result = 0;
    let mut x = n;
    let mut i = 0;
    while i < 8 {
        result = (result << 1) | (x & 1);
        x = x >> 1;
        i = i + 1;
    }
    result
}

// Next power of 2 >= n
fn next_pow2(n: Int) -> Int {
    let mut p = 1;
    while p < n {
        p = p << 1;
    }
    p
}

// Swap two values using XOR
type Pair is { a: Int, b: Int };

fn xor_swap(p: Pair) -> Pair {
    let mut a = p.a;
    let mut b = p.b;
    a = a ^ b;
    b = a ^ b;
    a = a ^ b;
    Pair { a: a, b: b }
}

// Extract bit at position k
fn get_bit(n: Int, k: Int) -> Int {
    (n >> k) & 1
}

// Set bit at position k
fn set_bit(n: Int, k: Int) -> Int {
    n | (1 << k)
}

// Clear bit at position k
fn clear_bit(n: Int, k: Int) -> Int {
    n & (0 - 1 - (1 << k))
}

// Toggle bit at position k
fn toggle_bit(n: Int, k: Int) -> Int {
    n ^ (1 << k)
}

// Count trailing zeros
fn ctz(n: Int) -> Int {
    if n == 0 { 0 }
    else { lowest_bit(n) }
}

// Gray code: n XOR (n >> 1)
fn gray_code(n: Int) -> Int {
    n ^ (n >> 1)
}

// Inverse gray code
fn gray_decode(g: Int) -> Int {
    let mut n = g;
    let mut mask = n >> 1;
    while mask != 0 {
        n = n ^ mask;
        mask = mask >> 1;
    }
    n
}

fn main() -> Int {
    // --- Basic bitwise operators ---
    assert_eq(5 & 3, 1);       // 101 & 011 = 001
    assert_eq(5 | 3, 7);       // 101 | 011 = 111
    assert_eq(5 ^ 3, 6);       // 101 ^ 011 = 110
    assert_eq(1 << 0, 1);
    assert_eq(1 << 1, 2);
    assert_eq(1 << 3, 8);
    assert_eq(1 << 10, 1024);
    assert_eq(16 >> 2, 4);
    assert_eq(255 >> 4, 15);
    assert_eq(1024 >> 10, 1);

    // XOR identities
    assert_eq(42 ^ 42, 0);         // a ^ a = 0
    assert_eq(42 ^ 0, 42);         // a ^ 0 = a
    assert_eq(0xFF ^ 0xFF, 0);
    assert_eq((5 ^ 3) ^ 3, 5);     // (a ^ b) ^ b = a

    // --- Popcount ---
    assert_eq(popcount(0), 0);
    assert_eq(popcount(1), 1);
    assert_eq(popcount(2), 1);
    assert_eq(popcount(3), 2);
    assert_eq(popcount(7), 3);
    assert_eq(popcount(8), 1);
    assert_eq(popcount(15), 4);
    assert_eq(popcount(255), 8);
    assert_eq(popcount(256), 1);
    assert_eq(popcount(1023), 10);
    assert_eq(popcount(170), 4);    // 10101010
    assert_eq(popcount(85), 4);     // 01010101

    // --- Power of 2 ---
    assert(is_pow2(1));
    assert(is_pow2(2));
    assert(is_pow2(4));
    assert(is_pow2(8));
    assert(is_pow2(16));
    assert(is_pow2(64));
    assert(is_pow2(1024));
    assert(!is_pow2(0));
    assert(!is_pow2(3));
    assert(!is_pow2(5));
    assert(!is_pow2(6));
    assert(!is_pow2(7));
    assert(!is_pow2(100));

    // --- Highest/Lowest bit ---
    assert_eq(highest_bit(0), 0 - 1);
    assert_eq(highest_bit(1), 0);
    assert_eq(highest_bit(2), 1);
    assert_eq(highest_bit(3), 1);
    assert_eq(highest_bit(4), 2);
    assert_eq(highest_bit(8), 3);
    assert_eq(highest_bit(255), 7);
    assert_eq(highest_bit(256), 8);
    assert_eq(highest_bit(1024), 10);

    assert_eq(lowest_bit(0), 0 - 1);
    assert_eq(lowest_bit(1), 0);
    assert_eq(lowest_bit(2), 1);
    assert_eq(lowest_bit(4), 2);
    assert_eq(lowest_bit(8), 3);
    assert_eq(lowest_bit(6), 1);   // 110 -> bit 1
    assert_eq(lowest_bit(12), 2);  // 1100 -> bit 2
    assert_eq(lowest_bit(48), 4);  // 110000 -> bit 4

    // --- Reverse bits (8-bit) ---
    assert_eq(reverse_bits_8(0), 0);
    assert_eq(reverse_bits_8(1), 128);
    assert_eq(reverse_bits_8(128), 1);
    assert_eq(reverse_bits_8(255), 255);
    assert_eq(reverse_bits_8(0xAA), 0x55);  // 10101010 -> 01010101
    assert_eq(reverse_bits_8(0x55), 0xAA);  // 01010101 -> 10101010
    // Double reverse = identity
    assert_eq(reverse_bits_8(reverse_bits_8(42)), 42);
    assert_eq(reverse_bits_8(reverse_bits_8(173)), 173);

    // --- Next power of 2 ---
    assert_eq(next_pow2(1), 1);
    assert_eq(next_pow2(2), 2);
    assert_eq(next_pow2(3), 4);
    assert_eq(next_pow2(5), 8);
    assert_eq(next_pow2(7), 8);
    assert_eq(next_pow2(9), 16);
    assert_eq(next_pow2(100), 128);
    assert_eq(next_pow2(129), 256);

    // --- XOR swap ---
    let p1 = xor_swap(Pair { a: 42, b: 99 });
    assert_eq(p1.a, 99);
    assert_eq(p1.b, 42);
    let p2 = xor_swap(Pair { a: 0, b: 255 });
    assert_eq(p2.a, 255);
    assert_eq(p2.b, 0);

    // --- Get/Set/Clear/Toggle bit ---
    assert_eq(get_bit(0b1010, 0), 0);
    assert_eq(get_bit(0b1010, 1), 1);
    assert_eq(get_bit(0b1010, 2), 0);
    assert_eq(get_bit(0b1010, 3), 1);

    assert_eq(set_bit(0, 3), 8);
    assert_eq(set_bit(1, 1), 3);
    assert_eq(set_bit(0b1000, 0), 0b1001);

    assert_eq(clear_bit(0xFF, 0), 0xFE);
    assert_eq(clear_bit(0xFF, 7), 0x7F);
    assert_eq(clear_bit(0b1010, 1), 0b1000);

    assert_eq(toggle_bit(0, 3), 8);
    assert_eq(toggle_bit(8, 3), 0);
    assert_eq(toggle_bit(0b1010, 1), 0b1000);
    assert_eq(toggle_bit(0b1010, 0), 0b1011);

    // --- Trailing zeros ---
    assert_eq(ctz(1), 0);
    assert_eq(ctz(2), 1);
    assert_eq(ctz(4), 2);
    assert_eq(ctz(8), 3);
    assert_eq(ctz(12), 2);   // 1100
    assert_eq(ctz(16), 4);
    assert_eq(ctz(48), 4);   // 110000

    // --- Gray code ---
    assert_eq(gray_code(0), 0);
    assert_eq(gray_code(1), 1);
    assert_eq(gray_code(2), 3);
    assert_eq(gray_code(3), 2);
    assert_eq(gray_code(4), 6);
    assert_eq(gray_code(5), 7);
    assert_eq(gray_code(6), 5);
    assert_eq(gray_code(7), 4);

    // Gray decode is inverse of gray code
    let mut i = 0;
    while i < 16 {
        assert_eq(gray_decode(gray_code(i)), i);
        i = i + 1;
    }

    // Adjacent gray codes differ by exactly 1 bit
    let mut j = 0;
    while j < 8 {
        let diff = gray_code(j) ^ gray_code(j + 1);
        assert_eq(popcount(diff), 1);
        j = j + 1;
    }

    // --- Bit mask iteration: isolate each set bit ---
    let val = 0b10110100;  // bits 2, 4, 5, 7 set
    assert_eq(popcount(val), 4);
    assert_eq(get_bit(val, 2), 1);
    assert_eq(get_bit(val, 4), 1);
    assert_eq(get_bit(val, 5), 1);
    assert_eq(get_bit(val, 7), 1);
    assert_eq(get_bit(val, 0), 0);
    assert_eq(get_bit(val, 1), 0);
    assert_eq(get_bit(val, 3), 0);
    assert_eq(get_bit(val, 6), 0);

    print("[OK] 033_differential_bitwise");
    0
}
