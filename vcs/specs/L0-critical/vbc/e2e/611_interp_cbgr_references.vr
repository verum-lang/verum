// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, cbgr, references, memory-safety
// @timeout: 50000
// @expected-exit: 0
//
// Interpreter e2e test: CBGR reference system, record field access, mutation patterns

// =============================================================================
// Basic record construction and field access
// =============================================================================

type Vec2 is { x: Int, y: Int };

implement Vec2 {
    fn new(x: Int, y: Int) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn plus(self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }

    fn dot(self, other: Vec2) -> Int {
        self.x * other.x + self.y * other.y
    }

    fn mag_sq(self) -> Int {
        self.x * self.x + self.y * self.y
    }
}

fn test_record_basics() {
    let v = Vec2.new(3, 4);
    assert_eq(v.x, 3);
    assert_eq(v.y, 4);
    assert_eq(v.mag_sq(), 25);

    let v2 = Vec2.new(1, 2);
    let v3 = v.plus(v2);
    assert_eq(v3.x, 4);
    assert_eq(v3.y, 6);

    assert_eq(v.dot(v2), 11); // 3*1 + 4*2
    print("  test_record_basics: ok");
}

// =============================================================================
// Mutable record patterns
// =============================================================================

fn test_mutable_records() {
    let mut p = Vec2.new(0, 0);

    // Reassign entire record
    p = Vec2.new(10, 20);
    assert_eq(p.x, 10);
    assert_eq(p.y, 20);

    // Chain operations and reassign
    p = p.plus(Vec2.new(5, 5));
    assert_eq(p.x, 15);
    assert_eq(p.y, 25);
    print("  test_mutable_records: ok");
}

// =============================================================================
// Records as function parameters
// =============================================================================

fn sum_components(v: Vec2) -> Int {
    v.x + v.y
}

fn scale_vec(v: Vec2, factor: Int) -> Vec2 {
    Vec2 { x: v.x * factor, y: v.y * factor }
}

fn test_record_params() {
    let v = Vec2.new(3, 7);
    assert_eq(sum_components(v), 10);

    let scaled = scale_vec(v, 3);
    assert_eq(scaled.x, 9);
    assert_eq(scaled.y, 21);
    print("  test_record_params: ok");
}

// =============================================================================
// Records in collections
// =============================================================================

fn test_records_in_lists() {
    let mut points: List<Int> = [];

    // Store x,y pairs interleaved
    let mut i = 0;
    while i < 5 {
        points.push(i * 10);     // x
        points.push(i * 10 + 1); // y
        i = i + 1;
    }

    assert_eq(points[0], 0);
    assert_eq(points[1], 1);
    assert_eq(points[2], 10);
    assert_eq(points[3], 11);
    assert_eq(points.len(), 10);
    print("  test_records_in_lists: ok");
}

// =============================================================================
// Nested record types
// =============================================================================

type AABB is { min_x: Int, min_y: Int, max_x: Int, max_y: Int };

implement AABB {
    fn new(x1: Int, y1: Int, x2: Int, y2: Int) -> AABB {
        AABB { min_x: x1, min_y: y1, max_x: x2, max_y: y2 }
    }

    fn width(self) -> Int {
        self.max_x - self.min_x
    }

    fn height(self) -> Int {
        self.max_y - self.min_y
    }

    fn area(self) -> Int {
        self.width() * self.height()
    }

    fn contains_point(self, px: Int, py: Int) -> Bool {
        px >= self.min_x && px <= self.max_x && py >= self.min_y && py <= self.max_y
    }

    fn intersects(self, other: AABB) -> Bool {
        self.min_x <= other.max_x && self.max_x >= other.min_x &&
        self.min_y <= other.max_y && self.max_y >= other.min_y
    }

    fn expand(self, amount: Int) -> AABB {
        AABB {
            min_x: self.min_x - amount,
            min_y: self.min_y - amount,
            max_x: self.max_x + amount,
            max_y: self.max_y + amount,
        }
    }
}

fn test_complex_record() {
    let box1 = AABB.new(0, 0, 10, 10);
    assert_eq(box1.width(), 10);
    assert_eq(box1.height(), 10);
    assert_eq(box1.area(), 100);

    assert_eq(box1.contains_point(5, 5), true);
    assert_eq(box1.contains_point(15, 5), false);

    let box2 = AABB.new(5, 5, 15, 15);
    assert_eq(box1.intersects(box2), true);

    let box3 = AABB.new(20, 20, 30, 30);
    assert_eq(box1.intersects(box3), false);

    let expanded = box1.expand(2);
    assert_eq(expanded.min_x, -2);
    assert_eq(expanded.max_x, 12);
    assert_eq(expanded.area(), 14 * 14);
    print("  test_complex_record: ok");
}

// =============================================================================
// Value semantics (records are value types)
// =============================================================================

fn test_value_semantics() {
    let v1 = Vec2.new(1, 2);
    let v2 = v1; // copy, not reference

    // v1 should still be accessible
    assert_eq(v1.x, 1);
    assert_eq(v2.x, 1);

    // Modifying a copy doesn't affect original
    let v3 = Vec2.new(v2.x + 10, v2.y + 10);
    assert_eq(v3.x, 11);
    assert_eq(v1.x, 1); // original unchanged
    print("  test_value_semantics: ok");
}

// =============================================================================
// Record construction patterns
// =============================================================================

type Config is { width: Int, height: Int, depth: Int, flags: Int };

implement Config {
    fn default_config() -> Config {
        Config { width: 800, height: 600, depth: 32, flags: 0 }
    }

    fn with_width(self, w: Int) -> Config {
        Config { width: w, height: self.height, depth: self.depth, flags: self.flags }
    }

    fn with_height(self, h: Int) -> Config {
        Config { width: self.width, height: h, depth: self.depth, flags: self.flags }
    }

    fn with_flag(self, flag: Int) -> Config {
        Config { width: self.width, height: self.height, depth: self.depth, flags: self.flags + flag }
    }
}

fn test_builder_pattern() {
    let cfg = Config.default_config()
        .with_width(1920)
        .with_height(1080)
        .with_flag(1)
        .with_flag(2);

    assert_eq(cfg.width, 1920);
    assert_eq(cfg.height, 1080);
    assert_eq(cfg.depth, 32);
    assert_eq(cfg.flags, 3);
    print("  test_builder_pattern: ok");
}

// =============================================================================
// Record method dispatch across types
// =============================================================================

type Circle is { cx: Int, cy: Int, radius: Int };
type MyRect is { rx: Int, ry: Int, rw: Int, rh: Int };

implement Circle {
    fn new(x: Int, y: Int, r: Int) -> Circle {
        Circle { cx: x, cy: y, radius: r }
    }
    fn perimeter_approx(self) -> Int {
        // 2 * pi * r ≈ 6 * r
        6 * self.radius
    }
}

implement MyRect {
    fn new(x: Int, y: Int, w: Int, h: Int) -> MyRect {
        MyRect { rx: x, ry: y, rw: w, rh: h }
    }
    fn perimeter_approx(self) -> Int {
        2 * (self.rw + self.rh)
    }
}

fn test_multiple_type_dispatch() {
    let c = Circle.new(0, 0, 10);
    let r = MyRect.new(0, 0, 5, 8);

    assert_eq(c.perimeter_approx(), 60);
    assert_eq(r.perimeter_approx(), 26);
    print("  test_multiple_type_dispatch: ok");
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_record_basics();
    test_mutable_records();
    test_record_params();
    test_records_in_lists();
    test_complex_record();
    test_value_semantics();
    test_builder_pattern();
    test_multiple_type_dispatch();
    print("[OK] 611_interp_cbgr_references");
    0
}
