// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, advanced, control-flow, nested
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: complex control flow — deeply nested if/else,
// while loops with complex conditions, early return, multiple return paths,
// break-like patterns via boolean flags

// =============================================================================
// Deeply nested if/else (10+ levels)
// =============================================================================

fn classify_deep(a: Int, b: Int, c: Int, d: Int) -> Int {
    if a > 0 {
        if b > 0 {
            if c > 0 {
                if d > 0 {
                    // all positive
                    1111
                } else if d == 0 {
                    1110
                } else {
                    1100
                }
            } else if c == 0 {
                if d > 0 {
                    1010
                } else {
                    1000
                }
            } else {
                if d > 0 {
                    1001
                } else {
                    1000
                }
            }
        } else {
            if c > 0 {
                if d > 0 {
                    101
                } else {
                    100
                }
            } else {
                if d > 0 {
                    10
                } else {
                    0
                }
            }
        }
    } else {
        if b > 0 {
            if c > 0 {
                if d > 0 {
                    -1111
                } else {
                    -1110
                }
            } else {
                -1000
            }
        } else {
            -1
        }
    }
}

fn test_deep_nesting() {
    assert_eq(classify_deep(1, 1, 1, 1), 1111);
    assert_eq(classify_deep(1, 1, 1, 0), 1110);
    assert_eq(classify_deep(1, 1, 1, -1), 1100);
    assert_eq(classify_deep(1, 1, 0, 1), 1010);
    assert_eq(classify_deep(1, 1, 0, 0), 1000);
    assert_eq(classify_deep(1, 1, -1, 1), 1001);
    assert_eq(classify_deep(1, 1, -1, 0), 1000);
    assert_eq(classify_deep(1, 0, 1, 1), 101);
    assert_eq(classify_deep(1, 0, 1, 0), 100);
    assert_eq(classify_deep(1, 0, 0, 1), 10);
    assert_eq(classify_deep(1, 0, 0, 0), 0);
    assert_eq(classify_deep(0, 1, 1, 1), -1111);
    assert_eq(classify_deep(0, 1, 1, 0), -1110);
    assert_eq(classify_deep(0, 1, 0, 0), -1000);
    assert_eq(classify_deep(0, 0, 0, 0), -1);
}

// =============================================================================
// 10-level deep nesting via binary tree evaluation
// =============================================================================

fn binary_path(bits: Int) -> Int {
    // Interpret 10-bit number as a path in binary tree
    let b9 = (bits / 512) % 2;
    let b8 = (bits / 256) % 2;
    let b7 = (bits / 128) % 2;
    let b6 = (bits / 64) % 2;
    let b5 = (bits / 32) % 2;

    if b9 == 1 {
        if b8 == 1 {
            if b7 == 1 {
                if b6 == 1 {
                    if b5 == 1 {
                        // 11111xxxxx
                        31
                    } else {
                        // 11110xxxxx
                        30
                    }
                } else {
                    if b5 == 1 {
                        29
                    } else {
                        28
                    }
                }
            } else {
                if b6 == 1 {
                    if b5 == 1 {
                        27
                    } else {
                        26
                    }
                } else {
                    25
                }
            }
        } else {
            if b7 == 1 {
                if b6 == 1 {
                    24
                } else {
                    23
                }
            } else {
                22
            }
        }
    } else {
        if b8 == 1 {
            if b7 == 1 {
                21
            } else {
                20
            }
        } else {
            if b7 == 1 {
                19
            } else {
                18
            }
        }
    }
}

fn test_binary_path() {
    // 11111xxxxx = 992+ -> 31
    assert_eq(binary_path(992), 31);
    // 11110xxxxx = 960+ -> 30
    assert_eq(binary_path(960), 30);
    // 00000xxxxx = 0+ -> 18
    assert_eq(binary_path(0), 18);
    // 01000xxxxx = 256+ -> 20
    assert_eq(binary_path(256), 20);
}

// =============================================================================
// While loops with complex conditions
// =============================================================================

fn test_while_compound_condition() {
    let mut x = 0;
    let mut y = 100;
    let mut steps = 0;
    while x < y && steps < 1000 {
        x = x + 3;
        y = y - 2;
        steps = steps + 1;
    }
    // x increases by 3, y decreases by 2. They meet when gap closes.
    // After n steps: x = 3n, y = 100 - 2n. x >= y when 3n >= 100-2n -> 5n >= 100 -> n >= 20
    assert_eq(steps, 20);
    assert_eq(x, 60);
    assert_eq(y, 60);
}

fn test_while_or_condition() {
    let mut a = 0;
    let mut b = 0;
    // Loop until both a >= 5 and b >= 5
    while a < 5 || b < 5 {
        if a < 5 {
            a = a + 1;
        }
        if b < 3 {
            b = b + 1;
        } else {
            b = b + 1;
        }
    }
    assert(a >= 5);
    assert(b >= 5);
}

// =============================================================================
// Early return from deeply nested code
// =============================================================================

fn find_first_multiple(target: Int, limit: Int) -> Int {
    let mut i = 1;
    while i <= limit {
        if i % target == 0 {
            return i;
        }
        i = i + 1;
    }
    return -1;
}

fn test_early_return() {
    assert_eq(find_first_multiple(7, 100), 7);
    assert_eq(find_first_multiple(13, 100), 13);
    assert_eq(find_first_multiple(1, 5), 1);
    assert_eq(find_first_multiple(200, 100), -1);
}

fn find_in_nested(target: Int) -> Int {
    let mut i = 0;
    while i < 10 {
        let mut j = 0;
        while j < 10 {
            let val = i * 10 + j;
            if val == target {
                return val;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return -1;
}

fn test_nested_early_return() {
    assert_eq(find_in_nested(42), 42);
    assert_eq(find_in_nested(0), 0);
    assert_eq(find_in_nested(99), 99);
    assert_eq(find_in_nested(100), -1);
}

// =============================================================================
// Multiple return paths
// =============================================================================

fn categorize_number(n: Int) -> Int {
    if n < 0 {
        return -1;
    }
    if n == 0 {
        return 0;
    }
    if n < 10 {
        return 1;
    }
    if n < 100 {
        return 2;
    }
    if n < 1000 {
        return 3;
    }
    return 4;
}

fn test_multiple_return_paths() {
    assert_eq(categorize_number(-5), -1);
    assert_eq(categorize_number(0), 0);
    assert_eq(categorize_number(5), 1);
    assert_eq(categorize_number(50), 2);
    assert_eq(categorize_number(500), 3);
    assert_eq(categorize_number(5000), 4);
}

// =============================================================================
// Break-like patterns using boolean flags
// =============================================================================

fn test_flag_break_pattern() {
    // Simulate "break" using a done flag
    let mut sum = 0;
    let mut i = 0;
    let mut done = 0;
    while i < 100 && done == 0 {
        sum = sum + i;
        if sum > 50 {
            done = 1;
        }
        i = i + 1;
    }
    // 0+1+2+...+10 = 55 > 50, so stops at i=11
    assert(sum > 50);
    assert(sum <= 66);
}

fn test_double_flag_break() {
    // Find first pair (i,j) where i*j > 50
    let mut found_i = -1;
    let mut found_j = -1;
    let mut outer_done = 0;
    let mut i = 1;
    while i < 20 && outer_done == 0 {
        let mut inner_done = 0;
        let mut j = 1;
        while j < 20 && inner_done == 0 {
            if i * j > 50 {
                found_i = i;
                found_j = j;
                inner_done = 1;
                outer_done = 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    assert(found_i > 0);
    assert(found_j > 0);
    assert(found_i * found_j > 50);
}

// =============================================================================
// Complex loop with multiple conditions and state
// =============================================================================

fn collatz_steps(n: Int) -> Int {
    let mut val = n;
    let mut steps = 0;
    while val != 1 && steps < 1000 {
        if val % 2 == 0 {
            val = val / 2;
        } else {
            val = val * 3 + 1;
        }
        steps = steps + 1;
    }
    steps
}

fn test_collatz() {
    assert_eq(collatz_steps(1), 0);
    assert_eq(collatz_steps(2), 1);
    assert_eq(collatz_steps(4), 2);
    // 3 -> 10 -> 5 -> 16 -> 8 -> 4 -> 2 -> 1 = 7 steps
    assert_eq(collatz_steps(3), 7);
    // 6 -> 3 -> 10 -> 5 -> 16 -> 8 -> 4 -> 2 -> 1 = 8 steps
    assert_eq(collatz_steps(6), 8);
}

// =============================================================================
// Nested loops with conditionals
// =============================================================================

fn test_nested_loops_with_conditions() {
    // Count pairs (i,j) where i+j is even and i*j < 20
    let mut count = 0;
    let mut i = 0;
    while i < 10 {
        let mut j = 0;
        while j < 10 {
            if (i + j) % 2 == 0 {
                if i * j < 20 {
                    count = count + 1;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    assert(count > 0);
    assert(count < 100);
}

// =============================================================================
// State machine pattern
// =============================================================================

fn run_state_machine(input: Int) -> Int {
    let mut state = 0;
    let mut remaining = input;
    let mut result = 0;
    let mut iterations = 0;

    while state != 99 && iterations < 100 {
        if state == 0 {
            if remaining > 0 {
                state = 1;
                result = result + 1;
            } else {
                state = 99;
            }
        } else if state == 1 {
            remaining = remaining - 1;
            if remaining % 3 == 0 {
                state = 2;
            } else {
                state = 0;
            }
            result = result + 10;
        } else if state == 2 {
            result = result + 100;
            state = 0;
        }
        iterations = iterations + 1;
    }
    result
}

fn test_state_machine() {
    let r0 = run_state_machine(0);
    assert(r0 >= 0);

    let r1 = run_state_machine(1);
    assert(r1 > 0);

    let r3 = run_state_machine(3);
    assert(r3 > r1);
}

// =============================================================================
// Complex return with nested conditions
// =============================================================================

fn evaluate(a: Int, b: Int, op: Int) -> Int {
    if op == 0 {
        if a > 0 && b > 0 {
            return a + b;
        } else if a > 0 {
            return a;
        } else if b > 0 {
            return b;
        } else {
            return 0;
        }
    } else if op == 1 {
        if a >= b {
            return a - b;
        } else {
            return b - a;
        }
    } else if op == 2 {
        if b != 0 {
            return a / b;
        } else {
            return -1;
        }
    }
    return -999;
}

fn test_evaluate() {
    assert_eq(evaluate(3, 4, 0), 7);
    assert_eq(evaluate(3, -1, 0), 3);
    assert_eq(evaluate(-1, 4, 0), 4);
    assert_eq(evaluate(-1, -1, 0), 0);
    assert_eq(evaluate(10, 3, 1), 7);
    assert_eq(evaluate(3, 10, 1), 7);
    assert_eq(evaluate(10, 3, 2), 3);
    assert_eq(evaluate(10, 0, 2), -1);
    assert_eq(evaluate(1, 1, 5), -999);
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_deep_nesting();
    test_binary_path();
    test_while_compound_condition();
    test_while_or_condition();
    test_early_return();
    test_nested_early_return();
    test_multiple_return_paths();
    test_flag_break_pattern();
    test_double_flag_break();
    test_collatz();
    test_nested_loops_with_conditions();
    test_state_machine();
    test_evaluate();
    print("[OK] 268_interp_complex_control");
    0
}
