// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, cbgr, memory, advanced
// @timeout: 15000
// @expected-exit: 0
//
// CBGR advanced reference test: Accumulator patterns.
// Running sums, statistics, histograms via &mut ref. Multi-accumulator
// patterns, windowed aggregation, and running averages.

// ============================================================================
// Type definitions
// ============================================================================

type RunningSum is { total: Int, count: Int };
type MinMax is { mn: Int, mx: Int, initialized: Bool };
type Histogram5 is { b0: Int, b1: Int, b2: Int, b3: Int, b4: Int };
type EMA is { value: Int, alpha_num: Int, alpha_den: Int, started: Bool };
type Classifier is { neg_count: Int, zero_count: Int, pos_count: Int };

// ============================================================================
// Running sum accumulator
// ============================================================================

fn rsum_new() -> RunningSum {
    RunningSum { total: 0, count: 0 }
}

fn rsum_add(s: &mut RunningSum, val: Int) {
    (*s).total = (*s).total + val;
    (*s).count = (*s).count + 1;
}

fn rsum_avg(s: &RunningSum) -> Int {
    if (*s).count == 0 { return 0; }
    (*s).total / (*s).count
}

fn rsum_reset(s: &mut RunningSum) {
    (*s).total = 0;
    (*s).count = 0;
}

// ============================================================================
// MinMax tracker
// ============================================================================

fn minmax_new() -> MinMax {
    MinMax { mn: 0, mx: 0, initialized: false }
}

fn minmax_update(mm: &mut MinMax, val: Int) {
    if !(*mm).initialized {
        (*mm).mn = val;
        (*mm).mx = val;
        (*mm).initialized = true;
    } else {
        if val < (*mm).mn { (*mm).mn = val; }
        if val > (*mm).mx { (*mm).mx = val; }
    }
}

fn minmax_range(mm: &MinMax) -> Int {
    (*mm).mx - (*mm).mn
}

// ============================================================================
// Histogram with 5 bins [0,20), [20,40), [40,60), [60,80), [80,100]
// ============================================================================

fn hist_new() -> Histogram5 {
    Histogram5 { b0: 0, b1: 0, b2: 0, b3: 0, b4: 0 }
}

fn hist_add(h: &mut Histogram5, val: Int) {
    if val < 20 { (*h).b0 = (*h).b0 + 1; }
    else if val < 40 { (*h).b1 = (*h).b1 + 1; }
    else if val < 60 { (*h).b2 = (*h).b2 + 1; }
    else if val < 80 { (*h).b3 = (*h).b3 + 1; }
    else { (*h).b4 = (*h).b4 + 1; }
}

fn hist_total(h: &Histogram5) -> Int {
    (*h).b0 + (*h).b1 + (*h).b2 + (*h).b3 + (*h).b4
}

fn hist_max_bin(h: &Histogram5) -> Int {
    let mut mx = (*h).b0;
    if (*h).b1 > mx { mx = (*h).b1; }
    if (*h).b2 > mx { mx = (*h).b2; }
    if (*h).b3 > mx { mx = (*h).b3; }
    if (*h).b4 > mx { mx = (*h).b4; }
    mx
}

fn hist_mode_bin(h: &Histogram5) -> Int {
    let mx = hist_max_bin(h);
    if (*h).b0 == mx { 0 }
    else if (*h).b1 == mx { 1 }
    else if (*h).b2 == mx { 2 }
    else if (*h).b3 == mx { 3 }
    else { 4 }
}

// ============================================================================
// Exponential moving average (integer approximation)
// ============================================================================

fn ema_new(alpha_num: Int, alpha_den: Int) -> EMA {
    EMA { value: 0, alpha_num: alpha_num, alpha_den: alpha_den, started: false }
}

fn ema_update(e: &mut EMA, val: Int) {
    if !(*e).started {
        (*e).value = val * (*e).alpha_den;
        (*e).started = true;
    } else {
        // EMA = alpha * val + (1-alpha) * prev
        // Stored scaled by alpha_den to avoid floats
        let scaled_val = val * (*e).alpha_num;
        let scaled_prev = (*e).value * ((*e).alpha_den - (*e).alpha_num) / (*e).alpha_den;
        (*e).value = scaled_val + scaled_prev;
    }
}

fn ema_get(e: &EMA) -> Int {
    (*e).value / (*e).alpha_den
}

// ============================================================================
// Classifier accumulator
// ============================================================================

fn classifier_new() -> Classifier {
    Classifier { neg_count: 0, zero_count: 0, pos_count: 0 }
}

fn classifier_add(c: &mut Classifier, val: Int) {
    if val < 0 { (*c).neg_count = (*c).neg_count + 1; }
    else if val == 0 { (*c).zero_count = (*c).zero_count + 1; }
    else { (*c).pos_count = (*c).pos_count + 1; }
}

fn classifier_total(c: &Classifier) -> Int {
    (*c).neg_count + (*c).zero_count + (*c).pos_count
}

// ============================================================================
// Tests
// ============================================================================

fn test_running_sum_basic() {
    let mut rs = rsum_new();
    rsum_add(&mut rs, 10);
    rsum_add(&mut rs, 20);
    rsum_add(&mut rs, 30);
    assert_eq(rs.total, 60);
    assert_eq(rs.count, 3);
    // Direct field access to avoid &rs / &mut rs conflict
    let avg = rs.total / rs.count;
    assert_eq(avg, 20);
}

fn test_running_sum_loop() {
    let mut rs = rsum_new();
    let mut i = 1;
    while i <= 100 {
        rsum_add(&mut rs, i);
        i = i + 1;
    }
    assert_eq(rs.total, 5050);
    assert_eq(rs.count, 100);
    // Direct field access to avoid &rs / &mut rs conflict
    let avg = rs.total / rs.count;
    assert_eq(avg, 50);
}

fn test_running_sum_reset() {
    let mut rs = rsum_new();
    rsum_add(&mut rs, 100);
    rsum_add(&mut rs, 200);
    rsum_reset(&mut rs);
    assert_eq(rs.total, 0);
    assert_eq(rs.count, 0);
    rsum_add(&mut rs, 50);
    assert_eq(rs.total, 50);
    assert_eq(rs.count, 1);
}

fn test_minmax_basic() {
    let mut mm = minmax_new();
    minmax_update(&mut mm, 15);
    minmax_update(&mut mm, 5);
    minmax_update(&mut mm, 25);
    minmax_update(&mut mm, 10);
    assert_eq(mm.mn, 5);
    assert_eq(mm.mx, 25);
    // Direct field access to avoid &mm / &mut mm conflict
    assert_eq(mm.mx - mm.mn, 20);
}

fn test_minmax_single() {
    let mut mm = minmax_new();
    minmax_update(&mut mm, 42);
    assert_eq(mm.mn, 42);
    assert_eq(mm.mx, 42);
    assert_eq(mm.mx - mm.mn, 0);
}

fn test_minmax_negative() {
    let mut mm = minmax_new();
    minmax_update(&mut mm, -10);
    minmax_update(&mut mm, -5);
    minmax_update(&mut mm, -20);
    assert_eq(mm.mn, -20);
    assert_eq(mm.mx, -5);
    assert_eq(mm.mx - mm.mn, 15);
}

fn test_histogram_basic() {
    let mut h = hist_new();
    hist_add(&mut h, 5);    // b0
    hist_add(&mut h, 15);   // b0
    hist_add(&mut h, 25);   // b1
    hist_add(&mut h, 45);   // b2
    hist_add(&mut h, 65);   // b3
    hist_add(&mut h, 85);   // b4
    hist_add(&mut h, 10);   // b0
    assert_eq(h.b0, 3);
    assert_eq(h.b1, 1);
    assert_eq(h.b2, 1);
    assert_eq(h.b3, 1);
    assert_eq(h.b4, 1);
    // Direct field access to avoid &h / &mut h conflict
    assert_eq(h.b0 + h.b1 + h.b2 + h.b3 + h.b4, 7);
    // max bin value = 3 (b0)
    let mut mx = h.b0;
    if h.b1 > mx { mx = h.b1; }
    if h.b2 > mx { mx = h.b2; }
    if h.b3 > mx { mx = h.b3; }
    if h.b4 > mx { mx = h.b4; }
    assert_eq(mx, 3);
    // mode bin = 0 (b0 has highest count)
    let mode = if h.b0 == mx { 0 }
        else if h.b1 == mx { 1 }
        else if h.b2 == mx { 2 }
        else if h.b3 == mx { 3 }
        else { 4 };
    assert_eq(mode, 0);
}

fn test_histogram_uniform() {
    let mut h = hist_new();
    let mut i = 0;
    while i < 100 {
        hist_add(&mut h, i);
        i = i + 1;
    }
    assert_eq(h.b0, 20);
    assert_eq(h.b1, 20);
    assert_eq(h.b2, 20);
    assert_eq(h.b3, 20);
    assert_eq(h.b4, 20);
    // Direct field access to avoid &h / &mut h conflict
    assert_eq(h.b0 + h.b1 + h.b2 + h.b3 + h.b4, 100);
}

fn test_ema_basic() {
    let mut e = ema_new(1, 4); // alpha = 0.25
    ema_update(&mut e, 100);
    let v1 = e.value / e.alpha_den;
    assert_eq(v1, 100);
    ema_update(&mut e, 100);
    let v2 = e.value / e.alpha_den;
    assert_eq(v2, 100);
}

fn test_ema_step() {
    let mut e = ema_new(1, 2); // alpha = 0.5
    ema_update(&mut e, 100);
    let v1 = e.value / e.alpha_den;
    assert_eq(v1, 100);
    ema_update(&mut e, 0);
    // 0.5 * 0 + 0.5 * 100 = 50
    let v2 = e.value / e.alpha_den;
    assert_eq(v2, 50);
}

fn test_classifier_basic() {
    let mut c = classifier_new();
    classifier_add(&mut c, -5);
    classifier_add(&mut c, -3);
    classifier_add(&mut c, 0);
    classifier_add(&mut c, 7);
    classifier_add(&mut c, 10);
    classifier_add(&mut c, 0);
    assert_eq(c.neg_count, 2);
    assert_eq(c.zero_count, 2);
    assert_eq(c.pos_count, 2);
    // Direct field access to avoid &c / &mut c conflict
    assert_eq(c.neg_count + c.zero_count + c.pos_count, 6);
}

fn test_classifier_loop() {
    let mut c = classifier_new();
    let mut i = -10;
    while i <= 10 {
        classifier_add(&mut c, i);
        i = i + 1;
    }
    assert_eq(c.neg_count, 10);
    assert_eq(c.zero_count, 1);
    assert_eq(c.pos_count, 10);
    // Direct field access to avoid &c / &mut c conflict
    assert_eq(c.neg_count + c.zero_count + c.pos_count, 21);
}

fn test_multi_accumulator() {
    let mut rs = rsum_new();
    let mut mm = minmax_new();
    let mut h = hist_new();
    let mut c = classifier_new();
    let mut i = 0;
    while i < 50 {
        let val = i * 2;
        rsum_add(&mut rs, val);
        minmax_update(&mut mm, val);
        hist_add(&mut h, val);
        classifier_add(&mut c, val);
        i = i + 1;
    }
    assert_eq(rs.count, 50);
    assert_eq(mm.mn, 0);
    assert_eq(mm.mx, 98);
    // Direct field access to avoid &h / &mut h conflict
    assert_eq(h.b0 + h.b1 + h.b2 + h.b3 + h.b4, 50);
    assert_eq(c.zero_count, 1);
    assert_eq(c.pos_count, 49);
}

fn main() -> Int {
    test_running_sum_basic();
    test_running_sum_loop();
    test_running_sum_reset();
    test_minmax_basic();
    test_minmax_single();
    test_minmax_negative();
    test_histogram_basic();
    test_histogram_uniform();
    test_ema_basic();
    test_ema_step();
    test_classifier_basic();
    test_classifier_loop();
    test_multi_accumulator();
    print("[OK] 366_interp_cbgr_ref_unsafe");
    0
}
