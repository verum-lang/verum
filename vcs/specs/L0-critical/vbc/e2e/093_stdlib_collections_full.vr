// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, stdlib, collections
// @timeout: 50000
// @expected-exit: 0
// @description: Stdlib collections — List/Map/Set full lifecycle simulation

// ============================================================================
// FixedList8: Manual array-backed list with 8 slots
// ============================================================================

type FixedList8 is {
    e0: Int, e1: Int, e2: Int, e3: Int,
    e4: Int, e5: Int, e6: Int, e7: Int,
    len: Int
};

fn fl_new() -> FixedList8 {
    FixedList8 { e0: 0, e1: 0, e2: 0, e3: 0, e4: 0, e5: 0, e6: 0, e7: 0, len: 0 }
}

fn fl_get(list: FixedList8, i: Int) -> Int {
    if i == 0 { list.e0 } else if i == 1 { list.e1 } else if i == 2 { list.e2 }
    else if i == 3 { list.e3 } else if i == 4 { list.e4 } else if i == 5 { list.e5 }
    else if i == 6 { list.e6 } else { list.e7 }
}

fn fl_set(list: FixedList8, i: Int, val: Int) -> FixedList8 {
    FixedList8 {
        e0: if i == 0 { val } else { list.e0 },
        e1: if i == 1 { val } else { list.e1 },
        e2: if i == 2 { val } else { list.e2 },
        e3: if i == 3 { val } else { list.e3 },
        e4: if i == 4 { val } else { list.e4 },
        e5: if i == 5 { val } else { list.e5 },
        e6: if i == 6 { val } else { list.e6 },
        e7: if i == 7 { val } else { list.e7 },
        len: list.len
    }
}

fn fl_push(list: FixedList8, val: Int) -> FixedList8 {
    let i = list.len;
    let updated = fl_set(list, i, val);
    FixedList8 {
        e0: updated.e0, e1: updated.e1, e2: updated.e2, e3: updated.e3,
        e4: updated.e4, e5: updated.e5, e6: updated.e6, e7: updated.e7,
        len: i + 1
    }
}

fn fl_pop(list: FixedList8) -> FixedList8 {
    // Removes last element (sets it to 0, decrements len)
    if list.len == 0 { list }
    else {
        let new_len = list.len - 1;
        let cleared = fl_set(list, new_len, 0);
        FixedList8 {
            e0: cleared.e0, e1: cleared.e1, e2: cleared.e2, e3: cleared.e3,
            e4: cleared.e4, e5: cleared.e5, e6: cleared.e6, e7: cleared.e7,
            len: new_len
        }
    }
}

fn fl_last(list: FixedList8) -> Int {
    if list.len == 0 { 0 }
    else { fl_get(list, list.len - 1) }
}

fn fl_contains(list: FixedList8, val: Int) -> Int {
    let mut i = 0;
    while i < list.len {
        if fl_get(list, i) == val { return 1; }
        i = i + 1;
    }
    0
}

fn fl_index_of(list: FixedList8, val: Int) -> Int {
    let mut i = 0;
    while i < list.len {
        if fl_get(list, i) == val { return i; }
        i = i + 1;
    }
    -1
}

// ============================================================================
// Map8: Manual hash map with 8 slots (linear probing)
// ============================================================================

type MapEntry is { key: Int, val: Int, occupied: Int };

type Map8 is {
    e0: MapEntry, e1: MapEntry, e2: MapEntry, e3: MapEntry,
    e4: MapEntry, e5: MapEntry, e6: MapEntry, e7: MapEntry
};

fn me_empty() -> MapEntry {
    MapEntry { key: 0, val: 0, occupied: 0 }
}

fn map_new() -> Map8 {
    Map8 {
        e0: me_empty(), e1: me_empty(), e2: me_empty(), e3: me_empty(),
        e4: me_empty(), e5: me_empty(), e6: me_empty(), e7: me_empty()
    }
}

fn map_entry_at(m: Map8, i: Int) -> MapEntry {
    if i == 0 { m.e0 } else if i == 1 { m.e1 } else if i == 2 { m.e2 }
    else if i == 3 { m.e3 } else if i == 4 { m.e4 } else if i == 5 { m.e5 }
    else if i == 6 { m.e6 } else { m.e7 }
}

fn map_set_entry(m: Map8, i: Int, e: MapEntry) -> Map8 {
    Map8 {
        e0: if i == 0 { e } else { m.e0 },
        e1: if i == 1 { e } else { m.e1 },
        e2: if i == 2 { e } else { m.e2 },
        e3: if i == 3 { e } else { m.e3 },
        e4: if i == 4 { e } else { m.e4 },
        e5: if i == 5 { e } else { m.e5 },
        e6: if i == 6 { e } else { m.e6 },
        e7: if i == 7 { e } else { m.e7 }
    }
}

fn map_hash(key: Int) -> Int {
    // Simple hash: key mod 8 (always positive)
    let h = key - (key / 8) * 8;
    if h < 0 { h + 8 } else { h }
}

fn map_insert(m: Map8, key: Int, val: Int) -> Map8 {
    let start = map_hash(key);
    let mut i = 0;
    let mut result = m;
    let mut done = 0;
    while i < 8 {
        if done == 0 {
            let slot = (start + i) - ((start + i) / 8) * 8;
            let entry = map_entry_at(result, slot);
            if entry.occupied == 0 {
                result = map_set_entry(result, slot, MapEntry { key: key, val: val, occupied: 1 });
                done = 1;
            } else if entry.key == key {
                // Update existing key
                result = map_set_entry(result, slot, MapEntry { key: key, val: val, occupied: 1 });
                done = 1;
            }
        }
        i = i + 1;
    }
    result
}

fn map_get(m: Map8, key: Int) -> Int {
    let start = map_hash(key);
    let mut i = 0;
    while i < 8 {
        let slot = (start + i) - ((start + i) / 8) * 8;
        let entry = map_entry_at(m, slot);
        if entry.occupied == 1 {
            if entry.key == key { return entry.val; }
        } else {
            return -1;  // Not found (empty slot breaks probe chain)
        }
        i = i + 1;
    }
    -1
}

fn map_contains_key(m: Map8, key: Int) -> Int {
    if map_get(m, key) == -1 { 0 } else { 1 }
}

fn map_count(m: Map8) -> Int {
    let mut c = 0;
    let mut i = 0;
    while i < 8 {
        let e = map_entry_at(m, i);
        if e.occupied == 1 { c = c + 1; }
        i = i + 1;
    }
    c
}

// ============================================================================
// Set8: Manual set based on FixedList8 (no duplicates)
// ============================================================================

fn set_add(s: FixedList8, val: Int) -> FixedList8 {
    if fl_contains(s, val) == 1 { s }
    else { fl_push(s, val) }
}

fn set_remove(s: FixedList8, val: Int) -> FixedList8 {
    // Find and remove by compacting
    let idx = fl_index_of(s, val);
    if idx == -1 { return s; }
    // Shift elements left from idx+1 onward
    let mut result = s;
    let mut i = idx;
    while i < s.len - 1 {
        result = fl_set(result, i, fl_get(result, i + 1));
        i = i + 1;
    }
    // Clear last slot and decrement
    result = fl_set(result, s.len - 1, 0);
    FixedList8 {
        e0: result.e0, e1: result.e1, e2: result.e2, e3: result.e3,
        e4: result.e4, e5: result.e5, e6: result.e6, e7: result.e7,
        len: s.len - 1
    }
}

fn set_union(a: FixedList8, b: FixedList8) -> FixedList8 {
    let mut result = a;
    let mut i = 0;
    while i < b.len {
        result = set_add(result, fl_get(b, i));
        i = i + 1;
    }
    result
}

fn set_intersection(a: FixedList8, b: FixedList8) -> FixedList8 {
    let mut result = fl_new();
    let mut i = 0;
    while i < a.len {
        let v = fl_get(a, i);
        if fl_contains(b, v) == 1 {
            result = fl_push(result, v);
        }
        i = i + 1;
    }
    result
}

// ============================================================================
// Test 1: List operations — push, pop, get, contains, index_of
// ============================================================================

@test
fn test_list_operations() {
    let mut list = fl_new();
    assert_eq(list.len, 0);

    // Push elements
    list = fl_push(list, 10);
    list = fl_push(list, 20);
    list = fl_push(list, 30);
    list = fl_push(list, 40);
    assert_eq(list.len, 4);

    // Get elements
    assert_eq(fl_get(list, 0), 10);
    assert_eq(fl_get(list, 1), 20);
    assert_eq(fl_get(list, 2), 30);
    assert_eq(fl_get(list, 3), 40);

    // Last element
    assert_eq(fl_last(list), 40);

    // Contains
    assert_eq(fl_contains(list, 20), 1);
    assert_eq(fl_contains(list, 50), 0);

    // Index of
    assert_eq(fl_index_of(list, 30), 2);
    assert_eq(fl_index_of(list, 99), -1);

    // Pop
    list = fl_pop(list);
    assert_eq(list.len, 3);
    assert_eq(fl_last(list), 30);

    // Pop again
    list = fl_pop(list);
    assert_eq(list.len, 2);
    assert_eq(fl_last(list), 20);

    // Set element
    list = fl_set(list, 0, 99);
    assert_eq(fl_get(list, 0), 99);
    assert_eq(list.len, 2);

    print("  test_list_operations: ok");
}

// ============================================================================
// Test 2: Map operations — insert, get, contains_key, update
// ============================================================================

@test
fn test_map_operations() {
    let mut m = map_new();
    assert_eq(map_count(m), 0);

    // Insert key-value pairs
    m = map_insert(m, 1, 100);
    m = map_insert(m, 2, 200);
    m = map_insert(m, 3, 300);
    assert_eq(map_count(m), 3);

    // Lookup
    assert_eq(map_get(m, 1), 100);
    assert_eq(map_get(m, 2), 200);
    assert_eq(map_get(m, 3), 300);

    // Contains key
    assert_eq(map_contains_key(m, 1), 1);
    assert_eq(map_contains_key(m, 99), 0);

    // Update existing key
    m = map_insert(m, 2, 999);
    assert_eq(map_get(m, 2), 999);
    assert_eq(map_count(m), 3);  // No extra entry

    // Insert more
    m = map_insert(m, 10, 1000);
    m = map_insert(m, 18, 1800);  // Same hash bucket as 10 (mod 8 = 2)
    assert_eq(map_get(m, 10), 1000);
    assert_eq(map_get(m, 18), 1800);
    assert_eq(map_count(m), 5);

    print("  test_map_operations: ok");
}

// ============================================================================
// Test 3: Set operations — add, contains, remove, no duplicates
// ============================================================================

@test
fn test_set_operations() {
    let mut s = fl_new();

    // Add elements
    s = set_add(s, 5);
    s = set_add(s, 10);
    s = set_add(s, 15);
    assert_eq(s.len, 3);

    // No duplicates
    s = set_add(s, 10);
    assert_eq(s.len, 3);
    s = set_add(s, 5);
    assert_eq(s.len, 3);

    // Contains
    assert_eq(fl_contains(s, 5), 1);
    assert_eq(fl_contains(s, 10), 1);
    assert_eq(fl_contains(s, 15), 1);
    assert_eq(fl_contains(s, 20), 0);

    // Remove
    s = set_remove(s, 10);
    assert_eq(s.len, 2);
    assert_eq(fl_contains(s, 10), 0);
    assert_eq(fl_contains(s, 5), 1);
    assert_eq(fl_contains(s, 15), 1);

    // Remove non-existent (no-op)
    s = set_remove(s, 99);
    assert_eq(s.len, 2);

    print("  test_set_operations: ok");
}

// ============================================================================
// Test 4: Set union and intersection
// ============================================================================

@test
fn test_set_algebra() {
    let mut a = fl_new();
    a = set_add(a, 1);
    a = set_add(a, 2);
    a = set_add(a, 3);

    let mut b = fl_new();
    b = set_add(b, 2);
    b = set_add(b, 3);
    b = set_add(b, 4);

    // Union: {1,2,3} | {2,3,4} = {1,2,3,4}
    let u = set_union(a, b);
    assert_eq(u.len, 4);
    assert_eq(fl_contains(u, 1), 1);
    assert_eq(fl_contains(u, 2), 1);
    assert_eq(fl_contains(u, 3), 1);
    assert_eq(fl_contains(u, 4), 1);

    // Intersection: {1,2,3} & {2,3,4} = {2,3}
    let inter = set_intersection(a, b);
    assert_eq(inter.len, 2);
    assert_eq(fl_contains(inter, 2), 1);
    assert_eq(fl_contains(inter, 3), 1);
    assert_eq(fl_contains(inter, 1), 0);
    assert_eq(fl_contains(inter, 4), 0);

    // Intersection with empty set
    let empty = fl_new();
    let inter2 = set_intersection(a, empty);
    assert_eq(inter2.len, 0);

    // Union with empty set
    let u2 = set_union(empty, b);
    assert_eq(u2.len, 3);

    print("  test_set_algebra: ok");
}

// ============================================================================
// Test 5: Edge cases — empty collections, boundary conditions
// ============================================================================

@test
fn test_edge_cases() {
    // Empty list operations
    let empty = fl_new();
    assert_eq(fl_contains(empty, 0), 0);
    assert_eq(fl_index_of(empty, 1), -1);
    assert_eq(fl_last(empty), 0);
    let still_empty = fl_pop(empty);
    assert_eq(still_empty.len, 0);

    // Fill list to capacity
    let mut full = fl_new();
    let mut i = 0;
    while i < 8 {
        full = fl_push(full, (i + 1) * 10);
        i = i + 1;
    }
    assert_eq(full.len, 8);
    assert_eq(fl_get(full, 0), 10);
    assert_eq(fl_get(full, 7), 80);

    // Empty map
    let em = map_new();
    assert_eq(map_get(em, 0), -1);
    assert_eq(map_count(em), 0);

    // Map with negative keys
    let mut m = map_new();
    m = map_insert(m, 0, 42);
    assert_eq(map_get(m, 0), 42);

    // Set: add then remove all
    let mut s = fl_new();
    s = set_add(s, 7);
    s = set_add(s, 14);
    s = set_remove(s, 7);
    s = set_remove(s, 14);
    assert_eq(s.len, 0);

    print("  test_edge_cases: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_list_operations();
    test_map_operations();
    test_set_operations();
    test_set_algebra();
    test_edge_cases();
    print("[OK] 093_stdlib_collections_full");
    0
}
