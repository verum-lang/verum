// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, char, classify
// @timeout: 50000
// @expected-exit: 0
// @description: Character classification — is_digit, is_alpha, is_upper, is_lower, is_space, case conversion

// ============================================================================
// Character classification functions (ASCII values)
// ============================================================================

// Digit: '0'(48) - '9'(57)
fn is_digit(c: Int) -> Int {
    if c >= 48 {
        if c <= 57 { 1 } else { 0 }
    } else { 0 }
}

// Uppercase: 'A'(65) - 'Z'(90)
fn is_upper(c: Int) -> Int {
    if c >= 65 {
        if c <= 90 { 1 } else { 0 }
    } else { 0 }
}

// Lowercase: 'a'(97) - 'z'(122)
fn is_lower(c: Int) -> Int {
    if c >= 97 {
        if c <= 122 { 1 } else { 0 }
    } else { 0 }
}

fn is_alpha(c: Int) -> Int {
    if is_upper(c) == 1 { 1 }
    else if is_lower(c) == 1 { 1 }
    else { 0 }
}

fn is_alnum(c: Int) -> Int {
    if is_alpha(c) == 1 { 1 }
    else if is_digit(c) == 1 { 1 }
    else { 0 }
}

// Space: ' '(32), '\t'(9), '\n'(10), '\r'(13)
fn is_space(c: Int) -> Int {
    if c == 32 { 1 }
    else if c == 9 { 1 }
    else if c == 10 { 1 }
    else if c == 13 { 1 }
    else { 0 }
}

fn to_upper(c: Int) -> Int {
    if is_lower(c) == 1 { c - 32 } else { c }
}

fn to_lower(c: Int) -> Int {
    if is_upper(c) == 1 { c + 32 } else { c }
}

// ============================================================================
// Test 1: Digit classification
// ============================================================================

@test
fn test_is_digit() {
    // '0' = 48 through '9' = 57
    assert_eq(is_digit(48), 1);   // '0'
    assert_eq(is_digit(53), 1);   // '5'
    assert_eq(is_digit(57), 1);   // '9'
    assert_eq(is_digit(47), 0);   // '/' (before '0')
    assert_eq(is_digit(58), 0);   // ':' (after '9')
    assert_eq(is_digit(65), 0);   // 'A'
    assert_eq(is_digit(0), 0);
    print("  test_is_digit: ok");
}

// ============================================================================
// Test 2: Alpha classification
// ============================================================================

@test
fn test_is_alpha() {
    assert_eq(is_alpha(65), 1);   // 'A'
    assert_eq(is_alpha(90), 1);   // 'Z'
    assert_eq(is_alpha(97), 1);   // 'a'
    assert_eq(is_alpha(122), 1);  // 'z'
    assert_eq(is_alpha(48), 0);   // '0'
    assert_eq(is_alpha(32), 0);   // space
    assert_eq(is_alpha(64), 0);   // '@'
    assert_eq(is_alpha(91), 0);   // '['
    assert_eq(is_alpha(96), 0);   // '`'
    assert_eq(is_alpha(123), 0);  // '{'
    print("  test_is_alpha: ok");
}

// ============================================================================
// Test 3: Upper/lower classification
// ============================================================================

@test
fn test_upper_lower() {
    assert_eq(is_upper(65), 1);   // 'A'
    assert_eq(is_upper(77), 1);   // 'M'
    assert_eq(is_upper(90), 1);   // 'Z'
    assert_eq(is_upper(97), 0);   // 'a'
    assert_eq(is_upper(48), 0);   // '0'

    assert_eq(is_lower(97), 1);   // 'a'
    assert_eq(is_lower(109), 1);  // 'm'
    assert_eq(is_lower(122), 1);  // 'z'
    assert_eq(is_lower(65), 0);   // 'A'
    assert_eq(is_lower(48), 0);   // '0'
    print("  test_upper_lower: ok");
}

// ============================================================================
// Test 4: Space classification
// ============================================================================

@test
fn test_is_space() {
    assert_eq(is_space(32), 1);   // space
    assert_eq(is_space(9), 1);    // tab
    assert_eq(is_space(10), 1);   // newline
    assert_eq(is_space(13), 1);   // carriage return
    assert_eq(is_space(0), 0);    // null
    assert_eq(is_space(65), 0);   // 'A'
    assert_eq(is_space(48), 0);   // '0'
    assert_eq(is_space(33), 0);   // '!'
    print("  test_is_space: ok");
}

// ============================================================================
// Test 5: Case conversion
// ============================================================================

@test
fn test_case_conversion() {
    // to_upper
    assert_eq(to_upper(97), 65);    // 'a' -> 'A'
    assert_eq(to_upper(122), 90);   // 'z' -> 'Z'
    assert_eq(to_upper(65), 65);    // 'A' unchanged
    assert_eq(to_upper(48), 48);    // '0' unchanged

    // to_lower
    assert_eq(to_lower(65), 97);    // 'A' -> 'a'
    assert_eq(to_lower(90), 122);   // 'Z' -> 'z'
    assert_eq(to_lower(97), 97);    // 'a' unchanged
    assert_eq(to_lower(48), 48);    // '0' unchanged

    // Round trip
    assert_eq(to_lower(to_upper(109)), 109);  // 'm' -> 'M' -> 'm'
    assert_eq(to_upper(to_lower(77)), 77);    // 'M' -> 'm' -> 'M'

    // is_alnum
    assert_eq(is_alnum(65), 1);   // 'A'
    assert_eq(is_alnum(48), 1);   // '0'
    assert_eq(is_alnum(32), 0);   // space
    print("  test_case_conversion: ok");
}

// ============================================================================
// Main
// ============================================================================

fn main() -> Int {
    test_is_digit();
    test_is_alpha();
    test_upper_lower();
    test_is_space();
    test_case_conversion();
    print("[OK] 144_char_classify");
    0
}
