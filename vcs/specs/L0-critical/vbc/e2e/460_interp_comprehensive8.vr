// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, comprehensive, milestone
// @timeout: 30000
// @expected-exit: 0
//
// Comprehensive test #8: exercises records, closures, generators,
// spawn/await, lists, f-strings.
// Milestone: ~287 interpreter tests.

// -- Record types --

type Range2D is { x_min: Int, x_max: Int, y_min: Int, y_max: Int };
type Counter is { value: Int, step: Int, limit: Int };

fn range2d_new(x0: Int, x1: Int, y0: Int, y1: Int) -> Range2D {
    Range2D { x_min: x0, x_max: x1, y_min: y0, y_max: y1 }
}

fn range2d_area(r: Range2D) -> Int {
    (r.x_max - r.x_min) * (r.y_max - r.y_min)
}

fn range2d_contains(r: Range2D, x: Int, y: Int) -> Int {
    if x >= r.x_min && x < r.x_max && y >= r.y_min && y < r.y_max { 1 } else { 0 }
}

fn range2d_intersects(a: Range2D, b: Range2D) -> Int {
    if a.x_max <= b.x_min || b.x_max <= a.x_min { 0 }
    else if a.y_max <= b.y_min || b.y_max <= a.y_min { 0 }
    else { 1 }
}

fn test_range2d_records() {
    let r1 = range2d_new(0, 10, 0, 5);
    let r2 = range2d_new(5, 15, 3, 8);
    let r3 = range2d_new(20, 30, 20, 30);

    // Area: (10-0)*(5-0) = 50
    assert_eq(range2d_area(r1), 50);
    // Area: (15-5)*(8-3) = 50
    assert_eq(range2d_area(r2), 50);
    // Area: 10*10 = 100
    assert_eq(range2d_area(r3), 100);

    // Containment
    assert_eq(range2d_contains(r1, 5, 3), 1);
    assert_eq(range2d_contains(r1, 10, 5), 0); // boundary is exclusive
    assert_eq(range2d_contains(r1, -1, 0), 0);

    // Intersection
    assert_eq(range2d_intersects(r1, r2), 1); // overlap at [5,10) x [3,5)
    assert_eq(range2d_intersects(r1, r3), 0); // disjoint
    assert_eq(range2d_intersects(r2, r3), 0); // disjoint

    print("range2d_records: ok");
}

// -- Counter operations --

fn counter_new(init: Int, step: Int, limit: Int) -> Counter {
    Counter { value: init, step: step, limit: limit }
}

fn counter_tick(c: Counter) -> Counter {
    let nv = c.value + c.step;
    Counter { value: nv, step: c.step, limit: c.limit }
}

fn counter_done(c: Counter) -> Int {
    if c.value >= c.limit { 1 } else { 0 }
}

fn test_counter_records() {
    let mut c = counter_new(0, 3, 15);
    // Tick 5 times: 0 -> 3 -> 6 -> 9 -> 12 -> 15
    let mut ticks = 0;
    while counter_done(c) == 0 {
        c = counter_tick(c);
        ticks = ticks + 1;
    }
    assert_eq(ticks, 5);
    assert_eq(c.value, 15);
    assert_eq(counter_done(c), 1);

    // Counter that overshoots
    let mut c2 = counter_new(0, 7, 20);
    // 0 -> 7 -> 14 -> 21 (done after 3 ticks since 21>=20)
    ticks = 0;
    while counter_done(c2) == 0 {
        c2 = counter_tick(c2);
        ticks = ticks + 1;
    }
    assert_eq(ticks, 3);
    assert_eq(c2.value, 21);

    print("counter_records: ok");
}

// -- Closures --

fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int {
    f(f(x))
}

fn compose_apply(f: fn(Int) -> Int, g: fn(Int) -> Int, x: Int) -> Int {
    f(g(x))
}

fn scan_sum(n: Int, f: fn(Int) -> Int) -> Int {
    // Sum f(0) + f(1) + ... + f(n-1)
    let mut acc = 0;
    let mut i = 0;
    while i < n {
        acc = acc + f(i);
        i = i + 1;
    }
    acc
}

fn test_closures() {
    // apply_twice(x*3, 2) = 2*3*3 = 18
    let triple = |x: Int| -> Int { x * 3 };
    assert_eq(apply_twice(triple, 2), 18);

    // apply_twice(x-1, 10) = 8
    let dec = |x: Int| -> Int { x - 1 };
    assert_eq(apply_twice(dec, 10), 8);

    // Compose: f(g(x)) where f(x)=x*2, g(x)=x+3
    // f(g(5)) = f(8) = 16
    let dbl = |x: Int| -> Int { x * 2 };
    let add3 = |x: Int| -> Int { x + 3 };
    assert_eq(compose_apply(dbl, add3, 5), 16);

    // Scan sum: sum of i^2 for i in 0..5 = 0+1+4+9+16 = 30
    let sq = |x: Int| -> Int { x * x };
    let sum_sq = scan_sum(5, sq);
    assert_eq(sum_sq, 30);

    // Scan sum: sum of (2*i+1) for i in 0..4 = 1+3+5+7 = 16
    let odd_fn = |x: Int| -> Int { 2 * x + 1 };
    let sum_odd = scan_sum(4, odd_fn);
    assert_eq(sum_odd, 16);

    // Closure capturing a value
    let base = 100;
    let add_base = |x: Int| -> Int { x + base };
    assert_eq(apply_twice(add_base, 5), 205); // 5+100+100=205

    print("closures: ok");
}

// -- Generators --

fn* powers_of_two(count: Int) -> Int {
    let mut v = 1;
    let mut i = 0;
    while i < count {
        yield v;
        v = v * 2;
        i = i + 1;
    }
}

fn* arithmetic_seq(start: Int, step: Int, count: Int) -> Int {
    let mut v = start;
    let mut i = 0;
    while i < count {
        yield v;
        v = v + step;
        i = i + 1;
    }
}

fn* collatz(n: Int) -> Int {
    let mut x = n;
    while x != 1 {
        yield x;
        if x % 2 == 0 { x = x / 2; } else { x = 3 * x + 1; }
    }
    yield 1; // yield the terminal 1
}

fn test_generators() {
    // Powers of 2: 1, 2, 4, 8, 16, 32
    let mut pow2 = [0, 0, 0, 0, 0, 0];
    let mut idx = 0;
    for p in powers_of_two(6) {
        pow2[idx] = p;
        idx = idx + 1;
    }
    assert_eq(pow2[0], 1);
    assert_eq(pow2[1], 2);
    assert_eq(pow2[2], 4);
    assert_eq(pow2[3], 8);
    assert_eq(pow2[4], 16);
    assert_eq(pow2[5], 32);

    // Arithmetic sequence: 5, 8, 11, 14, 17
    let mut arith = [0, 0, 0, 0, 0];
    idx = 0;
    for v in arithmetic_seq(5, 3, 5) {
        arith[idx] = v;
        idx = idx + 1;
    }
    assert_eq(arith[0], 5);
    assert_eq(arith[1], 8);
    assert_eq(arith[2], 11);
    assert_eq(arith[3], 14);
    assert_eq(arith[4], 17);

    // Sum of first 6 powers of 2 = 1+2+4+8+16+32 = 63
    let mut total = 0;
    let mut k = 0;
    while k < 6 { total = total + pow2[k]; k = k + 1; }
    assert_eq(total, 63);

    // Collatz sequence starting at 6: 6,3,10,5,16,8,4,2,1
    let mut coll = [0, 0, 0, 0, 0, 0, 0, 0, 0];
    idx = 0;
    for c in collatz(6) {
        if idx < 9 { coll[idx] = c; idx = idx + 1; }
    }
    assert_eq(coll[0], 6);
    assert_eq(coll[1], 3);
    assert_eq(coll[2], 10);
    assert_eq(coll[3], 5);
    assert_eq(coll[4], 16);
    assert_eq(coll[5], 8);
    assert_eq(coll[6], 4);
    assert_eq(coll[7], 2);
    assert_eq(coll[8], 1);

    print("generators: ok");
}

// -- Spawn/Await --

fn sum_range(lo: Int, hi: Int) -> Int {
    // Sum lo + (lo+1) + ... + (hi-1) = (hi-lo)*(lo+hi-1)/2
    let n = hi - lo;
    n * (lo + hi - 1) / 2
}

fn power_mod(base: Int, exp: Int, modulus: Int) -> Int {
    // Compute base^exp mod modulus via fast exponentiation
    let mut result = 1;
    let mut b = base % modulus;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 { result = (result * b) % modulus; }
        e = e / 2;
        b = (b * b) % modulus;
    }
    result
}

fn max_in_range(lo: Int, hi: Int) -> Int {
    // max value in [lo, hi) using formula
    hi - 1
}

fn test_spawn_await() {
    // Sum 1..100 = 5050
    let t1 = spawn sum_range(1, 101);
    // Sum 1..50 = 1275
    let t2 = spawn sum_range(1, 51);
    // 2^10 mod 1000 = 1024 mod 1000 = 24
    let t3 = spawn power_mod(2, 10, 1000);

    let r1 = t1.await;
    let r2 = t2.await;
    let r3 = t3.await;

    assert_eq(r1, 5050);
    assert_eq(r2, 1275);
    assert_eq(r3, 24);

    // 3^7 mod 100 = 2187 mod 100 = 87
    let t4 = spawn power_mod(3, 7, 100);
    // max in [50, 200) = 199
    let t5 = spawn max_in_range(50, 200);
    let r4 = t4.await;
    let r5 = t5.await;
    assert_eq(r4, 87);
    assert_eq(r5, 199);

    print("spawn_await: ok");
}

// -- List operations --

fn test_list_operations() {
    // Build prefix sums
    let arr = [3, 1, 4, 1, 5, 9, 2, 6];
    let n = 8;
    let mut prefix = [0, 0, 0, 0, 0, 0, 0, 0];
    prefix[0] = arr[0];
    let mut i = 1;
    while i < n { prefix[i] = prefix[i - 1] + arr[i]; i = i + 1; }
    // prefix = [3, 4, 8, 9, 14, 23, 25, 31]
    assert_eq(prefix[7], 31); // total sum = 3+1+4+1+5+9+2+6=31
    assert_eq(prefix[4], 14); // 3+1+4+1+5=14

    // Range query: sum of arr[2..5] = arr[2]+arr[3]+arr[4] = 4+1+5 = 10
    // = prefix[4] - prefix[1] = 14 - 4 = 10
    let range_sum = prefix[4] - prefix[1];
    assert_eq(range_sum, 10);

    // Selection sort
    let mut a = [5, 3, 8, 1, 9, 2, 7, 4];
    let mut j = 0;
    while j < n - 1 {
        let mut min_idx = j;
        let mut k = j + 1;
        while k < n {
            if a[k] < a[min_idx] { min_idx = k; }
            k = k + 1;
        }
        if min_idx != j {
            let tmp = a[j]; a[j] = a[min_idx]; a[min_idx] = tmp;
        }
        j = j + 1;
    }
    assert_eq(a[0], 1);
    assert_eq(a[1], 2);
    assert_eq(a[2], 3);
    assert_eq(a[3], 4);
    assert_eq(a[4], 5);
    assert_eq(a[5], 7);
    assert_eq(a[6], 8);
    assert_eq(a[7], 9);

    // Counting: how many elements > 5 in sorted array
    let mut count_gt5 = 0;
    i = 0;
    while i < n { if a[i] > 5 { count_gt5 = count_gt5 + 1; } i = i + 1; }
    assert_eq(count_gt5, 3); // 7, 8, 9

    print("list_operations: ok");
}

// -- Format strings --

fn test_format_strings() {
    let r = range2d_new(2, 8, 3, 11);
    let area = range2d_area(r);
    let msg = f"range [{r.x_min},{r.x_max})x[{r.y_min},{r.y_max}) area={area}";
    print(msg);
    assert_eq(area, 48); // (8-2)*(11-3) = 6*8 = 48

    // Format loop with running totals
    let mut sum = 0;
    let mut i = 1;
    while i <= 6 {
        sum = sum + i;
        let sq = i * i;
        print(f"  n={i} n^2={sq} sum={sum}");
        i = i + 1;
    }
    // Sum of 1..6 = 21
    assert_eq(sum, 21);

    // Counter formatting
    let c = counter_new(10, 5, 40);
    let steps_needed = (c.limit - c.value) / c.step;
    let info = f"counter: start={c.value} step={c.step} limit={c.limit} steps={steps_needed}";
    print(info);
    assert_eq(steps_needed, 6);

    print("format_strings: ok");
}

// -- Combined pipeline --

@allow(unbounded_recursion)
fn is_power_of_two(n: Int) -> Int {
    if n <= 0 { 0 } else if n == 1 { 1 }
    else if n % 2 != 0 { 0 }
    else { is_power_of_two(n / 2) }
}

fn count_collatz_steps(n: Int) -> Int {
    let mut x = n;
    let mut steps = 0;
    while x != 1 {
        if x % 2 == 0 { x = x / 2; } else { x = 3 * x + 1; }
        steps = steps + 1;
    }
    steps
}

fn test_combined_pipeline() {
    // Identify which powers of two are in a range using generator + closure
    let is_pow2 = |x: Int| -> Int { is_power_of_two(x) };

    // Count powers of 2 in arithmetic_seq(1, 1, 16) = [1..16]
    let mut pow2_count = 0;
    for v in arithmetic_seq(1, 1, 16) {
        if is_pow2(v) == 1 { pow2_count = pow2_count + 1; }
    }
    // Powers of 2 in [1..16]: 1,2,4,8,16 = 5
    assert_eq(pow2_count, 5);

    // Sum of Collatz steps for [6, 7, 11, 27]:
    // Collatz(6): 6->3->10->5->16->8->4->2->1 = 8 steps
    // Collatz(7): 7->22->11->34->17->52->26->13->40->20->10->5->16->8->4->2->1 = 16 steps
    // Collatz(11): 11->34->17->52->26->13->40->20->10->5->16->8->4->2->1 = 14 steps
    // Collatz(27): known to take 111 steps
    let t_c6  = spawn count_collatz_steps(6);
    let t_c7  = spawn count_collatz_steps(7);
    let t_c11 = spawn count_collatz_steps(11);
    let steps6  = t_c6.await;
    let steps7  = t_c7.await;
    let steps11 = t_c11.await;

    assert_eq(steps6, 8);
    assert_eq(steps7, 16);
    assert_eq(steps11, 14);

    let total_steps = steps6 + steps7 + steps11;
    assert_eq(total_steps, 38);

    // Use generator to build Collatz-length histogram for 2..9
    // Lengths: collatz(2)=1, collatz(3)=7, collatz(4)=2, collatz(5)=5,
    //          collatz(6)=8, collatz(7)=16, collatz(8)=3, collatz(9)=19
    let mut lengths = [0, 0, 0, 0, 0, 0, 0, 0];
    let mut idx = 0;
    for start in arithmetic_seq(2, 1, 8) {
        lengths[idx] = count_collatz_steps(start);
        idx = idx + 1;
    }
    assert_eq(lengths[0], 1);  // collatz(2)=1
    assert_eq(lengths[1], 7);  // collatz(3)=7
    assert_eq(lengths[2], 2);  // collatz(4)=2
    assert_eq(lengths[3], 5);  // collatz(5)=5
    assert_eq(lengths[4], 8);  // collatz(6)=8
    assert_eq(lengths[5], 16); // collatz(7)=16
    assert_eq(lengths[6], 3);  // collatz(8)=3
    assert_eq(lengths[7], 19); // collatz(9)=19

    // Sum of all 8 lengths = 1+7+2+5+8+16+3+19 = 61
    let mut len_sum = 0;
    let mut k = 0;
    while k < 8 { len_sum = len_sum + lengths[k]; k = k + 1; }
    assert_eq(len_sum, 61);

    let msg = f"pipeline: pow2_in_16={pow2_count} collatz_sum={len_sum}";
    print(msg);
    print("combined_pipeline: ok");
}

fn main() -> Int {
    test_range2d_records();
    test_counter_records();
    test_closures();
    test_generators();
    test_spawn_await();
    test_list_operations();
    test_format_strings();
    test_combined_pipeline();
    print("[OK] 460_interp_comprehensive8 — MILESTONE: ~287 interpreter tests");
    0
}
