// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, error-propagation, result, option
// @timeout: 50000
// @expected-exit: 0
//
// Interpreter e2e test: error handling patterns, Result-like types, propagation

// =============================================================================
// Result type
// =============================================================================

type Res is ROk(Int) | RErr(Int);

fn res_is_ok(r: Res) -> Bool {
    match r {
        ROk(_) => true,
        RErr(_) => false,
    }
}

fn res_unwrap(r: Res) -> Int {
    match r {
        ROk(v) => v,
        RErr(_) => -999,
    }
}

fn res_unwrap_err(r: Res) -> Int {
    match r {
        ROk(_) => -999,
        RErr(e) => e,
    }
}

fn res_map(r: Res, factor: Int) -> Res {
    match r {
        ROk(v) => ROk(v * factor),
        RErr(e) => RErr(e),
    }
}

// =============================================================================
// Basic error handling
// =============================================================================

fn checked_div(a: Int, b: Int) -> Res {
    if b == 0 {
        RErr(1) // division by zero error code
    } else {
        ROk(a / b)
    }
}

fn checked_sqrt_int(n: Int) -> Res {
    if n < 0 {
        RErr(2) // negative number error code
    } else {
        // integer square root via iteration
        let mut guess = 0;
        while guess * guess <= n {
            guess = guess + 1;
        }
        ROk(guess - 1)
    }
}

fn test_basic_error_handling() {
    let r1 = checked_div(10, 3);
    assert_eq(res_is_ok(r1), true);
    assert_eq(res_unwrap(r1), 3);

    let r2 = checked_div(10, 0);
    assert_eq(res_is_ok(r2), false);
    assert_eq(res_unwrap_err(r2), 1);

    let r3 = checked_sqrt_int(16);
    assert_eq(res_unwrap(r3), 4);

    let r4 = checked_sqrt_int(-1);
    assert_eq(res_is_ok(r4), false);
    assert_eq(res_unwrap_err(r4), 2);
    print("  test_basic_error_handling: ok");
}

// =============================================================================
// Error propagation (manual ? operator pattern)
// =============================================================================

fn compute_ratio(a: Int, b: Int, c: Int) -> Res {
    // Compute (a / b) * c, propagating division error
    let div_result = checked_div(a, b);
    match div_result {
        RErr(e) => RErr(e),
        ROk(quotient) => ROk(quotient * c),
    }
}

fn compute_chain(a: Int, b: Int, c: Int) -> Res {
    // Compute a / b / c, propagating both division errors
    let r1 = checked_div(a, b);
    match r1 {
        RErr(e) => RErr(e),
        ROk(v1) => {
            let r2 = checked_div(v1, c);
            r2
        }
    }
}

fn test_error_propagation() {
    let r1 = compute_ratio(10, 2, 3);
    assert_eq(res_unwrap(r1), 15);

    let r2 = compute_ratio(10, 0, 3);
    assert_eq(res_is_ok(r2), false);

    let r3 = compute_chain(100, 5, 4);
    assert_eq(res_unwrap(r3), 5);

    let r4 = compute_chain(100, 0, 4);
    assert_eq(res_is_ok(r4), false);

    let r5 = compute_chain(100, 5, 0);
    assert_eq(res_is_ok(r5), false);
    print("  test_error_propagation: ok");
}

// =============================================================================
// Chaining operations on Result
// =============================================================================

fn test_result_chaining() {
    let r = checked_div(100, 5);
    let r2 = res_map(r, 3);
    assert_eq(res_unwrap(r2), 60); // (100/5) * 3 = 60

    let err = checked_div(1, 0);
    let err2 = res_map(err, 3);
    assert_eq(res_is_ok(err2), false); // error propagates through map
    print("  test_result_chaining: ok");
}

// =============================================================================
// Multiple error types (error codes)
// =============================================================================

fn validate_and_compute(x: Int, y: Int) -> Res {
    if x < 0 {
        return RErr(10); // negative x
    }
    if y < 0 {
        return RErr(11); // negative y
    }
    if x + y > 1000 {
        return RErr(12); // overflow
    }
    ROk(x * y)
}

fn test_multiple_error_types() {
    let r1 = validate_and_compute(5, 10);
    assert_eq(res_unwrap(r1), 50);

    let r2 = validate_and_compute(-1, 10);
    assert_eq(res_unwrap_err(r2), 10);

    let r3 = validate_and_compute(5, -1);
    assert_eq(res_unwrap_err(r3), 11);

    let r4 = validate_and_compute(500, 600);
    assert_eq(res_unwrap_err(r4), 12);
    print("  test_multiple_error_types: ok");
}

// =============================================================================
// Default values on error
// =============================================================================

fn res_unwrap_or(r: Res, default_val: Int) -> Int {
    match r {
        ROk(v) => v,
        RErr(_) => default_val,
    }
}

fn res_or_else(r: Res, fallback: Int) -> Res {
    match r {
        ROk(v) => ROk(v),
        RErr(_) => ROk(fallback),
    }
}

fn test_default_on_error() {
    assert_eq(res_unwrap_or(ROk(42), 0), 42);
    assert_eq(res_unwrap_or(RErr(1), 0), 0);

    let recovered = res_or_else(RErr(1), 99);
    assert_eq(res_unwrap(recovered), 99);
    assert_eq(res_is_ok(recovered), true);
    print("  test_default_on_error: ok");
}

// =============================================================================
// Error accumulation pattern
// =============================================================================

fn test_error_accumulation() {
    let mut errors: List<Int> = [];
    let mut successes = 0;

    let mut i = 0;
    while i < 10 {
        let r = checked_div(100, i); // i=0 will fail
        match r {
            ROk(_) => { successes = successes + 1; }
            RErr(e) => { errors.push(e); }
        }
        i = i + 1;
    }

    assert_eq(errors.len(), 1); // only i=0 fails
    assert_eq(successes, 9);
    print("  test_error_accumulation: ok");
}

// =============================================================================
// Validation pipeline
// =============================================================================

fn check_positive(n: Int) -> Res {
    if n > 0 { ROk(n) } else { RErr(20) }
}

fn check_even(n: Int) -> Res {
    if n % 2 == 0 { ROk(n) } else { RErr(21) }
}

fn check_small(n: Int) -> Res {
    if n < 100 { ROk(n) } else { RErr(22) }
}

fn validate_pipeline(n: Int) -> Res {
    let r1 = check_positive(n);
    match r1 {
        RErr(e) => RErr(e),
        ROk(v) => {
            let r2 = check_even(v);
            match r2 {
                RErr(e) => RErr(e),
                ROk(v2) => check_small(v2),
            }
        }
    }
}

fn test_validation_pipeline() {
    let r1 = validate_pipeline(42);
    assert_eq(res_is_ok(r1), true);
    assert_eq(res_unwrap(r1), 42);

    let r2 = validate_pipeline(-5);
    assert_eq(res_unwrap_err(r2), 20); // not positive

    let r3 = validate_pipeline(7);
    assert_eq(res_unwrap_err(r3), 21); // not even

    let r4 = validate_pipeline(200);
    assert_eq(res_unwrap_err(r4), 22); // not small
    print("  test_validation_pipeline: ok");
}

// =============================================================================
// Retry pattern
// =============================================================================

fn flaky_operation(attempt: Int) -> Res {
    // Succeeds on attempt >= 3
    if attempt >= 3 {
        ROk(attempt * 10)
    } else {
        RErr(attempt)
    }
}

fn test_retry_pattern() {
    let mut attempt = 0;
    let mut final_result = RErr(0);
    while attempt < 5 {
        let r = flaky_operation(attempt);
        match r {
            ROk(_) => {
                final_result = r;
                break;
            }
            RErr(_) => {
                attempt = attempt + 1;
            }
        }
    }
    assert_eq(res_is_ok(final_result), true);
    assert_eq(res_unwrap(final_result), 30); // succeeds on attempt=3
    assert_eq(attempt, 3);
    print("  test_retry_pattern: ok");
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_basic_error_handling();
    test_error_propagation();
    test_result_chaining();
    test_multiple_error_types();
    test_default_on_error();
    test_error_accumulation();
    test_validation_pipeline();
    test_retry_pattern();
    print("[OK] 610_interp_error_propagation");
    0
}
