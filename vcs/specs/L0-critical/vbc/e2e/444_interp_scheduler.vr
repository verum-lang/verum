// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, scheduler, round_robin, priority
// @timeout: 15000
// @expected-exit: 0
//
// Tests round-robin scheduler simulation with process queue,
// time slices, and priority-based scheduling.

fn test_round_robin_basic() {
    // 4 processes with burst times, quantum = 3
    // Process: id, burst_remaining
    let n = 4;
    let quantum = 3;
    let mut burst = [6, 4, 10, 2]; // remaining burst time
    let mut wait  = [0, 0, 0, 0];  // accumulated wait time
    let mut done  = [0, 0, 0, 0];  // 1 if finished
    let mut completed = 0;
    let mut current_time = 0;

    // Run until all processes complete
    let mut iterations = 0;
    while completed < n && iterations < 100 {
        let mut p = 0;
        while p < n {
            if done[p] == 0 && burst[p] > 0 {
                // Run for min(quantum, remaining burst)
                let run_time = if burst[p] < quantum { burst[p] } else { quantum };

                // All other non-done processes wait during run_time
                let mut q = 0;
                while q < n {
                    if q != p && done[q] == 0 && burst[q] > 0 {
                        wait[q] = wait[q] + run_time;
                    }
                    q = q + 1;
                }
                current_time = current_time + run_time;
                burst[p] = burst[p] - run_time;

                if burst[p] == 0 {
                    done[p] = 1;
                    completed = completed + 1;
                }
            }
            p = p + 1;
        }
        iterations = iterations + 1;
    }

    // Total execution time = sum of original bursts = 6+4+10+2 = 22
    assert_eq(current_time, 22);

    // Total wait time (sum across all processes)
    let total_wait = wait[0] + wait[1] + wait[2] + wait[3];

    // Each process waits while others run. Let's verify total_wait is reasonable.
    // With quantum=3:
    // Round 1: P0 runs 3 (P1,P2,P3 wait 3 each -> +9)
    //          P1 runs 3 (P0,P2,P3 wait 3; but P0 has 3 left, P2 has 10, P3 has 2)
    //          Wait: P0 +3, P2 +3, P3 +3 -> +9
    //          P2 runs 3: P0 +3, P1 +1(just 1 remaining), P3 +3 -> P0:3+3+3=9, P1:3+3=6, P3:3+3+3=9
    //          Wait(+7 for P0,P1 remaining + P3): P0 +3, P1 +3, P3 +3 -> wait now: P0=3+3+3=9, P1=3+3=6, P2=3+3+3=9(but done later), P3=3+3+3=9
    // Actually let's just verify it's positive and all processes completed
    assert(total_wait > 0);
    assert_eq(completed, 4);
    assert_eq(done[0], 1);
    assert_eq(done[1], 1);
    assert_eq(done[2], 1);
    assert_eq(done[3], 1);

    print("round_robin_basic: ok");
}

fn test_round_robin_equal_burst() {
    // All processes same burst, should be perfectly fair
    // 3 processes, burst=6, quantum=2
    let n = 3;
    let quantum = 2;
    let mut burst = [6, 6, 6];
    let mut wait  = [0, 0, 0];
    let mut done  = [0, 0, 0];
    let mut completed = 0;
    let mut current_time = 0;

    let mut iterations = 0;
    while completed < n && iterations < 50 {
        let mut p = 0;
        while p < n {
            if done[p] == 0 && burst[p] > 0 {
                let run_time = if burst[p] < quantum { burst[p] } else { quantum };
                let mut q = 0;
                while q < n {
                    if q != p && done[q] == 0 && burst[q] > 0 {
                        wait[q] = wait[q] + run_time;
                    }
                    q = q + 1;
                }
                current_time = current_time + run_time;
                burst[p] = burst[p] - run_time;
                if burst[p] == 0 {
                    done[p] = 1;
                    completed = completed + 1;
                }
            }
            p = p + 1;
        }
        iterations = iterations + 1;
    }

    assert_eq(current_time, 18); // 3 * 6
    // P0 runs first each round so waits less; wait[0] < wait[1] < wait[2]
    assert(wait[0] <= wait[1]);
    assert(wait[1] <= wait[2]);
    // Total wait should be reasonable (each process waits while others run)
    let total_wait = wait[0] + wait[1] + wait[2];
    assert(total_wait > 0);
    assert_eq(completed, 3);

    print("round_robin_equal_burst: ok");
}

fn test_priority_scheduler() {
    // Priority scheduling (non-preemptive): run highest priority process first
    // priority: lower number = higher priority
    let n = 5;
    let ids      = [0, 1, 2, 3, 4];
    let priority = [3, 1, 4, 1, 5]; // priorities
    let burst    = [5, 3, 1, 4, 2]; // burst times
    let mut done = [0, 0, 0, 0, 0];
    let mut order = [0, 0, 0, 0, 0]; // execution order

    let mut current_time = 0;
    let mut completed = 0;

    while completed < n {
        // Find highest priority ready process (not done)
        let mut best = -1;
        let mut best_pri = 99999;
        let mut p = 0;
        while p < n {
            if done[p] == 0 && priority[p] < best_pri {
                best_pri = priority[p];
                best = p;
            }
            p = p + 1;
        }
        if best >= 0 {
            order[completed] = best;
            current_time = current_time + burst[best];
            done[best] = 1;
            completed = completed + 1;
        }
    }

    // Priority 1: processes 1 and 3 (burst 3 and 4)
    // Priority 3: process 0 (burst 5)
    // Priority 4: process 2 (burst 1)
    // Priority 5: process 4 (burst 2)
    // Execution order: one of {1,3} first (same priority), then {3,1}, then 0, then 2, then 4
    // The loop always picks the lowest index in ties (since it uses <, first found wins)
    // So order: 1, 3, 0, 2, 4
    assert_eq(order[0], 1); // priority 1 (first found)
    assert_eq(order[1], 3); // priority 1 (second)
    assert_eq(order[2], 0); // priority 3
    assert_eq(order[3], 2); // priority 4
    assert_eq(order[4], 4); // priority 5

    // Total time = 3+4+5+1+2 = 15
    assert_eq(current_time, 15);

    print("priority_scheduler: ok");
}

fn test_time_slice_tracking() {
    // Track context switches and CPU utilization
    // 3 processes: burst 7, 4, 9, quantum 3
    let n = 3;
    let quantum = 3;
    let mut burst = [7, 4, 9];
    let mut done  = [0, 0, 0];
    let mut context_switches = 0;
    let mut last_running = -1;
    let mut cpu_time = 0;
    let mut completed = 0;

    let mut iters = 0;
    while completed < n && iters < 200 {
        let mut p = 0;
        while p < n {
            if done[p] == 0 && burst[p] > 0 {
                if last_running != p {
                    context_switches = context_switches + 1;
                    last_running = p;
                }
                let run = if burst[p] < quantum { burst[p] } else { quantum };
                cpu_time = cpu_time + run;
                burst[p] = burst[p] - run;
                if burst[p] == 0 {
                    done[p] = 1;
                    completed = completed + 1;
                }
            }
            p = p + 1;
        }
        iters = iters + 1;
    }

    assert_eq(cpu_time, 20); // 7+4+9 = 20
    assert_eq(completed, 3);
    // Context switches: each time we switch to a different process
    // Round 1: P0(run3), P1(run3), P2(run3) = 3 switches
    // Round 2: P0(run3), P1(run1 done), P2(run3) = 3 switches (P0 again after P2 counts)
    // Round 3: P0(run1 done), P2(run3 done) = 2 switches
    // Total = 8 switches
    assert_eq(context_switches, 8);

    print("time_slice_tracking: ok");
}

fn test_shortest_job_first() {
    // SJF non-preemptive: always run shortest remaining burst
    let n = 4;
    let burst_orig = [6, 8, 7, 3]; // original burst times
    let mut burst = [6, 8, 7, 3];
    let mut done  = [0, 0, 0, 0];
    let mut finish_time = [0, 0, 0, 0];
    let mut current_time = 0;
    let mut completed = 0;

    while completed < n {
        // Find shortest burst among ready (not done)
        let mut best = -1;
        let mut best_burst = 99999;
        let mut p = 0;
        while p < n {
            if done[p] == 0 && burst[p] < best_burst {
                best_burst = burst[p];
                best = p;
            }
            p = p + 1;
        }
        if best >= 0 {
            current_time = current_time + burst[best];
            finish_time[best] = current_time;
            done[best] = 1;
            completed = completed + 1;
        }
    }

    // Execution order: P3(3), P0(6), P2(7), P1(8)
    // Finish times: P3=3, P0=9, P2=16, P1=24
    assert_eq(finish_time[3], 3);
    assert_eq(finish_time[0], 9);
    assert_eq(finish_time[2], 16);
    assert_eq(finish_time[1], 24);

    // Turnaround times = finish_time - arrival_time (all arrive at 0)
    let tat0 = finish_time[0] - 0;
    let tat1 = finish_time[1] - 0;
    let tat2 = finish_time[2] - 0;
    let tat3 = finish_time[3] - 0;
    let avg_tat_x4 = tat0 + tat1 + tat2 + tat3; // 9+24+16+3 = 52
    assert_eq(avg_tat_x4, 52);

    print("shortest_job_first: ok");
}

fn main() -> Int {
    test_round_robin_basic();
    test_round_robin_equal_burst();
    test_priority_scheduler();
    test_time_slice_tracking();
    test_shortest_job_first();
    print("[OK] 444_interp_scheduler");
    0
}
