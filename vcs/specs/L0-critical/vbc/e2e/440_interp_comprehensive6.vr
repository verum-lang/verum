// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, comprehensive, milestone
// @timeout: 30000
// @expected-exit: 0
//
// Comprehensive test #6: exercises all major interpreter features.
// Milestone: ~267 interpreter tests.

type Ratio is { num: Int, den: Int };

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 { a } else { gcd(b, a % b) }
}

fn ratio_new(n: Int, d: Int) -> Ratio {
    let g = gcd(if n < 0 { 0 - n } else { n }, if d < 0 { 0 - d } else { d });
    Ratio { num: n / g, den: d / g }
}

fn ratio_add(a: Ratio, b: Ratio) -> Ratio {
    ratio_new(a.num * b.den + b.num * a.den, a.den * b.den)
}

fn ratio_mul(a: Ratio, b: Ratio) -> Ratio {
    ratio_new(a.num * b.num, a.den * b.den)
}

fn* range(start: Int, end_excl: Int) -> Int {
    let mut i = start;
    while i < end_excl {
        yield i;
        i = i + 1;
    }
}

fn test_rational_arithmetic() {
    // 1/2 + 1/3 = 5/6
    let a = ratio_new(1, 2);
    let b = ratio_new(1, 3);
    let sum = ratio_add(a, b);
    assert_eq(sum.num, 5);
    assert_eq(sum.den, 6);

    // 2/3 * 3/4 = 6/12 = 1/2
    let c = ratio_new(2, 3);
    let d = ratio_new(3, 4);
    let prod = ratio_mul(c, d);
    assert_eq(prod.num, 1);
    assert_eq(prod.den, 2);

    // 1/2 + 1/3 + 1/6 = 1
    let e = ratio_new(1, 6);
    let total = ratio_add(ratio_add(a, b), e);
    assert_eq(total.num, 1);
    assert_eq(total.den, 1);
    print("rational_arithmetic: ok");
}

fn test_harmonic_partial() {
    // Compute H_n = 1/1 + 1/2 + ... + 1/n as rational
    // H_4 = 1 + 1/2 + 1/3 + 1/4 = 25/12
    let mut h = ratio_new(0, 1);
    let mut i = 1;
    while i <= 4 {
        h = ratio_add(h, ratio_new(1, i));
        i = i + 1;
    }
    assert_eq(h.num, 25);
    assert_eq(h.den, 12);
    print("harmonic_partial: ok");
}

fn test_generator_accumulate() {
    // Running sum with generator
    let mut running = 0;
    let mut max_running = 0;
    for i in range(1, 11) {
        running = running + i;
        if running > max_running { max_running = running; }
    }
    assert_eq(running, 55);
    assert_eq(max_running, 55);
    print("generator_accumulate: ok");
}

fn multiply(a: Int, b: Int) -> Int { a * b }
fn add_three(a: Int, b: Int, c: Int) -> Int { a + b + c }

fn test_spawn_parallel() {
    let t1 = spawn multiply(12, 34);
    let t2 = spawn add_three(100, 200, 300);
    let r1 = t1.await;
    let r2 = t2.await;
    assert_eq(r1, 408);
    assert_eq(r2, 600);
    print("spawn_parallel: ok");
}

fn test_complex_list_ops() {
    // Matrix-vector multiply: [1,2; 3,4] * [5;6] = [17;39]
    let m = [1, 2, 3, 4];
    let v = [5, 6];
    let mut result = [0, 0];

    let mut r = 0;
    while r < 2 {
        let mut c = 0;
        while c < 2 {
            result[r] = result[r] + m[r * 2 + c] * v[c];
            c = c + 1;
        }
        r = r + 1;
    }
    assert_eq(result[0], 17);
    assert_eq(result[1], 39);
    print("complex_list_ops: ok");
}

fn test_closure_with_records() {
    let r = Ratio { num: 3, den: 4 };
    let scale = |x: Int| -> Int { x * r.num / r.den };
    assert_eq(scale(100), 75);
    assert_eq(scale(200), 150);
    print("closure_with_records: ok");
}

fn test_format_everything() {
    let a = 42;
    let b = 7;
    let r = ratio_new(a, b);
    let msg = f"{a}/{b} = {r.num}/{r.den}";
    print(msg);

    let mut i = 0;
    while i < 3 {
        let sq = (i + 1) * (i + 1);
        print(f"  {i}: sq={sq}");
        i = i + 1;
    }
    print("format_everything: ok");
}

fn main() -> Int {
    test_rational_arithmetic();
    test_harmonic_partial();
    test_generator_accumulate();
    test_spawn_parallel();
    test_complex_list_ops();
    test_closure_with_records();
    test_format_everything();
    print("[OK] 440_interp_comprehensive6 — MILESTONE: ~267 interpreter tests");
    0
}
