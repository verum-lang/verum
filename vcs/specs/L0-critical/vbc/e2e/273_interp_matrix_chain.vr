// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, e2e, interp, algo, dp, matrix-chain
// @timeout: 15000
// @expected-exit: 0
//
// Interpreter e2e test: Matrix chain multiplication — find optimal
// parenthesization cost for small sequences. Uses direct variable DP
// for 3-4 matrices to avoid heavy record operations.

// =============================================================================
// Helper: min of two values
// =============================================================================

fn min_val(a: Int, b: Int) -> Int {
    if a < b { a } else { b }
}

// =============================================================================
// Matrix chain for 2 matrices: trivial, cost = d0*d1*d2
// =============================================================================

fn chain2(d0: Int, d1: Int, d2: Int) -> Int {
    d0 * d1 * d2
}

// =============================================================================
// Matrix chain for 3 matrices with dims [d0, d1, d2, d3]
// Two parenthesizations:
//   (A0 A1) A2: cost = d0*d1*d2 + d0*d2*d3
//   A0 (A1 A2): cost = d1*d2*d3 + d0*d1*d3
// =============================================================================

fn chain3(d0: Int, d1: Int, d2: Int, d3: Int) -> Int {
    let cost1 = d0 * d1 * d2 + d0 * d2 * d3;
    let cost2 = d1 * d2 * d3 + d0 * d1 * d3;
    min_val(cost1, cost2)
}

// =============================================================================
// Matrix chain for 4 matrices with dims [d0, d1, d2, d3, d4]
// DP approach with explicit variables:
// dp[i][j] stored as variables:
//   dp01 = 0 (single matrix)
//   dp12 = 0
//   dp23 = 0
//   dp34 = 0 (N/A for 4 matrices, indices 0-3)
//   dp02 = d0*d1*d2  (only one split at k=1: dp[0][0]+dp[1][1]+d0*d1*d2... wait)
//
// Let me use standard DP indexing: matrices are A0..A3.
// dp[i][j] = min cost to multiply Ai..Aj
// dp[i][i] = 0
// dp[0][1] = d0*d1*d2
// dp[1][2] = d1*d2*d3
// dp[2][3] = d2*d3*d4
// dp[0][2] = min(dp[0][0]+dp[1][2]+d0*d1*d3, dp[0][1]+dp[2][2]+d0*d2*d3)
// dp[1][3] = min(dp[1][1]+dp[2][3]+d1*d2*d4, dp[1][2]+dp[3][3]+d1*d3*d4)
// dp[0][3] = min(dp[0][0]+dp[1][3]+d0*d1*d4,
//                dp[0][1]+dp[2][3]+d0*d2*d4,
//                dp[0][2]+dp[3][3]+d0*d3*d4)
// =============================================================================

fn chain4(d0: Int, d1: Int, d2: Int, d3: Int, d4: Int) -> Int {
    // Base cases (chain length 1)
    // dp[i][i] = 0

    // Chain length 2
    let dp01 = d0 * d1 * d2;
    let dp12 = d1 * d2 * d3;
    let dp23 = d2 * d3 * d4;

    // Chain length 3
    // dp[0][2] = min(0 + dp12 + d0*d1*d3, dp01 + 0 + d0*d2*d3)
    let dp02 = min_val(dp12 + d0 * d1 * d3, dp01 + d0 * d2 * d3);
    // dp[1][3] = min(0 + dp23 + d1*d2*d4, dp12 + 0 + d1*d3*d4)
    let dp13 = min_val(dp23 + d1 * d2 * d4, dp12 + d1 * d3 * d4);

    // Chain length 4
    // dp[0][3] = min(0 + dp13 + d0*d1*d4,
    //               dp01 + dp23 + d0*d2*d4,
    //               dp02 + 0 + d0*d3*d4)
    let c1 = dp13 + d0 * d1 * d4;
    let c2 = dp01 + dp23 + d0 * d2 * d4;
    let c3 = dp02 + d0 * d3 * d4;
    min_val(c1, min_val(c2, c3))
}

// =============================================================================
// Test: 2 matrices
// A: 10x30, B: 30x5 => cost = 10*30*5 = 1500
// =============================================================================

fn test_chain_2() {
    assert_eq(chain2(10, 30, 5), 1500);
}

// =============================================================================
// Test: 3 matrices
// A: 10x30, B: 30x5, C: 5x60
// (AB)C: 10*30*5 + 10*5*60 = 1500 + 3000 = 4500
// A(BC): 30*5*60 + 10*30*60 = 9000 + 18000 = 27000
// Optimal: 4500
// =============================================================================

fn test_chain_3() {
    assert_eq(chain3(10, 30, 5, 60), 4500);
}

// =============================================================================
// Test: 3 matrices, all same dimension (square)
// Any parenthesization: 10*10*10 + 10*10*10 = 2000
// =============================================================================

fn test_chain_3_square() {
    assert_eq(chain3(10, 10, 10, 10), 2000);
}

// =============================================================================
// Test: 4 matrices (classic textbook)
// dims = [40, 20, 30, 10, 30]
// Expected optimal: 26000
// =============================================================================

fn test_chain_4_classic() {
    assert_eq(chain4(40, 20, 30, 10, 30), 26000);
}

// =============================================================================
// Test: 4 matrices alternating
// dims = [1, 100, 1, 100, 1]
// dp01 = 100, dp12 = 10000, dp23 = 100
// dp02 = min(10000 + 100, 100 + 100) = 200
// dp13 = min(100 + 100, 10000 + 10000) = 200
// dp03 = min(200 + 100, 100 + 100 + 100, 200 + 100)
//       = min(300, 300, 300) = 300?
// Wait let me recompute:
// dp03: c1 = dp13 + d0*d1*d4 = 200 + 1*100*1 = 300
//        c2 = dp01 + dp23 + d0*d2*d4 = 100 + 100 + 1*1*1 = 201
//        c3 = dp02 + d0*d3*d4 = 200 + 1*100*1 = 300
// min = 201
// =============================================================================

fn test_chain_4_alternating() {
    assert_eq(chain4(1, 100, 1, 100, 1), 201);
}

// =============================================================================
// Test: brute force check for 3 matrices
// dims = [5, 10, 3, 12]
// (AB)C = 5*10*3 + 5*3*12 = 150 + 180 = 330
// A(BC) = 10*3*12 + 5*10*12 = 360 + 600 = 960
// min = 330
// =============================================================================

fn test_chain_3_brute() {
    let dp_cost = chain3(5, 10, 3, 12);
    let cost1 = 5 * 10 * 3 + 5 * 3 * 12;
    let cost2 = 10 * 3 * 12 + 5 * 10 * 12;
    let brute_min = min_val(cost1, cost2);
    assert_eq(dp_cost, brute_min);
    assert_eq(dp_cost, 330);
}

// =============================================================================
// Test: chain4 with equal dimensions (should be n^3 * (n-1)/2 per split)
// dims = [10, 10, 10, 10, 10]
// All single: 1000
// dp01=1000, dp12=1000, dp23=1000
// dp02 = min(1000 + 1000, 1000 + 1000) = 2000
// dp13 = min(1000 + 1000, 1000 + 1000) = 2000
// dp03 = min(2000 + 1000, 1000 + 1000 + 1000, 2000 + 1000) = 3000
// =============================================================================

fn test_chain_4_square() {
    assert_eq(chain4(10, 10, 10, 10, 10), 3000);
}

// =============================================================================
// Test: asymmetric dimensions
// dims = [2, 3, 4, 5]
// (AB)C = 2*3*4 + 2*4*5 = 24 + 40 = 64
// A(BC) = 3*4*5 + 2*3*5 = 60 + 30 = 90
// min = 64
// =============================================================================

fn test_chain_3_asymmetric() {
    assert_eq(chain3(2, 3, 4, 5), 64);
}

// =============================================================================
// Test: very different sizes
// dims = [1, 1000, 1, 1000]
// (AB)C = 1*1000*1 + 1*1*1000 = 1000 + 1000 = 2000
// A(BC) = 1000*1*1000 + 1*1000*1000 = 1000000 + 1000000 = 2000000
// min = 2000
// =============================================================================

fn test_chain_3_extreme() {
    assert_eq(chain3(1, 1000, 1, 1000), 2000);
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_chain_2();
    test_chain_3();
    test_chain_3_square();
    test_chain_4_classic();
    test_chain_4_alternating();
    test_chain_3_brute();
    test_chain_4_square();
    test_chain_3_asymmetric();
    test_chain_3_extreme();
    print("[OK] 273_interp_matrix_chain");
    0
}
