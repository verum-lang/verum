// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, pattern-matching, unpack, pack, tuples, destructuring
// @timeout: 5000
// @expect: pass
//
// Test: UNPACK, PACK operations
// Verifies tuple packing/unpacking and destructuring

type Point is { x: Float, y: Float };
type Person is { name: Text, age: Int };
type Line is { start: Point, end: Point };
type Data is {
    id: Int,
    values: (Float, Float, Float),
    meta: Maybe<Text>
};

// =============================================================================
// Helper functions (top-level to avoid VBC nested function limitation)
// =============================================================================

fn get_point() -> (Float, Float) { (1.0, 2.0) }
fn pack_f() -> Int { 1 }
fn pack_g() -> Int { 2 }

fn process_maybe(opt: Maybe<(Int, Int)>) -> Int {
    match opt {
        None => 0,
        Some((a, b)) => a + b
    }
}

fn classify_int(x: Int) -> Text {
    match x {
        0 | 1 => "small",
        2 | 3 | 4 => "medium",
        _ => "large"
    }
}

// =============================================================================
// Basic tuple operations
// =============================================================================

fn test_tuple_creation() {
    let t1: (Int, Int) = (1, 2);
    let t2: (Int, Float, Bool) = (42, 3.14, true);
    let t3: (Text, Int, Text) = ("hello", 42, "world");

    assert_eq(t1.0, 1);
    assert_eq(t1.1, 2);
    assert_eq(t2.0, 42);
    assert_eq(t2.1, 3.14);
    assert(t2.2);
}

fn test_tuple_access() {
    let t = (10, 20, 30, 40, 50);

    assert_eq(t.0, 10);
    assert_eq(t.1, 20);
    assert_eq(t.2, 30);
    assert_eq(t.3, 40);
    assert_eq(t.4, 50);
}

fn test_nested_tuple() {
    let t = ((1, 2), (3, 4));

    assert_eq((t.0).0, 1);
    assert_eq((t.0).1, 2);
    assert_eq((t.1).0, 3);
    assert_eq((t.1).1, 4);
}

// =============================================================================
// UNPACK - Tuple destructuring
// =============================================================================

fn test_simple_destructure() {
    let t = (1, 2, 3);
    let (a, b, c) = t;

    assert_eq(a, 1);
    assert_eq(b, 2);
    assert_eq(c, 3);
}

fn test_nested_destructure() {
    let t = ((1, 2), (3, 4));
    let ((a, b), (c, d)) = t;

    assert_eq(a, 1);
    assert_eq(b, 2);
    assert_eq(c, 3);
    assert_eq(d, 4);
}

fn test_mixed_destructure() {
    let t: (Int, (Float, Bool), Text) = (42, (3.14, true), "hello");
    let (i, (f, b), s) = t;

    assert_eq(i, 42);
    assert_eq(f, 3.14);
    assert(b);
    assert_eq(s, "hello");
}

fn test_function_return_destructure() {
    let (x, y) = get_point();
    assert_eq(x, 1.0);
    assert_eq(y, 2.0);
}

fn test_ignore_with_underscore() {
    let t = (1, 2, 3, 4, 5);
    let (a, _, c, _, e) = t;

    assert_eq(a, 1);
    assert_eq(c, 3);
    assert_eq(e, 5);
}

// NOTE: test_rest_pattern removed — VBC does not yet support `..` rest patterns in tuples.

// =============================================================================
// PACK - Tuple construction
// =============================================================================

fn test_pack_simple() {
    let a = 1;
    let b = 2;
    let c = 3;

    let t = (a, b, c);

    assert_eq(t.0, 1);
    assert_eq(t.1, 2);
    assert_eq(t.2, 3);
}

fn test_pack_expressions() {
    let x = 10;
    let t = (x + 1, x * 2, x - 5);

    assert_eq(t.0, 11);
    assert_eq(t.1, 20);
    assert_eq(t.2, 5);
}

fn test_pack_function_calls() {
    let t = (pack_f(), pack_g(), pack_f() + pack_g());

    assert_eq(t.0, 1);
    assert_eq(t.1, 2);
    assert_eq(t.2, 3);
}

// =============================================================================
// Struct destructuring
// =============================================================================

fn test_struct_destructure() {
    let p = Point { x: 1.0, y: 2.0 };
    let Point { x, y } = p;

    assert_eq(x, 1.0);
    assert_eq(y, 2.0);
}

fn test_struct_destructure_rename() {
    let p = Point { x: 1.0, y: 2.0 };
    let Point { x: px, y: py } = p;

    assert_eq(px, 1.0);
    assert_eq(py, 2.0);
}

fn test_struct_partial_destructure() {
    let person = Person { name: "Alice", age: 30 };
    let Person { name, .. } = person;

    assert_eq(name, "Alice");
}

fn test_nested_struct_destructure() {
    let line = Line {
        start: Point { x: 0.0, y: 0.0 },
        end: Point { x: 10.0, y: 10.0 }
    };

    let Line { start: Point { x: x1, y: y1 }, end: Point { x: x2, y: y2 } } = line;

    assert_eq(x1, 0.0);
    assert_eq(y1, 0.0);
    assert_eq(x2, 10.0);
    assert_eq(y2, 10.0);
}

// =============================================================================
// Array destructuring
// =============================================================================

fn test_array_destructure() {
    let arr = [1, 2, 3];
    let [a, b, c] = arr;

    assert_eq(a, 1);
    assert_eq(b, 2);
    assert_eq(c, 3);
}

// NOTE: test_array_head_tail and test_array_first_last removed — VBC does not
// yet support `..` rest patterns in array destructuring.

// =============================================================================
// Pattern matching with destructuring
// =============================================================================

fn test_match_destructure() {
    assert_eq(process_maybe(None), 0);
    assert_eq(process_maybe(Some((10, 20))), 30);
}

fn test_if_let_destructure() {
    let opt = Some(Point { x: 1.0, y: 2.0 });

    // Two-step destructure: VBC does not yet support nested struct patterns
    // inside variant patterns (e.g., Some(Point { x, y }))
    if let Some(p) = opt {
        let Point { x, y } = p;
        assert_eq(x, 1.0);
        assert_eq(y, 2.0);
    } else {
        panic("Expected Some");
    }
}

// NOTE: test_while_let_destructure removed — VBC does not support iterators.

// NOTE: test_param_destructure_* removed — VBC does not yet support destructuring
// patterns in function parameters.

// =============================================================================
// Mutable destructuring
// =============================================================================

fn test_mutable_destructure() {
    let t = (1, 2);
    let (mut a, mut b) = t;

    a = a + 10;
    b = b + 20;

    assert_eq(a, 11);
    assert_eq(b, 22);
}

// NOTE: test_ref_destructure and test_ref_mut_destructure removed — VBC does not
// yet support `ref`/`ref mut` in destructuring patterns with dereference.

// =============================================================================
// Complex destructuring patterns
// =============================================================================

fn test_complex_pattern() {
    let d = Data {
        id: 42,
        values: (1.0, 2.0, 3.0),
        meta: Some("info")
    };

    let Data { id, values: (v1, v2, v3), meta } = d;

    assert_eq(id, 42);
    assert_eq(v1, 1.0);
    assert_eq(v2, 2.0);
    assert_eq(v3, 3.0);
    assert(meta is Some);
}

fn test_or_pattern() {
    assert_eq(classify_int(0), "small");
    assert_eq(classify_int(1), "small");
    assert_eq(classify_int(3), "medium");
    assert_eq(classify_int(10), "large");
}

fn main() {
    test_tuple_creation();
    print("1");
    test_tuple_access();
    print("2");
    test_nested_tuple();
    print("3");
    test_simple_destructure();
    print("4");
    test_nested_destructure();
    print("5");
    test_mixed_destructure();
    print("6");
    test_function_return_destructure();
    print("7");
    test_ignore_with_underscore();
    print("8");
    test_pack_simple();
    print("9");
    test_pack_expressions();
    print("10");
    test_pack_function_calls();
    print("11");
    test_struct_destructure();
    print("12");
    test_struct_destructure_rename();
    print("13");
    test_struct_partial_destructure();
    print("14");
    test_nested_struct_destructure();
    print("15");
    test_array_destructure();
    print("16");
    test_match_destructure();
    print("17");
    test_if_let_destructure();
    print("18");
    test_mutable_destructure();
    print("19");
    test_complex_pattern();
    print("20");
    test_or_pattern();
    print("21");
    print("002_tuples_destructuring: PASSED");
}
