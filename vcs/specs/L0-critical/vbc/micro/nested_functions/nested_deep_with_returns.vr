// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, nested-functions, deep-nesting, returns
// @timeout: 5000
// @expected-exit: 0

fn main() {
    fn level1(x: Int) -> Int {
        fn level2(y: Int) -> Int {
            fn level3(z: Int) -> Int {
                fn level4(w: Int) -> Int {
                    return w + 1;
                }
                return level4(z) + 10;
            }
            return level3(y) + 100;
        }
        return level2(x) + 1000;
    }

    // x=5 -> level4(5)=6, level3(5)=16, level2(5)=116, level1(5)=1116
    assert_eq(level1(5), 1116);

    // Chain of nested functions calling each other (mutual forward references)
    fn chain_start(n: Int) -> Int {
        fn chain_a(x: Int) -> Int {
            if x <= 0 {
                return 0;
            }
            return x + chain_b(x - 1);
        }
        fn chain_b(x: Int) -> Int {
            if x <= 0 {
                return 0;
            }
            return x * 2 + chain_a(x - 1);
        }
        return chain_a(n);
    }

    // chain_a(3) = 3 + chain_b(2) = 3 + (4 + chain_a(1)) = 3 + 4 + (1 + chain_b(0)) = 3 + 4 + 1 + 0 = 8
    assert_eq(chain_start(3), 8);
}
