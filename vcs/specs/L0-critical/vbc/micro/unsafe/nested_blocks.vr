// @test: typecheck-pass
// @level: L0
// @tags: unsafe, nested, block
// @description: Nested unsafe blocks with proper context management
mount core.prelude.*;

fn main() {
    let outer: Int = unsafe {
        let a: Int = 10;
        let inner: Int = unsafe {
            let b: Int = 20;
            a + b
        };
        inner + 5
    };
    assert_eq(outer, 35);
}
