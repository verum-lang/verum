// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @description: Test type properties for built-in types (Int, Float, Bool, Byte, Char)

fn main() {
    // Test Int (64-bit signed)
    assert_eq(Int.size, 8);
    assert_eq(Int.alignment, 8);
    assert_eq(Int.bits, 64);
    assert_eq(Int.min, -9223372036854775808);
    assert_eq(Int.max, 9223372036854775807);
    assert_eq(Int.name, "Int");

    // Test Float (64-bit IEEE 754)
    assert_eq(Float.size, 8);
    assert_eq(Float.alignment, 8);
    assert_eq(Float.bits, 64);
    assert_eq(Float.name, "Float");

    // Test Bool
    assert_eq(Bool.size, 1);
    assert_eq(Bool.alignment, 1);
    assert_eq(Bool.bits, 8);  // Stored as 1 byte
    assert_eq(Bool.name, "Bool");

    // Test Byte (UInt8)
    assert_eq(Byte.size, 1);
    assert_eq(Byte.alignment, 1);
    assert_eq(Byte.bits, 8);
    assert_eq(Byte.min, 0);
    assert_eq(Byte.max, 255);
    assert_eq(Byte.name, "Byte");

    // Test Char (Unicode code point, 4 bytes)
    assert_eq(Char.size, 4);
    assert_eq(Char.alignment, 4);
    assert_eq(Char.bits, 32);
    assert_eq(Char.name, "Char");
}
