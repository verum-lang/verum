// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @description: Test type size/alignment/bits properties for float types

fn main() {
    // Test Float32 properties
    assert_eq(Float32.size, 4);
    assert_eq(Float32.alignment, 4);
    assert_eq(Float32.bits, 32);

    // Test Float64 properties
    assert_eq(Float64.size, 8);
    assert_eq(Float64.alignment, 8);
    assert_eq(Float64.bits, 64);

    // Test Float (same as Float64)
    assert_eq(Float.size, 8);
    assert_eq(Float.alignment, 8);
    assert_eq(Float.bits, 64);

    // Test compatibility aliases
    assert_eq(f32.size, 4);
    assert_eq(f32.bits, 32);
    assert_eq(f64.size, 8);
    assert_eq(f64.bits, 64);
}
