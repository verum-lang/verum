// @test: run
// @level: L0
// @tier: 0
// @expected-exit: 0
fn main() {
    let mut sum = 0;
    let mut i = 0;

    while i < 10 {
        i = i + 1;
        if i % 2 == 0 {
            continue;  // Skip even numbers
        }
        sum = sum + i;  // Only add odd numbers
    }

    // Sum of odd numbers 1-9: 1+3+5+7+9 = 25
    assert_eq(sum, 25);
}
