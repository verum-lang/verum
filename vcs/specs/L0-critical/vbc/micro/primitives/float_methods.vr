// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @description: Test Float methods

fn main() {
    // Test abs
    assert_eq((-3.14).abs(), 3.14);
    assert_eq(3.14.abs(), 3.14);

    // Test signum
    assert_eq((-3.14).signum(), -1.0);
    assert_eq(3.14.signum(), 1.0);
    assert_eq((0.0).signum(), 0.0);

    // Test is_nan, is_infinite, is_finite
    let nan = (0.0) / (0.0);        // NaN
    let inf = (1.0) / (0.0);        // +Infinity
    let neg_inf = (-1.0) / (0.0);   // -Infinity

    assert(nan.is_nan());
    assert(!3.14.is_nan());

    assert(inf.is_infinite());
    assert(neg_inf.is_infinite());
    assert(!3.14.is_infinite());

    assert(3.14.is_finite());
    assert(!nan.is_finite());
    assert(!inf.is_finite());

    // Test is_positive, is_negative
    assert(3.14.is_positive());
    assert((-3.14).is_negative());
    assert(!(0.0).is_positive());

    // Test floor, ceil, round, trunc
    assert_eq(3.7.floor(), 3.0);
    assert_eq(3.2.ceil(), 4.0);
    assert_eq(3.5.round(), 4.0);
    assert_eq(3.7.trunc(), 3.0);
    assert_eq((-3.7).trunc(), -3.0);

    // Test fract
    let x = 3.7;
    let frac = x.fract();
    assert(frac > 0.69 && frac < 0.71);  // ~0.7

    // Test min, max
    assert_eq((3.0).min(5.0), 3.0);
    assert_eq((3.0).max(5.0), 5.0);

    // Test clamp
    assert_eq((3.0).clamp(0.0, 10.0), 3.0);
    assert_eq((-5.0).clamp(0.0, 10.0), 0.0);
    assert_eq((15.0).clamp(0.0, 10.0), 10.0);
}
