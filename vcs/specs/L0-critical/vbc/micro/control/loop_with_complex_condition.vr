// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, control-flow, stress
// @timeout: 5000
// @expected-exit: 0

fn main() {
    let mut count: Int = 0;
    let mut i: Int = 0;

    // Complex condition with && and ||
    while (i < 100) && ((i % 7 != 0) || (i < 20)) {
        count = count + 1;
        i = i + 1;
    }

    // Loop continues while i < 100 AND (i is not divisible by 7 OR i < 20)
    // Stops at i=21 (first i >= 20 where i % 7 == 0)
    assert_eq(i, 21);
    assert_eq(count, 21);

    // Test with negation
    let mut j: Int = 0;
    let mut neg_count: Int = 0;

    while !(j >= 10) {
        neg_count = neg_count + 1;
        j = j + 1;
    }

    assert_eq(neg_count, 10);

    // Test nested boolean expressions
    let mut k: Int = 0;
    let mut nested_count: Int = 0;

    while ((k < 5) || (k < 3)) && (!(k > 4)) {
        nested_count = nested_count + 1;
        k = k + 1;
    }

    assert_eq(nested_count, 5);
}
