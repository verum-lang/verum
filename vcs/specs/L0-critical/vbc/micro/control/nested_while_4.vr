// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, control-flow, stress
// @timeout: 5000
// @expected-exit: 0

fn main() {
    let mut total: Int = 0;
    let mut i: Int = 0;

    while i < 3 {
        let mut j: Int = 0;
        while j < 3 {
            let mut k: Int = 0;
            while k < 3 {
                let mut l: Int = 0;
                while l < 3 {
                    total = total + 1;
                    l = l + 1;
                }
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }

    // 3 * 3 * 3 * 3 = 81 iterations
    assert_eq(total, 81);
}
