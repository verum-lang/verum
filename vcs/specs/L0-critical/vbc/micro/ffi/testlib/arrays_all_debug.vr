// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @tags: ffi, arrays, debug
// @description: Debug all array operations

@ffi("vcs/testlibs/ffi_testlib/target/release/libffi_testlib.dylib")
extern {
    fn ffi_sum_array_i32(arr: &Int, len: Int) -> Int;
    fn ffi_sum_array_f64(arr: &Float, len: Int) -> Float;
    fn ffi_max_array_i32(arr: &Int, len: Int) -> Int;
    fn ffi_min_array_i32(arr: &Int, len: Int) -> Int;
    fn ffi_fill_array_i32(arr: &mut Int, len: Int, value: Int);
    fn ffi_reverse_array_i32(arr: &mut Int, len: Int);
    fn ffi_copy_array_i64(dst: &mut Int, src: &Int, len: Int);
}

fn main() {
    print("Test 1: sum_array_i32\n");
    let arr1 = [1, 2, 3, 4, 5];
    let sum = ffi_sum_array_i32(&arr1[0], 5);
    print("sum = "); print(sum); print("\n");
    assert_eq(sum, 15);
    print("Test 1 passed\n");

    print("Test 2: sum_array_f64\n");
    let arr2 = [1.5, 2.5, 3.0, 4.0];
    let fsum = ffi_sum_array_f64(&arr2[0], 4);
    print("fsum = "); print(fsum); print("\n");
    assert(fsum > 10.99 && fsum < 11.01);
    print("Test 2 passed\n");

    print("Test 3: max_array_i32\n");
    let arr3 = [5, 2, 8, 1, 9, 3];
    let max_val = ffi_max_array_i32(&arr3[0], 6);
    print("max_val = "); print(max_val); print("\n");
    assert_eq(max_val, 9);
    print("Test 3 passed\n");

    print("Test 4: min_array_i32\n");
    let min_val = ffi_min_array_i32(&arr3[0], 6);
    print("min_val = "); print(min_val); print("\n");
    assert_eq(min_val, 1);
    print("Test 4 passed\n");

    print("Test 5: fill_array_i32\n");
    let mut arr4 = [0, 0, 0, 0];
    ffi_fill_array_i32(&mut arr4[0], 4, 42);
    print("arr4[0] = "); print(arr4[0]); print("\n");
    assert_eq(arr4[0], 42);
    assert_eq(arr4[1], 42);
    assert_eq(arr4[2], 42);
    assert_eq(arr4[3], 42);
    print("Test 5 passed\n");

    print("Test 6: reverse_array_i32\n");
    let mut arr5 = [1, 2, 3, 4, 5];
    ffi_reverse_array_i32(&mut arr5[0], 5);
    print("arr5[0] = "); print(arr5[0]); print("\n");
    assert_eq(arr5[0], 5);
    assert_eq(arr5[1], 4);
    assert_eq(arr5[2], 3);
    assert_eq(arr5[3], 2);
    assert_eq(arr5[4], 1);
    print("Test 6 passed\n");

    print("Test 7: copy_array\n");
    let src = [10, 20, 30, 40];
    let mut dst = [0, 0, 0, 0];
    ffi_copy_array_i64(&mut dst[0], &src[0], 4);
    print("dst[0] = "); print(dst[0]); print("\n");
    assert_eq(dst[0], 10);
    assert_eq(dst[1], 20);
    assert_eq(dst[2], 30);
    assert_eq(dst[3], 40);
    print("Test 7 passed\n");

    print("ALL TESTS PASSED!\n");
}
