// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @tags: ffi, callbacks, function-pointers
// @description: Test FFI callback operations

@ffi("vcs/testlibs/ffi_testlib/target/release/libffi_testlib.dylib")
extern {
    // All callbacks use Int32 (i32) not Int (i64)
    fn ffi_call_comparator(f: fn(Int32, Int32) -> Int32, a: Int32, b: Int32) -> Int32;
    fn ffi_apply_unary(f: fn(Int32) -> Int32, x: Int32) -> Int32;
    fn ffi_apply_binary(f: fn(Int32, Int32) -> Int32, a: Int32, b: Int32) -> Int32;
    fn ffi_sort_array_i32(arr: &mut Int32, len: Int, cmp: fn(Int32, Int32) -> Int32);
    // ffi_map_array_i32 modifies in place: (arr: *mut i32, len: usize, f: fn(i32) -> i32)
    fn ffi_map_array_i32(arr: &mut Int32, len: Int, f: fn(Int32) -> Int32);
    // ffi_filter_array_i32 filters in place, returns new length
    fn ffi_filter_array_i32(arr: &mut Int32, len: Int, pred: fn(Int32) -> Int32) -> Int;
    fn ffi_fold_array_i32(arr: &Int32, len: Int, init: Int32, f: fn(Int32, Int32) -> Int32) -> Int32;
    // ffi_find_array_i32 returns index (i64), not value
    fn ffi_find_array_i32(arr: &Int32, len: Int, pred: fn(Int32) -> Int32) -> Int;
    fn ffi_count_array_i32(arr: &Int32, len: Int, pred: fn(Int32) -> Int32) -> Int;
    fn ffi_any_array_i32(arr: &Int32, len: Int, pred: fn(Int32) -> Int32) -> Int32;
    fn ffi_all_array_i32(arr: &Int32, len: Int, pred: fn(Int32) -> Int32) -> Int32;
}

// Comparator: ascending order
fn ascending(a: Int32, b: Int32) -> Int32 {
    if a < b { -1 } else if a > b { 1 } else { 0 }
}

// Comparator: descending order
fn descending(a: Int32, b: Int32) -> Int32 {
    if a > b { -1 } else if a < b { 1 } else { 0 }
}

// Unary operations
fn double_val(x: Int32) -> Int32 { x * 2 }
fn square(x: Int32) -> Int32 { x * x }
fn negate(x: Int32) -> Int32 { -x }

// Binary operations
fn add(a: Int32, b: Int32) -> Int32 { a + b }
fn multiply(a: Int32, b: Int32) -> Int32 { a * b }
fn max_op(a: Int32, b: Int32) -> Int32 { if a > b { a } else { b } }

// Predicates
fn is_positive(x: Int32) -> Int32 { if x > 0 { 1 } else { 0 } }
fn is_even(x: Int32) -> Int32 { if x % 2 == 0 { 1 } else { 0 } }
fn is_greater_than_5(x: Int32) -> Int32 { if x > 5 { 1 } else { 0 } }

fn main() {
    print("Starting callback tests...\n");

    // Test ffi_call_comparator
    print("Testing ffi_call_comparator...\n");
    let cmp1 = ffi_call_comparator(ascending, 3, 5);
    print("cmp1="); print(cmp1); print("\n");
    assert_eq(cmp1, -1);  // 3 < 5

    let cmp2 = ffi_call_comparator(ascending, 5, 3);
    assert_eq(cmp2, 1);   // 5 > 3

    let cmp3 = ffi_call_comparator(ascending, 4, 4);
    assert_eq(cmp3, 0);   // 4 == 4

    // Test ffi_apply_unary
    print("Testing ffi_apply_unary...\n");
    let doubled = ffi_apply_unary(double_val, 7);
    print("doubled="); print(doubled); print("\n");
    assert_eq(doubled, 14);

    let squared = ffi_apply_unary(square, 5);
    assert_eq(squared, 25);

    let negated = ffi_apply_unary(negate, 10);
    assert_eq(negated, -10);

    // Test ffi_apply_binary
    let sum = ffi_apply_binary(add, 10, 20);
    assert_eq(sum, 30);

    let prod = ffi_apply_binary(multiply, 6, 7);
    assert_eq(prod, 42);

    let maximum = ffi_apply_binary(max_op, 15, 8);
    assert_eq(maximum, 15);

    // Test ffi_sort_array_i32 with ascending comparator
    print("Testing ffi_sort_array_i32 ascending...\n");
    let mut arr1: [Int32; 6] = [5, 2, 8, 1, 9, 3];
    ffi_sort_array_i32(&mut arr1[0], 6, ascending);
    print("arr1[0]="); print(arr1[0]); print("\n");
    assert_eq(arr1[0], 1);
    assert_eq(arr1[1], 2);
    assert_eq(arr1[2], 3);
    assert_eq(arr1[3], 5);
    assert_eq(arr1[4], 8);
    assert_eq(arr1[5], 9);

    // Test ffi_sort_array_i32 with descending comparator
    let mut arr2: [Int32; 6] = [5, 2, 8, 1, 9, 3];
    ffi_sort_array_i32(&mut arr2[0], 6, descending);
    assert_eq(arr2[0], 9);
    assert_eq(arr2[1], 8);
    assert_eq(arr2[2], 5);
    assert_eq(arr2[3], 3);
    assert_eq(arr2[4], 2);
    assert_eq(arr2[5], 1);

    // Test ffi_map_array_i32 - modifies array in place
    let mut arr3: [Int32; 4] = [1, 2, 3, 4];
    ffi_map_array_i32(&mut arr3[0], 4, double_val);
    assert_eq(arr3[0], 2);
    assert_eq(arr3[1], 4);
    assert_eq(arr3[2], 6);
    assert_eq(arr3[3], 8);

    // Test ffi_fold_array_i32 (sum)
    let arr4: [Int32; 5] = [1, 2, 3, 4, 5];
    let fold_sum = ffi_fold_array_i32(&arr4[0], 5, 0, add);
    assert_eq(fold_sum, 15);  // 1+2+3+4+5=15

    // Test ffi_fold_array_i32 (product)
    let arr5: [Int32; 4] = [1, 2, 3, 4];
    let fold_prod = ffi_fold_array_i32(&arr5[0], 4, 1, multiply);
    assert_eq(fold_prod, 24);  // 1*2*3*4=24

    // Test ffi_fold_array_i32 (max)
    let arr6: [Int32; 5] = [3, 7, 2, 9, 4];
    let fold_max = ffi_fold_array_i32(&arr6[0], 5, -1000, max_op);
    assert_eq(fold_max, 9);

    // Test ffi_filter_array_i32 - filters in place, returns new length
    let mut arr7: [Int32; 6] = [1, -2, 3, -4, 5, -6];
    let filtered_len = ffi_filter_array_i32(&mut arr7[0], 6, is_positive);
    assert_eq(filtered_len, 3);  // 1, 3, 5 are positive
    assert_eq(arr7[0], 1);
    assert_eq(arr7[1], 3);
    assert_eq(arr7[2], 5);

    // Test ffi_find_array_i32 - returns INDEX of first matching element
    let arr8: [Int32; 6] = [1, 3, 5, 7, 9, 11];
    let found_idx = ffi_find_array_i32(&arr8[0], 6, is_greater_than_5);
    assert_eq(found_idx, 3);  // Index of 7 (first element > 5)

    // Test ffi_count_array_i32
    let arr9: [Int32; 7] = [2, 3, 4, 5, 6, 7, 8];
    let even_count = ffi_count_array_i32(&arr9[0], 7, is_even);
    assert_eq(even_count, 4);  // 2, 4, 6, 8 are even

    // Test ffi_any_array_i32
    let arr10: [Int32; 5] = [-1, -2, -3, 4, -5];
    let any_pos = ffi_any_array_i32(&arr10[0], 5, is_positive);
    assert_eq(any_pos, 1);  // 4 is positive

    let arr11: [Int32; 3] = [-1, -2, -3];
    let any_pos2 = ffi_any_array_i32(&arr11[0], 3, is_positive);
    assert_eq(any_pos2, 0);  // None positive

    // Test ffi_all_array_i32
    let arr12: [Int32; 4] = [2, 4, 6, 8];
    let all_even = ffi_all_array_i32(&arr12[0], 4, is_even);
    assert_eq(all_even, 1);  // All even

    let arr13: [Int32; 4] = [2, 3, 4, 6];
    let all_even2 = ffi_all_array_i32(&arr13[0], 4, is_even);
    assert_eq(all_even2, 0);  // 3 is odd

    print("Callback tests passed!\n");
}
