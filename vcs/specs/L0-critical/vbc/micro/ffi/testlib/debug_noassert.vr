// @test: run-interpreter
// @level: L0
// @was-skip: FIXED - FFI CallFfiC handler implemented
// @tier: 0
// @expected-exit: 0
// @tags: ffi, testlib, debug
// @description: FFI call without assert - see output

@ffi("vcs/testlibs/ffi_testlib/target/release/libffi_testlib.dylib")
extern {
    fn ffi_add_i32(a: Int, b: Int) -> Int;
}

fn main() {
    print("start\n");
    let a = 10;
    let b = 32;
    print("a="); print(a); print(" b="); print(b); print("\n");
    let result = ffi_add_i32(a, b);
    print("result="); print(result); print("\n");
    print("end\n");
}
