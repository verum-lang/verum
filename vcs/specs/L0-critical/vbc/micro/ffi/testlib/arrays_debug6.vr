// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @tags: ffi, arrays, debug
// @description: Debug test for reverse_array

@ffi("vcs/testlibs/ffi_testlib/target/release/libffi_testlib.dylib")
extern {
    fn ffi_reverse_array_i32(arr: &mut Int, len: Int);
}

fn main() {
    // Test reverse_array_i32
    let mut arr5 = [1, 2, 3, 4, 5];

    print("Before reverse:\n");
    print("arr5[0] = "); print(arr5[0]); print("\n");
    print("arr5[4] = "); print(arr5[4]); print("\n");

    ffi_reverse_array_i32(&mut arr5[0], 5);

    print("After reverse:\n");
    print("arr5[0] = "); print(arr5[0]); print("\n");
    print("arr5[1] = "); print(arr5[1]); print("\n");
    print("arr5[2] = "); print(arr5[2]); print("\n");
    print("arr5[3] = "); print(arr5[3]); print("\n");
    print("arr5[4] = "); print(arr5[4]); print("\n");

    // Check: should be [5, 4, 3, 2, 1]
    assert_eq(arr5[0], 5);
    assert_eq(arr5[1], 4);
    assert_eq(arr5[2], 3);
    assert_eq(arr5[3], 2);
    assert_eq(arr5[4], 1);

    print("SUCCESS!\n");
}
