// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @tags: ffi, arrays, debug
// @description: Debug test for FFI array operations - f64 sum

@ffi("vcs/testlibs/ffi_testlib/target/release/libffi_testlib.dylib")
extern {
    fn ffi_sum_array_f64(arr: &Float, len: Int) -> Float;
}

fn main() {
    // Test sum_array_f64
    let arr2 = [1.5, 2.5, 3.0, 4.0];
    print("Calling ffi_sum_array_f64...\n");
    let fsum = ffi_sum_array_f64(&arr2[0], 4);
    print("fsum = ");
    print(fsum);
    print("\n");

    if fsum > 10.99 && fsum < 11.01 {
        print("SUCCESS: fsum is correct!\n");
    } else {
        print("FAILURE: expected ~11.0\n");
    }
}
