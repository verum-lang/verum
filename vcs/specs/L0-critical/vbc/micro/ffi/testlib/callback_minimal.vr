// @test: run-interpreter
// @level: L0
// @tier: 0
// @expected-exit: 0
// @tags: ffi, callbacks
// @description: Minimal FFI callback test

@ffi("vcs/testlibs/ffi_testlib/target/release/libffi_testlib.dylib")
extern {
    fn ffi_apply_unary(f: fn(Int32) -> Int32, x: Int32) -> Int32;
}

fn double_val(x: Int32) -> Int32 { x * 2 }

fn main() {
    let doubled: Int32 = ffi_apply_unary(double_val, 7);
    print(doubled);
    print("\n");
}
