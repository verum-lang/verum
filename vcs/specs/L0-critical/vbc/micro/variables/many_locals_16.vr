// @test: run
// @level: L0
// @tier: 0
// @tags: vbc, registers, stress
// @timeout: 5000
// @expected-exit: 0
// @description: Register allocation stress test with 16 local variables

fn main() {
    let v0: Int = 0;
    let v1: Int = 1;
    let v2: Int = 2;
    let v3: Int = 3;
    let v4: Int = 4;
    let v5: Int = 5;
    let v6: Int = 6;
    let v7: Int = 7;
    let v8: Int = 8;
    let v9: Int = 9;
    let v10: Int = 10;
    let v11: Int = 11;
    let v12: Int = 12;
    let v13: Int = 13;
    let v14: Int = 14;
    let v15: Int = 15;

    let sum = v0 + v1 + v2 + v3 + v4 + v5 + v6 + v7 + v8 + v9 + v10 + v11 + v12 + v13 + v14 + v15;
    assert_eq(sum, 120);
}
