// @test: run
// @level: L0
// @tier: 0
// @expected-exit: 0
fn classify(x: Int) -> Int {
    if x < 0 {
        if x < -10 { -2 } else { -1 }
    } else {
        if x > 10 { 2 } else { if x > 0 { 1 } else { 0 } }
    }
}

fn main() {
    assert_eq(classify(-100), -2);
    assert_eq(classify(-5), -1);
    assert_eq(classify(0), 0);
    assert_eq(classify(5), 1);
    assert_eq(classify(100), 2);
}
