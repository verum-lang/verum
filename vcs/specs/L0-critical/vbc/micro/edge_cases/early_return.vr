// @test: run
// @level: L0
// @tier: 0
// @expected-exit: 0
fn find_first_positive(a: Int, b: Int, c: Int) -> Int {
    if a > 0 { return a; }
    if b > 0 { return b; }
    if c > 0 { return c; }
    return -1;
}

fn main() {
    assert_eq(find_first_positive(-1, -2, 5), 5);
    assert_eq(find_first_positive(-1, 3, 5), 3);
    assert_eq(find_first_positive(7, -2, 5), 7);
    assert_eq(find_first_positive(-1, -2, -3), -1);
}
