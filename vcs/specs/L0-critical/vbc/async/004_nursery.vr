// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, async, nursery, structured-concurrency
// @timeout: 5000
// @expect: pass
//
// Test: NURSERY_INIT, NURSERY_SPAWN, NURSERY_AWAIT, NURSERY_CANCEL, NURSERY_CONFIG
// Verifies structured concurrency with nursery pattern

// =============================================================================
// Basic nursery usage
// =============================================================================

async fn test_nursery_basic() {
    let mut results: List<Int> = [];

    nursery {
        spawn async {
            results.push(1);
        };
        spawn async {
            results.push(2);
        };
        spawn async {
            results.push(3);
        };
    }  // Waits for all spawned tasks

    assert_eq(results.len(), 3);
    assert(results.contains(1));
    assert(results.contains(2));
    assert(results.contains(3));
}

async fn test_nursery_empty() {
    // Empty nursery should complete immediately
    nursery {
        // No spawns
    }

    assert(true);  // Reached here without hanging
}

async fn test_nursery_single_task() {
    let mut completed: Bool = false;

    nursery {
        spawn async {
            completed = true;
        };
    }

    assert(completed);
}

// =============================================================================
// Nursery with return values
// =============================================================================

async fn test_nursery_collect_results() {
    let results = nursery<List<Int>> {
        let mut collected: List<Int> = [];

        spawn async {
            collected.push(compute(1).await);
        };
        spawn async {
            collected.push(compute(2).await);
        };
        spawn async {
            collected.push(compute(3).await);
        };

        collected
    };

    assert_eq(results.len(), 3);
}

async fn compute(x: Int) -> Int { x * 10 }

async fn test_nursery_channel_pattern() {
    // Use channel to collect results
    let (tx, rx) = channel<Int>();

    nursery {
        for i in 0..5 {
            let tx = tx.clone();
            spawn async move {
                tx.send(i * i);
            };
        }
    }

    drop(tx);  // Close sender

    let mut sum: Int = 0;
    while let Some(v) = rx.recv() {
        sum = sum + v;
    }

    assert_eq(sum, 30);  // 0 + 1 + 4 + 9 + 16
}

// =============================================================================
// Error handling in nursery
// =============================================================================

async fn test_nursery_one_error() {
    let result = @catch(async {
        nursery {
            spawn async { panic("task failed"); };
            spawn async { 42 };
        }
    });

    // Nursery should propagate error
    assert(result is Err);
}

async fn test_nursery_multiple_errors() {
    let result = nursery<Result<(), List<Text>>> {
        let errors: List<Text> = [];

        spawn async {
            Err("error 1")
        };
        spawn async {
            Err("error 2")
        };
        spawn async {
            Ok(())
        };

        if errors.len() > 0 {
            Err(errors)
        } else {
            Ok(())
        }
    };

    assert(result is Err);
}

async fn test_nursery_error_cancels_siblings() {
    let mut task2_completed: Bool = false;

    let result = @catch(async {
        nursery {
            spawn async {
                panic("early failure");
            };
            spawn async {
                // Long running task
                for _ in 0..1000000 { }
                task2_completed = true;
            };
        }
    });

    // Task 2 should be cancelled when task 1 fails
    // (exact behavior depends on timing)
    assert(result is Err);
}

// =============================================================================
// Nursery cancellation
// =============================================================================

async fn test_nursery_explicit_cancel() {
    let mut started: [Bool; 3] = [false, false, false];
    let mut completed: [Bool; 3] = [false, false, false];

    nursery |n| {
        for i in 0..3 {
            spawn async {
                started[i] = true;
                for _ in 0..1000000 { }  // Simulate work
                completed[i] = true;
            };
        }

        // Cancel all after brief delay
        n.cancel_all();
    }

    // At least some started
    assert(started[0] || started[1] || started[2]);
}

async fn test_nursery_cancel_scope() {
    let mut outer_completed: Bool = false;

    nursery {
        spawn async {
            nursery |inner| {
                spawn async {
                    for _ in 0.. { }  // Infinite loop
                };

                inner.cancel_all();  // Cancel inner nursery
            }

            outer_completed = true;  // Should reach here
        };
    }

    assert(outer_completed);
}

// =============================================================================
// Nursery configuration
// =============================================================================

async fn test_nursery_with_timeout() {
    let result = nursery @timeout(100.ms) {
        spawn async {
            // Task that takes too long
            for _ in 0..100000000 { }
            42
        };
    };

    // Should timeout
    assert(result is Err(Timeout));
}

async fn test_nursery_max_concurrency() {
    let mut max_concurrent: Int = 0;
    let mut current: Int = 0;

    nursery @max_concurrent(2) {
        for i in 0..10 {
            spawn async {
                current = current + 1;
                if current > max_concurrent {
                    max_concurrent = current;
                }
                // Simulate work
                for _ in 0..1000 { }
                current = current - 1;
            };
        }
    }

    // Should never exceed 2 concurrent
    assert(max_concurrent <= 2);
}

async fn test_nursery_fail_fast() {
    let tasks_run: Int = 0;

    let result = @catch(async {
        nursery @fail_fast {
            for i in 0..100 {
                spawn async {
                    tasks_run = tasks_run + 1;
                    if i == 5 {
                        panic("failure");
                    }
                    for _ in 0..10000 { }  // Work
                };
            }
        }
    });

    // Should fail fast, not all 100 tasks complete
    assert(result is Err);
    assert(tasks_run < 100);
}

// =============================================================================
// Nested nurseries
// =============================================================================

async fn test_nested_nurseries() {
    let mut results: List<Int> = [];

    nursery {
        spawn async {
            nursery {
                spawn async { results.push(1); };
                spawn async { results.push(2); };
            }
        };
        spawn async {
            nursery {
                spawn async { results.push(3); };
                spawn async { results.push(4); };
            }
        };
    }

    assert_eq(results.len(), 4);
}

async fn test_nursery_scope_isolation() {
    // Inner nursery errors shouldn't escape if handled
    let mut inner_error: Bool = false;

    nursery {
        spawn async {
            let result = @catch(async {
                nursery {
                    spawn async { panic("inner failure"); };
                }
            });
            inner_error = result is Err;
        };
    }

    assert(inner_error);
}

// =============================================================================
// Resource cleanup
// =============================================================================

async fn test_nursery_cleanup_on_success() {
    let mut cleanup_ran: Bool = false;

    nursery |n| {
        n.on_cleanup(fn() {
            cleanup_ran = true;
        });

        spawn async { 42 };
    }

    assert(cleanup_ran);
}

async fn test_nursery_cleanup_on_error() {
    let mut cleanup_ran: Bool = false;

    let _ = @catch(async {
        nursery |n| {
            n.on_cleanup(fn() {
                cleanup_ran = true;
            });

            spawn async { panic("error"); };
        }
    });

    assert(cleanup_ran);
}

async fn test_nursery_cleanup_order() {
    let mut order: List<Int> = [];

    nursery |n| {
        n.on_cleanup(fn() { order.push(1); });
        n.on_cleanup(fn() { order.push(2); });
        n.on_cleanup(fn() { order.push(3); });
    }

    // LIFO order
    assert_eq(order, [3, 2, 1]);
}

// =============================================================================
// Advanced patterns
// =============================================================================

async fn test_nursery_supervisor() {
    // Restart failed tasks
    let mut attempts: Int = 0;
    let max_attempts: Int = 3;

    nursery |n| {
        n.on_task_error(fn(err) {
            attempts = attempts + 1;
            if attempts < max_attempts {
                n.spawn(failing_task());  // Restart
            }
        });

        spawn failing_task();
    }

    assert_eq(attempts, max_attempts);
}

async fn failing_task() {
    panic("always fails");
}

async fn test_nursery_scatter_gather() {
    // Scatter work, gather results
    let inputs = [1, 2, 3, 4, 5];
    let mut outputs: List<Int> = [];

    nursery {
        for input in inputs {
            spawn async {
                let result = process_item(input).await;
                outputs.push(result);
            };
        }
    }

    assert_eq(outputs.len(), 5);
    let sum: Int = outputs.iter().sum();
    assert_eq(sum, 30);  // 2+4+6+8+10
}

async fn process_item(x: Int) -> Int { x * 2 }

fn main() {
    @block_on(async {
        // Basic usage
        test_nursery_basic().await;
        test_nursery_empty().await;
        test_nursery_single_task().await;

        // Return values
        test_nursery_collect_results().await;
        test_nursery_channel_pattern().await;

        // Error handling
        test_nursery_one_error().await;
        test_nursery_multiple_errors().await;
        test_nursery_error_cancels_siblings().await;

        // Cancellation
        test_nursery_explicit_cancel().await;
        test_nursery_cancel_scope().await;

        // Configuration
        test_nursery_with_timeout().await;
        test_nursery_max_concurrency().await;
        test_nursery_fail_fast().await;

        // Nesting
        test_nested_nurseries().await;
        test_nursery_scope_isolation().await;

        // Cleanup
        test_nursery_cleanup_on_success().await;
        test_nursery_cleanup_on_error().await;
        test_nursery_cleanup_order().await;

        // Advanced patterns
        test_nursery_supervisor().await;
        test_nursery_scatter_gather().await;
    });

    print("004_nursery: PASSED");
}
