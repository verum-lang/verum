// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, tensor, one-hot, nonzero, encoding
// @timeout: 50000
// @expected-exit: 0
// @description: OneHot encoding and Nonzero index finding

// =============================================================================
// Helpers
// =============================================================================

type Arr5 is { d0: Float, d1: Float, d2: Float, d3: Float, d4: Float };

fn arr5_get(a: Arr5, idx: Int) -> Float {
    if idx == 0 { a.d0 }
    else if idx == 1 { a.d1 }
    else if idx == 2 { a.d2 }
    else if idx == 3 { a.d3 }
    else { a.d4 }
}

// one_hot: create array of size 5 with 1.0 at position `idx`, 0.0 elsewhere
fn one_hot5(idx: Int) -> Arr5 {
    let v0 = if idx == 0 { 1.0 } else { 0.0 };
    let v1 = if idx == 1 { 1.0 } else { 0.0 };
    let v2 = if idx == 2 { 1.0 } else { 0.0 };
    let v3 = if idx == 3 { 1.0 } else { 0.0 };
    let v4 = if idx == 4 { 1.0 } else { 0.0 };
    Arr5 { d0: v0, d1: v1, d2: v2, d3: v3, d4: v4 }
}

// count nonzero elements
fn count_nonzero(a: Arr5) -> Int {
    let mut count = 0;
    if a.d0 != 0.0 { count = count + 1; }
    if a.d1 != 0.0 { count = count + 1; }
    if a.d2 != 0.0 { count = count + 1; }
    if a.d3 != 0.0 { count = count + 1; }
    if a.d4 != 0.0 { count = count + 1; }
    count
}

// find first nonzero index (-1 if none)
fn first_nonzero(a: Arr5) -> Int {
    if a.d0 != 0.0 { 0 }
    else if a.d1 != 0.0 { 1 }
    else if a.d2 != 0.0 { 2 }
    else if a.d3 != 0.0 { 3 }
    else if a.d4 != 0.0 { 4 }
    else { 0 - 1 }
}

// sum using individual float parameters (workaround: record field addition bug)
fn sum5f(v0: Float, v1: Float, v2: Float, v3: Float, v4: Float) -> Float {
    v0 + v1 + v2 + v3 + v4
}

// =============================================================================
// Tests
// =============================================================================

@test
fn test_one_hot_basic() {
    // One-hot encode index 2 into array of 5
    let oh = one_hot5(2);

    assert_eq(oh.d0, 0.0);
    assert_eq(oh.d1, 0.0);
    assert_eq(oh.d2, 1.0);
    assert_eq(oh.d3, 0.0);
    assert_eq(oh.d4, 0.0);

    // Sum should be exactly 1.0
    let s = sum5f(oh.d0, oh.d1, oh.d2, oh.d3, oh.d4);
    assert_eq(s, 1.0);
    print("  test_one_hot_basic: ok");
}

@test
fn test_one_hot_multi() {
    // Create multiple one-hot vectors and verify each
    let oh0 = one_hot5(0);
    let oh1 = one_hot5(1);
    let oh3 = one_hot5(3);
    let oh4 = one_hot5(4);

    // Each should have exactly one 1.0
    assert_eq(oh0.d0, 1.0);
    assert_eq(oh1.d1, 1.0);
    assert_eq(oh3.d3, 1.0);
    assert_eq(oh4.d4, 1.0);

    // All should sum to 1.0 (verify via individual field checks)
    assert_eq(sum5f(oh0.d0, oh0.d1, oh0.d2, oh0.d3, oh0.d4), 1.0);
    assert_eq(sum5f(oh1.d0, oh1.d1, oh1.d2, oh1.d3, oh1.d4), 1.0);
    assert_eq(sum5f(oh3.d0, oh3.d1, oh3.d2, oh3.d3, oh3.d4), 1.0);
    assert_eq(sum5f(oh4.d0, oh4.d1, oh4.d2, oh4.d3, oh4.d4), 1.0);

    // Verify cross-positions are zero
    assert_eq(oh0.d1, 0.0);
    assert_eq(oh1.d0, 0.0);
    assert_eq(oh3.d4, 0.0);
    assert_eq(oh4.d3, 0.0);
    print("  test_one_hot_multi: ok");
}

@test
fn test_nonzero_sparse() {
    // Sparse array: nonzero at positions 1 and 3
    let sparse = Arr5 { d0: 0.0, d1: 7.0, d2: 0.0, d3: -3.0, d4: 0.0 };

    assert_eq(count_nonzero(sparse), 2);
    assert_eq(first_nonzero(sparse), 1);

    // Verify all-zero array
    let zeros = Arr5 { d0: 0.0, d1: 0.0, d2: 0.0, d3: 0.0, d4: 0.0 };
    assert_eq(count_nonzero(zeros), 0);
    let neg1 = 0 - 1;
    assert_eq(first_nonzero(zeros), neg1);
    print("  test_nonzero_sparse: ok");
}

@test
fn test_nonzero_all() {
    // All elements nonzero
    let dense = Arr5 { d0: 1.0, d1: -2.0, d2: 3.0, d3: -4.0, d4: 5.0 };

    assert_eq(count_nonzero(dense), 5);
    assert_eq(first_nonzero(dense), 0);

    // Single nonzero at last position
    let last = Arr5 { d0: 0.0, d1: 0.0, d2: 0.0, d3: 0.0, d4: 42.0 };
    assert_eq(count_nonzero(last), 1);
    assert_eq(first_nonzero(last), 4);
    print("  test_nonzero_all: ok");
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_one_hot_basic();
    test_one_hot_multi();
    test_nonzero_sparse();
    test_nonzero_all();

    print("[OK] 010_one_hot_nonzero");
    0
}
