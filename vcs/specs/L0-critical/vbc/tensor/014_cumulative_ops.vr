// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: vbc, tensor, cumulative, cumsum, cumprod, cummax, cummin
// @timeout: 50000
// @expected-exit: 0
// @description: Cumulative operations — cumsum, cumprod, cummax, cummin

// =============================================================================
// Helpers
// =============================================================================

fn abs_f(x: Float) -> Float {
    if x < 0.0 { 0.0 - x } else { x }
}

type Arr4 is { d0: Float, d1: Float, d2: Float, d3: Float };

fn arr4_get(a: Arr4, idx: Int) -> Float {
    if idx == 0 { a.d0 }
    else if idx == 1 { a.d1 }
    else if idx == 2 { a.d2 }
    else { a.d3 }
}

// cumsum using individual float parameters (avoids record-field addition bug)
fn cumsum4f(v0: Float, v1: Float, v2: Float, v3: Float) -> Arr4 {
    let s0 = v0;
    let s1 = s0 + v1;
    let s2 = s1 + v2;
    let s3 = s2 + v3;
    Arr4 { d0: s0, d1: s1, d2: s2, d3: s3 }
}

// cumprod using individual float parameters
fn cumprod4f(v0: Float, v1: Float, v2: Float, v3: Float) -> Arr4 {
    let p0 = v0;
    let p1 = p0 * v1;
    let p2 = p1 * v2;
    let p3 = p2 * v3;
    Arr4 { d0: p0, d1: p1, d2: p2, d3: p3 }
}

fn max_f(a: Float, b: Float) -> Float {
    if a >= b { a } else { b }
}

fn min_f(a: Float, b: Float) -> Float {
    if a <= b { a } else { b }
}

// cummax using individual float parameters
fn cummax4f(v0: Float, v1: Float, v2: Float, v3: Float) -> Arr4 {
    let m0 = v0;
    let m1 = max_f(m0, v1);
    let m2 = max_f(m1, v2);
    let m3 = max_f(m2, v3);
    Arr4 { d0: m0, d1: m1, d2: m2, d3: m3 }
}

// cummin using individual float parameters
fn cummin4f(v0: Float, v1: Float, v2: Float, v3: Float) -> Arr4 {
    let m0 = v0;
    let m1 = min_f(m0, v1);
    let m2 = min_f(m1, v2);
    let m3 = min_f(m2, v3);
    Arr4 { d0: m0, d1: m1, d2: m2, d3: m3 }
}

// =============================================================================
// Tests
// =============================================================================

@test
fn test_cumsum() {
    // [1, 2, 3, 4] -> [1, 3, 6, 10]
    let cs = cumsum4f(1.0, 2.0, 3.0, 4.0);

    assert_eq(cs.d0, 1.0);
    assert_eq(cs.d1, 3.0);
    assert_eq(cs.d2, 6.0);
    assert_eq(cs.d3, 10.0);

    // With negative values: [5, -2, 3, -1] -> [5, 3, 6, 5]
    let cs2 = cumsum4f(5.0, -2.0, 3.0, -1.0);
    assert_eq(cs2.d0, 5.0);
    assert_eq(cs2.d1, 3.0);
    assert_eq(cs2.d2, 6.0);
    assert_eq(cs2.d3, 5.0);
    print("  test_cumsum: ok");
}

@test
fn test_cumprod() {
    // [1, 2, 3, 4] -> [1, 2, 6, 24]
    let cp = cumprod4f(1.0, 2.0, 3.0, 4.0);

    assert_eq(cp.d0, 1.0);
    assert_eq(cp.d1, 2.0);
    assert_eq(cp.d2, 6.0);
    assert_eq(cp.d3, 24.0);

    // With a zero: [2, 3, 0, 5] -> [2, 6, 0, 0]
    let cp2 = cumprod4f(2.0, 3.0, 0.0, 5.0);
    assert_eq(cp2.d0, 2.0);
    assert_eq(cp2.d1, 6.0);
    assert_eq(cp2.d2, 0.0);
    assert_eq(cp2.d3, 0.0);
    print("  test_cumprod: ok");
}

@test
fn test_cummax() {
    // [3, 1, 4, 1] -> [3, 3, 4, 4]
    let cm = cummax4f(3.0, 1.0, 4.0, 1.0);

    assert_eq(cm.d0, 3.0);
    assert_eq(cm.d1, 3.0);
    assert_eq(cm.d2, 4.0);
    assert_eq(cm.d3, 4.0);

    // Monotonically increasing: [1, 2, 3, 4] -> [1, 2, 3, 4]
    let cm2 = cummax4f(1.0, 2.0, 3.0, 4.0);
    assert_eq(cm2.d0, 1.0);
    assert_eq(cm2.d1, 2.0);
    assert_eq(cm2.d2, 3.0);
    assert_eq(cm2.d3, 4.0);
    print("  test_cummax: ok");
}

@test
fn test_cummin() {
    // [3, 1, 4, 1] -> [3, 1, 1, 1]
    let cm = cummin4f(3.0, 1.0, 4.0, 1.0);

    assert_eq(cm.d0, 3.0);
    assert_eq(cm.d1, 1.0);
    assert_eq(cm.d2, 1.0);
    assert_eq(cm.d3, 1.0);

    // Monotonically decreasing: [4, 3, 2, 1] -> [4, 3, 2, 1]
    let cm2 = cummin4f(4.0, 3.0, 2.0, 1.0);
    assert_eq(cm2.d0, 4.0);
    assert_eq(cm2.d1, 3.0);
    assert_eq(cm2.d2, 2.0);
    assert_eq(cm2.d3, 1.0);
    print("  test_cummin: ok");
}

// =============================================================================
// Main
// =============================================================================

fn main() -> Int {
    test_cumsum();
    test_cumprod();
    test_cummax();
    test_cummin();

    print("[OK] 014_cumulative_ops");
    0
}
