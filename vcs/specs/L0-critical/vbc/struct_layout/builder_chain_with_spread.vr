// @test: run
// @tier: 0
// @level: L0
// @tags: vbc, struct-layout, builder-pattern, regression
// @expected-stdout: ok
// @expected-exit: 0
// @description: Regression — chained builders using `..self` spread must
//               preserve the full struct layout across calls.
//
// Minimal reproducer for a bug where the second (and further) builder
// call in a chain returns a struct with truncated layout, so a later
// field write triggers "field write out of bounds: field index N
// exceeds object data size M" in the VBC interpreter.

type Config is {
    a: Int,
    b: Int,
    c: Int,
    d: Int,
    e: Int,
    f: Int,
};

implement Config {
    public fn new() -> Config {
        Config { a: 0, b: 0, c: 0, d: 0, e: 0, f: 0 }
    }
    public fn with_a(self, v: Int) -> Config { Config { a: v, ..self } }
    public fn with_b(self, v: Int) -> Config { Config { b: v, ..self } }
    public fn with_c(self, v: Int) -> Config { Config { c: v, ..self } }
    public fn with_d(self, v: Int) -> Config { Config { d: v, ..self } }
    public fn with_e(self, v: Int) -> Config { Config { e: v, ..self } }
    public fn with_f(self, v: Int) -> Config { Config { f: v, ..self } }
}

fn main() {
    // One builder — passes today.
    let single = Config.new().with_a(1);
    assert_eq(single.a, 1);
    assert_eq(single.f, 0);

    // Two builders — regression: second write used to fail.
    let pair = Config.new().with_a(1).with_b(2);
    assert_eq(pair.a, 1);
    assert_eq(pair.b, 2);
    assert_eq(pair.f, 0);

    // Full chain — stresses the layout across every field.
    let full = Config.new()
        .with_a(1)
        .with_b(2)
        .with_c(3)
        .with_d(4)
        .with_e(5)
        .with_f(6);
    assert_eq(full.a, 1);
    assert_eq(full.b, 2);
    assert_eq(full.c, 3);
    assert_eq(full.d, 4);
    assert_eq(full.e, 5);
    assert_eq(full.f, 6);

    print("ok");
}
