//
// Pinning tests for round-2 vectors already in DEFENSE state but missing
// explicit guardrails. Each section maps to a specific round-2 vector
// from `vcs/red-team/round-2-implementation.md`.
//
// Audit: vcs/red-team/round-2-implementation.md (post-2026-04-28).

// -----------------------------------------------------------------------------
// §2.4 — Recursive impl blocks (DEFENSE CONFIRMED)
// -----------------------------------------------------------------------------
// The closure-walker terminates on impl-block cycles. Mutually-recursive
// types implementing each other's protocols compile without infinite loop.

module impl_a {
    pub type AType is { value: Int };
    pub type AProtocol is protocol {
        fn produce_a(&self) -> AType;
    };
}

module impl_b {
    mount cog.impl_a.{AType, AProtocol};

    pub type BType is { label: Text };
    pub type BProtocol is protocol {
        fn produce_b(&self) -> BType;
    };
}

module impl_recursive_pair {
    mount cog.impl_a.{AType, AProtocol};
    mount cog.impl_b.{BType, BProtocol};

    // Both types implement BOTH protocols — closure walker must
    // terminate on the resulting impl-graph cycle.
    implement AProtocol for AType {
        fn produce_a(&self) -> AType { *self }
    }

    implement BProtocol for AType {
        fn produce_b(&self) -> BType { BType { label: "from-a" } }
    }

    implement AProtocol for BType {
        fn produce_a(&self) -> AType { AType { value: 0 } }
    }

    implement BProtocol for BType {
        fn produce_b(&self) -> BType { *self }
    }
}

// -----------------------------------------------------------------------------
// §5.1 — Module cycle A→B→A (DEFENSE CONFIRMED)
// -----------------------------------------------------------------------------
// Verum allows cyclic module dependencies through references; the closure
// walker handles cycles without infinite recursion. (Exercised at deeper
// scale by `circular_type_dependency.vr`; this module pins a 4-cycle.)

module cycle_w {
    mount cog.cycle_x.XType;
    pub type WType is { x_ref: Maybe<&XType> };
}

module cycle_x {
    mount cog.cycle_y.YType;
    pub type XType is { y_ref: Maybe<&YType> };
}

module cycle_y {
    mount cog.cycle_z.ZType;
    pub type YType is { z_ref: Maybe<&ZType> };
}

module cycle_z {
    mount cog.cycle_w.WType;
    pub type ZType is { w_ref: Maybe<&WType> };
}

// -----------------------------------------------------------------------------
// §5.2 — 4-level deep super chain (DEFENSE CONFIRMED)
// -----------------------------------------------------------------------------
// `super.super.super.super.X` is a no-op at the lexer level; no
// confused-deputy escape via deep super-chains.

module super_outer {
    pub type OuterT is { tag: Int };
}

module super_outer.middle1 {
    pub type Middle1T is { inner: Int };
}

module super_outer.middle1.middle2 {
    pub type Middle2T is { inner: Int };
}

module super_outer.middle1.middle2.middle3 {
    pub type Middle3T is { inner: Int };
}

module super_outer.middle1.middle2.middle3.deep {
    // Reach back up through 4 levels of super.
    mount super.super.super.super.OuterT;

    pub fn use_outer(o: OuterT) -> Int {
        o.tag
    }
}

// -----------------------------------------------------------------------------
// §3.4 — Frame-stack overflow recipe (DEFENSE CONFIRMED)
// -----------------------------------------------------------------------------
// `try_push_frame` is fallible by design (interpreter/registers.rs:117).
// Every caller routes through it (`grep frame_stack.push` outside the
// wrapper found zero direct-push violations per the audit).
//
// The Rust-level unit test `test_stack_overflow` in
// crates/verum_vbc/src/interpreter/stack.rs:294 pins this. Surface-level
// check: deep recursion from .vr code surfaces as `StackOverflow`,
// not a runtime panic / segfault.

fn deep_recursion_witness(n: Int) -> Int {
    // No-op recursion — exercises the call-stack until try_push_frame
    // returns Err(StackOverflow) at max_depth. The interpreter
    // surfaces this as InterpreterError::StackOverflow which the
    // verum-test harness sees as a graceful failure, NOT a SIGSEGV.
    if n <= 0 { 0 } else { deep_recursion_witness(n - 1) + 1 }
}

// -----------------------------------------------------------------------------
// §2.3 — Nested generics 32 levels deep (DEFENSE CONFIRMED + guardrail 2026-04-28)
// -----------------------------------------------------------------------------
// Stress on the type-checker's `ast_to_type` recursion-depth handling.
// A 32-level `Maybe<Maybe<…<Int>…>>` chain comfortably exceeds the depths
// real-world code produces while staying well within the type-walker's
// hard recursion-depth cap (currently 64; rejection at 65+ is exercised
// by `vcs/specs/L0-critical/parser/edge_cases/red_team_nested_generic_recursion_limit.vr`).
//
// Pin: this function must parse + type-check + monomorphize without panic
// or stack-overflow.  Should the type-walker ever degrade to unbounded
// recursion, the test suite catches it before a malicious .vr file does.
//
// The body returns `None`, so codegen sees the deeply-nested annotation
// but the runtime sees a plain Maybe — keeping the test orthogonal to
// runtime semantics.

fn deep_generic_witness()
    -> Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<
       Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<
       Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<
       Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Maybe<Int
       >>>>>>>>
       >>>>>>>>
       >>>>>>>>
       >>>>>>>> {
    None
}

fn main() {
    // Smoke check that the impl-cycle, module-cycle, deep-super, and
    // deep-generic graphs all compile without the closure walker
    // infinite-looping or the type-checker stack-overflowing.
    let _ = deep_generic_witness();
    print("L0-critical: red-team round-2 confirmations");
}
