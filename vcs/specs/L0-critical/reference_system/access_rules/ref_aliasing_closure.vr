// @test: typecheck-fail
// @expected-error: closure
// @tier: 0
// @level: L0
// @tags: reference_system, cbgr, access_rules, aliasing, closures, negative-test

/// Test aliasing violation with closure captures.
/// Closure capturing reference prevents other borrows.
/// Verum detects this at COMPILE-TIME via borrow checking.
/// Spec: 04-memory-model.md#closure-captures

fn main() {
    let mut data = [1, 2, 3];

    let read_closure = || {
        // Closure captures &data - acquires read epoch capability
        let mut sum = 0;
        for item in &data {
            sum = sum + item;
        }
        sum
    };

    data.push(4);                   // Mutation attempt - requires exclusive write capability
    // PANIC: epoch violation (closure holds read capability on data)

    print(read_closure());
}
