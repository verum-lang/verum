// @test: typecheck-fail
// @expected-error: E310
// @tier: 0
// @level: L0
// @tags: reference_system, cbgr, access_rules, conflict, negative-test

/// Test that borrowing conflicts are detected at compile-time via borrow checking.
/// Cannot mutate while immutable reference exists.
/// Verum detects this at COMPILE-TIME via borrow checking.
/// Spec: 04-memory-model.md#aliasing-rules

fn main() {
    let mut data = [1, 2, 3, 0];

    let first = &data[0];  // Immutable reference - acquires read epoch capability
    data[3] = 4;  // Mutation attempt - requires exclusive write capability
    // PANIC: epoch violation (read capability still held by first)
    print(*first);
}
