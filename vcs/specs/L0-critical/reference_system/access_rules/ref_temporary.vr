// @test: typecheck-pass
// @tier: all
// @level: L0
// @tags: reference_system, cbgr, access_rules, temporary, lifetime-extension

/// Test borrowing from temporary values.
/// Temporaries have their lifetime extended when borrowed.
/// Spec: 04-memory-model.md#temporary-lifetime

fn main() {
    test_temporary_borrow();
    test_temporary_in_expression();
    test_temporary_method_chain();
    test_temporary_in_match();
}

/// Test basic temporary borrowing
fn test_temporary_borrow() {
    // Temporary Text's lifetime extended for the borrow
    let ref_temp: &Text = &Text.from("temporary");

    // ref_temp is valid for the statement - compare via len()
    assert(ref_temp.len() == 9);
}

/// Test temporary in complex expression
fn test_temporary_in_expression() {
    // Temporary created in function call
    let len = get_length(&Text.from("inline temp"));

    assert(len == 11);
}

fn get_length(s: &Text) -> Int {
    s.len()
}

/// Test temporary in method chain
fn test_temporary_method_chain() {
    // Each step may create temporaries - simplified to avoid complex iterator chains
    let arr = [1, 2, 3, 4, 5];
    let mut result = 0;

    // Manually compute: filter elements > 2, double them, sum
    // Elements > 2: 3, 4, 5 -> doubled: 6, 8, 10 -> sum: 24
    let mut i = 0;
    while i < 5 {
        let val = arr[i];
        if val > 2 {
            result = result + (val * 2);
        }
        i = i + 1;
    }

    assert(result == 24);  // 6 + 8 + 10
}

/// Test temporary in match expression
fn test_temporary_in_match() {
    // Temporary Maybe created and matched - use Maybe<Int> for simpler type inference
    let maybe_value: Maybe<Int> = Some(42);
    match maybe_value {
        Some(v) => assert(v == 42),
        None => panic("Expected Some"),
    }
}

/// Test nested temporary borrows
fn test_nested_temporaries() {
    // Multiple nested temporaries
    let result = process_pair(
        &Text.from("first"),
        &Text.from("second"),
    );

    assert(result == "first-second");
}

fn process_pair(a: &Text, b: &Text) -> Text {
    *a + "-" + *b
}

/// Test temporary struct
fn test_temporary_struct() {
    let ref_point: &Point = &Point { x: 10, y: 20 };

    assert(ref_point.x == 10);
    assert(ref_point.y == 20);
}

/// Test temporary with conditional
fn test_conditional_temporary() {
    let condition = true;

    let value = if condition {
        let temp = Text.from("true branch");
        temp.len()
    } else {
        let temp = Text.from("false");
        temp.len()
    };

    assert(value == 11);
}

type Point is {
    x: Int,
    y: Int,
};
