// @test: typecheck-fail
// @expected-error: E310
// @tier: 0
// @level: L0
// @tags: reference_system, cbgr, access_rules, aliasing, negative-test

/// Test that multiple mutable references cause compile-time error.
/// Only one mutable reference to data can exist at a time.
/// This prevents data races and iterator invalidation.
/// Verum detects this at COMPILE-TIME via borrow checking.
/// Spec: 04-memory-model.md#aliasing-rules

fn main() {
    let mut data = [1, 2, 3, 4, 5];

    let ref1 = &mut data;      // First mutable reference - acquires exclusive epoch capability
    let ref2 = &mut data;      // Second mutable reference attempt
    // CBGR detects epoch violation at runtime

    ref1.push(6);  // PANIC: epoch violation (multiple exclusive capabilities)
    ref2.push(7);
}
