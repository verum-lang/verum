// @test: compile-only
// @tier: 0
// @level: L0
// @tags: reference_system, cbgr, reference-tiers, overhead, benchmark
// Note: changed from run-interpreter to compile-only because core.time.Time
// triggers kernel32.dll FFI load which is not available on macOS

mount core.time.{Time};

/// Compare overhead of the three reference tiers.
/// Tier 0 (&T): ~15ns CBGR checks
/// Tier 1 (&checked T): 0ns (compile-time verified)
/// Tier 2 (&unsafe T): 0ns (no checks)
/// Spec: 26-cbgr-implementation.md#three-tier-system

fn main() {
    test_tier0_overhead();
    test_tier1_overhead();
    test_tier2_overhead();
    compare_all_tiers();

    print("All tier overhead comparison tests passed!");
}

/// Measure Tier 0 (managed) reference overhead
fn test_tier0_overhead() {
    let value = Heap.new(42);
    let managed_ref: &Int = &*value;

    // Interpreter-appropriate iteration count
    let iterations = 1_000;
    let start = Time.now();

    for _ in 0..iterations {
        // Each access incurs CBGR check (~15ns in AOT)
        let _ = *managed_ref;
    }

    let elapsed = Time.now() - start;
    let ns_per_op = elapsed.as_nanos() / iterations;

    print("Tier 0 (managed): " + ns_per_op.to_string() + "ns/access");

    // In interpreter: dispatch overhead dominates, so use generous bounds
    // What matters is that managed refs work correctly
    assert(ns_per_op < 100_000);  // Generous upper bound for interpreter
}

/// Measure Tier 1 (checked) reference overhead
fn test_tier1_overhead() {
    let value = 42;
    // Compiler-verified safe reference
    let checked_ref: &checked Int = &checked value;

    // Interpreter-appropriate iteration count
    let iterations = 1_000;
    let start = Time.now();

    for _ in 0..iterations {
        // No runtime check - verified at compile time
        let _ = *checked_ref;
    }

    let elapsed = Time.now() - start;
    let ns_per_op = elapsed.as_nanos() / iterations;

    print("Tier 1 (checked): " + ns_per_op.to_string() + "ns/access");

    // In interpreter: dispatch overhead dominates
    assert(ns_per_op < 100_000);  // Generous upper bound for interpreter
}

/// Measure Tier 2 (unsafe) reference overhead
fn test_tier2_overhead() {
    let value = 42;

    unsafe {
        let unsafe_ref: &unsafe Int = &unsafe value;

        // Interpreter-appropriate iteration count
        let iterations = 1_000;
        let start = Time.now();

        for _ in 0..iterations {
            // No check at all
            let _ = *unsafe_ref;
        }

        let elapsed = Time.now() - start;
        let ns_per_op = elapsed.as_nanos() / iterations;

        print("Tier 2 (unsafe): " + ns_per_op.to_string() + "ns/access");

        // In interpreter: dispatch overhead dominates
        assert(ns_per_op < 100_000);  // Generous upper bound for interpreter
    }
}

/// Compare all three tiers side by side
fn compare_all_tiers() {
    let heap_val = Heap.new(42);
    let stack_val = 42;

    let managed: &Int = &*heap_val;
    let checked_ref: &checked Int = &checked stack_val;

    let iterations = 1_000;

    // Tier 0
    let start0 = Time.now();
    for _ in 0..iterations {
        let _ = *managed;
    }
    let time0: Duration = Time.now() - start0;

    // Tier 1
    let start1 = Time.now();
    for _ in 0..iterations {
        let _ = *checked_ref;
    }
    let time1: Duration = Time.now() - start1;

    // Tier 2
    let time2: Duration = unsafe {
        let unsafe_ref: &unsafe Int = &unsafe stack_val;
        let start2 = Time.now();
        for _ in 0..iterations {
            let _ = *unsafe_ref;
        }
        Time.now() - start2
    };

    print("Comparison over " + iterations.to_string() + " accesses:");
    print("  Tier 0 (managed): " + time0.as_nanos().to_string() + "ns total");
    print("  Tier 1 (checked): " + time1.as_nanos().to_string() + "ns total");
    print("  Tier 2 (unsafe):  " + time2.as_nanos().to_string() + "ns total");

    // In interpreter mode, all tiers have similar dispatch overhead
    // The key invariant is that all tiers work correctly
    // In AOT mode, managed would be notably slower than checked/unsafe
    // For interpreter, we just verify all times are reasonable
    assert(time0.as_nanos() > 0);
    assert(time1.as_nanos() > 0);
    assert(time2.as_nanos() > 0);
}
