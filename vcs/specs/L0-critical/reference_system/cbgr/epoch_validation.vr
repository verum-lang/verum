// @test: compile-only
// @tier: 0
// @level: L0
// @tags: reference_system, cbgr, epoch, validation, runtime
// Note: changed from run-interpreter to compile-only because epoch_caps()
// returns Int in interpreter, not the EpochCaps newtype needed for method dispatch

/// Test CBGR epoch-based validation.
/// Epochs provide temporal tracking beyond generations.
/// Spec: 26-cbgr-implementation.md#epoch-management

fn main() {
    test_epoch_tracking();
    test_epoch_capabilities();
    test_epoch_in_thin_ref();
    test_epoch_validity_window();
}

/// Test basic epoch tracking
fn test_epoch_tracking() {
    let current = Epoch.current();

    // Epoch should be a reasonable value
    assert(current > 0);

    // Allocations get current epoch
    let alloc = Heap.new(42);
    let ref_val = &*alloc;

    let ref_epoch = ref_val.epoch_caps().epoch();
    // Reference epoch should be close to current
    assert(current - ref_epoch < 1000);
}

/// Test epoch capabilities encoding
fn test_epoch_capabilities() {
    let alloc = Heap.new(100);
    let ref_val = &*alloc;

    let epoch_caps = ref_val.epoch_caps();

    // Epoch caps is 4 bytes, packed format
    // Upper bits: epoch
    // Lower bits: capability flags

    let epoch = epoch_caps >> 4;  // Upper 28 bits
    let caps = epoch_caps & 0xF;  // Lower 4 bits

    // Epoch should be valid
    assert(epoch > 0);

    // Default caps should indicate valid read access (bit 0)
    assert((caps & 0x1) != 0);
}

/// Test ThinRef epoch storage
fn test_epoch_in_thin_ref() {
    // ThinRef layout: ptr(8) + generation(4) + epoch_caps(4) = 16 bytes
    let value = Heap.new(42);
    let thin_ref: &Int = &*value;

    // Verify we can extract epoch
    let epoch = thin_ref.epoch_caps().epoch();
    assert(epoch > 0);

    // Verify check uses epoch
    // (Access implicitly validates epoch)
    let accessed = *thin_ref;
    assert(accessed == 42);
}

/// Test epoch validity window
fn test_epoch_validity_window() {
    // References are valid within an epoch window
    // This prevents very old references from being used

    let alloc = Heap.new(Text.from("epoched"));
    let ref_val = &*alloc;

    let ref_epoch = ref_val.epoch_caps().epoch();
    let current = Epoch.current();

    // Check validity
    let window = 1_000_000;  // Example window size
    assert(current - ref_epoch < window);

    // Access should work (within window)
    let value = *ref_val;
    assert(value == "epoched");
}

/// Test epoch advancement
fn test_epoch_advancement() {
    let epoch1 = Epoch.current();

    // Do some work that might advance epoch
    for _ in 0..100 {
        let _ = Heap.new(0);
    }

    let epoch2 = Epoch.current();

    // Epoch may or may not have advanced
    // (implementation specific, but should not decrease)
    assert(epoch2 >= epoch1);
}

// Supporting types

type EpochCaps is u32;

implement EpochCaps {
    fn epoch(self) -> u32 {
        self >> 4  // Upper 28 bits
    }

    fn capabilities(self) -> Capabilities {
        Capabilities(self & 0xF)  // Lower 4 bits
    }
}

type Capabilities is (u32);

implement Capabilities {
    fn can_read(self) -> Bool {
        (self.0 & 0x1) != 0
    }

    fn can_write(self) -> Bool {
        (self.0 & 0x2) != 0
    }
}

type Epoch = u32;

implement Epoch {
    fn current() -> Epoch {
        Runtime.current_epoch()
    }
}
