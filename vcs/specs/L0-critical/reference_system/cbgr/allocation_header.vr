// @test: run-interpreter
// @tier: 0
// @level: L0
// @tags: reference_system, cbgr, allocation, header, layout

/// Test CBGR allocation header behavior.
/// Every heap allocation has a 32-byte header with generation info.
/// Spec: 26-cbgr-implementation.md#allocation-header
/// Source: verum_common/src/cbgr.rs AllocationHeader
///
/// AllocationHeader layout (32 bytes):
/// - bytes 0-3:   size (u32)
/// - bytes 4-7:   alignment (u32)
/// - bytes 8-11:  generation (u32)
/// - bytes 12-13: epoch (u16)
/// - bytes 14-15: capabilities (u16)
/// - bytes 16-19: type_id (u32)
/// - bytes 20-23: flags (u32)
/// - bytes 24-31: reserved (u64)

fn main() {
    test_generation_tracking();
    test_epoch_tracking();
    test_generation_update_on_free();
    test_multiple_allocations_different_generations();
    test_capability_flags();
    print("All allocation header tests passed!");
}

/// Test that allocations have valid generations
fn test_generation_tracking() {
    print("  [TEST] test_generation_tracking");

    let value = Heap.new(42);
    let ref_val = &*value;

    // Get generation from reference - should be > 0
    let gen = ref_val.stored_generation();
    assert(gen > 0);

    print("  [OK] test_generation_tracking");
}

/// Test epoch tracking on allocations
fn test_epoch_tracking() {
    print("  [TEST] test_epoch_tracking");

    let value = Heap.new(100);
    let ref_val = &*value;

    // Get epoch_caps from reference
    let epoch_caps = ref_val.epoch_caps();
    // epoch_caps encodes: ((epoch & 0x00FF_FFFF) << 8) | capabilities
    // Capabilities should have at least read bit set
    let caps = epoch_caps & 0xFF;
    assert(caps > 0);  // Should have at least one capability

    print("  [OK] test_epoch_tracking");
}

/// Test that generation changes on deallocation
fn test_generation_update_on_free() {
    print("  [TEST] test_generation_update_on_free");

    let gen_before: Int;

    // Scope to create and drop allocation
    {
        let value = Heap.new(42);
        gen_before = value.generation() as Int;
    }
    // value is dropped here, generation in header should be bumped

    // New allocation may reuse memory but has different generation
    let new_value = Heap.new(100);
    let gen_after = new_value.generation() as Int;

    // Even if same memory is reused, generation differs
    // (Either because allocator returned different memory,
    // or because the freed slot's generation was bumped)
    assert(gen_after != gen_before);

    print("  [OK] test_generation_update_on_free");
}

/// Test that different allocations have different generations
fn test_multiple_allocations_different_generations() {
    print("  [TEST] test_multiple_allocations_different_generations");

    // Create several allocations in sequence
    let v1 = Heap.new(1);
    let v2 = Heap.new(2);
    let v3 = Heap.new(3);

    let g1 = v1.generation();
    let g2 = v2.generation();
    let g3 = v3.generation();

    // Each allocation should have a distinct generation
    // (generations increment for each new allocation)
    assert(g1 != g2);
    assert(g2 != g3);
    assert(g1 != g3);

    // Generations should increase monotonically
    assert(g2 > g1);
    assert(g3 > g2);

    print("  [OK] test_multiple_allocations_different_generations");
}

/// Test capability flags in epoch_caps
fn test_capability_flags() {
    print("  [TEST] test_capability_flags");

    let value = Heap.new(42);

    // Create immutable reference - should have read capability
    let ref_val = &*value;
    let caps1 = ref_val.epoch_caps() & 0xFF;
    assert(caps1 & 0x01 != 0);  // Read capability

    // Create mutable reference - should have read+write capabilities
    let mut_ref = &mut *value;
    let caps2 = mut_ref.epoch_caps() & 0xFF;
    assert(caps2 & 0x03 == 0x03);  // Read + Write capabilities

    print("  [OK] test_capability_flags");
}
