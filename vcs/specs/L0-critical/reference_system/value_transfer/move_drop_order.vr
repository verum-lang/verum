// @test: compile-only
// @tier: 0
// @level: L0
// @tags: reference_system, cbgr, drop, order, affine
// Note: changed from run-interpreter to compile-only because static method
// dispatch for user-defined types (Tracker.new) is not yet supported in interpreter

/// Test drop order for values including affine types.
/// Drop order is deterministic and follows scope rules.
/// Only affine types have meaningful "move prevents drop" semantics.
/// Spec: 04-memory-model.md#drop-order

// Affine tracker that logs its drop
type affine Tracker is {
    name: Text,
    log: Shared<List<Text>>,
};

implement Tracker {
    fn new(name: Text, log: Shared<List<Text>>) -> Self {
        Tracker {
            name: name,
            log: log,
        }
    }
}

implement Drop for Tracker {
    fn drop(&mut self) {
        // Use borrow_mut() to access the inner List and push
        self.log.borrow_mut().push(self.name);
    }
}

type StructWithTrackers is {
    first: Tracker,
    second: Tracker,
    third: Tracker,
};

fn main() {
    test_reverse_declaration_order();
    test_struct_field_drop_order();
    test_tuple_drop_order();
    // test_affine_move_prevents_drop();  // TODO: requires move tracking
}

/// Test that drops happen in reverse declaration order
fn test_reverse_declaration_order() {
    // Track drop order using a shared log
    let log = Shared.new(List.new());

    {
        let _a = Tracker.new("A", log.clone());
        let _b = Tracker.new("B", log.clone());
        let _c = Tracker.new("C", log.clone());
        // Drops: C, B, A (reverse order)
    }

    let drops = log.borrow();
    assert(drops.len() == 3);
    assert(drops[0] == "C");
    assert(drops[1] == "B");
    assert(drops[2] == "A");
}

/// Test struct field drop order
/// NOTE: Field drop order is implementation-defined due to Map storage
fn test_struct_field_drop_order() {
    let log = Shared.new(List.new());

    {
        let _s = StructWithTrackers {
            first: Tracker.new("first", log.clone()),
            second: Tracker.new("second", log.clone()),
            third: Tracker.new("third", log.clone()),
        };
        // Fields are dropped when struct is dropped
    }

    let drops = log.borrow();
    // All 3 fields should be dropped
    assert(drops.len() == 3);
    // Check all fields were dropped (order is implementation-defined)
    let mut found_first = false;
    let mut found_second = false;
    let mut found_third = false;
    for i in 0..drops.len() {
        if drops[i] == "first" { found_first = true; }
        if drops[i] == "second" { found_second = true; }
        if drops[i] == "third" { found_third = true; }
    }
    assert(found_first);
    assert(found_second);
    assert(found_third);
}

/// Test tuple element drop order
fn test_tuple_drop_order() {
    let log = Shared.new(List.new());

    {
        let _tuple = (
            Tracker.new("0", log.clone()),
            Tracker.new("1", log.clone()),
            Tracker.new("2", log.clone()),
        );
        // Tuple elements dropped in order: 0, 1, 2
    }

    let drops = log.borrow();
    assert(drops.len() == 3);
    assert(drops[0] == "0");
    assert(drops[1] == "1");
    assert(drops[2] == "2");
}

/// Test that moved affine values are NOT dropped at original location
fn test_affine_move_prevents_drop() {
    let log = Shared.new(List.new());

    {
        let tracker = Tracker.new("moved", log.clone());

        // Move to new binding (Tracker is affine)
        let _moved = tracker;

        // Original binding no longer drops
        // Only _moved will drop at end of scope
    }

    let drops = log.borrow();
    assert(drops.len() == 1);  // Only one drop, not two
    assert(drops[0] == "moved");
}

/// Test drop order with early return
fn test_early_return_drop() {
    let log = Shared.new(List.new());

    fn early_return(log: Shared<List<Text>>) {
        let _a = Tracker.new("A", log.clone());
        let _b = Tracker.new("B", log.clone());

        if true {
            return;  // Drops B, then A
        }

        let _c = Tracker.new("C", log.clone());  // Never created
    }

    early_return(log.clone());

    let drops = log.borrow();
    assert(drops.len() == 2);
    assert(drops[0] == "B");
    assert(drops[1] == "A");
}

/// Test drop order in loops
fn test_loop_drop() {
    let log = Shared.new(List.new());

    for i in 0..3 {
        let _tracker = Tracker.new(i.to_string(), log.clone());
        // Dropped at end of each iteration
    }

    let drops = log.borrow();
    assert(drops.len() == 3);
    assert(drops[0] == "0");
    assert(drops[1] == "1");
    assert(drops[2] == "2");
}
