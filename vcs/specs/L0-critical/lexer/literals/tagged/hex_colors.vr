// @test: parse-pass
// @tier: all
// @level: L0
// @tags: lexer, literals, tagged, color, hex

// Hex color literal syntax

fn test_6_digit_rgb_colors() {
    // 6-digit RGB colors (full format)
    let red = #FF0000;
    let green = #00FF00;
    let blue = #0000FF;
    let white = #FFFFFF;
    let black = #000000;
}

fn test_common_web_colors() {
    // Common web colors
    let orange = #FFA500;
    let yellow = #FFFF00;
    let purple = #800080;
    let pink = #FFC0CB;
    let cyan = #00FFFF;
    let magenta = #FF00FF;
}

fn test_expanded_shorthand_rgb() {
    // Expanded from 3-digit shorthand RGB (e.g. #F00 -> #FF0000)
    let red_expanded = #FF0000;
    let green_expanded = #00FF00;
    let blue_expanded = #0000FF;
    let white_expanded = #FFFFFF;
    let black_expanded = #000000;
}

fn test_8_digit_rgba_colors() {
    // 8-digit RGBA colors (with alpha)
    let red_alpha = #FF0000FF;      // Fully opaque red
    let semi_transparent = #FF000080;  // 50% transparent red
    let transparent_white = #FFFFFF00;  // Fully transparent white
    let semi_blue = #0000FF7F;      // ~50% transparent blue
}

fn test_expanded_shorthand_rgba() {
    // Expanded from 4-digit shorthand RGBA (e.g. #F00F -> #FF0000FF)
    let red_alpha_expanded = #FF0000FF;
    let transparent_expanded = #FFFFFF00;
}

fn test_lowercase_variant() {
    // Lowercase variant
    let lowercase_red = #ff0000;
    let lowercase_green = #00ff00;
    let lowercase_blue = #0000ff;
}

fn test_mixed_case() {
    // Mixed case
    let mixed_case = #FfAa00;
}

