    // Pastel colors
    let pastel_pink = #FFD1DC;
    let pastel_blue = #AEC6CF;
    let pastel_green = #77DD77;
    let pastel_yellow = #FDFD96;
    let pastel_purple = #B19CD9;
}

fn test_brand_colors() {
    // Brand colors (examples)
    let brand_facebook = #1877F2;
    let brand_twitter = #1DA1F2;
    let brand_github = #333333;
    let brand_spotify = #1DB954;
}

fn test_color_in_expressions() {
    // Color in expressions
    let primary = #3498DB;
    let secondary = #2ECC71;
    let is_same = primary == secondary;
}

fn test_color_arithmetic() {
    // Color arithmetic (if supported)
    let darkened = #FF0000.darken(0.2);
    let lightened = #FF0000.lighten(0.2);
    let mixed = #FF0000.mix(#0000FF, 0.5);
}

// Color in function parameters
fn set_background(color: Color) {
    element.style.background_color = color
}

fn test_function_call() {
    set_background(#F5F5F5);
}

// Color in structs
type Theme is {
    primary: Color,
    secondary: Color,
    background: Color,
    text_color: Color,
};

fn test_color_in_structs() {
    let dark_theme = Theme {
        primary: #BB86FC,
        secondary: #03DAC6,
        background: #121212,
        text_color: #FFFFFF,
    };

    let light_theme = Theme {
        primary: #6200EE,
        secondary: #03DAC6,
        background: #FFFFFF,
        text_color: #000000,
    };
}

fn test_color_in_arrays() {
    // Color in arrays
    let palette = [#FF0000, #FF7F00, #FFFF00, #00FF00, #0000FF, #4B0082, #9400D3];
    let gradient = [#000000, #333333, #666666, #999999, #CCCCCC, #FFFFFF];
}

fn test_color_in_maps() {
    // Color in maps
    let color_names: Map<Text, Color> = {
        "red": #FF0000,
        "green": #00FF00,
        "blue": #0000FF,
    };
}

fn test_color_conversion() {
    // Color conversion
    let rgb = #FF5733;
    let hsl = rgb.to_hsl();
    let hsv = rgb.to_hsv();
    let cmyk = rgb.to_cmyk();
}

fn test_color_components() {
    // Color components
    let color = #FF8800;
    let r = color.red();
    let g = color.green();
    let b = color.blue();
    let a = color.alpha();
}

fn test_color_from_components() {
    // Color from components
    let from_rgb = Color.rgb(255, 136, 0);
    let from_rgba = Color.rgba(255, 136, 0, 128);
    let from_hsl = Color.hsl(32, 100, 50);
}

// Color comparison
fn color_category(c: Color) -> Text {
    // Using if-else for color comparison since hex literals in patterns
    // may not be supported in all contexts
    if c == #FF0000 {
        "pure red"
    } else if c == #00FF00 {
        "pure green"
    } else if c == #0000FF {
        "pure blue"
    } else if c.red() > 200 {
        "reddish"
    } else if c.green() > 200 {
        "greenish"
    } else if c.blue() > 200 {
        "bluish"
    } else {
        "mixed"
    }
}

fn test_color_interpolation() {
    // Color interpolation
    let start_color = #FF0000;
    let end_color = #0000FF;
    let midpoint = start_color.lerp(end_color, 0.5);
}

fn test_contrast_calculation() {
    // Contrast calculation
    let bg = #FFFFFF;
    let fg = #000000;
    let contrast_ratio = bg.contrast_ratio(fg);
    let is_accessible = contrast_ratio >= 4.5;
}

fn test_color_with_alpha_operations() {
    // Color with alpha operations
    let base = #FF0000;
    let with_alpha = base.with_alpha(0.5);
    let opaque = with_alpha.opaque();
}
