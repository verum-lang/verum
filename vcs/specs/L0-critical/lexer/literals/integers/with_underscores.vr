// @test: parse-pass
// @tier: all
// @level: L0
// @tags: lexer, literals, integers, underscores, separators

// Integer literals with underscore separators

fn test_decimal_with_thousands_separators() {
    // Decimal with thousands separators
    let thousand = 1_000;
    let million = 1_000_000;
    let billion = 1_000_000_000;
    let trillion = 1_000_000_000_000;
}

fn test_large_numbers_with_grouping() {
    // Large numbers with grouping
    let large_num = 123_456_789;
    let bigger = 9_876_543_210;
    let phone_style = 555_123_4567;
}

fn test_grouping_by_different_units() {
    // Grouping by different units
    let by_hundreds = 12_34_56;  // Indian numbering style
    let by_thousands = 123_456_789;
}

fn test_hexadecimal_with_byte_grouping() {
    // Hexadecimal with byte grouping
    let hex_bytes = 0xFF_FF_FF_FF;
    let hex_words = 0xFFFF_FFFF;
    let hex_nibbles = 0xF_F_F_F;
    let hex_address = 0x0000_1000_0000_0000;
    let hex_color = 0xFF_88_00;
}

fn test_hexadecimal_common_patterns() {
    // Hexadecimal common patterns
    let hex_grouped = 0xDEAD_BEEF;
    let hex_magic = 0xCAFE_BABE;
    let hex_pattern = 0x1234_5678_9ABC_DEF0;
}

fn test_binary_with_nibble_grouping() {
    // Binary with nibble grouping
    let bin_nibbles = 0b1111_0000;
    let bin_bytes = 0b1111_0000_1111_0000;
    let bin_word = 0b1010_1010_0101_0101;
}

fn test_binary_with_bit_grouping() {
    // Binary with bit grouping
    let bin_pairs = 0b11_00_11_00;
    let bin_singles = 0b1_0_1_0_1_0_1_0;
}

fn test_octal_with_grouping() {
    // Octal with grouping
    let oct_grouped = 0o777_777;
    let oct_perms = 0o7_5_5;
    let oct_mode = 0o4_7_5_5;
}

fn test_underscore_positions() {
    // Underscores at different positions
    let trailing_group = 1000_;
    // let leading_group = _1000  // This is an identifier, not a number

    // Single underscore between every digit
    let separated = 1_2_3_4_5;
}

fn test_underscore_with_type_suffix() {
    // Underscore with type suffix
    let typed_decimal = 1_000i32;
    let typed_hex = 0xFF_FF_u16;
    let typed_bin = 0b1111_0000u8;
}

fn test_in_expressions() {
    // In expressions
    let sum = 1_000 + 2_000;
    let product = 1_000_000 * 2;
    let hex_sum = 0xFF_00 + 0x00_FF;
}

fn test_in_comparisons() {
    let value = 2_000_000;
    let code = 0x1000;
    // In comparisons
    let is_large = value > 1_000_000;
    let is_valid = code >= 0x0000 && code <= 0xFFFF;
}

fn test_in_arrays() {
    // In arrays
    let powers = [1, 10, 100, 1_000, 10_000, 100_000, 1_000_000];
    let hex_values = [0x00_FF, 0xFF_00, 0xFF_FF];
    let bin_flags = [0b0001_0000, 0b0010_0000, 0b0100_0000, 0b1000_0000];
}

// In function calls
fn format_currency(amount: Int) -> Text {
    // amount might be 1_000_000
    ""
}

fn test_cents_representation() {
    let price = 99_99;  // $99.99 in cents
}

fn test_memory_sizes() {
    // Memory sizes
    let kilobyte = 1_024;
    let megabyte = 1_048_576;
    let gigabyte = 1_073_741_824;
}

fn test_time_durations() {
    // Time durations in various units
    let milliseconds = 1_000;
    let microseconds = 1_000_000;
    let nanoseconds = 1_000_000_000;
}

fn test_port_numbers() {
    // Port numbers and network values
    let http_port = 8_080;
    let max_port = 65_535;
}

fn test_ip_components() {
    // IP address components (conceptual)
    let ip_part = 192_168_1_1;  // Note: this is just a number, not actual IP
}

fn test_file_sizes() {
    // File sizes
    let file_size = 4_294_967_296;  // 4GB
}

// Match with underscored literals
fn categorize_size(bytes: Int) -> Text {
    match bytes {
        0..1_024 => "bytes"
        1_024..1_048_576 => "kilobytes"
        1_048_576..1_073_741_824 => "megabytes"
        _ => "gigabytes"
    }
}

fn test_bit_masks() {
    // Bit masks with clear grouping
    let mask_32 = 0xFFFF_FFFF;
    let mask_high = 0xFFFF_0000;
    let mask_low = 0x0000_FFFF;
}
