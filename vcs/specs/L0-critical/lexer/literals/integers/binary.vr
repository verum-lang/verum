// @test: parse-pass
// @tier: all
// @level: L0
// @tags: lexer, literals, integers, binary

// Binary integer literals

fn test_basic_binary() {
    // Basic binary values
    let bin_zero = 0b0;
    let bin_one = 0b1;
    let bin_two = 0b10;
    let bin_three = 0b11;
    let bin_four = 0b100;
}

fn test_byte_values() {
    // Single byte values
    let byte_zero = 0b00000000;
    let byte_one = 0b00000001;
    let byte_max = 0b11111111;
    let byte_half = 0b10000000;
    let byte_alternating = 0b10101010;
    let byte_alternating2 = 0b01010101;
}

fn test_powers_of_two() {
    // Powers of 2
    let p0 = 0b1;
    let p1 = 0b10;
    let p2 = 0b100;
    let p3 = 0b1000;
    let p4 = 0b10000;
    let p5 = 0b100000;
    let p6 = 0b1000000;
    let p7 = 0b10000000;
}

fn test_patterns() {
    // Common patterns
    let all_zeros = 0b0000;
    let all_ones = 0b1111;
    let low_nibble = 0b00001111;
    let high_nibble = 0b11110000;
    let even_bits = 0b01010101;
    let odd_bits = 0b10101010;
}

fn test_word_values() {
    // 16-bit values
    let word_zero = 0b0000000000000000;
    let word_max = 0b1111111111111111;
    let word_pattern = 0b1010101010101010;
}

fn test_underscores() {
    // With underscores for readability (byte grouping)
    let grouped_byte = 0b1111_0000;
    let grouped_word = 0b1111_0000_1111_0000;
    let grouped_dword = 0b1111_0000_1111_0000_1111_0000_1111_0000;
    let nibble_groups = 0b1010_0101_1100_0011;
}

fn test_bit_positions() {
    // Bit positions
    let bit0 = 0b0000_0001;
    let bit1 = 0b0000_0010;
    let bit2 = 0b0000_0100;
    let bit3 = 0b0000_1000;
    let bit4 = 0b0001_0000;
    let bit5 = 0b0010_0000;
    let bit6 = 0b0100_0000;
    let bit7 = 0b1000_0000;
}

fn test_flags() {
    // Bit masks for flags
    let read_flag = 0b001;
    let write_flag = 0b010;
    let execute_flag = 0b100;
    let rw_flags = 0b011;
    let rwx_flags = 0b111;
}

fn test_expressions() {
    // Binary patterns in expressions
    let masked = 0b11110000 & 0b10101010;
    let or_result = 0b1100 | 0b0011;
    let xor_result = 0b1111 ^ 0b1010;
    let not_result = ~0b10101010 & 0xFF;  // Use ~ for bitwise not
    let shifted = 0b1 << 4;
}

fn test_comparisons() {
    let value = 0b1000;
    let n = 8;

    // In comparisons
    let is_bit_set = (value & 0b1000) != 0;
    let is_power_of_two = (n & (n - 1)) == 0;
}

// In match expressions
fn decode_instruction(opcode: Int) -> Text {
    match opcode & 0b11 {
        0b00 => "load"
        0b01 => "store"
        0b10 => "compute"
        0b11 => "branch"
        _ => "unknown"
    }
}

fn test_arrays() {
    // In arrays
    let bits = [0b0001, 0b0010, 0b0100, 0b1000];
    let flags = [0b000, 0b001, 0b010, 0b011, 0b100, 0b101, 0b110, 0b111];
}

// Note: Uppercase 0B prefix not supported in Verum
// Use lowercase 0b prefix only

fn test_minimal() {
    // Minimal binary
    let min_bin = 0b0;
    let min_bin1 = 0b1;
}

fn test_bit_fields() {
    let value = 0b11110000;

    // Binary for bit field extraction
    let mask = 0b0011_1100;
    let extract_bits = (value >> 2) & 0b1111;
}

fn test_complex_patterns() {
    // Complex bit patterns
    let checkered = 0b1010_1010_0101_0101_1010_1010_0101_0101;
    let stripes = 0b1111_0000_1111_0000_1111_0000_1111_0000;
}

fn test_permissions() {
    // Used in permissions/modes
    let owner_read = 0b100_000_000;
    let owner_write = 0b010_000_000;
    let owner_exec = 0b001_000_000;
    let group_read = 0b000_100_000;
    let other_read = 0b000_000_100;
    let full_perms = 0b111_111_111;
}
