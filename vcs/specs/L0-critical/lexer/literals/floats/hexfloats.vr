// @test: parse-pass
// @tier: all
// @level: L0
// @tags: lexer, literals, floats, hexadecimal, hexfloats

// Hexadecimal floating-point literals (IEEE 754 format)

fn test_basic_hex_float_format() {
    // Basic hex float format: 0x<mantissa>p<exponent>
    let hex_one = 0x1p0;           // 1.0
    let hex_two = 0x1p1;           // 2.0
    let hex_four = 0x1p2;          // 4.0
    let hex_half = 0x1p-1;         // 0.5
    let hex_quarter = 0x1p-2;      // 0.25
}

fn test_hex_mantissa_with_fraction() {
    // Hex mantissa with fractional part
    let hex_frac_1 = 0x1.0p0;      // 1.0
    let hex_frac_2 = 0x1.8p0;      // 1.5 (1 + 0.5)
    let hex_frac_3 = 0x1.Cp0;      // 1.75 (1 + 0.5 + 0.25)
    let hex_frac_4 = 0x1.Fp0;      // 1.9375
}

fn test_lowercase_hex_digits() {
    // Lowercase hex digits
    let hex_lower_a = 0x1.ap0;
    let hex_lower_b = 0x1.bp0;
    let hex_lower_c = 0x1.cp0;
    let hex_lower_d = 0x1.dp0;
    let hex_lower_e = 0x1.ep0;
    let hex_lower_f = 0x1.fp0;
}

fn test_uppercase_hex_digits() {
    // Uppercase hex digits
    let hex_upper_A = 0x1.Ap0;
    let hex_upper_B = 0x1.Bp0;
    let hex_upper_C = 0x1.Cp0;
    let hex_upper_D = 0x1.Dp0;
    let hex_upper_E = 0x1.Ep0;
    let hex_upper_F = 0x1.Fp0;
}

fn test_positive_exponents() {
    // Positive exponents with P
    let hex_exp_p0 = 0x1p0;
    let hex_exp_p1 = 0x1p1;
    let hex_exp_p10 = 0x1p10;
    let hex_exp_p100 = 0x1p100;
}

fn test_positive_exponents_explicit_sign() {
    // Positive exponents with explicit sign
    let hex_exp_plus_0 = 0x1p+0;
    let hex_exp_plus_10 = 0x1p+10;
    let hex_exp_plus_100 = 0x1p+100;
}

fn test_negative_exponents() {
    // Negative exponents
    let hex_exp_neg_1 = 0x1p-1;
    let hex_exp_neg_10 = 0x1p-10;
    let hex_exp_neg_100 = 0x1p-100;
}

fn test_uppercase_exponent_P() {
    // Uppercase P for exponent
    let hex_upper_P = 0x1P0;
    let hex_upper_P_pos = 0x1P+10;
    let hex_upper_P_neg = 0x1P-10;
}

fn test_common_values_hex() {
    // Common values in hex float
    let pi_hex = 0x1.921fb54442d18p+1;      // pi
    let e_hex = 0x1.5bf0a8b145769p+1;       // e
    let sqrt2_hex = 0x1.6a09e667f3bcdp+0;   // sqrt(2)
}

fn test_ieee_754_representations() {
    // IEEE 754 special representations
    let one_hex = 0x1.0p0;
    let two_hex = 0x1.0p1;
    let ten_hex = 0x1.4p3;
}

fn test_multiple_hex_digits_mantissa() {
    // Multiple hex digits in mantissa
    let multi_mantissa_1 = 0xABCp0;
    let multi_mantissa_2 = 0x123.456p0;
    let multi_mantissa_3 = 0xDEAD.BEEFp0;
}

fn test_hex_float_with_underscores() {
    // Hex float with underscores
    let hex_under_1 = 0x1_2_3.4_5_6p0;
    let hex_under_2 = 0xAB_CD.EF_01p+10;
    let hex_under_exp = 0x1p1_0;
}

fn test_very_large_hex_floats() {
    // Very large hex floats
    let hex_large_1 = 0x1p127;
    let hex_large_2 = 0x1.FFFFFEp127;
    let hex_large_3 = 0x1p1000;
}

fn test_very_small_hex_floats() {
    // Very small hex floats
    let hex_small_1 = 0x1p-126;
    let hex_small_2 = 0x1p-1022;
    let hex_small_3 = 0x0.0001p-1022;
}

fn test_zero_hex_float() {
    // Zero in hex float
    let hex_zero = 0x0p0;
    let hex_zero_frac = 0x0.0p0;
    let hex_zero_exp = 0x0p100;
}

fn test_negative_hex_floats() {
    // Negative hex floats
    let neg_hex_1 = -0x1p0;
    let neg_hex_2 = -0x1.5p+10;
    let neg_hex_3 = -0xABCp-5;
}

fn test_hex_in_expressions() {
    // In expressions
    let hex_sum = 0x1p0 + 0x1p1;        // 1.0 + 2.0 = 3.0
    let hex_prod = 0x1p2 * 0x1p3;       // 4.0 * 8.0 = 32.0
    let hex_div = 0x1p10 / 0x1p5;       // 1024.0 / 32.0 = 32.0
}

fn test_hex_in_comparisons() {
    // In comparisons
    let hex_gt = 0x1p10 > 0x1p5;
    let hex_eq = 0x1p0 == 0x1.0p0;
}

fn test_hex_in_arrays() {
    // In arrays
    let hex_powers = [0x1p0, 0x1p1, 0x1p2, 0x1p3, 0x1p4];
    let hex_fracs = [0x1p-1, 0x1p-2, 0x1p-3, 0x1p-4];
}

fn test_hex_type_suffixes() {
    // Type suffixes (require underscore before suffix for hex floats)
    let hex_f32 = 0x1.0p0_f32;
    let hex_f64 = 0x1.FFFFFFFFFFFFFp0_f64;
}

fn test_edge_cases() {
    // Edge case: minimal hex float
    let min_hex_float = 0x1p0;
    let min_hex_with_frac = 0x0.1p0;

    // Edge case: long mantissa
    let long_mantissa = 0x1.23456789ABCDEFp0;
}

// Constants in hex float form
const HEX_PI: f64 = 0x1.921fb54442d18p+1;
const HEX_E: f64 = 0x1.5bf0a8b145769p+1;
const HEX_ONE: f64 = 0x1p0;
