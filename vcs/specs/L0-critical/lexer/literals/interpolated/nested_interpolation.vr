// @test: parse-pass
// @tier: all
// @level: L0
// @tags: lexer, literals, strings, interpolated, nested

// Nested and complex interpolation scenarios

fn test_basic_nested() {
    // Expression returning string that itself contains formatting
    let inner = "World";
    let outer = f"Hello, {inner}!";
    let nested = f"Greeting: {outer}";
}

// Function returning formatted string
fn greet(name: Text) -> Text {
    f"Hello, {name}!"
}

fn test_function_result() {
    let func_result = f"Message: {greet("Alice")}";
}

fn test_interpolation_within_arguments() {
    // Interpolation within interpolation arguments
    let base = "user";
    let id = 42;
    let path = f"/api/{f"{base}s"}/{id}";  // Nested format string
}

fn test_conditional_expressions() {
    // Conditional expressions in interpolation
    let value = 10;
    let description = f"Value is {if value > 5 { f"large ({value})" } else { f"small ({value})" }}";
}

fn test_match_expressions() {
    // Match expressions in interpolation
    let status_code = 200;
    let response = f"Status: {match status_code {
        200 => f"OK ({status_code})"
        404 => f"Not Found ({status_code})"
        500 => f"Error ({status_code})"
        _ => f"Unknown ({status_code})"
    }}";
}

fn test_array_operations() {
    // Array operations returning strings
    let names = ["Alice", "Bob", "Charlie"];
    let joined = f"Users: {names.join(", ")}";
    let first = f"First user: {names[0]}";
}

fn test_method_chains() {
    // Method chains in interpolation
    let text = "  hello world  ";
    let processed = f"Result: {text.trim().to_upper()}";
}

// Struct definitions
type Address is { city: Text, country: Text };
type PersonNested is { name: Text, address: Address };

fn test_struct_field_chains() {
    // Struct field access chains
    let person = PersonNested {
        name: "John",
        address: Address { city: "NYC", country: "USA" }
    };
    let location = f"{person.name} lives in {person.address.city}, {person.address.country}";
}

fn test_complex_arithmetic() {
    // Complex arithmetic expressions
    let a = 5;
    let b = 3;
    let c = 2;
    let math_result = f"Result: {(a + b) * c} = ({a} + {b}) * {c}";
}

fn test_closure_calls() {
    // Closure calls in interpolation
    let double_closure = |x: Int| x * 2;
    let closure_result = f"Doubled: {double_closure(21)}";
}

fn test_option_unwrapping() {
    // Option/Maybe unwrapping in interpolation
    let maybe_name: Maybe<Text> = Some("Alice");
    let greeting_maybe = f"Hello, {maybe_name.unwrap_or("Guest")}";
}

fn test_result_handling() {
    // Result handling in interpolation
    let result: Result<Int, Text> = Ok(42);
    let result_msg = f"Value: {match result { Ok(v) => f"{v}", Err(e) => f"Error: {e}" }}";
}

// Recursive string building
fn build_path(parts: List<Text>) -> Text {
    if parts.is_empty() {
        ""
    } else if parts.len() == 1 {
        parts[0]
    } else {
        f"{parts[0]}/{build_path(parts.tail())}"
    }
}

fn test_recursive_building() {
    let path_result = f"Path: {build_path(["home", "user", "docs"])}";
}

fn test_format_specs_nested() {
    // Format specs within nested interpolation
    let pi = 3.14159;
    let formatted = f"Pi is approximately {f"{pi:.2}"}";
}

fn test_multiple_nesting_levels() {
    // Multiple nesting levels
    let level1 = "L1";
    let level2 = f"L2-{level1}";
    let level3 = f"L3-{level2}";
    let level4 = f"L4-{level3}";
}

fn test_escapes_in_nested() {
    let value = 10;
    // Interpolation with escape sequences
    let with_newline = f"Line 1\nLine 2: {value}";
    let nested_escape = f"Outer: {f"Inner: {value}\t"}\n";
}

fn test_mixed_interpolation_types() {
    // Mixed interpolation types
    let user_id = 42;
    let sql_query = sql"SELECT * FROM users WHERE id = {user_id}";
    let log_message = f"Executing: {sql_query}";  // Format string containing SQL query result
}

fn test_html_within_format() {
    // HTML within format string
    let name_input = "Alice";
    let html_content = html"<span>{name_input}</span>";
    let full_message = f"Rendered: {html_content}";
}

// Complex template building
fn build_list_item(item: Text, index: Int) -> Text {
    f"<li>{index + 1}. {item}</li>"
}

fn test_complex_templates() {
    let items = ["Apple", "Banana", "Cherry"];
    let list_items = items.enumerate().map(|(i, item)| build_list_item(item, i));
    let list_html = f"<ul>{list_items.join("")}</ul>";
}

fn test_ternary_patterns() {
    // Ternary-like patterns
    let count = 5;
    let item_word = f"item{if count != 1 { "s" } else { "" }}";
    let count_message = f"You have {count} {item_word}";
}

fn test_debug_formatting_nested() {
    // Debug formatting with nesting
    let debug_obj = DebugPoint { x: 1, y: 2 };
    let debug_str = f"Debug: {f"{debug_obj:?}"}";
}

type DebugPoint is { x: Int, y: Int };

fn test_multiline_nested() {
    let name_ml = "World";
    let value = 10;
    // Interpolation in multiline strings
    let multiline_nested = f"""
Hello, {name_ml}!
This is a {f"nested {name_ml}"} example.
Value: {value}
""";
}

// Deeply nested access patterns
type DeepLevel3 is { value: Int };
type DeepLevel2 is { level3: DeepLevel3 };
type DeepLevel1 is { level2: DeepLevel2 };
type Deep is { level1: DeepLevel1 };

fn test_deeply_nested_access() {
    let deep = Deep { level1: DeepLevel1 { level2: DeepLevel2 { level3: DeepLevel3 { value: 42 } } } };
    let deep_access = f"Deep value: {deep.level1.level2.level3.value}";
}

fn test_complex_boolean_expressions() {
    // Complex boolean expressions
    let x = 10;
    let y = 20;
    let z = 15;
    let bool_result = f"Result: {if x < y && y > z || x == z { "true" } else { "false" }}";
}
