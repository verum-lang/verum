// Character classification
fn is_greek(c: Char) -> Bool {
    c >= '\u{0370}' && c <= '\u{03FF}'
}

fn is_cyrillic(c: Char) -> Bool {
    c >= '\u{0400}' && c <= '\u{04FF}'
}

fn is_cjk(c: Char) -> Bool {
    c >= '\u{4E00}' && c <= '\u{9FFF}'
}

fn is_emoji(c: Char) -> Bool {
    c >= '\u{1F600}' && c <= '\u{1F64F}'
}
