// @test: parse-pass
// @tier: all
// @level: L0
// @tags: lexer, literals, characters, unicode

// Unicode character literals

fn test_latin_extended() {
    // Latin Extended
    let ae = '\u{00E6}';           // Latin small ligature ae
    let eth = '\u{00F0}';          // Latin small eth
    let thorn = '\u{00FE}';        // Latin small thorn
}

fn test_greek_letters() {
    // Greek letters (direct input via unicode escapes)
    let alpha_direct = '\u{03B1}';   // Greek small alpha
    let beta_direct = '\u{03B2}';    // Greek small beta
    let gamma_direct = '\u{03B3}';   // Greek small gamma
    let delta_direct = '\u{03B4}';   // Greek small delta
    let epsilon_direct = '\u{03B5}'; // Greek small epsilon
    let pi_direct = '\u{03C0}';      // Greek small pi
    let sigma_direct = '\u{03C3}';   // Greek small sigma
    let omega_direct = '\u{03C9}';   // Greek small omega
}

fn test_cyrillic_letters() {
    // Cyrillic letters
    let a_cyrillic = '\u{0410}';  // Cyrillic A
    let b_cyrillic = '\u{0411}';  // Cyrillic Be
    let v_cyrillic = '\u{0412}';  // Cyrillic Ve
    let ya_cyrillic = '\u{042F}'; // Cyrillic Ya
}

fn test_cjk_characters() {
    // CJK characters
    let ren = '\u{4EBA}';    // Chinese "person"
    let ri = '\u{65E5}';     // Chinese "sun/day"
    let yue = '\u{6708}';    // Chinese "moon/month"
    let shan = '\u{5C71}';   // Chinese "mountain"
}

