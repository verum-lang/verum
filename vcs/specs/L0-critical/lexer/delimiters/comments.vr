// Comments and string interactions
fn test_comments_and_strings() {
    let str_with_slashes = "not a // comment";
    let str_with_block = "not a /* comment */ either";
    // These are strings "with quotes" not code

    // Consecutive different comment types
    // Line comment
    /* Block comment */
    // Line comment again
    /* Block again */

    // Empty block comment
    /**/

    // Minimal comments
    //
    /**/
    /* */

    // Comments around operators
    let expr = 1 +/* comment */2 */* another */3;

    // Comments in complex expressions
    let complex = (
        1 // one
        + 2 // two
        * 3 // three
        - 4 // four
        / 5 // five
    );
}

