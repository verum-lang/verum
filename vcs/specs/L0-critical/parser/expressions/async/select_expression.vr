// 13. TYPE INFERENCE TESTS
// ============================================================================

// 13.1 Inferred return type from branches
async fn test_infer_from_branches() {
    let int_future = async { 42 };
    let another_int_future = async { 100 };
    // All branches return Int, so result is Int
    let result: Int = select {
        x = int_future.await => x,
        y = another_int_future.await => y,
    };
}

// 13.2 Inferred Option type
async fn test_infer_option() {
    // Branches return Some(T) and None, result is Maybe<T>
    let result: Maybe<Data> = select {
        Ok(data) = fetch().await => Some(data),
        _ = timeout(Duration.from_secs(1)).await => None,
    };
}

// 13.3 Inferred Result type
async fn test_infer_result() {
    // Branches return Ok and Err, result is Result<T, E>
    let result: Result<Data, Error> = select {
        Ok(data) = fetch().await => Ok(data),
        _ = timeout(Duration.from_secs(1)).await => Err(Error.Timeout),
    };
}

// 13.4 Branch body type unification
async fn test_type_unification() {
    let future_a = async { Data { value: 1 } };
    let future_b = async { Data { value: 2 } };
    // Both branches must unify to same type
    let result = select {
        x = future_a.await => process_a(x),  // Returns Output
        y = future_b.await => process_b(y),  // Must also return Output
    };
}

