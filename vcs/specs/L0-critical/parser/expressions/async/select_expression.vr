// 11.5 Select with all features combined
async fn test_all_features() {
    let primary = async { Ok(Response { status: 200, body: None }) };
    let secondary = async { Data { value: 1 } };
    let primary_enabled = true;
    let secondary_enabled = true;
    let result = select biased {
        @hot
        Ok(Response { status, .. }) = primary.await if primary_enabled => {
            log("Using primary");
            Data { value: status }
        },
        @cold
        data = secondary.await if secondary_enabled => {
            log("Using secondary");
            data
        },
        else => {
            log("Using fallback");
            default_data()
        },
    };
}

// 11.6 Select as expression in various positions
async fn test_select_positions() {
    let f = async { 42 };
    // In let binding
    let a = select { x = f.await => x, else => 0 };

    // In function argument
    process_int(select { x = f.await => x, else => 0 });

    // In return
    return select { x = f.await => x, else => 0 };
}

