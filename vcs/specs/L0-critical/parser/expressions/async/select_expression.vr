    let mode_local: Mode = Mode.Fast;
    let result = match mode_local {
        Mode.Fast => select {
            x = fast.await => x,
            else => 0,
        },
        Mode.Slow => select {
            x = slow.await => x,
            else => 0,
        },
    };
}

