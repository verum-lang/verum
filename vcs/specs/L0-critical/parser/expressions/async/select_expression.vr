}

// ============================================================================
// 12. REAL-WORLD PATTERNS
// ============================================================================

// 12.1 HTTP request with timeout
async fn http_fetch_timeout(url_param: Text, timeout_duration: Duration) -> Result<Response, HttpError> {
    let http = HttpClient.new();
    select {
        Ok(response) = http.get(url_param).await => Ok(response),
        Err(e) = http.get(url_param).await => Err(HttpError.Request(e)),
        _ = sleep(timeout_duration).await => Err(HttpError.Timeout),
    }
}

// 12.2 Database query with failover
// Note: Context access is an L2 feature. For L0 tests, we use local stubs.
async fn query_with_failover(sql: Text) -> Result<Rows, DbError> {
    let primary = DatabaseConnection.new();
    let replica = DatabaseConnection.new();
    select {
        result = primary.query(sql).await => {
            match result {
                Ok(rows) => {
                    log("Query succeeded on primary");
                    Ok(rows)
                },
                Err(e) => {
                    log("Primary failed, trying replica");
                    replica.query(sql).await
                },
            }
        },
        _ = timeout(Duration.from_secs(30)).await => {
            log("Query timed out");
            Err(DbError.Timeout)
        },
    }
}

// 12.3 Graceful shutdown pattern
// Note: Context access is an L2 feature. For L0 tests, we use local stubs.
async fn run_service() -> Result<(), Error> {
    let listener: Listener = Listener { _marker: 0 };
    let shutdown_signal_recv = async { };  // Stub for shutdown signal
    loop {
        select biased {
            _ = shutdown_signal_recv.await => {
                log("Shutdown requested");
                break;
            },
            request = listener.accept().await => {
                spawn_task(request);
            },
        }
    }

    cleanup().await;
    Ok(())
}

// 12.4 Heartbeat pattern
async fn worker_with_heartbeat(coordinator: Coordinator) -> Result<(), Error> {
    let heartbeat_interval = Duration.from_secs(10);

    loop {
        select {
            result = do_work().await => {
                if result.is_done() { break; }
            },
            _ = sleep(heartbeat_interval).await => {
                // Send heartbeat
            },
        }
    }

    Ok(())
}

// 12.5 First-wins race pattern
async fn fetch_fastest(sources: List<DataSource>) -> Maybe<Data> {
    select {
        data = sources[0].fetch().await => Some(data),
        data = sources[1].fetch().await => Some(data),
        data = sources[2].fetch().await => Some(data),
        else => None,
    }
}

// 12.6 Retry with exponential backoff
// Note: async fn type uses fn() -> Future<Result<T, Error>> syntax
async fn retry_with_backoff<T>(
    operation: fn() -> Future<Result<T, Error>>,
    max_retries: Int,
) -> Result<T, Error>
{
    let mut delay = Duration.from_millis(100);
    let mut attempt = 0;

    while attempt < max_retries {
        let result = select {
            Ok(data) = operation().await => Ok(data),
            Err(e) = operation().await => {
                sleep(delay).await;
                delay = Duration.from_millis(delay.millis * 2);
                Err(e)
            },
            _ = timeout(Duration.from_secs(30)).await => Err(Error.Timeout),
        };
        match result {
            Ok(data) => { return Ok(data) },
            Err(Error.Timeout) => { return Err(Error.Timeout) },
            Err(_) => { attempt = attempt + 1 },
        }
    }

    Err(Error.MaxRetriesExceeded)
}

// 12.7 Multiplexed message handling
// Note: Context access is an L2 feature. For L0 tests, we use local stubs.
async fn message_loop() {
    let control_rx: Receiver<Control> = Receiver { _marker: 0 };
    let data_rx: Receiver<Message> = Receiver { _marker: 0 };
    let metrics_interval: Interval = Interval { _marker: 0 };
    loop {
        select biased {
            // Highest priority: Control messages
            ctrl = control_rx.recv().await => {
                match ctrl {
                    Control.Stop => {
                        log("Stopping message loop");
                        break;
                    },
                    Control.Flush => {
                        flush_buffers().await;
                    },
                }
            },

            // Normal priority: Data messages
            msg = data_rx.recv().await => {
                match msg {
                    Message.Data(payload) => {
                        process_payload(payload).await;
                    },
                    Message.Empty => { },
                }
            },

            // Low priority: Metrics
            _ = metrics_interval.tick().await => {
                report_metrics().await;
            },
        }
    }
}

// 12.8 Cancellation token pattern
async fn cancellable_operation(cancel: CancellationToken) -> Result<Data, Error> {
    select {
        result = long_running_computation().await => Ok(result),
        _ = cancel.cancelled().await => Err(Error.Cancelled),
    }
}

