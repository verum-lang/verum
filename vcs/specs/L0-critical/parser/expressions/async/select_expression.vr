async fn test_attributes_multiple() {
    let optimized_path = async { Data { value: 1 } };
    let fallback_path = async { Data { value: 2 } };
    let result = select {
        @hot @inline
        fast = optimized_path.await => fast,
        @cold
        slow = fallback_path.await => slow,
    };
}

