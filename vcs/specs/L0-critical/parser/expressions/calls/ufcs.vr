fn test_nested_type_path() {
    // Nested type path (module is a reserved word)
    std.collections.Map.new();
    cog.utils.Helper.create();
}

fn test_static_on_generic() {
    // Static method on generic type (single type param only)
    Maybe.Some(42);
    Result.Ok(value);
    List.with_capacity(n);
}

// Static method returning Self
implement Point {
    fn new(x: Float, y: Float) -> Self {
        Point { x, y }
    }

    fn origin() -> Self {
        Self.new(0.0, 0.0)
    }
}

fn test_static_chained_with_instance() {
    // Static method chained with instance method
    Point.new(1.0, 2.0).distance_to(other);
    Config.default().with_timeout(1000);
}

fn test_associated_constants() {
    // Associated constant access
    Math.PI;
    Config.DEFAULT_TIMEOUT;
    Type.MAX_VALUE;
}

fn test_enum_variant_static() {
    // Enum variant as static path
    Option.Some(value);
    Option.None;
    Result.Ok(success);
    Result.Err(error);
}

fn test_static_in_expression() {
    // Static method in expression
    let point = Point.new(x, y);
    let config = Config.from_env().unwrap();
    let sum = List.from_iter(items).sum();
}

