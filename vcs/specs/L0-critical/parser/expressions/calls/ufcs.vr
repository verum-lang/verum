// @test: parse-pass
// @tier: all
// @level: L0
// @tags: parser, expressions, calls, ufcs, static, associated

fn test_static_method_calls() {
    // Static method call (associated function)
    Object.new();
    Point.origin();
    List.empty();
}

fn test_static_method_with_args() {
    // Static method with arguments
    Point.from_coords(x, y);
    Config.from_file("config.toml");
    Parser.parse(input);
}

fn test_static_method_with_generics() {
    // Static method with type parameters (single type param only)
    List.new<Int>();
    Map.with_capacity(100);
    Result.ok<Int>(42);
}

fn test_fully_qualified_ufcs() {
    // Fully qualified method call (UFCS)
    Display.display(&obj);
    Iterator.next(&mut iter);
    Clone.clone(&value);
}

// NOTE: <Type as Trait> syntax may not be supported
