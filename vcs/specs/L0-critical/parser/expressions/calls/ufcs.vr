fn test_trait_default_implementation() {
    // Calling trait default implementation
    Trait.default_method(&self);
    Iterator.count(self);
}

fn test_static_async() {
    // Static async method
    let client = HttpClient.connect(url).await;
    let result = Database.query(sql).await;
}
