// fn test_spread_operator() {
//     merge(...arrays);
//     apply(func, ...args);
// }

fn test_type_arguments() {
    // Function call with type arguments (single type param)
    parse<Int>("42");
    collect<List>(iter);
    default<MyType>();
}

fn test_function_call_in_let() {
    // Function call as expression
    let result = compute(x);
    let sum = add(a, b);
}

fn test_function_call_in_expressions() {
    // Function call in expressions
    let total = base + compute(modifier);
    let valid = check(a) && check(b);
}

fn test_nested_function_calls() {
    // Nested function calls
    let deep = a(b(c(d(e()))));
    let complex = outer(inner1(), inner2(nested()));
}

fn test_block_argument() {
    // Function call with block argument
    with_context({
        do_work();
        complete();
    });
}

fn test_closure_argument() {
    // Function call with closure argument
    list.map(|x| x * 2);
    filter(items, |item| item.valid);
}

fn test_generic_closure() {
    // Function call with generic closure (single type param)
    transform<Text>(value, |n| n.to_string());
}

fn test_method_on_result() {
    // Function call on returned value
    get_list().len();
    create_map().insert(key, value);
}

fn test_void_function_calls() {
    // Void function calls as statements
    log("message");
    cleanup();
    notify_observers();
}
