// @test: parse-pass
// @tier: all
// @level: L0
// @tags: parser, expressions, calls, function

fn test_simple_function_calls() {
    // Simple function call with no arguments
    func();
    do_something();
    init();
}

fn test_single_argument_calls() {
    // Function call with single argument
    print("hello");
    sqrt(16);
    process(data);
}

fn test_multiple_argument_calls() {
    // Function call with multiple arguments
    add(1, 2);
    create_point(x, y, z);
    send_message(recipient, subject, body);
}

fn test_trailing_comma() {
    // Function call with trailing comma
    format(
        template,
        arg1,
        arg2,
    );
}

fn test_expression_arguments() {
    // Function call with expression arguments
    compute(a + b, c * d);
    combine(get_first(), get_second());
    nested(outer(inner()));
}

// NOTE: Named arguments (name: value) are not currently in the grammar
// fn test_named_arguments() {
//     create_user(name: "Alice", age: 30, active: true);
//     configure(timeout: 1000, retries: 3);
// }

