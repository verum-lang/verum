fn test_very_long_expression() {
    let a_val = 1; let b_val = 2; let c_val = 3; let d_val = 4; let e_val = 5;
    let f_val = 6; let g_val = 7; let h_val = 8; let i_val = 9; let j_val = 10;
    let k_val = 11; let l_val = 12; let m_val = 13; let n_val = 14; let o_val = 15;
    let p_val = 16; let q_val = 17; let r_val = 18; let s_val = 19; let t_val = 20;
    let u_val = 21; let v_val = 22; let w_val = 23; let x_val = 24; let y_val = 25;
    let z_val = 26;

    // Very long expression
    let long_expr = a_val + b_val + c_val + d_val + e_val + f_val + g_val + h_val + i_val + j_val + k_val + l_val + m_val + n_val + o_val + p_val + q_val + r_val + s_val + t_val + u_val + v_val + w_val + x_val + y_val + z_val;
}

fn test_many_nested_calls() {
    fn p_inner<T>(x: T) -> T { x }
    fn q_inner<T>(x: T) -> T { x }
    fn r_inner<T>(x: T) -> T { x }
    fn s_inner<T>(x: T) -> T { x }
    fn t_inner<T>(x: T) -> T { x }
    fn u_inner<T>(x: T) -> T { x }
    fn v_inner<T>(x: T) -> T { x }
    fn w_inner<T>(x: T) -> T { x }
    fn x_inner<T>(x: T) -> T { x }
    fn y_inner<T>(x: T) -> T { x }
    fn z_inner<T>(x: T) -> T { x }

    // Many nested calls
    let result = z_inner(y_inner(x_inner(w_inner(v_inner(u_inner(t_inner(s_inner(r_inner(q_inner(p_inner(0)))))))))));
}

fn test_long_method_chain() {
    type Obj is { val: Int };
    fn a_method(o: Obj) -> Obj { o }
    fn b_method(o: Obj) -> Obj { o }
    fn c_method(o: Obj) -> Obj { o }
    fn d_method(o: Obj) -> Obj { o }
    fn e_method(o: Obj) -> Obj { o }
    fn f_method(o: Obj) -> Obj { o }
    fn g_method(o: Obj) -> Obj { o }
    fn h_method(o: Obj) -> Obj { o }
    fn i_method(o: Obj) -> Obj { o }
    fn j_method(o: Obj) -> Obj { o }

    let obj = Obj { val: 0 };

    // Long method chain
    let chained = j_method(i_method(h_method(g_method(f_method(e_method(d_method(c_method(b_method(a_method(obj)))))))))).val;
}

