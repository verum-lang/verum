// ============================================================================
// SECTION 10: Complex Event Sequences
// ============================================================================

// Test complex match expression event sequence
fn complex_match_events(x: Maybe<Int>) -> Int {
    match x {
        Some(n) => n * 2,
        None => 0,
    }
}

// Test if-else event sequence
fn complex_if_events(x: Int) -> Int {
    if x > 0 {
        x
    } else if x < 0 {
        -x
    } else {
        0
    }
}

// Test loop event sequences
fn complex_loop_events() {
    for i in 0..10 {
        let doubled = i * 2;
    }

    while true {
        break;
    }

    loop {
        break;
    }
}

// Test type definition event sequence
type EventTestRecord is {
    name: Text,
    value: Int,
    enabled: Bool,
};

// Test sum type event sequence
type EventTestVariant is
    | Empty
    | Single(Int)
    | Multiple { x: Int, y: Int };

// Test protocol event sequence
type EventTestProtocol is protocol {
    type Item;
    fn next(&mut self) -> Maybe<Self.Item>;
};

// Test implementation block event sequence
implement EventTestProtocol for EventTestRecord {
    type Item is Int;
    fn next(&mut self) -> Maybe<Int> {
        None
    }
}
