// ============================================================================
// SECTION 1: Basic Node Structure
// ============================================================================

// Simple function - tests basic node structure
fn simple() { }

// Nested blocks - tests tree depth
fn nested() {
    {
        {
            {
                let deep = 1;
            }
        }
    }
}

// Multiple children - tests sibling handling
fn many_children(a: Int, b: Int, c: Int, d: Int, e: Int) -> Int {
    a + b + c + d + e
}

// Complex expression tree
fn expressions() {
    let x = 1 + 2 * 3 - 4 / 5;
    let y = (a + b) * (c + d);
    let z = a.b.c.d.e();
}

