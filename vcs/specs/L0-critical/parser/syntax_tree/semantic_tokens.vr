// @test: parse-pass
// @tier: 0
// @level: L0
// @tags: parser, syntax-tree, semantic-tokens, lsp, events, trivia
// @description: Test semantic token classification for IDE highlighting via event-based parsing

// ============================================================================
// SECTION 1: Keyword Classification
// ============================================================================

// Test keywords (should be classified as Keyword)
fn keyword_test() {
    let x = 1;
    if x > 0 {
        return x;
    } else {
        return 0;
    }
}

// Test all control flow keywords
fn control_keywords() {
    for i in 0..10 {
        if i > 5 {
            break;
        }
        continue;
    }

    while true {
        break;
    }

    loop {
        break;
    }
}

// ============================================================================
// SECTION 2: Operator Classification
// ============================================================================

// Test operators (should be classified as Operator)
fn operator_test(a: Int, b: Int) -> Int {
    let sum = a + b;
    let diff = a - b;
    let prod = a * b;
    let quot = a / b;
    let eq = a == b;
    let neq = a != b;
    let lt = a < b;
    let gt = a > b;
    let land = eq && neq;
    let lor = lt || gt;
    sum
}

// Test additional operators
fn additional_operators() {
    let range = 0..10;
    let range_incl = 0..=10;
    let pipe = value |> transform;
}

// ============================================================================
// SECTION 3: Literal Classification
// ============================================================================

// Test literals (should be classified as Number/String)
fn literal_test() {
    let int_lit = 42;
    let float_lit = 3.14;
    let str_lit = "hello world";
    let char_lit = 'x';
}

// Test numeric literal variants
fn numeric_literals() {
    let decimal = 123456;
    let hex = 0xDEADBEEF;
    let octal = 0o755;
    let binary = 0b10101010;
    let float_exp = 1.5e10;
}

