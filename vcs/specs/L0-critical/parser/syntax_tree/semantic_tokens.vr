// Test identifiers in different contexts
fn identifier_test() {
    let variable = 1;
    let _ = variable + 1;
}

// Test type identifiers vs value identifiers
fn identifier_contexts(param: Int) -> Int {
    let local = param;
    local
}

// ============================================================================
// SECTION 6: Attribute Classification
// ============================================================================

// Test attributes (should be classified as Decorator)
// Note: 'pure' is a function modifier, not an attribute
pure fn pure_function(x: Int) -> Int {
    x * 2
}

@inline
fn inline_function(x: Int) -> Int {
    x + 1
}

@derive(Debug, Clone)
type SemanticRecord is {
    field: Int,
};

