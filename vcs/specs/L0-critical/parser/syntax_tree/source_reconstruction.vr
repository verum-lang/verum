// ============================================================================
// SECTION 9: Event-Based Roundtrip
// ============================================================================

// Test that events preserve all source information
fn event_roundtrip() {
    // Comment preserved through events
    let x = 1;  // Trailing preserved
    let y = 2;
}

// Test complex event sequence preserves formatting
fn event_complex_roundtrip(input: Maybe<Int>) -> Int {
    match input {
        Some(n) if n > 0 => n * 2,  // Positive case
        Some(n) => -n,               // Negative case
        None => 0,                   // Default case
    }
}

