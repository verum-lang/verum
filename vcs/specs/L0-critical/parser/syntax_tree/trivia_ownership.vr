// ============================================================================
// SECTION 6: Trivia in Type Definitions
// ============================================================================

// Test trivia in record type
type TriviaRecord is {
    // Field comment
    name: Text,    // Trailing for name
    // Another comment
    value: Int,
};

// Test trivia in sum type
type TriviaSum is
    // Variant comment
    | First     // Trailing for First
    // Another variant
    | Second(Int);

// Test trivia in protocol
type TriviaProtocol is protocol {
    // Type comment
    type Item;
    // Method comment
    fn next(&mut self) -> Maybe<Self.Item>;
};

