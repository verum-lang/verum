// @test: unit
// @tier: 0
// @level: L0
// @tags: lexer, trivia, ownership, lossless, whitespace, comments
// @description: Test trivia ownership rules including leading/trailing assignment and newline boundaries
// @expect: pass

// ============================================================================
// SECTION 1: Leading Trivia Assignment
// ============================================================================

// Test that whitespace before token becomes leading trivia
fn leading_whitespace() {
    let    x = 1;  // Whitespace before 'x' is leading trivia for 'x'
}

// Test that line comments become leading trivia for next significant token
// Comment below is leading trivia for 'let'
fn leading_line_comment() {
    // This comment is leading trivia
    let x = 1;
}

// Test that block comments become leading trivia
fn leading_block_comment() {
    /* Block comment leading trivia */
    let x = 1;
}

// Test that multiple consecutive comments are all leading trivia
fn leading_multiple_comments() {
    // First comment
    // Second comment
    // Third comment
    let x = 1;  // All three are leading trivia for 'let'
}

// Test doc comments as leading trivia
/// Doc comment for the function
fn leading_doc_comment() { }

// Test inner doc comments
//! Module-level inner doc
fn leading_inner_doc() { }

// Test leading trivia at start of file
// This comment is leading trivia for the first function

fn leading_trivia_file_start() { }

// ============================================================================
// SECTION 2: Trailing Trivia (Up to Newline)
// ============================================================================

// Test that inline comment becomes trailing trivia
fn trailing_inline_comment() {
    let x = 1;  // This is trailing trivia for semicolon
}

// Test that spaces after token become trailing trivia
fn trailing_spaces() {
    let x = 1   ;  // Spaces before semicolon are trailing trivia for '1'
}

// Test that block comment on same line is trailing trivia
fn trailing_block_comment() {
    let x = 1; /* inline block comment */
}

// Test trailing trivia stops at newline
fn trailing_stops_at_newline() {
    let x = 1;  // Trailing for semicolon
    let y = 2;  // This is a different statement
}

// Test trailing trivia with CRLF
fn trailing_with_crlf() {
    let x = 1;  // Trailing comment ends at \r\n
}

// ============================================================================
// SECTION 3: Newline Ownership Boundary
// ============================================================================

// Test that newline belongs to leading trivia of next token
fn newline_belongs_to_next() {
    let x = 1;
    let y = 2;  // Newline after x's semicolon is leading for 'let y'
}

// Test multiple newlines
fn multiple_newlines() {
    let x = 1;


    let y = 2;  // Both newlines are leading trivia for 'let y'
}

// Test newline in multi-line expressions
fn newline_in_expression() {
    let x = 1
        + 2
        + 3;  // Newlines are trivia between tokens
}

// Test newline boundary with inline comment
fn newline_boundary_with_comment() {
    let x = 1;  // Comment
    // This newline ends trailing, starts leading
    let y = 2;
}

// ============================================================================
// SECTION 4: Mixed Trivia Sequences
// ============================================================================

// Test alternating whitespace and comments
fn mixed_trivia_alternating() {
    let x = 1;  /* block */ // line
    let y = 2;
}

// Test tabs and spaces
fn mixed_tabs_spaces() {
	let tab = 1;
    let space = 2;
	    let mixed = 3;
}

// Test complex trivia sequence
fn mixed_complex() {
    /* A */ let /* B */ x /* C */ = /* D */ 1 /* E */ ; /* F */
    // G
    let y = 2;
}

