// @description: Test structured error recovery - parser should continue after errors, event-based error handling
// @expected-error-count: 4

// ============================================================================
// SECTION 1: Basic Error Recovery
// ============================================================================

// Missing type annotation - should recover and parse rest
fn missing_type(x) {
    let result = x + 1;
    result
}

// Unclosed parenthesis - should create ERROR node and continue
fn unclosed_paren(a: Int, b: Int {
    a + b
}

// Invalid operator - should create ERROR node
fn invalid_operator() {
    let x = 1 @@ 2;  // @@ is not a valid operator
}

// Missing expression after operator - should create ERROR node
fn missing_expr() {
    let x = 1 +;
}

// Valid function after errors - should parse correctly
fn valid_after_errors() {
    let x = 1;
    let y = 2;
    x + y
}

