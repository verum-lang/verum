fn vget_low_f32(a: float32x4_t) -> float32x2_t { unreachable() }
fn vget_high_f32(a: float32x4_t) -> float32x2_t { unreachable() }
fn vget_low_s32(a: int32x4_t) -> int32x2_t { unreachable() }
fn vget_low_p8(a: poly8x16_t) -> poly8x8_t { unreachable() }
fn vcombine_f32(a: float32x2_t, b: float32x2_t) -> float32x4_t { unreachable() }
fn vzipq_f32(a: float32x4_t, b: float32x4_t) -> (float32x4_t, float32x4_t) { unreachable() }
fn vuzpq_f32(a: float32x4_t, b: float32x4_t) -> (float32x4_t, float32x4_t) { unreachable() }
fn vtrnq_f32(a: float32x4_t, b: float32x4_t) -> (float32x4_t, float32x4_t) { unreachable() }
fn vrev64q_f32(a: float32x4_t) -> float32x4_t { unreachable() }
fn vextq_f32<const N: usize>(a: float32x4_t, b: float32x4_t) -> float32x4_t { unreachable() }
fn vqtbl1q_u8(t: uint8x16_t, idx: uint8x16_t) -> uint8x16_t { unreachable() }
fn vdupq_laneq_f32<const N: usize>(a: float32x4_t) -> float32x4_t { unreachable() }

fn vpaddq_f32(a: float32x4_t, b: float32x4_t) -> float32x4_t { unreachable() }
fn vpmaxq_f32(a: float32x4_t, b: float32x4_t) -> float32x4_t { unreachable() }
fn vpminq_f32(a: float32x4_t, b: float32x4_t) -> float32x4_t { unreachable() }
fn vaddvq_f32(a: float32x4_t) -> f32 { unreachable() }
fn vdotq_u32(acc: uint32x4_t, a: uint8x16_t, b: uint8x16_t) -> uint32x4_t { unreachable() }
fn vdotq_s32(acc: int32x4_t, a: int8x16_t, b: int8x16_t) -> int32x4_t { unreachable() }

fn vmull_p8(a: poly8x8_t, b: poly8x8_t) -> poly16x8_t { unreachable() }

fn vaeseq_u8(a: uint8x16_t, b: uint8x16_t) -> uint8x16_t { unreachable() }
fn vaesdq_u8(a: uint8x16_t, b: uint8x16_t) -> uint8x16_t { unreachable() }
fn vaesmcq_u8(a: uint8x16_t) -> uint8x16_t { unreachable() }
fn vaesimcq_u8(a: uint8x16_t) -> uint8x16_t { unreachable() }
fn vsha256hq_u32(a: uint32x4_t, b: uint32x4_t, c: uint32x4_t) -> uint32x4_t { unreachable() }
fn vsha256su0q_u32(a: uint32x4_t, b: uint32x4_t) -> uint32x4_t { unreachable() }
fn vbfdotq_f32(acc: float32x4_t, a: bfloat16x8_t, b: bfloat16x8_t) -> float32x4_t { unreachable() }

type poly8x8_t is { data: [u8; 8] };
