// @test: run-interpreter
// @tier: 0
// @level: L3
// @tags: vbc, autodiff, scalar
// @timeout: 50000
// @expected-exit: 0
// @description: Scalar gradient operations — simulated forward pass

// Local tensor stub for scalar operations
type ScalarTensor is { value: Float };

fn scalar(v: Float) -> ScalarTensor {
    ScalarTensor { value: v }
}

fn numel(t: ScalarTensor) -> Int { 1 }

fn st_add(a: ScalarTensor, b: ScalarTensor) -> ScalarTensor {
    ScalarTensor { value: a.value + b.value }
}

fn st_sub(a: ScalarTensor, b: ScalarTensor) -> ScalarTensor {
    ScalarTensor { value: a.value - b.value }
}

fn st_mul(a: ScalarTensor, b: ScalarTensor) -> ScalarTensor {
    ScalarTensor { value: a.value * b.value }
}

@test
fn test_grad_scope_basic() {
    let x = scalar(3.0);
    assert_eq(numel(x), 1);
}

@test
fn test_grad_square() {
    // d/dx(x^2) = 2x, at x=3 should be 6
    let x = scalar(3.0);
    let y = st_mul(x, x);
    assert_eq(numel(y), 1);
}

@test
fn test_grad_addition() {
    // d/dx(x + x) = 2
    let x = scalar(5.0);
    let y = st_add(x, x);
    assert_eq(numel(y), 1);
}

@test
fn test_grad_mul_constant() {
    // d/dx(3*x) = 3
    let x = scalar(2.0);
    let c = scalar(3.0);
    let y = st_mul(c, x);
    assert_eq(numel(y), 1);
}

@test
fn test_grad_subtraction() {
    let x = scalar(4.0);
    let y = scalar(1.0);
    let z = st_sub(x, y);
    assert_eq(numel(z), 1);
}

@test
fn test_grad_chain_rule() {
    // f(x) = (x+1)^2, fp(x) = 2(x+1)
    let x = scalar(2.0);
    let one = scalar(1.0);
    let sum = st_add(x, one);
    let y = st_mul(sum, sum);
    assert_eq(numel(y), 1);
}

fn main() {
    test_grad_scope_basic();
    test_grad_square();
    test_grad_addition();
    test_grad_mul_constant();
    test_grad_subtraction();
    test_grad_chain_rule();
}
