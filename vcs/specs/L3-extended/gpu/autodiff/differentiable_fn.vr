// @test: parse
// @tier: 3
// @level: L3
// @skip-disabled: GPU tests downgraded to parse-only
// @tags: autodiff, gradient

@differentiable
fn loss(x: Tensor<f32, [N]>, y: Tensor<f32, [N]>) -> f32 {
    (x - y).pow(2).sum()
}

@differentiable
fn mse_loss(pred: Tensor<f32, [N]>, target: Tensor<f32, [N]>) -> f32 {
    let diff = pred - target;
    diff.pow(2).mean()
}

@differentiable
fn cross_entropy_loss(logits: Tensor<f32, [N]>, target: Tensor<f32, [N]>) -> f32 {
    let log_probs = logits.log_softmax();
    -(target * log_probs).sum()
}

@differentiable
fn simple_network(
    x: Tensor<f32, [BATCH, IN]>,
    w1: Tensor<f32, [IN, HIDDEN]>,
    b1: Tensor<f32, [HIDDEN]>,
    w2: Tensor<f32, [HIDDEN, OUT]>,
    b2: Tensor<f32, [OUT]>
) -> Tensor<f32, [BATCH, OUT]> {
    let hidden = (matmul(x, w1) + b1).relu();
    matmul(hidden, w2) + b2
}

@differentiable
fn polynomial(x: f32, coeffs: Tensor<f32, [N]>) -> f32 {
    let mut result = coeffs[N-1];
    for i in (0..N-1).rev() {
        result = result * x + coeffs[i];
    }
    result
}

fn main() {
    // Basic gradient computation
    let x = tensor<4>f32{1.0, 2.0, 3.0, 4.0};
    let y = tensor<4>f32{1.0, 1.0, 1.0, 1.0};

    let (value, grad) = gradient(loss, x, y);
    // grad = 2 * (x - y) for MSE loss
    // For x - y = [0, 1, 2, 3], grad = [0, 2, 4, 6]

    assert((grad[0] - 0.0).abs() < 1e-5);
    assert((grad[1] - 2.0).abs() < 1e-5);
    assert((grad[2] - 4.0).abs() < 1e-5);
    assert((grad[3] - 6.0).abs() < 1e-5);

    // Gradient with respect to second argument
    let (value2, grad_y) = gradient_wrt(loss, (x, y), arg: 1);
    // grad_y = -2 * (x - y)
    assert((grad_y[1] - (-2.0)).abs() < 1e-5);

    // Multiple gradients at once
    let (value3, (grad_x, grad_y2)) = gradient_all(loss, x, y);
    assert((grad_x[1] - 2.0).abs() < 1e-5);
    assert((grad_y2[1] - (-2.0)).abs() < 1e-5);

    // Network gradient computation
    let batch_size = 32;
    let input: Tensor<f32, [32, 784]> = Tensor.randn();
    let target: Tensor<f32, [32, 10]> = Tensor.zeros();  // One-hot encoded

    let w1: Tensor<f32, [784, 128]> = Tensor.randn() * 0.01;
    let b1: Tensor<f32, [128]> = Tensor.zeros();
    let w2: Tensor<f32, [128, 10]> = Tensor.randn() * 0.01;
    let b2: Tensor<f32, [10]> = Tensor.zeros();

    // Define complete loss function
    @differentiable
    fn network_loss(
        input: Tensor<f32, [32, 784]>,
        target: Tensor<f32, [32, 10]>,
        w1: Tensor<f32, [784, 128]>,
        b1: Tensor<f32, [128]>,
        w2: Tensor<f32, [128, 10]>,
        b2: Tensor<f32, [10]>
    ) -> f32 {
        let output = simple_network(input, w1, b1, w2, b2);
        cross_entropy_loss(output.mean(axis: 0), target.mean(axis: 0))
    }

    // Compute gradients for all parameters
    let (loss_val, (_, _, grad_w1, grad_b1, grad_w2, grad_b2)) = gradient_all(
        network_loss,
        input, target, w1, b1, w2, b2
    );

    // Gradients have same shape as parameters
    assert(grad_w1.shape() == [784, 128]);
    assert(grad_b1.shape() == [128]);
    assert(grad_w2.shape() == [128, 10]);
    assert(grad_b2.shape() == [10]);

    // Jacobian computation
    @differentiable
    fn vector_fn(x: Tensor<f32, [3]>) -> Tensor<f32, [2]> {
        tensor<2>f32{
            x[0] * x[1],
            x[1] * x[2]
        }
    }

    let point = tensor<3>f32{1.0, 2.0, 3.0};
    let jacobian: Tensor<f32, [2, 3]> = jacobian(vector_fn, point);
    // J[i,j] = d(output[i]) / d(input[j])
    // J = [[y, x, 0],
    //      [0, z, y]]
    // J = [[2, 1, 0],
    //      [0, 3, 2]]

    assert((jacobian[0, 0] - 2.0).abs() < 1e-5);  // d(x*y)/dx = y
    assert((jacobian[0, 1] - 1.0).abs() < 1e-5);  // d(x*y)/dy = x
    assert((jacobian[1, 2] - 2.0).abs() < 1e-5);  // d(y*z)/dz = y

    // Hessian computation
    @differentiable
    fn scalar_fn(x: Tensor<f32, [2]>) -> f32 {
        x[0].pow(2) + x[0] * x[1] + x[1].pow(2)
    }

    let pt = tensor<2>f32{1.0, 1.0};
    let hess: Tensor<f32, [2, 2]> = hessian(scalar_fn, pt);
    // H[i,j] = d^2 f / (dx[i] dx[j])
    // f = x^2 + xy + y^2
    // H = [[2, 1],
    //      [1, 2]]

    assert((hess[0, 0] - 2.0).abs() < 1e-5);
    assert((hess[0, 1] - 1.0).abs() < 1e-5);
    assert((hess[1, 0] - 1.0).abs() < 1e-5);
    assert((hess[1, 1] - 2.0).abs() < 1e-5);

    // Value and gradient in one call (efficient)
    let (val, grad) = value_and_gradient(loss, x, y);
    assert(val == loss(x, y));

    // Higher-order derivatives
    @differentiable
    fn f(x: f32) -> f32 {
        x.pow(3)
    }

    let x0: f32 = 2.0;

    let df = derivative(f, x0);          // 3x^2 = 12
    let d2f = derivative(derivative(f), x0);  // 6x = 12
    let d3f = derivative(derivative(derivative(f)), x0);  // 6

    assert((df - 12.0).abs() < 1e-5);
    assert((d2f - 12.0).abs() < 1e-5);
    assert((d3f - 6.0).abs() < 1e-5);

    // Custom VJP (Vector-Jacobian Product) for efficiency
    @differentiable(vjp = custom_matmul_vjp)
    fn custom_matmul(a: Tensor<f32, [M, K]>, b: Tensor<f32, [K, N]>) -> Tensor<f32, [M, N]> {
        matmul(a, b)
    }

    fn custom_matmul_vjp(
        a: Tensor<f32, [M, K]>,
        b: Tensor<f32, [K, N]>,
        cotangent: Tensor<f32, [M, N]>
    ) -> (Tensor<f32, [M, K]>, Tensor<f32, [K, N]>) {
        // grad_a = matmul(cotangent, b.T)
        // grad_b = matmul(a.T, cotangent)
        (matmul(cotangent, b.T), matmul(a.T, cotangent))
    }

    // Non-differentiable operations are tracked
    @differentiable
    fn with_non_diff(x: Tensor<f32, [N]>) -> f32 {
        let positive = x.relu();  // Differentiable (subdifferentiable)
        let rounded = x.round();  // Non-differentiable, gradient is 0

        stop_gradient(rounded).sum()  // Explicit no-gradient
    }
}
