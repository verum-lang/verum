// @tier: 3
// @level: L3
// @skip-disabled: GPU tests downgraded to parse-only, runtime needs GPU device
// @tags: gpu, kernel, launch

@kernel(block_size = 256)
fn add_kernel(
    a: &Tensor<f32, [N]>,
    b: &Tensor<f32, [N]>,
    c: &mut Tensor<f32, [N]>
) {
    let idx = global_id().x;
    if idx < N {
        c[idx] = a[idx] + b[idx];
    }
}

@kernel(block_size = (16, 16), grid_size = auto)
fn matmul_kernel(
    a: &Tensor<f32, [M, K]>,
    b: &Tensor<f32, [K, N]>,
    c: &mut Tensor<f32, [M, N]>
) {
    let row = global_id().y;
    let col = global_id().x;

    if row < M && col < N {
        let mut sum = 0.0f32;
        for k in 0..K {
            sum += a[row, k] * b[k, col];
        }
        c[row, col] = sum;
    }
}

fn main() {
    // GPU kernel launch syntax (<<<grid, block>>>) requires runtime
    // This test validates kernel function parsing only
}
