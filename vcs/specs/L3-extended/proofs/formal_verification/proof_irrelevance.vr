// @test: verify-pass
// @tier: 3
// @level: L3
// @tags: proofs, formal-verification, irrelevance
// @timeout: 15000

/// Proof irrelevance: two proofs of the same proposition are equal

/// Basic proof irrelevance for Bool propositions
theorem bool_proof_irrelevance(p: Bool)
    requires p == true
    ensures true
{
    proof by auto
}

/// Proof irrelevance for ordering
theorem le_proof_irrelevance(a: Int, b: Int)
    requires a <= b
    ensures true
{
    proof by auto
}

/// Any two proofs of True are equal
theorem true_unique: True == True {
    proof by trivial
}

/// Proof irrelevance for arithmetic facts
theorem arith_irrelevance(n: Nat)
    requires n >= 0
    ensures true
{
    proof by trivial
}

/// Proof irrelevance in function types
/// Functions that return proof-irrelevant results are equal
theorem fn_proof_irrel(f: fn(Int) -> Bool, g: fn(Int) -> Bool)
    requires forall x: Int. f(x) == g(x)
    ensures f == g
{
    proof by auto
}

/// Proof irrelevance for propositions
theorem prop_irrelevance<P: Prop>()
    requires P
    ensures true
{
    proof by trivial
}

/// Proof of negation is unique
theorem neg_proof_unique<P: Prop>()
    requires !P
    ensures true
{
    proof by auto
}

/// Proof irrelevance for existentials (propositional truncation)
theorem exists_irrelevance(n: Nat)
    requires exists m: Nat. m > n
    ensures true
{
    proof by trivial
}

/// Proof terms don't affect computation
theorem proof_no_runtime_effect(x: Int, y: Int)
    requires x > 0
    requires y > 0
    ensures x + y == y + x
{
    proof by ring
}

/// Uniqueness of identity proofs (UIP)
theorem uip_nat(a: Nat, b: Nat)
    requires a == b
    ensures true
{
    proof by auto
}

/// Proof irrelevance for refinement types
theorem refinement_irrelevance(x: Int)
    requires x > 0
    requires x > 0
    ensures x > 0
{
    proof by auto
}

fn main() {}
