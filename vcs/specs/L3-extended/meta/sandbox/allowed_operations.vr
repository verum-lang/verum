// @test: typecheck-pass
// @tier: 3
// @level: L3
// @tags: meta, sandbox, allowed

/// Разрешённые операции в meta sandbox
///
/// Meta функции выполняются в изолированном sandbox,
/// который ограничивает доступные операции для безопасности.
/// Тест использует только базовые возможности языка без stdlib.

// ============================================================
// 1. ЧИСТЫЕ ВЫЧИСЛЕНИЯ
// ============================================================

meta fn pure_math(x: Int64, y: Int64) -> Int64 {
    x * y + x - y
}

meta fn pure_bool(a: Bool, b: Bool) -> Bool {
    (a && b) || (!a && !b)
}

// ============================================================
// 2. РАБОТА С МАССИВАМИ (ФИКСИРОВАННОГО РАЗМЕРА)
// ============================================================

meta fn process_array(items: [Int64; 4]) -> Int64 {
    let mut sum: Int64 = 0;
    let mut i = 0;
    while i < 4 {
        if items[i] > 0 {
            sum = sum + items[i] * 2;
        }
        i = i + 1;
    }
    sum
}

meta fn filter_positive() -> [Int64; 4] {
    // Возвращаем только положительные из примера
    let input: [Int64; 4] = [1, -2, 3, -4];
    let mut result: [Int64; 4] = [0, 0, 0, 0];
    let mut j = 0;
    let mut i = 0;
    while i < 4 {
        if input[i] > 0 {
            result[j] = input[i] * 2;
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

// ============================================================
// 3. PATTERN MATCHING
// ============================================================

type Maybe<T> is
    | Some(T)
    | None;

meta fn match_option(opt: Maybe<Int64>, default: Int64) -> Int64 {
    match opt {
        Maybe.Some(v) => v,
        Maybe.None => default,
    }
}

type Result<T, E> is
    | Ok(T)
    | Err(E);

meta fn match_result(result: Result<Int64, Int64>, on_error: Int64) -> Int64 {
    match result {
        Result.Ok(v) => v,
        Result.Err(_) => on_error,
    }
}

// ============================================================
// 4. РЕКУРСИЯ
// ============================================================

@allow(unbounded_recursion)
meta fn gcd(a: UInt64, b: UInt64) -> UInt64 {
    if b == 0 { a }
    else { gcd(b, a % b) }
}

@allow(unbounded_recursion)
meta fn factorial(n: UInt64) -> UInt64 {
    if n <= 1 { 1 }
    else { n * factorial(n - 1) }
}

@allow(unbounded_recursion)
meta fn fibonacci(n: UInt64) -> UInt64 {
    if n <= 1 { n }
    else { fibonacci(n - 1) + fibonacci(n - 2) }
}

// ============================================================
// 5. COMPILE-TIME ИНФОРМАЦИЯ
// ============================================================

const INT_SIZE: Int = @size_of(Int);
const BOOL_SIZE: Int = @size_of(Bool);

// Use type alias for pointer types in @size_of
type IntPtr is *const Int;
const PTR_SIZE: Int = @size_of(IntPtr);

// ============================================================
// 6. TYPE INTROSPECTION (READ-ONLY)
// ============================================================

type Point is {
    x: Int,
    y: Int,
};

const POINT_SIZE: Int = @size_of(Point);
const POINT_ALIGN: Int = @align_of(Point);

// ============================================================
// 7. БИТОВЫЕ ОПЕРАЦИИ
// ============================================================

meta fn bit_manipulation(n: UInt64) -> UInt64 {
    let a = n & 0xFF;          // AND
    let b = n | 0xFF00;        // OR
    let c = n ^ 0xFFFF;        // XOR
    let d = n << 4;            // Left shift
    let e = n >> 4;            // Right shift
    a + b + c + d + e
}

meta fn count_ones(n: UInt64) -> UInt64 {
    let mut count: UInt64 = 0;
    let mut x = n;
    while x > 0 {
        count = count + (x & 1);
        x = x >> 1;
    }
    count
}

// ============================================================
// 8. ЧИСТЫЕ ХЭШ-ФУНКЦИИ
// ============================================================

meta fn simple_hash(a: UInt64, b: UInt64, c: UInt64) -> UInt64 {
    let mut hash: UInt64 = 5381;
    hash = ((hash << 5) + hash) + a;
    hash = ((hash << 5) + hash) + b;
    hash = ((hash << 5) + hash) + c;
    hash
}

meta fn fnv1a_hash(a: UInt64, b: UInt64, c: UInt64) -> UInt64 {
    let offset: UInt64 = 14695981039346656037;
    let prime: UInt64 = 1099511628211;

    let mut hash = offset;
    hash = (hash ^ a) * prime;
    hash = (hash ^ b) * prime;
    hash = (hash ^ c) * prime;
    hash
}

// ============================================================
// 9. УСЛОВНАЯ ЛОГИКА
// ============================================================

meta fn max3(a: UInt64, b: UInt64, c: UInt64) -> UInt64 {
    if a >= b && a >= c { a }
    else if b >= c { b }
    else { c }
}

meta fn min3(a: UInt64, b: UInt64, c: UInt64) -> UInt64 {
    if a <= b && a <= c { a }
    else if b <= c { b }
    else { c }
}

meta fn abs_diff(a: Int64, b: Int64) -> Int64 {
    if a > b { a - b }
    else { b - a }
}

// ============================================================
// 10. COMPILE-TIME ASSERTIONS
// ============================================================

const _SIZE_CHECK: () = {
    @static_assert(@size_of(Int) == 8);
};

const _ALIGN_CHECK: () = {
    @static_assert(@align_of(Int) >= 4);
};

// ============================================================
// ИСПОЛЬЗОВАНИЕ РАЗРЕШЁННЫХ ОПЕРАЦИЙ
// ============================================================

const MATH_RESULT: Int64 = pure_math(10, 20);
const PROCESSED: [Int64; 4] = filter_positive();
const GCD_RESULT: UInt64 = gcd(48, 18);     // 6
const FACT_5: UInt64 = factorial(5);         // 120
const FIB_10: UInt64 = fibonacci(10);        // 55
const HASH_123: UInt64 = simple_hash(1, 2, 3);
const MAX_VAL: UInt64 = max3(5, 12, 8);      // 12
const MIN_VAL: UInt64 = min3(5, 12, 8);      // 5

fn main() {
    // Compile-time computed values used at runtime
    let result = MATH_RESULT;
    let gcd = GCD_RESULT;
    let fact = FACT_5;
}
