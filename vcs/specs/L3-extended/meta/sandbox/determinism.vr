// @test: typecheck-pass
// @tier: 3
// @level: L3
// @tags: meta, sandbox, determinism

/// Детерминизм meta функций
///
/// Meta функции ДОЛЖНЫ быть детерминированными:
/// одинаковые входные данные всегда дают одинаковый результат.
/// Тест использует только базовые возможности языка без stdlib.

// ============================================================
// ДЕТЕРМИНИРОВАННЫЕ ФУНКЦИИ (разрешены)
// ============================================================

// Чистые математические функции - всегда детерминированы
meta fn deterministic_math(x: Int64) -> Int64 {
    x * x + 2 * x + 1
}

// Рекурсия - детерминирована при чистых операциях
meta fn deterministic_fib(n: UInt64) -> UInt64 {
    match n {
        0 => 0,
        1 => 1,
        _ => deterministic_fib(n - 1) + deterministic_fib(n - 2),
    }
}

// Мемоизация для оптимизации (всё ещё детерминирована)
// Компилятор автоматически мемоизирует результаты meta функций
meta fn memoized_fib(n: UInt64) -> UInt64 {
    // Simple recursive implementation - compiler can optimize
    match n {
        0 => 0,
        1 => 1,
        _ => memoized_fib(n - 1) + memoized_fib(n - 2),
    }
}

// ============================================================
// ХЭШИРОВАНИЕ - ДЕТЕРМИНИРОВАНО
// ============================================================

// FNV-1a hash - детерминированный алгоритм
meta fn deterministic_hash(a: UInt64, b: UInt64, c: UInt64) -> UInt64 {
    let offset: UInt64 = 14695981039346656037;
    let prime: UInt64 = 1099511628211;

    let mut hash = offset;
    hash = (hash ^ a) * prime;
    hash = (hash ^ b) * prime;
    hash = (hash ^ c) * prime;
    hash
}

// ============================================================
// СОРТИРОВКА - ДЕТЕРМИНИРОВАНА (stable sort)
// ============================================================

meta fn sort_4(items: [Int64; 4]) -> [Int64; 4] {
    // Простая сортировка пузырьком для фиксированного массива
    let mut arr = items;
    let mut i = 0;
    while i < 3 {
        let mut j = 0;
        while j < 3 - i {
            if arr[j] > arr[j + 1] {
                let tmp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = tmp;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    arr
}

// ============================================================
// ФИЛЬТРАЦИЯ - ДЕТЕРМИНИРОВАНА
// ============================================================

meta fn filter_positive(items: [Int64; 4]) -> [Int64; 4] {
    let mut result: [Int64; 4] = [0, 0, 0, 0];
    let mut j = 0;
    let mut i = 0;
    while i < 4 {
        if items[i] > 0 {
            result[j] = items[i];
            j = j + 1;
        }
        i = i + 1;
    }
    result
}

// ============================================================
// ГАРАНТИИ ДЕТЕРМИНИЗМА
// ============================================================

// Компилятор проверяет детерминизм:
// 1. Нет доступа к внешнему состоянию
// 2. Нет IO операций
// 3. Нет random
// 4. Нет доступа к времени
// 5. Нет глобальных мутабельных переменных

// Пример с локальной мутабельностью (разрешено)
meta fn local_mutation(n: UInt64) -> UInt64 {
    // Локальная мутация не нарушает детерминизм
    let mut sum: UInt64 = 0;
    let mut i: UInt64 = 0;
    while i < n {
        sum = sum + i;
        i = i + 1;
    }
    sum
}

// ============================================================
// COMPILE-TIME ПРОВЕРКИ ДЕТЕРМИНИЗМА
// ============================================================

// Статические проверки одинаковых результатов
const _: () = {
    // Эти assertion-ы проверяются во время компиляции
    @static_assert(deterministic_math(5) == 36);  // 25 + 10 + 1
    @static_assert(deterministic_fib(10) == 55);
    @static_assert(deterministic_hash(1, 2, 3) == deterministic_hash(1, 2, 3));

    // Повторные вызовы дают одинаковый результат
    @static_assert(deterministic_math(100) == deterministic_math(100));
};

// Компилятор может кэшировать результаты meta функций,
// потому что они гарантированно детерминированы
const CACHED_FIB_20: UInt64 = memoized_fib(20);  // Вычисляется один раз

// ============================================================
// ИДЕМПОТЕНТНОСТЬ
// ============================================================

// Идемпотентность - многократное применение даёт тот же результат
meta fn idempotent_clamp(x: Int64, min: Int64, max: Int64) -> Int64 {
    if x < min { min }
    else if x > max { max }
    else { x }
}

const _: () = {
    let clamped = idempotent_clamp(150, 0, 100);     // 100
    let reclamped = idempotent_clamp(clamped, 0, 100); // 100
    @static_assert(clamped == reclamped);  // Повторное clamping не меняет результат
};

// ============================================================
// КОММУТАТИВНОСТЬ ОПЕРАЦИЙ (ГДЕ ПРИМЕНИМО)
// ============================================================

meta fn max_of_two(a: Int64, b: Int64) -> Int64 {
    if a >= b { a } else { b }
}

meta fn min_of_two(a: Int64, b: Int64) -> Int64 {
    if a <= b { a } else { b }
}

const _: () = {
    // max и min коммутативны
    @static_assert(max_of_two(10, 20) == max_of_two(20, 10));
    @static_assert(min_of_two(10, 20) == min_of_two(20, 10));
};

// ============================================================
// АССОЦИАТИВНОСТЬ
// ============================================================

meta fn add(a: Int64, b: Int64) -> Int64 {
    a + b
}

const _: () = {
    // Сложение ассоциативно
    @static_assert(add(add(1, 2), 3) == add(1, add(2, 3)));
};

// ============================================================
// ИСПОЛЬЗОВАНИЕ
// ============================================================

const MATH_RESULT: Int64 = deterministic_math(10);  // 121
const FIB_RESULT: UInt64 = deterministic_fib(10);   // 55
const HASH_RESULT: UInt64 = deterministic_hash(1, 2, 3);
const SORTED: [Int64; 4] = sort_4([3, 1, 4, 2]);    // [1, 2, 3, 4]
const FILTERED: [Int64; 4] = filter_positive([-1, 2, -3, 4]); // [2, 4, 0, 0]
const SUM_10: UInt64 = local_mutation(10);          // 45

fn main() {
    // All values computed at compile time
    let math = MATH_RESULT;
    let fib = FIB_RESULT;
    let sorted = SORTED;
}
