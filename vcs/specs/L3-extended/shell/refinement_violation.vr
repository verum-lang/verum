// @test: typecheck-pass
// @tier: 0
// @level: L3
// @tags: shell, refinement, verify, runtime-check
// @timeout: 30000
// @expect: pass

// DeployConfig.parse refines `version` to a SemVer string at construction.
// This test exercises the runtime refinement check: a malformed version
// returns Err — the test asserts Err shape rather than compile failure
// because Verum's refinement-on-constructor pattern is checked at the
// call site, not in the type signature itself.

mount core.shell.verify.{DeployConfig};
mount core.shell.result.{ShellError};

fn main() {
    let bad_version = DeployConfig.parse(
        "myservice".into(),
        "not-a-semver".into(),    // refinement violation — runtime Err
        "production".into(),
        "manifest.yaml".into(),
        300,
    );
    assert(bad_version.is_err(), "DeployConfig.parse must reject bad version");

    let good = DeployConfig.parse(
        "myservice".into(),
        "1.2.3".into(),
        "production".into(),
        "manifest.yaml".into(),
        300,
    );
    assert(good.is_ok(), "DeployConfig.parse must accept valid input");
}
