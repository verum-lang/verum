// @test: typecheck-pass
// @tier: 0
// @level: L3
// @tags: shell, permission, capability-audit, runtime-check
// @timeout: 30000
// @expect: pass

// Runtime permission gate: PermissionSet.check_run rejects programs not
// in the allow-list.  A static `@permission(run: [...])` audit pass that
// rejects sh#"X" calls outside the declared list is tracked separately —
// this test exercises the runtime gate the audit pass relies on.

mount core.shell.context.{PermissionSet};
mount core.shell.result.{ShellError};

fn main() {
    let p = PermissionSet.deny_all().with_run(["kubectl".into()]);
    assert(p.check_run(&"kubectl".into()).is_ok(),  "kubectl is allow-listed");
    assert(p.check_run(&"curl".into()).is_err(),    "curl is denied");
    assert(p.check_run(&"/usr/bin/kubectl".into()).is_ok(),
           "absolute path matches by basename");
}
