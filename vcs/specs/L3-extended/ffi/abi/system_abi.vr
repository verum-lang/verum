// @test: compile-only
// @tier: 3
// @level: L3
// @tags: ffi, abi, system, calling-convention, unsafe
// @description: Tests system ABI calling convention (stdcall on Windows x86)

/// ============================================================
/// SYSTEM ABI
/// ============================================================
///
/// The "system" calling convention is platform-specific:
/// - Windows x86: stdcall
/// - Windows x64: win64 (same as C)
/// - Unix: C calling convention

// ------------------------------------------------------------
// System Calling Convention
// ------------------------------------------------------------

/// System convention (platform-specific)
ffi system_lib {
    @extern("system")
    fn system_function(a: c_int, b: c_int) -> c_int;
}

/// Export with system convention
@export("system")
extern "system" fn verum_system(a: c_int, b: c_int) -> c_int {
    a * b
}

// ------------------------------------------------------------
// Windows System Calls
// ------------------------------------------------------------

@cfg(target_os = "windows")
ffi kernel32 {
    /// Windows API uses stdcall on x86, win64 on x64
    @extern("system")
    fn GetLastError() -> DWORD;

    @extern("system")
    fn SetLastError(dwErrCode: DWORD);

    @extern("system")
    fn CloseHandle(hObject: HANDLE) -> BOOL;

    @extern("system")
    fn CreateFileW(
        lpFileName: LPCWSTR,
        dwDesiredAccess: DWORD,
        dwShareMode: DWORD,
        lpSecurityAttributes: *mut SECURITY_ATTRIBUTES,
        dwCreationDisposition: DWORD,
        dwFlagsAndAttributes: DWORD,
        hTemplateFile: HANDLE
    ) -> HANDLE;

    @extern("system")
    fn ReadFile(
        hFile: HANDLE,
        lpBuffer: LPVOID,
        nNumberOfBytesToRead: DWORD,
        lpNumberOfBytesRead: LPDWORD,
        lpOverlapped: *mut OVERLAPPED
    ) -> BOOL;

    @extern("system")
    fn WriteFile(
        hFile: HANDLE,
        lpBuffer: LPCVOID,
        nNumberOfBytesToWrite: DWORD,
        lpNumberOfBytesWritten: LPDWORD,
        lpOverlapped: *mut OVERLAPPED
    ) -> BOOL;

    @extern("system")
    fn GetModuleHandleW(lpModuleName: LPCWSTR) -> HMODULE;

    @extern("system")
    fn GetProcAddress(hModule: HMODULE, lpProcName: LPCSTR) -> FARPROC;

    @extern("system")
    fn VirtualAlloc(
        lpAddress: LPVOID,
        dwSize: SIZE_T,
        flAllocationType: DWORD,
        flProtect: DWORD
    ) -> LPVOID;

    @extern("system")
    fn VirtualFree(
        lpAddress: LPVOID,
        dwSize: SIZE_T,
        dwFreeType: DWORD
    ) -> BOOL;
}

@cfg(target_os = "windows")
ffi user32 {
    @extern("system")
    fn MessageBoxW(
        hWnd: HWND,
        lpText: LPCWSTR,
        lpCaption: LPCWSTR,
        uType: UINT
    ) -> c_int;

    @extern("system")
    fn GetMessageW(
        lpMsg: *mut MSG,
        hWnd: HWND,
        wMsgFilterMin: UINT,
        wMsgFilterMax: UINT
    ) -> BOOL;

    @extern("system")
    fn DispatchMessageW(lpMsg: *const MSG) -> LRESULT;

    @extern("system")
    fn DefWindowProcW(
        hWnd: HWND,
        Msg: UINT,
        wParam: WPARAM,
        lParam: LPARAM
    ) -> LRESULT;
}

// ------------------------------------------------------------
// Windows Types
// ------------------------------------------------------------

@cfg(target_os = "windows")
type BOOL is c_int;
@cfg(target_os = "windows")
type DWORD is u32;
@cfg(target_os = "windows")
type UINT is u32;
@cfg(target_os = "windows")
type HANDLE is *mut c_void;
@cfg(target_os = "windows")
type HWND is *mut c_void;
@cfg(target_os = "windows")
type HMODULE is *mut c_void;
@cfg(target_os = "windows")
type LPVOID is *mut c_void;
@cfg(target_os = "windows")
type LPCVOID is *const c_void;
@cfg(target_os = "windows")
type LPDWORD is *mut DWORD;
@cfg(target_os = "windows")
type LPCSTR is *const c_char;
@cfg(target_os = "windows")
type LPCWSTR is *const u16;
@cfg(target_os = "windows")
type FARPROC is *mut c_void;
@cfg(target_os = "windows")
type SIZE_T is usize;
@cfg(target_os = "windows")
type WPARAM is usize;
@cfg(target_os = "windows")
type LPARAM is isize;
@cfg(target_os = "windows")
type LRESULT is isize;

@cfg(target_os = "windows")
@extern
type SECURITY_ATTRIBUTES is ();

@cfg(target_os = "windows")
@extern
type OVERLAPPED is ();

@cfg(target_os = "windows")
@extern
type MSG is ();

// ------------------------------------------------------------
// Windows Constants
// ------------------------------------------------------------

@cfg(target_os = "windows")
const INVALID_HANDLE_VALUE: HANDLE = -1isize as HANDLE;
@cfg(target_os = "windows")
const NULL_HANDLE: HANDLE = 0 as HANDLE;

@cfg(target_os = "windows")
const GENERIC_READ: DWORD = 0x80000000;
@cfg(target_os = "windows")
const GENERIC_WRITE: DWORD = 0x40000000;
@cfg(target_os = "windows")
const FILE_SHARE_READ: DWORD = 0x00000001;
@cfg(target_os = "windows")
const OPEN_EXISTING: DWORD = 3;
@cfg(target_os = "windows")
const CREATE_ALWAYS: DWORD = 2;

@cfg(target_os = "windows")
const MEM_COMMIT: DWORD = 0x1000;
@cfg(target_os = "windows")
const MEM_RESERVE: DWORD = 0x2000;
@cfg(target_os = "windows")
const MEM_RELEASE: DWORD = 0x8000;
@cfg(target_os = "windows")
const PAGE_READWRITE: DWORD = 0x04;

@cfg(target_os = "windows")
const MB_OK: UINT = 0x00000000;
@cfg(target_os = "windows")
const MB_YESNO: UINT = 0x00000004;
@cfg(target_os = "windows")
const MB_ICONERROR: UINT = 0x00000010;

// ------------------------------------------------------------
// Safe Windows Wrappers
// ------------------------------------------------------------

@cfg(target_os = "windows")
fn get_last_error() -> DWORD {
    // SAFETY: Always safe to call
    unsafe { kernel32.GetLastError() }
}

@cfg(target_os = "windows")
fn close_handle(handle: HANDLE) -> Bool {
    if handle == INVALID_HANDLE_VALUE || handle == NULL_HANDLE {
        return false;
    }
    // SAFETY: Handle must be valid
    unsafe { kernel32.CloseHandle(handle) != 0 }
}

@cfg(target_os = "windows")
type WinHandle is {
    handle: HANDLE,
};

@cfg(target_os = "windows")
implement WinHandle {
    fn new(handle: HANDLE) -> Maybe<WinHandle> {
        if handle == INVALID_HANDLE_VALUE || handle == NULL_HANDLE {
            None
        } else {
            Some(WinHandle { handle })
        }
    }

    fn as_raw(&self) -> HANDLE {
        self.handle
    }
}

@cfg(target_os = "windows")
implement Drop for WinHandle {
    fn drop(&mut self) {
        if self.handle != INVALID_HANDLE_VALUE && self.handle != NULL_HANDLE {
            unsafe { kernel32.CloseHandle(self.handle); }
        }
    }
}

@cfg(target_os = "windows")
fn message_box(text: &str, caption: &str, style: UINT) -> c_int {
    let wide_text = text.to_wide_null();
    let wide_caption = caption.to_wide_null();

    // SAFETY: Strings are valid null-terminated wide strings
    unsafe {
        user32.MessageBoxW(
            NULL_HANDLE as HWND,
            wide_text.as_ptr(),
            wide_caption.as_ptr(),
            style
        )
    }
}

// ------------------------------------------------------------
// Unix System Calls (for comparison)
// ------------------------------------------------------------

@cfg(unix)
ffi libc {
    /// Unix uses C convention for system calls
    @extern("C")
    fn syscall(number: c_long, ...) -> c_long;

    @extern("C")
    fn open(pathname: *const c_char, flags: c_int, ...) -> c_int;

    @extern("C")
    fn close(fd: c_int) -> c_int;

    @extern("C")
    fn read(fd: c_int, buf: *mut c_void, count: c_size_t) -> c_ssize_t;

    @extern("C")
    fn write(fd: c_int, buf: *const c_void, count: c_size_t) -> c_ssize_t;

    @extern("C")
    fn mmap(
        addr: *mut c_void,
        length: c_size_t,
        prot: c_int,
        flags: c_int,
        fd: c_int,
        offset: off_t
    ) -> *mut c_void;

    @extern("C")
    fn munmap(addr: *mut c_void, length: c_size_t) -> c_int;
}

// ------------------------------------------------------------
// Cross-Platform Abstraction
// ------------------------------------------------------------

/// Platform-agnostic file handle
type FileHandle is {
    @cfg(windows)
    handle: HANDLE,
    @cfg(unix)
    fd: c_int,
};

implement FileHandle {
    @cfg(windows)
    fn open(path: &str, write: Bool) -> Result<FileHandle, FfiIoError> {
        let wide_path = path.to_wide_null();
        let access = if write { GENERIC_WRITE } else { GENERIC_READ };
        let disposition = if write { CREATE_ALWAYS } else { OPEN_EXISTING };

        let handle = unsafe {
            kernel32.CreateFileW(
                wide_path.as_ptr(),
                access,
                FILE_SHARE_READ,
                std.ptr.null as *mut c_void,
                disposition,
                0,
                NULL_HANDLE
            )
        };

        if handle == INVALID_HANDLE_VALUE {
            Err(FfiIoError.from_last_error())
        } else {
            Ok(FileHandle { handle })
        }
    }

    @cfg(unix)
    fn open(path: &str, write: Bool) -> Result<FileHandle, FfiIoError> {
        let c_path = path.to_cstring();
        let flags = if write { O_WRONLY | O_CREAT | O_TRUNC } else { O_RDONLY };

        let fd = unsafe {
            libc.open(c_path.as_ptr(), flags, 0o644)
        };

        if fd < 0 {
            Err(FfiIoError.from_errno())
        } else {
            Ok(FileHandle { fd })
        }
    }

    fn close(self) {
        // Handled by Drop
    }
}

implement Drop for FileHandle {
    fn drop(&mut self) {
        @cfg(windows)
        {
            if self.handle != INVALID_HANDLE_VALUE {
                unsafe { kernel32.CloseHandle(self.handle); }
            }
        }

        @cfg(unix)
        {
            if self.fd >= 0 {
                unsafe { libc.close(self.fd); }
            }
        }
    }
}

// ------------------------------------------------------------
// Type Definitions
// ------------------------------------------------------------

type c_char is i8;
type c_int is i32;
type c_long is i64;
type c_size_t is usize;
type c_ssize_t is isize;
type c_void is ();
type off_t is i64;

@cfg(unix)
const O_RDONLY: c_int = 0;
@cfg(unix)
const O_WRONLY: c_int = 1;
@cfg(unix)
const O_CREAT: c_int = 0o100;
@cfg(unix)
const O_TRUNC: c_int = 0o1000;

type FfiIoError is
    | NotFound
    | PermissionDenied
    | Other(c_int);

implement FfiIoError {
    @cfg(windows)
    fn from_last_error() -> FfiIoError {
        let code = unsafe { kernel32.GetLastError() };
        Other(code as c_int)
    }

    @cfg(unix)
    fn from_errno() -> FfiIoError {
        // Would read errno
        Other(-1)
    }
}

fn main() {
    // System ABI tests
}
