// @test: typecheck-pass
// @tier: 3
// @level: L3
// @tags: ffi, safety, buffer-overflow
// @description: Tests buffer size validation patterns at FFI boundaries

/// ============================================================
/// BUFFER OVERFLOW PREVENTION - FFI PATTERNS
/// ============================================================
///
/// Buffer overflows are critical security vulnerabilities. This file
/// demonstrates safe buffer handling patterns for FFI boundaries.

// ------------------------------------------------------------
// Type Definitions
// ------------------------------------------------------------

type c_void is ();
type c_char is i8;
type c_int is i32;
type c_size is usize;

type BufferError is
    | NullPointer
    | ZeroSizeBuffer
    | IndexOutOfBounds
    | InsufficientCapacity
    | ArithmeticOverflow
    | NoNullTerminator
    | InvalidUtf8;

// ------------------------------------------------------------
// Bounded Buffer Types
// ------------------------------------------------------------

/// Buffer with known capacity
@repr(C)
type BoundedBuffer is {
    ptr: *mut u8,
    len: c_size,
    capacity: c_size,
};

/// Immutable bounded slice view
@repr(C)
type BoundedSlice is {
    ptr: *const u8,
    len: c_size,
};

// ------------------------------------------------------------
// FFI Buffer Validation - libc bindings
// ------------------------------------------------------------

ffi libc_memcpy {
    @extern("C")
    fn memcpy(dest: *mut c_void, src: *const c_void, n: c_size) -> *mut c_void;
}

ffi libc_memmove {
    @extern("C")
    fn memmove(dest: *mut c_void, src: *const c_void, n: c_size) -> *mut c_void;
}

ffi libc_memset {
    @extern("C")
    fn memset(s: *mut c_void, c: c_int, n: c_size) -> *mut c_void;
}

ffi libc_strncpy {
    @extern("C")
    fn strncpy(dest: *mut c_char, src: *const c_char, n: c_size) -> *mut c_char;
}

ffi libc_snprintf {
    @extern("C")
    fn snprintf(str: *mut c_char, size: c_size, format: *const c_char) -> c_int;
}

ffi libc_strlen {
    @extern("C")
    fn strlen(s: *const c_char) -> c_size;
}

// ------------------------------------------------------------
// FFI Buffer Callback Pattern
// ------------------------------------------------------------

/// Callback that receives buffer with size
@repr(C)
type BufferCallbackCtx is {
    buffer: *mut u8,
    size: c_size,
    user_data: *mut c_void,
};

// ------------------------------------------------------------
// Chunked Processing Types
// ------------------------------------------------------------

/// Stream processing context
@repr(C)
type StreamContext is {
    read_ptr: *const u8,
    read_len: c_size,
    write_ptr: *mut u8,
    write_len: c_size,
};

// ------------------------------------------------------------
// Range Types
// ------------------------------------------------------------

/// Range specification for buffer operations
@repr(C)
type BufferRange is {
    start: c_size,
    end: c_size,
};

// ------------------------------------------------------------
// Export Functions
// ------------------------------------------------------------

/// Export function that validates input buffer
@export("C")
@no_mangle
fn process_buffer(
    input: *const u8,
    input_len: c_size,
    output: *mut u8,
    output_len: c_size
) -> c_int {
    // Check output is large enough
    if output_len < input_len {
        return -3;  // Output too small
    }

    input_len as c_int
}

// ------------------------------------------------------------
// Main
// ------------------------------------------------------------

fn main() {
    // Test FFI declarations and types compile
    print("Buffer overflow prevention patterns passed");
}
