implement Sandbox {
    fn clone(&self) -> Sandbox {
        Sandbox {
            allow_file_io: self.allow_file_io,
            allow_network: self.allow_network,
            allow_subprocess: self.allow_subprocess,
            memory_limit: self.memory_limit,
            cpu_time_limit_ms: self.cpu_time_limit_ms,
            instruction_limit: self.instruction_limit,
        }
    }
}

// Import from embed_runtime
extern "C" {
    fn verum_runtime_create() -> *mut VerumRuntime;
    fn verum_runtime_destroy(runtime: *mut VerumRuntime);
}

@opaque
type VerumRuntime is ();

@opaque
type VerumModule is ();

@opaque
type VerumValue is ();

type Value is
    | Null
    | Bool(Bool)
    | Int(i64)
    | Float(f64)
    | Text(Text)
    | Array(List<Value>)
    | Object(Map<Text, Value>);

implement Value {
    fn clone(&self) -> Value {
        match self {
            Value.Null => Value.Null,
            Value.Bool(b) => Value.Bool(*b),
            Value.Int(i) => Value.Int(*i),
            Value.Float(f) => Value.Float(*f),
            Value.Text(s) => Value.Text(s.clone()),
            Value.Array(a) => Value.Array(a.clone()),
            Value.Object(o) => Value.Object(o.clone()),
        }
    }
}

type c_char is i8;
type c_int is i32;
type c_void is ();

type CStr is { ptr: *const c_char };
implement CStr {
    unsafe fn from_ptr(ptr: *const c_char) -> CStr { CStr { ptr } }
    fn to_str(&self) -> Result<&str, ()> { Ok("") }
}

