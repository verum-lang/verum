// @test: compile-only
// @tier: 3
// @level: L3
// @tags: ffi, memory, raw-pointer
// @description: Tests raw pointer operations for FFI interoperability

type c_int is i32;
type c_char is i8;
type c_void is ();
type size_t is usize;

ffi libc {
    @extern("C")
    fn malloc(size: size_t) -> *mut c_void;
    @extern("C")
    fn free(ptr: *mut c_void);
    @extern("C")
    fn memcpy(dst: *mut c_void, src: *const c_void, n: size_t) -> *mut c_void;
}

/// Pointer arithmetic
fn ptr_add(ptr: *const u8, offset: size_t) -> *const u8 {
    unsafe { ptr.add(offset) }
}

fn ptr_add_mut(ptr: *mut u8, offset: size_t) -> *mut u8 {
    unsafe { ptr.add(offset) }
}

/// Pointer dereference
fn read_ptr(ptr: *const c_int) -> c_int {
    unsafe { *ptr }
}

fn write_ptr(ptr: *mut c_int, val: c_int) {
    unsafe { *ptr = val; }
}

/// Pointer comparison
fn ptr_eq(a: *const c_void, b: *const c_void) -> Bool {
    a == b
}

/// Pointer casting
fn cast_to_void(ptr: *mut u8) -> *mut c_void {
    ptr as *mut c_void
}

fn cast_from_void(ptr: *mut c_void) -> *mut u8 {
    ptr as *mut u8
}

/// Safe slice creation from raw parts
unsafe fn slice_from_raw(ptr: *const u8, len: size_t) -> &[u8] {
    &*std.ptr.slice_from_raw_parts(ptr, len)
}

/// C string operations
unsafe fn cstr_len(s: *const c_char) -> size_t {
    let mut len: size_t = 0;
    let mut p = s;
    while *p != 0 {
        len += 1;
        p = p.add(1);
    }
    len
}

/// Copy between raw buffers
unsafe fn raw_copy(dst: *mut u8, src: *const u8, len: size_t) {
    libc.memcpy(dst as *mut c_void, src as *const c_void, len);
}

/// Zero fill
unsafe fn raw_zero(dst: *mut u8, len: size_t) {
    for i in 0..len {
        *dst.add(i) = 0;
    }
}

/// Non-null pointer wrapper
type NonNull<T> is { ptr: *mut T };

implement NonNull<c_void> {
    fn new(ptr: *mut c_void) -> Maybe<NonNull<c_void>> {
        if ptr.is_null() {
            None
        } else {
            Some(NonNull { ptr })
        }
    }
}

fn main() {
    let mut value: c_int = 42;
    let ptr = &mut value as *mut c_int;
    write_ptr(ptr, 100);
    assert(read_ptr(ptr as *const c_int) == 100);
}
