// @test: compile-only
// @tier: 3
// @level: L3
// @tags: ffi, serialization, messagepack
// @description: Tests MessagePack serialization for compact FFI data exchange

/// ============================================================
/// MESSAGEPACK SERIALIZATION
/// ============================================================
///
/// MessagePack is a binary format similar to JSON but more compact.
/// Itps widely used in network protocols and FFI data exchange.

// ------------------------------------------------------------
// MessagePack Format Codes
// ------------------------------------------------------------

module format {
    // Positive fixint: 0x00 - 0x7f
    pub const POSITIVE_FIXINT_MAX: u8 = 0x7f;

    // Fixmap: 0x80 - 0x8f (up to 15 elements)
    pub const FIXMAP_MIN: u8 = 0x80;
    pub const FIXMAP_MAX: u8 = 0x8f;

    // Fixarray: 0x90 - 0x9f (up to 15 elements)
    pub const FIXARRAY_MIN: u8 = 0x90;
    pub const FIXARRAY_MAX: u8 = 0x9f;

    // Fixstr: 0xa0 - 0xbf (up to 31 bytes)
    pub const FIXSTR_MIN: u8 = 0xa0;
    pub const FIXSTR_MAX: u8 = 0xbf;

    // Nil, false, true
    pub const NIL: u8 = 0xc0;
    pub const FALSE: u8 = 0xc2;
    pub const TRUE: u8 = 0xc3;

    // Binary
    pub const BIN8: u8 = 0xc4;
    pub const BIN16: u8 = 0xc5;
    pub const BIN32: u8 = 0xc6;

    // Extension
    pub const EXT8: u8 = 0xc7;
    pub const EXT16: u8 = 0xc8;
    pub const EXT32: u8 = 0xc9;

    // Float
    pub const FLOAT32: u8 = 0xca;
    pub const FLOAT64: u8 = 0xcb;

    // Unsigned int
    pub const UINT8: u8 = 0xcc;
    pub const UINT16: u8 = 0xcd;
    pub const UINT32: u8 = 0xce;
    pub const UINT64: u8 = 0xcf;

    // Signed int
    pub const INT8: u8 = 0xd0;
    pub const INT16: u8 = 0xd1;
    pub const INT32: u8 = 0xd2;
    pub const INT64: u8 = 0xd3;

    // Fixed ext
    pub const FIXEXT1: u8 = 0xd4;
    pub const FIXEXT2: u8 = 0xd5;
    pub const FIXEXT4: u8 = 0xd6;
    pub const FIXEXT8: u8 = 0xd7;
    pub const FIXEXT16: u8 = 0xd8;

    // Text
    pub const STR8: u8 = 0xd9;
    pub const STR16: u8 = 0xda;
    pub const STR32: u8 = 0xdb;

    // Array
    pub const ARRAY16: u8 = 0xdc;
    pub const ARRAY32: u8 = 0xdd;

    // Map
    pub const MAP16: u8 = 0xde;
    pub const MAP32: u8 = 0xdf;

    // Negative fixint: 0xe0 - 0xff (-32 to -1)
    pub const NEGATIVE_FIXINT_MIN: u8 = 0xe0;
}

// ------------------------------------------------------------
// MessagePack Value
// ------------------------------------------------------------

type MsgPackValue is
    | Nil
    | Bool(Bool)
    | Int(i64)
    | UInt(u64)
    | Float(f64)
    | Text(Text)
    | Binary(List<u8>)
    | Array(List<MsgPackValue>)
    | Map(List<(MsgPackValue, MsgPackValue)>)
    | Extension { type_id: i8, data: List<u8> };

// ------------------------------------------------------------
// Encoder
// ------------------------------------------------------------

type MsgPackWriter is {
    buffer: List<u8>,
};

implement MsgPackWriter {
    fn new() -> MsgPackWriter {
        MsgPackWriter { buffer: List.new() }
    }

    fn into_bytes(self) -> List<u8> {
        self.buffer
    }

    fn write_nil(&mut self) {
        self.buffer.push(format.NIL);
    }

    fn write_bool(&mut self, value: Bool) {
        self.buffer.push(if value { format.TRUE } else { format.FALSE });
    }

    fn write_int(&mut self, value: i64) {
        if value >= 0 {
            self.write_uint(value as u64);
        } else if value >= -32 {
            // Negative fixint
            self.buffer.push(value as u8);
        } else if value >= i8.MIN as i64 {
            self.buffer.push(format.INT8);
            self.buffer.push(value as u8);
        } else if value >= i16.MIN as i64 {
            self.buffer.push(format.INT16);
            self.buffer.extend_from_slice(&(value as i16).to_be_bytes());
        } else if value >= i32.MIN as i64 {
            self.buffer.push(format.INT32);
            self.buffer.extend_from_slice(&(value as i32).to_be_bytes());
        } else {
            self.buffer.push(format.INT64);
            self.buffer.extend_from_slice(&value.to_be_bytes());
        }
    }

    fn write_uint(&mut self, value: u64) {
        if value <= format.POSITIVE_FIXINT_MAX as u64 {
            // Positive fixint
            self.buffer.push(value as u8);
        } else if value <= u8.MAX as u64 {
            self.buffer.push(format.UINT8);
            self.buffer.push(value as u8);
        } else if value <= u16.MAX as u64 {
            self.buffer.push(format.UINT16);
            self.buffer.extend_from_slice(&(value as u16).to_be_bytes());
        } else if value <= u32.MAX as u64 {
            self.buffer.push(format.UINT32);
            self.buffer.extend_from_slice(&(value as u32).to_be_bytes());
        } else {
            self.buffer.push(format.UINT64);
            self.buffer.extend_from_slice(&value.to_be_bytes());
        }
    }

    fn write_f32(&mut self, value: f32) {
        self.buffer.push(format.FLOAT32);
        self.buffer.extend_from_slice(&value.to_be_bytes());
    }

    fn write_f64(&mut self, value: f64) {
        self.buffer.push(format.FLOAT64);
        self.buffer.extend_from_slice(&value.to_be_bytes());
    }

    fn write_string(&mut self, s: &str) {
        let bytes = s.as_bytes();
        let len = bytes.len();

        if len <= 31 {
            // Fixstr
            self.buffer.push(format.FIXSTR_MIN | (len as u8));
        } else if len <= u8.MAX as usize {
            self.buffer.push(format.STR8);
            self.buffer.push(len as u8);
        } else if len <= u16.MAX as usize {
            self.buffer.push(format.STR16);
            self.buffer.extend_from_slice(&(len as u16).to_be_bytes());
        } else {
            self.buffer.push(format.STR32);
            self.buffer.extend_from_slice(&(len as u32).to_be_bytes());
        }
        self.buffer.extend_from_slice(bytes);
    }

    fn write_binary(&mut self, data: &[u8]) {
        let len = data.len();

        if len <= u8.MAX as usize {
            self.buffer.push(format.BIN8);
            self.buffer.push(len as u8);
        } else if len <= u16.MAX as usize {
            self.buffer.push(format.BIN16);
            self.buffer.extend_from_slice(&(len as u16).to_be_bytes());
        } else {
            self.buffer.push(format.BIN32);
            self.buffer.extend_from_slice(&(len as u32).to_be_bytes());
        }
        self.buffer.extend_from_slice(data);
    }

    fn write_array_header(&mut self, len: usize) {
        if len <= 15 {
            // Fixarray
            self.buffer.push(format.FIXARRAY_MIN | (len as u8));
        } else if len <= u16.MAX as usize {
            self.buffer.push(format.ARRAY16);
            self.buffer.extend_from_slice(&(len as u16).to_be_bytes());
        } else {
            self.buffer.push(format.ARRAY32);
            self.buffer.extend_from_slice(&(len as u32).to_be_bytes());
        }
    }

    fn write_map_header(&mut self, len: usize) {
        if len <= 15 {
            // Fixmap
            self.buffer.push(format.FIXMAP_MIN | (len as u8));
        } else if len <= u16.MAX as usize {
            self.buffer.push(format.MAP16);
            self.buffer.extend_from_slice(&(len as u16).to_be_bytes());
        } else {
            self.buffer.push(format.MAP32);
            self.buffer.extend_from_slice(&(len as u32).to_be_bytes());
        }
    }

    fn write_ext(&mut self, type_id: i8, data: &[u8]) {
        let len = data.len();

        match len {
            1 => self.buffer.push(format.FIXEXT1),
            2 => self.buffer.push(format.FIXEXT2),
            4 => self.buffer.push(format.FIXEXT4),
            8 => self.buffer.push(format.FIXEXT8),
            16 => self.buffer.push(format.FIXEXT16),
            _ if len <= u8.MAX as usize => {
                self.buffer.push(format.EXT8);
                self.buffer.push(len as u8);
            }
            _ if len <= u16.MAX as usize => {
                self.buffer.push(format.EXT16);
                self.buffer.extend_from_slice(&(len as u16).to_be_bytes());
            }
            _ => {
                self.buffer.push(format.EXT32);
                self.buffer.extend_from_slice(&(len as u32).to_be_bytes());
            }
        }
        self.buffer.push(type_id as u8);
        self.buffer.extend_from_slice(data);
    }

    fn write_value(&mut self, value: &MsgPackValue) {
        match value {
            Nil => self.write_nil(),
            Bool(b) => self.write_bool(b),
            Int(i) => self.write_int(i),
            UInt(u) => self.write_uint(u),
            Float(f) => self.write_f64(f),
            Text(s) => self.write_string(s),
            Binary(b) => self.write_binary(b),
            Array(arr) => {
                self.write_array_header(arr.len());
                for elem in arr {
                    self.write_value(elem);
                }
            }
            Map(map) => {
                self.write_map_header(map.len());
                for (k, v) in map {
                    self.write_value(k);
                    self.write_value(v);
                }
            }
            Extension { type_id, data } => {
                self.write_ext(type_id, data);
            }
        }
    }
}

// ------------------------------------------------------------
// Decoder
// ------------------------------------------------------------

type MsgPackReader is {
    data: &[u8],
    pos: usize,
};

implement MsgPackReader {
    fn new(data: &[u8]) -> MsgPackReader {
        MsgPackReader { data, pos: 0 }
    }

    fn remaining(&self) -> usize {
        self.data.len() - self.pos
    }

    fn read_byte(&mut self) -> Result<u8, MsgPackError> {
        if self.pos >= self.data.len() {
            return Err(UnexpectedEof);
        }
        let byte = self.data[self.pos];
        self.pos += 1;
        Ok(byte)
    }

    fn read_bytes(&mut self, len: usize) -> Result<&[u8], MsgPackError> {
        if self.remaining() < len {
            return Err(UnexpectedEof);
        }
        let bytes = &self.data[self.pos..self.pos + len];
        self.pos += len;
        Ok(bytes)
    }

    fn read_u16(&mut self) -> Result<u16, MsgPackError> {
        let bytes = self.read_bytes(2)?;
        Ok(u16.from_be_bytes([bytes[0], bytes[1]]))
    }

    fn read_u32(&mut self) -> Result<u32, MsgPackError> {
        let bytes = self.read_bytes(4)?;
        Ok(((bytes[0] as u32) << 24) | ((bytes[1] as u32) << 16) | ((bytes[2] as u32) << 8) | (bytes[3] as u32))
    }

    fn read_u64(&mut self) -> Result<u64, MsgPackError> {
        let bytes = self.read_bytes(8)?;
        Ok(u64.from_be_bytes([
            bytes[0], bytes[1], bytes[2], bytes[3],
            bytes[4], bytes[5], bytes[6], bytes[7],
        ]))
    }

    fn read_value(&mut self) -> Result<MsgPackValue, MsgPackError> {
        let byte = self.read_byte()?;

        match byte {
            // Positive fixint
            0x00..=0x7f => Ok(UInt(byte as u64)),

            // Fixmap
            0x80..=0x8f => {
                let len = (byte & 0x0f) as usize;
                self.read_map(len)
            }

            // Fixarray
            0x90..=0x9f => {
                let len = (byte & 0x0f) as usize;
                self.read_array(len)
            }

            // Fixstr
            0xa0..=0xbf => {
                let len = (byte & 0x1f) as usize;
                self.read_string(len)
            }

            format.NIL => Ok(Nil),
            format.FALSE => Ok(Bool(false)),
            format.TRUE => Ok(Bool(true)),

            format.BIN8 => {
                let len = self.read_byte()? as usize;
                self.read_binary(len)
            }
            format.BIN16 => {
                let len = self.read_u16()? as usize;
                self.read_binary(len)
            }
            format.BIN32 => {
                let len = self.read_u32()? as usize;
                self.read_binary(len)
            }

            format.FLOAT32 => {
                let bytes = self.read_bytes(4)?;
                let bits = ((bytes[0] as u32) << 24) | ((bytes[1] as u32) << 16) | ((bytes[2] as u32) << 8) | (bytes[3] as u32);
                Ok(Float(0.0)) // Placeholder: real impl converts bits to float
            }
            format.FLOAT64 => {
                let bytes = self.read_bytes(8)?;
                Ok(Float(0.0)) // Placeholder: real impl converts bytes to f64
            }

            format.UINT8 => {
                let v = self.read_byte()?;
                Ok(UInt(v as u64))
            }
            format.UINT16 => {
                let v = self.read_u16()?;
                Ok(UInt(v as u64))
            }
            format.UINT32 => {
                let v = self.read_u32()?;
                Ok(UInt(v as u64))
            }
            format.UINT64 => {
                let v = self.read_u64()?;
                Ok(UInt(v))
            }

            format.INT8 => {
                let v = self.read_byte()? as i8;
                Ok(Int(v as i64))
            }
            format.INT16 => {
                let v = self.read_u16()? as i16;
                Ok(Int(v as i64))
            }
            format.INT32 => {
                let v = self.read_u32()? as i32;
                Ok(Int(v as i64))
            }
            format.INT64 => {
                let v = self.read_u64()? as i64;
                Ok(Int(v))
            }

            format.STR8 => {
                let len = self.read_byte()? as usize;
                self.read_string(len)
            }
            format.STR16 => {
                let len = self.read_u16()? as usize;
                self.read_string(len)
            }
            format.STR32 => {
                let len = self.read_u32()? as usize;
                self.read_string(len)
            }

            format.ARRAY16 => {
                let len = self.read_u16()? as usize;
                self.read_array(len)
            }
            format.ARRAY32 => {
                let len = self.read_u32()? as usize;
                self.read_array(len)
            }

            format.MAP16 => {
                let len = self.read_u16()? as usize;
                self.read_map(len)
            }
            format.MAP32 => {
                let len = self.read_u32()? as usize;
                self.read_map(len)
            }

            // Negative fixint
            0xe0..=0xff => {
                Ok(Int((byte as i8) as i64))
            }

            _ => Err(InvalidFormat(byte)),
        }
    }

    fn read_string(&mut self, len: usize) -> Result<MsgPackValue, MsgPackError> {
        let bytes = self.read_bytes(len)?;
        let s = Text.from_utf8(bytes.to_vec())
            .map_err(|_| InvalidUtf8)?;
        Ok(Text(s))
    }

    fn read_binary(&mut self, len: usize) -> Result<MsgPackValue, MsgPackError> {
        let bytes = self.read_bytes(len)?;
        Ok(Binary(bytes.to_vec()))
    }

    fn read_array(&mut self, len: usize) -> Result<MsgPackValue, MsgPackError> {
        let mut arr = List.with_capacity(len);
        for _ in 0..len {
            arr.push(self.read_value()?);
        }
        Ok(Array(arr))
    }

    fn read_map(&mut self, len: usize) -> Result<MsgPackValue, MsgPackError> {
        let mut map = List.with_capacity(len);
        for _ in 0..len {
            let key = self.read_value()?;
            let value = self.read_value()?;
            map.push((key, value));
        }
        Ok(Map(map))
    }
}

// ------------------------------------------------------------
// Public API
// ------------------------------------------------------------

fn pack(value: &MsgPackValue) -> List<u8> {
    let mut writer = MsgPackWriter.new();
    writer.write_value(value);
    writer.into_bytes()
}

fn unpack(data: &[u8]) -> Result<MsgPackValue, MsgPackError> {
    let mut reader = MsgPackReader.new(data);
    reader.read_value()
}

// ------------------------------------------------------------
// Type Definitions
// ------------------------------------------------------------

type MsgPackError is
    | UnexpectedEof
    | InvalidFormat(u8)
    | InvalidUtf8
    | TypeMismatch { expected: &str, found: &str };

fn main() {
    // MessagePack test
}
