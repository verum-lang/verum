// ------------------------------------------------------------
// Typed Memory Views
// ------------------------------------------------------------

/// View into WASM memory as typed array
type TypedArray<T> is {
    memory: *const WasmMemory,
    offset: usize,
    length: usize,
    _marker: PhantomData<T>,
};

implement<T: Copy> TypedArray<T> {
    fn new(memory: &WasmMemory, offset: usize, length: usize) -> Result<TypedArray<T>, WasmError> {
        let byte_len = length * T.size;

        if !memory.is_valid_range(offset, byte_len) {
            return Err(WasmError.OutOfBounds { offset, size: memory.size() });
        }

        if offset % T.alignment != 0 {
            return Err(WasmError.UnalignedAccess { offset, align: T.alignment });
        }

        Ok(TypedArray {
            memory,
            offset,
            length,
            _marker: PhantomData,
        })
    }

    fn get(&self, index: usize) -> Result<T, WasmError> {
        if index >= self.length {
            return Err(WasmError.IndexOutOfBounds { index, length: self.length });
        }

        let mem = unsafe { &*self.memory };
        mem.read(self.offset + index * T.size)
    }

    fn len(&self) -> usize {
        self.length
    }

    fn as_slice(&self) -> &[T] {
        let mem = unsafe { &*self.memory };
        unsafe {
            std.slice.from_raw_parts(
                mem.base.add(self.offset) as *const T,
                self.length
            )
        }
    }
}

// Specific typed array types
type Int8Array is TypedArray<i8>;
type Uint8Array is TypedArray<u8>;
type Int16Array is TypedArray<i16>;
type Uint16Array is TypedArray<u16>;
type Int32Array is TypedArray<i32>;
type Uint32Array is TypedArray<u32>;
type Float32Array is TypedArray<f32>;
type Float64Array is TypedArray<f64>;

// ------------------------------------------------------------
// Text Handling
// ------------------------------------------------------------

/// Read null-terminated string from WASM memory
fn read_string(mem: &WasmMemory, ptr: usize) -> Result<Text, WasmError> {
    let mut len = 0;
    let max_len = mem.size() - ptr;

    // Find null terminator
    while len < max_len {
        if mem.read<u8>(ptr + len)? == 0 {
            break;
        }
        len += 1;
    }

    if len == max_len {
        return Err(WasmError.NoNullTerminator);
    }

    let slice = mem.slice(ptr, len)?;
    Text.from_utf8(slice.to_list())
        .map_err(|_| WasmError.InvalidUtf8)
}

/// Write string to WASM memory
fn write_string(mem: &mut WasmMemory, ptr: usize, s: &str) -> Result<usize, WasmError> {
    let bytes = s.as_bytes();
    let len_with_null = bytes.len() + 1;

    if !mem.is_valid_range(ptr, len_with_null) {
        return Err(WasmError.OutOfBounds { offset: ptr, size: mem.size() });
    }

    let slice = mem.slice_mut(ptr, len_with_null)?;
    slice[..bytes.len()].copy_from_slice(bytes);
    slice[bytes.len()] = 0;  // Null terminator

    Ok(bytes.len())
}

/// Read length-prefixed string
fn read_length_prefixed_string(mem: &WasmMemory, ptr: usize) -> Result<Text, WasmError> {
    let len: u32 = mem.read(ptr)?;
    let data_ptr = ptr + 4;

    let slice = mem.slice(data_ptr, len as usize)?;
    Text.from_utf8(slice.to_list())
        .map_err(|_| WasmError.InvalidUtf8)
}

// ------------------------------------------------------------
// Memory Exports
// ------------------------------------------------------------

/// Export memory for JS access
@wasm_export
static memory: WasmMemory = WasmMemory { base: null as *mut u8, pages: 0 };

/// Get memory size in pages
@wasm_export
fn memory_size() -> i32 {
    unsafe { (&memory).pages as i32 }
}

/// Grow memory
@wasm_export
fn memory_grow_pages(delta: i32) -> i32 {
    if delta < 0 {
        return -1;
    }

    unsafe {
        match (&mut memory).grow(delta as u32) {
            Ok(old_pages) => old_pages as i32,
            Err(_) => -1,
        }
    }
}

// ------------------------------------------------------------
// Type Definitions
// ------------------------------------------------------------

type WasmError is
    | OutOfBounds { offset: usize, size: usize }
    | UnalignedAccess { offset: usize, align: usize }
    | IndexOutOfBounds { index: usize, length: usize }
    | GrowthOverflow
    | MemoryLimitExceeded
    | OutOfMemory
    | DataSegmentOutOfBounds
    | NoNullTerminator
    | InvalidUtf8
    | ArithmeticOverflow;

type PhantomData<T> is {};

// Type properties: use T.size and T.alignment instead of deprecated intrinsics

fn main() {
    // WASM memory test
}
