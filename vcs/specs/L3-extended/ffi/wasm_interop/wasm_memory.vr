// @test: compile-only
// @tier: 3
// @level: L3
// @tags: ffi, wasm, memory
// @description: Tests WebAssembly linear memory access patterns

/// ============================================================
/// WEBASSEMBLY LINEAR MEMORY
/// ============================================================
///
/// WASM uses a flat, linear memory model. This file demonstrates
/// safe patterns for accessing and managing WASM memory.

// ------------------------------------------------------------
// WASM Memory Intrinsics
// ------------------------------------------------------------

/// WASM memory representation
type WasmMemory is {
    /// Base pointer to linear memory
    base: *mut u8,
    /// Current size in pages (64KB each)
    pages: u32,
};

implement WasmMemory {
    const PAGE_SIZE: usize = 65536;  // 64KB

    /// Get memory size in bytes
    fn size(&self) -> usize {
        (self.pages as usize) * Self.PAGE_SIZE
    }

    /// Check if address range is valid
    fn is_valid_range(&self, offset: usize, len: usize) -> Bool {
        offset.checked_add(len)
            .map(|end| end <= self.size())
            .unwrap_or(false)
    }

    /// Get raw pointer at offset
    fn ptr_at(&self, offset: usize) -> Result<*mut u8, WasmError> {
        if offset >= self.size() {
            Err(WasmError.OutOfBounds { offset, size: self.size() })
        } else {
            Ok(unsafe { self.base.add(offset) })
        }
    }

    /// Get typed pointer at offset
    fn ptr_at_typed<T>(&self, offset: usize) -> Result<*mut T, WasmError> {
        if !self.is_valid_range(offset, T.size) {
            return Err(WasmError.OutOfBounds { offset, size: self.size() });
        }

        // Check alignment
        if offset % T.alignment != 0 {
            return Err(WasmError.UnalignedAccess { offset, align: T.alignment });
        }

        Ok(unsafe { self.base.add(offset) as *mut T })
    }

    /// Read value from memory
    fn read<T: Copy>(&self, offset: usize) -> Result<T, WasmError> {
        let ptr = self.ptr_at_typed<T>(offset)?;
        Ok(unsafe { *ptr })
    }

    /// Write value to memory
    fn write<T: Copy>(&mut self, offset: usize, value: T) -> Result<(), WasmError> {
        let ptr = self.ptr_at_typed<T>(offset)?;
        unsafe { *ptr = value };
        Ok(())
    }

    /// Get slice view of memory range
    fn slice(&self, offset: usize, len: usize) -> Result<&[u8], WasmError> {
        if !self.is_valid_range(offset, len) {
            return Err(WasmError.OutOfBounds { offset, size: self.size() });
        }
        Ok(unsafe { std.slice.from_raw_parts(self.base.add(offset), len) })
    }

    /// Get mutable slice view
    fn slice_mut(&mut self, offset: usize, len: usize) -> Result<&mut [u8], WasmError> {
        if !self.is_valid_range(offset, len) {
            return Err(WasmError.OutOfBounds { offset, size: self.size() });
        }
        Ok(unsafe { std.slice.from_raw_parts_mut(self.base.add(offset), len) })
    }

    /// Grow memory by delta pages
    fn grow(&mut self, delta: u32) -> Result<u32, WasmError> {
        let old_pages = self.pages;
        let new_pages = self.pages.checked_add(delta)
            .ok_or(WasmError.GrowthOverflow)?;

        // Platform limit check (typically 2GB or 4GB)
        if new_pages > MAX_WASM_PAGES {
            return Err(WasmError.MemoryLimitExceeded);
        }

        // Actual reallocation would happen here
        self.pages = new_pages;
        Ok(old_pages)
    }
}

const MAX_WASM_PAGES: u32 = 32768;  // 2GB

// ------------------------------------------------------------
// Memory Operations
// ------------------------------------------------------------

/// Copy within WASM memory
fn memory_copy(
    mem: &mut WasmMemory,
    dest: usize,
    src: usize,
    len: usize
) -> Result<(), WasmError> {
    // Validate ranges
    if !mem.is_valid_range(dest, len) {
        return Err(WasmError.OutOfBounds { offset: dest, size: mem.size() });
    }
    if !mem.is_valid_range(src, len) {
        return Err(WasmError.OutOfBounds { offset: src, size: mem.size() });
    }

    unsafe {
        let dest_ptr = mem.base.add(dest);
        let src_ptr = mem.base.add(src);
        // memmove handles overlapping regions
        std.ptr.copy(src_ptr, dest_ptr, len);
    }

    Ok(())
}

/// Fill memory with value
fn memory_fill(
    mem: &mut WasmMemory,
    dest: usize,
    value: u8,
    len: usize
) -> Result<(), WasmError> {
    if !mem.is_valid_range(dest, len) {
        return Err(WasmError.OutOfBounds { offset: dest, size: mem.size() });
    }

    unsafe {
        std.ptr.write_bytes(mem.base.add(dest), value, len);
    }

    Ok(())
}

/// Initialize memory from data segment
fn memory_init(
    mem: &mut WasmMemory,
    dest: usize,
    data: &[u8],
    src_offset: usize,
    len: usize
) -> Result<(), WasmError> {
    if src_offset + len > data.len() {
        return Err(WasmError.DataSegmentOutOfBounds);
    }
    if !mem.is_valid_range(dest, len) {
        return Err(WasmError.OutOfBounds { offset: dest, size: mem.size() });
    }

    unsafe {
        std.ptr.copy_nonoverlapping(
            data.as_ptr().add(src_offset),
            mem.base.add(dest),
            len
        );
    }

    Ok(())
}

// ------------------------------------------------------------
// WASM Memory Allocator
// ------------------------------------------------------------

/// Simple bump allocator for WASM memory
type WasmAllocator is {
    memory: *mut WasmMemory,
    heap_base: usize,
    heap_ptr: usize,
};

implement WasmAllocator {
    fn new(memory: *mut WasmMemory, heap_base: usize) -> WasmAllocator {
        WasmAllocator {
            memory,
            heap_base,
            heap_ptr: heap_base,
        }
    }

    /// Allocate bytes
    fn alloc(&mut self, size: usize) -> Result<usize, WasmError> {
        let mem = unsafe { &*self.memory };

        // Align to 8 bytes
        let aligned_ptr = (self.heap_ptr + 7) & !7;
        let new_ptr = aligned_ptr + size;

        if new_ptr > mem.size() {
            return Err(OutOfMemory);
        }

        self.heap_ptr = new_ptr;
        Ok(aligned_ptr)
    }

    /// Allocate and zero bytes
    fn calloc(&mut self, size: usize) -> Result<usize, WasmError> {
        let ptr = self.alloc(size)?;
        let mem = unsafe { &mut *self.memory };
        memory_fill(mem, ptr, 0, size)?;
        Ok(ptr)
    }

    /// Reset allocator (free all)
    fn reset(&mut self) {
        self.heap_ptr = self.heap_base;
    }
}

/// Export allocator functions for JS
@wasm_export
fn wasm_alloc(size: i32) -> i32 {
    // Placeholder: real impl uses global allocator
    0
}

@wasm_export
fn wasm_free(_ptr: i32) {
    // Bump allocator doesn't support individual free
    // Would need more sophisticated allocator for that
}

