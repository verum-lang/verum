// @test: compile-only
// @tier: 3
// @level: L3
// @tags: ffi, safety, undefined-behavior
// @description: Documents undefined behavior that must be avoided in unsafe code

type c_int is i32;
type c_void is ();
type size_t is usize;

/// Categories of undefined behavior in FFI
type UBCategory is
    | NullDereference
    | UseAfterFree
    | DoubleFree
    | BufferOverflow
    | DataRace
    | TypePunning
    | UnalignedAccess
    | UninitializedRead;

ffi libc {
    @extern("C")
    fn malloc(size: size_t) -> *mut c_void;
    @extern("C")
    fn free(ptr: *mut c_void);
    @extern("C")
    fn memcpy(dst: *mut c_void, src: *const c_void, n: size_t) -> *mut c_void;
}

/// Safe wrapper preventing null dereference
fn safe_read(ptr: *const c_int) -> Maybe<c_int> {
    if ptr.is_null() {
        None
    } else {
        Some(unsafe { *ptr })
    }
}

/// Safe wrapper preventing buffer overflow
fn safe_write_buffer(buf: *mut u8, buf_len: size_t, data: &[u8]) -> Bool {
    if data.len() > buf_len {
        false
    } else {
        unsafe {
            libc.memcpy(buf as *mut c_void, data.as_ptr() as *const c_void, data.len());
        }
        true
    }
}

/// RAII wrapper preventing use-after-free
type ManagedPtr<T> is {
    ptr: *mut T,
    freed: Bool,
};

implement<T> ManagedPtr<T> {
    fn new(ptr: *mut T) -> ManagedPtr<T> {
        ManagedPtr { ptr, freed: false }
    }

    fn get(&self) -> Maybe<*mut T> {
        if self.freed || self.ptr.is_null() {
            None
        } else {
            Some(self.ptr)
        }
    }
}

implement<T> Drop for ManagedPtr<T> {
    fn drop(&mut self) {
        if !self.freed && !self.ptr.is_null() {
            unsafe { libc.free(self.ptr as *mut c_void); }
            self.freed = true;
        }
    }
}

/// Alignment-safe read
fn aligned_read_u32(ptr: *const u32) -> u32 {
    unsafe { *ptr }
}

/// Type-safe pointer cast
fn safe_cast_to_int(ptr: *const c_void) -> *const c_int {
    ptr as *const c_int
}

fn main() {
    // UB prevention patterns
    let null_ptr: *const c_int = 0 as *const c_int;
    let result = safe_read(null_ptr);
    assert(result is None);
}
