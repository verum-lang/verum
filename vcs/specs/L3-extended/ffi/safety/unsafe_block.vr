// @test: compile-only
// @tier: 3
// @level: L3
// @tags: ffi, safety, unsafe
// @description: Tests unsafe block syntax and safety requirements

type c_int is i32;
type c_void is ();
type size_t is usize;

ffi libc {
    @extern("C")
    fn malloc(size: size_t) -> *mut c_void;
    @extern("C")
    fn free(ptr: *mut c_void);
    @extern("C")
    fn memcpy(dst: *mut c_void, src: *const c_void, n: size_t) -> *mut c_void;
}

/// Basic unsafe block for pointer dereference
fn read_through_pointer(ptr: *const c_int) -> c_int {
    // SAFETY: Caller guarantees ptr is valid and aligned
    unsafe { *ptr }
}

/// Unsafe block for FFI call
fn allocate(size: size_t) -> *mut c_void {
    // SAFETY: malloc is safe to call with any size
    unsafe { libc.malloc(size) }
}

/// Unsafe block for mutation through raw pointer
fn write_through_pointer(ptr: *mut c_int, value: c_int) {
    // SAFETY: Caller guarantees ptr is valid, aligned, and not aliased
    unsafe { *ptr = value; }
}

/// Unsafe block for slice creation
unsafe fn create_slice(ptr: *const u8, len: size_t) -> &[u8] {
    // SAFETY: Caller guarantees ptr is valid for len bytes
    &*std.ptr.slice_from_raw_parts(ptr, len)
}

/// Unsafe function (entire body is unsafe)
unsafe fn raw_copy(dst: *mut u8, src: *const u8, len: size_t) {
    libc.memcpy(dst as *mut c_void, src as *const c_void, len);
}

/// Minimal unsafe scope
fn safe_wrapper(ptr: *const c_int) -> Maybe<c_int> {
    if ptr.is_null() {
        None
    } else {
        let value = unsafe { *ptr };
        Some(value)
    }
}

/// Multiple unsafe blocks with documentation
fn safe_string_copy(dst: *mut u8, dst_len: size_t, src: *const u8, src_len: size_t) -> Bool {
    if src_len >= dst_len {
        return false;
    }

    // SAFETY: Both pointers are valid and non-overlapping per caller guarantee
    unsafe {
        libc.memcpy(dst as *mut c_void, src as *const c_void, src_len);
    }

    // SAFETY: dst is valid for dst_len bytes
    unsafe {
        *dst.add(src_len) = 0;  // Null terminate
    }

    true
}

/// Unsafe protocol implementation
type UnsafeMarker is protocol {
    /// SAFETY: Implementations must guarantee thread safety
    fn unsafe_method(&self);
};

type SafeType is { value: c_int };

implement UnsafeMarker for SafeType {
    fn unsafe_method(&self) {
        // SAFETY: SafeType is Copy and has no interior mutability
    }
}

/// RAII guard for unsafe operations
type UnsafeGuard<T> is {
    data: *mut T,
};

implement<T> Drop for UnsafeGuard<T> {
    fn drop(&mut self) {
        if !self.data.is_null() {
            unsafe {
                libc.free(self.data as *mut c_void);
            }
        }
    }
}

fn main() {
    let mut value: c_int = 42;
    let ptr = &mut value as *mut c_int;
    write_through_pointer(ptr, 100);
    let result = read_through_pointer(ptr as *const c_int);
    assert(result == 100);
}
