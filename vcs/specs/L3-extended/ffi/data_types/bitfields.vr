// @test: typecheck-pass
// @tier: 0
// @level: L3
// @tags: bitfield, low-level, ffi, bits, endian
// @description: Tests bitfield type declarations and accessor generation

/// ============================================================
/// BITFIELD TYPES
/// ============================================================
///
/// Bitfields allow precise bit-level layout of data, essential for:
/// - Network protocol headers
/// - Hardware register interfaces
/// - Memory-mapped I/O
/// - Compact data structures

// ------------------------------------------------------------
// Basic Bitfield Definition
// ------------------------------------------------------------

/// Simple bitfield with automatic layout
@bitfield
type Flags is {
    @bits(1) enabled: Bool,
    @bits(1) readable: Bool,
    @bits(1) writable: Bool,
    @bits(1) executable: Bool,
    @bits(4) reserved: u8,
};

fn test_basic_bitfield() {
    let flags = Flags {
        enabled: true,
        readable: true,
        writable: false,
        executable: false,
        reserved: 0,
    };
    // Bitfield getter/setter methods are generated by @bitfield attribute
    assert(flags.enabled == true);
    assert(flags.readable == true);
    assert(flags.writable == false);
}

// ------------------------------------------------------------
// Network Protocol Headers
// ------------------------------------------------------------

/// IPv4 header (RFC 791)
@bitfield
@repr(C)
@endian(big)
type Ipv4Header is {
    @bits(4) version: u8,
    @bits(4) ihl: u8,           // Internet Header Length
    @bits(6) dscp: u8,          // Differentiated Services Code Point
    @bits(2) ecn: u8,           // Explicit Congestion Notification
    @bits(16) total_length: u16,
    @bits(16) identification: u16,
    @bits(1) reserved: Bool,
    @bits(1) dont_fragment: Bool,
    @bits(1) more_fragments: Bool,
    @bits(13) fragment_offset: u16,
    @bits(8) ttl: u8,
    @bits(8) protocol: u8,
    @bits(16) checksum: u16,
    @bits(32) src_addr: u32,
    @bits(32) dst_addr: u32,
};

fn test_ipv4_header() {
    // Bitfield getters are generated by @bitfield attribute
    let header = Ipv4Header {
        version: 4,
        ihl: 5,                 // 5 * 4 = 20 bytes (minimum)
        dscp: 0,
        ecn: 0,
        total_length: 40,
        identification: 0x1234,
        reserved: false,
        dont_fragment: true,
        more_fragments: false,
        fragment_offset: 0,
        ttl: 64,
        protocol: 6,            // TCP
        checksum: 0,
        src_addr: 0xC0A80001,   // 192.168.0.1
        dst_addr: 0xC0A80002,   // 192.168.0.2
    };

    assert(header.version == 4);
    assert(header.ttl == 64);
}

/// TCP header flags
@bitfield
@endian(big)
type TcpFlags is {
    @bits(1) fin: Bool,
    @bits(1) syn: Bool,
    @bits(1) rst: Bool,
    @bits(1) psh: Bool,
    @bits(1) ack: Bool,
    @bits(1) urg: Bool,
    @bits(1) ece: Bool,
    @bits(1) cwr: Bool,
};

fn test_tcp_flags() {
    let syn_flags = TcpFlags {
        fin: false, syn: true, rst: false, psh: false,
        ack: false, urg: false, ece: false, cwr: false,
    };
    assert(syn_flags.syn == true);
    assert(syn_flags.ack == false);
}

// ------------------------------------------------------------
// Hardware Register Bitfields
// ------------------------------------------------------------

/// ARM CPSR (Current Program Status Register)
@bitfield
@repr(C)
type ArmCpsr is {
    @bits(5) mode: u8,          // Processor mode
    @bits(1) thumb: Bool,       // Thumb state
    @bits(1) fiq_disable: Bool,
    @bits(1) irq_disable: Bool,
    @bits(1) async_abort_disable: Bool,
    @bits(1) endian: Bool,      // 0=little, 1=big
    @bits(6) it_state_low: u8,
    @bits(4) ge: u8,            // Greater or equal flags
    @bits(4) reserved: u8,
    @bits(1) jazelle: Bool,
    @bits(2) it_state_high: u8,
    @bits(1) q: Bool,           // Saturation flag
    @bits(1) v: Bool,           // Overflow flag
    @bits(1) c: Bool,           // Carry flag
    @bits(1) z: Bool,           // Zero flag
    @bits(1) n: Bool,           // Negative flag
};

/// x86 EFLAGS register
@bitfield
type X86Eflags is {
    @bits(1) cf: Bool,          // Carry
    @bits(1) reserved1: Bool,
    @bits(1) pf: Bool,          // Parity
    @bits(1) reserved2: Bool,
    @bits(1) af: Bool,          // Auxiliary carry
    @bits(1) reserved3: Bool,
    @bits(1) zf: Bool,          // Zero
    @bits(1) sf: Bool,          // Sign
    @bits(1) tf: Bool,          // Trap
    @bits(1) if_: Bool,         // Interrupt enable
    @bits(1) df: Bool,          // Direction
    @bits(1) of: Bool,          // Overflow
    @bits(2) iopl: u8,          // I/O privilege level
    @bits(1) nt: Bool,          // Nested task
    @bits(1) reserved4: Bool,
    @bits(1) rf: Bool,          // Resume
    @bits(1) vm: Bool,          // Virtual 8086 mode
    @bits(1) ac: Bool,          // Alignment check
    @bits(1) vif: Bool,         // Virtual interrupt
    @bits(1) vip: Bool,         // Virtual interrupt pending
    @bits(1) id: Bool,          // ID flag
    @bits(10) reserved5: u16,
};

// ------------------------------------------------------------
// USB Endpoint Descriptor
// ------------------------------------------------------------

@bitfield
@repr(packed)
@endian(little)
type UsbEndpointDescriptor is {
    @bits(8) length: u8,
    @bits(8) descriptor_type: u8,
    @bits(4) endpoint_number: u8,
    @bits(3) reserved: u8,
    @bits(1) direction: Bool,       // 0=OUT, 1=IN
    @bits(2) transfer_type: u8,     // 0=Control, 1=Iso, 2=Bulk, 3=Interrupt
    @bits(2) sync_type: u8,
    @bits(2) usage_type: u8,
    @bits(2) reserved2: u8,
    @bits(11) max_packet_size: u16,
    @bits(2) transactions: u8,
    @bits(3) reserved3: u8,
    @bits(8) interval: u8,
};

// ------------------------------------------------------------
// Bitfield with Enums
// ------------------------------------------------------------

type ProtocolType is
    | Tcp = 6
    | Udp = 17
    | Icmp = 1;

@bitfield
type PacketHeader is {
    @bits(4) version: u8,
    @bits(8) protocol: ProtocolType,
    @bits(20) reserved: u32,
};

fn test_enum_bitfield() {
    let header = PacketHeader {
        version: 4,
        protocol: ProtocolType.Tcp,
        reserved: 0,
    };
    assert(header.version == 4);
}

// ------------------------------------------------------------
// Bitfield Byte Order
// ------------------------------------------------------------

/// Big-endian for network protocols
@bitfield
@endian(big)
type NetworkU32 is {
    @bits(32) value: u32,
};

/// Little-endian for x86 hardware
@bitfield
@endian(little)
type X86Register is {
    @bits(32) value: u32,
};

/// Native endianness
@bitfield
@endian(native)
type NativeWord is {
    @bits(64) value: u64,
};

fn test_endianness() {
    let net = NetworkU32 { value: 0x12345678 };
    let x86 = X86Register { value: 0x12345678 };
    // Byte order is handled by @endian attribute
}

// ------------------------------------------------------------
// Packed Structures with Bitfields
// ------------------------------------------------------------

/// Ethernet frame header
@bitfield
@repr(packed)
@endian(big)
type EthernetHeader is {
    @bits(48) dst_mac: u64,     // Destination MAC (6 bytes)
    @bits(48) src_mac: u64,     // Source MAC (6 bytes)
    @bits(16) ethertype: u16,   // EtherType
};

fn test_ethernet_header() {
    let header = EthernetHeader {
        dst_mac: 0xFFFFFFFFFFFF,
        src_mac: 0x001122334455,
        ethertype: 0x0800,
    };
    assert(header.ethertype == 0x0800);
}

// ------------------------------------------------------------
// Bitfield Methods
// ------------------------------------------------------------

@bitfield
type PermissionBits is {
    @bits(1) read: Bool,
    @bits(1) write: Bool,
    @bits(1) execute: Bool,
    @bits(5) reserved: u8,
};

implement PermissionBits {
    fn new_readonly() -> PermissionBits {
        PermissionBits { read: true, write: false, execute: false, reserved: 0 }
    }

    fn new_readwrite() -> PermissionBits {
        PermissionBits { read: true, write: true, execute: false, reserved: 0 }
    }

    fn is_accessible(&self) -> Bool {
        self.read || self.write || self.execute
    }

    fn can_modify(&self) -> Bool {
        self.write
    }
}

fn test_bitfield_methods() {
    let ro = PermissionBits.new_readonly();
    assert(ro.read == true);
    assert(ro.can_modify() == false);
}

// ------------------------------------------------------------
// Bitfield Serialization
// ------------------------------------------------------------

fn test_serialization() {
    let original = Ipv4Header {
        version: 4, ihl: 5, dscp: 0, ecn: 0,
        total_length: 40, identification: 0x1234,
        reserved: false, dont_fragment: true, more_fragments: false,
        fragment_offset: 0, ttl: 64, protocol: 6,
        checksum: 0xABCD, src_addr: 0xC0A80001, dst_addr: 0xC0A80002,
    };
    assert(original.version == 4);
    assert(original.ttl == 64);
}

// ------------------------------------------------------------
// Bitfield Validation
// ------------------------------------------------------------

@bitfield
type ValidatedHeader is {
    @bits(4) version: u8,
    @bits(4) ihl: u8,
};

implement ValidatedHeader {
    fn validate(&self) -> Result<(), Text> {
        if self.version != 4 && self.version != 6 {
            return Err(Text.from("Invalid IP version"));
        }
        if self.version == 4 && self.ihl < 5 {
            return Err(Text.from("IPv4 header length too small"));
        }
        Ok(())
    }
}

fn main() {
    test_basic_bitfield();
    test_ipv4_header();
    test_tcp_flags();
    test_enum_bitfield();
    test_endianness();
    test_ethernet_header();
    test_bitfield_methods();
    test_serialization();
}
