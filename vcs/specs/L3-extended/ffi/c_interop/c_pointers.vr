unsafe fn ptr_write_bytes<T>(dst: *mut T, val: u8, count: usize) {
    // Placeholder - would be intrinsic
}

unsafe fn ptr_swap<T>(a: *mut T, b: *mut T) {
    // Placeholder - would be intrinsic
}

unsafe fn ptr_replace<T>(dst: *mut T, value: T) -> T {
    // Placeholder - would be intrinsic
    value
}

unsafe fn slice_from_raw_parts<T>(ptr: *const T, len: usize) -> &[T] {
    // Placeholder - would be intrinsic
    &[]
}

unsafe fn slice_from_raw_parts_mut<T>(ptr: *mut T, len: usize) -> &mut [T] {
    // Placeholder - would be intrinsic
    &mut []
}

// ------------------------------------------------------------
// Tests
// ------------------------------------------------------------

fn test_null_ptr() {
    let ptr: ConstPtr<c_int> = null_ptr();
    assert(ptr == null);
}

fn test_non_null() {
    let value: c_int = 42;
    let ptr = as_mut_ptr(&mut value);
    let nn = NonNull.new(ptr);
    assert(nn.is_some());

    let null_ptr: MutPtr<c_int> = null as *mut c_int;
    let nn = NonNull.new(null_ptr);
    assert(nn.is_none());
}

fn test_pointer_arithmetic() {
    let arr: [c_int; 4] = [1, 2, 3, 4];
    let ptr = arr.as_ptr();

    unsafe {
        let ptr2 = add(ptr, 2);
        assert(*ptr2 == 3);
    }
}

fn test_buffer() {
    let buf = Buffer.new(1024);
    assert(buf.is_ok());

    let buf = buf.unwrap();
    assert(buf.capacity == 1024);
    assert(buf.len == 0);
}

fn test_ffi_slice() {
    let data: [c_int; 3] = [10, 20, 30];
    let slice = FfiSlice.from_slice(&data);
    assert(slice.len == 3);
    assert(slice.ptr != null);
}

fn test_handle() {
    fn dummy_destructor<T>(ptr: *mut T) {
        // No-op for test
    }

    let ptr: *mut c_int = null as *mut c_int;
    let handle = Handle.new(ptr, dummy_destructor);
    assert(handle.is_ok());
}

fn main() {
    test_null_ptr();
    test_non_null();
    test_pointer_arithmetic();
    test_buffer();
    test_ffi_slice();
    test_handle();
    print("C pointer tests passed");
}
