// @test: compile-only
// @tier: 3
// @level: L3
// @tags: ffi, c-interop, calling-convention
// @description: Tests different calling conventions for FFI

/// ============================================================
/// CALLING CONVENTIONS
/// ============================================================
///
/// Different platforms and languages use different calling conventions.
/// Verum supports specifying the calling convention for FFI functions.

// ------------------------------------------------------------
// Standard Calling Conventions
// ------------------------------------------------------------

/// C calling convention (default for most platforms)
ffi libc {
    @extern("C")  // cdecl on x86, platform default on others
    fn standard_c_function(a: c_int, b: c_int) -> c_int;
}

/// System calling convention
ffi system {
    @extern("system")  // stdcall on Windows x86, C elsewhere
    fn system_call(handle: c_int, flags: c_int) -> c_int;
}

/// Fastcall convention
ffi optimized {
    @extern("fastcall")  // Passes args in registers when possible
    fn fast_function(a: c_int, b: c_int) -> c_int;
}

/// Vectorcall convention (Windows)
@cfg(target_os = "windows")
ffi win_vectorcall {
    @extern("vectorcall")  // Optimized for SIMD
    fn simd_function(v: f32x4) -> f32x4;
}

// ------------------------------------------------------------
// Platform-Specific Conventions
// ------------------------------------------------------------

/// Windows API convention
@cfg(target_os = "windows")
ffi windows {
    @extern("stdcall")
    fn MessageBoxW(
        hwnd: HWND,
        text: *const u16,
        caption: *const u16,
        type_: c_uint
    ) -> c_int;

    @extern("stdcall")
    fn GetLastError() -> DWORD;

    @extern("stdcall")
    fn CloseHandle(handle: HANDLE) -> BOOL;
}

/// Unix/Linux convention
@cfg(unix)
ffi posix {
    @extern("C")
    fn fork() -> pid_t;

    @extern("C")
    fn execve(
        pathname: *const c_char,
        argv: *const *const c_char,
        envp: *const *const c_char
    ) -> c_int;
}

/// macOS specific
@cfg(target_os = "macos")
ffi darwin {
    @extern("C")
    fn dispatch_async(
        queue: dispatch_queue_t,
        block: dispatch_block_t
    );
}

// ------------------------------------------------------------
// Architecture-Specific Conventions
// ------------------------------------------------------------

/// x86-64 System V ABI (Linux, macOS, BSD)
@cfg(all(target_arch = "x86_64", not(target_os = "windows")))
ffi sysv {
    @extern("C")  // System V AMD64 ABI
    // First 6 integer args: RDI, RSI, RDX, RCX, R8, R9
    // First 8 float args: XMM0-XMM7
    // Return: RAX (integer), XMM0 (float)
    fn sysv_function(
        a: c_long,   // RDI
        b: c_long,   // RSI
        c: c_long,   // RDX
        d: c_long,   // RCX
        e: c_long,   // R8
        f: c_long    // R9
    ) -> c_long;     // RAX
}

/// x86-64 Windows ABI
@cfg(all(target_arch = "x86_64", target_os = "windows"))
ffi win64 {
    @extern("win64")
    // First 4 args: RCX, RDX, R8, R9 (or XMM0-XMM3 for floats)
    // Return: RAX (integer), XMM0 (float)
    fn win64_function(
        a: c_long,   // RCX
        b: c_long,   // RDX
        c: c_long,   // R8
        d: c_long    // R9
    ) -> c_long;     // RAX
}

/// ARM64 AAPCS
@cfg(target_arch = "aarch64")
ffi aarch64 {
    @extern("C")  // AAPCS64
    // First 8 integer args: X0-X7
    // First 8 float args: V0-V7
    // Return: X0 (integer), V0 (float)
    fn arm64_function(
        a: c_long,   // X0
        b: c_long,   // X1
        c: c_long,   // X2
        d: c_long    // X3
    ) -> c_long;     // X0
}

// ------------------------------------------------------------
// Callback Function Types
// ------------------------------------------------------------

/// C function pointer type with specific calling convention
type CCallback is extern "C" fn(c_int, *mut c_void) -> c_int;

/// Registering a callback
ffi callback_api {
    @extern("C")
    fn register_callback(
        cb: CCallback,
        user_data: *mut c_void
    ) -> c_int;
}

/// Verum function exported with C convention
@export("C")
fn verum_callback(value: c_int, data: *mut c_void) -> c_int {
    // This can be passed to C code
    value * 2
}

/// Using the callback
fn setup_callback() {
    let result = unsafe {
        let null: *mut c_void = 0 as *mut c_void;
        callback_api.register_callback(verum_callback, null)
    };
}

// ------------------------------------------------------------
// Variadic Conventions
// ------------------------------------------------------------

/// Variadic function (C calling convention)
ffi libc {
    @extern("C")
    @variadic
    fn printf(format: *const c_char, ...) -> c_int;

    @extern("C")
    @variadic
    fn sprintf(
        buffer: *mut c_char,
        format: *const c_char,
        ...
    ) -> c_int;
}

/// va_list handling
ffi libc {
    @extern("C")
    fn vprintf(format: *const c_char, ap: va_list) -> c_int;
}

// ------------------------------------------------------------
// Interrupt and Naked Functions
// ------------------------------------------------------------

/// Interrupt handler type
type InterruptStackFrame is {
    instruction_pointer: u64,
    code_segment: u64,
    cpu_flags: u64,
    stack_pointer: u64,
    stack_segment: u64,
};

/// Interrupt handler (x86)
@cfg(target_arch = "x86_64")
@interrupt
fn timer_interrupt(frame: &InterruptStackFrame) {
    // Special calling convention for interrupt handlers
    // All registers saved/restored automatically
}

/// Context for context switching
type Context is {
    rsp: u64,
};

/// Naked function (no prologue/epilogue) - platform intrinsic stub
@extern("C")
unsafe fn context_switch(old: *mut Context, new: *const Context);

// ------------------------------------------------------------
// Register Constraints
// ------------------------------------------------------------

/// Inline assembly with register constraints (platform intrinsic stub)
@extern("C")
fn read_timestamp() -> u64;

/// CPUID instruction wrapper (platform intrinsic stub)
@extern("C")
fn cpuid(leaf: u32) -> (u32, u32, u32, u32);

// ------------------------------------------------------------
// Stack Alignment
// ------------------------------------------------------------

/// Ensure 16-byte stack alignment (required by System V ABI)
@stack_align(16)
fn aligned_function() {
    // Stack is guaranteed 16-byte aligned here
    let buffer: [u8; 32] = [0; 32];  // Properly aligned
}

/// Custom stack alignment for SIMD
@stack_align(32)
fn avx_function() {
    let vectors: [[f32; 8]; 4] = [[0.0; 8]; 4];  // 32-byte aligned
}

// ------------------------------------------------------------
// Function Attributes
// ------------------------------------------------------------

/// No-return function
@noreturn
ffi libc {
    @extern("C")
    fn exit(status: c_int) -> !;

    @extern("C")
    fn abort() -> !;
}

/// Pure function (no side effects)
@pure
ffi math {
    @extern("C")
    fn sqrt(x: c_double) -> c_double;
}

/// Cold function (unlikely to be called)
@cold
fn error_handler(code: c_int) {
    // Optimized for size, not speed
}

/// Hot function (frequently called)
@hot
fn fast_path(data: *const u8, len: usize) -> u64 {
    // Optimized aggressively
    // ...
}
