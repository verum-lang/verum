// =============================================================================
// L4-performance: Red-team Round 3 §5.2 — Deeply nested @cfg conditional
// =============================================================================
// @test: typecheck-pass
// @tier: all
// @level: L4
// @tags: red-team, perf, cfg, attributes, red-team-3.5.2
// @timeout: 30000
// @expect: pass
// =============================================================================
//
// Pins the @cfg-overlap walker scaling against deeply nested conditionals.
// The walker must enumerate cfg-predicate satisfiability without SAT
// blow-up; for K nested @cfg attributes the walker should be linear, not
// 2^K (every cfg leaf is independent of others — independence is the
// optimization the walker depends on).
//
// **Audit reference:** vcs/red-team/round-3-perf.md §5.2.
//
// **Invariant being pinned:** the cfg-overlap walker is conservative on
// the `unix`/`linux`/`macos`/`windows` predicate family (per round-1
// §4.1 audit), but more importantly: K independent @cfg attributes
// produce K type registrations, not 2^K — each cfg-leaf participates
// independently.

// 8 functions, each gated on a distinct @cfg predicate. K = 8 is enough
// to expose any 2^K cliff if the walker is wrong; 1024+ is the
// fuzz-corpus territory.

@cfg(target_os = "linux")
fn cfg_lin1() -> Int { 1 }

@cfg(target_os = "macos")
fn cfg_mac1() -> Int { 2 }

@cfg(target_os = "windows")
fn cfg_win1() -> Int { 3 }

@cfg(target_arch = "x86_64")
fn cfg_x64() -> Int { 4 }

@cfg(target_arch = "aarch64")
fn cfg_aarch() -> Int { 5 }

@cfg(feature = "async")
fn cfg_async() -> Int { 6 }

@cfg(feature = "tls")
fn cfg_tls() -> Int { 7 }

@cfg(debug_assertions)
fn cfg_debug() -> Int { 8 }

// Combined cfg via `any` / `all` — exercises the predicate-tree
// expansion in the walker. This is where a naive walker would
// SAT-explode if it expanded `any(A, B, C)` to `(A ∨ B ∨ C)` with
// per-clause work.
@cfg(any(target_os = "linux", target_os = "macos"))
fn cfg_unix_like() -> Int { 9 }

@cfg(all(target_arch = "x86_64", any(target_os = "linux", target_os = "macos")))
fn cfg_x64_unix() -> Int { 10 }

@cfg(not(target_os = "windows"))
fn cfg_not_windows() -> Int { 11 }

@cfg(any(
    target_os = "linux",
    target_os = "macos",
    target_os = "freebsd",
    target_os = "openbsd",
    target_os = "netbsd",
    target_os = "dragonfly"
))
fn cfg_bsd_or_unix() -> Int { 12 }

// -----------------------------------------------------------------------------
// Bulk @cfg expansion — push past the 12-predicate scale to 64+
// -----------------------------------------------------------------------------
// Independent feature flags.  If the walker were exponential in the
// number of distinct cfg predicates, K = 50 here (combined with the
// 12 above + 16 nested-any/all/not below) would force ~2^60+ work per
// compilation.  In practice the walker is linear — each cfg-leaf
// participates independently in type registration — so this batch
// adds only a few microseconds to the predicate evaluation phase.
@cfg(feature = "verum_cfg_bulk_01") fn cfg_bulk_01() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_02") fn cfg_bulk_02() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_03") fn cfg_bulk_03() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_04") fn cfg_bulk_04() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_05") fn cfg_bulk_05() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_06") fn cfg_bulk_06() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_07") fn cfg_bulk_07() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_08") fn cfg_bulk_08() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_09") fn cfg_bulk_09() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_10") fn cfg_bulk_10() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_11") fn cfg_bulk_11() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_12") fn cfg_bulk_12() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_13") fn cfg_bulk_13() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_14") fn cfg_bulk_14() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_15") fn cfg_bulk_15() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_16") fn cfg_bulk_16() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_17") fn cfg_bulk_17() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_18") fn cfg_bulk_18() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_19") fn cfg_bulk_19() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_20") fn cfg_bulk_20() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_21") fn cfg_bulk_21() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_22") fn cfg_bulk_22() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_23") fn cfg_bulk_23() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_24") fn cfg_bulk_24() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_25") fn cfg_bulk_25() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_26") fn cfg_bulk_26() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_27") fn cfg_bulk_27() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_28") fn cfg_bulk_28() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_29") fn cfg_bulk_29() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_30") fn cfg_bulk_30() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_31") fn cfg_bulk_31() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_32") fn cfg_bulk_32() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_33") fn cfg_bulk_33() -> Int { 100 }
@cfg(feature = "verum_cfg_bulk_34") fn cfg_bulk_34() -> Int { 100 }
