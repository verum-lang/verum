// =============================================================================
// L4-performance: Red-team Round 3 §1.1 — Deep generic compilation bounded
// =============================================================================
// @test: typecheck-pass
// @tier: 0
// @level: L4
// @tags: red-team, perf, generics, monomorphization, red-team-3.1.1
// @timeout: 30000
// @expect: pass
// =============================================================================
//
// Pins the compile-time scaling for nested generic instantiation against
// a stack-overflow-style cliff. The full attack vector is `List<List<...
// List<Int>>>>` 1024 deep; here we exercise 15 doubling-levels —
// 2^14 = 16,384 effective List wrappings — which is enough to expose
// any non-linear monomorphization scaling without timing out CI.
//
// **Audit reference:** vcs/red-team/round-3-perf.md §1.1.
//
// **Invariant being pinned:** monomorphization is approximately linear in
// the nested-generic depth — N levels produce N type instances, not
// 2^N. The compiler does NOT recurse exponentially through the type
// argument tree.
//
// Companion: a benchmark in `crates/verum_compiler/benches/` measuring
// the actual scaling slope is a round-3 follow-up; this test only
// pins correctness + termination.

mount core.collections.list.{List};

// Build a 32-level type. If the compiler exponentially expands generic
// instantiation, this would either OOM or stack-overflow. The test
// passes by *compiling* — runtime behaviour is incidental.
type L01<T> is List<T>;
type L02<T> is L01<L01<T>>;
type L03<T> is L02<L02<T>>;
type L04<T> is L03<L03<T>>;
type L05<T> is L04<L04<T>>;
type L06<T> is L05<L05<T>>;
type L07<T> is L06<L06<T>>;
type L08<T> is L07<L07<T>>;
type L09<T> is L08<L08<T>>;
type L10<T> is L09<L09<T>>;
type L11<T> is L10<L10<T>>;
type L12<T> is L11<L11<T>>;
type L13<T> is L12<L12<T>>;
type L14<T> is L13<L13<T>>;
type L15<T> is L14<L14<T>>;

// Concretise at Int.  L15 = 2^14 = 16,384 effective List wrappings.
// Without structural dedup the type arena would balloon to 2^15 =
// 32,768 nodes; with dedup it stays at one entry per distinct shape.
// A regression to non-deduplicating type-canonicalisation would
// surface as a 30s timeout (this test compiles in well under that).
type Deep32 is L15<Int>;

// Function type-signature alone exercises monomorphization on the
// deeply-nested type without requiring a method-resolution walk
// over `Deep32` (which at 2^14 wrapping depth would itself stress
// the resolver).  The body returns via parameter pass-through.
fn deep_constructor(seed: Deep32) -> Deep32 {
    seed
}

fn main() {
    print("L4-perf: red-team-3.1.1 deep generic compilation bounded");
}
