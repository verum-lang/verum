    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;
    let ms_per_10k = (avg_ms / loc as Float) * 10_000.0;

    BenchmarkResult {
        name: "small_project_1k",
        metric: "ms/10K LOC",
        value: ms_per_10k,
        target: TARGET_MS_PER_10K_LOC,
        passed: ms_per_10k < TARGET_MS_PER_10K_LOC,
    }
}

