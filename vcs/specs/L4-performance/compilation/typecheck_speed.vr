// @test: parse
// @tier: 3
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: compilation, typecheck, inference, speed
// @description: Type checking performance benchmark (target: < 100ms per 10K LOC)

/// Type Checking Performance Benchmark
///
/// This benchmark measures the throughput of the Verum type checker.
/// Type checking is typically the most expensive compilation phase.
///
/// Target: < 100ms per 10,000 lines of code
///
/// Type checker characteristics:
/// - Hindley-Milner type inference with extensions
/// - Refinement type verification via SMT
/// - Bidirectional type checking
/// - Incremental type checking support
///
/// Spec reference: docs/detailed/03-type-system.md

const TARGET_MS_PER_10K_LOC: Float = 100.0;
const SMALL_LOC: Int = 1_000;
const MEDIUM_LOC: Int = 10_000;
const LARGE_LOC: Int = 50_000;

fn main() {
    let results = BenchmarkResults.new("Type Checker Performance");

    // Basic inference benchmarks
    results.add(benchmark_simple_inference());
    results.add(benchmark_generic_inference());
    results.add(benchmark_complex_inference());

    // Scale benchmarks
    results.add(benchmark_small_project());
    results.add(benchmark_medium_project());
    results.add(benchmark_large_project());

    // Specific type system features
    results.add(benchmark_refinement_types());
    results.add(benchmark_context_propagation());
    results.add(benchmark_protocol_conformance());
    results.add(benchmark_incremental_typecheck());

    results.report();
    assert(results.all_pass(), "Type checker performance below target");
}

/// Generate code with simple type inference
fn generate_simple_inference_code(functions: Int) -> Text {
    let mut source = Text.with_capacity(functions * 100);
    source.push_str("module simple_inference;\n\n");

    for i in 0..functions {
        source.push_str(&format(
            "fn simple_{}() -> Int {{
    let x = 42;
    let y = x + 10;
    let z = y * 2;
    z
}}

", i));
    }

    source
}

/// Benchmark: Simple type inference
fn benchmark_simple_inference() -> BenchmarkResult {
    let source = generate_simple_inference_code(100);
    let loc = count_lines(&source);
    let iterations = 100;

    // Warmup
    for _ in 0..10 {
        black_box(typecheck_source(&source));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(typecheck_source(&source));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;
    let ms_per_10k = (avg_ms / loc as Float) * 10_000.0;

    BenchmarkResult {
        name: "simple_inference",
        metric: "ms/10K LOC",
        value: ms_per_10k,
        target: TARGET_MS_PER_10K_LOC,
        passed: ms_per_10k < TARGET_MS_PER_10K_LOC,
    }
}

/// Generate code with generic type inference
fn generate_generic_code(functions: Int) -> Text {
    let mut source = Text.with_capacity(functions * 200);
    source.push_str("module generic_inference;\n\n");

    for i in 0..functions {
        source.push_str(&format(
            "fn generic_{}<T: Clone + Eq, U: Display>(x: T, y: U) -> (T, Text) {{
    let cloned = x.clone();
    let displayed = y.to_string();
    let pair = (cloned, displayed);
    pair
}}

fn use_generic_{}() {{
    let result1 = generic_{}(42, \"hello\");
    let result2 = generic_{}(3.14, true);
    let result3 = generic_{}([1, 2, 3], Maybe.some(10));
}}

", i, i, i, i, i));
    }

    source
}

/// Benchmark: Generic type inference
fn benchmark_generic_inference() -> BenchmarkResult {
    let source = generate_generic_code(50);
    let loc = count_lines(&source);
    let iterations = 50;

    for _ in 0..5 {
        black_box(typecheck_source(&source));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(typecheck_source(&source));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;
    let ms_per_10k = (avg_ms / loc as Float) * 10_000.0;

    // Generic inference is more expensive
    let target = TARGET_MS_PER_10K_LOC * 1.5;

    BenchmarkResult {
        name: "generic_inference",
        metric: "ms/10K LOC",
        value: ms_per_10k,
        target: target,
        passed: ms_per_10k < target,
    }
}

/// Generate complex code with multiple features
fn generate_complex_code(functions: Int) -> Text {
    let mut source = Text.with_capacity(functions * 500);
    source.push_str("module complex_inference;\n\n");

    // Record types
    source.push_str("record Person {\n");
    source.push_str("    name: Text,\n");
    source.push_str("    age: Int{>= 0 && <= 150},\n");
    source.push_str("    email: Maybe<Text>,\n");
    source.push_str("}\n\n");

    // Protocol
    source.push_str("protocol Serializable {\n");
    source.push_str("    fn serialize(self) -> Text;\n");
    source.push_str("    fn deserialize(data: Text) -> Result<Self, Error>;\n");
    source.push_str("}\n\n");

    for i in 0..functions {
        source.push_str(&format(
            "fn complex_{}<T: Serializable + Clone>(
    items: List<T>,
    filter: fn(T) -> Bool,
    transform: fn(T) -> Text
) -> Result<List<Text>, Error> using [Logger] {{
    let filtered = items.iter()
        .filter(filter)
        .map(transform)
        .collect();

    Logger.info(\"Processed {{}} items\", filtered.len());

    Ok(filtered)
}}

", i));
    }

    source
}

/// Benchmark: Complex type inference
fn benchmark_complex_inference() -> BenchmarkResult {
    let source = generate_complex_code(30);
    let loc = count_lines(&source);
    let iterations = 30;

    for _ in 0..3 {
        black_box(typecheck_source(&source));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(typecheck_source(&source));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;
    let ms_per_10k = (avg_ms / loc as Float) * 10_000.0;

    // Complex inference is more expensive
    let target = TARGET_MS_PER_10K_LOC * 2.0;

    BenchmarkResult {
        name: "complex_inference",
        metric: "ms/10K LOC",
        value: ms_per_10k,
        target: target,
        passed: ms_per_10k < target,
    }
}

/// Generate a project of specified LOC
fn generate_project(loc: Int) -> Text {
    let functions = loc / 15;  // ~15 LOC per function
    generate_complex_code(functions)
}

/// Benchmark: Small project (~1K LOC)
fn benchmark_small_project() -> BenchmarkResult {
    let source = generate_project(SMALL_LOC);
    let loc = count_lines(&source);
