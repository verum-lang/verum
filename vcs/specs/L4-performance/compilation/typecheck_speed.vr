        target: TARGET_MS_PER_10K_LOC,
        passed: ms_per_10k < TARGET_MS_PER_10K_LOC,
    }
}

/// Generate code with refinement types
fn generate_refinement_code(predicates: Int) -> Text {
    let mut source = Text.new();
    source.push_str("module refinement_benchmark;\n\n");

    for i in 0..predicates {
        source.push_str(&format(
            "type Bounded{} = Int{{>= {} && <= {}}};\n",
            i, i * 10, (i + 1) * 100
        ));

        source.push_str(&format(
            "fn use_bounded_{}(x: Bounded{}) -> Int {{
    x * 2
}}

", i, i));
    }

    source
}

/// Benchmark: Refinement type verification
fn benchmark_refinement_types() -> BenchmarkResult {
    let source = generate_refinement_code(50);
    let iterations = 30;

    for _ in 0..3 {
        black_box(typecheck_source(&source));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(typecheck_source(&source));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;

    // Refinement checking involves SMT solver
    let target = 50.0;  // 50ms for 50 predicates

    BenchmarkResult {
        name: "refinement_types",
        metric: "ms/50 predicates",
        value: avg_ms,
        target: target,
        passed: avg_ms < target,
    }
}

/// Generate code with context propagation
fn generate_context_code(depth: Int) -> Text {
    let mut source = Text.new();
    source.push_str("module context_benchmark;\n\n");

    source.push_str("context Logger { fn log(msg: Text); }\n");
    source.push_str("context Database { fn query(q: Text) -> List<Row>; }\n");
    source.push_str("context Config { fn get(key: Text) -> Text; }\n\n");

    for i in 0..depth {
        let contexts = match i % 3 {
            0 => "[Logger]",
            1 => "[Logger, Database]",
            _ => "[Logger, Database, Config]",
        };

        source.push_str(&format(
            "fn layer_{}(x: Int) -> Int using {} {{
    if x > 0 {{
        layer_{}(x - 1)
    }} else {{
        x
    }}
}}

", i, contexts, if i > 0 { i - 1 } else { 0 }));
    }

    source
}

/// Benchmark: Context propagation checking
fn benchmark_context_propagation() -> BenchmarkResult {
    let source = generate_context_code(100);
    let iterations = 50;

    for _ in 0..5 {
        black_box(typecheck_source(&source));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(typecheck_source(&source));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;

    let target = 20.0;  // 20ms for 100-depth context chain

    BenchmarkResult {
        name: "context_propagation",
        metric: "ms/100 layers",
        value: avg_ms,
        target: target,
        passed: avg_ms < target,
    }
}

/// Generate code with protocol implementations
fn generate_protocol_code(impls: Int) -> Text {
    let mut source = Text.new();
    source.push_str("module protocol_benchmark;\n\n");

    source.push_str("protocol Comparable {\n");
    source.push_str("    fn compare(self, other: Self) -> Ordering;\n");
    source.push_str("}\n\n");

    source.push_str("protocol Hashable {\n");
    source.push_str("    fn hash(self) -> Int;\n");
    source.push_str("}\n\n");

    source.push_str("protocol Displayable {\n");
    source.push_str("    fn display(self) -> Text;\n");
    source.push_str("}\n\n");

    for i in 0..impls {
        source.push_str(&format("record Type{} {{ value: Int }}\n\n", i));

        source.push_str(&format(
            "impl Comparable for Type{} {{
    fn compare(self, other: Self) -> Ordering {{
        self.value.compare(other.value)
    }}
}}

implement Hashable for Type{} {{
    fn hash(self) -> Int {{
        self.value
    }}
}}

implement Displayable for Type{} {{
    fn display(self) -> Text {{
        self.value.to_string()
    }}
}}

", i, i, i));
    }

    source
}

/// Benchmark: Protocol conformance checking
fn benchmark_protocol_conformance() -> BenchmarkResult {
    let source = generate_protocol_code(50);
    let iterations = 30;

    for _ in 0..3 {
        black_box(typecheck_source(&source));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(typecheck_source(&source));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;

    let target = 30.0;  // 30ms for 50 types x 3 protocols

    BenchmarkResult {
        name: "protocol_conformance",
        metric: "ms/150 impls",
        value: avg_ms,
        target: target,
        passed: avg_ms < target,
    }
}

/// Benchmark: Incremental type checking after small change
fn benchmark_incremental_typecheck() -> BenchmarkResult {
    let original = generate_project(MEDIUM_LOC);

    // Initial full typecheck
    let _types = typecheck_source(&original);

    // Make a small change (modify one function)
    let modified = original.replace(
        "let filtered =",
        "let filtered_items ="
    );

    let iterations = 100;

    for _ in 0..10 {
        black_box(typecheck_incremental(&modified));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(typecheck_incremental(&modified));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;

    // Incremental should be much faster than full
    let target = 10.0;  // 10ms for incremental update

    BenchmarkResult {
        name: "incremental_typecheck",
        metric: "ms/change",
        value: avg_ms,
        target: target,
        passed: avg_ms < target,
    }
}

fn count_lines(source: &Text) -> Int {
    source.lines().count()
}

fn typecheck_source(source: &Text) -> TypedAst {
    let ast = compiler.parse(source);
    compiler.typecheck(ast)
}

fn typecheck_incremental(source: &Text) -> TypedAst {
    compiler.typecheck_incremental(source)
}

type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}
