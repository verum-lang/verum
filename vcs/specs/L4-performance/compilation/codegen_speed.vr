/// Generate async code
fn generate_async_code(functions: Int) -> TypedAst {
    let mut source = Text.new();
    source.push_str("module async_codegen;\n\n");

    for i in 0..functions {
        source.push_str(&format(
            "async fn fetch_{}(url: Text) -> Result<Text, Error> {{
    let response = http.get(url).await?;
    let body = response.text().await?;
    Ok(body)
}}

async fn process_{}() {{
    let urls = [\"a\", \"b\", \"c\"];
    let futures = urls.iter().map(|u| fetch_{}(u.to_string()));
    let results = join_all(futures).await;
}}

", i, i, i));
    }

    let ast = compiler.parse(&source);
    compiler.typecheck(ast)
}

/// Benchmark: Async function codegen
fn benchmark_async_codegen() -> BenchmarkResult {
    let typed_ast = generate_async_code(30);
    let loc = typed_ast.line_count();
    let iterations = 20;

    for _ in 0..2 {
        black_box(codegen(&typed_ast, OptLevel.O2));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(codegen(&typed_ast, OptLevel.O2));
    }

    let elapsed_ms = timer.elapsed_ms();
    let total_loc = loc * iterations;
    let loc_per_sec = (total_loc as Float / elapsed_ms as Float) * 1000.0;

    // Async codegen involves state machine generation
    let target = TARGET_LOC_PER_SEC as Float * 0.7;

    BenchmarkResult {
        name: "async_codegen",
        metric: "LOC/sec",
        value: loc_per_sec,
        target: target,
        passed: loc_per_sec > target,
    }
}

/// Generate code with context usage
fn generate_context_code(functions: Int) -> TypedAst {
    let mut source = Text.new();
    source.push_str("module context_codegen;\n\n");

    source.push_str("context Logger { fn log(msg: Text); }\n\n");

    for i in 0..functions {
        source.push_str(&format(
            "fn logged_op_{}(x: Int) -> Int using [Logger] {{
    Logger.log(\"Starting operation {}\");
    let result = x * 2;
    Logger.log(\"Completed operation {}\");
    result
}}

", i, i, i));
    }

    let ast = compiler.parse(&source);
    compiler.typecheck(ast)
}

/// Benchmark: Context-aware codegen
fn benchmark_context_codegen() -> BenchmarkResult {
    let typed_ast = generate_context_code(50);
    let loc = typed_ast.line_count();
    let iterations = 30;

    for _ in 0..3 {
        black_box(codegen(&typed_ast, OptLevel.O2));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(codegen(&typed_ast, OptLevel.O2));
    }

    let elapsed_ms = timer.elapsed_ms();
    let total_loc = loc * iterations;
    let loc_per_sec = (total_loc as Float / elapsed_ms as Float) * 1000.0;

    BenchmarkResult {
        name: "context_codegen",
        metric: "LOC/sec",
        value: loc_per_sec,
        target: TARGET_LOC_PER_SEC as Float,
        passed: loc_per_sec > TARGET_LOC_PER_SEC as Float,
    }
}

/// Benchmark: Native code emission (LLVM -> object file)
fn benchmark_native_emission() -> BenchmarkResult {
    let typed_ast = generate_project(MEDIUM_LOC);
    let llvm_module = codegen(&typed_ast, OptLevel.O2);
    let iterations = 5;

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(emit_object(&llvm_module));
    }

    let elapsed_ms = timer.elapsed_ms();
    let avg_ms = elapsed_ms as Float / iterations as Float;

    // Native emission for 10K LOC should be < 500ms
    let target = 500.0;

    BenchmarkResult {
        name: "native_emission",
        metric: "ms/10K LOC",
        value: avg_ms,
        target: target,
        passed: avg_ms < target,
    }
}

type OptLevel is O0 | O1 | O2 | O3;

fn codegen(ast: &TypedAst, opt: OptLevel) -> LlvmModule {
    compiler.codegen(ast, opt)
}

fn emit_object(mod_ref: &LlvmModule) -> List<u8> {
    compiler.emit_object(mod_ref)
}

type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}
