// @test: parse
// @tier: 3
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: compilation, codegen, llvm, speed
// @description: Code generation performance benchmark (target: > 50K LOC/sec)

/// Code Generation Performance Benchmark
///
/// This benchmark measures the throughput of the Verum code generator.
/// Code generation produces LLVM IR from typed AST.
///
/// Target: > 50,000 lines of code per second
///
/// Codegen characteristics:
/// - LLVM IR generation via Inkwell
/// - CBGR instrumentation insertion
/// - Optimization passes (O0, O1, O2, O3)
/// - Native code emission
///
/// Spec reference: docs/detailed/26-cbgr-implementation.md

const TARGET_LOC_PER_SEC: Int = 50_000;
const SMALL_LOC: Int = 1_000;
const MEDIUM_LOC: Int = 10_000;
const LARGE_LOC: Int = 50_000;

fn main() {
    let results = BenchmarkResults.new("Code Generation Performance");

    // Basic codegen benchmarks
    results.add(benchmark_simple_codegen());
    results.add(benchmark_generic_codegen());
    results.add(benchmark_cbgr_instrumentation());

    // Scale benchmarks
    results.add(benchmark_small_project_codegen());
    results.add(benchmark_medium_project_codegen());
    results.add(benchmark_large_project_codegen());

    // Optimization level comparison
    results.add(benchmark_opt_level_o0());
    results.add(benchmark_opt_level_o1());
    results.add(benchmark_opt_level_o2());
    results.add(benchmark_opt_level_o3());

    // Specific codegen features
    results.add(benchmark_async_codegen());
    results.add(benchmark_context_codegen());
    results.add(benchmark_native_emission());

    results.report();
    assert(results.all_pass(), "Codegen performance below target");
}

/// Generate simple function code
fn generate_simple_functions(count: Int) -> TypedAst {
    let mut source = Text.with_capacity(count * 100);
    source.push_str("module simple_codegen;\n\n");

    for i in 0..count {
        source.push_str(&format(
            "fn add_{}(x: Int, y: Int) -> Int {{
    x + y
}}

fn mul_{}(x: Int, y: Int) -> Int {{
    x * y
}}

", i, i));
    }

    let ast = compiler.parse(&source);
    compiler.typecheck(ast)
}

/// Benchmark: Simple function codegen
fn benchmark_simple_codegen() -> BenchmarkResult {
    let typed_ast = generate_simple_functions(100);
    let loc = typed_ast.line_count();
    let iterations = 50;

    for _ in 0..5 {
        black_box(codegen(&typed_ast, OptLevel.O0));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(codegen(&typed_ast, OptLevel.O0));
    }

    let elapsed_ms = timer.elapsed_ms();
    let total_loc = loc * iterations;
    let loc_per_sec = (total_loc as Float / elapsed_ms as Float) * 1000.0;

    BenchmarkResult {
        name: "simple_codegen",
        metric: "LOC/sec",
        value: loc_per_sec,
        target: TARGET_LOC_PER_SEC as Float,
        passed: loc_per_sec > TARGET_LOC_PER_SEC as Float,
    }
}

/// Generate generic function code
fn generate_generic_functions(count: Int) -> TypedAst {
    let mut source = Text.new();
    source.push_str("module generic_codegen;\n\n");

    for i in 0..count {
        source.push_str(&format(
            "fn swap_{}<T>(a: &mut T, b: &mut T) {{
    let temp = *a;
    *a = *b;
    *b = temp;
}}

fn identity_{}<T: Clone>(x: T) -> T {{
    x.clone()
}}

", i, i));
    }

    let ast = compiler.parse(&source);
    compiler.typecheck(ast)
}

/// Benchmark: Generic function codegen (monomorphization)
fn benchmark_generic_codegen() -> BenchmarkResult {
    let typed_ast = generate_generic_functions(50);
    let loc = typed_ast.line_count();
    let iterations = 30;

    for _ in 0..3 {
        black_box(codegen(&typed_ast, OptLevel.O0));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(codegen(&typed_ast, OptLevel.O0));
    }

    let elapsed_ms = timer.elapsed_ms();
    let total_loc = loc * iterations;
    let loc_per_sec = (total_loc as Float / elapsed_ms as Float) * 1000.0;

    // Generic codegen involves monomorphization overhead
    let target = TARGET_LOC_PER_SEC as Float * 0.8;

    BenchmarkResult {
        name: "generic_codegen",
        metric: "LOC/sec",
        value: loc_per_sec,
        target: target,
        passed: loc_per_sec > target,
    }
}

/// Generate code requiring CBGR instrumentation
fn generate_cbgr_code(refs: Int) -> TypedAst {
    let mut source = Text.new();
    source.push_str("module cbgr_codegen;\n\n");

    for i in 0..refs {
        source.push_str(&format(
            "fn use_ref_{}(data: Heap<Int>) -> Int {{
    let ref_data = &*data;
    *ref_data + {}
}}

fn chain_refs_{}() {{
    let a = Heap.new(1);
    let b = Heap.new(&*a);
    let c = Heap.new(&*b);
    let val = ***c;
}}

", i, i, i));
    }

    let ast = compiler.parse(&source);
    compiler.typecheck(ast)
}

/// Benchmark: CBGR instrumentation insertion
fn benchmark_cbgr_instrumentation() -> BenchmarkResult {
    let typed_ast = generate_cbgr_code(50);
    let loc = typed_ast.line_count();
    let iterations = 30;

    for _ in 0..3 {
        black_box(codegen(&typed_ast, OptLevel.O0));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(codegen(&typed_ast, OptLevel.O0));
    }

    let elapsed_ms = timer.elapsed_ms();
    let total_loc = loc * iterations;
    let loc_per_sec = (total_loc as Float / elapsed_ms as Float) * 1000.0;

    // CBGR instrumentation adds some overhead
    let target = TARGET_LOC_PER_SEC as Float * 0.9;

    BenchmarkResult {
        name: "cbgr_instrumentation",
        metric: "LOC/sec",
        value: loc_per_sec,
        target: target,
        passed: loc_per_sec > target,
    }
}

/// Generate project of specified size
fn generate_project(loc: Int) -> TypedAst {
    let functions = loc / 10;
    generate_simple_functions(functions)
}

/// Benchmark: Small project codegen (~1K LOC)
fn benchmark_small_project_codegen() -> BenchmarkResult {
    let typed_ast = generate_project(SMALL_LOC);
    let loc = typed_ast.line_count();
    let iterations = 20;

    for _ in 0..2 {
        black_box(codegen(&typed_ast, OptLevel.O2));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(codegen(&typed_ast, OptLevel.O2));
    }

    let elapsed_ms = timer.elapsed_ms();
    let total_loc = loc * iterations;
    let loc_per_sec = (total_loc as Float / elapsed_ms as Float) * 1000.0;

    BenchmarkResult {
        name: "small_project_1k",
        metric: "LOC/sec",
        value: loc_per_sec,
        target: TARGET_LOC_PER_SEC as Float,
        passed: loc_per_sec > TARGET_LOC_PER_SEC as Float,
    }
}

