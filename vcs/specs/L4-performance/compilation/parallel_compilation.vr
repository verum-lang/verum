    let speedup = baseline_ms / avg_ms;
    let efficiency = speedup / 4.0;

    // Target: 70% efficiency with 4 cores
    let target_efficiency = 0.7;

    BenchmarkResult {
        name: "4_core_scaling",
        metric: "speedup",
        value: speedup,
        target: 4.0 * target_efficiency,
        passed: efficiency > target_efficiency,
    }
}

