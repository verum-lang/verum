// @test: parse
// @tier: 3
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: compilation, parallel, scaling, throughput
// @description: Parallel compilation performance benchmark (target: > 4x speedup on 8 cores)

/// Parallel Compilation Performance Benchmark
///
/// This benchmark measures the scalability of parallel compilation.
/// Parallel compilation distributes work across multiple CPU cores.
///
/// Target: > 4x speedup on 8 cores (50%+ efficiency)
///
/// Parallelization strategies:
/// - Module-level parallelism (independent modules)
/// - Function-level parallelism (within modules)
/// - Pipeline parallelism (parse -> typecheck -> codegen)
/// - Work stealing for load balancing
///
/// Spec reference: docs/detailed/28-implementation-roadmap.md

const SMALL_PROJECT_MODULES: Int = 20;
const MEDIUM_PROJECT_MODULES: Int = 100;
const LARGE_PROJECT_MODULES: Int = 500;
const LOC_PER_MODULE: Int = 500;

fn main() {
    let results = BenchmarkResults.new("Parallel Compilation Performance");

    // Core scaling benchmarks
    results.add(benchmark_scaling_1_core());
    results.add(benchmark_scaling_2_cores());
    results.add(benchmark_scaling_4_cores());
    results.add(benchmark_scaling_8_cores());
    results.add(benchmark_scaling_16_cores());

    // Project size impact
    results.add(benchmark_small_project_parallel());
    results.add(benchmark_medium_project_parallel());
    results.add(benchmark_large_project_parallel());

    // Parallelization strategies
    results.add(benchmark_module_level_parallel());
    results.add(benchmark_pipeline_parallel());
    results.add(benchmark_work_stealing_efficiency());

    // Overhead analysis
    results.add(benchmark_parallel_overhead());
    results.add(benchmark_synchronization_cost());

    results.report();
    results.export_scaling_chart("/tmp/parallel_scaling.json");

    assert(results.all_pass(), "Parallel compilation below target efficiency");
}

/// Generate a project with specified modules
fn generate_project(module_count: Int) -> List<ModuleSource> {
    let mut modules: List<ModuleSource> = List.new();

    // Create independent modules for maximum parallelism
    for i in 0..module_count {
        let functions_per_module = LOC_PER_MODULE / 10;
        let mut source = format("module mod_{};\n\n", i);

        for j in 0..functions_per_module {
            source.push_str(&format("
fn compute_{}_{}(x: Int, y: Int) -> Int {{
    let a = x + y;
    let b = x * y;
    let c = a - b;
    let d = (a + b) * c;
    if d > 0 {{ a + b + c + d }} else {{ a * b * c }}
}}
", i, j));
        }

        modules.push(ModuleSource {
            name: format("mod_{}", i),
            source: source,
            dependencies: [],
        });
    }

    modules
}

/// Run compilation with specified thread count
fn compile_with_threads(modules: &List<ModuleSource>, threads: Int) -> Int {
    let timer = Timer.new();
    timer.start();

    compiler.parallel_build(modules, threads);

    timer.elapsed_ms()
}

/// Benchmark: Single-threaded baseline
fn benchmark_scaling_1_core() -> BenchmarkResult {
    let modules = generate_project(MEDIUM_PROJECT_MODULES);
    let iterations = 3;

    let mut total_ms = 0;
    for _ in 0..iterations {
        total_ms += compile_with_threads(&modules, 1);
    }

    let avg_ms = total_ms as Float / iterations as Float;

    // Establish baseline
    BenchmarkResult {
        name: "1_core_baseline",
        metric: "ms",
        value: avg_ms,
        target: f64.MAX,  // No target for baseline
        passed: true,
        extra: Some(("baseline_ms", avg_ms)),
    }
}

/// Benchmark: 2-core scaling
fn benchmark_scaling_2_cores() -> BenchmarkResult {
    let modules = generate_project(MEDIUM_PROJECT_MODULES);
    let iterations = 3;

    // Get baseline
    let baseline_ms = compile_with_threads(&modules, 1) as Float;

    let mut total_ms = 0;
    for _ in 0..iterations {
        total_ms += compile_with_threads(&modules, 2);
    }

    let avg_ms = total_ms as Float / iterations as Float;
    let speedup = baseline_ms / avg_ms;
    let efficiency = speedup / 2.0;

    // Target: 80% efficiency with 2 cores
    let target_efficiency = 0.8;

    BenchmarkResult {
        name: "2_core_scaling",
        metric: "speedup",
        value: speedup,
        target: 2.0 * target_efficiency,
        passed: efficiency > target_efficiency,
    }
}

