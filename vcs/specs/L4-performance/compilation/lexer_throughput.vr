/// Benchmark: Mixed realistic source
fn benchmark_mixed_tokens() -> LexerBenchmarkResult {
    let source = generate_complex_mixed_source(1_000);
    let source_bytes = source.len();

    for _ in 0..WARMUP_ITERATIONS {
        let tokens = Lexer.tokenize(&source);
        black_box(tokens.len());
    }

    let start = Instant.now();
    let mut total_tokens = 0;

    for _ in 0..BENCHMARK_ITERATIONS {
        let tokens = Lexer.tokenize(&source);
        total_tokens += tokens.len();
    }

    let elapsed = start.elapsed();

    LexerBenchmarkResult {
        name: "mixed_realistic",
        source_bytes: source_bytes * BENCHMARK_ITERATIONS,
        total_tokens,
        elapsed_ms: elapsed.as_millis(),
        tokens_per_sec: total_tokens as f64 / elapsed.as_secs_f64(),
        bytes_per_sec: (source_bytes * BENCHMARK_ITERATIONS) as f64 / elapsed.as_secs_f64(),
        target_tokens_per_sec: 5_000_000.0,
    }
}

/// Benchmark: Large file (stress test)
fn benchmark_large_file() -> LexerBenchmarkResult {
    let source = generate_complex_mixed_source(10_000);
    let source_bytes = source.len();

    for _ in 0..WARMUP_ITERATIONS / 5 {
        let tokens = Lexer.tokenize(&source);
        black_box(tokens.len());
    }

    let start = Instant.now();
    let mut total_tokens = 0;

    for _ in 0..(BENCHMARK_ITERATIONS / 10) {
        let tokens = Lexer.tokenize(&source);
        total_tokens += tokens.len();
    }

    let elapsed = start.elapsed();

    LexerBenchmarkResult {
        name: "large_file_stress",
        source_bytes: source_bytes * BENCHMARK_ITERATIONS / 10,
        total_tokens,
        elapsed_ms: elapsed.as_millis(),
        tokens_per_sec: total_tokens as f64 / elapsed.as_secs_f64(),
        bytes_per_sec: (source_bytes * BENCHMARK_ITERATIONS / 10) as f64 / elapsed.as_secs_f64(),
        target_tokens_per_sec: 5_000_000.0,
    }
}

fn main() {
    println("=== Lexer Throughput Benchmark ===\n");

    let results = [
        benchmark_simple_tokens(),
        benchmark_function_tokens(),
        benchmark_expression_tokens(),
        benchmark_string_tokens(),
        benchmark_comment_tokens(),
        benchmark_unicode_tokens(),
        benchmark_mixed_tokens(),
        benchmark_large_file(),
    ];

    println("{:<25} {:>12} {:>12} {:>12} {:>8}",
            "Benchmark", "Tokens/sec", "MB/sec", "Target", "Status");
    println("{}", "-".repeat(75));

    for result in results {
        let passed = result.tokens_per_sec >= result.target_tokens_per_sec;
        let status = if passed { "PASS" } else { "FAIL" };

        println("{:<25} {:>12.2}M {:>12.2} {:>12.2}M {:>8}",
                result.name,
                result.tokens_per_sec / 1_000_000.0,
                result.bytes_per_sec / 1_000_000.0,
                result.target_tokens_per_sec / 1_000_000.0,
                status);
    }

    println("");
    println("Overall target: > 5M tokens/sec for mixed content");
}

type LexerBenchmarkResult is {
    name: Text,
    source_bytes: Int,
    total_tokens: Int,
    elapsed_ms: Int,
    tokens_per_sec: f64,
    bytes_per_sec: f64,
    target_tokens_per_sec: f64,
};

// Mock Lexer for benchmark specification
module Lexer {
    pub fn tokenize(source: &Text) -> List<Token> {
        List.new()
    }
}

type Token is Ident | Number | String | Keyword | Operator | Punctuation;

type Instant is { nanos: Int };
implement Instant {
    fn now() -> Self { Self { nanos: 0 } }
    fn elapsed(&self) -> Duration { Duration { nanos: 0 } }
}

type Duration is { nanos: Int };
implement Duration {
    fn as_millis(&self) -> Int { self.nanos / 1_000_000 }
    fn as_secs_f64(&self) -> f64 { self.nanos as f64 / 1e9 }
}

fn black_box<T>(x: T) -> T { x }
fn format(fmt: &Text, args: List<Text>) -> Text { Text.new() }
