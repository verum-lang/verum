// @test: parse
// @tier: 3
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: compilation, parser, speed, throughput
// @description: Parser performance benchmark (target: > 100K LOC/sec)

/// Parser Performance Benchmark
///
/// This benchmark measures the throughput of the Verum parser.
/// Parsing is typically the fastest phase of compilation.
///
/// Target: > 100,000 lines of code per second
///
/// Parser characteristics:
/// - Recursive descent parser
/// - Single-pass tokenization (logos)
/// - Zero-copy where possible
/// - Parallel module parsing
///
/// Spec reference: docs/detailed/05-syntax-grammar.md

const SMALL_FILE_LINES: Int = 100;
const MEDIUM_FILE_LINES: Int = 1_000;
const LARGE_FILE_LINES: Int = 10_000;
const XLARGE_FILE_LINES: Int = 100_000;

const TARGET_LOC_PER_SEC: Int = 100_000;

fn main() {
    let results = BenchmarkResults.new("Parser Performance");

    // Single-file parsing benchmarks
    results.add(benchmark_small_file_parse());
    results.add(benchmark_medium_file_parse());
    results.add(benchmark_large_file_parse());
    results.add(benchmark_xlarge_file_parse());

    // Parser stress tests
    results.add(benchmark_deep_nesting());
    results.add(benchmark_wide_expressions());
    results.add(benchmark_complex_types());
    results.add(benchmark_many_functions());

    // Parallel parsing
    results.add(benchmark_parallel_module_parse());

    results.report();
    assert(results.all_pass(), "Parser performance below target");
}

/// Generate synthetic Verum source code
fn generate_source(lines: Int) -> Text {
    let mut source = Text.with_capacity(lines * 50);

    // Module header
    source.push_str("// Auto-generated benchmark source\n");
    source.push_str("module benchmark;\n\n");

    // Generate functions to reach target line count
    let functions_needed = lines / 10;  // ~10 lines per function

    for i in 0..functions_needed {
        source.push_str(&format(
            "fn compute_{}(x: Int, y: Int) -> Int {{\n",
            i
        ));
        source.push_str("    let a = x + y;\n");
        source.push_str("    let b = x * y;\n");
        source.push_str("    let c = a - b;\n");
        source.push_str("    if c > 0 {\n");
        source.push_str("        a + b + c\n");
        source.push_str("    } else {\n");
        source.push_str("        a * b * c\n");
        source.push_str("    }\n");
        source.push_str("}\n\n");
    }

    source
}

/// Benchmark: Parse small file (~100 LOC)
fn benchmark_small_file_parse() -> BenchmarkResult {
    let source = generate_source(SMALL_FILE_LINES);
    let iterations = 10_000;

    // Warmup
    for _ in 0..1_000 {
        black_box(parse_source(&source));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..iterations {
        black_box(parse_source(&source));
    }

    let elapsed_ms = timer.elapsed_ms();
    let total_lines = SMALL_FILE_LINES * iterations;
    let loc_per_sec = (total_lines as Float / elapsed_ms as Float) * 1000.0;

    BenchmarkResult {
        name: "small_file_parse",
        metric: "LOC/sec",
        value: loc_per_sec,
        target: TARGET_LOC_PER_SEC as Float,
        passed: loc_per_sec > TARGET_LOC_PER_SEC as Float,
    }
}

