        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        target_mb_per_sec: 200.0,
    }
}

/// Benchmark: Typed deserialization
fn benchmark_typed_deserialize() -> JsonBenchmarkResult {
    type Item is {
        id: Int,
        name: Text,
        value: Float,
    };

    let json = generate_array_json(1000);
    let json_bytes = json.len();

    for _ in 0..WARMUP_ITERATIONS {
        let items: List<Item> = Json.from_str(&json).unwrap();
        black_box(items);
    }

    let start = Instant.now();

    for _ in 0..BENCHMARK_ITERATIONS {
        let items: List<Item> = Json.from_str(&json).unwrap();
        black_box(items);
    }

    let elapsed = start.elapsed();
    let total_bytes = json_bytes * BENCHMARK_ITERATIONS;

    JsonBenchmarkResult {
        name: "typed_deserialize",
        bytes_processed: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        target_mb_per_sec: 120.0,
    }
}

/// Benchmark: Typed serialization
fn benchmark_typed_serialize() -> JsonBenchmarkResult {
    type Item is {
        id: Int,
        name: Text,
        value: Float,
    };

    let items: List<Item> = (0..1000)
        .map(|i| Item {
            id: i,
            name: format("item_{}", i),
            value: i as f64 * 1.5,
        })
        .collect();

    for _ in 0..WARMUP_ITERATIONS {
        let output = Json.to_string(&items);
        black_box(output);
    }

    let start = Instant.now();
    let mut total_bytes = 0;

    for _ in 0..BENCHMARK_ITERATIONS {
        let output = Json.to_string(&items);
        total_bytes += output.len();
        black_box(output);
    }

    let elapsed = start.elapsed();

    JsonBenchmarkResult {
        name: "typed_serialize",
        bytes_processed: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        target_mb_per_sec: 250.0,
    }
}

/// Benchmark: Streaming parse
fn benchmark_stream_parse() -> JsonBenchmarkResult {
    let json = generate_array_json(10000);
    let json_bytes = json.len();

    for _ in 0..WARMUP_ITERATIONS / 5 {
        let mut count = 0;
        for event in Json.stream_parse(&json) {
            count += 1;
            black_box(event);
        }
        black_box(count);
    }

    let start = Instant.now();

    for _ in 0..(BENCHMARK_ITERATIONS / 5) {
        for event in Json.stream_parse(&json) {
            black_box(event);
        }
    }

    let elapsed = start.elapsed();
    let total_bytes = json_bytes * BENCHMARK_ITERATIONS / 5;

    JsonBenchmarkResult {
        name: "stream_parse",
        bytes_processed: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        target_mb_per_sec: 150.0,
    }
}

fn main() {
    println("=== JSON Parsing Performance Benchmark ===\n");

    let results = [
        benchmark_parse_simple(),
        benchmark_parse_array(),
        benchmark_parse_nested(),
        benchmark_parse_strings(),
        benchmark_parse_mixed(),
        benchmark_serialize(),
        benchmark_serialize_pretty(),
        benchmark_typed_deserialize(),
        benchmark_typed_serialize(),
        benchmark_stream_parse(),
    ];

    println("{:<30} {:>12} {:>12} {:>8}",
            "Benchmark", "MB/sec", "Target", "Status");
    println("{}", "-".repeat(65));

    for result in results {
        let passed = result.mb_per_sec >= result.target_mb_per_sec;
        let status = if passed { "PASS" } else { "FAIL" };

        println("{:<30} {:>12.1} {:>12.0} {:>8}",
                result.name, result.mb_per_sec, result.target_mb_per_sec, status);
    }

    println("");
    println("JSON Performance Targets:");
    println("  - Simple parse:   > 200 MB/sec");
    println("  - Complex parse:  > 100 MB/sec");
    println("  - Serialize:      > 300 MB/sec");
    println("  - Stream parse:   > 150 MB/sec");
}

type JsonBenchmarkResult is {
    name: Text,
    bytes_processed: Int,
    elapsed_ms: Int,
    mb_per_sec: f64,
    target_mb_per_sec: f64,
};

module Json {
    pub fn parse(s: &Text) -> Result<JsonValue, Error> { Ok(JsonValue.Null) }
    pub fn from_str<T>(s: &Text) -> Result<T, Error> { todo() }
    pub fn to_string<T>(v: &T) -> Text { Text.new() }
    pub fn stream_parse(s: &Text) -> impl Iterator<Item = JsonEvent> { [].into_iter() }
}

type JsonValue is Null | Bool(Bool) | Number(f64) | String(Text) | Array(List<JsonValue>) | Object(Map<Text, JsonValue>);

implement JsonValue {
    fn to_string(&self) -> Text { Text.new() }
    fn to_string_pretty(&self) -> Text { Text.new() }
}

type JsonEvent is StartObject | EndObject | StartArray | EndArray | Key(Text) | Value(JsonValue);

type Instant is { nanos: Int };
implement Instant {
    fn now() -> Self { Self { nanos: 0 } }
    fn elapsed(&self) -> Duration { Duration { nanos: 0 } }
}

type Duration is { nanos: Int };
implement Duration {
    fn as_millis(&self) -> Int { self.nanos / 1_000_000 }
    fn as_secs_f64(&self) -> f64 { self.nanos as f64 / 1e9 }
}

fn black_box<T>(x: T) -> T { x }
fn format(fmt: &Text, args: List<Text>) -> Text { Text.new() }
