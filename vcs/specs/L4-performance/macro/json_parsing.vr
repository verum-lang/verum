// @test: parse
// @tier: all
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: macro, json, parsing, serialization, real-world
// @description: JSON parsing and serialization performance (target: > 100MB/sec)

/// JSON Parsing Performance Benchmark
///
/// Measures real-world JSON parsing and serialization performance.
/// JSON is ubiquitous in web services and configuration.
///
/// Performance targets:
/// - Parse simple:    > 200MB/sec
/// - Parse complex:   > 100MB/sec
/// - Serialize:       > 300MB/sec
/// - Pretty print:    > 200MB/sec
/// - Stream parse:    > 150MB/sec
///
/// Test data characteristics:
/// - Small objects (config-like)
/// - Large arrays (data payloads)
/// - Deeply nested structures
/// - Unicode content
///
/// Spec reference: docs/detailed/20-standard-library.md

const WARMUP_ITERATIONS: Int = 10;
const BENCHMARK_ITERATIONS: Int = 100;

/// Generate sample JSON data
fn generate_simple_json(entries: Int) -> Text {
    let mut json = Text.from("{");

    for i in 0..entries {
        if i > 0 { json.push_str(","); }
        json.push_str(&format(
            r#""key_{}": {}"#,
            i, i * 42
        ));
    }

    json.push_str("}");
    json
}

fn generate_array_json(elements: Int) -> Text {
    let mut json = Text.from("[");

    for i in 0..elements {
        if i > 0 { json.push_str(","); }
        json.push_str(&format(
            r#"{{"id": {}, "name": "item_{}", "value": {}.{}}}"#,
            i, i, i * 10, i % 100
        ));
    }

    json.push_str("]");
    json
}

fn generate_nested_json(depth: Int) -> Text {
    let mut json = Text.new();

    for _ in 0..depth {
        json.push_str(r#"{"nested": "#);
    }

    json.push_str(r#"{"value": 42}"#);

    for _ in 0..depth {
        json.push_str("}");
    }

    json
}

fn generate_string_heavy_json(entries: Int) -> Text {
    let mut json = Text.from("{");

    for i in 0..entries {
        if i > 0 { json.push_str(","); }
        json.push_str(&format(
            r#""key_{}": "This is a longer string value with some content for entry number {}""#,
            i, i
        ));
    }

    json.push_str("}");
    json
}

fn generate_mixed_json(size: Int) -> Text {
    let mut json = Text.from(r#"{"metadata": {"version": 1, "name": "test"}, "data": ["#);

    for i in 0..size {
        if i > 0 { json.push_str(","); }
        json.push_str(&format(
            r#"{{"id": {}, "active": {}, "tags": ["tag1", "tag2"], "nested": {{"a": {}, "b": "value"}}}}"#,
            i, i % 2 == 0, i * 3
        ));
    }

    json.push_str("]}");
    json
}

/// Benchmark: Parse simple object
fn benchmark_parse_simple() -> JsonBenchmarkResult {
    let json = generate_simple_json(100);
    let json_bytes = json.len();

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        let parsed = Json.parse(&json);
        black_box(parsed);
    }

    let start = Instant.now();

    for _ in 0..BENCHMARK_ITERATIONS {
        let parsed = Json.parse(&json);
        black_box(parsed);
    }

    let elapsed = start.elapsed();
    let total_bytes = json_bytes * BENCHMARK_ITERATIONS;

    JsonBenchmarkResult {
        name: "parse_simple_100_keys",
        bytes_processed: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        target_mb_per_sec: 200.0,
    }
}

