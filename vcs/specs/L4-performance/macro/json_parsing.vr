}

/// Benchmark: Parse deeply nested
fn benchmark_parse_nested() -> JsonBenchmarkResult {
    let json = generate_nested_json(50);
    let json_bytes = json.len();

    for _ in 0..WARMUP_ITERATIONS {
        let parsed = Json.parse(&json);
        black_box(parsed);
    }

    let start = Instant.now();

    for _ in 0..(BENCHMARK_ITERATIONS * 10) {
        let parsed = Json.parse(&json);
        black_box(parsed);
    }

    let elapsed = start.elapsed();
    let total_bytes = json_bytes * BENCHMARK_ITERATIONS * 10;

    JsonBenchmarkResult {
        name: "parse_nested_50_levels",
        bytes_processed: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        target_mb_per_sec: 100.0,
    }
}

