/// Benchmark: Serialize to string
fn benchmark_serialize() -> JsonBenchmarkResult {
    let json = generate_mixed_json(500);
    let parsed = Json.parse(&json).unwrap();

    for _ in 0..WARMUP_ITERATIONS {
        let output = parsed.to_string();
        black_box(output);
    }

    let start = Instant.now();
    let mut total_bytes = 0;

    for _ in 0..BENCHMARK_ITERATIONS {
        let output = parsed.to_string();
        total_bytes += output.len();
        black_box(output);
    }

    let elapsed = start.elapsed();

    JsonBenchmarkResult {
        name: "serialize_compact",
        bytes_processed: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        target_mb_per_sec: 300.0,
    }
}

/// Benchmark: Serialize pretty-printed
fn benchmark_serialize_pretty() -> JsonBenchmarkResult {
    let json = generate_mixed_json(500);
    let parsed = Json.parse(&json).unwrap();

    for _ in 0..WARMUP_ITERATIONS {
        let output = parsed.to_string_pretty();
        black_box(output);
    }

    let start = Instant.now();
    let mut total_bytes = 0;

    for _ in 0..BENCHMARK_ITERATIONS {
