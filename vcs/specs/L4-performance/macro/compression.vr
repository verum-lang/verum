/// Benchmark: LZ4 decompression
fn benchmark_lz4_decompress() -> CompressionBenchmarkResult {
    let data = generate_text_data(DATA_SIZE);
    let compressed = lz4.compress(&data);

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        let decompressed = lz4.decompress(&compressed, DATA_SIZE);
        black_box(decompressed);
    }

    let start = Instant.now();

    for _ in 0..BENCHMARK_ITERATIONS {
        let decompressed = lz4.decompress(&compressed, DATA_SIZE);
        black_box(decompressed);
    }

    let elapsed = start.elapsed();
    let total_bytes = DATA_SIZE * BENCHMARK_ITERATIONS;

    CompressionBenchmarkResult {
        name: "lz4_decompress",
        algorithm: "lz4",
        operation: "decompress",
        input_bytes: compressed.len() * BENCHMARK_ITERATIONS,
        output_bytes: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        compression_ratio: 0.0,
        target_mb_per_sec: 1000.0,
    }
}

