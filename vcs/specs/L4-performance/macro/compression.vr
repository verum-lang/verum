// @test: parse
// @tier: all
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: macro, compression, gzip, zstd, real-world
// @description: Compression benchmarks (target: > 100MB/s compress, > 300MB/s decompress)

/// Compression Performance Benchmark
///
/// Measures compression and decompression performance for various algorithms.
/// Compression is critical for storage efficiency and network transfer.
///
/// Performance targets:
/// - Gzip compression:    > 100MB/sec
/// - Gzip decompression:  > 300MB/sec
/// - Zstd compression:    > 200MB/sec
/// - Zstd decompression:  > 500MB/sec
/// - LZ4 compression:     > 400MB/sec
/// - LZ4 decompression:   > 1GB/sec
///
/// Test data types:
/// - Text (high compression ratio)
/// - Binary (mixed compressibility)
/// - Random (incompressible)
///
/// Spec reference: docs/detailed/20-standard-library.md

const WARMUP_ITERATIONS: Int = 10;
const BENCHMARK_ITERATIONS: Int = 100;
const DATA_SIZE: Int = 1_000_000;  // 1MB

/// Generate compressible text data
fn generate_text_data(size: Int) -> List<u8> {
    let sample = "The quick brown fox jumps over the lazy dog. Lorem ipsum dolor sit amet. ";
    let mut data = Text.with_capacity(size);

    while data.len() < size {
        data.push_str(sample);
    }

    data.truncate(size);
    data.into_bytes()
}

/// Generate structured data (JSON-like)
fn generate_structured_data(size: Int) -> List<u8> {
    let mut data = Text.with_capacity(size);
    data.push_str("[");

    let entry_size = 80;
    let entries = size / entry_size;

    for i in 0..entries {
        if i > 0 { data.push_str(","); }
        data.push_str(&format(
            r#"{{"id":{},"name":"item_{}","value":{}}}"#,
            i, i, i * 42
        ));
    }

    data.push_str("]");
    data.into_bytes()
}

/// Generate binary data (mixed patterns)
fn generate_binary_data(size: Int) -> List<u8> {
    let mut data = List.with_capacity(size);

    for i in 0..size {
        // Mix of patterns
        let byte = if i % 100 < 50 {
            // Repetitive section
            (i % 16) as u8
        } else {
            // Varied section
            ((i * 7 + 13) % 256) as u8
        };
        data.push(byte);
    }

    data
}

/// Generate random data (incompressible)
fn generate_random_data(size: Int) -> List<u8> {
    let mut data = List.with_capacity(size);
    let mut rng = Random.with_seed(42);

    for _ in 0..size {
        data.push((rng.next() % 256) as u8);
    }

    data
}

/// Benchmark: Gzip compression
fn benchmark_gzip_compress() -> CompressionBenchmarkResult {
    let data = generate_text_data(DATA_SIZE);

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        let compressed = gzip.compress(&data, CompressionLevel.Default);
        black_box(compressed);
    }

    let start = Instant.now();
    let mut total_compressed_size = 0;

    for _ in 0..BENCHMARK_ITERATIONS {
        let compressed = gzip.compress(&data, CompressionLevel.Default);
        total_compressed_size += compressed.len();
        black_box(compressed);
    }

    let elapsed = start.elapsed();
    let total_bytes = DATA_SIZE * BENCHMARK_ITERATIONS;

    CompressionBenchmarkResult {
        name: "gzip_compress",
        algorithm: "gzip",
        operation: "compress",
        input_bytes: total_bytes,
        output_bytes: total_compressed_size,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        compression_ratio: total_bytes as f64 / total_compressed_size as f64,
        target_mb_per_sec: 100.0,
    }
}

/// Benchmark: Gzip decompression
fn benchmark_gzip_decompress() -> CompressionBenchmarkResult {
    let data = generate_text_data(DATA_SIZE);
    let compressed = gzip.compress(&data, CompressionLevel.Default);

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        let decompressed = gzip.decompress(&compressed);
        black_box(decompressed);
    }

    let start = Instant.now();

    for _ in 0..BENCHMARK_ITERATIONS {
        let decompressed = gzip.decompress(&compressed);
        black_box(decompressed);
    }

    let elapsed = start.elapsed();
    let total_bytes = DATA_SIZE * BENCHMARK_ITERATIONS;

    CompressionBenchmarkResult {
        name: "gzip_decompress",
        algorithm: "gzip",
        operation: "decompress",
        input_bytes: compressed.len() * BENCHMARK_ITERATIONS,
        output_bytes: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        compression_ratio: 0.0,  // Not applicable for decompress
        target_mb_per_sec: 300.0,
    }
}

/// Benchmark: Zstd compression
fn benchmark_zstd_compress() -> CompressionBenchmarkResult {
    let data = generate_text_data(DATA_SIZE);

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        let compressed = zstd.compress(&data, 3);  // Level 3
        black_box(compressed);
    }

    let start = Instant.now();
    let mut total_compressed_size = 0;

    for _ in 0..BENCHMARK_ITERATIONS {
        let compressed = zstd.compress(&data, 3);
        total_compressed_size += compressed.len();
        black_box(compressed);
    }

    let elapsed = start.elapsed();
    let total_bytes = DATA_SIZE * BENCHMARK_ITERATIONS;

    CompressionBenchmarkResult {
        name: "zstd_compress",
        algorithm: "zstd",
        operation: "compress",
        input_bytes: total_bytes,
        output_bytes: total_compressed_size,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        compression_ratio: total_bytes as f64 / total_compressed_size as f64,
        target_mb_per_sec: 200.0,
    }
}

/// Benchmark: Zstd decompression
fn benchmark_zstd_decompress() -> CompressionBenchmarkResult {
    let data = generate_text_data(DATA_SIZE);
    let compressed = zstd.compress(&data, 3);

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        let decompressed = zstd.decompress(&compressed);
        black_box(decompressed);
    }

    let start = Instant.now();

    for _ in 0..BENCHMARK_ITERATIONS {
        let decompressed = zstd.decompress(&compressed);
        black_box(decompressed);
    }

    let elapsed = start.elapsed();
    let total_bytes = DATA_SIZE * BENCHMARK_ITERATIONS;

    CompressionBenchmarkResult {
        name: "zstd_decompress",
        algorithm: "zstd",
        operation: "decompress",
        input_bytes: compressed.len() * BENCHMARK_ITERATIONS,
        output_bytes: total_bytes,
        elapsed_ms: elapsed.as_millis(),
        mb_per_sec: (total_bytes as f64 / 1e6) / elapsed.as_secs_f64(),
        compression_ratio: 0.0,
        target_mb_per_sec: 500.0,
    }
}

