// @test: typecheck-pass
// @tier: all
// @level: L4
// @tags: micro, list, performance, throughput
// @description: List push/iterate/sort throughput benchmarks

/// List Operations Throughput Benchmark

fn bench_push(count: Int) -> Int {
    let mut list = List.new();
    let mut i = 0;
    while i < count {
        list.push(i);
        i = i + 1;
    }
    list.len()
}

fn bench_iterate_sum(count: Int) -> Int {
    let mut list = List.new();
    let mut i = 0;
    while i < count {
        list.push(i);
        i = i + 1;
    }
    let mut sum = 0;
    i = 0;
    while i < list.len() {
        sum = sum + list[i];
        i = i + 1;
    }
    sum
}

fn bench_index_access(count: Int) -> Int {
    let mut list = List.new();
    let mut i = 0;
    while i < 1000 {
        list.push(i);
        i = i + 1;
    }
    let mut sum = 0;
    i = 0;
    while i < count {
        sum = sum + list[i % 1000];
        i = i + 1;
    }
    sum
}

fn bench_push_pop(count: Int) -> Int {
    let mut list = List.new();
    let mut i = 0;
    // Push all
    while i < count {
        list.push(i);
        i = i + 1;
    }
    // Read from end and count
    let mut popped = 0;
    i = list.len() - 1;
    while i >= 0 {
        let _ = list[i];
        popped = popped + 1;
        i = i - 1;
    }
    popped
}

fn main() -> Int {
    let count = 100000;
    print("=== List Operations Benchmarks ===");
    print(f"Element count: {count}");

    let r1 = bench_push(count);
    print(f"  push: done (len={r1})");

    let r2 = bench_iterate_sum(count);
    print(f"  iterate_sum: done (sum={r2})");

    let r3 = bench_index_access(count);
    print(f"  index_access: done (sum={r3})");

    let r4 = bench_push_pop(count);
    print(f"  push_pop: done (count={r4})");

    // Verify
    if r1 != count {
        print("FAIL: push count wrong");
        return 1;
    }
    let expected_sum = (count - 1) * count / 2;
    if r2 != expected_sum {
        print(f"FAIL: iterate_sum expected {expected_sum}, got {r2}");
        return 1;
    }

    print("All list operation benchmarks completed");
    0
}
