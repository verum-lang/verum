// @test: parse
// @tier: all
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: runtime, virtual, dispatch, protocol, polymorphism
// @description: Virtual dispatch benchmark (target: < 15ns per dispatch)

/// Virtual Dispatch (Protocol) Benchmark
///
/// Measures the overhead of virtual method calls through protocol dispatch.
/// This includes vtable lookup, indirect call, and CBGR checks.
///
/// Targets:
/// - Monomorphic dispatch: < 10ns (predictable branch)
/// - Polymorphic dispatch: < 15ns (vtable lookup)
/// - Megamorphic dispatch: < 20ns (cache miss potential)
///
/// Spec reference: docs/detailed/26-cbgr-implementation.md

module vcs.specs.l4.runtime.virtual_dispatch;

const WARMUP_ITERATIONS: Int = 100_000;
const BENCHMARK_ITERATIONS: Int = 10_000_000;

/// Base protocol for dispatch testing
type Computable is protocol {
    fn compute(&self, x: Int) -> Int;
};

/// Protocol with multiple methods
type MultiMethod is protocol {
    fn method_a(&self, x: Int) -> Int;
    fn method_b(&self, x: Int) -> Int;
    fn method_c(&self, x: Int) -> Int;
};

/// Implementations for dispatch testing
type ImplA is { value: Int };
type ImplB is { value: Int };
type ImplC is { value: Int };
type ImplD is { value: Int };

implement Computable for ImplA {
    fn compute(&self, x: Int) -> Int {
        self.value + x
    }
}

implement Computable for ImplB {
    fn compute(&self, x: Int) -> Int {
        self.value * x
    }
}

implement Computable for ImplC {
    fn compute(&self, x: Int) -> Int {
        self.value - x
    }
}

implement Computable for ImplD {
    fn compute(&self, x: Int) -> Int {
        self.value / (x + 1)
    }
}

implement MultiMethod for ImplA {
    fn method_a(&self, x: Int) -> Int { self.value + x }
    fn method_b(&self, x: Int) -> Int { self.value * x }
    fn method_c(&self, x: Int) -> Int { self.value - x }
}

fn main() {
    let results = BenchmarkResults.new("Virtual Dispatch Overhead");

    // Basic dispatch benchmarks
    results.add(benchmark_monomorphic_dispatch());
    results.add(benchmark_bimorphic_dispatch());
    results.add(benchmark_polymorphic_dispatch());
    results.add(benchmark_megamorphic_dispatch());

    // Multi-method dispatch
    results.add(benchmark_multi_method_same_receiver());
    results.add(benchmark_multi_method_different_methods());

    // Comparison benchmarks
    results.add(benchmark_static_vs_virtual());
    results.add(benchmark_inline_vs_virtual());

    // Protocol hierarchy
    results.add(benchmark_single_protocol());
    results.add(benchmark_protocol_chain());

    // Real-world patterns
    results.add(benchmark_iterator_dispatch());
    results.add(benchmark_visitor_pattern());

    results.report();
    assert(results.all_pass(), "Virtual dispatch overhead exceeds targets");
}

/// Monomorphic dispatch (always same concrete type)
fn benchmark_monomorphic_dispatch() -> BenchmarkResult {
    let obj: &Computable = &ImplA { value: 10 };

    // Warmup - train branch predictor
    for _ in 0..WARMUP_ITERATIONS {
        black_box(obj.compute(5));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(obj.compute(5));
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "monomorphic_dispatch",
        metric: "ns/call",
        value: per_call_ns,
        target: 10.0,
        passed: per_call_ns < 10.0,
    }
}

/// Bimorphic dispatch (alternating between 2 types)
fn benchmark_bimorphic_dispatch() -> BenchmarkResult {
    let obj_a: &Computable = &ImplA { value: 10 };
    let obj_b: &Computable = &ImplB { value: 20 };

    // Warmup
    for i in 0..WARMUP_ITERATIONS {
        if i % 2 == 0 {
            black_box(obj_a.compute(5));
        } else {
            black_box(obj_b.compute(5));
        }
    }

    let timer = Timer.new();
    timer.start();

    for i in 0..BENCHMARK_ITERATIONS {
        if i % 2 == 0 {
            black_box(obj_a.compute(5));
        } else {
            black_box(obj_b.compute(5));
        }
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "bimorphic_dispatch",
        metric: "ns/call",
        value: per_call_ns,
        target: 12.0,
        passed: per_call_ns < 12.0,
    }
}

/// Polymorphic dispatch (cycling through 4 types)
fn benchmark_polymorphic_dispatch() -> BenchmarkResult {
    let objects: List<Heap<Computable>> = [
        Heap(ImplA { value: 1 }),
        Heap(ImplB { value: 2 }),
        Heap(ImplC { value: 3 }),
        Heap(ImplD { value: 4 }),
    ];

    // Warmup
    for _ in 0..(WARMUP_ITERATIONS / 4) {
        for obj in objects.iter() {
            black_box(obj.compute(5));
        }
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..(BENCHMARK_ITERATIONS / 4) {
        for obj in objects.iter() {
            black_box(obj.compute(5));
        }
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "polymorphic_dispatch",
        metric: "ns/call",
        value: per_call_ns,
        target: 15.0,
        passed: per_call_ns < 15.0,
    }
}

/// Megamorphic dispatch (many types, random order)
fn benchmark_megamorphic_dispatch() -> BenchmarkResult {
    // Create many implementations
    let objects: List<Heap<Computable>> = List.new();
    for i in 0..16 {
        match i % 4 {
            0 => objects.push(Heap(ImplA { value: i })),
            1 => objects.push(Heap(ImplB { value: i })),
            2 => objects.push(Heap(ImplC { value: i })),
            _ => objects.push(Heap(ImplD { value: i })),
        }
    }

    // Shuffle for random access pattern
    let mut rng = Rng.with_seed(12345);
    let indices: List<Int> = List.with_capacity(BENCHMARK_ITERATIONS);
    for _ in 0..BENCHMARK_ITERATIONS {
        indices.push(rng.next_int() % 16);
    }

    // Warmup
    for i in 0..WARMUP_ITERATIONS {
        let idx = indices[i % indices.len()];
        black_box(objects[idx].compute(5));
    }

    let timer = Timer.new();
    timer.start();

    for idx in indices.iter() {
        black_box(objects[*idx].compute(5));
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "megamorphic_dispatch",
        metric: "ns/call",
        value: per_call_ns,
        target: 20.0,
        passed: per_call_ns < 20.0,
    }
}

/// Multiple methods on same receiver
fn benchmark_multi_method_same_receiver() -> BenchmarkResult {
    let obj: &MultiMethod = &ImplA { value: 10 };

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        black_box(obj.method_a(5));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(obj.method_a(5));
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "multi_method_same_receiver",
        metric: "ns/call",
        value: per_call_ns,
        target: 10.0,
        passed: per_call_ns < 10.0,
    }
}

/// Calling different methods on same receiver
fn benchmark_multi_method_different_methods() -> BenchmarkResult {
    let obj: &MultiMethod = &ImplA { value: 10 };

    // Warmup
    for _ in 0..(WARMUP_ITERATIONS / 3) {
        black_box(obj.method_a(5));
        black_box(obj.method_b(5));
        black_box(obj.method_c(5));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..(BENCHMARK_ITERATIONS / 3) {
        black_box(obj.method_a(5));
        black_box(obj.method_b(5));
        black_box(obj.method_c(5));
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "multi_method_different",
        metric: "ns/call",
        value: per_call_ns,
        target: 12.0,
        passed: per_call_ns < 12.0,
    }
}

/// Compare static dispatch to virtual dispatch
fn benchmark_static_vs_virtual() -> BenchmarkResult {
    let concrete = ImplA { value: 10 };
    let dynamic: &Computable = &concrete;

    // Measure static dispatch
    let timer_static = Timer.new();
    timer_static.start();
    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(concrete.compute(5));
    }
    let static_ns = timer_static.elapsed_ns();

    // Measure virtual dispatch
    let timer_virtual = Timer.new();
    timer_virtual.start();
    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(dynamic.compute(5));
    }
    let virtual_ns = timer_virtual.elapsed_ns();

    let overhead_ns = (virtual_ns - static_ns) as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "static_vs_virtual_overhead",
        metric: "ns overhead",
        value: overhead_ns,
        target: 8.0,
        passed: overhead_ns < 8.0,
    }
}

/// Compare inlined call to virtual dispatch
fn benchmark_inline_vs_virtual() -> BenchmarkResult {
    @inline(always)
    fn inline_compute(value: Int, x: Int) -> Int {
        value + x
    }

    let value = 10;
    let dynamic: &Computable = &ImplA { value };

    // Measure inlined call
    let timer_inline = Timer.new();
    timer_inline.start();
    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(inline_compute(value, 5));
    }
    let inline_ns = timer_inline.elapsed_ns();

    // Measure virtual dispatch
    let timer_virtual = Timer.new();
    timer_virtual.start();
    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(dynamic.compute(5));
    }
    let virtual_ns = timer_virtual.elapsed_ns();

    let overhead_ns = (virtual_ns - inline_ns) as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "inline_vs_virtual_overhead",
        metric: "ns overhead",
        value: overhead_ns,
        target: 10.0,
        passed: overhead_ns < 10.0,
    }
}

/// Single protocol implementation
fn benchmark_single_protocol() -> BenchmarkResult {
    let obj: &Computable = &ImplA { value: 42 };

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(obj.compute(1));
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "single_protocol",
        metric: "ns/call",
        value: per_call_ns,
        target: 10.0,
        passed: per_call_ns < 10.0,
    }
}

/// Protocol inheritance chain
type BaseProtocol is protocol {
    fn base_method(&self) -> Int;
};

type DerivedProtocol is protocol extends BaseProtocol {
    fn derived_method(&self) -> Int;
};

type ChainImpl is { value: Int };

implement BaseProtocol for ChainImpl {
    fn base_method(&self) -> Int { self.value }
}

implement DerivedProtocol for ChainImpl {
    fn derived_method(&self) -> Int { self.value * 2 }
}

fn benchmark_protocol_chain() -> BenchmarkResult {
    let obj: &DerivedProtocol = &ChainImpl { value: 21 };

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        black_box(obj.base_method());
        black_box(obj.derived_method());
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..(BENCHMARK_ITERATIONS / 2) {
        black_box(obj.base_method());
        black_box(obj.derived_method());
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "protocol_chain",
        metric: "ns/call",
        value: per_call_ns,
        target: 12.0,
        passed: per_call_ns < 12.0,
    }
}

/// Iterator dispatch pattern
type Iterator is protocol {
    type Item;
    fn next(&mut self) -> Maybe<Self.Item>;
};

type RangeIterator is {
    current: Int,
    end: Int,
};

implement Iterator for RangeIterator {
    type Item is Int;

    fn next(&mut self) -> Maybe<Int> {
        if self.current < self.end {
            let val = self.current;
            self.current += 1;
            Some(val)
        } else {
            None
        }
    }
}

fn benchmark_iterator_dispatch() -> BenchmarkResult {
    let mut iter: &mut Iterator<Item = Int> = &mut RangeIterator {
        current: 0,
        end: BENCHMARK_ITERATIONS as Int,
    };

    let timer = Timer.new();
    timer.start();

    while let Some(val) = iter.next() {
        black_box(val);
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "iterator_dispatch",
        metric: "ns/call",
        value: per_call_ns,
        target: 15.0,
        passed: per_call_ns < 15.0,
    }
}

/// Visitor pattern dispatch
type Visitor is protocol {
    fn visit_a(&self, node: &NodeA) -> Int;
    fn visit_b(&self, node: &NodeB) -> Int;
};

type Node is protocol {
    fn accept(&self, visitor: &Visitor) -> Int;
};

type NodeA is { value: Int };
type NodeB is { value: Int };

implement Node for NodeA {
    fn accept(&self, visitor: &Visitor) -> Int {
        visitor.visit_a(self)
    }
}

implement Node for NodeB {
    fn accept(&self, visitor: &Visitor) -> Int {
        visitor.visit_b(self)
    }
}

type ConcreteVisitor is {};

implement Visitor for ConcreteVisitor {
    fn visit_a(&self, node: &NodeA) -> Int { node.value + 1 }
    fn visit_b(&self, node: &NodeB) -> Int { node.value * 2 }
}

fn benchmark_visitor_pattern() -> BenchmarkResult {
    let nodes: List<Heap<Node>> = [
        Heap(NodeA { value: 1 }),
        Heap(NodeB { value: 2 }),
    ];
    let visitor: &Visitor = &ConcreteVisitor {};

    // Warmup
    for _ in 0..(WARMUP_ITERATIONS / 2) {
        for node in nodes.iter() {
            black_box(node.accept(visitor));
        }
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..(BENCHMARK_ITERATIONS / 2) {
        for node in nodes.iter() {
            black_box(node.accept(visitor));
        }
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    // Visitor pattern has double dispatch
    BenchmarkResult {
        name: "visitor_pattern",
        metric: "ns/call",
        value: per_call_ns,
        target: 25.0,
        passed: per_call_ns < 25.0,
    }
}

// Benchmark infrastructure
type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(&self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results.iter() {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}

@extern("verum_bench")
fn black_box<T>(value: T) -> T;

type Timer is {
    start_time: u64,
};

implement Timer {
    fn new() -> Self {
        Self { start_time: 0 }
    }

    fn start(&mut self) {
        self.start_time = clock_ns();
    }

    fn elapsed_ns(&self) -> u64 {
        clock_ns() - self.start_time
    }
}

@extern("verum_time")
fn clock_ns() -> u64;

type Rng is {
    state: u64,
};

implement Rng {
    fn with_seed(seed: u64) -> Self {
        Self { state: seed }
    }

    fn next_int(&mut self) -> Int {
        self.state = self.state * 6364136223846793005 + 1442695040888963407;
        (self.state >> 32) as Int
    }
}
