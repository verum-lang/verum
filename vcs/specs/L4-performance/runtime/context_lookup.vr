/// Five context lookups
fn benchmark_five_context_lookup() -> BenchmarkResult {
    provide Cache = InMemoryCache {};
    provide Metrics = NoOpMetrics {};

    fn use_five_contexts() using [Logger, Database, Config, Cache, Metrics] {
        let _ = Logger;
        let _ = Database;
        let _ = Config;
        let _ = Cache;
        let _ = Metrics;
    }

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        use_five_contexts();
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        use_five_contexts();
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_lookup_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "five_context_lookup",
        metric: "ns/lookup",
        value: per_lookup_ns,
        target: 50.0,
        passed: per_lookup_ns < 50.0,
    }
}

/// Context propagation through function calls
fn benchmark_context_propagation() -> BenchmarkResult {
    fn level_3() using [Logger] {
        Logger.log("level 3");
    }

    fn level_2() using [Logger] {
        level_3();
    }

    fn level_1() using [Logger] {
        level_2();
    }

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        level_1();
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        level_1();
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_propagation_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    // 3 levels of propagation
    let per_level_ns = per_propagation_ns / 3.0;

    BenchmarkResult {
        name: "context_propagation",
        metric: "ns/level",
        value: per_level_ns,
        target: 10.0,
        passed: per_level_ns < 10.0,
    }
}

/// Nested context calls with different contexts
fn benchmark_nested_context_calls() -> BenchmarkResult {
    fn inner() using [Database] {
        let _ = Database;
    }

    fn outer() using [Logger] {
        Logger.log("before inner");
        inner();
        Logger.log("after inner");
    }

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        outer();
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        outer();
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "nested_context_calls",
        metric: "ns/call",
        value: per_call_ns,
        target: 40.0,
        passed: per_call_ns < 40.0,
    }
}

/// Context override in nested scope
fn benchmark_context_override() -> BenchmarkResult {
    fn use_logger() using [Logger] {
        Logger.log("message");
    }

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        provide Logger = ConsoleLogger { level: LogLevel.Debug };
        use_logger();
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        provide Logger = ConsoleLogger { level: LogLevel.Debug };
        use_logger();
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_override_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "context_override",
        metric: "ns/override",
        value: per_override_ns,
        target: 30.0,
        passed: per_override_ns < 30.0,
    }
}

/// Scoped context with cleanup
fn benchmark_scoped_context() -> BenchmarkResult {
    fn scoped_operation() {
        provide Logger = ConsoleLogger { level: LogLevel.Error };
        {
            provide Logger = ConsoleLogger { level: LogLevel.Debug };
            // Nested scope with different logger
            fn inner() using [Logger] {
                let _ = Logger.level();
            }
            inner();
        }
        // Original logger restored
    }

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        scoped_operation();
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        scoped_operation();
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_scope_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "scoped_context",
        metric: "ns/scope",
        value: per_scope_ns,
        target: 50.0,
        passed: per_scope_ns < 50.0,
    }
}

/// Service layer pattern (typical enterprise pattern)
fn benchmark_service_layer_pattern() -> BenchmarkResult {
    type UserService is {};

    implement UserService {
        fn get_user(id: Int) -> Maybe<User> using [Database, Logger, Cache] {
            Logger.log("Getting user {}", id);

            // Check cache first
            if let Some(user) = Cache.get.<User>("user:{}", id) {
                return Some(user);
            }

            // Query database
            let rows = Database.query("SELECT * FROM users WHERE id = ?");
            if rows.is_empty() {
                return None;
            }

            let user = User.from_row(&rows[0]);
            Cache.set("user:{}", id, user.clone());
            Some(user)
        }
    }

    type User is { id: Int, name: Text };

    implement User {
        fn from_row(row: &Row) -> Self {
            Self { id: 0, name: "test".to_text() }
        }
    }

    provide Cache = InMemoryCache {};

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        black_box(UserService.get_user(1));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(UserService.get_user(1));
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_call_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "service_layer_pattern",
        metric: "ns/call",
        value: per_call_ns,
        target: 60.0,
        passed: per_call_ns < 60.0,
    }
}

/// Middleware pattern (request processing chain)
fn benchmark_middleware_pattern() -> BenchmarkResult {
    type Request is { path: Text };
    type Response is { status: Int };

    fn handler(req: Request) -> Response using [Logger, Database] {
        Logger.log("Handling {}", req.path);
        Response { status: 200 }
    }

    fn logging_middleware(req: Request) -> Response using [Logger] {
        Logger.log("Request: {}", req.path);
        let response = handler(req);
        Logger.log("Response: {}", response.status);
        response
    }

    fn auth_middleware(req: Request) -> Response using [Logger, Database] {
        Logger.log("Auth check");
        logging_middleware(req)
    }

    let req = Request { path: "/test".to_text() };

    // Warmup
    for _ in 0..WARMUP_ITERATIONS {
        black_box(auth_middleware(req.clone()));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..BENCHMARK_ITERATIONS {
        black_box(auth_middleware(req.clone()));
    }

    let elapsed_ns = timer.elapsed_ns();
    let per_request_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

    BenchmarkResult {
        name: "middleware_pattern",
        metric: "ns/request",
        value: per_request_ns,
        target: 80.0,
        passed: per_request_ns < 80.0,
    }
}

// Mock implementations
type InMemoryCache is { data: Map<Text, Heap<Any>> };

implement Cache for InMemoryCache {
    fn get<T>(&self, key: Text) -> Maybe<T> {
        None
    }

    fn set<T>(&self, key: Text, value: T) {
        // No-op
    }
}

type NoOpMetrics is {};

implement Metrics for NoOpMetrics {
    fn counter(&self, name: Text) -> Counter {
        Counter { name }
    }

    fn gauge(&self, name: Text) -> Gauge {
        Gauge { name }
    }
}

// Benchmark infrastructure
type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(&self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results.iter() {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}

@extern("verum_bench")
fn black_box<T>(value: T) -> T;

type Timer is {
    start_time: u64,
};

implement Timer {
    fn new() -> Self {
        Self { start_time: 0 }
    }

    fn start(&mut self) {
        self.start_time = clock_ns();
    }

    fn elapsed_ns(&self) -> u64 {
        clock_ns() - self.start_time
    }
}

@extern("verum_time")
fn clock_ns() -> u64;
