// @test: parse
// @tier: all
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @tags: runtime, async, spawn, await, futures, overhead
// @description: Async runtime performance benchmark (target: < 100ns spawn overhead)

/// Async Runtime Performance Benchmark
///
/// This benchmark measures the overhead of async/await operations in Verum.
/// Efficient async is critical for I/O-bound and concurrent applications.
///
/// Targets:
/// - Spawn overhead: < 100ns
/// - Await overhead: < 50ns
/// - Future poll: < 20ns
/// - Channel send/recv: < 100ns
///
/// Async characteristics:
/// - Stackless coroutines (state machine transformation)
/// - Work-stealing scheduler
/// - Zero-allocation fast path
/// - Cooperative cancellation
///
/// Spec reference: docs/detailed/10-concurrency-model.md

const WARMUP_ITERATIONS: Int = 10_000;
const BENCHMARK_ITERATIONS: Int = 1_000_000;

fn main() {
    let results = BenchmarkResults.new("Async Runtime Performance");

    // Spawn benchmarks
    results.add(benchmark_spawn_overhead());
    results.add(benchmark_spawn_with_capture());
    results.add(benchmark_spawn_local());

    // Await benchmarks
    results.add(benchmark_await_ready());
    results.add(benchmark_await_pending());
    results.add(benchmark_nested_await());

    // Future operations
    results.add(benchmark_future_poll_ready());
    results.add(benchmark_future_combinators());

    // Channel operations
    results.add(benchmark_channel_unbounded());
    results.add(benchmark_channel_bounded());
    results.add(benchmark_channel_oneshot());

    // Synchronization
    results.add(benchmark_mutex_uncontended());
    results.add(benchmark_semaphore_acquire());

    // Complex patterns
    results.add(benchmark_select());
    results.add(benchmark_join_all());

    results.report();
    assert(results.all_pass(), "Async overhead exceeds target");
}

/// Benchmark: Basic spawn overhead
fn benchmark_spawn_overhead() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        // Warmup
        for _ in 0..WARMUP_ITERATIONS {
            spawn(async { }).await;
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            spawn(async { }).await;
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_spawn_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "spawn_overhead",
            metric: "ns/spawn",
            value: per_spawn_ns,
            target: 100.0,
            passed: per_spawn_ns < 100.0,
        }
    })
}

/// Benchmark: Spawn with captured variables
fn benchmark_spawn_with_capture() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        let captured = 42;
        let captured_text = Text.from("test");

        for _ in 0..WARMUP_ITERATIONS {
            let c = captured;
            let t = captured_text.clone();
            spawn(async move {
                black_box(c + t.len());
            }).await;
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            let c = captured;
            let t = captured_text.clone();
            spawn(async move {
                black_box(c + t.len());
            }).await;
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_spawn_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        // Capture adds some overhead
        BenchmarkResult {
            name: "spawn_with_capture",
            metric: "ns/spawn",
            value: per_spawn_ns,
            target: 150.0,
            passed: per_spawn_ns < 150.0,
        }
    })
}

/// Benchmark: Spawn local (same-thread execution)
fn benchmark_spawn_local() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        for _ in 0..WARMUP_ITERATIONS {
            spawn_local(async { }).await;
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            spawn_local(async { }).await;
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_spawn_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        // Local spawn should be faster (no cross-thread sync)
        BenchmarkResult {
            name: "spawn_local",
            metric: "ns/spawn",
            value: per_spawn_ns,
            target: 50.0,
            passed: per_spawn_ns < 50.0,
        }
    })
}

/// Benchmark: Await on ready future
fn benchmark_await_ready() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        for _ in 0..WARMUP_ITERATIONS {
            black_box(ready(42).await);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            black_box(ready(42).await);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_await_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        // Ready future should be near-zero cost
        BenchmarkResult {
            name: "await_ready",
            metric: "ns/await",
            value: per_await_ns,
            target: 10.0,
            passed: per_await_ns < 10.0,
        }
    })
}

/// Benchmark: Await on pending-then-ready future
fn benchmark_await_pending() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        for _ in 0..WARMUP_ITERATIONS {
            // Future that is pending once, then ready
            black_box(pending_once().await);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            black_box(pending_once().await);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_await_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "await_pending",
            metric: "ns/await",
            value: per_await_ns,
            target: 50.0,
            passed: per_await_ns < 50.0,
        }
    })
}

/// A future that returns Pending once, then Ready
async fn pending_once() -> Int {
    yield_now().await;
    42
}

/// Benchmark: Nested await calls
fn benchmark_nested_await() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        for _ in 0..WARMUP_ITERATIONS {
            black_box(nested_async(5).await);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..(BENCHMARK_ITERATIONS / 5) {
            black_box(nested_async(5).await);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_await_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "nested_await_5_deep",
            metric: "ns/await",
            value: per_await_ns,
            target: 30.0,
            passed: per_await_ns < 30.0,
        }
    })
}

async fn nested_async(depth: Int) -> Int {
    if depth > 0 {
        nested_async(depth - 1).await + 1
    } else {
        0
    }
}

/// Benchmark: Future poll on ready state
fn benchmark_future_poll_ready() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        let future = ready(42);
        let waker = noop_waker();
        let mut cx = Context.from_waker(&waker);

        for _ in 0..WARMUP_ITERATIONS {
            let mut fut = ready(42);
            black_box(Pin.new(&mut fut).poll(&mut cx));
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            let mut fut = ready(42);
            black_box(Pin.new(&mut fut).poll(&mut cx));
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_poll_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "future_poll_ready",
            metric: "ns/poll",
            value: per_poll_ns,
            target: 20.0,
            passed: per_poll_ns < 20.0,
        }
    })
}

/// Benchmark: Future combinators (map, then, etc.)
fn benchmark_future_combinators() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        for _ in 0..WARMUP_ITERATIONS {
            let result = ready(42)
                .map(|x| x + 1)
                .then(|x| ready(x * 2))
                .map(|x| x.to_string())
                .await;
            black_box(result);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            let result = ready(42)
                .map(|x| x + 1)
                .then(|x| ready(x * 2))
                .map(|x| x.to_string())
                .await;
            black_box(result);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_chain_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "future_combinators",
            metric: "ns/chain",
            value: per_chain_ns,
            target: 50.0,
            passed: per_chain_ns < 50.0,
        }
    })
}

/// Benchmark: Unbounded channel send/recv
fn benchmark_channel_unbounded() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        let (tx, rx) = channel.unbounded.<Int>();

        for _ in 0..WARMUP_ITERATIONS {
            tx.send(42).await;
            black_box(rx.recv().await);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            tx.send(42).await;
            black_box(rx.recv().await);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_op_ns = elapsed_ns as Float / (BENCHMARK_ITERATIONS as Float * 2.0);

        BenchmarkResult {
            name: "channel_unbounded",
            metric: "ns/op",
            value: per_op_ns,
            target: 100.0,
            passed: per_op_ns < 100.0,
        }
    })
}

/// Benchmark: Bounded channel send/recv
fn benchmark_channel_bounded() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        let (tx, rx) = channel.bounded.<Int>(1000);

        for _ in 0..WARMUP_ITERATIONS {
            tx.send(42).await;
            black_box(rx.recv().await);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            tx.send(42).await;
            black_box(rx.recv().await);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_op_ns = elapsed_ns as Float / (BENCHMARK_ITERATIONS as Float * 2.0);

        BenchmarkResult {
            name: "channel_bounded",
            metric: "ns/op",
            value: per_op_ns,
            target: 150.0,
            passed: per_op_ns < 150.0,
        }
    })
}

/// Benchmark: Oneshot channel
