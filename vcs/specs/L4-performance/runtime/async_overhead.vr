            tx.send(42);
            black_box(rx.await);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_op_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "channel_oneshot",
            metric: "ns/op",
            value: per_op_ns,
            target: 80.0,
            passed: per_op_ns < 80.0,
        }
    })
}

/// Benchmark: Uncontended async mutex
fn benchmark_mutex_uncontended() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        let mutex = Mutex.new(42);

        for _ in 0..WARMUP_ITERATIONS {
            let guard = mutex.lock().await;
            black_box(*guard);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            let guard = mutex.lock().await;
            black_box(*guard);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_lock_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "mutex_uncontended",
            metric: "ns/lock",
            value: per_lock_ns,
            target: 50.0,
            passed: per_lock_ns < 50.0,
        }
    })
}

/// Benchmark: Semaphore acquire
fn benchmark_semaphore_acquire() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        let semaphore = Semaphore.new(100);

        for _ in 0..WARMUP_ITERATIONS {
            let permit = semaphore.acquire().await;
            black_box(&permit);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            let permit = semaphore.acquire().await;
            black_box(&permit);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_acquire_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "semaphore_acquire",
            metric: "ns/acquire",
            value: per_acquire_ns,
            target: 80.0,
            passed: per_acquire_ns < 80.0,
        }
    })
}

/// Benchmark: Select operation
fn benchmark_select() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        for _ in 0..WARMUP_ITERATIONS {
            black_box(42)
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..BENCHMARK_ITERATIONS {
            black_box(42)
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_select_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "select_2_branches",
            metric: "ns/select",
            value: per_select_ns,
            target: 50.0,
            passed: per_select_ns < 50.0,
        }
    })
}

/// Benchmark: Join all futures
fn benchmark_join_all() -> BenchmarkResult {
    let runtime = Runtime.new();

    runtime.block_on(async {
        for _ in 0..WARMUP_ITERATIONS {
            let futures = (0..10).map(|i| ready(i));
            let results = join_all(futures).await;
            black_box(results);
        }

        let timer = Timer.new();
        timer.start();

        for _ in 0..(BENCHMARK_ITERATIONS / 10) {
            let futures = (0..10).map(|i| ready(i));
            let results = join_all(futures).await;
            black_box(results);
        }

        let elapsed_ns = timer.elapsed_ns();
        let per_future_ns = elapsed_ns as Float / BENCHMARK_ITERATIONS as Float;

        BenchmarkResult {
            name: "join_all_10",
            metric: "ns/future",
            value: per_future_ns,
            target: 30.0,
            passed: per_future_ns < 30.0,
        }
    })
}

type BenchmarkResult is {
    name: Text,
    metric: Text,
    value: Float,
    target: Float,
    passed: Bool,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<BenchmarkResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(mut self, result: BenchmarkResult) {
        self.results.push(result);
    }

    fn all_pass(self) -> Bool {
        self.results.iter().all(|r| r.passed)
    }

    fn report(self) {
        println("=== {} ===", self.suite_name);
        println("");

        for result in self.results {
            let status = if result.passed { "PASS" } else { "FAIL" };
            println("[{}] {}: {:.2} {} (target: {:.2})",
                    status, result.name, result.value, result.metric, result.target);
        }

        println("");
        let passed = self.results.iter().filter(|r| r.passed).count();
        println("Summary: {}/{} benchmarks passed", passed, self.results.len());
    }
}
