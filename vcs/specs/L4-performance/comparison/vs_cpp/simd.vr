/// Benchmark: Horizontal sum
fn benchmark_horizontal_sum() -> ComparisonResult {
    let a: List<f32> = (0..VECTOR_SIZE).map(|i| i as f32).collect();

    // Warmup
    for _ in 0..10 {
        black_box(simd.horizontal_sum(&a[0..10000]));
    }

    let timer = Timer.new();
    timer.start();

    let mut result: f32 = 0.0;
    for _ in 0..ITERATIONS {
        result = simd.horizontal_sum(&a);
    }

    let verum_ms = timer.elapsed_ms() as Float / ITERATIONS as Float;
    let cpp_ms = cpp_baselines.HSUM_10M_MS;

    black_box(result);

    ComparisonResult {
        name: "horizontal_sum_10m",
        verum_ms,
        baseline_ms: cpp_ms,
        ratio: cpp_ms / verum_ms,
        min_target: 0.90,
        category: "horizontal",
    }
}

/// Benchmark: Horizontal min
fn benchmark_horizontal_min() -> ComparisonResult {
    let mut rng = Random.with_seed(42);
    let a: List<f32> = (0..VECTOR_SIZE)
        .map(|_| rng.gen_range(0, 1_000_000) as f32)
        .collect();

    // Warmup
    for _ in 0..10 {
        black_box(simd.horizontal_min(&a[0..10000]));
    }

    let timer = Timer.new();
    timer.start();

    let mut result: f32 = f32.MAX;
    for _ in 0..ITERATIONS {
        result = simd.horizontal_min(&a);
    }

    let verum_ms = timer.elapsed_ms() as Float / ITERATIONS as Float;
    let cpp_ms = cpp_baselines.HMIN_10M_MS;

    black_box(result);

    ComparisonResult {
        name: "horizontal_min_10m",
        verum_ms,
        baseline_ms: cpp_ms,
        ratio: cpp_ms / verum_ms,
        min_target: 0.90,
        category: "horizontal",
    }
}

/// Benchmark: Dot product
fn benchmark_dot_product() -> ComparisonResult {
    let a: List<f32> = (0..VECTOR_SIZE).map(|i| (i % 100) as f32).collect();
    let b: List<f32> = (0..VECTOR_SIZE).map(|i| (i % 100) as f32).collect();

    // Warmup
    for _ in 0..10 {
        black_box(simd.dot_product(&a[0..10000], &b[0..10000]));
    }

    let timer = Timer.new();
    timer.start();

    let mut result: f32 = 0.0;
    for _ in 0..ITERATIONS {
        result = simd.dot_product(&a, &b);
    }

    let verum_ms = timer.elapsed_ms() as Float / ITERATIONS as Float;
    let cpp_ms = cpp_baselines.DOT_PRODUCT_10M_MS;

    black_box(result);

    ComparisonResult {
        name: "dot_product_10m",
        verum_ms,
        baseline_ms: cpp_ms,
        ratio: cpp_ms / verum_ms,
        min_target: 0.85,
        category: "complex",
    }
}

/// Benchmark: Matrix multiplication
fn benchmark_matrix_multiply() -> ComparisonResult {
    let a: List<List<f32>> = (0..MATRIX_SIZE)
        .map(|i| (0..MATRIX_SIZE).map(|j| ((i + j) % 100) as f32).collect())
        .collect();
    let b: List<List<f32>> = (0..MATRIX_SIZE)
        .map(|i| (0..MATRIX_SIZE).map(|j| ((i * j) % 100) as f32).collect())
        .collect();

    // Warmup with smaller matrix
    let small_a: List<List<f32>> = (0..100)
        .map(|i| (0..100).map(|j| ((i + j) % 100) as f32).collect())
        .collect();
    let small_b: List<List<f32>> = (0..100)
        .map(|i| (0..100).map(|j| ((i * j) % 100) as f32).collect())
        .collect();
    black_box(simd.matmul(&small_a, &small_b));

    let timer = Timer.new();
    timer.start();

    let result = simd.matmul(&a, &b);

    let verum_ms = timer.elapsed_ms() as Float;
    let cpp_ms = cpp_baselines.MATMUL_1000_MS;

    black_box(result);

    ComparisonResult {
        name: "matmul_1000x1000",
        verum_ms,
        baseline_ms: cpp_ms,
        ratio: cpp_ms / verum_ms,
        min_target: 0.85,
        category: "matrix",
    }
}

/// Benchmark: Fused multiply-add
fn benchmark_fused_multiply_add() -> ComparisonResult {
    let a: List<f32> = (0..VECTOR_SIZE).map(|i| i as f32).collect();
    let b: List<f32> = (0..VECTOR_SIZE).map(|i| (i * 2) as f32).collect();
    let c: List<f32> = (0..VECTOR_SIZE).map(|i| (i * 3) as f32).collect();
    let mut result: List<f32> = List.with_capacity(VECTOR_SIZE);
    result.resize(VECTOR_SIZE, 0.0);

    // Warmup
    for _ in 0..10 {
        simd.fma(&a[0..10000], &b[0..10000], &c[0..10000], &mut result[0..10000]);
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..ITERATIONS {
        simd.fma(&a, &b, &c, &mut result);
    }

    let verum_ms = timer.elapsed_ms() as Float / ITERATIONS as Float;
    let cpp_ms = cpp_baselines.FMA_10M_MS;

    black_box(&result);

    ComparisonResult {
        name: "fma_10m",
        verum_ms,
        baseline_ms: cpp_ms,
        ratio: cpp_ms / verum_ms,
        min_target: 0.90,
        category: "complex",
    }
}

