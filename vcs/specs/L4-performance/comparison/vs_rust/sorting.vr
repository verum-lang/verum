// @test: benchmark
// @tier: all
// @level: L4
// @baseline-comparison: rust
// @tags: comparison, rust, sorting, algorithm, baseline, performance
// @description: Sorting vs Rust benchmark (target: 0.85-1.0x Rust performance)

/// Verum vs Rust: Sorting Benchmark
///
/// This benchmark compares Verum's sorting performance against Rust.
/// Sorting is a fundamental operation that tests array access, comparisons,
/// and memory operations.
///
/// Target: 0.85-1.0x Rust performance
///
/// Test cases:
/// - Quicksort (manual implementation)
/// - Mergesort (manual implementation)
/// - Heapsort (manual implementation)
/// - Introsort (std library)
/// - Radix sort (specialized)
///
/// Input patterns tested:
/// - Random data
/// - Nearly sorted data
/// - Reverse sorted data
/// - Data with many duplicates
///
/// Spec reference: docs/detailed/26-cbgr-implementation.md

const DATA_SIZE: Int = 1_000_000;
const SMALL_SIZE: Int = 10_000;

/// Rust baseline measurements (pre-measured with release build)
module rust_baselines {
    /// Rust quicksort 1M random elements in milliseconds
    pub const QUICKSORT_1M_MS: Float = 100.0;

    /// Rust mergesort 1M random elements in milliseconds
    pub const MERGESORT_1M_MS: Float = 120.0;

    /// Rust heapsort 1M random elements in milliseconds
    pub const HEAPSORT_1M_MS: Float = 150.0;

    /// Rust std sort 1M random elements in milliseconds
    pub const STD_SORT_1M_MS: Float = 80.0;

    /// Rust radix sort 1M random u32 in milliseconds
    pub const RADIX_SORT_1M_MS: Float = 50.0;

    /// Rust std sort 1M nearly sorted in milliseconds
    pub const NEARLY_SORTED_1M_MS: Float = 30.0;

    /// Rust std sort 1M reverse sorted in milliseconds
    pub const REVERSE_SORTED_1M_MS: Float = 20.0;

    /// Rust std sort 1M duplicates in milliseconds
    pub const DUPLICATES_1M_MS: Float = 60.0;
}

fn main() {
    let results = BenchmarkResults.new("Verum vs Rust: Sorting");

    // Algorithm comparisons
    results.add(benchmark_quicksort());
    results.add(benchmark_mergesort());
    results.add(benchmark_heapsort());
    results.add(benchmark_std_sort());
    results.add(benchmark_radix_sort());

    // Input pattern comparisons
    results.add(benchmark_nearly_sorted());
    results.add(benchmark_reverse_sorted());
    results.add(benchmark_duplicates());

    results.report();
    results.export_comparison("/tmp/verum_vs_rust_sorting.json");

    let all_meet_target = results.results.iter()
        .all(|r| r.ratio >= r.min_target);
    assert(all_meet_target, "Verum sorting performance below target");
}

/// Generate random test data
fn generate_random_data(size: Int, seed: u64) -> List<Int> {
    let mut rng = Random.with_seed(seed);
    (0..size).map(|_| rng.gen_range(0, Int.MAX)).collect()
}

/// Generate nearly sorted data (1% out of place)
fn generate_nearly_sorted(size: Int) -> List<Int> {
    let mut data: List<Int> = (0..size).collect();
    let mut rng = Random.with_seed(42);

    for _ in 0..(size / 100) {
        let i = rng.gen_range(0, size);
        let j = rng.gen_range(0, size);
        data.swap(i, j);
    }

    data
}

/// Generate reverse sorted data
fn generate_reverse_sorted(size: Int) -> List<Int> {
    (0..size).rev().collect()
}

/// Generate data with many duplicates
fn generate_duplicates(size: Int) -> List<Int> {
    let mut rng = Random.with_seed(42);
    (0..size).map(|_| rng.gen_range(0, 100)).collect()
}

/// Quicksort implementation
fn quicksort<T: Ord>(arr: &mut [T]) {
    if arr.len() <= 1 { return; }

    let pivot_idx = partition(arr);

    let (left, right) = arr.split_at_mut(pivot_idx);
    quicksort(left);
    if right.len() > 1 {
        quicksort(&mut right[1..]);
    }
}

fn partition<T: Ord>(arr: &mut [T]) -> Int {
    let len = arr.len();
    let pivot_idx = len - 1;
    let mut i = 0;

    for j in 0..pivot_idx {
        if arr[j] < arr[pivot_idx] {
            arr.swap(i, j);
            i += 1;
        }
    }
    arr.swap(i, pivot_idx);
    i
}

/// Benchmark: Quicksort 1M elements
fn benchmark_quicksort() -> ComparisonResult {
    let original = generate_random_data(DATA_SIZE, 42);

    // Warmup
    for _ in 0..3 {
        let mut data = original[0..SMALL_SIZE].to_vec();
        quicksort(&mut data);
        black_box(data);
    }

    let mut data = original.clone();

    let timer = Timer.new();
    timer.start();

    quicksort(&mut data);

    let verum_ms = timer.elapsed_ms() as Float;
    let rust_ms = rust_baselines.QUICKSORT_1M_MS;

    black_box(data);

    ComparisonResult {
        name: "quicksort_1m_random",
        verum_ms,
        baseline_ms: rust_ms,
        ratio: rust_ms / verum_ms,
        min_target: 0.85,
        category: "algorithm",
    }
}

/// Mergesort implementation
fn mergesort<T: Ord + Clone>(arr: &mut [T]) {
    let len = arr.len();
    if len <= 1 { return; }

    let mid = len / 2;
    mergesort(&mut arr[0..mid]);
    mergesort(&mut arr[mid..]);

    let left: List<T> = arr[0..mid].to_vec();
    let right: List<T> = arr[mid..].to_vec();

    merge(arr, &left, &right);
}

fn merge<T: Ord + Clone>(arr: &mut [T], left: &[T], right: &[T]) {
    let mut i = 0;
    let mut j = 0;
    let mut k = 0;

    while i < left.len() && j < right.len() {
        if left[i] <= right[j] {
            arr[k] = left[i].clone();
            i += 1;
        } else {
            arr[k] = right[j].clone();
            j += 1;
        }
        k += 1;
    }

    while i < left.len() {
        arr[k] = left[i].clone();
        i += 1;
        k += 1;
    }

    while j < right.len() {
        arr[k] = right[j].clone();
        j += 1;
        k += 1;
    }
}

/// Benchmark: Mergesort 1M elements
fn benchmark_mergesort() -> ComparisonResult {
    let original = generate_random_data(DATA_SIZE, 42);

    // Warmup
    for _ in 0..3 {
        let mut data = original[0..SMALL_SIZE].to_vec();
