/// Radix sort for integers
fn radix_sort(arr: &mut [u32]) {
    let max = arr.iter().max().copied().unwrap_or(0);
    let mut exp: u32 = 1;

    let mut output: List<u32> = List.with_capacity(arr.len());
    output.resize(arr.len(), 0);

    while max / exp > 0 {
        counting_sort(arr, &mut output, exp);
        exp *= 10;
    }
}

fn counting_sort(arr: &mut [u32], output: &mut [u32], exp: u32) {
    let mut count = [0u32; 10];

    for &val in arr.iter() {
        count[((val / exp) % 10) as usize] += 1;
    }

    for i in 1..10 {
        count[i] += count[i - 1];
    }

    for &val in arr.iter().rev() {
        let digit = ((val / exp) % 10) as usize;
        count[digit] -= 1;
        output[count[digit] as usize] = val;
    }

    arr.copy_from_slice(output);
}

/// Benchmark: Radix sort 1M elements
fn benchmark_radix_sort() -> ComparisonResult {
    let mut rng = Random.with_seed(42);
    let original: List<u32> = (0..DATA_SIZE)
        .map(|_| rng.gen_range(0, u32.MAX as Int) as u32)
        .collect();

    // Warmup
    for _ in 0..3 {
        let mut data = original[0..SMALL_SIZE].to_vec();
        radix_sort(&mut data);
        black_box(data);
    }

    let mut data = original.clone();

    let timer = Timer.new();
    timer.start();

    radix_sort(&mut data);

    let verum_ms = timer.elapsed_ms() as Float;
    let rust_ms = rust_baselines.RADIX_SORT_1M_MS;

    black_box(data);

    ComparisonResult {
        name: "radix_sort_1m_u32",
        verum_ms,
        baseline_ms: rust_ms,
        ratio: rust_ms / verum_ms,
        min_target: 0.85,
        category: "specialized",
    }
}

