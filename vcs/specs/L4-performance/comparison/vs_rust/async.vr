/// Benchmark: Semaphore acquire/release
async fn benchmark_semaphore() -> ComparisonResult {
    let semaphore = AsyncSemaphore.new(10);

    // Warmup
    for _ in 0..1000 {
        let permit = semaphore.acquire().await.unwrap();
        black_box(&permit);
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..TASK_COUNT {
        let permit = semaphore.acquire().await.unwrap();
        black_box(&permit);
