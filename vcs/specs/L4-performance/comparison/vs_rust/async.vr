// ============================================================================
// Concurrent Execution Benchmarks
// ============================================================================

/// Benchmark: Parallel compute tasks
async fn benchmark_parallel_compute() -> ComparisonResult {
    // Warmup
    for _ in 0..10 {
        let futures: List<_> = (0..100)
            .map(|i| spawn(async move { fib(20) + i }))
            .collect();
        for f in futures { black_box(f.await); }
    }

    let timer = Timer.new();
    timer.start();

    let futures: List<_> = (0..CONCURRENT_TASKS)
        .map(|i| spawn(async move { fib(25) + i }))
        .collect();

    let mut sum: Int = 0;
    for f in futures {
        sum += f.await;
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(sum);

    ComparisonResult {
        name: "parallel_compute_1k",
        verum_ms,
        baseline_ms: rust_baselines.PARALLEL_COMPUTE_1K_MS,
        ratio: rust_baselines.PARALLEL_COMPUTE_1K_MS / verum_ms,
        min_target: 0.85,
        category: "concurrent",
    }
}

/// Benchmark: Pipeline of async stages
async fn benchmark_pipeline() -> ComparisonResult {
    let (tx1, mut rx1) = mpsc.channel.<Int>(256);
    let (tx2, mut rx2) = mpsc.channel.<Int>(256);
    let (tx3, mut rx3) = mpsc.channel.<Int>(256);

    // Stage 1: Double
    let stage1 = spawn(async move {
        while let Some(v) = rx1.recv().await {
            tx2.send(v * 2).await.unwrap();
        }
    });

    // Stage 2: Add offset
    let stage2 = spawn(async move {
        while let Some(v) = rx2.recv().await {
            tx3.send(v + 10).await.unwrap();
        }
    });

    // Stage 3: Collect
    let stage3 = spawn(async move {
        let mut sum: Int = 0;
        while let Some(v) = rx3.recv().await {
            sum += v;
        }
        sum
    });

    // Warmup
    for i in 0..1000 {
        tx1.send(i).await.unwrap();
    }

    let timer = Timer.new();
    timer.start();

    for i in 0..TASK_COUNT {
        tx1.send(i).await.unwrap();
    }

    drop(tx1);

    stage1.await;
    drop(tx2);
    stage2.await;
    drop(tx3);
    let result = stage3.await;

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(result);

    ComparisonResult {
        name: "pipeline_100k",
        verum_ms,
        baseline_ms: rust_baselines.PIPELINE_100K_MS,
        ratio: rust_baselines.PIPELINE_100K_MS / verum_ms,
        min_target: 0.85,
        category: "concurrent",
    }
}

/// Benchmark: Fan-out and fan-in pattern
async fn benchmark_fan_out_in() -> ComparisonResult {
    let num_workers = 10;
    let items_per_worker = TASK_COUNT / num_workers;

    // Warmup
    let warmup_futures: List<_> = (0..10)
        .map(|_| spawn(async { fib(15) }))
        .collect();
    for f in warmup_futures { black_box(f.await); }

    let timer = Timer.new();
    timer.start();

    // Fan out to workers
    let worker_futures: List<_> = (0..num_workers)
        .map(|worker_id| {
            let start = worker_id * items_per_worker;
            spawn(async move {
                let mut sum: Int = 0;
                for i in start..(start + items_per_worker) {
                    sum += i * 2;
                }
                sum
            })
        })
        .collect();

    // Fan in results
    let mut total: Int = 0;
    for f in worker_futures {
        total += f.await;
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(total);

    ComparisonResult {
        name: "fan_out_in_10k",
        verum_ms,
        baseline_ms: rust_baselines.FAN_OUT_IN_10K_MS,
        ratio: rust_baselines.FAN_OUT_IN_10K_MS / verum_ms,
        min_target: 0.85,
        category: "concurrent",
    }
}

/// Simple fibonacci for compute workload
fn fib(n: Int) -> Int {
    if n <= 1 { n }
    else { fib(n - 1) + fib(n - 2) }
}

type ComparisonResult is {
    name: Text,
    verum_ms: Float,
    baseline_ms: Float,
    ratio: Float,
    min_target: Float,
    category: Text,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<ComparisonResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: ComparisonResult) {
        self.results.push(result);
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");
        println("{:<30} {:>12} {:>12} {:>10} {:>8} {:>8}",
                "Benchmark", "Verum (ms)", "Rust (ms)", "Ratio", "Target", "Status");
        println("{}", "-".repeat(85));

        for result in &self.results {
            let passed = result.ratio >= result.min_target;
            let status = if passed { "PASS" } else { "FAIL" };
            let ratio_pct = result.ratio * 100.0;

            println("{:<30} {:>12.2} {:>12.2} {:>9.1}% {:>7.0}% {:>8}",
                    result.name, result.verum_ms, result.baseline_ms,
                    ratio_pct, result.min_target * 100.0, status);
        }
    }

    fn export_comparison(&self, path: Text) {
        let json = Json.object();
        json.set("suite", &self.suite_name);
        json.set("baseline", "rust");

        let results_json = Json.array();
        for result in &self.results {
            let r = Json.object();
            r.set("name", &result.name);
            r.set("verum_ms", result.verum_ms);
            r.set("baseline_ms", result.baseline_ms);
            r.set("ratio", result.ratio);
            r.set("min_target", result.min_target);
            r.set("category", &result.category);
            r.set("passed", result.ratio >= result.min_target);
            results_json.push(r);
        }
        json.set("results", results_json);

        File.write(path, json.to_string_pretty());
    }
}

fn black_box<T>(x: T) -> T { x }

// Async runtime stubs
async fn spawn<F, T>(f: F) -> JoinHandle<T>
where F: Future<Output = T> + Send + 'static, T: Send + 'static {
    JoinHandle { value: None }
}

async fn spawn_local<F, T>(f: F) -> JoinHandle<T>
where F: Future<Output = T> + 'static {
    JoinHandle { value: None }
}

async fn yield_now() {}

async fn join_all<I, F>(futures: I) -> List<F.Output>
where I: IntoIterator<Item = F>, F: Future {
    List.new()
}

type JoinHandle<T> is { value: Maybe<T> };
implement<T> JoinHandle<T> {
    async fn await(self) -> T { self.value.unwrap() }
}

module mpsc {
    pub fn channel<T>(capacity: Int) -> (Sender<T>, Receiver<T>) {
        (Sender { _phantom: () }, Receiver { _phantom: () })
    }

    pub type Sender<T> is { _phantom: () };
    implement<T> Sender<T> {
        pub async fn send(&self, value: T) -> Result<(), ()> { Ok(()) }
    }

    pub type Receiver<T> is { _phantom: () };
    implement<T> Receiver<T> {
        pub async fn recv(&mut self) -> Maybe<T> { None }
    }
}

module broadcast {
    pub fn channel<T>(capacity: Int) -> (Sender<T>, Receiver<T>) {
        (Sender { _phantom: () }, Receiver { _phantom: () })
    }

    pub type Sender<T> is { _phantom: () };
    implement<T> Sender<T> {
        pub fn send(&self, value: T) -> Result<(), ()> { Ok(()) }
        pub fn subscribe(&self) -> Receiver<T> { Receiver { _phantom: () } }
    }

    pub type Receiver<T> is { _phantom: () };
    implement<T> Receiver<T> {
        pub async fn recv(&mut self) -> Result<T, ()> { Err(()) }
    }
}

module oneshot {
    pub fn channel<T>() -> (Sender<T>, Receiver<T>) {
        (Sender { _phantom: () }, Receiver { _phantom: () })
    }

    pub type Sender<T> is { _phantom: () };
    implement<T> Sender<T> {
        pub fn send(self, value: T) -> Result<(), ()> { Ok(()) }
    }

    pub type Receiver<T> is { _phantom: () };
    implement<T> Receiver<T> {
        pub async fn await(self) -> T { panic("stub") }
    }
}

type AsyncMutex<T> is { value: T };
implement<T> AsyncMutex<T> {
    fn new(value: T) -> Self { Self { value } }
    async fn lock(&self) -> MutexGuard<T> { MutexGuard { _phantom: () } }
}

type MutexGuard<'a, T> is { _phantom: () };

type AsyncRwLock<T> is { value: T };
implement<T> AsyncRwLock<T> {
    fn new(value: T) -> Self { Self { value } }
    async fn read(&self) -> RwLockReadGuard<T> { RwLockReadGuard { _phantom: () } }
    async fn write(&self) -> RwLockWriteGuard<T> { RwLockWriteGuard { _phantom: () } }
}

type RwLockReadGuard<'a, T> is { _phantom: () };
type RwLockWriteGuard<'a, T> is { _phantom: () };

type AsyncSemaphore is { permits: Int };
implement AsyncSemaphore {
    fn new(permits: Int) -> Self { Self { permits } }
    async fn acquire(&self) -> Result<SemaphorePermit, ()> { Ok(SemaphorePermit { _phantom: () }) }
}

type SemaphorePermit is { _phantom: () };

type Timer is { start_time: Instant };
implement Timer {
    fn new() -> Self { Self { start_time: Instant.now() } }
    fn start(&mut self) { self.start_time = Instant.now(); }
    fn elapsed_ms(&self) -> Int { self.start_time.elapsed().as_millis() }
}

type Instant is { nanos: Int };
implement Instant {
    fn now() -> Self { Self { nanos: 0 } }
    fn elapsed(&self) -> Duration { Duration { nanos: 0 } }
}

type Duration is { nanos: Int };
implement Duration {
    fn as_millis(&self) -> Int { self.nanos / 1_000_000 }
}

type Json is { data: Map<Text, Heap<Any>> };
implement Json {
    fn object() -> Self { Self { data: Map.new() } }
    fn array() -> Self { Self { data: Map.new() } }
    fn set<T>(&mut self, key: &Text, value: T) {}
    fn push<T>(&mut self, value: T) {}
    fn to_string_pretty(&self) -> Text { Text.new() }
}

module File {
    pub fn write(path: Text, content: Text) {}
}
