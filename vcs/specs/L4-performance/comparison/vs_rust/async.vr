    }
}

/// Benchmark: Yield to scheduler
async fn benchmark_yield_now() -> ComparisonResult {
    // Warmup
    for _ in 0..1000 {
        yield_now().await;
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..TASK_COUNT {
        yield_now().await;
    }

    let verum_ms = timer.elapsed_ms() as Float;

    ComparisonResult {
        name: "yield_100k",
        verum_ms,
        baseline_ms: rust_baselines.YIELD_100K_MS,
        ratio: rust_baselines.YIELD_100K_MS / verum_ms,
        min_target: 0.85,
        category: "spawn",
    }
}

/// Benchmark: Join all tasks
async fn benchmark_join_all() -> ComparisonResult {
    // Warmup
    for _ in 0..10 {
        let futures: List<_> = (0..100).map(|i| async move { i * 2 }).collect();
        black_box(join_all(futures).await);
    }

    let timer = Timer.new();
    timer.start();

    let futures: List<_> = (0..CONCURRENT_TASKS)
        .map(|i| async move { fib(20) + i })
        .collect();

    let results = join_all(futures).await;

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(results);

    ComparisonResult {
        name: "join_all_1k",
        verum_ms,
        baseline_ms: rust_baselines.JOIN_ALL_1K_MS,
        ratio: rust_baselines.JOIN_ALL_1K_MS / verum_ms,
        min_target: 0.85,
        category: "spawn",
    }
}

// ============================================================================
// Channel Benchmarks
// ============================================================================

/// Benchmark: MPSC channel send
async fn benchmark_mpsc_send() -> ComparisonResult {
    let (tx, mut rx) = mpsc.channel.<Int>(1024);

    // Spawn receiver
    let receiver = spawn(async move {
        let mut count = 0;
        while let Some(_) = rx.recv().await {
            count += 1;
        }
        count
    });

    // Warmup
    for i in 0..10000 {
        tx.send(i).await.unwrap();
    }

    let timer = Timer.new();
    timer.start();

    for i in 0..CHANNEL_OPS {
        tx.send(i).await.unwrap();
    }

    drop(tx);
    let count = receiver.await;

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(count);

    ComparisonResult {
        name: "mpsc_send_1m",
        verum_ms,
        baseline_ms: rust_baselines.MPSC_SEND_1M_MS,
        ratio: rust_baselines.MPSC_SEND_1M_MS / verum_ms,
        min_target: 0.85,
        category: "channel",
    }
}

/// Benchmark: MPSC channel receive
async fn benchmark_mpsc_recv() -> ComparisonResult {
    let (tx, mut rx) = mpsc.channel.<Int>(1024);

    // Pre-fill channel
    let sender = spawn(async move {
        for i in 0..CHANNEL_OPS {
            tx.send(i).await.unwrap();
        }
    });

    // Warmup - wait for some messages
    yield_now().await;

    let timer = Timer.new();
    timer.start();

    let mut count: Int = 0;
    while let Some(v) = rx.recv().await {
        count += 1;
        black_box(v);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    sender.await;

    ComparisonResult {
        name: "mpsc_recv_1m",
        verum_ms,
        baseline_ms: rust_baselines.MPSC_RECV_1M_MS,
        ratio: rust_baselines.MPSC_RECV_1M_MS / verum_ms,
        min_target: 0.85,
        category: "channel",
    }
}

/// Benchmark: Broadcast channel
async fn benchmark_broadcast() -> ComparisonResult {
    let (tx, _) = broadcast.channel.<Int>(1024);

    // Create multiple receivers
    let mut receivers: List<_> = (0..10)
        .map(|_| tx.subscribe())
        .collect();

    // Spawn receiver tasks
    let receiver_handles: List<_> = receivers.into_iter()
        .map(|mut rx| spawn(async move {
            let mut count = 0;
            while let Ok(_) = rx.recv().await {
                count += 1;
            }
            count
        }))
        .collect();

    // Warmup
    for i in 0..1000 {
        let _ = tx.send(i);
    }

    let timer = Timer.new();
    timer.start();

    for i in 0..(TASK_COUNT / 10) {
        let _ = tx.send(i);
    }

    drop(tx);

    for handle in receiver_handles {
        black_box(handle.await);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    ComparisonResult {
        name: "broadcast_100k",
        verum_ms,
        baseline_ms: rust_baselines.BROADCAST_SEND_100K_MS,
        ratio: rust_baselines.BROADCAST_SEND_100K_MS / verum_ms,
        min_target: 0.85,
        category: "channel",
    }
}

/// Benchmark: Oneshot channel
async fn benchmark_oneshot() -> ComparisonResult {
    // Warmup
    for _ in 0..1000 {
        let (tx, rx) = oneshot.channel.<Int>();
        tx.send(42).unwrap();
        black_box(rx.await);
    }

    let timer = Timer.new();
    timer.start();

    for i in 0..TASK_COUNT {
        let (tx, rx) = oneshot.channel.<Int>();
        tx.send(i).unwrap();
        black_box(rx.await);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    ComparisonResult {
        name: "oneshot_100k",
        verum_ms,
        baseline_ms: rust_baselines.ONESHOT_100K_MS,
        ratio: rust_baselines.ONESHOT_100K_MS / verum_ms,
        min_target: 0.85,
        category: "channel",
    }
}

