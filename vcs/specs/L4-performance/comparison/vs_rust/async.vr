/// Benchmark: Async mutex lock/unlock
async fn benchmark_async_mutex() -> ComparisonResult {
    let mutex = AsyncMutex.new(0);

    // Warmup
    for _ in 0..1000 {
        let mut guard = mutex.lock().await;
        *guard += 1;
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..TASK_COUNT {
        let mut guard = mutex.lock().await;
        *guard += 1;
    }

    let verum_ms = timer.elapsed_ms() as Float;

    ComparisonResult {
        name: "async_mutex_100k",
        verum_ms,
        baseline_ms: rust_baselines.MUTEX_LOCK_100K_MS,
        ratio: rust_baselines.MUTEX_LOCK_100K_MS / verum_ms,
        min_target: 0.85,
        category: "sync",
    }
}

