/// Benchmark: Join strings
fn benchmark_join() -> ComparisonResult {
    let parts: List<Text> = (0..100).map(|i| i.to_string()).collect();

    // Warmup
    for _ in 0..1000 {
        black_box(parts.join(","));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..ITERATIONS {
        black_box(parts.join(","));
    }

    let verum_ms = timer.elapsed_ms() as Float;

    ComparisonResult {
        name: "join_100k",
        verum_ms,
        baseline_ms: rust_baselines.JOIN_100K_MS,
        ratio: rust_baselines.JOIN_100K_MS / verum_ms,
        min_target: 0.85,
        category: "misc",
