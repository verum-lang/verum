// @test: parse
// @tier: all
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @baseline-comparison: rust
// @tags: comparison, rust, collections, data-structures, baseline, performance
// @description: Collections vs Rust benchmark (target: 0.85-1.0x Rust performance)

/// Verum vs Rust: Collections Benchmark
///
/// This benchmark compares Verum's collection operations against Rust.
/// Collections are fundamental data structures that test memory layout,
/// cache efficiency, and CBGR overhead.
///
/// Target: 0.85-1.0x Rust performance
///
/// Collections tested:
/// - List (Vec equivalent)
/// - Map (HashMap equivalent)
/// - Set (HashSet equivalent)
/// - Heap (BinaryHeap equivalent)
///
/// Operations tested:
/// - Insert/Push
/// - Lookup/Get
/// - Remove
/// - Iteration
/// - Bulk operations
///
/// Spec reference: docs/detailed/26-cbgr-implementation.md

const DATA_SIZE: Int = 1_000_000;
const SMALL_SIZE: Int = 10_000;
const LOOKUP_COUNT: Int = 1_000_000;

/// Rust baseline measurements
module rust_baselines {
    // List/Vec operations
    pub const VEC_PUSH_1M_MS: Float = 15.0;
    pub const VEC_PUSH_WITH_CAP_1M_MS: Float = 8.0;
    pub const VEC_POP_1M_MS: Float = 5.0;
    pub const VEC_INSERT_FRONT_10K_MS: Float = 200.0;
    pub const VEC_RANDOM_ACCESS_1M_MS: Float = 5.0;
    pub const VEC_ITER_SUM_1M_MS: Float = 2.0;
    pub const VEC_CLONE_1M_MS: Float = 10.0;

    // Map/HashMap operations
    pub const MAP_INSERT_1M_MS: Float = 200.0;
    pub const MAP_GET_1M_MS: Float = 50.0;
    pub const MAP_REMOVE_1M_MS: Float = 60.0;
    pub const MAP_ITER_1M_MS: Float = 30.0;
    pub const MAP_CONTAINS_1M_MS: Float = 45.0;

    // Set/HashSet operations
    pub const SET_INSERT_1M_MS: Float = 180.0;
    pub const SET_CONTAINS_1M_MS: Float = 40.0;
    pub const SET_UNION_500K_MS: Float = 100.0;
    pub const SET_INTERSECTION_500K_MS: Float = 80.0;

    // Heap/BinaryHeap operations
    pub const HEAP_PUSH_1M_MS: Float = 50.0;
    pub const HEAP_POP_1M_MS: Float = 80.0;
    pub const HEAP_PEEK_1M_MS: Float = 2.0;
}

fn main() {
    let results = BenchmarkResults.new("Verum vs Rust: Collections");

    // List benchmarks
    results.add(benchmark_list_push());
    results.add(benchmark_list_push_with_capacity());
    results.add(benchmark_list_pop());
    results.add(benchmark_list_insert_front());
    results.add(benchmark_list_random_access());
    results.add(benchmark_list_iteration());
    results.add(benchmark_list_clone());

    // Map benchmarks
    results.add(benchmark_map_insert());
    results.add(benchmark_map_get());
    results.add(benchmark_map_remove());
    results.add(benchmark_map_iteration());
    results.add(benchmark_map_contains());

    // Set benchmarks
    results.add(benchmark_set_insert());
    results.add(benchmark_set_contains());
    results.add(benchmark_set_union());
    results.add(benchmark_set_intersection());

    // Heap benchmarks
    results.add(benchmark_heap_push());
    results.add(benchmark_heap_pop());
    results.add(benchmark_heap_peek());

    results.report();
    results.export_comparison("/tmp/verum_vs_rust_collections.json");

    let all_meet_target = results.results.iter()
        .all(|r| r.ratio >= r.min_target);
    assert(all_meet_target, "Verum collection performance below target");
}

// ============================================================================
// List Benchmarks
// ============================================================================

/// Benchmark: List push 1M elements
fn benchmark_list_push() -> ComparisonResult {
    // Warmup
    for _ in 0..3 {
        let mut list: List<Int> = List.new();
        for i in 0..SMALL_SIZE {
            list.push(i);
        }
        black_box(list);
    }

    let mut list: List<Int> = List.new();

    let timer = Timer.new();
    timer.start();

    for i in 0..DATA_SIZE {
        list.push(i);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(list);

    ComparisonResult {
        name: "list_push_1m",
        verum_ms,
        baseline_ms: rust_baselines.VEC_PUSH_1M_MS,
        ratio: rust_baselines.VEC_PUSH_1M_MS / verum_ms,
        min_target: 0.85,
        category: "list",
    }
}

/// Benchmark: List push with pre-allocated capacity
fn benchmark_list_push_with_capacity() -> ComparisonResult {
    // Warmup
    for _ in 0..3 {
        let mut list: List<Int> = List.with_capacity(SMALL_SIZE);
        for i in 0..SMALL_SIZE {
            list.push(i);
        }
        black_box(list);
    }

    let mut list: List<Int> = List.with_capacity(DATA_SIZE);

    let timer = Timer.new();
    timer.start();

    for i in 0..DATA_SIZE {
        list.push(i);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(list);

    ComparisonResult {
        name: "list_push_with_cap_1m",
        verum_ms,
        baseline_ms: rust_baselines.VEC_PUSH_WITH_CAP_1M_MS,
        ratio: rust_baselines.VEC_PUSH_WITH_CAP_1M_MS / verum_ms,
        min_target: 0.90,
        category: "list",
    }
}

/// Benchmark: List pop 1M elements
fn benchmark_list_pop() -> ComparisonResult {
    // Warmup
    for _ in 0..3 {
        let mut list: List<Int> = (0..SMALL_SIZE).collect();
        while list.pop().is_some() {}
        black_box(list);
    }

    let mut list: List<Int> = (0..DATA_SIZE).collect();

    let timer = Timer.new();
    timer.start();

    while list.pop().is_some() {}

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(list);

    ComparisonResult {
        name: "list_pop_1m",
        verum_ms,
        baseline_ms: rust_baselines.VEC_POP_1M_MS,
        ratio: rust_baselines.VEC_POP_1M_MS / verum_ms,
        min_target: 0.90,
        category: "list",
    }
}

/// Benchmark: List insert at front (expensive)
fn benchmark_list_insert_front() -> ComparisonResult {
    // Warmup
    for _ in 0..3 {
        let mut list: List<Int> = List.new();
        for i in 0..100 {
            list.insert(0, i);
        }
        black_box(list);
    }

    let mut list: List<Int> = List.new();

    let timer = Timer.new();
    timer.start();

    for i in 0..SMALL_SIZE {
        list.insert(0, i);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(list);

    ComparisonResult {
        name: "list_insert_front_10k",
        verum_ms,
        baseline_ms: rust_baselines.VEC_INSERT_FRONT_10K_MS,
        ratio: rust_baselines.VEC_INSERT_FRONT_10K_MS / verum_ms,
        min_target: 0.85,
        category: "list",
    }
}

/// Benchmark: List random access
fn benchmark_list_random_access() -> ComparisonResult {
    let list: List<Int> = (0..DATA_SIZE).collect();
    let mut rng = Random.with_seed(42);
    let indices: List<Int> = (0..LOOKUP_COUNT)
        .map(|_| rng.gen_range(0, DATA_SIZE))
        .collect();

    // Warmup
    for i in 0..SMALL_SIZE {
        black_box(list[indices[i]]);
    }

    let timer = Timer.new();
    timer.start();

    let mut sum: Int = 0;
    for i in 0..LOOKUP_COUNT {
        sum += list[indices[i]];
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(sum);

    ComparisonResult {
        name: "list_random_access_1m",
        verum_ms,
        baseline_ms: rust_baselines.VEC_RANDOM_ACCESS_1M_MS,
        ratio: rust_baselines.VEC_RANDOM_ACCESS_1M_MS / verum_ms,
        min_target: 0.85,
        category: "list",
    }
}

/// Benchmark: List iteration
fn benchmark_list_iteration() -> ComparisonResult {
    let list: List<Int> = (0..DATA_SIZE).collect();

    // Warmup
    black_box(list.iter().take(SMALL_SIZE).sum.<Int>());

    let timer = Timer.new();
    timer.start();

    let sum: Int = list.iter().sum();

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(sum);

    ComparisonResult {
        name: "list_iter_sum_1m",
        verum_ms,
        baseline_ms: rust_baselines.VEC_ITER_SUM_1M_MS,
        ratio: rust_baselines.VEC_ITER_SUM_1M_MS / verum_ms,
        min_target: 0.90,
        category: "list",
    }
}

/// Benchmark: List clone
fn benchmark_list_clone() -> ComparisonResult {
    let list: List<Int> = (0..DATA_SIZE).collect();

    // Warmup
    for _ in 0..3 {
        let small: List<Int> = (0..SMALL_SIZE).collect();
        black_box(small.clone());
    }

    let timer = Timer.new();
    timer.start();

    let cloned = list.clone();

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(cloned);

    ComparisonResult {
        name: "list_clone_1m",
        verum_ms,
        baseline_ms: rust_baselines.VEC_CLONE_1M_MS,
        ratio: rust_baselines.VEC_CLONE_1M_MS / verum_ms,
        min_target: 0.90,
        category: "list",
    }
}

