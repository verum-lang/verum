        ratio: rust_baselines.SET_CONTAINS_1M_MS / verum_ms,
        min_target: 0.85,
        category: "set",
    }
}

/// Benchmark: Set union
fn benchmark_set_union() -> ComparisonResult {
    let half = DATA_SIZE / 2;

    let set_a: Set<Int> = (0..half).collect();
    let set_b: Set<Int> = (half/2..half + half/2).collect();

    // Warmup
    let small_a: Set<Int> = (0..1000).collect();
    let small_b: Set<Int> = (500..1500).collect();
    black_box(small_a.union(&small_b).count());

    let timer = Timer.new();
    timer.start();

    let union: Set<Int> = set_a.union(&set_b).cloned().collect();

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(union);

    ComparisonResult {
        name: "set_union_500k",
        verum_ms,
        baseline_ms: rust_baselines.SET_UNION_500K_MS,
        ratio: rust_baselines.SET_UNION_500K_MS / verum_ms,
        min_target: 0.85,
        category: "set",
    }
}

