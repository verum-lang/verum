/// Benchmark: Map insert 1M elements
fn benchmark_map_insert() -> ComparisonResult {
    // Warmup
    for _ in 0..3 {
        let mut map: Map<Int, Int> = Map.new();
        for i in 0..SMALL_SIZE {
            map.insert(i, i * 2);
        }
        black_box(map);
    }

    let mut map: Map<Int, Int> = Map.new();

    let timer = Timer.new();
    timer.start();

    for i in 0..DATA_SIZE {
        map.insert(i, i * 2);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(map);

    ComparisonResult {
        name: "map_insert_1m",
        verum_ms,
        baseline_ms: rust_baselines.MAP_INSERT_1M_MS,
        ratio: rust_baselines.MAP_INSERT_1M_MS / verum_ms,
        min_target: 0.85,
        category: "map",
    }
}

/// Benchmark: Map get 1M lookups
fn benchmark_map_get() -> ComparisonResult {
    let mut map: Map<Int, Int> = Map.new();
    for i in 0..DATA_SIZE {
        map.insert(i, i * 2);
    }

    let mut rng = Random.with_seed(42);
    let keys: List<Int> = (0..LOOKUP_COUNT)
        .map(|_| rng.gen_range(0, DATA_SIZE))
        .collect();

    // Warmup
    for i in 0..SMALL_SIZE {
        black_box(map.get(&keys[i]));
    }

    let timer = Timer.new();
    timer.start();

    let mut sum: Int = 0;
    for i in 0..LOOKUP_COUNT {
        if let Some(&v) = map.get(&keys[i]) {
            sum += v;
        }
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(sum);

    ComparisonResult {
        name: "map_get_1m",
        verum_ms,
        baseline_ms: rust_baselines.MAP_GET_1M_MS,
        ratio: rust_baselines.MAP_GET_1M_MS / verum_ms,
        min_target: 0.85,
        category: "map",
    }
}

/// Benchmark: Map remove 1M elements
fn benchmark_map_remove() -> ComparisonResult {
    // Warmup
    for _ in 0..3 {
        let mut map: Map<Int, Int> = Map.new();
        for i in 0..SMALL_SIZE {
            map.insert(i, i * 2);
        }
        for i in 0..SMALL_SIZE {
            map.remove(&i);
        }
        black_box(map);
    }

    let mut map: Map<Int, Int> = Map.new();
    for i in 0..DATA_SIZE {
        map.insert(i, i * 2);
    }

    let timer = Timer.new();
    timer.start();

    for i in 0..DATA_SIZE {
        map.remove(&i);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(map);

    ComparisonResult {
        name: "map_remove_1m",
        verum_ms,
        baseline_ms: rust_baselines.MAP_REMOVE_1M_MS,
        ratio: rust_baselines.MAP_REMOVE_1M_MS / verum_ms,
        min_target: 0.85,
        category: "map",
    }
}

/// Benchmark: Map iteration
fn benchmark_map_iteration() -> ComparisonResult {
    let mut map: Map<Int, Int> = Map.new();
    for i in 0..DATA_SIZE {
        map.insert(i, i * 2);
    }

    // Warmup
    let mut small_map: Map<Int, Int> = Map.new();
    for i in 0..SMALL_SIZE {
        small_map.insert(i, i * 2);
    }
    black_box(small_map.iter().map(|(k, v)| k + v).sum.<Int>());

    let timer = Timer.new();
    timer.start();

    let sum: Int = map.iter().map(|(k, v)| k + v).sum();

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(sum);

    ComparisonResult {
        name: "map_iter_1m",
        verum_ms,
        baseline_ms: rust_baselines.MAP_ITER_1M_MS,
        ratio: rust_baselines.MAP_ITER_1M_MS / verum_ms,
        min_target: 0.85,
        category: "map",
    }
}

/// Benchmark: Map contains_key
fn benchmark_map_contains() -> ComparisonResult {
    let mut map: Map<Int, Int> = Map.new();
    for i in 0..DATA_SIZE {
        map.insert(i, i * 2);
    }

    let mut rng = Random.with_seed(42);
    let keys: List<Int> = (0..LOOKUP_COUNT)
        .map(|_| rng.gen_range(0, DATA_SIZE * 2)) // 50% hit rate
        .collect();

    // Warmup
    for i in 0..SMALL_SIZE {
        black_box(map.contains_key(&keys[i]));
    }

    let timer = Timer.new();
    timer.start();

    let mut count: Int = 0;
    for i in 0..LOOKUP_COUNT {
        if map.contains_key(&keys[i]) {
            count += 1;
        }
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(count);

    ComparisonResult {
        name: "map_contains_1m",
        verum_ms,
        baseline_ms: rust_baselines.MAP_CONTAINS_1M_MS,
        ratio: rust_baselines.MAP_CONTAINS_1M_MS / verum_ms,
        min_target: 0.85,
        category: "map",
    }
}

