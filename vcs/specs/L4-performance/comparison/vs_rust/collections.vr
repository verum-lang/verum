    let set_a: Set<Int> = (0..half).collect();
    let set_b: Set<Int> = (half/2..half + half/2).collect();

    // Warmup
    let small_a: Set<Int> = (0..1000).collect();
    let small_b: Set<Int> = (500..1500).collect();
    black_box(small_a.intersection(&small_b).count());

    let timer = Timer.new();
    timer.start();

    let intersection: Set<Int> = set_a.intersection(&set_b).cloned().collect();

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(intersection);

    ComparisonResult {
        name: "set_intersection_500k",
        verum_ms,
        baseline_ms: rust_baselines.SET_INTERSECTION_500K_MS,
        ratio: rust_baselines.SET_INTERSECTION_500K_MS / verum_ms,
        min_target: 0.85,
        category: "set",
    }
}

// ============================================================================
// Heap Benchmarks
// ============================================================================

/// Benchmark: Heap push 1M elements
fn benchmark_heap_push() -> ComparisonResult {
    let mut rng = Random.with_seed(42);
    let data: List<Int> = (0..DATA_SIZE)
        .map(|_| rng.gen_range(0, DATA_SIZE))
        .collect();

    // Warmup
    for _ in 0..3 {
        let mut heap: Heap<Int> = Heap();
        for i in 0..SMALL_SIZE {
            heap.push(data[i]);
        }
        black_box(heap);
    }

    let mut heap: Heap<Int> = Heap();

    let timer = Timer.new();
    timer.start();

    for i in 0..DATA_SIZE {
        heap.push(data[i]);
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(heap);

    ComparisonResult {
        name: "heap_push_1m",
        verum_ms,
        baseline_ms: rust_baselines.HEAP_PUSH_1M_MS,
        ratio: rust_baselines.HEAP_PUSH_1M_MS / verum_ms,
        min_target: 0.85,
        category: "heap",
    }
}

/// Benchmark: Heap pop 1M elements
fn benchmark_heap_pop() -> ComparisonResult {
    let mut rng = Random.with_seed(42);

    // Warmup
    for _ in 0..3 {
        let mut heap: Heap<Int> = Heap();
        for _ in 0..SMALL_SIZE {
            heap.push(rng.gen_range(0, SMALL_SIZE));
        }
        while heap.pop().is_some() {}
        black_box(heap);
    }

    let mut heap: Heap<Int> = Heap();
    for i in 0..DATA_SIZE {
        heap.push(rng.gen_range(0, DATA_SIZE));
    }

    let timer = Timer.new();
    timer.start();

    while heap.pop().is_some() {}

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(heap);

    ComparisonResult {
        name: "heap_pop_1m",
        verum_ms,
        baseline_ms: rust_baselines.HEAP_POP_1M_MS,
        ratio: rust_baselines.HEAP_POP_1M_MS / verum_ms,
        min_target: 0.85,
        category: "heap",
    }
}

/// Benchmark: Heap peek 1M times
fn benchmark_heap_peek() -> ComparisonResult {
    let mut rng = Random.with_seed(42);
    let mut heap: Heap<Int> = Heap();
    for _ in 0..DATA_SIZE {
        heap.push(rng.gen_range(0, DATA_SIZE));
    }

    // Warmup
    for _ in 0..SMALL_SIZE {
        black_box(heap.peek());
    }

    let timer = Timer.new();
    timer.start();

    let mut sum: Int = 0;
    for _ in 0..LOOKUP_COUNT {
        if let Some(&v) = heap.peek() {
            sum += v;
        }
    }

    let verum_ms = timer.elapsed_ms() as Float;

    black_box(sum);

    ComparisonResult {
        name: "heap_peek_1m",
        verum_ms,
        baseline_ms: rust_baselines.HEAP_PEEK_1M_MS,
        ratio: rust_baselines.HEAP_PEEK_1M_MS / verum_ms,
        min_target: 0.90,
        category: "heap",
    }
}

type ComparisonResult is {
    name: Text,
    verum_ms: Float,
    baseline_ms: Float,
    ratio: Float,
    min_target: Float,
    category: Text,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<ComparisonResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: ComparisonResult) {
        self.results.push(result);
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");
        println("{:<30} {:>12} {:>12} {:>10} {:>8} {:>8}",
                "Benchmark", "Verum (ms)", "Rust (ms)", "Ratio", "Target", "Status");
        println("{}", "-".repeat(85));

        for result in &self.results {
            let passed = result.ratio >= result.min_target;
            let status = if passed { "PASS" } else { "FAIL" };
            let ratio_pct = result.ratio * 100.0;

            println("{:<30} {:>12.2} {:>12.2} {:>9.1}% {:>7.0}% {:>8}",
                    result.name, result.verum_ms, result.baseline_ms,
                    ratio_pct, result.min_target * 100.0, status);
        }
    }

    fn export_comparison(&self, path: Text) {
        let json = Json.object();
        json.set("suite", &self.suite_name);
        json.set("baseline", "rust");

        let results_json = Json.array();
        for result in &self.results {
            let r = Json.object();
            r.set("name", &result.name);
            r.set("verum_ms", result.verum_ms);
            r.set("baseline_ms", result.baseline_ms);
            r.set("ratio", result.ratio);
            r.set("min_target", result.min_target);
            r.set("category", &result.category);
            r.set("passed", result.ratio >= result.min_target);
            results_json.push(r);
        }
        json.set("results", results_json);

        File.write(path, json.to_string_pretty());
    }
}

fn black_box<T>(x: T) -> T { x }

type Timer is { start_time: Instant };
implement Timer {
    fn new() -> Self { Self { start_time: Instant.now() } }
    fn start(&mut self) { self.start_time = Instant.now(); }
    fn elapsed_ms(&self) -> Int { self.start_time.elapsed().as_millis() }
}

type Random is { seed: u64 };
implement Random {
    fn with_seed(seed: u64) -> Self { Self { seed } }
    fn gen_range(&mut self, min: Int, max: Int) -> Int { min }
}

type Instant is { nanos: Int };
implement Instant {
    fn now() -> Self { Self { nanos: 0 } }
    fn elapsed(&self) -> Duration { Duration { nanos: 0 } }
}

type Duration is { nanos: Int };
implement Duration {
    fn as_millis(&self) -> Int { self.nanos / 1_000_000 }
}

type Json is { data: Map<Text, Heap<Any>> };
implement Json {
    fn object() -> Self { Self { data: Map.new() } }
    fn array() -> Self { Self { data: Map.new() } }
    fn set<T>(&mut self, key: &Text, value: T) {}
    fn push<T>(&mut self, value: T) {}
    fn to_string_pretty(&self) -> Text { Text.new() }
}

module File {
    pub fn write(path: Text, content: Text) {}
}
