/// Benchmark: Set add 1M elements
fn benchmark_set_add() -> ComparisonResult {
    // Warmup
    for _ in 0..3 {
        let mut set: Set<Int> = Set.new();
        for i in 0..SMALL_SIZE {
            set.insert(i);
        }
        black_box(set);
    }

    let mut set: Set<Int> = Set.new();

    let timer = Timer.new();
    timer.start();

    for i in 0..DATA_SIZE {
        set.insert(i);
    }

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.HASHSET_ADD_1M_MS;

    black_box(set);

    ComparisonResult {
        name: "set_add_1m",
        verum_ms,
        baseline_ms: java_ms,
        speedup: java_ms / verum_ms,
        min_speedup: 1.5,
        category: "set",
    }
}

/// Benchmark: Set contains 1M times
fn benchmark_set_contains() -> ComparisonResult {
    let set: Set<Int> = (0..DATA_SIZE).collect();
    let mut rng = Random.with_seed(42);
    let values: List<Int> = (0..LOOKUP_COUNT)
        .map(|_| rng.gen_range(0, DATA_SIZE * 2))
        .collect();

    // Warmup
    for i in 0..SMALL_SIZE {
        black_box(set.contains(&values[i]));
    }

    let timer = Timer.new();
    timer.start();

    let mut count: Int = 0;
    for i in 0..LOOKUP_COUNT {
        if set.contains(&values[i]) {
            count += 1;
        }
    }

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.HASHSET_CONTAINS_1M_MS;

    black_box(count);

    ComparisonResult {
        name: "set_contains_1m",
        verum_ms,
        baseline_ms: java_ms,
        speedup: java_ms / verum_ms,
        min_speedup: 1.5,
        category: "set",
    }
}

// ============================================================================
// Heap/PriorityQueue Benchmarks
// ============================================================================

/// Benchmark: Heap add 1M elements
fn benchmark_heap_add() -> ComparisonResult {
    let mut rng = Random.with_seed(42);
    let data: List<Int> = (0..DATA_SIZE)
        .map(|_| rng.gen_range(0, DATA_SIZE))
        .collect();

    // Warmup
    for _ in 0..3 {
        let mut heap: Heap<Int> = Heap();
        for i in 0..SMALL_SIZE {
            heap.push(data[i]);
        }
        black_box(heap);
    }

    let mut heap: Heap<Int> = Heap();

    let timer = Timer.new();
    timer.start();

    for i in 0..DATA_SIZE {
        heap.push(data[i]);
    }

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.PQUEUE_ADD_1M_MS;

    black_box(heap);

    ComparisonResult {
        name: "heap_add_1m",
        verum_ms,
        baseline_ms: java_ms,
        speedup: java_ms / verum_ms,
        min_speedup: 1.5,
        category: "heap",
    }
}

/// Benchmark: Heap poll 1M elements
fn benchmark_heap_poll() -> ComparisonResult {
    let mut rng = Random.with_seed(42);
    let mut heap: Heap<Int> = Heap();
    for _ in 0..DATA_SIZE {
        heap.push(rng.gen_range(0, DATA_SIZE));
    }

    // Warmup with smaller heap
    let mut small_heap: Heap<Int> = Heap();
    for _ in 0..SMALL_SIZE { small_heap.push(rng.gen_range(0, SMALL_SIZE)); }
    while small_heap.pop().is_some() {}

    let timer = Timer.new();
    timer.start();

    while heap.pop().is_some() {}

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.PQUEUE_POLL_1M_MS;

    ComparisonResult {
        name: "heap_poll_1m",
        verum_ms,
        baseline_ms: java_ms,
        speedup: java_ms / verum_ms,
        min_speedup: 1.5,
        category: "heap",
    }
}

// ============================================================================
// Boxing Overhead Benchmark
// ============================================================================

/// Benchmark: No boxing overhead (Verum primitives vs Java boxed Integer)
fn benchmark_no_boxing() -> ComparisonResult {
    let data: List<Int> = (0..10_000_000).collect();

    // Warmup
    black_box(data.iter().take(100_000).sum.<Int>());

    let timer = Timer.new();
    timer.start();

    // In Java, this would involve boxing/unboxing for Integer
    let sum: Int = data.iter().sum();

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.BOXING_OVERHEAD_10M_MS;

    black_box(sum);

    ComparisonResult {
        name: "no_boxing_sum_10m",
        verum_ms,
        baseline_ms: java_ms,
        speedup: java_ms / verum_ms,
        min_speedup: 5.0, // Major advantage - no boxing
        category: "boxing",
    }
}

/// Benchmark: Stream-like operations
fn benchmark_stream_operations() -> ComparisonResult {
    let data: List<Int> = (0..DATA_SIZE).collect();

    // Warmup
    black_box(data.iter()
        .take(SMALL_SIZE)
        .filter(|&x| x % 2 == 0)
        .map(|x| x * 2)
        .collect.<List<_>>());

    let timer = Timer.new();
    timer.start();

    let result: List<Int> = data.iter()
        .filter(|&x| x % 2 == 0)
        .map(|x| x * 2)
        .collect();

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.STREAM_COLLECT_1M_MS;

    black_box(result);

    ComparisonResult {
        name: "stream_collect_1m",
        verum_ms,
        baseline_ms: java_ms,
        speedup: java_ms / verum_ms,
        min_speedup: 1.5,
        category: "functional",
    }
}

type ComparisonResult is {
    name: Text,
    verum_ms: Float,
    baseline_ms: Float,
    speedup: Float,
    min_speedup: Float,
    category: Text,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<ComparisonResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: ComparisonResult) {
        self.results.push(result);
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");
        println("{:<30} {:>12} {:>12} {:>10} {:>10} {:>8}",
                "Benchmark", "Verum (ms)", "Java (ms)", "Speedup", "Target", "Status");
        println("{}", "-".repeat(90));

        for result in &self.results {
            let passed = result.speedup >= result.min_speedup;
            let status = if passed { "PASS" } else { "FAIL" };

            println("{:<30} {:>12.2} {:>12.2} {:>10.2}x {:>10.1}x {:>8}",
                    result.name, result.verum_ms, result.baseline_ms,
                    result.speedup, result.min_speedup, status);
        }

        println("");
        let avg_speedup = self.results.iter()
            .map(|r| r.speedup)
            .sum.<Float>() / self.results.len() as Float;
        println("Average speedup: {:.2}x faster than Java", avg_speedup);
        println("");
        println("Key advantages:");
        println("  - No primitive boxing overhead");
        println("  - No object header overhead (16 bytes per object in Java)");
        println("  - Better cache locality (contiguous memory)");
        println("  - Predictable CBGR vs unpredictable GC pauses");
    }

    fn export_comparison(&self, path: Text) {
        let json = Json.object();
        json.set("suite", &self.suite_name);
        json.set("baseline", "java");

        let results_json = Json.array();
        for result in &self.results {
            let r = Json.object();
            r.set("name", &result.name);
            r.set("verum_ms", result.verum_ms);
            r.set("baseline_ms", result.baseline_ms);
            r.set("speedup", result.speedup);
            r.set("min_speedup", result.min_speedup);
            r.set("category", &result.category);
            r.set("passed", result.speedup >= result.min_speedup);
            results_json.push(r);
        }
        json.set("results", results_json);

        File.write(path, json.to_string_pretty());
    }
}

fn black_box<T>(x: T) -> T { x }

type Timer is { start_time: Instant };
implement Timer {
    fn new() -> Self { Self { start_time: Instant.now() } }
    fn start(&mut self) { self.start_time = Instant.now(); }
    fn elapsed_ms(&self) -> Int { self.start_time.elapsed().as_millis() }
}

type Random is { seed: u64 };
implement Random {
    fn with_seed(seed: u64) -> Self { Self { seed } }
    fn gen_range(&mut self, min: Int, max: Int) -> Int { min }
}

type Instant is { nanos: Int };
implement Instant {
    fn now() -> Self { Self { nanos: 0 } }
    fn elapsed(&self) -> Duration { Duration { nanos: 0 } }
}

type Duration is { nanos: Int };
implement Duration {
    fn as_millis(&self) -> Int { self.nanos / 1_000_000 }
}

type Json is { data: Map<Text, Heap<Any>> };
implement Json {
    fn object() -> Self { Self { data: Map.new() } }
    fn array() -> Self { Self { data: Map.new() } }
    fn set<T>(&mut self, key: &Text, value: T) {}
    fn push<T>(&mut self, value: T) {}
    fn to_string_pretty(&self) -> Text { Text.new() }
}

module File {
    pub fn write(path: Text, content: Text) {}
}
