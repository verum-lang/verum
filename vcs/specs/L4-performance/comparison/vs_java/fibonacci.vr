// @test: parse
// @tier: all
// @level: L4
// @skip-disabled: benchmark tests can typecheck without runtime
// @baseline-comparison: java
// @tags: comparison, java, jvm, fibonacci, compute, baseline, performance
// @description: Fibonacci vs Java benchmark (target: > 1.2x Java performance)

/// Verum vs Java: Fibonacci Benchmark
///
/// This benchmark compares Verum's performance against Java (HotSpot JVM)
/// for recursive Fibonacci computation. This tests JIT compilation
/// effectiveness, function call overhead, and pure compute performance.
///
/// Target: > 1.2x Java performance (at least 20% faster)
///
/// Test cases:
/// - Naive recursive fib(40) (JIT warmup sensitive)
/// - Memoized fib(50) with HashMap
/// - Iterative fib(10000)
/// - BigInteger fib for large numbers
///
/// Why Verum should be faster:
/// - AOT compilation (no JIT warmup)
/// - No JVM runtime overhead
/// - Direct native code execution
/// - No object allocation for primitives
///
/// Spec reference: docs/detailed/26-cbgr-implementation.md

const WARMUP_ITERATIONS: Int = 20;
const BENCHMARK_ITERATIONS: Int = 5;

/// Java baseline measurements (HotSpot JIT warmed up)
module java_baselines {
    /// Java fib(40) naive recursive in milliseconds (after warmup)
    pub const FIB_40_NAIVE_MS: Float = 600.0;

    /// Java fib(50) memoized with HashMap in milliseconds
    pub const FIB_50_MEMO_MS: Float = 0.2;

    /// Java fib(10000) iterative in milliseconds
    pub const FIB_10000_ITER_MS: Float = 1.0;

    /// Java fib(1000000) BigInteger in milliseconds
    pub const FIB_1M_BIGINT_MS: Float = 2000.0;

    /// Java fib(40) before JIT warmup in milliseconds
    pub const FIB_40_COLD_MS: Float = 1500.0;

    /// Java Stream-based fib in milliseconds
    pub const FIB_STREAM_MS: Float = 100.0;
}

fn main() {
    let results = BenchmarkResults.new("Verum vs Java: Fibonacci");

    results.add(benchmark_fib_naive());
    results.add(benchmark_fib_cold_start());
    results.add(benchmark_fib_memoized());
    results.add(benchmark_fib_iterative());
    results.add(benchmark_fib_bigint());
    results.add(benchmark_fib_functional());

    results.report();
    results.export_comparison("/tmp/verum_vs_java_fibonacci.json");

    let all_meet_target = results.results.iter()
        .all(|r| r.speedup >= r.min_speedup);
    assert(all_meet_target, "Verum Fibonacci performance below target vs Java");
}

/// Naive recursive Fibonacci
fn fib_naive(n: Int) -> Int {
    if n <= 1 { n }
    else { fib_naive(n - 1) + fib_naive(n - 2) }
}

/// Benchmark: Naive recursive fibonacci(40)
fn benchmark_fib_naive() -> ComparisonResult {
    // No warmup needed for Verum (AOT compiled)
    // Java would need warmup for JIT

    let mut total_ms: Float = 0.0;

    for _ in 0..BENCHMARK_ITERATIONS {
        let timer = Timer.new();
        timer.start();

        let result = fib_naive(40);

        total_ms += timer.elapsed_ms() as Float;
        black_box(result);
    }

    let verum_ms = total_ms / BENCHMARK_ITERATIONS as Float;
    let java_ms = java_baselines.FIB_40_NAIVE_MS;
    let speedup = java_ms / verum_ms;

    ComparisonResult {
        name: "fib_40_naive_recursive",
        verum_ms,
        baseline_ms: java_ms,
        speedup,
        min_speedup: 1.2, // 20% faster than warmed-up Java
        category: "compute",
    }
}

/// Benchmark: Cold start comparison (first run)
fn benchmark_fib_cold_start() -> ComparisonResult {
    // Simulate "cold" execution for Verum
    // Java's first run is much slower before JIT kicks in

    let timer = Timer.new();
    timer.start();

    let result = fib_naive(40);

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.FIB_40_COLD_MS;

    black_box(result);

    let speedup = java_ms / verum_ms;

    ComparisonResult {
        name: "fib_40_cold_start",
        verum_ms,
        baseline_ms: java_ms,
        speedup,
        min_speedup: 2.5, // Much faster on cold start (no JIT warmup)
        category: "startup",
    }
}

/// Memoized Fibonacci
fn fib_memoized(n: Int, memo: &mut Map<Int, Int>) -> Int {
    if n <= 1 { return n; }

    if let Some(&cached) = memo.get(&n) {
        return cached;
    }

    let result = fib_memoized(n - 1, memo) + fib_memoized(n - 2, memo);
    memo.insert(n, result);
    result
}

/// Benchmark: Memoized fibonacci(50)
fn benchmark_fib_memoized() -> ComparisonResult {
    // Warmup
    for _ in 0..WARMUP_ITERATIONS * 10 {
        let mut memo: Map<Int, Int> = Map.new();
        black_box(fib_memoized(50, &mut memo));
    }

    let mut total_ms: Float = 0.0;

    for _ in 0..BENCHMARK_ITERATIONS * 1000 {
        let mut memo: Map<Int, Int> = Map.new();

        let timer = Timer.new();
        timer.start();

        let result = fib_memoized(50, &mut memo);

        total_ms += timer.elapsed_ms() as Float;
        black_box(result);
    }

    let verum_ms = total_ms / (BENCHMARK_ITERATIONS * 1000) as Float;
    let java_ms = java_baselines.FIB_50_MEMO_MS;
    let speedup = java_ms / verum_ms;

    ComparisonResult {
        name: "fib_50_memoized",
        verum_ms,
        baseline_ms: java_ms,
        speedup,
        min_speedup: 1.5, // HashMap operations should be faster
        category: "compute_memo",
    }
}

/// Iterative Fibonacci
fn fib_iterative(n: Int) -> Int {
    if n <= 1 { return n; }

    let mut prev = 0;
    let mut curr = 1;

    for _ in 2..=n {
        let next = prev + curr;
        prev = curr;
        curr = next;
    }

    curr
}

/// Benchmark: Iterative fibonacci(10000)
fn benchmark_fib_iterative() -> ComparisonResult {
    // Warmup
    for _ in 0..WARMUP_ITERATIONS * 100 {
        black_box(fib_iterative(10000));
    }

    let mut total_ms: Float = 0.0;

    for _ in 0..BENCHMARK_ITERATIONS * 1000 {
        let timer = Timer.new();
        timer.start();

        let result = fib_iterative(10000);

        total_ms += timer.elapsed_ms() as Float;
        black_box(result);
    }

    let verum_ms = total_ms / (BENCHMARK_ITERATIONS * 1000) as Float;
    let java_ms = java_baselines.FIB_10000_ITER_MS;
    let speedup = java_ms / verum_ms;

    ComparisonResult {
        name: "fib_10000_iterative",
        verum_ms,
        baseline_ms: java_ms,
        speedup,
        min_speedup: 1.5, // No boxing overhead
        category: "compute_iter",
    }
}

/// BigInt Fibonacci for large numbers
fn fib_bigint(n: Int) -> BigInt {
    if n <= 1 { return BigInt.from(n); }

    let mut prev = BigInt.from(0);
    let mut curr = BigInt.from(1);

    for _ in 2..=n {
        let next = &prev + &curr;
        prev = curr;
        curr = next;
    }

    curr
}

/// Benchmark: BigInteger fibonacci(1000000)
fn benchmark_fib_bigint() -> ComparisonResult {
    // Warmup with smaller n
    for _ in 0..10 {
        black_box(fib_bigint(10000));
    }

    let timer = Timer.new();
    timer.start();

    let result = fib_bigint(100000); // Smaller for reasonable time

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.FIB_1M_BIGINT_MS / 10.0; // Scale

    black_box(result);

    let speedup = java_ms / verum_ms;

    ComparisonResult {
        name: "fib_100k_bigint",
        verum_ms,
        baseline_ms: java_ms,
        speedup,
        min_speedup: 1.2, // BigInt libraries may vary
        category: "bigint",
    }
}

/// Functional-style Fibonacci using iterators
fn fib_functional(n: Int) -> Int {
    type FibIterator is { curr: Int, next: Int };

    implement Iterator for FibIterator {
        type Item = Int;
        fn next(&mut self) -> Maybe<Int> {
            let result = self.curr;
            let new_next = self.curr + self.next;
            self.curr = self.next;
            self.next = new_next;
            Some(result)
        }
    }

    FibIterator { curr: 0, next: 1 }
        .nth(n as usize)
        .unwrap_or(0)
}

/// Benchmark: Functional-style fibonacci
fn benchmark_fib_functional() -> ComparisonResult {
    // Warmup
    for _ in 0..WARMUP_ITERATIONS * 100 {
        black_box(fib_functional(1000));
    }

    let timer = Timer.new();
    timer.start();

    for _ in 0..10000 {
        black_box(fib_functional(1000));
    }

    let verum_ms = timer.elapsed_ms() as Float;
    let java_ms = java_baselines.FIB_STREAM_MS;

    let speedup = java_ms / verum_ms;

    ComparisonResult {
        name: "fib_1000_functional",
        verum_ms,
        baseline_ms: java_ms,
        speedup,
        min_speedup: 2.0, // Java streams have significant overhead
        category: "functional",
    }
}

type ComparisonResult is {
    name: Text,
    verum_ms: Float,
    baseline_ms: Float,
    speedup: Float,
    min_speedup: Float,
    category: Text,
};

type BenchmarkResults is {
    suite_name: Text,
    results: List<ComparisonResult>,
};

implement BenchmarkResults {
    fn new(name: Text) -> Self {
        Self { suite_name: name, results: List.new() }
    }

    fn add(&mut self, result: ComparisonResult) {
        self.results.push(result);
    }

    fn report(&self) {
        println("=== {} ===", self.suite_name);
        println("");
        println("{:<30} {:>12} {:>12} {:>10} {:>10} {:>8}",
                "Benchmark", "Verum (ms)", "Java (ms)", "Speedup", "Target", "Status");
        println("{}", "-".repeat(90));

        for result in &self.results {
            let passed = result.speedup >= result.min_speedup;
            let status = if passed { "PASS" } else { "FAIL" };

            println("{:<30} {:>12.4} {:>12.4} {:>10.2}x {:>10.1}x {:>8}",
                    result.name, result.verum_ms, result.baseline_ms,
                    result.speedup, result.min_speedup, status);
        }

        println("");
        let avg_speedup = self.results.iter()
            .map(|r| r.speedup)
            .sum.<Float>() / self.results.len() as Float;
        println("Average speedup: {:.2}x faster than Java", avg_speedup);
        println("");
        println("Note: Java measurements assume HotSpot JIT fully warmed up.");
        println("Cold start shows dramatic Verum advantage due to AOT compilation.");
    }

    fn export_comparison(&self, path: Text) {
        let json = Json.object();
        json.set("suite", &self.suite_name);
        json.set("baseline", "java");

        let results_json = Json.array();
        for result in &self.results {
            let r = Json.object();
            r.set("name", &result.name);
            r.set("verum_ms", result.verum_ms);
            r.set("baseline_ms", result.baseline_ms);
            r.set("speedup", result.speedup);
            r.set("min_speedup", result.min_speedup);
            r.set("category", &result.category);
            r.set("passed", result.speedup >= result.min_speedup);
            results_json.push(r);
        }
        json.set("results", results_json);

        File.write(path, json.to_string_pretty());
        println("Comparison exported to {}", path);
    }
}

fn black_box<T>(x: T) -> T { x }

type BigInt is { digits: List<u64> };
implement BigInt {
    fn from(n: Int) -> Self { Self { digits: List.new() } }
}

implement Add for &BigInt {
    type Output = BigInt;
    fn add(self, other: &BigInt) -> BigInt { BigInt { digits: List.new() } }
}

type Timer is { start_time: Instant };
implement Timer {
    fn new() -> Self { Self { start_time: Instant.now() } }
    fn start(&mut self) { self.start_time = Instant.now(); }
    fn elapsed_ms(&self) -> Int { self.start_time.elapsed().as_millis() }
}

type Instant is { nanos: Int };
implement Instant {
    fn now() -> Self { Self { nanos: 0 } }
    fn elapsed(&self) -> Duration { Duration { nanos: 0 } }
}

type Duration is { nanos: Int };
implement Duration {
    fn as_millis(&self) -> Int { self.nanos / 1_000_000 }
}

type Json is { data: Map<Text, Heap<Any>> };
implement Json {
    fn object() -> Self { Self { data: Map.new() } }
    fn array() -> Self { Self { data: Map.new() } }
    fn set<T>(&mut self, key: &Text, value: T) {}
    fn push<T>(&mut self, value: T) {}
    fn to_string_pretty(&self) -> Text { Text.new() }
}

module File {
    pub fn write(path: Text, content: Text) {}
}
