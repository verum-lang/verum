// @test: meta-pass
// @level: L1
// @tier: 0
// @tags: meta, quote, hygiene, lift, stage, escape
// @description: Tests lift expressions and stage escaping in multi-stage metaprogramming

// =============================================================================
// BASIC LIFT EXPRESSIONS
// =============================================================================

// Lift a compile-time value to runtime code
meta fn lift_value(val: Int) -> TokenStream {
    quote {
        let x = ${val};  // Lift val into generated code
        x
    }
}

// Lift complex expressions
meta fn lift_expression(a: Int, b: Int) -> TokenStream {
    let result = a * b + 10;  // Computed at meta level
    quote {
        let computed = ${result};  // Lifted result
        computed
    }
}

// Lift list literal
meta fn lift_list(items: List<Int>) -> TokenStream {
    quote {
        let list = [${items}];  // Lift entire list
        list
    }
}

// =============================================================================
// STAGE 0: META LEVEL
// =============================================================================

// Stage 0 computation - runs at compile time
meta fn stage0_compute() -> Int {
    let x = 10;
    let y = 20;
    x + y  // Returns 30 at compile time
}

meta fn use_stage0() -> TokenStream {
    let result = stage0_compute();
    quote {
        let value = ${result};  // Lift stage 0 result
        value
    }
}

// =============================================================================
// STAGE 1: QUOTE LEVEL
// =============================================================================

// Stage 1 code within quote
meta fn stage1_code() -> TokenStream {
    quote {
        // This code is stage 1 - exists but not yet executed
        let x = 10;
        let y = 20;
        x + y
    }
}

// Mixed stage 0 and stage 1
meta fn mixed_stages(multiplier: Int) -> TokenStream {
    let prefix = "result_";  // Stage 0
    let computed = multiplier * 100;  // Stage 0

    quote {
        // Stage 1 code with lifted stage 0 values
        let ${ident(prefix + "a")} = ${computed};
        let ${ident(prefix + "b")} = ${computed + 50};
    }
}

// =============================================================================
// STAGE 2+: NESTED QUOTES
// =============================================================================

// Generate code that generates code
meta fn stage2_generator() -> TokenStream {
    let outer_val = 42;  // Stage 0

    quote {
        // Stage 1: This returns a meta function
        meta fn inner_gen() -> TokenStream {
            let inner_val = ${outer_val};  // Lifted from stage 0 to stage 1
            quote {
                // Stage 2: Code generated by inner_gen
                let final_val = $${inner_val};  // Double-splice for stage 2
                final_val
            }
        }
    }
}

// Three-level staging
meta fn stage3_example() -> TokenStream {
    let level0 = "L0";  // Stage 0

    quote {
        let level1 = ${level0};  // Lift to stage 1

        meta fn gen_level2() -> TokenStream {
            let level2_var = $$level1;  // Reference stage 1 binding

            quote {
                let level2 = $$$level2_var;  // Stage 2

                meta fn gen_level3() -> TokenStream {
                    quote {
                        let level3 = $$$level2;  // Stage 3
                        level3
                    }
                }
            }
        }
    }
}

// =============================================================================
// ESCAPE HATCHES
// =============================================================================

// Force evaluation at current stage using escape
meta fn escape_to_stage0(code: TokenStream) -> TokenStream {
    // Evaluate the token stream at meta level
    let result: Int = eval(code);
    quote {
        let evaluated = ${result};
        evaluated
    }
}

// Stage escape with expression
meta fn escape_expression() -> TokenStream {
    quote {
        let x = ${
            // This block runs at stage 0
            let a = 10;
            let b = 20;
            a + b
        };
        x
    }
}

// =============================================================================
// LIFT WITH TYPE PRESERVATION
// =============================================================================

// Lift preserves type information
meta fn lift_typed<T>(value: T) -> TokenStream {
    quote {
        let typed_val: ${type_of(value)} = ${value};
        typed_val
    }
}

// Lift tuple
meta fn lift_tuple(a: Int, b: Text, c: Bool) -> TokenStream {
    let tuple = (a, b, c);
    quote {
        let t = ${tuple};
        t
    }
}

// Lift struct instance
meta fn lift_struct(point: Point) -> TokenStream {
    quote {
        let p = Point {
            x: ${point.x},
            y: ${point.y},
        };
        p
    }
}

// =============================================================================
// CONDITIONAL STAGING
// =============================================================================

// Choose stage based on condition
meta fn conditional_stage(use_static: Bool, val: Int) -> TokenStream {
    if use_static {
        // Compute at stage 0, lift result
        let computed = val * val;
        quote {
            let x = ${computed};  // Static value
            x
        }
    } else {
        // Generate dynamic computation
        quote {
            let v = ${val};
            let x = v * v;  // Dynamic computation
            x
        }
    }
}

// =============================================================================
// STAGE POLYMORPHISM
// =============================================================================

// Function works across stages
meta fn cross_stage_fn(input: TokenStream) -> TokenStream {
    quote {
        fn process(x: Int) -> Int {
            x * 2
        }

        let result = process(${eval(input)});
        result
    }
}

// =============================================================================
// LIFT WITH HYGIENE
// =============================================================================

// Lifted values don't interfere with local bindings
meta fn lift_with_hygiene() -> TokenStream {
    let x = 100;  // Stage 0 'x'

    quote {
        let x = 50;  // Stage 1 'x' - different binding
        let lifted = ${x};  // Lifts stage 0 'x' (100), not stage 1's
        assert(x == 50);
        assert(lifted == 100);
    }
}

// Multiple lifts with same name
meta fn multiple_lifts() -> TokenStream {
    let a = 10;
    let b = 20;

    quote {
        let a = 1;  // Local a
        let b = 2;  // Local b

        // Lifted values are distinct from locals
        let lifted_a = ${a};  // 10
        let lifted_b = ${b};  // 20

        assert(a == 1);
        assert(b == 2);
        assert(lifted_a == 10);
        assert(lifted_b == 20);
    }
}

// =============================================================================
// STAGE-AWARE GENSYM
// =============================================================================

// Gensym works correctly across stages
meta fn staged_gensym() -> TokenStream {
    let stage0_sym = gensym("s0");  // Created at stage 0

    quote {
        let $stage0_sym = 42;

        meta fn inner() -> TokenStream {
            let stage1_sym = gensym("s1");  // Created at stage 1
            quote {
                let $$stage1_sym = 100;
                $$$stage0_sym + $$stage1_sym
            }
        }
    }
}

// =============================================================================
// RECURSIVE STAGING
// =============================================================================

// Recursively generate staged code
meta fn recursive_stage(depth: Int) -> TokenStream {
    if depth == 0 {
        quote { 1 }
    } else {
        let inner = recursive_stage(depth - 1);
        quote {
            ${depth} + $inner
        }
    }
}

// =============================================================================
// VERIFICATION
// =============================================================================

fn test_lift_value() {
    let result = @lift_value(42);
    assert(result == 42);
}

fn test_lift_expression() {
    let result = @lift_expression(5, 3);  // 5 * 3 + 10 = 25
    assert(result == 25);
}

fn test_use_stage0() {
    let result = @use_stage0();
    assert(result == 30);
}

fn test_mixed_stages() {
    @mixed_stages(2);
    assert(result_a == 200);
    assert(result_b == 250);
}

fn test_conditional_stage_static() {
    let result = @conditional_stage(true, 5);
    assert(result == 25);  // Computed at compile time
}

fn test_conditional_stage_dynamic() {
    let result = @conditional_stage(false, 5);
    assert(result == 25);  // Computed at runtime
}

fn test_lift_with_hygiene() {
    @lift_with_hygiene();
}

fn test_multiple_lifts() {
    @multiple_lifts();
}

fn test_recursive_stage() {
    let result = @recursive_stage(3);  // 3 + 2 + 1 + 1 = 7
    assert(result == 7);
}

fn main() {
    test_lift_value();
    test_lift_expression();
    test_use_stage0();
    test_mixed_stages();
    test_conditional_stage_static();
    test_conditional_stage_dynamic();
    test_lift_with_hygiene();
    test_multiple_lifts();
    test_recursive_stage();
}
