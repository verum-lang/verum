    config_names
}

// =============================================================================
// PRACTICAL USE CASES
// =============================================================================

// Auto-discover test files (requires dir parameter to avoid auto-execution)
meta fn discover_test_files(tests_dir: Text) -> [Text] using [BuildAssets] {
    asset_list_dir(tests_dir)
}

// Check if schema exists before loading
meta fn load_schema_safe(name: Text) -> Maybe<Text> using [BuildAssets] {
    let path = text_concat("schemas/", name, ".json");
    if asset_exists(path) {
        Some(load_text(path))
    } else {
        None
    }
}

// Get total size of directory
meta fn count_directory_files(dir: Text) -> Int using [BuildAssets] {
    let files = asset_list_dir(dir);
    list_len(files)
}

// Check if asset was modified recently (stub - would use actual time comparison)
meta fn is_recently_modified(path: Text) -> Bool using [BuildAssets] {
    if asset_exists(path) {
        let (_, modified, _, _, _) = asset_metadata(path);
        // Stub: always return true for test
        true
    } else {
        false
    }
}

// =============================================================================
// MAYBE TYPE DEFINITION (for tests)
// =============================================================================

type Maybe<T> is None | Some(T);

// =============================================================================
// MAIN TEST FUNCTION
// =============================================================================

fn main() {
    // Test list operations that don't require real files
    @const assert(list_len([]) == 0);
    @const assert(list_len(["a", "b", "c"]) == 3);

    // Test text operations
    @const assert(text_len("test") == 4);
    @const assert(text_concat("hello", "/", "world") == "hello/world");

    // Meta functions requiring file access are tested at integration level
}
