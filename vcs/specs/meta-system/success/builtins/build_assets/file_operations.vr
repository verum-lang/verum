// =============================================================================
// ASSET_METADATA TESTS
// =============================================================================

// Test asset_metadata basic
// Returns: (size: UInt, modified_ns: UInt, is_directory: Bool, is_file: Bool, is_symlink: Bool)
meta fn test_asset_metadata(path: Text) -> (UInt, UInt, Bool, Bool, Bool) using [BuildAssets] {
    asset_metadata(path)
}

// Test getting file size
meta fn get_file_size(path: Text) -> UInt using [BuildAssets] {
    let (size, _modified, _is_dir, _is_file, _is_symlink) = asset_metadata(path);
    size
}

// Test checking if path is directory
meta fn is_directory(path: Text) -> Bool using [BuildAssets] {
    let (_size, _modified, is_dir, _is_file, _is_symlink) = asset_metadata(path);
    is_dir
}

// Test checking if path is regular file
meta fn is_regular_file(path: Text) -> Bool using [BuildAssets] {
    let (_size, _modified, _is_dir, is_file, _is_symlink) = asset_metadata(path);
    is_file
}

// Test checking modification time
meta fn get_modified_time(path: Text) -> UInt using [BuildAssets] {
    let (_size, modified, _is_dir, _is_file, _is_symlink) = asset_metadata(path);
    modified
}

// Test checking for symlinks
meta fn is_symlink(path: Text) -> Bool using [BuildAssets] {
    let (_size, _modified, _is_dir, _is_file, is_symlink) = asset_metadata(path);
    is_symlink
}

// =============================================================================
// COMBINED OPERATIONS
// =============================================================================

// Test exists and metadata
meta fn safe_get_size(path: Text) -> Maybe<UInt> using [BuildAssets] {
    if asset_exists(path) {
        let (size, _, _, _, _) = asset_metadata(path);
        Some(size)
    } else {
        None
    }
}

// Test list and filter directories
meta fn list_subdirectories(parent: Text) -> [Text] using [BuildAssets] {
