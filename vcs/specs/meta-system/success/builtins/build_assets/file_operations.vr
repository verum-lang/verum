// Test listing for auto-discovery
meta fn discover_modules(modules_dir: Text) -> [Text] using [BuildAssets] {
    asset_list_dir(modules_dir)
}

// Test listing for plugin discovery (requires dir parameter to avoid auto-execution)
meta fn discover_plugins(plugins_dir: Text) -> [Text] using [BuildAssets] {
    asset_list_dir(plugins_dir)
}

// Test listing templates (requires dir parameter to avoid auto-execution)
meta fn list_templates(templates_dir: Text) -> [Text] using [BuildAssets] {
    asset_list_dir(templates_dir)
