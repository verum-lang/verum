// =============================================================================
// ASSET_EXISTS TESTS
// =============================================================================

// Test asset_exists basic
meta fn test_asset_exists(path: Text) -> Bool using [BuildAssets] {
    asset_exists(path)
}

// Test asset_exists for conditional loading
meta fn conditional_asset(path: Text, fallback: Text) -> Text using [BuildAssets] {
    if asset_exists(path) {
        path
    } else {
        fallback
    }
}

// Test asset_exists with multiple paths
meta fn find_first_existing(paths: [Text]) -> Maybe<Text> using [BuildAssets] {
    // Simplified: check first path only
    if list_len(paths) > 0 {
        let first = maybe_unwrap(list_get(paths, 0));
        if asset_exists(first) {
            Some(first)
        } else {
            None
        }
    } else {
        None
    }
}

// Test asset_exists for feature detection
meta fn has_optional_config(config_name: Text) -> Bool using [BuildAssets] {
    let path = text_concat("config/optional/", config_name, ".toml");
    asset_exists(path)
}

// Test asset_exists for migration detection
meta fn has_migration(version: Int) -> Bool using [BuildAssets] {
    let path = text_concat("migrations/v", stringify(version), ".sql");
    asset_exists(path)
}

