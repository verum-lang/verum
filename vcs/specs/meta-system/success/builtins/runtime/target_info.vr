// @test: meta-pass
// @level: L1
// @tier: 0
// @tags: meta, builtins, runtime, target_os, target_arch
// @description: Test runtime/build information builtins
// @contexts: MetaRuntime

// =============================================================================
// TARGET_OS TESTS
// =============================================================================

// Test target_os returns valid OS string
meta fn test_target_os_valid() -> Bool using [MetaRuntime] {
    let os = target_os();
    // Must be one of the known OS values
    os == "linux" || os == "macos" || os == "windows" ||
    os == "freebsd" || os == "ios" || os == "android"
}

// Test target_os is non-empty
meta fn test_target_os_nonempty() -> Bool using [MetaRuntime] {
    let os = target_os();
    text_len(os) > 0
}

// Test conditional compilation based on OS
meta fn platform_specific_value() -> Int using [MetaRuntime] {
    let os = target_os();
    if os == "linux" {
        1
    } else if os == "macos" {
        2
    } else if os == "windows" {
        3
    } else {
        0
    }
}

// =============================================================================
// TARGET_ARCH TESTS
// =============================================================================

// Test target_arch returns valid architecture string
meta fn test_target_arch_valid() -> Bool using [MetaRuntime] {
    let arch = target_arch();
    // Must be one of the known architectures
    arch == "x86_64" || arch == "aarch64" || arch == "arm" ||
    arch == "x86" || arch == "riscv64" || arch == "wasm32"
}

// Test target_arch is non-empty
meta fn test_target_arch_nonempty() -> Bool using [MetaRuntime] {
    let arch = target_arch();
    text_len(arch) > 0
}

// Test pointer size based on architecture
meta fn pointer_size_from_arch() -> Int using [MetaRuntime] {
    let arch = target_arch();
    if arch == "x86_64" || arch == "aarch64" || arch == "riscv64" {
        8  // 64-bit
    } else if arch == "x86" || arch == "arm" || arch == "wasm32" {
        4  // 32-bit
    } else {
        0  // Unknown
    }
}

// =============================================================================
// TARGET_ENDIAN TESTS
// =============================================================================

// Test target_endian returns valid value
meta fn test_target_endian_valid() -> Bool using [MetaRuntime] {
    let endian = target_endian();
    endian == "little" || endian == "big"
}

// =============================================================================
// COMBINED TESTS
// =============================================================================

// Test building platform-specific paths
meta fn system_lib_path() -> Text using [MetaRuntime] {
    let os = target_os();
    if os == "linux" {
        "/usr/lib"
    } else if os == "macos" {
        "/usr/local/lib"
    } else if os == "windows" {
        "C:\\Windows\\System32"
    } else {
        "/lib"
    }
}

// Test building platform-specific extensions
meta fn shared_lib_extension() -> Text using [MetaRuntime] {
    let os = target_os();
    if os == "linux" || os == "freebsd" {
        ".so"
    } else if os == "macos" || os == "ios" {
        ".dylib"
    } else if os == "windows" {
        ".dll"
    } else {
        ".so"
    }
}

// Test feature detection based on platform
meta fn has_feature(feature: Text) -> Bool using [MetaRuntime] {
    let os = target_os();
    let arch = target_arch();

    if feature == "simd" {
        // x86_64 and aarch64 have SIMD
        arch == "x86_64" || arch == "aarch64"
    } else if feature == "threads" {
        // All major platforms support threads
        os == "linux" || os == "macos" || os == "windows"
    } else if feature == "gpu" {
        // Desktop platforms have GPU support
        (os == "linux" || os == "macos" || os == "windows") &&
        (arch == "x86_64" || arch == "aarch64")
    } else {
        false
    }
}

// Main test function
fn main() {
    // OS tests
    @const assert(test_target_os_valid());
    @const assert(test_target_os_nonempty());

    // Arch tests
    @const assert(test_target_arch_valid());
    @const assert(test_target_arch_nonempty());

    // Endian tests
    @const assert(test_target_endian_valid());

    // Combined tests - just evaluate to ensure they don't panic
    @const assert(text_len(system_lib_path()) > 0);
    @const assert(text_len(shared_lib_extension()) > 0);
    @const assert(platform_specific_value() >= 0);
    @const assert(pointer_size_from_arch() >= 0);

    // Feature detection tests
    @const assert(has_feature("simd") || !has_feature("simd"));
    @const assert(has_feature("threads") || !has_feature("threads"));
    @const assert(has_feature("gpu") || !has_feature("gpu"));
}
