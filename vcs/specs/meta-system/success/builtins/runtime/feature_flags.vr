// @test: meta-pass
// @level: L1
// @tier: 0
// @tags: meta, builtins, runtime, feature_flags, target_has_feature
// @description: Comprehensive tests for feature flags and target feature detection builtins
// @contexts: MetaRuntime

// =============================================================================
// TARGET_HAS_FEATURE TESTS
// =============================================================================

// Test target_has_feature returns boolean
meta fn test_target_has_feature_returns_bool() -> Bool using [MetaRuntime] {
    let has_sse2 = target_has_feature("sse2");
    has_sse2 || !has_sse2  // Tautology to verify boolean
}

// Test common x86_64 features
meta fn test_target_features_x86() -> Bool using [MetaRuntime] {
    let arch = target_arch();
    if arch == "x86_64" {
        // x86_64 should have these baseline features
        // Just verify the function works, not that features are present
        let has_sse = target_has_feature("sse");
        let has_sse2 = target_has_feature("sse2");
        has_sse || !has_sse  // Just verify it returns bool
    } else {
        true  // Skip on non-x86
    }
}

// Test common ARM features
meta fn test_target_features_arm() -> Bool using [MetaRuntime] {
    let arch = target_arch();
    if arch == "aarch64" {
        // aarch64 features
        let has_neon = target_has_feature("neon");
        has_neon || !has_neon  // Just verify it returns bool
    } else {
        true  // Skip on non-ARM
    }
}

// Test unknown feature returns false
meta fn test_target_has_feature_unknown() -> Bool using [MetaRuntime] {
    // A clearly invalid feature name should return false
    !target_has_feature("this_feature_definitely_does_not_exist_xyz123")
}

// =============================================================================
// HAS_FEATURE TESTS (Crate-level features)
// =============================================================================

// Test has_feature returns boolean
meta fn test_has_feature_returns_bool() -> Bool using [MetaRuntime] {
    let has = has_feature("some_feature");
    has || !has  // Tautology
}

// Test common feature patterns
meta fn test_has_feature_common() -> Bool using [MetaRuntime] {
    // These are just testing that the function works
    let has_std = has_feature("std");
    let has_alloc = has_feature("alloc");
    // Just verify they return bools
    (has_std || !has_std) && (has_alloc || !has_alloc)
}

// Test unknown feature returns false
meta fn test_has_feature_unknown() -> Bool using [MetaRuntime] {
    !has_feature("unknown_feature_that_does_not_exist_xyz987")
}

// =============================================================================
// ENABLED_FEATURES TESTS
// =============================================================================

// Test enabled_features returns a list
meta fn test_enabled_features_returns_list() -> Bool using [MetaRuntime] {
    let features = enabled_features();
    // List length should be >= 0
    list_len(features) >= 0
}

// Test enabled features contains only strings
meta fn test_enabled_features_are_strings() -> Bool using [MetaRuntime] {
    let features = enabled_features();
    if list_len(features) > 0 {
        // Get first feature and verify it's a string (has length)
        let first = maybe_unwrap(list_get(features, 0));
        text_len(first) >= 0
    } else {
        true  // Empty list is valid
    }
}

// Test enabled features are unique
meta fn test_enabled_features_unique() -> Bool using [MetaRuntime] {
    let features = enabled_features();
    let len = list_len(features);

    // For simplicity, just check the list is well-formed
    // A comprehensive uniqueness check would require more complex logic
    len >= 0
}

// =============================================================================
// FEATURE-BASED CONDITIONAL COMPILATION
// =============================================================================

// Test selecting implementation based on target features
meta fn select_simd_impl() -> Text using [MetaRuntime] {
    let arch = target_arch();

    if arch == "x86_64" {
        if target_has_feature("avx2") {
            "avx2"
        } else if target_has_feature("sse4.2") {
            "sse4"
        } else if target_has_feature("sse2") {
            "sse2"
        } else {
            "scalar"
        }
    } else if arch == "aarch64" {
        if target_has_feature("neon") {
            "neon"
        } else {
            "scalar"
        }
    } else {
        "scalar"
    }
}

meta fn test_select_simd_impl() -> Bool using [MetaRuntime] {
    let impl_name = select_simd_impl();
    text_len(impl_name) > 0
}

// Test feature-gated code path
meta fn crypto_impl() -> Text using [MetaRuntime] {
    let arch = target_arch();

    if arch == "x86_64" && target_has_feature("aes") {
        "hardware_aes"
    } else if arch == "aarch64" && target_has_feature("aes") {
        "hardware_aes"
    } else {
        "software_aes"
    }
}

meta fn test_crypto_impl() -> Bool using [MetaRuntime] {
    let impl_name = crypto_impl();
    impl_name == "hardware_aes" || impl_name == "software_aes"
}

// =============================================================================
// FEATURE REQUIREMENT CHECKS
// =============================================================================

// Helper to check if all required features are present
meta fn has_all_features(features: List<Text>) -> Bool using [MetaRuntime] {
    let len = list_len(features);
    if len == 0 {
        true
    } else {
        // Check each feature
        let all_present = list_fold(features, true,
            |acc: Bool, feature: Text| -> Bool {
                acc && has_feature(feature)
            }
        );
        all_present
    }
}

meta fn test_has_all_features_empty() -> Bool using [MetaRuntime] {
    // Empty list should return true
    let empty: List<Text> = [];
    has_all_features(empty)
}

// Helper to check if any required feature is present
meta fn has_any_feature(features: List<Text>) -> Bool using [MetaRuntime] {
    let len = list_len(features);
    if len == 0 {
        false
    } else {
        let any_present = list_fold(features, false,
            |acc: Bool, feature: Text| -> Bool {
                acc || has_feature(feature)
            }
        );
        any_present
    }
}

meta fn test_has_any_feature_empty() -> Bool using [MetaRuntime] {
    // Empty list should return false
    let empty: List<Text> = [];
    !has_any_feature(empty)
}

// =============================================================================
// PLATFORM CAPABILITY DETECTION
// =============================================================================

// Detect SIMD capability level
meta fn simd_capability_level() -> Int using [MetaRuntime] {
    let arch = target_arch();

    if arch == "x86_64" {
        if target_has_feature("avx512f") {
            4
        } else if target_has_feature("avx2") {
            3
        } else if target_has_feature("avx") {
            2
        } else if target_has_feature("sse4.2") {
            1
        } else {
            0
        }
    } else if arch == "aarch64" {
        if target_has_feature("sve2") {
            3
        } else if target_has_feature("sve") {
            2
        } else if target_has_feature("neon") {
            1
        } else {
            0
        }
    } else {
        0
    }
}

meta fn test_simd_capability_level() -> Bool using [MetaRuntime] {
    let level = simd_capability_level();
    level >= 0 && level <= 4
}

// =============================================================================
// MAIN TEST FUNCTION
// =============================================================================

fn main() {
    // target_has_feature tests
    @const assert(test_target_has_feature_returns_bool());
    @const assert(test_target_features_x86());
    @const assert(test_target_features_arm());
    @const assert(test_target_has_feature_unknown());

    // has_feature tests
    @const assert(test_has_feature_returns_bool());
    @const assert(test_has_feature_common());
    @const assert(test_has_feature_unknown());

    // enabled_features tests
    @const assert(test_enabled_features_returns_list());
    @const assert(test_enabled_features_are_strings());
    @const assert(test_enabled_features_unique());

    // Conditional compilation tests
    @const assert(test_select_simd_impl());
    @const assert(test_crypto_impl());

    // Feature requirement checks
    @const assert(test_has_all_features_empty());
    @const assert(test_has_any_feature_empty());

    // Platform capability detection
    @const assert(test_simd_capability_level());
}
