// @test: meta-pass
// @level: L1
// @tier: 0
// @tags: meta, hygiene, derive, integration
// @description: Test hygiene in derive-style macros with gensym

// =============================================================================
// SIMPLE DERIVE MACROS
// =============================================================================
// These derive macros demonstrate hygienic code generation using gensym

// =============================================================================
// DERIVE CLONE
// =============================================================================

meta fn derive_clone(type_name: Ident, fields: List<Ident>) -> TokenStream {
    quote {
        implement Clone for $type_name {
            fn clone(&self) -> Self {
                $type_name {
                    $[for field in fields {
                        $field: self.$field.clone(),
                    }]
                }
            }
        }
    }
}

// =============================================================================
// DERIVE PARTIAL_EQ
// =============================================================================

meta fn derive_partial_eq(type_name: Ident, fields: List<Ident>) -> TokenStream {
    let other = gensym("other");  // Hygienic parameter name

    quote {
        implement PartialEq for $type_name {
            fn eq(&self, $other: &Self) -> Bool {
                true $[for field in fields {
                    && self.$field == $other.$field
                }]
            }
        }
    }
}

// =============================================================================
// DERIVE DEFAULT
// =============================================================================

meta fn derive_default(type_name: Ident, field_defaults: List<(Ident, Expr)>) -> TokenStream {
    quote {
        implement Default for $type_name {
            fn default() -> Self {
                $type_name {
                    $[for (field_name, default_value) in field_defaults {
                        $field_name: $default_value,
                    }]
                }
            }
        }
    }
}

// =============================================================================
// DERIVE NEW (CONSTRUCTOR)
// =============================================================================

meta fn derive_new(type_name: Ident, fields: List<(Ident, Type)>) -> TokenStream {
    quote {
        implement $type_name {
            fn new($[for (field_name, field_type) in fields {
                $field_name: $field_type,
            }]) -> Self {
                $type_name {
                    $[for (field_name, _field_type) in fields {
                        $field_name: $field_name,
                    }]
                }
            }
        }
    }
}

// =============================================================================
// DERIVE GETTERS
// =============================================================================

meta fn derive_getters(type_name: Ident, fields: List<(Ident, Type)>) -> TokenStream {
    quote {
        implement $type_name {
            $[for (field_name, field_type) in fields {
                fn $field_name(&self) -> &$field_type {
                    &self.$field_name
                }
            }]
        }
    }
}

// =============================================================================
// VERIFICATION - Meta functions that test derive hygiene
// =============================================================================

// Test that derive_clone generates hygienic code
meta fn test_derive_clone_hygiene() -> Int {
    let type_name = ident("TestClone");
    let fields = [ident("field1"), ident("field2")];

    let _tokens = derive_clone(type_name, fields);
    1
}

// Test that derive_partial_eq generates hygienic code with gensym
meta fn test_derive_partial_eq_hygiene() -> Int {
    let type_name = ident("TestEq");
    let fields = [ident("x"), ident("y")];

    let _tokens = derive_partial_eq(type_name, fields);

    // The 'other' gensym should be unique
    1
}

// Test that derive_default generates hygienic code
meta fn test_derive_default_hygiene() -> Int {
    let type_name = ident("TestDefault");
    let field_defaults = [(ident("a"), quote { 0 }), (ident("b"), quote { 1 })];

    let _tokens = derive_default(type_name, field_defaults);
    1
}

// Test that derive_new generates hygienic code
meta fn test_derive_new_hygiene() -> Int {
    let type_name = ident("TestNew");
    let fields = [(ident("x"), ident("Int")), (ident("y"), ident("Int"))];

    let _tokens = derive_new(type_name, fields);
    1
}

// Test that derive_getters generates hygienic code
meta fn test_derive_getters_hygiene() -> Int {
    let type_name = ident("TestGetters");
    let fields = [(ident("value"), ident("Int"))];

    let _tokens = derive_getters(type_name, fields);
    1
}

// Combined test
meta fn test_all_derives() -> Int {
    test_derive_clone_hygiene() +
    test_derive_partial_eq_hygiene() +
    test_derive_default_hygiene() +
    test_derive_new_hygiene() +
    test_derive_getters_hygiene()
}

fn main() {
    // Runtime verification that meta tests passed
    // The meta functions are evaluated at compile time
}
