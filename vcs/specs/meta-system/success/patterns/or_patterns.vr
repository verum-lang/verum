// @test: meta-pass
// @level: L0
// @tier: 0
// @tags: meta, patterns, matching, or, alternatives
// @description: Test or pattern matching (alternatives) in meta functions

// =============================================================================
// BASIC OR PATTERNS
// =============================================================================

meta fn test_or_literals() -> Bool {
    match 5 {
        1 | 2 | 3 | 4 | 5 => true,
        _ => false,
    }
}

meta fn test_or_with_default() -> Text {
    match 7 {
        1 | 2 | 3 => "low",
        4 | 5 | 6 => "medium",
        _ => "high",
    }
}

meta fn test_or_single_match() -> Text {
    match 3 {
        1 | 3 | 5 | 7 | 9 => "odd",
        2 | 4 | 6 | 8 | 10 => "even",
        _ => "unknown",
    }
}

// =============================================================================
// OR PATTERNS WITH CHAR
// =============================================================================

meta fn test_or_char_vowels() -> Bool {
    match 'e' {
        'a' | 'e' | 'i' | 'o' | 'u' => true,
        'A' | 'E' | 'I' | 'O' | 'U' => true,
        _ => false,
    }
}

// =============================================================================
// OR PATTERNS WITH TEXT
// =============================================================================

meta fn test_or_text() -> Bool {
    match "yes" {
        "yes" | "y" | "true" | "1" => true,
        "no" | "n" | "false" | "0" => false,
        _ => false,
    }
}

// =============================================================================
// OR PATTERNS IN TUPLES
// =============================================================================

meta fn test_or_tuple_alternatives() -> Int {
    match (true, false) {
        (true, true) | (false, false) => 1,
        (true, false) | (false, true) => 2,
    }
}

// =============================================================================
// OR PATTERNS WITH VARIANTS
// =============================================================================

type Status is
    | Pending
    | Running
    | Success
    | Failure
    | Cancelled;

meta fn test_or_variant() -> Bool {
    let status = Success;
    match status {
        Success | Failure | Cancelled => true,
        Pending | Running => false,
    }
}

meta fn test_or_variant_categories() -> Text {
    let status = Running;
    match status {
        Pending | Running => "in progress",
        Success => "completed successfully",
        Failure | Cancelled => "not completed",
    }
}

// =============================================================================
// MAIN TEST FUNCTION
// =============================================================================

fn main() {
    // Basic or patterns
    @const assert(test_or_literals());
    @const assert_eq(test_or_with_default(), "high");
    @const assert_eq(test_or_single_match(), "odd");

    // Char or patterns
    @const assert(test_or_char_vowels());

    // Text or patterns
    @const assert(test_or_text());

    // Tuples with or patterns
    @const assert_eq(test_or_tuple_alternatives(), 2);

    // Variants with or patterns
    @const assert(test_or_variant());
    @const assert_eq(test_or_variant_categories(), "in progress");
}
