// @test: verify-pass
// @tier: 0
// @level: L2
// @tags: proof-stability, recursive, termination
// @timeout: 60000

/// Recursive function proofs - testing termination and well-foundedness.
/// These proofs verify that recursive functions terminate and produce correct results.

/// Test: Simple recursive factorial with termination measure
fn factorial(n: Int{>= 0}) -> Int
    decreases n
    ensures result >= 1
    ensures n == 0 implies result == 1
    ensures n == 1 implies result == 1
{
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

/// Test: Fibonacci with termination
fn fib(n: Int{>= 0}) -> Int
    decreases n
    ensures result >= 0
    ensures n <= 1 implies result == n
{
    if n <= 1 {
        n
    } else {
        fib(n - 1) + fib(n - 2)
    }
}

/// Test: Binary search with termination
fn binary_search(
    arr: List<Int>,
    target: Int,
    lo: Int,
    hi: Int
) -> Maybe<Int>
    requires lo >= 0
    requires hi <= len(arr)
    requires lo <= hi
    requires forall i in 0..(len(arr)-1) => arr[i] <= arr[i+1]  // sorted
    decreases hi - lo
    ensures result.is_some() implies arr[result.unwrap()] == target
{
    if lo >= hi {
        None
    } else {
        let mid = lo + (hi - lo) / 2;
        if arr[mid] == target {
            Some(mid)
        } else if arr[mid] < target {
            binary_search(arr, target, mid + 1, hi)
        } else {
            binary_search(arr, target, lo, mid)
        }
    }
}

/// Test: GCD with Euclidean algorithm
fn gcd(a: Int{>= 0}, b: Int{>= 0}) -> Int
    decreases a + b
    ensures result >= 0
    ensures a == 0 && b == 0 implies result == 0
    ensures b == 0 implies result == a
{
    if b == 0 {
        a
    } else {
        gcd(b, a % b)
    }
}

/// Test: Ackermann function (challenging termination)
fn ackermann(m: Int{>= 0}, n: Int{>= 0}) -> Int
    decreases m, n  // lexicographic
    ensures result > n
{
    if m == 0 {
        n + 1
    } else if n == 0 {
        ackermann(m - 1, 1)
    } else {
        ackermann(m - 1, ackermann(m, n - 1))
    }
}

/// Test: Tree traversal termination
type Tree is
    | Leaf(Int)
    | Node(Heap<Tree>, Heap<Tree>);

fn tree_sum(t: Tree) -> Int
    decreases t.size()
    ensures result >= 0 || t.has_negative()
{
    match t {
        Leaf(v) => v,
        Node(left, right) => tree_sum(*left) + tree_sum(*right),
    }
}

/// Test: List length with accumulator
fn list_length<T>(list: List<T>, acc: Int{>= 0}) -> Int
    decreases len(list)
    ensures result == acc + len(list)
    ensures result >= acc
{
    if len(list) == 0 {
        acc
    } else {
        list_length(list.tail(), acc + 1)
    }
}

/// Test: Mutual recursion termination
fn is_even(n: Int{>= 0}) -> Bool
    decreases n
{
    if n == 0 {
        true
    } else {
        is_odd(n - 1)
    }
}

fn is_odd(n: Int{>= 0}) -> Bool
    decreases n
{
    if n == 0 {
        false
    } else {
        is_even(n - 1)
    }
}

/// Test: Nested recursion
fn mccarthy91(n: Int) -> Int
    decreases 101 - n
    ensures n > 100 implies result == n - 10
    ensures n <= 100 implies result == 91
{
    if n > 100 {
        n - 10
    } else {
        mccarthy91(mccarthy91(n + 11))
    }
}

fn main() {
    assert(factorial(5) == 120);
    assert(fib(10) == 55);
    assert(gcd(48, 18) == 6);
    assert(is_even(4));
    assert(!is_odd(4));
    assert(mccarthy91(99) == 91);
    assert(mccarthy91(101) == 91);
}
