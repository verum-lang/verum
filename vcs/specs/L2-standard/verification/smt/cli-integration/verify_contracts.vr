// @test: run
// @level: L2
// @tier: 0
// @tags: smt, verification, contracts, precondition, postcondition, cli-integration
// @timeout: 15000
// @description: Contract verification patterns — function pre/post conditions, loop invariants

/// Safe division with non-zero divisor
fn safe_div(a: Int, b: Int) -> Int {
    a / b
}

/// Safe modulo with non-zero divisor
fn safe_mod(a: Int, b: Int) -> Int {
    a % b
}

/// Array-like bounded access precondition
fn bounded_value(index: Int, length: Int) -> Bool {
    index >= 0 && index < length
}

/// Power of two is always positive
fn power_of_two(n: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < n {
        result = result * 2;
        i = i + 1;
    }
    result
}

/// Midpoint computation avoids overflow
fn midpoint(low: Int, high: Int) -> Int {
    low + (high - low) / 2
}

/// Sign function trichotomy
fn sign(x: Int) -> Int {
    if x > 0 { 1 }
    else if x < 0 { -1 }
    else { 0 }
}

/// Ordering comparison
fn compare(a: Int, b: Int) -> Int {
    if a < b { -1 }
    else if a > b { 1 }
    else { 0 }
}

fn test_safe_div() -> Int {
    if safe_div(10, 3) != 3 { print("FAIL safe_div"); return 1; }
    if safe_div(9, 3) != 3 { print("FAIL safe_div 9/3"); return 1; }
    print("  safe_div: OK");
    0
}

fn test_safe_mod() -> Int {
    if safe_mod(10, 3) != 1 { print("FAIL safe_mod"); return 1; }
    if safe_mod(9, 3) != 0 { print("FAIL safe_mod 9%3"); return 1; }
    print("  safe_mod: OK");
    0
}

fn test_bounded_value() -> Int {
    if !bounded_value(2, 5) { print("FAIL bounded in"); return 1; }
    if bounded_value(5, 5) { print("FAIL bounded out"); return 1; }
    if bounded_value(-1, 5) { print("FAIL bounded neg"); return 1; }
    print("  bounded_value: OK");
    0
}

fn test_power_of_two() -> Int {
    if power_of_two(0) != 1 { print("FAIL pow2(0)"); return 1; }
    if power_of_two(1) != 2 { print("FAIL pow2(1)"); return 1; }
    if power_of_two(10) != 1024 { print("FAIL pow2(10)"); return 1; }
    print("  power_of_two: OK");
    0
}

fn test_midpoint() -> Int {
    if midpoint(0, 100) != 50 { print("FAIL midpoint"); return 1; }
    if midpoint(10, 20) != 15 { print("FAIL midpoint 10-20"); return 1; }
    print("  midpoint: OK");
    0
}

fn test_sign() -> Int {
    if sign(42) != 1 { print("FAIL sign pos"); return 1; }
    if sign(-42) != -1 { print("FAIL sign neg"); return 1; }
    if sign(0) != 0 { print("FAIL sign zero"); return 1; }
    print("  sign: OK");
    0
}

fn test_compare() -> Int {
    if compare(3, 7) != -1 { print("FAIL compare lt"); return 1; }
    if compare(7, 3) != 1 { print("FAIL compare gt"); return 1; }
    if compare(5, 5) != 0 { print("FAIL compare eq"); return 1; }
    print("  compare: OK");
    0
}

fn main() -> Int {
    let mut failures = 0;
    failures = failures + test_safe_div();
    failures = failures + test_safe_mod();
    failures = failures + test_bounded_value();
    failures = failures + test_power_of_two();
    failures = failures + test_midpoint();
    failures = failures + test_sign();
    failures = failures + test_compare();
    if failures == 0 {
        print("All verify_contracts tests passed");
    }
    failures
}
