// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: async, await, futures
// @timeout: 10000
// @expect: pass

async fn fetch_value(id: Int) -> Int {
    id * 10
}

async fn add_async(a: Int, b: Int) -> Int {
    a + b
}

async fn compute() -> Int {
    let a = fetch_value(3).await;
    let b = fetch_value(4).await;
    add_async(a, b).await
}

async fn chain() -> Int {
    let x = fetch_value(1).await;
    let y = fetch_value(x).await;
    y
}

fn main() {
    // Basic async/await
    let a = fetch_value(5).await;
    assert_eq(a, 50);

    // Async composition
    let result = compute().await;
    assert_eq(result, 70);

    // Sequential chaining
    let chained = chain().await;
    assert_eq(chained, 100);

    // Inline async call
    let sum = add_async(10, 20).await;
    assert_eq(sum, 30);
}
