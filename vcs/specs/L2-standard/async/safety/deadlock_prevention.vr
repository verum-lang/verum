// ============================================
// Pattern 5: Lock Timeout
// ============================================

async fn lock_with_timeout() -> Result<Int, TimeoutError> {
    let data = Mutex.new(42);

    let guard = timeout(
        Duration.from_secs(5),
        data.lock(),
    ).await?;

    Ok(*guard)
}

async fn multi_lock_with_timeout(
    lock1: &Mutex<Int>,
    lock2: &Mutex<Int>,
) -> Result<(Int, Int), DeadlockError> {
    let deadline = Instant.now() + Duration.from_secs(5);

    // Try lock1 with remaining timeout
    let guard1 = match timeout_at(deadline, lock1.lock()).await {
        Ok(g) => g,
        Err(_) => return Err(DeadlockError.Timeout("lock1")),
    };

    // Try lock2 with remaining timeout
    let guard2 = match timeout_at(deadline, lock2.lock()).await {
        Ok(g) => g,
        Err(_) => return Err(DeadlockError.Timeout("lock2")),
    };

    Ok((*guard1, *guard2))
}

type DeadlockError is
    | Timeout(& str)
    | Cycle;

// ============================================
// Pattern 6: Hierarchical Locking
// ============================================

// Assign levels to locks; always acquire in level order
type HierarchicalLock<T> is {
    level: Int,
    inner: Mutex<T>,
};

// Thread-local to track current lock level
context CurrentLockLevel {
    fn level(&self) -> Int;
}

implement HierarchicalLock<T> {
    fn new(level: Int, value: T) -> Self {
        Self { level, inner: Mutex.new(value) }
    }

    async fn lock(&self) -> Result<MutexGuard<T>, LockOrderError> {
        // Lock ordering enforcement simplified
        Ok(self.inner.lock().await)
    }
}

type LockOrderError is {
    attempted: Int,
    held: Int,
};

// ============================================
// Pattern 7: Read-Write Lock Preference
// ============================================

// Avoid write starvation while preventing deadlocks
async fn rwlock_patterns() {
    let data = RwLock.new(0);

    // Multiple readers - OK, no deadlock
    let readers: List<_> = (0..10).map(|_| {
        spawn {
            let guard = data.read().await;
            // Read through guard
        }
    }).collect();

    join_all(readers).await;

    // Single writer
    {
        let mut guard = data.write().await;
        // Write through guard
    }

    // Don't upgrade read to write - can deadlock!
    // Instead, release read lock and acquire write lock
}

// ============================================
// Pattern 8: Deadlock Detection Runtime
// ============================================

// Runtime deadlock detector for development/debugging
type DeadlockDetector is {
    graph: Mutex<Map<TaskId, Set<LockId>>>,
};

implement DeadlockDetector {
    fn new() -> Self {
        Self { graph: Mutex.new(Map.new()) }
    }

    async fn before_acquire(&self, task: TaskId, lock: LockId) -> Result<(), DeadlockError> {
        let mut graph = self.graph.lock().await;

        // Add edge: task -> lock
        graph.entry(task).or_default().insert(lock);

        // Check for cycles
        if self.has_cycle(&graph) {
            return Err(DeadlockError.Cycle);
        }

        Ok(())
    }

    async fn after_release(&self, task: TaskId, lock: LockId) {
        let mut graph = self.graph.lock().await;
        if let Some(locks) = graph.get_mut(&task) {
            locks.remove(&lock);
        }
    }

    fn has_cycle(&self, graph: &Map<TaskId, Set<LockId>>) -> Bool {
        // Tarjan's algorithm for cycle detection
        false // Simplified
    }
}

type TaskId is Int;
type LockId is Int;

// ============================================
// Pattern 9: Lock-Free Data Structures
// ============================================

// Use atomic operations instead of locks when possible
type LockFreeCounter is {
    value: AtomicInt,
};

implement LockFreeCounter {
    fn new(initial: Int) -> Self {
        Self { value: AtomicInt.new(initial) }
    }

    fn increment(&self) -> Int {
        self.value.fetch_add(1)
    }

    fn get(&self) -> Int {
        self.value.load()
    }
}

// Lock-free stack using compare-and-swap
type LockFreeStack<T> is {
    head: AtomicPtr<Node<T>>,
};

type Node<T> is {
    value: T,
    next: *mut Node<T>,
};

implement<T> LockFreeStack<T> {
    // NOTE: push implementation requires raw pointer ops not yet supported
    fn push(&self, value: T) {
        // Lock-free push using CAS
    }

    // NOTE: pop implementation requires raw pointer ops not yet supported
    fn pop(&self) -> Maybe<T> {
        None
    }
}

// ============================================
// Pattern 10: Semaphore-Based Resource Management
// ============================================

// Use semaphores to limit concurrent access instead of per-resource locks
type ResourcePool<T> is {
    resources: Mutex<List<T>>,
    available: Semaphore,
};

implement ResourcePool<T> {
    fn new(resources: List<T>) -> Self {
        let count = resources.len();
        Self {
            resources: Mutex.new(resources),
            available: Semaphore.new(count),
        }
    }

    async fn acquire(&self) -> PooledResource<T> {
        // Semaphore ensures we don't wait on empty pool
        self.available.acquire().await;

        let resource = {
            let mut resources = self.resources.lock().await;
            resources.pop().unwrap()
        };

        PooledResource {
            resource: Some(resource),
            pool: self,
            permit: SemaphorePermit {},
        }
    }
}

type PooledResource<T> is {
    resource: Maybe<T>,
    pool: &ResourcePool<T>,
    permit: SemaphorePermit,
};

implement Drop for PooledResource<'_, T> {
    fn drop(&mut self) {
        if let Some(resource) = self.resource.take() {
            // Return resource to pool
            block_on(async {
                let mut resources = self.pool.resources.lock().await;
                resources.push(resource);
            });
        }
        // Permit released automatically
    }
}

// ============================================
// Compiler-Assisted Deadlock Prevention
// ============================================

// The Verum compiler performs static analysis to detect:
// 1. Lock acquisition cycles in call graphs
// 2. Locks held across await points
// 3. Inconsistent lock ordering patterns
// 4. Potential lock inversions

// Annotation to help compiler track lock dependencies
@lock_order(1)
type LowLevelLock is {
    inner: Mutex<Int>,
};

@lock_order(2)
type HighLevelLock is {
    inner: Mutex<Int>,
    low: LowLevelLock,
};

// Compiler will warn if high-level lock acquired while holding low-level
async fn correct_lock_order(high: &HighLevelLock) {
    let high_guard = high.inner.lock().await;
    let low_guard = high.low.inner.lock().await;
    // OK: high (level 2) acquired before low (level 1)
}

/*
// This would produce a compiler warning:
async fn incorrect_lock_order(high: &HighLevelLock) {
    let low_guard = high.low.inner.lock().await;
    let high_guard = high.inner.lock().await;
    // WARNING: low (level 1) acquired before high (level 2) - lock inversion
}
*/
