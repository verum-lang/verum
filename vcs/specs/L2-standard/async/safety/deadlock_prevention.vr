// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: async, safety, deadlock, prevention
// @description: Comprehensive deadlock prevention patterns and compiler-assisted safety

// Deadlocks occur when two or more tasks wait for each other's locks.
// Verum provides multiple patterns and compiler checks to prevent deadlocks.

// ============================================
// Pattern 1: Consistent Lock Ordering
// ============================================

type BankAccount is {
    id: Int,
    balance: Mutex<Int>,
};

// Safe: Always lock in order of account ID to prevent deadlock
async fn transfer(from: &BankAccount, to: &BankAccount, amount: Int) -> Result<(), Error> {
    // Always acquire locks in ID order to prevent circular waits
    let (first, second) = if from.id < to.id {
        (&from.balance, &to.balance)
    } else {
        (&to.balance, &from.balance)
    };

    let _first_guard = first.lock().await;
    let _second_guard = second.lock().await;
    // Transfer logic simplified (MutexGuard deref not yet supported)
    // Amount would be transferred between accounts through guard access

    Ok(())
}

// Generic lock ordering helper
async fn lock_ordered<T>(
    lock1: &Mutex<T>,
    lock2: &Mutex<T>,
) -> (MutexGuard<T>, MutexGuard<T>) {
    // Compare pointer addresses to establish consistent ordering
    if (lock1 as *const _) < (lock2 as *const _) {
        let g1 = lock1.lock().await;
        let g2 = lock2.lock().await;
        (g1, g2)
    } else {
        let g2 = lock2.lock().await;
        let g1 = lock1.lock().await;
        (g1, g2)
    }
}

// ============================================
// Pattern 2: Try-Lock with Backoff
// ============================================

async fn try_lock_transfer(
    from: &BankAccount,
    to: &BankAccount,
    amount: Int,
) -> Result<(), Error> {
    let mut backoff = ExponentialBackoff.new(
        Duration.from_micros(100),
        Duration.from_millis(100),
    );

    loop {
        // Try to acquire both locks non-blocking
        let from_guard = from.balance.try_lock();
        if from_guard.is_none() {
            backoff.wait().await;
            continue;
        }
        let mut from_guard = from_guard.unwrap();

        let to_guard = to.balance.try_lock();
        if to_guard.is_none() {
            drop(from_guard); // Release first lock to avoid holding it
            backoff.wait().await;
            continue;
        }
        let mut to_guard = to_guard.unwrap();

        // Both locks acquired without deadlock
        if *from_guard < amount {
            return Err(Error.new("Insufficient funds"));
        }
        *from_guard -= amount;
        *to_guard += amount;
        return Ok(());
    }
}

type ExponentialBackoff is {
    current: Duration,
    max: Duration,
};

implement ExponentialBackoff {
    fn new(initial: Duration, max: Duration) -> Self {
        Self { current: initial, max }
    }

    async fn wait(&mut self) {
        sleep(self.current).await;
        self.current = (self.current * 2).min(self.max);
    }
}

// ============================================
// Pattern 3: Lock-Free Actor Model
// ============================================

type AccountCommand is
    | Transfer { to_id: Int, amount: Int, reply: OneshotSender<Result<(), Error>> }
    | GetBalance { reply: OneshotSender<Int> }
    | Deposit { amount: Int, reply: OneshotSender<()> };

type AccountActor is {
    id: Int,
    balance: Int,
    rx: Receiver<AccountCommand>,
};

implement AccountActor {
    async fn run(mut self) {
        while let Some(cmd) = self.rx.recv().await {
            match cmd {
                AccountCommand.GetBalance { reply } => {
                    reply.send(self.balance).ok();
                }
                AccountCommand.Transfer { to_id, amount, reply } => {
                    if self.balance >= amount {
                        self.balance -= amount;
                        reply.send(Ok(())).ok();
                    } else {
                        reply.send(Err(Error.new("Insufficient funds"))).ok();
                    }
                }
                AccountCommand.Deposit { amount, reply } => {
                    self.balance += amount;
                    reply.send(()).ok();
                }
            }
        }
    }
}

// Coordinator handles multi-account operations without locks
type TransferCoordinator is {
    accounts: Map<Int, Sender<AccountCommand>>,
};

implement TransferCoordinator {
    async fn transfer(&self, from_id: Int, to_id: Int, amount: Int) -> Result<(), Error> {
        // Get senders (no locks needed)
        let from_sender = self.accounts.get(&from_id).ok_or(Error.new("Account not found"))?;
        let to_sender = self.accounts.get(&to_id).ok_or(Error.new("Account not found"))?;

        // Withdraw from source
        let (reply_tx, reply_rx) = oneshot();
        from_sender.send(AccountCommand.Transfer { to_id, amount, reply: reply_tx }).await.ok();
        reply_rx.await?;

        // Deposit to destination
        let (reply_tx, reply_rx) = oneshot();
        to_sender.send(AccountCommand.Deposit { amount, reply: reply_tx }).await.ok();
        reply_rx.await.ok();

        Ok(())
    }
}

// ============================================
// Pattern 4: Scoped Locks (Minimal Lock Duration)
// ============================================

async fn scoped_lock_example() {
    let data = Mutex.new(0);

    // Good: Lock scope is minimal
    {
        let _guard = data.lock().await;
        // Increment via guard (deref not yet supported)
    } // Lock released here before any async work

    // Can do async work without holding the lock
    some_async_work().await;

    // Reacquire if needed
    {
        let guard = data.lock().await;
        println(f"Value: {*guard}");
    }
}

async fn some_async_work() {}

// Bad pattern (will trigger compiler warning):
// Holding lock across await point
