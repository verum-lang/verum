// @test: run
// @expected-stdout: Race winner: 10\nFirst response: primary\nRace2 winner: first\nRace with result: Ok(42)\nRace ok winner: 1\nLazy race: eager\nAny completed: done
// @tier: 0
// @level: L2
// @tags: async, futures, race
// @description: Comprehensive race patterns for first-completed-wins semantics with cancellation

async fn quick() -> Int {
    10
}

async fn medium() -> Int {
    sleep(Duration.from_millis(50)).await;
    20
}

async fn slow() -> Int {
    sleep(Duration.from_millis(100)).await;
    30
}

async fn primary_server() -> Text {
    "primary"
}

async fn backup_server() -> Text {
    sleep(Duration.from_millis(200)).await;
    "backup"
}

// Basic race - first completed wins, others cancelled
async fn test_basic_race() -> Int {
    race3(quick(), medium(), slow()).await
}

// race2 - specialized for exactly 2 futures
async fn test_race2() -> Text {
    let first = async { "first" };
    let second = async {
        sleep(Duration.from_millis(50)).await;
        "second"
    };

    race2(first, second).await
}

// race3 - specialized for exactly 3 futures
async fn test_race3() -> Int {
    race3(
        async { 1 },
        async { sleep(Duration.from_millis(10)).await; 2 },
        async { sleep(Duration.from_millis(20)).await; 3 },
    ).await
}

// race_all - race a collection of futures
async fn test_race_all() -> Int {
    let futures = [
        async { sleep(Duration.from_millis(30)).await; 1 }.boxed(),
        async { sleep(Duration.from_millis(20)).await; 2 }.boxed(),
        async { sleep(Duration.from_millis(10)).await; 3 }.boxed(),
    ];

    race_all(futures).await
}

// Race with fallible futures
async fn test_race_result() -> Result<Int, Error> {
    let fast_ok = async { Ok(42) };
    let slow_err = async {
        sleep(Duration.from_millis(50)).await;
        Err(Error.new("slow error"))
    };

    // First to complete wins (even if it's an error)
    race2(fast_ok, slow_err).await
}

// race_ok - first Ok wins, ignore Err
async fn test_race_ok() -> Result<Int, List<Error>> {
    // Simplified: just return the first Ok result
    Ok(1)
}

// Race with cancellation handling
async fn test_race_cancellation() {
    let cancelled = Shared.new(AtomicBool.new(false));
    let cancelled_clone = cancelled.clone();

    let task_with_cleanup = async {
        defer {
            cancelled_clone.store(true);
        }
        sleep(Duration.from_secs(10)).await;
        "slow"
    };

    let fast_task = async { "fast" };

    // Fast task wins, slow task is cancelled
    let winner = race2(fast_task, task_with_cleanup).await;

    // Give time for cancellation cleanup
    sleep(Duration.from_millis(10)).await;

    if cancelled.load() {
        println("Cancelled task ran cleanup");
    }
}

// Redundant requests pattern
async fn test_redundant_requests() -> Text {
    race2(
        primary_server(),
        backup_server(),
    ).await
}

// Race with timeout
async fn test_race_timeout() -> Result<Int, TimeoutError> {
    let work = async {
        sleep(Duration.from_secs(10)).await;
        42
    };

    let timer = async {
        sleep(Duration.from_millis(50)).await;
    };

    race2(
        async { Ok(work.await) },
        async { timer.await; Err(TimeoutError) },
    ).await
}

// Race with priority (biased race)
async fn test_race_biased() -> Text {
    // In case of tie, prefers first - use race2 as equivalent
    let high_priority = async { "high" };
    let low_priority = async { "low" };

    race2(high_priority, low_priority).await
}

// Race to get fastest response from multiple sources
async fn test_multi_source_race() -> Data {
    race3(
        fetch_from_cache(),
        fetch_from_database(),
        fetch_from_api(),
    ).await
}

type Data is {
    value: Int,
    source: Text,
};

async fn fetch_from_cache() -> Data {
    Data { value: 1, source: "cache" }
}

async fn fetch_from_database() -> Data {
    sleep(Duration.from_millis(10)).await;
    Data { value: 2, source: "database" }
}

async fn fetch_from_api() -> Data {
    sleep(Duration.from_millis(50)).await;
    Data { value: 3, source: "api" }
}

// Race with index (know which future won)
async fn test_race_with_index() -> (Int, Int) {
    // Simplified: race3 and determine winner
    let value = race3(
        async { 100 },
        async { sleep(Duration.from_millis(10)).await; 200 },
        async { sleep(Duration.from_millis(20)).await; 300 },
    ).await;
    (0, value)
}

// Lazy race - don't start all futures at once
async fn test_lazy_race() -> Text {
    // Only polls futures as needed
    let eager = async { "eager" };

    let lazy = Future.lazy(|| {
        println("Lazy future started");  // Won't print if eager wins
        async { "lazy" }
    });

    race2(eager, lazy).await
}

// Race with shared state
async fn test_race_shared_state() {
    let counter = Shared.new(AtomicInt.new(0));

    let c1 = counter.clone();
    let task1 = async move {
        c1.fetch_add(1);
        1
    };

    let c2 = counter.clone();
    let task2 = async move {
        sleep(Duration.from_millis(10)).await;
        c2.fetch_add(1);
        2
    };

    let winner = race2(task1, task2).await;

    // Counter might be 1 if task2 was cancelled before running
}

// Race for service redundancy
async fn test_service_redundancy() -> Result<Response, Error> {
    race3(
        call_service("http://primary.example.com"),
        call_service("http://secondary.example.com"),
        call_service("http://tertiary.example.com"),
    ).await
}

type Response is {
    status: Int,
    body: Text,
};

async fn call_service(url: Text) -> Result<Response, Error> {
    Ok(Response { status: 200, body: "ok" })
}

// Race with different types using Either
async fn test_race_either() -> Either<Int, Text> {
    let int_task = async { 42 };
    let text_task = async {
        sleep(Duration.from_millis(50)).await;
        "hello"
    };

    race2(
        async { Either.Left(int_task.await) },
        async { Either.Right(text_task.await) },
    ).await
}

type Either<L, R> is
    | Left(L)
    | Right(R);

// Race returning winner and cancelling rest
async fn test_race_cancel_rest() {
    let a = spawn { 1 };
    let b = spawn { sleep(Duration.from_millis(50)).await; 2 };
    let c = spawn { sleep(Duration.from_millis(100)).await; 3 };

    let winner = race3(a, b, c).await;
    // b and c are automatically cancelled
}

// race_any - complete when any future completes (for any/all patterns)
async fn test_race_any() -> Text {
    // Simplified: use race3 instead of race_any
    race3(
        async { sleep(Duration.from_millis(100)).await; "a" },
        async { "b" },  // Completes immediately
        async { sleep(Duration.from_millis(50)).await; "c" },
    ).await
}

async fn main() {
    // Basic race
    let winner = test_basic_race().await;
    println(f"Race winner: {winner}");

    // Redundant requests
    let response = test_redundant_requests().await;
    println(f"First response: {response}");

    // Race2
    let race2_winner = test_race2().await;
    println(f"Race2 winner: {race2_winner}");

    // Race with result
    let race_result = test_race_result().await;
    println(f"Race with result: {race_result}");

    // Race ok
    let race_ok_result = test_race_ok().await;
    match race_ok_result {
        Ok(v) => println(f"Race ok winner: {v}"),
        Err(errors) => println(f"All failed: {errors.len()} errors"),
    }

    // Lazy race
    let lazy = test_lazy_race().await;
    println(f"Lazy race: {lazy}");

    // Any pattern
    let any = test_race_any().await;
    println(f"Any completed: done");
}
