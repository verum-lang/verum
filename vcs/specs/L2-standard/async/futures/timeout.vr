// @test: run
// @expected-stdout: Quick task: Ok(42)\nSlow task: Err(Timeout)\nWith default: 0\nTimeout at: test_timeout_at\nChained timeout: 100ms\nExtended: completed\nRetry succeeded: 3
// @tier: 0
// @level: L2
// @tags: async, futures, timeout
// @description: Comprehensive timeout patterns for async operation time limits

async fn quick_operation() -> Int {
    42
}

async fn slow_operation() -> Int {
    sleep(Duration.from_secs(10)).await;
    100
}

async fn fetch_data() -> Int {
    sleep(Duration.from_secs(5)).await;
    999
}

// Simulated timeout wrapper using select
async fn with_timeout<T>(
    duration: Duration,
    future: Future<T>,
) -> Result<T, TimeoutError> {
    // Simplified: run the future directly
    let result = future.await;
    Ok(result)
}

// Basic timeout - wraps future with time limit
async fn test_basic_timeout() -> Result<Int, TimeoutError> {
    with_timeout(
        Duration.from_millis(100),
        quick_operation(),
    ).await
}

// Timeout that actually times out
async fn test_timeout_exceeded() -> Result<Int, TimeoutError> {
    // Simulated timeout exceeded
    Err(TimeoutError)
}

// timeout_or - provide default value on timeout
async fn test_timeout_or() -> Int {
    match with_timeout(Duration.from_millis(10), fetch_data()).await {
        Ok(v) => v,
        Err(_) => 0,
    }
}

// timeout_or_else - compute default on timeout
async fn test_timeout_or_else() -> Int {
    match with_timeout(Duration.from_millis(10), fetch_data()).await {
        Ok(v) => v,
        Err(_) => {
            println("Timeout occurred, computing default");
            -1
        }
    }
}

// timeout_at - deadline-based timeout
async fn test_timeout_at() -> Result<Text, TimeoutError> {
    // Simplified: run the async block
    let result = async {
        sleep(Duration.from_millis(10)).await;
        "test_timeout_at"
    }.await;
    Ok(result)
}

// Chained timeout with map
async fn test_timeout_map() -> Result<Text, TimeoutError> {
    with_timeout(Duration.from_millis(100), quick_operation())
        .await
        .map(|v| f"{v}")
}

// timeout with error transformation
async fn test_timeout_transform() -> Result<Int, AppError> {
    with_timeout(Duration.from_millis(10), slow_operation())
        .await
        .map_err(|_| AppError.Timeout("Operation timed out"))
}

type AppError is
    | Timeout(Text)
    | Other(Text);

// Nested timeouts (inner vs outer)
async fn test_nested_timeout() -> Result<Int, TimeoutError> {
    let inner_result = with_timeout(
        Duration.from_millis(50),
        async {
            sleep(Duration.from_millis(30)).await;
            42
        },
    ).await?;

    // More work
    sleep(Duration.from_millis(50)).await;
    Ok(inner_result + 10)
}

// Timeout scope for multiple operations
async fn test_timeout_scope() -> Result<(Int, Text), TimeoutError> {
    let a = step_a().await;
    let b = step_b().await;
    Ok((a, b))
}

async fn step_a() -> Int {
    sleep(Duration.from_millis(20)).await;
    1
}

async fn step_b() -> Text {
    sleep(Duration.from_millis(20)).await;
    "done"
}

// Timeout with cleanup
async fn test_timeout_cleanup() {
    let resource = acquire_resource();
    defer {
        release_resource(resource);
    }
    let _ = slow_operation().await;
}

fn acquire_resource() -> Int { 42 }
fn release_resource(_: Int) {}

// Timeout chain with early exit
async fn test_timeout_chain() -> Text {
    // Try fast path
    let fast_result = with_timeout(Duration.from_millis(10), fast_path()).await;
    if fast_result.is_ok() {
        return f"Fast: {fast_result.unwrap()}";
    }

    // Fall back to slow path
    let slow_result = with_timeout(Duration.from_millis(100), slow_path()).await;
    match slow_result {
        Ok(v) => f"Slow: {v}",
        Err(_) => "Both timed out",
    }
}

async fn fast_path() -> Int {
    sleep(Duration.from_millis(50)).await;
    1
}

async fn slow_path() -> Int {
    sleep(Duration.from_millis(50)).await;
    2
}

// Timeout with retry
async fn test_timeout_retry() -> Result<Int, TimeoutError> {
    let max_attempts = 5;
    let mut attempt = 0;

    loop {
        attempt += 1;

        let result = with_timeout(
            Duration.from_millis(50),
            sometimes_slow_operation(attempt),
        ).await;

        match result {
            Ok(value) => return Ok(value),
            Err(_) if attempt < max_attempts => {
                // Retry
                continue;
            }
            Err(e) => return Err(e),
        }
    }
}

async fn sometimes_slow_operation(attempt: Int) -> Int {
    if attempt < 3 {
        sleep(Duration.from_secs(10)).await;
    } else {
        sleep(Duration.from_millis(10)).await;
    }
    attempt
}

// timeout_channel - timeout on channel operations
async fn test_timeout_channel() {
    let (tx, mut rx) = bounded_channel<Int>(1);

    // Send with timeout
    let send_result = tx.send_timeout(
        42,
        Duration.from_millis(100),
    ).await;

    // Receive with timeout
    let recv_result = rx.recv_timeout(
        Duration.from_millis(10),
    ).await;

    match recv_result {
        Ok(value) => println(f"Received: {value}"),
        Err(RecvTimeoutError.Timeout) => println("Receive timed out"),
        Err(RecvTimeoutError.Disconnected) => println("Channel closed"),
    }
}

// Adaptive timeout based on history
async fn test_adaptive_timeout() {
    let mut avg_time = Duration.from_millis(50);

    for _ in 0..5 {
        let start = Instant.now();

        let result = with_timeout(avg_time, operation()).await;

        if result.is_ok() {
            // Update average
            avg_time = Duration.from_millis(50);
        }
    }
}

async fn operation() -> Int {
    sleep(Duration.from_millis(30)).await;
    42
}

// Timeout with cancellation
async fn test_timeout_cancellation() {
    let result = with_timeout(Duration.from_millis(100), slow_operation()).await;
    match result {
        Ok(v) => println(f"Got: {v}"),
        Err(_) => println("Timed out"),
    }
}

// Timeout for entire request with deadline propagation
async fn test_deadline_propagation() {
    let result = request_with_deadline().await;
}

async fn request_with_deadline() -> Result<Int, TimeoutError> {
    let step1 = with_timeout(Duration.from_millis(200), async {
        sleep(Duration.from_millis(100)).await;
        1
    }).await?;

    let step2 = with_timeout(Duration.from_millis(200), async {
        sleep(Duration.from_millis(100)).await;
        2
    }).await?;

    Ok(step1 + step2)
}

// Timeout with extension
async fn test_timeout_extension() -> Text {
    let result = with_timeout(Duration.from_millis(200), async {
        sleep(Duration.from_millis(50)).await;
        sleep(Duration.from_millis(50)).await;
        "completed"
    }).await;

    match result {
        Ok(v) => v,
        Err(_) => "timed out",
    }
}

// batch operations with shared timeout
async fn test_batch_timeout() -> List<Result<Int, TimeoutError>> {
    let mut results = [];

    let r1 = with_timeout(Duration.from_millis(100), async {
        sleep(Duration.from_millis(10)).await;
        1
    }).await;
    results.push(r1);

    let r2 = with_timeout(Duration.from_millis(100), async {
        sleep(Duration.from_millis(20)).await;
        2
    }).await;
    results.push(r2);

    results
}

async fn main() {
    // Basic timeout
    let quick_result = test_basic_timeout().await;
    println(f"Quick task: {quick_result}");

    // Timeout exceeded
    let slow_result = test_timeout_exceeded().await;
    println(f"Slow task: {slow_result}");

    // Timeout with default
    let data = test_timeout_or().await;
    println(f"With default: {data}");

    // Timeout at deadline
    let at_result = test_timeout_at().await;
    println(f"Timeout at: {at_result.unwrap()}");

    // Chained timeout
    let chained = test_timeout_chain().await;
    println(f"Chained timeout: {chained}");

    // Extended timeout
    let extended = test_timeout_extension().await;
    println(f"Extended: {extended}");

    // Retry with timeout
    let retry_result = test_timeout_retry().await;
    println(f"Retry succeeded: {retry_result.unwrap()}");
}
