// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: async, channels, watch, broadcast, pattern
// @timeout: 10000
// @expect: pass
// @description: Watch channel pattern — use broadcast_channel as substrate

// Reshaped 2026-04-20 from a legacy `runtime.create_watch` stub. A true
// `WatchChannel<T>` with "subscribe sees current value" semantics is future
// work (broadcast.vr Phase 2 follow-up); this test exercises the simpler
// broadcast-based notification pattern.

mount core.async.broadcast.{
    BroadcastSender, BroadcastReceiver, RecvError,
    broadcast_channel,
};

// Shape tests — broadcast with capacity=1 approximates "latest value".
fn test_watch_like_shape() {
    let (tx, rx): (BroadcastSender<Int>, BroadcastReceiver<Int>) = broadcast_channel(1);
    let _ = tx.send(42);
    let _rx2 = tx.subscribe();
    let _ = rx;
}

// Config-hot-reload pattern: subscriber-fanout on configuration change.
fn test_config_hot_reload_pattern() {
    let (tx, rx) = broadcast_channel::<Text>(8);
    let _consumer_a = tx.subscribe();
    let _consumer_b = tx.subscribe();
    let _: Int = tx.receiver_count();   // 3 — initial rx + two subscribes

    let _ = tx.send("new-config".into());
    let _ = rx;
}

fn main() {
    test_watch_like_shape();
    test_config_hot_reload_pattern();
}
