// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: async, channels, mpsc
// @timeout: 10000
// @expect: pass
// @description: MPSC channel — uses stdlib core.async.channel

// Reshaped 2026-04-20 from a legacy `@test: run` with `runtime.create_channel`
// stub (no such intrinsic) into a typecheck-pass against the real stdlib API.

mount core.async.channel.{
    Sender, Receiver, SendError, TrySendError, TryRecvError,
    channel, bounded, bounded_channel, unbounded_channel,
};

fn test_unbounded_api() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = channel();
    let _tx2 = tx.clone();
    let _c: Bool = tx.is_closed();
    let _d: Bool = tx.is_disconnected();
    let _e: Bool = rx.is_empty();
    let _l: Int = rx.len();
    let _cap: Maybe<Int> = tx.capacity();
}

fn test_bounded_api() {
    let (tx, rx): (Sender<Int>, Receiver<Int>) = bounded(8);
    let _: Maybe<Int> = tx.capacity();

    // Fill up
    let _ = tx.try_send(1);
    let _ = tx.try_send(2);

    // Drain
    let _: Result<Int, TryRecvError> = rx.try_recv();
}

fn test_unbounded_alias() {
    let (tx, rx) = unbounded_channel::<Text>();
    let _ = tx;
    let _ = rx;
}

fn test_bounded_alias() {
    let (tx, rx) = bounded_channel::<Bool>(4);
    let _ = tx;
    let _ = rx;
}

fn main() {
    test_unbounded_api();
    test_bounded_api();
    test_unbounded_alias();
    test_bounded_alias();
}
