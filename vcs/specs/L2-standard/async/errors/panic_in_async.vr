// @test: run
// @expected-stdout: Task started\nCaught panic: task panicked\nRecovery complete\nNested panic caught\nAll handlers executed
// @tier: 0
// @level: L2
// @tags: async, errors, panic, recovery
// @description: Panic handling in async tasks

// Basic panic in spawned task
async fn panicking_task() {
    println("Task started");
    panic("task panicked");
}

// Test basic panic handling
async fn test_basic_panic_handling() {
    let handle = spawn { panicking_task().await; };
    match handle.await {
        Err(e) => println(f"Caught panic: {e}"),
        Ok(_) => println("No panic"),
    }
}

// Recovery after catching panic
async fn test_recovery() {
    let handle = spawn { panic("recoverable"); };
    match handle.await {
        Err(_) => println("Recovery complete"),
        Ok(_) => {}
    }
}

// Nested panic handling (simplified to avoid deep type inference)
async fn test_nested_panic() {
    let handle = spawn {
        panic("inner panic");
    };
    match handle.await {
        Err(_) => println("Nested panic caught"),
        Ok(_) => {}
    }
}

// Multiple concurrent panics
async fn test_multiple_panics() {
    let h1 = spawn { panic("panic 1"); };
    let h2 = spawn { panic("panic 2"); };
    let h3 = spawn { 42 };

    let r1 = h1.await;
    let r2 = h2.await;
    let r3 = h3.await;

    assert(r1.is_err());
    assert(r2.is_err());
    assert(r3.is_ok());
    println("All handlers executed");
}

async fn main() {
    test_basic_panic_handling().await;
    test_recovery().await;
    test_nested_panic().await;
    test_multiple_panics().await;
}
