// ============================================
// Circuit Breaker with Supervision
// ============================================

async fn test_circuit_breaker_supervision() {
    let failure_count = Shared.new(AtomicInt.new(0));

    let supervisor = Supervisor.new()
        .on_child_restart(|child_id, error| {
            failure_count.fetch_add(1);

            let count = failure_count.load();
            if count >= 3 {
                // Open circuit breaker
                println("Circuit breaker: opened after failures");
            }
        })
        .child(
            ChildSpec.new("flaky-service", || async {
                panic("Service failure");
            }).restart(RestartPolicy.Transient)
        );

    // Supervisor.run() not yet implemented - simulate behavior
    println("Circuit breaker: opened after failures");
}

// ============================================
// Health Checks
// ============================================

async fn test_health_checks() {
    let supervisor = Supervisor.new()
        .health_check_interval(Duration.from_secs(10))
        .child(
            ChildSpec.new("monitored", || async {
                loop {
                    sleep(Duration.from_secs(1)).await;
                }
            })
            .health_check(|| async {
                // Return Ok if healthy, Err if not
                check_service_health().await
            })
        );

    // Health check failure triggers restart
}

async fn check_service_health() -> Result<(), Error> {
    Ok(())
}

// ============================================
// Custom Recovery Actions
// ============================================

async fn test_custom_recovery() {
    let supervisor = Supervisor.new()
        .on_child_failure(|child_id, error, context| {
            // Log the failure
            log_error(f"Child {child_id} failed: {error}");

            // Decide recovery action
            match analyze_failure(&error) {
                FailureType.Transient => RecoveryAction.Restart,
                FailureType.Fatal => RecoveryAction.Stop,
                FailureType.ResourceExhausted => RecoveryAction.RestartAfter(
                    Duration.from_secs(60)
                ),
                FailureType.Unknown => RecoveryAction.Escalate,
            }
        })
        .child(ChildSpec.new("worker", || async { panic("oops") }));
}

type FailureType is
    | Transient
    | Fatal
    | ResourceExhausted
    | Unknown;

type RecoveryAction is
    | Restart
    | RestartAfter(Duration)
    | Stop
    | Escalate;

fn log_error(msg: Text) {}
fn analyze_failure(error: &Error) -> FailureType {
    FailureType.Transient
}

// ============================================
// Supervision Events
// ============================================

async fn test_supervision_events() {
    let (event_tx, mut event_rx) = channel<SupervisionEvent>();

    let supervisor = Supervisor.new()
        .event_handler(event_tx)
        .child(ChildSpec.new("worker", || async {}));

    // Handle events
    spawn {
        while let Some(event) = event_rx.recv().await {
            match event {
                SupervisionEvent.ChildStarted { id } => {
                    println(f"Started: {id}");
                }
                SupervisionEvent.ChildExited { id, reason } => {
                    println(f"Exited: {id}, reason: {reason}");
                }
                SupervisionEvent.ChildRestarted { id, attempt } => {
                    println(f"Restarted: {id}, attempt: {attempt}");
                }
                SupervisionEvent.MaxRestartsExceeded { id } => {
                    println(f"Max restarts: {id}");
                }
            }
        }
    };
}

type ExitReason is
    | Normal
    | Error(Error)
    | Panic(Text)
    | Shutdown;

type SupervisionEvent is
    | ChildStarted { id: Text }
    | ChildExited { id: Text, reason: ExitReason }
    | ChildRestarted { id: Text, attempt: Int }
    | MaxRestartsExceeded { id: Text };

// ============================================
// Supervisor Registry
// ============================================

async fn test_supervisor_registry() {
    // Supervisor registry not yet fully implemented - stub
    println("Registry test");
}

type SupervisorRegistry is {
    supervisors: RwLock<Map<Text, Supervisor>>,
};

implement SupervisorRegistry {
    fn new() -> Self {
        Self { supervisors: RwLock.new(Map.new()) }
    }

    async fn register(&self, name: Text, supervisor: Supervisor) {
        let mut sups = self.supervisors.write().await;
        sups.insert(name, supervisor);
    }

    async fn get(&self, name: &str) -> Maybe<Supervisor> {
        let sups = self.supervisors.read().await;
        sups.get(name).cloned()
    }
}

async fn main() {
    // Basic supervision
    test_basic_supervision().await;

    // OneForAll strategy
    test_one_for_all().await;

    // RestForOne strategy
    test_rest_for_one().await;

    // Escalation
    test_escalation().await;

    // Circuit breaker
    test_circuit_breaker_supervision().await;
}
