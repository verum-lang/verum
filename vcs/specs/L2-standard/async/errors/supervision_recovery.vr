// Child Specifications
// ============================================

async fn test_child_specs() {
    let supervisor = Supervisor.new()
        .child(
            ChildSpec.new("worker", worker_fn)
                .restart(RestartPolicy.Transient)
                .shutdown(ShutdownSpec.Timeout(Duration.from_secs(5)))
        )
        .child(
            ChildSpec.new("optional", optional_worker)
                .restart(RestartPolicy.Temporary)
                .shutdown(ShutdownSpec.Brutal)
        );
}

async fn worker_fn() {}
async fn optional_worker() {}

// ============================================
// Shutdown Strategies
// ============================================

async fn test_shutdown() {
    let supervisor = Supervisor.new()
        .shutdown_order(ShutdownOrder.Sequential)  // Shutdown children in order
        .child(
            ChildSpec.new("first", || async {})
                .shutdown(ShutdownSpec.Timeout(Duration.from_secs(10)))
        )
        .child(
            ChildSpec.new("second", || async {})
                .shutdown(ShutdownSpec.Timeout(Duration.from_secs(5)))
        );

    // Graceful shutdown
    supervisor.shutdown().await;

    // Or brutal shutdown
    // supervisor.terminate();
}

type ShutdownSpec is
    | Timeout(Duration)  // Wait for graceful exit
    | Brutal             // Kill immediately
    | Infinity;          // Wait forever

type ShutdownOrder is
    | Sequential   // Shutdown in reverse start order
    | Parallel;    // Shutdown all at once

