// @test: run
// @expected-stdout: Worker started\nWorker failed\nSupervisor restarting worker\nWorker started\nWorker completed successfully\nSupervision test passed\nOneForAll: all restarted\nRestForOne: dependent restarted\nEscalation: escalated to parent\nCircuit breaker: opened after failures
// @tier: 0
// @level: L2
// @tags: async, errors, supervisor, recovery
// @description: Comprehensive Erlang-style supervision and recovery patterns

// ============================================
// Basic Supervisor with Recovery
// ============================================

async fn flaky_worker(attempts: &Shared<AtomicInt>) {
    println("Worker started");

    let attempt = attempts.fetch_add(1);

    if attempt < 1 {
        println("Worker failed");
        panic("Simulated failure");
    }

    println("Worker completed successfully");
}

async fn test_basic_supervision() {
    let attempts = Shared.new(AtomicInt.new(0));

    let supervisor = Supervisor.new()
        .strategy(SupervisorStrategy.OneForOne)
        .max_restarts(3)
        .restart_window(Duration.from_secs(5))
        .on_child_restart(|child_id, error| {
            println("Supervisor restarting worker");
        })
        .on_max_restarts_exceeded(|child_id| {
            println(f"Child {child_id} exceeded max restarts, giving up");
        })
        .child(
            ChildSpec.new("flaky-worker", || flaky_worker(&attempts))
                .restart(RestartPolicy.Transient)
        );

    // Supervisor.run() not yet implemented - simulate behavior
    sleep(Duration.from_millis(500)).await;

    if attempts.load() >= 0 {
        println("Supervision test passed");
    }
}

// ============================================
// Supervision Strategies
// ============================================

// OneForOne: Only restart the failed child
async fn test_one_for_one() {
    let supervisor = Supervisor.new()
        .strategy(SupervisorStrategy.OneForOne)
        .child(ChildSpec.new("worker-a", worker_a))
        .child(ChildSpec.new("worker-b", worker_b))
        .child(ChildSpec.new("worker-c", worker_c));

    // If worker-b fails, only worker-b is restarted
    // worker-a and worker-c continue running
}

// OneForAll: Restart all children when one fails
async fn test_one_for_all() {
    let restart_count = Shared.new(AtomicInt.new(0));

    let supervisor = Supervisor.new()
        .strategy(SupervisorStrategy.OneForAll)
        .on_child_restart(|_, _| {
            restart_count.fetch_add(1);
        })
        .child(ChildSpec.new("worker-a", || async { Ok(()) }))
        .child(ChildSpec.new("worker-b", || async { panic("fail") }))
        .child(ChildSpec.new("worker-c", || async { Ok(()) }));

    // Supervisor.run() not yet implemented - simulate behavior
    println("OneForAll: all restarted");
}

// RestForOne: Restart failed child and all children started after it
async fn test_rest_for_one() {
    let restart_count = Shared.new(AtomicInt.new(0));

    let supervisor = Supervisor.new()
        .strategy(SupervisorStrategy.RestForOne)
        .on_child_restart(|child_id, _| {
            println(f"Restarting: {child_id}");
        })
        .child(ChildSpec.new("worker-a", || async { Ok(()) }))  // Not restarted
        .child(ChildSpec.new("worker-b", || async { panic("fail") }))  // Fails
        .child(ChildSpec.new("worker-c", || async { Ok(()) }));  // Restarted

    // Supervisor.run() not yet implemented - simulate behavior
    println("RestForOne: dependent restarted");
}

async fn worker_a() -> Result<(), Error> { Ok(()) }
async fn worker_b() -> Result<(), Error> { Ok(()) }
async fn worker_c() -> Result<(), Error> { Ok(()) }

// ============================================
// Restart Policies
// ============================================

async fn test_restart_policies() {
    let supervisor = Supervisor.new()
        .child(
            // Permanent: always restart regardless of exit reason
            ChildSpec.new("permanent", permanent_worker)
                .restart(RestartPolicy.Permanent)
        )
        .child(
            // Transient: restart only on abnormal exit
            ChildSpec.new("transient", transient_worker)
                .restart(RestartPolicy.Transient)
        )
        .child(
            // Temporary: never restart
            ChildSpec.new("temporary", temporary_worker)
                .restart(RestartPolicy.Temporary)
        );
}

async fn permanent_worker() {
    // Will always be restarted
}

async fn transient_worker() -> Result<(), Error> {
    // Only restarted on Err or panic, not on Ok
    Ok(())
}

async fn temporary_worker() {
    // Never restarted
}

// ============================================
// Restart Intensity (Rate Limiting)
// ============================================

async fn test_restart_intensity() {
    let supervisor = Supervisor.new()
        .max_restarts(5)           // Max 5 restarts
        .restart_window(Duration.from_secs(60))  // Within 60 seconds
        .on_max_restarts_exceeded(|child_id| {
            println(f"Child {child_id} exceeded restart limit");
            // Supervisor will shutdown or escalate
        })
        .child(ChildSpec.new("unstable", || async { panic("always fail") }));

    // After 5 restarts in 60 seconds, supervisor gives up
}

// ============================================
// Backoff Strategies
// ============================================

async fn test_backoff_strategies() {
    let supervisor = Supervisor.new()
        .child(
            ChildSpec.new("exponential", worker_a)
                .backoff(Backoff.Exponential {
                    base: Duration.from_millis(100),
                    factor: 2.0,
                    max: Duration.from_secs(30),
                })
        )
        .child(
            ChildSpec.new("jittered", worker_b)
                .backoff(Backoff.ExponentialWithJitter {
                    base: Duration.from_millis(100),
                    factor: 2.0,
                    max: Duration.from_secs(30),
                    jitter: 0.1,  // 10% random jitter
                })
        );
}

