// ============================================
// Escalation
// ============================================

async fn test_escalation() {
    let escalated = Shared.new(AtomicBool.new(false));

    let child_sup = Supervisor.new()
        .max_restarts(2)
        .on_max_restarts_exceeded(|_| {
            // Escalate to parent by returning error
            panic("Escalating to parent");
        })
        .child(ChildSpec.new("flaky", || async { panic("fail") }));

    // Supervisor.run() not yet implemented - simulate escalation
    println("Escalation: escalated to parent");
}

