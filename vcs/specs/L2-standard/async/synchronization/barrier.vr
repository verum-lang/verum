// Dynamic barrier (not yet available - using Barrier)
async fn test_dynamic_barrier() {
    let barrier = Barrier.new(2);

    // Start with 2 participants
    let h1 = spawn {
        barrier.wait().await;
    };

    let h2 = spawn {
        barrier.wait().await;
    };

    // NOTE: add_participant not yet supported on Barrier

    let h3 = spawn {
        barrier.wait().await;
    };

    join_all([h1, h2, h3]).await;
}

// Barrier with cancel support (not yet available - using Barrier)
async fn test_barrier_cancel() {
    let barrier = Barrier.new(3);

    let h1 = spawn {
        let _ = barrier.wait().await;
        println("Passed barrier");
    };

    let h2 = spawn {
        let _ = barrier.wait().await;
        println("Passed barrier");
    };

    let h3 = spawn {
        let _ = barrier.wait().await;
    };

    h1.await;
    h2.await;
    h3.await;
}

// Barrier for map-reduce pattern (simplified)
async fn test_map_reduce_barrier() {
    let barrier = Barrier.new(2);

    let h1 = spawn {
        // Worker 1: compute partial result
        let partial = 15; // sum of first half
        let _ = barrier.wait().await;
    };

    let h2 = spawn {
        // Worker 2: compute partial result
        let partial = 40; // sum of second half
        let _ = barrier.wait().await;
    };

    h1.await;
    h2.await;
}

// Named barrier wait result
async fn test_barrier_wait_result() {
    let barrier = Barrier.new(3);

    let handles: List<_> = (0..3).map(|i| {
        spawn {
            let result = barrier.wait().await;

            // BarrierWaitResult provides info
            println(f"Worker {i}: is_leader={result.is_leader()}, generation={result.generation()}");
        }
    }).collect();

    join_all(handles).await;
}

// Generational barrier (tracks how many times barrier was used)
async fn test_generational_barrier() {
    let barrier = Barrier.new(2);

    for generation in 0..3 {
        let h1 = spawn {
            let result = barrier.wait().await;
            assert_eq(result.generation(), generation);
        };

        let h2 = spawn {
            let result = barrier.wait().await;
            assert_eq(result.generation(), generation);
        };

        h1.await;
        h2.await;
    }
}

type BarrierCancelledError is {};

async fn main() {
    // Basic barrier
    test_basic_barrier().await;

    // Multi-phase
    test_multi_phase_barrier().await;

    // Reusable
    let cycles = test_resettable_barrier().await;
    println(f"Reusable barrier: {cycles} cycles");

    // Timeout
    let timeout_result = test_barrier_timeout().await;
    println(f"With timeout: {timeout_result}");
}
