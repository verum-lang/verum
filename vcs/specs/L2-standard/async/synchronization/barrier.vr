// @test: run
// @expected-stdout: Worker 0 waiting at barrier\nWorker 1 waiting at barrier\nWorker 2 waiting at barrier\nAll workers passed barrier\nWorker 0 finished\nWorker 1 finished\nWorker 2 finished\nPhase 1 complete\nPhase 2 complete\nReusable barrier: 3 cycles\nWith timeout: passed
// @tier: 0
// @level: L2
// @tags: async, synchronization, barrier
// @description: Comprehensive async barrier patterns for multi-task synchronization

// Basic barrier synchronization
async fn test_basic_barrier() {
    let barrier = Barrier.new(3);

    let handles: List<_> = (0..3).map(|i| {
        spawn {
            println(f"Worker {i} waiting at barrier");

            let result = barrier.wait().await;

            if result.is_leader() {
                println("All workers passed barrier");
            }

            println(f"Worker {i} finished");
        }
    }).collect();

    for handle in handles {
        handle.await;
    }
}

// Multi-phase barrier (reusable)
async fn test_multi_phase_barrier() {
    let barrier = Barrier.new(3);
    let mut phase_count = 0;

    let handles: List<_> = (0..3).map(|i| {
        let b = &barrier;
        spawn {
            // Phase 1
            do_phase1_work(i).await;
            let result = b.wait().await;
            if result.is_leader() {
                println("Phase 1 complete");
            }

            // Phase 2
            do_phase2_work(i).await;
            let result = b.wait().await;
            if result.is_leader() {
                println("Phase 2 complete");
            }
        }
    }).collect();

    for handle in handles {
        handle.await;
    }
}

async fn do_phase1_work(id: Int) {
    sleep(Duration.from_millis(10 * id)).await;
}

async fn do_phase2_work(id: Int) {
    sleep(Duration.from_millis(5 * id)).await;
}

// Barrier with callback on release
async fn test_barrier_callback() {
    let barrier = Barrier.with_callback(3, || {
        println("All workers synchronized, starting next phase");
    });

    let handles: List<_> = (0..3).map(|_| {
        spawn {
            barrier.wait().await;
        }
    }).collect();

    join_all(handles).await;
}

// Leader election via barrier
async fn test_leader_election() {
    let barrier = Barrier.new(5);
    let leader_id = Shared.new(AtomicInt.new(-1));

    let handles: List<_> = (0..5).map(|i| {
        let lid = leader_id.clone();
        spawn {
            let result = barrier.wait().await;

            if result.is_leader() {
                lid.store(i);
            }
        }
    }).collect();

    join_all(handles).await;

    let leader = leader_id.load();
    println(f"Elected leader: {leader}");
}

// Barrier with timeout
async fn test_barrier_timeout() -> Text {
    let barrier = Barrier.new(3);

    // Only 2 workers join
    let h1 = spawn {
        timeout(Duration.from_millis(100), barrier.wait()).await
    };

    let h2 = spawn {
        timeout(Duration.from_millis(100), barrier.wait()).await
    };

    // Third worker joins late but within timeout
    let h3 = spawn {
        sleep(Duration.from_millis(50)).await;
        timeout(Duration.from_millis(100), barrier.wait()).await
    };

    let r1 = h1.await;
    let r2 = h2.await;
    let r3 = h3.await;

    if r1.is_ok() && r2.is_ok() && r3.is_ok() {
        "passed"
    } else {
        "timeout"
    }
}

// Resettable barrier (not yet available)
async fn test_resettable_barrier() -> Int {
    let barrier = Barrier.new(3);
    let cycle_count = Shared.new(AtomicInt.new(0));

    let handles: List<_> = (0..3).map(|_| {
        let b = &barrier;
        let cc = cycle_count.clone();
        spawn {
            for _ in 0..3 {
                b.wait().await;
                cc.fetch_add(1);
            }
        }
    }).collect();

    join_all(handles).await;

    cycle_count.load() / 3 // Number of complete cycles
}

// Barrier with shared data
async fn test_barrier_shared_data() {
    type SharedData is {
        values: Mutex<List<Int>>,
        barrier: Barrier,
    };

    let shared = Shared.new(SharedData {
        values: Mutex.new([]),
        barrier: Barrier.new(3),
    });

    let handles: List<_> = (0..3).map(|i| {
        let s = shared.clone();
        spawn {
            // Each worker contributes a value
            {
                let mut values = s.values.lock().await;
                values.push(i);
            }

            // Wait for all contributions
            let result = s.barrier.wait().await;

            // Leader processes all values
            if result.is_leader() {
                let _values = s.values.lock().await;
                // Processing values via guard
            }
        }
    }).collect();

    join_all(handles).await;
}

