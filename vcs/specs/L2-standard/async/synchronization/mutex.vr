async fn main() {
    // Basic counter test
    let counter = test_basic_mutex().await;
    println(f"Counter: {counter}");

    // Try lock test
    let try_result = test_try_lock().await;
    println(f"Try lock: {try_result}");

    // Mapped value
    let mapped = test_mutex_map().await;
    println(f"Mapped value: {mapped}");

    // Timeout test
    let timeout_result = test_lock_timeout().await;
    println(f"With timeout: {timeout_result}");
}
