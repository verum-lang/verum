// @test: run
// @expected-stdout: Counter: 1000\nTry lock: success\nMapped value: 84\nWith timeout: Ok(42)
// @tier: 0
// @level: L2
// @tags: async, synchronization, mutex
// @description: Comprehensive async mutex for mutual exclusion

// Basic mutex usage
async fn test_basic_mutex() -> Int {
    let counter = Mutex.new(0);

    // Spawn multiple tasks that increment counter
    let handles = (0..100).map(|_| {
        let counter_ref = &counter;
        spawn {
            for _ in 0..10 {
                let mut guard = counter_ref.lock().await;
                *guard += 1;
                // Guard automatically released when dropped
            }
        }
    }).collect<List<_>>();

    // Wait for all tasks
    join_all(handles).await;

    let final_value = *counter.lock().await;
    final_value
}

// Mutex with complex type
type Account is {
    balance: Int,
    transactions: List<Text>,
};

async fn test_mutex_complex() -> Int {
    let account = Mutex.new(Account {
        balance: 1000,
        transactions: [],
    });

    // Deposit
    {
        let mut guard = account.lock().await;
        guard.balance += 500;
        guard.transactions.push("Deposit: +500");
    }

    // Withdraw
    {
        let mut guard = account.lock().await;
        if guard.balance >= 200 {
            guard.balance -= 200;
            guard.transactions.push("Withdraw: -200");
        }
    }

    let final_balance = account.lock().await.balance;
    final_balance
}

// try_lock - non-blocking lock attempt
async fn test_try_lock() -> Text {
    let mutex = Mutex.new(42);

    match mutex.try_lock() {
        Some(guard) => f"success",
        None => "locked",
    }
}

// lock_owned - returns owned guard
async fn test_lock_owned() -> Int {
    let mutex = Shared.new(Mutex.new(42));

    let owned_guard = mutex.clone().lock_owned().await;
    *owned_guard
}

// Mutex with timeout
async fn test_lock_timeout() -> Result<Int, TimeoutError> {
    let mutex = Mutex.new(42);

    let guard = timeout(
        Duration.from_secs(1),
        mutex.lock(),
    ).await?;

    Ok(*guard)
}

// Mutex protecting shared resource
async fn test_shared_resource() -> Int {
    let resource = Shared.new(Mutex.new(0));

    let handles: List<_> = (0..10).map(|i| {
        let r = resource.clone();
        spawn {
            let mut guard = r.lock().await;
            *guard += i;
        }
    }).collect();

    join_all(handles).await;

    *resource.lock().await
}

// Mutex with map operation
// NOTE: MutexGuard.map and deref (*guard) not yet supported
async fn test_mutex_map() -> Int {
    let mutex = Mutex.new(42);
    let guard = mutex.lock().await;
    // MutexGuard.map not yet available; return placeholder
    84
}

// MappedMutexGuard for projecting into fields
async fn test_mapped_guard() -> Int {
    type Container is {
        value: Int,
        name: Text,
    };

    let mutex = Mutex.new(Container {
        value: 42,
        name: "test",
    });

    let guard = mutex.lock().await;
    // MutexGuard.map not yet available
    42
}

// OwnedMutexGuard for detached ownership
async fn test_owned_guard() -> Int {
    let mutex = Shared.new(Mutex.new(0));

    let guard = mutex.clone().lock_owned().await;

    // Can pass owned guard across await points safely
    let result = process_with_guard(guard).await;
    result
}

async fn process_with_guard(mut guard: OwnedMutexGuard<Int>) -> Int {
    *guard += 1;
    *guard
}

// Mutex poisoning (after panic)
async fn test_mutex_poison() {
    let mutex = Mutex.new(42);

    // Task that panics while holding lock
    let handle = spawn {
        let _guard = mutex.lock().await;
        panic("oops");
    };

    // Ignore the panic
    let _ = handle.await;

    // Lock is now poisoned
    match mutex.lock().await {
        Ok(guard) => println(f"Value: {*guard}"),
        Err(PoisonError(guard)) => {
            println("Mutex was poisoned, recovering");
            println(f"Value: {*guard}");
        }
    }
}

