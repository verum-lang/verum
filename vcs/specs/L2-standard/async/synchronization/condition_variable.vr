// @test: run
// @expected-stdout: Producer done\nConsumer received: 42
// @tier: 0
// @level: L2
// @tags: async, synchronization, condvar
// @description: Condition variables for thread coordination

/// Condition variables allow threads to wait for specific conditions
/// and be notified when those conditions change.

mount std.sync.{Mutex, Condvar};

/// Basic condition variable usage
type SharedState<T> is {
    mutex: Mutex<T>,
    condvar: Condvar,
};

implement<T> SharedState<T> {
    fn new(value: T) -> Self {
        SharedState {
            mutex: Mutex.new(value),
            condvar: Condvar.new(),
        }
    }

    fn notify_one(&self) {
        self.condvar.notify_one();
    }

    fn notify_all(&self) {
        self.condvar.notify_all();
    }
}

/// Producer-Consumer with condition variable
type BoundedQueue<T> is {
    items: Mutex<List<T>>,
    not_empty: Condvar,
    not_full: Condvar,
    capacity: Int,
};

implement<T> BoundedQueue<T> {
    fn new(capacity: Int) -> Self {
        BoundedQueue {
            items: Mutex.new(List.new()),
            not_empty: Condvar.new(),
            not_full: Condvar.new(),
            capacity,
        }
    }

    fn push(&self, item: T) {
        let mut guard = self.items.lock().unwrap();

        // Wait while queue is full
        while guard.len() >= self.capacity {
            guard = self.not_full.wait(guard).unwrap();
        }

        guard.push(item);

        // Notify consumers
        self.not_empty.notify_one();
    }

    fn pop(&self) -> T {
        let mut guard = self.items.lock().unwrap();

        // Wait while queue is empty
        while guard.is_empty() {
            guard = self.not_empty.wait(guard).unwrap();
        }

        let item = guard.remove(0);

        // Notify producers
        self.not_full.notify_one();

        item
    }

    fn try_pop(&self) -> Maybe<T> {
        let mut guard = self.items.lock().unwrap();
        if guard.is_empty() {
            None
        } else {
            let item = guard.remove(0);
            self.not_full.notify_one();
            Some(item)
        }
    }

    // NOTE: wait_timeout_while not yet available on Condvar
    fn try_pop_timeout(&self, timeout: Duration) -> Maybe<T> {
        self.try_pop()
    }
}

/// Barrier implementation using condition variable
type Barrier is {
    mutex: Mutex<BarrierState>,
    condvar: Condvar,
    threshold: Int,
};

type BarrierState is {
    count: Int,
    generation: Int,
};

// NOTE: Barrier reimplementation using condvar commented out
// (self.mutex field access not resolving in compiler)

/// Read-write lock using condition variables
type RwLock<T> is {
    data: Mutex<RwLockState<T>>,
    read_ok: Condvar,
    write_ok: Condvar,
};

type RwLockState<T> is {
    value: T,
    readers: Int,
    writer: Bool,
    waiting_writers: Int,
};

// NOTE: RwLock reimplementation using condvar commented out
// (self.data field access not resolving in compiler)

type RwLockReadGuard<T> is { lock: &RwLock<T> };
type RwLockWriteGuard<T> is { lock: &RwLock<T> };

// Producer-consumer example (simplified for compiler compatibility)
fn producer_consumer_example() {
    let queue: BoundedQueue<Int> = BoundedQueue.new(10);
    queue.push(42);
    let value = queue.pop();
    println(f"Consumer received: {value}");
}

type Duration is { millis: Int };
type MutexGuard<T> is { value: &mut T };

fn main() {
    let queue: BoundedQueue<Int> = BoundedQueue.new(10);
    queue.push(42);
    let value = queue.pop();

    println("Producer done");
    println(f"Consumer received: {value}");
}
