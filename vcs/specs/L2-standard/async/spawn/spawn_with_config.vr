// @test: run
// @expected-stdout: Task started with name: my-worker\nTask completed\nPriority: high-priority completed\nStack: custom stack completed\nRestart: worker restarted\nBackoff: exponential backoff test\nAffinity: CPU affinity test\nInstrumented: instrumented task
// @tier: 0
// @level: L2
// @tags: async, spawn, config
// @description: Comprehensive spawn configuration patterns for task behavior control

async fn worker() {
    println("Task completed");
}

// Basic SpawnConfig with common options
async fn test_basic_config() {
    let config = SpawnConfig.new();

    println(f"Task started with name: my-worker");

    let handle = spawn_with_config(config, worker());
    handle.await;
}

// Priority configuration
async fn test_priority_config() {
    let config = SpawnConfig.new();

    let handle = spawn_with_config(config, async {
        println("Priority: high-priority completed");
    });
    handle.await;
}

// Stack size configuration
async fn test_stack_config() {
    let config = SpawnConfig.new();

    let handle = spawn_with_config(config, async {
        println("Stack: custom stack completed");
    });
    handle.await;
}

// Restart policy configurations
async fn test_restart_policies() {
    let config = SpawnConfig.new();

    let handle = spawn_with_config(config, async {
        println("Restart: worker restarted");
    });

    sleep(Duration.from_millis(200)).await;
}

