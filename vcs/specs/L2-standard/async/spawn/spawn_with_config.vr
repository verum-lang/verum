async fn test_resource_limits() {
    let config = SpawnConfig.new();

    let handle = spawn_with_config(config, async {
        42
    });
    handle.await;
}

// Timeout configuration
async fn test_timeout_config() {
    let config = SpawnConfig.new();

    let handle = spawn_with_config(config, async {
        42
    });
    handle.await;
}

