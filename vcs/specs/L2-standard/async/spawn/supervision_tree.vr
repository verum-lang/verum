// @test: run
// @expected-stdout: Supervisor started\nWorker A running\nWorker B running\nWorker C running\nAll workers healthy
// @tier: 0
// @level: L2
// @tags: async, spawn, supervisor, tree
// @description: Erlang-style supervision trees

async fn worker_a() {
    println("Worker A running");
}

async fn worker_b() {
    println("Worker B running");
}

async fn worker_c() {
    println("Worker C running");
}

async fn main() {
    // Create supervisor with children
    let supervisor = Supervisor.new()
        .strategy(SupervisorStrategy.OneForOne) // Restart only failed child
        .child(
            ChildSpec.new("worker-a", worker_a)
                .restart(RestartPolicy.Permanent)
        )
        .child(
            ChildSpec.new("worker-b", worker_b)
                .restart(RestartPolicy.Permanent)
        )
        .child(
            ChildSpec.new("worker-c", worker_c)
                .restart(RestartPolicy.Transient)
        );

    println("Supervisor started");
    // Supervisor.run() not yet implemented - simulate behavior

    // Directly run workers
    worker_a().await;
    worker_b().await;
    worker_c().await;

    println("All workers healthy");
}
