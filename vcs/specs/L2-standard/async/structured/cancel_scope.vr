// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: async, structured-concurrency, cancellation, scope
// @timeout: 10000
// @expect: pass
// @description: Cancellation scopes via core.async.cancellation.CancelScope

// Reshaped 2026-04-20 to use the stdlib CancelScope / CancellationToken
// from core.async.cancellation, replacing a self-contained re-impl that
// used an unfulfillable `CancelCtx` context.

mount core.async.cancellation.{
    CancellationToken,
    CancellationTokenSource,
    CancelScope,
    CancelReason,
    CancellationError,
    Registration,
};
mount core.time.duration.Duration;
mount core.sync.atomic.{AtomicBool, MemoryOrdering};

// -----------------------------------------------------------------------------
// Basic cancel-scope — auto-cancel on drop
// -----------------------------------------------------------------------------

fn test_scope_auto_cancel_on_drop() {
    let token = {
        let scope = CancelScope.new();
        scope.token()
        // scope is dropped at end of block — token auto-cancelled
    };
    assert(token.is_cancelled(), "scope-linked token cancelled on scope drop");
}

// -----------------------------------------------------------------------------
// Dismissed scope — token survives
// -----------------------------------------------------------------------------

fn test_dismissed_scope_preserves_token() {
    let token = {
        let scope = CancelScope.new();
        scope.dismiss();
        scope.token()
    };
    assert(!token.is_cancelled(), "dismissed scope does not cancel");
}

// -----------------------------------------------------------------------------
// Linked-to-parent cancellation
// -----------------------------------------------------------------------------

fn test_linked_scope_propagates_from_parent() {
    let parent = CancellationTokenSource.new();
    let scope = CancelScope.linked_to(&parent.token());
    let scope_token = scope.token();

    scope.dismiss();       // don't auto-cancel on drop; rely purely on parent

    parent.cancel();
    assert(scope_token.is_cancelled(), "scope token cancelled via parent");
    match scope_token.reason().unwrap() {
        CancelReason.ParentCancelled => { /* ok */ }
        _ => assert(false, "expected ParentCancelled"),
    }
}

// -----------------------------------------------------------------------------
// Cancellation check inside a long-running operation
// -----------------------------------------------------------------------------

fn worker_loop_with_check(token: &CancellationToken) -> Result<Int, CancellationError> {
    let mut total = 0;
    let mut i = 0;
    while i < 100 {
        token.throw_if_cancelled()?;
        total = total + i;
        i = i + 1;
    }
    Ok(total)
}

fn test_cancellation_check_in_loop() {
    let source = CancellationTokenSource.new();
    let token = source.token();

    // Un-cancelled run — completes normally
    let r1 = worker_loop_with_check(&token);
    assert(r1.is_ok(), "uncancelled worker completes");

    // Cancel + run — bails out via throw_if_cancelled
    source.cancel_with(CancelReason.Aborted("shutdown".into()));
    let r2 = worker_loop_with_check(&token);
    assert(r2.is_err(), "cancelled worker errors out");
}

// -----------------------------------------------------------------------------
// Sync callback cleanup via Registration
// -----------------------------------------------------------------------------

fn test_cleanup_callback() {
    let source = CancellationTokenSource.new();
    let cleanup_ran = AtomicBool.new(false);
    let flag = &cleanup_ran;

    let _reg: Registration = source.token().register(|| {
        flag.store(true, MemoryOrdering.Release);
    });

    source.cancel();

    assert(
        cleanup_ran.load(MemoryOrdering.Acquire),
        "cleanup callback ran on cancel"
    );
}

// -----------------------------------------------------------------------------
// Scope with timeout builder (typecheck only — runtime sleep needs executor)
// -----------------------------------------------------------------------------

fn test_scope_with_timeout_typecheck() {
    let _scope = CancelScope.with_timeout(Duration.from_millis(100));
}

fn main() {
    test_scope_auto_cancel_on_drop();
    test_dismissed_scope_preserves_token();
    test_linked_scope_propagates_from_parent();
    test_cancellation_check_in_loop();
    test_cleanup_callback();
    test_scope_with_timeout_typecheck();
}
