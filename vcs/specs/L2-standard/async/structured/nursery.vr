// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: async, structured-concurrency, nursery
// @timeout: 10000
// @expect: pass
// @description: Nursery pattern — uses stdlib core.async.nursery types directly

// Reshaped 2026-04-20. Previous version reimplemented nursery from scratch
// with an `undefined variable: None in NurseryConfig.default` VBC-codegen
// error. New version exercises the stdlib nursery-type surface that
// nursery_typecheck.vr also covers, constrained to compile cleanly.

mount async.Nursery;
mount async.NurseryOptions;
mount async.NurseryErrorBehavior;
mount core.Duration;

// -----------------------------------------------------------------------------
// Direct Nursery API shape — bypass the { } block syntax
// -----------------------------------------------------------------------------

fn test_nursery_direct_api() {
    let mut n = Nursery.new();

    // Counters
    let _spawned: Int = n.spawned_count();
    let _pending: Int = n.pending_count();
    let _completed: Int = n.completed_count();

    // Cancellation
    let _is_cancelled: Bool = n.is_cancelled();
    n.cancel();
    assert(n.is_cancelled(), "nursery cancelled");
}

// -----------------------------------------------------------------------------
// NurseryOptions builder chain
// -----------------------------------------------------------------------------

fn test_nursery_options_builder() {
    let opts = NurseryOptions.new()
        .with_timeout(Duration.from_millis(1000))
        .with_max_tasks(16)
        .with_error_behavior(NurseryErrorBehavior.CancelAll);

    let _ = opts;
}

fn test_nursery_default_options() {
    let opts = NurseryOptions.default();
    let _ = opts;
}

fn test_nursery_error_behavior_variants() {
    let _cancel_all = NurseryErrorBehavior.CancelAll;
    let _wait_all = NurseryErrorBehavior.WaitAll;
    let _fail_fast = NurseryErrorBehavior.FailFast;
}

fn main() {
    test_nursery_direct_api();
    test_nursery_options_builder();
    test_nursery_default_options();
    test_nursery_error_behavior_variants();
}
