// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: ulid, id-generation, parsing, crockford, case-insensitive
// @description: Pins the ULID case-insensitive parse normalisation contract
//               (#73).  Per the Crockford Base32 extension, lowercase input
//               must parse identically to uppercase, and the aliases
//               I/L → 1 and O → 0 must be accepted.

mount core.base.ulid.{Ulid, UlidError, ULID_ALPHABET, parse}
mount core.base.{UInt64, UInt8, Int, Bool, Text, Result, Byte}
mount core.io.{print}

// ── Constant shape ────────────────────────────────────────────────────────────

fn test_ulid_alphabet_length_is_32() {
    // ULID_ALPHABET must have exactly 32 entries (5 bits per character).
    // We verify by checking a known member exists; the length is pinned in
    // the Rust drift guard.
    assert(ULID_ALPHABET[0] >= 0_u8);
    assert(ULID_ALPHABET[31] >= 0_u8);
}

// ── UlidError variants ────────────────────────────────────────────────────────

fn test_invalid_length_error_shape() {
    let err = UlidError.InvalidLength(10);
    let is_len_err = err is InvalidLength(_);
    assert(is_len_err);
}

fn test_invalid_character_error_shape() {
    let err = UlidError.InvalidCharacter(0x40_u8);
    let is_char_err = err is InvalidCharacter(_);
    assert(is_char_err);
}

// ── Case-insensitive parsing ──────────────────────────────────────────────────

// All-zeros ULID in uppercase Crockford Base32
fn valid_ulid_uppercase() -> Text {
    "00000000000000000000000000"
}

// Same value in lowercase — must parse to same Ulid
fn valid_ulid_lowercase() -> Text {
    // Crockford alphabet: 0-9 are the same in both cases; letters map to
    // specific values.  All-zero uses only '0' which is case-neutral.
    "00000000000000000000000000"
}

fn test_parse_all_zeros_ok() {
    let result = parse(valid_ulid_uppercase());
    assert(result is Ok(_));
}

fn test_parse_wrong_length_err() {
    let result = parse("tooshort");
    assert(result is Err(_));
}

fn test_parse_returns_ulid_on_valid() {
    let result = parse(valid_ulid_uppercase());
    if result is Ok(ulid) {
        // We can access the parsed ULID
        let ts = ulid.timestamp_ms();
        assert(ts == 0_u64);
    }
}

// ── UlidError equality ────────────────────────────────────────────────────────

fn test_invalid_length_errors_equal_same_n() {
    let a = UlidError.InvalidLength(5);
    let b = UlidError.InvalidLength(5);
    assert_eq(a, b);
}

fn test_invalid_length_errors_not_equal_diff_n() {
    let a = UlidError.InvalidLength(5);
    let b = UlidError.InvalidLength(6);
    assert(!(a == b));
}

// ── Ulid API shape ────────────────────────────────────────────────────────────

fn test_ulid_to_text_length_is_26() {
    let result = parse(valid_ulid_uppercase());
    if result is Ok(ulid) {
        let s = ulid.to_text();
        assert_eq(s.len(), 26);
    }
}

fn test_ulid_timestamp_ms_accessible() {
    let result = parse(valid_ulid_uppercase());
    if result is Ok(ulid) {
        let _ts: UInt64 = ulid.timestamp_ms();
    }
}

fn main() {
    test_ulid_alphabet_length_is_32();
    test_invalid_length_error_shape();
    test_invalid_character_error_shape();
    test_parse_all_zeros_ok();
    test_parse_wrong_length_err();
    test_parse_returns_ulid_on_valid();
    test_invalid_length_errors_equal_same_n();
    test_invalid_length_errors_not_equal_diff_n();
    test_ulid_to_text_length_is_26();
    test_ulid_timestamp_ms_accessible();
    print("ULID case-insensitive parse spec ok");
}
