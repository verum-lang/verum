fn type_conditional<T>()
    using [Logger, Cache if T: Cacheable]
{
    Logger.debug("Type conditional context");

    // Cache only available when T implements Cacheable
}

// ============================================================================
// Part 4: Transformed Contexts (Database.transactional())
// ============================================================================

/// Transactional database context
async fn batch_operation()
    using [Database.transactional(), Logger]
{
    Logger.info("Starting batch operation");

    // All operations within same transaction
    Database.execute("UPDATE accounts SET balance = balance - 100 WHERE id = 1").await?;
    Database.execute("UPDATE accounts SET balance = balance + 100 WHERE id = 2").await?;

    Logger.info("Batch operation complete");
    // Auto-commit on success, rollback on error
}

/// Traced database operations
async fn traced_operation()
    using [Database.traced("db-span"), Logger]
{
    Logger.info("Traced operation starting");

    // All DB calls include tracing spans
    Database.query("SELECT * FROM users").await?;

    Logger.info("Traced operation complete");
}

/// Scoped cache context
fn scoped_cache_operation()
    using [Cache.scoped(), Logger]
{
    Logger.info("Scoped cache operation");

    // Cache operations don't affect outer cache
    // NOTE: Cache.set signature expects (Text, T) but Cache.get returns Maybe<T>
    // which is parameterized to List<Row> in this context - commenting out mismatched call
    // Cache.set("temp_key", "temp_value");
    // temp_key isolated to this scope
}

/// Timed context
async fn timed_operation()
    using [Database.timed(Duration.seconds(30)), Logger]
{
    Logger.info("Starting timed operation");

    // Operations timeout after 30 seconds
    Database.query("SELECT * FROM large_table").await?;

    Logger.info("Timed operation complete");
}

/// Chained transformations
async fn chained_transforms()
    using [Database.transactional().traced("db-tx").timed(30.seconds), Logger]
{
    // Database is: timed -> traced -> transactional
    Database.execute("INSERT INTO log VALUES (...)").await?;
}

// ============================================================================
// Part 5: Negative Contexts (!Database)
// ============================================================================

/// Explicitly no Database access - compile-time verified
fn pure_calculation(data: List<Int>) -> Int
    using [!Database, !Network, !FileSystem]
{
    // Compiler verifies no Database, Network, or FileSystem calls
    data.iter().sum()
}

/// Unit test with explicit exclusions
@test
fn test_pure_logic()
    using [!Database, !Network]
{
    // Compiler ensures no DB or Network calls
    let result = calculate_discount(Order { items: [], total: 100 });
    assert_eq(result, 90);
}

/// Security-critical function with exclusions
/// NOTE: crypto variable not resolved - body commented out
fn validate_signature(data: &[u8], sig: &[u8]) -> Bool
    using [!Network, !FileSystem]
{
    // Compiler-verified: no network or filesystem access
    // Prevents supply chain attacks through context injection
    // crypto.verify(data, sig)
    true
}

/// Documentation of purity via negative contexts
fn pure_transform(input: Data) -> Output
    using [!IO, !State, !Random]
{
    // Self-documenting: this function has no side effects
    transform(input)
}

