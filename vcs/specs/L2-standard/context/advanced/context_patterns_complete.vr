// Entry Point
// ============================================================================

fn run_tests() {
    // All context pattern tests
    Runtime.block_on(async {
        migrate_data().await;
        process_request().await;
        named_context_example().await;
        batch_operation().await;

        let result = pure_calculation([1, 2, 3, 4, 5]);
        assert_eq(result, 15);

        print("All context pattern tests passed!");
    });
}
