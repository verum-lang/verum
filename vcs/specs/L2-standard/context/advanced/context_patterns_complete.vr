/// Comprehensive test for advanced context patterns (16-context-system.md Section 2.11 - Advanced Context Patterns)
/// Spec: docs/detailed/16-context-system.md Section 2.11
/// Grammar: grammar/verum.ebnf v2.12 - extended_context_list

// ============================================================================
// Type Stubs
// ============================================================================

type NetworkError is { message: Text };
type Output is { data: Text };
type MigrationStats is { count: Int, duration: Int };
type Order is { items: List<Text>, total: Int };
type Data is { payload: Text };

fn calculate_discount(order: Order) -> Int { order.total - 10 }
fn transform(input: Data) -> Output { Output { data: input.payload } }

// ============================================================================
// Context Definitions for Testing
// ============================================================================

context Logger {
    fn log(level: Level, message: Text);
    fn debug(message: Text);
    fn info(message: Text);
    fn warn(message: Text);
    fn error(message: Text);
}

context async Database {
    async fn query(sql: Text) -> Result<List<Row>, DbError>;
    async fn execute(sql: Text) -> Result<u64, DbError>;
    async fn begin_transaction() -> Transaction;
}

context async Network {
    async fn fetch(url: Text) -> Result<Response, NetworkError>;
    async fn post(url: Text, body: Bytes) -> Result<Response, NetworkError>;
}

context Metrics {
    fn increment(name: Text);
    fn record(name: Text, value: Float);
    fn timing(name: Text, duration: Duration);
}

context Analytics {
    fn track(event: Text, data: Map<Text, Value>);
}

context Cache {
    fn get<T>(key: Text) -> Maybe<T>;
    fn set<T>(key: Text, value: T);
    fn invalidate(key: Text);
}

context FileSystem {
    async fn read(path: Text) -> Result<Bytes, IoError>;
    async fn write(path: Text, data: Bytes) -> Result<(), IoError>;
}

// ============================================================================
// Part 1: Aliased Contexts (Database as db)
// ============================================================================

/// Multiple instances of the same context type using aliases
async fn migrate_data()
    using [Database as source, Database as target, Logger]
{
    Logger.info("Starting migration");

    let data = source.query("SELECT * FROM users").await?;

    for row in data {
        target.execute(f"INSERT INTO users_new VALUES ({row.to_sql()})").await?;
    }

    Logger.info("Migration complete");
}

/// Mixed aliased and unaliased contexts
async fn process_request()
    using [Database as db, Logger, Cache as cache, Metrics]
{
    Metrics.increment("requests.total");

    // Use aliased contexts
    if let Maybe.Some(cached) = cache.get("response") {
        Metrics.increment("cache.hits");
        return cached;
    }

    let result = db.query("SELECT * FROM data").await?;
    cache.set("response", result.clone());
    Metrics.increment("cache.misses");

    result
}

// ============================================================================
// Part 2: Named Contexts (db: Database)
// ============================================================================

/// Named context bindings - alternative syntax
async fn named_context_example()
    using [db: Database, log: Logger, cache: Cache]
{
    log.info("Starting operation");

    let cached = cache.get("key");
    if cached.is_none() {
        let data = db.query("SELECT * FROM table").await?;
        cache.set("key", data);
    }

    log.debug("Operation complete");
}

/// Mixed named and simple contexts
fn mixed_naming()
    using [log: Logger, Metrics, cache: Cache]
{
    log.info("Mixed context usage");
    Metrics.increment("operations");
    cache.invalidate("old_key");
}

