// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: contexts, spawn, tasks, concurrent
// @description: Tests context declarations and using clauses for spawned tasks

// Context declarations for dependency injection
context Logger {
    fn info(source: Text, message: Text);
}

context JobQueue {
    fn get_next_job(worker_id: Text) -> Maybe<Text>;
    fn complete_job(job_id: Text);
}

// Worker function that uses contexts
fn worker(id: Text) using [Logger, JobQueue] {
    Logger.info("Worker " + id, "Starting work");

    let mut processed = 0;

    match JobQueue.get_next_job("worker" + id) {
        Some(job) => {
            Logger.info("Worker " + id, "Processing: " + job);
            JobQueue.complete_job(job);
            processed = processed + 1;
        },
        None => {},
    };

    Logger.info("Worker " + id, "Done");
}

// Function composing multiple contexts
fn run_workers() using [Logger, JobQueue] {
    worker("1");
    worker("2");
}

// Function that only needs Logger
fn log_status(msg: Text) using [Logger] {
    Logger.info("Status", msg);
}

fn main() {
    // Context composition test: functions declare which contexts they need,
    // and the type checker verifies the contexts are available at call sites.
    let x = 42;
    assert(x == 42);
}
