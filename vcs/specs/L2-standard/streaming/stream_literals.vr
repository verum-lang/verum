// =============================================================================
// Main test runner
// =============================================================================

fn main() {
    // Element-based streams
    test_stream_elements_basic();
    test_stream_elements_single();
    test_stream_elements_finite();
    test_stream_elements_empty();
    test_stream_elements_collect_take();

    // Arithmetic sequence detection
    test_stream_arithmetic_sequence();
    test_stream_arithmetic_step();
    test_stream_arithmetic_negative();
    test_stream_not_arithmetic_cycles();

    // Range-based streams
    test_stream_range_exclusive();
    test_stream_range_inclusive();
    test_stream_range_empty();
    test_stream_range_negative();
    test_stream_range_infinite();
    test_stream_range_infinite_from_value();

    // Laziness
    test_stream_is_lazy();
    test_stream_range_is_lazy();

    // Type inference
    test_stream_element_type_inference();
    test_stream_range_type_inference();

    // Pipeline integration
    test_stream_pipeline();
    test_stream_range_pipeline();
    test_stream_with_transducer();

    // Edge cases
    test_stream_text_elements();
    test_stream_bool_cycle();

    print("All stream literal tests passed!");
}
