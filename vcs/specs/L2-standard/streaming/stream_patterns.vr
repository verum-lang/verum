// =============================================================================
// stream_patterns.vr - Tests for stream pattern matching
// =============================================================================
// @test: unit
// @tier: 2
// @level: L2
// @tags: streaming, patterns, iterator, destructuring, lazy
// @spec: docs/improvements.md Section 18.3 - Stream Pattern Matching
// =============================================================================
//
// Tests for stream pattern syntax in match expressions:
// - stream[first, second, ...rest] - consume head, bind rest
// - stream[head, ...tail] - consume one, bind remaining
// - stream[] - match empty stream
//
// Key difference from slice patterns:
// - Stream patterns consume lazily from iterator
// - Rest binding is remaining ITERATOR, not a list
//
// =============================================================================

module tests.streaming.stream_patterns;

mount core.*;

// =============================================================================
// Test 1: Basic stream pattern matching
// =============================================================================

fn test_stream_pattern_single_head() {
    let stream = [1, 2, 3, 4, 5].iter();

    match stream {
        stream[first, ...rest] => {
            assert_eq(first, 1);
            // rest is remaining iterator
            let remaining = rest.collect<List<Int>>();
            assert_eq(remaining, [2, 3, 4, 5]);
        }
    }
}

fn test_stream_pattern_two_heads() {
    let stream = [10, 20, 30, 40].iter();

    match stream {
        stream[first, second, ...rest] => {
            assert_eq(first, 10);
            assert_eq(second, 20);
            let remaining = rest.collect<List<Int>>();
            assert_eq(remaining, [30, 40]);
        }
    }
}

fn test_stream_pattern_three_heads() {
    let stream = ["a", "b", "c", "d", "e"].iter();

    match stream {
        stream[a, b, c, ...rest] => {
            assert_eq(a, "a");
            assert_eq(b, "b");
            assert_eq(c, "c");
            let remaining = rest.collect<List<Text>>();
            assert_eq(remaining, ["d", "e"]);
        }
    }
}

// =============================================================================
// Test 2: Empty stream pattern
// =============================================================================

fn test_stream_pattern_empty_match() {
    let stream: List<Int> = [];
    let iter = stream.iter();

    match iter {
        stream[] => {
            // Empty stream matched
            assert(true);
        }
        stream[_, ...] => {
            assert(false);  // Should not match
        }
    }
}

fn test_stream_pattern_empty_vs_nonempty() {
    fn classify<I: Iterator<Item = Int>>(stream: I) -> Text {
        match stream {
            stream[] => "empty",
            stream[only] => f"single: {only}",
            stream[first, second, ...] => f"multiple starting with {first}, {second}",
        }
    }

    assert_eq(classify([].iter()), "empty");
    assert_eq(classify([42].iter()), "single: 42");
    assert_eq(classify([1, 2].iter()), "multiple starting with 1, 2");
    assert_eq(classify([1, 2, 3, 4, 5].iter()), "multiple starting with 1, 2");
}

// =============================================================================
// Test 3: Stream patterns with nested patterns
// =============================================================================

fn test_stream_pattern_with_tuple_destructuring() {
    let stream = [(1, "a"), (2, "b"), (3, "c")].iter();

    match stream {
        stream[(n, s), ...rest] => {
            assert_eq(n, 1);
            assert_eq(s, "a");
            let remaining = rest.collect<List<(Int, Text)>>();
            assert_eq(remaining.len(), 2);
        }
    }
}

fn test_stream_pattern_with_variant() {
    type Item is Value(Int) | Empty;

    let stream = [Value(1), Value(2), Empty, Value(3)].iter();

    match stream {
        stream[Value(first), Value(second), ...rest] => {
            assert_eq(first, 1);
            assert_eq(second, 2);
        }
        _ => assert(false),
    }
}

// =============================================================================
// Test 4: Stream pattern exhaustiveness
// =============================================================================

fn test_stream_pattern_exhaustive() {
    fn process<I: Iterator<Item = Int>>(stream: I) -> Int {
        match stream {
            stream[] => 0,
            stream[only] => only,
            stream[a, b, ...rest] => a + b + rest.fold(0, |acc, x| acc + x),
        }
    }

    assert_eq(process([].iter()), 0);
    assert_eq(process([10].iter()), 10);
    assert_eq(process([1, 2, 3, 4].iter()), 10);
}

// =============================================================================
// Test 5: Stream pattern with guards
// =============================================================================

fn test_stream_pattern_with_guard() {
    let stream = [5, 10, 15, 20].iter();

    match stream {
        stream[first, ...rest] if first < 10 => {
            assert_eq(first, 5);
        }
        stream[first, ...rest] if first >= 10 => {
            assert(false);  // Should not reach
        }
        _ => assert(false),
    }
}

fn test_stream_pattern_multiple_guards() {
    fn categorize<I: Iterator<Item = Int>>(stream: I) -> Text {
        match stream {
            stream[] => "empty",
            stream[x, ...] if x < 0 => "starts negative",
            stream[x, ...] if x == 0 => "starts zero",
            stream[x, ...] if x > 0 && x < 10 => "starts small positive",
            stream[x, ...] => "starts large positive",
        }
    }

    assert_eq(categorize([].iter()), "empty");
    assert_eq(categorize([-5, 1, 2].iter()), "starts negative");
    assert_eq(categorize([0, 1, 2].iter()), "starts zero");
    assert_eq(categorize([5, 100, 200].iter()), "starts small positive");
    assert_eq(categorize([100, 200].iter()), "starts large positive");
}

// =============================================================================
// Test 6: Stream pattern without rest binding
// =============================================================================

fn test_stream_pattern_no_rest_binding() {
    let stream = [1, 2, 3, 4, 5].iter();

    match stream {
        stream[first, second, ...] => {
            // rest is discarded
            assert_eq(first, 1);
            assert_eq(second, 2);
        }
    }
    // Remaining elements [3, 4, 5] are dropped
}

fn test_stream_pattern_exact_count() {
    let stream = [1, 2, 3].iter();

    match stream {
        stream[a, b, c] => {
            // Exact match, no rest
            assert_eq(a, 1);
            assert_eq(b, 2);
            assert_eq(c, 3);
        }
        _ => assert(false),
    }
}

// =============================================================================
// Test 7: Stream pattern chaining operations
// =============================================================================

fn test_stream_pattern_chain_remaining() {
    let stream = range(0, 100);

    match stream {
        stream[first, ...rest] => {
            assert_eq(first, 0);

            // Chain operations on remaining iterator
            let sum = rest.take(10).fold(0, |acc, x| acc + x);
            // 1 + 2 + 3 + ... + 10 = 55
            assert_eq(sum, 55);
        }
    }
}

