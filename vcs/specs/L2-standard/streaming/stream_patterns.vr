// =============================================================================
// Test 9: Performance - laziness verification
// =============================================================================

fn test_stream_pattern_is_lazy() {
    // Pattern matching should only consume requested elements
    let mut call_count = 0;

    fn counted_iter() -> impl Iterator<Item = Int> {
        unfold(0, |state| {
            call_count = call_count + 1;
            let current = *state;
            *state = current + 1;
            Some(current)
        })
    }

    let stream = counted_iter();

    match stream {
        stream[first, second, ...rest] => {
            // Only 2 elements consumed by pattern
            assert_eq(first, 0);
            assert_eq(second, 1);
            // call_count should be 2, not infinite!
            assert_eq(call_count, 2);

            // Now consume 3 more
            let more = rest.take(3).collect<List<Int>>();
            assert_eq(more, [2, 3, 4]);
            assert_eq(call_count, 5);
        }
    }
}

// =============================================================================
// Test 10: Complex real-world examples
// =============================================================================

type Command is
    | Ping
    | Echo(Text)
    | Add(Int, Int)
    | Quit;

fn test_stream_pattern_command_processor() {
    fn process_commands<I: Iterator<Item = Command>>(commands: I) -> List<Text> {
        let mut results = List.new();

        fn process_recursive<I: Iterator<Item = Command>>(
            commands: I,
            results: &mut List<Text>
        ) {
            match commands {
                stream[] => {}  // Done
                stream[Ping, ...rest] => {
                    results.push("PONG");
                    process_recursive(rest, results);
                }
                stream[Echo(msg), ...rest] => {
                    results.push(msg);
                    process_recursive(rest, results);
                }
                stream[Add(a, b), ...rest] => {
                    results.push(f"{a + b}");
                    process_recursive(rest, results);
                }
                stream[Quit, ...] => {
                    results.push("GOODBYE");
                    // Don't process remaining
                }
            }
        }

        process_recursive(commands, &mut results);
        results
    }

    let commands = [Ping, Echo("hello"), Add(2, 3), Quit, Echo("ignored")].iter();
    let results = process_commands(commands);

    assert_eq(results, ["PONG", "hello", "5", "GOODBYE"]);
}

fn test_stream_pattern_parse_args() {
    fn parse_args<I: Iterator<Item = Text>>(args: I) -> Result<(Text, Int), Text> {
        match args {
            stream[] => Err("missing arguments"),
            stream[name] => Err("missing count"),
            stream[name, count_str, ...] => {
                match count_str.parse_int() {
                    Ok(count) => Ok((name, count)),
                    Err(_) => Err(f"invalid count: {count_str}"),
                }
            }
        }
    }

    assert_eq(parse_args([].iter()), Err("missing arguments"));
    assert_eq(parse_args(["name"].iter()), Err("missing count"));
    assert_eq(parse_args(["name", "42"].iter()), Ok(("name", 42)));
    assert_eq(parse_args(["name", "abc"].iter()), Err("invalid count: abc"));
    assert_eq(parse_args(["name", "10", "extra", "args"].iter()), Ok(("name", 10)));
}

// =============================================================================
// Main test runner
// =============================================================================

fn main() {
    // Basic stream patterns
    test_stream_pattern_single_head();
    test_stream_pattern_two_heads();
    test_stream_pattern_three_heads();

    // Empty stream
    test_stream_pattern_empty_match();
    test_stream_pattern_empty_vs_nonempty();

    // Nested patterns
    test_stream_pattern_with_tuple_destructuring();
    test_stream_pattern_with_variant();

    // Exhaustiveness
    test_stream_pattern_exhaustive();

    // Guards
    test_stream_pattern_with_guard();
    test_stream_pattern_multiple_guards();

    // Without rest binding
    test_stream_pattern_no_rest_binding();
    test_stream_pattern_exact_count();

    // Chaining
    test_stream_pattern_chain_remaining();

    // With stream literals (commented out - stream literal construction not yet supported)
    // test_stream_pattern_on_stream_literal();
    // test_stream_pattern_on_range_literal();

    // Laziness
    test_stream_pattern_is_lazy();

    // Real-world examples
    test_stream_pattern_command_processor();
    test_stream_pattern_parse_args();

    print("All stream pattern tests passed!");
}
