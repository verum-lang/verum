/// Practical combinator patterns
fn practical_patterns() {
    // Config loading with defaults
    fn load_config() -> Config {
        Config {
            database_url: std.env.var("DATABASE_URL").ok(),
            port: std.env.var("PORT").ok().and_then(|s| s.parse().ok()),
            max_retries: Some(3)
        }
    }

    fn get_port(config: &Config) -> Int {
        config.port
            .filter(|p| *p > 0 && *p < 65536)
            .unwrap_or(8080)
    }

    // Data transformation pipeline
    fn process_user(id: Int) -> Maybe<Text> {
        find_user(id)
            .filter(|u| u.age.map_or(false, |a| a >= 18))
            .and_then(|u| u.email)
            .map(|e| e.to_lowercase())
    }

    fn find_user(id: Int) -> Maybe<User> {
        if id == 1 {
            Some(User {
                id: 1,
                name: "Alice",
                email: Some("ALICE@EXAMPLE.COM"),
                age: Some(25)
            })
        } else {
            None
        }
    }

    // Optional chaining simulation
    fn get_nested_value(data: &Map<Text, Map<Text, Int>>) -> Maybe<Int> {
        data.get("outer")
            .and_then(|inner| inner.get("key"))
            .cloned()
    }

    // Combining multiple optional sources
    fn get_best_value(
        primary: Maybe<Int>,
        secondary: Maybe<Int>,
        default: Int
    ) -> Int {
        primary
            .filter(|v| *v > 0)  // Must be positive
            .or(secondary.filter(|v| *v > 0))
            .unwrap_or(default)
    }
}

/// Combining with iteration
fn iteration_combinators() {
    let items: List<Maybe<Int>> = [Some(1), None, Some(2), None, Some(3)];

    // Filter out Nones
    let values: List<Int> = items.into_iter()
        .flatten()  // Flatten removes Nones
        .collect();
    assert_eq(values, [1, 2, 3]);

    // Map and flatten
    fn lookup(id: Int) -> Maybe<User> {
        if id > 0 {
            Some(User { id, name: format("User{}", id), email: None, age: None })
        } else {
            None
        }
    }

    let ids = [1, -1, 2, 0, 3];
    let users: List<User> = ids.into_iter()
        .map(lookup)
        .flatten()
        .collect();
    assert_eq(users.len(), 3);
}

fn main() {
    // map example
    let mapped = Some(42).map(|n| n * 2);
    println(format("Mapped: {}", mapped.unwrap()));

    // and_then example
    let chained = Some(42)
        .and_then(|n| Some(n * 2))
        .and_then(|n| Some(n + 42));
    println(format("Chained: {}", chained.unwrap()));

    // or_else example
    let alternative: Maybe<Int> = None;
    let with_alt = alternative.or_else(|| Some(42));
    println(format("Alternative: {}", with_alt.unwrap()));

    println("Operation completed");
}
