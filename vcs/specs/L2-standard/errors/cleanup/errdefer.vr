// @test: run
// @expected-stdout: Success path: defer only\nError path: errdefer then defer\nOrder: errdefer runs first, then defer\nResource cleanup on error: released\nAll tests passed
// @tier: 0
// @level: L2
// @tags: errors, cleanup, errdefer, defer, error-path
// @description: Test errdefer only runs on error path, and ordering with defer

/// Errdefer semantics tests.
/// errdefer: Only executes when scope exits via error path
/// defer: Always executes at scope exit (success or error)
/// Spec: grammar/verum.ebnf Section 2.13 - defer_stmt
/// Spec: docs/detailed/20-error-handling.md Section 2.7 - The errdefer Pattern

// === Types for testing ===

type ResourceError is
    | AcquisitionFailed(Text)
    | OperationFailed(Text)
    | CleanupFailed(Text);

type Resource is {
    id: Int,
    name: Text,
    is_acquired: Bool
};

type Log is {
    entries: List<Text>
};

// === Global log for tracking execution order ===

static mut GLOBAL_LOG: List<Text> = List.new();

fn clear_log() {
    GLOBAL_LOG.clear();
}

fn log(msg: Text) {
    GLOBAL_LOG.push(msg);
}

fn get_log() -> List<Text> {
    GLOBAL_LOG.clone()
}

// === Basic errdefer vs defer ===

/// Errdefer does NOT run on success path
fn success_path() -> Result<Int, Text> {
    clear_log();

    defer log("defer_executed");
    errdefer log("errdefer_executed");  // Should NOT run

    log("operation_start");
    let result = 42;
    log("operation_success");

    Ok(result)
}

/// Errdefer DOES run on error path
fn error_path() -> Result<Int, Text> {
    clear_log();

    defer log("defer_executed");
    errdefer log("errdefer_executed");  // Should run

    log("operation_start");
    Err("intentional_failure")?;

    // This line never reached
    Ok(42)
}

// === Execution order: errdefer before defer ===

/// When both run, errdefer executes before defer (LIFO within category)
fn order_on_error() -> Result<Int, Text> {
    clear_log();

    defer log("defer_1");
    errdefer log("errdefer_1");
    defer log("defer_2");
    errdefer log("errdefer_2");

    Err("error")?;
    Ok(42)
}
// Expected order: errdefer_2, errdefer_1, defer_2, defer_1
// (errdefers in reverse order, then defers in reverse order)

/// Multiple errdefers execute in LIFO order
fn multiple_errdefers() -> Result<Int, Text> {
    clear_log();

    errdefer log("errdefer_first_declared");
    errdefer log("errdefer_second_declared");
    errdefer log("errdefer_third_declared");

    Err("error")?;
    Ok(42)
}
// Expected: third, second, first (LIFO)

// === Errdefer with resource cleanup ===

fn acquire_resource(id: Int) -> Result<Resource, ResourceError> {
    if id < 0 {
        Err(ResourceError.AcquisitionFailed("Invalid ID"))
    } else {
        Ok(Resource { id, name: format("Resource_{}", id), is_acquired: true })
    }
}

fn release_resource(resource: &Resource) {
    log(format("released_{}", resource.id));
}

fn use_resource(resource: &Resource) -> Result<Int, ResourceError> {
    if resource.id == 999 {
        Err(ResourceError.OperationFailed("Special ID causes failure"))
    } else {
        Ok(resource.id * 10)
    }
}

/// Resource cleanup with errdefer - only cleans up on error
fn resource_with_errdefer(id: Int) -> Result<Int, ResourceError> {
    clear_log();

    let resource = acquire_resource(id)?;

    // Only release on error - success case keeps resource
    errdefer release_resource(&resource);

    log("using_resource");
    let result = use_resource(&resource)?;
    log("success");

    Ok(result)
}

/// Contrast: defer always releases
fn resource_with_defer(id: Int) -> Result<Int, ResourceError> {
    clear_log();

    let resource = acquire_resource(id)?;

    // Always release - even on success
    defer release_resource(&resource);

    log("using_resource");
    let result = use_resource(&resource)?;
    log("success");

    Ok(result)
}

// === Errdefer with partial initialization ===

type ComplexResource is {
    part1: Maybe<Resource>,
    part2: Maybe<Resource>,
    part3: Maybe<Resource>
};

fn partial_init(fail_at: Int) -> Result<ComplexResource, ResourceError> {
    clear_log();

    let mut complex = ComplexResource {
        part1: None,
        part2: None,
        part3: None
    };

    // Acquire part1
    complex.part1 = Some(acquire_resource(1)?);
    errdefer {
        if let Some(ref r) = complex.part1 {
            release_resource(r);
        }
    }
    log("part1_acquired");

    // Acquire part2
    if fail_at == 2 {
        Err(ResourceError.AcquisitionFailed("Simulated failure at part2"))?;
    }
    complex.part2 = Some(acquire_resource(2)?);
    errdefer {
        if let Some(ref r) = complex.part2 {
            release_resource(r);
        }
    }
    log("part2_acquired");

    // Acquire part3
    if fail_at == 3 {
        Err(ResourceError.AcquisitionFailed("Simulated failure at part3"))?;
    }
    complex.part3 = Some(acquire_resource(3)?);
    // No errdefer for part3 - handled by success path
    log("part3_acquired");

    Ok(complex)
}

// === Errdefer with expression body ===

fn errdefer_expression_body() -> Result<Int, Text> {
    clear_log();

    let counter = 0;

    // Single expression errdefer
    errdefer log(format("counter_at_error: {}", counter));

    Err("fail")?;
    Ok(42)
}

/// Errdefer with block body
fn errdefer_block_body() -> Result<Int, Text> {
    clear_log();

    let resource_id = 100;

    errdefer {
        log("cleanup_start");
        log(format("cleaning_resource_{}", resource_id));
        log("cleanup_end");
    }

    Err("fail")?;
    Ok(42)
}

// === Errdefer captures values at declaration ===

fn errdefer_captures_at_declaration() -> Result<Int, Text> {
    clear_log();

    let mut value = 1;
    errdefer log(format("errdefer_sees: {}", value));

    value = 2;  // Changed after errdefer declared

    defer log(format("defer_sees: {}", value));

    value = 3;  // Changed again

    Err("fail")?;
    Ok(42)
}
// errdefer captures value at declaration time (1)
// defer sees current value at execution time (3)

// === Errdefer in loops ===

fn errdefer_in_loop() -> Result<Int, Text> {
    clear_log();

    for i in 0..3 {
        errdefer log(format("loop_errdefer_{}", i));

        if i == 2 {
            Err("fail_at_2")?;
        }
    }

    Ok(42)
}
// Only errdefer from iteration 2 runs (others already exited successfully)

// === Errdefer with nested scopes ===

fn nested_errdefer() -> Result<Int, Text> {
    clear_log();

    errdefer log("outer_errdefer");

    let result = {
        errdefer log("inner_errdefer");

        // Inner scope exits with error
        Err("inner_error")?;
        42
    };

    Ok(result)
}
// Both inner and outer errdefers run

// === Errdefer with try-recover interaction ===

fn errdefer_with_recover() -> Int {
    clear_log();

    try {
        errdefer log("errdefer_in_try");
        defer log("defer_in_try");

        Err("trigger_recover")?;
        42
    } recover |_e| {
        log("in_recover");
        0
    }
}
// errdefer runs before recover handles the error

// === Transaction pattern with errdefer ===

type Transaction is {
    id: Int,
    active: Bool
};

fn begin_transaction() -> Transaction {
    log("tx_begin");
    Transaction { id: 1, active: true }
}

fn commit_transaction(tx: &mut Transaction) {
    log("tx_commit");
    tx.active = false;
}

fn rollback_transaction(tx: &mut Transaction) {
    log("tx_rollback");
    tx.active = false;
}

fn transactional_operation(should_fail: Bool) -> Result<Int, Text> {
    clear_log();

    let mut tx = begin_transaction();

    // Rollback on error, commit on success
    errdefer rollback_transaction(&mut tx);

    if should_fail {
        Err("operation_failed")?;
    }

    log("operation_success");
    commit_transaction(&mut tx);

    Ok(42)
}

// === Verification tests ===

fn main() {
    // Test 1: Success path - only defer runs
    let _ = success_path();
    let log1 = get_log();
    assert(log1.contains(&"defer_executed"));
    assert(!log1.contains(&"errdefer_executed"));
    println("Success path: defer only");

    // Test 2: Error path - both run
    let _ = error_path();
    let log2 = get_log();
    assert(log2.contains(&"defer_executed"));
    assert(log2.contains(&"errdefer_executed"));
    println("Error path: errdefer then defer");

    // Test 3: Execution order
    let _ = order_on_error();
    let log3 = get_log();
    // Find indices to verify order
    let idx_errdefer_2 = log3.iter().position(|s| s == "errdefer_2").unwrap();
    let idx_errdefer_1 = log3.iter().position(|s| s == "errdefer_1").unwrap();
    let idx_defer_2 = log3.iter().position(|s| s == "defer_2").unwrap();
    let idx_defer_1 = log3.iter().position(|s| s == "defer_1").unwrap();
    assert(idx_errdefer_2 < idx_errdefer_1);  // LIFO within errdefers
    assert(idx_errdefer_1 < idx_defer_2);      // errdefers before defers
    assert(idx_defer_2 < idx_defer_1);         // LIFO within defers
    println("Order: errdefer runs first, then defer");

    // Test 4: Resource cleanup on error
    let result4 = resource_with_errdefer(999);  // Will fail
    assert(result4.is_err());
    let log4 = get_log();
    assert(log4.contains(&"released_999"));
    println("Resource cleanup on error: released");

    // Test 5: Resource NOT cleaned on success with errdefer
    let result5 = resource_with_errdefer(1);  // Will succeed
    assert(result5.is_ok());
    let log5 = get_log();
    assert(!log5.contains(&"released_1"));  // NOT released on success

    // Test 6: Resource cleaned on success with defer
    let result6 = resource_with_defer(1);  // Will succeed
    assert(result6.is_ok());
    let log6 = get_log();
    assert(log6.contains(&"released_1"));  // Released even on success

    // Test 7: Partial initialization cleanup
    let result7 = partial_init(3);  // Fail at part3
    assert(result7.is_err());
    let log7 = get_log();
    assert(log7.contains(&"part1_acquired"));
    assert(log7.contains(&"part2_acquired"));
    assert(!log7.contains(&"part3_acquired"));
    assert(log7.contains(&"released_2"));  // part2 cleaned up
    assert(log7.contains(&"released_1"));  // part1 cleaned up

    // Test 8: Transaction rollback on error
    let tx_fail = transactional_operation(true);
    assert(tx_fail.is_err());
    let log8 = get_log();
    assert(log8.contains(&"tx_begin"));
    assert(log8.contains(&"tx_rollback"));
    assert(!log8.contains(&"tx_commit"));

    // Test 9: Transaction commit on success
    let tx_ok = transactional_operation(false);
    assert(tx_ok.is_ok());
    let log9 = get_log();
    assert(log9.contains(&"tx_begin"));
    assert(log9.contains(&"tx_commit"));
    assert(!log9.contains(&"tx_rollback"));

    // Test 10: errdefer with try-recover
    let recover_result = errdefer_with_recover();
    assert(recover_result == 0);
    let log10 = get_log();
    // errdefer should run before recover takes over
    assert(log10.contains(&"errdefer_in_try"));
    assert(log10.contains(&"defer_in_try"));
    assert(log10.contains(&"in_recover"));

    println("All tests passed");
}
