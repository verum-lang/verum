// @test: run
// @expected-stdout: Cleanup executed\nFile closed: /data.txt\nOperation result: 42
// @tier: 0
// @level: L2
// @tags: errors, recovery, try, finally, cleanup
// @description: try { } finally { } guaranteed cleanup pattern

/// Try-finally pattern - guaranteed cleanup execution.
/// The finally clause always runs, regardless of success or failure.

type ResourceError is
    | AcquisitionFailed(Text)
    | OperationFailed(Text)
    | ReleaseFailed(Text);

type Resource is {
    id: Int,
    name: Text,
    is_open: Bool
};

/// Resource acquisition
fn acquire(id: Int) -> Result<Resource, ResourceError> {
    if id > 0 {
        Ok(Resource { id, name: f"Resource_{id}", is_open: true })
    } else {
        Err(ResourceError.AcquisitionFailed("Invalid resource ID"))
    }
}

fn release(resource: &Resource) {
    println(f"Releasing resource: {resource.name}");
}

/// Basic try-finally - cleanup always runs
fn with_resource<T, F>(
    resource_id: Int,
    operation: F
) -> Result<T, ResourceError>
where F: Fn(&Resource) -> Result<T, ResourceError> {
    let mut resource: Maybe<Resource> = None;

    try {
        resource = Some(acquire(resource_id)?);
        operation(resource.as_ref().unwrap())
    } finally {
        // Cleanup always runs
        if let Some(ref r) = resource {
            release(r);
        }
    }
}

/// File-like resource with try-finally
type FileHandle is {
    path: Text,
    is_open: Bool
};

type FileError is
    | OpenFailed(Text)
    | ReadFailed(Text)
    | WriteFailed(Text)
    | CloseFailed(Text);

fn open_file(path: &Text) -> Result<FileHandle, FileError> {
    if path.starts_with("/") {
        Ok(FileHandle { path: path.clone(), is_open: true })
    } else {
        Err(FileError.OpenFailed(path.clone()))
    }
}

fn close_file(handle: &mut FileHandle) {
    if handle.is_open {
        println(f"File closed: {handle.path}");
        handle.is_open = false;
    }
}

fn read_contents(handle: &FileHandle) -> Result<Text, FileError> {
    if handle.is_open {
        Ok("file contents")
    } else {
        Err(FileError.ReadFailed("File not open"))
    }
}

/// File reading with guaranteed close
fn read_file_safe(path: &Text) -> Result<Text, FileError> {
    let mut file: Maybe<FileHandle> = None;

    try {
        file = Some(open_file(path)?);
        read_contents(file.as_ref().unwrap())
    } finally {
        // File is always closed, even if read fails
        if let Some(ref mut f) = file {
            close_file(f);
        }
    }
}

/// Finally execution order demonstration
fn execution_order() -> Result<Int, Text> {
    let mut log: List<Text> = List.new();

    let result = try {
        log.push("1. Try body start");
        let value = Some(42).ok_or("missing")?;
        log.push("2. Try body end");
        value
    } finally {
        log.push("3. Finally block");
        // Log: ["1. Try body start", "2. Try body end", "3. Finally block"]
    };

    result
}

/// Finally runs even on error
fn finally_on_error() -> Result<Int, Text> {
    let mut cleanup_ran = false;

    let result = try {
        let r: Result<Int, Text> = Err("intentional error");
        let _ = r?;
        42
    } finally {
        cleanup_ran = true;
        // This still runs despite the error
    };

    // cleanup_ran is true even though error occurred
    result
}

/// Finally with return value - doesn't affect result
fn finally_with_logging<T>(
    operation: fn() -> Result<T, Text>,
    operation_name: &Text
) -> Result<T, Text> {
    let start_time = now();

    try {
        operation()
    } finally {
        let elapsed = now() - start_time;
        println(f"{operation_name} completed in {elapsed}ms");
    }
}

fn now() -> Int {
    0 // Placeholder
}

/// Connection pool with finally
type Connection is {
    id: Int,
    is_active: Bool
};

type ConnectionPool is {
    connections: List<Connection>,
    max_size: Int
};

fn borrow_connection(pool: &mut ConnectionPool) -> Result<Connection, Text> {
    if pool.connections.is_empty() {
        Err("No connections available")
    } else {
        Ok(pool.connections.pop().unwrap())
    }
}

fn return_connection(pool: &mut ConnectionPool, conn: Connection) {
    pool.connections.push(conn);
}

fn with_connection<T, F>(
    pool: &mut ConnectionPool,
    operation: F
) -> Result<T, Text>
where F: Fn(&Connection) -> Result<T, Text> {
    let conn = borrow_connection(pool)?;

    try {
        operation(&conn)
    } finally {
        return_connection(pool, conn);
    }
}

/// Lock-like resource management
type Lock is {
    name: Text,
    held: Bool
};

fn acquire_lock(name: &Text) -> Lock {
    Lock { name: name.clone(), held: true }
}

fn release_lock(lock: &mut Lock) {
    lock.held = false;
}

fn with_lock<T, F>(lock_name: &Text, operation: F) -> T
where F: Fn() -> T {
    let mut lock = acquire_lock(lock_name);

    try {
        operation()
    } finally {
        release_lock(&mut lock);
    }
}

/// Multiple resources with nested finally
fn multi_resource_operation() -> Result<Int, Text> {
    let mut resource1: Maybe<Resource> = None;
    let mut resource2: Maybe<Resource> = None;

    try {
        resource1 = Some(acquire(1).map_err(|e| f"{e}")?);

        try {
            resource2 = Some(acquire(2).map_err(|e| f"{e}")?);

            // Use both resources
            let r1 = resource1.as_ref().unwrap();
            let r2 = resource2.as_ref().unwrap();
            r1.id + r2.id
        } finally {
            // Release resource2 first (LIFO order)
            if let Some(ref r) = resource2 {
                release(r);
            }
        }
    } finally {
        // Release resource1
        if let Some(ref r) = resource1 {
            release(r);
        }
    }
}

/// Async context with finally
async fn async_with_finally() -> Result<Int, Text> {
    let mut resource_acquired = false;

    try {
        resource_acquired = true;
        async_operation().await
    } finally {
        if resource_acquired {
            async_cleanup().await;
        }
    }
}

async fn async_operation() -> Result<Int, Text> {
    Ok(42)
}

async fn async_cleanup() {
    // Async cleanup operations
}

/// Transaction-like pattern
type Transaction is {
    id: Int,
    active: Bool
};

fn begin_transaction() -> Transaction {
    Transaction { id: 1, active: true }
}

fn commit(tx: &mut Transaction) {
    tx.active = false;
}

fn rollback(tx: &mut Transaction) {
    tx.active = false;
}

fn with_transaction<T, F>(operation: F) -> Result<T, Text>
where F: Fn(&Transaction) -> Result<T, Text> {
    let mut tx = begin_transaction();
    let mut success = false;

    let result = try {
        let r = operation(&tx)?;
        success = true;
        r
    } finally {
        if success {
            commit(&mut tx);
        } else {
            rollback(&mut tx);
        }
    };

    result
}

fn main() {
    // Basic finally demonstration
    let content = try {
        let value = Some(42).ok_or("missing")?;
        value
    } finally {
        println("Cleanup executed");
    };

    // File with guaranteed close
    let _ = read_file_safe("/data.txt");

    let val = content.unwrap_or(0);
    println(f"Operation result: {val}");
}
