// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: errors, custom, definition, type

/// Custom error type definition - creating domain-specific error types.
/// Best practices for defining error types in Verum.

/// Simple error enum - most common pattern
type ParseError is
    | EmptyInput
    | UnexpectedChar(Char)
    | UnexpectedEof
    | InvalidToken { expected: Text, found: Text, position: Int }

    /// Nested parse error from sub-parser
    | Nested(Heap<ParseError>)
;

/// Error type with Display implementation
implement Display for ParseError {
    fn display(&self) -> Text {
        match self {
            ParseError.EmptyInput =>
                "Cannot parse empty input",
            ParseError.UnexpectedChar(c) =>
                f"Unexpected character: '{c}'",
            ParseError.UnexpectedEof =>
                "Unexpected end of input",
            ParseError.InvalidToken { expected, found, position } =>
                f"Expected {expected} at position {position}, found {found}",
            ParseError.Nested(inner) =>
                f"Parse error: {inner}",
        }
    }
}

/// Error type with Debug implementation
implement Debug for ParseError {
    fn debug(&self) -> Text {
        match self {
            ParseError.EmptyInput =>
                "ParseError.EmptyInput",
            ParseError.UnexpectedChar(c) =>
                f"ParseError.UnexpectedChar({c})",
            ParseError.UnexpectedEof =>
                "ParseError.UnexpectedEof",
            ParseError.InvalidToken { expected, found, position } =>
                f"ParseError.InvalidToken {{ expected: {expected}, found: {found}, position: {position} }}",
            ParseError.Nested(inner) =>
                f"ParseError.Nested({inner})",
        }
    }
}

/// Error protocol implementation
type Error is protocol {
    /// Returns a short description of the error
    fn description(&self) -> &Text;

    /// Returns the source/cause of this error, if any
    fn source(&self) -> Maybe<&Error> {
        None
    }
};

implement Error for ParseError {
    fn description(&self) -> &Text {
        match self {
            ParseError.EmptyInput => "empty input",
            ParseError.UnexpectedChar(_) => "unexpected character",
            ParseError.UnexpectedEof => "unexpected end of input",
            ParseError.InvalidToken { .. } => "invalid token",
            ParseError.Nested(_) => "nested parse error"
        }
    }

    fn source(&self) -> Maybe<&Error> {
        None
    }
}

/// Struct-based error - for more complex error data
type ValidationError is {
    /// The field that failed validation
    field: Text,

    /// The invalid value (as string for display)
    value: Text,

    /// The validation rule that was violated
    rule: ValidationRule,

    /// Human-readable error message
    message: Text,

    /// Optional suggestions for fixing the error
    suggestions: List<Text>
};

type ValidationRule is
    | Required
    | MinLength(Int)
    | MaxLength(Int)
    | Pattern(Text)
    | Range { min: Int, max: Int }
    | Custom(Text)
;

implement ValidationError {
    /// Create a new validation error
    fn new(field: Text, value: Text, rule: ValidationRule) -> Self {
        let message = Self.generate_message(&field, &value, &rule);
        ValidationError {
            field,
            value,
            rule,
            message,
            suggestions: List.new()
        }
    }

    /// Add a suggestion for fixing this error
    fn with_suggestion(mut self, suggestion: Text) -> Self {
        self.suggestions.push(suggestion);
        self
    }

    /// Generate human-readable message
    fn generate_message(field: &Text, value: &Text, rule: &ValidationRule) -> Text {
        match rule {
            ValidationRule.Required =>
                f"Field '{field}' is required",
            ValidationRule.MinLength(min) =>
                f"Field '{field}' must be at least {min} characters",
            ValidationRule.MaxLength(max) =>
                f"Field '{field}' must be at most {max} characters",
            ValidationRule.Pattern(pattern) =>
                f"Field '{field}' must match pattern: {pattern}",
            ValidationRule.Range { min, max } =>
                f"Field '{field}' must be between {min} and {max}",
            ValidationRule.Custom(msg) =>
                f"Field '{field}': {msg}",
        }
    }
}

implement Display for ValidationError {
    fn display(&self) -> Text {
        if !self.suggestions.is_empty() {
            let joined = self.suggestions.join(", ");
            f"{self.message} (suggestions: {joined})"
        } else {
            self.message.clone()
        }
    }
}

/// Error with source location tracking
type CompileError is {
    kind: CompileErrorKind,
    location: SourceLocation,
    notes: List<Note>
};

type CompileErrorKind is
    | Syntax(Text)
    | Type { expected: Text, found: Text }
    | Undefined(Text)
    | Duplicate(Text)
    | Circular(List<Text>)
;

type SourceLocation is {
    file: Text,
    line: Int,
    column: Int,
    span: Int
};

type Note is {
    message: Text,
    location: Maybe<SourceLocation>
};

implement CompileError {
    fn new(kind: CompileErrorKind, location: SourceLocation) -> Self {
        CompileError {
            kind,
            location,
            notes: List.new()
        }
    }

    fn with_note(mut self, message: Text) -> Self {
        self.notes.push(Note { message, location: None });
        self
    }

    fn with_note_at(mut self, message: Text, location: SourceLocation) -> Self {
        self.notes.push(Note { message, location: Some(location) });
        self
    }
}

/// Error code pattern - for stable error identification
type NetworkError is {
    code: ErrorCode,
    message: Text,
    source: Maybe<Heap<Error>>
};

type ErrorCode is
    | E1001_ConnectionRefused
    | E1002_ConnectionTimeout
    | E1003_ConnectionReset
    | E2001_InvalidProtocol
    | E2002_HandshakeFailed
    | E2003_InvalidMessage
    | E3001_ResourceExhausted
    | E3002_QuotaExceeded
    | E3003_RateLimited;

implement ErrorCode {
    fn code(&self) -> Int {
        match self {
            ErrorCode.E1001_ConnectionRefused => 1001,
            ErrorCode.E1002_ConnectionTimeout => 1002,
            ErrorCode.E1003_ConnectionReset => 1003,
            ErrorCode.E2001_InvalidProtocol => 2001,
            ErrorCode.E2002_HandshakeFailed => 2002,
            ErrorCode.E2003_InvalidMessage => 2003,
            ErrorCode.E3001_ResourceExhausted => 3001,
            ErrorCode.E3002_QuotaExceeded => 3002,
            ErrorCode.E3003_RateLimited => 3003
        }
    }

    fn is_retriable(&self) -> Bool {
        match self {
            ErrorCode.E1002_ConnectionTimeout => true,
            ErrorCode.E1003_ConnectionReset => true,
            ErrorCode.E3003_RateLimited => true,
            _ => false
        }
    }
}

/// Generic error wrapper for adding context
type ContextError<E> is {
    inner: E,
    context: Text
};

implement<E: Error> ContextError<E> {
    fn new(inner: E, context: Text) -> Self {
        ContextError { inner, context }
    }
}

implement<E: Error> Display for ContextError<E> {
    fn display(&self) -> Text {
        f"{self.context}: {self.inner}"
    }
}

implement<E: Error> Error for ContextError<E> {
    fn description(&self) -> &Text {
        &self.context
    }

    fn source(&self) -> Maybe<&Error> {
        Some(&self.inner)
    }
}

/// Builder pattern for complex errors
type RequestError is {
    status_code: Int,
    message: Text,
    request_id: Maybe<Text>,
    timestamp: Int,
    details: Map<Text, Text>
};

type RequestErrorBuilder is {
    status_code: Int,
    message: Text,
    request_id: Maybe<Text>,
    timestamp: Maybe<Int>,
    details: Map<Text, Text>
};

implement RequestErrorBuilder {
    fn new(status_code: Int, message: Text) -> Self {
        RequestErrorBuilder {
            status_code,
            message,
            request_id: None,
            timestamp: None,
            details: Map.new()
        }
    }

    fn request_id(mut self, id: Text) -> Self {
        self.request_id = Some(id);
        self
    }

    fn timestamp(mut self, ts: Int) -> Self {
        self.timestamp = Some(ts);
        self
    }

    fn detail(mut self, key: Text, value: Text) -> Self {
        self.details.insert(key, value);
        self
    }

    fn build(self) -> RequestError {
        RequestError {
            status_code: self.status_code,
            message: self.message,
            request_id: self.request_id,
            timestamp: self.timestamp.unwrap_or_else(|| now()),
            details: self.details
        }
    }
}

fn now() -> Int {
    0 // Placeholder
}

fn main() {
    // Create and use custom errors
    let parse_err = ParseError.InvalidToken {
        expected: "identifier",
        found: "number",
        position: 42
    };

    print(f"Parse error: {parse_err}");

    let validation_err = ValidationError.new(
        "email",
        "invalid@",
        ValidationRule.Pattern("^[^@]+@[^@]+\\.[^@]+$")
    ).with_suggestion("Include a valid domain after @");

    print(f"Validation error: {validation_err}");

    let request_err = RequestErrorBuilder.new(404, "Not Found")
        .request_id("req-12345")
        .detail("path", "/api/users/999")
        .build();

    print(f"Request error: {request_err.message} ({request_err.status_code})");
}
