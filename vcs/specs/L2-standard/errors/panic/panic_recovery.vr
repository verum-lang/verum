}

fn log_panic(message: &Text, location: &Text) {
    println(f"PANIC at {location}: {message}");
}

/// Resumable panic handling (controlled unwinding)
fn resumable_operation<T, F, R>(
    operation: F,
    recovery: R
) -> T
where F: Fn() -> T, R: Fn(PanicInfo) -> T
{
    match catch_unwind(operation) {
        Ok(value) => value,
        Err(panic) => {
            let info = PanicInfo {
                message: f"{panic}",
                location: None
            };
            recovery(info)
        }
    }
}

/// Test helper for expecting panics
fn assert_panics<F>(f: F) -> PanicInfo
where F: Fn() {
    match catch_unwind(f) {
        Ok(_) => panic("Expected panic but operation succeeded"),
        Err(panic) => PanicInfo {
            message: f"{panic}",
            location: None
        }
    }
}

/// Panic recovery with retry
fn retry_on_panic<T, F>(
    operation: F,
    max_retries: Int
) -> Result<T, Text>
where F: Fn() -> T {
    let mut last_panic: Maybe<Text> = None;

    for attempt in 0..max_retries {
        match catch_unwind(operation.clone()) {
            Ok(value) => return Ok(value),
            Err(panic) => {
                let msg = f"{panic}";
                println(f"Attempt {attempt + 1} panicked: {msg}");
                last_panic = Some(msg);
            }
        }
    }

    Err(last_panic.unwrap_or_else(|| "Unknown error".to_text()))
}

/// Supervisor pattern - restart on panic
type Supervisor<T> is {
    task: Heap<fn() -> T>,
    restart_policy: RestartPolicy
};

type RestartPolicy is
    | Never
    | Always
    | OnPanic { max_restarts: Int }
    | Exponential { base_delay_ms: Int, max_delay_ms: Int }
;

implement<T> Supervisor<T> {
    fn run(&self) -> Result<T, SupervisorError> {
        match self.restart_policy {
            RestartPolicy.Never => {
                catch_unwind(&self.task)
                    .map_err(|_| SupervisorError.Panicked)
            },
            RestartPolicy.Always => {
                loop {
                    match catch_unwind(&self.task) {
                        Ok(value) => return Ok(value),
                        Err(_) => {
                            println("Task panicked, restarting...");
                            continue;
                        }
                    }
                }
            },
            RestartPolicy.OnPanic { max_restarts } => {
                for _ in 0..=max_restarts {
                    match catch_unwind(&self.task) {
                        Ok(value) => return Ok(value),
                        Err(_) => continue
                    }
                }
                Err(SupervisorError.MaxRestartsExceeded)
            },
            RestartPolicy.Exponential { base_delay_ms, max_delay_ms } => {
                let mut delay = base_delay_ms;
                loop {
                    match catch_unwind(&self.task) {
                        Ok(value) => return Ok(value),
                        Err(_) => {
                            sleep_ms(delay);
                            delay = (delay * 2).min(max_delay_ms);
                        }
                    }
                }
            }
        }
    }
}

type SupervisorError is
    | Panicked
    | MaxRestartsExceeded;

fn sleep_ms(ms: Int) {
    // Platform sleep
}

fn main() {
    // Demonstrate panic recovery
    let result = panic_to_result(|| {
        panic("test panic");
    });

    match result {
        Ok(v) => println(f"Got value: {v}"),
        Err(msg) => println(f"Caught panic: {msg}")
    }

    println("Recovered successfully");
}
