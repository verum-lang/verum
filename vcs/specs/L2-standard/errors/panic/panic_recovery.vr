/// Panic recovery - catching panics at boundaries.
/// Controlled panic catching for thread/task boundaries and FFI.

/// Basic catch_unwind pattern
fn catch_panic_basic() -> Result<Int, PanicInfo> {
    catch_unwind(|| {
        // Code that might panic
        let value = risky_operation().unwrap_or(0);
        value * 2
    })
}

fn risky_operation() -> Result<Int, Text> {
    // Might panic or return error
    Ok(42)
}

type PanicInfo is {
    message: Text,
    location: Maybe<Location>
};

type Location is {
    file: Text,
    line: Int,
    column: Int
};

/// Catch and convert panic to Result
fn panic_to_result<T, F>(f: F) -> Result<T, Text>
where F: Fn() -> T {
    match catch_unwind(f) {
        Ok(value) => Ok(value),
        Err(panic) => Err(f"Panic: {panic}")
    }
}

/// Panic recovery at thread boundary
fn thread_with_recovery() {
    let handle = spawn(|| {
        catch_unwind(|| {
            // Thread work that might panic
            process_data()
        })
    });

    match handle.join() {
        Ok(inner) => {
            match inner {
                Ok(result) => println(f"Thread result: {result}"),
                Err(panic_info) => println(f"Thread panicked: {panic_info}"),
            }
        },
        Err(join_error) => {
            println(f"Thread join error: {join_error}");
        }
    }
}

fn process_data() -> Int {
    42
}

/// Recovery with cleanup
fn recover_with_cleanup<T, F>(operation: F) -> Result<T, Text>
where F: Fn() -> T {
    let mut needs_cleanup = true;

    let result = catch_unwind(|| {
        let value = operation();
        needs_cleanup = false;  // Mark successful completion
        value
    });

    if needs_cleanup {
        // Perform cleanup after panic
        perform_emergency_cleanup();
    }

    result.map_err(|e| f"Operation panicked: {e}")
}

fn perform_emergency_cleanup() {
    println("Emergency cleanup executed");
}

/// Panic barrier for isolating subsystems
type PanicBarrier<T> is {
    result: Result<T, PanicInfo>
};

implement<T> PanicBarrier<T> {
    fn run<F>(f: F) -> Self
    where F: Fn() -> T {
        let result = catch_unwind(f);
        PanicBarrier {
            result: result.map_err(|p| PanicInfo {
                message: f"{p}",
                location: None
            })
        }
    }

    fn into_result(self) -> Result<T, PanicInfo> {
        self.result
    }

    fn unwrap_or(self, default: T) -> T {
        self.result.unwrap_or(default)
    }

    fn map<U, F>(self, f: F) -> PanicBarrier<U>
    where F: Fn(T) -> U {
        PanicBarrier {
            result: self.result.map(f)
        }
    }
}

