// @test: run
// @expected-stdout: Division result: 21.0\nUser found: Alice
// @tier: 0
// @level: L2
// @tags: errors, result, type

/// Result type - the primary error handling mechanism in Verum.
/// Result<T, E> represents either a success (Ok(T)) or failure (Err(E)).

/// Custom error type for arithmetic operations
type ArithmeticError is
    | DivisionByZero
    | Overflow
    | Underflow
    | InvalidOperand(Text);

/// Performs safe division, returning an error for division by zero
fn divide(x: Float, y: Float) -> Result<Float, ArithmeticError> {
    if y == 0.0 {
        Err(ArithmeticError.DivisionByZero)
    } else {
        Ok(x / y)
    }
}

/// Performs safe integer addition with overflow checking
fn safe_add(x: Int, y: Int) -> Result<Int, ArithmeticError> {
    let result = x + y;
    // Simplified overflow check (actual implementation would be more robust)
    if x > 0 && y > 0 && result < 0 {
        Err(ArithmeticError.Overflow)
    } else if x < 0 && y < 0 && result > 0 {
        Err(ArithmeticError.Underflow)
    } else {
        Ok(result)
    }
}

/// Result methods demonstration
fn demonstrate_result_methods() -> Result<Int, ArithmeticError> {
    let result = divide(84.0, 2.0);

    // is_ok() and is_err() methods
    if result.is_ok() {
        let value = result.unwrap();  // Safe because we checked is_ok
    }

    // unwrap_or() - provides default on error
    let with_default = divide(10.0, 0.0).unwrap_or(0.0);

    // unwrap_or_else() - lazy default computation
    let lazy_default = divide(10.0, 0.0).unwrap_or_else(|e| {
        match e {
            ArithmeticError.DivisionByZero => -1.0,
            _ => 0.0
        }
    });

    // map() - transform success value
    let mapped = divide(10.0, 2.0).map(|x| x as Int);

    // map_err() - transform error value
    let mapped_err = divide(10.0, 0.0).map_err(|e| {
        match e {
            ArithmeticError.DivisionByZero => "Cannot divide by zero",
            _ => "Unknown error"
        }
    });

    // and_then() - chain Result-returning operations
    let chained = divide(100.0, 2.0)
        .and_then(|x| divide(x, 2.0))
        .and_then(|x| divide(x, 2.0));

    // ok() - convert to Maybe<T>
    let as_maybe = divide(10.0, 2.0).ok();

    // err() - convert error to Maybe<E>
    let error_maybe = divide(10.0, 0.0).err();

    Ok(42)
}

/// Database-like user lookup example
type UserId is Int;

type User is {
    id: UserId,
    name: Text,
    email: Text
};

type UserError is
    | NotFound(UserId)
    | DatabaseError(Text)
    | PermissionDenied;

/// Simulated user database lookup
fn find_user(id: UserId) -> Result<User, UserError> {
    if id == 1 {
        Ok(User { id: 1, name: "Alice", email: "alice@example.com" })
    } else if id == 2 {
        Ok(User { id: 2, name: "Bob", email: "bob@example.com" })
    } else if id < 0 {
        Err(UserError.DatabaseError("Invalid user ID"))
    } else {
        Err(UserError.NotFound(id))
    }
}

/// Demonstrates pattern matching on Result
fn get_user_name(id: UserId) -> Text {
    match find_user(id) {
        Ok(user) => user.name,
        Err(UserError.NotFound(missing_id)) =>
            format("User {} not found", missing_id),
        Err(UserError.DatabaseError(msg)) =>
            format("Database error: {}", msg),
        Err(UserError.PermissionDenied) =>
            "Permission denied"
    }
}

/// Combining multiple Results with collect
fn get_multiple_users(ids: List<UserId>) -> Result<List<User>, UserError> {
    let mut users: List<User> = List.new();
    for id in ids {
        match find_user(id) {
            Ok(user) => users.push(user),
            Err(e) => return Err(e)
        }
    }
    Ok(users)
}

fn main() {
    // Basic Result usage
    let div_result = divide(42.0, 2.0);
    match div_result {
        Ok(value) => println(format("Division result: {}", value)),
        Err(e) => println("Division failed")
    }

    // User lookup
    let user_result = find_user(1);
    match user_result {
        Ok(user) => println(format("User found: {}", user.name)),
        Err(e) => println("User lookup failed")
    }
}
