// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: weft, proxy, health_check, active, surface
// @timeout: 15000
// @expected-exit: 0

// `core/net/proxy/health_check.vr` — surface check for the
// ActiveHealthChecker added to close net-framework.md §9.3 Phase 2
// follow-up "Active health-check runner".
//
// Validates that:
//
//   1. ActiveHealthChecker.new ties an Upstream + ProxyHealthStatus + cfg.
//   2. record_outcome respects healthy_threshold / unhealthy_threshold.
//   3. `Disabled` / `Passive` configs make `run` exit immediately.
//   4. The HealthProbe protocol is constructible.

mount core.*;
mount core.collections.list.{List};
mount core.net.proxy.health_check.{
    HealthCheck, ProxyHealthStatus, ActiveHealthChecker,
    HealthProbe, HealthCheckError,
};
mount core.net.proxy.upstream_pool.{Upstream};

fn checker_construction() {
    let up = Upstream.new(f"http", f"backend.local", 8080);
    let status = ProxyHealthStatus.new();
    let cfg = HealthCheck.active(5_000, f"/healthz");
    let chk = ActiveHealthChecker.new(up, status, cfg);
    assert(chk.probes_attempted() == 0);
    assert(chk.probes_ok() == 0);
}

fn record_outcome_threshold_marks_unhealthy_after_three_failures() {
    let up = Upstream.new(f"http", f"backend.local", 8080);
    let status = ProxyHealthStatus.new();
    // active(5s, /healthz) defaults — healthy_threshold=2,
    // unhealthy_threshold=3.
    let cfg = HealthCheck.active(5_000, f"/healthz");
    let chk = ActiveHealthChecker.new(up, status.clone_handle(), cfg);

    // Three consecutive failures must flip healthy → false.
    chk.record_outcome(false);
    assert(status.is_healthy());
    chk.record_outcome(false);
    assert(status.is_healthy());
    chk.record_outcome(false);
    assert(false == status.is_healthy());
}

fn record_outcome_two_successes_recover() {
    let up = Upstream.new(f"http", f"backend.local", 8080);
    let status = ProxyHealthStatus.new();
    let cfg = HealthCheck.active(5_000, f"/healthz");
    let chk = ActiveHealthChecker.new(up, status.clone_handle(), cfg);

    // Force unhealthy first.
    chk.record_outcome(false);
    chk.record_outcome(false);
    chk.record_outcome(false);
    assert(false == status.is_healthy());

    // Two successes restore health (default healthy_threshold=2).
    chk.record_outcome(true);
    assert(false == status.is_healthy());     // 1 < threshold
    chk.record_outcome(true);
    assert(status.is_healthy());               // 2 >= threshold
}

fn stop_signals_cancel() {
    let up = Upstream.new(f"http", f"backend.local", 8080);
    let status = ProxyHealthStatus.new();
    let cfg = HealthCheck.active(1_000, f"/health");
    let chk = ActiveHealthChecker.new(up, status, cfg);
    chk.stop();
    // No further assertion — the body of `run` checks `cancel` on
    // every tick; calling `stop` before spawning is the canonical
    // "don't actually run" pattern.
}

@main
public fn main() -> Int {
    checker_construction();
    record_outcome_threshold_marks_unhealthy_after_three_failures();
    record_outcome_two_successes_recover();
    stop_signals_cancel();
    print("ActiveHealthChecker thresholds + lifecycle verified");
    0
}
