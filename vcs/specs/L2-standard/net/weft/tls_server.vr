// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: net, weft, tls, terminator, alpn, transport, connection-runner
// @timeout: 10000
// @expect: pass

// §6.7 — Unified Server<H> handles both plain TCP (.serve) and TLS
// (.serve_tls); TLS lifecycle is implemented as a ConnectionRunner
// plugged into the shared accept_loop. TlsTransport adapts TlsStream
// to the WeftTransport protocol.

mount core.net.http.{Response};
mount core.net.tls.{TlsConfig, TlsVersion};
mount core.net.weft.handler.{WeftRequest, Handler};
mount core.net.weft.router.{Router};
mount core.net.weft.listener.{Server, ListenerConfig, ConnectionRunner, PlainHttp1Runner};
mount core.net.weft.tls.{TlsTransport, TlsHttp1Runner};
mount core.net.weft.transport.{WeftTransport};
mount core.net.weft.error.{WeftError};
mount core.net.weft.response_ext.{resp_ok};
mount core.collections.list.{List};

type Noop is {};
implement Handler for Noop {
    async fn handle(&self, _req: WeftRequest) -> Result<Response, WeftError> {
        Ok(resp_ok())
    }
}

fn typecheck_tls_config() -> TlsConfig {
    let mut alpn = List.new();
    alpn.push("h2");
    alpn.push("http/1.1");
    TlsConfig.server()
        .with_min_version(TlsVersion.Tls13)
        .with_alpn(alpn)
}

async fn typecheck_plain_serve() -> Result<(), Text> {
    let router = Router.new().get("/", Noop {});
    let server = Server.bind("127.0.0.1:0", router, ListenerConfig.default())?;
    server.serve().await
}

async fn typecheck_tls_serve() -> Result<(), Text> {
    // Shape-only: TlsConfig.server() without identity will fail at
    // runtime, but the types round-trip cleanly.
    let router = Router.new().get("/", Noop {});
    let server = Server.bind("127.0.0.1:0", router, ListenerConfig.default())?;
    server.serve_tls(typecheck_tls_config()).await
}

// Protocol witnesses — compile-time check that our runners satisfy
// the ConnectionRunner protocol and TlsTransport satisfies WeftTransport.
fn typecheck_transport_witness(t: TlsTransport) -> impl WeftTransport { t }

fn main() {
    let _ = typecheck_tls_config();
}
