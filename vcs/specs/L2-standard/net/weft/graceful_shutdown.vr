// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: net, weft, shutdown, drain, reuseport, k8s
// @timeout: 10000
// @expect: pass

// §7.8 — Two-phase graceful shutdown: begin_drain + shutdown, bounded
// by drain_grace_ms. SO_REUSEPORT bind surface for blue/green handoff.

mount core.net.http.{Response};
mount core.net.weft.service.{ServiceBuilder};
mount core.net.weft.handler.{WeftRequest, Handler};
mount core.net.weft.router.{Router};
mount core.net.weft.listener.{Server, ListenerConfig};
mount core.net.weft.error.{WeftError};
mount core.net.weft.response_ext.{resp_ok};
mount core.async.cancellation.{CancellationToken};

type Noop is {};
implement Handler for Noop {
    async fn handle(&self, _req: WeftRequest) -> Result<Response, WeftError> {
        Ok(resp_ok())
    }
}

fn typecheck_config_builders() -> ListenerConfig {
    ListenerConfig.default()
        .with_drain_grace_ms(60_000)
        .with_reuseport(true)
}

fn typecheck_server_lifecycle() -> Result<(), Text> {
    let router = Router.new().get("/", Noop {});
    let cfg = ListenerConfig.default().with_drain_grace_ms(5_000);
    let server = match Server.bind(
        "127.0.0.1:0",
        router,
        cfg,
    ) {
        Err(e) => return Err(e),
        Ok(s)  => s,
    };

    // Drain signal surface.
    server.begin_drain();
    let _ = server.drain_handle();

    // Full shutdown path — sets draining AND cancels the token.
    let token: CancellationToken = server.shutdown_token();
    server.shutdown();
    let _ = token;

    Ok(())
}

fn main() {
    let _ = typecheck_config_builders();
    let _ = typecheck_server_lifecycle();
}
