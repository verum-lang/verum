// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: net, weft, backpressure, vegas, adaptive, concurrency
// @timeout: 10000
// @expect: pass

// §5.5 — AdaptiveConcurrencyLayer (Vegas) shape + introspection.

mount core.net.http.{Response};
mount core.net.weft.service.{ServiceBuilder};
mount core.net.weft.handler.{WeftRequest, Handler};
mount core.net.weft.adaptive.{AdaptiveConcurrencyLayer};
mount core.net.weft.error.{WeftError};
mount core.net.weft.response_ext.{resp_ok};

type Noop is {};
implement Handler for Noop {
    async fn handle(&self, _req: WeftRequest) -> Result<Response, WeftError> {
        Ok(resp_ok())
    }
}

fn typecheck_default() -> impl Handler {
    ServiceBuilder.new(Noop {})
        .layer(AdaptiveConcurrencyLayer.default())
        .build()
}

fn typecheck_custom_vegas() -> impl Handler {
    ServiceBuilder.new(Noop {})
        .layer(AdaptiveConcurrencyLayer.vegas(20, 2, 500))
        .build()
}

fn typecheck_introspection() -> (Int, Int) {
    let layer = AdaptiveConcurrencyLayer.default();
    (layer.current_limit(), layer.current_inflight())
}

fn main() {
    let _ = typecheck_default();
    let _ = typecheck_custom_vegas();
    let _ = typecheck_introspection();
}
