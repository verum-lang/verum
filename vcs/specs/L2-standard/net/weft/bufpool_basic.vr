// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: net, weft, bufpool, io-uring, phase5, zero-copy
// @timeout: 10000
// @expect: pass

// §4.2.1 / §6.17 — Registered buffer pool shape. Kernel-side
// io_uring registration is exposed via `register_with_iouring(driver)`
// on Linux; this file typechecks the Verum-level API surface and the
// Linux-only registration entry points.

mount core.net.weft.bufpool.{BufferPool, BufferPoolConfig, BufferHandle};
mount core.collections.list.{List};
mount core.sys.common.{IOVec};

@cfg(target_os = "linux")
mount core.sys.linux.io.{IoUringDriver, LinuxIoDriverError};

fn typecheck_cfg() -> BufferPoolConfig {
    BufferPoolConfig.default()
        .with_count(512)
        .with_buf_size(32 * 1024)
        .with_io_uring(true)
}

fn typecheck_pool() -> BufferPool {
    BufferPool.new(typecheck_cfg())
}

fn typecheck_lease(pool: &BufferPool) -> Maybe<(Int, Int)> {
    match pool.acquire() {
        None    => None,
        Some(h) => Some((h.fd_offset(), h.slot().1)),
    }
}

fn typecheck_metrics(pool: &BufferPool) -> (Bool, Int, Int, Int) {
    (pool.iouring_registered(),
     pool.free_count(),
     pool.acquires_total(),
     pool.misses_total())
}

fn typecheck_iovecs(pool: &BufferPool) -> List<IOVec> {
    pool.build_iovecs()
}

@cfg(target_os = "linux")
fn typecheck_register(pool: &BufferPool, driver: &mut IoUringDriver)
    -> Result<(), LinuxIoDriverError>
{
    pool.register_with_iouring(driver)
}

@cfg(target_os = "linux")
fn typecheck_unregister(pool: &BufferPool, driver: &mut IoUringDriver)
    -> Result<(), LinuxIoDriverError>
{
    pool.unregister_iouring(driver)
}

fn main() {
    let _ = typecheck_cfg();
}
