// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, rfc8448, kat, resumption, zero_rtt, psk, early_data
// @timeout: 15000
// @expected-exit: 0

// RFC 8448 Appendix B — resumed handshake + 0-RTT trace.
//
// Scenario: after RFC 8448 §A.1 the server issued a NewSessionTicket.
// The client now initiates a fresh connection presenting
// `pre_shared_key` + `psk_key_exchange_modes` + `early_data`. The
// server accepts 0-RTT; the key schedule derives:
//
//   early_secret         = HKDF-Extract(0, resumption_master_secret)
//   binder_key           = Derive-Secret(early_secret, "res binder", "")
//   client_early_traffic = Derive-Secret(early_secret,
//                                        "c e traffic",
//                                        ClientHello)
//   early_exporter_mstr  = Derive-Secret(early_secret,
//                                        "e exp master",
//                                        ClientHello)
//
// This test checks the *surface*: the per-stage labels exist with the
// expected byte content and derive_secret accepts them. Byte-exact
// assertion of the RFC vectors lands once vtest runs under LLVM.

mount core.*;
mount core.collections.List;
mount core.net.tls13.cipher_suite.{HashKind};
mount core.net.tls13.keyschedule.derive_secret.{
    LABEL_DERIVED,
    LABEL_RES_BINDER,
    LABEL_EXT_BINDER,
    LABEL_CLIENT_EARLY_TRAFFIC,
    LABEL_EARLY_EXPORTER_MASTER,
    LABEL_RESUMPTION_MASTER,
    LABEL_RESUMPTION,
    LABEL_FINISHED,
    derive_secret,
};
mount core.net.tls13.keyschedule.hkdf_label.{hkdf_expand_label};
mount core.security.hash.sha256.{Sha256};

fn bytes_eq(a: &[Byte], b: &[Byte]) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        if a[i] != b[i] { return false; }
        i = i + 1;
    }
    true
}

// =============================================================================
// Label byte-content sanity (RFC 8446 §7.1)
// =============================================================================

fn label_res_binder_bytes_match_rfc() {
    // "res binder" = 0x72 0x65 0x73 0x20 0x62 0x69 0x6e 0x64 0x65 0x72
    let expected: List<Byte> = [
        0x72_u8, 0x65_u8, 0x73_u8, 0x20_u8, 0x62_u8,
        0x69_u8, 0x6E_u8, 0x64_u8, 0x65_u8, 0x72_u8,
    ];
    let got: List<Byte> = LABEL_RES_BINDER.to_list();
    assert(bytes_eq(&expected, &got));
}

fn label_ext_binder_bytes_match_rfc() {
    // "ext binder"
    let expected: List<Byte> = [
        0x65_u8, 0x78_u8, 0x74_u8, 0x20_u8, 0x62_u8,
        0x69_u8, 0x6E_u8, 0x64_u8, 0x65_u8, 0x72_u8,
    ];
    let got: List<Byte> = LABEL_EXT_BINDER.to_list();
    assert(bytes_eq(&expected, &got));
}

fn label_client_early_traffic_bytes_match_rfc() {
    // "c e traffic"
    let expected: List<Byte> = [
        0x63_u8, 0x20_u8, 0x65_u8, 0x20_u8, 0x74_u8,
        0x72_u8, 0x61_u8, 0x66_u8, 0x66_u8, 0x69_u8,
        0x63_u8,
    ];
    let got: List<Byte> = LABEL_CLIENT_EARLY_TRAFFIC.to_list();
    assert(bytes_eq(&expected, &got));
}

fn label_early_exporter_master_bytes_match_rfc() {
    // "e exp master"
    let expected: List<Byte> = [
        0x65_u8, 0x20_u8, 0x65_u8, 0x78_u8, 0x70_u8,
        0x20_u8, 0x6D_u8, 0x61_u8, 0x73_u8, 0x74_u8,
        0x65_u8, 0x72_u8,
    ];
    let got: List<Byte> = LABEL_EARLY_EXPORTER_MASTER.to_list();
    assert(bytes_eq(&expected, &got));
}

fn label_resumption_master_bytes_match_rfc() {
    // "res master"
    let expected: List<Byte> = [
        0x72_u8, 0x65_u8, 0x73_u8, 0x20_u8, 0x6D_u8,
        0x61_u8, 0x73_u8, 0x74_u8, 0x65_u8, 0x72_u8,
    ];
    let got: List<Byte> = LABEL_RESUMPTION_MASTER.to_list();
    assert(bytes_eq(&expected, &got));
}

// =============================================================================
// Derive-Secret surface for the 0-RTT branch
// =============================================================================

fn derive_secret_accepts_all_resumption_labels() {
    let zero32: List<Byte> = [
        0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8,
        0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8,
        0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8,
        0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8, 0_u8,
    ];
    let empty_hash: List<Byte> = Sha256.digest(&[]).to_list();

    // Each of these derivations is exercised in the resumption path.
    // The actual byte values come from the RFC vectors; here we only
    // ensure the APIs accept the labels without error.
    let _d = derive_secret(HashKind.Sha256, zero32.as_slice(),
                           LABEL_DERIVED.as_slice(),
                           empty_hash.as_slice()).unwrap();

    let _binder = derive_secret(HashKind.Sha256, zero32.as_slice(),
                                LABEL_RES_BINDER.as_slice(),
                                empty_hash.as_slice()).unwrap();

    let _early = derive_secret(HashKind.Sha256, zero32.as_slice(),
                               LABEL_CLIENT_EARLY_TRAFFIC.as_slice(),
                               empty_hash.as_slice()).unwrap();

    let _exporter = derive_secret(HashKind.Sha256, zero32.as_slice(),
                                  LABEL_EARLY_EXPORTER_MASTER.as_slice(),
                                  empty_hash.as_slice()).unwrap();

    let _resmst = derive_secret(HashKind.Sha256, zero32.as_slice(),
                                LABEL_RESUMPTION_MASTER.as_slice(),
                                empty_hash.as_slice()).unwrap();
}

fn hkdf_expand_label_ticket_key_derivation() {
    // Per RFC 8446 §4.6.1: PSK = HKDF-Expand-Label(resumption_master,
    // "resumption", ticket_nonce, Hash.length)
    let rmaster: List<Byte> = [
        1_u8, 2_u8, 3_u8, 4_u8, 5_u8, 6_u8, 7_u8, 8_u8,
        9_u8, 10_u8, 11_u8, 12_u8, 13_u8, 14_u8, 15_u8, 16_u8,
        17_u8, 18_u8, 19_u8, 20_u8, 21_u8, 22_u8, 23_u8, 24_u8,
        25_u8, 26_u8, 27_u8, 28_u8, 29_u8, 30_u8, 31_u8, 32_u8,
    ];
    let nonce: List<Byte> = [0xFF_u8, 0xFE_u8, 0xFD_u8, 0xFC_u8];
    let psk = hkdf_expand_label(
        HashKind.Sha256,
        rmaster.as_slice(),
        LABEL_RESUMPTION.as_slice(),
        nonce.as_slice(),
        32,
    ).unwrap();
    assert(psk.len() == 32);
}

@main
public fn main() -> Int {
    label_res_binder_bytes_match_rfc();
    label_ext_binder_bytes_match_rfc();
    label_client_early_traffic_bytes_match_rfc();
    label_early_exporter_master_bytes_match_rfc();
    label_resumption_master_bytes_match_rfc();
    derive_secret_accepts_all_resumption_labels();
    hkdf_expand_label_ticket_key_derivation();
    print("RFC 8448 Appendix B — resumption + 0-RTT labels + derivation surface verified");
    0
}
