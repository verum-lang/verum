// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, rfc8448, kat, hrr, hello_retry_request, transcript
// @timeout: 15000
// @expected-exit: 0

// RFC 8448 Appendix C — HelloRetryRequest trace.
//
// Scenario: client offers a key_share for `secp256r1` but server only
// supports `x25519`; server sends HelloRetryRequest with
// key_share(selected_group = x25519), client re-sends ClientHello2
// with the new share, handshake proceeds.
//
// The key post-HRR correctness property is that the transcript hash
// used in every Derive-Secret step is:
//
//   Transcript-Hash(ClientHello1, HelloRetryRequest, ClientHello2, ...) =
//       Hash(message_hash || uint24(Hash.length) || Hash(ClientHello1) ||
//            HelloRetryRequest || ClientHello2 || ...)
//
// i.e. the first ClientHello is REPLACED by a synthetic message_hash
// record (handshake type = 254). This prevents second-preimage /
// bid-down attacks and keeps the handshake transcript incremental.
//
// This test exercises the surface: `Transcript.reseed_for_hrr` must
// run without error on a fresh transcript and leave the hasher in a
// valid state for further `append` calls.

mount core.*;
mount core.collections.List;
mount core.net.tls13.cipher_suite.{HashKind};
mount core.net.tls13.handshake.transcript.{Transcript};
mount core.net.tls13.handshake.messages.{
    HandshakeMessage, ServerHello,
    is_hello_retry_request, HRR_RANDOM,
};

// Hex helper — replicates rfc8448_simple_1rtt.vr
fn hex_byte(c: Byte) -> Byte {
    if c >= ('0' as Byte) && c <= ('9' as Byte) { return c - ('0' as Byte); }
    if c >= ('a' as Byte) && c <= ('f' as Byte) { return c - ('a' as Byte) + 10_u8; }
    if c >= ('A' as Byte) && c <= ('F' as Byte) { return c - ('A' as Byte) + 10_u8; }
    0_u8
}

fn hex_to_bytes(hex: &str) -> List<Byte> {
    let b = hex.as_bytes();
    let mut out: List<Byte> = [];
    let mut i: Int = 0;
    while i + 1 < b.len() {
        if b[i] == (' ' as Byte) || b[i] == ('\n' as Byte) || b[i] == ('\t' as Byte) {
            i = i + 1;
            continue;
        }
        let hi = hex_byte(b[i]);
        let lo = hex_byte(b[i + 1]);
        out.push((hi << 4) | lo);
        i = i + 2;
    }
    out
}

// =============================================================================
// RFC 8448 §C.1 — ClientHello1 (prior to retry) key fragment
// =============================================================================
//
// The full appendix has a ~150-byte ClientHello; only the first bytes
// are needed to exercise the surface. Full byte vectors land once
// vtest runs under LLVM and the transcript hash is compared byte-for-
// byte against the RFC vectors.

const CLIENT_HELLO1_PREFIX_HEX: &str =
    "010000c0 0303 cb349888 5a5f2a 6f7a5c dc87";

// HRR on the wire: server_hello type (0x02) + 3-byte length + legacy
// version 0x0303 + 32-byte HRR sentinel random (RFC 8446 §4.1.3).
const HRR_PREFIX_HEX: &str =
    "02 00 00 56 03 03 cf 21 ad 74 e5 9a 61 11 be 1d 8c 02 1e 65 b8 91 c2 a2 11 16 7a bb 8c 5e 07 9e 09 e2 c8 a8 33 9c";

fn hrr_random_matches_sentinel() {
    let s = hex_to_bytes(HRR_PREFIX_HEX);
    // Extract the 32-byte random starting at offset 2+2+2 = 6 (type + 3-byte len + 2-byte legacy_version).
    let mut extracted: List<Byte> = [];
    let mut i: Int = 6;
    while i < 6 + 32 && i < s.len() {
        extracted.push(s[i]);
        i = i + 1;
    }
    // The sentinel constant must equal what appears on the wire.
    assert(extracted.len() == 32);
    let sentinel: List<Byte> = HRR_RANDOM.to_list();
    assert(extracted.len() == sentinel.len());
    let mut k: Int = 0;
    while k < extracted.len() {
        assert(extracted[k] == sentinel[k]);
        k = k + 1;
    }
}

// The core transcript reseeding primitive — exercises the same code
// path used in client_sm.vr / server_sm.vr when a HelloRetryRequest
// is received/sent.
fn transcript_reseed_for_hrr_surface() {
    let mut tr = Transcript.new(HashKind.Sha256);
    // Feed a synthetic ClientHello1 body.
    let ch1 = hex_to_bytes(CLIENT_HELLO1_PREFIX_HEX);
    tr.append(ch1.as_slice());
    let ch1_hash = tr.snapshot();
    assert(ch1_hash.len() == 32);   // SHA-256 output

    // Reseed — replaces the hasher with one seeded at message_hash.
    tr.reseed_for_hrr();

    // After reseeding, appending HRR + ClientHello2 yields the post-
    // HRR handshake hash. We only typecheck the surface here.
    let hrr = hex_to_bytes(HRR_PREFIX_HEX);
    tr.append(hrr.as_slice());
    let post = tr.snapshot();
    assert(post.len() == 32);
    // Snapshot must differ from the pre-reseed hash.
    let mut differ = false;
    let mut i: Int = 0;
    while i < post.len() {
        if post[i] != ch1_hash[i] { differ = true; break; }
        i = i + 1;
    }
    assert(differ);
}

@main
public fn main() -> Int {
    hrr_random_matches_sentinel();
    transcript_reseed_for_hrr_surface();
    print("RFC 8448 Appendix C — HRR sentinel + transcript reseed verified");
    0
}
