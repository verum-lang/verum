// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, rfc9001, initial, kat, crypto
// @timeout: 10000
// @expect: pass
//
// RFC 9001 Appendix A.1 — Keys derivation test vector for a sample
// client Initial packet. Nominal test:
//
//   Client DCID = 0x8394c8f03e515708
//
//   Expected derived secrets / keys:
//     initial_salt     = 38762cf7f55934b34d179ae6a4c80cadccbb7f0a
//     initial_secret   = 7db5df06e7a69e432496adedb0085192
//                        3595221596ae2ae9fb8115c1e9ed0a44
//     client_initial_secret = c00cf151ca5be075ed0ebfb5c80323c4
//                             2d6b7db67881289af4008f1f6c357aea
//     server_initial_secret = 3c9bf6a9c1c8c71819876967bd8b979e
//                             fd98ec665edf27f22c06e51e3eeb5b18
//     client key (AES-128) = 1f369613dd76d5467730efcbe3b1a22d
//     client iv            = fa044b2f42a3fd3b46fb255c
//     client hp            = 9f50449e04a0e810283a1e9933adedd2
//     server key           = cf3a5331653c364c88f0f379b6067e37
//     server iv            = 0ac1493ca1905853b0bba03e
//     server hp            = c206b8d9b9f0f37644430b490eeaa314
//
// This file is a typecheck-pass harness verifying the KAT pipeline
// compiles through `derive_initial_secrets` + `derive_initial_keys`.
// Byte-exact assertions materialise when vtest can actually run the
// test under LLVM.

mount core.net.quic.crypto.{
    InitialSecrets, InitialKeys,
    derive_initial_secrets, derive_initial_keys,
};

fn hex_to_bytes(hex: &str) -> List<Byte> {
    let b = hex.as_bytes();
    let mut out: List<Byte> = [];
    let mut i: Int = 0;
    while i + 1 < b.len() {
        let hi = hex_digit(b[i]);
        let lo = hex_digit(b[i + 1]);
        out.push((hi << 4) | lo);
        i = i + 2;
    }
    out
}

fn hex_digit(c: Byte) -> Byte {
    if c >= ('0' as Byte) && c <= ('9' as Byte) {
        c - ('0' as Byte)
    } else if c >= ('a' as Byte) && c <= ('f' as Byte) {
        c - ('a' as Byte) + 10_u8
    } else if c >= ('A' as Byte) && c <= ('F' as Byte) {
        c - ('A' as Byte) + 10_u8
    } else {
        0_u8
    }
}

fn bytes_eq(a: &[Byte], b: &[Byte]) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        if a[i] != b[i] { return false; }
        i = i + 1;
    }
    true
}

fn check_initial_pipeline() -> Result<(), core.security.kdf.hkdf.HkdfError> {
    // RFC 9001 §A.1 — client DCID
    let dcid = hex_to_bytes("8394c8f03e515708");
    let secrets = derive_initial_secrets(dcid.as_slice())?;

    let expected_client_secret = hex_to_bytes(
        "c00cf151ca5be075ed0ebfb5c80323c42d6b7db67881289af4008f1f6c357aea"
    );
    let expected_server_secret = hex_to_bytes(
        "3c9bf6a9c1c8c71819876967bd8b979efd98ec665edf27f22c06e51e3eeb5b18"
    );
    let _ = bytes_eq(secrets.client.as_slice(), expected_client_secret.as_slice());
    let _ = bytes_eq(secrets.server.as_slice(), expected_server_secret.as_slice());

    // Derive per-direction keys.
    let client_keys = derive_initial_keys(secrets.client.as_slice())?;
    let server_keys = derive_initial_keys(secrets.server.as_slice())?;

    let expected_client_key = hex_to_bytes("1f369613dd76d5467730efcbe3b1a22d");
    let expected_client_iv  = hex_to_bytes("fa044b2f42a3fd3b46fb255c");
    let expected_client_hp  = hex_to_bytes("9f50449e04a0e810283a1e9933adedd2");
    let expected_server_key = hex_to_bytes("cf3a5331653c364c88f0f379b6067e37");
    let expected_server_iv  = hex_to_bytes("0ac1493ca1905853b0bba03e");
    let expected_server_hp  = hex_to_bytes("c206b8d9b9f0f37644430b490eeaa314");

    let _ = bytes_eq(client_keys.key.as_slice(), expected_client_key.as_slice());
    let _ = bytes_eq(server_keys.key.as_slice(), expected_server_key.as_slice());
    let _ = bytes_eq(client_keys.hp.as_slice(),  expected_client_hp.as_slice());
    let _ = bytes_eq(server_keys.hp.as_slice(),  expected_server_hp.as_slice());
    // IV is [Byte; 12]; compare against slice view.
    let _ = bytes_eq(&client_keys.iv[..], expected_client_iv.as_slice());
    let _ = bytes_eq(&server_keys.iv[..], expected_server_iv.as_slice());

    Ok(())
}

fn main() {
    let _ = check_initial_pipeline();
}
