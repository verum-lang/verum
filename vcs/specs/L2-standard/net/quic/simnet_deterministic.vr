// @test: unit
// @tier: 0
// @level: L2
// @tags: quic, simnet, dst, deterministic, testing
// @timeout: 5000
// @expect: pass

// Deterministic-simulation test (spec tls-quic.md §4.10).  SimNetwork
// uses an xorshift64 PRNG so the same `(seed, loss_rate, sequence of
// sends)` always produces identical {dropped, delivered, inflight}
// counters.  That reproducibility is the basis for all DST tests
// downstream — any random flakiness would invalidate the harness.

mount core.*;
mount core.net.quic.transport.abstraction.{SimNetwork};

fn main() {
    // Seed=42, 20% loss. Draw 100 decisions and record the drop count.
    let mut a = SimNetwork.new().with_seed(42_u64).with_loss_rate_bp(2000_u64);
    let mut drops_a: Int = 0;
    let mut i: Int = 0;
    while i < 100 {
        if a.should_drop() { drops_a = drops_a + 1; }
        i = i + 1;
    }

    // Same seed + same parameters — replay must produce identical
    // drop count (determinism property).
    let mut b = SimNetwork.new().with_seed(42_u64).with_loss_rate_bp(2000_u64);
    let mut drops_b: Int = 0;
    let mut j: Int = 0;
    while j < 100 {
        if b.should_drop() { drops_b = drops_b + 1; }
        j = j + 1;
    }
    assert_eq(drops_a, drops_b);

    // Different seed — (essentially always) different trace.
    let mut c = SimNetwork.new().with_seed(17_u64).with_loss_rate_bp(2000_u64);
    let mut drops_c: Int = 0;
    let mut k: Int = 0;
    while k < 100 {
        if c.should_drop() { drops_c = drops_c + 1; }
        k = k + 1;
    }
    // Note: with low iteration count and moderate rate, counts could
    // still match occasionally. Accept any non-zero drop count as a
    // smoke signal that the PRNG isn't constant.
    assert_eq(drops_a >= 10 && drops_a <= 30, true);  // ~20% of 100 ± bounds

    // Zero loss — never drops.
    let mut zero = SimNetwork.new().with_seed(1_u64).with_loss_rate_bp(0_u64);
    let mut zl: Int = 0;
    let mut l: Int = 0;
    while l < 100 {
        if zero.should_drop() { zl = zl + 1; }
        l = l + 1;
    }
    assert_eq(zl, 0);

    // 100% loss (10000 bp) — always drops.
    let mut all = SimNetwork.new().with_seed(1_u64).with_loss_rate_bp(10000_u64);
    let mut al: Int = 0;
    let mut m: Int = 0;
    while m < 100 {
        if all.should_drop() { al = al + 1; }
        m = m + 1;
    }
    assert_eq(al, 100);

    print(f"SimNet deterministic: seed=42 20% → {drops_a} drops over 100");
}
