// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, pn_space, v4, monotonicity, rfc9000_12_3
// @timeout: 15000
// @expected-exit: 0

// RFC 9000 §12.3 PN allocation: per-space next_packet_number is
// strictly monotonic (V4 invariant). Separate spaces
// (Initial / Handshake / Application) maintain independent counters.

mount core.*;
mount core.net.quic.recovery.pn_space.{PnSpace, PnSpaceKind};

fn space_starts_at_zero() {
    let s = PnSpace.new(PnSpaceKind.Initial);
    assert(s.pn_monotonic_ok());
}

fn next_packet_number_advances_strictly() {
    let mut s = PnSpace.new(PnSpaceKind.Initial);
    let pn0 = s.next_packet_number();
    let pn1 = s.next_packet_number();
    let pn2 = s.next_packet_number();
    assert(pn0 == 0_u64);
    assert(pn1 == 1_u64);
    assert(pn2 == 2_u64);
    assert(pn1 > pn0);
    assert(pn2 > pn1);
    assert(s.pn_monotonic_ok());
}

fn three_spaces_are_independent() {
    let mut initial   = PnSpace.new(PnSpaceKind.Initial);
    let mut handshake = PnSpace.new(PnSpaceKind.Handshake);
    let mut app       = PnSpace.new(PnSpaceKind.Application);

    // Advance Initial twice; Handshake once; Application three times.
    let _ = initial.next_packet_number();
    let _ = initial.next_packet_number();
    let _ = handshake.next_packet_number();
    let _ = app.next_packet_number();
    let _ = app.next_packet_number();
    let _ = app.next_packet_number();

    // Each space's next counter reflects its own sequence only.
    let next_i = initial.next_packet_number();
    let next_h = handshake.next_packet_number();
    let next_a = app.next_packet_number();
    assert(next_i == 2_u64);
    assert(next_h == 1_u64);
    assert(next_a == 3_u64);
}

fn space_kind_as_index_matches_array_layout() {
    // RFC 9001 §2.1 — LossDetection indexes spaces as
    // [Initial=0, Handshake=1, Application=2].
    assert(PnSpaceKind.Initial.as_index()     == 0);
    assert(PnSpaceKind.Handshake.as_index()   == 1);
    assert(PnSpaceKind.Application.as_index() == 2);
}

@main
public fn main() -> Int {
    space_starts_at_zero();
    next_packet_number_advances_strictly();
    three_spaces_are_independent();
    space_kind_as_index_matches_array_layout();
    print("RFC 9000 §12.3 PnSpace monotonicity (V4) verified");
    0
}
