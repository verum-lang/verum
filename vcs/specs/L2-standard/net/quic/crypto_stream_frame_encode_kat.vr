// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, frame, crypto, stream, encode, rfc9000_19_6, rfc9000_19_8
// @timeout: 15000
// @expected-exit: 0

// RFC 9000 §19.6 CRYPTO Frame (Type = 0x06):
//
//   CRYPTO Frame {
//       Type (i) = 0x06,
//       Offset (i),
//       Length (i),
//       Crypto Data (..),
//   }
//
// RFC 9000 §19.8 STREAM Frame (Type = 0b00001XXX, where X bits are OFF,
// LEN, FIN):
//
//   STREAM Frame {
//       Type (i) = 0x08..0x0f,
//       Stream ID (i),
//       [Offset (i)],         -- present iff OFF bit set
//       [Length (i)],         -- present iff LEN bit set
//       Stream Data (..),
//   }
//
// The encoder always sets the LEN flag, sets OFF if offset > 0, and
// sets FIN per the frame's fin field. All values here fit in 1-byte
// QUIC varint form.

mount core.*;
mount core.collections.List;
mount core.net.quic.frame.{QuicFrame, encode_frame, decode_frame};

fn crypto_frame_offset_zero_byte_exact() {
    // CRYPTO offset=0, data=[0x01 0x00 0x02 0x01 0x01 0x00 0x00 0x3A]
    // (a synthetic 8-byte ClientHello prefix).
    let data: List<Byte> = [
        0x01_u8, 0x00_u8, 0x02_u8, 0x01_u8,
        0x01_u8, 0x00_u8, 0x00_u8, 0x3A_u8,
    ];
    let f = QuicFrame.CryptoFrame { offset: 0_u64, data: data.clone() };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // Wire: type(1) + offset(1) + len(1) + 8 data = 11 bytes.
    assert(out.len() == 11);
    assert(out[0] == 0x06_u8);        // CRYPTO type
    assert(out[1] == 0x00_u8);        // offset = 0
    assert(out[2] == 0x08_u8);        // length = 8
    assert(out[3] == 0x01_u8);        // data[0]
    assert(out[10] == 0x3A_u8);       // data[7]
}

fn crypto_frame_nonzero_offset_byte_exact() {
    let data: List<Byte> = [0xAB_u8, 0xCD_u8];
    let f = QuicFrame.CryptoFrame { offset: 16_u64, data: data };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    assert(out.len() == 5);
    assert(out[0] == 0x06_u8);
    assert(out[1] == 0x10_u8);        // offset = 16
    assert(out[2] == 0x02_u8);        // length = 2
    assert(out[3] == 0xAB_u8);
    assert(out[4] == 0xCD_u8);
}

fn stream_frame_offset_zero_not_fin_type_is_0x0A() {
    // Minimal STREAM: offset=0 (no OFF bit), LEN always set, FIN clear
    //   → type = 0x08 | 0x02 = 0x0A.
    let data: List<Byte> = [0x48_u8, 0x49_u8];    // "HI"
    let f = QuicFrame.StreamFrame {
        stream_id: 4_u64,
        offset:    0_u64,
        data:      data,
        fin:       false,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // Wire: type(1) + sid(1) + len(1) + 2 data = 5.
    assert(out.len() == 5);
    assert(out[0] == 0x0A_u8);        // type (OFF=0, LEN=1, FIN=0)
    assert(out[1] == 0x04_u8);        // stream_id = 4
    assert(out[2] == 0x02_u8);        // length = 2
    assert(out[3] == 0x48_u8);
    assert(out[4] == 0x49_u8);
}

fn stream_frame_fin_sets_low_bit() {
    let f = QuicFrame.StreamFrame {
        stream_id: 8_u64,
        offset:    0_u64,
        data:      [],
        fin:       true,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // type = 0x08 | 0x02 | 0x01 = 0x0B. sid(1) + len(1). 3 bytes total.
    assert(out.len() == 3);
    assert(out[0] == 0x0B_u8);
    assert(out[1] == 0x08_u8);
    assert(out[2] == 0x00_u8);        // length = 0
    // FIN flag visible in low bit.
    assert((out[0] & 0x01_u8) == 0x01_u8);
}

fn stream_frame_nonzero_offset_sets_off_bit() {
    let data: List<Byte> = [0xFF_u8];
    let f = QuicFrame.StreamFrame {
        stream_id: 2_u64,
        offset:    32_u64,
        data:      data,
        fin:       false,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // type = 0x08 | 0x04 | 0x02 = 0x0E.
    // Wire: type(1) + sid(1) + offset(1) + len(1) + 1 data = 5.
    assert(out.len() == 5);
    assert(out[0] == 0x0E_u8);
    assert(out[1] == 0x02_u8);        // sid = 2
    assert(out[2] == 0x20_u8);        // offset = 32
    assert(out[3] == 0x01_u8);        // length = 1
    assert(out[4] == 0xFF_u8);
    // OFF flag visible in bit 2.
    assert((out[0] & 0x04_u8) == 0x04_u8);
}

fn stream_frame_fin_and_offset_together_type_0x0F() {
    let data: List<Byte> = [0xAA_u8];
    let f = QuicFrame.StreamFrame {
        stream_id: 12_u64,
        offset:    5_u64,
        data:      data,
        fin:       true,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // type = 0x08 | 0x04 | 0x02 | 0x01 = 0x0F.
    assert(out[0] == 0x0F_u8);
    assert((out[0] & 0x01_u8) == 0x01_u8);
    assert((out[0] & 0x04_u8) == 0x04_u8);
}

fn crypto_frame_decode_roundtrip() {
    let data: List<Byte> = [0xDE_u8, 0xAD_u8, 0xBE_u8, 0xEF_u8];
    let f = QuicFrame.CryptoFrame { offset: 4_u64, data: data.clone() };
    let mut wire: List<Byte> = [];
    let _ = encode_frame(&f, &mut wire);
    let (decoded, _) = decode_frame(wire.as_slice(), 0).unwrap();
    match decoded {
        QuicFrame.CryptoFrame { offset, data: dec } => {
            assert(offset == 4_u64);
            assert(dec.len() == 4);
            assert(dec[0] == 0xDE_u8 && dec[3] == 0xEF_u8);
        },
        _ => panic("expected CryptoFrame"),
    }
}

fn stream_frame_decode_preserves_fin() {
    let data: List<Byte> = [0x01_u8, 0x02_u8];
    let f = QuicFrame.StreamFrame {
        stream_id: 4_u64,
        offset:    100_u64,
        data:      data.clone(),
        fin:       true,
    };
    let mut wire: List<Byte> = [];
    let _ = encode_frame(&f, &mut wire);
    let (decoded, _) = decode_frame(wire.as_slice(), 0).unwrap();
    match decoded {
        QuicFrame.StreamFrame { stream_id, offset, data: dec, fin } => {
            assert(stream_id == 4_u64);
            assert(offset == 100_u64);
            assert(dec.len() == 2);
            assert(fin == true);
        },
        _ => panic("expected StreamFrame"),
    }
}

@main
public fn main() -> Int {
    crypto_frame_offset_zero_byte_exact();
    crypto_frame_nonzero_offset_byte_exact();
    stream_frame_offset_zero_not_fin_type_is_0x0A();
    stream_frame_fin_sets_low_bit();
    stream_frame_nonzero_offset_sets_off_bit();
    stream_frame_fin_and_offset_together_type_0x0F();
    crypto_frame_decode_roundtrip();
    stream_frame_decode_preserves_fin();
    print("RFC 9000 §19.6 CRYPTO + §19.8 STREAM frame encode KAT verified");
    0
}
