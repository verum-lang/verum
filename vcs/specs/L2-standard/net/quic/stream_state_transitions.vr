// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, stream, state_machine, rfc9000_3
// @timeout: 15000
// @expected-exit: 0

// RFC 9000 §3.1 SendStream state machine transitions:
//
//   Ready → Send       (first byte admitted by `write`)
//   Send → DataSent    (FIN set via `close` + buffer drained)
//   Ready/Send → ResetSent (via `reset`)
//   ResetSent → AlreadyReset on repeat `reset`
//   DataSent → AlreadyFinished on repeat `close`

mount core.*;
mount core.collections.List;
mount core.net.quic.stream_sm.send.{SendStream, SendState, SendError};

fn new_stream_starts_in_ready() {
    let s = SendStream.new(0_u64, 1024_u64);
    match s.state() {
        SendState.Ready => {},
        _ => panic("new stream must be Ready"),
    }
}

fn write_transitions_ready_to_send() {
    let mut s = SendStream.new(0_u64, 1024_u64);
    let data: List<Byte> = [0x41_u8, 0x42_u8, 0x43_u8];
    let n = s.write(data.as_slice(), 1024_u64).unwrap();
    assert(n == 3);
    match s.state() {
        SendState.Send => {},
        _ => panic("Ready → Send after write"),
    }
}

fn close_after_writes_sets_final_size() {
    let mut s = SendStream.new(0_u64, 1024_u64);
    let data: List<Byte> = [0x01_u8, 0x02_u8, 0x03_u8, 0x04_u8];
    let _ = s.write(data.as_slice(), 1024_u64);
    // Before FIN ack the stream stays in Send; close sets final_size
    // but keeps state=Send until the wire layer acks the FIN.
    s.close().unwrap();
    match s.state() {
        SendState.Send => {},
        _ => panic("close sets final_size; state flips later"),
    }
}

fn reset_transitions_to_reset_sent() {
    let mut s = SendStream.new(0_u64, 1024_u64);
    let data: List<Byte> = [0xAA_u8, 0xBB_u8];
    let _ = s.write(data.as_slice(), 1024_u64);
    let final_size = s.reset(0x00_u64).unwrap();
    assert(final_size == 2_u64);
    match s.state() {
        SendState.ResetSent => {},
        _ => panic("reset → ResetSent"),
    }
}

fn reset_after_reset_returns_already_reset() {
    let mut s = SendStream.new(0_u64, 1024_u64);
    let _ = s.reset(0_u64);
    match s.reset(0_u64) {
        Err(SendError.AlreadyReset) => {},
        _ => panic("double reset must error"),
    }
}

fn write_after_reset_returns_already_reset() {
    let mut s = SendStream.new(0_u64, 1024_u64);
    let _ = s.reset(0_u64);
    let data: List<Byte> = [0x01_u8];
    match s.write(data.as_slice(), 1024_u64) {
        Err(SendError.AlreadyReset) => {},
        _ => panic("write after reset must error"),
    }
}

fn flow_control_budget_caps_write_length() {
    let mut s = SendStream.new(0_u64, 8_u64);        // stream FC budget = 8
    let big: List<Byte> = [
        0_u8, 1_u8, 2_u8, 3_u8, 4_u8, 5_u8, 6_u8, 7_u8,
        8_u8, 9_u8, 10_u8, 11_u8, 12_u8, 13_u8, 14_u8, 15_u8,
    ];
    let n = s.write(big.as_slice(), 16_u64).unwrap();
    assert(n == 8);                                    // clamped by stream budget
}

fn flow_control_raises_on_max_stream_data() {
    let mut s = SendStream.new(0_u64, 4_u64);
    let data: List<Byte> = [0_u8, 1_u8, 2_u8, 3_u8, 4_u8, 5_u8];
    let n = s.write(data.as_slice(), 100_u64).unwrap();
    assert(n == 4);                                    // capped at 4
    s.on_max_stream_data(8_u64);
    let n2 = s.write(data.as_slice(), 100_u64).unwrap();
    assert(n2 == 4);                                   // budget extended to 8
}

@main
public fn main() -> Int {
    new_stream_starts_in_ready();
    write_transitions_ready_to_send();
    close_after_writes_sets_final_size();
    reset_transitions_to_reset_sent();
    reset_after_reset_returns_already_reset();
    write_after_reset_returns_already_reset();
    flow_control_budget_caps_write_length();
    flow_control_raises_on_max_stream_data();
    print("RFC 9000 §3 SendStream state transitions verified");
    0
}
