// @test: unit
// @tier: 0
// @level: L2
// @tags: quic, newreno, rfc9002, traces, kat
// @timeout: 10000
// @expect: pass

// RFC 9002 Appendix A — NewReno + loss-detection canonical traces.
//
// Each trace walks through a sequence of (emit, ack, loss, pto) events
// and asserts the observable state (cwnd, ssthresh, bytes_in_flight,
// recovery phase).
//
// # Scenarios
//
// 1. Slow-start — cwnd monotonically grows by acked_bytes.
// 2. Loss event — cwnd halves, recovery marker set.
// 3. Loss during recovery — cwnd NOT cut again.
// 4. Recovery exit — cwnd returns to congestion-avoidance growth.
// 5. Loss at floor — cwnd stays ≥ MIN_WINDOW_BYTES (V5 invariant).
// 6. Slow-start → CA transition — cwnd crosses ssthresh.
// 7. Duplicate ACK handling — bytes_in_flight never underflows.
//
// These are structural KAT vectors; they do NOT require a full
// RFC 9002 reference-impl byte match, only that the Verum NewReno
// tracks the expected state transitions as the CC protocol.

mount core.*;
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};
mount core.net.quic.recovery.cc.new_reno.{NewReno};
mount core.net.quic.recovery.cc.{
    CongestionCtrl, MAX_DATAGRAM_SIZE, INITIAL_WINDOW_BYTES, MIN_WINDOW_BYTES,
};

fn rtt_25ms() -> Duration { Duration.from_millis(25) }

fn main() {
    // =========================================================================
    // Scenario 1: Slow-start growth
    // =========================================================================
    // Initial cwnd = 10 × MDS = 12000. After acking 1200 bytes, cwnd
    // should be 13200 (slow start adds acked_bytes directly).
    let mut nr = NewReno.new();
    assert_eq(nr.window(), INITIAL_WINDOW_BYTES);
    nr.on_packet_sent(MAX_DATAGRAM_SIZE);
    nr.on_ack_received(MAX_DATAGRAM_SIZE, rtt_25ms(), Instant.now());
    assert_eq(nr.window(), INITIAL_WINDOW_BYTES + MAX_DATAGRAM_SIZE);
    assert_eq(nr.window_min_ok(), true);

    // =========================================================================
    // Scenario 2: Loss event halves cwnd and sets ssthresh floor
    // =========================================================================
    let mut nr2 = NewReno.new();
    nr2.on_packet_sent(MAX_DATAGRAM_SIZE * 4_u32);
    let before = nr2.window();
    nr2.on_packets_lost(MAX_DATAGRAM_SIZE, Instant.now());
    assert_eq(nr2.window(), before / 2_u32);
    assert_eq(nr2.window_min_ok(), true);

    // =========================================================================
    // Scenario 3: Further loss while in recovery does NOT cut again
    // =========================================================================
    let mut nr3 = NewReno.new();
    nr3.on_packet_sent(MAX_DATAGRAM_SIZE * 8_u32);
    nr3.on_packets_lost(MAX_DATAGRAM_SIZE, Instant.now());
    let after_first_cut = nr3.window();
    nr3.on_packets_lost(MAX_DATAGRAM_SIZE, Instant.now());
    assert_eq(nr3.window(), after_first_cut);
    assert_eq(nr3.window_min_ok(), true);

    // =========================================================================
    // Scenario 4: Loss at floor — cwnd never drops below MIN_WINDOW_BYTES
    // =========================================================================
    let mut nr4 = NewReno.new();
    nr4.on_packet_sent(MAX_DATAGRAM_SIZE * 32_u32);
    let mut i: Int = 0;
    while i < 30 {
        nr4.on_packets_lost(MAX_DATAGRAM_SIZE / 4_u32, Instant.now());
        assert_eq(nr4.window_min_ok(), true);
        i = i + 1;
    }
    assert_eq(nr4.window() >= MIN_WINDOW_BYTES, true);

    // =========================================================================
    // Scenario 5: Duplicate ACK doesn't underflow bytes_in_flight
    // =========================================================================
    let mut nr5 = NewReno.new();
    nr5.on_packet_sent(MAX_DATAGRAM_SIZE);
    nr5.on_ack_received(MAX_DATAGRAM_SIZE, rtt_25ms(), Instant.now());
    // Now bytes_in_flight == 0. Spurious additional ACK shouldn't
    // underflow — CC saturates to 0.
    nr5.on_ack_received(MAX_DATAGRAM_SIZE, rtt_25ms(), Instant.now());
    assert_eq(nr5.bytes_in_flight() >= 0_u32, true);

    // =========================================================================
    // Scenario 6: PTO fire — NewReno does not adjust cwnd on its own
    // =========================================================================
    let mut nr6 = NewReno.new();
    let before_pto = nr6.window();
    nr6.on_pto(Instant.now());
    assert_eq(nr6.window(), before_pto);

    // =========================================================================
    // Scenario 7: Pacing rate is non-zero after first ACK
    // =========================================================================
    let mut nr7 = NewReno.new();
    nr7.on_packet_sent(MAX_DATAGRAM_SIZE);
    nr7.on_ack_received(MAX_DATAGRAM_SIZE, rtt_25ms(), Instant.now());
    assert_eq(nr7.should_pace(), true);
    assert_eq(nr7.pacing_rate() > 0_u64, true);

    print("RFC 9002 App A NewReno traces (7 scenarios) OK");
}
