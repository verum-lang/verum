// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, frame, stream, large_varint, encode, rfc9000_19_8, rfc9000_16
// @timeout: 15000
// @expected-exit: 0

// RFC 9000 §19.8 STREAM frame with multi-byte varint fields.
// `crypto_stream_frame_encode_kat.vr` covers the 1-byte-per-varint
// cases; this KAT stresses the 2-byte and 4-byte varint encodings
// for stream_id and offset, which appear once streams cross the
// 63/16383/2^30 value boundaries.

mount core.*;
mount core.collections.List;
mount core.net.quic.frame.{Frame, encode_frame, decode_frame};

fn stream_id_64_uses_two_byte_varint() {
    // stream_id = 64 → 2-byte varint 0x40 0x40.
    // offset=0 (no OFF bit), type=0x0A (OFF=0 LEN=1 FIN=0).
    let data: List<Byte> = [0x01_u8];
    let f = Frame.StreamFrame {
        stream_id: 64_u64,
        offset:    0_u64,
        data:      data,
        fin:       false,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // Wire: type(1) + sid(2) + len(1) + 1 data = 5.
    assert(out.len() == 5);
    assert(out[0] == 0x0A_u8);
    assert(out[1] == 0x40_u8);         // sid high varint byte
    assert(out[2] == 0x40_u8);         // sid low byte (= 64)
    assert(out[3] == 0x01_u8);         // length
    assert(out[4] == 0x01_u8);         // payload
}

fn stream_offset_16384_uses_four_byte_varint_and_sets_off_bit() {
    // offset = 16384 → 4-byte varint 0x80 0x00 0x40 0x00.
    // Setting offset > 0 sets the OFF bit in the type; base 0x08 |
    // 0x04 (OFF) | 0x02 (LEN) | 0x00 (FIN) = 0x0E.
    let data: List<Byte> = [0xFF_u8, 0xEE_u8];
    let f = Frame.StreamFrame {
        stream_id: 4_u64,
        offset:    16_384_u64,
        data:      data,
        fin:       false,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // Wire: type(1) + sid(1) + offset(4) + len(1) + 2 data = 9.
    assert(out.len() == 9);
    assert(out[0] == 0x0E_u8);                        // type with OFF bit
    assert(out[1] == 0x04_u8);                        // sid = 4
    // 4-byte varint for 16384:
    assert((out[2] & 0xC0_u8) == 0x80_u8);            // top 2 bits = 10
    assert(out[2] == 0x80_u8);
    assert(out[3] == 0x00_u8);
    assert(out[4] == 0x40_u8);
    assert(out[5] == 0x00_u8);
    assert(out[6] == 0x02_u8);                        // length
    assert(out[7] == 0xFF_u8);
    assert(out[8] == 0xEE_u8);
}

fn stream_very_large_id_uses_eight_byte_varint() {
    // stream_id = 2^30 = 1_073_741_824 — first value that needs an
    // 8-byte varint (14 bits are exactly 16383, 30 bits are
    // 1073741823, so 2^30 = 1073741824 needs 62-bit encoding).
    // Wire: top 2 bits = 11 → 0xC0 prefix.
    let data: List<Byte> = [0x00_u8];
    let f = Frame.StreamFrame {
        stream_id: 1_073_741_824_u64,
        offset:    0_u64,
        data:      data,
        fin:       false,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // type(1) + sid(8) + len(1) + 1 = 11.
    assert(out.len() == 11);
    assert(out[0] == 0x0A_u8);
    assert((out[1] & 0xC0_u8) == 0xC0_u8);            // top bits = 11
}

fn stream_fin_with_large_offset() {
    // Offset=100 (2-byte varint 0x40 0x64), FIN=true, LEN=true, OFF=true.
    // Type = 0x08 | 0x04 | 0x02 | 0x01 = 0x0F.
    let data: List<Byte> = [0xAB_u8];
    let f = Frame.StreamFrame {
        stream_id: 0_u64,
        offset:    100_u64,
        data:      data,
        fin:       true,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // Wire: type(1) + sid(1) + offset(2) + len(1) + 1 data = 6.
    assert(out.len() == 6);
    assert(out[0] == 0x0F_u8);
    assert(out[1] == 0x00_u8);         // sid = 0
    assert(out[2] == 0x40_u8);
    assert(out[3] == 0x64_u8);         // offset = 100
    assert(out[4] == 0x01_u8);         // length
    assert(out[5] == 0xAB_u8);
    // Type bits: OFF=1, LEN=1, FIN=1.
    assert((out[0] & 0x04_u8) == 0x04_u8);
    assert((out[0] & 0x02_u8) == 0x02_u8);
    assert((out[0] & 0x01_u8) == 0x01_u8);
}

fn stream_large_values_decode_roundtrip() {
    let data: List<Byte> = [0x01_u8, 0x02_u8, 0x03_u8];
    let f = Frame.StreamFrame {
        stream_id: 16_383_u64,           // max 2-byte varint
        offset:    16_384_u64,           // first 4-byte varint
        data:      data,
        fin:       true,
    };
    let mut wire: List<Byte> = [];
    let _ = encode_frame(&f, &mut wire);
    let (decoded, next) = decode_frame(wire.as_slice(), 0).unwrap();
    assert(next == wire.len());
    match decoded {
        Frame.StreamFrame { stream_id, offset, data: dec, fin } => {
            assert(stream_id == 16_383_u64);
            assert(offset == 16_384_u64);
            assert(dec.len() == 3);
            assert(fin == true);
        },
        _ => panic("expected StreamFrame"),
    }
}

@main
public fn main() -> Int {
    stream_id_64_uses_two_byte_varint();
    stream_offset_16384_uses_four_byte_varint_and_sets_off_bit();
    stream_very_large_id_uses_eight_byte_varint();
    stream_fin_with_large_offset();
    stream_large_values_decode_roundtrip();
    print("RFC 9000 §19.8 STREAM frame multi-byte varint encode KAT verified");
    0
}
