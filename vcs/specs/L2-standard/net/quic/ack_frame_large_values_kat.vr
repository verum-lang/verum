// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, frame, ack, large_values, encode, rfc9000_19_3, rfc9000_16
// @timeout: 15000
// @expected-exit: 0

// RFC 9000 §19.3 ACK frame with varint values that require multi-byte
// encoding. `ack_frame_encode_kat.vr` covers the 1-byte-per-varint
// case; this KAT exercises the 2-byte and 4-byte varint forms,
// which are common once a session has accumulated ≥ 64 packets.
//
// QUIC varint length (§16):
//   < 64          → 1 byte  (top 2 bits 00)
//   < 16384       → 2 bytes (top 2 bits 01)
//   < 2^30        → 4 bytes (top 2 bits 10)
//   < 2^62        → 8 bytes (top 2 bits 11)

mount core.*;
mount core.collections.List;
mount core.net.quic.frame.{QuicFrame, AckRange, EcnCounts, encode_frame, decode_frame};

fn ack_largest_in_two_byte_varint_range() {
    // largest_acked = 100 → 2-byte varint 0x40 0x64.
    // ack_delay = 0 → 1 byte.
    // range_count = 0 → 1 byte.
    // first_range_len = 0 → 1 byte.
    // Wire: 0x02 0x40 0x64 0x00 0x00 0x00 = 6 bytes.
    let ranges: List<AckRange> = [ AckRange { smallest: 100_u64, largest: 100_u64 } ];
    let f = QuicFrame.AckFrame {
        largest_acked: 100_u64,
        ack_delay:     0_u64,
        ranges:        ranges,
        ecn:           None,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    assert(out.len() == 6);
    assert(out[0] == 0x02_u8);        // ACK type
    assert(out[1] == 0x40_u8);        // largest varint high
    assert(out[2] == 0x64_u8);        // largest varint low (= 100)
    assert(out[3] == 0x00_u8);        // delay
    assert(out[4] == 0x00_u8);        // range count
    assert(out[5] == 0x00_u8);        // first range len
}

fn ack_largest_at_four_byte_varint_boundary() {
    // largest_acked = 16384 → first value requiring 4-byte varint.
    //   = 0x80 0x00 0x40 0x00 (top 2 bits = 10, 30-bit value = 16384).
    let ranges: List<AckRange> = [ AckRange { smallest: 16384_u64, largest: 16384_u64 } ];
    let f = QuicFrame.AckFrame {
        largest_acked: 16384_u64,
        ack_delay:     0_u64,
        ranges:        ranges,
        ecn:           None,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // type(1) + largest(4) + delay(1) + count(1) + first_len(1) = 8.
    assert(out.len() == 8);
    assert(out[0] == 0x02_u8);
    assert(out[1] == 0x80_u8);        // top bits = 10
    assert(out[2] == 0x00_u8);
    assert(out[3] == 0x40_u8);
    assert(out[4] == 0x00_u8);
    // Verify top 2 bits encode 4-byte length class.
    assert((out[1] & 0xC0_u8) == 0x80_u8);
}

fn ack_first_range_spans_100_packets() {
    // first range = 100 packets wide. Largest = 100, smallest = 1.
    //   first_len = 99 → 2-byte varint 0x40 0x63.
    let ranges: List<AckRange> = [ AckRange { smallest: 1_u64, largest: 100_u64 } ];
    let f = QuicFrame.AckFrame {
        largest_acked: 100_u64,
        ack_delay:     0_u64,
        ranges:        ranges,
        ecn:           None,
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    assert(out[0] == 0x02_u8);
    assert(out[1] == 0x40_u8 && out[2] == 0x64_u8);    // largest 100 (2-byte)
    assert(out[3] == 0x00_u8);                          // delay
    assert(out[4] == 0x00_u8);                          // range_count = 0
    assert(out[5] == 0x40_u8 && out[6] == 0x63_u8);    // first_len 99 (2-byte)
    assert(out.len() == 7);
}

fn ack_ecn_counts_large_values() {
    // ECN counts at 1000 each — each is a 2-byte varint.
    // 1000 = 0x3E8 → 0x43 0xE8.
    let ranges: List<AckRange> = [ AckRange { smallest: 5_u64, largest: 5_u64 } ];
    let f = QuicFrame.AckFrame {
        largest_acked: 5_u64,
        ack_delay:     0_u64,
        ranges:        ranges,
        ecn:           Some(EcnCounts { ect0: 1000_u64, ect1: 1000_u64, ce: 1000_u64 }),
    };
    let mut out: List<Byte> = [];
    let _ = encode_frame(&f, &mut out);
    // Wire: 0x03 (ACK_ECN) || 0x05 largest || 0x00 delay || 0x00 count ||
    //       0x00 first_len || ect0(2) || ect1(2) || ce(2) = 11.
    assert(out.len() == 11);
    assert(out[0] == 0x03_u8);
    // ect0 varint at bytes 5..=6.
    assert(out[5] == 0x43_u8 && out[6] == 0xE8_u8);
    assert(out[7] == 0x43_u8 && out[8] == 0xE8_u8);
    assert(out[9] == 0x43_u8 && out[10] == 0xE8_u8);
}

fn ack_frame_multi_byte_decode_roundtrip() {
    // Round-trip a frame that has 2-byte and 4-byte varints.
    let ranges: List<AckRange> = [
        AckRange { smallest: 16000_u64, largest: 16384_u64 },   // first_len = 384 (2-byte)
        AckRange { smallest: 1_u64,     largest: 15_000_u64 },   // gap + len vary
    ];
    let f = QuicFrame.AckFrame {
        largest_acked: 16384_u64,
        ack_delay:     200_u64,
        ranges:        ranges,
        ecn:           None,
    };
    let mut wire: List<Byte> = [];
    let _ = encode_frame(&f, &mut wire);
    let (decoded, next) = decode_frame(wire.as_slice(), 0).unwrap();
    assert(next == wire.len());
    match decoded {
        QuicFrame.AckFrame { largest_acked, ack_delay, ranges: dec_ranges, ecn } => {
            assert(largest_acked == 16384_u64);
            assert(ack_delay == 200_u64);
            assert(dec_ranges.len() == 2);
            assert(dec_ranges[0].largest == 16384_u64);
            assert(dec_ranges[0].smallest == 16000_u64);
            assert(dec_ranges[1].largest == 15_000_u64);
            assert(dec_ranges[1].smallest == 1_u64);
            match ecn {
                None    => {},
                Some(_) => panic("expected no ECN"),
            }
        },
        _ => panic("expected AckFrame"),
    }
}

@main
public fn main() -> Int {
    ack_largest_in_two_byte_varint_range();
    ack_largest_at_four_byte_varint_boundary();
    ack_first_range_spans_100_packets();
    ack_ecn_counts_large_values();
    ack_frame_multi_byte_decode_roundtrip();
    print("RFC 9000 §19.3 ACK frame multi-byte-varint encode KAT verified");
    0
}
