// @test: unit
// @tier: 0
// @level: L2
// @tags: quic, cubic, rfc9438, congestion_control, kat
// @timeout: 10000
// @expect: pass

// RFC 9438 CUBIC congestion-control validation traces.
//
// CUBIC invariants this test asserts:
//   * Constructor starts at INITIAL_WINDOW_BYTES, above MIN.
//   * On loss event, cwnd = w_max × β (β = 0.7), floored at MIN.
//   * Repeated losses continue to floor-clamp at MIN_WINDOW_BYTES
//     (shared V5-style invariant).
//   * Pacing activates after the first valid RTT sample.

mount core.*;
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};
mount core.net.quic.recovery.cc.cubic.{Cubic};
mount core.net.quic.recovery.cc.{
    CongestionCtrl, MAX_DATAGRAM_SIZE, INITIAL_WINDOW_BYTES, MIN_WINDOW_BYTES,
};

fn rtt_25ms() -> Duration { Duration.from_millis(25) }

fn main() {
    // Scenario 1: fresh CUBIC sits at 10 × MDS.
    let c0 = Cubic.new();
    assert_eq(c0.window(), INITIAL_WINDOW_BYTES);

    // Scenario 2: loss cuts cwnd and sets ssthresh floor.
    let mut c1 = Cubic.new();
    c1.on_packet_sent(MAX_DATAGRAM_SIZE * 4_u32);
    let w_before = c1.window();
    c1.on_packets_lost(MAX_DATAGRAM_SIZE, Instant.now());
    // Post-loss cwnd = β × w_before ≈ 0.7 × w_before, but capped at MIN.
    assert_eq(c1.window() <= w_before, true);
    assert_eq(c1.window() >= MIN_WINDOW_BYTES, true);

    // Scenario 3: repeated losses floor at MIN.
    let mut c2 = Cubic.new();
    c2.on_packet_sent(MAX_DATAGRAM_SIZE * 32_u32);
    let mut i: Int = 0;
    while i < 30 {
        c2.on_packets_lost(MAX_DATAGRAM_SIZE / 4_u32, Instant.now());
        assert_eq(c2.window() >= MIN_WINDOW_BYTES, true);
        i = i + 1;
    }

    // Scenario 4: pacing rate becomes non-zero after an ACK provides RTT.
    let mut c3 = Cubic.new();
    c3.on_packet_sent(MAX_DATAGRAM_SIZE);
    c3.on_ack_received(MAX_DATAGRAM_SIZE, rtt_25ms(), Instant.now());
    assert_eq(c3.pacing_rate() > 0_u64 || !c3.should_pace(), true);

    // Scenario 5: bytes_in_flight never goes negative on over-ACK.
    let mut c4 = Cubic.new();
    c4.on_packet_sent(MAX_DATAGRAM_SIZE);
    c4.on_ack_received(MAX_DATAGRAM_SIZE, rtt_25ms(), Instant.now());
    c4.on_ack_received(MAX_DATAGRAM_SIZE, rtt_25ms(), Instant.now());   // spurious
    assert_eq(c4.bytes_in_flight() >= 0_u32, true);

    print("RFC 9438 CUBIC traces (5 scenarios) OK");
}
