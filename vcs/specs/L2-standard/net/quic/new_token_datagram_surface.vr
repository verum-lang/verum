// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, new_token, datagram, rfc9000_19_7, rfc9221
// @timeout: 15000
// @expected-exit: 0

// Surface-level coverage for two previously-untested QUIC frame
// variants:
//
//   * NEW_TOKEN (0x07, RFC 9000 §19.7) — server-to-client, gives the
//     client an address-validation token for future 0-RTT.
//   * DATAGRAM (0x30 / 0x31, RFC 9221) — optional datagram extension.
//     0x30 = no length prefix, 0x31 = with length prefix.
//
// This test exercises construction + encode + decode-all round-trip
// on the typed surface. Ack-eliciting classification is also checked:
// NEW_TOKEN elicits ACKs; DATAGRAM elicits ACKs.

mount core.*;
mount core.collections.List;
mount core.net.quic.frame.{QuicFrame, encode_frame, decode_all_frames};

fn bytes_eq(a: &[Byte], b: &[Byte]) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        if a[i] != b[i] { return false; }
        i = i + 1;
    }
    true
}

fn assert_decoded_new_token(f: &Frame, want: &[Byte]) {
    match f {
        QuicFrame.NewToken(tok) => {
            assert(bytes_eq(tok, want));
        },
        _ => panic("expected NewToken"),
    }
}

fn assert_decoded_datagram(f: &Frame, want: &[Byte], want_with_length: Bool) {
    match f {
        QuicFrame.Datagram { data, with_length } => {
            assert(bytes_eq(data, want));
            assert(with_length == want_with_length);
        },
        _ => panic("expected Datagram"),
    }
}

fn new_token_roundtrip_surface() {
    let token: List<Byte> = [0xDE_u8, 0xAD_u8, 0xBE_u8, 0xEF_u8];
    let f = QuicFrame.NewToken(token.clone());
    assert(f.is_ack_eliciting());

    let mut buf: List<Byte> = [];
    let _ = encode_frame(&f, &mut buf);
    assert(buf.len() > 0);
    assert(buf[0] == 0x07_u8);

    let _ = decode_all_frames(&buf);   // parser must accept
}

fn datagram_with_length_surface() {
    let data: List<Byte> = [0x01_u8, 0x02_u8, 0x03_u8];
    let f = QuicFrame.Datagram { data: data.clone(), with_length: true };
    assert(f.is_ack_eliciting());

    let mut buf: List<Byte> = [];
    let _ = encode_frame(&f, &mut buf);
    assert(buf.len() > 0);
    assert(buf[0] == 0x31_u8);

    let _ = decode_all_frames(&buf);
}

fn datagram_no_length_surface() {
    let data: List<Byte> = [0x04_u8, 0x05_u8];
    let f = QuicFrame.Datagram { data: data.clone(), with_length: false };
    assert(f.is_ack_eliciting());

    let mut buf: List<Byte> = [];
    let _ = encode_frame(&f, &mut buf);
    assert(buf.len() > 0);
    assert(buf[0] == 0x30_u8);
}

@main
public fn main() -> Int {
    new_token_roundtrip_surface();
    datagram_with_length_surface();
    datagram_no_length_surface();
    print("NEW_TOKEN + DATAGRAM surface verified");
    0
}
