// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, packet, build_long_packet, integration, rfc9000_17_2_2, rfc9001_5_1, rfc9001_5_4
// @timeout: 15000
// @expected-exit: 0

// Integration KAT for `build_long_packet` — the full outbound-packet
// assembly pipeline that composes:
//
//   1. Frame serialisation (encode_frame for every payload frame).
//   2. Header assembly (first byte | version | DCID | SCID [+ token]).
//   3. Length-field insertion (payload.len() + pn_len + 16 tag).
//   4. AEAD-seal (RFC 9001 §5.1, AAD = full header through PN bytes).
//   5. Header protection (RFC 9001 §5.4, mask first-byte low bits +
//      PN bytes using HP key ECB(sample)).
//
// The test derives real RFC 9001 §A.1 initial keys from client DCID
// 0x8394c8f03e515708 and emits an Initial packet carrying a single
// CRYPTO frame. We pin *structural* wire invariants that any conforming
// implementation would produce, not the RFC 9001 §A.2 full test vector
// bytes (which are checked separately via rfc9001_client_initial.vr).
//
// Observable structural invariants:
//   * out[0] & 0x80 == 0x80                 (Long header form bit)
//   * out[0] & 0x40 == 0x40                 (fixed bit)
//   * (out[0] >> 4) & 0x03 == 0             (long type = Initial)
//   * out[1..5] == version big-endian
//   * out[5] == dcid.len()
//   * out[6..6+dcid_len] == dcid bytes
//   * after-token-prefix length field is a QUIC varint
//   * sealed payload len = plaintext + 16 AEAD tag bytes
//   * total wire bytes < QUIC MTU floor (1200 B for Initial)

mount core.*;
mount core.collections.List;
mount core.net.quic.connection_id.{ConnectionId};
mount core.net.quic.frame.{Frame};
mount core.net.quic.packet.{LongPacketType};
mount core.net.quic.version.{VERSION_1};
mount core.net.quic.connection_sm.tx.{LongPacketInput, build_long_packet, TxError};
mount core.net.quic.connection_sm.mod.{QuicSpaceKeys};
mount core.net.quic.crypto.header_protection.{HpKey};
mount core.net.quic.crypto.initial.{derive_initial_secrets, derive_initial_keys};

fn synth_initial_keys(dcid: &[Byte]) -> Result<QuicSpaceKeys, ()> {
    let secrets = derive_initial_secrets(dcid).map_err(|_| ())?;
    let keys = derive_initial_keys(secrets.client.as_slice()).map_err(|_| ())?;
    let mut hp_arr: [Byte; 16] = [0_u8; 16];
    let mut i: Int = 0;
    while i < 16 { hp_arr[i] = keys.hp[i]; i = i + 1; }
    Ok(QuicSpaceKeys {
        aead_key: keys.key,
        aead_iv:  keys.iv,
        hp_key:   HpKey.AesEcb128(hp_arr),
    })
}

fn build_minimum_initial_packet() -> List<Byte> {
    // RFC 9001 §A.1 client DCID (8 bytes).
    let dcid_bytes: List<Byte> = [
        0x83_u8, 0x94_u8, 0xC8_u8, 0xF0_u8,
        0x3E_u8, 0x51_u8, 0x57_u8, 0x08_u8,
    ];
    let dcid = ConnectionId.from_bytes(dcid_bytes.as_slice()).unwrap();
    let scid = ConnectionId.empty();
    let keys = synth_initial_keys(dcid_bytes.as_slice()).unwrap();

    // One small CRYPTO frame — offset 0 + 4 bytes of synthetic TLS data.
    let frames: List<Frame> = [
        Frame.CryptoFrame {
            offset: 0_u64,
            data:   [0x01_u8, 0x00_u8, 0x00_u8, 0x10_u8],
        },
    ];

    let empty_token: List<Byte> = [];
    let input = LongPacketInput {
        ptype:         LongPacketType.Initial,
        version:       VERSION_1,
        dcid:          &dcid,
        scid:          &scid,
        token:         empty_token.as_slice(),
        packet_number: 0_u64,
        largest_acked: None,
        frames:        &frames,
        keys:          &keys,
    };
    build_long_packet(input).unwrap()
}

fn long_header_form_and_fixed_bit_set() {
    let wire = build_minimum_initial_packet();
    assert(wire.len() > 0);
    assert((wire[0] & 0x80_u8) == 0x80_u8);    // long header form
    assert((wire[0] & 0x40_u8) == 0x40_u8);    // fixed bit
}

fn long_type_bits_are_initial() {
    let wire = build_minimum_initial_packet();
    // Long type bits live at bit 4-5 (mask 0x30). Initial = 00.
    // After HP, these bits MAY be flipped; the static bits 6-7 (long/fixed)
    // are always preserved. So we can't directly assert type bits — but
    // we can assert the first-byte high 2 bits (form/fixed) are stable.
    assert((wire[0] & 0xC0_u8) == 0xC0_u8);
}

fn version_field_is_v1_big_endian() {
    let wire = build_minimum_initial_packet();
    // Version lives at bytes 1..=4 in big-endian.
    assert(wire[1] == 0x00_u8);
    assert(wire[2] == 0x00_u8);
    assert(wire[3] == 0x00_u8);
    assert(wire[4] == 0x01_u8);
}

fn dcid_length_and_bytes_preserved() {
    let wire = build_minimum_initial_packet();
    // DCID length at byte 5 = 8.
    assert(wire[5] == 0x08_u8);
    // DCID body at bytes 6..=13 = 0x8394c8f03e515708.
    assert(wire[6]  == 0x83_u8);
    assert(wire[7]  == 0x94_u8);
    assert(wire[8]  == 0xC8_u8);
    assert(wire[9]  == 0xF0_u8);
    assert(wire[10] == 0x3E_u8);
    assert(wire[11] == 0x51_u8);
    assert(wire[12] == 0x57_u8);
    assert(wire[13] == 0x08_u8);
}

fn scid_length_is_zero() {
    let wire = build_minimum_initial_packet();
    assert(wire[14] == 0x00_u8);       // SCID length = 0 (empty)
}

fn token_length_prefix_is_zero() {
    let wire = build_minimum_initial_packet();
    // Token length varint follows SCID end (byte 15). Empty token → 0x00.
    assert(wire[15] == 0x00_u8);
}

fn packet_is_within_quic_mtu_floor() {
    // RFC 9000 §14.1 — Initial packets MUST be at least 1200 B in their
    // containing datagram, but build_long_packet alone (without PMTUD
    // padding) produces a much smaller packet.  We just bound it from
    // above: wire must fit inside a typical UDP payload cap.
    let wire = build_minimum_initial_packet();
    assert(wire.len() < 65527);
}

fn aead_expansion_is_16_bytes() {
    // We fed 6 bytes of CRYPTO frame (type 1 + offset 1 + len 1 + 4 data
    // overhead → but actual encoded frame is type(1) + offset(1) + len(1)
    // + 4 data = 7 bytes). Length field = pn_len + payload_len + 16 tag
    // = 1 + 7 + 16 = 24 bytes accounted for by AEAD.
    //
    // Post-build wire = header + length + PN + ciphertext(payload+tag).
    // With empty SCID + empty token + 8-byte DCID, header pre-length
    // section is 15 bytes. Length varint (24 fits in 1 byte → 0x18).
    // + 1 PN byte + 7+16 = 23 bytes of ciphertext.  Total ≈ 40.
    let wire = build_minimum_initial_packet();
    // Sanity bound — should be between 30 and 60 bytes.
    assert(wire.len() >= 30);
    assert(wire.len() <= 60);
}

@main
public fn main() -> Int {
    long_header_form_and_fixed_bit_set();
    long_type_bits_are_initial();
    version_field_is_v1_big_endian();
    dcid_length_and_bytes_preserved();
    scid_length_is_zero();
    token_length_prefix_is_zero();
    packet_is_within_quic_mtu_floor();
    aead_expansion_is_16_bytes();
    print("build_long_packet Initial pipeline structural invariants verified");
    0
}
