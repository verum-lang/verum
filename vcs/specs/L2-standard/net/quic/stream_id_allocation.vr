// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, stream_id, flow_control, rfc9000_2_1
// @timeout: 15000
// @expected-exit: 0

// RFC 9000 §2.1 stream-ID encoding:
//
//   bit 0  (LSB): initiator — 0 client, 1 server
//   bit 1: direction — 0 bidi, 1 uni
//   bits 2..:   sequence number within the 4 classes
//
// alloc_stream_bidi / alloc_stream_uni produce IDs with the right
// low bits set for the role + type.
//
// The allocator respects initial_max_streams_{bidi,uni}: once
// `next_stream_*_local == max_streams_*_remote`, further allocs
// return None and MUST wait for a MAX_STREAMS frame from the peer
// (on_peer_max_streams_*).

mount core.*;
mount core.net.quic.stream_sm.flow_control.{ConnFlowControl};

fn client_bidi_ids_have_low_bits_00() {
    let mut fc = ConnFlowControl::new(
        0_u64, 0_u64,
        /* max_bidi_remote */ 3_u64, 0_u64,
        0_u64, 0_u64,
    );
    match fc.alloc_stream_bidi(false) {
        Some(id) => assert(id == 0_u64),
        None => panic("first bidi alloc must succeed"),
    }
    match fc.alloc_stream_bidi(false) {
        Some(id) => assert(id == 4_u64),       // seq 1 << 2 | 0x00
        None => panic("second bidi alloc"),
    }
    match fc.alloc_stream_bidi(false) {
        Some(id) => assert(id == 8_u64),       // seq 2 << 2 | 0x00
        None => panic("third bidi alloc"),
    }
    // Budget of 3 — fourth allocation refused.
    match fc.alloc_stream_bidi(false) {
        None => {},
        _ => panic("fourth alloc must exhaust budget"),
    }
}

fn server_bidi_ids_have_low_bits_01() {
    let mut fc = ConnFlowControl::new(0_u64, 0_u64, 2_u64, 0_u64, 0_u64, 0_u64);
    match fc.alloc_stream_bidi(true) {
        Some(id) => assert(id == 1_u64),       // seq 0 << 2 | 0x01
        None => panic("server bidi 0"),
    }
    match fc.alloc_stream_bidi(true) {
        Some(id) => assert(id == 5_u64),       // seq 1 << 2 | 0x01
        None => panic("server bidi 1"),
    }
}

fn client_uni_ids_have_low_bits_10() {
    let mut fc = ConnFlowControl::new(0_u64, 0_u64, 0_u64, 0_u64, 2_u64, 0_u64);
    match fc.alloc_stream_uni(false) {
        Some(id) => assert(id == 2_u64),       // seq 0 << 2 | 0x02
        None => panic("client uni 0"),
    }
    match fc.alloc_stream_uni(false) {
        Some(id) => assert(id == 6_u64),       // seq 1 << 2 | 0x02
        None => panic("client uni 1"),
    }
}

fn server_uni_ids_have_low_bits_11() {
    let mut fc = ConnFlowControl::new(0_u64, 0_u64, 0_u64, 0_u64, 2_u64, 0_u64);
    match fc.alloc_stream_uni(true) {
        Some(id) => assert(id == 3_u64),       // seq 0 << 2 | 0x03
        None => panic("server uni 0"),
    }
    match fc.alloc_stream_uni(true) {
        Some(id) => assert(id == 7_u64),       // seq 1 << 2 | 0x03
        None => panic("server uni 1"),
    }
}

fn on_peer_max_streams_unblocks_allocator() {
    let mut fc = ConnFlowControl::new(0_u64, 0_u64, 1_u64, 0_u64, 0_u64, 0_u64);
    // Spend the single credit.
    let _ = fc.alloc_stream_bidi(false);
    match fc.alloc_stream_bidi(false) {
        None => {},
        _ => panic("budget exhausted"),
    }
    // Peer raises bidi limit → allocator unblocks.
    fc.on_peer_max_streams_bidi(3_u64);
    match fc.alloc_stream_bidi(false) {
        Some(id) => assert(id == 4_u64),
        None => panic("on_peer_max_streams_bidi should raise budget"),
    }
}

fn stream_id_low_bits_are_pairwise_distinct_across_roles() {
    // Allocate one of each kind and verify the low 2 bits form the
    // complete set {00, 01, 10, 11} = {0, 1, 2, 3}.
    let mut fc = ConnFlowControl::new(0_u64, 0_u64, 2_u64, 2_u64, 2_u64, 2_u64);
    let client_bidi = fc.alloc_stream_bidi(false).unwrap() & 0x03_u64;
    let server_bidi = fc.alloc_stream_bidi(true).unwrap()  & 0x03_u64;
    let client_uni  = fc.alloc_stream_uni(false).unwrap()  & 0x03_u64;
    let server_uni  = fc.alloc_stream_uni(true).unwrap()   & 0x03_u64;
    assert(client_bidi == 0_u64);
    assert(server_bidi == 1_u64);
    assert(client_uni  == 2_u64);
    assert(server_uni  == 3_u64);
}

@main
public fn main() -> Int {
    client_bidi_ids_have_low_bits_00();
    server_bidi_ids_have_low_bits_01();
    client_uni_ids_have_low_bits_10();
    server_uni_ids_have_low_bits_11();
    on_peer_max_streams_unblocks_allocator();
    stream_id_low_bits_are_pairwise_distinct_across_roles();
    print("RFC 9000 §2.1 stream-ID allocation verified");
    0
}
