// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: quic, ack, ecn, rfc9000_19_3
// @timeout: 15000
// @expected-exit: 0

// RFC 9000 §19.3.2 ECN-extended ACK frame (type 0x03): carries
// EcnCounts {ect0, ect1, ce} as three varints after the normal ACK
// range block. This test exercises encode/decode round-trip on the
// typed surface.

mount core.*;
mount core.collections.List;
mount core.net.quic.frame.{
    QuicFrame, AckRange, EcnCounts,
    encode_frame, decode_all_frames,
};

fn assert_ack_ecn_eq(f: &Frame, want_largest: UInt64, want_delay: UInt64,
                     want_e0: UInt64, want_e1: UInt64, want_ce: UInt64) {
    match f {
        QuicFrame.AckFrame { largest_acked, ack_delay, ranges: _, ecn } => {
            assert(largest_acked == want_largest);
            assert(ack_delay == want_delay);
            match ecn {
                Some(c) => {
                    assert(c.ect0 == want_e0);
                    assert(c.ect1 == want_e1);
                    assert(c.ce   == want_ce);
                },
                None => panic("expected ECN counts present"),
            }
        },
        _ => panic("expected AckFrame"),
    }
}

fn ecn_ack_encodes_to_type_0x03() {
    let ranges: List<AckRange> = [
        AckRange { smallest: 10_u64, largest: 10_u64 },
    ];
    let ecn = Some(EcnCounts { ect0: 5_u64, ect1: 3_u64, ce: 1_u64 });
    let f = QuicFrame.AckFrame {
        largest_acked: 10_u64,
        ack_delay:     0_u64,
        ranges:        ranges,
        ecn:           ecn,
    };
    let mut buf: List<Byte> = [];
    let _ = encode_frame(&f, &mut buf);
    // Type byte 0x03 = ACK_ECN.
    assert(buf[0] == 0x03_u8);
    let frames = decode_all_frames(&buf).unwrap();
    assert(frames.len() == 1);
    assert_ack_ecn_eq(&frames[0], 10_u64, 0_u64, 5_u64, 3_u64, 1_u64);
}

fn plain_ack_encodes_to_type_0x02() {
    let ranges: List<AckRange> = [
        AckRange { smallest: 20_u64, largest: 20_u64 },
    ];
    let f = QuicFrame.AckFrame {
        largest_acked: 20_u64,
        ack_delay:     0_u64,
        ranges:        ranges,
        ecn:           None,
    };
    let mut buf: List<Byte> = [];
    let _ = encode_frame(&f, &mut buf);
    assert(buf[0] == 0x02_u8);
    let frames = decode_all_frames(&buf).unwrap();
    match &frames[0] {
        QuicFrame.AckFrame { ecn, .. } => {
            match ecn {
                None => {},
                _ => panic("plain ACK must not carry ECN"),
            }
        },
        _ => panic("expected AckFrame"),
    }
}

fn ecn_ack_with_multiple_ranges_preserves_all_fields() {
    let ranges: List<AckRange> = [
        AckRange { smallest: 100_u64, largest: 102_u64 },
        AckRange { smallest: 50_u64,  largest: 60_u64 },
    ];
    let ecn = Some(EcnCounts { ect0: 1000_u64, ect1: 1001_u64, ce: 7_u64 });
    let f = QuicFrame.AckFrame {
        largest_acked: 102_u64,
        ack_delay:     12345_u64,
        ranges:        ranges,
        ecn:           ecn,
    };
    let mut buf: List<Byte> = [];
    let _ = encode_frame(&f, &mut buf);
    assert(buf[0] == 0x03_u8);
    let frames = decode_all_frames(&buf).unwrap();
    assert_ack_ecn_eq(&frames[0], 102_u64, 12345_u64, 1000_u64, 1001_u64, 7_u64);
}

@main
public fn main() -> Int {
    ecn_ack_encodes_to_type_0x03();
    plain_ack_encodes_to_type_0x02();
    ecn_ack_with_multiple_ranges_preserves_all_fields();
    print("RFC 9000 §19.3 ACK + ECN round-trip verified");
    0
}
