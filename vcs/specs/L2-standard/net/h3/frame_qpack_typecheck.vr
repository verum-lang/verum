// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: h3, qpack, rfc9114, rfc9204, typecheck
// @timeout: 10000
// @expect: pass

// Explicit imports — avoid the glob-import collision where `stat`
// module alias resolves to `core.sys.Stat` struct via a transitively
// imported core.*.
mount core.net.h3.frame.{
    H3Frame, encode_frame, decode_frame,
    SETTING_QPACK_MAX_TABLE_CAPACITY, SETTING_QPACK_BLOCKED_STREAMS,
    UniStreamType, encode_stream_type, decode_stream_type,
};
mount core.net.h3.qpack.decoder.{
    QpackHeaderField, QpackDecodeError, decode_field_section,
};
mount core.net.h3.qpack.encoder.{encode_field_section};
mount core.net.h3.qpack.static_table.{get as st_get, find as st_find, find_name as st_find_name};
mount core.net.h3.qpack.huffman.{encoded_bit_length as huff_bit_len, encode as huff_encode, decode as huff_decode};

fn check_frame_roundtrip() {
    let f = H3Frame.SettingsFrame([
        (SETTING_QPACK_MAX_TABLE_CAPACITY, 0_u64),
        (SETTING_QPACK_BLOCKED_STREAMS, 0_u64),
    ]);
    let mut buf: List<Byte> = [];
    encode_frame(&f, &mut buf);
    let _ = decode_frame(buf.as_slice(), 0);
}

fn check_stream_type() {
    let mut buf: List<Byte> = [];
    encode_stream_type(&UniStreamType.ControlStream, &mut buf);
    let _ = decode_stream_type(buf.as_slice());
}

fn check_qpack_static_table() {
    let _ = st_get(0);
    let _ = st_get(98);
    let _ = st_find(&Text.from(":method"), &Text.from("GET"));
    let _ = st_find_name(&Text.from(":status"));
}

fn check_qpack_roundtrip() -> Result<(), QpackDecodeError> {
    let headers: List<QpackHeaderField> = [
        QpackHeaderField { name: Text.from(":method"), value: Text.from("GET") },
        QpackHeaderField { name: Text.from(":scheme"), value: Text.from("https") },
        QpackHeaderField { name: Text.from(":path"),   value: Text.from("/api/users/42") },
        QpackHeaderField { name: Text.from(":authority"), value: Text.from("example.com") },
        QpackHeaderField { name: Text.from("user-agent"), value: Text.from("verum-h3/0.1") },
    ];
    let encoded = encode_field_section(&headers);
    let _ = decode_field_section(encoded.as_slice())?;
    Ok(())
}

fn check_huffman_shape() {
    let bytes: [Byte; 5] = [0x68_u8, 0x65_u8, 0x6c_u8, 0x6c_u8, 0x6f_u8];  // "hello"
    let _ = huff_bit_len(&bytes);
    let mut out: List<Byte> = [];
    huff_encode(&bytes, &mut out);
    let _ = huff_decode(out.as_slice());
}

fn main() {
    check_frame_roundtrip();
    check_stream_type();
    check_qpack_static_table();
    let _ = check_qpack_roundtrip();
    check_huffman_shape();
}
