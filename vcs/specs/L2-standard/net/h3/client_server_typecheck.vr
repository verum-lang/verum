// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: h3, client, server, facade, typecheck
// @timeout: 10000
// @expect: pass

// Explicit submodule mounts — `mount core.net.h3.*;` here would
// collide with the subsequent nested mounts and make `ClientOptions`
// / `ServerOptions` report as unbound (known latent bug in nested+glob
// interaction).
mount core.net.h3.client.{H3Client, ClientOptions, H3ClientError};
mount core.net.h3.server.{H3Server, ServerOptions, H3Handler, H3ServerError};

async fn check_client_api() -> Result<(), H3ClientError> {
    let opts = ClientOptions.default();
    let mut client = H3Client.connect(&"https://example.com/", opts).await?;
    let _ = client.authority();
    let _ = client.peer_addr();
    let _ = client.selected_alpn();

    // Typecheck the request helpers.
    let _ = client.get(&"/api/v1/ping").await;
    let _ = client.post(
        &"/api/v1/users",
        &"application/json",
        b"{}".to_list(),
    ).await;
    Ok(())
}

fn check_server_api_shape() {
    // Server construction shape — full flow exercised in the
    // integration commit once QUIC transport end-to-end wires in.
    let _ = ServerOptions.from_cert;
    let _ = H3Server.bind;
}

fn main() {
    let _ = check_client_api;
    check_server_api_shape();
}
