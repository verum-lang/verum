// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: net, ipv6, rfc5952, canonical, typecheck
// @timeout: 10000
// @expect: pass

mount core.net.ipv6_canonical.{
    Ipv6CanonicalError, format, parse, canonicalize, equal_addresses,
};
mount core.net.addr.{Ipv6Addr};

fn exercise_canonical() -> Result<(), Ipv6CanonicalError> {
    // Parse various equivalent spellings + canonicalise.
    let _ = canonicalize(&Text.from("2001:0db8.1"))?;
    let _ = canonicalize(&Text.from("2001:DB8:0:0:0:0:0:1"))?;
    let _ = canonicalize(&Text.from("2001:0DB8:0000:0000:0000:0000:0000:0001"))?;

    // All above should canonicalise equal.
    let a = Text.from("2001:0db8.1");
    let b = Text.from("2001:0DB8:0:0:0:0:0:1");
    assert(equal_addresses(&a, &b));

    // Loopback + all-zeros canonical forms.
    let loop_c = canonicalize(&Text.from("0:0:0:0:0:0:0:1"))?;
    let _ = loop_c;

    // Single-zero group NOT compressed per §4.2.2.
    // 2001:db8:0:1.1 — 5th group is single zero, should NOT become ::.
    let _ = canonicalize(&Text.from("2001:db8:0:1:1:1:1:1"))?;

    // IPv4-mapped form preserved.
    let _ = canonicalize(&Text.from("::ffff:192.0.2.1"))?;

    // Direct format call.
    let addr: Ipv6Addr = parse(&Text.from("2001:db8::"))?;
    let s: Text = format(&addr);
    let _ = s;

    // Malformed input → typed error.
    let bad = canonicalize(&Text.from("not an address"));
    let _ = bad;
    Ok(())
}

fn main() { let _ = exercise_canonical(); }
