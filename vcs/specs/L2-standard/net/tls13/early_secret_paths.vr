// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, keyschedule, early_secret, rfc8446_7_1
// @timeout: 15000
// @expected-exit: 0

// RFC 8446 §7.1 EarlySecret derivation — two entry points:
//
//   EarlySecret.derive_no_psk(hash)         — fresh (non-resumption)
//                                              handshake; IKM = HashLen
//                                              zeros.
//   EarlySecret.derive_with_psk(hash, psk)  — resumption or external
//                                              PSK path; IKM = psk.
//
// derive_no_psk is exactly derive_with_psk with an all-zero IKM of
// HashLen bytes — the equality pins that invariant so a future
// refactor doesn't accidentally diverge the paths.
//
// binder_key(is_ext) picks between "ext binder" and "res binder"
// labels (§4.2.11.2) — a domain separator keeping external vs
// resumption PSKs from cross-binding.

mount core.*;
mount core.collections.List;
mount core.net.tls13.cipher_suite.{HashKind};
mount core.net.tls13.keyschedule.schedule.{EarlySecret, SecretBytes};

fn bytes_eq(a: &[Byte], b: &[Byte]) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        if a[i] != b[i] { return false; }
        i = i + 1;
    }
    true
}

fn no_psk_equals_all_zero_psk_sha256() {
    let no_psk = EarlySecret.derive_no_psk(HashKind.Sha256).unwrap();
    let zeros: List<Byte> = [0_u8; 32].to_list();
    let with_zero = EarlySecret.derive_with_psk(HashKind.Sha256, zeros.as_slice()).unwrap();
    // Both must extract to the same PRK — RFC 8446 §7.1 says
    // "zero-filled vector of length Hash.length" is the no-PSK input.
    assert(bytes_eq(no_psk.secret.as_slice(), with_zero.secret.as_slice()));
}

fn no_psk_equals_all_zero_psk_sha384() {
    let no_psk = EarlySecret.derive_no_psk(HashKind.Sha384).unwrap();
    let zeros: List<Byte> = [0_u8; 48].to_list();
    let with_zero = EarlySecret.derive_with_psk(HashKind.Sha384, zeros.as_slice()).unwrap();
    assert(bytes_eq(no_psk.secret.as_slice(), with_zero.secret.as_slice()));
}

fn different_psks_yield_different_secrets() {
    let a: List<Byte> = [0x11_u8; 32];
    let b: List<Byte> = [0x22_u8; 32];
    let es_a = EarlySecret.derive_with_psk(HashKind.Sha256, a.as_slice()).unwrap();
    let es_b = EarlySecret.derive_with_psk(HashKind.Sha256, b.as_slice()).unwrap();
    // Bytewise difference — HKDF-Extract is PRF-like, so all-uniform PSK
    // inputs produce essentially-random PRKs; at least one byte differs.
    let a_slice = es_a.secret.as_slice();
    let b_slice = es_b.secret.as_slice();
    let mut any_diff = false;
    let mut i: Int = 0;
    while i < a_slice.len() {
        if a_slice[i] != b_slice[i] { any_diff = true; }
        i = i + 1;
    }
    assert(any_diff);
}

fn hash_kind_survives_derive() {
    let es = EarlySecret.derive_no_psk(HashKind.Sha384).unwrap();
    match es.hash {
        HashKind.Sha384 => {},
        _ => panic("hash must round-trip as Sha384"),
    }
    // Secret length matches HashLen (48 for SHA-384).
    assert(es.secret.len() == 48);
}

fn ext_binder_key_differs_from_res_binder_key() {
    // RFC 8446 §7.1 — "ext binder" vs "res binder" labels domain-
    // separate external PSKs from resumption PSKs. The binder keys
    // MUST differ bytewise even though the parent EarlySecret is
    // the same.
    let es = EarlySecret.derive_no_psk(HashKind.Sha256).unwrap();
    let ext_bk = es.binder_key(true).unwrap();
    let res_bk = es.binder_key(false).unwrap();
    let ext_slice = ext_bk.as_slice();
    let res_slice = res_bk.as_slice();
    assert(ext_slice.len() == res_slice.len());
    let mut any_diff = false;
    let mut i: Int = 0;
    while i < ext_slice.len() {
        if ext_slice[i] != res_slice[i] { any_diff = true; }
        i = i + 1;
    }
    assert(any_diff);
}

@main
public fn main() -> Int {
    no_psk_equals_all_zero_psk_sha256();
    no_psk_equals_all_zero_psk_sha384();
    different_psks_yield_different_secrets();
    hash_kind_survives_derive();
    ext_binder_key_differs_from_res_binder_key();
    print("RFC 8446 §7.1 EarlySecret derivation paths verified");
    0
}
