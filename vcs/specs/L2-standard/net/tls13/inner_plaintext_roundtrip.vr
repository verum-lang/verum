// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, record, inner_plaintext, rfc8446_5_2
// @timeout: 15000
// @expected-exit: 0

// RFC 8446 §5.2 TLSInnerPlaintext layout:
//
//   struct {
//       opaque      content[TLSPlaintext.length];
//       ContentType type;
//       uint8       zeros[length_of_padding];
//   }
//
// `build_inner_plaintext(content, type, pad_len)` appends the bytes in
// that order. `parse_inner_plaintext(inner)` strips trailing zeros to
// discover the ContentType at the tail, then returns (type, content).
//
//   - all-zero payload → NoContentType
//   - trailing Invalid (0) ContentType → InvalidInnerType
//   - roundtrip preserves content bytes + type
//   - arbitrary padding length is tolerated

mount core.*;
mount core.collections.List;
mount core.net.tls13.record.content_type.{ContentType};
mount core.net.tls13.record.plaintext.{
    build_inner_plaintext, parse_inner_plaintext,
    RecordDecodeError, MAX_PLAINTEXT_SIZE, MAX_CIPHERTEXT_SIZE,
};

fn build_appends_type_then_padding() {
    let content: List<Byte> = [0xA1_u8, 0xA2_u8, 0xA3_u8];
    let inner = build_inner_plaintext(content.as_slice(), ContentType.Handshake, 4);
    // 3 content + 1 type + 4 zeros = 8.
    assert(inner.len() == 8);
    assert(inner[0] == 0xA1_u8);
    assert(inner[1] == 0xA2_u8);
    assert(inner[2] == 0xA3_u8);
    assert(inner[3] == ContentType.Handshake.to_u8());  // 22
    assert(inner[4] == 0_u8);
    assert(inner[7] == 0_u8);
}

fn parse_recovers_type_and_content() {
    let content: List<Byte> = [0xDE_u8, 0xAD_u8, 0xBE_u8, 0xEF_u8];
    let inner = build_inner_plaintext(content.as_slice(), ContentType.ApplicationData, 6);
    let (t, body) = parse_inner_plaintext(inner.as_slice()).unwrap();
    match t {
        ContentType.ApplicationData => {},
        _ => panic("expected ApplicationData"),
    }
    assert(body.len() == 4);
    assert(body[0] == 0xDE_u8);
    assert(body[3] == 0xEF_u8);
}

fn parse_with_zero_padding_recovers_type_at_tail() {
    // No padding — ContentType sits as the very last byte.
    let content: List<Byte> = [0x01_u8];
    let inner = build_inner_plaintext(content.as_slice(), ContentType.Alert, 0);
    let (t, body) = parse_inner_plaintext(inner.as_slice()).unwrap();
    match t {
        ContentType.Alert => {},
        _ => panic("expected Alert"),
    }
    assert(body.len() == 1);
    assert(body[0] == 0x01_u8);
}

fn parse_with_large_padding_still_finds_type() {
    let content: List<Byte> = [0x42_u8, 0x42_u8];
    // 100 zero-bytes of padding should not confuse the scanner.
    let inner = build_inner_plaintext(content.as_slice(), ContentType.Handshake, 100);
    let (t, body) = parse_inner_plaintext(inner.as_slice()).unwrap();
    match t {
        ContentType.Handshake => {},
        _ => panic("expected Handshake after stripping 100 zero bytes"),
    }
    assert(body.len() == 2);
}

fn parse_all_zeros_fails_no_content_type() {
    // A fully-zero blob means "everything is padding" — there is no
    // trailing type byte to recover.
    let blob: List<Byte> = [0_u8; 32];
    match parse_inner_plaintext(blob.as_slice()) {
        Err(RecordDecodeError.NoContentType) => {},
        _ => panic("all-zero blob must be NoContentType"),
    }
}

fn parse_invalid_inner_type_is_fatal() {
    // Trailing ContentType = 0 (Invalid) is forbidden per RFC 8446 §5.1.
    // Careful: we also need a non-zero byte earlier so the padding
    // stripper stops at position > 0.
    let mut blob: List<Byte> = [];
    blob.push(0xAA_u8);      // content
    blob.push(0xBB_u8);      // content
    blob.push(0x00_u8);      // Invalid ContentType (also looks like padding)
    // To make byte 2 (Invalid=0) the "apparent" ContentType, the tail
    // must look like a zero run terminated by this byte — i.e. stop
    // before any earlier zero. Since 0xAA/0xBB are both non-zero, the
    // scanner sees the last byte (position 2, value 0) and strips it —
    // then position 1 (0xBB) is the new tail, which is NOT Invalid.
    // So this particular blob would parse as type=0xBB (= Unknown(0xBB)).
    // Instead: force the very last byte non-zero = 0 (Invalid), with NO
    // trailing zeros. Verify error path.
    let only_invalid: List<Byte> = [0xAA_u8, 0x00_u8];
    // Here byte 1 = 0 is stripped, byte 0 = 0xAA is the type.
    // So this also doesn't hit the Invalid branch. Use an all-non-zero
    // tail with Invalid 0 sandwiched. The only way to hit InvalidInnerType
    // is for the LAST non-zero byte to decode as ContentType.Invalid(0).
    // Since 0 IS a padding byte, the scanner can never stop on 0 unless
    // there's a single byte whose value is 0 with no earlier content —
    // but that produces NoContentType (all zeros). So InvalidInnerType
    // is effectively unreachable via this API — proving the property
    // that the parser never returns ContentType.Invalid on success.
    let (t, _body) = parse_inner_plaintext(only_invalid.as_slice()).unwrap();
    match t {
        ContentType.Invalid => panic("parser must never return Invalid"),
        _ => {},
    }
}

fn record_size_constants_match_rfc() {
    // 2^14 = 16384 plaintext bound, 2^14 + 256 = 16640 ciphertext bound.
    assert(MAX_PLAINTEXT_SIZE   == 16384);
    assert(MAX_CIPHERTEXT_SIZE  == 16640);
    assert(MAX_CIPHERTEXT_SIZE - MAX_PLAINTEXT_SIZE == 256);
}

@main
public fn main() -> Int {
    build_appends_type_then_padding();
    parse_recovers_type_and_content();
    parse_with_zero_padding_recovers_type_at_tail();
    parse_with_large_padding_still_finds_type();
    parse_all_zeros_fails_no_content_type();
    parse_invalid_inner_type_is_fatal();
    record_size_constants_match_rfc();
    print("RFC 8446 §5.2 TLSInnerPlaintext build + parse verified");
    0
}
