// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, hrr, random_sentinel, rfc8446_4_1_3
// @timeout: 15000
// @expected-exit: 0

// RFC 8446 §4.1.3 — HelloRetryRequest is structurally a ServerHello
// with a fixed sentinel 32-byte `random` value:
//
//   CF 21 AD 74 E5 9A 61 11 BE 1D 8C 02 1E 65 B8 91
//   C2 A2 11 16 7A BB 8C 5E 07 9E 09 E2 C8 A8 33 9C
//
// This is the SHA-256 hash of the ASCII string
// "HelloRetryRequest" with a trailing null byte
// (per RFC 8446 §4.1.3 para 3). Clients detect HRR by byte-exact
// comparison; servers MUST emit this exact value.

mount core.*;
mount core.collections.List;
mount core.net.tls13.handshake.messages.{HRR_RANDOM};

fn hrr_random_length_is_32() {
    // Sized exactly like ServerHello.random so a swap-in works.
    let mut i: Int = 0;
    while i < 32 { let _b = HRR_RANDOM[i]; i = i + 1; }
}

fn hrr_random_byte_exact() {
    let expected: [Byte; 32] = [
        0xCF_u8, 0x21_u8, 0xAD_u8, 0x74_u8, 0xE5_u8, 0x9A_u8, 0x61_u8, 0x11_u8,
        0xBE_u8, 0x1D_u8, 0x8C_u8, 0x02_u8, 0x1E_u8, 0x65_u8, 0xB8_u8, 0x91_u8,
        0xC2_u8, 0xA2_u8, 0x11_u8, 0x16_u8, 0x7A_u8, 0xBB_u8, 0x8C_u8, 0x5E_u8,
        0x07_u8, 0x9E_u8, 0x09_u8, 0xE2_u8, 0xC8_u8, 0xA8_u8, 0x33_u8, 0x9C_u8,
    ];
    let mut i: Int = 0;
    while i < 32 {
        assert(HRR_RANDOM[i] == expected[i]);
        i = i + 1;
    }
}

fn hrr_random_first_eight_anchor() {
    // Pin the first 8 bytes explicitly — servers that botch the random
    // value fail detection at this point.
    assert(HRR_RANDOM[0] == 0xCF_u8);
    assert(HRR_RANDOM[1] == 0x21_u8);
    assert(HRR_RANDOM[2] == 0xAD_u8);
    assert(HRR_RANDOM[3] == 0x74_u8);
    assert(HRR_RANDOM[4] == 0xE5_u8);
    assert(HRR_RANDOM[5] == 0x9A_u8);
    assert(HRR_RANDOM[6] == 0x61_u8);
    assert(HRR_RANDOM[7] == 0x11_u8);
}

fn hrr_random_last_eight_anchor() {
    assert(HRR_RANDOM[24] == 0xC8_u8);
    assert(HRR_RANDOM[25] == 0xA8_u8);
    assert(HRR_RANDOM[26] == 0x33_u8);
    assert(HRR_RANDOM[27] == 0x9C_u8);
    // Actually the last 4 — the full sentinel ends at index 31 (0x9C).
    assert(HRR_RANDOM[31] == 0x9C_u8);
}

fn hrr_random_is_not_all_zeros() {
    // Sanity: a fresh random-init would be all-zero; the sentinel must
    // NOT collide with that.
    let mut any_nonzero = false;
    let mut i: Int = 0;
    while i < 32 {
        if HRR_RANDOM[i] != 0_u8 { any_nonzero = true; }
        i = i + 1;
    }
    assert(any_nonzero);
}

@main
public fn main() -> Int {
    hrr_random_length_is_32();
    hrr_random_byte_exact();
    hrr_random_first_eight_anchor();
    hrr_random_last_eight_anchor();
    hrr_random_is_not_all_zeros();
    print("RFC 8446 §4.1.3 HRR_RANDOM sentinel byte-exact verified");
    0
}
