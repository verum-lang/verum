// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, rfc8446, post-handshake-auth, extension, typecheck
// @timeout: 10000
// @expect: pass
//
// RFC 8446 §4.6.2 — Post-Handshake Authentication.
//
//   1. Client advertises `post_handshake_auth` (extension 49, zero
//      body) in its ClientHello.
//   2. Server MAY, at any point in the connection, send a
//      CertificateRequest as a post-handshake message.
//   3. Client responds with Certificate + CertificateVerify + Finished,
//      computed against a transcript that includes the CR.
//
// Regression coverage added in this commit:
//   * `Extension.PostHandshakeAuthExt` variant (encode + decode).
//   * `ClientSm.on_post_handshake` now returns a `PostHandshakeOutcome`
//     discriminator — `CertificateRequestReceived(cr)` is surfaced
//     so callers can drive the app-level response flow.
//
// Full §4.6.2 client-side response assembly (cert chain + signature)
// lives in the application layer because it requires a client
// identity this library doesn't otherwise own — covered by the
// outcome surfacing here but not by a generated reply.

mount core.net.tls13.handshake.extension.{
    Extension, ExtensionContext, EXT_POST_HANDSHAKE_AUTH,
    encode_extension, decode_extension,
};
mount core.net.tls13.handshake.codec.{Reader};
mount core.net.tls13.handshake.client_sm.{PostHandshakeOutcome};
mount core.collections.List;

fn check_extension_roundtrip() {
    // Encode → decode roundtrip for the zero-body extension.
    let mut wire: List<Byte> = [];
    let _ = encode_extension(&Extension.PostHandshakeAuthExt, &mut wire);
    assert(wire.len() == 4);  // 2-byte type + 2-byte length

    // Wire layout: 0x00 0x31 0x00 0x00 (big-endian).
    assert(wire[0] == 0x00_u8);
    assert(wire[1] == 0x31_u8);   // type 49
    assert(wire[2] == 0x00_u8);
    assert(wire[3] == 0x00_u8);   // length 0

    // Decode — context is ClientHelloCtx (client-issued).
    let mut r = Reader.new(wire.as_slice());
    let decoded = decode_extension(&mut r, ExtensionContext.ClientHelloCtx);
    match decoded {
        Ok(ext) => {
            match ext {
                Extension.PostHandshakeAuthExt => {},
                _ => panic("expected PostHandshakeAuthExt"),
            }
        },
        Err(_) => panic("decode failed"),
    }
}

fn check_extension_id_constant() {
    // RFC 8446 §4.6.2 pins the extension type at 49.
    assert(EXT_POST_HANDSHAKE_AUTH == 49_u16);
}

fn check_outcome_variants() {
    // Pin the enum surface so callers routing post-handshake records
    // can dispatch on the variants returned by `on_post_handshake`.
    let _ = PostHandshakeOutcome.Ignored;
}

fn main() {
    check_extension_roundtrip();
    check_extension_id_constant();
    check_outcome_variants();
}
