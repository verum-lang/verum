// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, rfc8446, resumption, psk, early-data, typecheck
// @timeout: 10000
// @expect: pass

mount core.net.tls13.handshake.{
    PskIdentity, OfferedPsks, BinderFlavor,
    ClientSession, SessionTicketKey, ServerTicketPlaintext,
    ClientSessionStore, TicketError,
    EarlyKeys, EarlyDataBudget,
    compute_binder, verify_binder, obfuscated_ticket_age,
    issue_ticket, decrypt_ticket, session_from_new_ticket,
    early_secret_from_psk,
};
mount core.net.tls13.handshake.early_data.{
    derive as early_derive,
    to_traffic_keys as early_to_traffic_keys,
};
mount core.net.tls13.cipher_suite.{CipherSuite, HashKind};
mount core.net.tls13.keyschedule.schedule.{EarlySecret, SecretBytes};
mount core.time.instant.{Instant};

fn check_ticket_roundtrip() -> Result<(), TicketError> {
    let stek = SessionTicketKey.generate();
    let rs_arr: [Byte; 32] = [0_u8; 32];
    let alpn_bytes: &[Byte] = b"h3";
    let pt = ServerTicketPlaintext {
        cipher_suite:        CipherSuite.TlsAes128GcmSha256,
        resumption_secret:   List.from_slice(&rs_arr[..]),
        max_early_data_size: 16384_u32,
        issued_at_unix:      1_700_000_000_u64,
        alpn:                List.from_slice(alpn_bytes),
    };
    let wire = issue_ticket(&stek, &pt)?;
    let recovered = decrypt_ticket(&stek, wire.as_slice())?;
    let _ = recovered;
    Ok(())
}

fn check_client_store() {
    let mut store = ClientSessionStore.new(16);
    let now = Instant.now();
    let ticket_bytes: &[Byte] = b"opaque-ticket";
    let nonce_bytes: &[Byte] = b"\x00\x01";
    let rm_arr: [Byte; 32] = [0_u8; 32];
    let authority: Text = "api.example.com";
    let sess = session_from_new_ticket(
        /* ticket */      List.from_slice(ticket_bytes),
        /* nonce */       List.from_slice(nonce_bytes),
        /* age_add */     12345_u32,
        /* lifetime */    604_800_u32,
        /* suite */       CipherSuite.TlsAes128GcmSha256,
        /* resumption */  List.from_slice(&rm_arr[..]),
        /* max_early */   16384_u32,
        /* now */         now.clone(),
    );
    store.insert(authority.clone(), sess);
    let _ = store.take(&authority, now);
    let _ = store.len();
}

fn check_binder() -> Result<(), core.security.kdf.hkdf.HkdfError> {
    let hash = HashKind.Sha256;
    let early_secret = EarlySecret.derive_with_psk(hash.clone(), &[0_u8; 32])?;
    let bk = early_secret.binder_key(false)?;    // "res binder"
    let transcript_hash: [Byte; 32] = [0_u8; 32];
    let _ = compute_binder(hash.clone(), &bk, &transcript_hash)?;
    let _ = verify_binder(hash, &bk, &transcript_hash, &[0_u8; 32])?;
    Ok(())
}

fn check_early_data_budget() {
    let mut budget = EarlyDataBudget.new(16384_u32);
    let _ = budget.try_consume(4096_u32);
    let _ = budget.remaining();
    let _ = budget.exceeded();
}

fn check_early_keys() -> Result<(), core.security.kdf.hkdf.HkdfError> {
    let early_secret = early_secret_from_psk(CipherSuite.TlsAes128GcmSha256, &[0_u8; 32])?;
    let transcript: [Byte; 32] = [0_u8; 32];
    let early_keys = early_derive(&early_secret, CipherSuite.TlsAes128GcmSha256, &transcript)?;
    let _ = early_to_traffic_keys(&early_keys)?;
    Ok(())
}

fn main() {
    let _ = check_ticket_roundtrip();
    check_client_store();
    let _ = check_binder();
    check_early_data_budget();
    let _ = check_early_keys();
    let _ = obfuscated_ticket_age(1000_u64, 42_u32);
}
