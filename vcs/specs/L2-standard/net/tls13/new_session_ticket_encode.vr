// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, handshake, new_session_ticket, encode, rfc8446_4_6_1
// @timeout: 15000
// @expected-exit: 0

// RFC 8446 §4.6.1 NewSessionTicket handshake body:
//
//   struct {
//       uint32 ticket_lifetime;
//       uint32 ticket_age_add;
//       opaque ticket_nonce<0..255>;
//       opaque ticket<1..2^16-1>;
//       Extension extensions<0..2^16-2>;
//   } NewSessionTicket;
//
// Wrapped as Handshake{type=4, length=body_len, body}.

mount core.*;
mount core.collections.List;
mount core.net.tls13.handshake.messages.{
    HandshakeMessage, NewSessionTicket, encode_handshake,
    HST_NEW_SESSION_TICKET,
};

fn minimum_nst_shape() {
    // Empty nonce + empty ticket + no extensions → smallest NST body.
    let nst = NewSessionTicket {
        ticket_lifetime: 0_u32,
        ticket_age_add:  0_u32,
        ticket_nonce:    [],
        ticket:          [],
        extensions:      [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.NewSessionTicketMsg(nst), &mut out).unwrap();
    // Header 4 + lifetime 4 + age_add 4 + nonce_u8_len 1 + ticket_u16_len 2
    //   + extensions_u16_len 2 = 17.
    assert(out.len() == 17);
    assert(out[0] == HST_NEW_SESSION_TICKET);      // 4
    // body length = 13.
    assert(out[1] == 0x00_u8 && out[2] == 0x00_u8 && out[3] == 0x0D_u8);
    // Both big-endian u32s = 0.
    assert(out[4]  == 0x00_u8 && out[5]  == 0x00_u8 && out[6]  == 0x00_u8 && out[7] == 0x00_u8);
    assert(out[8]  == 0x00_u8 && out[9]  == 0x00_u8 && out[10] == 0x00_u8 && out[11] == 0x00_u8);
    assert(out[12] == 0x00_u8);                     // nonce len
    assert(out[13] == 0x00_u8 && out[14] == 0x00_u8);   // ticket len
    assert(out[15] == 0x00_u8 && out[16] == 0x00_u8);   // extensions len
}

fn lifetime_and_age_add_big_endian() {
    let nst = NewSessionTicket {
        ticket_lifetime: 0x11223344_u32,
        ticket_age_add:  0xDEADBEEF_u32,
        ticket_nonce:    [],
        ticket:          [],
        extensions:      [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.NewSessionTicketMsg(nst), &mut out).unwrap();
    // lifetime bytes [4..=7], age_add [8..=11].
    assert(out[4]  == 0x11_u8 && out[5]  == 0x22_u8 && out[6]  == 0x33_u8 && out[7]  == 0x44_u8);
    assert(out[8]  == 0xDE_u8 && out[9]  == 0xAD_u8 && out[10] == 0xBE_u8 && out[11] == 0xEF_u8);
}

fn nonce_and_ticket_appear_after_counters() {
    let nonce: List<Byte> = [0xAA_u8, 0xBB_u8];
    let ticket: List<Byte> = [0x01_u8, 0x02_u8, 0x03_u8, 0x04_u8];
    let nst = NewSessionTicket {
        ticket_lifetime: 0_u32,
        ticket_age_add:  0_u32,
        ticket_nonce:    nonce,
        ticket:          ticket,
        extensions:      [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.NewSessionTicketMsg(nst), &mut out).unwrap();
    // Layout after 12 prefix bytes (header+two u32s): nonce_len=2, 2 bytes,
    // ticket_u16_len=4, 4 bytes, extensions_u16_len=0.
    assert(out[12] == 0x02_u8);
    assert(out[13] == 0xAA_u8);
    assert(out[14] == 0xBB_u8);
    assert(out[15] == 0x00_u8 && out[16] == 0x04_u8);
    assert(out[17] == 0x01_u8);
    assert(out[20] == 0x04_u8);
    assert(out[21] == 0x00_u8 && out[22] == 0x00_u8);
}

fn nonce_max_255_bytes() {
    // opaque ticket_nonce<0..255> — u8 length prefix.
    let mut nonce: List<Byte> = [];
    let mut i: Int = 0;
    while i < 255 { nonce.push(i as Byte); i = i + 1; }
    let nst = NewSessionTicket {
        ticket_lifetime: 0_u32,
        ticket_age_add:  0_u32,
        ticket_nonce:    nonce,
        ticket:          [],
        extensions:      [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.NewSessionTicketMsg(nst), &mut out).unwrap();
    assert(out[12] == 0xFF_u8);    // 255
}

@main
public fn main() -> Int {
    minimum_nst_shape();
    lifetime_and_age_add_big_endian();
    nonce_and_ticket_appear_after_counters();
    nonce_max_255_bytes();
    print("RFC 8446 §4.6.1 NewSessionTicket wire encode verified");
    0
}
