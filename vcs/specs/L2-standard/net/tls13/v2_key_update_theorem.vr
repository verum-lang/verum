// @test: verify-pass
// @tier: 0
// @level: L2
// @tags: tls13, key_update, v2, smt, theorem, rfc8446_4_6_3
// @timeout: 15000
// @expect: pass

// V2 theorem (tls-quic.md §9): KeyUpdate rotation correctness.
//
// RFC 8446 §4.6.3 / §7.2:
//
//   application_traffic_secret_N+1 =
//       HKDF-Expand-Label(application_traffic_secret_N,
//                         "traffic upd", "", Hash.length)
//
// The rotation counter `N` must strictly increase by one on each
// sender-side KeyUpdate; the refinement guarantee is:
//
//   (i) `N+1 > N` (monotonic counter, never wraps u64 in any realistic
//       handshake — a KeyUpdate per AEAD record × 2^64 = 2^119 bytes
//       before overflow);
//
//   (ii) the per-direction rotation counters on the peer sides remain
//       invariantly linked: after the sender KeyUpdate, the sender
//       uses secret_{N+1} and the peer uses secret_N until it receives
//       the record with keys derived from secret_{N+1}; the peer must
//       then switch-in secret_{N+1} before it can open any record.
//
// These are refinement-level facts; the underlying HKDF collision
// resistance is the crypto assumption on HMAC-SHA-2 (spec §8.1).

mount core.*;

// (i) counter strictly increases by one
theorem key_update_counter_strictly_monotonic(n: UInt64)
    requires n < 18446744073709551614_u64   // leave one slot below u64::MAX
    ensures  n + 1_u64 > n
    ensures  (n + 1_u64) - n == 1_u64
{
    proof by auto
}

// (i') multi-step monotonicity: after k updates from generation n the
// generation is n + k, still strictly greater than n (for k > 0).
theorem key_update_multi_step_monotonic(n: UInt64, k: UInt64)
    requires k > 0_u64
    requires n < 18446744073709551615_u64 - k   // no overflow on n + k
    ensures  n + k > n
{
    proof by auto
}

// (ii) peer-side linked-rotation invariant:
// While the sender is on generation `s` and the peer is on generation
// `p`, the valid range is `p ≤ s ≤ p + 1` (the peer may lag by one
// generation while it is still draining records encrypted with the
// older key; it must switch-in the new key before the sender rotates
// a second time).
theorem sender_peer_generation_gap_at_most_one(
    sender_gen: UInt64,
    peer_gen:   UInt64,
)
    requires peer_gen <= sender_gen
    requires sender_gen <= peer_gen + 1_u64
    ensures  sender_gen - peer_gen <= 1_u64
{
    proof by auto
}

// (iii) record-sequence counter reset on rotation:
// After KeyUpdate the record-sequence counter MUST start at 0
// (RFC 8446 §5.3). The previous sequence counter is independent.
theorem record_seq_reset_to_zero_on_rotation(
    prev_seq: UInt64,
    new_seq:  UInt64,
)
    requires new_seq == 0_u64
    ensures  new_seq == 0_u64
    ensures  new_seq <= prev_seq || prev_seq == 0_u64
{
    proof by auto
}

fn main() {
    print("V2 KeyUpdate rotation — counter monotonicity + peer-gap + seq reset proved");
}
