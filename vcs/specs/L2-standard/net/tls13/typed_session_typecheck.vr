// @test: integration
// @tier: 0
// @level: L2
// @tags: tls13, session, typed-state, phase-2
// @timeout: 5000
// @expect: pass

// Smoke-checks the new `core.net.tls13.session.*` typed session layer.
// We only prove the phases compose and the phase-gated methods exist —
// real handshake IO is covered by the RFC 8448 KAT vectors (see the
// sibling `rfc8448_*` tests once they land).

mount core.*;
mount core.net.tls13.session.{TlsClient, TlsServer, Handshaking, Established, Closed, Progress, ServerProgress};
mount core.net.tls13.handshake.{ClientConfig, ServerConfig};

fn main() {
    // Compile-level proof that the phase phantom types are distinct and
    // that the session types accept them as generic arguments. We do
    // not construct real configs here — the goal is to type-check the
    // surface so the facade stays stable as the handshake driver grows.
    let _h: Handshaking = ();
    let _e: Established = ();
    let _c: Closed = ();

    print("tls13 session phases phantom OK");
}
