// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, extension, supported_groups, supported_versions, encode, rfc8446_4_2_1, rfc8446_4_2_7
// @timeout: 15000
// @expected-exit: 0

// RFC 8446 §4.2.7 supported_groups extension (NamedGroupList):
//   Extension 10 (u16) || outer u16 len || inner u16 len || group * N (u16 each)
//
// RFC 8446 §4.2.1 supported_versions extension — two carriers:
//
//   ClientHello:  Extension 43 || outer u16 len || inner u8 len ||
//                   ProtocolVersion * N  (N: 1..127)
//
//   ServerHello:  Extension 43 || outer u16 len || selected ProtocolVersion
//                   (no inner list)

mount core.*;
mount core.collections.List;
mount core.net.tls13.named_group.{NamedGroup};
mount core.net.tls13.version.{TLS_1_3, LEGACY_VERSION_TLS_1_2, ProtocolVersion};
mount core.net.tls13.handshake.extension.{
    Extension, encode_extension,
    EXT_SUPPORTED_GROUPS, EXT_SUPPORTED_VERSIONS,
};

fn supported_groups_single_x25519() {
    let ext = Extension.SupportedGroupsExt { groups: [NamedGroup.X25519] };
    let mut out: List<Byte> = [];
    encode_extension(&ext, &mut out).unwrap();
    // Layout: ext_type(2) + outer(2) + inner(2) + group(2) = 8.
    assert(out.len() == 8);
    assert(out[0] == 0x00_u8 && out[1] == 0x0A_u8);    // ext_type = 10
    assert(out[2] == 0x00_u8 && out[3] == 0x04_u8);    // outer = 4
    assert(out[4] == 0x00_u8 && out[5] == 0x02_u8);    // inner = 2
    assert(out[6] == 0x00_u8 && out[7] == 0x1D_u8);    // X25519 = 0x001D
}

fn supported_groups_four_groups_order_preserved() {
    let groups: List<NamedGroup> = [
        NamedGroup.X25519,
        NamedGroup.Secp256r1,
        NamedGroup.Secp384r1,
        NamedGroup.Secp521r1,
    ];
    let ext = Extension.SupportedGroupsExt { groups: groups };
    let mut out: List<Byte> = [];
    encode_extension(&ext, &mut out).unwrap();
    // inner = 4 * 2 = 8; outer = 10; total = 14.
    assert(out.len() == 14);
    assert(out[4] == 0x00_u8 && out[5] == 0x08_u8);    // inner = 8
    // Four 2-byte u16 group codes at [6..14].
    assert(out[6]  == 0x00_u8 && out[7]  == 0x1D_u8);  // X25519
    assert(out[8]  == 0x00_u8 && out[9]  == 0x17_u8);  // Secp256r1
    assert(out[10] == 0x00_u8 && out[11] == 0x18_u8);  // Secp384r1
    assert(out[12] == 0x00_u8 && out[13] == 0x19_u8);  // Secp521r1
}

fn supported_versions_client_single_tls13() {
    let ext = Extension.SupportedVersionsClient { versions: [TLS_1_3] };
    let mut out: List<Byte> = [];
    encode_extension(&ext, &mut out).unwrap();
    // ext_type(2) + outer(2) + inner_u8(1) + version(2) = 7.
    assert(out.len() == 7);
    assert(out[0] == 0x00_u8 && out[1] == 0x2B_u8);    // ext_type = 43
    assert(out[2] == 0x00_u8 && out[3] == 0x03_u8);    // outer = 3
    assert(out[4] == 0x02_u8);                         // inner u8 = 2
    assert(out[5] == 0x03_u8 && out[6] == 0x04_u8);    // TLS 1.3 = 0x0304
}

fn supported_versions_client_three_versions() {
    let v12: ProtocolVersion = LEGACY_VERSION_TLS_1_2;
    let v11: ProtocolVersion = ProtocolVersion { major: 0x03_u8, minor: 0x02_u8 };
    // Offer 1.3 first (preferred), then lie-back 1.2 for compatibility
    // scanning, then 1.1 to exercise a three-element list.
    let versions: List<ProtocolVersion> = [TLS_1_3, v12, v11];
    let ext = Extension.SupportedVersionsClient { versions: versions };
    let mut out: List<Byte> = [];
    encode_extension(&ext, &mut out).unwrap();
    // inner_u8 = 3*2 = 6; outer = 1 + 6 = 7; total = 4 + 7 = 11.
    assert(out.len() == 11);
    assert(out[4] == 0x06_u8);                         // inner u8 = 6
    assert(out[5] == 0x03_u8 && out[6] == 0x04_u8);    // TLS 1.3
    assert(out[7] == 0x03_u8 && out[8] == 0x03_u8);    // TLS 1.2
    assert(out[9] == 0x03_u8 && out[10] == 0x02_u8);   // TLS 1.1
}

fn supported_versions_server_byte_exact() {
    // Server carrier: selected ProtocolVersion, no inner list prefix.
    let ext = Extension.SupportedVersionsServer { selected: TLS_1_3 };
    let mut out: List<Byte> = [];
    encode_extension(&ext, &mut out).unwrap();
    // ext_type(2) + outer(2) + version(2) = 6.
    assert(out.len() == 6);
    assert(out[0] == 0x00_u8 && out[1] == 0x2B_u8);    // ext_type = 43
    assert(out[2] == 0x00_u8 && out[3] == 0x02_u8);    // outer = 2
    assert(out[4] == 0x03_u8 && out[5] == 0x04_u8);    // selected = TLS 1.3
}

@main
public fn main() -> Int {
    supported_groups_single_x25519();
    supported_groups_four_groups_order_preserved();
    supported_versions_client_single_tls13();
    supported_versions_client_three_versions();
    supported_versions_server_byte_exact();
    print("RFC 8446 §4.2.1 + §4.2.7 supported_groups / supported_versions encode verified");
    0
}
