// @test: unit
// @tier: 0
// @level: L2
// @tags: tls13, keyschedule, v1, rfc8446_7_1
// @timeout: 5000
// @expect: pass

// V1 theorem (spec §9): derive_secret(s, L, c) monotonicity over the
// label. Two different labels applied to the same (secret, context)
// MUST produce distinct output keys. We exercise this empirically
// against the SHA-256 and SHA-384 paths over the known label set used
// in RFC 8446 §7.1 key schedule.

mount core.*;
mount core.collections.List;
mount core.net.tls13.cipher_suite.{HashKind};
mount core.net.tls13.keyschedule.derive_secret.{
    derive_secret,
    LABEL_DERIVED,
};

fn bytes_eq(a: &[Byte], b: &[Byte]) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        if a[i] != b[i] { return false; }
        i = i + 1;
    }
    true
}

fn main() {
    // Arbitrary 32-byte input key — fixed so the test is deterministic.
    let secret: [Byte; 32] = [
        0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88,
        0x99, 0xAA, 0xBB, 0xCC, 0xDD, 0xEE, 0xFF, 0x00,
        0x01, 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08,
        0x09, 0x0A, 0x0B, 0x0C, 0x0D, 0x0E, 0x0F, 0x10,
    ];
    let empty: [Byte; 0] = [];

    // Two distinct labels from the TLS 1.3 key schedule.
    let label_a = b"c hs traffic";
    let label_b = b"s hs traffic";

    match derive_secret(HashKind.Sha256, &secret, label_a, &empty) {
        Ok(out_a) => match derive_secret(HashKind.Sha256, &secret, label_b, &empty) {
            Ok(out_b) => {
                if bytes_eq(out_a.as_slice(), out_b.as_slice()) {
                    panic("V1 violated: distinct labels produced identical secret");
                }
            },
            Err(_) => panic("derive_secret(label_b) failed"),
        },
        Err(_) => panic("derive_secret(label_a) failed"),
    }

    // Also sha384 path, plus a third label.
    let label_c = b"res master";
    match derive_secret(HashKind.Sha384, &secret, label_a, &empty) {
        Ok(out_a) => match derive_secret(HashKind.Sha384, &secret, label_c, &empty) {
            Ok(out_c) => {
                if bytes_eq(out_a.as_slice(), out_c.as_slice()) {
                    panic("V1 violated on sha384 path");
                }
            },
            Err(_) => panic("sha384 derive_secret failed"),
        },
        Err(_) => panic("sha384 derive_secret label_a failed"),
    }

    print("V1 derive_secret label-distinctness holds");
}
