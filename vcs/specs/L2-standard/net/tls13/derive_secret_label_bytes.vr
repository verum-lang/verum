// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, keyschedule, derive_secret, rfc8446_7_1, label_bytes
// @timeout: 15000
// @expected-exit: 0

// RFC 8446 §7.1 Derive-Secret label byte-content KAT. Every constant
// matches its ASCII spelling exactly — no accidental 0x20-vs-underscore
// confusion, no length drift.

mount core.*;
mount core.net.tls13.keyschedule.derive_secret.{
    LABEL_DERIVED,
    LABEL_EXT_BINDER, LABEL_RES_BINDER,
    LABEL_CLIENT_EARLY_TRAFFIC, LABEL_EARLY_EXPORTER_MASTER,
    LABEL_CLIENT_HS_TRAFFIC, LABEL_SERVER_HS_TRAFFIC,
    LABEL_CLIENT_AP_TRAFFIC, LABEL_SERVER_AP_TRAFFIC,
    LABEL_EXPORTER_MASTER, LABEL_RESUMPTION_MASTER,
    LABEL_TRAFFIC_UPD, LABEL_FINISHED,
    LABEL_KEY, LABEL_IV, LABEL_RESUMPTION,
};

fn derived_label() {
    // "derived" = 64 65 72 69 76 65 64
    assert(LABEL_DERIVED[0] == 0x64_u8);
    assert(LABEL_DERIVED[1] == 0x65_u8);
    assert(LABEL_DERIVED[2] == 0x72_u8);
    assert(LABEL_DERIVED[3] == 0x69_u8);
    assert(LABEL_DERIVED[4] == 0x76_u8);
    assert(LABEL_DERIVED[5] == 0x65_u8);
    assert(LABEL_DERIVED[6] == 0x64_u8);
}

fn hs_traffic_labels_differ_only_in_first_byte() {
    // "c hs traffic" vs "s hs traffic" differ only at index 0.
    assert(LABEL_CLIENT_HS_TRAFFIC[0] == 0x63_u8);   // 'c'
    assert(LABEL_SERVER_HS_TRAFFIC[0] == 0x73_u8);   // 's'
    let mut i: Int = 1;
    while i < 12 {
        assert(LABEL_CLIENT_HS_TRAFFIC[i] == LABEL_SERVER_HS_TRAFFIC[i]);
        i = i + 1;
    }
}

fn ap_traffic_labels_differ_only_in_first_byte() {
    assert(LABEL_CLIENT_AP_TRAFFIC[0] == 0x63_u8);
    assert(LABEL_SERVER_AP_TRAFFIC[0] == 0x73_u8);
    let mut i: Int = 1;
    while i < 12 {
        assert(LABEL_CLIENT_AP_TRAFFIC[i] == LABEL_SERVER_AP_TRAFFIC[i]);
        i = i + 1;
    }
}

fn short_labels() {
    assert(LABEL_KEY[0] == 0x6B_u8);                 // 'k'
    assert(LABEL_KEY[1] == 0x65_u8);                 // 'e'
    assert(LABEL_KEY[2] == 0x79_u8);                 // 'y'
    assert(LABEL_IV[0]  == 0x69_u8);                 // 'i'
    assert(LABEL_IV[1]  == 0x76_u8);                 // 'v'
}

fn finished_label() {
    // "finished"
    assert(LABEL_FINISHED[0] == 0x66_u8);            // 'f'
    assert(LABEL_FINISHED[7] == 0x64_u8);            // 'd'
}

fn traffic_upd_label() {
    // "traffic upd"
    assert(LABEL_TRAFFIC_UPD[0]  == 0x74_u8);        // 't'
    assert(LABEL_TRAFFIC_UPD[6]  == 0x63_u8);        // 'c'
    assert(LABEL_TRAFFIC_UPD[7]  == 0x20_u8);        // ' '
    assert(LABEL_TRAFFIC_UPD[10] == 0x64_u8);        // 'd'
}

fn resumption_labels_are_distinct() {
    // "resumption" vs "res master" — different length + content.
    // res_master is 10 bytes, resumption is 10 bytes; first 4 share
    // "res " BUT "resumption" at byte 3 is 'u' (0x75) whereas "res master"
    // at byte 3 is ' ' (0x20). That single byte differs.
    assert(LABEL_RESUMPTION[3]        == 0x75_u8);   // 'u'
    assert(LABEL_RESUMPTION_MASTER[3] == 0x20_u8);   // ' '
}

fn ext_and_res_binders_differ_only_at_first_byte() {
    // "ext binder" vs "res binder" differ only at bytes 0..2:
    //   "ext " = 0x65 0x78 0x74 0x20
    //   "res " = 0x72 0x65 0x73 0x20
    let mut i: Int = 4;
    while i < 10 {
        assert(LABEL_EXT_BINDER[i] == LABEL_RES_BINDER[i]);
        i = i + 1;
    }
}

@main
public fn main() -> Int {
    derived_label();
    hs_traffic_labels_differ_only_in_first_byte();
    ap_traffic_labels_differ_only_in_first_byte();
    short_labels();
    finished_label();
    traffic_upd_label();
    resumption_labels_are_distinct();
    ext_and_res_binders_differ_only_at_first_byte();
    print("RFC 8446 §7.1 Derive-Secret label byte-content verified");
    0
}
