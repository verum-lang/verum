// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tls13, handshake, server_hello, encode, rfc8446_4_1_3
// @timeout: 15000
// @expected-exit: 0

// RFC 8446 §4.1.3 ServerHello wire body:
//
//   ProtocolVersion legacy_version = 0x0303;       -- u16
//   Random random;                                   -- 32 bytes
//   opaque legacy_session_id_echo<0..32>;            -- u8 len-prefixed
//   CipherSuite cipher_suite;                        -- u16
//   uint8 legacy_compression_method = 0;             -- single byte (no length)
//   Extension extensions<6..2^16-1>;                 -- u16 len-prefixed
//
// Handshake wrap: type=2 (server_hello), u24 length.
//
// HelloRetryRequestMsg is structurally a ServerHello — encode_handshake
// wraps it with type=2 and the HRR_RANDOM sentinel in the random field.

mount core.*;
mount core.collections.List;
mount core.net.tls13.cipher_suite.{CipherSuite};
mount core.net.tls13.version.{LEGACY_VERSION_TLS_1_2};
mount core.net.tls13.handshake.messages.{
    HandshakeMessage, ServerHello, encode_handshake,
    HST_SERVER_HELLO, HRR_RANDOM,
};

fn minimum_server_hello_byte_exact() {
    let mut random: [Byte; 32] = [0_u8; 32];
    let mut i: Int = 0;
    while i < 32 { random[i] = 0x55_u8; i = i + 1; }
    let sh = ServerHello {
        legacy_version:             LEGACY_VERSION_TLS_1_2,
        random:                     random,
        legacy_session_id_echo:     [],
        cipher_suite:               CipherSuite.TlsAes128GcmSha256,
        legacy_compression_method:  0_u8,
        extensions:                 [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.ServerHelloMsg(sh), &mut out).unwrap();
    // Body = 2 + 32 + 1 + 2 + 1 + 2 = 40.
    // Wrap = 4 + 40 = 44.
    assert(out.len() == 44);
    assert(out[0] == HST_SERVER_HELLO);         // type = 2
    assert(out[1] == 0x00_u8);
    assert(out[2] == 0x00_u8);
    assert(out[3] == 0x28_u8);                  // body length = 40
    // legacy_version = 0x0303.
    assert(out[4] == 0x03_u8 && out[5] == 0x03_u8);
    // 32 random bytes all 0x55.
    let mut j: Int = 0;
    while j < 32 { assert(out[6 + j] == 0x55_u8); j = j + 1; }
    // session_id_echo len = 0.
    assert(out[38] == 0x00_u8);
    // cipher_suite = 0x1301.
    assert(out[39] == 0x13_u8 && out[40] == 0x01_u8);
    // compression = 0.
    assert(out[41] == 0x00_u8);
    // extensions block empty u16.
    assert(out[42] == 0x00_u8 && out[43] == 0x00_u8);
}

fn server_hello_echo_session_id() {
    let random: [Byte; 32] = [0_u8; 32];
    let sh = ServerHello {
        legacy_version:             LEGACY_VERSION_TLS_1_2,
        random:                     random,
        legacy_session_id_echo:     [0xDE_u8, 0xAD_u8, 0xBE_u8, 0xEF_u8],
        cipher_suite:               CipherSuite.TlsChaCha20Poly1305Sha256,
        legacy_compression_method:  0_u8,
        extensions:                 [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.ServerHelloMsg(sh), &mut out).unwrap();
    // sess_id_echo len byte at 38, 4 bytes follow, then cipher_suite.
    assert(out[38] == 0x04_u8);
    assert(out[39] == 0xDE_u8);
    assert(out[40] == 0xAD_u8);
    assert(out[41] == 0xBE_u8);
    assert(out[42] == 0xEF_u8);
    // cipher_suite TlsChaCha20Poly1305Sha256 = 0x1303 at 43..45.
    assert(out[43] == 0x13_u8 && out[44] == 0x03_u8);
}

fn hello_retry_request_uses_hrr_sentinel() {
    // HRR is structurally a ServerHello with HRR_RANDOM in the random
    // field. The encode path wraps both as handshake type 2.
    let mut random: [Byte; 32] = [0_u8; 32];
    let mut i: Int = 0;
    while i < 32 { random[i] = HRR_RANDOM[i]; i = i + 1; }
    let sh = ServerHello {
        legacy_version:             LEGACY_VERSION_TLS_1_2,
        random:                     random,
        legacy_session_id_echo:     [],
        cipher_suite:               CipherSuite.TlsAes128GcmSha256,
        legacy_compression_method:  0_u8,
        extensions:                 [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.HelloRetryRequestMsg(sh), &mut out).unwrap();
    // Outer type still HST_SERVER_HELLO (2) per §4.1.3.
    assert(out[0] == HST_SERVER_HELLO);
    // Random field at offset 6..38 = HRR sentinel.
    let mut j: Int = 0;
    while j < 32 {
        assert(out[6 + j] == HRR_RANDOM[j]);
        j = j + 1;
    }
}

fn cipher_suite_in_server_hello_selects_256_gcm() {
    let random: [Byte; 32] = [0_u8; 32];
    let sh = ServerHello {
        legacy_version:             LEGACY_VERSION_TLS_1_2,
        random:                     random,
        legacy_session_id_echo:     [],
        cipher_suite:               CipherSuite.TlsAes256GcmSha384,
        legacy_compression_method:  0_u8,
        extensions:                 [],
    };
    let mut out: List<Byte> = [];
    encode_handshake(&HandshakeMessage.ServerHelloMsg(sh), &mut out).unwrap();
    // TlsAes256GcmSha384 = 0x1302.
    assert(out[39] == 0x13_u8 && out[40] == 0x02_u8);
}

@main
public fn main() -> Int {
    minimum_server_hello_byte_exact();
    server_hello_echo_session_id();
    hello_retry_request_uses_hrr_sentinel();
    cipher_suite_in_server_hello_selects_256_gcm();
    print("RFC 8446 §4.1.3 ServerHello encode byte-exact verified");
    0
}
