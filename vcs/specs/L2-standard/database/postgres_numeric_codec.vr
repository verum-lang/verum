// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: database, postgres, spindle, codec, numeric, tsvector
// @timeout: 30000
//
// Type-check exercise for the PG NUMERIC + tsvector binary codecs.
// Validates that:
//
//   * `decode_numeric(&ArenaSlice) -> Result<PgNumeric, DbError>` is
//     callable with the canonical signature.
//   * `PgNumeric.to_text(&self) -> Text` produces a Text value.
//   * `PgNumeric.{is_nan,is_pos_inf,is_neg_inf,is_negative,is_zero}`
//     return Bool.
//   * `encode_numeric_from_int(buf, arena, i64) -> Bool` is callable.
//   * `PG_NUMERIC_{POS,NEG,NAN,PINF,NINF}` constants visible.
//   * `supports_binary(PG_TYPE_NUMERIC)` returns true.
//   * `decode_tsvector(&ArenaSlice) -> Result<PgTsVector, DbError>` is
//     callable; `PgTsLexeme` + `PgTsPosition` shapes line up.
//   * `PG_TS_WEIGHT_{D,C,B,A}` constants visible.
//   * `supports_binary(PG_TYPE_TSVECTOR)` returns true.

mount core.*;
mount collections.List;
mount core.database.common.error.DbError;
mount core.database.common.types.{ArenaSlice, ArenaWireBuf};
mount core.database.common.arena.SpindleArena;
mount core.database.postgres.wire.codec.{
    PgNumeric,
    decode_numeric,
    encode_numeric_from_int,
    supports_binary,
    PG_TYPE_NUMERIC, PG_TYPE_TSVECTOR,
    PG_NUMERIC_POS, PG_NUMERIC_NEG,
    PG_NUMERIC_NAN, PG_NUMERIC_PINF, PG_NUMERIC_NINF,
    PgTsVector, PgTsLexeme, PgTsPosition,
    decode_tsvector,
    PG_TS_WEIGHT_D, PG_TS_WEIGHT_C, PG_TS_WEIGHT_B, PG_TS_WEIGHT_A,
};

fn check_decode_signature(slice: &ArenaSlice) -> Result<PgNumeric, DbError> {
    decode_numeric(slice)
}

fn check_text_render(n: &PgNumeric) -> Text {
    n.to_text()
}

fn check_predicates(n: &PgNumeric) -> Bool {
    n.is_nan()
        || n.is_pos_inf()
        || n.is_neg_inf()
        || n.is_negative()
        || n.is_zero()
}

fn check_encode(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, value: Int) -> Bool {
    encode_numeric_from_int(buf, arena, value)
}

fn check_decode_tsvector(slice: &ArenaSlice) -> Result<PgTsVector, DbError> {
    decode_tsvector(slice)
}

fn check_lexeme_shape(lex: &PgTsLexeme) -> Int {
    lex.positions.len()
}

fn check_position_shape(p: &PgTsPosition) -> Int {
    p.position + p.weight
}

fn check_constants() {
    assert(PG_NUMERIC_POS  == 0x0000);
    assert(PG_NUMERIC_NEG  == 0x4000);
    assert(PG_NUMERIC_NAN  == 0xC000);
    assert(PG_NUMERIC_PINF == 0xD000);
    assert(PG_NUMERIC_NINF == 0xF000);
    assert(supports_binary(PG_TYPE_NUMERIC));

    assert(PG_TS_WEIGHT_D == 0);
    assert(PG_TS_WEIGHT_C == 1);
    assert(PG_TS_WEIGHT_B == 2);
    assert(PG_TS_WEIGHT_A == 3);
    assert(supports_binary(PG_TYPE_TSVECTOR));
}

fn main() {
    check_constants();
}
