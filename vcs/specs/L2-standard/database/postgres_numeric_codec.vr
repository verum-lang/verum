// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: database, postgres, spindle, codec, numeric, tsvector, composite
// @timeout: 30000
//
// Type-check exercise for the PG NUMERIC + tsvector + composite
// binary codecs (last three deferred types in postgres/wire/codec.vr,
// all shipped 2026-05-04).  Validates the full type contract of:
//
//   * `decode_numeric(&ArenaSlice) -> Result<PgNumeric, DbError>` +
//     `PgNumeric.to_text(&self) -> Text` + predicates +
//     `encode_numeric_from_int(buf, arena, i64) -> Bool` +
//     `PG_NUMERIC_{POS,NEG,NAN,PINF,NINF}` constants +
//     `supports_binary(PG_TYPE_NUMERIC)`.
//   * `decode_tsvector(&ArenaSlice) -> Result<PgTsVector, DbError>` +
//     `PgTsLexeme` / `PgTsPosition` shapes + `PG_TS_WEIGHT_{D,C,B,A}` +
//     `supports_binary(PG_TYPE_TSVECTOR)`.
//   * `decode_composite(&ArenaSlice) -> Result<PgComposite, DbError>` +
//     `encode_composite(buf, arena, fields) -> Bool` +
//     `PgCompositeField` shape + `supports_binary(PG_TYPE_RECORD)`.

mount core.*;
mount collections.List;
mount core.database.common.error.DbError;
mount core.database.common.types.{ArenaSlice, ArenaWireBuf};
mount core.database.common.arena.SpindleArena;
mount core.database.postgres.wire.codec.{
    PgNumeric,
    decode_numeric,
    encode_numeric_from_int,
    supports_binary,
    PG_TYPE_NUMERIC, PG_TYPE_TSVECTOR, PG_TYPE_RECORD,
    PG_NUMERIC_POS, PG_NUMERIC_NEG,
    PG_NUMERIC_NAN, PG_NUMERIC_PINF, PG_NUMERIC_NINF,
    PgTsVector, PgTsLexeme, PgTsPosition,
    decode_tsvector,
    PG_TS_WEIGHT_D, PG_TS_WEIGHT_C, PG_TS_WEIGHT_B, PG_TS_WEIGHT_A,
    PgComposite, PgCompositeField,
    decode_composite, encode_composite,
};

fn check_decode_signature(slice: &ArenaSlice) -> Result<PgNumeric, DbError> {
    decode_numeric(slice)
}

fn check_text_render(n: &PgNumeric) -> Text {
    n.to_text()
}

fn check_predicates(n: &PgNumeric) -> Bool {
    n.is_nan()
        || n.is_pos_inf()
        || n.is_neg_inf()
        || n.is_negative()
        || n.is_zero()
}

fn check_encode(buf: &mut ArenaWireBuf, arena: &mut SpindleArena, value: Int) -> Bool {
    encode_numeric_from_int(buf, arena, value)
}

fn check_decode_tsvector(slice: &ArenaSlice) -> Result<PgTsVector, DbError> {
    decode_tsvector(slice)
}

fn check_lexeme_shape(lex: &PgTsLexeme) -> Int {
    lex.positions.len()
}

fn check_position_shape(p: &PgTsPosition) -> Int {
    p.position + p.weight
}

fn check_decode_composite(slice: &ArenaSlice) -> Result<PgComposite, DbError> {
    decode_composite(slice)
}

fn check_composite_field_shape(f: &PgCompositeField) -> Int {
    f.type_oid
}

fn check_composite_field_count(c: &PgComposite) -> Int {
    c.field_count()
}

fn check_encode_composite(
    buf: &mut ArenaWireBuf,
    arena: &mut SpindleArena,
    fields: &List<PgCompositeField>,
) -> Bool {
    encode_composite(buf, arena, fields)
}

fn check_constants() {
    assert(PG_NUMERIC_POS  == 0x0000);
    assert(PG_NUMERIC_NEG  == 0x4000);
    assert(PG_NUMERIC_NAN  == 0xC000);
    assert(PG_NUMERIC_PINF == 0xD000);
    assert(PG_NUMERIC_NINF == 0xF000);
    assert(supports_binary(PG_TYPE_NUMERIC));

    assert(PG_TS_WEIGHT_D == 0);
    assert(PG_TS_WEIGHT_C == 1);
    assert(PG_TS_WEIGHT_B == 2);
    assert(PG_TS_WEIGHT_A == 3);
    assert(supports_binary(PG_TYPE_TSVECTOR));

    assert(PG_TYPE_RECORD == 2249);
    assert(supports_binary(PG_TYPE_RECORD));
}

fn main() {
    check_constants();
}
