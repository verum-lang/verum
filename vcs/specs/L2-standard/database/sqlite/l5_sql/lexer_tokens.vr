// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, sql, lexer, tokens
// @timeout: 15000
// @description: SQL lexer — keyword + identifier + literal + operator shape
//
// Spec: internal/specs/sqlite-native.md §12.1

mount core.*;
mount collections.List;
mount core.database.sqlite.native.l5_sql.{
    Token, Keyword, Operator, Punct, VariableKind, LexError,
    lex, lookup_keyword,
};

fn keyword_lookup_case_insensitive() {
    match lookup_keyword(&"SELECT".clone()) {
        Some(KwSelect) => {}, _ => panic("SELECT"),
    }
    match lookup_keyword(&"select".clone()) {
        Some(KwSelect) => {}, _ => panic("select lowercase"),
    }
    match lookup_keyword(&"SeLeCt".clone()) {
        Some(KwSelect) => {}, _ => panic("SeLeCt mixed"),
    }
    match lookup_keyword(&"BEGIN".clone()) {
        Some(KwBegin) => {}, _ => panic("BEGIN"),
    }
    match lookup_keyword(&"xyz".clone()) {
        None => {},
        Some(_) => panic("xyz should not be a keyword"),
    }
}

fn lex_simple_select_shape() {
    let src = "SELECT id FROM t".clone();
    let toks = match lex(&src) {
        Ok(ts) => ts,
        Err(_) => { panic("lex"); return; }
    };
    // Expected: TKeyword(KwSelect) TIdent("id") TKeyword(KwFrom) TIdent("t") TEof
    assert_eq(toks.len(), 5);
}

fn lex_string_literal_with_escape() {
    let src = "SELECT 'it''s fine'".clone();
    let toks = match lex(&src) {
        Ok(ts) => ts,
        Err(_) => { panic("lex"); return; }
    };
    assert_eq(toks.len(), 3);
    match toks[1] {
        TStringLit(_) => {},
        _ => panic("expected string literal"),
    }
}

fn lex_number_variants() {
    let src = "SELECT 42 3.14 1e10 0xFF".clone();
    let toks = match lex(&src) {
        Ok(ts) => ts,
        Err(_) => { panic("lex numbers"); return; }
    };
    // SELECT + 4 numbers + EOF
    assert_eq(toks.len(), 6);
    match toks[1] { TIntLit(i)   => { assert_eq(i as Int, 42); }, _ => panic("42"), }
    match toks[2] { TFloatLit(_) => {},                           _ => panic("3.14"), }
    match toks[3] { TFloatLit(_) => {},                           _ => panic("1e10"), }
    match toks[4] { TIntLit(i)   => { assert_eq(i as Int, 255); }, _ => panic("0xFF"), }
}

fn lex_operators_and_punct() {
    let src = "a=1 AND b<=2 OR c<>3".clone();
    let toks = match lex(&src) {
        Ok(ts) => ts,
        Err(_) => { panic("lex ops"); return; }
    };
    // a = 1 AND b <= 2 OR c <> 3 EOF — 11 tokens + eof = 12
    assert_eq(toks.len(), 12);
}

fn lex_variable_kinds() {
    let src = "? ?5 :name @x $y".clone();
    let toks = match lex(&src) {
        Ok(ts) => ts,
        Err(_) => { panic("lex vars"); return; }
    };
    assert_eq(toks.len(), 6);    // 5 vars + EOF
    match toks[0] { TVariable(VAnon)       => {}, _ => panic("anon"), }
    match toks[1] { TVariable(VIndexed(n)) => { assert_eq(n, 5); }, _ => panic("idx"), }
    match toks[2] { TVariable(VNamedColon(_))  => {}, _ => panic(":name"), }
    match toks[3] { TVariable(VNamedAt(_))     => {}, _ => panic("@x"), }
    match toks[4] { TVariable(VNamedDollar(_)) => {}, _ => panic("$y"), }
}

fn lex_comments_skipped() {
    let src = "SELECT -- line comment\n42 /* block */ 7".clone();
    let toks = match lex(&src) {
        Ok(ts) => ts,
        Err(_) => { panic("lex comments"); return; }
    };
    // SELECT 42 7 EOF
    assert_eq(toks.len(), 4);
}

fn lex_blob_literal() {
    let src = "X'DEADBEEF'".clone();
    let toks = match lex(&src) {
        Ok(ts) => ts,
        Err(_) => { panic("lex blob"); return; }
    };
    assert_eq(toks.len(), 2);
    match toks[0] {
        TBlobLit(bytes) => {
            assert_eq(bytes.len(), 4);
            assert_eq(bytes[0] as Int, 0xDE);
            assert_eq(bytes[3] as Int, 0xEF);
        }
        _ => panic("blob literal"),
    }
}

fn main() {
    keyword_lookup_case_insensitive();
    lex_simple_select_shape();
    lex_string_literal_with_escape();
    lex_number_variants();
    lex_operators_and_punct();
    lex_variable_kinds();
    lex_comments_skipped();
    lex_blob_literal();
    print("lexer_tokens typecheck ok");
}
