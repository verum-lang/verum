// @test: wip
// @tier: 0 | 3
// @level: L2
// @tags: sqlite, native, sql, parser, ast
// @timeout: 3000
// @expected-exit: 0
// @description: SQL parser — sanity check on SELECT variants. AST shape
//               assertions over classic forms: ordinary, DISTINCT, JOINs,
//               subquery, WITH-CTE.

mount core.database.sqlite.native.l5_sql.{parse, SqlStatement, SelectStmt};

@main
public async fn main() -> Result<(), Error> {
    // Simple SELECT:
    let stmt = parse("SELECT id, name FROM users WHERE id = 1")?;
    match stmt {
        SqlStatement.Select(s) => {
            assert!(s.order_by.is_none());
            assert!(s.limit.is_none());
        }
        _ => panic("expected Select"),
    }

    // DISTINCT + ORDER BY + LIMIT:
    let stmt = parse("SELECT DISTINCT name FROM users ORDER BY name DESC LIMIT 10")?;
    let s = stmt.as_select_or_panic();
    assert!(s.order_by.is_some());
    assert_eq(s.limit.unwrap().limit, 10);

    // WITH-CTE:
    let stmt = parse("WITH t AS (SELECT 1) SELECT * FROM t")?;
    let s = stmt.as_select_or_panic();
    assert!(s.with_clause.is_some());

    // Subquery in FROM:
    let stmt = parse("SELECT * FROM (SELECT id FROM x) AS sub")?;
    assert!(stmt.is_select());

    // INNER JOIN:
    let stmt = parse("SELECT a.x, b.y FROM a INNER JOIN b ON a.id = b.aid")?;
    assert!(stmt.is_select());

    Ok(())
}
