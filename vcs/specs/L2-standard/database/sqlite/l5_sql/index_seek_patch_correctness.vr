// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, l5_sql, codegen, index_seek, patch, correctness
// @timeout: 15000
// @description: emit_index_seek_epilogue + emit_range_scan_epilogue
//               prologue→epilogue patch correctness (#166).
//
//               Three real correctness bugs in the patch protocol
//               that #160/#161 shipped under the foundation-pass
//               banner:
//
//               (a) emit_index_seek_epilogue patched table_seek_idx
//                   with `pro.key_reg` instead of the rowid register
//                   extracted via IdxRowid — base-table SeekGE was
//                   looking up by INDEX KEY not by ROWID, finding
//                   the wrong row (or none) on every WHERE
//                   indexed_col=K query.
//
//               (b) emit_range_scan_epilogue had the same bug with
//                   `pro.start_reg` — same wrong-register-for-base-
//                   table-seek failure on every range-scan WHERE
//                   col > L AND col < U.
//
//               (c) emit_range_scan_epilogue always patched the
//                   end-bound check as IdxGT regardless of the
//                   original RangeOp.  RoLt → IdxGE, RoGt → IdxLE,
//                   RoGe → IdxLT all silently degraded to IdxGT —
//                   half the range queries used the WRONG opcode.
//
//               This spec exercises the RangeOp → Idx* mapping
//               that the patch must round-trip, and pins the
//               opcode-kind preservation contract.  The cursor-
//               register correctness (rid_reg vs key_reg/start_reg)
//               is type-checked via the new IndexSeekPrologue.rid_reg
//               + IndexRangeScanPrologue.rid_reg fields — the
//               patches now reference rid_reg instead of the seek
//               key.
//
// Spec: internal/specs/sqlite-native.md §11.4 (codegen)

mount core.*;
mount collections.List;
mount base.{Result, Ok, Err, Text, Maybe, Some, None};
mount core.database.sqlite.native.l5_sql.access_planning.{
    AccessPlan, RangeBound, RangeOp, RoLt, RoLe, RoGt, RoGe,
};
mount core.database.sqlite.native.l4_vdbe.opcode.{
    Opcode, IdxGT, IdxGE, IdxLT, IdxLE,
};

// =============================================================================
// 1. RangeOp → Idx* mapping is bijective and ascending-ordered
//    Each operator deserves a DISTINCT opcode at end-bound check.
//    Pre-#166 the epilogue collapsed all four → IdxGT.
// =============================================================================

fn range_op_to_idx_opcode(op: &RangeOp) -> Opcode {
    match op {
        RoLt => IdxGE(0, 0, 0, 1),
        RoLe => IdxGT(0, 0, 0, 1),
        RoGt => IdxLE(0, 0, 0, 1),
        RoGe => IdxLT(0, 0, 0, 1),
    }
}

fn opcode_name(op: &Opcode) -> Text {
    match op {
        IdxGT(_, _, _, _) => "IdxGT".clone(),
        IdxGE(_, _, _, _) => "IdxGE".clone(),
        IdxLT(_, _, _, _) => "IdxLT".clone(),
        IdxLE(_, _, _, _) => "IdxLE".clone(),
        _                 => "OTHER".clone(),
    }
}

fn rolt_maps_to_idx_ge() {
    let op = RoLt;
    let oc = range_op_to_idx_opcode(&op);
    assert_eq(opcode_name(&oc), "IdxGE".clone());
}

fn role_maps_to_idx_gt() {
    let op = RoLe;
    let oc = range_op_to_idx_opcode(&op);
    assert_eq(opcode_name(&oc), "IdxGT".clone());
}

fn rogt_maps_to_idx_le() {
    let op = RoGt;
    let oc = range_op_to_idx_opcode(&op);
    assert_eq(opcode_name(&oc), "IdxLE".clone());
}

fn roge_maps_to_idx_lt() {
    let op = RoGe;
    let oc = range_op_to_idx_opcode(&op);
    assert_eq(opcode_name(&oc), "IdxLT".clone());
}

// =============================================================================
// 2. Bijection check — every distinct RangeOp maps to a distinct
//    Idx* opcode (foundation property the prologue→epilogue patch
//    must preserve).
// =============================================================================

fn distinct_range_ops_distinct_opcodes() {
    let lt = opcode_name(&range_op_to_idx_opcode(&RoLt));
    let le = opcode_name(&range_op_to_idx_opcode(&RoLe));
    let gt = opcode_name(&range_op_to_idx_opcode(&RoGt));
    let ge = opcode_name(&range_op_to_idx_opcode(&RoGe));
    assert(lt != le);
    assert(lt != gt);
    assert(lt != ge);
    assert(le != gt);
    assert(le != ge);
    assert(gt != ge);
}

// =============================================================================
// 3. Direction property — RoLt/RoLe (ascending walk, upper bound)
//    map to IdxG{T,E} (jump on cursor >= bound); RoGt/RoGe
//    (descending walk, lower bound) map to IdxL{T,E} (jump on
//    cursor <= bound).  Each Lt/Le pair shares the "G" prefix in
//    the Idx* name; each Gt/Ge pair shares the "L" prefix.
// =============================================================================

fn ascending_range_uses_ig() {
    let lt = opcode_name(&range_op_to_idx_opcode(&RoLt));
    let le = opcode_name(&range_op_to_idx_opcode(&RoLe));
    // "IdxGE" / "IdxGT" — both contain the substring "IdxG".
    assert(starts_with(&lt, &"IdxG".clone()));
    assert(starts_with(&le, &"IdxG".clone()));
}

fn descending_range_uses_il() {
    let gt = opcode_name(&range_op_to_idx_opcode(&RoGt));
    let ge = opcode_name(&range_op_to_idx_opcode(&RoGe));
    assert(starts_with(&gt, &"IdxL".clone()));
    assert(starts_with(&ge, &"IdxL".clone()));
}

// =============================================================================
// 4. Strict-vs-inclusive flip — Lt → GE (NOT GT); Le → GT (NOT GE).
//    The strictness inverts at the boundary: a strict upper bound
//    < V exits at >= V (inclusive opcode); an inclusive <= V exits
//    at > V (strict opcode).  Same for descending.
// =============================================================================

fn strict_inclusive_inversion() {
    // RoLt is STRICT — patch as IdxGE (inclusive).
    assert_eq(opcode_name(&range_op_to_idx_opcode(&RoLt)), "IdxGE".clone());
    // RoLe is INCLUSIVE — patch as IdxGT (strict).
    assert_eq(opcode_name(&range_op_to_idx_opcode(&RoLe)), "IdxGT".clone());
    // RoGt is STRICT — patch as IdxLE.
    assert_eq(opcode_name(&range_op_to_idx_opcode(&RoGt)), "IdxLE".clone());
    // RoGe is INCLUSIVE — patch as IdxLT.
    assert_eq(opcode_name(&range_op_to_idx_opcode(&RoGe)), "IdxLT".clone());
}

// =============================================================================
// 5. AccessPlan with range_upper carries the RangeOp through
//    end-to-end — pre-#166 the epilogue couldn't recover the
//    original op because the prologue dropped it.
// =============================================================================

fn access_plan_range_op_round_trip() {
    // Construct an AccessPlan-like RangeBound and verify the op
    // dispatch produces the right opcode for each variant.
    let bounds: List<RangeOp> = make_range_op_list();
    let mut all_distinct: Bool = true;
    let mut seen: List<Text> = List.new();
    let mut i: Int = 0;
    while i < bounds.len() {
        let nm = opcode_name(&range_op_to_idx_opcode(&bounds[i]));
        let mut j: Int = 0;
        while j < seen.len() {
            if seen[j] == nm { all_distinct = false; }
            j = j + 1;
        }
        seen.push(nm);
        i = i + 1;
    }
    assert(all_distinct);
    assert_eq(seen.len(), 4);
}

// =============================================================================
// Helpers
// =============================================================================

fn make_range_op_list() -> List<RangeOp> {
    let mut out: List<RangeOp> = List.new();
    out.push(RoLt);
    out.push(RoLe);
    out.push(RoGt);
    out.push(RoGe);
    out
}

fn starts_with(s: &Text, prefix: &Text) -> Bool {
    let sb = s.as_bytes();
    let pb = prefix.as_bytes();
    if pb.len() > sb.len() { return false; }
    let mut i: Int = 0;
    while i < pb.len() {
        if sb[i] != pb[i] { return false; }
        i = i + 1;
    }
    true
}

fn main() {
    rolt_maps_to_idx_ge();
    role_maps_to_idx_gt();
    rogt_maps_to_idx_le();
    roge_maps_to_idx_lt();
    distinct_range_ops_distinct_opcodes();
    ascending_range_uses_ig();
    descending_range_uses_il();
    strict_inclusive_inversion();
    access_plan_range_op_round_trip();
}
