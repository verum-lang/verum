// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, file_control, fcntl, vfs, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.file_control.opcode.{
    FileCtrlOp,
    FcLockstate, FcPragma, FcSync, FcMmapSize,
    FcPersistWal, FcSizeHint, FcChunkSize, FcReserveBytes,
    FcDataVersion, FcUnknown,
    op_numeric, op_name, is_writable,
};
mount core.database.sqlite.native.file_control.request.{
    FileCtrlRequest, new_request, main_db_request,
};
mount core.database.sqlite.native.file_control.result.{
    FileCtrlResult,
    FrOk, FrNotFound, FrFailed,
    is_ok, should_cascade, result_code,
};
mount core.database.sqlite.native.errors.code.{
    extended_of, PcIoErr,
};
mount base.{Bool};

fn test_opcode_numeric_matches_header() {
    assert_eq(op_numeric(&FcLockstate), 1);
    assert_eq(op_numeric(&FcSizeHint), 5);
    assert_eq(op_numeric(&FcChunkSize), 6);
    assert_eq(op_numeric(&FcPragma), 14);
    assert_eq(op_numeric(&FcMmapSize), 18);
    assert_eq(op_numeric(&FcDataVersion), 36);
    assert_eq(op_numeric(&FcReserveBytes), 39);
    assert_eq(op_numeric(&FcUnknown(999)), 999);
}

fn test_op_name_mentions_fcntl() {
    assert(op_name(&FcPragma) == "SQLITE_FCNTL_PRAGMA".clone());
    assert(op_name(&FcSync) == "SQLITE_FCNTL_SYNC".clone());
}

fn test_is_writable_matches_doc() {
    assert(is_writable(&FcSizeHint));
    assert(is_writable(&FcChunkSize));
    assert(is_writable(&FcPersistWal));
    assert(!is_writable(&FcLockstate));
    assert(!is_writable(&FcPragma));
}

fn test_new_request_preserves_fields() {
    let r = new_request("main".clone(), FcSync, 0 as Int64);
    assert(r.schema_name == "main".clone());
    assert_eq(r.payload_ptr, 0 as Int64);
}

fn test_main_db_request_helper() {
    let r = main_db_request(FcMmapSize, 42 as Int64);
    assert(r.schema_name == "main".clone());
}

fn test_result_is_ok() {
    assert(is_ok(&FrOk));
    assert(!is_ok(&FrNotFound));
}

fn test_should_cascade_only_notfound() {
    assert(should_cascade(&FrNotFound));
    assert(!should_cascade(&FrOk));
}

fn test_result_code_mapping() {
    assert_eq(result_code(&FrOk), 0);
    assert_eq(result_code(&FrNotFound), 12);
    let failed: FileCtrlResult = FrFailed {
        code: extended_of(PcIoErr, 0),
        reason: "io".clone(),
    };
    assert(result_code(&failed) != 0);
}

fn main() {
    test_opcode_numeric_matches_header();
    test_op_name_mentions_fcntl();
    test_is_writable_matches_doc();
    test_new_request_preserves_fields();
    test_main_db_request_helper();
    test_result_is_ok();
    test_should_cascade_only_notfound();
    test_result_code_mapping();
}
