// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, where_loop_cost_model, planner
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.where_loop_cost_model.logest.{
    logest_zero, from_int, mul, div, add, is_cheaper_than, same_cost,
};
mount core.database.sqlite.native.where_loop_cost_model.loop_.{
    WhereLoop,
    new, total_cost, output_cardinality, dominates,
    free_scan_of, pick_cheaper,
};
mount base.{Bool, Int64};

fn test_logest_zero_and_from_int() {
    assert_eq(logest_zero(), 0);
    assert_eq(from_int0_i64, 0);
    assert_eq(from_int1_i64, 0);
    // from_int is monotone.
    let a = from_int10_i64;
    let b = from_int100_i64;
    let c = from_int1000_i64;
    assert(b > a);
    assert(c > b);
}

fn test_mul_and_div() {
    let a = from_int100_i64;
    let b = from_int10_i64;
    // mul is addition in log space
    let prod = mul(a, b);
    assert(prod > a);
    assert(prod > b);
    // div is inverse
    assert_eq(div(prod, b), a);
}

fn test_add_is_monotone() {
    let small = 10;
    let big   = 100;
    let sum   = add(small, big);
    // result >= max (big)
    assert(sum >= big);
    // far-apart costs collapse to the larger.
    let far = add(10, 200);
    assert_eq(far, 200);
}

fn test_compare_helpers() {
    assert(is_cheaper_than(5, 10));
    assert(!is_cheaper_than(10, 5));
    assert(same_cost(7, 7));
    assert(!same_cost(7, 8));
}

fn test_loop_total_cost() {
    let l = new(10, 5, from_int100_i64);
    let outer = from_int10_i64;
    let cost = total_cost(&l, outer);
    // cost = r_setup + outer*r_run (log-space add of setup and scaled run)
    assert(cost >= 10);
}

fn test_output_cardinality() {
    let l = new(0, 0, from_int50_i64);
    let outer = from_int100_i64;
    let card = output_cardinality(&l, outer);
    // multiplicative: outer + n_out in log-est
    assert(card > from_int100_i64);
}

fn test_dominates() {
    let cheap = new(5, 5, 5);
    let mid   = new(10, 10, 10);
    assert(dominates(&cheap, &mid));
    assert(!dominates(&mid, &cheap));
    // equal → neither dominates
    let same = new(10, 10, 10);
    assert(!dominates(&same, &mid));
}

fn test_free_scan() {
    let l = free_scan_of42_i64;
    assert_eq(l.r_setup, 0);
    assert_eq(l.r_run, 0);
    assert(l.n_out > 0);
}

fn test_pick_cheaper() {
    let expensive = new(100, 50, from_int10_i64);
    let cheap     = new(5,   1,  from_int10_i64);
    let outer     = from_int100_i64;
    let winner = pick_cheaper(expensive, cheap, outer);
    assert_eq(winner.r_setup, 5);
}

fn main() {
    test_logest_zero_and_from_int();
    test_mul_and_div();
    test_add_is_monotone();
    test_compare_helpers();
    test_loop_total_cost();
    test_output_cardinality();
    test_dominates();
    test_free_scan();
    test_pick_cheaper();
}
