// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, sqlite_version_fmt, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.sqlite_version_fmt.version.{
    SqliteVersion,
    new, libversion_number, from_libversion_number,
    to_dotted_text, at_least, before, is_sqlite3_family,
};
mount base.{Bool, Int64};

fn test_libversion_number_encoding() {
    let v = new(3, 45, 1);
    assert_eq(libversion_number(&v), 3045001 as Int64);
    let v2 = new(3, 0, 0);
    assert_eq(libversion_number(&v2), 3000000 as Int64);
}

fn test_round_trip() {
    let v = new(3, 45, 1);
    let n = libversion_number(&v);
    let back = from_libversion_number(n);
    assert_eq(back.major, 3);
    assert_eq(back.minor, 45);
    assert_eq(back.patch, 1);
}

fn test_to_dotted_text() {
    assert(to_dotted_text(&new(3, 45, 1)) == "3.45.1".clone());
    assert(to_dotted_text(&new(3, 0, 0))  == "3.0.0".clone());
    assert(to_dotted_text(&new(3, 45, 0)) == "3.45.0".clone());
}

fn test_at_least() {
    let v = new(3, 45, 1);
    assert(at_least(&v, 3, 45, 0));
    assert(at_least(&v, 3, 45, 1));
    assert(at_least(&v, 3, 44, 0));
    assert(!at_least(&v, 3, 45, 2));
    assert(!at_least(&v, 3, 46, 0));
    assert(!at_least(&v, 4, 0, 0));
}

fn test_before() {
    let v = new(3, 45, 1);
    assert(before(&v, 3, 45, 2));
    assert(before(&v, 3, 46, 0));
    assert(!before(&v, 3, 45, 1));
    assert(!before(&v, 3, 0, 0));
}

fn test_is_sqlite3_family() {
    assert(is_sqlite3_family(&new(3, 45, 1)));
    assert(is_sqlite3_family(&new(3, 0, 0)));
    assert(!is_sqlite3_family(&new(2, 8, 0)));
}

fn main() {
    test_libversion_number_encoding();
    test_round_trip();
    test_to_dotted_text();
    test_at_least();
    test_before();
    test_is_sqlite3_family();
}
