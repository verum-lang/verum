// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, l3_btree, comparator, seek, balance, foundation
// @timeout: 15000
// @description: L3 B-tree foundation — comparator, seek, balance-apply,
//               and btree_ops integration (#140 foundation).
//
// Spec: internal/specs/sqlite-native.md §10.3 .. §10.5
//
// Asserts the new B-tree surface composes:
//   1. Comparator primitives (cmp_int64, cmp_bytes) match expected
//      ordering semantics
//   2. Binary search on synthetic cell-key list returns the right
//      (index, ordering) pair
//   3. PageStore round-trips bytes
//   4. BalanceDecision dispatches through apply_balance_decision
//      without crashing for every variant

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.database.sqlite.native.l3_btree.{
    KkRowId, KkRecord,
    SeekKey, SkRowId, SkRecord,
    CellKey, CkRowId, CkRecord,
    cmp_int64, cmp_bytes, cmp_keys,
    BinarySearchResult, binary_search_cells,
    PageStore, page_store_new,
    PageBuf, page_buf,
    apply_balance_decision,
    RebalanceLog, RebalanceStep,
    BalanceContext, balance_context_new,
    BalanceDecision, NoChange, Split, Merge, Rotate, GrowRoot, ShrinkRoot,
};

// -----------------------------------------------------------------------------
// 1. Primitive comparators
// -----------------------------------------------------------------------------

fn cmp_int64_basics() {
    match cmp_int64(1_i64, 2_i64) {
        Less => {},
        _ => panic("expected 1 < 2"),
    }
    match cmp_int64(5_i64, 5_i64) {
        Equal => {},
        _ => panic("expected 5 == 5"),
    }
    match cmp_int64(9_i64, 3_i64) {
        Greater => {},
        _ => panic("expected 9 > 3"),
    }
}

fn cmp_bytes_basics() {
    let mut a: List<Byte> = List.new();
    a.push(0x01 as Byte);
    a.push(0x02 as Byte);
    let mut b: List<Byte> = List.new();
    b.push(0x01 as Byte);
    b.push(0x03 as Byte);
    match cmp_bytes(&a, &b) {
        Less => {},
        _ => panic("expected [01,02] < [01,03]"),
    }
    // Prefix comparison: shorter is less when prefixes match.
    let mut c: List<Byte> = List.new();
    c.push(0x01 as Byte);
    let mut d: List<Byte> = List.new();
    d.push(0x01 as Byte);
    d.push(0x00 as Byte);
    match cmp_bytes(&c, &d) {
        Less => {},
        _ => panic("expected [01] < [01,00] (shorter prefix)"),
    }
}

// -----------------------------------------------------------------------------
// 2. cmp_keys cross-shape error path
// -----------------------------------------------------------------------------

fn cmp_keys_kind_mismatch() {
    let target = SkRowId(42_i64);
    let cell = CkRecord(List.new());
    match cmp_keys(&target, &cell) {
        Err(_) => {},
        Ok(_) => panic("expected Err on rowid vs record mismatch"),
    }
}

// -----------------------------------------------------------------------------
// 3. PageStore install + fetch round-trip
// -----------------------------------------------------------------------------

fn page_store_round_trip() {
    let mut store = page_store_new();
    let mut bytes: List<Byte> = List.new();
    bytes.push(0xDE as Byte);
    bytes.push(0xAD as Byte);
    store.install(7, bytes);
    match store.fetch(7) {
        Some(b) => {
            assert_eq(b.len(), 2);
            assert_eq(b[0] as Int, 0xDE);
            assert_eq(b[1] as Int, 0xAD);
        }
        None => panic("expected Some bytes for page 7"),
    }
    match store.fetch(99) {
        None => {},
        Some(_) => panic("expected None for missing page"),
    }
}

// -----------------------------------------------------------------------------
// 4. apply_balance_decision dispatches every variant without crash
// -----------------------------------------------------------------------------

fn balance_apply_no_change() {
    let ctx = balance_context_new(4096, 0);
    let pages: List<PageBuf> = List.new();
    match apply_balance_decision(&NoChange, &pages, &ctx) {
        Ok(outcome) => {
            assert_eq(outcome.updated_pages.len(), 0);
            assert_eq(outcome.freed_pages.len(), 0);
        }
        Err(_) => panic("NoChange should never fail"),
    }
}

fn balance_apply_split() {
    let ctx = balance_context_new(4096, 0);
    let mut pages: List<PageBuf> = List.new();
    let mut bytes: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < 4096 { bytes.push(0 as Byte); i = i + 1; }
    pages.push(page_buf(2, bytes));
    let decision = Split(2, 5, 5, 5, 0);
    match apply_balance_decision(&decision, &pages, &ctx) {
        Ok(outcome) => {
            // Foundation: emits at least the donor; ripple is Some.
            assert(outcome.updated_pages.len() >= 1);
            match &outcome.ripple {
                Some(_) => {},
                None => panic("Split should produce a RippleHint"),
            }
        }
        Err(_) => panic("Split shape should apply cleanly"),
    }
}

fn balance_apply_merge() {
    let ctx = balance_context_new(4096, 0);
    let mut pages: List<PageBuf> = List.new();
    let mut bytes_l: List<Byte> = List.new();
    let mut bytes_r: List<Byte> = List.new();
    let mut i: Int = 0;
    while i < 4096 {
        bytes_l.push(0 as Byte);
        bytes_r.push(0 as Byte);
        i = i + 1;
    }
    pages.push(page_buf(2, bytes_l));
    pages.push(page_buf(3, bytes_r));
    let decision = Merge(2, 3, 0);
    match apply_balance_decision(&decision, &pages, &ctx) {
        Ok(outcome) => {
            assert_eq(outcome.freed_pages.len(), 1);
            assert_eq(outcome.freed_pages[0], 3);
        }
        Err(_) => panic("Merge shape should apply cleanly"),
    }
}

fn main() {
    cmp_int64_basics();
    cmp_bytes_basics();
    cmp_keys_kind_mismatch();
    page_store_round_trip();
    balance_apply_no_change();
    balance_apply_split();
    balance_apply_merge();
}
