// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, bind_blob_v2, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.bind_blob_v2.spec.{
    BindBlobSpec, BindApi, BaV1, BaV2,
    v1_spec, v2_spec, is_valid,
};
mount core.database.sqlite.native.bind_blob_v2.engine.{
    BindBlobEngine, new_engine,
};
mount core.database.sqlite.native.destructor_api.kind.{
    Destructor, DStatic, DTransient,
};
mount base.{Bool};

fn test_v1_valid() {
    let s = v1_spec(1024, DStatic);
    assert(is_valid(&s));
}

fn test_v2_accepts_large_size() {
    let big: Int64 = 4_000_000_000 as Int64;
    let s = v2_spec(big, DTransient);
    assert(is_valid(&s));
}

fn test_v1_rejects_above_int32_max() {
    let too_big: Int64 = 2_147_483_647_i64 + 1_i64;
    let s = BindBlobSpec {
        byte_len: too_big,
        destructor: DStatic,
        api: BaV1,
    };
    assert(!is_valid(&s));
}

fn test_negative_size_invalid() {
    let s = v2_spec(-1 as Int64, DStatic);
    assert(!is_valid(&s));
}

fn test_engine_bind_ok() {
    let mut e = new_engine(4);
    let r = e.sqlite3_bind_blob(2, v1_spec(256, DTransient));
    assert_eq(r, 0);
}

fn test_engine_bind_bad_index_is_range() {
    let mut e = new_engine(2);
    assert_eq(e.sqlite3_bind_blob(0, v1_spec(1, DStatic)), 25);
}

fn test_engine_bind_negative_size_is_misuse() {
    let mut e = new_engine(4);
    let r = e.sqlite3_bind_blob(1, v2_spec(-1 as Int64, DStatic));
    assert_eq(r, 21);   // SQLITE_MISUSE
    assert_eq(e.rejections, 1 as Int64);
}

fn test_engine_clear_zeroes_slot() {
    let mut e = new_engine(4);
    let _ = e.sqlite3_bind_blob(2, v1_spec(64, DTransient));
    assert(e.clear(2));
}

fn main() {
    test_v1_valid();
    test_v2_accepts_large_size();
    test_v1_rejects_above_int32_max();
    test_negative_size_invalid();
    test_engine_bind_ok();
    test_engine_bind_bad_index_is_range();
    test_engine_bind_negative_size_is_misuse();
    test_engine_clear_zeroes_slot();
}
