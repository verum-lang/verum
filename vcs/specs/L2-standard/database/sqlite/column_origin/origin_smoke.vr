// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, column_origin, metadata, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.column_origin.info.{
    ColumnOriginInfo,
    new_info, derived_expression, is_derived,
};
mount core.database.sqlite.native.column_origin.engine.{
    ColumnOriginTable, new_table,
};
mount base.{Bool};

fn test_new_info_flags() {
    let ci = new_info(
        "main".clone(), "users".clone(),
        "id".clone(), "INTEGER".clone(),
    );
    assert(!is_derived(&ci));
    assert(ci.database == "main".clone());
}

fn test_derived_expression_is_derived() {
    let ci = derived_expression();
    assert(is_derived(&ci));
}

fn test_table_returns_info_when_enabled() {
    let mut t = new_table(true);
    t.push(new_info("main".clone(), "users".clone(), "id".clone(), "INTEGER".clone()));
    assert(t.sqlite3_column_database_name(0) == "main".clone());
    assert(t.sqlite3_column_table_name(0) == "users".clone());
    assert(t.sqlite3_column_origin_name(0) == "id".clone());
    assert(t.sqlite3_column_decltype(0) == "INTEGER".clone());
}

fn test_table_returns_empty_when_disabled() {
    let mut t = new_table(false);
    t.push(new_info("main".clone(), "users".clone(), "id".clone(), "INTEGER".clone()));
    assert_eq(t.sqlite3_column_database_name(0).len(), 0);
    assert_eq(t.sqlite3_column_table_name(0).len(), 0);
    assert_eq(t.sqlite3_column_origin_name(0).len(), 0);
    assert_eq(t.sqlite3_column_decltype(0).len(), 0);
}

fn test_table_out_of_range_returns_empty() {
    let t = new_table(true);
    assert_eq(t.sqlite3_column_database_name(99).len(), 0);
    assert_eq(t.sqlite3_column_table_name(-1).len(), 0);
}

fn test_table_length() {
    let mut t = new_table(true);
    t.push(new_info("main".clone(), "t".clone(), "a".clone(), "INTEGER".clone()));
    t.push(new_info("main".clone(), "t".clone(), "b".clone(), "TEXT".clone()));
    assert_eq(t.len(), 2);
}

fn main() {
    test_new_info_flags();
    test_derived_expression_is_derived();
    test_table_returns_info_when_enabled();
    test_table_returns_empty_when_disabled();
    test_table_out_of_range_returns_empty();
    test_table_length();
}
