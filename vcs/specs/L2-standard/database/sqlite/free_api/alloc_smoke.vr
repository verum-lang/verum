// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, free_api, allocator, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.free_api.ptr.{
    OpaqueHandle, null_handle, new_handle, is_null,
};
mount core.database.sqlite.native.free_api.engine.{
    FreeEngine, new_engine,
};
mount base.{Bool};

fn test_null_handle_is_null() {
    let h = null_handle();
    assert(is_null(&h));
}

fn test_new_handle_nonzero_is_not_null() {
    let h = new_handle(1 as Int64, 64 as Int64);
    assert(!is_null(&h));
}

fn test_malloc_returns_fresh_id_and_tracks_bytes() {
    let mut e = new_engine();
    let h = e.sqlite3_malloc(128);
    assert(!is_null(&h));
    assert_eq(e.sqlite3_msize(&h), 128 as Int64);
    assert_eq(e.outstanding_bytes, 128 as Int64);
    assert_eq(e.mallocs, 1 as Int64);
}

fn test_malloc_zero_returns_null() {
    let mut e = new_engine();
    let h = e.sqlite3_malloc(0);
    assert(is_null(&h));
}

fn test_malloc_negative_returns_null() {
    let mut e = new_engine();
    let h = e.sqlite3_malloc(-1);
    assert(is_null(&h));
}

fn test_malloc64_accepts_large_sizes() {
    let mut e = new_engine();
    let big: Int64 = 1024 as Int64;
    let h = e.sqlite3_malloc64(big);
    assert(!is_null(&h));
    assert_eq(e.sqlite3_msize(&h), big);
}

fn test_free_shrinks_outstanding() {
    let mut e = new_engine();
    let h = e.sqlite3_malloc(64);
    e.sqlite3_free(&h);
    assert_eq(e.outstanding_bytes, 0 as Int64);
    assert_eq(e.frees, 1 as Int64);
}

fn test_free_null_is_noop() {
    let mut e = new_engine();
    let h = null_handle();
    e.sqlite3_free(&h);
    assert_eq(e.frees, 0 as Int64);
}

fn test_realloc_tracks_delta() {
    let mut e = new_engine();
    let h = e.sqlite3_malloc(32);
    let h2 = e.sqlite3_realloc(&h, 64);
    assert(!is_null(&h2));
    assert_eq(e.sqlite3_msize(&h2), 64 as Int64);
    assert_eq(e.outstanding_bytes, 64 as Int64);
    assert_eq(e.reallocs, 1 as Int64);
}

fn test_hard_limit_rejects_oversize() {
    let mut e = new_engine();
    e.set_hard_limit100_i64;
    let ok = e.sqlite3_malloc(80);
    assert(!is_null(&ok));
    let fail = e.sqlite3_malloc(40);
    assert(is_null(&fail));   // 80 + 40 > 100
}

fn test_realloc_zero_size_frees() {
    let mut e = new_engine();
    let h = e.sqlite3_malloc(32);
    let h2 = e.sqlite3_realloc(&h, 0);
    assert(is_null(&h2));
    assert_eq(e.outstanding_bytes, 0 as Int64);
}

fn main() {
    test_null_handle_is_null();
    test_new_handle_nonzero_is_not_null();
    test_malloc_returns_fresh_id_and_tracks_bytes();
    test_malloc_zero_returns_null();
    test_malloc_negative_returns_null();
    test_malloc64_accepts_large_sizes();
    test_free_shrinks_outstanding();
    test_free_null_is_noop();
    test_realloc_tracks_delta();
    test_hard_limit_rejects_oversize();
    test_realloc_zero_size_frees();
}
