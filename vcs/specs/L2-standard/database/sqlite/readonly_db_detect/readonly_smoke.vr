// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, readonly_db_detect, errors
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.readonly_db_detect.reason.{
    base_code,
    ReadonlyReason,
    RrBase, RrRecovery, RrCantLock, RrRollback, RrDbMoved, RrCantInit, RrDirectory,
    sub_code, extended_code, from_extended, reason_name,
    is_transient, is_corruption_hint, well_known_count,
};
mount base.{Bool, Maybe};

fn test_base_code() {
    assert_eq(base_code(), 8);
}

fn test_sub_codes_distinct() {
    assert_eq(sub_code(&RrBase),      0);
    assert_eq(sub_code(&RrRecovery),  1);
    assert_eq(sub_code(&RrCantLock),  2);
    assert_eq(sub_code(&RrRollback),  3);
    assert_eq(sub_code(&RrDbMoved),   4);
    assert_eq(sub_code(&RrCantInit),  5);
    assert_eq(sub_code(&RrDirectory), 6);
}

fn test_extended_codes() {
    assert_eq(extended_code(&RrBase),      8);
    assert_eq(extended_code(&RrRecovery),  264);    // 8 | (1 << 8)
    assert_eq(extended_code(&RrCantLock),  520);    // 8 | (2 << 8)
    assert_eq(extended_code(&RrRollback),  776);
    assert_eq(extended_code(&RrDbMoved),   1032);
    assert_eq(extended_code(&RrCantInit),  1288);
    assert_eq(extended_code(&RrDirectory), 1544);
}

fn test_from_extended_round_trip() {
    match from_extended(8) {
        Maybe.Some(r) => match &r { RrBase => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_extended(264) {
        Maybe.Some(r) => match &r { RrRecovery => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_extended(1032) {
        Maybe.Some(r) => match &r { RrDbMoved => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
}

fn test_unknown_base_rejected() {
    match from_extended(7) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
    match from_extended(16) { Maybe.None => {}, Maybe.Some(_) => assert(false) }   // different base
}

fn test_reason_names() {
    assert(reason_name(&RrBase)      == "READONLY".clone());
    assert(reason_name(&RrRecovery)  == "READONLY_RECOVERY".clone());
    assert(reason_name(&RrDirectory) == "READONLY_DIRECTORY".clone());
}

fn test_is_transient_set() {
    assert(is_transient(&RrCantLock));
    assert(is_transient(&RrRecovery));
    assert(!is_transient(&RrBase));
    assert(!is_transient(&RrDirectory));
}

fn test_is_corruption_hint_only_rollback() {
    assert(is_corruption_hint(&RrRollback));
    assert(!is_corruption_hint(&RrRecovery));
    assert(!is_corruption_hint(&RrBase));
}

fn test_well_known_count() {
    assert_eq(well_known_count(), 7);
}

fn main() {
    test_base_code();
    test_sub_codes_distinct();
    test_extended_codes();
    test_from_extended_round_trip();
    test_unknown_base_rejected();
    test_reason_names();
    test_is_transient_set();
    test_is_corruption_hint_only_rollback();
    test_well_known_count();
}
