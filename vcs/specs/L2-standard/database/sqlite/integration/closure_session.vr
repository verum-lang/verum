// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, integration, l1, l3, l4, ssa, foundation
// @timeout: 15000
// @description: Closure session integration — exercises SSA optimizer,
//               cursor-btree bridge, WAL actor, and VFS injection all
//               composing through the new architectural surfaces
//               (#137/#139/#140/#141 closure).
//
// Spec: internal/specs/sqlite-native.md §4.4 + §7 + §8 + §10 + §11

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l1_pager.{
    // VFS injection (#137)
    VfsInjection, ViMemory, pager_open_with_vfs, pager_open_with_vfs_default,
    // WAL actor bridge (#139 closure)
    WalPagerActor, wal_actor_new, wal_pager_apply,
    // Existing pager request shape
    PagerRequest, PagerReply,
};
mount core.database.sqlite.native.l4_vdbe.{
    // Cursor-btree bridge (#141 cursor opcode closure)
    CursorBridgeError, op_open_read, op_seek, op_next, op_rowid,
};
mount core.database.sqlite.native.l4_vdbe.ssa.value.{
    SValueKind, SkInt, SkBool,
    ssa_value, value_id, value_id_raw, kind_eq,
};
mount core.database.sqlite.native.l4_vdbe.ssa.inst.{
    SsaInst, IIntImm, IBranch, IJump, IHalt,
};
mount core.database.sqlite.native.l4_vdbe.ssa.block.{
    BasicBlock, BlockId, block_id, block_id_raw,
};
mount core.database.sqlite.native.l4_vdbe.ssa.program.{
    SsaProgram, ssa_program_new,
};
mount core.database.sqlite.native.l4_vdbe.ssa.dce.{run_dce, has_side_effect, DceReport};
mount core.database.sqlite.native.l4_vdbe.ssa.jump_threading.{
    run_jump_threading, JumpThreadReport,
};
mount core.database.sqlite.native.l4_vdbe.ssa.optimizer.{
    optimize_ssa, SsaOptimizerReport,
};
mount core.database.sqlite.native.l3_btree.cursor_seek.{PageStore, page_store_new};
mount core.database.sqlite.native.l3_btree.comparator.{
    SeekKey, SkRowId,
};
mount core.database.sqlite.native.btree_seek_op_codes.op.{SeekOp, SoGe};

// -----------------------------------------------------------------------------
// 1. VFS injection — ViMemory variant constructs successfully
// -----------------------------------------------------------------------------

fn vfs_injection_memory() {
    match pager_open_with_vfs_default(ViMemory) {
        Ok(_)  => {},
        Err(_) => panic("pager_open_with_vfs_default(ViMemory) failed"),
    }
}

// -----------------------------------------------------------------------------
// 2. SSA optimizer pipeline runs to completion on an empty program
// -----------------------------------------------------------------------------

fn ssa_optimize_empty_program() {
    let mut p = ssa_program_new("SELECT 1".clone());
    let report: SsaOptimizerReport = optimize_ssa(&mut p);
    // Empty program → zero edits, single iteration to detect zero edits.
    assert_eq(report.total_dce_removed, 0);
    assert_eq(report.total_jumps_threaded, 0);
    assert_eq(report.total_branches_folded, 0);
    assert(report.iterations >= 1);
}

// -----------------------------------------------------------------------------
// 3. has_side_effect classifies known opcodes correctly
// -----------------------------------------------------------------------------

fn ssa_dce_side_effect_classification() {
    // Terminators always side-effect.
    assert(has_side_effect(&IJump(block_id(0))));
    assert(has_side_effect(&IHalt(0, "".clone())));
    // Pure compute does not.
    let v = ssa_value(value_id(1), SkInt);
    assert(!has_side_effect(&IIntImm(v, 0_i64)));
}

// -----------------------------------------------------------------------------
// 4. Cursor-btree bridge — op_open_read returns a valid cursor on
//    a degenerate (empty) page store; the cursor is positioned at
//    the root.  (Page-fetch failure is the expected error path
//    when the store is empty.)
// -----------------------------------------------------------------------------

fn cursor_bridge_open_read() {
    match op_open_read(2, 4096, 0) {
        Ok(cursor) => {
            assert_eq(cursor.root_page, 2);
            assert_eq(cursor.page_size, 4096);
        }
        Err(_) => panic("op_open_read(root=2) should succeed"),
    }
}

// -----------------------------------------------------------------------------
// 5. PageStore round-trip + cursor seek error path on missing root
// -----------------------------------------------------------------------------

fn cursor_seek_missing_root() {
    let mut cursor = match op_open_read(99, 4096, 0) {
        Ok(c)  => c,
        Err(_) => panic("open_read failed"),
    };
    let pages = page_store_new();
    let target = SkRowId(42_i64);
    match op_seek(&mut cursor, &pages, &target, SoGe) {
        Err(_) => {},   // expected — no page 99 in empty store
        Ok(_) => panic("seek on empty store should error"),
    }
}

fn main() {
    vfs_injection_memory();
    ssa_optimize_empty_program();
    ssa_dce_side_effect_classification();
    cursor_bridge_open_read();
    cursor_seek_missing_root();
}
