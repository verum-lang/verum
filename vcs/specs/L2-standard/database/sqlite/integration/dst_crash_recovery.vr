// @test: wip
// @tier: 0 | 3
// @level: L2
// @tags: sqlite, native, dst, wal, crash, recovery, mockvfs
// @timeout: 15000
// @expected-exit: 0
// @description: Deterministic Simulation Test — inject power-loss in the
//               middle of a commit sequence, reopen, verify state matches
//               "only the committed writes survived". Core correctness
//               invariant for crash-safety (sqlite-native.md §21.4).

mount core.database.sqlite.native.{Connection};
mount core.database.sqlite.native.l0_vfs.{MockVfs, CrashPoint};
mount core.context.{provide};

@test(dst = true, seed = 0xDEADBEEF)
@main
public async fn main() using [MockVfs] -> Result<(), Error> {
    // Open WAL-mode DB:
    let conn = Connection.open("/virt/db").await?;
    conn.execute(sql#"PRAGMA journal_mode = WAL"#).await?;
    conn.execute(sql#"CREATE TABLE t (x INT)"#).await?;

    // Two committed inserts:
    conn.execute(sql#"INSERT INTO t VALUES (1)"#).await?;
    conn.execute(sql#"INSERT INTO t VALUES (2)"#).await?;

    // Inject crash after the next fsync:
    MockVfs.inject_crash_after_fsync(1);

    // Attempt third insert — commit will fsync and then crash.
    let result = conn.execute(sql#"INSERT INTO t VALUES (3)"#).await;
    assert!(result.is_err());

    MockVfs.power_cycle();

    // Reopen; recovery must reconcile committed frames.
    let conn2 = Connection.open("/virt/db").await?;
    let rows: List<Int> = conn2
        .query(sql#"SELECT x FROM t ORDER BY x"#)
        .collect()
        .await?;

    // Rows 1 and 2 must survive; row 3 must not (inject crashed its commit).
    assert_eq(rows, list![1, 2]);
    Ok(())
}
