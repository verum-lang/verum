// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, bind_pointer, carray, typed-pointer, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.bind_pointer.tag.{
    PointerTag, TagRegistry,
    new_tag, tags_match, new_registry,
    tag_carray, tag_json, tag_regexp, tag_series,
};
mount core.database.sqlite.native.bind_pointer.handle.{
    TypedPointer,
    new_pointer, empty_pointer, is_empty, fetch_if_match,
};
mount core.database.sqlite.native.bind_pointer.engine.{
    BindPointerEngine, new_engine,
};
mount base.{Bool};

fn test_tag_helpers() {
    assert(tag_carray() == "carray".clone());
    assert(tag_json() == "json".clone());
    assert(tag_regexp() == "regexp".clone());
    assert(tag_series() == "series".clone());
}

fn test_tags_match() {
    let a = new_tag("carray".clone());
    let b = new_tag("carray".clone());
    let c = new_tag("json".clone());
    assert(tags_match(&a, &b));
    assert(!tags_match(&a, &c));
}

fn test_tag_registry_unique() {
    let mut r = new_registry();
    assert(r.register("carray".clone()));
    assert(!r.register("carray".clone()));
    assert_eq(r.len(), 1);
    assert(r.contains(&"carray".clone()));
    assert(!r.contains(&"json".clone()));
}

fn test_empty_pointer_is_empty() {
    let p = empty_pointer();
    assert(is_empty(&p));
}

fn test_nonempty_pointer_is_not_empty() {
    let p = new_pointer("carray".clone(), 42 as Int64, true);
    assert(!is_empty(&p));
}

fn test_fetch_requires_tag_match() {
    let p = new_pointer("carray".clone(), 42 as Int64, true);
    let want_match = new_tag("carray".clone());
    let want_miss = new_tag("json".clone());
    assert_eq(fetch_if_match(&p, &want_match), 42 as Int64);
    assert_eq(fetch_if_match(&p, &want_miss), 0 as Int64);
}

fn test_fetch_of_empty_is_zero() {
    let p = empty_pointer();
    let want = new_tag("anything".clone());
    assert_eq(fetch_if_match(&p, &want), 0 as Int64);
}

fn test_engine_bind_and_fetch_round_trip() {
    let mut e = new_engine(4);
    let p = new_pointer("carray".clone(), 99 as Int64, true);
    assert(e.sqlite3_bind_pointer(2, p));
    let want = new_tag("carray".clone());
    assert_eq(e.sqlite3_value_pointer(2, &want), 99 as Int64);
}

fn test_engine_rejects_out_of_range_index() {
    let mut e = new_engine(2);
    let p = new_pointer("carray".clone(), 1 as Int64, false);
    assert(!e.sqlite3_bind_pointer(0, p));
}

fn test_engine_clear_zeroes_slot() {
    let mut e = new_engine(4);
    let p = new_pointer("carray".clone(), 99 as Int64, true);
    let _ = e.sqlite3_bind_pointer(2, p);
    assert(e.clear(2));
    let want = new_tag("carray".clone());
    assert_eq(e.sqlite3_value_pointer(2, &want), 0 as Int64);
}

fn test_engine_value_fetch_wrong_tag_yields_zero() {
    let mut e = new_engine(4);
    let p = new_pointer("carray".clone(), 7 as Int64, false);
    let _ = e.sqlite3_bind_pointer(1, p);
    let want_wrong = new_tag("json".clone());
    assert_eq(e.sqlite3_value_pointer(1, &want_wrong), 0 as Int64);
}

fn main() {
    test_tag_helpers();
    test_tags_match();
    test_tag_registry_unique();
    test_empty_pointer_is_empty();
    test_nonempty_pointer_is_not_empty();
    test_fetch_requires_tag_match();
    test_fetch_of_empty_is_zero();
    test_engine_bind_and_fetch_round_trip();
    test_engine_rejects_out_of_range_index();
    test_engine_clear_zeroes_slot();
    test_engine_value_fetch_wrong_tag_yields_zero();
}
