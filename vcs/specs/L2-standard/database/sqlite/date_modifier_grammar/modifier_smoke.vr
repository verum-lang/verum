// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, date_modifier_grammar, datetime
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.date_modifier_grammar.modifier.{
    Unit, UDays, UHours, UMinutes, USeconds, UMonths, UYears,
    unit_name, is_variable_length,
    Modifier,
    MdOffset, MdReplaceDate, MdReplaceTime, MdStartOfMonth, MdStartOfYear, MdStartOfDay,
    MdWeekday, MdLocalTime, MdUtc, MdUnixEpoch, MdJulianDay, MdSubsec,
    modifier_kind, is_absolute, is_timezone, is_output_format, valid_weekday,
};
mount base.{Bool, Int64};

fn test_unit_names() {
    assert(unit_name(&UDays) == "days".clone());
    assert(unit_name(&UMonths) == "months".clone());
}

fn test_variable_length_units() {
    assert(is_variable_length(&UMonths));
    assert(is_variable_length(&UYears));
    assert(!is_variable_length(&UDays));
    assert(!is_variable_length(&USeconds));
}

fn test_modifier_kinds() {
    let m0: Modifier = Modifier.MdOffset { amount: 5 as Int64, unit: UDays };
    assert(modifier_kind(&m0) == "offset".clone());
    assert(modifier_kind(&Modifier.MdReplaceDate("2026-01-01".clone())) == "replace_date".clone());
    assert(modifier_kind(&Modifier.MdStartOfMonth) == "start_of_month".clone());
    assert(modifier_kind(&Modifier.MdWeekday(0_i64)) == "weekday".clone());
    assert(modifier_kind(&Modifier.MdLocalTime) == "localtime".clone());
    assert(modifier_kind(&Modifier.MdUnixEpoch) == "unixepoch".clone());
    assert(modifier_kind(&Modifier.MdSubsec) == "subsec".clone());
}

fn test_is_absolute() {
    assert(is_absolute(&Modifier.MdStartOfMonth));
    assert(is_absolute(&Modifier.MdStartOfYear));
    assert(is_absolute(&Modifier.MdStartOfDay));
    assert(is_absolute(&Modifier.MdReplaceDate("2020-01-01".clone())));
    assert(is_absolute(&Modifier.MdReplaceTime("00:00:00".clone())));
    assert(is_absolute(&Modifier.MdWeekday(1_i64)));
    let off: Modifier = Modifier.MdOffset { amount: 3 as Int64, unit: UDays };
    assert(!is_absolute(&off));
    assert(!is_absolute(&Modifier.MdUtc));
}

fn test_is_timezone() {
    assert(is_timezone(&Modifier.MdLocalTime));
    assert(is_timezone(&Modifier.MdUtc));
    assert(!is_timezone(&Modifier.MdUnixEpoch));
    assert(!is_timezone(&Modifier.MdStartOfDay));
}

fn test_output_format() {
    assert(is_output_format(&Modifier.MdUnixEpoch));
    assert(is_output_format(&Modifier.MdJulianDay));
    assert(is_output_format(&Modifier.MdSubsec));
    assert(!is_output_format(&Modifier.MdLocalTime));
    assert(!is_output_format(&Modifier.MdStartOfDay));
}

fn test_valid_weekday() {
    assert(valid_weekday0_i64);
    assert(valid_weekday6_i64);
    assert(!valid_weekday7_i64);
    assert(!valid_weekday-1_i64);
}

fn main() {
    test_unit_names();
    test_variable_length_units();
    test_modifier_kinds();
    test_is_absolute();
    test_is_timezone();
    test_output_format();
    test_valid_weekday();
}
