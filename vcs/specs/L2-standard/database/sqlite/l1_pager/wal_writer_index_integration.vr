// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, l1_pager, wal_writer, wal_index, integration, multi_reader
// @timeout: 15000
// @description: WalWriter ↔ WalIndex integration (#163) — pre-fix
//               every wal_writer_append_frame wrote the WAL file
//               but left the .shm WalIndex empty; readers attaching
//               to the index saw nothing and had to walk the WAL
//               from byte 0.  Post-fix every mutation propagates:
//               append_frame → index.append_frame, commit → index.
//               commit_header, reset → index.reset_after_checkpoint.
//
// Note: the `WalWriter` constructor requires a `WalBackend` whose
// `WbMem(file)` variant currently has an upstream-regressed
// `not a function` error unrelated to #163.  This test exercises
// the WalIndex protocol surface directly + the index-publish
// recovery seam (which doesn't need a backend) — together they
// cover the post-condition contract that #163 wires.  Once the
// backend regression resolves, a follow-up spec adds the full
// writer→index round-trip.
//
// Spec: internal/specs/sqlite-native.md §8.2 (multi-reader/single-writer)

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l1_pager.{
    WalIndex, wal_index_new,
};

// =============================================================================
// 1. Fresh WalIndex matches the writer's pre-commit state contract
// =============================================================================

fn fresh_index_uninitialised() {
    let idx = wal_index_new(4096);
    // Pre-commit invariant the writer must respect on a fresh
    // WAL: index header is uninitialised (is_init = false).
    // After the writer's first commit, this flips to true.
    assert(!idx.is_initialised());
    assert_eq(idx.mx_frame(), 0);
}

// =============================================================================
// 2. append_frame mirrors what the writer's append_frame must do —
//    publish (page_no, frame_no) so readers can find_frame
// =============================================================================

fn append_frame_publishes_for_readers() {
    let mut idx = wal_index_new(4096);
    // Simulate `wal_writer_append_frame`'s post-condition:
    // every successful frame write is mirrored in the index.
    idx.append_frame(7, 1);
    idx.append_frame(99, 2);
    idx.append_frame(7, 3);  // re-write of page 7
    // A reader's find_frame must see all three.
    let r1 = idx.find_frame(7, 100, 0);
    let r2 = idx.find_frame(99, 100, 0);
    match r1 {
        Some(frame_no) => assert_eq(frame_no, 3),  // newest wins
        None => panic("page 7 should be at frame 3"),
    }
    match r2 {
        Some(frame_no) => assert_eq(frame_no, 2),
        None => panic("page 99 should be at frame 2"),
    }
}

// =============================================================================
// 3. commit_header mirrors what wal_writer_commit must do —
//    publish mx_frame + flip is_init so readers see the txn
// =============================================================================

fn commit_header_publishes_mx_frame() {
    let mut idx = wal_index_new(4096);
    idx.append_frame(1, 1);
    idx.append_frame(2, 2);
    // Pre-commit: index has frames but is_init = false.  Readers
    // attaching to is_init=false must trigger recovery.
    assert(!idx.is_initialised());
    // Simulate wal_writer_commit's post-condition.
    idx.commit_header(2, 100 as u32, 1 as u32, 2 as u32);
    // Post-commit: is_init = true, mx_frame published.
    assert(idx.is_initialised());
    assert_eq(idx.mx_frame(), 2);
    assert_eq(idx.n_page(), 100);
}

// =============================================================================
// 4. reset_after_checkpoint mirrors wal_writer_reset's effect —
//    drop hash sections + bump change_count so readers detect rotation
// =============================================================================

fn reset_drops_index_state() {
    let mut idx = wal_index_new(4096);
    idx.append_frame(1, 1);
    idx.append_frame(2, 2);
    idx.commit_header(2, 100 as u32, 0xAA as u32, 0xBB as u32);
    let pre_change = idx.hdr.change_count as Int;
    idx.reset_after_checkpoint(0xCC as u32, 0xDD as u32);
    assert_eq(idx.mx_frame(), 0);
    assert_eq(idx.sections.len(), 0);
    assert_eq(idx.hdr.salt1 as Int, 0xCC as Int);
    let post_change = idx.hdr.change_count as Int;
    assert(post_change > pre_change);
}

// =============================================================================
// 5. n_backfill bound mirrors wal_writer's checkpoint-drain contract:
//    advance_backfill clamped by min_active_reader_mark
// =============================================================================

fn backfill_bound_protects_readers() {
    let mut idx = wal_index_new(4096);
    idx.append_frame(1, 1);
    idx.append_frame(2, 2);
    idx.append_frame(3, 3);
    idx.commit_header(3, 100 as u32, 1 as u32, 2 as u32);
    // Reader claims a snapshot at mx_frame=3.
    let reader_slot = idx.try_acquire_reader_mark();
    assert(reader_slot >= 1);
    // Checkpointer tries to backfill past 3 — must clamp.
    let advanced = idx.advance_backfill(50);
    assert(advanced);
    assert_eq(idx.n_backfill(), 3);  // clamped to reader mark
}

// =============================================================================
// 6. Find with snapshot — reader sees frames at-or-below their mx_frame
// =============================================================================

fn find_respects_reader_snapshot() {
    let mut idx = wal_index_new(4096);
    idx.append_frame(7, 1);
    idx.append_frame(7, 5);  // newer frame for page 7
    // Reader took a snapshot at mx_frame=3 — must NOT see frame 5.
    let r = idx.find_frame(7, 3, 0);
    match r {
        Some(frame_no) => assert_eq(frame_no, 1),  // older visible
        None => panic("page 7 should still be findable at frame 1"),
    }
}

// =============================================================================
// 7. Multi-reader sharing: same mx_frame snapshot ⇒ same slot
// =============================================================================

fn shared_slot_for_same_snapshot() {
    let mut idx = wal_index_new(4096);
    idx.commit_header(10, 0 as u32, 1 as u32, 2 as u32);
    let s1 = idx.try_acquire_reader_mark();
    let s2 = idx.try_acquire_reader_mark();
    // Both readers at mx_frame=10 — share the slot via refcount.
    assert_eq(s1, s2);
}

fn main() {
    fresh_index_uninitialised();
    append_frame_publishes_for_readers();
    commit_header_publishes_mx_frame();
    reset_drops_index_state();
    backfill_bound_protects_readers();
    find_respects_reader_snapshot();
    shared_slot_for_same_snapshot();
}
