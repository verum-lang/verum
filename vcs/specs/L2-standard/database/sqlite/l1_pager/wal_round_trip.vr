// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, l1_pager, wal, foundation
// @timeout: 15000
// @description: WAL round-trip — exercises the new WalWriter +
//               WalReader + WalPager pipeline (#139 foundation).
//
// Spec: internal/specs/sqlite-native.md §8 (WAL mode)
//
// Asserts the WAL surface composes:
//   1. WalWriter create on a MemDb backend with explicit salts
//   2. Append a frame; WalState records mx_frame=1 + frame_index
//   3. Append a commit frame; last_commit_db_size populated
//   4. Reader snapshot sees the appended frames
//   5. Reset rotates salts and zeroes mx_frame/n_backfill

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l0_vfs.memdb_vfs.{
    MemDbFile, open_memory_rwc,
};
mount core.database.sqlite.native.l1_pager.{
    WalState, WalReaderSnapshot,
    wal_state_new, snapshot_wal,
    WalWriter, WbMem,
    wal_writer_create, wal_writer_append_frame,
    wal_writer_reset, wal_writer_truncate,
};

// -----------------------------------------------------------------------------
// 1. wal_state_new — fresh state has zero frames
// -----------------------------------------------------------------------------

fn fresh_state_zero_frames() {
    let s = wal_state_new(4096);
    assert_eq(s.mx_frame, 0);
    assert_eq(s.n_backfill, 0);
    assert(!s.has_pending_frames());
    assert_eq(s.pending_frame_count(), 0);
}

// -----------------------------------------------------------------------------
// 2. record_appended_frame bumps mx_frame and updates index
// -----------------------------------------------------------------------------

fn append_records_frame() {
    let mut s = wal_state_new(4096);
    s.record_appended_frame(7, false, 0);
    assert_eq(s.mx_frame, 1);
    match s.newest_frame_for(7) {
        Some(fno) => assert_eq(fno, 1),
        None => panic("expected frame 1 for page 7"),
    }
}

// -----------------------------------------------------------------------------
// 3. commit frame populates last_commit_db_size
// -----------------------------------------------------------------------------

fn commit_records_db_size() {
    let mut s = wal_state_new(4096);
    s.record_appended_frame(1, false, 0);
    s.record_appended_frame(2, true, 42);   // commit at db_size=42
    assert_eq(s.mx_frame, 2);
    assert_eq(s.last_commit_db_size, 42);
}

// -----------------------------------------------------------------------------
// 4. advance_backfill marks frames as checkpointed
// -----------------------------------------------------------------------------

fn backfill_marks_drained() {
    let mut s = wal_state_new(4096);
    s.record_appended_frame(1, true, 1);
    s.record_appended_frame(2, true, 2);
    s.record_appended_frame(3, true, 3);
    assert_eq(s.pending_frame_count(), 3);
    s.advance_backfill(2);
    assert_eq(s.pending_frame_count(), 1);
    // newest_frame_for skips past-checkpoint frames.
    match s.newest_frame_for(1) {
        None => {},
        Some(_) => panic("page 1 should be backfilled"),
    }
    match s.newest_frame_for(3) {
        Some(fno) => assert_eq(fno, 3),
        None => panic("page 3 should still be in WAL"),
    }
}

// -----------------------------------------------------------------------------
// 5. reset_for_restart rotates salts and zeroes counters
// -----------------------------------------------------------------------------

fn reset_rotates_salts() {
    let mut s = wal_state_new(4096);
    s.record_appended_frame(1, true, 1);
    let old_salt1 = s.salt1;
    let old_seq = s.checkpoint_seq;
    s.reset_for_restart(0xFEEDC0DE as u32, 0xBADCAFE0 as u32);
    assert_eq(s.mx_frame, 0);
    assert_eq(s.n_backfill, 0);
    assert_eq(s.last_commit_db_size, 0);
    assert(s.salt1 != old_salt1);
    assert(s.checkpoint_seq != old_seq);
}

// -----------------------------------------------------------------------------
// 6. snapshot freezes mx_frame
// -----------------------------------------------------------------------------

fn snapshot_freezes_mx_frame() {
    let mut s = wal_state_new(4096);
    s.record_appended_frame(1, true, 1);
    let snap: WalReaderSnapshot = snapshot_wal(&s);
    // After snapshot, writer keeps appending — snapshot mx_frame
    // stays at 1.
    s.record_appended_frame(2, true, 2);
    assert_eq(snap.mx_frame, 1);
    assert_eq(s.mx_frame, 2);
}

// -----------------------------------------------------------------------------
// 7. WalWriter create / state introspection
// -----------------------------------------------------------------------------

fn wal_writer_create_smoke() {
    let backend_file = match open_memory_rwc(&":memory-wal:".clone()) {
        Ok(f) => f,
        Err(_) => panic("open_memory_rwc failed"),
    };
    let backend = WbMem(backend_file);
    match wal_writer_create(backend, 4096, 0xDEADBEEF as u32, 0xCAFEBABE as u32) {
        Ok(w) => {
            assert_eq(w.page_size(), 4096);
            assert_eq(w.mx_frame(), 0);
            assert_eq(w.n_backfill(), 0);
            assert_eq(w.pending_frames(), 0);
        }
        Err(_) => panic("wal_writer_create failed"),
    }
}

fn main() {
    fresh_state_zero_frames();
    append_records_frame();
    commit_records_db_size();
    backfill_marks_drained();
    reset_rotates_salts();
    snapshot_freezes_mx_frame();
    wal_writer_create_smoke();
}
