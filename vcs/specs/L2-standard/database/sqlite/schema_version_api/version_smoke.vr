// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, schema_version_api, header_counters, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.schema_version_api.counters.{
    HeaderCounters,
    APPID_SQLAR, APPID_MBTILES, APPID_FDO, APPID_GPKG,
    fresh_counters, is_known_appid,
};
mount core.database.sqlite.native.schema_version_api.engine.{
    VersionEngine, SetOutcome, SoOk, SoReadOnly,
    new_engine,
};
mount base.{Bool};

fn test_fresh_counters_zero() {
    let c = fresh_counters();
    assert_eq(c.schema_version, 0);
    assert_eq(c.user_version, 0);
    assert_eq(c.application_id, 0);
}

fn test_known_appids() {
    assert(is_known_appid(APPID_SQLAR));
    assert(is_known_appid(APPID_MBTILES));
    assert(is_known_appid(APPID_FDO));
    assert(is_known_appid(APPID_GPKG));
    assert(!is_known_appid(0));
    assert(!is_known_appid(0x12345678));
}

fn test_engine_writable_bumps_schema_version() {
    let mut e = new_engine(false);
    assert_eq(e.schema_version(), 0);
    let v1 = e.bump_schema_version();
    let v2 = e.bump_schema_version();
    assert_eq(v1, 1);
    assert_eq(v2, 2);
    assert_eq(e.ddl_commits, 2 as Int64);
}

fn test_engine_readonly_noop_on_bump() {
    let mut e = new_engine(true);
    let v = e.bump_schema_version();
    assert_eq(v, 0);
    assert_eq(e.ddl_commits, 0 as Int64);
}

fn test_engine_set_user_version_writable() {
    let mut e = new_engine(false);
    match e.set_user_version(42) {
        SoOk => {},
        _ => assert(false),
    }
    assert_eq(e.user_version(), 42);
}

fn test_engine_set_user_version_readonly() {
    let mut e = new_engine(true);
    match e.set_user_version(42) {
        SoReadOnly => {},
        _ => assert(false),
    }
    assert_eq(e.user_version(), 0);
}

fn test_engine_set_application_id() {
    let mut e = new_engine(false);
    match e.set_application_id(APPID_SQLAR) {
        SoOk => {},
        _ => assert(false),
    }
    assert_eq(e.application_id(), APPID_SQLAR);
}

fn test_engine_upgrade_writable_unblocks() {
    let mut e = new_engine(true);
    match e.set_user_version(1) {
        SoReadOnly => {},
        _ => assert(false),
    }
    e.upgrade_writable();
    match e.set_user_version(1) {
        SoOk => {},
        _ => assert(false),
    }
}

fn main() {
    test_fresh_counters_zero();
    test_known_appids();
    test_engine_writable_bumps_schema_version();
    test_engine_readonly_noop_on_bump();
    test_engine_set_user_version_writable();
    test_engine_set_user_version_readonly();
    test_engine_set_application_id();
    test_engine_upgrade_writable_unblocks();
}
