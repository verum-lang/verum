// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, vfs_api, registry, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.vfs_api.entry.{
    VfsEntry, new_entry, promote_to_default, entry_matches,
};
mount core.database.sqlite.native.vfs_api.registry.{
    VfsRegistry, new_registry,
};
mount base.{Bool, Maybe};

fn test_new_entry_not_default() {
    let e = new_entry("unix".clone(), 42 as Int64);
    assert(!e.made_default);
}

fn test_promote_to_default() {
    let mut e = new_entry("unix".clone(), 42 as Int64);
    promote_to_default(&mut e);
    assert(e.made_default);
}

fn test_entry_matches() {
    let e = new_entry("unix".clone(), 42 as Int64);
    assert(entry_matches(&e, &"unix".clone()));
    assert(!entry_matches(&e, &"win32".clone()));
}

fn test_registry_register_ok() {
    let mut r = new_registry();
    assert_eq(r.sqlite3_vfs_register("unix".clone(), 42 as Int64, true), 0);
    assert_eq(r.len(), 1);
    assert_eq(r.default_handle, 42 as Int64);
}

fn test_registry_duplicate_name_misuse() {
    let mut r = new_registry();
    let _ = r.sqlite3_vfs_register("unix".clone(), 42 as Int64, false);
    assert_eq(r.sqlite3_vfs_register("unix".clone(), 99 as Int64, false), 1);
}

fn test_registry_find_by_name() {
    let mut r = new_registry();
    let _ = r.sqlite3_vfs_register("unix".clone(), 42 as Int64, true);
    let _ = r.sqlite3_vfs_register("memdb".clone(), 7 as Int64, false);
    let handle = r.sqlite3_vfs_find(&Maybe.Some("memdb".clone()));
    assert_eq(handle, 7 as Int64);
}

fn test_registry_find_default() {
    let mut r = new_registry();
    let _ = r.sqlite3_vfs_register("unix".clone(), 42 as Int64, true);
    assert_eq(r.sqlite3_vfs_find(&Maybe.None), 42 as Int64);
}

fn test_registry_find_missing_returns_zero() {
    let r = new_registry();
    assert_eq(r.sqlite3_vfs_find(&Maybe.Some("absent".clone())), 0 as Int64);
}

fn test_unregister_removes_and_promotes_next() {
    let mut r = new_registry();
    let _ = r.sqlite3_vfs_register("unix".clone(), 42 as Int64, true);
    let _ = r.sqlite3_vfs_register("memdb".clone(), 7 as Int64, false);
    assert_eq(r.sqlite3_vfs_unregister(42 as Int64), 0);
    assert_eq(r.len(), 1);
    // Default promotes to the now-head entry.
    assert_eq(r.default_handle, 7 as Int64);
}

fn test_unregister_not_found_returns_one() {
    let mut r = new_registry();
    assert_eq(r.sqlite3_vfs_unregister(99 as Int64), 1);
}

fn main() {
    test_new_entry_not_default();
    test_promote_to_default();
    test_entry_matches();
    test_registry_register_ok();
    test_registry_duplicate_name_misuse();
    test_registry_find_by_name();
    test_registry_find_default();
    test_registry_find_missing_returns_zero();
    test_unregister_removes_and_promotes_next();
    test_unregister_not_found_returns_one();
}
