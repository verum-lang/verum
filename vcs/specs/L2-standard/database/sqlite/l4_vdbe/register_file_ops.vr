// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, vdbe, register, move, copy
// @timeout: 10000
// @description: RegisterFile — get/set, move_range, copy_range, clear_range, truthy
//
// Spec: internal/specs/sqlite-native.md §11.1

mount core.*;
mount collections.List;
mount core.database.sqlite.native.l4_vdbe.{
    Register, RegisterKind, RegisterFile,
    register_file_new, register_kind, register_is_truthy,
};

fn construction_and_defaults() {
    let rf = register_file_new(8);
    assert_eq(rf.size(), 8);
    match rf.get(0) { RNull => {}, _ => panic("slot 0 should be RNull"), }
    match rf.get(7) { RNull => {}, _ => panic("slot 7 should be RNull"), }
}

fn set_and_get() {
    let mut rf = register_file_new(4);
    rf.set(0, RInt(42_i64));
    rf.set(1, RReal(3.14));
    rf.set(2, RText("hi".clone()));
    match rf.get(0) { RInt(i) => { assert_eq(i as Int, 42); }, _ => panic("slot 0"), }
    match rf.get(1) { RReal(_) => {}, _ => panic("slot 1"), }
    match rf.get(2) { RText(_) => {}, _ => panic("slot 2"), }
    match rf.get(3) { RNull => {}, _ => panic("slot 3 untouched"), }
}

fn out_of_bounds_reads_null() {
    let rf = register_file_new(2);
    match rf.get(-1) { RNull => {}, _ => panic("negative index"), }
    match rf.get(99) { RNull => {}, _ => panic("past end"), }
}

fn kind_tags() {
    match register_kind(&RNull)  { KNull => {}, _ => panic("kind null"), }
    match register_kind(&RInt(0_i64)) { KInt => {}, _ => panic("kind int"), }
    match register_kind(&RReal(0.0)) { KReal => {}, _ => panic("kind real"), }
    match register_kind(&RText("x".clone())) { KText => {}, _ => panic("kind text"), }
    let mut b: List<Byte> = List.new();
    b.push(0 as Byte);
    match register_kind(&RBlob(b)) { KBlob => {}, _ => panic("kind blob"), }
    match register_kind(&RRowId(1_i64)) { KRowId => {}, _ => panic("kind rowid"), }
}

fn truthy_rules() {
    assert(!register_is_truthy(&RNull));
    assert(!register_is_truthy(&RInt(0_i64)));
    assert(register_is_truthy(&RInt(1_i64)));
    assert(!register_is_truthy(&RReal(0.0)));
    assert(register_is_truthy(&RReal(0.5)));
    assert(!register_is_truthy(&RText("".clone())));
    assert(register_is_truthy(&RText("x".clone())));
}

fn move_and_copy() {
    let mut rf = register_file_new(6);
    rf.set(0, RInt(1_i64));
    rf.set(1, RInt(2_i64));
    rf.set(2, RInt(3_i64));
    // Move 0..3 → 3..6.
    rf.move_range(0, 3, 3);
    match rf.get(0) { RNull => {}, _ => panic("src cleared"), }
    match rf.get(3) { RInt(i) => { assert_eq(i as Int, 1); }, _ => panic("dst 3"), }
    match rf.get(5) { RInt(i) => { assert_eq(i as Int, 3); }, _ => panic("dst 5"), }

    // Copy keeps source intact.
    rf.copy_range(3, 0, 3);
    match rf.get(0) { RInt(i) => { assert_eq(i as Int, 1); }, _ => panic("copied dst 0"), }
    match rf.get(3) { RInt(i) => { assert_eq(i as Int, 1); }, _ => panic("src still 1"), }
}

fn clear_range_fills_null() {
    let mut rf = register_file_new(4);
    rf.set(0, RInt(1_i64));
    rf.set(1, RInt(2_i64));
    rf.set(2, RInt(3_i64));
    rf.clear_range(0, 2);
    match rf.get(0) { RNull => {}, _ => panic("cleared 0"), }
    match rf.get(1) { RNull => {}, _ => panic("cleared 1"), }
    match rf.get(2) { RNull => {}, _ => panic("cleared 2"), }
}

fn main() {
    construction_and_defaults();
    set_and_get();
    out_of_bounds_reads_null();
    kind_tags();
    truthy_rules();
    move_and_copy();
    clear_range_fills_null();
    print("register_file_ops typecheck ok");
}
