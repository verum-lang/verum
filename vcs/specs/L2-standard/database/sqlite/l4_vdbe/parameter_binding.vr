// @test: run-interpreter
// @tier: 0
// @level: L2
// @tags: sqlite, native, l4_vdbe, l5_sql, l6_session, parameter-binding, P0
// @timeout: 30000
// @expected-exit: 0
//
// **End-to-end parameter-binding integration**.  Pre-fix every
// parameterized query was broken (`ParamBindings` was write-only;
// L4 had no `Variable` opcode; `EVar`/`EPositional` codegen was
// `unsupported`).  This pin asserts the full chain:
//
//   1. SQL parser sees `?N` / `:name` / `@name` → AST `EPositional(N)` / `EVar(name)`
//   2. L5 codegen emits `Variable(reg, N)` / `VariableNamed(reg, name_const_idx)`
//   3. L6 `PreparedStatement.step()` snapshots `bindings` into `state.bindings`
//   4. L4 interpreter `Variable` / `VariableNamed` handler reads from `state.bindings`
//   5. The bound value reaches the destination register
//
// Spec: sqlite-native.md §16.3 (parameter binding API)

mount core.database.sqlite.native.l6_session.statement.{
    PreparedStatement, prepare, StmtError,
};
mount core.database.sqlite.native.l4_vdbe.{
    Register, RInt, RText, RNull,
    StepResult, Row, Done,
};
mount collections.List;

fn assert_step_done(stmt: &mut PreparedStatement, label: &Text) {
    let result = stmt.step();
    match result {
        Done => { /* expected */ }
        Row(_, _) => { panic(f"{label}: unexpected Row, expected Done"); }
        ExecError(c, m) => { panic(f"{label}: ExecError({c}, {m})"); }
        Yield => { panic(f"{label}: unexpected Yield"); }
    }
}

fn test_positional_int_passthrough() {
    print("test_positional_int_passthrough");
    // SELECT ?1 — the only construct that doesn't need a planner
    // wired to a schema, so this exercises the parameter-binding
    // path in isolation from the read-side cursor pipeline.
    let mut stmt = match prepare(&"SELECT ?1".clone()) {
        Ok(s) => s,
        Err(e) => { panic(f"prepare failed: {e}"); return; }
    };
    stmt.bind_int(1, 42 as Int64);
    let result = stmt.step();
    match result {
        Row(start, n) => {
            assert_eq(n, 1);
            let v = stmt.column(0);
            match v {
                RInt(x) => { assert_eq(x, 42 as Int64); }
                _ => { panic(f"expected RInt(42), got something else"); }
            }
        }
        _ => { panic(f"expected Row, got: {result:?}"); }
    }
}

fn test_positional_unbound_is_null() {
    print("test_positional_unbound_is_null");
    let mut stmt = match prepare(&"SELECT ?1".clone()) {
        Ok(s) => s,
        Err(e) => { panic(f"prepare failed: {e}"); return; }
    };
    // No bind_* call — slot 1 is unbound, must read as NULL
    let result = stmt.step();
    match result {
        Row(start, n) => {
            assert_eq(n, 1);
            let v = stmt.column(0);
            match v {
                RNull => { /* expected */ }
                _ => { panic(f"expected RNull for unbound ?1"); }
            }
        }
        _ => { panic(f"expected Row, got: {result:?}"); }
    }
}

fn test_positional_text_passthrough() {
    print("test_positional_text_passthrough");
    let mut stmt = match prepare(&"SELECT ?1".clone()) {
        Ok(s) => s,
        Err(e) => { panic(f"prepare failed: {e}"); return; }
    };
    stmt.bind_text(1, "hello".clone());
    let result = stmt.step();
    match result {
        Row(start, n) => {
            assert_eq(n, 1);
            let v = stmt.column(0);
            match v {
                RText(s) => { assert_eq(s, "hello".clone()); }
                _ => { panic(f"expected RText('hello'), got something else"); }
            }
        }
        _ => { panic(f"expected Row, got: {result:?}"); }
    }
}

fn test_reset_keeps_bindings() {
    print("test_reset_keeps_bindings");
    let mut stmt = match prepare(&"SELECT ?1".clone()) {
        Ok(s) => s,
        Err(e) => { panic(f"prepare failed: {e}"); return; }
    };
    stmt.bind_int(1, 99 as Int64);
    let _ = stmt.step();           // first row
    assert_step_done(&mut stmt, &"first done".clone());
    stmt.reset();
    // Reset should rewind pc but PRESERVE bindings (SQLite contract).
    let result = stmt.step();
    match result {
        Row(start, n) => {
            let v = stmt.column(0);
            match v {
                RInt(x) => { assert_eq(x, 99 as Int64); }
                _ => { panic("reset should preserve binding 99"); }
            }
        }
        _ => { panic(f"expected Row after reset, got: {result:?}"); }
    }
}

fn test_clear_bindings_drops_to_null() {
    print("test_clear_bindings_drops_to_null");
    let mut stmt = match prepare(&"SELECT ?1".clone()) {
        Ok(s) => s,
        Err(e) => { panic(f"prepare failed: {e}"); return; }
    };
    stmt.bind_int(1, 7 as Int64);
    stmt.clear_bindings();
    stmt.reset();
    let result = stmt.step();
    match result {
        Row(start, n) => {
            let v = stmt.column(0);
            match v {
                RNull => { /* expected — clear_bindings dropped the value */ }
                _ => { panic("clear_bindings should reset slot to RNull"); }
            }
        }
        _ => { panic(f"expected Row, got: {result:?}"); }
    }
}

fn main() {
    test_positional_int_passthrough();
    test_positional_unbound_is_null();
    test_positional_text_passthrough();
    test_reset_keeps_bindings();
    test_clear_bindings_drops_to_null();
    print("L4 parameter-binding integration ok");
}
