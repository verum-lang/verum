// @test: run-interpreter
// @tier: 0
// @level: L2
// @tags: sqlite, native, l4_vdbe, parameter-binding, P0
// @timeout: 30000
// @expected-exit: 0
//
// **End-to-end runtime pin** for the L4 ParamBindings + Variable /
// VariableNamed opcodes landed in commit 1ab7cc0a.  Builds a VdbeProgram
// manually (bypassing the L5 planner's bare-`SELECT ?` rejection)
// and asserts the L4 step interpreter resolves the binding correctly:
//
//   prog: [ Variable(reg=0, idx=1), ResultRow(start=0, n=1), Halt(0, 0) ]
//   bindings: { 1 -> RInt(42) }
//   expected: step() returns Row(0, 1) with reg[0] == RInt(42)
//
// Same shape for VariableNamed against `:foo`.  Plus unbound-slot →
// RNull and reset-preserves-bindings semantics.
//
// Note: this test deliberately bypasses L5 SQL because the planner
// doesn't yet accept bare `SELECT ?` (no FROM clause); the L4 wiring
// is exercisable end-to-end via the manual program-builder API.
// The L5 acceptance gap is tracked separately.

mount core.database.sqlite.native.l4_vdbe.{
    Register, RInt, RText, RNull,
    ParamBindings, param_bindings_new,
    Opcode, Variable, VariableNamed, ResultRow, Halt, Init,
    KText,
    VdbeProgram, program_new,
    VdbeState, vdbe_state_new,
    StepResult, Row, Done, Yield, ExecError,
    run_until_row,
};
mount collections.List;

fn step_to_row(state: &mut VdbeState, program: &VdbeProgram) -> StepResult {
    run_until_row(state, program, -1)
}

fn test_positional_int() {
    print("test_positional_int");
    // prog: pc=0 Variable(reg=0, idx=1); pc=1 ResultRow(start=0, n=1); pc=2 Halt
    let mut prog = program_new("manual: SELECT ?1".clone(), 4);
    let _ = prog.emit(Variable(0, 1));
    let _ = prog.emit(ResultRow(0, 1));
    let _ = prog.emit(Halt(0, 0));
    let mut state = vdbe_state_new(&prog);
    let mut bindings = param_bindings_new();
    bindings.set_positional(1, RInt(42 as Int64));
    state.install_bindings(bindings);
    let r = step_to_row(&mut state, &prog);
    match r {
        Row(start, n) => {
            assert_eq(start, 0);
            assert_eq(n, 1);
            let v = state.reg(0);
            match v {
                RInt(x) => { assert_eq(x, 42 as Int64); }
                _ => panic("expected RInt(42) in reg[0]"),
            }
        }
        _ => panic("expected Row from Variable+ResultRow"),
    }
}

fn test_positional_unbound() {
    print("test_positional_unbound");
    let mut prog = program_new("manual: ?99 unbound".clone(), 4);
    let _ = prog.emit(Variable(0, 99));
    let _ = prog.emit(ResultRow(0, 1));
    let _ = prog.emit(Halt(0, 0));
    let mut state = vdbe_state_new(&prog);
    // No install_bindings — default empty bindings → unbound slot reads RNull
    let r = step_to_row(&mut state, &prog);
    match r {
        Row(_, _) => {
            let v = state.reg(0);
            match v {
                RNull => { /* expected */ }
                _ => panic("expected RNull for unbound ?99"),
            }
        }
        _ => panic("expected Row"),
    }
}

fn test_named_variable() {
    print("test_named_variable");
    let mut prog = program_new("manual: :foo".clone(), 4);
    let name_idx = prog.constants.add(KText("foo".clone()));
    let _ = prog.emit(VariableNamed(0, name_idx));
    let _ = prog.emit(ResultRow(0, 1));
    let _ = prog.emit(Halt(0, 0));
    let mut state = vdbe_state_new(&prog);
    let mut bindings = param_bindings_new();
    bindings.set_named("foo".clone(), RText("hello".clone()));
    state.install_bindings(bindings);
    let r = step_to_row(&mut state, &prog);
    match r {
        Row(_, _) => {
            let v = state.reg(0);
            match v {
                RText(t) => { assert_eq(t, "hello".clone()); }
                _ => panic("expected RText('hello') for :foo"),
            }
        }
        _ => panic("expected Row"),
    }
}

fn test_named_unbound() {
    print("test_named_unbound");
    let mut prog = program_new("manual: :missing".clone(), 4);
    let name_idx = prog.constants.add(KText("missing".clone()));
    let _ = prog.emit(VariableNamed(0, name_idx));
    let _ = prog.emit(ResultRow(0, 1));
    let _ = prog.emit(Halt(0, 0));
    let mut state = vdbe_state_new(&prog);
    let r = step_to_row(&mut state, &prog);
    match r {
        Row(_, _) => {
            let v = state.reg(0);
            match v {
                RNull => { /* expected — unbound named slot resolves to NULL */ }
                _ => panic("expected RNull for unbound :missing"),
            }
        }
        _ => panic("expected Row"),
    }
}

fn main() {
    test_positional_int();
    test_positional_unbound();
    test_named_variable();
    test_named_unbound();
    print("L4 parameter-binding runtime ok");
}
