// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, native, l4_vdbe, l5_sql, l6_session, parameter-binding, P0
// @timeout: 30000
//
// **Parameter-binding wiring pin (typecheck-pass)**.  Pre-fix every
// parameterized query was broken (`ParamBindings` was write-only;
// L4 had no `Variable` opcode; `EVar`/`EPositional` codegen was
// `unsupported`).  This pin asserts the surface signatures still
// type-check after the L4/L5/L6 wiring landed in commit 1ab7cc0a:
//
//   1. SQL parser sees `?N` / `:name` / `@name` → AST `EPositional(N)` / `EVar(name)`
//   2. L5 codegen emits `Variable(reg, N)` / `VariableNamed(reg, name_const_idx)`
//   3. L6 `PreparedStatement.step()` snapshots `bindings` into `state.bindings`
//   4. L4 interpreter `Variable` / `VariableNamed` handler reads from `state.bindings`
//   5. The bound value reaches the destination register
//
// Runtime end-to-end coverage requires planner support for bare
// `SELECT ?` (no FROM clause) — tracked separately as a planner
// follow-up.  The wiring contract itself is validated by:
//   * `bindings.vr` import resolves
//   * `PreparedStatement.bind_*` calls type-check
//   * `Variable` / `VariableNamed` opcodes exist and route through
//     `step` (the static layout-validator at codegen finalize would
//     reject any wiring break — this pin doubles as a guard against
//     regressing the opcode catalog)
//
// Spec: sqlite-native.md §16.3 (parameter binding API)

mount core.database.sqlite.native.l6_session.statement.{
    PreparedStatement, prepare,
};
mount core.database.sqlite.native.l4_vdbe.{
    Register, RInt, RText, RNull,
    ParamBindings, param_bindings_new,
    Opcode, Variable, VariableNamed,
    StepResult, Row, Done,
};
mount collections.List;

fn smoke_param_bindings_surface() {
    // Construct an empty ParamBindings and round-trip a positional
    // value through the L4 surface (no SQL involved — pure L4 API).
    let mut b = param_bindings_new();
    b.set_positional(1, RInt(42 as Int64));
    let v = b.get_positional(1);
    match v {
        RInt(x) => { assert_eq(x, 42 as Int64); }
        _ => panic("expected RInt(42)"),
    }
    // Unbound slot reads as RNull.
    let nv = b.get_positional(99);
    match nv {
        RNull => {}
        _ => panic("expected RNull for unbound slot"),
    }
}

fn smoke_named_bindings_surface() {
    let mut b = param_bindings_new();
    b.set_named("foo".clone(), RText("hello".clone()));
    let v = b.get_named(&"foo".clone());
    match v {
        RText(s) => { assert_eq(s, "hello".clone()); }
        _ => panic("expected RText"),
    }
}

fn smoke_opcode_surface() {
    // Construct the new opcodes — proves the variants exist with
    // the documented operand shape.  The static type-layout
    // validator at codegen finalize would reject any drift.
    let _v = Variable(0, 1);
    let _vn = VariableNamed(0, 7);
}

fn main() {
    smoke_param_bindings_surface();
    smoke_named_bindings_surface();
    smoke_opcode_surface();
    print("L4 parameter-binding surface ok");
}
