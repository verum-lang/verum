// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, vtab_collation, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.vtab_collation.lookup.{
    ConstraintCollation, CollationTable,
    entry, new_table,
};
mount core.database.sqlite.native.vtab_collation.engine.{
    sqlite3_vtab_collation, sqlite3_vtab_collation_or_binary,
};
mount base.{Maybe};

fn test_new_table_empty() {
    let t = new_table();
    assert_eq(t.len(), 0);
    match sqlite3_vtab_collation(&t, 0) {
        Maybe.None => {},
        Maybe.Some(_) => assert(false),
    }
}

fn test_push_and_lookup() {
    let mut t = new_table();
    t.push(entry(0, "NOCASE".clone()));
    t.push(entry(1, "BINARY".clone()));
    assert_eq(t.len(), 2);
    match sqlite3_vtab_collation(&t, 0) {
        Maybe.Some(n) => assert(n == "NOCASE".clone()),
        Maybe.None => assert(false),
    }
    match sqlite3_vtab_collation(&t, 1) {
        Maybe.Some(n) => assert(n == "BINARY".clone()),
        Maybe.None => assert(false),
    }
}

fn test_or_binary_fallback_on_miss() {
    let t = new_table();
    assert(sqlite3_vtab_collation_or_binary(&t, 99) == "BINARY".clone());
}

fn test_or_binary_uses_stored_value_on_hit() {
    let mut t = new_table();
    t.push(entry(0, "RTRIM".clone()));
    assert(sqlite3_vtab_collation_or_binary(&t, 0) == "RTRIM".clone());
}

fn main() {
    test_new_table_empty();
    test_push_and_lookup();
    test_or_binary_fallback_on_miss();
    test_or_binary_uses_stored_value_on_hit();
}
