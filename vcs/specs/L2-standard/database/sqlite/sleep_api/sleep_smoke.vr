// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, sleep_api, busy_wait, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.sleep_api.request.{
    SleepRequest, new_request, is_noop, to_ns,
};
mount core.database.sqlite.native.sleep_api.engine.{
    SleepEngine, new_engine,
};
mount base.{Bool};

fn test_request_positive_ms() {
    let r = new_request(250);
    assert(!is_noop(&r));
    assert_eq(r.milliseconds, 250);
}

fn test_request_zero_is_noop() {
    let r = new_request(0);
    assert(is_noop(&r));
    assert_eq(to_ns(&r), 0 as Int64);
}

fn test_request_negative_is_noop() {
    let r = new_request(-1);
    assert(is_noop(&r));
}

fn test_to_ns_conversion() {
    let r = new_request(3);
    assert_eq(to_ns(&r), 3_000_000 as Int64);
}

fn test_engine_sleep_records() {
    let mut e = new_engine(0);
    let r = new_request(100);
    let slept = e.sqlite3_sleep(&r);
    assert_eq(slept, 100);
    assert_eq(e.sleeps_taken, 1 as Int64);
    assert_eq(e.requested_ms, 100 as Int64);
    assert_eq(e.actual_ms, 100 as Int64);
}

fn test_engine_sleep_floor_clamps_up() {
    let mut e = new_engine(5);
    let r = new_request(1);
    let slept = e.sqlite3_sleep(&r);
    // Floor upgraded 1ms to 5ms.
    assert_eq(slept, 5);
    assert_eq(e.requested_ms, 1 as Int64);
    assert_eq(e.actual_ms, 5 as Int64);
}

fn test_engine_sleep_noop_skipped() {
    let mut e = new_engine(0);
    let r = new_request(0);
    let slept = e.sqlite3_sleep(&r);
    assert_eq(slept, 0);
    assert_eq(e.sleeps_taken, 0 as Int64);
}

fn test_engine_sleep_respects_existing_bigger_value() {
    let mut e = new_engine(5);
    let r = new_request(100);
    let slept = e.sqlite3_sleep(&r);
    assert_eq(slept, 100);
}

fn main() {
    test_request_positive_ms();
    test_request_zero_is_noop();
    test_request_negative_is_noop();
    test_to_ns_conversion();
    test_engine_sleep_records();
    test_engine_sleep_floor_clamps_up();
    test_engine_sleep_noop_skipped();
    test_engine_sleep_respects_existing_bigger_value();
}
