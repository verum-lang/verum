// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, stmt_status_op_codes, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.stmt_status_op_codes.op.{
    StmtStatusOp,
    SsFullscanStep, SsSort, SsAutoIndex, SsVmStep,
    SsReprepare, SsRun, SsFilterMiss, SsFilterHit, SsMemUsed,
    op_code, from_code, op_name,
    is_performance_warning, is_bloom_filter_counter, well_known_count,
};
mount base.{Bool, Maybe};

fn test_op_codes_match_sqlite_header() {
    assert_eq(op_code(&SsFullscanStep), 1);
    assert_eq(op_code(&SsSort),         2);
    assert_eq(op_code(&SsAutoIndex),    3);
    assert_eq(op_code(&SsVmStep),       4);
    assert_eq(op_code(&SsReprepare),    5);
    assert_eq(op_code(&SsRun),          6);
    assert_eq(op_code(&SsFilterMiss),   7);
    assert_eq(op_code(&SsFilterHit),    8);
    assert_eq(op_code(&SsMemUsed),     99);
}

fn test_round_trip_from_code() {
    match from_code(4) {
        Maybe.Some(o) => match &o { SsVmStep => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(99) {
        Maybe.Some(o) => match &o { SsMemUsed => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
}

fn test_from_unknown_returns_none() {
    match from_code(0)   { Maybe.None => {}, Maybe.Some(_) => assert(false) }
    match from_code(20)  { Maybe.None => {}, Maybe.Some(_) => assert(false) }
    match from_code(100) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
}

fn test_names() {
    assert(op_name(&SsFullscanStep) == "FULLSCAN_STEP".clone());
    assert(op_name(&SsFilterHit)    == "FILTER_HIT".clone());
    assert(op_name(&SsMemUsed)      == "MEMUSED".clone());
}

fn test_performance_warning_set() {
    assert(is_performance_warning(&SsFullscanStep));
    assert(is_performance_warning(&SsSort));
    assert(is_performance_warning(&SsAutoIndex));
    assert(!is_performance_warning(&SsVmStep));
    assert(!is_performance_warning(&SsMemUsed));
}

fn test_bloom_filter_counter_set() {
    assert(is_bloom_filter_counter(&SsFilterHit));
    assert(is_bloom_filter_counter(&SsFilterMiss));
    assert(!is_bloom_filter_counter(&SsSort));
}

fn test_well_known_count() {
    assert_eq(well_known_count(), 9);
}

fn main() {
    test_op_codes_match_sqlite_header();
    test_round_trip_from_code();
    test_from_unknown_returns_none();
    test_names();
    test_performance_warning_set();
    test_bloom_filter_counter_set();
    test_well_known_count();
}
