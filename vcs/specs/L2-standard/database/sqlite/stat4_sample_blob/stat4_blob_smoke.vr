// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, stat4_sample_blob, statistics
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.stat4_sample_blob.shape.{
    SampleBlob,
    new,
    total_blob_bytes, is_empty,
    typical_max_bytes, fits_in_typical_blob,
    aligned_with_stat4_arrays, header_size_byte_count,
};
mount base.{Bool};

fn test_new_basic() {
    let s = new(3, 5, 100);
    assert_eq(s.column_count, 3);
    assert_eq(s.serial_types_byte_len, 5);
    assert_eq(s.payload_byte_len, 100);
    assert_eq(total_blob_bytes(&s), 105);
    assert(!is_empty(&s));
}

fn test_empty_blob() {
    let s = new(0, 0, 0);
    assert(is_empty(&s));
}

fn test_fits_in_typical_blob() {
    let small = new(2, 5, 100);
    assert(fits_in_typical_blob(&small));
    let big = new(10, 100, typical_max_bytes());
    assert(!fits_in_typical_blob(&big));
}

fn test_typical_max_bytes() {
    assert_eq(typical_max_bytes(), 65536);
}

fn test_aligned_with_stat4_arrays() {
    assert(aligned_with_stat4_arrays(3, 3));
    assert(!aligned_with_stat4_arrays(2, 3));
}

fn test_header_size_byte_count() {
    assert_eq(header_size_byte_count(), 1);
}

fn main() {
    test_new_basic();
    test_empty_blob();
    test_fits_in_typical_blob();
    test_typical_max_bytes();
    test_aligned_with_stat4_arrays();
    test_header_size_byte_count();
}
