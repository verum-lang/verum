// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, bloom_filter_api, optimizer
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.bloom_filter_api.spec.{
    FilterSpec,
    default_bits_per_entry,
    new, with_hash_count, record_insert,
    approximate_fpr, is_worthwhile, bits_per_entry,
};
mount base.{Bool, Int64};

fn test_default_bits_per_entry() {
    assert_eq(default_bits_per_entry(), 8);
}

fn test_new_spec_sizing() {
    let s = new(1000 as Int64);
    assert_eq(s.bit_count, 8000 as Int64);
    assert_eq(s.hash_count, 1);
    assert_eq(s.expected_entries, 1000 as Int64);
    assert_eq(s.entries_inserted, 0 as Int64);
}

fn test_with_hash_count_floors_at_one() {
    let s = with_hash_count(new(100 as Int64), 0);
    assert_eq(s.hash_count, 1);
    let s2 = with_hash_count(new(100 as Int64), 3);
    assert_eq(s2.hash_count, 3);
}

fn test_record_insert_bumps_counter() {
    let s = record_insert(record_insert(new(100 as Int64)));
    assert_eq(s.entries_inserted, 2 as Int64);
}

fn test_bits_per_entry_matches_default() {
    let s = new(1000 as Int64);
    let b = bits_per_entry(&s);
    assert(b > 7.9 as Float);
    assert(b < 8.1 as Float);
}

fn test_is_worthwhile_threshold() {
    assert(!is_worthwhile(10 as Int64));
    assert(!is_worthwhile(24 as Int64));
    assert(is_worthwhile(25 as Int64));
    assert(is_worthwhile(1000 as Int64));
}

fn test_fpr_grows_with_inserts() {
    let mut s = new(1000 as Int64);
    let f0 = approximate_fpr(&s);
    s = record_insert(record_insert(s));
    let f1 = approximate_fpr(&s);
    assert(f1 >= f0);
}

fn test_fpr_capped_at_one() {
    // Push way past the expected entries — linear approx still clamped.
    let mut s = new(10 as Int64);
    let mut i: Int = 0;
    while i < 100 {
        s = record_insert(s);
        i = i + 1;
    }
    let f = approximate_fpr(&s);
    assert(f <= 1.0 as Float);
    assert(f >= 0.0 as Float);
}

fn test_fpr_for_empty_bit_count_is_one() {
    let s = FilterSpec {
        bit_count: 0 as Int64,
        hash_count: 1,
        expected_entries: 0 as Int64,
        entries_inserted: 0 as Int64,
    };
    let f = approximate_fpr(&s);
    assert_eq(f, 1.0 as Float);
}

fn main() {
    test_default_bits_per_entry();
    test_new_spec_sizing();
    test_with_hash_count_floors_at_one();
    test_record_insert_bumps_counter();
    test_bits_per_entry_matches_default();
    test_is_worthwhile_threshold();
    test_fpr_grows_with_inserts();
    test_fpr_capped_at_one();
    test_fpr_for_empty_bit_count_is_one();
}
