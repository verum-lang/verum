// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sqlite, native, l7_api, e2e, prepared_statement, lifecycle, sql_value
// @timeout: 30000
// @description: End-to-end PreparedStatement lifecycle (#152) —
//               prepare → bind → step → column_value → reset →
//               re-step.  Exercises the L6 statement_lifecycle
//               surface (column_count / column_name / column_int
//               / column_text / column_type) plus the rich
//               SqlValue accessors (#158) that ride on top.
//               Complements `e2e_create_insert_select.vr` which
//               drives the high-level execute/query_* facade.
//
// Spec: internal/specs/sqlite-native.md §17 (PreparedStatement)

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Text, Maybe};
mount core.database.sqlite.native.l7_api.{
    Database, SqliteApiDbError,
    open_admin, open_readwrite,
};
mount core.database.sqlite.native.l6_session.{
    PreparedStatement, StmtError,
    LifecycleError, StepOutcome, SoRowReady, SoDone, SoErrored,
    column_count, column_name, column_declared_type,
    column_value, column_kind,
    column_sql_value, column_type, column_type_int,
    column_int, column_double, column_text, column_text16,
    column_blob, column_bytes, column_bytes16,
    bind_positional, bind_sql_value,
    step_one, reset, finalize,
    ColumnType, CtNull, CtInt, CtReal, CtText, CtBlob,
};
mount core.database.sqlite.native.l4_vdbe.register.{
    Register, RNull, RInt, RReal, RText, RBlob,
};

// =============================================================================
// Helpers
// =============================================================================

fn open_or_panic() -> Database {
    match open_admin() {
        Ok(d)  => d,
        Err(_) => panic("e2e-prep: open_admin failed"),
    }
}

fn execute_or_panic(db: &mut Database, sql: &Text) {
    match db.execute(sql) {
        Ok(_)  => {},
        Err(_) => panic(f"e2e-prep: execute failed: {sql}".as_str().to_owned()),
    }
}

fn col_type_eq(a: &ColumnType, b: &ColumnType) -> Bool {
    match a {
        CtNull => match b { CtNull => true, _ => false },
        CtInt  => match b { CtInt  => true, _ => false },
        CtReal => match b { CtReal => true, _ => false },
        CtText => match b { CtText => true, _ => false },
        CtBlob => match b { CtBlob => true, _ => false },
    }
}

// =============================================================================
// 1. prepare + step + column_count for a literal SELECT
// =============================================================================

fn prepare_step_literal_select() {
    let db = open_or_panic();
    let r = db.prepare(&"SELECT 42".clone());
    let mut stmt = match r {
        Ok(s)  => s,
        Err(_) => panic("prepare failed for SELECT 42"),
    };
    assert_eq(column_count(&stmt), 1);
    let outcome = step_one(&mut stmt);
    match outcome {
        SoRowReady => {
            // Use the primitive accessor (column_int) instead of
            // SqlValue destructuring — the codebase has two SqlValue
            // types (l6_session.VNull vs differential.SvNull) and
            // direct variant pattern matching picks the wrong one.
            assert_eq(column_int(&stmt, 0), 42_i64);
        }
        _ => panic("expected SoRowReady"),
    }
}

// =============================================================================
// 2. column_int coercion through the L6 lifecycle
// =============================================================================

fn column_int_coercion() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 100".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let v = column_int(&stmt, 0);
    assert_eq(v, 100_i64);
}

// =============================================================================
// 3. column_text coercion
// =============================================================================

fn column_text_coercion() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 'verum'".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let t = column_text(&stmt, 0);
    assert_eq(t, "verum".clone());
}

// =============================================================================
// 4. column_type matches the SQL literal class
// =============================================================================

fn column_type_int_literal() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 7".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let t = column_type(&stmt, 0);
    assert(col_type_eq(&t, &CtInt));
}

fn column_type_text_literal() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 'x'".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let t = column_type(&stmt, 0);
    assert(col_type_eq(&t, &CtText));
}

fn column_type_null_literal() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT NULL".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let t = column_type(&stmt, 0);
    assert(col_type_eq(&t, &CtNull));
}

// =============================================================================
// 5. column_type_int: SQLite C constant codes (1/2/3/4/5)
// =============================================================================

fn column_type_int_constants() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 1".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    assert_eq(column_type_int(&stmt, 0), 1);  // SQLITE_INTEGER
}

// =============================================================================
// 6. column_text16 — UTF-16 round-trip for TEXT columns
// =============================================================================

fn column_text16_round_trip() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 'hi'".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let units = column_text16(&stmt, 0);
    // "hi" = 2 BMP code points → 2 UTF-16 code units.
    assert_eq(units.len(), 2);
    assert_eq(column_bytes16(&stmt, 0), 4);
}

// =============================================================================
// 7. column_bytes for TEXT
// =============================================================================

fn column_bytes_for_text() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 'hello'".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    assert_eq(column_bytes(&stmt, 0), 5);
}

// =============================================================================
// 8. step → done after exhausting the result
// =============================================================================

fn second_step_returns_done() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 1".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let first = step_one(&mut stmt);
    match first {
        SoRowReady => {},
        _ => panic("first step should be SoRowReady"),
    }
    let second = step_one(&mut stmt);
    match second {
        SoDone => {},
        _ => panic("second step should be SoDone"),
    }
}

// =============================================================================
// 9. reset re-runs the statement
// =============================================================================

fn reset_re_runs_statement() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 5".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let _ = step_one(&mut stmt);  // exhausted
    // Reset and step again — should produce the row a second time.
    let r = reset(&mut stmt, false);
    match r {
        Ok(_)  => {},
        Err(_) => panic("reset failed"),
    }
    let after_reset = step_one(&mut stmt);
    match after_reset {
        SoRowReady => {
            let v = column_int(&stmt, 0);
            assert_eq(v, 5_i64);
        }
        _ => panic("post-reset step should yield row again"),
    }
}

// =============================================================================
// 10. column_count for multi-column SELECT
// =============================================================================

fn column_count_multi() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 1, 'two', NULL, 3.14".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    assert_eq(column_count(&stmt), 4);
    let _ = step_one(&mut stmt);
    // Verify each column's type tag.
    assert(col_type_eq(&column_type(&stmt, 0), &CtInt));
    assert(col_type_eq(&column_type(&stmt, 1), &CtText));
    assert(col_type_eq(&column_type(&stmt, 2), &CtNull));
}

// =============================================================================
// 11. column accessors out-of-range guard
// =============================================================================

fn column_out_of_range_returns_null() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 1".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    // Index 100 is way out of range — must return null/zero/empty
    // (defensive default matching SQLite C API behaviour).
    // Use primitive accessors only — see note in
    // `prepare_step_literal_select` re: SqlValue type conflict.
    assert_eq(column_int(&stmt, 100), 0_i64);
    assert_eq(column_text(&stmt, 100), "".clone());
    // out-of-range column type should be CtNull.
    assert(col_type_eq(&column_type(&stmt, 100), &CtNull));
}

// =============================================================================
// 12. finalize releases the statement
// =============================================================================

fn finalize_releases_statement() {
    let db = open_or_panic();
    let mut stmt = match db.prepare(&"SELECT 99".clone()) {
        Ok(s)  => s,
        Err(_) => panic("prepare failed"),
    };
    let _ = step_one(&mut stmt);
    let r = finalize(&mut stmt);
    match r {
        Ok(_)  => {},
        Err(_) => panic("finalize failed"),
    }
}

fn main() {
    prepare_step_literal_select();
    column_int_coercion();
    column_text_coercion();
    column_type_int_literal();
    column_type_text_literal();
    column_type_null_literal();
    column_type_int_constants();
    column_text16_round_trip();
    column_bytes_for_text();
    second_step_returns_done();
    reset_re_runs_statement();
    column_count_multi();
    column_out_of_range_returns_null();
    finalize_releases_statement();
}
