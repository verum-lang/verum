// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, varint_encode_api, encoding
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.varint_encode_api.lengths.{
    max_value_for, encoded_length, decode_length_from_lead,
    max_length, min_length, length_of_zero,
};
mount base.{Bool, Int64};

fn test_bounds() {
    assert_eq(max_length(), 9);
    assert_eq(min_length(), 1);
    assert_eq(length_of_zero(), 1);
}

fn test_max_value_for_1_byte() {
    assert_eq(max_value_for(1), 127 as Int64);
}

fn test_max_value_for_2_bytes() {
    assert_eq(max_value_for(2), 16383 as Int64);
}

fn test_max_value_for_3_bytes() {
    assert_eq(max_value_for(3), 2097151 as Int64);
}

fn test_max_value_for_sentinel_cap() {
    // n>=9 returns Int64 max
    assert_eq(max_value_for(9), 0x7FFFFFFFFFFFFFFF as Int64);
    assert_eq(max_value_for(100), 0x7FFFFFFFFFFFFFFF as Int64);
}

fn test_encoded_length_boundaries() {
    assert_eq(encoded_length0_i64,   1);
    assert_eq(encoded_length127_i64, 1);
    assert_eq(encoded_length128_i64, 2);
    assert_eq(encoded_length16383_i64, 2);
    assert_eq(encoded_length16384_i64, 3);
    assert_eq(encoded_length2097151_i64, 3);
    assert_eq(encoded_length2097152_i64, 4);
}

fn test_encoded_length_negative_fills_nine_bytes() {
    assert_eq(encoded_length-1_i64, 9);
    assert_eq(encoded_length-0x7FFFFFFFFFFFFFFF_i64, 9);
}

fn test_decode_length_from_lead_ascii() {
    // high bit clear → 1 byte
    assert_eq(decode_length_from_lead(0x00 as u8), 1);
    assert_eq(decode_length_from_lead(0x7F as u8), 1);
    // high bit set → need more context
    assert_eq(decode_length_from_lead(0x80 as u8), -1);
    assert_eq(decode_length_from_lead(0xFF as u8), -1);
}

fn main() {
    test_bounds();
    test_max_value_for_1_byte();
    test_max_value_for_2_bytes();
    test_max_value_for_3_bytes();
    test_max_value_for_sentinel_cap();
    test_encoded_length_boundaries();
    test_encoded_length_negative_fills_nine_bytes();
    test_decode_length_from_lead_ascii();
}
