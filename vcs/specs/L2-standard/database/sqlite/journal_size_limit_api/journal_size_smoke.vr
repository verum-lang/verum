// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, journal_size_limit_api, pragmas
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.journal_size_limit_api.limit.{
    LimitMode, LmUnlimited, LmTruncate, LmCap,
    PostCommitAction, PcKeepAsIs, PcTruncateToZero, PcShrinkToCap,
    mode_name, action_name,
    from_pragma_value, to_pragma_value,
    truncates_after_commit, has_cap, allows,
    post_commit_action, default_value,
};
mount base.{Bool, Int64};

fn test_default_value() {
    assert_eq(default_value(), -1 as Int64);
}

fn test_from_pragma_value_round_trip() {
    match from_pragma_value-1_i64 { LmUnlimited => {}, _ => assert(false) }
    match from_pragma_value0_i64  { LmTruncate  => {}, _ => assert(false) }
    match from_pragma_value4096_i64 {
        LmCap(n) => assert_eq(n, 4096 as Int64),
        _ => assert(false),
    }
}

fn test_to_pragma_value() {
    assert_eq(to_pragma_value(&LmUnlimited), -1 as Int64);
    assert_eq(to_pragma_value(&LmTruncate),   0 as Int64);
    assert_eq(to_pragma_value(&LmCap(8192_i64)), 8192 as Int64);
}

fn test_mode_names() {
    assert(mode_name(&LmUnlimited)            == "unlimited".clone());
    assert(mode_name(&LmTruncate)             == "truncate".clone());
    assert(mode_name(&LmCap(1_i64))      == "cap".clone());
}

fn test_truncates_and_cap_helpers() {
    assert(truncates_after_commit(&LmTruncate));
    assert(!truncates_after_commit(&LmUnlimited));
    assert(!truncates_after_commit(&LmCap(1_i64)));
    assert(has_cap(&LmCap(99_i64)));
    assert(!has_cap(&LmTruncate));
}

fn test_allows_predicate() {
    assert(allows(&LmUnlimited, 1024 as Int64));
    assert(allows(&LmTruncate, 0 as Int64));
    assert(!allows(&LmTruncate, 1 as Int64));
    assert(allows(&LmCap(2048_i64), 2048 as Int64));
    assert(!allows(&LmCap(2048_i64), 4096 as Int64));
}

fn test_post_commit_action() {
    match post_commit_action(&LmUnlimited, 4096 as Int64) {
        PcKeepAsIs => {}, _ => assert(false),
    }
    match post_commit_action(&LmTruncate, 4096 as Int64) {
        PcTruncateToZero => {}, _ => assert(false),
    }
    match post_commit_action(&LmCap(2048_i64), 4096 as Int64) {
        PcShrinkToCap => {}, _ => assert(false),
    }
    match post_commit_action(&LmCap(8192_i64), 4096 as Int64) {
        PcKeepAsIs => {}, _ => assert(false),
    }
}

fn test_action_names() {
    assert(action_name(&PcKeepAsIs)       == "keep".clone());
    assert(action_name(&PcTruncateToZero) == "truncate".clone());
    assert(action_name(&PcShrinkToCap)    == "shrink".clone());
}

fn main() {
    test_default_value();
    test_from_pragma_value_round_trip();
    test_to_pragma_value();
    test_mode_names();
    test_truncates_and_cap_helpers();
    test_allows_predicate();
    test_post_commit_action();
    test_action_names();
}
