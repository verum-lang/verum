// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, cksm_file, fcntl, integrity, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.cksm_file.status.{
    CksmStatus, CsNotChecked, CsVerified, CsCorrupted,
    status_name, is_ok, corrupt_count,
};
mount core.database.sqlite.native.cksm_file.engine.{
    CksmEngine,
    SQLITE_FCNTL_CKSM_FILE, SQLITE_FCNTL_RESERVE_BYTES,
    new_engine,
};
mount collections.List;
mount base.{Bool};

fn test_fcntl_constants_match_c_header() {
    assert_eq(SQLITE_FCNTL_CKSM_FILE, 43);
    assert_eq(SQLITE_FCNTL_RESERVE_BYTES, 39);
}

fn test_new_engine_defaults() {
    let e = new_engine();
    assert_eq(e.reserve_bytes, 0);
    assert(!e.checksumming_enabled());
    match &e.status {
        CsNotChecked => {},
        _ => assert(false),
    }
}

fn test_set_reserve_bytes_ok() {
    let mut e = new_engine();
    assert(e.set_reserve_bytes(8));
    assert(e.checksumming_enabled());
}

fn test_set_reserve_bytes_rejects_out_of_range() {
    let mut e = new_engine();
    assert(!e.set_reserve_bytes(-1));
    assert(!e.set_reserve_bytes(256));
}

fn test_verify_all_good_returns_ok() {
    let mut e = new_engine();
    let _ = e.set_reserve_bytes(8);
    let empty: List<Int64> = List.new();
    assert_eq(e.sqlite3_file_control_cksm_file(100 as Int64, empty), 0);
    assert(is_ok(&e.status));
    assert_eq(e.verify_count, 1 as Int64);
}

fn test_verify_with_corrupt_pages_returns_corrupt() {
    let mut e = new_engine();
    let _ = e.set_reserve_bytes(8);
    let mut bad: List<Int64> = List.new();
    bad.push7_i64;
    bad.push19_i64;
    assert_eq(e.sqlite3_file_control_cksm_file(100 as Int64, bad), 11);  // SQLITE_CORRUPT
    assert(!is_ok(&e.status));
    assert_eq(corrupt_count(&e.status), 2);
}

fn test_status_names() {
    assert(status_name(&CsNotChecked) == "not-checked".clone());
    assert(status_name(&CsVerified100_i64) == "verified".clone());
    let corrupt: CksmStatus = CsCorrupted {
        corrupt_pages: List.new(),
        verified: 0 as Int64,
    };
    assert(status_name(&corrupt) == "corrupted".clone());
}

fn test_corrupt_count_zero_for_other_states() {
    assert_eq(corrupt_count(&CsNotChecked), 0);
    assert_eq(corrupt_count(&CsVerified99_i64), 0);
}

fn main() {
    test_fcntl_constants_match_c_header();
    test_new_engine_defaults();
    test_set_reserve_bytes_ok();
    test_set_reserve_bytes_rejects_out_of_range();
    test_verify_all_good_returns_ok();
    test_verify_with_corrupt_pages_returns_corrupt();
    test_status_names();
    test_corrupt_count_zero_for_other_states();
}
