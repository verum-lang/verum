// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, limit_clause_validator, sql
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.limit_clause_validator.clause.{
    SqlLimitClause,
    unbounded, resolve,
    is_unbounded, emits_zero_rows, applies_offset,
    int64_max, offset_overflows_after_n,
};
mount base.{Bool, Int64, Maybe};

fn test_unbounded_defaults() {
    let c = unbounded();
    assert(!c.has_limit);
    assert_eq(c.effective_limit, -1 as Int64);
    assert_eq(c.effective_offset, 0 as Int64);
    assert(is_unbounded(&c));
}

fn test_resolve_null_limit_is_unbounded() {
    let c = resolve(&Maybe.None, &Maybe.None);
    assert(is_unbounded(&c));
}

fn test_resolve_positive_limit() {
    let l: Maybe<Int64> = Maybe.Some(10 as Int64);
    let c = resolve(&l, &Maybe.None);
    assert(c.has_limit);
    assert_eq(c.effective_limit, 10 as Int64);
    assert(!is_unbounded(&c));
}

fn test_resolve_negative_limit_is_unbounded() {
    let l: Maybe<Int64> = Maybe.Some(-1 as Int64);
    let c = resolve(&l, &Maybe.None);
    assert(is_unbounded(&c));
    let l2: Maybe<Int64> = Maybe.Some(-100 as Int64);
    let c2 = resolve(&l2, &Maybe.None);
    assert(is_unbounded(&c2));
}

fn test_resolve_zero_limit_emits_zero_rows() {
    let l: Maybe<Int64> = Maybe.Some(0 as Int64);
    let c = resolve(&l, &Maybe.None);
    assert(c.has_limit);
    assert(emits_zero_rows(&c));
}

fn test_resolve_offset_positive_and_negative() {
    let o: Maybe<Int64> = Maybe.Some(5 as Int64);
    let l: Maybe<Int64> = Maybe.Some(10 as Int64);
    let c = resolve(&l, &o);
    assert_eq(c.effective_offset, 5 as Int64);
    assert(applies_offset(&c));
    let bad_o: Maybe<Int64> = Maybe.Some(-3 as Int64);
    let c2 = resolve(&l, &bad_o);
    assert_eq(c2.effective_offset, 0 as Int64);
    assert(!applies_offset(&c2));
}

fn test_int64_max() {
    assert_eq(int64_max(), 0x7FFFFFFFFFFFFFFF as Int64);
}

fn test_offset_overflow_detection() {
    let o: Maybe<Int64> = Maybe.Some(100 as Int64);
    let c = resolve(&Maybe.None, &o);
    assert(!offset_overflows_after_n(&c, 1000 as Int64));
    assert(offset_overflows_after_n(&c, int64_max()));
}

fn main() {
    test_unbounded_defaults();
    test_resolve_null_limit_is_unbounded();
    test_resolve_positive_limit();
    test_resolve_negative_limit_is_unbounded();
    test_resolve_zero_limit_emits_zero_rows();
    test_resolve_offset_positive_and_negative();
    test_int64_max();
    test_offset_overflow_detection();
}
