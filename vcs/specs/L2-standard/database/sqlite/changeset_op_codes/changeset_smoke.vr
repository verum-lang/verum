// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, changeset_op_codes, session
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.changeset_op_codes.row_op.{
    RowOp, RoInsert, RoUpdate, RoDelete,
    op_code, from_code, op_name, carries_new_row, carries_old_row,
};
mount core.database.sqlite.native.changeset_op_codes.conflict.{
    ConflictReason, CrData, CrNotFound, CrConflict, CrConstraint, CrForeignKey,
    reason_code, reason_from_code, reason_name,
    Disposition, DpOmit, DpReplace, DpAbort,
    disposition_code, disposition_from_code, disposition_name,
    default_disposition, is_terminal_disposition, allows_replace,
};
mount base.{Bool, Maybe};

fn test_row_op_codes() {
    assert_eq(op_code(&RoInsert), 18);
    assert_eq(op_code(&RoUpdate), 23);
    assert_eq(op_code(&RoDelete),  9);
}

fn test_row_op_round_trip() {
    match from_code(18) {
        Maybe.Some(o) => match &o { RoInsert => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(23) {
        Maybe.Some(o) => match &o { RoUpdate => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(9) {
        Maybe.Some(o) => match &o { RoDelete => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(5) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
}

fn test_row_op_names() {
    assert(op_name(&RoInsert) == "INSERT".clone());
    assert(op_name(&RoUpdate) == "UPDATE".clone());
    assert(op_name(&RoDelete) == "DELETE".clone());
}

fn test_row_op_new_old_payloads() {
    assert(carries_new_row(&RoInsert));
    assert(!carries_old_row(&RoInsert));
    assert(carries_new_row(&RoUpdate));
    assert(carries_old_row(&RoUpdate));
    assert(!carries_new_row(&RoDelete));
    assert(carries_old_row(&RoDelete));
}

fn test_conflict_reason_codes() {
    assert_eq(reason_code(&CrData),       1);
    assert_eq(reason_code(&CrNotFound),   2);
    assert_eq(reason_code(&CrConflict),   3);
    assert_eq(reason_code(&CrConstraint), 4);
    assert_eq(reason_code(&CrForeignKey), 5);
}

fn test_conflict_reason_round_trip() {
    match reason_from_code(3) {
        Maybe.Some(r) => match &r { CrConflict => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match reason_from_code(0) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
    match reason_from_code(6) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
}

fn test_disposition_codes() {
    assert_eq(disposition_code(&DpOmit),    0);
    assert_eq(disposition_code(&DpReplace), 1);
    assert_eq(disposition_code(&DpAbort),   2);
}

fn test_disposition_round_trip() {
    match disposition_from_code(0) {
        Maybe.Some(d) => match &d { DpOmit => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match disposition_from_code(2) {
        Maybe.Some(d) => match &d { DpAbort => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match disposition_from_code(9) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
}

fn test_default_is_abort() {
    match default_disposition() { DpAbort => {}, _ => assert(false) }
}

fn test_is_terminal_only_abort() {
    assert(is_terminal_disposition(&DpAbort));
    assert(!is_terminal_disposition(&DpOmit));
    assert(!is_terminal_disposition(&DpReplace));
}

fn test_allows_replace_per_reason() {
    assert(allows_replace(&CrData));
    assert(allows_replace(&CrConflict));
    assert(allows_replace(&CrConstraint));
    assert(!allows_replace(&CrNotFound));
    assert(!allows_replace(&CrForeignKey));
}

fn test_reason_names() {
    assert(reason_name(&CrForeignKey) == "FOREIGN_KEY".clone());
    assert(disposition_name(&DpReplace) == "REPLACE".clone());
}

fn main() {
    test_row_op_codes();
    test_row_op_round_trip();
    test_row_op_names();
    test_row_op_new_old_payloads();
    test_conflict_reason_codes();
    test_conflict_reason_round_trip();
    test_disposition_codes();
    test_disposition_round_trip();
    test_default_is_abort();
    test_is_terminal_only_abort();
    test_allows_replace_per_reason();
    test_reason_names();
}
