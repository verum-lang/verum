// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, vtab_constraint_ops, capi, vtab
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.vtab_constraint_ops.op.{
    ConstraintOp,
    CoEq, CoGt, CoLe, CoLt, CoGe, CoMatch, CoLike, CoGlob, CoRegexp,
    CoNe, CoIsNot, CoIsNotNull, CoIsNull, CoIs, CoLimit, CoOffset, CoFunction,
    op_code, from_code, op_name,
    is_equality, is_ordering, is_null_test, is_string_pattern, is_limit_offset,
    well_known_count,
};
mount base.{Bool, Maybe};

fn test_codes_match_sqlite_header() {
    assert_eq(op_code(&CoEq), 2);
    assert_eq(op_code(&CoGt), 4);
    assert_eq(op_code(&CoLe), 8);
    assert_eq(op_code(&CoLt), 16);
    assert_eq(op_code(&CoGe), 32);
    assert_eq(op_code(&CoMatch), 64);
    assert_eq(op_code(&CoLike), 65);
    assert_eq(op_code(&CoGlob), 66);
    assert_eq(op_code(&CoRegexp), 67);
    assert_eq(op_code(&CoNe), 68);
    assert_eq(op_code(&CoIsNot), 69);
    assert_eq(op_code(&CoIsNotNull), 70);
    assert_eq(op_code(&CoIsNull), 71);
    assert_eq(op_code(&CoIs), 72);
    assert_eq(op_code(&CoLimit), 73);
    assert_eq(op_code(&CoOffset), 74);
}

fn test_function_code_pass_through() {
    assert_eq(op_code(&CoFunction(150)), 150);
    assert_eq(op_code(&CoFunction(200)), 200);
}

fn test_round_trip_from_code() {
    match from_code(2) {
        Maybe.Some(o) => match &o { CoEq => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(64) {
        Maybe.Some(o) => match &o { CoMatch => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(74) {
        Maybe.Some(o) => match &o { CoOffset => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(151) {
        Maybe.Some(o) => match &o { CoFunction(n) => assert_eq(n, 151), _ => assert(false) },
        Maybe.None => assert(false),
    }
}

fn test_unknown_code_none() {
    match from_code(99) {
        Maybe.None => {},
        Maybe.Some(_) => assert(false),
    }
    match from_code(149) {
        Maybe.None => {},
        Maybe.Some(_) => assert(false),
    }
}

fn test_name_lookup() {
    assert(op_name(&CoEq) == "=".clone());
    assert(op_name(&CoMatch) == "MATCH".clone());
    assert(op_name(&CoLimit) == "LIMIT".clone());
    assert(op_name(&CoFunction(160)) == "FUNCTION".clone());
}

fn test_equality_set() {
    assert(is_equality(&CoEq));
    assert(is_equality(&CoIs));
    assert(!is_equality(&CoLt));
    assert(!is_equality(&CoNe));
}

fn test_ordering_set() {
    assert(is_ordering(&CoLt));
    assert(is_ordering(&CoLe));
    assert(is_ordering(&CoGt));
    assert(is_ordering(&CoGe));
    assert(!is_ordering(&CoEq));
    assert(!is_ordering(&CoMatch));
}

fn test_null_test_set() {
    assert(is_null_test(&CoIsNull));
    assert(is_null_test(&CoIsNotNull));
    assert(!is_null_test(&CoIs));
    assert(!is_null_test(&CoEq));
}

fn test_string_pattern_set() {
    assert(is_string_pattern(&CoLike));
    assert(is_string_pattern(&CoGlob));
    assert(is_string_pattern(&CoRegexp));
    assert(is_string_pattern(&CoMatch));
    assert(!is_string_pattern(&CoEq));
}

fn test_limit_offset_set() {
    assert(is_limit_offset(&CoLimit));
    assert(is_limit_offset(&CoOffset));
    assert(!is_limit_offset(&CoEq));
}

fn test_well_known_count_matches_table_size() {
    assert_eq(well_known_count(), 16);
}

fn main() {
    test_codes_match_sqlite_header();
    test_function_code_pass_through();
    test_round_trip_from_code();
    test_unknown_code_none();
    test_name_lookup();
    test_equality_set();
    test_ordering_set();
    test_null_test_set();
    test_string_pattern_set();
    test_limit_offset_set();
    test_well_known_count_matches_table_size();
}
