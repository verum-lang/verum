// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, jsonb_binary_format, json1
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.jsonb_binary_format.element.{
    ElementType,
    EtNull, EtTrue, EtFalse, EtInt, EtInt5, EtFloat, EtFloat5,
    EtText, EtTextJ, EtText5, EtTextRaw, EtArray, EtObject,
    tag_nibble, from_nibble, element_name,
    is_container, is_scalar, is_empty_payload, well_known_count,
};
mount core.database.sqlite.native.jsonb_binary_format.header.{
    Header,
    decode, encode_byte, len_class_for, header_bytes, is_consistent,
};
mount base.{Bool, Int64, Maybe};

fn test_tag_nibble_table() {
    assert_eq(tag_nibble(&EtNull),    0);
    assert_eq(tag_nibble(&EtTrue),    1);
    assert_eq(tag_nibble(&EtFalse),   2);
    assert_eq(tag_nibble(&EtInt),     3);
    assert_eq(tag_nibble(&EtInt5),    4);
    assert_eq(tag_nibble(&EtFloat),   5);
    assert_eq(tag_nibble(&EtFloat5),  6);
    assert_eq(tag_nibble(&EtText),    7);
    assert_eq(tag_nibble(&EtTextJ),   8);
    assert_eq(tag_nibble(&EtText5),   9);
    assert_eq(tag_nibble(&EtTextRaw), 10);
    assert_eq(tag_nibble(&EtArray),   11);
    assert_eq(tag_nibble(&EtObject),  12);
}

fn test_from_nibble_round_trip() {
    match from_nibble(3) {
        Maybe.Some(e) => match &e { EtInt => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_nibble(12) {
        Maybe.Some(e) => match &e { EtObject => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_nibble(13) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
    match from_nibble(-1) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
}

fn test_element_names() {
    assert(element_name(&EtNull)  == "null".clone());
    assert(element_name(&EtArray) == "array".clone());
    assert(element_name(&EtText5) == "text5".clone());
}

fn test_is_container_and_scalar() {
    assert(is_container(&EtArray));
    assert(is_container(&EtObject));
    assert(!is_container(&EtInt));
    assert(is_scalar(&EtNull));
    assert(is_scalar(&EtText));
    assert(!is_scalar(&EtArray));
}

fn test_is_empty_payload() {
    assert(is_empty_payload(&EtNull));
    assert(is_empty_payload(&EtTrue));
    assert(is_empty_payload(&EtFalse));
    assert(!is_empty_payload(&EtInt));
    assert(!is_empty_payload(&EtText));
}

fn test_well_known_count() {
    assert_eq(well_known_count(), 13);
}

fn test_header_decode_inline() {
    // low nibble 3 (EtInt), high nibble 5 → inline length 5
    let byte0 = (0x53 as u8);
    match decode(byte0) {
        Maybe.Some(h) => {
            match &h.element { EtInt => {}, _ => assert(false) }
            assert_eq(h.inline_payload_len, 5);
            assert_eq(h.ext_bytes, 0);
            assert_eq(header_bytes(&h), 1);
            assert(is_consistent(&h));
        },
        Maybe.None => assert(false),
    }
}

fn test_header_decode_extended_classes() {
    // high nibble 12 → 1 ext byte
    let h1 = decode((0xC7 as u8));   // EtText + ext1
    match h1 {
        Maybe.Some(h) => {
            assert_eq(h.inline_payload_len, 0);
            assert_eq(h.ext_bytes, 1);
        },
        Maybe.None => assert(false),
    }
    // high nibble 14 → 4 ext bytes
    let h2 = decode((0xE7 as u8));
    match h2 {
        Maybe.Some(h) => assert_eq(h.ext_bytes, 4),
        Maybe.None => assert(false),
    }
    // high nibble 15 → 8 ext bytes
    let h3 = decode((0xFB as u8));   // EtArray + ext8
    match h3 {
        Maybe.Some(h) => assert_eq(h.ext_bytes, 8),
        Maybe.None => assert(false),
    }
}

fn test_header_decode_unknown_nibble() {
    match decode((0x0D as u8)) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
}

fn test_encode_byte_round_trip() {
    let b = encode_byte(&EtInt, 5);
    assert_eq(b, 0x53 as u8);
    match decode(b) {
        Maybe.Some(h) => {
            match &h.element { EtInt => {}, _ => assert(false) }
            assert_eq(h.inline_payload_len, 5);
        },
        Maybe.None => assert(false),
    }
}

fn test_len_class_for_boundaries() {
    assert_eq(len_class_for(0 as Int64),    0);
    assert_eq(len_class_for(11 as Int64),   11);
    assert_eq(len_class_for(12 as Int64),   12);
    assert_eq(len_class_for(0xFF as Int64), 12);
    assert_eq(len_class_for(0x100 as Int64), 13);
    assert_eq(len_class_for(0x10000 as Int64), 14);
    assert_eq(len_class_for(0x100000000 as Int64), 15);
}

fn test_header_consistency_for_empty_payload_elements() {
    let bad = Header { element: EtNull, inline_payload_len: 5, ext_bytes: 0 };
    assert(!is_consistent(&bad));
    let good = Header { element: EtNull, inline_payload_len: 0, ext_bytes: 0 };
    assert(is_consistent(&good));
}

fn main() {
    test_tag_nibble_table();
    test_from_nibble_round_trip();
    test_element_names();
    test_is_container_and_scalar();
    test_is_empty_payload();
    test_well_known_count();
    test_header_decode_inline();
    test_header_decode_extended_classes();
    test_header_decode_unknown_nibble();
    test_encode_byte_round_trip();
    test_len_class_for_boundaries();
    test_header_consistency_for_empty_payload_elements();
}
