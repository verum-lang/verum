// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: sqlite, xfilecontrol_opcodes, capi
// @timeout: 5000
// @expected-exit: 0

mount core.database.sqlite.native.xfilecontrol_opcodes.op.{
    FcntlOp,
    FoLockstate, FoSizeHint, FoChunkSize, FoPersistWal, FoVfsname,
    FoPragma, FoBusyhandler, FoMmapSize, FoHasMoved, FoSync,
    FoCommitPhasetwo, FoWalBlock, FoDataVersion,
    FoBeginAtomicWrite, FoCommitAtomicWrite, FoRollbackAtomicWrite,
    FoCkptStart, FoCkptDone, FoCkpts,
    op_code, op_name, is_atomic_write, is_checkpoint_ctrl,
    from_code, well_known_count,
};
mount base.{Bool, Maybe};

fn test_selected_codes() {
    assert_eq(op_code(&FoLockstate), 1);
    assert_eq(op_code(&FoSizeHint),  5);
    assert_eq(op_code(&FoChunkSize), 6);
    assert_eq(op_code(&FoPersistWal), 10);
    assert_eq(op_code(&FoPragma),    14);
    assert_eq(op_code(&FoMmapSize),  18);
    assert_eq(op_code(&FoCommitPhasetwo), 22);
    assert_eq(op_code(&FoWalBlock),  24);
    assert_eq(op_code(&FoBeginAtomicWrite), 31);
    assert_eq(op_code(&FoDataVersion), 35);
    assert_eq(op_code(&FoCkptStart),  39);
}

fn test_op_names() {
    assert(op_name(&FoLockstate) == "LOCKSTATE".clone());
    assert(op_name(&FoSizeHint)  == "SIZE_HINT".clone());
    assert(op_name(&FoPersistWal) == "PERSIST_WAL".clone());
    assert(op_name(&FoBeginAtomicWrite) == "BEGIN_ATOMIC_WRITE".clone());
}

fn test_atomic_write_set() {
    assert(is_atomic_write(&FoBeginAtomicWrite));
    assert(is_atomic_write(&FoCommitAtomicWrite));
    assert(is_atomic_write(&FoRollbackAtomicWrite));
    assert(!is_atomic_write(&FoLockstate));
    assert(!is_atomic_write(&FoWalBlock));
}

fn test_checkpoint_ctrl_set() {
    assert(is_checkpoint_ctrl(&FoCkptStart));
    assert(is_checkpoint_ctrl(&FoCkptDone));
    assert(is_checkpoint_ctrl(&FoCkpts));
    assert(!is_checkpoint_ctrl(&FoSizeHint));
    assert(!is_checkpoint_ctrl(&FoWalBlock));
}

fn test_from_code_round_trip() {
    match from_code(1)  {
        Maybe.Some(o) => match &o { FoLockstate => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(14) {
        Maybe.Some(o) => match &o { FoPragma => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(31) {
        Maybe.Some(o) => match &o { FoBeginAtomicWrite => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
    match from_code(35) {
        Maybe.Some(o) => match &o { FoDataVersion => {}, _ => assert(false) },
        Maybe.None => assert(false),
    }
}

fn test_unknown_code_returns_none() {
    match from_code(0)  { Maybe.None => {}, Maybe.Some(_) => assert(false) }
    match from_code(17) { Maybe.None => {}, Maybe.Some(_) => assert(false) }    // unused slot
    match from_code(42) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
    match from_code(-1) { Maybe.None => {}, Maybe.Some(_) => assert(false) }
}

fn test_well_known_count() {
    assert_eq(well_known_count(), 40);
}

fn main() {
    test_selected_codes();
    test_op_names();
    test_atomic_write_set();
    test_checkpoint_ctrl_set();
    test_from_code_round_trip();
    test_unknown_code_returns_none();
    test_well_known_count();
}
