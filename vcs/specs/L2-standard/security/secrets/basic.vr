// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: security, secrets, vault, aws, gcp, secret-manager
// @timeout: 10000
// @expect: pass

// Secret-manager client API surface — Vault / AWS / GCP + SecretStore protocol.

mount core.security.secrets.{
    SecretStore, Secret, SecretError, SecretVersion, SecretReference,
    VaultClient, VaultConfig, VaultAuth, VaultError,
    AwsSecretsClient, AwsRegion, AwsCredentials,
    GcpSecretsClient, GcpAuth,
};
mount core.security.secrets.aws.{AwsCredentialProvider};
mount core.time.duration.{Duration};
mount core.time.instant.{Instant};

// SecretReference + version enum.
fn typecheck_reference() -> (SecretReference, SecretReference, SecretReference) {
    (
        SecretReference.latest("db/password".into()),
        SecretReference.at("db/password".into(), SecretVersion.Number(3)),
        SecretReference.at("db/password".into(), SecretVersion.Stage("AWSCURRENT".into())),
    )
}

// SecretError variants.
fn typecheck_errors() -> List<SecretError> {
    let mut xs: List<SecretError> = List.new();
    xs.push(SecretError.NotFound { name: "missing".into() });
    xs.push(SecretError.PermissionDenied("403".into()));
    xs.push(SecretError.Unavailable("502".into()));
    xs.push(SecretError.AuthenticationFailed("expired".into()));
    xs.push(SecretError.Malformed("bad json".into()));
    xs.push(SecretError.RateLimited { retry_after: Duration.from_secs(1) });
    xs.push(SecretError.VersionNotFound {
        name: "n".into(),
        version: SecretVersion.Number(42),
    });
    xs.push(SecretError.CryptoError("unwrap failed".into()));
    xs.push(SecretError.Backend("backend said no".into()));
    xs
}

// ==== Vault ====

fn typecheck_vault_config() -> VaultConfig {
    VaultConfig.new(
        "https://vault.internal:8200".into(),
        VaultAuth.AppRole {
            role_id: "rid".into(),
            secret_id: "sid".into(),
            mount_path: "approle".into(),
        },
    )
    .with_namespace("tenant-a".into())
    .with_kv_mount("secret".into())
    .with_tls_skip_verify(false)
}

async fn typecheck_vault_connect(config: VaultConfig) -> Result<VaultClient, VaultError> {
    VaultClient.connect(config).await
}

async fn typecheck_vault_kv_flow(c: &VaultClient) -> Result<(), VaultError> {
    let _ = c.kv_read(&"db/password".into(), SecretVersion.Latest).await?;
    let _ = c.kv_write(&"db/password".into(), b"new-pw").await?;
    let _ = c.kv_delete(&"db/password".into()).await?;
    let _ = c.kv_list(&"".into()).await?;
    Ok(())
}

async fn typecheck_vault_transit(c: &VaultClient) -> Result<(), VaultError> {
    let ct = c.transit_encrypt(&"payments-key".into(), b"plaintext").await?;
    let _pt = c.transit_decrypt(&"payments-key".into(), &ct).await?;
    Ok(())
}

async fn typecheck_vault_renew(c: &VaultClient) -> Result<Duration, VaultError> {
    c.renew_token().await
}

// ==== AWS ====

fn typecheck_aws_region() -> (AwsRegion, AwsRegion) {
    (AwsRegion.us_east_1(), AwsRegion.eu_west_1())
}

fn typecheck_aws_creds() -> AwsCredentials {
    AwsCredentials.new("AKIA…".into(), "secret-key".into())
        .with_session_token("token".into())
}

async fn typecheck_aws_connect(region: AwsRegion, provider: AwsCredentialProvider)
    -> Result<AwsSecretsClient, SecretError>
{
    AwsSecretsClient.connect(region, provider).await
}

async fn typecheck_aws_flow(c: &AwsSecretsClient) -> Result<(), SecretError> {
    let _ = c.get_secret_value(&SecretReference.latest("db/password".into())).await?;
    let _ = c.put_secret_value(&"db/password".into(), b"new").await?;
    c.delete_secret(&"db/password".into(), Duration.from_secs(7 * 86400)).await?;
    let _ = c.list_secrets(&"prod/".into()).await?;
    Ok(())
}

// ==== GCP ====

fn typecheck_gcp_auth() -> List<GcpAuth> {
    let mut xs: List<GcpAuth> = List.new();
    xs.push(GcpAuth.ApplicationDefault);
    xs.push(GcpAuth.ServiceAccountJson("/etc/gcp/sa.json".into()));
    xs.push(GcpAuth.Bearer("ya29.xxx".into()));
    xs
}

async fn typecheck_gcp_flow(project: Text, auth: GcpAuth) -> Result<(), SecretError> {
    let c = GcpSecretsClient.connect(project, auth).await?;
    let _ = c.access_secret_version(&SecretReference.latest("payments-key".into())).await?;
    let _ = c.add_secret_version(&"payments-key".into(), b"rotated").await?;
    c.delete_secret(&"payments-key".into()).await?;
    let _ = c.list_secrets(&"".into()).await?;
    Ok(())
}

// ==== Protocol dispatch ====
//
// Polymorphic use — the caller does not care which backend it's talking
// to. We verify that all three clients satisfy SecretStore by invoking
// their methods.

async fn typecheck_protocol_vault(store: &VaultClient) -> Result<Secret, SecretError> {
    store.get(&SecretReference.latest("x".into())).await
}

async fn typecheck_protocol_aws(store: &AwsSecretsClient) -> Result<Secret, SecretError> {
    store.get(&SecretReference.latest("x".into())).await
}

async fn typecheck_protocol_gcp(store: &GcpSecretsClient) -> Result<Secret, SecretError> {
    store.get(&SecretReference.latest("x".into())).await
}

fn main() {
    // Shape-only.
}
