// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: security, hmac, sha1, rfc-2202, otp, totp
// @timeout: 10000
// @expect: pass
//
// V8 (#247) — HMAC-SHA-1 known-answer test vectors from RFC 2202.
//
// Pre-#247 the OtpHash.Sha1 arm of hotp() returned
// OtpError.UnsupportedHash because no hmac_sha1 was wired in
// core.security.mac.hmac. This spec pins the new construction
// against RFC 2202's canonical KATs so the byte-for-byte
// agreement is checkable as a typecheck assertion.

mount core.security.mac.hmac.{hmac_sha1, HmacSha1};

fn hex_byte_eq(a: [Byte; 20], expected: List<Byte>) -> Bool {
    if expected.len() != 20 { return false; }
    let mut i: Int = 0;
    while i < 20 {
        if a[i] != expected[i] { return false; }
        i = i + 1;
    }
    true
}

fn exercise_rfc2202_test_case_1() {
    // RFC 2202 §3 Test Case 1
    //   key  = 0x0b * 20
    //   data = "Hi There"
    //   mac  = b617318655057264e28bc0b6fb378c8ef146be00
    let mut key: List<Byte> = [];
    let mut i: Int = 0;
    while i < 20 { key.push(0x0b_u8); i = i + 1; }
    let data: List<Byte> = [
        0x48_u8, 0x69_u8, 0x20_u8, 0x54_u8, 0x68_u8,
        0x65_u8, 0x72_u8, 0x65_u8,
    ];
    let expected: List<Byte> = [
        0xb6_u8, 0x17_u8, 0x31_u8, 0x86_u8, 0x55_u8,
        0x05_u8, 0x72_u8, 0x64_u8, 0xe2_u8, 0x8b_u8,
        0xc0_u8, 0xb6_u8, 0xfb_u8, 0x37_u8, 0x8c_u8,
        0x8e_u8, 0xf1_u8, 0x46_u8, 0xbe_u8, 0x00_u8,
    ];
    let mac = hmac_sha1(key.as_slice(), data.as_slice());
    assert(hex_byte_eq(mac, expected));
}

fn exercise_rfc2202_test_case_2() {
    // RFC 2202 §3 Test Case 2
    //   key  = "Jefe"
    //   data = "what do ya want for nothing?"
    //   mac  = effcdf6ae5eb2fa2d27416d5f184df9c259a7c79
    let key: List<Byte> = [0x4a_u8, 0x65_u8, 0x66_u8, 0x65_u8];
    let data: List<Byte> = [
        0x77, 0x68, 0x61, 0x74, 0x20, 0x64, 0x6f, 0x20,
        0x79, 0x61, 0x20, 0x77, 0x61, 0x6e, 0x74, 0x20,
        0x66, 0x6f, 0x72, 0x20, 0x6e, 0x6f, 0x74, 0x68,
        0x69, 0x6e, 0x67, 0x3f,
    ];
    let expected: List<Byte> = [
        0xef, 0xfc, 0xdf, 0x6a, 0xe5, 0xeb, 0x2f, 0xa2,
        0xd2, 0x74, 0x16, 0xd5, 0xf1, 0x84, 0xdf, 0x9c,
        0x25, 0x9a, 0x7c, 0x79,
    ];
    let mac = hmac_sha1(key.as_slice(), data.as_slice());
    assert(hex_byte_eq(mac, expected));
}

fn exercise_streaming_matches_oneshot() {
    // Update + finalize must produce same output as one-shot.
    let key: List<Byte> = [0xaa_u8; 20];
    let data: List<Byte> = [0xbb_u8, 0xcc_u8, 0xdd_u8];
    let oneshot = hmac_sha1(key.as_slice(), data.as_slice());

    let mut h = HmacSha1.new(key.as_slice());
    h.update(&[0xbb_u8][..]);
    h.update(&[0xcc_u8, 0xdd_u8][..]);
    let streamed = h.finalize();

    let mut i: Int = 0;
    while i < 20 {
        assert(oneshot[i] == streamed[i]);
        i = i + 1;
    }
}

fn main() {
    exercise_rfc2202_test_case_1();
    exercise_rfc2202_test_case_2();
    exercise_streaming_matches_oneshot();
}
