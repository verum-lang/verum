// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: x509, algorithm, signature, spki, rfc5280, rfc8017
// @timeout: 15000
// @expected-exit: 0

// RFC 5280 §4.1.1.2 AlgorithmIdentifier — SignatureAlg + PublicKeyAlg
// ADT surface coverage. Ensures every WebPKI-registered algorithm is
// constructible at the type level.

mount core.*;
mount core.collections.List;
mount core.security.x509.algorithm.{
    SignatureAlg, PublicKeyAlg, EcNamedCurve,
    RsaPssParams, RsaPssHash,
};
mount core.security.x509.spki.{
    SubjectPublicKey, Spki,
    RsaPublicKey, EcPublicKeyBytes,
    Ed25519PublicKeyBytes, Ed448PublicKeyBytes,
    X25519PublicKeyBytes, X448PublicKeyBytes,
};

fn signature_alg_variants_constructible() {
    let pss = RsaPssParams {
        hash:        RsaPssHash.Sha256Hash,
        salt_length: 32,
    };
    // Every WebPKI-registered variant round-trips through a match.
    let algos: List<SignatureAlg> = [
        SignatureAlg.Sha256WithRsa,
        SignatureAlg.Sha384WithRsa,
        SignatureAlg.Sha512WithRsa,
        SignatureAlg.RsaPss(pss),
        SignatureAlg.EcdsaWithSha256,
        SignatureAlg.EcdsaWithSha384,
        SignatureAlg.EcdsaWithSha512,
        SignatureAlg.Ed25519Sig,
        SignatureAlg.Ed448Sig,
    ];
    assert(algos.len() == 9);
}

fn public_key_alg_variants_constructible() {
    let algos: List<PublicKeyAlg> = [
        PublicKeyAlg.RsaEncryption,
        PublicKeyAlg.EcPublicKey(EcNamedCurve.P256),
        PublicKeyAlg.EcPublicKey(EcNamedCurve.P384),
        PublicKeyAlg.EcPublicKey(EcNamedCurve.P521),
        PublicKeyAlg.Ed25519Key,
        PublicKeyAlg.Ed448Key,
        PublicKeyAlg.X25519Key,
        PublicKeyAlg.X448Key,
    ];
    assert(algos.len() == 8);
}

fn subject_public_key_variants() {
    let rsa = RsaPublicKey {
        modulus:  [0x01_u8, 0x00_u8, 0x01_u8],
        exponent: [0x01_u8, 0x00_u8, 0x01_u8],
    };
    let ec = EcPublicKeyBytes { bytes: [0x04_u8] };
    let ed25519 = Ed25519PublicKeyBytes { bytes: [0_u8; 32] };
    let x25519  = X25519PublicKeyBytes  { bytes: [0_u8; 32] };

    let keys: List<SubjectPublicKey> = [
        SubjectPublicKey.Rsa(rsa),
        SubjectPublicKey.EcP256(ec),
        SubjectPublicKey.Ed25519(ed25519),
        SubjectPublicKey.X25519(x25519),
    ];
    assert(keys.len() == 4);
}

fn rsa_pss_hash_variants() {
    let hashes: List<RsaPssHash> = [
        RsaPssHash.Sha256Hash,
        RsaPssHash.Sha384Hash,
        RsaPssHash.Sha512Hash,
    ];
    assert(hashes.len() == 3);
}

@main
public fn main() -> Int {
    signature_alg_variants_constructible();
    public_key_alg_variants_constructible();
    subject_public_key_variants();
    rsa_pss_hash_variants();
    print("RFC 5280 + RFC 8017 AlgorithmIdentifier ADT surface verified");
    0
}
