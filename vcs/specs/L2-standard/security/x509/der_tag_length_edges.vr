// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: x509, der, encoding, edge_cases, rfc5280
// @timeout: 15000
// @expected-exit: 0

// RFC 5280 + ITU-T X.690 strict-DER edge cases: indefinite-length
// rejection, long-form length requires minimal encoding, redundant
// leading-zero length bytes rejected, truncation at tag or length
// produces UnexpectedEndOfInput.

mount core.*;
mount core.collections.List;
mount core.encoding.der.{DerReader, DerError, DerErrorKind};

fn indefinite_length_rejected() {
    // 0x30 = SEQUENCE, 0x80 = indefinite length form — banned in DER.
    let buf: List<Byte> = [0x30_u8, 0x80_u8, 0x00_u8, 0x00_u8];
    let mut r = DerReader.new(buf.as_slice());
    match r.read_tag_length() {
        Err(e) => match e.kind {
            DerErrorKind.MalformedDer => {},
            _ => panic("expected MalformedDer"),
        },
        _ => panic("indefinite length must be rejected"),
    }
}

fn non_minimal_long_form_length_rejected() {
    // 0x30 0x81 0x00 — length 0 encoded in long form with minimum 1
    // byte < 128 MUST use short form. BER allows; DER rejects.
    let buf: List<Byte> = [0x30_u8, 0x81_u8, 0x00_u8];
    let mut r = DerReader.new(buf.as_slice());
    match r.read_tag_length() {
        Err(e) => match e.kind {
            DerErrorKind.MalformedDer => {},
            _ => panic("expected MalformedDer"),
        },
        _ => panic("non-minimal long-form must be rejected"),
    }
}

fn leading_zero_length_byte_rejected() {
    // 0x30 0x82 0x00 0x05 — length 5 encoded with a leading zero
    // byte; DER requires no leading-zero padding (§8.1.3.5).
    let buf: List<Byte> = [0x30_u8, 0x82_u8, 0x00_u8, 0x05_u8];
    let mut r = DerReader.new(buf.as_slice());
    match r.read_tag_length() {
        Err(e) => match e.kind {
            DerErrorKind.MalformedDer => {},
            _ => panic("expected MalformedDer"),
        },
        _ => panic("leading-zero length byte must be rejected"),
    }
}

fn truncated_tag_byte_rejected() {
    let buf: List<Byte> = [];
    let mut r = DerReader.new(buf.as_slice());
    match r.read_tag_length() {
        Err(e) => match e.kind {
            DerErrorKind.UnexpectedEndOfInput => {},
            _ => panic("expected UnexpectedEndOfInput"),
        },
        _ => panic("empty buffer must return UnexpectedEndOfInput"),
    }
}

fn truncated_length_byte_rejected() {
    // 0x30 alone — no length byte.
    let buf: List<Byte> = [0x30_u8];
    let mut r = DerReader.new(buf.as_slice());
    match r.read_tag_length() {
        Err(e) => match e.kind {
            DerErrorKind.UnexpectedEndOfInput => {},
            _ => panic("expected UnexpectedEndOfInput"),
        },
        _ => panic("truncated length must return UnexpectedEndOfInput"),
    }
}

fn length_runs_past_buffer_rejected() {
    // 0x04 0x05 — OCTET STRING declaring 5-byte value but buffer has only 2 after header.
    let buf: List<Byte> = [0x04_u8, 0x05_u8, 0x00_u8, 0x00_u8];
    let mut r = DerReader.new(buf.as_slice());
    match r.read_tag_length() {
        Err(e) => match e.kind {
            DerErrorKind.UnexpectedEndOfInput => {},
            _ => panic("expected UnexpectedEndOfInput"),
        },
        _ => panic("length past buffer must return UnexpectedEndOfInput"),
    }
}

fn short_form_length_accepted() {
    // 0x04 0x03 0xAA 0xBB 0xCC — OCTET STRING with 3-byte value.
    let buf: List<Byte> = [0x04_u8, 0x03_u8, 0xAA_u8, 0xBB_u8, 0xCC_u8];
    let mut r = DerReader.new(buf.as_slice());
    let (_tag, len) = r.read_tag_length().unwrap();
    assert(len == 3);
}

@main
public fn main() -> Int {
    indefinite_length_rejected();
    non_minimal_long_form_length_rejected();
    leading_zero_length_byte_rejected();
    truncated_tag_byte_rejected();
    truncated_length_byte_rejected();
    length_runs_past_buffer_rejected();
    short_form_length_accepted();
    print("ITU-T X.690 / RFC 5280 DER strict-form edge cases verified");
    0
}
