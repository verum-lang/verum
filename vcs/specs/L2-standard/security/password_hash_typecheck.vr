// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: security, password-hash, pbkdf2, phc, typecheck
// @timeout: 10000
// @expect: pass

mount core.security.password_hash.{
    PasswordHasher, PasswordHashError,
    Pbkdf2Sha256Hasher,
    DEFAULT_PBKDF2_ITERATIONS, MIN_PBKDF2_ITERATIONS,
    DEFAULT_SALT_BYTES, DEFAULT_OUTPUT_BYTES,
    PBKDF2_SHA256_ID,
};
mount core.security.kdf.pbkdf2.{pbkdf2_hmac_sha256, Pbkdf2Error};
mount core.collections.List;

fn admit_via_protocol<H: PasswordHasher>(h: &H, pw: &[Byte]) -> Result<Text, PasswordHashError> {
    h.hash(pw)
}

fn exercise_hasher() -> Result<(), PasswordHashError> {
    let hasher = Pbkdf2Sha256Hasher.with_defaults();

    // Hash via the protocol.
    let pw: [Byte; 8] = [0x70_u8, 0x77_u8, 0x30_u8, 0x72_u8, 0x64_u8, 0x21_u8, 0x40_u8, 0x23_u8];
    let phc: Text = admit_via_protocol(&hasher, &pw[..])?;

    // Verify round-trip.
    let ok = hasher.verify(&pw[..], &phc)?;
    assert(ok);

    // Wrong password → false (still Ok, not error).
    let wrong: [Byte; 3] = [0x62_u8, 0x61_u8, 0x64_u8];
    let no = hasher.verify(&wrong[..], &phc)?;
    assert(!no);
    Ok(())
}

fn exercise_weak_rejected() {
    // Iteration count below floor is refused at hash time.
    let weak = Pbkdf2Sha256Hasher.with_defaults().with_iterations(1000_u32);
    let pw: [Byte; 3] = [1_u8, 2_u8, 3_u8];
    let result = weak.hash(&pw[..]);
    let _ = result;    // Expected WeakParameters.
}

fn exercise_pbkdf2_direct() -> Result<(), Pbkdf2Error> {
    let out = pbkdf2_hmac_sha256(
        b"passwd", b"salt", 1_u32, 32,
    )?;
    let _ = out.len();
    Ok(())
}

fn main() {
    let _ = exercise_hasher();
    exercise_weak_rejected();
    let _ = exercise_pbkdf2_direct();

    // Constants visible.
    let _: UInt32 = DEFAULT_PBKDF2_ITERATIONS;
    let _: UInt32 = MIN_PBKDF2_ITERATIONS;
    let _: Int = DEFAULT_SALT_BYTES;
    let _: Int = DEFAULT_OUTPUT_BYTES;
    let _: &str = PBKDF2_SHA256_ID;
}
