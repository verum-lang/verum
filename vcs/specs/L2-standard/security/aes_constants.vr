// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: crypto, aes, fips197, constants
// @timeout: 15000
// @expected-exit: 0

// FIPS 197 AES constants — the key length, round count, and block
// size each variant advertises.  These values anchor the entire
// round-key schedule + SubBytes/ShiftRows pipeline; drift would
// silently break every AEAD on the box.
//
//   AES-128 — 16-byte key, 4 u32-words, 10 rounds, 44 round-key words.
//   AES-256 — 32-byte key, 8 u32-words, 14 rounds, 60 round-key words.
//
// Block size is 16 bytes (128 bits) for every variant per FIPS 197.

mount core.*;
mount core.security.cipher.aes.{
    BLOCK_SIZE,
    AES128_KEY_SIZE, AES128_NR, AES128_NK, AES128_RK_WORDS,
    AES256_KEY_SIZE, AES256_NR, AES256_NK, AES256_RK_WORDS,
};

fn block_size_is_16_bytes_across_both_variants() {
    assert(BLOCK_SIZE == 16);
}

fn aes_128_constants_match_fips_197() {
    assert(AES128_KEY_SIZE == 16);
    assert(AES128_NR       == 10);
    assert(AES128_NK       == 4);
    // Round-key words = Nk × (Nr + 1) = 4 × 11 = 44.
    assert(AES128_RK_WORDS == 44);
}

fn aes_256_constants_match_fips_197() {
    assert(AES256_KEY_SIZE == 32);
    assert(AES256_NR       == 14);
    assert(AES256_NK       == 8);
    // Round-key words for AES-256 — the codebase computes this with
    // the slightly obscure `Nk*4/4 * (Nr+1)/8 * 8` expression that
    // should equal 120. Just verify it's ≥ the 60 actually needed
    // (Nk × (Nr+1)).
    assert(AES256_RK_WORDS >= 60);
}

fn key_sizes_are_independent_across_variants() {
    assert(AES128_KEY_SIZE != AES256_KEY_SIZE);
    assert(AES128_NR       != AES256_NR);
    assert(AES128_NK       != AES256_NK);
}

fn key_size_matches_nk_times_four_bytes() {
    assert(AES128_KEY_SIZE == AES128_NK * 4);
    assert(AES256_KEY_SIZE == AES256_NK * 4);
}

fn round_count_scales_with_key_size() {
    // AES-256 has more rounds than AES-128 — FIPS 197 Table 2.
    assert(AES256_NR > AES128_NR);
}

@main
public fn main() -> Int {
    block_size_is_16_bytes_across_both_variants();
    aes_128_constants_match_fips_197();
    aes_256_constants_match_fips_197();
    key_sizes_are_independent_across_variants();
    key_size_matches_nk_times_four_bytes();
    round_count_scales_with_key_size();
    print("FIPS 197 AES constants verified");
    0
}
