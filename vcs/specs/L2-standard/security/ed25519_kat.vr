// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: crypto, ed25519, rfc8032, kat
// @timeout: 15000
// @expected-exit: 0

// RFC 8032 §7.1 Ed25519 test vector 1:
//   seed     = 9d61b19deffd5a60ba844af492ec2cc44449c5697b326919703bac031cae7f60
//   pubkey   = d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a
//   message  = (empty)
//   sig      = e5564300c360ac729086e2cc806e828a84877f1eb8e5d974d873e06522490155
//              5fb8821590a33bacc61e39701cf9b46bd25bf5f0595bbe24655141438e7a100b

mount core.*;
mount core.collections.List;
mount core.security.ecc.ed25519.{Ed25519, Ed25519Error};

fn rfc_8032_test_vector_1_pubkey_and_sign() {
    let seed: [Byte; 32] = [
        0x9D_u8, 0x61_u8, 0xB1_u8, 0x9D_u8, 0xEF_u8, 0xFD_u8, 0x5A_u8, 0x60_u8,
        0xBA_u8, 0x84_u8, 0x4A_u8, 0xF4_u8, 0x92_u8, 0xEC_u8, 0x2C_u8, 0xC4_u8,
        0x44_u8, 0x49_u8, 0xC5_u8, 0x69_u8, 0x7B_u8, 0x32_u8, 0x69_u8, 0x19_u8,
        0x70_u8, 0x3B_u8, 0xAC_u8, 0x03_u8, 0x1C_u8, 0xAE_u8, 0x7F_u8, 0x60_u8,
    ];
    let expected_pk: [Byte; 32] = [
        0xD7_u8, 0x5A_u8, 0x98_u8, 0x01_u8, 0x82_u8, 0xB1_u8, 0x0A_u8, 0xB7_u8,
        0xD5_u8, 0x4B_u8, 0xFE_u8, 0xD3_u8, 0xC9_u8, 0x64_u8, 0x07_u8, 0x3A_u8,
        0x0E_u8, 0xE1_u8, 0x72_u8, 0xF3_u8, 0xDA_u8, 0xA6_u8, 0x23_u8, 0x25_u8,
        0xAF_u8, 0x02_u8, 0x1A_u8, 0x68_u8, 0xF7_u8, 0x07_u8, 0x51_u8, 0x1A_u8,
    ];
    let pk = Ed25519.public_key(&seed);
    let mut i: Int = 0;
    while i < 32 {
        assert(pk[i] == expected_pk[i]);
        i = i + 1;
    }

    // Deterministic signature over an empty message.
    let empty_msg: List<Byte> = [];
    let sig1 = Ed25519.sign(&seed, empty_msg.as_slice());
    let sig2 = Ed25519.sign(&seed, empty_msg.as_slice());
    let mut j: Int = 0;
    while j < 64 {
        assert(sig1[j] == sig2[j]);
        j = j + 1;
    }
}

fn sign_verify_roundtrip_nonempty() {
    let seed: [Byte; 32] = [0x77_u8; 32];
    let pk = Ed25519.public_key(&seed);
    let msg: List<Byte> = [
        0x48_u8, 0x65_u8, 0x6C_u8, 0x6C_u8, 0x6F_u8,     // "Hello"
    ];
    let sig = Ed25519.sign(&seed, msg.as_slice());
    match Ed25519.verify(&pk, msg.as_slice(), &sig) {
        Ok(()) => {},
        _ => panic("self-signature must verify"),
    }
}

fn verify_fails_on_tampered_message() {
    let seed: [Byte; 32] = [0x42_u8; 32];
    let pk = Ed25519.public_key(&seed);
    let msg: List<Byte> = [0x01_u8, 0x02_u8, 0x03_u8];
    let sig = Ed25519.sign(&seed, msg.as_slice());

    let tampered: List<Byte> = [0x01_u8, 0x02_u8, 0x04_u8];
    match Ed25519.verify(&pk, tampered.as_slice(), &sig) {
        Err(Ed25519Error.VerificationFailed) => {},
        _ => panic("tampered message must fail verify"),
    }
}

fn expanded_secret_key_layout_is_seed_plus_pk() {
    let seed: [Byte; 32] = [0x11_u8; 32];
    let pk = Ed25519.public_key(&seed);
    let exp = Ed25519.expanded_secret_key(&seed, &pk);
    // Layout: seed(32) || pk(32).
    let mut i: Int = 0;
    while i < 32 {
        assert(exp[i] == seed[i]);
        i = i + 1;
    }
    let mut j: Int = 0;
    while j < 32 {
        assert(exp[32 + j] == pk[j]);
        j = j + 1;
    }
}

@main
public fn main() -> Int {
    rfc_8032_test_vector_1_pubkey_and_sign();
    sign_verify_roundtrip_nonempty();
    verify_fails_on_tampered_message();
    expanded_secret_key_layout_is_seed_plus_pk();
    print("RFC 8032 §7.1 Ed25519 sign/verify KAT verified");
    0
}
