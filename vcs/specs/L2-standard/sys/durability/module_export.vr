// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: sys, durability, fsync, sqlite-gap-2
// @timeout: 5000
// @description: sys.durability re-exports full_fsync / sync_directory / pread / pwrite
//
// Spec: internal/specs/sqlite-native.md §3.2 Gap 2
//
// Ensures the dedicated durability module is wired and callable via
// the intent-named surface. Runtime behaviour is covered in
// sys/io/pread_pwrite_roundtrip.vr once the shared platform-open
// language issues are resolved.

mount core.*;
mount sys.durability.{full_fsync, sync_directory, pread, pwrite, FileDesc, OSError};
mount base.result.Result;

fn durability_surface_typecheck(fd: FileDesc) -> Result<(), OSError> {
    full_fsync(fd)
}

fn main() {
    print("durability_module_export typecheck ok");
}
