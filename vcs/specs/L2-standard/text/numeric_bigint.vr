// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: text, numeric, bigint, arbitrary-precision
// @timeout: 30000
//
// Type-check exercise for `core.text.numeric.bigint` — the
// arbitrary-precision signed integer module.  Validates every
// constructor / predicate / arithmetic op / comparison branch /
// render shape / parse error variant.

mount core.*;
mount base.{Result, Ok, Err, Text, Bool};
mount base.ordering.{Ordering, Less, Equal, Greater};
mount core.text.numeric.{
    BigInt, BigIntError,
    BIGINT_BASE, BIGINT_DIGITS_PER_CHUNK,
    parse_bigint,
};

fn check_constructors() {
    let z = BigInt.zero();
    assert(z.is_zero());
    assert(!z.is_negative());
    assert(!z.is_positive());

    let o = BigInt.one();
    assert(!o.is_zero());
    assert(o.is_positive());

    let n = BigInt.from_int(42);
    assert(n.is_positive());

    let neg = BigInt.from_int(-1234);
    assert(neg.is_negative());

    // Round-trip through to_int.
    match neg.to_int() {
        Some(v) => assert(v == -1234),
        None => assert(false),
    };
}

fn check_predicates() {
    let pos = BigInt.from_int(5);
    let neg = BigInt.from_int(-3);
    let zero = BigInt.zero();

    assert(pos.is_positive());
    assert(neg.is_negative());
    assert(zero.is_zero());

    let abs_neg = neg.abs();
    assert(abs_neg.is_positive());

    let neg2 = pos.neg();
    assert(neg2.is_negative());

    // neg(0) is canonical zero.
    let neg_zero = zero.neg();
    assert(neg_zero.is_zero());
}

fn check_arith() {
    let a = BigInt.from_int(100);
    let b = BigInt.from_int(50);
    let sum = a.add(&b);
    let expected = BigInt.from_int(150);
    assert(sum.eq(&expected));

    let diff = a.sub(&b);
    assert(diff.eq(&BigInt.from_int(50)));

    let prod = a.mul(&b);
    assert(prod.eq(&BigInt.from_int(5000)));

    // Mixed signs: -100 + 30 = -70.
    let neg_a = BigInt.from_int(-100);
    let small = BigInt.from_int(30);
    let mixed = neg_a.add(&small);
    assert(mixed.eq(&BigInt.from_int(-70)));

    // Negative * negative = positive.
    let neg_b = BigInt.from_int(-50);
    let pp = neg_a.mul(&neg_b);
    assert(pp.eq(&BigInt.from_int(5000)));

    // Subtracting larger from smaller flips the sign.
    let small_minus_big = b.sub(&a);
    assert(small_minus_big.eq(&BigInt.from_int(-50)));
}

fn check_arith_crosses_chunk_boundary() {
    // Magnitudes that cross BIGINT_BASE = 10^9 to exercise carry.
    let big = BigInt.from_int(999_999_999);  // = BIGINT_BASE - 1
    let one = BigInt.one();
    let plus_one = big.add(&one);
    // Result should be 10^9 = BIGINT_BASE — fits in a single i64
    // but spans 2 chunks in BigInt land (digits = [0, 1]).
    match plus_one.to_int() {
        Some(v) => assert(v == 1_000_000_000),
        None => assert(false),
    };
}

fn check_compare() {
    let a = BigInt.from_int(5);
    let b = BigInt.from_int(10);
    let c = BigInt.from_int(5);
    let neg = BigInt.from_int(-100);

    assert(matches_less(a.compare(&b)));
    assert(matches_equal(a.compare(&c)));
    assert(matches_greater(b.compare(&a)));

    // Negatives always less than positives (zero handled separately).
    assert(matches_less(neg.compare(&a)));

    // Negative ordering is REVERSED of magnitude.
    let big_neg = BigInt.from_int(-1_000_000);
    assert(matches_less(big_neg.compare(&neg)));
}

fn matches_equal(o: Ordering) -> Bool { match o { Equal => true, _ => false } }
fn matches_less(o: Ordering) -> Bool  { match o { Less => true,  _ => false } }
fn matches_greater(o: Ordering) -> Bool { match o { Greater => true, _ => false } }

fn check_render() {
    assert(BigInt.zero().to_text() == "0");
    assert(BigInt.from_int(42).to_text() == "42");
    assert(BigInt.from_int(-1234).to_text() == "-1234");

    // Large value spanning multiple chunks: 1_000_000_000_000 has
    // digits = [0, 1000] in base-10^9 ⇒ rendered as
    // "1000" + "000000000" = "1000000000000".
    let trillion = BigInt.from_int(1_000_000_000_000);
    assert(trillion.to_text() == "1000000000000");
}

fn check_parse() -> Result<Bool, BigIntError> {
    let a = parse_bigint(&"42".clone())?;
    assert(a.eq(&BigInt.from_int(42)));

    let b = parse_bigint(&"-1234".clone())?;
    assert(b.eq(&BigInt.from_int(-1234)));

    let c = parse_bigint(&"0".clone())?;
    assert(c.is_zero());

    // Large value beyond i64 range parses successfully.
    let big = parse_bigint(&"123456789012345678901234567890".clone())?;
    assert(!big.is_zero());
    // Round-trip through to_text.
    assert(big.to_text() == "123456789012345678901234567890");

    // Empty input ⇒ ParseEmpty.
    let empty = match parse_bigint(&"".clone()) {
        Err(BigIntError.ParseEmpty) => true,
        _ => false,
    };
    assert(empty);

    // Lone sign ⇒ ParseInvalidShape.
    let lone = match parse_bigint(&"-".clone()) {
        Err(BigIntError.ParseInvalidShape { reason: _ }) => true,
        _ => false,
    };
    assert(lone);

    // Garbage character mid-input ⇒ ParseInvalidChar.
    let garbage = match parse_bigint(&"12x34".clone()) {
        Err(BigIntError.ParseInvalidChar { byte_offset: _, byte: _ }) => true,
        _ => false,
    };
    assert(garbage);

    Ok(true)
}

fn check_constants() {
    assert(BIGINT_BASE == 1_000_000_000);
    assert(BIGINT_DIGITS_PER_CHUNK == 9);
}

fn check_div_rem() -> Result<Bool, BigIntError> {
    // Single-chunk divisor path.  100 / 7 = 14 rem 2.
    let a = BigInt.from_int(100);
    let b = BigInt.from_int(7);
    let (q, r) = a.div_rem(&b)?;
    assert(q.eq(&BigInt.from_int(14)));
    assert(r.eq(&BigInt.from_int(2)));

    // Sign rules: -100 / 7 = -14 rem -2 (truncated towards zero).
    let neg_a = BigInt.from_int(-100);
    let (q2, r2) = neg_a.div_rem(&b)?;
    assert(q2.eq(&BigInt.from_int(-14)));
    assert(r2.eq(&BigInt.from_int(-2)));

    // 100 / -7 = -14 rem 2.
    let neg_b = BigInt.from_int(-7);
    let (q3, r3) = a.div_rem(&neg_b)?;
    assert(q3.eq(&BigInt.from_int(-14)));
    assert(r3.eq(&BigInt.from_int(2)));

    // |a| < |b| ⇒ q=0, r=a.
    let small = BigInt.from_int(3);
    let big = BigInt.from_int(10);
    let (q4, r4) = small.div_rem(&big)?;
    assert(q4.is_zero());
    assert(r4.eq(&BigInt.from_int(3)));

    // Exact division: 1000 / 5 = 200 rem 0.
    let thou = BigInt.from_int(1000);
    let five = BigInt.from_int(5);
    let (q5, r5) = thou.div_rem(&five)?;
    assert(q5.eq(&BigInt.from_int(200)));
    assert(r5.is_zero());

    // div / rem convenience wrappers.
    let qq = a.div(&b)?;
    assert(qq.eq(&BigInt.from_int(14)));
    let rr = a.rem(&b)?;
    assert(rr.eq(&BigInt.from_int(2)));

    Ok(true)
}

fn check_div_by_zero() {
    let a = BigInt.from_int(10);
    let z = BigInt.zero();
    let result = match a.div_rem(&z) {
        Err(BigIntError.DivByZero) => true,
        _ => false,
    };
    assert(result);
}

fn check_karatsuba_threshold() -> Result<Bool, BigIntError> {
    // Build a magnitude that's well past KARATSUBA_THRESHOLD (32
    // chunks at base-10^9 = ~290 decimal digits).  Constructing
    // 10^400 forces the multiplier through the Karatsuba path.
    //
    // We verify CORRECTNESS — Karatsuba and schoolbook MUST agree.
    // Build 10^400 as a BigInt by parsing "1" + 400 zeros:
    let big_text = "1".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone()
        + "0000000000".clone()  + "0000000000".clone();
    let big = parse_bigint(&big_text)?;

    // (10^400)^2 = 10^800.  Build the expected text the same way.
    // Just verify by squaring and checking the result has the
    // right number of digits (1 followed by 800 zeros = 801 chars).
    let sq = big.mul(&big);
    let sq_text = sq.to_text();
    assert((sq_text.len() as Int) == 801);

    // Cross-check: 10^400 × 10^400 / 10^400 = 10^400 (round-trip).
    let div_back = sq.div(&big)?;
    assert(div_back.eq(&big));

    Ok(true)
}

fn check_div_multi_chunk() -> Result<Bool, BigIntError> {
    // Multi-chunk divisor path (Knuth Algorithm D).  Build a value
    // larger than 10^9 to force the multi-chunk branch.
    //
    // 5 × 10^18 = "5_000_000_000_000_000_000" — 19 decimal digits,
    // spans 3 chunks: [0, 0, 5].
    // 2 × 10^9 = "2_000_000_000" — 10 digits, spans 2 chunks: [0, 2].
    //
    // Quotient: 5×10^18 / 2×10^9 = 2.5×10^9 = "2_500_000_000".
    // (Truncated integer ⇒ exact since 5/2 = 2 rem 1; aligned at
    //  the 10^9 boundary that's 2_500_000_000 rem 0.)
    //
    // Remainder: 0.
    let big_dividend = match parse_bigint(&"5000000000000000000".clone()) {
        Ok(v)  => v,
        Err(_) => BigInt.zero(),
    };
    let big_divisor = match parse_bigint(&"2000000000".clone()) {
        Ok(v)  => v,
        Err(_) => BigInt.zero(),
    };
    let (q, r) = big_dividend.div_rem(&big_divisor)?;
    let expected_q = match parse_bigint(&"2500000000".clone()) {
        Ok(v)  => v,
        Err(_) => BigInt.zero(),
    };
    assert(q.eq(&expected_q));
    assert(r.is_zero());

    Ok(true)
}

fn main() {
    check_constructors();
    check_predicates();
    check_arith();
    check_arith_crosses_chunk_boundary();
    check_compare();
    check_render();
    let _ = check_parse();
    check_constants();
    let _ = check_div_rem();
    check_div_by_zero();
    let _ = check_div_multi_chunk();
    let _ = check_karatsuba_threshold();
}
