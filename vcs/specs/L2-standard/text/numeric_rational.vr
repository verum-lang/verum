// @test: typecheck-pass
// @level: L2
// @tier: 0
// @tags: text, numeric, rational, exact-arithmetic
// @timeout: 30000
//
// Type-check exercise for `core.text.numeric.rational` — exact-
// rational arithmetic over BigInt.  Validates the constructor /
// predicate / arithmetic / comparison / render / parse surface,
// including the canonical-form invariants (denominator > 0,
// gcd-reduced) and the exact-arithmetic guarantee
// (1/3 + 1/3 + 1/3 == 1).

mount core.*;
mount base.{Result, Ok, Err, Text, Bool};
mount base.ordering.{Ordering, Less, Equal, Greater};
mount core.text.numeric.{
    Rational, RationalError, parse_rational,
    BigInt,
    Decimal, BigDecimal, RoundingMode, HalfEven,
};

fn check_constructors() -> Result<Bool, RationalError> {
    let z = Rational.zero();
    assert(z.is_zero());

    let o = Rational.one();
    assert(o.is_positive());

    let n = Rational.from_int(42);
    assert(!n.is_zero());

    let half = Rational.from_parts(BigInt.one(), BigInt.from_int(2))?;
    assert(!half.is_zero());

    // Constructor with den=0 → DenominatorIsZero.
    let dzero = match Rational.from_parts(BigInt.one(), BigInt.zero()) {
        Err(RationalError.DenominatorIsZero) => true,
        _ => false,
    };
    assert(dzero);

    Ok(true)
}

fn check_canonicalisation() -> Result<Bool, RationalError> {
    // 4/8 reduces to 1/2.
    let r = Rational.from_parts(BigInt.from_int(4), BigInt.from_int(8))?;
    let half = Rational.from_parts(BigInt.one(), BigInt.from_int(2))?;
    assert(r.eq(&half));

    // -3/-6 reduces to 1/2 (sign normalisation).
    let r2 = Rational.from_parts(BigInt.from_int(-3), BigInt.from_int(-6))?;
    assert(r2.eq(&half));

    // 3/-6 reduces to -1/2.
    let neg_half = Rational.from_parts(BigInt.from_int(3), BigInt.from_int(-6))?;
    assert(neg_half.is_negative());

    // 0/N is canonical zero (den=1).
    let zero_via_div = Rational.from_parts(BigInt.zero(), BigInt.from_int(99))?;
    assert(zero_via_div.is_zero());
    Ok(true)
}

fn check_predicates() -> Result<Bool, RationalError> {
    let pos = Rational.from_int(5);
    let neg = Rational.from_int(-3);

    let abs_neg = neg.abs();
    assert(abs_neg.is_positive());

    let neg2 = pos.neg();
    assert(neg2.is_negative());

    // Reciprocal: 2/3 → 3/2.
    let two_thirds = Rational.from_parts(BigInt.from_int(2), BigInt.from_int(3))?;
    let recip = two_thirds.reciprocal()?;
    let three_halves = Rational.from_parts(BigInt.from_int(3), BigInt.from_int(2))?;
    assert(recip.eq(&three_halves));

    // Reciprocal of zero → DenominatorIsZero.
    let zero = Rational.zero();
    let bad = match zero.reciprocal() {
        Err(RationalError.DenominatorIsZero) => true,
        _ => false,
    };
    assert(bad);

    Ok(true)
}

fn check_exact_arithmetic() -> Result<Bool, RationalError> {
    // The classic test: 1/3 + 1/3 + 1/3 == 1, exactly.  Decimal /
    // BigDecimal at any finite precision can't represent this
    // without rounding error.  Rational nails it.
    let third = Rational.from_parts(BigInt.one(), BigInt.from_int(3))?;
    let two_thirds = third.add(&third);
    let three_thirds = two_thirds.add(&third);
    assert(three_thirds.eq(&Rational.one()));

    // Exact subtraction: 1/2 - 1/4 = 1/4.
    let half = Rational.from_parts(BigInt.one(), BigInt.from_int(2))?;
    let quarter = Rational.from_parts(BigInt.one(), BigInt.from_int(4))?;
    assert(half.sub(&quarter).eq(&quarter));

    // Exact multiplication: 2/3 * 9/8 = 18/24 = 3/4.
    let a = Rational.from_parts(BigInt.from_int(2), BigInt.from_int(3))?;
    let b = Rational.from_parts(BigInt.from_int(9), BigInt.from_int(8))?;
    let three_quarters = Rational.from_parts(BigInt.from_int(3), BigInt.from_int(4))?;
    assert(a.mul(&b).eq(&three_quarters));

    // Exact division: 3/4 / 1/2 = 6/4 = 3/2.
    let three_halves = Rational.from_parts(BigInt.from_int(3), BigInt.from_int(2))?;
    assert(three_quarters.div(&half)?.eq(&three_halves));

    Ok(true)
}

fn check_compare() -> Result<Bool, RationalError> {
    let a = Rational.from_parts(BigInt.one(), BigInt.from_int(2))?;  // 1/2
    let b = Rational.from_parts(BigInt.one(), BigInt.from_int(3))?;  // 1/3
    // 1/2 > 1/3 (cross-mult: 1*3 > 1*2 ⇒ 3 > 2 ✓)
    assert(matches_greater(a.compare(&b)));
    assert(matches_less(b.compare(&a)));

    let c = Rational.from_parts(BigInt.from_int(2), BigInt.from_int(4))?;  // 2/4 = 1/2
    assert(matches_equal(a.compare(&c)));
    assert(a.eq(&c));

    Ok(true)
}

fn matches_equal(o: Ordering) -> Bool { match o { Equal => true, _ => false } }
fn matches_less(o: Ordering)  -> Bool { match o { Less => true,  _ => false } }
fn matches_greater(o: Ordering) -> Bool { match o { Greater => true, _ => false } }

fn check_render() -> Result<Bool, RationalError> {
    assert(Rational.zero().to_text() == "0");
    assert(Rational.one().to_text() == "1");
    assert(Rational.from_int(42).to_text() == "42");

    let two_thirds = Rational.from_parts(BigInt.from_int(2), BigInt.from_int(3))?;
    assert(two_thirds.to_text() == "2/3");

    let neg_half = Rational.from_parts(BigInt.from_int(-1), BigInt.from_int(2))?;
    assert(neg_half.to_text() == "-1/2");

    Ok(true)
}

fn check_parse() -> Result<Bool, RationalError> {
    // Slash form.
    let a = parse_rational(&"3/4".clone())?;
    let three_quarters = Rational.from_parts(BigInt.from_int(3), BigInt.from_int(4))?;
    assert(a.eq(&three_quarters));

    // Negative slash form.
    let b = parse_rational(&"-22/7".clone())?;
    assert(b.is_negative());

    // Plain integer.
    let c = parse_rational(&"42".clone())?;
    assert(c.eq(&Rational.from_int(42)));

    // Decimal text → Rational via BigDecimal.
    let d = parse_rational(&"1.5".clone())?;
    let three_halves = Rational.from_parts(BigInt.from_int(3), BigInt.from_int(2))?;
    assert(d.eq(&three_halves));

    // x/0 → DenominatorIsZero.
    let dzero = match parse_rational(&"5/0".clone()) {
        Err(RationalError.DenominatorIsZero) => true,
        _ => false,
    };
    assert(dzero);

    // Empty input → ParseEmpty.
    let empty = match parse_rational(&"".clone()) {
        Err(RationalError.ParseEmpty) => true,
        _ => false,
    };
    assert(empty);

    Ok(true)
}

fn check_interop() -> Result<Bool, RationalError> {
    // Rational from Decimal: Decimal{c=125, s=2} = 1.25 = 125/100 → 5/4.
    let d = match Decimal.from_parts(125, 2) {
        Ok(v)  => v,
        Err(_) => Decimal.zero(),
    };
    let r = Rational.from_decimal(&d);
    let five_fourths = Rational.from_parts(BigInt.from_int(5), BigInt.from_int(4))?;
    assert(r.eq(&five_fourths));

    // Approximate: 1/3 ≈ 0.333 at precision=3 HalfEven.
    let third = Rational.from_parts(BigInt.one(), BigInt.from_int(3))?;
    match third.to_bigdecimal(3, HalfEven) {
        Ok(bd) => assert(bd.to_text() == "0.333"),
        Err(_) => assert(false),
    }

    Ok(true)
}

fn main() {
    let _ = check_constructors();
    let _ = check_canonicalisation();
    let _ = check_predicates();
    let _ = check_exact_arithmetic();
    let _ = check_compare();
    let _ = check_render();
    let _ = check_parse();
    let _ = check_interop();
}
