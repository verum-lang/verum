// @test: differential
// @tier: 0
// @level: L2
// @tags: differential, complex, integration, tier-equivalence
// @timeout: 60000
// @expected-exit: 0

/// L2-Standard: Complex Programs
///
/// This test exercises complex programs that combine multiple language
/// features to verify tier equivalence in realistic scenarios.

// =============================================================================
// Stack using flat struct (4 elements)
// =============================================================================

type Stack4 is {
    a0: Int, a1: Int, a2: Int, a3: Int,
    top: Int
};

fn stack_new() -> Stack4 {
    Stack4 { a0: 0, a1: 0, a2: 0, a3: 0, top: 0 }
}

fn stack_push(s: Stack4, v: Int) -> Stack4 {
    let idx = s.top;
    Stack4 {
        a0: if idx == 0 { v } else { s.a0 },
        a1: if idx == 1 { v } else { s.a1 },
        a2: if idx == 2 { v } else { s.a2 },
        a3: if idx == 3 { v } else { s.a3 },
        top: idx + 1
    }
}

fn stack_peek(s: Stack4) -> Int {
    let idx = s.top - 1;
    if idx == 0 { s.a0 } else if idx == 1 { s.a1 }
    else if idx == 2 { s.a2 } else { s.a3 }
}

fn stack_pop(s: Stack4) -> Stack4 {
    Stack4 {
        a0: s.a0, a1: s.a1, a2: s.a2, a3: s.a3,
        top: s.top - 1
    }
}

fn stack_is_empty(s: Stack4) -> Bool {
    s.top == 0
}

fn stack_size(s: Stack4) -> Int {
    s.top
}

// =============================================================================
// Simple sorting: selection sort on 4 elements
// =============================================================================

type Quad is { a: Int, b: Int, c: Int, d: Int };

fn quad_get(q: Quad, i: Int) -> Int {
    if i == 0 { q.a } else if i == 1 { q.b }
    else if i == 2 { q.c } else { q.d }
}

fn quad_set(q: Quad, i: Int, v: Int) -> Quad {
    Quad {
        a: if i == 0 { v } else { q.a },
        b: if i == 1 { v } else { q.b },
        c: if i == 2 { v } else { q.c },
        d: if i == 3 { v } else { q.d }
    }
}

fn quad_swap(q: Quad, i: Int, j: Int) -> Quad {
    let vi = quad_get(q, i);
    let vj = quad_get(q, j);
    let q2 = quad_set(q, i, vj);
    quad_set(q2, j, vi)
}

fn sort4(q: Quad) -> Quad {
    let mut arr = q;
    // Selection sort on 4 elements
    let mut i = 0;
    while i < 4 {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < 4 {
            if quad_get(arr, j) < quad_get(arr, min_idx) {
                min_idx = j;
            }
            j = j + 1;
        }
        if min_idx != i {
            arr = quad_swap(arr, i, min_idx);
        }
        i = i + 1;
    }
    arr
}

// =============================================================================
// Algorithms
// =============================================================================

fn is_prime(n: Int) -> Bool {
    if n < 2 { false }
    else if n < 4 { true }
    else if n % 2 == 0 { false }
    else {
        let mut i = 3;
        let mut result = true;
        while i * i <= n {
            if n % i == 0 {
                result = false;
            }
            i = i + 2;
        }
        result
    }
}

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 { a } else { gcd(b, a % b) }
}

fn lcm(a: Int, b: Int) -> Int {
    (a * b) / gcd(a, b)
}

fn digit_sum(n: Int) -> Int {
    let mut val = n;
    if val < 0 { val = 0 - val; }
    let mut s = 0;
    while val > 0 {
        s = s + val % 10;
        val = val / 10;
    }
    s
}

fn collatz_steps(n: Int) -> Int {
    let mut val = n;
    let mut steps = 0;
    while val != 1 {
        if val % 2 == 0 {
            val = val / 2;
        } else {
            val = val * 3 + 1;
        }
        steps = steps + 1;
    }
    steps
}

// =============================================================================
// State machine using integers
// =============================================================================

fn state_transition(state: Int, event: Int) -> Int {
    if state == 0 && event == 0 { 1 }
    else if state == 1 && event == 1 { 2 }
    else if state == 1 && event == 3 { 3 }
    else if state == 1 && event == 4 { 4 }
    else if state == 2 && event == 2 { 1 }
    else if state == 2 && event == 5 { 0 }
    else if state == 3 && event == 5 { 0 }
    else if state == 4 && event == 5 { 0 }
    else { state }
}

// =============================================================================
// Higher-order combining
// =============================================================================

fn apply(f: fn(Int) -> Int, x: Int) -> Int { f(x) }

fn twice(f: fn(Int) -> Int, x: Int) -> Int { f(f(x)) }

fn test_sorting() -> Int {
    let q = Quad { a: 64, b: 12, c: 90, d: 5 };
    let sorted = sort4(q);
    assert_eq(quad_get(sorted, 0), 5);
    assert_eq(quad_get(sorted, 1), 12);
    assert_eq(quad_get(sorted, 2), 64);
    assert_eq(quad_get(sorted, 3), 90);
    let orig_sum = q.a + q.b + q.c + q.d;
    let sort_sum = sorted.a + sorted.b + sorted.c + sorted.d;
    assert_eq(orig_sum, sort_sum);
    let q2 = Quad { a: 1, b: 2, c: 3, d: 4 };
    let s2 = sort4(q2);
    assert_eq(quad_get(s2, 0), 1);
    assert_eq(quad_get(s2, 3), 4);
    let q3 = Quad { a: 4, b: 3, c: 2, d: 1 };
    let s3 = sort4(q3);
    assert_eq(quad_get(s3, 0), 1);
    assert_eq(quad_get(s3, 3), 4);
    0
}

fn test_stack() -> Int {
    let mut s = stack_new();
    s = stack_push(s, 10);
    s = stack_push(s, 20);
    s = stack_push(s, 30);
    assert_eq(stack_size(s), 3);
    assert_eq(stack_peek(s), 30);
    s = stack_pop(s);
    assert_eq(stack_peek(s), 20);
    assert_eq(stack_size(s), 2);
    s = stack_pop(s);
    s = stack_pop(s);
    assert(stack_is_empty(s));
    let mut st = stack_new();
    let mut i = 1;
    while i <= 4 {
        st = stack_push(st, i);
        i = i + 1;
    }
    let mut pop_sum = 0;
    while !stack_is_empty(st) {
        pop_sum = pop_sum + stack_peek(st);
        st = stack_pop(st);
    }
    assert_eq(pop_sum, 10);
    0
}

fn test_algorithms() -> Int {
    assert(is_prime(2));
    assert(is_prime(3));
    assert(!is_prime(4));
    assert(is_prime(5));
    assert(is_prime(7));
    assert(!is_prime(9));
    assert(is_prime(11));
    assert(is_prime(97));
    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(17, 13), 1);
    assert_eq(lcm(12, 18), 36);
    assert_eq(lcm(4, 6), 12);
    assert_eq(digit_sum(12345), 15);
    assert_eq(digit_sum(999), 27);
    assert_eq(collatz_steps(1), 0);
    assert_eq(collatz_steps(6), 8);
    assert_eq(collatz_steps(27), 111);
    0
}

fn test_state_machine() -> Int {
    let mut state = 0;
    state = state_transition(state, 0);
    assert_eq(state, 1);
    state = state_transition(state, 1);
    assert_eq(state, 2);
    state = state_transition(state, 2);
    assert_eq(state, 1);
    state = state_transition(state, 3);
    assert_eq(state, 3);
    state = state_transition(state, 5);
    assert_eq(state, 0);
    state = state_transition(state, 0);
    state = state_transition(state, 4);
    assert_eq(state, 4);
    state = state_transition(state, 5);
    assert_eq(state, 0);
    assert_eq(state_transition(0, 1), 0);
    assert_eq(state_transition(3, 0), 3);
    0
}

fn test_higher_order() -> Int {
    let double = |x: Int| -> Int { x * 2 };
    let inc = |x: Int| -> Int { x + 1 };
    assert_eq(apply(double, 21), 42);
    assert_eq(twice(double, 3), 12);
    assert_eq(twice(inc, 10), 12);
    0
}

fn main() -> Int {
    test_sorting();
    test_stack();
    test_algorithms();
    test_state_machine();
    test_higher_order();
    print("PASS: complex_programs");
    0
}
