// @test: differential
// @tier: 0
// @level: L2
// @tags: differential, recursion, tier-equivalence
// @timeout: 30000
// @expected-exit: 0

/// L2-Standard: Recursion
///
/// This test verifies that recursive patterns produce identical
/// results in interpreter and AOT, including tail recursion optimization.

@allow(unbounded_recursion)
fn factorial(n: Int) -> Int {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

@allow(unbounded_recursion)
fn fib(n: Int) -> Int {
    if n <= 1 { n } else { fib(n - 1) + fib(n - 2) }
}

@allow(unbounded_recursion)
fn sum_to(n: Int) -> Int {
    if n <= 0 { 0 } else { n + sum_to(n - 1) }
}

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 { a } else { gcd(b, a % b) }
}

@allow(unbounded_recursion)
fn power_fast(base: Int, exp: Int) -> Int {
    if exp == 0 {
        1
    } else if exp % 2 == 0 {
        let half = power_fast(base, exp / 2);
        half * half
    } else {
        base * power_fast(base, exp - 1)
    }
}

// === Tail-recursive variants ===

@allow(unbounded_recursion)
fn tail_sum(n: Int, acc: Int) -> Int {
    if n <= 0 { acc } else { tail_sum(n - 1, acc + n) }
}

@allow(unbounded_recursion)
fn tail_factorial(n: Int, acc: Int) -> Int {
    if n <= 1 { acc } else { tail_factorial(n - 1, acc * n) }
}

@allow(unbounded_recursion)
fn tail_fib(n: Int, a: Int, b: Int) -> Int {
    if n == 0 { a }
    else if n == 1 { b }
    else { tail_fib(n - 1, b, a + b) }
}

// === Mutual recursion ===

@allow(unbounded_recursion)
fn is_even_rec(n: Int) -> Bool {
    if n == 0 { true } else { is_odd_rec(n - 1) }
}

@allow(unbounded_recursion)
fn is_odd_rec(n: Int) -> Bool {
    if n == 0 { false } else { is_even_rec(n - 1) }
}

@allow(unbounded_recursion)
fn alt_sum_a(n: Int) -> Int {
    if n == 0 { 0 } else { n + alt_sum_b(n - 1) }
}

@allow(unbounded_recursion)
fn alt_sum_b(n: Int) -> Int {
    if n == 0 { 0 } else { 0 - n + alt_sum_a(n - 1) }
}

// === Tree recursion ===

@allow(unbounded_recursion)
fn combinations(n: Int, k: Int) -> Int {
    if k == 0 || k == n { 1 }
    else { combinations(n - 1, k - 1) + combinations(n - 1, k) }
}

@allow(unbounded_recursion)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 { n + 1 }
    else if n == 0 { ackermann(m - 1, 1) }
    else { ackermann(m - 1, ackermann(m, n - 1)) }
}

// === Numeric recursion ===

@allow(unbounded_recursion)
fn digit_sum(n: Int) -> Int {
    if n < 0 { digit_sum(-n) }
    else if n < 10 { n }
    else { n % 10 + digit_sum(n / 10) }
}

@allow(unbounded_recursion)
fn digital_root(n: Int) -> Int {
    if n < 10 { n }
    else { digital_root(digit_sum(n)) }
}

@allow(unbounded_recursion)
fn count_down(n: Int) -> Int {
    // Returns sum n + (n-1) + ... + 1 + 0
    if n <= 0 { 0 } else { n + count_down(n - 1) }
}

fn main() -> Int {
    // === Basic recursion ===
    assert_eq(factorial(0), 1);
    assert_eq(factorial(1), 1);
    assert_eq(factorial(5), 120);
    assert_eq(factorial(10), 3628800);
    assert_eq(factorial(12), 479001600);

    assert_eq(fib(0), 0);
    assert_eq(fib(1), 1);
    assert_eq(fib(2), 1);
    assert_eq(fib(5), 5);
    assert_eq(fib(10), 55);
    assert_eq(fib(15), 610);
    assert_eq(fib(20), 6765);

    assert_eq(sum_to(0), 0);
    assert_eq(sum_to(1), 1);
    assert_eq(sum_to(10), 55);
    assert_eq(sum_to(100), 5050);

    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 25), 25);
    assert_eq(gcd(17, 13), 1);
    assert_eq(gcd(1071, 462), 21);

    assert_eq(power_fast(2, 10), 1024);
    assert_eq(power_fast(3, 5), 243);
    assert_eq(power_fast(5, 4), 625);
    assert_eq(power_fast(10, 3), 1000);

    // === Tail recursion ===
    assert_eq(tail_sum(100, 0), 5050);
    assert_eq(tail_sum(1000, 0), 500500);

    assert_eq(tail_factorial(10, 1), 3628800);
    assert_eq(tail_factorial(15, 1), 1307674368000);
    assert_eq(tail_factorial(20, 1), 2432902008176640000);

    assert_eq(tail_fib(10, 0, 1), 55);
    assert_eq(tail_fib(20, 0, 1), 6765);
    assert_eq(tail_fib(30, 0, 1), 832040);
    assert_eq(tail_fib(40, 0, 1), 102334155);

    // === Mutual recursion ===
    assert(is_even_rec(0));
    assert(!is_even_rec(1));
    assert(is_even_rec(42));
    assert(!is_even_rec(99));

    assert(!is_odd_rec(0));
    assert(is_odd_rec(1));
    assert(!is_odd_rec(42));
    assert(is_odd_rec(99));

    assert_eq(alt_sum_a(10), 5);
    assert_eq(alt_sum_b(10), -5);

    // === Tree recursion ===
    assert_eq(combinations(5, 2), 10);
    assert_eq(combinations(10, 3), 120);
    assert_eq(combinations(7, 4), 35);
    assert_eq(combinations(6, 6), 1);
    assert_eq(combinations(6, 0), 1);

    assert_eq(ackermann(0, 0), 1);
    assert_eq(ackermann(0, 5), 6);
    assert_eq(ackermann(1, 3), 5);
    assert_eq(ackermann(2, 3), 9);
    assert_eq(ackermann(3, 2), 29);
    assert_eq(ackermann(3, 3), 61);

    // === Numeric recursion ===
    assert_eq(digit_sum(12345), 15);
    assert_eq(digit_sum(0), 0);
    assert_eq(digit_sum(9), 9);
    assert_eq(digit_sum(999), 27);

    assert_eq(digital_root(12345), 6);
    assert_eq(digital_root(0), 0);
    assert_eq(digital_root(9), 9);
    assert_eq(digital_root(999), 9);

    assert_eq(count_down(10), 55);
    assert_eq(count_down(0), 0);

    // Print deterministic output
    print("rec_fact12=479001600");
    print("rec_fib20=6765");
    print("rec_gcd=21");
    print("rec_tail_fib40=102334155");
    print("rec_ack33=61");
    print("rec_comb=120");
    print("rec_droot=6");
    print("PASS: recursion");
    0
}
