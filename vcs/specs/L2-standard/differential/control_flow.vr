// @test: differential
// @tier: 0
// @level: L2
// @tags: differential, control-flow, tier-equivalence
// @timeout: 10000
// @expected-exit: 0

/// L2-Standard: Control Flow
///
/// This test verifies that all control flow constructs produce
/// identical behavior in the interpreter (Tier 0) and AOT compiler (Tier 3).

fn abs_val(n: Int) -> Int {
    if n < 0 { -n } else { n }
}

fn clamp(val: Int, lo: Int, hi: Int) -> Int {
    if val < lo {
        lo
    } else if val > hi {
        hi
    } else {
        val
    }
}

fn classify(x: Int) -> Int {
    // Returns 0=negative, 1=zero, 2=small, 3=medium, 4=large
    if x < 0 {
        0
    } else if x == 0 {
        1
    } else if x < 10 {
        2
    } else if x < 100 {
        3
    } else {
        4
    }
}

fn sum_while(n: Int) -> Int {
    let mut total = 0;
    let mut i = 1;
    while i <= n {
        total = total + i;
        i = i + 1;
    }
    total
}

fn count_digits(n: Int) -> Int {
    if n == 0 { 1 } else {
        let mut count = 0;
        let mut val = n;
        if val < 0 { val = -val; }
        while val > 0 {
            count = count + 1;
            val = val / 10;
        }
        count
    }
}

fn collatz_steps(n: Int) -> Int {
    let mut val = n;
    let mut steps = 0;
    while val != 1 {
        if val % 2 == 0 {
            val = val / 2;
        } else {
            val = val * 3 + 1;
        }
        steps = steps + 1;
    }
    steps
}

fn main() -> Int {
    // === If/Else ===
    assert_eq(abs_val(5), 5);
    assert_eq(abs_val(-5), 5);
    assert_eq(abs_val(0), 0);

    // If as expression
    let result = if true { 1 } else { 2 };
    assert_eq(result, 1);

    let max_val = if 10 > 5 { 10 } else { 5 };
    assert_eq(max_val, 10);

    // If-else-if chain
    assert_eq(clamp(5, 0, 10), 5);
    assert_eq(clamp(-5, 0, 10), 0);
    assert_eq(clamp(15, 0, 10), 10);

    assert_eq(classify(-10), 0);
    assert_eq(classify(0), 1);
    assert_eq(classify(5), 2);
    assert_eq(classify(42), 3);
    assert_eq(classify(999), 4);

    // Nested if
    let a = 5;
    let b = 10;
    let nested = if a > 0 {
        if b > a { 1 } else { 2 }
    } else {
        3
    };
    assert_eq(nested, 1);

    // === While loops ===
    assert_eq(sum_while(0), 0);
    assert_eq(sum_while(10), 55);
    assert_eq(sum_while(100), 5050);

    assert_eq(count_digits(0), 1);
    assert_eq(count_digits(1), 1);
    assert_eq(count_digits(42), 2);
    assert_eq(count_digits(12345), 5);
    assert_eq(count_digits(-99), 2);

    // === Loop with break ===
    let mut count = 0;
    while true {
        count = count + 1;
        if count >= 10 {
            break;
        }
    }
    assert_eq(count, 10);

    // === Loop with continue-like (skip odds) ===
    let mut even_sum = 0;
    let mut i = 1;
    while i <= 10 {
        if i % 2 == 0 {
            even_sum = even_sum + i;
        }
        i = i + 1;
    }
    assert_eq(even_sum, 30);

    // === Nested loops ===
    let mut matrix_sum = 0;
    let mut row = 0;
    while row < 3 {
        let mut col = 0;
        while col < 3 {
            if row == col {
                matrix_sum = matrix_sum + 1;
            } else if row < col {
                matrix_sum = matrix_sum + 2;
            }
            col = col + 1;
        }
        row = row + 1;
    }
    assert_eq(matrix_sum, 9);

    // === Collatz sequence ===
    assert_eq(collatz_steps(1), 0);
    assert_eq(collatz_steps(2), 1);
    assert_eq(collatz_steps(6), 8);
    assert_eq(collatz_steps(27), 111);

    // Print deterministic output
    print("cf_abs=5");
    print("cf_sum=5050");
    print("cf_digits=5");
    print("cf_collatz_27=111");
    print("cf_matrix=9");
    print("PASS: control_flow");
    0
}
