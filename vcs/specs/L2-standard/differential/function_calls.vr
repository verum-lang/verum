// @test: differential
// @tier: 0
// @level: L2
// @tags: differential, functions, tier-equivalence
// @timeout: 15000
// @expected-exit: 0

/// L2-Standard: Function Calls
///
/// This test verifies that function calls, including various calling
/// conventions, produce identical results in interpreter and AOT.

fn constant() -> Int { 42 }
fn double_it(x: Int) -> Int { x * 2 }
fn add(a: Int, b: Int) -> Int { a + b }
fn subtract(a: Int, b: Int) -> Int { a - b }

fn min_max_sum(a: Int, b: Int) -> Int {
    // Returns min + max (equals a + b)
    let mn = if a <= b { a } else { b };
    let mx = if a >= b { a } else { b };
    mn + mx
}

fn square(x: Int) -> Int { x * x }

fn cube(x: Int) -> Int { x * x * x }

@allow(unbounded_recursion)
fn power_rec(base: Int, exp: Int) -> Int {
    if exp == 0 {
        1
    } else if exp == 1 {
        base
    } else {
        base * power_rec(base, exp - 1)
    }
}

@allow(unbounded_recursion)
fn gcd(a: Int, b: Int) -> Int {
    if b == 0 {
        a
    } else {
        gcd(b, a % b)
    }
}

fn is_even(n: Int) -> Bool {
    n % 2 == 0
}

@allow(unbounded_recursion)
fn sum_to(n: Int) -> Int {
    if n <= 0 { 0 } else { n + sum_to(n - 1) }
}

@allow(unbounded_recursion)
fn factorial(n: Int) -> Int {
    if n <= 1 { 1 } else { n * factorial(n - 1) }
}

@allow(unbounded_recursion)
fn fibonacci(n: Int) -> Int {
    if n <= 1 { n } else { fibonacci(n - 1) + fibonacci(n - 2) }
}

fn apply_fn(f: fn(Int) -> Int, x: Int) -> Int {
    f(x)
}

fn make_adder(n: Int) -> fn(Int) -> Int {
    |x: Int| -> Int { x + n }
}

fn compose_fn(f: fn(Int) -> Int, g: fn(Int) -> Int) -> fn(Int) -> Int {
    |x: Int| -> Int { f(g(x)) }
}

// Iterative power (no recursion needed)
fn power_iter(base: Int, exp: Int) -> Int {
    let mut result = 1;
    let mut i = 0;
    while i < exp {
        result = result * base;
        i = i + 1;
    }
    result
}

fn main() -> Int {
    // === Simple functions ===
    assert_eq(constant(), 42);
    assert_eq(double_it(21), 42);
    assert_eq(add(10, 32), 42);
    assert_eq(subtract(50, 8), 42);

    // === Nested calls ===
    assert_eq(add(double_it(3), double_it(4)), 14);
    assert_eq(square(7), 49);
    assert_eq(cube(3), 27);
    assert_eq(add(square(3), square(4)), 25);

    // === Min/Max ===
    assert_eq(min_max_sum(5, 10), 15);
    assert_eq(min_max_sum(10, 5), 15);
    assert_eq(min_max_sum(7, 7), 14);

    // === Recursive functions ===
    assert_eq(power_rec(2, 10), 1024);
    assert_eq(power_rec(3, 5), 243);
    assert_eq(gcd(48, 18), 6);
    assert_eq(gcd(100, 75), 25);
    assert_eq(gcd(17, 13), 1);

    // === Boolean-returning functions ===
    assert(is_even(4));
    assert(!is_even(7));
    assert(is_even(0));
    assert(!is_even(1));

    // === Sum and factorial ===
    assert_eq(sum_to(10), 55);
    assert_eq(sum_to(100), 5050);
    assert_eq(factorial(0), 1);
    assert_eq(factorial(1), 1);
    assert_eq(factorial(5), 120);
    assert_eq(factorial(10), 3628800);

    // === Fibonacci ===
    assert_eq(fibonacci(0), 0);
    assert_eq(fibonacci(1), 1);
    assert_eq(fibonacci(10), 55);
    assert_eq(fibonacci(15), 610);

    // === Higher-order functions ===
    let dbl = |x: Int| -> Int { x * 2 };
    assert_eq(apply_fn(dbl, 21), 42);

    let adder = make_adder(10);
    assert_eq(adder(32), 42);

    let add_one = |x: Int| -> Int { x + 1 };
    let double_then_inc = compose_fn(add_one, dbl);
    assert_eq(double_then_inc(10), 21);

    // === Iterative power ===
    assert_eq(power_iter(2, 10), 1024);
    assert_eq(power_iter(3, 5), 243);
    assert_eq(power_iter(5, 0), 1);
    assert_eq(power_iter(5, 1), 5);

    // Print deterministic output
    print("fn_constant=42");
    print("fn_factorial10=3628800");
    print("fn_fib15=610");
    print("fn_gcd=6");
    print("fn_power=1024");
    print("fn_compose=21");
    print("PASS: function_calls");
    0
}
