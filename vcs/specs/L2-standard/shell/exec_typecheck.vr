// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: shell, exec, executor, retry, typecheck
// @timeout: 5000
// @expect: pass

mount core.shell.exec.{run, sh, sh_check};
mount core.shell.executor.{Executor, RetryPolicy};
mount core.shell.context.{ShellContext};
mount core.shell.result.{ShellResult, ShellError};
mount core.async.cancellation.{CancellationToken};
mount core.time.duration.{Duration};

provide ShellContext = ShellContext.for_tests();

async fn exercise_run() {
    let r1: Result<ShellResult, ShellError> = run(&"echo".into(), ["hello".into()]).await;
    let _ = r1;
}

async fn exercise_sh() {
    let r2: ShellResult = sh(&"true".into()).await;
    let _ = r2;
    let r3: Result<ShellResult, ShellError> = sh_check(&"true".into()).await;
    let _ = r3;
}

async fn exercise_executor() {
    let exec = Executor.new()
        .with_timeout(Duration.from_millis(5000))
        .with_retry(RetryPolicy.simple(3));
    let _: Result<ShellResult, ShellError> = exec.sh(&"true".into()).await;
    let _: Result<ShellResult, ShellError> = exec.run(&"echo".into(), ["x".into()]).await;
}

async fn exercise_retry_policy_variants() {
    let _: RetryPolicy = RetryPolicy.simple(5);
    let _: RetryPolicy = RetryPolicy.on_exit_codes(3, [1, 2, 5]);
}

async fn exercise_cancel() {
    let token = CancellationToken.new();
    let exec = Executor.new()
        .with_cancel(token)
        .with_grace(Duration.from_millis(2000));
    let _: Result<ShellResult, ShellError> = exec.sh(&"true".into()).await;
}

async fn main() {
    exercise_run().await;
    exercise_sh().await;
    exercise_executor().await;
    exercise_retry_policy_variants().await;
    exercise_cancel().await;
}
