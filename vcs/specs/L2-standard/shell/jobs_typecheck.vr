// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: shell, jobs, parallel, structured-concurrency, typecheck
// @timeout: 30000
// @expect: pass

mount core.shell.jobs.{
    JobHandle, background, background_with_grace,
    wait_all, parallel, parallel_bounded,
    fail_fast, fanout,
};
mount core.shell.context.{ShellContext};
mount core.shell.result.{ShellResult, ShellError};
mount core.async.nursery.{NurseryErrorBehavior};
mount core.time.duration.{Duration};



async fn exercise_background() using [ShellContext] {
    let job: JobHandle = background(&"true".into());
    let _: &Text = job.command();
    let _: Bool = job.is_finished();
    let r: Result<ShellResult, ShellError> = job.await().await;
    let _ = r;
}

async fn exercise_background_with_grace() using [ShellContext] {
    let job = background_with_grace(&"true".into(), Duration.from_millis(1000));
    let _: Result<ShellResult, ShellError> = job.kill().await;
}

async fn exercise_parallel() using [ShellContext] {
    let cmds: List<Text> = ["echo a".into(), "echo b".into(), "echo c".into()];
    let _: List<Result<ShellResult, ShellError>> = parallel(cmds.clone()).await;
    let _: List<Result<ShellResult, ShellError>> = parallel_bounded(cmds, 2).await;
}

async fn exercise_fail_fast() using [ShellContext] {
    let cmds: List<Text> = ["true".into(), "false".into()];
    let _: Result<List<ShellResult>, ShellError> = fail_fast(cmds).await;
}

async fn exercise_fanout() using [ShellContext] {
    let cmds: List<Text> = ["echo a".into(), "echo b".into()];
    let _: Result<List<Result<ShellResult, ShellError>>, ShellError> =
        fanout(cmds, NurseryErrorBehavior.WaitAll).await;
}

async fn main() using [ShellContext] {
    exercise_background().await;
    exercise_background_with_grace().await;
    exercise_parallel().await;
    exercise_fail_fast().await;
    exercise_fanout().await;
}
