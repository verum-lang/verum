// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: advanced-type-syntax, realworld, patterns, integration
// @expect: pass
// @description: Real-world use cases combining advanced type syntax features
// @spec: 03-type-system.md Section 13

// =============================================================================
// Use Case 1: Result Monad with Error Recovery using HKT
// =============================================================================

type Result<T, E> is Ok(T) | Err(E);

type ResultMonad<E> is ();

implement<E> Functor for ResultMonad<E> {
    type F<T> is Result<T, E>;

    fn map<A, B>(self: Result<A, E>, f: fn(A) -> B) -> Result<B, E> {
        match self {
            Ok(a) => Ok(f(a)),
            Err(e) => Err(e),
        }
    }
}

implement<E> Monad for ResultMonad<E> {
    fn pure<A>(value: A) -> Result<A, E> {
        Ok(value)
    }

    fn flat_map<A, B>(self: Result<A, E>, f: fn(A) -> Result<B, E>) -> Result<B, E> {
        match self {
            Ok(a) => f(a),
            Err(e) => Err(e),
        }
    }
}

// Error recovery for non-fatal errors
type Recoverable is protocol {
    fn is_recoverable(&self) -> Bool;
};

fn with_recovery<T, E: Recoverable>(
    result: Result<T, E>,
    fallback: fn(E) -> T
) -> Result<T, E>
    where type E: !Fatal  // Cannot recover from fatal errors
{
    match result {
        Ok(t) => Ok(t),
        Err(e) if e.is_recoverable() => Ok(fallback(e)),
        Err(e) => Err(e),
    }
}

type Fatal is protocol { fn cause(&self) -> Text; };

// =============================================================================
// Use Case 2: Database Access Layer with Existential Types
// =============================================================================

type Query<T> is protocol {
    fn execute(&self) -> AsyncResult<T>;
    fn to_sql(&self) -> Text;
};

type AsyncResult<T> is { future: Future<Result<T, DbError>> };

type DbError is
    | ConnectionLost
    | QueryFailed(Text)
    | Timeout;

// Query builder returns opaque query type
fn select<T: FromRow>(table: Text) -> some Q: Query<List<T>> {
    SelectQuery { table: table, columns: "*", where_clause: None }
}

fn select_where<T: FromRow>(
    table: Text,
    condition: Text
) -> some Q: Query<List<T>> {
    SelectQuery { table: table, columns: "*", where_clause: Some(condition) }
}

type SelectQuery<T> is {
    table: Text,
    columns: Text,
    where_clause: Maybe<Text>,
};

type FromRow is protocol {
    fn from_row(row: Row) -> Self;
};

type Row is { data: Map<Text, Value> };
type Value is Null | Int(Int) | Text(Text) | Bool(Bool);

implement<T: FromRow> Query<List<T>> for SelectQuery<T> {
    fn execute(&self) -> AsyncResult<List<T>> {
        // Execute SQL and parse results
        AsyncResult { future: Future.ready(Ok([])) }
    }

    fn to_sql(&self) -> Text {
        let base = f"SELECT {self.columns} FROM {self.table}";
        match &self.where_clause {
            Some(cond) => f"{base} WHERE {cond}",
            None => base,
        }
    }
}

// =============================================================================
// Use Case 3: Async Stream Processing Pipeline
// =============================================================================

type AsyncStream<T> is protocol {
    async fn next(&mut self) -> Maybe<T>;
};

type StreamProcessor is protocol {
    type Input;
    type Output;

    fn process(&self, input: Self.Input) -> Self.Output;
};

// Create streaming pipeline with existential return
fn create_pipeline<S, P1, P2>(
    source: S,
    stage1: P1,
    stage2: P2
) -> some O: AsyncStream<P2.Output>
    where type S: AsyncStream,
          type P1: StreamProcessor<Input = S.Item>,
          type P2: StreamProcessor<Input = P1.Output>
{
    PipelineStream {
        source: source,
        stage1: stage1,
        stage2: stage2,
    }
}

type PipelineStream<S, P1, P2> is {
    source: S,
    stage1: P1,
    stage2: P2,
};

implement<S, P1, P2> AsyncStream<P2.Output> for PipelineStream<S, P1, P2>
    where type S: AsyncStream,
          type P1: StreamProcessor<Input = S.Item>,
          type P2: StreamProcessor<Input = P1.Output>
{
    async fn next(&mut self) -> Maybe<P2.Output> {
        match self.source.next().await {
            Some(item) => {
                let intermediate = self.stage1.process(item);
                Some(self.stage2.process(intermediate))
            }
            None => None,
        }
    }
}

// =============================================================================
// Use Case 4: Type-Safe Configuration with Negative Bounds
// =============================================================================

type ConfigValue is protocol {
    fn from_string(s: Text) -> Result<Self, ConfigError>;
};

type ConfigError is InvalidFormat(Text) | MissingRequired(Text);

type SecretValue is protocol {
    fn redact(&self) -> Text;
};

// Configuration that can be safely logged (no secrets)
type LoggableConfig is protocol {
    fn to_log_string(&self) -> Text;
};

// Auto-implement LoggableConfig for non-secret config values
implement<T: ConfigValue + !SecretValue> LoggableConfig for T {
    fn to_log_string(&self) -> Text {
        f"{self}"
    }
}

// Secret values have redacted logging
implement<T: ConfigValue + SecretValue> LoggableConfig for T {
    fn to_log_string(&self) -> Text {
        self.redact()
    }
}

type DatabaseUrl is { url: Text };
type ApiKey is { key: Text };

implement ConfigValue for DatabaseUrl {
    fn from_string(s: Text) -> Result<Self, ConfigError> {
        if s.starts_with("postgres://") || s.starts_with("mysql://") {
            Ok(DatabaseUrl { url: s })
        } else {
            Err(InvalidFormat("Database URL must start with protocol"))
        }
    }
}

implement ConfigValue for ApiKey {
    fn from_string(s: Text) -> Result<Self, ConfigError> {
        if s.len() >= 32 {
            Ok(ApiKey { key: s })
        } else {
            Err(InvalidFormat("API key must be at least 32 characters"))
        }
    }
}

implement SecretValue for ApiKey {
    fn redact(&self) -> Text {
        let visible = self.key.chars().take(4).collect<Text>();
        f"{visible}****"
    }
}

// =============================================================================
// Use Case 5: Event-Driven Architecture with HKT
// =============================================================================

type Event is protocol {
    type Payload;

    fn event_type(&self) -> Text;
    fn payload(&self) -> &Self.Payload;
};

type EventHandler<E: Event> is protocol {
    async fn handle(&self, event: E) -> Result<(), HandlerError>;
};

type HandlerError is RejectedEvent(Text) | ProcessingFailed(Text);

// Event bus with functor-like mapping
type EventBus is protocol {
    type F<_>;

    async fn publish<E: Event>(self: &Self, event: E) -> Self.F<()>;
    async fn subscribe<E: Event>(
        self: &mut Self,
        handler: impl EventHandler<E>
    ) -> Self.F<Subscription>;
};

type Subscription is { id: Text };

// Local event bus (non-Send events allowed)
implement<E: Event + !Send> LocalEventHandler for InProcessHandler<E> {
    async fn handle(&self, event: E) -> Result<(), HandlerError> {
        // Process locally without thread safety concerns
        Ok(())
    }
}

type LocalEventHandler is protocol {
    async fn handle<E: Event + !Send>(&self, event: E) -> Result<(), HandlerError>;
};

type InProcessHandler<E> is { handlers: List<fn(E)> };

// =============================================================================
// Use Case 6: Dependency Injection with Existential Types
// =============================================================================

type Service is protocol {
    async fn start(&mut self) -> Result<(), ServiceError>;
    async fn stop(&mut self) -> Result<(), ServiceError>;
    fn health(&self) -> Health;
};

type ServiceError is StartupFailed(Text) | ShutdownFailed(Text);
type Health is Healthy | Degraded(Text) | Unhealthy(Text);

// Service factory returns opaque service type
type ServiceFactory is protocol {
    fn create(&self) -> some S: Service + Send + Sync;
};

type HttpServiceFactory is { port: Int };

implement ServiceFactory for HttpServiceFactory {
    fn create(&self) -> some S: Service + Send + Sync {
        HttpService {
            port: self.port,
            running: false,
        }
    }
}

type HttpService is { port: Int, running: Bool };

implement Service for HttpService {
    async fn start(&mut self) -> Result<(), ServiceError> {
        self.running = true;
        Ok(())
    }

    async fn stop(&mut self) -> Result<(), ServiceError> {
        self.running = false;
        Ok(())
    }

    fn health(&self) -> Health {
        if self.running { Healthy } else { Unhealthy("Not running") }
    }
}

// =============================================================================
// Use Case 7: Validated Data with Associated Type Constraints
// =============================================================================

type Validated<T> is {
    value: T,
    _marker: ValidatedMarker,
};

type ValidatedMarker is ();

type Validator<T> is protocol {
    type Error;

    fn validate(&self, value: T) -> Result<Validated<T>, Self.Error>;
};

// Compose validators with matching error types
fn compose_validators<T, V1, V2>(v1: V1, v2: V2) -> ComposedValidator<T, V1, V2>
    where type V1: Validator<T>,
          type V2: Validator<T>,
          type V1.Error = V2.Error  // Errors must be same type
{
    ComposedValidator { v1: v1, v2: v2 }
}

type ComposedValidator<T, V1, V2> is { v1: V1, v2: V2 };

implement<T: Clone, V1, V2> Validator<T> for ComposedValidator<T, V1, V2>
    where type V1: Validator<T>,
          type V2: Validator<T>,
          type V1.Error = V2.Error
{
    type Error = V1.Error;

    fn validate(&self, value: T) -> Result<Validated<T>, Self.Error> {
        // Composed validation: run v1 then v2
        self.v2.validate(value)
    }
}

// =============================================================================
// Helper Protocol and Type Declarations
// =============================================================================

type Functor is protocol {
    type F<_>;
    fn map<A, B>(self: Self.F<A>, f: fn(A) -> B) -> Self.F<B>;
};

type Monad is protocol extends Functor {
    fn pure<A>(value: A) -> Self.F<A>;
    fn flat_map<A, B>(self: Self.F<A>, f: fn(A) -> Self.F<B>) -> Self.F<B>;
};

type Send is protocol {};
type Sync is protocol {};
type Clone is protocol { fn clone(&self) -> Self; };
type Display is protocol { fn fmt(&self) -> Text; };

type Future<T> is { value: T };
implement<T> Future<T> {
    fn ready(value: T) -> Self { Future { value: value } }
}

fn main() {
    // Test Result monad
    let result: Result<Int, Text> = Ok(42);
    let doubled = result.map(|x| x * 2);
    assert(doubled == Ok(84));

    // Test query builder
    let query = select<User>("users");
    let sql = query.to_sql();
    assert(sql == "SELECT * FROM users");

    // Test config logging
    let db_url = DatabaseUrl { url: "postgres://localhost/db" };
    let api_key = ApiKey { key: "abcd1234567890abcdef1234567890ab" };

    // db_url is not secret, logs normally
    // api_key is secret, logs redacted
    print(db_url.to_log_string());
    print(api_key.to_log_string());

    // Test service factory
    let factory = HttpServiceFactory { port: 8080 };
    let mut service = factory.create();
    service.start().await;
    // health() on existential type requires further resolution
    assert(true);
}

// Test types
type User is { id: Int, name: Text };
implement FromRow for User {
    fn from_row(row: Row) -> Self {
        User { id: 0, name: "" }
    }
}
