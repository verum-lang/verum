// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: tracing, opentelemetry, span, trace-context, w3c, sampler
// @timeout: 15000
// @expect: pass

// OpenTelemetry-compatible tracing API surface.

mount core.tracing.{
    TraceId, SpanId, SpanContext, TraceFlags, TraceState,
    AttributeValue, AttributeKind, AttributeSet, Resource,
    Sampler, SamplingDecision, SamplingResult, SamplerHandle,
    AlwaysOn, AlwaysOff, TraceIdRatio, ParentBased,
    always_on, always_off, trace_id_ratio, parent_based,
    TraceExportResult, ExportError, ExportErrorKind,
    SpanExporter, ExporterHandle, NoopExporter, StdoutExporter, InMemoryExporter, FileExporter,
    SpanProcessor, ProcessorHandle, SimpleProcessor, BatchProcessor, CompositeProcessor,
    Span, SpanKind, SpanStatus, SpanStatusCode, SpanEvent, SpanLink, SpanData,
    IdGenerator, DefaultIdGenerator, IdGeneratorHandle, default_id_generator,
    Tracer, TracerHandle, TracerProvider, TracerProviderBuilder, NoopTracer,
    get_tracer, global_tracer_provider, set_global_tracer_provider,
    TextMapPropagator, W3CTraceContext,
    inject_traceparent, extract_traceparent,
    generate_trace_id, generate_span_id,
};
mount core.tracing.processor.{BatchConfig};
mount core.time.duration.{Duration};

// Identifier shape — generation, hex codec, protocol impls.
fn typecheck_ids() -> (TraceId, SpanId) {
    let tid = generate_trace_id();
    let sid = generate_span_id();
    let _hex_t = tid.to_hex();
    let _hex_s = sid.to_hex();
    let _same = tid.eq(&tid) && sid.eq(&sid);
    (tid, sid)
}

fn typecheck_id_from_hex(hex: &[Byte]) -> Maybe<TraceId> {
    TraceId.from_hex(hex)
}

fn typecheck_id_generator() -> IdGeneratorHandle {
    let g = default_id_generator();
    let _t = g.new_trace_id();
    let _s = g.new_span_id();
    g
}

// Context + flags + state.
fn typecheck_context() -> SpanContext {
    let tid = generate_trace_id();
    let sid = generate_span_id();
    let flags = TraceFlags.sampled();
    let state = TraceState.empty().with("vendor".into(), "value".into());
    SpanContext.new(tid, sid, flags, state, false)
}

fn typecheck_invalid() -> SpanContext {
    SpanContext.invalid()
}

// Resource.
fn typecheck_resource() -> Resource {
    Resource.service(&"svc".into(), &"1.0".into())
        .with_attribute("deployment.env".into(), AttributeValue.Text("prod".into()))
}

// Attribute values — all primitive shapes; set() reports storage.
fn typecheck_attribute_values() -> AttributeSet {
    let mut s = AttributeSet.new();
    let _stored = s.set("a.text".into(), AttributeValue.Text("v".into()));
    let _ = s.set("a.bool".into(), AttributeValue.Bool(true));
    let _ = s.set("a.int".into(), AttributeValue.Int(42));
    let _ = s.set("a.float".into(), AttributeValue.Float(3.14));
    s
}

// Structured export errors.
fn typecheck_export_errors() -> TraceExportResult {
    let e = ExportError.transport("reset".into());
    let _k: ExportErrorKind = e.kind();
    let _retry = e.is_retryable();
    TraceExportResult.Success.combine(TraceExportResult.Failure(e))
}

// Samplers — record-form protocol impls + handle dispatch. (Unit-type
// statics such as AlwaysOn.new() don't resolve through mounts in the
// strict checker; the handle factories cover them.)
fn typecheck_samplers(parent: &SpanContext, trace_id: &TraceId, attrs: &AttributeSet) {
    let ratio = TraceIdRatio.new(0.1);
    let pb = ParentBased.new(always_on());
    let _c = ratio.should_sample(parent, trace_id, &"n".into(), SpanKind.KindInternal, attrs);
    let _d = pb.parent_decide(parent, trace_id, &"n".into(), SpanKind.KindInternal, attrs);
    let handle: SamplerHandle = parent_based(trace_id_ratio(0.5));
    let _e = handle.should_sample(parent, trace_id, &"n".into(), SpanKind.KindInternal, attrs);
    let _factories = (always_off(), handle.clone());
}

// Exporters — concrete types + handle dispatch.
fn typecheck_exporters() -> (NoopExporter, StdoutExporter) {
    (NoopExporter.new(), StdoutExporter.new())
}

fn typecheck_in_memory() -> (InMemoryExporter, Text, Int) {
    let sink = InMemoryExporter.new();
    let handle = sink.clone();
    (handle, sink.take_text(), sink.lines_len())
}

fn typecheck_export(exp: &NoopExporter, spans: &List<SpanData>) -> TraceExportResult {
    exp.export(spans)
}

fn typecheck_file_exporter(spans: &List<SpanData>) -> TraceExportResult {
    let e = FileExporter.new("/tmp/vcs-tracing-basic.log".into());
    let h = ExporterHandle.file("/tmp/vcs-tracing-basic.log".into());
    e.file_export(spans).combine(h.export(spans))
}

fn typecheck_exporter_handle(spans: &List<SpanData>) -> TraceExportResult {
    let h = ExporterHandle.in_memory(InMemoryExporter.new());
    h.export(spans)
        .combine(h.force_flush(Duration.from_secs(1)))
        .combine(h.shutdown(Duration.from_secs(1)))
}

// Processors — concrete types + handle dispatch.
fn typecheck_simple_processor() -> SimpleProcessor {
    SimpleProcessor.new(ExporterHandle.noop())
}

fn typecheck_batch_processor() -> BatchProcessor {
    BatchProcessor.with_config(
        ExporterHandle.noop(),
        BatchConfig.default()
            .with_queue_size(4096)
            .with_max_export_batch_size(256)
            .with_scheduled_delay(Duration.millis(500)),
    )
}

fn typecheck_processor_handles() -> ProcessorHandle {
    let mut children: List<ProcessorHandle> = List.new();
    children.push(ProcessorHandle.simple(ExporterHandle.stdout()));
    children.push(ProcessorHandle.noop());
    ProcessorHandle.composite(children)
}

// Tracer + TracerProvider.
fn typecheck_tracer_provider() -> TracerProvider {
    TracerProvider.builder()
        .with_resource(Resource.service(&"svc".into(), &"1.0".into()))
        .with_sampler(always_on())
        .with_id_generator(default_id_generator())
        .with_processor(ProcessorHandle.simple(ExporterHandle.noop()))
        .build()
}

fn typecheck_provider_lifecycle(provider: &TracerProvider) -> TraceExportResult {
    provider.force_flush(Duration.from_secs(1))
        .combine(provider.shutdown(Duration.from_secs(5)))
}

fn typecheck_global() {
    set_global_tracer_provider(typecheck_tracer_provider());
    let _provider = global_tracer_provider();
    let _tracer: TracerHandle = get_tracer(&"my.instrumentation".into(), &"1.0".into());
}

// Full start-span flow using a TracerHandle. end() delivers the frozen
// SpanData to the attached processor and returns nothing.
fn typecheck_span_flow(provider: &TracerProvider) {
    let tracer = provider.tracer(&"scope".into(), &"1.0".into());
    let parent = SpanContext.invalid();
    let attrs = AttributeSet.new();
    let links: List<SpanLink> = List.new();
    let span = tracer.start_span(&"handle".into(), SpanKind.KindServer, attrs, links, &parent);
    span.set_attribute("http.method".into(), AttributeValue.Text("GET".into()));
    span.add_event_now("request.received".into());
    span.set_status(SpanStatus.ok());
    let _recording = span.is_recording();
    span.end();
}

// NoopTracer keeps the concrete protocol-form surface.
fn typecheck_noop_tracer() {
    let tracer = NoopTracer.new("scope".into(), "1.0".into());
    let parent = SpanContext.invalid();
    let links: List<SpanLink> = List.new();
    let span = tracer.start_span(&"handle".into(), SpanKind.KindInternal, AttributeSet.new(), links, &parent);
    span.end();
}

// W3C traceparent / tracestate codec — via the single-header free
// functions (the unit-type propagator's statics don't resolve through
// mounts in the strict checker; the codec itself is identical).
fn typecheck_inject_extract() -> SpanContext {
    let ctx = SpanContext.new(
        generate_trace_id(), generate_span_id(),
        TraceFlags.sampled(), TraceState.empty(), false,
    );
    let hdr = inject_traceparent(&ctx);
    extract_traceparent(&hdr)
}

fn main() {
    // Shape-only test.
}
