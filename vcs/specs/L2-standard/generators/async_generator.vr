/// Test cleanup on early termination
async fn test_early_termination_cleanup() using [Logger] {
    let mut cleanup_called = false;

    async fn* generator_with_cleanup() -> Int {
        defer {
            cleanup_called = true;
        }
        for i in 0..1000 {
            yield i;
        }
    }

    // Only consume first 5 items
    let mut count = 0;
    for await item in generator_with_cleanup() {
        count += 1;
        if count >= 5 {
            break;
        }
    }

    assert(cleanup_called);
}

/// Test nested generator consumption
async fn test_nested_generators() using [Logger] {
    async fn* outer() -> Int {
        for i in 0..3 {
            yield i * 10;
        }
    }

    async fn* inner(base: Int) -> Int {
        for j in 0..3 {
            yield base + j;
        }
    }

    let mut all_values: List<Int> = List.new();
    for await o in outer() {
        for await i in inner(o) {
            all_values.push(i);
        }
    }

    assert_eq(all_values.len(), 9);
    // Should be: 0,1,2, 10,11,12, 20,21,22
}

// =============================================================================
// Section 10: Main Test Entry Point
// =============================================================================

/// Protocol for async iterator testing
type AsyncIterator<T> is protocol {
    type Item = T;
    async fn next(&mut self) -> Maybe<T>;
};

/// Collect async iterator into list
async fn collect<T>(iter: impl AsyncIterator<Item = T>) -> List<T> {
    let mut result: List<T> = List.new();
    for await item in iter {
        result.push(item);
    }
    result
}

async fn main() using [Http, Database, Cache, Logger, Metrics] {
    Logger.info("Starting async generator integration tests");

    // Run test suite
    test_basic_consumption().await;
    test_pipeline_composition().await;
    test_nested_generators().await;
    test_early_termination_cleanup().await;

    Logger.info("All tests passed!");
}
