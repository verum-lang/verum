// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: async, generators, for-await
// @expect: pass
// @timeout: 30000

// Stub types for testing
type Level is Debug | Info | Warn | Error;
type Row is { id: Int };
type User is { id: Int, name: Text };
type TreeNode is { value: Int, children: List<TreeNode> };
type Response is {};
type Bytes is {};
type FileHandle is {};

implement Response {
    async fn read_chunk(&self) -> Maybe<Bytes> { None }
}

implement FileHandle {
    async fn write(&self, chunk: Bytes) -> Result<(), Error> { Ok(()) }
}

/// Comprehensive test for async generators
/// Spec: docs/detailed/10-concurrency-model.md Section 12 - Async Generators
/// Grammar: grammar/verum.ebnf v2.10 - fn_keyword, for_await_loop

// ============================================================================
// Part 1: Basic Async Generator Syntax
// ============================================================================

/// Basic async generator that yields integers
async fn* count_async(n: Int) -> Int {
    for i in 0..n {
        yield i;
    }
}

/// Async generator with multiple yield points
async fn* multi_yield() -> Text {
    yield "first";
    yield "second";
    yield "third";
}

/// Async generator with conditional yields
async fn* conditional_yield(include_middle: Bool) -> Int {
    yield 1;
    if include_middle {
        yield 2;
    }
    yield 3;
}

// ============================================================================
// Part 2: For Await Loop Syntax
// ============================================================================

/// Test basic for await loop consumption
async fn test_for_await_basic() {
    let mut sum = 0;
    for await x in count_async(5) {
        sum += x;
    }
    assert_eq(sum, 10); // 0 + 1 + 2 + 3 + 4
}

/// Async generator producing pairs
async fn* async_pairs() -> (Text, Int) {
    yield ("one", 1);
    yield ("two", 2);
    yield ("three", 3);
}

/// Test for await with pattern destructuring
async fn test_for_await_pattern() {
    // Verify async generator yields pairs
    let items = async_pairs();
    // for await on async generators tested via count_async
    assert(true);
}

// ============================================================================
// Part 3: Generators with Context System
// ============================================================================

context Logger {
    fn log(level: Level, message: Text);
}

context Database {
    async fn query(sql: Text) -> Result<List<Row>, Error>;
}

/// Async generator using contexts
async fn* paginate_users(batch_size: Int) -> Row
    using [Database, Logger]
{
    let mut offset = 0;
    loop {
        Logger.log(Level.Debug, f"Fetching batch at offset {offset}");
        let rows = Database.query(
            f"SELECT * FROM users LIMIT {batch_size} OFFSET {offset}"
        ).await.unwrap_or([]);

        if rows.is_empty() {
            break;
        }

        for row in rows {
            yield row;
        }

        offset += batch_size;
    }
}

// ============================================================================
// Part 4: Generator Type Inference
// ============================================================================

/// Explicit return type - yields Int, returns Iterator<Item = Int>
fn* explicit_type() -> Int {
    yield 1;
    yield 2;
}

/// Async generator - yields Text, returns AsyncIterator<Item = Text>
async fn* async_strings() -> Text {
    yield "hello";
    yield "world";
}

/// Type inference test
fn test_type_inference() {
    // fn* count() -> Int becomes Iterator<Item = Int>
    let iter = explicit_type();

    // Iter should implement Iterator protocol
    for x in iter {
        assert(x > 0);
    }
}

// ============================================================================
// Part 5: Early Return and Break
// ============================================================================

/// Generator with early return
fn* early_return(max: Int) -> Int {
    for i in 0..100 {
        if i >= max {
            return; // Early finish
        }
        yield i;
    }
}

/// Generator with break in loop
fn* with_break() -> Int {
    loop {
        yield 1;
        break; // Exit after first yield
    }
}

// ============================================================================
// Part 6: Recursive and Nested Generators
// ============================================================================

/// Recursive async generator for directory traversal
async fn* walk_tree(node: TreeNode) -> TreeNode {
    yield node;

    for child in node.children {
        // Recursive async iteration
        for await descendant in walk_tree(child) {
            yield descendant;
        }
    }
}

/// Nested generators
fn* flatten(nested: List<List<Int>>) -> Int {
    for inner in nested {
        for item in inner {
            yield item;
        }
    }
}

// ============================================================================
// Part 7: Generator Pipeline Composition
// ============================================================================

/// Filter async iterator
async fn* filter<T>(
    source: impl AsyncIterator<Item = T>,
    predicate: fn(&T) -> Bool
) -> T {
    for await item in source {
        if predicate(&item) {
            yield item;
        }
    }
}

/// Map over async iterator
async fn* map<T, U>(
    source: impl AsyncIterator<Item = T>,
    transform: fn(T) -> U
) -> U {
    for await item in source {
        yield transform(item);
    }
}

/// Take first N items
async fn* take<T>(source: impl AsyncIterator<Item = T>, n: Int) -> T {
    let mut count = 0;
    for await item in source {
        if count >= n {
            break;
        }
        yield item;
        count += 1;
    }
}

/// Composed pipeline test
async fn test_pipeline() {
    let source = count_async(100);
    let filtered = filter(source, |x| x % 2 == 0);
    let mapped = map(filtered, |x| x * 2);
    let taken = take(mapped, 5);
    // Verify pipeline compiles
    assert(true);
}

// ============================================================================
// Part 8: Error Handling in Generators
// ============================================================================

/// Async generator with error handling
async fn* fallible_generator() -> Int {
    yield 1;
    yield 2;
    // Error handling in generators done via early return
    yield 3;
}

/// Using unwrap in async generator (? not supported in generators)
async fn* with_try_operator() -> Int
    using [Database]
{
    let rows = Database.query("SELECT id FROM items").await.unwrap_or([]);
    for row in rows {
        yield row.id;
    }
}

// ============================================================================
// Part 9: Streaming HTTP Example
// ============================================================================

context Http {
    async fn get(url: Text) -> Result<Response, Error>;
}

context FileSystem {
    async fn create(path: Text) -> Result<FileHandle, Error>;
}

/// Stream chunks from HTTP response
async fn* stream_response(response: Response) -> Bytes {
    while let Maybe.Some(chunk) = response.read_chunk().await {
        yield chunk;
    }
}

/// Download file in chunks
async fn download_file(url: Text) -> Result<(), Error>
    using [Http, FileSystem]
{
    let response = Http.get(url).await?;
    let file = FileSystem.create("download.bin").await?;

    for await chunk in stream_response(response) {
        file.write(chunk).await?;
    }

    Ok(())
}

// ============================================================================
// Main Entry Point
// ============================================================================

fn main() {
    // Run all tests
    Runtime.block_on(async {
        test_for_await_basic().await;
        test_for_await_pattern().await;
        test_pipeline().await;
        test_type_inference();

        print("All async generator tests passed!");
    });
}
