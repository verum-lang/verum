// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: math, bits, intrinsics
// @timeout: 15000
// @description: core.math.bits intrinsic surface — clz/ctz/popcnt/rotl/rotr/bswap

mount core.*;
mount core.math.bits.{
    clz, ctz, popcnt,
    clz32, ctz32, popcnt32,
    rotl, rotr, rotl32, rotr32,
    bswap, bswap32, bswap16,
    highest_bit, lowest_bit,
};

fn count_leading_zeros() {
    // 1 → 63 leading zeros (64-bit MSB).
    let c = clz1_u64;
    assert_eq(c, 63 as UInt32);
}

fn count_trailing_zeros() {
    let c = ctz8_u64;      // 0b1000 → 3 trailing zeros
    assert_eq(c, 3 as UInt32);
}

fn popcount_on_all_ones() {
    // Low 8 bits all set — popcount should be 8.
    let p = popcnt0xFF_u64;
    assert_eq(p, 8 as UInt32);
}

fn rotate_left_and_right() {
    let r = rotl(1 as UInt64, 4 as UInt32);
    assert_eq(r, 16 as UInt64);
    let b = rotr(16 as UInt64, 4 as UInt32);
    assert_eq(b, 1 as UInt64);
}

fn byte_swap_round_trip() {
    let original: UInt32 = 0x12345678 as UInt32;
    let swapped = bswap32(original);
    let round = bswap32(swapped);
    assert_eq(round, original);
}

fn highest_and_lowest_bit() {
    let hi = highest_bit0b00011000_u64;   // 0b00010000
    assert_eq(hi, 16 as UInt64);
    let lo = lowest_bit0b00011000_u64;    // 0b00001000
    assert_eq(lo, 8 as UInt64);
}

fn clz32_and_ctz32() {
    let a = clz321_u32;
    assert_eq(a, 31 as UInt32);
    let b = ctz324_u32;
    assert_eq(b, 2 as UInt32);
    let p = popcnt327_u32;
    assert_eq(p, 3 as UInt32);
}

fn bswap16_byte_swap() {
    let swapped = bswap160x1234_u16;
    assert_eq(swapped, 0x3412 as UInt16);
}

fn main() {
    count_leading_zeros();
    count_trailing_zeros();
    popcount_on_all_ones();
    rotate_left_and_right();
    byte_swap_round_trip();
    highest_and_lowest_bit();
    clz32_and_ctz32();
    bswap16_byte_swap();
    print("bit_intrinsics typecheck ok");
}
