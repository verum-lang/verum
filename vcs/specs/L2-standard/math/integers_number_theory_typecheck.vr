// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: math, integers, number-theory, euler-totient, divisors, prev-prime
// @timeout: 10000
// @expect: pass
//
// V8 (#251) — Euler totient + prev_prime + divisors / sigma / tau.
//
// Pre-#251 these number-theoretic primitives were missing despite
// being foundational for crypto (RSA φ(n), Lucas-Lehmer), divisor
// theory, and the divisor-sum and divisor-count functions.

mount core.math.integers.{
    euler_phi, prev_prime, divisors, sigma, tau,
    next_prime, gcd,
};

fn exercise_euler_phi_small() {
    // φ(1) = 1.
    assert(euler_phi(1) == 1);
    // φ(p) = p − 1 for primes 2,3,5,7,11.
    assert(euler_phi(2) == 1);
    assert(euler_phi(3) == 2);
    assert(euler_phi(5) == 4);
    assert(euler_phi(7) == 6);
    assert(euler_phi(11) == 10);
}

fn exercise_euler_phi_prime_powers() {
    // φ(p^k) = p^(k-1) · (p − 1).
    // φ(4) = φ(2²) = 2 · 1 = 2.
    assert(euler_phi(4) == 2);
    // φ(8) = φ(2³) = 4 · 1 = 4.
    assert(euler_phi(8) == 4);
    // φ(9) = φ(3²) = 3 · 2 = 6.
    assert(euler_phi(9) == 6);
    // φ(16) = 8.
    assert(euler_phi(16) == 8);
    // φ(27) = 9 · 2 = 18.
    assert(euler_phi(27) == 18);
}

fn exercise_euler_phi_composite() {
    // φ(12) = 12 · (1 − 1/2) · (1 − 1/3) = 4.
    assert(euler_phi(12) == 4);
    // φ(36) = 36 · 1/2 · 2/3 = 12.
    assert(euler_phi(36) == 12);
    // φ(100) = 100 · 1/2 · 4/5 = 40.
    assert(euler_phi(100) == 40);
}

fn exercise_euler_phi_multiplicative_for_coprime() {
    // gcd(a, b) = 1 ⇒ φ(a · b) = φ(a) · φ(b).
    // (3, 5) coprime: φ(15) = φ(3)·φ(5) = 2 · 4 = 8.
    assert(gcd(3, 5) == 1);
    assert(euler_phi(15) == euler_phi(3) * euler_phi(5));
    // (7, 9) coprime: φ(63) = φ(7)·φ(9) = 6 · 6 = 36.
    assert(gcd(7, 9) == 1);
    assert(euler_phi(63) == euler_phi(7) * euler_phi(9));
}

fn exercise_prev_prime_basic() {
    // No prime below 2.
    assert(matches!(prev_prime(0), None));
    assert(matches!(prev_prime(1), None));
    // prev_prime(2) = 2 (2 is the first prime).
    assert(matches!(prev_prime(2), Some(2)));
    // prev_prime(3) = 3.
    assert(matches!(prev_prime(3), Some(3)));
    // prev_prime(10) = 7.
    assert(matches!(prev_prime(10), Some(7)));
    // prev_prime(20) = 19.
    assert(matches!(prev_prime(20), Some(19)));
}

fn exercise_prev_prime_inverse_of_next_prime() {
    // For prime p > 2: next_prime(p − 1) = p, prev_prime(p + 1) = p.
    let primes = [3, 5, 7, 11, 13, 17, 19, 23];
    let mut i: Int = 0;
    while i < primes.len() {
        let p = primes[i];
        assert(next_prime(p - 1) == p);
        assert(matches!(prev_prime(p + 1), Some(q) if q == p));
        i = i + 1;
    }
}

fn exercise_divisors_small() {
    // divisors(1) = [1].
    let d1 = divisors(1);
    assert(d1.len() == 1);
    assert(d1[0] == 1);

    // divisors(6) = [1, 2, 3, 6].
    let d6 = divisors(6);
    assert(d6.len() == 4);
    assert(d6[0] == 1 && d6[1] == 2 && d6[2] == 3 && d6[3] == 6);

    // divisors(12) = [1, 2, 3, 4, 6, 12].
    let d12 = divisors(12);
    assert(d12.len() == 6);
    assert(d12[0] == 1 && d12[5] == 12);

    // Perfect square: divisors(16) = [1, 2, 4, 8, 16] — sqrt(16) = 4
    // appears exactly once.
    let d16 = divisors(16);
    assert(d16.len() == 5);
    assert(d16[2] == 4);
}

fn exercise_sigma_and_tau() {
    // σ(1) = 1, τ(1) = 1.
    assert(sigma(1) == 1);
    assert(tau(1) == 1);

    // σ(prime p) = p + 1, τ(p) = 2.
    assert(sigma(7) == 8);
    assert(tau(7) == 2);

    // σ(6) = 1 + 2 + 3 + 6 = 12 (perfect-number example).
    assert(sigma(6) == 12);
    assert(tau(6) == 4);

    // σ(12) = 1+2+3+4+6+12 = 28.
    assert(sigma(12) == 28);
    assert(tau(12) == 6);
}

fn exercise_divisors_sum_equals_sigma() {
    // Cross-check: sigma(n) computed via divisors() must equal direct sigma(n).
    let ns = [1, 6, 12, 28, 100];
    let mut i: Int = 0;
    while i < ns.len() {
        let n = ns[i];
        let ds = divisors(n);
        let mut total: Int = 0;
        let mut j: Int = 0;
        while j < ds.len() { total = total + ds[j]; j = j + 1; }
        assert(total == sigma(n));
        i = i + 1;
    }
}

fn main() {
    exercise_euler_phi_small();
    exercise_euler_phi_prime_powers();
    exercise_euler_phi_composite();
    exercise_euler_phi_multiplicative_for_coprime();
    exercise_prev_prime_basic();
    exercise_prev_prime_inverse_of_next_prime();
    exercise_divisors_small();
    exercise_sigma_and_tau();
    exercise_divisors_sum_equals_sigma();
}
