// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: math, sdg, differential-forms, wedge, multi-index, anti-symmetry
// @timeout: 10000
// @expect: pass
//
// V8 (#248) — full multi-index Leibniz wedge product.
//
// Pre-#248 the p ≥ 1, q ≥ 1 case fell through to a degree-correct
// zero stub. This spec pins the V2 contract:
//   • Combinations enumerator yields canonical lex order.
//   • combination_index is inverse of combinations.
//   • merge_with_sign returns sorted union + correct shuffle parity.
//   • Wedge of two 1-forms on R³ gives the right 2-form.
//   • α ∧ β = -β ∧ α for 1-forms (anti-symmetry).
//   • α ∧ α = 0 for any 1-form (degeneracy).

mount core.math.sdg.{
    Polynomial, polynomial, poly_constant,
    DifferentialForm, zero_form, wedge_product,
    combinations, combination_index,
};

fn exercise_combinations_lex_order() {
    // C(3, 2) = 3: [0,1], [0,2], [1,2]
    let cs = combinations(3, 2);
    assert(cs.len() == 3);
    assert(cs[0][0] == 0 && cs[0][1] == 1);
    assert(cs[1][0] == 0 && cs[1][1] == 2);
    assert(cs[2][0] == 1 && cs[2][1] == 2);

    // C(4, 2) = 6: [0,1], [0,2], [0,3], [1,2], [1,3], [2,3]
    let cs4 = combinations(4, 2);
    assert(cs4.len() == 6);
    assert(cs4[3][0] == 1 && cs4[3][1] == 2);
    assert(cs4[5][0] == 2 && cs4[5][1] == 3);
}

fn exercise_combinations_edge_cases() {
    // C(n, 0) = 1 — the empty subset.
    let zero_subsets = combinations(5, 0);
    assert(zero_subsets.len() == 1);
    assert(zero_subsets[0].len() == 0);

    // C(n, n) = 1 — the full subset.
    let full = combinations(3, 3);
    assert(full.len() == 1);
    assert(full[0][0] == 0 && full[0][1] == 1 && full[0][2] == 2);
}

fn exercise_combination_index_round_trip() {
    // For every combo c in combinations(n, k),
    // combination_index(n, c) must give back its position.
    let n = 4;
    let k = 2;
    let cs = combinations(n, k);
    let mut i: Int = 0;
    while i < cs.len() {
        assert(combination_index(n, cs[i]) == i);
        i = i + 1;
    }
}

fn exercise_wedge_two_one_forms_on_r3() {
    // α = dx + 2 dy + 3 dz   (1-form on R³, basis {dx, dy, dz})
    // β = 4 dx + 5 dy + 6 dz
    //
    // α ∧ β has basis {dx∧dy, dx∧dz, dy∧dz} → 3 coefficients (C(3,2) = 3).
    //
    // Computing:
    //   α ∧ β = (1·5 − 2·4) dx∧dy + (1·6 − 3·4) dx∧dz + (2·6 − 3·5) dy∧dz
    //         = (5 − 8) dx∧dy + (6 − 12) dx∧dz + (12 − 15) dy∧dz
    //         = -3 dx∧dy + (-6) dx∧dz + (-3) dy∧dz
    let alpha = DifferentialForm {
        degree: 1,
        coefficients: [
            poly_constant(1.0),
            poly_constant(2.0),
            poly_constant(3.0),
        ],
        dimension: 3,
    };
    let beta = DifferentialForm {
        degree: 1,
        coefficients: [
            poly_constant(4.0),
            poly_constant(5.0),
            poly_constant(6.0),
        ],
        dimension: 3,
    };
    let result = wedge_product(alpha, beta);
    assert(result.degree == 2);
    assert(result.coefficients.len() == 3);
    // dx ∧ dy coefficient.
    assert(result.coefficients[0].coefficients[0] == -3.0);
    // dx ∧ dz coefficient.
    assert(result.coefficients[1].coefficients[0] == -6.0);
    // dy ∧ dz coefficient.
    assert(result.coefficients[2].coefficients[0] == -3.0);
}

fn exercise_wedge_anti_symmetry_one_forms() {
    // α ∧ β = -β ∧ α for two 1-forms.
    let alpha = DifferentialForm {
        degree: 1,
        coefficients: [poly_constant(2.0), poly_constant(3.0)],
        dimension: 2,
    };
    let beta = DifferentialForm {
        degree: 1,
        coefficients: [poly_constant(5.0), poly_constant(7.0)],
        dimension: 2,
    };
    // α ∧ β: coefficient of dx∧dy is (2·7 − 3·5) = 14 − 15 = -1.
    let ab = wedge_product(alpha, beta);
    assert(ab.coefficients[0].coefficients[0] == -1.0);

    // β ∧ α: coefficient of dx∧dy is (5·3 − 7·2) = 15 − 14 = 1.
    let ba = wedge_product(beta, alpha);
    assert(ba.coefficients[0].coefficients[0] == 1.0);

    // Anti-symmetry pinned: ab + ba = 0 component-wise.
    assert(ab.coefficients[0].coefficients[0]
         + ba.coefficients[0].coefficients[0] == 0.0);
}

fn exercise_wedge_self_zero_for_one_form() {
    // α ∧ α = 0 for any 1-form (degeneracy of the alternating tensor).
    let alpha = DifferentialForm {
        degree: 1,
        coefficients: [poly_constant(3.0), poly_constant(7.0)],
        dimension: 2,
    };
    let alpha_clone = DifferentialForm {
        degree: 1,
        coefficients: [poly_constant(3.0), poly_constant(7.0)],
        dimension: 2,
    };
    let result = wedge_product(alpha, alpha_clone);
    // C(2,2) = 1 coefficient (dx∧dy), which must be zero.
    //   3·7 − 7·3 = 0.
    assert(result.coefficients[0].coefficients[0] == 0.0);
}

fn main() {
    exercise_combinations_lex_order();
    exercise_combinations_edge_cases();
    exercise_combination_index_round_trip();
    exercise_wedge_two_one_forms_on_r3();
    exercise_wedge_anti_symmetry_one_forms();
    exercise_wedge_self_zero_for_one_form();
}
