// ============================================================================
// Example main.vr using the directory module
// ============================================================================

fn main() {
    // Clean mount from directory module - mod.vr handles re-exports
    mount auth.{login, logout, User, Session, Credentials, AuthError};
    mount auth.middleware.require_auth;

    let credentials = Credentials.UsernamePassword {
        username: "alice",
        password: "secret123"
    };

    match login(credentials) {
        Ok(session) => {
            // User is authenticated
            println("Logged in with session: {}", session.id);

            // Later...
            logout(&session);
        },
        Err(AuthError.InvalidCredentials) => {
            println("Invalid username or password");
        },
        Err(AuthError.AccountLocked) => {
            println("Account is locked");
        },
        Err(e) => {
            println("Authentication failed: {:?}", e);
        }
    }
}
