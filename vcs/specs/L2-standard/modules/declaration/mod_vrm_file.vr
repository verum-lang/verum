// @test: parse-pass
// @tier: 0
// @level: L2
// @tags: modules, declaration, mod-vr

/// mod.vr file as directory module entry point.
/// This file demonstrates the convention where `mod.vr` serves as the
/// entry point for a directory module, similar to `index.js` in Node.js.
///
/// Project structure:
/// ```
/// src/
///   main.vr              <- imports from directory modules
///   auth/                <- directory module
///     mod.vr             <- THIS FILE - entry point, re-exports public API
///     strategies/        <- nested directory module
///       mod.vr           <- nested entry point
///       oauth.vr
///       jwt.vr
///       basic.vr
///     middleware.vr
///     session.vr
///     types.vr
/// ```

// ============================================================================
// This would be auth/mod.vr - the module entry point
// ============================================================================

/// Declare submodules (both file-based and directory-based)
module strategies;
module middleware;
module session;
module types;

// Re-export public API - users only need `mount auth.{...}`
pub mount types.{User, Session, Credentials, AuthError};
pub mount session.{create_session, validate_session, destroy_session};
pub mount middleware.{require_auth, AuthMiddleware};
pub mount strategies.{Strategy, authenticate};

/// High-level authentication function using configured strategy
pub fn login(credentials: Credentials) -> Result<Session, AuthError> {
    let strategy = strategies.get_default_strategy();
    let user = authenticate(strategy, credentials)?;
    create_session(user)
}

pub fn logout(session: &Session) -> Result<(), AuthError> {
    destroy_session(session)
}

