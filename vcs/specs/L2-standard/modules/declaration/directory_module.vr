// @test: parse-pass
// @tier: 0
// @level: L2
// @tags: modules, declaration, directory-based

/// Directory module declaration - module spread across multiple files in a directory.
///
/// Project structure:
/// ```
/// src/
///   main.vr              <- this file
///   http/                <- directory module
///     mod.vr             <- module root (re-exports)
///     client.vr          <- submodule
///     server.vr          <- submodule
///     types.vr           <- submodule
///   crypto/              <- another directory module
///     mod.vr
///     hash.vr
///     encrypt.vr
/// ```

// Declare directory-based modules
module http;
module crypto;

fn main() {
    // Import from directory module submodules
    mount http.{Client, Server, Request, Response};
    mount crypto.{hash_sha256, encrypt_aes};

    // Create HTTP client
    let client = Client.new();

    // Make a request
    let request = Request {
        method: "GET",
        url: "https://api.example.com/data",
        headers: Map.new(),
        body: None
    };

    let response = client.send(request);

    match response {
        Ok(resp) => {
            // Process response
            let hash = hash_sha256(resp.body);
            let encrypted = encrypt_aes(resp.body, "secret_key");
        },
        Err(e) => {
            // Handle error
        }
    }

    // Create HTTP server
    let server = Server.bind("0.0.0.0:8080");
    // server.serve(handler);
}

