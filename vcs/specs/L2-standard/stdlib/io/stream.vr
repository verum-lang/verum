/// Test buffered stream operations
fn test_buffered_streams() using [FileSystem] {
    // BufReader for efficient reading
    let file: File = File.open("data.txt")?;
    let reader: BufReader<File> = BufReader.new(file);

    // Custom buffer size
    let file2: File = File.open("data.txt")?;
    let big_reader: BufReader<File> = BufReader.with_capacity(65536, file2);

    // BufRead trait methods
    fn process_lines(reader: &BufRead) -> Result<(), IoError> {
        // read_line() - read one line
        let mut line: Text = Text.new();
        let bytes: usize = reader.read_line(&mut line)?;

        // lines() - iterator over lines
        for line_result in reader.lines() {
            let line: Text = line_result?;
            println(f"{line}");
        }

        // read_until() - read until delimiter
        let mut until_null: List<u8> = List.new();
        reader.read_until(b'\0', &mut until_null)?;

        // split() - iterator split by byte
        for segment in reader.split(b'\n') {
            let data: List<u8> = segment?;
        }

        Ok(())
    }

    // Access underlying buffer
    let filled: &[u8] = reader.fill_buf()?;
    let available: usize = filled.len();
    reader.consume(available);

    // BufWriter for efficient writing
    let out_file: File = File.create("output.txt")?;
    let mut writer: BufWriter<File> = BufWriter.new(out_file);

    writer.write_all(b"Line 1\n")?;
    writer.write_all(b"Line 2\n")?;
    // Data may be buffered until flush or drop
    writer.flush()?;

    // Get inner writer
    let inner: File = writer.into_inner()?;

    // LineWriter - flushes on newline
    let out_file2: File = File.create("lines.txt")?;
    let mut line_writer: LineWriter<File> = LineWriter.new(out_file2);

    line_writer.write_all(b"This line ")?;
    // Not flushed yet
    line_writer.write_all(b"continues\n")?;
    // Flushed because of newline
}

