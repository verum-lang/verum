/// Test basic read stream operations
fn test_read_stream() using [FileSystem] {
    // Read trait methods
    let mut file: File = File.open("test.txt")?;

    // read() - reads into buffer, returns bytes read
    let mut buf: [u8; 1024] = [0; 1024];
    let bytes_read: usize = file.read(&mut buf)?;
    assert(bytes_read <= 1024);

    // read_exact() - reads exactly n bytes or errors
    let mut exact_buf: [u8; 10] = [0; 10];
    file.read_exact(&mut exact_buf)?;

    // read_to_end() - reads all remaining bytes
    let mut all_bytes: List<u8> = List.new();
    let total: usize = file.read_to_end(&mut all_bytes)?;

    // read_to_string() - reads all as UTF-8 string
    let mut file2: File = File.open("text.txt")?;
    let mut content: Text = Text.new();
    file2.read_to_string(&mut content)?;

    // bytes() - iterator over bytes
    let mut file3: File = File.open("data.bin")?;
    for byte_result in file3.bytes() {
        match byte_result {
            Ok(b) => { /* process byte */ },
            Err(e) => break,
        }
    }

    // Chain multiple readers
    let file_a: File = File.open("part_a.txt")?;
    let file_b: File = File.open("part_b.txt")?;
    let mut chained: Chain<File, File> = file_a.chain(file_b);
    let mut combined: List<u8> = List.new();
    chained.read_to_end(&mut combined)?;

    // Take limited bytes
    let mut file4: File = File.open("large.dat")?;
    let mut limited: Take<File> = file4.take(100);
    let mut limited_buf: List<u8> = List.new();
    limited.read_to_end(&mut limited_buf)?;
    assert(limited_buf.len() <= 100);
}

