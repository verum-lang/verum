/// Test seekable stream operations
fn test_seekable_stream() using [FileSystem] {
    let mut file: File = OpenOptions.new()
        .read(true)
        .write(true)
        .open("seekable.dat")?;

    // Seek to position
    file.seek(SeekFrom.Start(100))?;

    // Get current position
    let pos: u64 = file.stream_position()?;
    assert(pos == 100);

    // Seek relative to current
    file.seek(SeekFrom.Current(50))?;
    assert(file.stream_position()? == 150);

    // Seek relative to end
    file.seek(SeekFrom.End(-10))?;

    // Rewind to start
    file.rewind()?;
    assert(file.stream_position()? == 0);

    // Stream length
    let len: u64 = file.seek(SeekFrom.End(0))?;
    file.rewind()?;

    // Read at specific position
    fn read_at<S: Read + Seek>(stream: &mut S, pos: u64, buf: &mut [u8]) -> Result<usize, IoError> {
        stream.seek(SeekFrom.Start(pos))?;
        stream.read(buf)
    }

    // Write at specific position
    fn write_at<S: Write + Seek>(stream: &mut S, pos: u64, data: &[u8]) -> Result<usize, IoError> {
        stream.seek(SeekFrom.Start(pos))?;
        stream.write(data)
    }

    // Set stream length (truncate or extend)
    file.set_len(1000)?;

    // Sync data to disk
    file.sync_data()?;

    // Sync all metadata
    file.sync_all()?;
}

