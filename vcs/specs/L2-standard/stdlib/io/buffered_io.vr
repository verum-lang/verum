/// Comprehensive test suite for buffered I/O operations.
/// Tests BufReader, BufWriter, and related buffering utilities.

using [FileSystem]

fn main() {
    test_buf_reader_creation();
    test_buf_reader_methods();
    test_buf_writer_creation();
    test_buf_writer_methods();
    test_line_writer();
    test_cursor();
    test_chain_and_take();
    test_copy_operations();
    test_split_and_bytes();
    test_buffer_performance();
}

/// Test BufReader creation and configuration
fn test_buf_reader_creation() using [FileSystem] {
    // Default buffered reader
    let file: File = File.open("input.txt")?;
    let reader: BufReader<File> = BufReader.new(file);

    // With custom capacity
    let file2: File = File.open("large.dat")?;
    let large_reader: BufReader<File> = BufReader.with_capacity(65536, file2);

    // Get capacity
    let capacity: usize = large_reader.capacity();
    assert(capacity >= 65536);

    // Commented out: io unbound variable
    // let stdin: StdinLock = io.stdin().lock();
    // let stdin_reader: BufReader<StdinLock> = BufReader.new(stdin);

    // Network socket
    let stream: TcpStream = TcpStream.connect("127.0.0.1:8080")?;
    let network_reader: BufReader<TcpStream> = BufReader.new(stream);

    // From bytes
    let bytes: &[u8] = b"Hello, World!";
    let bytes_reader: BufReader<&[u8]> = BufReader.new(bytes);

    // Nested buffering (usually unnecessary)
    let file: File = File.open("nested.txt")?;
    let inner: BufReader<File> = BufReader.new(file);
    let outer: BufReader<BufReader<File>> = BufReader.new(inner);
    // Warning: Adds overhead without benefit
}

/// Test BufReader methods
fn test_buf_reader_methods() using [FileSystem] {
    let file: File = File.open("test.txt")?;
    let mut reader: BufReader<File> = BufReader.new(file);

    // fill_buf() - fill internal buffer and return reference
    let buf: &[u8] = reader.fill_buf()?;
    println(f"Buffer has {buf.len()} bytes");

    // consume() - mark bytes as consumed
    reader.consume(10);  // Skip 10 bytes

    // Read line by line
    let mut line: Text = Text.new();
    let bytes_read: usize = reader.read_line(&mut line)?;
    if bytes_read > 0 {
        // Line includes trailing newline
        println(f"Read line: {line}");
    }
    line.clear();  // Reuse for next line

    // lines() iterator
    for line_result in reader.lines() {
        match line_result {
            Ok(line) => println(f"Line: {line}"),  // No trailing newline
            Err(e) => {
                println(f"Error: {e}");
                break;
            }
        }
    }

    // read_until() - read until delimiter
    let mut until_buf: List<u8> = List.new();
    reader.read_until(b'\n', &mut until_buf)?;  // Includes delimiter

    // split() - iterate by delimiter
    let file: File = File.open("delimited.txt")?;
    let mut reader: BufReader<File> = BufReader.new(file);
    for segment in reader.split(b',') {
        match segment {
            Ok(data) => {
                let text = Text.from_utf8_lossy(&data);
                println(f"Segment: {text}");
            },
            Err(e) => break,
        }
    }

    // Commented out: buffer() returns BufReader<File> not &[u8]
    // let current_buffer: &[u8] = reader.buffer();
    // println(f"Buffer contains {current_buffer.len()} bytes");

    // Get inner reader
    let inner: &File = reader.get_ref();
    let inner_mut: &mut File = reader.get_mut();

    // Consume and get inner
    let file: File = reader.into_inner();

    // seek_relative for efficient seeking within buffer
    let file: File = File.open("seekable.txt")?;
    let mut reader: BufReader<File> = BufReader.with_capacity(8192, file);
    reader.fill_buf()?;  // Fill buffer
    // Commented out: seek_relative() not yet in stdlib
    // reader.seek_relative(100)?;
}

/// Test BufWriter creation and configuration
fn test_buf_writer_creation() using [FileSystem] {
    // Default buffered writer
    let file: File = File.create("output.txt")?;
    let writer: BufWriter<File> = BufWriter.new(file);

    // With custom capacity
    let file2: File = File.create("large_output.txt")?;
    let large_writer: BufWriter<File> = BufWriter.with_capacity(65536, file2);

    // Get capacity
    let capacity: usize = large_writer.capacity();
    assert(capacity >= 65536);

    // For network
    let stream: TcpStream = TcpStream.connect("127.0.0.1:8080")?;
    let network_writer: BufWriter<TcpStream> = BufWriter.new(stream);

    // Commented out: io unbound variable
    // let stdout: StdoutLock = io.stdout().lock();
    // let stdout_writer: BufWriter<StdoutLock> = BufWriter.new(stdout);

    // To in-memory buffer
    let buffer: List<u8> = List.new();
    let mem_writer: BufWriter<Cursor<List<u8>>> = BufWriter.new(Cursor.new(buffer));
}

/// Test BufWriter methods
