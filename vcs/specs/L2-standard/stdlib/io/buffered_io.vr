    // Get inner writer
    let inner: &File = writer.get_ref();
    let inner_mut: &mut File = writer.get_mut();

    // into_inner - flush and unwrap
    match writer.into_inner() {
        Ok(file) => {
            // Writer was flushed successfully
            println("Got inner file");
        },
        Err(err) => {
            // Commented out: into_parts() not yet in stdlib
            // let (write_error, buffered_writer) = err.into_parts();
            println(f"Flush error: {err}");
        }
    }

    // Commented out: into_parts() not yet in stdlib; File.create() not available
