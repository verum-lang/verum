/// Test LineWriter for line-buffered output
fn test_line_writer() using [FileSystem] {
    let file: File = File.create("line_output.txt")?;
    let mut writer: LineWriter<File> = LineWriter.new(file);

    // Write with newline - flushes immediately
    writer.write_all(b"Line 1\n")?;  // Flushed
    writer.write_all(b"Line 2\n")?;  // Flushed

    // Partial line - buffered until newline
    writer.write_all(b"Partial")?;    // Buffered
    writer.write_all(b" line")?;      // Still buffered
    writer.write_all(b"\n")?;         // Now flushed

    // Custom capacity
    let file2: File = File.create("line_output2.txt")?;
    let writer2: LineWriter<File> = LineWriter.with_capacity(4096, file2);

    // Multiple newlines
    writer.write_all(b"Line A\nLine B\nLine C\n")?;  // All flushed

    // Commented out: writeln() accepts at most 1 argument; File.create() not available
    // let mut log: LineWriter<File> = LineWriter.new(File.create("log.txt")?);
    // writeln(&mut log, "INFO: Application started")?;
    // writeln(&mut log, "DEBUG: Processing...")?;
    // writeln(&mut log, "ERROR: Something failed")?;

    // Get inner
    let inner: File = writer.into_inner()?;
}

/// Test Cursor for in-memory I/O
fn test_cursor() using [FileSystem] {
    // Create cursor over list
    let mut cursor: Cursor<List<u8>> = Cursor.new(List.new());

    // Write to cursor
    cursor.write_all(b"Hello, World!")?;

    // Get position
    let pos: u64 = cursor.position();
    assert(pos == 13);

    // Seek to beginning
    cursor.set_position(0);

    // Read back
    let mut buffer: [u8; 5] = [0; 5];
    cursor.read(&mut buffer)?;
    assert(&buffer == b"Hello");

    // Seek operations
    cursor.seek(SeekFrom.Start(7))?;  // Position 7
    cursor.seek(SeekFrom.Current(2))?;  // Position 9
    cursor.seek(SeekFrom.End(-1))?;  // Position 12

    // Get inner data
    let data: List<u8> = cursor.into_inner();
    assert(data == b"Hello, World!".to_vec());

    // Cursor over slice (read-only)
    let slice: &[u8] = b"Read only data";
    let mut slice_cursor: Cursor<&[u8]> = Cursor.new(slice);
    let mut read_buf: [u8; 4] = [0; 4];
    slice_cursor.read(&mut read_buf)?;
    assert(&read_buf == b"Read");

    // Cursor over string
    let text: Text = "Hello, Text!".to_text();
    let text_cursor: Cursor<Text> = Cursor.new(text);

    // Get reference to inner
    let inner_ref: &List<u8> = cursor.get_ref();
    let inner_mut: &mut List<u8> = cursor.get_mut();

    // Stream length
    cursor.set_position(0);
    let len: u64 = cursor.seek(SeekFrom.End(0))?;
}

/// Test Chain and Take adapters
fn test_chain_and_take() using [FileSystem] {
    // Chain two readers
    let file1: File = File.open("part1.txt")?;
    let file2: File = File.open("part2.txt")?;
    let mut chained: Chain<File, File> = file1.chain(file2);

    let mut combined: List<u8> = List.new();
    chained.read_to_end(&mut combined)?;
    // combined contains part1 followed by part2

    // Chain multiple readers
    let readers: List<File> = [
        File.open("a.txt")?,
        File.open("b.txt")?,
        File.open("c.txt")?,
    ];

    // Commented out: io unbound variable
    // fn chain_all<R: Read>(readers: impl IntoIterator<Item = R>) -> Heap<Read> {
    //     readers.into_iter().fold(
    //         Heap(io.empty()) as Heap<Read>,
    //         |acc, r| Heap(acc.chain(r))
    //     )
    // }

    // Take limited bytes
    let file: File = File.open("large.dat")?;
    let mut limited: Take<File> = file.take(1024);

    let mut buffer: List<u8> = List.new();
    limited.read_to_end(&mut buffer)?;
    assert(buffer.len() <= 1024);

    // Get remaining limit
    let remaining: u64 = limited.limit();

    // Set new limit
    limited.set_limit(2048);

    // Get inner reader
    let inner: File = limited.into_inner();

    // Commented out: take() returns Take<File>, not File; chain type mismatch
    // let header: File = File.open("header.bin")?.take(64);
    // let body: File = File.open("body.bin")?;
    // let mut message: Chain<Take<File>, File> = header.chain(body);
}

/// Test copy operations
fn test_copy_operations() using [FileSystem] {
    // Copy file contents
    let mut src: File = File.open("source.txt")?;
    let mut dst: File = File.create("destination.txt")?;
    // Commented out: io unbound variable
    // let bytes_copied: u64 = io.copy(&mut src, &mut dst)?;
    // println(f"Copied {bytes_copied} bytes");

    // Copy with buffering
    let src: File = File.open("source.txt")?;
    let dst: File = File.create("dest.txt")?;
    let mut src_buf: BufReader<File> = BufReader.new(src);
    let mut dst_buf: BufWriter<File> = BufWriter.new(dst);
    // Commented out: io unbound variable
    // io.copy(&mut src_buf, &mut dst_buf)?;
    dst_buf.flush()?;

    // Copy between in-memory buffers
    let src_data: &[u8] = b"Data to copy";
    let mut src_cursor: Cursor<&[u8]> = Cursor.new(src_data);
    let mut dst_vec: List<u8> = List.new();
    // Commented out: io unbound variable
    // io.copy(&mut src_cursor, &mut dst_vec)?;
    // assert(dst_vec == src_data.to_vec());

    // Tee - copy while reading
    type TeeReader<R, W> is {
        reader: R,
        writer: W,
    };

    implement<R: Read, W: Write> Read for TeeReader<R, W> {
        fn read(&mut self, buf: &mut [u8]) -> Result<usize, IoError> {
            let n = self.reader.read(buf)?;
            self.writer.write_all(&buf[..n])?;
            Ok(n)
        }
    }

    let file: File = File.open("input.txt")?;
    let log: File = File.create("copy.log")?;
    let mut tee = TeeReader { reader: file, writer: log };
    let mut output: List<u8> = List.new();
    tee.read_to_end(&mut output)?;
    // output contains data, and copy.log has a copy

    // copy_buf for buffered copy (more efficient)
    let src: File = File.open("source.txt")?;
    let dst: File = File.create("dest.txt")?;
    let mut src_buf: BufReader<File> = BufReader.new(src);
    let mut dst_buf: BufWriter<File> = BufWriter.new(dst);
    // io.copy_buf(&mut src_buf, &mut dst_buf)?;  // If available
}

/// Test split and bytes iterators
fn test_split_and_bytes() using [FileSystem] {
    // Commented out: bytes().collect() type mismatch StreamCollect
    // let data: &[u8] = b"Hello";
    // let bytes: List<u8> = data.bytes().map(|b| b.unwrap()).collect();
    // assert(bytes == [72, 101, 108, 108, 111]);

    // File bytes
    let file: File = File.open("small.txt")?;
    let mut byte_count: usize = 0;
    for byte_result in file.bytes() {
        match byte_result {
            Ok(_byte) => byte_count += 1,
            Err(e) => {
                println(f"Error: {e}");
                break;
            }
        }
    }
    println(f"Read {byte_count} bytes");

    // split() by delimiter
    let data: &[u8] = b"a,b,c,d";
    let parts: List<List<u8>> = data.split(|b| *b == b',')
        .map(|s| s.to_vec())
        .collect();
    assert(parts.len() == 4);

    // BufRead.split
    let file: File = File.open("records.txt")?;
    let reader: BufReader<File> = BufReader.new(file);
    for record in reader.split(b'\n') {
        match record {
            Ok(data) => {
                // Process record (does not include delimiter)
                let text: Text = Text.from_utf8_lossy(&data);
            },
            Err(e) => break,
        }
    }

    // Read until specific sequence
    fn read_until_sequence(reader: &mut impl BufRead, seq: &[u8]) -> Result<List<u8>, IoError> {
        let mut result: List<u8> = List.new();
        loop {
            let available = reader.fill_buf()?;
            if available.is_empty() {
                break;
            }
            if let Some(pos) = available.windows(seq.len()).position(|w| w == seq) {
                result.extend_from_slice(&available[..pos]);
                reader.consume(pos + seq.len());
                break;
            }
            result.extend_from_slice(available);
            let len = available.len();
            reader.consume(len);
        }
        Ok(result)
    }
}

/// Test buffer performance considerations
fn test_buffer_performance() using [FileSystem] {
    // Optimal buffer sizes
    const SMALL_BUFFER: usize = 8 * 1024;      // 8 KB - good for small files
    const MEDIUM_BUFFER: usize = 64 * 1024;    // 64 KB - good default
    const LARGE_BUFFER: usize = 256 * 1024;    // 256 KB - good for sequential reads
    const HUGE_BUFFER: usize = 1024 * 1024;    // 1 MB - for very large files

    // Choose buffer size based on file size
    fn optimal_buffer_size(file_size: u64) -> usize {
        match file_size {
            0..=1024 => 1024,
            1025..=65536 => 8192,
            65537..=1048576 => 65536,
            _ => 262144,
        }
    }

    // Commented out: metadata() not yet in stdlib
    // let file: File = File.open("data.bin")?;
