    // println(f"Buffered {buffered.len()} bytes");

    // flush() - write buffer to underlying writer
    writer.flush()?;
    assert(writer.buffer().is_empty());

    // Commented out: write() accepts at most 1 argument
    // write(&mut writer, "Number: {}\n", 42)?;
    // writeln(&mut writer, "Another line")?;

