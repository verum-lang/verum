/// Comprehensive test suite for file writing operations.
/// Tests various methods of writing file contents.
/// All IO operations require the IO context.

/// Stub types for IO operations
type IoSlice is { data: &[u8] };
implement IoSlice {
    fn new(data: &[u8]) -> Self { IoSlice { data } }
}

type NamedTempFile is {};
implement NamedTempFile {
    fn new() -> Result<Self, IoError> { Ok(NamedTempFile {}) }
    fn new_in(dir: &Path) -> Result<Self, IoError> { Ok(NamedTempFile {}) }
    fn write_all(&mut self, data: &[u8]) -> Result<(), IoError> { Ok(()) }
    fn flush(&mut self) -> Result<(), IoError> { Ok(()) }
    fn as_file(&self) -> &File { unreachable() }
    fn path(&self) -> &Path { unreachable() }
    fn persist(&self, path: impl Into<Path>) -> Result<(), IoError> { Ok(()) }
}

using [FileSystem]

fn main() {
    test_write_string();
    test_write_bytes();
    test_write_lines();
    test_buffered_writing();
    test_append_mode();
    test_file_creation();
    test_atomic_write();
    test_write_with_seek();
    test_truncate();
    test_sync_and_flush();
}

/// Test writing strings to files
fn test_write_string() using [FileSystem] {
    // Simple write_all
    let result: Result<(), IoError> = fs.write("output.txt", "Hello, World!");
    match result {
        Ok(()) => {
            // Verify by reading back
            let content: Text = fs.read_to_string("output.txt")?;
            assert(content == "Hello, World!");
        },
        Err(e) => println(f"Write error: {e}"),
    }

    // Write with Path
    let path: Path = Path.from("data/output.txt");
    fs.write(&path, "Content here")?;

    // Write empty file
    fs.write("empty.txt", "")?;
    let empty: Text = fs.read_to_string("empty.txt")?;
    assert(empty.is_empty());

    // Write multiline
    let multiline: Text = "Line 1\nLine 2\nLine 3";
    fs.write("multiline.txt", &multiline)?;

    // Using File handle
    let mut file: File = File.create("manual.txt")?;
    file.write_all(b"Written with File handle")?;

    // Write formatted content
    let name: Text = "Alice";
    let age: Int = 30;
    let formatted: Text = format("Name: {}\nAge: {}", name, age);
    fs.write("person.txt", &formatted)?;

    // Write with custom encoding (UTF-8 is default)
    let unicode: Text = "Hello 世界 🌍";
    fs.write("unicode.txt", &unicode)?;
    let read_back: Text = fs.read_to_string("unicode.txt")?;
    assert(read_back == unicode);
}

