/// Test file truncation
fn test_truncate() using [FileSystem] {
    // Create file with content
    fs.write("to_truncate.txt", "Hello, World! This is a long string.")?;

    // Truncate to specific size
    let file: File = OpenOptions.new()
        .write(true)
        .open("to_truncate.txt")?;
    file.set_len(13)?;  // Truncate to "Hello, World!"

    let content: Text = fs.read_to_string("to_truncate.txt")?;
    assert(content == "Hello, World!");

    // Truncate to zero (empty file)
    let file: File = OpenOptions.new()
        .write(true)
        .truncate(true)
        .open("to_truncate.txt")?;
    // File is now empty

    // Extend file with zeros
    let file: File = OpenOptions.new()
        .write(true)
        .open("to_extend.txt")?;
    fs.write("to_extend.txt", "Short")?;
    file.set_len(1024)?;  // Extend to 1024 bytes

    // Truncate using seek
    let mut file: File = OpenOptions.new()
        .write(true)
        .open("truncate_seek.txt")?;
    file.seek(SeekFrom.Start(0))?;
    file.write_all(b"Overwrite")?;
    file.set_len(file.stream_position()?)?;  // Truncate at current position
}

