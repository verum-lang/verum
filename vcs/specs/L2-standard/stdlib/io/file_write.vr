/// Test writing lines to files
fn test_write_lines() using [FileSystem] {
    // Write list of lines
    let lines: List<Text> = [
        "First line",
        "Second line",
        "Third line",
    ];

    let content: Text = lines.join("\n");
    fs.write("lines.txt", &content)?;

    // Using BufWriter with write!/writeln!
    let file: File = File.create("buffered_lines.txt")?;
    let mut writer: BufWriter<File> = BufWriter.new(file);

    for (i, line) in lines.iter().enumerate() {
        writer.write(f"{i + 1}: {line}\n".as_bytes())?;
    }
    writer.flush()?;

    // Write with custom line endings
    let windows_lines: Text = lines.join("\r\n");
    fs.write("windows.txt", &windows_lines)?;

    // Write log entries
    fn write_log(writer: &mut impl Write, level: &str, message: &str) -> Result<(), IoError> {
        let timestamp: Text = "2024-01-01 00:00:00";
        writer.write(f"[{timestamp}] {level}: {message}\n".as_bytes())
    }

    let log_file: File = File.create("app.log")?;
    let mut log_writer: BufWriter<File> = BufWriter.new(log_file);
    write_log(&mut log_writer, "INFO", "Application started")?;
    write_log(&mut log_writer, "DEBUG", "Processing request")?;
    write_log(&mut log_writer, "ERROR", "Something went wrong")?;
    log_writer.flush()?;

    // Write CSV
    let csv_data: List<List<Text>> = [
        ["Name", "Age", "City"],
        ["Alice", "30", "NYC"],
        ["Bob", "25", "LA"],
    ];

    let csv_file: File = File.create("data.csv")?;
    let mut csv_writer: BufWriter<File> = BufWriter.new(csv_file);
    for row in csv_data.iter() {
        csv_writer.write((row.join(",") + "\n").as_bytes())?;
    }
    csv_writer.flush()?;
}

/// Test buffered writing
fn test_buffered_writing() using [FileSystem] {
    // Default buffered writer
    let file: File = File.create("buffered.txt")?;
    let mut writer: BufWriter<File> = BufWriter.new(file);

    // Custom buffer size
    let file2: File = File.create("large_buffer.txt")?;
    let mut large_writer: BufWriter<File> = BufWriter.with_capacity(65536, file2);

    // Write many small chunks efficiently
    for i in 0..10000 {
        writer.write(f"Line {i}\n".as_bytes())?;
    }
    writer.flush()?;  // Ensure all data is written

    // Check buffer state
    let buffered = writer.buffer();
    let capacity = writer.capacity();

    // Auto-flush on drop (but explicit flush is safer)
    {
        let file: File = File.create("auto_flush.txt")?;
        let mut writer: BufWriter<File> = BufWriter.new(file);
        writer.write("This will be flushed on drop".as_bytes())?;
        // writer goes out of scope and flushes
    }

    // LineWriter - flushes on each newline
    let file: File = File.create("line_buffered.txt")?;
    let mut line_writer: LineWriter<File> = LineWriter.new(file);
    line_writer.write("Line 1\n".as_bytes())?;  // Flushed immediately
    line_writer.write("Line 2\n".as_bytes())?;  // Flushed immediately
    line_writer.write("Partial".as_bytes())?;   // Buffered until newline or flush

    // Get inner writer
    let inner: File = writer.into_inner()?;

    // Unwrap BufWriter without flushing (loses buffered data)
    // let inner: File = writer.into_parts().0;  // Careful!
}

