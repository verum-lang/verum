/// Test file creation options
fn test_file_creation() using [FileSystem] {
    // Create new file (fails if exists)
    let result: Result<File, IoError> = OpenOptions.new()
        .write(true)
        .create_new(true)
        .open("new_file.txt");

    match result {
        Ok(mut file) => {
            file.write_all(b"New file content")?;
        },
        Err(e) => {
            // Handle error
        },
    }

    // Create or truncate
    let mut file: File = OpenOptions.new()
        .write(true)
        .create(true)
        .truncate(true)
        .open("overwrite.txt")?;
    file.write_all(b"Fresh content")?;

    // Create with permissions (Unix)
    @cfg(unix)
    {
        mount std.os.unix.fs.OpenOptionsExt;
        let mut file: File = OpenOptions.new()
            .write(true)
            .create(true)
            .mode(0o644)  // rw-r--r--
            .open("with_perms.txt")?;
    }

    // Create parent directories
    fn create_with_parents(path: &Path, content: &str) -> Result<(), IoError> using [FileSystem] {
        if let Some(parent) = path.parent() {
            fs.create_dir_all(parent)?;
        }
        fs.write(path, content)
    }

    create_with_parents(&Path.from("deep/nested/dir/file.txt"), "Content")?;

    // Temporary file
    let mut temp: NamedTempFile = NamedTempFile.new()?;
    temp.write_all(b"Temporary content")?;
    let temp_path: &Path = temp.path();
    println(f"Temp file: {temp_path.display()}");
    // File is deleted when temp goes out of scope

    // Persist temp file
    let temp: NamedTempFile = NamedTempFile.new()?;
    temp.persist("permanent.txt")?;
}

