}

/// Test buffered reading
fn test_buffered_reading() using [FileSystem] {
    // Create buffered reader
    let file: File = File.open("large_file.txt")?;
    let reader: BufReader<File> = BufReader.new(file);

    // Custom buffer size
    let file2: File = File.open("large_file.txt")?;
    let custom_reader: BufReader<File> = BufReader.with_capacity(65536, file2);

    // Read line by line efficiently
    let mut line: Text = Text.new();
    while reader.read_line(&mut line)? > 0 {
        // Process line (includes trailing newline if present)
        let trimmed: &str = line.trim_end();
        line.clear();  // Reuse buffer
    }

    // Read until delimiter
    let mut until_delim: List<u8> = List.new();
    reader.read_until(b'\0', &mut until_delim)?;

    // Fill buffer and check capacity
    reader.fill_buf()?;
    // Commented out: buffer() returns BufReader<File> not &[u8]
    // let buffered: &[u8] = reader.buffer();
    let cap: usize = reader.capacity();

    // Consume bytes from buffer
    reader.consume(100);  // Mark 100 bytes as read

    // Commented out: split() returns SplitIter not Split
