}

/// Test reading with seek
fn test_read_with_seek() using [FileSystem] {
    // Open file with read and seek
    let mut file: File = File.open("seekable.dat")?;

    // Seek from start
    file.seek(SeekFrom.Start(100))?;

    // Read at position
    let mut buffer: [u8; 10] = [0; 10];
    file.read(&mut buffer)?;

    // Seek from current position
    file.seek(SeekFrom.Current(50))?;  // Forward 50 bytes
    file.seek(SeekFrom.Current(-20))?; // Back 20 bytes

    // Seek from end
    file.seek(SeekFrom.End(-100))?;  // 100 bytes before end

    // Get current position
    let position: u64 = file.stream_position()?;

    // Rewind to beginning
    file.rewind()?;  // Same as seek(SeekFrom.Start(0))
    assert(file.stream_position()? == 0);

    // Seek and read pattern
    fn read_at(file: &mut File, offset: u64, buffer: &mut [u8]) -> Result<usize, IoError> {
        file.seek(SeekFrom.Start(offset))?;
        file.read(buffer)
    }

    let mut chunk: [u8; 256] = [0; 256];
    let read: usize = read_at(&mut file, 1024, &mut chunk)?;

    // Stream length
    let len: u64 = file.seek(SeekFrom.End(0))?;
    file.rewind()?;

    // Read specific record from file
    fn read_record(file: &mut File, record_num: u64, record_size: u64) -> Result<List<u8>, IoError> {
        let offset: u64 = record_num * record_size;
        file.seek(SeekFrom.Start(offset))?;

        let mut buffer: List<u8> = [0; record_size as usize];
        file.read_exact(&mut buffer)?;
        Ok(buffer)
    }
}

/// Test partial reading
fn test_read_partial() using [FileSystem] {
    let mut file: File = File.open("data.txt")?;

    // Read may return fewer bytes than buffer size
    let mut buffer: [u8; 1024] = [0; 1024];
    let bytes_read: usize = file.read(&mut buffer)?;
    // bytes_read <= 1024

    // Handle partial reads
    fn read_all(file: &mut File, buffer: &mut [u8]) -> Result<usize, IoError> {
        let mut total: usize = 0;
        while total < buffer.len() {
            match file.read(&mut buffer[total..])? {
                0 => break,  // EOF
                n => total += n,
            }
        }
        Ok(total)
    }

    // Read with timeout (platform-specific)
    // let result = file.read_timeout(&mut buffer, Duration.from_secs(5));

    // Take limited reader
    let mut file2: File = File.open("large.dat")?;
    let mut limited: Take<File> = file2.take(1024);  // Read at most 1024 bytes

    let mut limited_buffer: List<u8> = List.new();
    limited.read_to_end(&mut limited_buffer)?;
    assert(limited_buffer.len() <= 1024);

    // Chain readers
    let file_a: File = File.open("part_a.txt")?;
    let file_b: File = File.open("part_b.txt")?;
    let mut chained: Chain<File, File> = file_a.chain(file_b);

    let mut combined: List<u8> = List.new();
    chained.read_to_end(&mut combined)?;
}

