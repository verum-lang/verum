/// Test reading entire file to string
fn test_read_to_string() using [FileSystem] {
    // Simple read_to_string
    let content: Result<Text, IoError> = fs.read_to_string("test_file.txt");
    match content {
        Ok(text) => {
            assert(!text.is_empty());
        },
        Err(e) => {
            // Handle file not found, permission denied, etc.
            println(f"Error reading file: {e}");
        },
    }

    // Read with explicit path
    let path: Path = Path.from("/home/user/document.txt");
    let doc: Result<Text, IoError> = fs.read_to_string(&path);

    // Read UTF-8 file (default encoding)
    let utf8_content: Result<Text, IoError> = fs.read_to_string("utf8_file.txt");

    // Commented out: Pattern expects variant type but scrutinee has StreamError
    // let maybe_invalid: Result<Text, IoError> = fs.read_to_string("binary_file.bin");
    // match maybe_invalid {
    //     Ok(_) => {},
    //     Err(IoError.InvalidData(_)) => {},
    //     Err(e) => panic(f"Unexpected error: {e}"),
    // }

    // Using File.open and read_to_string
    let file: Result<File, IoError> = File.open("test.txt");
    match file {
        Ok(mut f) => {
            let mut contents: Text = Text.new();
            let result: Result<usize, IoError> = f.read_to_string(&mut contents);
            match result {
                Ok(bytes_read) => {
                    assert(bytes_read == contents.len());
                },
                Err(e) => println(f"Read error: {e}"),
            }
        },
        Err(e) => println(f"Open error: {e}"),
    }
}

/// Test reading file to bytes
fn test_read_to_bytes() using [FileSystem] {
    // Read entire file as bytes
    let bytes: Result<List<u8>, IoError> = fs.read("binary_file.bin");
    match bytes {
        Ok(data) => {
            assert(!data.is_empty());
            // Process binary data
            let first_byte: u8 = data[0];
            let length: usize = data.len();
        },
        Err(e) => println(f"Error: {e}"),
    }

    // Read image file
    let image: Result<List<u8>, IoError> = fs.read("image.png");
    match image {
        Ok(data) => {
            // Check PNG magic bytes
            if data.len() >= 8 {
                assert(data[0] == 0x89);
                assert(data[1] == 0x50);  // 'P'
                assert(data[2] == 0x4E);  // 'N'
                assert(data[3] == 0x47);  // 'G'
            }
        },
        Err(_) => {},
    }

    // Using File handle
    let mut file: File = File.open("data.bin")?;
    let mut buffer: List<u8> = List.with_capacity(1024);
    buffer.resize(1024, 0);

    let bytes_read: usize = file.read(&mut buffer)?;
    buffer.truncate(bytes_read);

    // Read to fixed-size array
    let mut fixed_buffer: [u8; 256] = [0; 256];
    let read_count: usize = file.read(&mut fixed_buffer)?;
}

/// Test line-by-line reading
fn test_read_lines() using [FileSystem] {
    // Using lines() iterator
    let file: File = File.open("log.txt")?;
    let reader: BufReader<File> = BufReader.new(file);

    for line_result in reader.lines() {
        match line_result {
            Ok(line) => {
                // Process each line (without trailing newline)
                assert(!line.ends_with("\n"));
                process_line(&line);
            },
            Err(e) => {
                println(f"Error reading line: {e}");
                break;
            },
        }
    }

    // Collect all lines to list
    let all_lines: Result<List<Text>, IoError> = {
        let file = File.open("data.txt")?;
        BufReader.new(file).lines().collect()
    };

    match all_lines {
        Ok(lines) => {
            assert(lines.len() > 0);
            let first_line: &Text = &lines[0];
            let last_line: &Text = &lines[lines.len() - 1];
        },
        Err(e) => println(f"Error: {e}"),
    }

    // Read with line count limit
    let limited_lines: List<Text> = {
        let file = File.open("large_file.txt")?;
        BufReader.new(file)
            .lines()
            .take(100)
            .filter_map(|r| r.ok())
            .collect()
    };

    // Read until condition
    let until_empty: List<Text> = {
        let file = File.open("data.txt")?;
        BufReader.new(file)
            .lines()
            .map_while(|r| r.ok())
            .take_while(|line| !line.is_empty())
            .collect()
    };

    // Split by custom delimiter
    let file: File = File.open("csv_data.txt")?;
    let reader: BufReader<File> = BufReader.new(file);

    // Commented out: split().collect() type mismatch StreamCollect
    // for line in reader.lines().filter_map(|r| r.ok()) {
    //     let fields: List<&str> = line.split(',').collect();
    // }
}

fn process_line(line: &Text) {
