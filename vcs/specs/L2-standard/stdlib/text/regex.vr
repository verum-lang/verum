    test_lookaround();
    test_regex_flags();
}

/// Test basic regex creation and matching
fn test_regex_basics() {
    // Create simple regex
    let re: Regex = Regex.new("""hello""").unwrap();
    assert(re.is_match("hello world"));
    assert(!re.is_match("goodbye world"));

    // Case sensitive by default
    assert(!re.is_match("Hello world"));

    // Invalid regex returns error
    let invalid: Result<Regex, RegexError> = Regex.new("""[invalid""");
    assert(invalid.is_err());

    // Empty pattern matches everything
    let empty: Regex = Regex.new("""""").unwrap();
    assert(empty.is_match("anything"));
    assert(empty.is_match(""));

    // Literal special characters (escaped)
    let special: Regex = Regex.new("""\.\*\+\?""").unwrap();
    assert(special.is_match(".*+?"));
    assert(!special.is_match("abcd"));

    // Unicode support
    let unicode: Regex = Regex.new("""\u{1F600}""").unwrap();
    assert(unicode.is_match("Hello \u{1F600} World"));
}

/// Test pattern matching
fn test_regex_matching() {
    // is_match
    let word_re: Regex = Regex.new("""\bword\b""").unwrap();
    assert(word_re.is_match("a word here"));
    assert(!word_re.is_match("a wording here"));

    // is_match_at - match starting at position
    let re: Regex = Regex.new("""abc""").unwrap();
    assert(re.is_match_at("123abc", 3));
    assert(!re.is_match_at("123abc", 0));

    // Match email pattern
    let email: Regex = Regex.new("""[\w.+-]+@[\w-]+\.[\w.-]+""").unwrap();
    assert(email.is_match("user@example.com"));
    assert(email.is_match("first.last+tag@sub.domain.org"));
    assert(!email.is_match("not an email"));

    // Match phone number
    let phone: Regex = Regex.new("""\d{3}[-.]?\d{3}[-.]?\d{4}""").unwrap();
    assert(phone.is_match("123-456-7890"));
    assert(phone.is_match("123.456.7890"));
    assert(phone.is_match("1234567890"));
    assert(!phone.is_match("12-345-6789"));

    // Match URL
    let url: Regex = Regex.new("""https?://[\w./-]+""").unwrap();
    assert(url.is_match("http://example.com"));
    assert(url.is_match("https://sub.example.com/path/to/page"));
}

