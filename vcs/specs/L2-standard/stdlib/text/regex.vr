/// Test grouping features
fn test_groups() {
    // Basic grouping
    let group: Regex = Regex.new("""(ab)+""").unwrap();
    assert(group.is_match("abab"));
    assert(!group.is_match("aabb"));

    // Non-capturing group
    let non_cap: Regex = Regex.new("""(?:ab)+c""").unwrap();
    let caps = non_cap.captures("ababc").unwrap();
    assert(caps.get(1).is_none());  // No capture

    // Alternation
    let alt: Regex = Regex.new("""cat|dog|bird""").unwrap();
    assert(alt.is_match("I have a cat"));
    assert(alt.is_match("I have a dog"));
    assert(!alt.is_match("I have a fish"));

    // Grouping with alternation
    let grouped_alt: Regex = Regex.new("""(red|blue) car""").unwrap();
    assert(grouped_alt.is_match("red car"));
    assert(grouped_alt.is_match("blue car"));
    assert(!grouped_alt.is_match("green car"));

    // Backreference
    let backref: Regex = Regex.new("""(\w+) \1""").unwrap();
    assert(backref.is_match("the the"));
    assert(!backref.is_match("the a"));

    // Named backreference
    let named_back: Regex = Regex.new("""(?P<word>\w+) (?P=word)""").unwrap();
    assert(named_back.is_match("hello hello"));
}

