/// Comprehensive test suite for regular expression operations.
/// Tests pattern matching, capturing, substitution, and regex features.

fn main() {
    test_regex_basics();
    test_regex_matching();
    test_regex_captures();
    test_regex_find();
    test_regex_replace();
    test_regex_split();
    test_character_classes();
    test_quantifiers();
    test_anchors();
