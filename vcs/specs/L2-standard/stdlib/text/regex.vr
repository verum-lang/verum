/// Test character classes
fn test_character_classes() {
    // Built-in classes
    let digit: Regex = Regex.new("""\d""").unwrap();
    assert(digit.is_match("a1b"));
    assert(!digit.is_match("abc"));

    let word: Regex = Regex.new("""\w+""").unwrap();
    assert(word.is_match("hello_123"));

    let space: Regex = Regex.new("""\s""").unwrap();
    assert(space.is_match("hello world"));

    // Negated classes
    let non_digit: Regex = Regex.new("""\D+""").unwrap();
    let nd_match = non_digit.find("123abc456").unwrap();
    assert(nd_match.as_str() == "abc");

    // Custom character class
    let vowels: Regex = Regex.new("""[aeiou]+""").unwrap();
    let v_match = vowels.find("hello").unwrap();
    assert(v_match.as_str() == "e");

    // Negated custom class
    let consonants: Regex = Regex.new("""[^aeiou\s]+""").unwrap();
    let c_match = consonants.find("hello").unwrap();
    assert(c_match.as_str() == "h");

    // Range in class
    let hex: Regex = Regex.new("""[0-9a-fA-F]+""").unwrap();
    assert(hex.is_match("DeadBeef"));
    assert(!hex.is_match("xyz"));

    // Unicode categories
    let letter: Regex = Regex.new("""\p{L}+""").unwrap();
    assert(letter.is_match("\u{0391}\u{0392}\u{0393}"));  // Greek letters

    // Special characters in class
    let special: Regex = Regex.new("""[\[\]\-\^]""").unwrap();
    assert(special.is_match("["));
    assert(special.is_match("-"));
}

/// Test quantifiers
fn test_quantifiers() {
    // Zero or more (*)
    let star: Regex = Regex.new("""ab*c""").unwrap();
    assert(star.is_match("ac"));
    assert(star.is_match("abc"));
    assert(star.is_match("abbbbc"));

    // One or more (+)
    let plus: Regex = Regex.new("""ab+c""").unwrap();
    assert(!plus.is_match("ac"));
    assert(plus.is_match("abc"));
    assert(plus.is_match("abbbbc"));

    // Zero or one (?)
    let opt: Regex = Regex.new("""colou?r""").unwrap();
    assert(opt.is_match("color"));
    assert(opt.is_match("colour"));

    // Exact count {n}
    let exact: Regex = Regex.new("""\d{3}""").unwrap();
    let exact_match = exact.find("12345").unwrap();
    assert(exact_match.as_str() == "123");

    // Range {n,m}
    let range: Regex = Regex.new("""\d{2,4}""").unwrap();
    assert(range.find("1").is_none());
    assert(range.find("12").is_some());
    assert(range.find("12345").unwrap().as_str() == "1234");

    // At least {n,}
    let at_least: Regex = Regex.new("""\d{2,}""").unwrap();
    assert(at_least.find("1").is_none());
    assert(at_least.find("12").is_some());

    // Greedy vs lazy
    let greedy: Regex = Regex.new("""<.*>""").unwrap();
    let lazy: Regex = Regex.new("""<.*?>""").unwrap();
    let html: Text = "<b>bold</b>";

    assert(greedy.find(&html).unwrap().as_str() == "<b>bold</b>");
    assert(lazy.find(&html).unwrap().as_str() == "<b>");

    // Possessive (if supported)
    // let possessive: Regex = Regex.new("""a++""").unwrap();
}

