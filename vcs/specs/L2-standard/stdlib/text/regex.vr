/// Test replacement operations
fn test_regex_replace() {
    let re: Regex = Regex.new("""\d+""").unwrap();
    let text: Text = "abc123def456ghi";

    // replace - first occurrence
    let replaced: Text = re.replace(&text, "XXX").to_text();
    assert(replaced == "abcXXXdef456ghi");

    // replace_all - all occurrences
    let all_replaced: Text = re.replace_all(&text, "XXX").to_text();
    assert(all_replaced == "abcXXXdefXXXghi");

    // replacen - limit replacements
    let limited: Text = re.replacen(&text, 1, "XXX").to_text();
    assert(limited == "abcXXXdef456ghi");

    // Capture group references in replacement
    let name_re: Regex = Regex.new("""(\w+), (\w+)""").unwrap();
    let swapped: Text = name_re.replace("Doe, John", "$2 $1").to_text();
    assert(swapped == "John Doe");

    // Named capture group references
    let date_re: Regex = Regex.new("""(?P<m>\d{2})/(?P<d>\d{2})/(?P<y>\d{4})""").unwrap();
    let iso_date: Text = date_re.replace("03/15/2024", "$y-$m-$d").to_text();
    assert(iso_date == "2024-03-15");

    // Replace with closure
    let doubled: Text = re.replace_all(&text, |caps: &Captures| {
        let num: Int = caps.get(0).unwrap().as_str().parse().unwrap();
        (num * 2).to_text()
    }).to_text();
    assert(doubled == "abc246def912ghi");

    // Escape replacement string
    let special: Regex = Regex.new("""x""").unwrap();
    let with_dollar: Text = special.replace("x", "$$10").to_text();
    assert(with_dollar == "$10");  // $$ escapes to $
}

