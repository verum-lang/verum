/// Test regex flags and options
fn test_regex_flags() {
    // Case insensitive
    let ci: Regex = Regex.new("""(?i)hello""").unwrap();
    assert(ci.is_match("Hello"));
    assert(ci.is_match("HELLO"));
    assert(ci.is_match("hElLo"));

    // Multiline mode
    let multi: Regex = Regex.new("""(?m)^line""").unwrap();
    assert(multi.find_iter("line1\nline2").count() == 2);

    // Dot matches newline
    let dotall: Regex = Regex.new("""(?s)a.b""").unwrap();
    assert(dotall.is_match("a\nb"));

    // Extended mode (comments and whitespace)
    let extended: Regex = Regex.new("""(?x)
        \d{3}  # area code
        -
        \d{4}  # number
    """).unwrap();
    assert(extended.is_match("123-4567"));

    // Combined flags
    let combined: Regex = Regex.new("""(?im)^hello""").unwrap();
    assert(combined.is_match("Hello"));
    assert(combined.find_iter("Hello\nHELLO").count() == 2);

    // Unicode mode (usually default)
    let unicode: Regex = Regex.new("""(?u)\w+""").unwrap();
    assert(unicode.is_match("\u{00E9}"));  // Accented e

    // Disable unicode
    let ascii_only: Regex = Regex.new("""(?-u)\w+""").unwrap();
    // Behavior depends on implementation

    // Set options via RegexBuilder
    let built: Regex = RegexBuilder.new("""hello""")
        .case_insensitive(true)
        .multi_line(true)
        .build()
        .unwrap();
    assert(built.is_match("HELLO"));
}
