/// Test split variants
fn test_split_variants() {
    let text: Text = "a,b,c,d,e";

    // splitn - limit number of splits
    let limited: List<&str> = text.splitn(3, ',').collect();
    assert(limited == ["a", "b", "c,d,e"]);

    // splitn with n=1 returns whole string
    let one: List<&str> = text.splitn(1, ',').collect();
    assert(one == ["a,b,c,d,e"]);

    // splitn with n=0 returns empty
    let zero: List<&str> = text.splitn(0, ',').collect();
    assert(zero.is_empty());

    // rsplit - split from right
    let rsplit_parts: List<&str> = text.rsplit(',').collect();
    assert(rsplit_parts == ["e", "d", "c", "b", "a"]);

    // rsplitn - limit splits from right
    let rlimited: List<&str> = text.rsplitn(3, ',').collect();
    assert(rlimited == ["e", "d", "a,b,c"]);

    // split_once - split at first occurrence
    let once: Maybe<(&str, &str)> = text.split_once(',');
    assert(once == Some(("a", "b,c,d,e")));

    // rsplit_once - split at last occurrence
    let ronce: Maybe<(&str, &str)> = text.rsplit_once(',');
    assert(ronce == Some(("a,b,c,d", "e")));

    // split_once when not found
    let no_split: Maybe<(&str, &str)> = "hello".split_once(',');
    assert(no_split.is_none());

    // Commented out: split_terminator()/rsplit_terminator() not yet in stdlib
    // let terminated: Text = "a,b,c,";
    // let term_parts: List<&str> = terminated.split_terminator(',').collect();
    // assert(term_parts == ["a", "b", "c"]);
    //
    // let rterm_parts: List<&str> = terminated.rsplit_terminator(',').collect();
    // assert(rterm_parts == ["c", "b", "a"]);

    // split_inclusive - keep delimiter
    let inclusive: List<&str> = text.split_inclusive(',').collect();
    assert(inclusive == ["a,", "b,", "c,", "d,", "e"]);
}

/// Test line splitting
fn test_lines() {
    // Unix line endings
    let unix: Text = "line1\nline2\nline3";
    let unix_lines: List<&str> = unix.lines().collect();
    assert(unix_lines == ["line1", "line2", "line3"]);

    // Windows line endings
    let windows: Text = "line1\r\nline2\r\nline3";
    let win_lines: List<&str> = windows.lines().collect();
    assert(win_lines == ["line1", "line2", "line3"]);

    // Mixed line endings
    let mixed: Text = "line1\nline2\r\nline3\rline4";
    let mixed_lines: List<&str> = mixed.lines().collect();
    assert(mixed_lines.len() == 4);

    // Trailing newline
    let trailing: Text = "line1\nline2\n";
    let trailing_lines: List<&str> = trailing.lines().collect();
    assert(trailing_lines == ["line1", "line2"]);  // No empty at end

    // Empty lines preserved
    let with_empty: Text = "line1\n\nline3";
    let empty_lines: List<&str> = with_empty.lines().collect();
    assert(empty_lines == ["line1", "", "line3"]);

    // Single line
    let single: Text = "hello";
    let single_lines: List<&str> = single.lines().collect();
    assert(single_lines == ["hello"]);

    // Empty string
    let empty: Text = "";
    let empty_result: List<&str> = empty.lines().collect();
    assert(empty_result.is_empty());

    // Only newlines
    let only_newlines: Text = "\n\n\n";
    let newline_lines: List<&str> = only_newlines.lines().collect();
    assert(newline_lines == ["", "", ""]);
}

/// Test join operations
fn test_join() {
    // Join with separator
    let parts: List<&str> = ["a", "b", "c"];
    let joined: Text = parts.join(",");
    assert(joined == "a,b,c");

    // Join with multi-char separator
    let long_sep: Text = parts.join(" . ");
    assert(long_sep == "a . b . c");

    // Join empty separator
    let no_sep: Text = parts.join("");
    assert(no_sep == "abc");

    // Join single element
    let single: List<&str> = ["alone"];
    let single_joined: Text = single.join(",");
    assert(single_joined == "alone");

    // Join empty vector
    let empty: List<&str> = [];
    let empty_joined: Text = empty.join(",");
    assert(empty_joined == "");

    // Commented out: concat() returns List<Text> not Text
    // let concatenated: Text = parts.concat();
    // assert(concatenated == "abc");

    // Join with Texts (owned strings)
    let owned: List<Text> = ["Hello".to_text(), "World".to_text()];
    let owned_joined: Text = owned.join(" ");
    assert(owned_joined == "Hello World");

    // Join slices
    let slices: [&str; 3] = ["one", "two", "three"];
    let slice_joined: Text = slices.join("-");
    assert(slice_joined == "one-two-three");

    // Intersperse (in iterator)
    // let interspersed: Text = parts.iter().intersperse(&", ").collect();
}

/// Test collecting split results
fn test_collect_patterns() {
    let csv: Text = "name,age,city";

    // Collect to Vec
    let vec: List<&str> = csv.split(',').collect();
    assert(vec.len() == 3);

    // Collect to array (if size known)
    let arr: [&str; 3] = csv.splitn(3, ',')
        .collect<List<_>>()
        .try_into()
        .unwrap();
    assert(arr == ["name", "age", "city"]);

    // Collect to HashSet (removes duplicates)
    let with_dups: Text = "a,b,a,c,b";
    let set: std.collections.Set<&str> = with_dups.split(',').collect();
    assert(set.len() == 3);

    // Map and collect
    let numbers: Text = "1,2,3,4,5";
    let parsed: List<Int> = numbers
        .split(',')
        .map(|s| s.parse().unwrap())
        .collect();
    assert(parsed == [1, 2, 3, 4, 5]);

    // Filter and collect
    let filtered: List<&str> = csv
        .split(',')
        .filter(|s| s.len() > 3)
        .collect();
    assert(filtered == ["name", "city"]);

    // Enumerate
    let enumerated: List<(usize, &str)> = csv.split(',').enumerate().collect();
    assert(enumerated == [(0, "name"), (1, "age"), (2, "city")]);

    // Find in split
    let found: Maybe<&str> = csv.split(',').find(|s| s.starts_with('a'));
    assert(found == Some("age"));

    // Position in split
    let pos: Maybe<usize> = csv.split(',').position(|s| s == "age");
    assert(pos == Some(1));
}

/// Test edge cases
fn test_split_edge_cases() {
    // Empty string with empty pattern
    let empty_both: List<&str> = "".split("").collect();
    assert(empty_both == ["", ""]);

    // Pattern longer than string
    let short: Text = "ab";
    let long_pattern: List<&str> = short.split("abc").collect();
    assert(long_pattern == ["ab"]);

    // Pattern equals string
    let equal: Text = "abc";
    let equal_split: List<&str> = equal.split("abc").collect();
    assert(equal_split == ["", ""]);

    // Unicode pattern
    let unicode: Text = "\u{1F600}hello\u{1F600}world\u{1F600}";
    let emoji_split: List<&str> = unicode.split("\u{1F600}").collect();
    assert(emoji_split == ["", "hello", "world", ""]);

    // Very long string
    let long: Text = "a,".repeat(1000) + "end";
    let long_parts: List<&str> = long.split(',').collect();
    assert(long_parts.len() == 1001);

    // Consecutive delimiters
    let consecutive: Text = "a,,,,b";
    let consec_parts: List<&str> = consecutive.split(',').collect();
    assert(consec_parts == ["a", "", "", "", "b"]);

    // Delimiter at boundaries
    let boundaries: Text = ",a,b,";
    let bound_parts: List<&str> = boundaries.split(',').collect();
    assert(bound_parts == ["", "a", "b", ""]);

    // Null byte
    let with_null: Text = "a\0b\0c";
    let null_parts: List<&str> = with_null.split('\0').collect();
    assert(null_parts == ["a", "b", "c"]);

    // Split and rejoin should give original (mostly)
    let original: Text = "hello,world,test";
    let rejoined: Text = original.split(',').collect<List<_>>().join(",");
    assert(rejoined == original);
}
