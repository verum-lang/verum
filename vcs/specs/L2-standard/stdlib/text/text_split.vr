// @test: run
// @tier: 0
// @level: L2
// @tags: stdlib, text, split, join

/// Comprehensive test suite for Text split and join operations.
/// Tests various splitting patterns and string joining methods.

fn main() {
    test_split_basic();
    test_split_char();
    test_split_string();
    test_split_whitespace();
    test_split_predicate();
    test_split_variants();
    test_lines();
    test_join();
    test_collect_patterns();
    test_split_edge_cases();
}

/// Test basic split operations
fn test_split_basic() {
    let text: Text = "a,b,c,d,e";

    // Split by single character
    let parts: List<&str> = text.split(',').collect();
    assert(parts == ["a", "b", "c", "d", "e"]);
    assert(parts.len() == 5);

    // Split by string
    let text2: Text = "a.b.c";
    let parts2: List<&str> = text2.split(".").collect();
    assert(parts2 == ["a", "b", "c"]);

    // No matches returns original string
    let no_match: List<&str> = "hello".split(',').collect();
    assert(no_match == ["hello"]);

    // Empty string split
    let empty: List<&str> = "".split(',').collect();
    assert(empty == [""]);

    // Split at every character boundary
    let chars: List<&str> = "abc".split("").collect();
    // Results in ["", "a", "b", "c", ""]
    assert(chars.len() == 5);
}

/// Test splitting by character
fn test_split_char() {
    let text: Text = "hello world";

    // Split by space
    let words: List<&str> = text.split(' ').collect();
    assert(words == ["hello", "world"]);

    // Split by multiple occurrences
    let repeated: Text = "a--b--c";
    let parts: List<&str> = repeated.split('-').collect();
    assert(parts == ["a", "", "b", "", "c"]);

    // Split at start
    let start: Text = ",a,b,c";
    let start_parts: List<&str> = start.split(',').collect();
    assert(start_parts == ["", "a", "b", "c"]);

    // Split at end
    let end: Text = "a,b,c,";
    let end_parts: List<&str> = end.split(',').collect();
    assert(end_parts == ["a", "b", "c", ""]);

    // Unicode character split
    let unicode: Text = "a\u{2022}b\u{2022}c";  // Bullet points
    let unicode_parts: List<&str> = unicode.split('\u{2022}').collect();
    assert(unicode_parts == ["a", "b", "c"]);
}

/// Test splitting by string pattern
fn test_split_string() {
    let text: Text = "foo<=>bar<=>baz";

    // Multi-character delimiter
    let parts: List<&str> = text.split("<=>").collect();
    assert(parts == ["foo", "bar", "baz"]);

    // Delimiter not found
    let no_match: List<&str> = text.split("|||").collect();
    assert(no_match == ["foo<=>bar<=>baz"]);

    // Overlapping pattern
    let overlap: Text = "aaaa";
    let overlap_parts: List<&str> = overlap.split("aa").collect();
    assert(overlap_parts == ["", "", ""]);

    // Case sensitive
    let case: Text = "aAbAa";
    let case_parts: List<&str> = case.split("A").collect();
    assert(case_parts == ["a", "b", "a"]);

    // Longer delimiter than string
    let short: Text = "ab";
    let long_parts: List<&str> = short.split("abc").collect();
    assert(long_parts == ["ab"]);
}

/// Test whitespace splitting
fn test_split_whitespace() {
    let text: Text = "  hello   world  ";

    // split_whitespace - splits on any whitespace, ignores empty
    let words: List<&str> = text.split_whitespace().collect();
    assert(words == ["hello", "world"]);

    // split_ascii_whitespace - ASCII whitespace only
    let ascii_words: List<&str> = text.split_ascii_whitespace().collect();
    assert(ascii_words == ["hello", "world"]);

    // Regular split preserves empty strings
    let split_space: List<&str> = text.split(' ').collect();
    assert(split_space.len() > 2);  // Contains empty strings

    // Various whitespace characters
    let various: Text = "a\tb\nc\rd e";
    let various_words: List<&str> = various.split_whitespace().collect();
    assert(various_words == ["a", "b", "c", "d", "e"]);

    // Unicode whitespace
    let unicode_ws: Text = "a\u{00A0}b";  // Non-breaking space
    let unicode_words: List<&str> = unicode_ws.split_whitespace().collect();
    assert(unicode_words == ["a", "b"]);

    // Only whitespace
    let only_ws: Text = "   \t\n   ";
    let ws_parts: List<&str> = only_ws.split_whitespace().collect();
    assert(ws_parts.is_empty());

    // No whitespace
    let no_ws: Text = "hello";
    let no_ws_parts: List<&str> = no_ws.split_whitespace().collect();
    assert(no_ws_parts == ["hello"]);
}

