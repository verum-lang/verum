/// Test format_args! and dynamic formatting
fn test_format_args() {
    // format_args! for deferred formatting
    fn log_message(args: std.fmt.Arguments) {
        // Would write to log file
        let message: Text = format("{}", args);
        assert(!message.is_empty());
    }

    // Commented out: format_args() accepts at most 1 arg
    // log_message(format_args("User {} logged in", "Alice"));

    // Dynamic format width
    fn pad_to_width(value: &str, width: usize) -> Text {
        format("{:width$}", value, width = width)
    }
    assert(pad_to_width("hi", 10) == "        hi");

    // Dynamic precision
    fn format_float(value: Float, precision: usize) -> Text {
        format("{:.precision$}", value, precision = precision)
    }
    assert(format_float(3.14159, 2) == "3.14");
    assert(format_float(3.14159, 4) == "3.1416");

    // Conditional formatting
    fn format_number(n: Int, as_hex: Bool) -> Text {
        if as_hex {
            format("{:#x}", n)
        } else {
            format("{}", n)
        }
    }
    assert(format_number(255, false) == "255");
    assert(format_number(255, true) == "0xff");

    // Commented out: max() expects 0 args, not 1
    // fn format_table(headers: &List<Text>, rows: &List<List<Text>>) -> Text { ... }
    // let headers: List<Text> = ["Name", "Age", "City"];
