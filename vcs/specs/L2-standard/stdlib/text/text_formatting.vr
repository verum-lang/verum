// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: stdlib, text, formatting

/// Comprehensive test suite for Text formatting operations.
/// Tests format strings, number formatting, alignment, and display traits.

fn main() {
    test_basic_formatting();
    test_numeric_formatting();
    test_alignment_formatting();
    test_precision_formatting();
    test_sign_formatting();
    test_alternate_formatting();
    test_fill_and_width();
    test_debug_formatting();
    // test_custom_formatting();  // Commented out: fmt.Result not found
    test_format_args();
}

/// Test basic format string operations
fn test_basic_formatting() {
    // Simple placeholder
    let result: Text = format("{}", "hello");
    assert(result == "hello");

    // Multiple placeholders
    let multi: Text = format("{} {} {}", "one", "two", "three");
    assert(multi == "one two three");

    // Positional arguments
    let positional: Text = format("{0} {1} {0}", "a", "b");
    assert(positional == "a b a");

    // Named arguments
    let named: Text = format("{name} is {age} years old", name = "Alice", age = 30);
    assert(named == "Alice is 30 years old");

    // Mixed positional and named
    let mixed: Text = format("{0} {name} {1}", "first", "second", name = "middle");
    assert(mixed == "first middle second");

    // Escaped braces
    let escaped: Text = format("{{}}");
    assert(escaped == "{}");

    let escaped_content: Text = format("{{value: {}}}", 42);
    assert(escaped_content == "{value: 42}");

    // Empty format
    let empty: Text = format("");
    assert(empty == "");

    // Types that implement Display
    let int_fmt: Text = format("{}", 42);
    assert(int_fmt == "42");

    let float_fmt: Text = format("{}", 3.14);
    assert(float_fmt.starts_with("3.14"));

    let bool_fmt: Text = format("{}", true);
    assert(bool_fmt == "true");

    let char_fmt: Text = format("{}", 'x');
    assert(char_fmt == "x");
}

/// Test numeric formatting options
fn test_numeric_formatting() {
    // Integer bases
    let decimal: Text = format("{}", 255);
    assert(decimal == "255");

    let binary: Text = format("{:b}", 255);
    assert(binary == "11111111");

    let octal: Text = format("{:o}", 255);
    assert(octal == "377");

    let hex_lower: Text = format("{:x}", 255);
    assert(hex_lower == "ff");

    let hex_upper: Text = format("{:X}", 255);
    assert(hex_upper == "FF");

    // With alternate form (prefix)
    let bin_alt: Text = format("{:#b}", 255);
    assert(bin_alt == "0b11111111");

    let oct_alt: Text = format("{:#o}", 255);
    assert(oct_alt == "0o377");

    let hex_alt: Text = format("{:#x}", 255);
    assert(hex_alt == "0xff");

    let hex_alt_upper: Text = format("{:#X}", 255);
    assert(hex_alt_upper == "0xFF");

    // Exponential notation
    let exp_lower: Text = format("{:e}", 12345.6789);
    assert(exp_lower.contains("e"));

    let exp_upper: Text = format("{:E}", 12345.6789);
    assert(exp_upper.contains("E"));

    // Pointer formatting
    let ptr: Text = format("{:p}", &42);
    assert(ptr.starts_with("0x"));

    // Thousands separator (custom implementation)
    fn format_with_separators(n: Int) -> Text {
        let s = n.abs().to_text();
        let chars: List<Char> = s.chars().rev().collect();
        let grouped: Text = chars.chunks(3)
            .map(|chunk| chunk.iter().rev().collect<Text>())
            .rev()
            .collect<List<_>>()
            .join(",");
        if n < 0 { format("-{}", grouped) } else { grouped }
    }
    assert(format_with_separators(1234567) == "1,234,567");
    assert(format_with_separators(-1000) == "-1,000");
}

/// Test alignment formatting
fn test_alignment_formatting() {
    // Left alignment
    let left: Text = format("{:<10}", "hello");
    assert(left == "hello     ");
    assert(left.len() == 10);

    // Right alignment
    let right: Text = format("{:>10}", "hello");
    assert(right == "     hello");
    assert(right.len() == 10);

    // Center alignment
    let center: Text = format("{:^10}", "hello");
    assert(center == "  hello   ");
    assert(center.len() == 10);

    // Odd centering
    let odd_center: Text = format("{:^11}", "hello");
    assert(odd_center == "   hello   ");

    // Numbers alignment
    let num_right: Text = format("{:>6}", 42);
    assert(num_right == "    42");

    let num_left: Text = format("{:<6}", 42);
    assert(num_left == "42    ");

    // Multiple aligned values
    let table_row: Text = format("{:<10} {:>5} {:^8}", "Name", 123, "OK");
    assert(table_row.len() == 10 + 1 + 5 + 1 + 8);

    // No alignment if content is longer
    let long: Text = format("{:>3}", "hello");
    assert(long == "hello");
}

/// Test precision formatting
fn test_precision_formatting() {
    // Float precision
    let pi: Float = 3.141592653589793;

    let p0: Text = format("{:.0}", pi);
    assert(p0 == "3");

    let p1: Text = format("{:.1}", pi);
    assert(p1 == "3.1");

    let p2: Text = format("{:.2}", pi);
    assert(p2 == "3.14");

    let p4: Text = format("{:.4}", pi);
    assert(p4 == "3.1416");

    let p10: Text = format("{:.10}", pi);
    assert(p10 == "3.1415926536");

    // Precision with width
    let width_prec: Text = format("{:10.2}", pi);
    assert(width_prec == "      3.14");

    // Left aligned with precision
    let left_prec: Text = format("{:<10.2}", pi);
    assert(left_prec == "3.14      ");

    // String truncation with precision
    let truncated: Text = format("{:.5}", "hello world");
    assert(truncated == "hello");

    let short: Text = format("{:.3}", "hi");
    assert(short == "hi");  // Not padded

    // Precision from argument
    let dynamic_prec: Text = format("{:.prec$}", pi, prec = 3);
    assert(dynamic_prec == "3.142");

    // Exponential with precision
    let exp_prec: Text = format("{:.2e}", 12345.0);
    assert(exp_prec.contains("e+"));

    // Zero precision for floats
    let zero_prec: Text = format("{:.0}", 3.9);
    assert(zero_prec == "4");  // Rounded
}

/// Test sign formatting
fn test_sign_formatting() {
    // Default (only negative)
    let neg: Text = format("{}", -42);
    assert(neg == "-42");

    let pos: Text = format("{}", 42);
    assert(pos == "42");

    // Always show sign
    let plus_pos: Text = format("{:+}", 42);
    assert(plus_pos == "+42");

    let plus_neg: Text = format("{:+}", -42);
    assert(plus_neg == "-42");

    // Space for positive
    let space_pos: Text = format("{: }", 42);
    assert(space_pos == " 42");

    let space_neg: Text = format("{: }", -42);
    assert(space_neg == "-42");

    // Zero
    let plus_zero: Text = format("{:+}", 0);
    assert(plus_zero == "+0");

    // Floats with sign
    let float_plus: Text = format("{:+.2}", 3.14);
    assert(float_plus == "+3.14");

    let float_neg: Text = format("{:+.2}", -3.14);
    assert(float_neg == "-3.14");

    // Sign with width
    let sign_width: Text = format("{:+8}", 42);
    assert(sign_width == "     +42");

    // Sign with zero padding
    let sign_zero_pad: Text = format("{:+08}", 42);
    assert(sign_zero_pad == "+0000042");
}

/// Test alternate formatting (#)
fn test_alternate_formatting() {
    // Alternate for integers (prefix)
    assert(format("{:#b}", 10) == "0b1010");
    assert(format("{:#o}", 10) == "0o12");
    assert(format("{:#x}", 10) == "0xa");
    assert(format("{:#X}", 10) == "0xA");

    // Alternate for floats (always show decimal point)
    assert(format("{:#}", 3.0) == "3.");
    assert(format("{:#.0}", 3.0) == "3.");

    // Alternate with width
    let alt_width: Text = format("{:#10x}", 255);
    assert(alt_width.len() == 10);
    assert(alt_width.contains("0xff"));

    // Alternate with zero padding
    let alt_zero: Text = format("{:#010x}", 255);
    assert(alt_zero == "0x000000ff");

    // Debug alternate (pretty print)
    let list: List<Int> = [1, 2, 3];
    let debug_compact: Text = format("{:?}", list);
    let debug_pretty: Text = format("{:#?}", list);
    assert(debug_pretty.contains("\n"));  // Multi-line
}

/// Test fill and width formatting
fn test_fill_and_width() {
    // Custom fill character
    let dash_fill: Text = format("{:-<10}", "hi");
    assert(dash_fill == "hi--------");

    let star_fill: Text = format("{:*>10}", "hi");
    assert(star_fill == "********hi");

    let dot_center: Text = format("{:.^10}", "hi");
    assert(dot_center == "....hi....");

    // Zero padding for numbers
    let zero_pad: Text = format("{:05}", 42);
    assert(zero_pad == "00042");

    let neg_zero_pad: Text = format("{:05}", -42);
    assert(neg_zero_pad == "-0042");

    // Zero padding with sign
    let sign_zero: Text = format("{:+05}", 42);
    assert(sign_zero == "+0042");

    // Width from argument
    let dynamic_width: Text = format("{:width$}", "hi", width = 10);
    assert(dynamic_width == "        hi");

    // Fill and width with alignment
    let fill_left: Text = format("{:_<10}", 42);
    assert(fill_left == "42________");

    let fill_right: Text = format("{:_>10}", 42);
    assert(fill_right == "________42");

    // Hex with zero padding
    let hex_padded: Text = format("{:08x}", 255);
    assert(hex_padded == "000000ff");

    // Binary with zero padding
    let bin_padded: Text = format("{:08b}", 5);
    assert(bin_padded == "00000101");
}

/// Test debug formatting
fn test_debug_formatting() {
    // Debug for primitives
    assert(format("{:?}", 42) == "42");
    assert(format("{:?}", "hello") == "\"hello\"");  // Quoted
    assert(format("{:?}", 'x') == "'x'");  // With quotes

    // Debug for bool
    assert(format("{:?}", true) == "true");
    assert(format("{:?}", false) == "false");

    // Debug for Option/Maybe
    assert(format("{:?}", Some(42)) == "Some(42)");
    assert(format("{:?}", None<Int>) == "None");

    // Debug for Result
    let ok: Result<Int, Text> = Ok(42);
    let err: Result<Int, Text> = Err("error");
    assert(format("{:?}", ok) == "Ok(42)");
    assert(format("{:?}", err) == "Err(\"error\")");

    // Debug for collections
    let list: List<Int> = [1, 2, 3];
    assert(format("{:?}", list) == "[1, 2, 3]");

    let map: Map<Text, Int> = map!{"a" => 1, "b" => 2};
    let map_debug: Text = format("{:?}", map);
    assert(map_debug.contains("\"a\""));
    assert(map_debug.contains("1"));

    // Pretty debug
    let nested: List<List<Int>> = [[1, 2], [3, 4]];
    let pretty: Text = format("{:#?}", nested);
    assert(pretty.contains("\n"));

    // Lower hex debug
    assert(format("{:x?}", [15, 255]) == "[f, ff]");

    // Upper hex debug
    assert(format("{:X?}", [15, 255]) == "[F, FF]");

    // Debug for tuples
    let tuple: (Int, Text, Bool) = (42, "hello", true);
    assert(format("{:?}", tuple) == "(42, \"hello\", true)");

    // Debug for custom types (requires @derive(Debug))
    @derive(Debug)
    type Point is { x: Int, y: Int };

    let point = Point { x: 10, y: 20 };
    assert(format("{:?}", point) == "Point { x: 10, y: 20 }");

    let pretty_point: Text = format("{:#?}", point);
    assert(pretty_point.contains("\n"));
}

