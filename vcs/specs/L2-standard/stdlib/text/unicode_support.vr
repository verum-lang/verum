/// Test Unicode length measurements
fn test_unicode_length() {
    let text: Text = "Hello 世界 🌍";

    // Byte length (len())
    let byte_len: usize = text.len();
    // H(1) + e(1) + l(1) + l(1) + o(1) + space(1) + 世(3) + 界(3) + space(1) + 🌍(4)
    assert(byte_len == 17);

    // Character count
    let char_count: usize = text.chars().count();
    assert(char_count == 11);

    // is_empty
    assert(!text.is_empty());
    assert("".is_empty());

    // Compare byte vs char length
    let ascii: Text = "hello";
    assert(ascii.len() == ascii.chars().count());  // Equal for ASCII

    let unicode: Text = "世界";
    assert(unicode.len() > unicode.chars().count());  // Bytes > chars

    // UTF-16 length
    let utf16_len: usize = text.encode_utf16().count();
    // Most chars are 1 unit, some supplementary are 2

    // Grapheme cluster count (requires unicode-segmentation crate)
    // let grapheme_count = text.graphemes(true).count();

    // Width calculation (for terminal display)
    fn display_width(text: &Text) -> usize {
        text.chars().map(|c| {
            if c.is_ascii() {
                1
            } else if c.is_cjk() {  // CJK chars are typically double-width
                2
            } else {
                1
            }
        }).sum()
    }

    // Byte length for capacity planning
    fn required_bytes(text: &Text) -> usize {
        text.len()
    }
}

