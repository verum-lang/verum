/// Comprehensive test suite for Unicode support in Text.
/// Tests UTF-8 encoding, character handling, normalization, and internationalization.

fn main() {
    test_utf8_encoding();
    test_unicode_characters();
    test_unicode_iteration();
    test_unicode_length();
    test_unicode_indexing();
    test_unicode_case_conversion();
    test_unicode_normalization();
    test_unicode_properties();
    test_unicode_grapheme_clusters();
    test_unicode_scripts();
}

/// Test UTF-8 encoding fundamentals
fn test_utf8_encoding() {
    // ASCII (1 byte per character)
    let ascii: Text = "Hello";
    assert(ascii.len() == 5);
    assert(ascii.chars().count() == 5);

    // Latin extended (2 bytes per character)
    let latin: Text = "caf\u{00E9}";  // cafe with accent
    assert(latin == "cafe");
    assert(latin.len() == 5);  // 4 ASCII + 1 two-byte char
    assert(latin.chars().count() == 4);

    // CJK characters (3 bytes per character)
    let chinese: Text = "\u{4E2D}\u{6587}";  // "Chinese" in Chinese
    assert(chinese.len() == 6);  // 2 chars * 3 bytes
    assert(chinese.chars().count() == 2);

    // Emoji (4 bytes per character)
    let emoji: Text = "\u{1F600}";  // Grinning face
    assert(emoji.len() == 4);
    assert(emoji.chars().count() == 1);

    // Mixed encoding
    let mixed: Text = "Hello 世界! 🌍";
    assert(mixed.chars().count() == 11);  // H e l l o   世 界 !   🌍
    assert(mixed.len() > mixed.chars().count());

    // Valid UTF-8 from bytes
    let bytes: List<u8> = [0xE4, 0xB8, 0x96, 0xE7, 0x95, 0x8C];  // 世界
    let from_bytes: Text = Text.from_utf8(bytes).unwrap();
    assert(from_bytes == "世界");

    // Invalid UTF-8 detection
    let invalid_bytes: List<u8> = [0xFF, 0xFE];
    let result: Result<Text, Utf8Error> = Text.from_utf8(invalid_bytes);
    assert(result.is_err());

    // Lossy conversion (replaces invalid sequences)
    let invalid: List<u8> = [0x48, 0xFF, 0x69];  // H, invalid, i
    let lossy: Text = Text.from_utf8_lossy(&invalid);
    assert(lossy.contains("H"));
    assert(lossy.contains("i"));
    assert(lossy.contains("\u{FFFD}"));  // Replacement character

    // UTF-8 byte length of characters
    assert('A'.len_utf8() == 1);
    assert('e'.len_utf8() == 2);  // With accent
    assert('世'.len_utf8() == 3);
    assert('🌍'.len_utf8() == 4);
}

/// Test Unicode character support
fn test_unicode_characters() {
    // Latin
    let latin: Text = "ABCabc";
    assert(latin.chars().all(|c| c.is_alphabetic()));

    // Greek
    let greek: Text = "αβγδ";
    assert(greek.chars().count() == 4);
    assert(greek.chars().all(|c| c.is_alphabetic()));

    // Cyrillic
    let cyrillic: Text = "Привет";
    assert(cyrillic.chars().count() == 6);
    assert(cyrillic.chars().all(|c| c.is_alphabetic()));

    // Arabic
    let arabic: Text = "مرحبا";
    assert(arabic.chars().all(|c| c.is_alphabetic()));

    // Hebrew
    let hebrew: Text = "שלום";
    assert(hebrew.chars().all(|c| c.is_alphabetic()));

    // Japanese (Hiragana)
    let hiragana: Text = "こんにちは";
    assert(hiragana.chars().count() == 5);

    // Japanese (Katakana)
    let katakana: Text = "コンニチハ";
    assert(katakana.chars().count() == 5);

    // Japanese (Kanji)
    let kanji: Text = "日本語";
    assert(kanji.chars().count() == 3);

    // Korean (Hangul)
    let korean: Text = "안녕하세요";
    assert(korean.chars().count() == 5);

    // Thai
    let thai: Text = "สวัสดี";
    // Thai has combining characters
    assert(thai.chars().count() >= 4);

    // Emoji
    let emojis: Text = "😀🎉🌍🚀";
    assert(emojis.chars().count() == 4);

    // Emoji with skin tone modifiers
    let skin_tone: Text = "👋🏻👋🏼👋🏽👋🏾👋🏿";
    // Each is base emoji + modifier

    // Mathematical symbols
    let math: Text = "∑∏∫∞≈≠";
    assert(math.chars().count() == 6);

    // Currency symbols
    let currency: Text = "$€£¥₹₿";
    assert(currency.chars().count() == 6);
}

