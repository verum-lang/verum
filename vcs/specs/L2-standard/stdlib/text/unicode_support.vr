/// Test Unicode case conversion
fn test_unicode_case_conversion() {
    // Basic ASCII
    let hello: Text = "hello";
    assert(hello.to_uppercase() == "HELLO");
    assert("HELLO".to_lowercase() == "hello");

    // Greek
    let greek: Text = "Ελληνικά";
    let greek_upper: Text = greek.to_uppercase();
    let greek_lower: Text = greek_upper.to_lowercase();

    // German sharp s - special case
    let german: Text = "\u{00DF}";  // Sharp s: ß
    let german_upper: Text = german.to_uppercase();
    assert(german_upper == "SS");  // Becomes two characters!
    // Note: to_lowercase("SS") does NOT become ß

    // Turkish dotted/dotless i - requires locale
    let turkish_i: Text = "I\u{0131}";  // I and dotless i
    // Standard case conversion doesn't handle Turkish correctly
    // Need locale-aware conversion for: I ↔ ı, İ ↔ i

    // Title case (first char upper, rest lower)
    fn to_title_case(text: &Text) -> Text {
        let mut chars = text.chars();
        match chars.next() {
            None => Text.new(),
            Some(first) => {
                first.to_uppercase().to_text() + chars.as_str().to_lowercase()
            }
        }
    }
    assert(to_title_case(&"hELLO") == "Hello");

    // Case folding (for case-insensitive comparison)
    fn case_fold(text: &Text) -> Text {
        text.to_lowercase()  // Simple case folding
    }
    assert(case_fold(&"HELLO") == case_fold(&"hello"));

    // Preserve case pattern
    fn preserve_case(template: &Text, text: &Text) -> Text {
        template.chars().zip(text.chars())
            .map(|(t, c)| {
                if t.is_uppercase() {
                    c.to_uppercase().next().unwrap_or(c)
                } else {
                    c.to_lowercase().next().unwrap_or(c)
                }
            })
            .collect()
    }
    assert(preserve_case(&"HeLLo", &"world") == "WoRLd");
}

/// Test Unicode normalization
fn test_unicode_normalization() {
    // Composed vs Decomposed forms
    let composed: Text = "e\u{0301}";  // e + combining accent
    let precomposed: Text = "\u{00E9}";  // e with accent (single codepoint)

    // These look the same but are different byte sequences!
    assert(composed.len() != precomposed.len());
    assert(composed.chars().count() != precomposed.chars().count());

    // Visual equality (would require normalization)
    // assert(composed.nfc() == precomposed.nfc());  // With unicode-normalization crate

    // NFC (Canonical Decomposition, followed by Canonical Composition)
    // NFD (Canonical Decomposition)
    // NFKC (Compatibility Decomposition, followed by Canonical Composition)
    // NFKD (Compatibility Decomposition)

    // Common normalization needs:
    // - Searching: normalize both query and text to same form
    // - Storage: normalize before storing
    // - Comparison: normalize both sides

    // Combining characters
    let base: Text = "a";
    let combining: Text = "a\u{0301}\u{0327}";  // a + acute + cedilla
    assert(combining.chars().count() == 3);

    // Hangul composition
    let hangul_composed: Text = "한";  // Single composed character
    let hangul_decomposed: Text = "\u{1112}\u{1161}\u{11AB}";  // Decomposed
    assert(hangul_composed.chars().count() == 1);
    assert(hangul_decomposed.chars().count() == 3);

    // Width variations (NFKC normalizes these)
    let fullwidth_a: Text = "\u{FF21}";  // Fullwidth A
    let halfwidth_a: Text = "A";  // Normal A
    assert(fullwidth_a != halfwidth_a);
    // NFKC would make them equal

    // Compatibility characters
    let circled_a: Text = "\u{24B6}";  // Circled Latin Capital Letter A
    // NFKC would normalize to "A"
}

/// Test Unicode character properties
fn test_unicode_properties() {
    // Alphabetic
    assert('a'.is_alphabetic());
    assert('α'.is_alphabetic());  // Greek
    assert('世'.is_alphabetic());  // CJK (ideographic)
    assert(!'1'.is_alphabetic());
    assert(!' '.is_alphabetic());

    // Numeric
    assert('0'.is_numeric());
    assert('\u{0661}'.is_numeric());  // Arabic-Indic digit 1
    assert('\u{4E00}'.is_numeric());  // CJK "one" (ideographic)
    assert(!'a'.is_numeric());

    // Alphanumeric
    assert('a'.is_alphanumeric());
    assert('1'.is_alphanumeric());
    assert(!' '.is_alphanumeric());

    // Whitespace
    assert(' '.is_whitespace());
    assert('\t'.is_whitespace());
    assert('\n'.is_whitespace());
    assert('\u{00A0}'.is_whitespace());  // Non-breaking space
    assert(!'a'.is_whitespace());

    // ASCII specific
    assert('a'.is_ascii());
    assert('Z'.is_ascii());
    assert('9'.is_ascii());
    assert(!'世'.is_ascii());
    assert(!'é'.is_ascii());

    // Control characters
    assert('\0'.is_control());
    assert('\n'.is_control());
    assert('\x1B'.is_control());  // Escape
    assert(!'a'.is_control());

    // Uppercase/Lowercase
    assert('A'.is_uppercase());
    assert('Σ'.is_uppercase());  // Greek capital sigma
    assert(!'a'.is_uppercase());

    assert('a'.is_lowercase());
    assert('σ'.is_lowercase());  // Greek small sigma
    assert(!'A'.is_lowercase());

    // Check string properties
    fn is_all_ascii(text: &Text) -> Bool {
        text.chars().all(|c| c.is_ascii())
    }
    assert(is_all_ascii(&"hello"));
    assert(!is_all_ascii(&"héllo"));

    fn is_all_numeric(text: &Text) -> Bool {
        !text.is_empty() && text.chars().all(|c| c.is_numeric())
    }
    assert(is_all_numeric(&"12345"));
    assert(!is_all_numeric(&"123a5"));
}

/// Test grapheme cluster handling
fn test_unicode_grapheme_clusters() {
    // Grapheme clusters are user-perceived characters
    // They may consist of multiple Unicode code points

    // Flag emoji (two regional indicator symbols)
    let flag: Text = "🇺🇸";  // US flag
    assert(flag.chars().count() == 2);  // Two code points
    // But one grapheme cluster

    // Emoji with skin tone
    let hand: Text = "👋🏽";  // Waving hand + medium skin tone
    assert(hand.chars().count() == 2);
    // One grapheme cluster

    // Emoji with ZWJ (Zero Width Joiner)
    let family: Text = "👨‍👩‍👧";  // Family emoji (man + ZWJ + woman + ZWJ + girl)
    assert(family.chars().count() > 3);
    // One grapheme cluster (appears as single emoji)

    // Accented characters (combining)
    let accented: Text = "e\u{0301}";  // e + combining acute
    assert(accented.chars().count() == 2);
    // One grapheme cluster

    // Complex script clusters
    let devanagari: Text = "नि";  // Hindi - base + vowel sign
    // May be multiple code points, one grapheme

    // Counting user-perceived characters requires grapheme segmentation
    // Simplified version counting base characters
    fn approx_grapheme_count(text: &Text) -> usize {
        text.chars()
            .filter(|c| {
                // Filter out combining marks, modifiers, ZWJ
                !(*c >= '\u{0300}' && *c <= '\u{036F}')  // Combining diacriticals
                && *c != '\u{200D}'  // ZWJ
                && !(*c >= '\u{1F3FB}' && *c <= '\u{1F3FF}')  // Skin tones
            })
            .count()
    }

    // Proper solution: use unicode-segmentation crate
    // use unicode_segmentation.UnicodeSegmentation;
    // text.graphemes(true).count()

    // String reversal should preserve grapheme clusters
    fn reverse_graphemes(text: &Text) -> Text {
        // Simplified: just reverse chars (incorrect for complex graphemes)
        text.chars().rev().collect()
    }

    // Proper reversal would use:
    // text.graphemes(true).rev().collect()
}

/// Test Unicode script detection
fn test_unicode_scripts() {
    // Detect script of text based on first character
    fn primary_script(text: &Text) -> Text {
        if text.is_empty() { return "Unknown"; }
        // Use first character's code point
        let chars: List<Char> = text.chars().collect();
        if chars.is_empty() { return "Unknown"; }
        let c: Char = chars[0];
        let code = c as Int;
        if (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z') { "Latin" }
        else if code >= 0x0400 && code <= 0x04FF { "Cyrillic" }
        else if code >= 0x0370 && code <= 0x03FF { "Greek" }
        else if code >= 0x4E00 && code <= 0x9FFF { "CJK" }
        else if code >= 0x3040 && code <= 0x309F { "Hiragana" }
        else if code >= 0x30A0 && code <= 0x30FF { "Katakana" }
        else if code >= 0xAC00 && code <= 0xD7AF { "Hangul" }
        else if code >= 0x0600 && code <= 0x06FF { "Arabic" }
        else if code >= 0x0590 && code <= 0x05FF { "Hebrew" }
        else if code >= 0x0900 && code <= 0x097F { "Devanagari" }
        else { "Unknown" }
    }

    assert(primary_script(&"Hello") == "Latin");
    assert(primary_script(&"Привет") == "Cyrillic");
    assert(primary_script(&"Γεια") == "Greek");
    assert(primary_script(&"你好") == "CJK");
    assert(primary_script(&"こんにちは") == "Hiragana");
    assert(primary_script(&"안녕") == "Hangul");

    // Bidirectional text (RTL)
    fn has_rtl(text: &Text) -> Bool {
        text.chars().any(|c| {
            (c >= '\u{0590}' && c <= '\u{05FF}') ||  // Hebrew
            (c >= '\u{0600}' && c <= '\u{06FF}') ||  // Arabic
            (c >= '\u{0750}' && c <= '\u{077F}')     // Arabic Supplement
        })
    }

    assert(!has_rtl(&"Hello"));
    assert(has_rtl(&"שלום"));
    assert(has_rtl(&"مرحبا"));

    // Mixed scripts (common in international text)
    let mixed: Text = "Hello Привет 你好";
    assert(mixed.chars().any(|c| (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')));
    assert(mixed.chars().any(|c| c >= '\u{0400}' && c <= '\u{04FF}'));
    assert(mixed.chars().any(|c| c >= '\u{4E00}' && c <= '\u{9FFF}'));

    // Confusable detection (basic homoglyph check)
    fn has_confusable_latin(text: &Text) -> Bool {
        // Check for Cyrillic characters that look like Latin
        text.chars().any(|c| {
            c is (
                '\u{0410}' |  // А (Cyrillic) looks like A
                '\u{0412}' |  // В (Cyrillic) looks like B
                '\u{0415}' |  // Е (Cyrillic) looks like E
                '\u{041A}' |  // К (Cyrillic) looks like K
                '\u{041C}' |  // М (Cyrillic) looks like M
                '\u{041D}' |  // Н (Cyrillic) looks like H
                '\u{041E}' |  // О (Cyrillic) looks like O
                '\u{0420}' |  // Р (Cyrillic) looks like P
                '\u{0421}' |  // С (Cyrillic) looks like C
                '\u{0422}' |  // Т (Cyrillic) looks like T
                '\u{0425}' |  // Х (Cyrillic) looks like X
                '\u{0430}' |  // а (Cyrillic) looks like a
                '\u{0435}' |  // е (Cyrillic) looks like e
                '\u{043E}' |  // о (Cyrillic) looks like o
                '\u{0440}' |  // р (Cyrillic) looks like p
                '\u{0441}' |  // с (Cyrillic) looks like c
                '\u{0443}' |  // у (Cyrillic) looks like y
                '\u{0445}'    // х (Cyrillic) looks like x
            )
        })
    }

    // Potential phishing attempt
    let suspicious: Text = "аpple.com";  // First 'a' is Cyrillic!
    assert(has_confusable_latin(&suspicious));
}
