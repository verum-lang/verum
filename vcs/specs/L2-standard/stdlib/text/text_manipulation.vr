    // let mut text: Text = "hello";
    // assert(remove_first_occurrence(&mut text, 'l'));
    // assert(text == "helo");
}

/// Test transformation operations
fn test_text_transformation() {
    // Reverse (using chars for Unicode safety)
    let text: Text = "hello";
    let reversed: Text = text.chars().rev().collect();
    assert(reversed == "olleh");

    // Reverse Unicode
    let unicode: Text = "Hello 世界";
    let unicode_rev: Text = unicode.chars().rev().collect();
    assert(unicode_rev == "界世 olleH");

    // Filter characters
    let with_punct: Text = "Hello, World!";
    let letters_only: Text = with_punct.chars()
        .filter(|c| c.is_alphabetic())
        .collect();
    assert(letters_only == "HelloWorld");

    // Map characters
    let mapped: Text = text.chars()
        .map(|c| if c == 'l' { 'L' } else { c })
        .collect();
    assert(mapped == "heLLo");

    // ROT13
    fn rot13(text: &Text) -> Text {
        text.chars().map(|c| {
            match c {
                'a'..='m' | 'A'..='M' => ((c as u8) + 13) as char,
                'n'..='z' | 'N'..='Z' => ((c as u8) - 13) as char,
                _ => c,
            }
        }).collect()
    }
    let original: Text = "Hello World";
    let encoded: Text = rot13(&original);
    let decoded: Text = rot13(&encoded);
    assert(decoded == original);

    // Commented out: escape_default() not yet in stdlib
    // let needs_escape: Text = "Hello\t\"World\"";
    // let escaped: Text = needs_escape.escape_default().to_text();
    // assert(escaped.contains("\\t"));
    // assert(escaped.contains("\\\""));

    // Unescape (parse escaped string)
    let escaped_str: Text = """Hello\nWorld""";
    // Custom unescape logic would be needed

    // encode/decode URL
    fn url_encode(text: &Text) -> Text {
        text.chars().map(|c| {
            match c {
                'a'..='z' | 'A'..='Z' | '0'..='9' | '-' | '_' | '.' | '~' => c.to_text(),
                ' ' => "+".to_text(),
                _ => format("%{:02X}", c as u32),
            }
        }).collect()
    }
    let url: Text = "hello world & more";
    let encoded_url: Text = url_encode(&url);
    assert(encoded_url.contains("+"));
    assert(encoded_url.contains("%26"));
}
