// @test: run
// @tier: 0
// @level: L2
// @tags: stdlib, text, encoding, utf8, unicode

/// Comprehensive test suite for Text encoding operations.
/// Tests UTF-8 encoding/decoding, character handling, and byte manipulation.

fn main() {
    test_utf8_basics();
    test_utf8_encoding();
    test_utf8_decoding();
    test_utf8_validation();
    test_unicode_properties();
    test_char_encoding();
    test_byte_operations();
    test_encoding_conversions();
    test_grapheme_clusters();
    test_normalization();
}

/// Test UTF-8 basics
fn test_utf8_basics() {
    // ASCII characters are 1 byte
    let ascii: Text = "Hello";
    assert(ascii.len() == 5);  // 5 bytes
    assert(ascii.chars().count() == 5);  // 5 characters

    // Latin extended characters may be 2 bytes
    let latin: Text = "\u{00E9}";  // e with acute (e)
    assert(latin.chars().count() == 1);
    assert(latin.len() == 2);

    // CJK characters are 3 bytes
    let chinese: Text = "\u{4E2D}";  // "middle"
    assert(chinese.chars().count() == 1);
    assert(chinese.len() == 3);

    // Emoji can be 4 bytes
    let emoji: Text = "\u{1F600}";  // Grinning face
    assert(emoji.chars().count() == 1);
    assert(emoji.len() == 4);

    // Mixed content
    let mixed: Text = "A\u{00E9}\u{4E2D}\u{1F600}";
    assert(mixed.chars().count() == 4);
    assert(mixed.len() == 1 + 2 + 3 + 4);  // 10 bytes
}

/// Test UTF-8 encoding
fn test_utf8_encoding() {
    // Encode string to bytes
    let text: Text = "Hello";
    let bytes: &[u8] = text.as_bytes();
    assert(bytes == &[72, 101, 108, 108, 111]);

    // Encode Unicode characters
    let unicode: Text = "\u{00E9}";  // e
    let unicode_bytes: &[u8] = unicode.as_bytes();
    assert(unicode_bytes == &[0xC3, 0xA9]);  // UTF-8 encoding

    // Encode emoji
    let emoji: Text = "\u{1F600}";
    let emoji_bytes: &[u8] = emoji.as_bytes();
    assert(emoji_bytes == &[0xF0, 0x9F, 0x98, 0x80]);

    // Commented out: encode_utf8() returns Int not &str
    // fn char_to_utf8(c: char) -> List<u8> {
    //     let mut buf: [u8; 4] = [0; 4];
    //     let s: &str = c.encode_utf8(&mut buf);
    //     s.as_bytes().to_vec()
    // }
    // assert(char_to_utf8('A') == [65]);
    // assert(char_to_utf8('\u{00E9}') == [0xC3, 0xA9]);
    // assert(char_to_utf8('\u{1F600}') == [0xF0, 0x9F, 0x98, 0x80]);

    // UTF-8 length prediction
    fn utf8_len(c: char) -> usize {
        c.len_utf8()
    }

    assert(utf8_len('A') == 1);
    assert(utf8_len('\u{00E9}') == 2);
    assert(utf8_len('\u{4E2D}') == 3);
    assert(utf8_len('\u{1F600}') == 4);
}

/// Test UTF-8 decoding
fn test_utf8_decoding() {
    // Decode valid UTF-8 bytes
    let bytes: List<u8> = [72, 101, 108, 108, 111];
    let text: Text = Text.from_utf8(bytes).unwrap();
    assert(text == "Hello");

    // Decode Unicode bytes
    let unicode_bytes: List<u8> = [0xC3, 0xA9];  // e
    let unicode: Text = Text.from_utf8(unicode_bytes).unwrap();
    assert(unicode == "\u{00E9}");

    // Decode emoji bytes
    let emoji_bytes: List<u8> = [0xF0, 0x9F, 0x98, 0x80];
    let emoji: Text = Text.from_utf8(emoji_bytes).unwrap();
    assert(emoji == "\u{1F600}");

    // from_utf8_lossy - replaces invalid sequences
    let invalid: List<u8> = [72, 101, 0xFF, 108, 111];
    let lossy: Text = Text.from_utf8_lossy(&invalid);
    assert(lossy.contains('\u{FFFD}'));  // Replacement character

    // from_utf8_unchecked (unsafe)
    // let unchecked: Text = unsafe { Text.from_utf8_unchecked(bytes) };

    // Decode character by character
    let text2: Text = "Hello";
    let mut decoded: List<char> = List.new();
    for byte in text2.bytes() {
        // Note: This only works for ASCII
        if byte < 128 {
            decoded.push(byte as char);
        }
    }
    assert(decoded == ['H', 'e', 'l', 'l', 'o']);
}

/// Test UTF-8 validation
fn test_utf8_validation() {
    // Valid UTF-8 sequences
    assert(std.str.from_utf8(&[72, 101, 108, 108, 111]).is_ok());
    assert(std.str.from_utf8(&[0xC3, 0xA9]).is_ok());
    assert(std.str.from_utf8(&[0xF0, 0x9F, 0x98, 0x80]).is_ok());

    // Invalid: standalone continuation byte
    assert(std.str.from_utf8(&[0x80]).is_err());

    // Invalid: incomplete sequence
    assert(std.str.from_utf8(&[0xC3]).is_err());  // Missing second byte
    assert(std.str.from_utf8(&[0xF0, 0x9F]).is_err());  // Missing bytes

    // Invalid: overlong encoding (security issue)
    assert(std.str.from_utf8(&[0xC0, 0x80]).is_err());  // Overlong NUL

    // Invalid: surrogate code points (U+D800-U+DFFF)
    assert(std.str.from_utf8(&[0xED, 0xA0, 0x80]).is_err());  // U+D800

    // Get error details
    match std.str.from_utf8(&[72, 0xFF, 108]) {
        Ok(_) => panic("should fail"),
        Err(e) => {
            assert(e.valid_up_to() == 1);  // Valid through index 0
        }
    }

    // Validate a string is valid UTF-8
    fn is_valid_utf8(bytes: &[u8]) -> Bool {
        std.str.from_utf8(bytes).is_ok()
    }

    assert(is_valid_utf8(b"Hello"));
    assert(!is_valid_utf8(&[0xFF, 0xFE]));
}

/// Test Unicode character properties
fn test_unicode_properties() {
    // Character classification
    assert('a'.is_alphabetic());
    assert('Z'.is_alphabetic());
    assert('\u{03B1}'.is_alphabetic());  // Greek alpha
    assert(!'1'.is_alphabetic());

    assert('5'.is_numeric());
    assert('\u{0661}'.is_numeric());  // Arabic-Indic digit one
    assert(!'a'.is_numeric());

    assert('a'.is_alphanumeric());
    assert('5'.is_alphanumeric());
    assert(!' '.is_alphanumeric());

    // Whitespace
    assert(' '.is_whitespace());
    assert('\t'.is_whitespace());
    assert('\n'.is_whitespace());
    assert('\u{00A0}'.is_whitespace());  // Non-breaking space
    assert(!'a'.is_whitespace());

    // Case properties
    assert('A'.is_uppercase());
    assert('a'.is_lowercase());
    assert(!'1'.is_uppercase());
    assert(!'1'.is_lowercase());

    // ASCII specific
    assert('A'.is_ascii());
    assert('a'.is_ascii_lowercase());
    assert('A'.is_ascii_uppercase());
    assert('5'.is_ascii_digit());
    assert('f'.is_ascii_hexdigit());
    assert(!' '.is_ascii_graphic());
    assert(!' '.is_ascii_whitespace());

    // Control characters
    assert('\x00'.is_control());
    assert('\x1F'.is_control());
    assert('\n'.is_control());
    assert(!'a'.is_control());

    // Character to/from digit
    assert('5'.to_digit(10) == Some(5));
    assert('f'.to_digit(16) == Some(15));
    assert('g'.to_digit(16).is_none());

    assert(char.from_digit(5, 10) == Some('5'));
    assert(char.from_digit(15, 16) == Some('f'));
}

/// Test character encoding details
fn test_char_encoding() {
    // Character is a Unicode scalar value (32 bits)
    assert(char.size == 4);

    // Code point to character
    let c: char = char.from_u32(0x1F600).unwrap();  // Emoji
    assert(c == '\u{1F600}');

    // Invalid code points return None
    assert(char.from_u32(0xD800).is_none());  // Surrogate
    assert(char.from_u32(0x110000).is_none());  // Too large

    // Commented out: Char as u32 cast not yet supported
    // let code: u32 = 'A' as u32;
    // assert(code == 65);
    //
    // let emoji_code: u32 = '\u{1F600}' as u32;
    // assert(emoji_code == 0x1F600);

    // UTF-16 encoding
    fn char_to_utf16(c: char) -> List<u16> {
        let mut buf: [u16; 2] = [0; 2];
        let len: usize = c.encode_utf16(&mut buf).len();
        buf[..len].to_vec()
    }

    assert(char_to_utf16('A') == [65]);
    assert(char_to_utf16('\u{1F600}').len() == 2);  // Surrogate pair

    // UTF-16 length
    assert('A'.len_utf16() == 1);
    assert('\u{1F600}'.len_utf16() == 2);

    // Escape sequences
    let newline: char = '\n';
    let tab: char = '\t';
    let backslash: char = '\\';
    let null: char = '\0';

    // Commented out: to_u32() not yet in stdlib for Char
    // assert(newline.to_u32() == 10);
    // assert(tab.to_u32() == 9);
    // assert(backslash.to_u32() == 92);
    // assert(null.to_u32() == 0);
}

/// Test byte-level operations
fn test_byte_operations() {
    let text: Text = "Hello";

    // bytes() iterator
    let byte_vec: List<u8> = text.bytes().collect();
    assert(byte_vec == [72, 101, 108, 108, 111]);

    // Access specific byte
    assert(text.as_bytes()[0] == 72);

    // Byte length vs char length
    let unicode: Text = "\u{4E2D}\u{6587}";  // Chinese characters
    assert(unicode.bytes().count() == 6);  // 3 bytes each
    assert(unicode.chars().count() == 2);

    // Find byte position
    fn find_byte_position(s: &str, target: u8) -> Maybe<usize> {
        s.bytes().position(|b| b == target)
    }

    assert(find_byte_position("Hello", b'l') == Some(2));
    assert(find_byte_position("Hello", b'x').is_none());

    // Safe byte slicing (at character boundaries)
    let text2: Text = "Hello";
    let slice: &str = &text2[0..3];
    assert(slice == "Hel");

    // Unsafe byte slicing of Unicode may panic
    // let unicode_slice = &unicode[0..1];  // Panics! Not a char boundary

    // get() for safe slicing
    let safe_slice: Maybe<&str> = unicode.get(0..3);  // First Chinese char
    assert(safe_slice.is_some());

    let bad_slice: Maybe<&str> = unicode.get(0..1);  // Not a char boundary
    assert(bad_slice.is_none());

    // is_char_boundary
    assert(unicode.is_char_boundary(0));
    assert(unicode.is_char_boundary(3));
    assert(!unicode.is_char_boundary(1));
}

/// Test encoding conversions
fn test_encoding_conversions() {
    // UTF-8 to UTF-16
    fn to_utf16(s: &str) -> List<u16> {
        s.encode_utf16().collect()
    }

    let utf16: List<u16> = to_utf16("Hello");
    assert(utf16 == [72, 101, 108, 108, 111]);

    // UTF-16 with surrogate pairs
    let emoji_utf16: List<u16> = to_utf16("\u{1F600}");
    assert(emoji_utf16.len() == 2);

    // Commented out: char.decode_utf16() collect type mismatch
    // fn from_utf16(units: &[u16]) -> Result<Text, std.char.DecodeUtf16Error> {
    //     char.decode_utf16(units.iter().copied())
    //         .collect<Result<Text, _>>()
    // }
    // let back: Text = from_utf16(&utf16).unwrap();
    // assert(back == "Hello");

    // Commented out: decode_utf16 collect type mismatch
    // fn from_utf16_lossy(units: &[u16]) -> Text {
    //     char.decode_utf16(units.iter().copied())
    //         .map(|r| r.unwrap_or('\u{FFFD}'))
    //         .collect()
    // }
    // let invalid_utf16: List<u16> = [0xD800];
    // let lossy: Text = from_utf16_lossy(&invalid_utf16);
    // assert(lossy.contains('\u{FFFD}'));

    // ASCII encoding
    fn to_ascii(s: &str) -> List<u8> {
        s.bytes().filter(|b| b.is_ascii()).collect()
    }

    let ascii: List<u8> = to_ascii("Hello\u{00E9}");
    assert(ascii == [72, 101, 108, 108, 111]);

    // Latin-1 (ISO-8859-1) - each byte is a code point
    fn from_latin1(bytes: &[u8]) -> Text {
        bytes.iter().map(|&b| b as char).collect()
    }

    let latin1: Text = from_latin1(&[72, 101, 108, 108, 111]);
    assert(latin1 == "Hello");
}

/// Test grapheme clusters
fn test_grapheme_clusters() {
    // Grapheme cluster = user-perceived character
    // May be multiple code points

    // Flag emoji (two regional indicator symbols)
    let flag: Text = "\u{1F1FA}\u{1F1F8}";  // US flag
    assert(flag.chars().count() == 2);  // 2 code points
    // But 1 grapheme cluster (requires unicode-segmentation crate)

    // Combining characters
    let combined: Text = "e\u{0301}";  // e + combining acute
    assert(combined.chars().count() == 2);  // 2 code points
    // But 1 grapheme cluster

    // Zero-width joiner sequences
    let family: Text = "\u{1F468}\u{200D}\u{1F469}\u{200D}\u{1F467}";
    // Multiple code points, 1 grapheme cluster

    // Simple character iteration (by code point)
    let chars: List<char> = combined.chars().collect();
    assert(chars.len() == 2);

    // For proper grapheme cluster iteration, use unicode-segmentation:
    // use unicode_segmentation.UnicodeSegmentation;
    // let graphemes: List<&str> = combined.graphemes(true).collect();
    // assert(graphemes.len() == 1);

    // Character indices
    let indices: List<(usize, char)> = combined.char_indices().collect();
    assert(indices.len() == 2);
    assert(indices[0] == (0, 'e'));
    assert(indices[1] == (1, '\u{0301}'));
}

/// Test Unicode normalization
fn test_normalization() {
    // Same character, different representations
    let nfc: Text = "\u{00E9}";  // Precomposed e with acute
    let nfd: Text = "e\u{0301}";  // Decomposed e + combining acute

    // They look the same but are different byte sequences
    assert(nfc != nfd);
    assert(nfc.len() != nfd.len());

    // After normalization, they should be equal
    // (requires unicode-normalization crate)
    // use unicode_normalization.UnicodeNormalization;
    // let nfc_normalized: Text = nfd.nfc().collect();
    // assert(nfc_normalized == nfc);

    // Compatibility equivalence
    // "\u{FB01}" (fi ligature) vs "fi"
    let ligature: Text = "\u{FB01}";
    let expanded: Text = "fi";
    assert(ligature != expanded);
    // But NFKC/NFKD normalization would make them equal

    // Case folding for comparison
    fn case_fold_eq(a: &str, b: &str) -> Bool {
        a.to_lowercase() == b.to_lowercase()
    }

    assert(case_fold_eq("Hello", "HELLO"));
    assert(case_fold_eq("\u{00DF}", "ss"));  // German sharp S

    // Simple equality check with normalization placeholder
    fn normalized_eq(a: &str, b: &str) -> Bool {
        // In practice, use unicode-normalization crate
        a == b  // Simplified
    }
}
