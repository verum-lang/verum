// @test: run
// @tier: 0
// @level: L2
// @tags: stdlib, time, duration

/// Comprehensive test suite for Duration type.
/// Tests time duration creation, arithmetic, and conversions.

fn main() {
    test_duration_creation();
    test_duration_components();
    test_duration_arithmetic();
    test_duration_comparison();
    test_duration_conversion();
    test_duration_formatting();
    test_duration_special_values();
    test_duration_checked_operations();
    test_duration_saturating_operations();
    test_duration_from_string();
}

/// Test various ways to create durations
fn test_duration_creation() {
    mount std.time.Duration;

    // From seconds
    let from_secs: Duration = Duration.from_secs(60);
    assert(from_secs.as_secs() == 60);

    // From milliseconds
    let from_millis: Duration = Duration.from_millis(1500);
    assert(from_millis.as_millis() == 1500);

    // From microseconds
    let from_micros: Duration = Duration.from_micros(1500000);
    assert(from_micros.as_micros() == 1500000);

    // From nanoseconds
    let from_nanos: Duration = Duration.from_nanos(1_000_000_000);
    assert(from_nanos.as_nanos() == 1_000_000_000);
    assert(from_nanos.as_secs() == 1);

    // From seconds and nanoseconds
    let precise: Duration = Duration.new(5, 500_000_000);
    assert(precise.as_secs() == 5);
    assert(precise.subsec_nanos() == 500_000_000);

    // From floating-point seconds
    let from_float: Duration = Duration.from_secs_f64(2.5);
    assert(from_float.as_secs() == 2);
    assert(from_float.subsec_millis() == 500);

    let from_f32: Duration = Duration.from_secs_f32(1.25);
    assert(from_f32.as_secs() == 1);
    assert(from_f32.subsec_millis() == 250);

    // Zero duration
    let zero: Duration = Duration.ZERO;
    assert(zero.as_secs() == 0);
    assert(zero.as_nanos() == 0);
    assert(zero.is_zero());

    // Max duration
    let max: Duration = Duration.MAX;
    assert(max.as_secs() > 0);

    // Commented out: Duration.SECOND constant not available
    let one_sec: Duration = Duration.from_secs(1);
    assert(one_sec.as_secs() == 1);

    // Commented out: Duration.MILLISECOND/MICROSECOND/NANOSECOND constants not available
    let one_ms: Duration = Duration.from_millis(1);
    assert(one_ms.as_millis() == 1);

    let one_us: Duration = Duration.from_micros(1);
    assert(one_us.as_micros() == 1);

    let one_ns: Duration = Duration.from_nanos(1);
    assert(one_ns.as_nanos() == 1);
}

/// Test duration components
fn test_duration_components() {
    mount std.time.Duration;

    let d: Duration = Duration.new(65, 123_456_789);

    // Whole seconds
    assert(d.as_secs() == 65);

    // Subsecond nanoseconds
    assert(d.subsec_nanos() == 123_456_789);

    // Subsecond microseconds
    assert(d.subsec_micros() == 123_456);

    // Subsecond milliseconds
    assert(d.subsec_millis() == 123);

    // Total in various units
    assert(d.as_nanos() == 65_123_456_789);
    assert(d.as_micros() == 65_123_456);
    assert(d.as_millis() == 65_123);

    // As floating-point seconds
    let secs_f64: f64 = d.as_secs_f64();
    assert((secs_f64 - 65.123456789).abs() < 1e-9);

    let secs_f32: f32 = d.as_secs_f32();
    assert((secs_f32 - 65.123456).abs() < 1e-5);

    // Zero duration components
    let zero: Duration = Duration.ZERO;
    assert(zero.as_secs() == 0);
    assert(zero.subsec_nanos() == 0);

    // Large duration
    let large: Duration = Duration.from_secs(3600);  // 1 hour
    assert(large.as_secs() == 3600);
    assert(large.as_millis() == 3_600_000);
}

