/// Test duration comparison
fn test_duration_comparison() {
    mount std.time.Duration;

    let a: Duration = Duration.from_secs(5);
    let b: Duration = Duration.from_secs(3);
    let c: Duration = Duration.from_secs(5);

    // Equality
    assert(a == c);
    assert(a != b);

    // Ordering
    assert(a > b);
    assert(b < a);
    assert(a >= c);
    assert(b <= a);

    // Min/max
    assert(a.min(b) == b);
    assert(a.max(b) == a);

    // Comparison with zero
    let zero: Duration = Duration.ZERO;
    assert(a > zero);
    assert(zero < a);
    assert(zero == Duration.ZERO);

    // Sorting durations
    let mut durations: List<Duration> = [
        Duration.from_millis(500),
        Duration.from_secs(1),
        Duration.from_millis(100),
        Duration.from_secs(2),
    ];
    durations.sort();
    assert(durations[0] == Duration.from_millis(100));
    assert(durations[3] == Duration.from_secs(2));

    // is_zero
    assert(Duration.ZERO.is_zero());
    assert(!a.is_zero());

    // Compare nanosecond precision
    let precise_a: Duration = Duration.from_nanos(1_000_000_001);
    let precise_b: Duration = Duration.from_nanos(1_000_000_000);
    assert(precise_a > precise_b);
}

/// Test duration conversion to other types
fn test_duration_conversion() {
    mount std.time.Duration;

    let d: Duration = Duration.from_secs(3661);  // 1 hour, 1 minute, 1 second

    // To total seconds
    assert(d.as_secs() == 3661);

    // To total milliseconds
    assert(d.as_millis() == 3_661_000);

    // To float seconds
    let secs: f64 = d.as_secs_f64();
    assert((secs - 3661.0).abs() < 0.001);

    // Custom conversion to hours/minutes/seconds
    fn to_hms(d: Duration) -> (u64, u64, u64) {
        let total_secs = d.as_secs();
        let hours = total_secs / 3600;
        let minutes = (total_secs % 3600) / 60;
        let seconds = total_secs % 60;
        (hours, minutes, seconds)
    }

    let (h, m, s) = to_hms(d);
    assert(h == 1);
    assert(m == 1);
    assert(s == 1);

    // Conversion constants
    const NANOS_PER_SEC: u64 = 1_000_000_000;
    const NANOS_PER_MILLI: u64 = 1_000_000;
    const NANOS_PER_MICRO: u64 = 1_000;

    let one_sec: Duration = Duration.from_secs(1);
    assert(one_sec.as_nanos() == NANOS_PER_SEC as u128);

    // Try_from patterns
    let secs: u64 = 10;
    let d: Duration = Duration.from_secs(secs);
    let back: u64 = d.as_secs();
    assert(back == secs);
}

/// Test duration formatting
fn test_duration_formatting() {
    mount std.time.Duration;

    let d: Duration = Duration.new(65, 123_456_789);

    // Debug format
    let debug: Text = format("{:?}", d);
    // Output like: 65.123456789s

    // Custom formatting
    fn format_duration(d: Duration) -> Text {
        let secs = d.as_secs();
        let nanos = d.subsec_nanos();

        if secs == 0 {
            if nanos < 1000 {
                format("{}ns", nanos)
            } else if nanos < 1_000_000 {
                format("{:.3}us", nanos as f64 / 1000.0)
            } else {
                format("{:.3}ms", nanos as f64 / 1_000_000.0)
            }
        } else if secs < 60 {
            format("{:.3}s", d.as_secs_f64())
        } else if secs < 3600 {
            format("{}m {}s", secs / 60, secs % 60)
        } else {
            format("{}h {}m {}s", secs / 3600, (secs % 3600) / 60, secs % 60)
        }
    }

    assert(format_duration(Duration.from_nanos(500)) == "500ns");
    assert(format_duration(Duration.from_micros(500)) == "500.000us");
    assert(format_duration(Duration.from_millis(500)) == "500.000ms");
    assert(format_duration(Duration.from_secs(30)) == "30.000s");
    assert(format_duration(Duration.from_secs(90)) == "1m 30s");
    assert(format_duration(Duration.from_secs(3661)) == "1h 1m 1s");

    // ISO 8601 duration format
    fn to_iso8601(d: Duration) -> Text {
        let secs = d.as_secs();
        let hours = secs / 3600;
        let minutes = (secs % 3600) / 60;
        let seconds = secs % 60;

        let mut result: Text = "PT".to_text();
        if hours > 0 {
            result.push_str(&format("{}H", hours));
        }
        if minutes > 0 {
            result.push_str(&format("{}M", minutes));
        }
        if seconds > 0 || (hours == 0 && minutes == 0) {
            result.push_str(&format("{}S", seconds));
        }
        result
    }

    assert(to_iso8601(Duration.from_secs(3661)) == "PT1H1M1S");
    assert(to_iso8601(Duration.from_secs(90)) == "PT1M30S");
    assert(to_iso8601(Duration.from_secs(0)) == "PT0S");
}

/// Test special duration values
fn test_duration_special_values() {
    mount std.time.Duration;

    // Zero
    let zero: Duration = Duration.ZERO;
    assert(zero.is_zero());
    assert(zero.as_secs() == 0);
    assert(zero.as_nanos() == 0);

    // Maximum
    let max: Duration = Duration.MAX;
    assert(!max.is_zero());
    // MAX is very large: u64.MAX seconds + 999_999_999 nanos

    // Minimum (same as zero for Duration)
    let min: Duration = Duration.ZERO;

    // Common time periods
    let nanosecond: Duration = Duration.from_nanos(1);
    let microsecond: Duration = Duration.from_micros(1);
    let millisecond: Duration = Duration.from_millis(1);
    let second: Duration = Duration.from_secs(1);
    let minute: Duration = Duration.from_secs(60);
    let hour: Duration = Duration.from_secs(3600);
    let day: Duration = Duration.from_secs(86400);
    let week: Duration = Duration.from_secs(604800);

    assert(minute == second * 60);
    assert(hour == minute * 60);
    assert(day == hour * 24);
    assert(week == day * 7);

    // Relationships
    assert(second.as_millis() == 1000);
    assert(second.as_micros() == 1_000_000);
    assert(second.as_nanos() == 1_000_000_000);
}

/// Test checked arithmetic operations
fn test_duration_checked_operations() {
    mount std.time.Duration;

    let a: Duration = Duration.from_secs(5);
    let b: Duration = Duration.from_secs(3);

    // checked_add
    let sum: Maybe<Duration> = a.checked_add(b);
    assert(sum == Some(Duration.from_secs(8)));

    // Overflow returns None
    let overflow: Maybe<Duration> = Duration.MAX.checked_add(Duration.from_nanos(1));
    assert(overflow.is_none());

    // checked_sub
    let diff: Maybe<Duration> = a.checked_sub(b);
    assert(diff == Some(Duration.from_secs(2)));

    // Underflow returns None
    let underflow: Maybe<Duration> = b.checked_sub(a);
    assert(underflow.is_none());

    // checked_mul
    let product: Maybe<Duration> = a.checked_mul(2);
    assert(product == Some(Duration.from_secs(10)));

    let mul_overflow: Maybe<Duration> = Duration.MAX.checked_mul(2);
    assert(mul_overflow.is_none());

    // checked_div
    let quotient: Maybe<Duration> = a.checked_div(2);
    assert(quotient == Some(Duration.from_millis(2500)));

    let div_zero: Maybe<Duration> = a.checked_div(0);
    assert(div_zero.is_none());

    // Safe computation pattern
    fn safe_total_duration(durations: &[Duration]) -> Maybe<Duration> {
        let mut total: Duration = Duration.ZERO;
        for &d in durations {
            total = total.checked_add(d)?;
        }
        Some(total)
    }

    let durations: List<Duration> = [
        Duration.from_secs(1),
        Duration.from_secs(2),
        Duration.from_secs(3),
    ];
    assert(safe_total_duration(&durations) == Some(Duration.from_secs(6)));
}

/// Test saturating arithmetic operations
fn test_duration_saturating_operations() {
    mount std.time.Duration;

    let a: Duration = Duration.from_secs(5);
    let b: Duration = Duration.from_secs(3);

    // saturating_add
    let sum: Duration = a.saturating_add(b);
    assert(sum == Duration.from_secs(8));

    // Saturates to MAX on overflow
    let saturated_sum: Duration = Duration.MAX.saturating_add(Duration.from_secs(1));
    assert(saturated_sum == Duration.MAX);

    // saturating_sub
    let diff: Duration = a.saturating_sub(b);
    assert(diff == Duration.from_secs(2));

    // Saturates to ZERO on underflow
    let saturated_diff: Duration = b.saturating_sub(a);
    assert(saturated_diff == Duration.ZERO);

    // saturating_mul
    let product: Duration = a.saturating_mul(2);
    assert(product == Duration.from_secs(10));

    let saturated_mul: Duration = Duration.MAX.saturating_mul(2);
    assert(saturated_mul == Duration.MAX);

    // Useful for clamping
    fn clamp_duration(d: Duration, min: Duration, max: Duration) -> Duration {
        if d < min {
            min
        } else if d > max {
            max
        } else {
            d
        }
    }

    let clamped = clamp_duration(
        Duration.from_secs(10),
        Duration.from_secs(1),
        Duration.from_secs(5),
    );
    assert(clamped == Duration.from_secs(5));
}

