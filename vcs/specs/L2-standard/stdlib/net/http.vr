/// Test streaming responses
fn test_http_streaming() using [Network] {
    mount reqwest.blocking.Client;
    mount std.io.Read;

    let client = Client.new();

    // Stream large response
    let mut response = client
        .get("https://httpbin.org/bytes/10000")
        .send()
        .unwrap();

    // Read in chunks
    let mut buffer = [0u8; 1024];
    let mut total_bytes = 0;

    while let Ok(n) = response.read(&mut buffer) {
        if n == 0 { break; }
        total_bytes += n;
        // Process chunk
    }

    // Copy to file
    let response = client
        .get("https://httpbin.org/image/png")
        .send()
        .unwrap();

    let mut file = std.fs.File.create("image.png").unwrap();
    let bytes_copied = std.io.copy(&mut response, &mut file).unwrap();

    // Progress callback (custom implementation)
    fn download_with_progress<F: FnMut(u64, u64)>(
        url: &str,
        mut progress: F
    ) -> Result<List<u8>, reqwest.Error> {
        let client = Client.new();
        let response = client.get(url).send()?;

        let total = response.content_length().unwrap_or(0);
        let mut downloaded: u64 = 0;
        let mut bytes = List.new();

        for chunk in response.bytes() {
            let chunk = chunk?;
            downloaded += chunk.len() as u64;
            bytes.extend_from_slice(&chunk);
            progress(downloaded, total);
        }

        Ok(bytes)
    }
}

/// Test HTTP authentication
fn test_http_authentication() using [Network] {
    mount reqwest.blocking.Client;

    let client = Client.new();

    // Basic authentication
    let response = client
        .get("https://httpbin.org/basic-auth/user/pass")
        .basic_auth("user", Some("pass"))
        .send()
        .unwrap();

    // Bearer token
    let response = client
        .get("https://httpbin.org/bearer")
        .bearer_auth("my-token-12345")
        .send()
        .unwrap();

    // Custom authorization header
    let response = client
        .get("https://api.example.com/data")
        .header("Authorization", "ApiKey my-api-key")
        .send();

    // OAuth2 (typically use oauth2 crate)
    type OAuth2Token is {
        access_token: Text,
        token_type: Text,
        expires_in: u64,
    };

    fn get_oauth_token(client_id: &str, client_secret: &str) -> Result<OAuth2Token, reqwest.Error> {
        let client = Client.new();

        let params = [
            ("grant_type", "client_credentials"),
            ("client_id", client_id),
            ("client_secret", client_secret),
        ];

        let response = client
            .post("https://auth.example.com/oauth/token")
            .form(&params)
            .send()?;

        response.json()
    }

    // Digest authentication (requires digest_auth crate or manual implementation)
}

/// Test HTTP timeouts
fn test_http_timeout() using [Network] {
    mount reqwest.blocking.Client;
    mount std.time.Duration;

    // Per-request timeout
    let client = Client.new();
    let result = client
        .get("https://httpbin.org/delay/10")
        .timeout(Duration.from_secs(5))
        .send();

    match result {
        Ok(response) => { /* Success */ },
        Err(e) if e.is_timeout() => {
            println("Request timed out");
        },
        Err(e) => {
            println(f"Other error: {e}");
        }
    }

    // Client-level timeout
    let client = Client.builder()
        .timeout(Duration.from_secs(30))
        .connect_timeout(Duration.from_secs(10))
        .build()
        .unwrap();

    // Connection timeout only
    let client = Client.builder()
        .connect_timeout(Duration.from_secs(5))
        .build()
        .unwrap();

    // Read timeout (time between bytes)
    // Note: reqwest uses total timeout, not read timeout
    // For fine-grained control, use hyper directly

    // Retry with timeout
    fn request_with_retry(
        client: &Client,
        url: &str,
        max_retries: u32
    ) -> Result<reqwest.blocking.Response, reqwest.Error> {
        let mut last_error = None;

        for attempt in 0..max_retries {
            let timeout = Duration.from_secs(5 * (1 << attempt));

            match client.get(url).timeout(timeout).send() {
                Ok(response) => return Ok(response),
                Err(e) if e.is_timeout() => {
                    last_error = Some(e);
                    continue;
                },
                Err(e) => return Err(e),
            }
        }

        Err(last_error.unwrap())
    }
}

