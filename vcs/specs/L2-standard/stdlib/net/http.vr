/// Test HTTP POST requests
fn test_http_post() using [Network] {
    mount reqwest.blocking.Client;

    let client = Client.new();

    // POST with body
    let response = client
        .post("https://httpbin.org/post")
        .body("raw body content")
        .send()
        .unwrap();

    assert(response.status().is_success());

    // POST with bytes
    let response = client
        .post("https://httpbin.org/post")
        .body([1, 2, 3, 4, 5])
        .send()
        .unwrap();

    // Other HTTP methods
    let put_response = client
        .put("https://httpbin.org/put")
        .body("put data")
        .send()
        .unwrap();

    let patch_response = client
        .patch("https://httpbin.org/patch")
        .body("patch data")
        .send()
        .unwrap();

    let delete_response = client
        .delete("https://httpbin.org/delete")
        .send()
        .unwrap();

    // HEAD request
    let head_response = client
        .head("https://httpbin.org/get")
        .send()
        .unwrap();
    // HEAD has no body but same headers as GET
}

