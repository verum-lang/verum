/// Test UDP socket creation
fn test_udp_socket() using [Network] {
    mount std.net.{UdpSocket, SocketAddr};

    // Bind to address
    let socket: UdpSocket = UdpSocket.bind("127.0.0.1:0").unwrap();

    // Get assigned port
    let local_addr: SocketAddr = socket.local_addr().unwrap();
    let port: u16 = local_addr.port();

    // Bind to specific port
    let specific = UdpSocket.bind("127.0.0.1:9999");

    // Bind to all interfaces
    let all_interfaces = UdpSocket.bind("0.0.0.0:0");

    // Bind IPv6
    let ipv6 = UdpSocket.bind("[.1]:0");

    // Clone socket (both can receive)
    let socket_clone = socket.try_clone().unwrap();
    // Same underlying socket, different handles

    // Multiple sockets can bind to same address with SO_REUSEADDR
    // (platform-specific, requires socket2 crate for explicit control)
}

/// Test UDP send and receive
fn test_udp_send_recv() using [Network] {
    mount std.net.UdpSocket;

    // Create two sockets
    let socket_a = UdpSocket.bind("127.0.0.1:0").unwrap();
    let socket_b = UdpSocket.bind("127.0.0.1:0").unwrap();

    let addr_a = socket_a.local_addr().unwrap();
    let addr_b = socket_b.local_addr().unwrap();

    // send_to: send datagram to specific address
    let data = b"Hello, UDP!";
    let bytes_sent = socket_a.send_to(data, addr_b).unwrap();
    assert(bytes_sent == data.len());

    // recv_from: receive datagram and sender address
    let mut buffer = [0u8; 1024];
    let (bytes_received, sender_addr) = socket_b.recv_from(&mut buffer).unwrap();

    assert(bytes_received == data.len());
    assert(&buffer[..bytes_received] == data);
    assert(sender_addr == addr_a);

    // peek_from: peek at datagram without consuming
    socket_a.send_to(b"Peek me", addr_b).unwrap();
    let (peek_len, _) = socket_b.peek_from(&mut buffer).unwrap();
    let (recv_len, _) = socket_b.recv_from(&mut buffer).unwrap();
    assert(peek_len == recv_len);  // Same datagram

    // Send to multiple recipients
    let recipients = [addr_b];
    for addr in recipients {
        socket_a.send_to(b"Broadcast-like", addr).unwrap();
    }
}

/// Test connected UDP socket
fn test_udp_connected() using [Network] {
    mount std.net.UdpSocket;

    let socket_a = UdpSocket.bind("127.0.0.1:0").unwrap();
    let socket_b = UdpSocket.bind("127.0.0.1:0").unwrap();

    let addr_b = socket_b.local_addr().unwrap();

    // Connect to peer (sets default destination)
    socket_a.connect(addr_b).unwrap();

    // After connect, can use send() instead of send_to()
    let bytes = socket_a.send(b"Connected send").unwrap();
    assert(bytes == 14);

    // recv() instead of recv_from()
    let mut buffer = [0u8; 1024];
    let (len, sender) = socket_b.recv_from(&mut buffer).unwrap();

    // Connect filters received datagrams
    socket_b.connect(socket_a.local_addr().unwrap()).unwrap();

    // Now recv() only accepts from connected peer
    socket_a.send(b"Only from A").unwrap();
    let n = socket_b.recv(&mut buffer).unwrap();
    assert(n == 11);

    // "Connect" to different address to change
    // socket_a.connect(other_addr).unwrap();
}

