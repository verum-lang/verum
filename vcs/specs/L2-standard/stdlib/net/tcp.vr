/// Test TCP listener
fn test_tcp_listener() using [Network] {
    mount std.net.{TcpListener, TcpStream, SocketAddr};

    // Bind to address
    let listener: TcpListener = TcpListener.bind("127.0.0.1:0").unwrap();

    // Get assigned port (when binding to port 0)
    let local_addr: SocketAddr = listener.local_addr().unwrap();
    let port: u16 = local_addr.port();

    // Bind to specific address
    let specific = TcpListener.bind("127.0.0.1:8888");

    // Bind to all interfaces
    let all_interfaces = TcpListener.bind("0.0.0.0:8888");

    // Bind with IPv6
    let ipv6 = TcpListener.bind("[.1]:8888");

    // Accept connections
    match listener.accept() {
        Ok((stream, addr)) => {
            println(f"New connection from: {addr}");
            handle_client(stream);
        },
        Err(e) => {
            println(f"Accept failed: {e}");
        }
    }

    // Non-blocking accept
    listener.set_nonblocking(true).unwrap();
    match listener.accept() {
        Ok((stream, addr)) => {
            // Got connection
        },
        Err(e) if e.kind() == std.io.ErrorKind.WouldBlock => {
            // No connection waiting
        },
        Err(e) => {
            println(f"Error: {e}");
        }
    }

    // Iterator over incoming connections
    for stream_result in listener.incoming() {
        match stream_result {
            Ok(stream) => {
                // Handle connection
                break;  // For test, handle only one
            },
            Err(e) => {
                println(f"Connection failed: {e}");
                break;
            }
        }
    }

    // Set backlog (max pending connections)
    // Note: This is set at bind time on most platforms
}

fn handle_client(stream: std.net.TcpStream) {
    // Handle client connection
}

