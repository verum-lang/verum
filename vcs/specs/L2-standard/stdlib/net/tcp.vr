/// Test concurrent TCP connections
fn test_tcp_concurrent() using [Network, Async] {
    mount std.net.{TcpListener, TcpStream};
    mount std.thread;
    mount std.sync.Arc;

    // Thread-per-connection server
    fn threaded_server(listener: TcpListener) {
        for stream in listener.incoming() {
            match stream {
                Ok(stream) => {
                    thread.spawn(move || {
                        handle_connection(stream);
                    });
                },
                Err(e) => {
                    eprint(f"Accept error: {e}");
                }
            }
        }
    }

    fn handle_connection(mut stream: TcpStream) {
        mount std.io.{Read, Write};

        let mut buffer = [0u8; 1024];
        while let Ok(n) = stream.read(&mut buffer) {
            if n == 0 {
                break;
            }
            stream.write_all(&buffer).unwrap();
        }
    }

    // Thread pool server (uses mpsc - not yet available)
    // fn pool_server(...) { ... }

    // Clone stream for separate read/write threads
    fn bidirectional_stream(stream: TcpStream) {
        let reader = stream.try_clone().unwrap();
        let writer = stream;

        let read_handle = thread.spawn(move || {
            mount std.io.Read;
            let mut reader = reader;
            let mut buffer = [0u8; 1024];
            while let Ok(n) = reader.read(&mut buffer) {
                if n == 0 { break; }
                print(f"Read {n} bytes");
            }
        });

        let write_handle = thread.spawn(move || {
            mount std.io.Write;
            let mut writer = writer;
            writer.write_all(b"Hello").unwrap();
        });

        read_handle.join().unwrap();
        write_handle.join().unwrap();
    }
}

/// Test TCP echo server pattern
fn test_tcp_echo_server() using [Network] {
    mount std.net.{TcpListener, TcpStream};
    mount std.io.{Read, Write, BufReader, BufRead, BufWriter};

    fn echo_server(addr: &str) -> Result<(), std.io.Error> {
        let listener = TcpListener.bind(addr)?;
        print(f"Echo server listening on {addr}");

        for stream in listener.incoming() {
            let stream = stream?;
            std.thread.spawn(move || {
                if let Err(e) = handle_echo_client(stream) {
                    eprint(f"Client error: {e}");
                }
            });
        }

        Ok(())
    }

    fn handle_echo_client(stream: TcpStream) -> Result<(), std.io.Error> {
        let mut reader = BufReader.new(stream.try_clone()?);
        let mut writer = BufWriter.new(stream);

        loop {
            let mut line = Text.new();
            let bytes = reader.read_line(&mut line)?;

            if bytes == 0 {
                break;  // EOF
            }

            // Echo back
            writer.write_all(line.as_bytes())?;
            writer.flush()?;
        }

        Ok(())
    }

    // Binary echo
    fn binary_echo(mut stream: TcpStream) -> Result<(), std.io.Error> {
        let mut buffer = [0u8; 4096];

        loop {
            let n = stream.read(&mut buffer)?;
            if n == 0 {
                break;
            }
            stream.write_all(&buffer[..n])?;
        }

        Ok(())
    }
}

