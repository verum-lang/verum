/// Test buffered TCP I/O
fn test_tcp_buffered() using [Network] {
    mount std.net.TcpStream;
    mount std.io.{BufReader, BufWriter, BufRead, Write};

    // Buffered reader for efficient line reading
    fn read_lines(stream: TcpStream) -> Result<List<Text>, std.io.Error> {
        let reader = BufReader.new(stream);
        let mut lines = List.new();

        for line_result in reader.lines() {
            let line = line_result?;
            if line.is_empty() {
                break;  // Empty line marks end
            }
            lines.push(line);
        }

        Ok(lines)
    }

    // Buffered writer for efficient writes
    fn write_response(stream: TcpStream, lines: &[&str]) -> Result<(), std.io.Error> {
        let mut writer = BufWriter.new(stream);

        for line in lines {
            writer.write(f"{line}\n".as_bytes())?;
        }

        writer.flush()?;
        Ok(())
    }

    // Custom buffer size
    fn create_buffered_stream(stream: TcpStream) -> (BufReader<TcpStream>, BufWriter<TcpStream>) {
        let stream_clone = stream.try_clone().unwrap();
        let reader = BufReader.with_capacity(64 * 1024, stream);
        let writer = BufWriter.with_capacity(64 * 1024, stream_clone);
        (reader, writer)
    }

    // Line-oriented protocol
    fn handle_line_protocol(mut stream: TcpStream) -> Result<(), std.io.Error> {
        let reader = BufReader.new(stream.try_clone()?);
        let mut writer = BufWriter.new(stream);

        for line in reader.lines() {
            let request = line?;
            let response = process_request(&request);
            writer.write(f"{response}\n".as_bytes())?;
            writer.flush()?;
        }

        Ok(())
    }

    fn process_request(req: &str) -> Text {
        format("Processed: {}", req)
    }
}

/// Test TCP shutdown
fn test_tcp_shutdown() using [Network] {
    mount std.net.{TcpStream, Shutdown};

    fn graceful_shutdown(mut stream: TcpStream) -> Result<(), std.io.Error> {
        // Shutdown write side (send FIN)
        stream.shutdown(Shutdown.Write)?;

        // Can still read after shutting down write
        let mut buffer = List.new();
        mount std.io.Read;
        stream.read_to_end(&mut buffer)?;

        // Shutdown read side
        stream.shutdown(Shutdown.Read)?;

        // Shutdown both directions
        // stream.shutdown(Shutdown.Both)?;

        Ok(())
    }

    // Half-close pattern
    fn half_close_client(mut stream: TcpStream) -> Result<List<u8>, std.io.Error> {
        mount std.io.{Read, Write};

        // Send request
        stream.write_all(b"GET /data")?;

        // Signal we're done sending
        stream.shutdown(Shutdown.Write)?;

        // Read complete response
        let mut response = List.new();
        stream.read_to_end(&mut response)?;

        Ok(response)
    }

    // Server side half-close
    fn half_close_server(mut stream: TcpStream) -> Result<(), std.io.Error> {
        mount std.io.{Read, Write};

        // Read complete request
        let mut request = List.new();
        stream.read_to_end(&mut request)?;

        // Send response
        stream.write_all(b"Response data")?;

        // Shutdown both (or let drop)
        stream.shutdown(Shutdown.Both)?;

        Ok(())
    }
}

