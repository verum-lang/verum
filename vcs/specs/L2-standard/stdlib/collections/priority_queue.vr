// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: stdlib, collections, priority-queue, heap

/// Comprehensive test suite for PriorityQueue<T> (BinaryHeap) operations.
/// PriorityQueue is a max-heap by default - largest element has highest priority.
/// Provides O(log n) insertion and O(log n) removal of the highest priority element.

fn main() {
    test_priority_queue_creation();
    test_priority_queue_push();
    test_priority_queue_pop();
    test_priority_queue_peek();
    test_priority_queue_iteration();
    test_priority_queue_modification();
    test_priority_queue_capacity();
    test_priority_queue_min_heap();
    test_priority_queue_custom_priority();
    test_priority_queue_applications();
}

/// Test various ways to create priority queues
fn test_priority_queue_creation() {
    // Empty priority queue
    let empty: PriorityQueue<Int> = PriorityQueue.new();
    assert(empty.is_empty());
    assert(empty.len() == 0);

    // Priority queue with capacity
    let with_capacity: PriorityQueue<Int> = PriorityQueue.with_capacity(100);
    assert(with_capacity.is_empty());
    assert(with_capacity.capacity() >= 100);

    // From iterator
    let from_iter: PriorityQueue<Int> = [3, 1, 4, 1, 5, 9, 2, 6].into_iter().collect();
    assert(from_iter.len() == 8);
    assert(from_iter.peek() == Some(&9));  // Max is at top

    // From list
    let list: List<Int> = [10, 5, 20, 15];
    let from_list: PriorityQueue<Int> = list.into_iter().collect();
    assert(from_list.peek() == Some(&20));

    // Clone
    let original: PriorityQueue<Int> = [1, 2, 3].into_iter().collect();
    let cloned: PriorityQueue<Int> = original.clone();
    assert(cloned.len() == original.len());
    assert(cloned.peek() == original.peek());

    // From vec (optimized O(n) heapify)
    let vec: List<Int> = [5, 3, 8, 1, 9, 2];
    let heap: PriorityQueue<Int> = PriorityQueue.from(vec);
    assert(heap.peek() == Some(&9));
}

/// Test push operations
fn test_priority_queue_push() {
    let mut pq: PriorityQueue<Int> = PriorityQueue.new();

    // Push maintains heap property
    pq.push(5);
    assert(pq.peek() == Some(&5));

    pq.push(3);
    assert(pq.peek() == Some(&5));  // 5 still largest

    pq.push(10);
    assert(pq.peek() == Some(&10));  // 10 is now largest

    pq.push(7);
    pq.push(1);
    pq.push(15);
    assert(pq.peek() == Some(&15));
    assert(pq.len() == 6);

    // Push with duplicates
    pq.push(15);
    pq.push(15);
    assert(pq.len() == 8);

    // Push negative numbers
    let mut neg_pq: PriorityQueue<Int> = PriorityQueue.new();
    neg_pq.push(-5);
    neg_pq.push(-1);
    neg_pq.push(-10);
    assert(neg_pq.peek() == Some(&-1));  // -1 is largest (closest to 0)

    // extend with multiple elements
    let mut extended: PriorityQueue<Int> = PriorityQueue.new();
    extended.extend([3, 1, 4, 1, 5]);
    assert(extended.len() == 5);
    assert(extended.peek() == Some(&5));

    // append another heap
    let mut base: PriorityQueue<Int> = [1, 2, 3].into_iter().collect();
    let mut other: PriorityQueue<Int> = [4, 5, 6].into_iter().collect();
    base.append(&mut other);
    assert(base.len() == 6);
    assert(base.peek() == Some(&6));
    assert(other.is_empty());
}

