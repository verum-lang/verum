/// Test peek operations
fn test_priority_queue_peek() {
    let mut pq: PriorityQueue<Int> = [3, 7, 2, 5].into_iter().collect();

    // peek returns reference to max without removing
    assert(pq.peek() == Some(&7));
    assert(pq.len() == 4);  // Unchanged

    assert(pq.peek() == Some(&7));  // Still 7

    // peek_mut allows modification
    match pq.peek_mut() {
        Some(mut top) => {
            *top = 1;  // Reduce the top value
        },
        None => panic("heap should not be empty"),
    }
    // After modification, heap property is restored
    assert(pq.peek() == Some(&5));  // 5 is now max

    // Empty heap peek
    let empty: PriorityQueue<Int> = PriorityQueue.new();
    assert(empty.peek().is_none());

    // PeekMut with Drop
    let mut peek_drop: PriorityQueue<Int> = [10, 5, 3].into_iter().collect();
    {
        let mut top = peek_drop.peek_mut().unwrap();
        *top = 1;  // Modify top
        // When `top` goes out of scope, heap is reordered
    }
    assert(peek_drop.peek() == Some(&5));

    // PeekMut.pop
    let mut peek_pop: PriorityQueue<Int> = [10, 5, 3].into_iter().collect();
    let popped = PeekMut.pop(peek_pop.peek_mut().unwrap());
    assert(popped == 10);
    assert(peek_pop.peek() == Some(&5));
}

/// Test iteration patterns
fn test_priority_queue_iteration() {
    let pq: PriorityQueue<Int> = [3, 1, 4, 1, 5].into_iter().collect();

    // iter() - iterate without consuming (arbitrary order!)
    let mut count: Int = 0;
    for elem in pq.iter() {
        count += 1;
    }
    assert(count == 5);
    assert(pq.len() == 5);  // Unchanged

    // NOTE: iter() does NOT iterate in priority order!
    // It iterates over the underlying array representation

    // For priority order, must pop repeatedly
    let mut ordered_pq: PriorityQueue<Int> = pq.clone();
    let mut priority_order: List<Int> = List.new();
    while let Some(val) = ordered_pq.pop() {
        priority_order.push(val);
    }
    assert(priority_order == [5, 4, 3, 1, 1]);

    // into_iter - consuming iteration (arbitrary order)
    let to_consume: PriorityQueue<Int> = [1, 2, 3].into_iter().collect();
    let sum: Int = to_consume.into_iter().sum();
    assert(sum == 6);

    // drain - remove all and iterate (arbitrary order)
    let mut to_drain: PriorityQueue<Int> = [10, 20, 30].into_iter().collect();
    let drained: List<Int> = to_drain.drain().collect();
    assert(to_drain.is_empty());
    assert(drained.iter().sum<Int>() == 60);

    // Commented out: drain_sorted() not yet in stdlib
    // let mut to_drain_sorted: PriorityQueue<Int> = [3, 1, 4, 1, 5].into_iter().collect();
    // let sorted: List<Int> = to_drain_sorted.drain_sorted().collect();
    // assert(sorted == [5, 4, 3, 1, 1]);  // Descending
}

/// Test modification operations
fn test_priority_queue_modification() {
    // clear
    let mut to_clear: PriorityQueue<Int> = [1, 2, 3].into_iter().collect();
    to_clear.clear();
    assert(to_clear.is_empty());

    // retain - keep elements matching predicate
    let mut to_retain: PriorityQueue<Int> = [1, 2, 3, 4, 5, 6].into_iter().collect();
    to_retain.retain(|x| *x % 2 == 0);
    assert(to_retain.len() == 3);
    assert(to_retain.peek() == Some(&6));

    // Commented out: into_vec() not yet in stdlib
    // let heap: PriorityQueue<Int> = [3, 1, 4].into_iter().collect();
    // let vec: List<Int> = heap.into_vec();
    // assert(vec.len() == 3);
    // Order is not guaranteed, but all elements present

    // Convert back and forth
    let list: List<Int> = [5, 3, 8, 1];
    let heap2: PriorityQueue<Int> = list.clone().into_iter().collect();
    let back_to_list: List<Int> = heap2.into_sorted_vec();
    assert(back_to_list == [1, 3, 5, 8]);
}

/// Test capacity management
fn test_priority_queue_capacity() {
    let mut pq: PriorityQueue<Int> = PriorityQueue.new();

    // Initial capacity
    let initial: Int = pq.capacity();
    assert(initial >= 0);

    // Reserve
    pq.reserve(100);
    assert(pq.capacity() >= 100);

    // Commented out: reserve_exact() not yet in stdlib
    // let mut exact: PriorityQueue<Int> = PriorityQueue.new();
    // exact.reserve_exact(50);
    // assert(exact.capacity() >= 50);

    // Add elements
    for i in 0..50 {
        pq.push(i);
    }
    assert(pq.len() == 50);

    // Shrink to fit
    pq.shrink_to_fit();
    assert(pq.capacity() >= 50);

    // Commented out: shrink_to() not yet in stdlib
    // pq.shrink_to(60);
    // assert(pq.capacity() >= 50);
}

