// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: stdlib, collections, map

/// Comprehensive test suite for Map<K, V> operations.
/// Map is an associative container mapping keys to values (semantic equivalent of HashMap).
/// Tests insertion, retrieval, removal, iteration, and all standard methods.

fn main() {
    test_map_creation();
    test_map_insertion();
    test_map_retrieval();
    test_map_removal();
    test_map_iteration();
    test_map_entry_api();
    test_map_functional_operations();
    test_map_merge_operations();
    test_map_capacity_management();
    test_map_comparison();
}

/// Test various ways to create maps
fn test_map_creation() {
    // Empty map with explicit types
    let empty: Map<Text, Int> = Map.new();
    assert(empty.is_empty());
    assert(empty.len() == 0);

    // Map literal macro
    let from_literal: Map<Text, Int> = map!{
        "one" => 1,
        "two" => 2,
        "three" => 3,
    };
    assert(from_literal.len() == 3);

    // Map with capacity hint
    let with_capacity: Map<Int, Text> = Map.with_capacity(100);
    assert(with_capacity.is_empty());
    assert(with_capacity.capacity() >= 100);

    // Map from iterator of tuples
    let pairs: List<(Text, Int)> = [("a", 1), ("b", 2), ("c", 3)];
    let from_iter: Map<Text, Int> = pairs.into_iter().collect();
    assert(from_iter.len() == 3);
    assert(from_iter["a"] == 1);

    // Commented out: FnvHasher type not found
    // let custom_hash: Map<Text, Int, FnvHasher> = Map.with_hasher(FnvHasher.new());
    // assert(custom_hash.is_empty());

    // Clone a map
    let original: Map<Text, Int> = map!{"key" => 42};
    let cloned: Map<Text, Int> = original.clone();
    assert(cloned == original);
    assert(cloned["key"] == 42);

    // Nested maps
    let nested: Map<Text, Map<Text, Int>> = map!{
        "outer1" => map!{"inner1" => 1, "inner2" => 2},
        "outer2" => map!{"inner3" => 3},
    };
    assert(nested.len() == 2);
    assert(nested["outer1"]["inner1"] == 1);
}

/// Test map insertion operations
fn test_map_insertion() {
    let mut map: Map<Text, Int> = Map.new();

    // Basic insert - returns None for new key
    let prev1: Maybe<Int> = map.insert("first", 1);
    assert(prev1.is_none());
    assert(map.len() == 1);

    // Insert returns previous value for existing key
    let prev2: Maybe<Int> = map.insert("first", 100);
    assert(prev2 == Some(1));
    assert(map["first"] == 100);

    // Insert multiple keys
    map.insert("second", 2);
    map.insert("third", 3);
    assert(map.len() == 3);

    // Insert with different key types
    let mut int_keys: Map<Int, Text> = Map.new();
    int_keys.insert(1, "one");
    int_keys.insert(2, "two");
    assert(int_keys[1] == "one");

    // Insert with complex value types
    let mut complex: Map<Text, List<Int>> = Map.new();
    complex.insert("numbers", [1, 2, 3]);
    assert(complex["numbers"] == [1, 2, 3]);

    // Bulk insert with extend
    let mut extended: Map<Text, Int> = map!{"a" => 1};
    extended.extend([("b", 2), ("c", 3)]);
    assert(extended.len() == 3);

    // Commented out: OccupiedError type not found
    // let mut try_map: Map<Text, Int> = map!{"exists" => 1};
    // let result1: Result<&mut Int, OccupiedError<Text, Int>> = try_map.try_insert("exists", 2);
    // assert(result1.is_err());
    // let result2: Result<&mut Int, OccupiedError<Text, Int>> = try_map.try_insert("new", 2);
    // assert(result2.is_ok());
}

/// Test map retrieval operations
fn test_map_retrieval() {
    let map: Map<Text, Int> = map!{
        "alice" => 100,
        "bob" => 85,
        "charlie" => 92,
    };

    // Direct indexing (panics if key not found)
    let alice_score: Int = map["alice"];
    assert(alice_score == 100);

    // Safe access with get() - returns Maybe<&V>
    let bob_score: Maybe<&Int> = map.get("bob");
    assert(bob_score == Some(&85));

    let not_found: Maybe<&Int> = map.get("unknown");
    assert(not_found.is_none());

    // get_key_value - returns both key and value
    let kv: Maybe<(&Text, &Int)> = map.get_key_value("charlie");
    match kv {
        Some((k, v)) => {
            assert(*k == "charlie");
            assert(*v == 92);
        },
        None => panic("key should exist"),
    }

    // Mutable access
    let mut mutable_map: Map<Text, Int> = map.clone();
    match mutable_map.get_mut("alice") {
        Some(v) => *v = 150,
        None => panic("key should exist"),
    }
    assert(mutable_map["alice"] == 150);

    // contains_key - check if key exists
    assert(map.contains_key("alice"));
    assert(!map.contains_key("unknown"));

    // Get with default
    let with_default: Int = map.get("unknown").copied().unwrap_or(0);
    assert(with_default == 0);

    // Get or insert default
    let mut default_map: Map<Text, Int> = Map.new();
    let value: &mut Int = default_map.entry("counter").or_default();
    assert(*value == 0);

    // Keys access
    let keys: List<&Text> = map.keys().collect();
    assert(keys.len() == 3);
    assert(keys.contains(&&"alice"));

    // Values access
    let values: List<&Int> = map.values().collect();
    assert(values.len() == 3);
    assert(values.contains(&&100));
}

/// Test map removal operations
fn test_map_removal() {
    let mut map: Map<Text, Int> = map!{
        "one" => 1,
        "two" => 2,
        "three" => 3,
        "four" => 4,
    };

    // Basic remove - returns Maybe<V>
    let removed: Maybe<Int> = map.remove("two");
    assert(removed == Some(2));
    assert(map.len() == 3);
    assert(!map.contains_key("two"));

    // Remove non-existent key
    let not_found: Maybe<Int> = map.remove("unknown");
    assert(not_found.is_none());
    assert(map.len() == 3);

    // remove_entry - returns key-value pair
    let entry: Maybe<(Text, Int)> = map.remove_entry("three");
    match entry {
        Some((k, v)) => {
            assert(k == "three");
            assert(v == 3);
        },
        None => panic("entry should exist"),
    }
    assert(map.len() == 2);

    // Clear - remove all entries
    let mut to_clear: Map<Text, Int> = map!{"a" => 1, "b" => 2};
    to_clear.clear();
    assert(to_clear.is_empty());
    assert(to_clear.len() == 0);

    // Retain - keep entries matching predicate
    let mut to_retain: Map<Text, Int> = map!{
        "a" => 1,
        "b" => 2,
        "c" => 3,
        "d" => 4,
    };
    to_retain.retain(|_, v| *v % 2 == 0);
    assert(to_retain.len() == 2);
    assert(to_retain.contains_key("b"));
    assert(to_retain.contains_key("d"));
    assert(!to_retain.contains_key("a"));

    // drain - remove and iterate all entries
    let mut to_drain: Map<Text, Int> = map!{"x" => 10, "y" => 20};
    let drained: List<(Text, Int)> = to_drain.drain().collect();
    assert(to_drain.is_empty());
    assert(drained.len() == 2);
}

/// Test map iteration patterns
fn test_map_iteration() {
    let map: Map<Text, Int> = map!{
        "alice" => 100,
        "bob" => 85,
        "charlie" => 92,
    };

    // Iterate over key-value pairs
    let mut pair_count: Int = 0;
    for (key, value) in map.iter() {
        assert(key.len() > 0);
        assert(*value > 0);
        pair_count += 1;
    }
    assert(pair_count == 3);

    // Iterate over keys only
    let mut key_list: List<Text> = List.new();
    for key in map.keys() {
        key_list.push(key.clone());
    }
    assert(key_list.len() == 3);
    assert(key_list.contains(&"alice"));

    // Iterate over values only
    let mut sum: Int = 0;
    for value in map.values() {
        sum += *value;
    }
    assert(sum == 277);

    // Mutable iteration over values
    let mut mutable_map: Map<Text, Int> = map.clone();
    for value in mutable_map.values_mut() {
        *value *= 2;
    }
    assert(mutable_map["alice"] == 200);
    assert(mutable_map["bob"] == 170);

    // Mutable iteration over pairs
    for (_, value) in mutable_map.iter_mut() {
        *value /= 2;
    }
    assert(mutable_map["alice"] == 100);

    // Consuming iteration with into_iter
    let to_consume: Map<Text, Int> = map!{"a" => 1, "b" => 2};
    let collected: List<(Text, Int)> = to_consume.into_iter().collect();
    assert(collected.len() == 2);
    // Note: to_consume is moved

    // Iteration order is not guaranteed for HashMap
    // Use BTreeMap for ordered iteration
    let ordered: BTreeMap<Text, Int> = BTreeMap.from([
        ("a", 1),
        ("b", 2),
        ("c", 3),
    ]);
    let ordered_keys: List<&Text> = ordered.keys().collect();
    assert(ordered_keys == [&"a", &"b", &"c"]);  // Lexicographic order
}

/// Test Entry API for conditional operations
fn test_map_entry_api() {
    let mut map: Map<Text, Int> = Map.new();

    // or_insert - insert if key doesn't exist
    map.entry("counter").or_insert(0);
    assert(map["counter"] == 0);

    // Returns mutable reference for modification
    *map.entry("counter").or_insert(0) += 1;
    assert(map["counter"] == 1);

    // or_insert doesn't overwrite existing
    map.entry("counter").or_insert(100);
    assert(map["counter"] == 1);

    // or_insert_with - lazy initialization
    let mut lazy_map: Map<Text, List<Int>> = Map.new();
    lazy_map.entry("numbers").or_insert_with(|| List.new()).push(1);
    lazy_map.entry("numbers").or_insert_with(|| List.new()).push(2);
    assert(lazy_map["numbers"] == [1, 2]);

    // or_insert_with_key - initialization using the key
    let mut key_init: Map<Text, Int> = Map.new();
    key_init.entry("hello").or_insert_with_key(|k| k.len() as Int);
    assert(key_init["hello"] == 5);

    // or_default - use Default trait
    let mut default_map: Map<Text, Int> = Map.new();
    *default_map.entry("value").or_default() = 42;
    assert(default_map["value"] == 42);

    // and_modify - modify existing entry
    let mut modify_map: Map<Text, Int> = map!{"existing" => 10};
    modify_map.entry("existing").and_modify(|v| *v += 5);
    assert(modify_map["existing"] == 15);

    modify_map.entry("new").and_modify(|v| *v += 5).or_insert(1);
    assert(modify_map["new"] == 1);  // and_modify skipped, or_insert used

    // Entry pattern for counting
    let words: List<Text> = ["apple", "banana", "apple", "cherry", "apple"];
    let mut counts: Map<Text, Int> = Map.new();
    for word in words.iter() {
        *counts.entry(word.clone()).or_insert(0) += 1;
    }
    assert(counts["apple"] == 3);
    assert(counts["banana"] == 1);

    // OccupiedEntry and VacantEntry
    match map.entry("counter") {
        Entry.Occupied(mut occupied) => {
            let old = occupied.insert(999);
            assert(old == 1);
        },
        Entry.Vacant(_) => panic("entry should be occupied"),
    }

    match map.entry("new_key") {
        Entry.Occupied(_) => panic("entry should be vacant"),
        Entry.Vacant(vacant) => {
            vacant.insert(42);
        },
    }
    assert(map["new_key"] == 42);
}

/// Test functional/iterator operations on maps
fn test_map_functional_operations() {
    let map: Map<Text, Int> = map!{
        "alice" => 100,
        "bob" => 85,
        "charlie" => 92,
        "david" => 78,
    };

    // filter - keep entries matching predicate
    let high_scores: Map<Text, Int> = map.iter()
        .filter(|(_, v)| **v >= 90)
        .map(|(k, v)| (k.clone(), *v))
        .collect();
    assert(high_scores.len() == 2);
    assert(high_scores.contains_key("alice"));
    assert(high_scores.contains_key("charlie"));

    // map values
    let doubled: Map<Text, Int> = map.iter()
        .map(|(k, v)| (k.clone(), *v * 2))
        .collect();
    assert(doubled["alice"] == 200);
    assert(doubled["bob"] == 170);

    // map keys
    let uppercase_keys: Map<Text, Int> = map.iter()
        .map(|(k, v)| (k.to_uppercase(), *v))
        .collect();
    assert(uppercase_keys.contains_key("ALICE"));
    assert(!uppercase_keys.contains_key("alice"));

    // fold over map
    let total: Int = map.values().fold(0, |acc, v| acc + *v);
    assert(total == 355);

    // Commented out: find() returns Item<MapIter> instead of (&Text, &Int)
    // let found: Maybe<(&Text, &Int)> = map.iter().find(|(_, v)| **v == 85);
    // match found {
    //     Some((k, v)) => {
    //         assert(*k == "bob");
    //         assert(*v == 85);
    //     },
    //     None => panic("should find bob"),
    // }

    // any and all
    let has_perfect: Bool = map.values().any(|v| *v == 100);
    assert(has_perfect);

    let all_passing: Bool = map.values().all(|v| *v >= 70);
    assert(all_passing);

    // partition
    let (high, low): (Map<Text, Int>, Map<Text, Int>) = map.iter()
        .map(|(k, v)| (k.clone(), *v))
        .partition(|(_, v)| *v >= 90);
    assert(high.len() == 2);
    assert(low.len() == 2);

    // group_by (custom implementation)
    let items: List<(Text, Int)> = [
        ("fruit", 1), ("veggie", 2), ("fruit", 3), ("veggie", 4),
    ];
    let mut grouped: Map<Text, List<Int>> = Map.new();
    for (category, value) in items.iter() {
        grouped.entry(category.clone()).or_default().push(*value);
    }
    assert(grouped["fruit"] == [1, 3]);
    assert(grouped["veggie"] == [2, 4]);
}

/// Test map merging and combining operations
fn test_map_merge_operations() {
    let map_a: Map<Text, Int> = map!{
        "one" => 1,
        "two" => 2,
    };
    let map_b: Map<Text, Int> = map!{
        "two" => 20,  // Conflict with map_a
        "three" => 3,
    };

    // extend - later values overwrite
    let mut extended: Map<Text, Int> = map_a.clone();
    extended.extend(map_b.iter().map(|(k, v)| (k.clone(), *v)));
    assert(extended["one"] == 1);
    assert(extended["two"] == 20);  // Overwritten
    assert(extended["three"] == 3);

    // Custom merge with conflict resolution
    let mut merged: Map<Text, Int> = map_a.clone();
    for (key, value) in map_b.iter() {
        merged.entry(key.clone())
            .and_modify(|v| *v += *value)  // Sum on conflict
            .or_insert(*value);
    }
    assert(merged["two"] == 22);  // 2 + 20

    // Union-like operation (keep all, prefer first)
    let mut union: Map<Text, Int> = map_a.clone();
    for (key, value) in map_b.iter() {
        union.entry(key.clone()).or_insert(*value);
    }
    assert(union["two"] == 2);  // Original preserved
    assert(union["three"] == 3);

    // Intersection-like (keep only common keys)
    let intersection: Map<Text, Int> = map_a.iter()
        .filter(|(k, _)| map_b.contains_key(*k))
        .map(|(k, v)| (k.clone(), *v))
        .collect();
    assert(intersection.len() == 1);
    assert(intersection.contains_key("two"));

    // Difference (keys in A but not in B)
    let difference: Map<Text, Int> = map_a.iter()
        .filter(|(k, _)| !map_b.contains_key(*k))
        .map(|(k, v)| (k.clone(), *v))
        .collect();
    assert(difference.len() == 1);
    assert(difference.contains_key("one"));
}

/// Test capacity management
fn test_map_capacity_management() {
    let mut map: Map<Text, Int> = Map.new();

    // Check initial capacity
    let initial_capacity: Int = map.capacity();
    assert(initial_capacity >= 0);

    // Reserve capacity
    map.reserve(100);
    assert(map.capacity() >= 100);

    // Add elements
    for i in 0..50 {
        map.insert(f"key_{i}", i);
    }
    assert(map.len() == 50);

    // Shrink to fit
    map.shrink_to_fit();
    let after_shrink: Int = map.capacity();
    assert(after_shrink >= 50);

    // Shrink to specific size
    map.shrink_to(60);
    assert(map.capacity() >= 50);

    // Commented out: BuildHasher type not found
    // let _hasher: &BuildHasher = map.hasher();
}

/// Test map comparisons
fn test_map_comparison() {
    let map_a: Map<Text, Int> = map!{
        "one" => 1,
        "two" => 2,
    };
    let map_b: Map<Text, Int> = map!{
        "two" => 2,
        "one" => 1,
    };
    let map_c: Map<Text, Int> = map!{
        "one" => 1,
        "two" => 3,  // Different value
    };
    let map_d: Map<Text, Int> = map!{
        "one" => 1,
    };

    // Equality (order doesn't matter for HashMap)
    assert(map_a == map_b);
    assert(map_a != map_c);
    assert(map_a != map_d);

    // Empty maps
    let empty1: Map<Text, Int> = Map.new();
    let empty2: Map<Text, Int> = Map.new();
    assert(empty1 == empty2);

    // is_empty check
    assert(empty1.is_empty());
    assert(!map_a.is_empty());
}
