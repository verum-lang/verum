/// Test memory layout
fn test_vec_memory_layout() {
    let vec: List<Int> = [1, 2, 3, 4, 5];

    // Vec is 3 words: ptr, len, cap
    assert(List<Int>.size == 3 * usize.size);

    // Elements are contiguous
    let ptr = vec.as_ptr();
    for i in 0..vec.len() {
        // unsafe { assert(*ptr.add(i) == vec[i]); }
    }

    // align_to - view bytes as different type
    let bytes: &[u8] = unsafe {
        let (prefix, aligned, suffix) = vec.align_to<u8>();
        aligned
    };

    // copy_from_slice
    let mut target: List<Int> = [0; 5];
    target.copy_from_slice(&vec);
    assert(target == vec);

    // Commented out: clone_from_slice() not yet in stdlib
