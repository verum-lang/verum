/// Test capacity management
fn test_heap_capacity() {
    let mut heap: Heap<Int> = Heap.new();

    // Initial capacity
    let initial: Int = heap.capacity();
    assert(initial >= 0);

    // Reserve capacity
    heap.reserve(100);
    assert(heap.capacity() >= 100);

    // Commented out: reserve_exact() not yet in stdlib
    // let mut exact: Heap<Int> = Heap.new();
    // exact.reserve_exact(50);
    // assert(exact.capacity() >= 50);

    // Add elements
    for i in 0..50 {
        heap.push(i);
    }
    assert(heap.len() == 50);

    // Shrink to fit
    heap.shrink_to_fit();
    assert(heap.capacity() >= 50);

    // Commented out: shrink_to() not yet in stdlib
    // heap.shrink_to(60);
    // assert(heap.capacity() >= 50);
}

