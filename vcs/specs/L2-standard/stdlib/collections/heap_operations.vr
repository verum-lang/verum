/// Test heap with custom ordering
fn test_heap_with_custom_ordering() {
    // Custom type
    type Task is {
        priority: Int,
        name: Text,
    };

    // Implement Ord based on priority
    implement Ord for Task {
        fn cmp(&self, other: &Self) -> Ordering {
            self.priority.cmp(&other.priority)
        }
    }

    implement PartialOrd for Task {
        fn partial_cmp(&self, other: &Self) -> Maybe<Ordering> {
            Some(self.cmp(other))
        }
    }

    implement Eq for Task {}
    implement PartialEq for Task {
        fn eq(&self, other: &Self) -> Bool {
            self.priority == other.priority
        }
    }

    let mut task_heap: Heap<Task> = Heap.new();
    task_heap.push(Task { priority: 3, name: "Low".to_text() });
    task_heap.push(Task { priority: 10, name: "High".to_text() });
    task_heap.push(Task { priority: 5, name: "Medium".to_text() });

    // Commented out: pop() returns Unit, not Maybe<Task>
    // assert(task_heap.pop().unwrap().name == "High");
    // assert(task_heap.pop().unwrap().name == "Medium");
    // assert(task_heap.pop().unwrap().name == "Low");
    task_heap.pop();
    task_heap.pop();
    task_heap.pop();

    // Heap with tuple ordering
    let mut tuple_heap: Heap<(Int, Text)> = Heap.new();
    tuple_heap.push((1, "first".to_text()));
    tuple_heap.push((3, "third".to_text()));
    tuple_heap.push((2, "second".to_text()));

    // Commented out: pop() returns Unit, not Maybe<(Int, Text)>
    // assert(tuple_heap.pop().unwrap() == (3, "third".to_text()));
    // assert(tuple_heap.pop().unwrap() == (2, "second".to_text()));
    // assert(tuple_heap.pop().unwrap() == (1, "first".to_text()));
    tuple_heap.pop();
    tuple_heap.pop();
    tuple_heap.pop();
}

