/// Test complex roots
fn test_complex_roots() {
    mount num.Complex;

    // Square root
    let c: Complex<Float> = Complex.new(-1.0, 0.0);
    let sqrt = c.sqrt();
    // sqrt(-1) = i
    assert((sqrt.re).abs() < EPSILON);
    assert((sqrt.im - 1.0).abs() < EPSILON);

    // Square root of positive real
    let pos: Complex<Float> = Complex.new(4.0, 0.0);
    let sqrt_pos = pos.sqrt();
    assert((sqrt_pos.re - 2.0).abs() < EPSILON);
    assert((sqrt_pos.im).abs() < EPSILON);

    // Square root of complex
    let complex: Complex<Float> = Complex.new(0.0, 2.0);
    let sqrt_complex = complex.sqrt();
    // sqrt(2i) = 1 + i
    assert((sqrt_complex.re - 1.0).abs() < EPSILON);
    assert((sqrt_complex.im - 1.0).abs() < EPSILON);

    // Verify: sqrt(z)^2 = z
    let z: Complex<Float> = Complex.new(3.0, 4.0);
    let sqrt_z = z.sqrt();
    let squared = sqrt_z * sqrt_z;
    assert((squared.re - z.re).abs() < EPSILON);
    assert((squared.im - z.im).abs() < EPSILON);

    // Cube root
    let cube: Complex<Float> = Complex.new(-8.0, 0.0);
    let cbrt = cube.cbrt();
    // Principal cube root of -8 is 1 + sqrt(3)i (not -2)
    // Verify: cbrt^3 = -8
    let cubed = cbrt * cbrt * cbrt;
    assert((cubed.re - (-8.0)).abs() < EPSILON);
    assert((cubed.im).abs() < EPSILON);

    // nth roots of unity
    fn nth_roots_of_unity(n: u32) -> List<Complex<Float>> {
        (0..n).map(|k| {
            let angle = 2.0 * PI * (k as Float) / (n as Float);
            Complex.from_polar(1.0, angle)
        }).collect()
    }

    let roots_4 = nth_roots_of_unity(4);
    // Should be 1, i, -1, -i
    assert(roots_4.len() == 4);
    // Product of all roots should be (-1)^(n-1) for nth roots of unity
}

/// Test complex exponential
fn test_complex_exponential() {
    mount num.Complex;

    // e^0 = 1
    let zero: Complex<Float> = Complex.new(0.0, 0.0);
    let exp_zero = zero.exp();
    assert((exp_zero.re - 1.0).abs() < EPSILON);
    assert((exp_zero.im).abs() < EPSILON);

    // e^(i*pi) = -1 (Euler's identity)
    let i_pi: Complex<Float> = Complex.new(0.0, PI);
    let euler = i_pi.exp();
    assert((euler.re - (-1.0)).abs() < EPSILON);
    assert((euler.im).abs() < EPSILON);

    // e^(i*pi/2) = i
    let i_pi_2: Complex<Float> = Complex.new(0.0, PI / 2.0);
    let result = i_pi_2.exp();
    assert((result.re).abs() < EPSILON);
    assert((result.im - 1.0).abs() < EPSILON);

    // e^x for real x
    let real: Complex<Float> = Complex.new(1.0, 0.0);
    let exp_real = real.exp();
    assert((exp_real.re - std.f64.consts.E).abs() < EPSILON);
    assert((exp_real.im).abs() < EPSILON);

    // General: e^(a+bi) = e^a * (cos(b) + i*sin(b))
    let a: Float = 1.0;
    let b: Float = 2.0;
    let c: Complex<Float> = Complex.new(a, b);
    let exp_c = c.exp();
    let expected_re = a.exp() * b.cos();
    let expected_im = a.exp() * b.sin();
    assert((exp_c.re - expected_re).abs() < EPSILON);
    assert((exp_c.im - expected_im).abs() < EPSILON);

    // exp(z1 + z2) = exp(z1) * exp(z2)
    let z1: Complex<Float> = Complex.new(1.0, 2.0);
    let z2: Complex<Float> = Complex.new(0.5, -1.0);
    let lhs = (z1 + z2).exp();
    let rhs = z1.exp() * z2.exp();
    assert((lhs.re - rhs.re).abs() < EPSILON);
    assert((lhs.im - rhs.im).abs() < EPSILON);
}

