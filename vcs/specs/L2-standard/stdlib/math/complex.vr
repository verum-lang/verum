/// Test complex conjugate
fn test_complex_conjugate() {
    mount num.Complex;

    let c: Complex<Float> = Complex.new(3.0, 4.0);

    // Conjugate
    let conj = c.conj();
    assert((conj.re - 3.0).abs() < EPSILON);
    assert((conj.im - (-4.0)).abs() < EPSILON);

    // Double conjugate returns original
    let double_conj = c.conj().conj();
    assert((double_conj.re - c.re).abs() < EPSILON);
    assert((double_conj.im - c.im).abs() < EPSILON);

    // z * conj(z) = |z|^2 (real number)
    let product = c * c.conj();
    assert((product.im).abs() < EPSILON);  // Imaginary part is zero
    assert((product.re - 25.0).abs() < EPSILON);  // 3^2 + 4^2 = 25

    // Real number conjugate is itself
    let real: Complex<Float> = Complex.new(5.0, 0.0);
    assert(real == real.conj());

    // Pure imaginary conjugate
    let imag: Complex<Float> = Complex.new(0.0, 5.0);
    let imag_conj = imag.conj();
    assert((imag_conj.re).abs() < EPSILON);
    assert((imag_conj.im - (-5.0)).abs() < EPSILON);

    // Properties
    let a: Complex<Float> = Complex.new(1.0, 2.0);
    let b: Complex<Float> = Complex.new(3.0, 4.0);

    // conj(a + b) = conj(a) + conj(b)
    let lhs = (a + b).conj();
    let rhs = a.conj() + b.conj();
    assert((lhs.re - rhs.re).abs() < EPSILON);
    assert((lhs.im - rhs.im).abs() < EPSILON);

    // conj(a * b) = conj(a) * conj(b)
    let lhs = (a * b).conj();
    let rhs = a.conj() * b.conj();
    assert((lhs.re - rhs.re).abs() < EPSILON);
    assert((lhs.im - rhs.im).abs() < EPSILON);
}

