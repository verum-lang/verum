const EPSILON: Float = 1e-10;
const PI: Float = std.f64.consts.PI;

/// Test complex number creation
fn test_complex_creation() {
    mount num.Complex;

    // From real and imaginary parts
    let c1: Complex<Float> = Complex.new(3.0, 4.0);
    assert(c1.re == 3.0);
    assert(c1.im == 4.0);

    // From real number (imaginary = 0)
    let c2: Complex<Float> = Complex.new(5.0, 0.0);
    assert(c2.re == 5.0);
    assert(c2.im == 0.0);

    // Pure imaginary
    let c3: Complex<Float> = Complex.new(0.0, 7.0);
    assert(c3.re == 0.0);
    assert(c3.im == 7.0);

    // Zero
    let zero: Complex<Float> = Complex.new(0.0, 0.0);
    assert(zero.re == 0.0);
    assert(zero.im == 0.0);

    // Imaginary unit
    let i: Complex<Float> = Complex.i();
    assert(i.re == 0.0);
    assert(i.im == 1.0);

    // One
    let one: Complex<Float> = Complex.one();
    assert(one.re == 1.0);
    assert(one.im == 0.0);

    // From polar coordinates
    let polar: Complex<Float> = Complex.from_polar(5.0, PI / 4.0);
    let expected_re = 5.0 * (PI / 4.0).cos();
    let expected_im = 5.0 * (PI / 4.0).sin();
    assert((polar.re - expected_re).abs() < EPSILON);
    assert((polar.im - expected_im).abs() < EPSILON);

    // Negative components
    let neg: Complex<Float> = Complex.new(-2.0, -3.0);
    assert(neg.re == -2.0);
    assert(neg.im == -3.0);
}

