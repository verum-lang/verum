/// Test complex number comparison
fn test_complex_comparison() {
    mount num.Complex;

    let a: Complex<Float> = Complex.new(3.0, 4.0);
    let b: Complex<Float> = Complex.new(3.0, 4.0);
    let c: Complex<Float> = Complex.new(3.0, 5.0);

    // Equality
    assert(a == b);
    assert(a != c);

    // Note: Complex numbers are not ordered!
    // a < b doesn't make sense for complex numbers

    // Check if zero
    let zero: Complex<Float> = Complex.new(0.0, 0.0);
    assert(zero.is_zero());
    assert(!a.is_zero());

    // Check if purely real
    fn is_real(c: Complex<Float>) -> Bool {
        c.im.abs() < EPSILON
    }

    let real: Complex<Float> = Complex.new(5.0, 0.0);
    assert(is_real(real));
    assert(!is_real(a));

    // Check if purely imaginary
    fn is_imaginary(c: Complex<Float>) -> Bool {
        c.re.abs() < EPSILON && c.im.abs() > EPSILON
    }

    let imag: Complex<Float> = Complex.new(0.0, 5.0);
    assert(is_imaginary(imag));
    assert(!is_imaginary(a));

    // Approximate equality
    fn approx_eq(a: Complex<Float>, b: Complex<Float>, eps: Float) -> Bool {
        (a.re - b.re).abs() < eps && (a.im - b.im).abs() < eps
    }

    let almost_a: Complex<Float> = Complex.new(3.0 + 1e-12, 4.0 - 1e-12);
    assert(approx_eq(a, almost_a, EPSILON));
}
