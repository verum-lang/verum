/// Test polar form
fn test_polar_form() {
    mount num.Complex;

    // Convert to polar
    let c: Complex<Float> = Complex.new(1.0, 1.0);
    let (r, theta) = c.to_polar();
    assert((r - 2.0.sqrt()).abs() < EPSILON);
    assert((theta - PI / 4.0).abs() < EPSILON);

    // Argument (angle)
    let c2: Complex<Float> = Complex.new(1.0, 0.0);
    assert((c2.arg()).abs() < EPSILON);  // Positive real axis

    let c3: Complex<Float> = Complex.new(0.0, 1.0);
    assert((c3.arg() - PI / 2.0).abs() < EPSILON);  // Positive imaginary

    let c4: Complex<Float> = Complex.new(-1.0, 0.0);
    assert((c4.arg() - PI).abs() < EPSILON);  // Negative real axis

    let c5: Complex<Float> = Complex.new(0.0, -1.0);
    assert((c5.arg() + PI / 2.0).abs() < EPSILON);  // Negative imaginary

    // Round trip: polar -> cartesian -> polar
    let original_r: Float = 5.0;
    let original_theta: Float = PI / 3.0;
    let cart = Complex.from_polar(original_r, original_theta);
    let (new_r, new_theta) = cart.to_polar();
    assert((new_r - original_r).abs() < EPSILON);
    assert((new_theta - original_theta).abs() < EPSILON);

    // Quadrant handling
    let q1: Complex<Float> = Complex.new(1.0, 1.0);   // First quadrant
    let q2: Complex<Float> = Complex.new(-1.0, 1.0);  // Second quadrant
    let q3: Complex<Float> = Complex.new(-1.0, -1.0); // Third quadrant
    let q4: Complex<Float> = Complex.new(1.0, -1.0);  // Fourth quadrant

    assert(q1.arg() > 0.0 && q1.arg() < PI / 2.0);
    assert(q2.arg() > PI / 2.0 && q2.arg() < PI);
    assert(q3.arg() < -PI / 2.0 && q3.arg() > -PI);
    assert(q4.arg() < 0.0 && q4.arg() > -PI / 2.0);
}

