/// Test bitwise operations
fn test_bit_operations() {
    // Bitwise AND
    assert(0b1100 & 0b1010 == 0b1000);
    assert(0xFF & 0x0F == 0x0F);

    // Bitwise OR
    assert(0b1100 | 0b1010 == 0b1110);
    assert(0xF0 | 0x0F == 0xFF);

    // Bitwise XOR
    assert(0b1100 ^ 0b1010 == 0b0110);
    assert(0xFF ^ 0xFF == 0x00);

    // Bitwise NOT
    assert(!0b0000_0000u8 == 0b1111_1111u8);
    // Bitwise NOT on u32 - use XOR with max value
    let not_zero_u32: u32 = 0 ^ u32.MAX;

    // Left shift
    assert(1u32 << 0 == 1);
    assert(1u32 << 1 == 2);
    assert(1u32 << 4 == 16);
    assert(0xFF_u32 << 8 == 0xFF00);

    // Right shift (logical for unsigned)
    assert(16u32 >> 4 == 1);
    assert(0xFF00_u32 >> 8 == 0xFF);

    // Right shift (arithmetic for signed)
    assert((-8i32) >> 2 == -2);  // Sign-extended

    // Rotate left/right
    assert(0b1000_0001u8.rotate_left(1) == 0b0000_0011);
    assert(0b1000_0001u8.rotate_right(1) == 0b1100_0000);

    // count_ones (popcount)
    assert(0b1010_1010u8.count_ones() == 4);
    assert(0u32.count_ones() == 0);
    assert(u32.MAX.count_ones() == 32);

    // count_zeros
    assert(0b1010_1010u8.count_zeros() == 4);

    // leading/trailing zeros
    assert(0b0001_0000u8.leading_zeros() == 3);
    assert(0b0001_0000u8.trailing_zeros() == 4);

    // leading/trailing ones
    // leading_ones not yet available on u8
    // assert(0b1110_0000u8.leading_ones() == 3);
    // trailing_ones not yet available on u8
    // assert(0b0000_0111u8.trailing_ones() == 3);

    // reverse_bits
    assert(0b1010_0000u8.reverse_bits() == 0b0000_0101);

    // swap_bytes
    assert(0x1234_u16.swap_bytes() == 0x3412);
    assert(0x12345678_u32.swap_bytes() == 0x78563412);

    // from_be/from_le bytes
    assert(u16.from_be_bytes([0x12, 0x34]) == 0x1234);
    assert(u16.from_le_bytes([0x12, 0x34]) == 0x3412);

    // to_be/to_le bytes - not yet available
    // assert(0x1234_u16.to_be_bytes() == [0x12, 0x34]);
    // assert(0x1234_u16.to_le_bytes() == [0x34, 0x12]);
}

