/// Test numeric properties and conversions
fn test_numeric_properties() {
    // Integer bounds
    assert(i8.MIN == -128);
    assert(i8.MAX == 127);
    assert(u8.MIN == 0);
    assert(u8.MAX == 255);
    assert(i32.MIN == -2147483648);
    assert(i32.MAX == 2147483647);

    // BITS constant
    assert(u8.BITS == 8);
    assert(u32.BITS == 32);
    assert(u64.BITS == 64);

    // Power of two checks
    assert(1u32.is_power_of_two());
    assert(2u32.is_power_of_two());
    assert(256u32.is_power_of_two());
    assert(!3u32.is_power_of_two());
    assert(!0u32.is_power_of_two());

    // next_power_of_two
    assert(3u32.next_power_of_two() == 4);
    assert(5u32.next_power_of_two() == 8);
    assert(8u32.next_power_of_two() == 8);

    // ilog (integer logarithm)
    assert(100u32.ilog10() == 2);
    assert(1000u32.ilog10() == 3);
    assert(8u32.ilog2() == 3);
    assert(9u32.ilog2() == 3);  // Truncates

    // Integer from/to string
    assert(42i32.to_text() == "42");
    assert((-42i32).to_text() == "-42");
    assert("42".parse<i32>().unwrap() == 42);
    assert("-42".parse<i32>().unwrap() == -42);

    // Radix conversion
    assert(format("{:b}", 42) == "101010");  // Binary
    assert(format("{:o}", 42) == "52");      // Octal
    assert(format("{:x}", 42) == "2a");      // Hex lowercase
    assert(format("{:X}", 42) == "2A");      // Hex uppercase

    assert(i32.from_str_radix("101010", 2).unwrap() == 42);
    assert(i32.from_str_radix("2a", 16).unwrap() == 42);

    // Type conversions
    assert((255u8 as i16) == 255);
    assert((-1i8 as u8) == 255);  // Bit reinterpretation
    assert((256i32 as u8) == 0);  // Truncation

    // try_into for fallible conversion
    let big: i32 = 1000;
    let result: Result<u8, _> = big.try_into();
    assert(result.is_err());

    let small: i32 = 100;
    let result: Result<u8, _> = small.try_into();
    assert(result == Ok(100));
}
