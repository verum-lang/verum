/// Comprehensive test suite for arithmetic operations.
/// Tests basic arithmetic, checked/wrapping operations, and integer math.

fn main() {
    test_basic_arithmetic();
    test_integer_division();
    test_modulo_operations();
    test_checked_arithmetic();
    test_saturating_arithmetic();
    test_wrapping_arithmetic();
    test_overflowing_arithmetic();
    test_bit_operations();
    test_comparison_operations();
    test_numeric_properties();
}

/// Test basic arithmetic operations
fn test_basic_arithmetic() {
    // Addition
    assert(2 + 3 == 5);
    assert(-5 + 3 == -2);
    assert(0 + 0 == 0);
    assert(i64.MAX + 0 == i64.MAX);

    // Subtraction
    assert(5 - 3 == 2);
    assert(3 - 5 == -2);
    assert(0 - 0 == 0);
    assert(i64.MIN - 0 == i64.MIN);

    // Multiplication
    assert(3 * 4 == 12);
    assert(-3 * 4 == -12);
    assert(-3 * -4 == 12);
    assert(0 * 1000 == 0);
    assert(1 * 1000 == 1000);

    // Division
    assert(12 / 4 == 3);
    assert(-12 / 4 == -3);
    assert(12 / -4 == -3);
    assert(-12 / -4 == 3);

    // Unary negation
    assert(-5 == 0 - 5);
    assert(-(-5) == 5);
    assert(-0 == 0);

    // Compound expressions
    assert(2 + 3 * 4 == 14);  // Precedence
    assert((2 + 3) * 4 == 20);
    assert(10 - 5 - 2 == 3);  // Left-to-right
    assert(10 - (5 - 2) == 7);

    // Floating point arithmetic
    let a: Float = 3.14;
    let b: Float = 2.0;
    assert((a + b - 5.14).abs() < 1e-10);
    assert((a * b - 6.28).abs() < 1e-10);
    assert((a / b - 1.57).abs() < 1e-10);

    // Mixed sign operations
    assert((-7) / 2 == -3);  // Truncates toward zero
    assert(7 / (-2) == -3);
    assert((-7) / (-2) == 3);
}

