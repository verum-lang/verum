// @test: run
// @tier: 0
// @level: L2
// @tags: stdlib, math, exponential, logarithm

/// Comprehensive test suite for exponential and logarithmic functions.
/// Tests exp, log, power functions and related operations.

fn main() {
    test_exp();
    test_exp2();
    test_exp_m1();
    test_ln();
    test_log2();
    test_log10();
    test_log();
    test_ln_1p();
    test_pow();
    test_powi();
    test_sqrt();
    test_cbrt();
    test_hypot();
    test_exponential_identities();
    test_logarithmic_identities();
}

const EPSILON: Float = 1e-10;
const E: Float = std.f64.consts.E;

/// Test natural exponential e^x
fn test_exp() {
    // Special values
    assert((0.0.exp() - 1.0).abs() < EPSILON);
    assert((1.0.exp() - E).abs() < EPSILON);
    assert((2.0.exp() - E * E).abs() < EPSILON);
    assert(((-1.0).exp() - 1.0 / E).abs() < EPSILON);

    // Negative exponents
    assert(((-2.0).exp() - 1.0 / (E * E)).abs() < EPSILON);

    // Property: e^(a+b) = e^a * e^b
    let a: Float = 1.5;
    let b: Float = 2.3;
    assert(((a + b).exp() - a.exp() * b.exp()).abs() < EPSILON);

    // Property: e^(-x) = 1 / e^x
    for x in [0.5, 1.0, 2.0, 3.0] {
        assert(((-x).exp() - 1.0 / x.exp()).abs() < EPSILON);
    }

    // Overflow
    assert(1000.0.exp().is_infinite());

    // Underflow
    assert((-1000.0).exp() == 0.0);

    // NaN handling
    assert(Float.nan.exp().is_nan());

    // Infinity handling
    assert(Float.infinity.exp().is_infinite());
    assert(Float.neg_infinity.exp() == 0.0);
}

/// Test base-2 exponential 2^x
fn test_exp2() {
    // Special values
    assert((0.0.exp2() - 1.0).abs() < EPSILON);
    assert((1.0.exp2() - 2.0).abs() < EPSILON);
    assert((10.0.exp2() - 1024.0).abs() < EPSILON);
    assert(((-1.0).exp2() - 0.5).abs() < EPSILON);

    // Integer powers
    for n in 0..10 {
        let expected = (1 << n) as Float;
        assert(((n as Float).exp2() - expected).abs() < EPSILON);
    }

    // Fractional powers
    assert((0.5.exp2() - std.f64.consts.SQRT_2).abs() < EPSILON);

    // Property: 2^(a+b) = 2^a * 2^b
    let a: Float = 1.5;
    let b: Float = 2.3;
    assert(((a + b).exp2() - a.exp2() * b.exp2()).abs() < EPSILON);

    // Relationship with exp
    for x in [0.0, 0.5, 1.0, 2.0] {
        let expected = (x * std.f64.consts.LN_2).exp();
        assert((x.exp2() - expected).abs() < EPSILON);
    }
}

/// Test exp_m1: e^x - 1 (more accurate for small x)
fn test_exp_m1() {
    // Special values
    assert(0.0.exp_m1().abs() < EPSILON);
    assert((1.0.exp_m1() - (E - 1.0)).abs() < EPSILON);

    // Small values (where exp_m1 is more accurate)
    for x in [1e-15, 1e-10, 1e-5] {
        let result = x.exp_m1();
        // For small x, exp_m1(x) ~ x
        assert((result - x).abs() < x * EPSILON);
    }

    // Comparison with naive approach for larger values
    for x in [0.1, 0.5, 1.0] {
        let via_exp_m1 = x.exp_m1();
        let naive = x.exp() - 1.0;
        assert((via_exp_m1 - naive).abs() < EPSILON);
    }

    // Negative values
    assert(((-1.0).exp_m1() - (1.0 / E - 1.0)).abs() < EPSILON);
}

