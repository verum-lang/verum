/// Test ln_1p: ln(1 + x) (more accurate for small x)
fn test_ln_1p() {
    // Special values
    assert(0.0.ln_1p().abs() < EPSILON);
    assert(((E - 1.0).ln_1p() - 1.0).abs() < EPSILON);

    // Small values (where ln_1p is more accurate)
    for x in [1e-15, 1e-10, 1e-5] {
        let result = x.ln_1p();
        // For small x, ln(1+x) ~ x
        assert((result - x).abs() < x * EPSILON);
    }

    // Comparison with naive approach
    for x in [0.1, 0.5, 1.0] {
        let via_ln_1p = x.ln_1p();
        let naive = (1.0 + x).ln();
        assert((via_ln_1p - naive).abs() < EPSILON);
    }

    // Domain: ln_1p(-1) = -infinity
    assert((-1.0).ln_1p().is_infinite());

    // Domain: ln_1p(x) where x < -1 = NaN
    assert((-2.0).ln_1p().is_nan());

    // Relationship with exp_m1
    for x in [-0.5, 0.0, 0.5, 1.0] {
        // ln_1p and exp_m1 are inverses
        assert((x.exp_m1().ln_1p() - x).abs() < EPSILON);
        if x > -1.0 {
            assert((x.ln_1p().exp_m1() - x).abs() < EPSILON);
        }
    }
}

