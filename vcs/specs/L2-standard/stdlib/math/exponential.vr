/// Test integer power function
fn test_powi() {
    // Integer powers
    assert((2.0.powi(10) - 1024.0).abs() < EPSILON);
    assert((3.0.powi(4) - 81.0).abs() < EPSILON);
    assert((10.0.powi(0) - 1.0).abs() < EPSILON);

    // Negative exponents
    assert((2.0.powi(-1) - 0.5).abs() < EPSILON);
    assert((2.0.powi(-3) - 0.125).abs() < EPSILON);

    // Negative base
    assert(((-2.0).powi(2) - 4.0).abs() < EPSILON);
    assert(((-2.0).powi(3) + 8.0).abs() < EPSILON);
    assert(((-3.0).powi(4) - 81.0).abs() < EPSILON);
    assert(((-3.0).powi(5) + 243.0).abs() < EPSILON);

    // Zero exponent
    assert((0.0.powi(0) - 1.0).abs() < EPSILON);
    assert(((-5.0).powi(0) - 1.0).abs() < EPSILON);

    // powi vs pow for integer exponents
    for base in [2.0, 3.0, 0.5] {
        for exp in 0..10 {
            let via_powi = base.powi(exp);
            let via_pow = base.pow(exp as Float);
            assert((via_powi - via_pow).abs() < EPSILON);
        }
    }
}

/// Test square root
fn test_sqrt() {
    // Perfect squares
    assert((4.0.sqrt() - 2.0).abs() < EPSILON);
    assert((9.0.sqrt() - 3.0).abs() < EPSILON);
    assert((16.0.sqrt() - 4.0).abs() < EPSILON);
    assert((100.0.sqrt() - 10.0).abs() < EPSILON);

    // Special values
    assert(0.0.sqrt().abs() < EPSILON);
    assert((1.0.sqrt() - 1.0).abs() < EPSILON);

    // Irrational results
    assert((2.0.sqrt() - std.f64.consts.SQRT_2).abs() < EPSILON);

    // Property: sqrt(x)^2 = x
    for x in [0.0, 1.0, 2.0, 10.0, 100.0] {
        let s = x.sqrt();
        assert((s * s - x).abs() < 1e-9);
    }

    // Property: sqrt(a*b) = sqrt(a) * sqrt(b)
    let a: Float = 4.0;
    let b: Float = 9.0;
    assert(((a * b).sqrt() - a.sqrt() * b.sqrt()).abs() < EPSILON);

    // Domain error
    assert((-1.0).sqrt().is_nan());
    assert((-100.0).sqrt().is_nan());

    // Relationship with pow
    for x in [1.0, 4.0, 9.0, 16.0] {
        assert((x.sqrt() - x.pow(0.5)).abs() < EPSILON);
    }
}

/// Test cube root
fn test_cbrt() {
    // Perfect cubes
    assert((8.0.cbrt() - 2.0).abs() < EPSILON);
    assert((27.0.cbrt() - 3.0).abs() < EPSILON);
    assert((64.0.cbrt() - 4.0).abs() < EPSILON);

    // Special values
    assert(0.0.cbrt().abs() < EPSILON);
    assert((1.0.cbrt() - 1.0).abs() < EPSILON);

    // Negative values (unlike sqrt, cbrt handles negatives)
    assert(((-8.0).cbrt() + 2.0).abs() < EPSILON);
    assert(((-27.0).cbrt() + 3.0).abs() < EPSILON);

    // Property: cbrt(x)^3 = x
    for x in [-27.0, -8.0, 0.0, 8.0, 27.0, 100.0] {
        let c = x.cbrt();
        assert((c * c * c - x).abs() < 1e-9);
    }

    // Relationship with pow (for positive values)
    for x in [1.0, 8.0, 27.0] {
        assert((x.cbrt() - x.pow(1.0 / 3.0)).abs() < EPSILON);
    }
}

/// Test hypot: sqrt(x^2 + y^2) without overflow
fn test_hypot() {
    // Pythagorean triples
    assert((3.0.hypot(4.0) - 5.0).abs() < EPSILON);
    assert((5.0.hypot(12.0) - 13.0).abs() < EPSILON);
    assert((8.0.hypot(15.0) - 17.0).abs() < EPSILON);

    // Special values
    assert((0.0.hypot(5.0) - 5.0).abs() < EPSILON);
    assert((5.0.hypot(0.0) - 5.0).abs() < EPSILON);
    assert(0.0.hypot(0.0).abs() < EPSILON);

    // Symmetric
    for (a, b) in [(3.0, 4.0), (1.0, 1.0), (5.0, 0.0)] {
        assert((a.hypot(b) - b.hypot(a)).abs() < EPSILON);
    }

    // Negative values
    assert(((-3.0).hypot(4.0) - 5.0).abs() < EPSILON);
    assert((3.0.hypot(-4.0) - 5.0).abs() < EPSILON);
    assert(((-3.0).hypot(-4.0) - 5.0).abs() < EPSILON);

    // Avoids overflow for large values
    let large: Float = 1e200;
    let result = large.hypot(large);
    assert(!result.is_nan());
    assert(!result.is_infinite());
    assert((result - large * std.f64.consts.SQRT_2).abs() < large * EPSILON);

    // Avoids underflow for small values
    let small: Float = 1e-200;
    let small_result = small.hypot(small);
    assert(small_result > 0.0);
}

/// Test exponential identities
fn test_exponential_identities() {
    let a: Float = 1.5;
    let b: Float = 2.3;

    // e^(a+b) = e^a * e^b
    assert(((a + b).exp() - a.exp() * b.exp()).abs() < EPSILON);

    // e^(a-b) = e^a / e^b
    assert(((a - b).exp() - a.exp() / b.exp()).abs() < EPSILON);

    // (e^a)^b = e^(a*b)
    assert((a.exp().pow(b) - (a * b).exp()).abs() < EPSILON);

    // e^(-x) = 1 / e^x
    assert(((-a).exp() - 1.0 / a.exp()).abs() < EPSILON);

    // For 2^x
    assert(((a + b).exp2() - a.exp2() * b.exp2()).abs() < EPSILON);
    assert(((-a).exp2() - 1.0 / a.exp2()).abs() < EPSILON);
}

