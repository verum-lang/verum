/// Test base-2 logarithm
fn test_log2() {
    // Special values
    assert(1.0.log2().abs() < EPSILON);
    assert((2.0.log2() - 1.0).abs() < EPSILON);
    assert((1024.0.log2() - 10.0).abs() < EPSILON);
    assert((0.5.log2() + 1.0).abs() < EPSILON);

    // Powers of 2
    for n in 0..20 {
        let x = (1u64 << n) as Float;
        assert((x.log2() - n as Float).abs() < EPSILON);
    }

    // Relationship with ln
    for x in [0.5, 1.0, 2.0, 10.0] {
        let via_ln = x.ln() / std.f64.consts.LN_2;
        assert((x.log2() - via_ln).abs() < EPSILON);
    }

    // 2^(log2(x)) = x
    for x in [0.1, 1.0, 5.0, 100.0] {
        assert((x.log2().exp2() - x).abs() < EPSILON);
    }
}

/// Test base-10 logarithm
fn test_log10() {
    // Special values
    assert(1.0.log10().abs() < EPSILON);
    assert((10.0.log10() - 1.0).abs() < EPSILON);
    assert((100.0.log10() - 2.0).abs() < EPSILON);
    assert((1000.0.log10() - 3.0).abs() < EPSILON);
    assert((0.1.log10() + 1.0).abs() < EPSILON);

    // Powers of 10
    for n in -5..10 {
        let x = 10.0f64.powi(n);
        assert((x.log10() - n as Float).abs() < EPSILON);
    }

    // Relationship with ln
    for x in [0.5, 1.0, 10.0, 100.0] {
        let via_ln = x.ln() / std.f64.consts.LN_10;
        assert((x.log10() - via_ln).abs() < EPSILON);
    }

    // Number of digits
    fn num_digits(n: u64) -> u32 {
        if n == 0 { return 1; }
        (n as Float).log10().floor() as u32 + 1
    }

    assert(num_digits(1) == 1);
    assert(num_digits(99) == 2);
    assert(num_digits(100) == 3);
    assert(num_digits(9999) == 4);
}

