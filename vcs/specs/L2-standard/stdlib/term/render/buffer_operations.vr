// @test: parse-pass
// @tier: 0
// @level: L2
// @tags: stdlib, term, render, buffer, cells, wide-chars
// @description: Buffer put/get, set_string cluster iteration, set_style, merge, reset.

mount core.term.render.{Buffer, Cell};
mount core.term.layout.Rect;
mount core.term.style.{Style, Color};

fn test_buffer_new_dimensions() {
    let b = Buffer.new(10, 4);
    assert_eq(b.width, 10);
    assert_eq(b.height, 4);
    assert_eq(b.cells.len(), 40);
}

fn test_buffer_new_zero_sized() {
    let b = Buffer.new(0, 0);
    assert_eq(b.cells.len(), 0);
}

fn test_from_rect() {
    let r = Rect.new(10, 20, 8, 4);
    let b = Buffer.from_rect(r);
    assert_eq(b.width, 8);
    assert_eq(b.height, 4);
}

fn test_in_bounds() {
    let b = Buffer.new(5, 3);
    assert(b.in_bounds(0, 0));
    assert(b.in_bounds(4, 2));
    assert(!b.in_bounds(5, 2));
    assert(!b.in_bounds(0, 3));
    assert(!b.in_bounds(-1, 0));
}

fn test_set_string_ascii() {
    let mut b = Buffer.new(20, 1);
    let end = b.set_string(0, 0, &"hello", Style.DEFAULT);
    assert_eq(end, 5);
    assert_eq(b.get(0, 0).grapheme, "h");
    assert_eq(b.get(4, 0).grapheme, "o");
}

fn test_set_string_truncates_at_width() {
    let mut b = Buffer.new(3, 1);
    let end = b.set_string(0, 0, &"hello", Style.DEFAULT);
    assert_eq(end, 3);
}

fn test_set_string_wide_char_marks_skip() {
    let mut b = Buffer.new(6, 1);
    b.set_string(0, 0, &"中a", Style.DEFAULT);
    assert_eq(b.get(0, 0).grapheme, "中");
    assert(b.get(1, 0).skip);
    assert_eq(b.get(2, 0).grapheme, "a");
}

fn test_set_string_offscreen_row_noop() {
    let mut b = Buffer.new(10, 2);
    let end = b.set_string(0, 5, &"hello", Style.DEFAULT);
    assert_eq(end, 0);
    // original cells remain empty
    assert_eq(b.get(0, 0).grapheme, " ");
}

fn test_set_style_area() {
    let mut b = Buffer.new(4, 2);
    b.set_style(Rect.new(0, 0, 2, 1), Style.new().fg(Color.Red));
    match b.get(0, 0).style.fg {
        Some(Color.Red) => {}
        _ => panic("expected Red fg"),
    }
    // untouched cell has default fg
    match b.get(2, 1).style.fg {
        None => {}
        _ => panic("expected default fg"),
    }
}

fn test_reset_clears_all() {
    let mut b = Buffer.new(3, 1);
    b.set_string(0, 0, &"xyz", Style.new().fg(Color.Red));
    b.reset();
    assert_eq(b.get(0, 0).grapheme, " ");
    match b.get(0, 0).style.fg {
        None => {}
        _ => panic("expected fg cleared"),
    }
}

fn test_fill_whole_buffer() {
    let mut b = Buffer.new(3, 2);
    b.fill(&".", Style.new().fg(Color.Blue));
    for y in 0..2 {
        for x in 0..3 {
            assert_eq(b.get(x, y).grapheme, ".");
        }
    }
}

fn test_to_lines_projection() {
    let mut b = Buffer.new(5, 2);
    b.set_string(0, 0, &"hi", Style.DEFAULT);
    b.set_string(0, 1, &"bye", Style.DEFAULT);
    let lines = b.to_lines();
    assert_eq(lines.len(), 2);
    // ASCII portion present; trailing whitespace is implementation-defined.
    assert(lines[0].len() >= 2);
    assert(lines[1].len() >= 3);
}

fn test_merge_non_blank_overwrites() {
    let mut dst = Buffer.new(5, 1);
    let mut src = Buffer.new(2, 1);
    src.set_string(0, 0, &"ab", Style.DEFAULT);
    dst.merge(&src, Rect.new(1, 0, 2, 1));
    assert_eq(dst.get(1, 0).grapheme, "a");
    assert_eq(dst.get(2, 0).grapheme, "b");
    assert_eq(dst.get(0, 0).grapheme, " ");  // unchanged
}

fn main() {
    test_buffer_new_dimensions();
    test_buffer_new_zero_sized();
    test_from_rect();
    test_in_bounds();
    test_set_string_ascii();
    test_set_string_truncates_at_width();
    test_set_string_wide_char_marks_skip();
    test_set_string_offscreen_row_noop();
    test_set_style_area();
    test_reset_clears_all();
    test_fill_whole_buffer();
    test_to_lines_projection();
    test_merge_non_blank_overwrites();
}
