// @test: parse-pass
// @tier: 0
// @level: L2
// @tags: stdlib, term, layout, constraint
// @description: Constraint layout splitter (Length/Min/Max/Percentage/Ratio/Fill).

mount core.term.layout.{Rect, Layout, Direction, Constraint};

fn test_length_exact_sum() {
    let area = Rect.new(0, 0, 30, 1);
    let mut cs = List.new();
    cs.push(Constraint.Length(10));
    cs.push(Constraint.Length(20));
    let parts = Layout.new().direction(Direction.Horizontal).constraints(cs).split(area);
    assert_eq(parts.len(), 2);
    assert_eq(parts[0].width, 10);
    assert_eq(parts[1].width, 20);
    assert_eq(parts[0].x + parts[0].width, parts[1].x);
}

fn test_percentage_distribution() {
    let area = Rect.new(0, 0, 100, 1);
    let mut cs = List.new();
    cs.push(Constraint.Percentage(30));
    cs.push(Constraint.Percentage(70));
    let parts = Layout.new().direction(Direction.Horizontal).constraints(cs).split(area);
    assert_eq(parts.len(), 2);
    assert_eq(parts[0].width, 30);
    assert_eq(parts[1].width, 70);
}

fn test_ratio_sum_equals_area() {
    let area = Rect.new(0, 0, 60, 1);
    let mut cs = List.new();
    cs.push(Constraint.Ratio(1, 4));
    cs.push(Constraint.Ratio(3, 4));
    let parts = Layout.new().direction(Direction.Horizontal).constraints(cs).split(area);
    assert_eq(parts.len(), 2);
    assert_eq(parts[0].width + parts[1].width, 60);
    assert_eq(parts[0].width, 15);
    assert_eq(parts[1].width, 45);
}

fn test_fill_absorbs_remainder() {
    let area = Rect.new(0, 0, 50, 1);
    let mut cs = List.new();
    cs.push(Constraint.Length(10));
    cs.push(Constraint.Fill(1));
    cs.push(Constraint.Length(5));
    let parts = Layout.new().direction(Direction.Horizontal).constraints(cs).split(area);
    assert_eq(parts.len(), 3);
    assert_eq(parts[0].width, 10);
    assert_eq(parts[2].width, 5);
    assert_eq(parts[1].width, 35);
}

fn test_min_floor_respected() {
    let area = Rect.new(0, 0, 10, 1);
    let mut cs = List.new();
    cs.push(Constraint.Min(5));
    cs.push(Constraint.Min(5));
    let parts = Layout.new().direction(Direction.Horizontal).constraints(cs).split(area);
    assert(parts[0].width >= 5);
    assert(parts[1].width >= 5);
    assert_eq(parts[0].width + parts[1].width, 10);
}

fn test_vertical_direction() {
    let area = Rect.new(0, 0, 10, 20);
    let mut cs = List.new();
    cs.push(Constraint.Length(5));
    cs.push(Constraint.Fill(1));
    cs.push(Constraint.Length(1));
    let parts = Layout.new().direction(Direction.Vertical).constraints(cs).split(area);
    assert_eq(parts[0].height, 5);
    assert_eq(parts[2].height, 1);
    assert_eq(parts[1].height, 14);
    // x/width match container in vertical split
    assert_eq(parts[0].x, 0);
    assert_eq(parts[0].width, 10);
}

fn test_rect_helpers() {
    let r = Rect.new(5, 10, 30, 20);
    assert_eq(r.right(), 35);
    assert_eq(r.bottom(), 30);
    assert(!r.is_empty());
    let empty = Rect.new(0, 0, 0, 0);
    assert(empty.is_empty());
}

fn main() {
    test_length_exact_sum();
    test_percentage_distribution();
    test_ratio_sum_equals_area();
    test_fill_absorbs_remainder();
    test_min_floor_respected();
    test_vertical_direction();
    test_rect_helpers();
}
