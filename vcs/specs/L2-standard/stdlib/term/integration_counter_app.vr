// @test: parse-pass
// @tier: 0
// @level: L2
// @tags: stdlib, term, integration, elm, counter
// @description: Counter TEA app — covers all 7 layers end-to-end.

/// Wire-up test: events → style → layout → widgets → app framework.
/// No real terminal is touched; the model is driven synthetically.

mount core.term.*;

type CounterMsg is Increment | Decrement | Reset;
type Counter is { count: Int };

fn counter_update(m: &mut Counter, msg: CounterMsg) -> Command<CounterMsg> {
    match msg {
        Increment => { m.count = m.count + 1; Command.Noop }
        Decrement => { m.count = m.count - 1; Command.Noop }
        Reset     => { m.count = 0;           Command.Noop }
    }
}

fn counter_view(_m: &Counter, frame: &mut Frame) {
    let area = frame.size();
    let (header, _body, _footer) = header_body_footer(area, 3, 1);
    Block.new().title("Counter").borders(Borders.ALL).render(header, frame.buffer);
}

fn counter_handle_event(event: Event) -> Maybe<CounterMsg> {
    match event {
        Event.Key(ke) => match ke.code {
            KeyCode.Up         => Some(CounterMsg.Increment),
            KeyCode.Down       => Some(CounterMsg.Decrement),
            KeyCode.Char('r')  => Some(CounterMsg.Reset),
            _                  => None,
        },
        _ => None,
    }
}

fn test_counter_logic() {
    let mut m = Counter { count: 0 };
    counter_update(&mut m, CounterMsg.Increment);
    counter_update(&mut m, CounterMsg.Increment);
    counter_update(&mut m, CounterMsg.Increment);
    assert_eq(m.count, 3);
    counter_update(&mut m, CounterMsg.Decrement);
    assert_eq(m.count, 2);
    counter_update(&mut m, CounterMsg.Reset);
    assert_eq(m.count, 0);
}

fn test_event_mapping() {
    let up = Event.Key(KeyEvent {
        code: KeyCode.Up, modifiers: Modifiers.NONE, kind: KeyEventKind.Press,
    });
    let mouse = Event.Mouse(MouseEvent {
        kind: MouseEventKind.Down(MouseButton.Left), column: 0, row: 0,
        modifiers: Modifiers.NONE,
    });
    assert(counter_handle_event(up).is_some());
    assert(counter_handle_event(mouse).is_none());
}

fn test_layout_pattern() {
    let area = Rect.new(0, 0, 80, 24);
    let (header, body, footer) = header_body_footer(area, 3, 1);
    assert_eq(header.y, 0);
    assert_eq(header.height, 3);
    assert_eq(footer.bottom(), 24);
    assert(body.height >= 18);
}

fn main() {
    test_counter_logic();
    test_event_mapping();
    test_layout_pattern();
}
