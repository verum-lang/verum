    assert(scientific_fmt.contains("e"));

    let fixed_width: Text = format("{:10.4}", value);
    assert(fixed_width.len() == 10);
}

/// Test bit manipulation of floats
fn test_float_bit_manipulation() {
    // to_bits / from_bits
    let value: Float = 1.0;
    let bits: u64 = value.to_bits();
    assert(bits == 0x3FF0000000000000);  // IEEE 754 representation

    let from_bits: Float = Float.from_bits(bits);
    assert(from_bits == 1.0);

    // Examine IEEE 754 components
    fn decompose_float(value: Float) -> (Bool, i32, u64) {
        let bits: u64 = value.to_bits();
        let sign: Bool = (bits >> 63) != 0;
        let exponent: i32 = ((bits >> 52) & 0x7FF) as i32 - 1023;
        let mantissa: u64 = bits & 0xFFFFFFFFFFFFF;
        (sign, exponent, mantissa)
    }

    let (sign, exp, mantissa) = decompose_float(1.0);
    assert(!sign);
    assert(exp == 0);
    assert(mantissa == 0);

    let (sign2, exp2, _) = decompose_float(-2.0);
    assert(sign2);
    assert(exp2 == 1);

    // Next representable float
    fn next_up(value: Float) -> Float {
        if value.is_nan() { return value; }
        if value == (1.0 / 0.0) { return value; }
        if value == 0.0 { return Float.MIN_POSITIVE; }

        let bits = value.to_bits();
        let next_bits = if value > 0.0 { bits + 1 } else { bits - 1 };
        Float.from_bits(next_bits)
    }

    fn next_down(value: Float) -> Float {
        if value.is_nan() { return value; }
        if value == (-1.0 / 0.0) { return value; }
        if value == 0.0 { return -Float.MIN_POSITIVE; }

        let bits = value.to_bits();
        let next_bits = if value > 0.0 { bits - 1 } else { bits + 1 };
        Float.from_bits(next_bits)
    }

    let one: Float = 1.0;
    let next: Float = next_up(one);
    assert(next > one);
    assert(next - one == Float.EPSILON);

    // ULP (Unit in Last Place)
    fn ulp(value: Float) -> Float {
        if value.is_nan() || value.is_infinite() { return (0.0 / 0.0); }
        let next = next_up(value.abs());
        next - value.abs()
    }
}

/// Test floating point precision
fn test_float_precision() {
    // Precision limits
    let epsilon: Float = Float.EPSILON;
    assert(1.0 + epsilon > 1.0);
    assert(1.0 + epsilon / 2.0 == 1.0);  // Below precision

    // Significant digits
    let max_int_exact: Float = 9007199254740992.0;  // 2^53
    assert(max_int_exact == max_int_exact + 1.0);  // Can't distinguish

    // Catastrophic cancellation
    let a: Float = 1e10;
    let b: Float = a + 1.0;
    let diff: Float = b - a;
    assert((diff - 1.0).abs() < 1e-5);  // OK at this scale

    let c: Float = 1e16;
    let d: Float = c + 1.0;
    let diff2: Float = d - c;
    assert(diff2 == 0.0);  // Lost precision!

    // Kahan summation for accurate sum
    fn kahan_sum(values: &List<Float>) -> Float {
        let mut sum: Float = 0.0;
        let mut c: Float = 0.0;  // Running compensation

        for value in values.iter() {
            let y = *value - c;
            let t = sum + y;
            c = (t - sum) - y;
            sum = t;
        }
        sum
    }

    // Test against naive sum
    let values: List<Float> = (0..1000000).map(|_| 0.1).collect();
    let naive_sum: Float = values.iter().sum();
    let kahan: Float = kahan_sum(&values);
    // Kahan is more accurate

    // Relative error
    fn relative_error(computed: Float, expected: Float) -> Float {
        if expected == 0.0 {
            computed.abs()
        } else {
            ((computed - expected) / expected).abs()
        }
    }

    assert(relative_error(3.14, std.f64.consts.PI) < 0.005);
}

/// Test float classification
fn test_float_classification() {
    // is_nan
    assert((0.0 / 0.0).is_nan());
    assert(!(1.0).is_nan());

    // is_infinite
    assert((1.0 / 0.0).is_infinite());
    assert((-1.0 / 0.0).is_infinite());
    assert(!(1.0).is_infinite());

    // is_finite
    assert((1.0).is_finite());
    assert((0.0).is_finite());
    assert(!(1.0 / 0.0).is_finite());
    assert(!(0.0 / 0.0).is_finite());

    // is_normal
    assert((1.0).is_normal());
    assert(!(0.0).is_normal());
    assert(!(1.0 / 0.0).is_normal());
    assert(!(1e-310).is_normal());  // Subnormal

    // is_subnormal
    assert((1e-310).is_subnormal());
    assert(!(1.0).is_subnormal());

    // classify
    let class: FpCategory = 1.0.classify();
    assert(class == FpCategory.Normal);

    assert(0.0.classify() == FpCategory.Zero);
    assert((1.0 / 0.0).classify() == FpCategory.Infinite);
    assert((0.0 / 0.0).classify() == FpCategory.Nan);
    assert((1e-310).classify() == FpCategory.Subnormal);

    // Sign checks
    assert((1.0).is_sign_positive());
    assert((-1.0).is_sign_negative());
    assert((0.0).is_sign_positive());
    assert((-0.0).is_sign_negative());

    // Combined checks
    fn is_valid_positive(f: Float) -> Bool {
        f.is_finite() && f.is_sign_positive() && f > 0.0
    }
    assert(is_valid_positive(3.14));
    assert(!is_valid_positive(-3.14));
    assert(!is_valid_positive((1.0 / 0.0)));
    assert(!is_valid_positive(0.0));
}
