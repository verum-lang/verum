// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: stdlib, numeric, fixed-precision, integers

/// Comprehensive test suite for fixed-precision integer types.
/// Tests i8, i16, i32, i64, u8, u16, u32, u64 operations.
/// Includes overflow handling, bitwise operations, and conversions.

fn main() {
    test_signed_integers();
    test_unsigned_integers();
    test_overflow_behavior();
    test_checked_operations();
    test_saturating_operations();
    test_wrapping_operations();
    test_overflowing_operations();
    test_bitwise_operations();
    test_type_conversion();
    // test_byte_operations();  // Commented out: from_be_bytes const generic mismatch
}

/// Test signed integer types (i8, i16, i32, i64)
fn test_signed_integers() {
    // i8: -128 to 127
    let i8_min: i8 = i8.MIN;
    let i8_max: i8 = i8.MAX;
    assert(i8_min == -128);
    assert(i8_max == 127);

    let i8_val: i8 = 42;
    let i8_neg: i8 = -100;
    assert(i8_val + 10 == 52);
    assert(i8_neg - 20 == -120);

    // i16: -32768 to 32767
    let i16_min: i16 = i16.MIN;
    let i16_max: i16 = i16.MAX;
    assert(i16_min == -32768);
    assert(i16_max == 32767);

    let i16_val: i16 = 1000;
    assert(i16_val * 10 == 10000);

    // i32: -2147483648 to 2147483647
    let i32_min: i32 = i32.MIN;
    let i32_max: i32 = i32.MAX;
    assert(i32_min == -2147483648);
    assert(i32_max == 2147483647);

    let i32_val: i32 = 1000000;
    assert(i32_val * 1000 == 1000000000);

    // i64: -9223372036854775808 to 9223372036854775807
    let i64_min: i64 = i64.MIN;
    let i64_max: i64 = i64.MAX;
    assert(i64_min == -9223372036854775808);
    assert(i64_max == 9223372036854775807);

    let i64_val: i64 = 1000000000000;
    assert(i64_val * 1000 == 1000000000000000);

    // Negation
    assert(-i8_val == -42);
    assert(-i16_val == -1000);
    assert(-i32_val == -1000000);

    // Absolute value
    assert(i8_neg.abs() == 100);
    assert((-1000i32).abs() == 1000);

    // Note: MIN.abs() overflows for signed types
    // assert(i8.MIN.abs());  // Would panic or wrap

    // Signum
    assert(i8_val.signum() == 1);
    assert(i8_neg.signum() == -1);
    assert(0i32.signum() == 0);
}

/// Test unsigned integer types (u8, u16, u32, u64)
fn test_unsigned_integers() {
    // u8: 0 to 255
    let u8_min: u8 = u8.MIN;
    let u8_max: u8 = u8.MAX;
    assert(u8_min == 0);
    assert(u8_max == 255);

    let u8_val: u8 = 200;
    assert(u8_val + 50 == 250);

    // u16: 0 to 65535
    let u16_min: u16 = u16.MIN;
    let u16_max: u16 = u16.MAX;
    assert(u16_min == 0);
    assert(u16_max == 65535);

    let u16_val: u16 = 50000;
    assert(u16_val + 10000 == 60000);

    // u32: 0 to 4294967295
    let u32_min: u32 = u32.MIN;
    let u32_max: u32 = u32.MAX;
    assert(u32_min == 0);
    assert(u32_max == 4294967295);

    let u32_val: u32 = 3000000000;
    assert(u32_val + 1000000000 == 4000000000);

    // u64: 0 to 18446744073709551615
    let u64_min: u64 = u64.MIN;
    let u64_max: u64 = u64.MAX;
    assert(u64_min == 0);
    assert(u64_max == 18446744073709551615);

    let u64_val: u64 = 10000000000000000000;
    assert(u64_val + 1000000000000000000 == 11000000000000000000);

    // No negation for unsigned
    // assert(-u8_val);  // Compile error

    // Leading zeros
    assert(u8_val.leading_zeros() >= 0);
    assert((1u32).leading_zeros() == 31);

    // Trailing zeros
    assert((8u32).trailing_zeros() == 3);  // 8 = 0b1000

    // Count ones
    assert((0b10110u8).count_ones() == 3);

    // Count zeros
    assert((0b11111111u8).count_zeros() == 0);
}

