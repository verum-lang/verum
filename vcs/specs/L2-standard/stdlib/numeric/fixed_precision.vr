/// Test checked operations (return None on overflow)
fn test_checked_operations() {
    // Checked addition
    let valid_add: Maybe<u8> = 200u8.checked_add(50);
    assert(valid_add == Some(250));

    let overflow_add: Maybe<u8> = 200u8.checked_add(100);
    assert(overflow_add.is_none());

    // Checked subtraction
    let valid_sub: Maybe<u8> = 100u8.checked_sub(50);
    assert(valid_sub == Some(50));

    let underflow_sub: Maybe<u8> = 50u8.checked_sub(100);
    assert(underflow_sub.is_none());

    // Checked multiplication
    let valid_mul: Maybe<u8> = 10u8.checked_mul(20);
    assert(valid_mul == Some(200));

    let overflow_mul: Maybe<u8> = 100u8.checked_mul(10);
    assert(overflow_mul.is_none());

    // Commented out: checked_div()/checked_rem() not yet in stdlib for i32
    // let valid_div: Maybe<i32> = 100i32.checked_div(3);
    // assert(valid_div == Some(33));
    // let div_zero: Maybe<i32> = 100i32.checked_div(0);
    // assert(div_zero.is_none());
    // let valid_rem: Maybe<i32> = 100i32.checked_rem(7);
    // assert(valid_rem == Some(2));
    // let rem_zero: Maybe<i32> = 100i32.checked_rem(0);
    // assert(rem_zero.is_none());

    // Commented out: checked_neg()/checked_abs()/checked_pow()/checked_shl() not yet in stdlib
    // let valid_neg: Maybe<i8> = 100i8.checked_neg();
    // let overflow_neg: Maybe<i8> = i8.MIN.checked_neg();
    // let valid_abs: Maybe<i8> = (-100i8).checked_abs();
    // let overflow_abs: Maybe<i8> = i8.MIN.checked_abs();
    // let valid_pow: Maybe<u32> = 2u32.checked_pow(10);
    // let overflow_pow: Maybe<u8> = 2u8.checked_pow(8);
    // let valid_shift: Maybe<u8> = 1u8.checked_shl(4);
    // let overflow_shift: Maybe<u8> = 1u8.checked_shl(8);
}

/// Test saturating operations (clamp at min/max)
fn test_saturating_operations() {
    // Saturating addition
    let sat_add: u8 = 200u8.saturating_add(100);
    assert(sat_add == 255);  // Clamped to max

    let no_sat_add: u8 = 100u8.saturating_add(50);
    assert(no_sat_add == 150);  // No saturation

    // Saturating subtraction
    let sat_sub: u8 = 50u8.saturating_sub(100);
    assert(sat_sub == 0);  // Clamped to min

    let no_sat_sub: u8 = 100u8.saturating_sub(50);
    assert(no_sat_sub == 50);

    // Saturating multiplication
    let sat_mul: u8 = 100u8.saturating_mul(10);
    assert(sat_mul == 255);

    let no_sat_mul: u8 = 10u8.saturating_mul(10);
    assert(no_sat_mul == 100);

    // Commented out: saturating_neg()/saturating_abs() not yet in stdlib
    // let sat_neg: i8 = i8.MIN.saturating_neg();
    // assert(sat_neg == i8.MAX);
    // let no_sat_neg: i8 = (-100i8).saturating_neg();
    // assert(no_sat_neg == 100);
    // let sat_abs: i8 = i8.MIN.saturating_abs();
    // assert(sat_abs == i8.MAX);

    // Saturating power
    let sat_pow: u8 = 10u8.saturating_pow(3);
    assert(sat_pow == 255);  // 1000 > 255

    // Commented out: saturating_add() not yet in stdlib for i8
    // let i8_sat_add_up: i8 = 100i8.saturating_add(50);
    // assert(i8_sat_add_up == 127);
    // let i8_sat_add_down: i8 = (-100i8).saturating_add(-50);
    // assert(i8_sat_add_down == -128);
}

/// Test wrapping operations (always wrap on overflow)
fn test_wrapping_operations() {
    // Wrapping addition
    let wrap_add: u8 = 255u8.wrapping_add(1);
    assert(wrap_add == 0);

    let wrap_add2: u8 = 255u8.wrapping_add(10);
    assert(wrap_add2 == 9);

    // Wrapping subtraction
    let wrap_sub: u8 = 0u8.wrapping_sub(1);
    assert(wrap_sub == 255);

    let wrap_sub2: u8 = 10u8.wrapping_sub(20);
    assert(wrap_sub2 == 246);

    // Wrapping multiplication
    let wrap_mul: u8 = 100u8.wrapping_mul(3);
    assert(wrap_mul == 44);  // 300 % 256

    // Wrapping negation
    let wrap_neg: i8 = i8.MIN.wrapping_neg();
    assert(wrap_neg == i8.MIN);  // -(-128) wraps to -128

    // Commented out: wrapping_abs() not yet in stdlib
    // let wrap_abs: i8 = i8.MIN.wrapping_abs();
    // assert(wrap_abs == i8.MIN);

    // Wrapping shift
    let wrap_shl: u8 = 1u8.wrapping_shl(8);
    assert(wrap_shl == 1);  // Shift wraps modulo 8

    let wrap_shr: u8 = 128u8.wrapping_shr(9);
    assert(wrap_shr == 64);  // 9 % 8 = 1, shift right by 1

    // Wrapping division
    let wrap_div: i8 = i8.MIN.wrapping_div(-1);
    assert(wrap_div == i8.MIN);  // MIN / -1 overflows

    // Commented out: wrapping_pow() not yet in stdlib
    // let wrap_pow: u8 = 10u8.wrapping_pow(3);
    // assert(wrap_pow == 232);
}

/// Test overflowing operations (return (result, did_overflow))
fn test_overflowing_operations() {
    // Overflowing addition
    let (result, overflow) = 200u8.overflowing_add(100);
    assert(result == 44);  // 300 % 256
    assert(overflow);

    let (result2, overflow2) = 100u8.overflowing_add(50);
    assert(result2 == 150);
    assert(!overflow2);

    // Overflowing subtraction
    let (sub_result, sub_overflow) = 50u8.overflowing_sub(100);
    assert(sub_result == 206);  // Wrapped
    assert(sub_overflow);

    // Overflowing multiplication
    let (mul_result, mul_overflow) = 100u8.overflowing_mul(3);
    assert(mul_result == 44);
    assert(mul_overflow);

    // Commented out: overflowing_neg()/overflowing_shl() not yet in stdlib
    // let (neg_result, neg_overflow) = i8.MIN.overflowing_neg();
    // assert(neg_result == i8.MIN);
    // assert(neg_overflow);
    // let (neg_ok, neg_no_overflow) = (-50i8).overflowing_neg();
    // assert(neg_ok == 50);
    // assert(!neg_no_overflow);
    // let (shl_result, shl_overflow) = 1u8.overflowing_shl(9);
    // assert(shl_result == 2);
    // assert(shl_overflow);

    // Use case: carry addition
    fn add_with_carry(a: u64, b: u64, carry_in: Bool) -> (u64, Bool) {
        let (sum1, overflow1) = a.overflowing_add(b);
        let (sum2, overflow2) = sum1.overflowing_add(if carry_in { 1 } else { 0 });
        (sum2, overflow1 || overflow2)
    }

    let (sum, carry) = add_with_carry(u64.MAX, 1, false);
    assert(sum == 0);
    assert(carry);
}

/// Test bitwise operations for all integer types
fn test_bitwise_operations() {
    // AND
    assert(0b1100u8 & 0b1010u8 == 0b1000);
    assert(0xFF00_u16 & 0x0FF0_u16 == 0x0F00);
    assert(0xFFFF0000_u32 & 0x0000FFFF_u32 == 0);

    // OR
    assert(0b1100u8 | 0b1010u8 == 0b1110);
    assert(0xFF00_u16 | 0x00FF_u16 == 0xFFFF);

    // XOR
    assert(0b1100u8 ^ 0b1010u8 == 0b0110);
    assert(0xFF_u8 ^ 0xFF_u8 == 0);

    // Commented out: NOT operator not supported for integer types
    // assert(!0u8 == 255);
    // assert(!0xFF_u8 == 0);
    // assert(!0i8 == -1);

    // Left shift
    assert(1u8 << 4 == 16);
    assert(1u16 << 15 == 32768);
    assert(1u32 << 31 == 2147483648);
    assert(1u64 << 63 == 9223372036854775808);

    // Right shift (logical for unsigned)
    assert(128u8 >> 3 == 16);
    assert(0x8000_u16 >> 8 == 0x80);

    // Right shift (arithmetic for signed)
    assert((-8i8) >> 2 == -2);  // Sign-extending
    assert((-128i8) >> 7 == -1);  // All 1s

    // Rotate left
    let rotl: u8 = 0b10000001u8.rotate_left(1);
    assert(rotl == 0b00000011);

    let rotl32: u32 = 0x80000001_u32.rotate_left(1);
    assert(rotl32 == 0x00000003);

    // Rotate right
    let rotr: u8 = 0b10000001u8.rotate_right(1);
    assert(rotr == 0b11000000);

    // Swap bytes
    assert(0x1234_u16.swap_bytes() == 0x3412);
    assert(0x12345678_u32.swap_bytes() == 0x78563412);

    // Reverse bits
    assert(0b10110000u8.reverse_bits() == 0b00001101);

    // From/to big-endian
    let be: u32 = u32.from_be(0x12345678);
    let le: u32 = u32.from_le(0x12345678);
    // Result depends on platform endianness

    // Power of two
    assert(16u32.is_power_of_two());
    assert(!15u32.is_power_of_two());
    assert(1u32.is_power_of_two());

    // Next power of two
    assert(5u32.next_power_of_two() == 8);
    assert(8u32.next_power_of_two() == 8);
    assert(9u32.next_power_of_two() == 16);
}

/// Test type conversions between integer types
fn test_type_conversion() {
    // Widening conversions (always safe)
    let i8_val: i8 = 100;
    let i16_val: i16 = i8_val.into();  // i8 -> i16
    let i32_val: i32 = i16_val.into();  // i16 -> i32
    let i64_val: i64 = i32_val.into();  // i32 -> i64
    assert(i64_val == 100);

    let u8_val: u8 = 200;
    let u16_val: u16 = u8_val.into();
    let u32_val: u32 = u16_val.into();
    let u64_val: u64 = u32_val.into();
    assert(u64_val == 200);

    // Narrowing conversions (may truncate)
    let big: i32 = 1000;
    let small: i8 = big as i8;  // Truncates to -24 (1000 % 256 = 232, interpreted as signed)
    assert(small == -24);

    // Try-from for safe narrowing
    let try_narrow: Result<i8, TryFromIntError> = i8.try_from(big);
    assert(try_narrow.is_err());

    // Commented out: Result type mismatch (Ok|Overflow vs Ok|Err)
    // let small_enough: i32 = 100;
    // let try_ok: Result<i8, TryFromIntError> = i8.try_from(small_enough);
    // assert(try_ok == Ok(100));

    // Signed to unsigned
    let neg: i8 = -1;
    let as_unsigned: u8 = neg as u8;  // Reinterpret bits
    assert(as_unsigned == 255);

    // Try-from fails for negative
    let try_unsigned: Result<u8, TryFromIntError> = u8.try_from(neg as i16);
    assert(try_unsigned.is_err());

    // Unsigned to signed
    let large_unsigned: u8 = 200;
    let as_signed: i8 = large_unsigned as i8;  // Reinterpret bits
    assert(as_signed == -56);

    // Float to integer
    let float_val: f64 = 3.7;
    let int_from_float: i32 = float_val as i32;  // Truncates
    assert(int_from_float == 3);

    // Integer to float
    let int_val: i64 = 1234567890;
    let float_from_int: f64 = int_val as f64;
    assert((float_from_int - 1234567890.0).abs() < 1.0);
}

