// @test: typecheck-pass
// @tier: 0
// @level: L2
// @tags: stdlib, numeric, int, arbitrary-precision

/// Comprehensive test suite for Int (arbitrary precision integer) operations.
/// Int represents integers of unlimited size (BigInt semantics).
/// Tests arithmetic, comparison, bitwise operations, and conversions.

fn main() {
    test_int_creation();
    test_int_arithmetic();
    test_int_comparison();
    test_int_bitwise();
    test_int_division();
    test_int_conversion();
    test_int_parsing();
    test_int_large_numbers();
    test_int_mathematical_operations();
    test_int_iteration();
}

/// Test Int creation and literals
fn test_int_creation() {
    // Simple literals
    let zero: Int = 0;
    let positive: Int = 42;
    let negative: Int = -100;

    assert(zero == 0);
    assert(positive == 42);
    assert(negative == -100);

    // Different bases
    let decimal: Int = 255;
    let hex: Int = 0xFF;
    let octal: Int = 0o377;
    let binary: Int = 0b11111111;

    assert(decimal == hex);
    assert(hex == octal);
    assert(octal == binary);

    // Underscores for readability
    let million: Int = 1_000_000;
    let billion: Int = 1_000_000_000;
    let binary_with_sep: Int = 0b1111_0000_1111_0000;

    assert(million == 1000000);
    assert(billion == 1000000000);

    // Commented out: Int.new() not found (literal type issue)
    // let from_new: Int = Int.new();
    // assert(from_new == 0);

    // Commented out: Int.from() returns literal type, not Int
    // let from_i32: Int = Int.from(42i32);
    // let from_i64: Int = Int.from(-9223372036854775808i64);
    // let from_u64: Int = Int.from(18446744073709551615u64);

    // Clone
    let original: Int = 12345;
    let cloned: Int = original.clone();
    assert(cloned == original);

    // Default (zero)
    let default: Int = Int.default();
    assert(default == 0);
}

/// Test arithmetic operations
fn test_int_arithmetic() {
    let a: Int = 100;
    let b: Int = 30;

    // Addition
    let sum: Int = a + b;
    assert(sum == 130);

    // Subtraction
    let diff: Int = a - b;
    assert(diff == 70);

    // Multiplication
    let product: Int = a * b;
    assert(product == 3000);

    // Division (truncates toward zero)
    let quotient: Int = a / b;
    assert(quotient == 3);

    // Remainder
    let remainder: Int = a % b;
    assert(remainder == 10);

    // Negation
    let neg_a: Int = -a;
    assert(neg_a == -100);

    // Exponentiation
    let power: Int = 2 ** 10;
    assert(power == 1024);

    let cube: Int = 3 ** 3;
    assert(cube == 27);

    // Compound assignment
    let mut x: Int = 10;
    x += 5;
    assert(x == 15);
    x -= 3;
    assert(x == 12);
    x *= 2;
    assert(x == 24);
    x /= 4;
    assert(x == 6);
    x %= 4;
    assert(x == 2);

    // Chained operations
    let result: Int = 2 + 3 * 4 - 6 / 2;  // = 2 + 12 - 3 = 11
    assert(result == 11);

    // Operations with negative numbers
    let neg_sum: Int = -10 + 5;
    assert(neg_sum == -5);

    let neg_product: Int = -3 * 4;
    assert(neg_product == -12);

    let neg_div: Int = -10 / 3;
    assert(neg_div == -3);  // Truncates toward zero

    // Absolute value
    let abs_neg: Int = (-42).abs();
    let abs_pos: Int = 42.abs();
    assert(abs_neg == 42);
    assert(abs_pos == 42);

    // Sign
    let sign_pos: Int = 42.signum();
    let sign_neg: Int = (-42).signum();
    let sign_zero: Int = 0.signum();
    assert(sign_pos == 1);
    assert(sign_neg == -1);
    assert(sign_zero == 0);
}

/// Test comparison operations
fn test_int_comparison() {
    let a: Int = 100;
    let b: Int = 50;
    let c: Int = 100;

    // Equality
    assert(a == c);
    assert(a != b);

    // Ordering
    assert(a > b);
    assert(b < a);
    assert(a >= c);
    assert(a <= c);

    // Comparison method
    let cmp_result: Ordering = a.cmp(&b);
    assert(cmp_result == Ordering.Greater);

    // Compare with zero
    assert(100 > 0);
    assert(-100 < 0);
    assert(0 == 0);

    // Min and max
    let min_val: Int = a.min(b);
    let max_val: Int = a.max(b);
    assert(min_val == 50);
    assert(max_val == 100);

    // Clamp
    let clamped: Int = 150.clamp(0, 100);
    assert(clamped == 100);

    let clamped_low: Int = (-50).clamp(0, 100);
    assert(clamped_low == 0);

    let clamped_in: Int = 50.clamp(0, 100);
    assert(clamped_in == 50);

    // Is positive/negative/zero
    assert(42.is_positive());
    assert((-42).is_negative());
    assert(!0.is_positive());
    assert(!0.is_negative());
}

/// Test bitwise operations
fn test_int_bitwise() {
    // AND
    let and_result: Int = 0b1100 & 0b1010;
    assert(and_result == 0b1000);

    // OR
    let or_result: Int = 0b1100 | 0b1010;
    assert(or_result == 0b1110);

    // XOR
    let xor_result: Int = 0b1100 ^ 0b1010;
    assert(xor_result == 0b0110);

    // NOT (two's complement)
    let not_result: Int = !0;
    assert(not_result == -1);

    // Left shift
    let left_shift: Int = 1 << 4;
    assert(left_shift == 16);

    let shift_val: Int = 5 << 3;
    assert(shift_val == 40);

    // Right shift (arithmetic for signed)
    let right_shift: Int = 16 >> 2;
    assert(right_shift == 4);

    let neg_shift: Int = -16 >> 2;
    assert(neg_shift == -4);  // Sign-extending

    // Compound assignment
    let mut x: Int = 0b1111;
    x &= 0b1010;
    assert(x == 0b1010);

    x |= 0b0101;
    assert(x == 0b1111);

    x ^= 0b1111;
    assert(x == 0);

    x = 1;
    x <<= 4;
    assert(x == 16);

    x >>= 2;
    assert(x == 4);

    // Count ones (popcount)
    let ones: u32 = 0b10110111.count_ones();
    assert(ones == 6);

    // Count zeros
    let zeros: u32 = 0b10110111.count_zeros();
    // Depends on bit width

    // Leading/trailing zeros
    let leading: u32 = 0b00001000.leading_zeros();
    let trailing: u32 = 0b00001000.trailing_zeros();
    assert(trailing == 3);

    // Power of two check
    fn is_power_of_two(n: Int) -> Bool {
        n > 0 && (n & (n - 1)) == 0
    }
    assert(is_power_of_two(16));
    assert(is_power_of_two(1));
    assert(!is_power_of_two(15));
}

/// Test division operations in detail
fn test_int_division() {
    // Euclidean division
    let a: Int = 17;
    let b: Int = 5;

    let div: Int = a / b;
    let rem: Int = a % b;
    assert(div == 3);
    assert(rem == 2);
    assert(a == div * b + rem);

    // Negative dividend
    let neg_a: Int = -17;
    let div_neg: Int = neg_a / b;
    let rem_neg: Int = neg_a % b;
    assert(neg_a == div_neg * b + rem_neg);
    // div_neg = -3 or -4 depending on convention

    // div_euclid and rem_euclid (always non-negative remainder)
    let euclid_div: Int = neg_a.div_euclid(b);
    let euclid_rem: Int = neg_a.rem_euclid(b);
    assert(euclid_rem >= 0);
    assert(euclid_rem < b.abs());
    assert(neg_a == euclid_div * b + euclid_rem);

    // Division by larger number
    let small: Int = 3;
    let large: Int = 10;
    assert(small / large == 0);
    assert(small % large == 3);

    // Division of zero
    let zero: Int = 0;
    assert(zero / 5 == 0);
    assert(zero % 5 == 0);

    // Divides evenly
    fn divides(a: Int, b: Int) -> Bool {
        b != 0 && a % b == 0
    }
    assert(divides(10, 5));
    assert(divides(10, 2));
    assert(!divides(10, 3));

    // GCD (Greatest Common Divisor)
    fn gcd(a: Int, b: Int) -> Int {
        let mut a = a.abs();
        let mut b = b.abs();
        while b != 0 {
            let t = b;
            b = a % b;
            a = t;
        }
        a
    }
    assert(gcd(48, 18) == 6);
    assert(gcd(17, 13) == 1);

    // LCM (Least Common Multiple)
    fn lcm(a: Int, b: Int) -> Int {
        (a * b).abs() / gcd(a, b)
    }
    assert(lcm(4, 6) == 12);
    assert(lcm(3, 5) == 15);
}

/// Test type conversions
fn test_int_conversion() {
    let big: Int = 1234567890;

    // To fixed-size integers (may fail)
    let to_i32: Result<i32, TryFromIntError> = big.try_into();
    assert(to_i32.is_ok());

    let too_big: Int = 9999999999999999999999;
    let fail_i64: Result<i64, TryFromIntError> = too_big.try_into();
    assert(fail_i64.is_err());

    // To float
    let as_f64: f64 = big.to_f64();
    assert((as_f64 - 1234567890.0).abs() < 1.0);

    // To unsigned (may fail for negative)
    let positive: Int = 100;
    let to_u64: Result<u64, TryFromIntError> = positive.try_into();
    assert(to_u64.is_ok());

    let negative: Int = -100;
    let neg_to_u64: Result<u64, TryFromIntError> = negative.try_into();
    assert(neg_to_u64.is_err());

    // To bytes (little-endian)
    let bytes: List<u8> = big.to_le_bytes();

    // From bytes
    let from_bytes: Int = Int.from_le_bytes(&bytes);
    assert(from_bytes == big);

    // To signed bytes (two's complement)
    let signed_bytes: List<u8> = big.to_signed_bytes_le();

    // To hex string
    let hex_str: Text = format("{:x}", big);
    assert(hex_str == "499602d2");

    // To binary string
    let bin_str: Text = format("{:b}", 42);
    assert(bin_str == "101010");

    // To octal string
    let oct_str: Text = format("{:o}", 64);
    assert(oct_str == "100");
}

