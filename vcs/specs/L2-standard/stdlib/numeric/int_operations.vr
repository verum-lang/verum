/// Test operations with large numbers
fn test_int_large_numbers() {
    // Very large numbers (arbitrary precision)
    let huge: Int = 9999999999999999999999999999999999999999;
    let also_huge: Int = 1111111111111111111111111111111111111111;

    // Arithmetic works with any size
    let sum: Int = huge + also_huge;
    let diff: Int = huge - also_huge;
    let product: Int = huge * 2;

    // Division
    let quotient: Int = huge / also_huge;
    assert(quotient == 9);

    // Factorial (grows quickly)
    fn factorial(n: Int) -> Int {
        if n <= 1 { 1 } else { n * factorial(n - 1) }
    }

    let fact_20: Int = factorial(20);
    assert(fact_20 == 2432902008176640000);

    let fact_50: Int = factorial(50);
    // fact_50 is a 65-digit number
    assert(fact_50 > 0);

    // Fibonacci (also grows)
    fn fibonacci(n: Int) -> Int {
        if n <= 1 { n } else { fibonacci(n - 1) + fibonacci(n - 2) }
    }

    // Iterative version for large n
    fn fib_iter(n: Int) -> Int {
        if n <= 1 { return n; }
        let mut a: Int = 0;
        let mut b: Int = 1;
        for _ in 2..=n {
            let temp = a + b;
            a = b;
            b = temp;
        }
        b
    }

    let fib_100: Int = fib_iter(100);
    // fib_100 = 354224848179261915075

    // Power of large base
    let power: Int = 2 ** 100;
    // 2^100 is a 31-digit number

    // Large modular arithmetic
    let big_mod: Int = huge % 1000000007;

    // Bit length
    let bit_len: usize = huge.bits();

    // Number of digits
    fn digit_count(n: Int) -> usize {
        if n == 0 { 1 } else { n.abs().to_text().len() }
    }
    assert(digit_count(12345) == 5);
    assert(digit_count(huge) > 30);
}

/// Test mathematical operations
fn test_int_mathematical_operations() {
    // Square root (integer)
    fn isqrt(n: Int) -> Int {
        if n < 0 { panic("negative sqrt"); }
        if n == 0 { return 0; }

        let mut x: Int = n;
        let mut y: Int = (x + 1) / 2;
        while y < x {
            x = y;
            y = (x + n / x) / 2;
        }
        x
    }
    assert(isqrt(16) == 4);
    assert(isqrt(17) == 4);
    assert(isqrt(100) == 10);

    // Is perfect square
    fn is_perfect_square(n: Int) -> Bool {
        if n < 0 { return false; }
        let sqrt = isqrt(n);
        sqrt * sqrt == n
    }
    assert(is_perfect_square(16));
    assert(!is_perfect_square(17));

    // Power with modulo (modular exponentiation)
    fn pow_mod(base: Int, exp: Int, modulus: Int) -> Int {
        if modulus == 1 { return 0; }
        let mut result: Int = 1;
        let mut base = base % modulus;
        let mut exp = exp;
        while exp > 0 {
            if exp % 2 == 1 {
                result = (result * base) % modulus;
            }
            exp = exp / 2;
            base = (base * base) % modulus;
        }
        result
    }
    assert(pow_mod(2, 10, 1000) == 24);  // 1024 % 1000

    // Primality test (simple)
    fn is_prime(n: Int) -> Bool {
        if n < 2 { return false; }
        if n == 2 { return true; }
        if n % 2 == 0 { return false; }

        let sqrt_n = isqrt(n);
        let mut i: Int = 3;
        while i <= sqrt_n {
            if n % i == 0 { return false; }
            i += 2;
        }
        true
    }
    assert(is_prime(2));
    assert(is_prime(17));
    assert(!is_prime(15));
    assert(is_prime(104729));

    // Extended Euclidean algorithm
    fn extended_gcd(a: Int, b: Int) -> (Int, Int, Int) {
        // Returns (gcd, x, y) such that a*x + b*y = gcd
        if b == 0 {
            (a, 1, 0)
        } else {
            let (g, x, y) = extended_gcd(b, a % b);
            (g, y, x - (a / b) * y)
        }
    }

    let (g, x, y) = extended_gcd(48, 18);
    assert(g == 6);
    assert(48 * x + 18 * y == 6);

    // Modular inverse
    fn mod_inverse(a: Int, m: Int) -> Maybe<Int> {
        let (g, x, _) = extended_gcd(a, m);
        if g != 1 {
            None
        } else {
            Some(((x % m) + m) % m)
        }
    }
    assert(mod_inverse(3, 7) == Some(5));  // 3 * 5 = 15 = 1 (mod 7)
}

/// Test iteration with Int
fn test_int_iteration() {
    // Range iteration
    let mut sum: Int = 0;
    for i in 0..10 {
        sum += i;
    }
    assert(sum == 45);

    // Inclusive range
    let mut product: Int = 1;
    for i in 1..=5 {
        product *= i;
    }
    assert(product == 120);

    // Countdown
    let mut countdown: List<Int> = List.new();
    for i in (0..5).rev() {
        countdown.push(i);
    }
    assert(countdown == [4, 3, 2, 1, 0]);

    // Step by
    let evens: List<Int> = (0..10).step_by(2).collect();
    assert(evens == [0, 2, 4, 6, 8]);

    // Filter and map
    let squares: List<Int> = (1..=10)
        .filter(|n| n % 2 == 0)
        .map(|n| n * n)
        .collect();
    assert(squares == [4, 16, 36, 64, 100]);

    // Sum and product with iterators
    let iter_sum: Int = (1..=100).sum();
    assert(iter_sum == 5050);

    let iter_product: Int = (1..=10).product();
    assert(iter_product == 3628800);

    // Fold
    let fold_sum: Int = (1..=5).fold(0, |acc, x| acc + x);
    assert(fold_sum == 15);

    // Find
    let first_over_50: Maybe<Int> = (1..).map(|n| n * n).find(|n| *n > 50);
    assert(first_over_50 == Some(64));

    // Take while
    let small: List<Int> = (1..).take_while(|n| *n < 10).collect();
    assert(small == [1, 2, 3, 4, 5, 6, 7, 8, 9]);
}
