// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: owl2, owl2-fs, export, vuva, phase-3, b5
// @timeout: 5000
// @expect: pass
//
// VVA §21.8 Phase 3 B5 — verum export --to owl2-fs smoke.
//
// Exercises every Owl2*Attr that the OWL 2 Functional-Syntax emitter
// consumes, ensuring the source declarations type-check. The CLI smoke
// (project walk, OFN emission, Pellet/HermiT compatibility) runs E2E
// against /tmp synthetic projects.

@owl2_class
public type Animal is { name: Text }

@owl2_class
@owl2_subclass_of(Animal)
public type Mammal is { name: Text }

@owl2_class
@owl2_subclass_of(Mammal)
public type Person is { name: Text }

@owl2_class
@owl2_disjoint_with([Mammal])
public type Mineral is { name: Text }

@owl2_class
@owl2_equivalent_class(HumanBeing)
public type Person2 is { name: Text }

@owl2_class
public type HumanBeing is { name: Text }

@owl2_class
@owl2_has_key(ssn, dob)
public type Citizen is { ssn: Text, dob: Text }

@owl2_property(domain = Person, range = Person, characteristic = [Symmetric, Transitive], inverse_of = knownBy)
public fn knows(a: Person, b: Person) -> Bool { true }

@owl2_property(domain = Person, range = Person)
public fn knownBy(a: Person, b: Person) -> Bool { true }

@owl2_characteristic("Functional")
public fn ssn_of(p: Citizen) -> Text { "" }

fn main() {
    print("owl2-fs export smoke ok");
}
