// @test: typecheck-fail
// @tier: 0
// @level: L1
// @tags: types, generics, bounds, errors
// @expected-error: E400

/// Test for generic bound error detection.
/// Verifies that the type checker rejects incompatible types.

type Label is { text: Text };
type Counter is { value: Int };

fn takes_counter(c: Counter) -> Int {
    c.value
}

fn main() {
    let l = Label { text: "hello" };
    // ERROR E400: Type mismatch - Label is not Counter
    let result = takes_counter(l);
}
