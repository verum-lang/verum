// @test: typecheck-pass
// @level: L1
// @tags: types, inference, quantifiers, forall, exists, domain
// @description: Comprehensive type inference tests for quantifier expressions

// ============================================================================
// Section 1: Basic Type-Annotated Quantifiers
// ============================================================================

/// Basic forall with explicit type annotation
fn test_forall_explicit_type() {
    // Type annotation provides the binding type
    let pred: Bool = forall x: Int . x + 1 > x;
    let pred2: Bool = forall a: Float . a * 1.0 == a;
    let pred3: Bool = forall b: Bool . b || !b;
}

/// Basic exists with explicit type annotation
fn test_exists_explicit_type() {
    let has_zero: Bool = exists x: Int . x == 0;
    let has_unit: Bool = exists f: Float . f * f == 1.0;
    let has_true: Bool = exists b: Bool . b == true;
}

/// Multiple bindings with type annotations
fn test_multiple_bindings_typed() {
    let commutativity: Bool = forall a: Int, b: Int . a + b == b + a;
    let associativity: Bool = forall x: Int, y: Int, z: Int . (x + y) + z == x + (y + z);
    let pair_exists: Bool = exists a: Int, b: Int . a + b == 0;
}

// ============================================================================
// Section 2: Domain-Based Type Inference (forall x in collection)
// ============================================================================

/// Type inferred from List<T> domain
fn test_domain_inference_list(numbers: List<Int>, strings: List<Text>) {
    // x: Int is inferred from List<Int>
    let all_positive: Bool = forall x in numbers . x > 0;
    let has_even: Bool = exists x in numbers . x % 2 == 0;

    // s: Text is inferred from List<Text>
    let all_non_empty: Bool = forall s in strings . s.len() > 0;
}

/// Type inferred from Range<T> domain
fn test_domain_inference_range() {
    // i: Int is inferred from Range<Int>
    let bounded: Bool = forall i in 1..100 . i >= 1 && i < 100;
    let has_fifty: Bool = exists i in 1..100 . i == 50;
}

/// Type inferred from array domain
fn test_domain_inference_array() {
    let arr: [Float; 3] = [1.0, 2.0, 3.0];
    // f: Float is inferred from [Float; 3]
    let all_positive: Bool = forall f in arr . f > 0.0;
}

/// Type inferred from slice domain
fn test_domain_inference_slice(slice: &[Int]) {
    // n: Int is inferred from &[Int]
    let all_non_negative: Bool = forall n in slice . n >= 0;
}

// ============================================================================
// Section 3: Combined Type Annotation with Domain
// ============================================================================

/// Explicit type with domain constraint
fn test_typed_with_domain(numbers: List<Int>) {
    // Both type annotation and domain
    let pred: Bool = forall x: Int in numbers . x > 0;

    // Type annotation can be more general or specialized (subtyping)
    let bounded: Bool = forall n: Int in 0..10 . n < 100;
}

// ============================================================================
// Section 4: Guard (where) Clause Type Checking
// ============================================================================

/// Guard must be Bool type
fn test_guard_boolean_type() {
    // Guard expression must evaluate to Bool
    let filtered: Bool = forall x: Int where x > 0 . x >= 1;
    // Using simpler guard without modulo to avoid precedence issues
    let conditional: Bool = exists n: Int where n >= 0 . n > 0;
}

/// Complex guard expressions
fn test_guard_complex(numbers: List<Int>) {
    // Compound guard with && - use parentheses to clarify precedence
    let pred1: Bool = forall x in numbers where (x > 0) && (x < 100) . x < 10000;

    // Guard with function call
    let pred2: Bool = forall n: Int where is_valid(n) . process(n) > 0;
}

fn is_valid(n: Int) -> Bool { n >= 0 }
fn process(n: Int) -> Int { n * 2 }

// ============================================================================
// Section 5: Body Expression Type Checking
// ============================================================================

/// Body must be Bool type
fn test_body_boolean_type() {
    // Direct comparison (Bool)
    let p1: Bool = forall x: Int . x == x;

    // Logical operations (Bool)
    let p2: Bool = forall a: Bool . a || !a;

    // Relational operators (Bool)
    let p3: Bool = forall x: Int, y: Int . x <= y || x > y;

    // Function returning Bool
    let p4: Bool = forall x: Int . check(x);
}

fn check(x: Int) -> Bool { x >= 0 }

/// Complex body expressions
fn test_body_complex(items: List<Int>) {
    // Implication pattern: !(A) || B
    let impl_pattern: Bool = forall x in items . !(x > 0) || x >= 1;

    // Nested quantifier in body
    let nested: Bool = forall x: Int . exists y: Int . y > x;

    // Method call in body
    let method_in_body: Bool = forall s: Text . s.is_empty() || s.len() > 0;
}

// ============================================================================
// Section 6: Quantifier Result Type
// ============================================================================

/// Quantifiers always return Bool
fn test_result_type_bool() {
    // Direct assignment shows type
    let b1: Bool = forall x: Int . x == x;
    let b2: Bool = exists x: Int . x == 0;

    // In boolean context
    let combined: Bool = (forall x: Int . x >= x) && (exists y: Int . y > 0);

    // As function return value
    let result = always_true();
}

fn always_true() -> Bool {
    forall x: Int . x == x
}

// ============================================================================
// Section 7: Nested Quantifiers
// ============================================================================

/// Deeply nested quantifiers
fn test_nested_quantifiers() {
    // Forall containing exists
    let surjection: Bool = forall y: Int . exists x: Int . double(x) == y;

    // Exists containing forall
    let identity_exists: Bool = exists e: Int . forall x: Int . x + e == x;

    // Triple nesting
    let transitive: Bool = forall a: Int . forall b: Int . forall c: Int .
        !(a < b && b < c) || a < c;
}

fn double(x: Int) -> Int { x * 2 }

// ============================================================================
// Section 8: Generic Context
// ============================================================================

/// Quantifiers over generic collections
fn test_generic_domain<T: Eq>(items: List<T>, target: T) -> Bool {
    // Type parameter T flows through
    exists x in items . x == target
}

/// Generic function with quantifier
fn all_satisfy<T>(items: List<T>, predicate: fn(T) -> Bool) -> Bool {
    forall x in items . predicate(x)
}

/// Quantifier with generic bounds
fn test_generic_bounds<T: Ord>(list: List<T>) -> Bool {
    forall a in list . forall b in list . a <= b || a > b
}

// ============================================================================
// Section 9: Scoping Verification
// ============================================================================

/// Bound variables are scoped to quantifier
fn test_scoping() {
    let x: Int = 10;  // Outer x

    // Inner x shadows outer in quantifier body
    let pred: Bool = forall x: Int . x >= 0 || x < 0;

    // Outer x still accessible after quantifier
    let outer_x_still_valid: Int = x + 1;

    // Multiple scopes don't interfere
    let p1: Bool = forall a: Int . a == a;
    let p2: Bool = forall a: Float . a == a;  // Different 'a', different type
}

/// Guard and body share scope
fn test_guard_body_scope() {
    // x is visible in both guard and body
    let pred: Bool = forall x: Int where x > 0 . x >= 1;

    // Multiple bindings share scope with each other
    let pred2: Bool = forall a: Int, b: Int where a < b . a != b;
}

// ============================================================================
// Section 10: Edge Cases
// ============================================================================

/// Empty domain quantifiers
fn test_empty_domain(empty: List<Int>) {
    // forall over empty set is vacuously true
    let vacuous: Bool = forall x in empty . x > 0;
    // exists over empty set is false
    let impossible: Bool = exists x in empty . x > 0;
}

/// Single-element domain
fn test_singleton_domain(single: List<Int>) {
    let all_42: Bool = forall x in single . x == 42;
    let has_42: Bool = exists x in single . x == 42;
}

/// Quantifier with slice domain
fn test_slice_domain(data: List<Int>) {
    // Domain is a slice - commented out as slice syntax may need verification
    // let slice_pred: Bool = forall x in data[1..3] . x > 0;

    // Simple domain with range
    let range_pred: Bool = forall i in 0..100 . i >= 0;
}

fn main() {
    // Type inference tests execute successfully
    print("Quantifier type inference tests passed");
}
