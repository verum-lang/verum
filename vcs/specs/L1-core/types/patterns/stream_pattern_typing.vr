// @test: typecheck-pass
// @level: L1
// @tags: types, patterns, stream, iterator, type-inference
// @description: Stream pattern type checking and inference

module tests.types.patterns.stream_typing;

mount core.*;

// =============================================================================
// Section 1: Basic Stream Pattern Type Inference
// =============================================================================

// Stream pattern infers element type from iterator
fn test_stream_type_inference<I: Iterator<Item = Int>>(iter: I) -> Int {
    match iter {
        stream[] => 0,
        stream[first, ...rest] => first,  // first: Int inferred
    }
}

// Stream pattern with explicit generic
fn test_generic_stream<T, I: Iterator<Item = T>>(iter: I) -> Maybe<T> {
    match iter {
        stream[] => Maybe.None,
        stream[head, ...] => Maybe.Some(head),
    }
}

// Stream pattern preserves iterator type in rest
fn test_rest_iterator_type<I: Iterator<Item = Int>>(iter: I) -> Int {
    match iter {
        stream[] => 0,
        stream[first, ...rest] => {
            // rest should be same iterator type I (or a derived type)
            let sum = rest.fold(first, |acc, x| acc + x);
            sum
        }
    }
}

// =============================================================================
// Section 2: Stream Pattern with Nested Types
// =============================================================================

type Pair<A, B> is { first: A, second: B };

fn test_stream_of_pairs<I: Iterator<Item = Pair<Int, Text>>>(iter: I) -> Text {
    match iter {
        stream[] => "empty",
        stream[Pair { first, second }, ...] => f"first pair: {first}, {second}",
    }
}

type Result<T, E> is Ok(T) | Err(E);

fn test_stream_of_results<I: Iterator<Item = Result<Int, Text>>>(iter: I) -> Int {
    match iter {
        stream[] => 0,
        stream[Ok(n), ...rest] => n + test_stream_of_results(rest),
        stream[Err(_), ...rest] => test_stream_of_results(rest),  // Skip errors
    }
}

// =============================================================================
// Section 3: Stream Pattern with Multiple Head Elements
// =============================================================================

fn test_two_head_elements<I: Iterator<Item = Int>>(iter: I) -> Maybe<(Int, Int)> {
    match iter {
        stream[] => Maybe.None,
        stream[only] => Maybe.None,  // Single element, no pair
        stream[a, b, ...] => Maybe.Some((a, b)),
    }
}

fn test_three_head_elements<I: Iterator<Item = Text>>(iter: I) -> Text {
    match iter {
        stream[a, b, c, ...] => f"{a}-{b}-{c}",
        stream[a, b] => f"{a}-{b}",
        stream[a] => a,
        stream[] => "",
    }
}

// =============================================================================
// Section 4: Stream Pattern Type Coercion
// =============================================================================

// Numeric widening in stream patterns (if supported)
fn test_stream_numeric_coercion<I: Iterator<Item = Int>>(iter: I) -> Float {
    match iter {
        stream[] => 0.0,
        stream[n, ...] => n.to_float(),  // Explicit conversion
    }
}

// =============================================================================
// Section 5: Stream Pattern with Guards and Types
// =============================================================================

fn test_stream_guard_types<I: Iterator<Item = Int>>(iter: I) -> Text {
    match iter {
        stream[] => "empty",
        stream[n, ...] if n > 0 => "positive start",  // n: Int in guard
        stream[n, ...] if n < 0 => "negative start",
        stream[n, ...] => "zero start",
    }
}

fn test_stream_guard_with_rest<I: Iterator<Item = Int>>(iter: I) -> Text {
    match iter {
        stream[a, b, ...rest] if a + b > 10 => {
            let rest_sum = rest.fold(0, |acc, x| acc + x);
            f"sum with rest: {a + b + rest_sum}"
        }
        stream[a, b, ...] => f"small start: {a + b}",
        stream[_] => "single",
        stream[] => "empty",
    }
}

// =============================================================================
// Section 6: Stream Pattern Exhaustiveness with Types
// =============================================================================

type Color is Red | Green | Blue;

fn test_stream_variant_exhaustive<I: Iterator<Item = Color>>(iter: I) -> Text {
    match iter {
        stream[] => "no colors",
        stream[Red, ...] => "starts with red",
        stream[Green, ...] => "starts with green",
        stream[Blue, ...] => "starts with blue",
    }
}

// Non-exhaustive should produce warning (compile-time diagnostic)
fn test_stream_partial_match<I: Iterator<Item = Color>>(iter: I) -> Maybe<Text> {
    match iter {
        stream[Red, Green, ...] => Maybe.Some("red-green pattern"),
        stream[Blue, ...] => Maybe.Some("blue start"),
        _ => Maybe.None,
    }
}

// =============================================================================
// Section 7: Stream Pattern with Protocol Bounds
// =============================================================================

type Comparable is protocol {
    fn compare(&self, other: &Self) -> Int;
};

fn test_stream_protocol_bound<T: Comparable, I: Iterator<Item = T>>(iter: I) -> Bool {
    match iter {
        stream[] => true,
        stream[only] => true,
        stream[a, b, ...rest] => {
            if a.compare(&b) <= 0 {
                // Create new iterator with b as first element
                test_stream_protocol_bound(once(b).chain(rest))
            } else {
                false
            }
        }
    }
}

// =============================================================================
// Section 8: Stream Pattern with Associated Types
// =============================================================================

type Collection<T> is protocol {
    type Iter: Iterator<Item = T>;
    fn iter(&self) -> Self.Iter;
};

fn test_stream_associated_type<C: Collection<Int>>(col: C) -> Int {
    match col.iter() {
        stream[] => 0,
        stream[first, ...rest] => first + rest.fold(0, |a, x| a + x),
    }
}

