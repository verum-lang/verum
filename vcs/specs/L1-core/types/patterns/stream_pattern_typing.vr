// =============================================================================
// Section 10: Advanced Stream Pattern Scenarios
// =============================================================================

// Recursive stream processing with type preservation
fn sum_stream<I: Iterator<Item = Int>>(iter: I) -> Int {
    match iter {
        stream[] => 0,
        stream[n, ...rest] => n + sum_stream(rest),
    }
}

// Stream pattern with transformation
fn transform_stream<T, U, I: Iterator<Item = T>>(
    iter: I,
    f: fn(T) -> U
) -> List<U> {
    match iter {
        stream[] => [],
        stream[head, ...rest] => {
            let mut result = [f(head)];
            result.extend(transform_stream(rest, f));
            result
        }
    }
}

// Stream pattern in closure
fn test_stream_in_closure() -> fn(List<Int>) -> Int {
    |list| {
        match list.iter() {
            stream[] => 0,
            stream[n, ...rest] => n + rest.fold(0, |a, x| a + x),
        }
    }
}

// =============================================================================
// Main Test Function
// =============================================================================

fn main() {
    // Test type inference
    let iter1 = [1, 2, 3, 4, 5].iter();
    assert_eq(test_stream_type_inference(iter1), 1);

    // Test generic stream
    let iter2 = [10, 20, 30].iter();
    assert_eq(test_generic_stream(iter2), Maybe.Some(10));

    // Test two head elements
    let iter3 = [5, 10, 15].iter();
    assert_eq(test_two_head_elements(iter3), Maybe.Some((5, 10)));

    // Test sum via stream recursion
    let iter4 = [1, 2, 3, 4, 5].iter();
    assert_eq(sum_stream(iter4), 15);

    // Test transformation
    let iter5 = [1, 2, 3].iter();
    let doubled = transform_stream(iter5, |x| x * 2);
    assert_eq(doubled, [2, 4, 6]);

    // Test closure with stream
    let sum_fn = test_stream_in_closure();
    assert_eq(sum_fn([10, 20, 30]), 60);

    print("All stream pattern typing tests passed!");
}
