// =============================================================================
// TEST 5: Generic Builder
// =============================================================================

@builder
type Container<T> is {
    value: T,
    label: Text = "default",
};

fn test_generic_builder() {
    let int_container = Container.builder()
        .value(42)
        .label("int")
        .build();

    assert_eq(int_container.value, 42);
    assert_eq(int_container.label, "int");

    let text_container = Container.builder()
        .value("hello")
        .build();

    assert_eq(text_container.value, "hello");
    assert_eq(text_container.label, "default");
}

// =============================================================================
// TEST 6: Builder with CBGR References
// =============================================================================

@builder
type DataProcessor is {
    name: Text,
    buffer_size: Int = 1024,
    enable_compression: Bool = false,
};

fn test_builder_cbgr_safety() {
    // Builder creates owned values, no reference issues
    let processor = DataProcessor.builder()
        .name("main_processor")
        .buffer_size(4096)
        .enable_compression(true)
        .build();

    // processor is fully owned, can be moved/used freely
    assert_eq(processor.name, "main_processor");
    assert_eq(processor.buffer_size, 4096);
    assert(processor.enable_compression);
}

// =============================================================================
// Main test runner
// =============================================================================

fn main() {
    test_builder_all_fields();
    test_builder_defaults();
    test_builder_chaining();
    test_builder_complex_types();
    // test_builder_missing_required_field_panics(); // Commented - would panic
    test_generic_builder();
    test_builder_cbgr_safety();

    print("All builder derive tests passed!");
}
