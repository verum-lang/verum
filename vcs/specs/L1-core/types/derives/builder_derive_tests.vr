// @test: unit
// @tier: 1
// @level: L1
// @tags: derives, builder, type-system
// @timeout: 10000
// @expect: pass
//
// Tests for @builder derive macro.
// Spec: docs/improvements.md Section 10 - Builder Pattern as First-Class Feature

// =============================================================================
// TEST 1: Basic Builder with Required and Optional Fields
// =============================================================================

@builder
type HttpRequest is {
    method: Text,                           // Required (no default)
    url: Text,                              // Required (no default)
    headers: Map<Text, Text> = Map.new(),   // Optional with default
    timeout: Int = 30,                      // Optional with default
};

// Test: Builder should allow setting all fields
fn test_builder_all_fields() {
    let request = HttpRequest.builder()
        .method("GET")
        .url("https://example.com")
        .headers(Map.from([("Accept", "application/json")]))
        .timeout(60)
        .build();

    assert_eq(request.method, "GET");
    assert_eq(request.url, "https://example.com");
    assert_eq(request.timeout, 60);
}

// Test: Builder should use defaults for optional fields
fn test_builder_defaults() {
    let request = HttpRequest.builder()
        .method("POST")
        .url("https://api.example.com")
        .build();

    assert_eq(request.method, "POST");
    assert_eq(request.url, "https://api.example.com");
    assert_eq(request.timeout, 30);  // Default value
}

// =============================================================================
// TEST 2: Fluent Chaining
// =============================================================================

@builder
type Config is {
    name: Text,
    debug: Bool = false,
    log_level: Text = "info",
    max_connections: Int = 100,
};

fn test_builder_chaining() {
    // Builder methods should be chainable in any order
    let config = Config.builder()
        .max_connections(200)
        .name("production")
        .debug(true)
        .log_level("debug")
        .build();

    assert_eq(config.name, "production");
    assert_eq(config.debug, true);
    assert_eq(config.log_level, "debug");
    assert_eq(config.max_connections, 200);
}

// =============================================================================
// TEST 3: Builder with Complex Types
// =============================================================================

type DatabaseConfig is {
    host: Text,
    port: Int,
};

@builder
type AppConfig is {
    app_name: Text,
    db_config: DatabaseConfig,
    features: List<Text> = List.new(),
};

fn test_builder_complex_types() {
    let db = DatabaseConfig { host: "localhost", port: 5432 };

    let config = AppConfig.builder()
        .app_name("my_app")
        .db_config(db)
        .features(List.from(["auth", "cache"]))
        .build();

    assert_eq(config.app_name, "my_app");
    assert_eq(config.db_config.host, "localhost");
    assert_eq(config.db_config.port, 5432);
    assert_eq(config.features.len(), 2);
}

