// @test: typecheck-pass
// @tier: all
// @level: L1
// @tags: types, properties, computational, pure, io, async, fallible, mutates, inference
// @description: Test computational property inference for functions and expressions

/// Tests for computational property inference system.
/// Computational properties track compile-time side effects and runtime behavior.
/// Unlike algebraic effects (which Verum rejects), these are zero-cost annotations.
/// Spec: docs/detailed/03-type-system.md Section 10.2
/// Grammar: grammar/verum.ebnf Section 2.4 - function_modifiers

// ============================================================================
// ERROR AND CONTEXT TYPES FOR TESTING
// ============================================================================

type IoError is
    | NotFound(Text)
    | PermissionDenied(Text)
    | Timeout;

type NetworkError is
    | ConnectionFailed(Text)
    | DNSError(Text);

type ParseError is
    | InvalidFormat(Text)
    | UnexpectedEof;

// Context definitions for IO operations
context FileSystem {
    fn read(path: &Text) -> Text;
    fn write(path: &Text, content: &Text) -> ();
}

context Network {
    fn get(url: &Text) -> Text;
    fn post(url: &Text, body: &Text) -> Text;
}

context Console {
    fn print(msg: &Text) -> ();
    fn readline() -> Text;
}

// ============================================================================
// TEST 1: Pure Property Inference
// ============================================================================

/// Pure functions have no side effects - default property when no others apply
/// Properties: {Pure}
fn add(x: Int, y: Int) -> Int {
    x + y
}

/// Pure function with complex logic - still Pure
/// Properties: {Pure}
fn factorial(n: Int) -> Int {
    if n <= 1 { 1 }
    else { n * factorial(n - 1) }
}

/// Pure function with local mutation - still Pure (no external effects)
/// Properties: {Pure}
fn sum_to_n(n: Int) -> Int {
    let mut total = 0;
    let mut i = 1;
    while i <= n {
        total += i;
        i += 1;
    }
    total
}

/// Pure function with pattern matching - still Pure
/// Properties: {Pure}
fn fibonacci(n: Int) -> Int {
    match n {
        0 => 0,
        1 => 1,
        _ => fibonacci(n - 1) + fibonacci(n - 2)
    }
}

/// Explicit pure modifier - compiler verifies purity
/// Properties: {Pure}
pure fn verified_add(x: Int, y: Int) -> Int {
    x + y
}

/// Using Pure context group - equivalent to pure modifier
/// Properties: {Pure}
fn add_with_context(x: Int, y: Int) -> Int using Pure {
    x + y
}

// ============================================================================
// TEST 2: IO Property Inference
// ============================================================================

/// File operations infer IO property
/// Properties: {IO, Mutates}
fn write_log(msg: &Text) using [FileSystem] {
    FileSystem.write("/var/log/app.log", msg);
}

/// Network operations infer IO property
/// Properties: {IO}
fn fetch_url(url: &Text) -> Text using [Network] {
    Network.get(url)
}

/// Console output infers IO property
/// Properties: {IO}
fn print_message(msg: &Text) using [Console] {
    Console.print(msg);
}

/// Multiple IO operations - still single IO property
/// Properties: {IO, Mutates}
fn read_transform_write(input_path: &Text, output_path: &Text) using [FileSystem] {
    let content = FileSystem.read(input_path);
    let transformed = content.to_uppercase();
    FileSystem.write(output_path, &transformed);
}

/// IO through function call - IO propagates
/// Properties: {IO}
fn read_and_process(path: &Text) -> Int using [FileSystem] {
    let content = FileSystem.read(path);
    content.len()
}

// ============================================================================
// TEST 3: Async Property Inference
// ============================================================================

/// Async function has Async property
/// Properties: {Async}
async fn delayed_add(x: Int, y: Int) -> Int {
    x + y
}

/// Await expression infers Async property
/// Properties: {Async}
async fn compute_async(a: Int, b: Int) -> Int {
    let x = delayed_add(a, b).await;
    let y = delayed_add(x, a).await;
    x + y
}

/// Async with IO - both properties
/// Properties: {Async, IO}
async fn fetch_data_async(url: &Text) -> Text using [Network] {
    Network.get(url)
}

/// Async block infers Async property
/// Properties: {Async}
fn create_async_task(x: Int) -> _ {
    async {
        x * 2
    }
}

/// Spawn expression infers Spawns property
/// Properties: {Async, Spawns}
async fn spawn_computation(x: Int) -> Int {
    let handle = spawn delayed_add(x, x);
    handle.await
}

// ============================================================================
// TEST 4: Fallible Property Inference
// ============================================================================

/// Throws clause infers Fallible property
/// Properties: {Fallible}
fn parse_int(input: &Text) throws(ParseError) -> Int {
    if input.is_empty() {
        throw ParseError.UnexpectedEof;
    }
    match input.parse<Int>() {
        Some(n) => n,
        None => throw ParseError.InvalidFormat(input.clone())
    }
}

/// ? operator infers Fallible property
/// Properties: {Fallible}
fn double_parsed(input: &Text) throws(ParseError) -> Int {
    let n = parse_int(input)?;
    n * 2
}

/// Calling Fallible function propagates Fallible
/// Properties: {Fallible}
fn chain_fallible(a: &Text, b: &Text) throws(ParseError) -> Int {
    let x = parse_int(a)?;
    let y = parse_int(b)?;
    x + y
}

/// Result return type with explicit Err implies Fallible
/// Properties: {Fallible}
fn validate_positive(n: Int) -> Result<Int, Text> {
    if n <= 0 {
        Err("Must be positive")
    } else {
        Ok(n)
    }
}

/// try/recover that catches all errors - removes Fallible
/// Properties: {Pure} (after catching all errors)
fn safe_parse(input: &Text) -> Int {
    try {
        parse_int(input)?
    } recover {
        _ => 0
    }
}

/// try/recover with partial catch - still Fallible
/// Properties: {Fallible}
fn partial_catch(input: &Text) throws(ParseError) -> Int {
    try {
        parse_int(input)?
    } recover {
        ParseError.UnexpectedEof => -1
        // InvalidFormat propagates
    }
}

// ============================================================================
// TEST 5: Mutates Property Inference
// ============================================================================

/// &mut parameter infers Mutates property
/// Properties: {Mutates}
fn increment(value: &mut Int) {
    *value += 1;
}

/// Multiple mutable references - still single Mutates
/// Properties: {Mutates}
fn swap(a: &mut Int, b: &mut Int) {
    let temp = *a;
    *a = *b;
    *b = temp;
}

/// Mutable reference in complex operation
/// Properties: {Mutates}
fn update_if_greater(current: &mut Int, new_value: Int) -> Bool {
    if new_value > *current {
        *current = new_value;
        true
    } else {
        false
    }
}

/// Interior mutability through method call
/// Properties: {Mutates}
fn push_element<T>(list: &mut List<T>, element: T) {
    list.push(element);
}

/// Pure despite taking &mut - if no mutation actually occurs
/// Note: Compiler cannot always prove this, so conservative = Mutates
/// Properties: {Mutates}
fn read_only_mut(value: &mut Int) -> Int {
    *value  // Only reads, but still typed as Mutates
}

// ============================================================================
// TEST 6: Property Composition
// ============================================================================

/// Calling Pure from Pure = Pure
/// Properties: {Pure}
fn composed_pure(x: Int) -> Int {
    let a = add(x, 1);
    let b = factorial(a);
    fibonacci(b % 10)
}

/// Calling IO from Pure function = IO (not possible without context)
/// Properties: {IO, Mutates}
fn write_computed(x: Int) using [FileSystem] {
    let result = factorial(x);
    FileSystem.write("/result.txt", &result.to_string());
}

/// Calling Async from non-async = Async (via spawn or block)
/// Properties: {Async}
fn trigger_async(x: Int) -> _ {
    async {
        delayed_add(x, x).await
    }
}

/// Multiple property composition: IO + Fallible + Async
/// Properties: {Async, IO, Fallible}
async fn complex_operation(url: &Text) throws(NetworkError | ParseError) -> Int
using [Network]
{
    let response = Network.get(url);
    if response.is_empty() {
        throw NetworkError.ConnectionFailed(url.clone());
    }
    parse_int(&response)?
}

/// All properties combined (except Divergent)
/// Properties: {Async, IO, Fallible, Mutates, Spawns, Allocates}
async fn everything_operation(
    counter: &mut Int,
    url: &Text
) throws(NetworkError | ParseError) -> List<Int>
using [Network, Console]
{
    // Mutates
    *counter += 1;

    // IO
    Console.print(&format("Fetching {}", url));

    // Async + IO
    let response = Network.get(url);

    // Fallible
    let value = parse_int(&response)?;

    // Allocates
    let result = List.new();
    result.push(value);

    // Spawns
    let handle = spawn delayed_add(value, value);
    let doubled = handle.await;
    result.push(doubled);

    result
}

// ============================================================================
// TEST 7: Property Subsumption
// ============================================================================

/// Higher-order function accepting any property set
fn apply<T, U, F>(value: T, f: F) -> U
where type F: Fn(T) -> U
{
    f(value)
}

/// Pure function can be passed where any property set expected
fn test_subsumption() -> Int {
    // Pure function as argument
    apply(5, |x| x * 2)
}

/// Property set subsumption: Pure <: {any}
fn map_values<T, U, F>(list: &List<T>, f: F) -> List<U>
where type F: Fn(&T) -> U
{
    let mut result = List.new();
    for item in list.iter() {
        result.push(f(item));
    }
    result
}

// ============================================================================
// TEST 8: FFI and Allocates Properties
// ============================================================================

/// FFI calls infer FFI property
/// Properties: {FFI, IO}
fn call_external() -> Int {
    unsafe {
        // FFI call would go here
        42
    }
}

/// Heap allocation infers Allocates property
/// Properties: {Allocates}
fn allocate_box(x: Int) -> Heap<Int> {
    Heap(x)
}

/// List creation infers Allocates
/// Properties: {Allocates}
fn create_list() -> List<Int> {
    List.from([1, 2, 3, 4, 5])
}

/// Map creation infers Allocates
/// Properties: {Allocates}
fn create_map() -> Map<Text, Int> {
    let mut m = Map.new();
    m.insert("one", 1);
    m.insert("two", 2);
    m
}

// ============================================================================
// TEST 9: Divergent Property (May Not Terminate)
// ============================================================================

/// Infinite loop infers Divergent
/// Properties: {Divergent}
fn infinite_loop() -> ! {
    loop {
        // Never terminates
    }
}

/// panic infers Divergent
/// Properties: {Divergent}
fn always_panics() {
    panic("This always fails");
}

/// Conditional divergence - function MAY diverge
/// Properties: {Divergent} (conservative)
fn may_diverge(condition: Bool) {
    if condition {
        loop {}
    }
}

/// While loop with unknown termination
/// Properties: {Divergent} (conservative, unless proven to terminate)
fn collatz(mut n: Int) -> Int {
    let mut steps = 0;
    while n != 1 {
        if n % 2 == 0 {
            n = n / 2;
        } else {
            n = 3 * n + 1;
        }
        steps += 1;
    }
    steps
}

// ============================================================================
// TEST 10: Verification - Property Inference Assertions
// ============================================================================

/// Meta-test: Verify property inference for pure fn(Int, Int) -> Int functions
@verify(static)
fn verify_pure_properties() {
    // properties_of is monomorphic: all calls must share the same function signature
    static_assert(properties_of(add) == {Pure});
    static_assert(properties_of(verified_add) == {Pure});
}

// ============================================================================
// TEST 11: Property Inference Rules Documentation
// ============================================================================

/// Document the inference rules that the compiler applies:
///
/// 1. Pure: Default when no other properties present
///    - No IO context usage
///    - No &mut parameters
///    - No async/await
///    - No throws/? operators
///    - All called functions are Pure
///
/// 2. IO: Inferred when:
///    - Function uses IO-related context (FileSystem, Network, Console)
///    - Calls another IO function
///
/// 3. Async: Inferred when:
///    - Function has `async` modifier
///    - Uses `.await` expression
///    - Uses `async { }` block
///    - Uses `spawn` expression
///
/// 4. Fallible: Inferred when:
///    - Function has `throws` clause
///    - Uses `?` operator
///    - Calls Fallible function without catching
///    - Returns Err explicitly
///
/// 5. Mutates: Inferred when:
///    - Function has `&mut T` parameter
///    - Calls method on `&mut self`
///    - Modifies data through mutable reference
///
/// 6. Allocates: Inferred when:
///    - Uses Heap(x) for boxing
///    - Creates List, Map, Set, etc.
///    - Calls allocating functions
///
/// 7. FFI: Inferred when:
///    - Calls @extern functions
///    - Uses unsafe blocks with FFI
///
/// 8. Divergent: Inferred when:
///    - Uses infinite loop
///    - Calls panic/unreachable
///    - May not terminate
///
/// 9. Spawns: Inferred when:
///    - Uses spawn expression
///    - Creates concurrent tasks

// ============================================================================
// MAIN ENTRY POINT
// ============================================================================

fn main() {
    // Test Pure property inference
    assert(add(2, 3) == 5);
    assert(factorial(5) == 120);
    assert(sum_to_n(10) == 55);
    assert(fibonacci(10) == 55);
    assert(verified_add(10, 20) == 30);

    // Test Fallible functions
    let result1 = try {
        parse_int("42")?
    } recover {
        _ => -1
    };
    assert(result1 == 42);

    let result2 = try {
        parse_int("")?
    } recover {
        ParseError.UnexpectedEof => -1,
        _ => -2
    };
    assert(result2 == -1);

    // Test safe_parse (catches all errors)
    assert(safe_parse("100") == 100);
    assert(safe_parse("") == 0);
    assert(safe_parse("invalid") == 0);

    // Test Mutates functions
    let mut counter = 0;
    increment(&mut counter);
    assert(counter == 1);
    increment(&mut counter);
    assert(counter == 2);

    let mut a = 10;
    let mut b = 20;
    swap(&mut a, &mut b);
    assert(a == 20);
    assert(b == 10);

    // Test composed pure functions
    assert(composed_pure(3) == 55);  // fib((4! % 10)) = fib(4) = 3? Actually: fib(24%10)=fib(4)

    // Test allocations
    let boxed = allocate_box(42);
    assert(*boxed == 42);

    let list = create_list();
    assert(list.len() == 5);

    // Test subsumption
    let doubled = test_subsumption();
    assert(doubled == 10);

    let numbers = List.from([1, 2, 3]);
    let squares = map_values(&numbers, |x| x * x);
    assert(squares == List.from([1, 4, 9]));

    // Test validate_positive
    match validate_positive(5) {
        Ok(n) => assert(n == 5),
        Err(_) => assert(false)
    }

    match validate_positive(-1) {
        Ok(_) => assert(false),
        Err(msg) => assert(msg == "Must be positive")
    }

    // Test Collatz (known to terminate for small values)
    assert(collatz(1) == 0);
    assert(collatz(2) == 1);
    assert(collatz(6) == 8);

    print("All computational_properties tests passed");
}
