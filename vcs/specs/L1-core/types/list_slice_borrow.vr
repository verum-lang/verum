// @test: run-interpreter
// @tier: 0
// @level: L1
// @tags: slice, borrow, list, range, regression
// @timeout: 5000
// @expected-exit: 0
//
// Regression for Issue #7 (root fix in
// crates/verum_vbc/src/codegen/expressions.rs.compile_unary).
//
// Before the fix, `&list[..]` (any range index under the `&` borrow)
// went through `compile_index`'s generic `GetE { arr, idx: range_value
// }` path. The index expression was a Range *value* (heap pointer),
// which the runtime then interpreted as an integer element index,
// producing
// `IndexOutOfBounds { index: 49843290736, length: 2 }` style
// panics on perfectly normal slice-borrow usage:
//
//     let mut b: List<Byte> = [];
//     b.push(0x41 as Byte);
//     b.push(0x42 as Byte);
//     let slice = &b[..];
//     slice.len();   // panic
//
// `compile_unary`'s special case for `&arr[i]` only handled an integer
// index (emitting `RefListElement`). The fix adds a sibling special
// case for the range-index shape that lowers to `RefSlice`, which
// already knows how to walk a List's `backing_ptr` and produce a
// proper `FatRef`. Covers all four exclusive-range borrow shapes
// (`[..]`, `[..end]`, `[start..]`, `[start..end]`).

mount collections.List;

fn main() {
    let mut b: List<Byte> = [];
    b.push(0x41 as Byte);
    b.push(0x42 as Byte);
    b.push(0x43 as Byte);
    b.push(0x44 as Byte);

    // The exact reproducer from the issue trace.
    let full = &b[..];
    assert_eq(full.len(), 4);

    let head = &b[..2];
    assert_eq(head.len(), 2);

    let tail = &b[2..];
    assert_eq(tail.len(), 2);

    let mid = &b[1..3];
    assert_eq(mid.len(), 2);

    // Bare list-index form (without `&`). Previously silently returned
    // an empty value via the same buggy `GetE { idx: range_value }` path
    // — `compile_index` shares the slice-creation lowering with
    // `compile_unary`'s `&arr[range]` special case.
    let bare = b[..];
    assert_eq(bare.len(), 4);

    print("list_slice_borrow ok");
}
