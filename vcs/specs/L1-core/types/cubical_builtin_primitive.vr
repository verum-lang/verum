// @test: parse
// @level: L1
// @tags: types, cubical, hott, builtin, meta-type
// @timeout: 5000

/// Cubical HoTT language primitives exposed via `@builtin_*` meta-type
/// markers. The stdlib `core/math/hott.vr` and `core/math/cubical.vr`
/// declare these types; the type-checker resolves each marker name to
/// an internal `Type.Interval` / `Type.PathType` / `Type.Named`
/// primitive via `resolve_builtin_meta_type` in `verum_types.infer`.
///
/// This test pins the surface: each declaration parses and type-checks
/// to its primitive, so follow-up cubical work (NbE reduction rules,
/// Glue, HITs) has a stable foundation.

/// The abstract interval — two endpoints `i0`, `i1`, with De Morgan
/// algebra operations `1 - i`, `i ∧ j`, `i ∨ j`.
public type I is @builtin_interval;

/// The path type constructor: `Path<A>(a, b)` is the type of paths
/// from `a` to `b` in carrier `A`. Uses `Path<A>(a, b)` sugar at
/// use-sites (elaborated to `Type.Eq` by the type-checker).
public type Path<A>(a: A, b: A) is @builtin_path;

/// The glue type constructor — foundation of computational univalence.
public type Glue<A>(phi: I, T: fn(I) -> Type, e: fn(i: I) -> Path<A>(T(i), A)) is @builtin_glue;

fn main() {
    print("cubical builtin primitives parsed");
}
