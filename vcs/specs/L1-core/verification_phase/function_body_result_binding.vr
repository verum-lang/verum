// @test: integration
// @tier: 0
// @level: L1
// @tags: verify, function, ensures, result, body, postcondition
// @expect: pass
//
// `fn foo(..) -> T ensures result == <expr> { body }` must verify by
// checking `ensures` against the actual body-returned value — not
// against an unconstrained `result`. Without the body→result binding,
// every non-trivial postcondition failed with a spurious counterexample.
//
// Locks in the FunctionBody encoding in `verify_postconditions`:
// tail-expression functions and blocks whose only content is a tail
// expression both get `result == body` asserted before ensures are
// checked.

@verify(formal)
fn identity(x: Int) -> Int
    ensures result == x
{
    x
}

@verify(formal)
fn doubled(x: Int) -> Int
    requires x >= 0
    ensures result == 2 * x
    ensures result >= 0
{
    x + x
}

@verify(formal)
fn add_seven(n: Int) -> Int
    requires n >= 0
    ensures result == n + 7
    ensures result >= 7
{
    n + 7
}

@verify(formal)
fn square(x: Int) -> Int
    requires x >= 0
    ensures result == x * x
    ensures result >= 0
{
    x * x
}

@verify(formal)
fn negated(x: Int) -> Bool
    ensures result == (x < 0)
{
    x < 0
}

@verify(formal)
fn single_let(x: Int) -> Int
    requires x >= 0
    ensures result == x * 2
{
    let y = x + x;
    y
}

@verify(formal)
fn multi_let(x: Int, y: Int) -> Int
    requires x >= 0
    requires y >= 0
    ensures result == x + y + 1
    ensures result >= 1
{
    let sum = x + y;
    let total = sum + 1;
    total
}

@verify(formal)
fn max_int(a: Int, b: Int) -> Int
    ensures result >= a
    ensures result >= b
{
    if a >= b { a } else { b }
}

@verify(formal)
fn abs_int(x: Int) -> Int
    ensures result >= 0
{
    if x >= 0 { x } else { -x }
}

@verify(formal)
fn clamp(x: Int, lo: Int, hi: Int) -> Int
    requires lo <= hi
    ensures result >= lo
    ensures result <= hi
    ensures (x < lo) -> result == lo
    ensures (x > hi) -> result == hi
    ensures (lo <= x && x <= hi) -> result == x
{
    if x < lo { lo } else if x > hi { hi } else { x }
}

fn main() {
    print("L1-core: verification_phase/function_body_result_binding");
}
