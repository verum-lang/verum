// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: verification, proof-erasure, axiom, vbc-codegen
// @timeout: 5000
// @description: Axiom declarations are unproven assumptions and are erased before VBC codegen.

/// Proof erasure regression: axiom declarations are unproven assumptions
/// used as hypotheses by theorems. They must reach the proof-verification
/// phase but **not** the VBC codegen phase.
///
/// See `crates/verum_vbc/src/codegen/mod.rs:3243-3249` for the explicit
/// match that skips `ItemKind::Axiom`.

axiom chosen_well_ordering(n: Int) -> Bool;

axiom excluded_middle(p: Bool) -> Bool;

// Runtime function proves axioms did not leak into VBC: if they had, the
// codegen would either fail or emit a bogus function body for them.
fn binary_choice(b: Bool) -> Int {
    if b { 1 } else { 0 }
}

fn main() {
    print(binary_choice(true));
}
