// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: types, inference, return, functions
// @description: Type inference in function return types

/// Test for function return type inference.
/// Return types are inferred from:
/// - Explicit return statements
/// - Implicit final expressions
/// - All branches of control flow

// ============================================================================
// Basic return type inference
// ============================================================================

fn add(a: Int, b: Int) -> Int {
    a + b
}

fn multiply(a: Float, b: Float) -> Float {
    a * b
}

fn greet(name: Text) -> Text {
    f"Hello, {name}!"
}

fn compute(x: Int) -> Int {
    let y = x * 2;
    let z = y + 1;
    z
}

fn make_tuple(a: Int, b: Text) -> (Int, Text) {
    (a, b)
}

// ============================================================================
// Return inference with control flow
// ============================================================================

fn early_return(x: Int) -> Int {
    if x < 0 {
        return 0;
    }
    x * 2
}

fn multiple_returns(x: Int) -> Int {
    if x < 0 {
        return -1;
    } else if x == 0 {
        return 0;
    }
    1
}

fn max_val(a: Int, b: Int) -> Int {
    if a > b { a } else { b }
}

fn classify(x: Int) -> Text {
    if x < 0 {
        "negative"
    } else if x == 0 {
        "zero"
    } else {
        "positive"
    }
}

fn abs_val(x: Int) -> Int {
    if x < 0 { -x } else { x }
}

// ============================================================================
// Return inference from match
// ============================================================================

fn describe(n: Int) -> Text {
    match n {
        0 => "zero",
        1 => "one",
        2 => "two",
        _ => "many",
    }
}

fn unwrap_or_zero(opt: Maybe<Int>) -> Int {
    match opt {
        Some(x) => x,
        None => 0,
    }
}

fn result_to_option<T>(res: Result<T, Text>) -> Maybe<T> {
    match res {
        Ok(x) => Some(x),
        Err(_) => None,
    }
}

// ============================================================================
// Return inference with loops
// ============================================================================

fn find_first_even(numbers: List<Int>) -> Maybe<Int> {
    for n in numbers {
        if n % 2 == 0 {
            return Some(n);
        }
    }
    None
}

fn sum_until(numbers: List<Int>, limit: Int) -> Int {
    let mut total = 0;
    for n in numbers {
        total += n;
        if total >= limit {
            return total;
        }
    }
    total
}

// ============================================================================
// Generic return inference
// ============================================================================

fn identity<T>(x: T) -> T {
    x
}

fn wrap_in_maybe<T>(x: T) -> Maybe<T> {
    Some(x)
}

fn make_pair<A, B>(a: A, b: B) -> (A, B) {
    (a, b)
}

fn first_of_pair<A, B>(pair: (A, B)) -> A {
    pair.0
}

// ============================================================================
// Return inference with closures
// ============================================================================

fn make_adder(n: Int) -> fn(Int) -> Int {
    |x: Int| x + n
}

fn make_multiplier(factor: Int) -> fn(Int) -> Int {
    |x: Int| x * factor
}

fn apply_fn<T, U>(f: fn(T) -> U, x: T) -> U {
    f(x)
}

fn text_len(s: Text) -> Int { s.len() }

// ============================================================================
// Unit return inference
// ============================================================================

fn log_value(x: Int) {
    print(f"Value: {x}");
    // No return expression -> Unit
}

fn side_effect() {
    let _ = 1 + 1;
    // No return expression -> Unit
}

// ============================================================================
// Main
// ============================================================================

fn main() {
    // Test basic return
    let sum = add(10, 20);
    assert(sum == 30);

    let product = multiply(2.0, 3.0);
    assert(product == 6.0);

    let greeting = greet("World");
    assert(greeting == "Hello, World!");

    let computed = compute(5);
    assert(computed == 11);

    let tpl = make_tuple(42, "hello");
    assert(tpl.0 == 42);
    assert(tpl.1 == "hello");

    // Test early return
    let early = early_return(-5);
    assert(early == 0);
    let normal = early_return(5);
    assert(normal == 10);

    // Test multiple returns
    assert(multiple_returns(-1) == -1);
    assert(multiple_returns(0) == 0);
    assert(multiple_returns(5) == 1);

    // Test if/else return
    let maximum = max_val(10, 20);
    assert(maximum == 20);

    let class_neg = classify(-3);
    assert(class_neg == "negative");
    let class_zero = classify(0);
    assert(class_zero == "zero");
    let class_pos = classify(5);
    assert(class_pos == "positive");

    assert(abs_val(-7) == 7);
    assert(abs_val(7) == 7);
    assert(abs_val(0) == 0);

    // Test match return
    assert(describe(0) == "zero");
    assert(describe(1) == "one");
    assert(describe(99) == "many");

    assert(unwrap_or_zero(Some(42)) == 42);
    assert(unwrap_or_zero(None) == 0);

    let ok_result: Result<Int, Text> = Ok(100);
    let err_result: Result<Int, Text> = Err("fail");
    assert(result_to_option(ok_result) == Some(100));
    assert(result_to_option(err_result) == None);

    // Test loop return
    let first_even = find_first_even([1, 3, 5, 6, 7]);
    assert(first_even == Some(6));
    let no_even = find_first_even([1, 3, 5, 7]);
    assert(no_even == None);

    let sum_lim = sum_until([1, 2, 3, 4, 5], 7);
    assert(sum_lim == 10);  // 1+2+3+4=10 >= 7

    // Test generic return
    assert(identity(42) == 42);
    assert(identity("hello") == "hello");
    assert(wrap_in_maybe(42) == Some(42));
    assert(wrap_in_maybe("x") == Some("x"));

    let p = make_pair(1, "two");
    assert(p.0 == 1);
    assert(p.1 == "two");
    assert(first_of_pair(p) == 1);

    // Test closure return
    let add_five = make_adder(5);
    assert(add_five(10) == 15);
    assert(add_five(0) == 5);

    let times_three = make_multiplier(3);
    assert(times_three(7) == 21);

    // Test apply_fn
    let doubled = apply_fn(|x: Int| x * 2, 21);
    assert(doubled == 42);

    let len = apply_fn(text_len, "hello");
    assert(len == 5);

    // Test unit return
    log_value(42);
    side_effect();

    print("Return inference tests passed!");
}
