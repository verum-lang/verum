// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: types, inference, patterns, destructuring
// @description: Type inference through pattern matching and destructuring

/// Test for type inference through pattern matching.
/// Types flow through patterns in:
/// - let bindings with destructuring
/// - match expressions
/// - function parameters
/// - guard conditions

// ============================================================================
// Type definitions
// ============================================================================

type Point is {
    x: Int,
    y: Int,
};

type Person is {
    name: Text,
    age: Int,
};

type Shape is
    | Circle { radius: Float }
    | Rect { width: Float, height: Float }
    | Triangle(Float, Float, Float);

type Tree<T> is
    | Leaf(T)
    | Node { value: T, left: Heap<Tree<T>>, right: Heap<Tree<T>> };

// ============================================================================
// Pattern-based functions
// ============================================================================

fn area(s: Shape) -> Float {
    match s {
        Circle { radius } => 3.14159 * radius * radius,
        Rect { width, height } => width * height,
        Triangle(a, b, c) => {
            // Heron's formula approximation
            let s_val = (a + b + c) / 2.0;
            // Just return semi-perimeter as proxy for test
            s_val
        },
    }
}

fn describe_point(p: Point) -> Text {
    match p {
        Point { x: 0, y: 0 } => "origin",
        Point { x, y: 0 } => f"x-axis at {x}",
        Point { x: 0, y } => f"y-axis at {y}",
        Point { x, y } => f"({x}, {y})",
    }
}

fn classify_age(p: Person) -> Text {
    match p {
        Person { age, .. } if age < 18 => "minor",
        Person { age, .. } if age < 65 => "adult",
        _ => "senior",
    }
}

@allow(unbounded_recursion)
fn tree_sum(t: Tree<Int>) -> Int {
    match t {
        Leaf(n) => n,
        Node { value, left, right } => value + tree_sum(*left) + tree_sum(*right),
    }
}

@allow(unbounded_recursion)
fn tree_height<T>(t: Tree<T>) -> Int {
    match t {
        Leaf(_) => 1,
        Node { left, right, .. } => {
            let lh = tree_height(*left);
            let rh = tree_height(*right);
            1 + (if lh > rh { lh } else { rh })
        },
    }
}

// ============================================================================
// Tuple pattern inference
// ============================================================================

fn combine_points(a: Point, b: Point) -> Point {
    let Point { x: ax, y: ay } = a;
    let Point { x: bx, y: by } = b;
    Point { x: ax + bx, y: ay + by }
}

fn quadrant(p: Point) -> Int {
    match p {
        Point { x, y } if x > 0 && y > 0 => 1,
        Point { x, y } if x < 0 && y > 0 => 2,
        Point { x, y } if x < 0 && y < 0 => 3,
        Point { x, y } if x > 0 && y < 0 => 4,
        _ => 0,
    }
}

// ============================================================================
// Nested pattern inference
// ============================================================================

fn nested_maybe(outer: Maybe<Maybe<Int>>) -> Int {
    match outer {
        Some(Some(n)) => n,
        Some(None) => -1,
        None => -2,
    }
}

fn classify_result(r: Result<Int, Text>) -> Text {
    match r {
        Ok(n) if n > 100 => "large ok",
        Ok(n) if n > 0 => "small ok",
        Ok(_) => "non-positive ok",
        Err(msg) => f"error: {msg}",
    }
}

// ============================================================================
// List pattern inference
// ============================================================================

fn list_head_tail<T: Clone>(lst: List<T>) -> Maybe<(T, List<T>)> {
    if lst.is_empty() {
        None
    } else {
        let head = lst[0].clone();
        let mut tail: List<T> = [];
        let mut i = 1;
        while i < lst.len() {
            tail.push(lst[i].clone());
            i += 1;
        }
        Some((head, tail))
    }
}

fn match_list_pattern(items: List<Int>) -> Text {
    match items[..] {
        [] => "empty",
        [x] => f"single: {x}",
        [x, y] => f"pair: {x}, {y}",
        [x, y, ..rest] => f"many starting with {x}, {y}",
    }
}

// ============================================================================
// Main
// ============================================================================

fn main() {
    // === Tuple pattern inference ===

    let pair = (42, "hello");
    let (a, b) = pair;
    assert(a == 42);
    assert(b == "hello");

    let nested_tpl = ((1, 2), (3, 4));
    let ((x1, y1), (x2, y2)) = nested_tpl;
    assert(x1 == 1);
    assert(y1 == 2);
    assert(x2 == 3);
    assert(y2 == 4);

    let (first, _) = pair;
    assert(first == 42);

    // === Struct pattern inference ===

    let p = Point { x: 1, y: 2 };
    let Point { x: px, y: py } = p;
    assert(px == 1);
    assert(py == 2);

    let person = Person { name: "Alice", age: 30 };
    let Person { name, age } = person;
    assert(name == "Alice");
    assert(age == 30);

    // === Shape matching ===

    let c = Circle { radius: 2.0 };
    let r = Rect { width: 3.0, height: 4.0 };
    let t = Triangle(3.0, 4.0, 5.0);

    assert(area(c) > 12.0);  // pi * 4 ≈ 12.57
    assert(area(r) == 12.0);
    assert(area(t) == 6.0);  // (3+4+5)/2 = 6

    // === describe_point ===

    assert(describe_point(Point { x: 0, y: 0 }) == "origin");
    assert(describe_point(Point { x: 5, y: 0 }) == "x-axis at 5");
    assert(describe_point(Point { x: 0, y: 3 }) == "y-axis at 3");
    assert(describe_point(Point { x: 2, y: 4 }) == "(2, 4)");

    // === classify_age ===

    assert(classify_age(Person { name: "child", age: 10 }) == "minor");
    assert(classify_age(Person { name: "adult", age: 30 }) == "adult");
    assert(classify_age(Person { name: "elder", age: 70 }) == "senior");

    // === Tree matching ===

    let tree: Tree<Int> = Node {
        value: 5,
        left: Heap(Node {
            value: 3,
            left: Heap(Leaf(1)),
            right: Heap(Leaf(4)),
        }),
        right: Heap(Leaf(7)),
    };

    assert(tree_sum(tree) == 20);  // 5+3+1+4+7=20
    assert(tree_height(tree) == 3);

    // === Point operations ===

    let p1 = Point { x: 1, y: 2 };
    let p2 = Point { x: 3, y: 4 };
    let combined = combine_points(p1, p2);
    assert(combined.x == 4);
    assert(combined.y == 6);

    assert(quadrant(Point { x: 1, y: 1 }) == 1);
    assert(quadrant(Point { x: -1, y: 1 }) == 2);
    assert(quadrant(Point { x: -1, y: -1 }) == 3);
    assert(quadrant(Point { x: 1, y: -1 }) == 4);
    assert(quadrant(Point { x: 0, y: 0 }) == 0);

    // === Nested Maybe matching ===

    assert(nested_maybe(Some(Some(42))) == 42);
    assert(nested_maybe(Some(None)) == -1);
    assert(nested_maybe(None) == -2);

    // === Result with guard ===

    assert(classify_result(Ok(200)) == "large ok");
    assert(classify_result(Ok(50)) == "small ok");
    assert(classify_result(Ok(-5)) == "non-positive ok");
    assert(classify_result(Err("oops")) == "error: oops");

    // === List head/tail ===

    let lst = [1, 2, 3, 4, 5];
    let ht = list_head_tail(lst);
    match ht {
        Some((h, t)) => {
            assert(h == 1);
            assert(t.len() == 4);
            assert(t[0] == 2);
        },
        None => assert(false),
    }

    let empty_lst: List<Int> = [];
    assert(list_head_tail(empty_lst) == None);

    // === List pattern matching ===

    assert(match_list_pattern([]) == "empty");
    assert(match_list_pattern([42]) == "single: 42");
    assert(match_list_pattern([1, 2]) == "pair: 1, 2");
    assert(match_list_pattern([1, 2, 3, 4]) == "many starting with 1, 2");

    print("Pattern inference tests passed!");
}
