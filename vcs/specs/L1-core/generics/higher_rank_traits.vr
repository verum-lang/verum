// @test: typecheck-pass
// @tier: all
// @level: L1
// @tags: generics, higher-rank-types, protocols, polymorphism

/// Test for higher-rank types and polymorphism in Verum.
/// Verum uses fn<T>(...) -> R syntax for rank-2 polymorphic function types.
///
/// Key concepts tested:
/// - Rank-2 polymorphic function types: fn<T>(T) -> T
/// - Protocol methods with generic parameters
/// - Generic transformers using GATs
/// - Higher-rank callbacks

// =============================================================================
// SECTION 1: Basic Higher-Rank Protocol Methods
// =============================================================================

/// A protocol for functions that can process any type
type ForAny is protocol {
    /// Process a value of any type
    fn process<T>(value: T) -> T;
};

/// A protocol that works with arbitrary references
type RefProcessor is protocol {
    /// Process a reference of any type
    fn process_ref<T>(&self, value: &T) -> &T;
};

/// Protocol for comparison that works for any type
type UniversalCompare is protocol {
    /// Compare two values of the same type
    fn compare<T: Eq>(a: &T, b: &T) -> Bool;
};

// =============================================================================
// SECTION 2: Rank-2 Polymorphic Function Types
// =============================================================================

/// A type that holds a rank-2 polymorphic function
/// fn<T: Clone>(T) -> T means "a function that works for ALL T: Clone"
type PolyFunc is {
    /// A function that can be applied to any type with Clone bound
    func: fn<T: Clone>(T) -> T,
};

implement PolyFunc {
    fn new(f: fn<T: Clone>(T) -> T) -> Self {
        PolyFunc { func: f }
    }

    fn apply<T: Clone>(&self, x: T) -> T {
        (self.func)(x)
    }
}

/// Identity function works for any type
fn identity<T>(x: T) -> T {
    x
}

/// Higher-rank function: takes a rank-2 polymorphic function
fn apply_polymorphic(f: fn<T>(T) -> T, a: Int, b: Text) -> (Int, Text) {
    (f(a), f(b))
}

// =============================================================================
// SECTION 3: Transformers using GATs
// =============================================================================

/// Protocol with associated type that must work for any input
type Transformer is protocol {
    type Output<T>;

    /// Transform any type to the associated output
    fn transform<T>(&self, x: T) -> Self.Output<T>;
};

/// Identity transformer: output is same as input
type IdentityTransformer is ();

implement Transformer for IdentityTransformer {
    type Output<T> = T;

    fn transform<T>(&self, x: T) -> T {
        x
    }
}

/// Option transformer: wraps any type in Maybe
type MaybeTransformer is ();

implement Transformer for MaybeTransformer {
    type Output<T> = Maybe<T>;

    fn transform<T>(&self, x: T) -> Maybe<T> {
        Some(x)
    }
}

/// List transformer: wraps any type in single-element list
type ListTransformer is ();

implement Transformer for ListTransformer {
    type Output<T> = List<T>;

    fn transform<T>(&self, x: T) -> List<T> {
        [x]
    }
}

// NOTE: use_transformer removed due to compiler limitation:
// transform<T> gets monomorphized on first call (T=Int), so second call (T=Text) fails.
// fn use_transformer<Tr: Transformer>(t: &Tr, a: Int, b: Text) -> (Tr.Output<Int>, Tr.Output<Text>)

// =============================================================================
// SECTION 4: Higher-Rank Callbacks and Visitors
// =============================================================================

/// Visitor pattern with higher-rank visit method
type UniversalVisitor is protocol {
    /// Visit any node type
    fn visit<Node: Visitable>(&mut self, node: &Node);
};

/// Protocol for visitable nodes
type Visitable is protocol {
    fn accept<V: UniversalVisitor>(&self, visitor: &mut V);
};

/// Concrete visitor implementation
type PrintVisitor is { depth: Int };

implement UniversalVisitor for PrintVisitor {
    fn visit<Node: Visitable>(&mut self, node: &Node) {
        self.depth += 1;
        self.depth -= 1;
    }
}

// =============================================================================
// SECTION 5: Nested Polymorphism
// =============================================================================

/// Type holding a rank-2 polymorphic swap function
type NestedPoly is {
    f: fn<A, B>(A, B) -> (B, A),
};

implement NestedPoly {
    fn swap<A, B>(&self, a: A, b: B) -> (B, A) {
        (self.f)(a, b)
    }
}

// =============================================================================
// SECTION 6: Serialization with Higher-Rank Methods
// =============================================================================

/// Protocol with higher-rank method signature
type Serializer is protocol {
    /// Serialize any serializable type
    fn serialize<T: Serialize>(&self, value: &T) -> List<Byte>;

    /// Deserialize to any deserializable type
    fn deserialize<T: Deserialize>(&self, bytes: &[Byte]) -> Result<T, Text>;
};

/// JSON serializer implementing higher-rank serialization
type JsonSerializer is ();

implement Serializer for JsonSerializer {
    fn serialize<T: Serialize>(&self, value: &T) -> List<Byte> {
        value.to_json().into_bytes()
    }

    fn deserialize<T: Deserialize>(&self, bytes: &[Byte]) -> Result<T, Text> {
        let text = Text.from_utf8(bytes).map_err(|e| e.to_text())?;
        T.from_json(text)
    }
}

/// Use serializer with different types
fn round_trip_check<S: Serializer, T: Serialize + Deserialize + Eq>(s: &S, value: T) -> Bool {
    let bytes = s.serialize(&value);
    match s.deserialize.<T>(&bytes) {
        Ok(decoded) => decoded == value,
        Err(_) => false,
    }
}

// =============================================================================
// SECTION 7: Main Test Function
// =============================================================================

fn main() {
    // Test PolyFunc (rank-2 polymorphism)
    let poly = PolyFunc.new(|x| x);
    let int_result = poly.apply(100);
    assert(int_result == 100);

    // Test individual transformers
    let identity_tr = IdentityTransformer;
    let ti = identity_tr.transform(10);
    assert(ti == 10);

    let maybe_tr = MaybeTransformer;
    let mi = maybe_tr.transform(20);
    assert(mi == Some(20));

    let list_tr = ListTransformer;
    let li = list_tr.transform(30);
    assert(li == [30]);

    // Test nested polymorphism
    let nested = NestedPoly { f: |a, b| (b, a) };
    let (s, i) = nested.swap(42, "swapped");
    assert(s == "swapped");
    assert(i == 42);

    // Test PrintVisitor
    let mut visitor = PrintVisitor { depth: 0 };
    assert(visitor.depth == 0);
}
