// @test: typecheck-pass
// @tier: all
// @level: L1
// @tags: generics, higher-kinded-types, hkt, functor, monad

/// Test for higher-kinded types (HKT).
/// HKTs allow abstraction over type constructors like List<_>, Maybe<_>, etc.
/// Syntax: F<_> represents a type constructor that takes one type parameter.
///
/// This file tests:
/// - Higher-kinded type parameters (F<_>)
/// - Functor protocol
/// - Applicative protocol
/// - Monad protocol
/// - Generic programming over type constructors

// =============================================================================
// SECTION 1: Higher-Kinded Type Syntax
// =============================================================================

/// Functor protocol - types that can be mapped over
/// F<_> is a higher-kinded type parameter (type constructor)
type Functor<F<_>> is protocol {
    /// Map a function over the functor
    fn map<A, B>(fa: F<A>, f: fn(A) -> B) -> F<B>;
};

/// Applicative - functors with pure and apply
type Applicative<F<_>> is protocol extends Functor<F> {
    /// Lift a value into the functor
    fn pure<A>(a: A) -> F<A>;

    /// Apply a function in context to a value in context
    fn apply<A, B>(ff: F<fn(A) -> B>, fa: F<A>) -> F<B>;
};

/// Monad - applicatives with flatMap (bind)
type Monad<F<_>> is protocol extends Applicative<F> {
    /// Chain computations in the functor
    fn flat_map<A, B>(fa: F<A>, f: fn(A) -> F<B>) -> F<B>;

    /// flatten nested functors
    fn flatten<A>(ffa: F<F<A>>) -> F<A> {
        Self.flat_map(ffa, |fa| fa)
    }
};

// =============================================================================
// SECTION 2: Maybe Functor/Applicative/Monad
// =============================================================================

type Maybe<T> is
    | Some(T)
    | None;

implement Functor for Maybe {
    fn map<A, B>(fa: Maybe<A>, f: fn(A) -> B) -> Maybe<B> {
        match fa {
            Maybe.Some(a) => Maybe.Some(f(a)),
            Maybe.None => Maybe.None,
        }
    }
}

implement Applicative for Maybe {
    fn pure<A>(a: A) -> Maybe<A> {
        Maybe.Some(a)
    }

    fn apply<A, B>(ff: Maybe<fn(A) -> B>, fa: Maybe<A>) -> Maybe<B> {
        match (ff, fa) {
            (Maybe.Some(f), Maybe.Some(a)) => Maybe.Some(f(a)),
            _ => Maybe.None,
        }
    }
}

implement Monad for Maybe {
    fn flat_map<A, B>(fa: Maybe<A>, f: fn(A) -> Maybe<B>) -> Maybe<B> {
        match fa {
            Maybe.Some(a) => f(a),
            Maybe.None => Maybe.None,
        }
    }
}

// =============================================================================
// SECTION 3: List Functor/Applicative/Monad
// =============================================================================

implement Functor for List {
    fn map<A, B>(fa: List<A>, f: fn(A) -> B) -> List<B> {
        fa.into_iter().map(f).collect()
    }
}

implement Applicative for List {
    fn pure<A>(a: A) -> List<A> {
        [a]
    }

    fn apply<A, B>(ff: List<fn(A) -> B>, fa: List<A>) -> List<B> {
        let mut result: List<B> = List.new();
        for f in ff {
            for a in &fa {
                result.push(f(a.clone()));
            }
        }
        result
    }
}

implement Monad for List {
    fn flat_map<A, B>(fa: List<A>, f: fn(A) -> List<B>) -> List<B> {
        fa.into_iter().flat_map(f).collect()
    }
}

// =============================================================================
// SECTION 4: Result Functor/Applicative/Monad
// =============================================================================

type Result<T, E> is
    | Ok(T)
    | Err(E);

/// For HKT purposes, we fix the error type and abstract over T
/// Result<_, E> is a type constructor in T
implement Functor for Result<_, E> {
    fn map<A, B>(fa: Result<A, E>, f: fn(A) -> B) -> Result<B, E> {
        match fa {
            Result.Ok(a) => Result.Ok(f(a)),
            Result.Err(e) => Result.Err(e),
        }
    }
}

implement Applicative for Result<_, E> where E: Clone {
    fn pure<A>(a: A) -> Result<A, E> {
        Result.Ok(a)
    }

    fn apply<A, B>(ff: Result<fn(A) -> B, E>, fa: Result<A, E>) -> Result<B, E> {
        match (ff, fa) {
            (Result.Ok(f), Result.Ok(a)) => Result.Ok(f(a)),
            (Result.Err(e), _) => Result.Err(e),
            (_, Result.Err(e)) => Result.Err(e),
        }
    }
}

implement Monad for Result<_, E> where E: Clone {
    fn flat_map<A, B>(fa: Result<A, E>, f: fn(A) -> Result<B, E>) -> Result<B, E> {
        match fa {
            Result.Ok(a) => f(a),
            Result.Err(e) => Result.Err(e),
        }
    }
}

// =============================================================================
// SECTION 7: Generic HKT helpers through protocol-qualified dispatch
// =============================================================================
//
// Previously (pre-L0-2) calling protocol methods through an HKT parameter
// inside a function body produced "MapFuture<_, F<_>> vs F<_>" mismatches
// because method resolution matched the FutureExt::map blanket before the
// bound on F was consulted. After L0-2 (part 1), protocol-qualified calls
// `Functor.map(...)` / `Applicative.apply(...)` dispatch through F's bound
// and return `F<B>` / `F<C>` with the caller's F substituted through.
//
// The method-on-value form (`fa.map(f)`) is still routed through a different
// resolver and remains on the L0-2 roadmap — see hkt_method_on_value.vr.

// Apply a pure function inside an Applicative context (lift-2).
fn lift2<F<_>: Applicative, A, B, C>(
    fa: F<A>,
    fb: F<B>,
    f: fn(A, B) -> C,
) -> F<C> {
    Applicative.apply(Functor.map(fa, |a| |b| f(a, b)), fb)
}

// =============================================================================
// SECTION 8: Main Test Cases
// =============================================================================

fn main() {
    // Test Maybe Functor
    let maybe_int: Maybe<Int> = Maybe.Some(42);
    let mapped_maybe = Maybe.map(maybe_int, |x| x * 2);
    assert(mapped_maybe == Maybe.Some(84));

    let none_int: Maybe<Int> = Maybe.None;
    let mapped_none = Maybe.map(none_int, |x| x * 2);
    assert(mapped_none == Maybe.None);

    // Test Maybe Applicative
    let pure_maybe: Maybe<Int> = Maybe.pure(42);
    assert(pure_maybe == Maybe.Some(42));

    let fn_maybe: Maybe<fn(Int) -> Int> = Maybe.Some(|x| x + 1);
    let applied = Maybe.apply(fn_maybe, Maybe.Some(41));
    assert(applied == Maybe.Some(42));

    // Test Maybe Monad
    let chained = Maybe.flat_map(Maybe.Some(21), |x| Maybe.Some(x * 2));
    assert(chained == Maybe.Some(42));

    let chained_none = Maybe.flat_map(Maybe.None, |x: Int| Maybe.Some(x * 2));
    assert(chained_none == Maybe.None);

    // Test List Functor
    let list_int: List<Int> = [1, 2, 3];
    let mapped_list = List.map(list_int, |x| x * 2);
    assert(mapped_list == [2, 4, 6]);

    // Test List Monad (flatMap)
    let flat_mapped = List.flat_map([1, 2, 3], |x| [x, x * 10]);
    assert(flat_mapped == [1, 10, 2, 20, 3, 30]);

    // Test Result Functor
    let ok_result: Result<Int, Text> = Result.Ok(42);
    let mapped_result = Result.map(ok_result, |x| x * 2);
    assert(mapped_result == Result.Ok(84));

    let err_result: Result<Int, Text> = Result.Err("error");
    let mapped_err = Result.map(err_result, |x| x * 2);
    assert(mapped_err == Result.Err("error"));

    // Test Result Monad
    let chained_result = Result.flat_map(Result.Ok(21), |x| {
        Result.Ok(x * 2)
    });
    assert(chained_result == Result.Ok(42));

    // Test flatten
    let nested: Maybe<Maybe<Int>> = Maybe.Some(Maybe.Some(42));
    let flattened = Maybe.flatten(nested);
    assert(flattened == Maybe.Some(42));

    // Generic HKT helper via protocol-qualified dispatch (post-L0-2).
    // F := Maybe, A := Int, B := Int, C := Int.
    let pair_summed: Maybe<Int> = lift2(Maybe.Some(40), Maybe.Some(2), |a, b| a + b);
    assert(pair_summed == Maybe.Some(42));
}
