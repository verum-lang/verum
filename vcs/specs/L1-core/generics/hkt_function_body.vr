// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: generics, higher-kinded-types, hkt, function-body, kind-inference
//
// Regression anchor for L0-2: HKT parameter substitution inside *function
// bodies* using the protocol-qualified call form.
//
// Previously fails with: "expected '_<_>', found 'MapFuture<_, F<_>>'"
// because method resolution on `fa: F<A>` fell through to FutureExt::map
// (a blanket impl that shadows the Functor bound on F). The fix adds a
// bound-first dispatch path in `infer.rs` that, when the receiver's head
// is a TypeVar (or a Generic whose name resolves to one) with a protocol
// bound, finds the method via the bound BEFORE blanket-impl lookup — and
// substitutes the protocol's HKT slot with the receiver's own TypeVar so
// the returned `F<B>` elaborates correctly.

type Functor<F<_>> is protocol {
    fn map<A, B>(fa: F<A>, f: fn(A) -> B) -> F<B>;
};

type Applicative<F<_>> is protocol extends Functor<F> {
    fn pure<A>(a: A) -> F<A>;
    fn apply<A, B>(ff: F<fn(A) -> B>, fa: F<A>) -> F<B>;
};

// Generic HKT function using protocol-qualified calls through F's bound.
fn fmap<F<_>: Functor, A, B>(fa: F<A>, f: fn(A) -> B) -> F<B> {
    Functor.map(fa, f)
}

// Applicative lift-2 — three F<_> positions and two protocol methods.
fn lift2<F<_>: Applicative, A, B, C>(
    fa: F<A>,
    fb: F<B>,
    f: fn(A, B) -> C,
) -> F<C> {
    Applicative.apply(Functor.map(fa, |a| |b| f(a, b)), fb)
}

type Maybe<T> is
    | Some(T)
    | None;

implement Functor for Maybe {
    fn map<A, B>(fa: Maybe<A>, f: fn(A) -> B) -> Maybe<B> {
        match fa {
            Maybe.Some(a) => Maybe.Some(f(a)),
            Maybe.None => Maybe.None,
        }
    }
}

implement Applicative for Maybe {
    fn pure<A>(a: A) -> Maybe<A> {
        Maybe.Some(a)
    }

    fn apply<A, B>(ff: Maybe<fn(A) -> B>, fa: Maybe<A>) -> Maybe<B> {
        match (ff, fa) {
            (Maybe.Some(g), Maybe.Some(a)) => Maybe.Some(g(a)),
            _ => Maybe.None,
        }
    }
}

fn main() {
    let a: Maybe<Int> = Maybe.Some(2);
    let b: Maybe<Int> = Maybe.Some(3);

    // Exercises HKT protocol method dispatch inside a function body with F := Maybe.
    let doubled: Maybe<Int> = fmap(a, |x| x * 2);
    assert(doubled == Maybe.Some(4));

    // Concrete instantiation: F := Maybe, A := Int, B := Int, C := Int
    let c: Maybe<Int> = lift2(a, b, |x, y| x + y);
    assert(c == Maybe.Some(5));
}
