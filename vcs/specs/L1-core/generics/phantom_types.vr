// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: generics, phantom-types, type-safety, zero-cost
// @description: Phantom types for type-safe programming without runtime cost

/// Test for phantom types.
/// Phantom types carry type information at compile-time without runtime cost.

// ============================================================================
// Phantom marker type
// ============================================================================

type PhantomData<T> is ();

// ============================================================================
// State machine with phantom types: Door
// ============================================================================

type Locked is ();
type Unlocked is ();

type Door<State> is {
    name: Text,
    _state: PhantomData<State>,
};

implement Door<Unlocked> {
    fn new(name: Text) -> Door<Unlocked> {
        Door { name, _state: PhantomData }
    }

    fn lock(self) -> Door<Locked> {
        print(f"Locking door: {self.name}");
        Door { name: self.name, _state: PhantomData }
    }

    fn open(&self) {
        print(f"Opening door: {self.name}");
    }

    fn close(&self) {
        print(f"Closing door: {self.name}");
    }
}

implement Door<Locked> {
    fn unlock(self) -> Door<Unlocked> {
        print(f"Unlocking door: {self.name}");
        Door { name: self.name, _state: PhantomData }
    }

    // Cannot open() or close() a locked door
}

// ============================================================================
// Units of measurement
// ============================================================================

type Meters is ();
type Kilometers is ();
type Miles is ();
type Feet is ();

type Distance<Unit> is {
    value: Float,
    _unit: PhantomData<Unit>,
};

implement<U> Distance<U> {
    fn new(value: Float) -> Distance<U> {
        Distance { value, _unit: PhantomData }
    }

    fn value(&self) -> Float {
        self.value
    }

    fn add(self, other: Distance<U>) -> Distance<U> {
        Distance { value: self.value + other.value, _unit: PhantomData }
    }

    fn sub(self, other: Distance<U>) -> Distance<U> {
        Distance { value: self.value - other.value, _unit: PhantomData }
    }

    fn scale(self, factor: Float) -> Distance<U> {
        Distance { value: self.value * factor, _unit: PhantomData }
    }
}

fn meters_to_km(d: Distance<Meters>) -> Distance<Kilometers> {
    Distance { value: d.value / 1000.0, _unit: PhantomData }
}

fn km_to_meters(d: Distance<Kilometers>) -> Distance<Meters> {
    Distance { value: d.value * 1000.0, _unit: PhantomData }
}

fn miles_to_km(d: Distance<Miles>) -> Distance<Kilometers> {
    Distance { value: d.value * 1.60934, _unit: PhantomData }
}

fn meters_to_feet(d: Distance<Meters>) -> Distance<Feet> {
    Distance { value: d.value * 3.28084, _unit: PhantomData }
}

// ============================================================================
// Currency phantom types
// ============================================================================

type USD is ();
type EUR is ();
type GBP is ();

type Money<Currency> is {
    cents: Int,
    _currency: PhantomData<Currency>,
};

implement<C> Money<C> {
    fn new(cents: Int) -> Money<C> {
        Money { cents, _currency: PhantomData }
    }

    fn from_major(amount: Float) -> Money<C> {
        Money { cents: (amount * 100.0) as Int, _currency: PhantomData }
    }

    fn cents_val(&self) -> Int {
        self.cents
    }

    fn to_major(&self) -> Float {
        self.cents as Float / 100.0
    }

    fn add_money(self, other: Money<C>) -> Money<C> {
        Money { cents: self.cents + other.cents, _currency: PhantomData }
    }

    fn mul_money(self, factor: Float) -> Money<C> {
        Money { cents: (self.cents as Float * factor) as Int, _currency: PhantomData }
    }
}

fn usd_to_eur(amount: Money<USD>, rate: Float) -> Money<EUR> {
    Money { cents: (amount.cents as Float * rate) as Int, _currency: PhantomData }
}

// ============================================================================
// Permission phantom types
// ============================================================================

type ReadOnly is ();
type ReadWrite is ();

type FileHandle<Permission> is {
    path: Text,
    _permission: PhantomData<Permission>,
};

implement FileHandle<ReadOnly> {
    fn open_readonly(path: Text) -> FileHandle<ReadOnly> {
        FileHandle { path, _permission: PhantomData }
    }

    fn read(&self) -> Text {
        f"Contents of {self.path}"
    }

    // No write method on ReadOnly
}

implement FileHandle<ReadWrite> {
    fn open_readwrite(path: Text) -> FileHandle<ReadWrite> {
        FileHandle { path, _permission: PhantomData }
    }

    fn read(&self) -> Text {
        f"Contents of {self.path}"
    }

    fn write(&mut self, content: Text) {
        print(f"Writing to {self.path}: {content}");
    }

    fn to_readonly(self) -> FileHandle<ReadOnly> {
        FileHandle { path: self.path, _permission: PhantomData }
    }
}

// ============================================================================
// Type-safe builder with phantom state
// ============================================================================

type NeedsName is ();
type NeedsAge is ();
type Built is ();

type PersonData is {
    name: Text,
    age: Int,
};

type Builder<State> is {
    name: Maybe<Text>,
    age: Maybe<Int>,
    _state: PhantomData<State>,
};

implement Builder<NeedsName> {
    fn new() -> Builder<NeedsName> {
        Builder { name: None, age: None, _state: PhantomData }
    }

    fn with_name(self, name: Text) -> Builder<NeedsAge> {
        Builder { name: Some(name), age: self.age, _state: PhantomData }
    }
}

implement Builder<NeedsAge> {
    fn with_age(self, age: Int) -> Builder<Built> {
        Builder { name: self.name, age: Some(age), _state: PhantomData }
    }
}

implement Builder<Built> {
    fn build(self) -> PersonData {
        PersonData {
            name: match self.name { Some(n) => n, None => "" },
            age: match self.age { Some(a) => a, None => 0 },
        }
    }
}

// ============================================================================
// Wrapper with phantom marker
// ============================================================================

type Validated is ();
type Unvalidated is ();

type Input<Status> is {
    data: Text,
    _status: PhantomData<Status>,
};

implement Input<Unvalidated> {
    fn new(data: Text) -> Input<Unvalidated> {
        Input { data, _status: PhantomData }
    }
}

fn validate(input: Input<Unvalidated>) -> Maybe<Input<Validated>> {
    if input.data.len() > 0 {
        Some(Input { data: input.data, _status: PhantomData })
    } else {
        None
    }
}

fn use_validated(input: Input<Validated>) -> Text {
    f"Valid: {input.data}"
}

// ============================================================================
// Main
// ============================================================================

fn main() {
    // Door state machine
    let door = Door.new("Front");
    door.open();
    door.close();
    let locked_door = door.lock();
    // locked_door.open();  // ERROR: not available on Door<Locked>
    let unlocked_again = locked_door.unlock();
    unlocked_again.open();

    // Distance with units
    let d1 = Distance.new(5000.0);
    let d2 = Distance.new(3000.0);
    let total_m: Distance<Meters> = d1.add(d2);
    assert(total_m.value() == 8000.0);

    let d1500: Distance<Meters> = Distance.new(1500.0);
    let km = meters_to_km(d1500);
    assert(km.value() == 1.5);

    // Cannot mix units:
    // let bad = d1.add(km);  // ERROR: Distance<Meters> vs Distance<Kilometers>

    let miles: Distance<Miles> = Distance.new(10.0);
    let km_from_miles = miles_to_km(miles);
    assert((km_from_miles.value() - 16.0934).abs() < 0.001);

    let d_a: Distance<Meters> = Distance.new(5000.0);
    let d_b: Distance<Meters> = Distance.new(2000.0);
    let d_sub = d_a.sub(d_b);
    assert(d_sub.value() == 3000.0);

    let d_c: Distance<Meters> = Distance.new(100.0);
    let d_scale = d_c.scale(2.5);
    assert(d_scale.value() == 250.0);

    // Money operations
    let usd1 = Money.new(1000);  // $10.00
    let usd2 = Money.new(500);   // $5.00
    let total_usd: Money<USD> = usd1.add_money(usd2);
    assert(total_usd.cents_val() == 1500);
    assert(total_usd.to_major() == 15.0);

    let eur: Money<EUR> = Money.new(800);
    // Cannot mix currencies:
    // let bad_add = usd1.add_money(eur);  // ERROR

    let usd3 = Money.from_major(7.50);
    assert(usd3.cents_val() == 750);

    // FileHandle permissions
    let ro_file = FileHandle.open_readonly("/etc/passwd");
    let content = ro_file.read();
    assert(content == "Contents of /etc/passwd");
    // ro_file.write("hack");  // ERROR: write not on ReadOnly

    let mut rw_file = FileHandle.open_readwrite("/tmp/data.txt");
    let content2 = rw_file.read();
    rw_file.write("new content");

    let downgraded = rw_file.to_readonly();
    // downgraded.write("hack");  // ERROR: now read-only

    // Builder pattern
    let person = Builder.new()
        .with_name("Alice")
        .with_age(30)
        .build();
    assert(person.name == "Alice");
    assert(person.age == 30);

    // Validated input
    let raw = Input.new("hello");
    let validated = validate(raw);
    match validated {
        Some(v) => {
            let result = use_validated(v);
            assert(result == "Valid: hello");
        },
        None => assert(false),
    }

    let empty = Input.new("");
    assert(validate(empty) == None);

    print("Phantom type tests passed!");
}
