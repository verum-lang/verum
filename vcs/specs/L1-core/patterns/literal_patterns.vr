// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: patterns, literals
//
// Tests literal pattern matching on integers, characters, strings, and booleans.

fn match_int(x: Int) -> Text {
    match x {
        0 => "zero",
        1 => "one",
        42 => "answer",
        -1 => "minus one",
        _ => "other",
    }
}

fn match_char(c: Char) -> Text {
    match c {
        'a' => "letter a",
        'b' => "letter b",
        '0' => "digit zero",
        '\n' => "newline",
        _ => "other char",
    }
}

fn match_bool(b: Bool) -> Text {
    match b {
        true => "yes",
        false => "no",
    }
}

fn match_string(s: Text) -> Int {
    match s {
        "hello" => 1,
        "world" => 2,
        "" => 0,
        _ => -1,
    }
}

fn match_float(f: Float) -> Text {
    match f {
        0.0 => "zero",
        1.0 => "one",
        3.14159 => "pi",
        _ => "other",
    }
}

// Hex, binary, octal literals in patterns
fn match_hex(x: Int) -> Text {
    match x {
        0x00 => "zero",
        0xFF => "max byte",
        0xDEAD => "dead",
        _ => "other",
    }
}

fn match_binary(x: Int) -> Text {
    match x {
        0b0000 => "zero",
        0b1111 => "fifteen",
        0b1010 => "ten",
        _ => "other",
    }
}

fn match_octal(x: Int) -> Text {
    match x {
        0o0 => "zero",
        0o777 => "all permissions",
        0o644 => "file permissions",
        _ => "other",
    }
}

// Escape sequences in char patterns
fn match_escape_char(c: Char) -> Text {
    match c {
        '\t' => "tab",
        '\r' => "carriage return",
        '\\' => "backslash",
        '\'' => "single quote",
        '\"' => "double quote",
        '\0' => "null",
        _ => "other",
    }
}

// Unicode escape in char patterns
fn match_unicode_char(c: Char) -> Text {
    match c {
        '\u{0041}' => "A",
        '\u{03B1}' => "alpha",
        '\u{1F600}' => "grinning face",
        _ => "other",
    }
}

// Multiple literal matches with same type
fn match_status_code(code: Int) -> Text {
    match code {
        200 => "OK",
        201 => "Created",
        204 => "No Content",
        400 => "Bad Request",
        401 => "Unauthorized",
        403 => "Forbidden",
        404 => "Not Found",
        500 => "Internal Server Error",
        502 => "Bad Gateway",
        503 => "Service Unavailable",
        _ => "Unknown",
    }
}

// Edge case: very large integers
fn match_large_int(x: Int) -> Text {
    match x {
        9223372036854775807 => "max i64",
        -9223372036854775808 => "min i64",
        _ => "other",
    }
}

// Edge case: special float values
fn match_special_float(f: Float) -> Text {
    match f {
        -0.0 => "negative zero",
        1.0e308 => "very large",
        1.0e-308 => "very small",
        _ => "other",
    }
}

fn main() {
    // Integer literals
    assert(match_int(0) == "zero");
    assert(match_int(1) == "one");
    assert(match_int(42) == "answer");
    assert(match_int(-1) == "minus one");
    assert(match_int(100) == "other");

    // Character literals
    assert(match_char('a') == "letter a");
    assert(match_char('b') == "letter b");
    assert(match_char('0') == "digit zero");
    assert(match_char('\n') == "newline");
    assert(match_char('z') == "other char");

    // Boolean literals
    assert(match_bool(true) == "yes");
    assert(match_bool(false) == "no");

    // Text literals
    assert(match_string("hello") == 1);
    assert(match_string("world") == 2);
    assert(match_string("") == 0);
    assert(match_string("unknown") == -1);

    // Float literals
    assert(match_float(0.0) == "zero");
    assert(match_float(3.14159) == "pi");

    // Hex literals
    assert(match_hex(0xFF) == "max byte");
    assert(match_hex(0xDEAD) == "dead");

    // Binary literals
    assert(match_binary(0b1111) == "fifteen");
    assert(match_binary(0b1010) == "ten");

    // Octal literals
    assert(match_octal(0o777) == "all permissions");
    assert(match_octal(0o644) == "file permissions");

    // Escape chars
    assert(match_escape_char('\t') == "tab");
    assert(match_escape_char('\\') == "backslash");

    // Unicode chars
    assert(match_unicode_char('\u{0041}') == "A");

    // Status codes
    assert(match_status_code(200) == "OK");
    assert(match_status_code(404) == "Not Found");
    assert(match_status_code(999) == "Unknown");
}
