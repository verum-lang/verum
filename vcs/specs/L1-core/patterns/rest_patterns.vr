// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: patterns, rest
//
// Tests rest patterns with `..` for matching remaining elements in sequences.

type Maybe<T> is
    | Some(T)
    | None;

/// Prepend an element to a list (helper to avoid spread-in-expression)
fn cons<T>(head: T, tail: List<T>) -> List<T> {
    let mut result: List<T> = [];
    result.push(head);
    let mut t = tail;
    result.append(&mut t);
    result
}

// Basic rest pattern: [first, ..rest]
fn first_and_rest<T>(list: List<T>) -> Maybe<(T, List<T>)> {
    match list {
        [first, ..rest] => Some((first, rest)),
        [] => None,
    }
}

// Rest at beginning: [..init, last]
fn init_and_last<T>(list: List<T>) -> Maybe<(List<T>, T)> {
    match list {
        [..init, last] => Some((init, last)),
        [] => None,
    }
}

// Rest in middle: [first, ..middle, last]
fn split_ends<T>(list: List<T>) -> Maybe<(T, List<T>, T)> {
    match list {
        [first, ..middle, last] if list.len() >= 2 => Some((first, middle, last)),
        _ => None,
    }
}

// Head function
fn head<T>(list: List<T>) -> Maybe<T> {
    match list {
        [first, ..] => Some(first),
        [] => None,
    }
}

// Tail function
fn tail<T>(list: List<T>) -> Maybe<List<T>> {
    match list {
        [_, ..rest] => Some(rest),
        [] => None,
    }
}

// Last function
fn last<T>(list: List<T>) -> Maybe<T> {
    match list {
        [.., last] => Some(last),
        [] => None,
    }
}

// Init function (all but last)
fn init<T>(list: List<T>) -> Maybe<List<T>> {
    match list {
        [..init, _] => Some(init),
        [] => None,
    }
}

// Take first n elements using rest pattern
@allow(unbounded_recursion)
fn take<T>(list: List<T>, n: Int) -> List<T> {
    match (list, n) {
        (_, 0) => [],
        ([], _) => [],
        ([first, ..rest], n) => cons(first, take(rest, n - 1)),
    }
}

// Drop first n elements
@allow(unbounded_recursion)
fn drop<T>(list: List<T>, n: Int) -> List<T> {
    match (list, n) {
        (list, 0) => list,
        ([], _) => [],
        ([_, ..rest], n) => drop(rest, n - 1),
    }
}

// Sum with rest pattern
@allow(unbounded_recursion)
fn sum(list: List<Int>) -> Int {
    match list {
        [] => 0,
        [head, ..tail] => head + sum(tail),
    }
}

// Length with rest pattern
@allow(unbounded_recursion)
fn length<T>(list: List<T>) -> Int {
    match list {
        [] => 0,
        [_, ..rest] => 1 + length(rest),
    }
}

// Map with rest pattern
@allow(unbounded_recursion)
fn map<A, B>(list: List<A>, f: fn(A) -> B) -> List<B> {
    match list {
        [] => [],
        [head, ..tail] => cons(f(head), map(tail, f)),
    }
}

// Filter with rest pattern
@allow(unbounded_recursion)
fn filter<T: Clone>(list: List<T>, pred: fn(T) -> Bool) -> List<T> {
    match list {
        [] => [],
        [head, ..tail] if pred(head.clone()) => cons(head, filter(tail, pred)),
        [_, ..tail] => filter(tail, pred),
    }
}

// Fold left with rest pattern
@allow(unbounded_recursion)
fn fold_left<A, B>(list: List<A>, init: B, f: fn(B, A) -> B) -> B {
    match list {
        [] => init,
        [head, ..tail] => fold_left(tail, f(init, head), f),
    }
}

// Reverse using fold_left (builds reversed list by prepending each element)
fn reverse<T>(list: List<T>) -> List<T> {
    fold_left(list, [], |acc, head| cons(head, acc))
}

// Zip two lists
@allow(unbounded_recursion)
fn zip<A, B>(a: List<A>, b: List<B>) -> List<(A, B)> {
    match (a, b) {
        ([x, ..xs], [y, ..ys]) => cons((x, y), zip(xs, ys)),
        _ => [],
    }
}

// Pattern matching specific positions with rest
fn classify_list(list: List<Int>) -> Text {
    match list {
        [] => "empty",
        [_] => "singleton",
        [a, b] => "pair",
        [a, b, c] => "triple",
        [a, .._, z] => f"long list from {a} to {z}",
    }
}

// Sliding window with rest
@allow(unbounded_recursion)
fn pairs<T: Clone>(list: List<T>) -> List<(T, T)> {
    match list {
        [a, b, ..rest] => cons((a.clone(), b.clone()), pairs(cons(b.clone(), rest))),
        _ => [],
    }
}

// Find element with rest pattern
@allow(unbounded_recursion)
fn find<T: Clone>(list: List<T>, pred: fn(T) -> Bool) -> Maybe<T> {
    match list {
        [] => None,
        [head, ..] if pred(head.clone()) => Some(head),
        [_, ..tail] => find(tail, pred),
    }
}

// Any element matches
@allow(unbounded_recursion)
fn any<T: Clone>(list: List<T>, pred: fn(T) -> Bool) -> Bool {
    match list {
        [] => false,
        [head, ..] if pred(head.clone()) => true,
        [_, ..tail] => any(tail, pred),
    }
}

// All elements match
@allow(unbounded_recursion)
fn all<T: Clone>(list: List<T>, pred: fn(T) -> Bool) -> Bool {
    match list {
        [] => true,
        [head, ..] if !pred(head.clone()) => false,
        [_, ..tail] => all(tail, pred),
    }
}

// Partition with rest pattern
@allow(unbounded_recursion)
fn partition<T: Clone>(list: List<T>, pred: fn(T) -> Bool) -> (List<T>, List<T>) {
    match list {
        [] => ([], []),
        [head, ..tail] => {
            let (yes, no) = partition(tail, pred);
            if pred(head.clone()) {
                (cons(head, yes), no)
            } else {
                (yes, cons(head, no))
            }
        }
    }
}

// Rest with named binding
fn named_rest(list: List<Int>) -> (Int, List<Int>, Int) {
    match list {
        [first, ..middle, last] => (first, middle, last),
        [single] => (single, [], single),
        [] => (0, [], 0),
    }
}

// Rest with guard
@allow(unbounded_recursion)
fn filtered_rest(list: List<Int>) -> List<Int> {
    match list {
        [x, ..rest] if x > 0 => cons(x, filtered_rest(rest)),
        [_, ..rest] => filtered_rest(rest),
        [] => [],
    }
}

// Multiple patterns with rest
fn categorize_with_rest(list: List<Int>) -> Text {
    match list {
        [] => "empty",
        [_] => "one",
        [_, _] => "two",
        [_, _, _] => "three",
        [a, b, ..rest] if a < b => "ascending start",
        [a, b, ..rest] if a > b => "descending start",
        [a, b, ..rest] => "equal start",
    }
}

fn main() {
    let list = [1, 2, 3, 4, 5];

    // First and rest
    match first_and_rest(list) {
        Some((first, rest)) => {
            assert(first == 1);
            assert(rest == [2, 3, 4, 5]);
        }
        None => unreachable(),
    }

    // Init and last
    match init_and_last(list) {
        Some((init_part, last_elem)) => {
            assert(init_part == [1, 2, 3, 4]);
            assert(last_elem == 5);
        }
        None => unreachable(),
    }

    // Split ends
    match split_ends(list) {
        Some((f, m, l)) => {
            assert(f == 1);
            assert(m == [2, 3, 4]);
            assert(l == 5);
        }
        None => unreachable(),
    }

    // Head, tail, last, init
    assert(head(list) == Some(1));
    assert(tail(list) == Some([2, 3, 4, 5]));
    assert(last(list) == Some(5));
    assert(init(list) == Some([1, 2, 3, 4]));

    // Take and drop
    assert(take(list, 3) == [1, 2, 3]);
    assert(drop(list, 2) == [3, 4, 5]);

    // Sum and length
    assert(sum(list) == 15);
    assert(length(list) == 5);

    // Map
    let doubled = map(list, |x| x * 2);
    assert(doubled == [2, 4, 6, 8, 10]);

    // Filter
    let evens = filter(list, |x| x % 2 == 0);
    assert(evens == [2, 4]);

    // Fold
    let product = fold_left(list, 1, |acc, x| acc * x);
    assert(product == 120);

    // Reverse
    assert(reverse(list) == [5, 4, 3, 2, 1]);

    // Zip
    let zipped = zip([1, 2, 3], ["a", "b", "c"]);
    assert(zipped == [(1, "a"), (2, "b"), (3, "c")]);

    // Classification
    assert(classify_list([]) == "empty");
    assert(classify_list([1]) == "singleton");
    assert(classify_list([1, 2]) == "pair");
    assert(classify_list([1, 2, 3]) == "triple");
    assert(classify_list([1, 2, 3, 4, 5]) == "long list from 1 to 5");

    // Find
    assert(find(list, |x| x > 3) == Some(4));
    assert(find(list, |x| x > 10) == None);

    // Any and all
    assert(any(list, |x| x == 3) == true);
    assert(any(list, |x| x == 10) == false);
    assert(all(list, |x| x > 0) == true);
    assert(all(list, |x| x > 3) == false);

    // Partition
    let (evens2, odds) = partition(list, |x| x % 2 == 0);
    assert(evens2 == [2, 4]);
    assert(odds == [1, 3, 5]);

    // Named rest
    let (f2, m2, l2) = named_rest([1, 2, 3, 4, 5]);
    assert(f2 == 1 && l2 == 5);

    // Categorize with rest
    assert(categorize_with_rest([]) == "empty");
    assert(categorize_with_rest([1]) == "one");
    assert(categorize_with_rest([1, 2, 3, 4]) == "ascending start");
    assert(categorize_with_rest([4, 2, 1]) == "descending start");
}
