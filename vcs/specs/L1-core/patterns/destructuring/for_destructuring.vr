// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: patterns, destructuring, for, loop
//
// Tests destructuring patterns in for loops.
// For loop destructuring enables direct extraction from iterated collections.

//------------------------------------------------------------------------------
// Basic Tuple Destructuring in For
//------------------------------------------------------------------------------

/// Destructure pair in for loop.
fn for_pairs(pairs: List<(Int, Int)>) -> Int {
    let mut sum = 0;
    for (a, b) in pairs {
        sum = sum + a + b;
    }
    sum
}

/// Destructure triple in for loop.
fn for_triples(triples: List<(Int, Int, Int)>) -> Int {
    let mut sum = 0;
    for (x, y, z) in triples {
        sum = sum + x + y + z;
    }
    sum
}

/// Nested tuple in for loop.
fn for_nested_tuples(items: List<((Int, Int), Int)>) -> Int {
    let mut sum = 0;
    for ((a, b), c) in items {
        sum = sum + a + b + c;
    }
    sum
}

//------------------------------------------------------------------------------
// Tuple with Index Pattern
//------------------------------------------------------------------------------

/// Enumerate with destructure.
fn for_enumerate(items: List<Int>) -> Int {
    let mut weighted_sum = 0;
    let mut index = 0;
    for value in items {
        weighted_sum = weighted_sum + index * value;
        index = index + 1;
    }
    weighted_sum
}

/// Enumerate pairs.
fn for_enumerate_pairs(pairs: List<(Int, Int)>) -> Int {
    let mut sum = 0;
    let mut i = 0;
    for (a, b) in pairs {
        sum = sum + i + a + b;
        i = i + 1;
    }
    sum
}

//------------------------------------------------------------------------------
// Struct Destructuring in For
//------------------------------------------------------------------------------

type Point is {
    x: Int,
    y: Int,
};

type Person is {
    name: Text,
    age: Int,
};

/// Destructure struct in for loop.
fn for_points(points: List<Point>) -> Int {
    let mut sum = 0;
    for Point { x, y } in points {
        sum = sum + x + y;
    }
    sum
}

/// Struct with field rename in for.
fn for_points_renamed(points: List<Point>) -> Int {
    let mut product = 0;
    for Point { x: px, y: py } in points {
        product = product + px * py;
    }
    product
}

/// Struct with rest in for.
fn for_ages(people: List<Person>) -> Int {
    let mut total_age = 0;
    for Person { age, .. } in people {
        total_age = total_age + age;
    }
    total_age
}

/// Nested struct in for.
type Line is {
    start: Point,
    end: Point,
};

fn for_lines(lines: List<Line>) -> Int {
    let mut total_length_sq = 0;
    for Line { start: Point { x: x1, y: y1 }, end: Point { x: x2, y: y2 } } in lines {
        let dx = x2 - x1;
        let dy = y2 - y1;
        total_length_sq = total_length_sq + dx * dx + dy * dy;
    }
    total_length_sq
}

//------------------------------------------------------------------------------
// Map Entry Destructuring
//------------------------------------------------------------------------------

/// Key-value pairs from map.
fn for_map_entries(map: Map<Text, Int>) -> Int {
    let mut sum = 0;
    for value in map.values() {
        sum = sum + *value;
    }
    sum
}

/// Map with key length sum.
fn for_map_keys(map: Map<Text, Int>) -> Int {
    let mut key_length_sum = 0;
    for key in map.keys() {
        key_length_sum = key_length_sum + key.len() as Int;
    }
    key_length_sum
}

/// Nested map values.
fn for_nested_map(map: Map<Text, (Int, Int)>) -> Int {
    let mut sum = 0;
    for pair in map.values() {
        let (a, b) = *pair;
        sum = sum + a + b;
    }
    sum
}

//------------------------------------------------------------------------------
// Wildcard Patterns in For
//------------------------------------------------------------------------------

/// Ignore first tuple element.
fn for_ignore_first(pairs: List<(Int, Int)>) -> Int {
    let mut sum = 0;
    for (_, b) in pairs {
        sum = sum + b;
    }
    sum
}

/// Ignore second tuple element.
fn for_ignore_second(pairs: List<(Int, Int)>) -> Int {
    let mut sum = 0;
    for (a, _) in pairs {
        sum = sum + a;
    }
    sum
}

/// Ignore all - just count.
fn for_count(items: List<(Int, Int)>) -> Int {
    let mut count = 0;
    for (_, _) in items {
        count = count + 1;
    }
    count
}

/// Partial struct destructure.
fn for_partial_struct(points: List<Point>) -> Int {
    let mut x_sum = 0;
    for Point { x, .. } in points {
        x_sum = x_sum + x;
    }
    x_sum
}

//------------------------------------------------------------------------------
// Range with Destructuring
//------------------------------------------------------------------------------

/// Zip with range.
fn for_zip_range(items: List<Text>) -> Int {
    let mut weighted_len = 0;
    let mut i = 0;
    for item in items {
        weighted_len = weighted_len + (i + 1) * item.len();
        i = i + 1;
    }
    weighted_len
}

//------------------------------------------------------------------------------
// Nested For with Destructuring
//------------------------------------------------------------------------------

/// Nested for loops with destructure.
fn for_nested(matrix: List<List<(Int, Int)>>) -> Int {
    let mut sum = 0;
    for row in matrix {
        for (a, b) in row {
            sum = sum + a + b;
        }
    }
    sum
}

/// Double enumeration.
fn for_double_enumerate(rows: List<List<Int>>) -> Int {
    let mut weighted = 0;
    let mut row_idx = 0;
    for row in rows {
        let mut col_idx = 0;
        for value in row {
            weighted = weighted + (row_idx + col_idx) * value;
            col_idx = col_idx + 1;
        }
        row_idx = row_idx + 1;
    }
    weighted
}

//------------------------------------------------------------------------------
// For with Guard-like Conditions
//------------------------------------------------------------------------------

/// Continue based on destructured value.
fn for_with_continue(pairs: List<(Int, Int)>) -> Int {
    let mut sum = 0;
    for (a, b) in pairs {
        if a < 0 { continue; }
        sum = sum + a + b;
    }
    sum
}

/// Break based on destructured value.
fn for_with_break(pairs: List<(Int, Int)>) -> Int {
    let mut sum = 0;
    for (a, b) in pairs {
        if a == 0 && b == 0 { break; }
        sum = sum + a + b;
    }
    sum
}

//------------------------------------------------------------------------------
// Complex For Patterns
//------------------------------------------------------------------------------

type Transaction is {
    from: Text,
    to: Text,
    amount: Int,
};

/// Complex struct iteration.
fn sum_transactions(transactions: List<Transaction>) -> Int {
    let mut total = 0;
    for Transaction { amount, .. } in transactions {
        total = total + amount;
    }
    total
}

/// Filter by destructured field.
fn sum_from(transactions: List<Transaction>, sender: Text) -> Int {
    let mut total = 0;
    for Transaction { from, amount, .. } in transactions {
        if from == sender {
            total = total + amount;
        }
    }
    total
}

type Maybe<T> is
    | Some(T)
    | None;

/// Iteration with Option.
fn for_options(items: List<Maybe<Int>>) -> Int {
    let mut sum = 0;
    for item in items {
        match item {
            Some(x) => { sum = sum + x; },
            None => {},
        }
    }
    sum
}

//------------------------------------------------------------------------------
// Tests
//------------------------------------------------------------------------------

@test
fn main() {
    // Basic pairs
    let pairs: List<(Int, Int)> = [(1, 2), (3, 4), (5, 6)];
    assert(for_pairs(pairs) == 21);

    // Triples
    let triples: List<(Int, Int, Int)> = [(1, 2, 3), (4, 5, 6)];
    assert(for_triples(triples) == 21);

    // Points
    let points: List<Point> = [Point { x: 1, y: 2 }, Point { x: 3, y: 4 }];
    assert(for_points(points) == 10);
    assert(for_points_renamed(points) == 14);  // 1*2 + 3*4

    // Partial destructure
    assert(for_partial_struct(points) == 4);  // 1 + 3

    // People
    let people: List<Person> = [
        Person { name: "Alice", age: 30 },
        Person { name: "Bob", age: 25 }
    ];
    assert(for_ages(people) == 55);

    // Wildcards
    assert(for_ignore_first(pairs) == 12);  // 2 + 4 + 6
    assert(for_ignore_second(pairs) == 9);  // 1 + 3 + 5
    assert(for_count(pairs) == 3);

    // Continue/break
    let mixed: List<(Int, Int)> = [(1, 2), (-1, 3), (4, 5)];
    assert(for_with_continue(mixed) == 12);  // (1+2) + (4+5), skip -1

    let with_sentinel: List<(Int, Int)> = [(1, 2), (3, 4), (0, 0), (5, 6)];
    assert(for_with_break(with_sentinel) == 10);  // (1+2) + (3+4), stop at (0,0)

    // Transactions
    let txs: List<Transaction> = [
        Transaction { from: "Alice", to: "Bob", amount: 100 },
        Transaction { from: "Bob", to: "Carol", amount: 50 }
    ];
    assert(sum_transactions(txs) == 150);
    assert(sum_from(txs, "Alice") == 100);

    // Options
    let opts: List<Maybe<Int>> = [Some(1), None, Some(2), None, Some(3)];
    assert(for_options(opts) == 6);
}
