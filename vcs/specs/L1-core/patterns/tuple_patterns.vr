// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: patterns, tuples
//
// Tests tuple pattern matching with various arities and nesting.

fn swap<A, B>(pair: (A, B)) -> (B, A) {
    let (a, b) = pair;
    (b, a)
}

fn first<A, B>(pair: (A, B)) -> A {
    let (a, _) = pair;
    a
}

fn second<A, B>(pair: (A, B)) -> B {
    let (_, b) = pair;
    b
}

fn unpack_triple<A, B, C>(triple: (A, B, C)) -> (C, B, A) {
    let (a, b, c) = triple;
    (c, b, a)
}

fn sum_pair(pair: (Int, Int)) -> Int {
    match pair {
        (a, b) => a + b,
    }
}

fn match_specific_tuple(pair: (Int, Int)) -> Text {
    match pair {
        (0, 0) => "origin",
        (0, _) => "on y-axis",
        (_, 0) => "on x-axis",
        (x, y) if x == y => "on diagonal",
        _ => "elsewhere",
    }
}

fn nested_tuples(data: ((Int, Int), (Int, Int))) -> Int {
    match data {
        ((a, b), (c, d)) => a + b + c + d,
    }
}

fn deeply_nested(data: (((Int, Int), Int), Int)) -> Int {
    let (((a, b), c), d) = data;
    a + b + c + d
}

fn single_element_tuple(x: (Int, Int)) -> Int {
    let (value, _) = x;
    value
}

fn quadruple<A, B, C, D>(q: (A, B, C, D)) -> (D, C, B, A) {
    let (a, b, c, d) = q;
    (d, c, b, a)
}

fn mixed_tuple_match(data: (Int, Text, Bool)) -> Text {
    match data {
        (n, s, true) if n > 0 => s,
        (n, _, false) if n < 0 => "negative false",
        (0, s, _) => "zero: " + s,
        _ => "default",
    }
}

// Large tuple pattern
fn large_tuple(t: (Int, Int, Int, Int, Int, Int, Int, Int)) -> Int {
    match t {
        (a, b, c, d, e, f, g, h) => a + b + c + d + e + f + g + h,
    }
}

// Tuple with all same types
fn all_same_type(t: (Int, Int, Int)) -> Int {
    match t {
        (a, b, c) if a == b && b == c => a,
        (a, b, c) if a == b => a,
        (a, _, _) => a,
    }
}

// Tuple pattern in function parameter
fn tuple_param((a, b): (Int, Int)) -> Int {
    a + b
}

// Nested tuple with mixed types
fn complex_nested(data: ((Int, Text), (Bool, Float))) -> Text {
    match data {
        ((n, s), (true, f)) => f"{s}: {n}",
        ((n, s), (false, _)) => "false: " + s,
    }
}

fn main() {
    // Basic swap
    let (x, y) = swap((1, 2));
    assert(x == 2 && y == 1);

    // Destructuring in let
    let (a, b, c) = (1, 2, 3);
    assert(a == 1 && b == 2 && c == 3);

    // First and second
    assert(first(("hello", 42)) == "hello");
    assert(second(("hello", 42)) == 42);

    // Triple unpacking
    let (z, y2, x2) = unpack_triple((1, 2, 3));
    assert(x2 == 1 && y2 == 2 && z == 3);

    // Sum pair
    assert(sum_pair((3, 4)) == 7);

    // Specific tuple matching
    assert(match_specific_tuple((0, 0)) == "origin");
    assert(match_specific_tuple((0, 5)) == "on y-axis");
    assert(match_specific_tuple((5, 0)) == "on x-axis");
    assert(match_specific_tuple((3, 3)) == "on diagonal");
    assert(match_specific_tuple((1, 2)) == "elsewhere");

    // Nested tuples
    assert(nested_tuples(((1, 2), (3, 4))) == 10);
    assert(deeply_nested((((1, 2), 3), 4)) == 10);

    // Single element tuple (workaround: use pair)
    assert(single_element_tuple((42, 0)) == 42);

    // Quadruple
    let (d, c2, b2, a2) = quadruple((1, 2, 3, 4));
    assert(a2 == 1 && b2 == 2 && c2 == 3 && d == 4);

    // Mixed tuple match
    assert(mixed_tuple_match((1, "success", true)) == "success");
    assert(mixed_tuple_match((-1, "x", false)) == "negative false");
    assert(mixed_tuple_match((0, "zero", true)) == "zero: zero");

    // Large tuple
    assert(large_tuple((1, 2, 3, 4, 5, 6, 7, 8)) == 36);

    // Tuple param
    assert(tuple_param((3, 4)) == 7);
}
