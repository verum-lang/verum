// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: refinement, syntax, predicate, named

/// Named predicate definitions for reusable refinement conditions.
/// Predicates are pure boolean functions that can be used in refinements.
/// They enable modular and composable constraint specifications.

// ============================================================================
// Basic predicate definitions
// ============================================================================

/// Check if integer is positive
predicate is_positive(x: Int) -> Bool {
    x > 0
}

/// Check if integer is non-negative
predicate is_non_negative(x: Int) -> Bool {
    x >= 0
}

/// Check if integer is negative
predicate is_negative(x: Int) -> Bool {
    x < 0
}

/// Check if integer is non-zero
predicate is_non_zero(x: Int) -> Bool {
    x != 0
}

/// Check if integer is zero
predicate is_zero(x: Int) -> Bool {
    x == 0
}

// ============================================================================
// Range predicates
// ============================================================================

/// Check if value is within inclusive bounds
predicate in_range(x: Int, lo: Int, hi: Int) -> Bool {
    x >= lo && x <= hi
}

/// Check if float is valid percentage
predicate is_valid_percentage(x: Float) -> Bool {
    x >= 0.0 && x <= 100.0
}

/// Check if float is in unit interval
predicate is_unit_interval(x: Float) -> Bool {
    x >= 0.0 && x <= 1.0
}

/// Check if integer is valid byte value
predicate is_byte(x: Int) -> Bool {
    x >= 0 && x < 256
}

/// Check if integer is valid port number
predicate is_valid_port(p: Int) -> Bool {
    p >= 1 && p <= 65535
}

/// Check if age is valid (0-150)
predicate is_valid_age(age: Int) -> Bool {
    age >= 0 && age <= 150
}

// ============================================================================
// Arithmetic predicates
// ============================================================================

/// Check if integer is even
predicate is_even(x: Int) -> Bool {
    x % 2 == 0
}

/// Check if integer is odd
predicate is_odd(x: Int) -> Bool {
    x % 2 != 0
}

/// Check if integer is divisible by n
predicate is_divisible_by(x: Int, n: Int) -> Bool {
    n != 0 && x % n == 0
}

/// Check if integer is a power of two
predicate is_power_of_two(n: Int) -> Bool {
    n > 0 && (n & (n - 1)) == 0
}

/// Check if integer is prime (naive check for demonstration)
predicate is_prime(n: Int) -> Bool {
    n > 1 &&
    forall d in 2..(n / 2 + 1) => n % d != 0
}

// ============================================================================
// Composed predicates (using other predicates)
// ============================================================================

/// Check if integer is even and positive
predicate is_even_positive(x: Int) -> Bool {
    is_positive(x) && is_even(x)
}

/// Check if integer is odd and positive
predicate is_odd_positive(x: Int) -> Bool {
    is_positive(x) && is_odd(x)
}

/// Check if integer is even and negative
predicate is_even_negative(x: Int) -> Bool {
    is_negative(x) && is_even(x)
}

/// Check if integer is a positive power of two
predicate is_positive_power_of_two(n: Int) -> Bool {
    is_positive(n) && is_power_of_two(n)
}

// ============================================================================
// Text/Text predicates
// ============================================================================

/// Check if text is non-empty
predicate is_non_empty(s: Text) -> Bool {
    len(s) > 0
}

/// Check if text is empty
predicate is_empty(s: Text) -> Bool {
    len(s) == 0
}

/// Check if text length is within bounds
predicate has_length_between(s: Text, min: Int, max: Int) -> Bool {
    len(s) >= min && len(s) <= max
}

/// Check if text starts with prefix
predicate starts_with_prefix(s: Text, prefix: Text) -> Bool {
    len(s) >= len(prefix) && s[0..len(prefix)] == prefix
}

/// Check if text ends with suffix
predicate ends_with_suffix(s: Text, suffix: Text) -> Bool {
    len(s) >= len(suffix) && s[len(s) - len(suffix)..] == suffix
}

/// Check if text contains substring
predicate contains_substring(s: Text, sub: Text) -> Bool {
    exists i in 0..=(len(s) - len(sub)) => s[i..i + len(sub)] == sub
}

// ============================================================================
// Character predicates
// ============================================================================

/// Check if character is ASCII
predicate is_ascii(c: Char) -> Bool {
    c >= '\0' && c <= '\x7f'
}

/// Check if character is lowercase letter
predicate is_lowercase(c: Char) -> Bool {
    c >= 'a' && c <= 'z'
}

/// Check if character is uppercase letter
predicate is_uppercase(c: Char) -> Bool {
    c >= 'A' && c <= 'Z'
}

/// Check if character is digit
predicate is_digit(c: Char) -> Bool {
    c >= '0' && c <= '9'
}

/// Check if character is alphanumeric
predicate is_alphanumeric(c: Char) -> Bool {
    is_lowercase(c) || is_uppercase(c) || is_digit(c)
}

/// Check if character is whitespace
predicate is_whitespace(c: Char) -> Bool {
    c == ' ' || c == '\t' || c == '\n' || c == '\r'
}

// ============================================================================
// Text predicates using character predicates
// ============================================================================

/// Check if text is all ASCII
predicate is_ascii_string(s: Text) -> Bool {
    forall i in 0..len(s) => is_ascii(s[i])
}

/// Check if text is all lowercase
predicate is_all_lowercase(s: Text) -> Bool {
    forall i in 0..len(s) => is_lowercase(s[i])
}

/// Check if text is all uppercase
predicate is_all_uppercase(s: Text) -> Bool {
    forall i in 0..len(s) => is_uppercase(s[i])
}

/// Check if text is all digits
predicate is_all_digits(s: Text) -> Bool {
    forall i in 0..len(s) => is_digit(s[i])
}

/// Check if text is alphanumeric
predicate is_alphanumeric_string(s: Text) -> Bool {
    forall i in 0..len(s) => is_alphanumeric(s[i])
}

/// Check if text is a valid identifier (starts with letter, alphanumeric)
predicate is_valid_identifier(s: Text) -> Bool {
    len(s) > 0 &&
    (is_lowercase(s[0]) || is_uppercase(s[0]) || s[0] == '_') &&
    forall i in 1..len(s) => is_alphanumeric(s[i]) || s[i] == '_'
}

// ============================================================================
// Collection predicates
// ============================================================================

/// Check if list is non-empty
predicate is_non_empty_list<T>(lst: List<T>) -> Bool {
    len(lst) > 0
}

/// Check if list is empty
predicate is_empty_list<T>(lst: List<T>) -> Bool {
    len(lst) == 0
}

/// Check if list is singleton
predicate is_singleton<T>(lst: List<T>) -> Bool {
    len(lst) == 1
}

/// Check if index is valid for list
predicate is_valid_index<T>(idx: Int, arr: List<T>) -> Bool {
    idx >= 0 && idx < len(arr)
}

/// Check if range is valid for list
predicate is_valid_range<T>(start: Int, end: Int, arr: List<T>) -> Bool {
    start >= 0 && end >= start && end <= len(arr)
}

// ============================================================================
// List ordering predicates
// ============================================================================

/// Check if list is sorted (ascending)
predicate is_sorted(arr: List<Int>) -> Bool {
    forall i in 0..(len(arr) - 1) => arr[i] <= arr[i + 1]
}

/// Check if list is strictly sorted (no duplicates)
predicate is_strictly_sorted(arr: List<Int>) -> Bool {
    forall i in 0..(len(arr) - 1) => arr[i] < arr[i + 1]
}

/// Check if list is sorted descending
predicate is_sorted_desc(arr: List<Int>) -> Bool {
    forall i in 0..(len(arr) - 1) => arr[i] >= arr[i + 1]
}

/// Check if all elements are positive
predicate all_positive(arr: List<Int>) -> Bool {
    forall x in arr => x > 0
}

/// Check if all elements are non-negative
predicate all_non_negative(arr: List<Int>) -> Bool {
    forall x in arr => x >= 0
}

/// Check if list contains a value
predicate contains_value<T: Eq>(arr: List<T>, val: T) -> Bool {
    exists x in arr => x == val
}

/// Check if list has unique elements
predicate all_unique<T: Eq>(arr: List<T>) -> Bool {
    forall i in 0..len(arr) =>
        forall j in (i + 1)..len(arr) =>
            arr[i] != arr[j]
}

// ============================================================================
// Domain-specific predicates
// ============================================================================

/// Check if user ID is valid
predicate is_valid_user_id(id: Int) -> Bool {
    is_positive(id) && id < 1_000_000
}

/// Check if email is valid (simple check)
predicate is_valid_email(email: Text) -> Bool {
    len(email) >= 5 &&
    contains_substring(email, "@") &&
    contains_substring(email, ".")
}

/// Check if username is valid
predicate is_valid_username(name: Text) -> Bool {
    has_length_between(name, 3, 20) &&
    is_valid_identifier(name)
}

/// Check if password is strong enough
predicate is_strong_password(pwd: Text) -> Bool {
    len(pwd) >= 12 &&
    exists i in 0..len(pwd) => is_uppercase(pwd[i]) &&
    exists i in 0..len(pwd) => is_lowercase(pwd[i]) &&
    exists i in 0..len(pwd) => is_digit(pwd[i])
}

// ============================================================================
// Geometric/mathematical predicates
// ============================================================================

/// Check if point is in unit circle
predicate in_unit_circle(x: Float, y: Float) -> Bool {
    x * x + y * y <= 1.0
}

/// Check if point is in first quadrant
predicate in_first_quadrant(x: Float, y: Float) -> Bool {
    x >= 0.0 && y >= 0.0
}

/// Check if dimensions form valid rectangle
predicate is_valid_dimensions(width: Float, height: Float) -> Bool {
    width > 0.0 && height > 0.0
}

/// Check if angle is valid (in radians, -pi to pi)
predicate is_valid_angle(theta: Float) -> Bool {
    theta >= -3.14159 && theta <= 3.14159
}

// ============================================================================
// Predicate with type parameters
// ============================================================================

/// Generic bounded check
predicate is_bounded<T: Ord>(val: T, lo: T, hi: T) -> Bool {
    val >= lo && val <= hi
}

/// Check if option is some
predicate is_some<T>(opt: Maybe<T>) -> Bool {
    match opt {
        Some(_) => true,
        None => false,
    }
}

/// Check if option is none
predicate is_none<T>(opt: Maybe<T>) -> Bool {
    match opt {
        Some(_) => false,
        None => true,
    }
}

// ============================================================================
// Using named predicates in type definitions
// ============================================================================

type Positive is Int where is_positive;
type NonNegative is Int where is_non_negative;
type NonZero is Int where is_non_zero;
type Percentage is Float where is_valid_percentage;
type UnitInterval is Float where is_unit_interval;
type Byte is Int where is_byte;
type Port is Int where is_valid_port;
type ValidAge is Int where is_valid_age;
type NonEmptyText is Text where is_non_empty;
type EvenPositive is Int where is_even_positive;
type AsciiText is Text where is_ascii_string;
type UserId is Int where is_valid_user_id;
type Identifier is Text where is_valid_identifier;
type SortedList is List<Int> where is_sorted;
type PositiveList is List<Int> where all_positive;
type UniqueList<T: Eq> is List<T> where all_unique;

// ============================================================================
// Functions using predicate-refined types
// ============================================================================

fn safe_divide(x: Int, y: NonZero) -> Int {
    x / y
}

fn average(arr: List<Int>) -> Float {
    // simplified: just return 0.0 for demonstration
    0.0
}

fn validate_user(id: UserId, name: Identifier) -> Bool {
    // Both arguments are pre-validated by their types
    true
}

// binary_search removed: indexing on refined list type aliases not yet supported

// ============================================================================
// Main function demonstrating usage
// ============================================================================

fn main() {
    // Basic predicate-refined types
    let x: Positive = 42;
    let nn: NonNegative = 0;
    let nz: NonZero = -1;
    let pct: Percentage = 75.5;
    let unit: UnitInterval = 0.5;
    let byte: Byte = 255;
    let port: Port = 8080;
    let age: ValidAge = 25;

    // Text-based types
    let name: NonEmptyText = "Alice";
    let id: Identifier = "my_variable";
    let ascii: AsciiText = "hello";
    let uid: UserId = 12345;

    // Arithmetic predicates
    let even: EvenPositive = 4;

    // Collection types
    let sorted: SortedList = [1, 2, 3, 4, 5];
    let positives: PositiveList = [1, 2, 3];
    let unique: UniqueList<Int> = [1, 2, 3, 4, 5];

    // Direct value checks (predicates not callable as functions yet)
    assert(10 > 0);
    assert(50.0 >= 0.0 && 50.0 <= 100.0);
    assert(!(-5 > 0));
    assert(0 >= 0);
    assert(4 % 2 == 0);
    assert(3 % 2 != 0);

    // Function calls
    let result = safe_divide(10, 2);
    assert(result == 5);
}
