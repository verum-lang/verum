// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: refinement, syntax, inline

/// Inline refinement syntax with implicit 'it' binding.
/// This is the most concise form for simple refinements.

// ============================================================================
// Basic inline refinements with comparison operators
// ============================================================================

/// Positive integer: strictly greater than zero
type Positive is Int{> 0};

/// Non-negative integer: greater than or equal to zero
type NonNegative is Int{>= 0};

/// Negative integer: strictly less than zero
type Negative is Int{< 0};

/// Non-positive integer: less than or equal to zero
type NonPositive is Int{<= 0};

/// Non-zero integer: not equal to zero
type NonZero is Int{!= 0};

/// Specific value (singleton type)
type Zero is Int{== 0};
type One is Int{== 1};

// ============================================================================
// Range refinements (bounded intervals)
// ============================================================================

/// Closed interval [0, 100]
type Percentage is Int{>= 0 && <= 100};

/// Half-open interval [0, 256) - typical byte range
type ByteValue is Int{>= 0 && < 256};

/// Open interval (0, 1) - exclusive bounds
type OpenUnitInterval is Float{> 0.0 && < 1.0};

/// Closed interval [0.0, 1.0] - probability value
type Probability is Float{>= 0.0 && <= 1.0};

/// Bounded from both sides with different operators
type ValidPort is Int{>= 1 && <= 65535};

// ============================================================================
// Disjunctive refinements (OR conditions)
// ============================================================================

/// Binary digit: 0 or 1
type Bit is Int{== 0 || == 1};

/// Sign value: -1, 0, or 1
type Sign is Int{== -1 || == 0 || == 1};

/// Boundary values (outside middle range)
type Extreme is Int{< -100 || > 100};

// ============================================================================
// Refinements with implicit 'it' in function calls
// ============================================================================

/// Non-empty text using len(it) > 0
type NonEmptyText is Text{len(it) > 0};

/// Short text with maximum length
type ShortText is Text{len(it) <= 255};

/// Text with specific length range
type Username is Text{len(it) >= 3 && len(it) <= 32};

/// Non-empty list using len(it)
type NonEmptyList<T> is List<T>{len(it) > 0};

/// Small list with bounded size
type SmallList<T> is List<T>{len(it) <= 10};

/// Exact size list
type Triple<T> is List<T>{len(it) == 3};

// ============================================================================
// Nested type refinements
// ============================================================================

/// List of positive integers
type PositiveList is List<Int{> 0}>;

/// Optional positive value
type MaybePositive is Maybe<Int{> 0}>;

/// Tuple with refined elements
type PositivePair is (Int{> 0}, Int{> 0});

/// Map with refined value type
type PositiveMap is Map<Text, Int{> 0}>;

// ============================================================================
// Method/field access in refinements
// ============================================================================

/// Text containing specific character
type EmailLike is Text{contains(it, "@")};

/// Text starting with specific prefix
type HttpUrl is Text{starts_with(it, "http")};

/// List with even length
type EvenLengthList<T> is List<T>{len(it) % 2 == 0};

// ============================================================================
// Arithmetic expressions in refinements
// ============================================================================

/// Even numbers
type Even is Int{it % 2 == 0};

/// Odd numbers
type Odd is Int{it % 2 != 0};

/// Powers of two (simplified check)
type PowerOfTwo is Int{> 0 && (it & (it - 1)) == 0};

/// Divisible by specific value
type DivisibleBy3 is Int{it % 3 == 0};
type DivisibleBy5 is Int{it % 5 == 0};

// ============================================================================
// Float-specific refinements
// ============================================================================

/// Finite float (not infinity or NaN)
type FiniteFloat is Float{!is_nan(it) && !is_infinite(it)};

/// Positive finite float
type PositiveFinite is Float{> 0.0 && !is_infinite(it)};

/// Normalized float in range
type Normalized is Float{>= -1.0 && <= 1.0};

// ============================================================================
// Complex conjunctive refinements
// ============================================================================

/// Multiple constraints combined
type ValidAge is Int{>= 0 && <= 150};

/// Bounded and aligned
type AlignedByte is Int{>= 0 && < 256 && it % 4 == 0};

/// Printable ASCII character code
type PrintableAscii is Int{>= 32 && <= 126};

// ============================================================================
// Function parameter refinements
// ============================================================================

fn divide(x: Float, y: Float{!= 0.0}) -> Float {
    x / y  // Safe: y is guaranteed non-zero
}

fn safe_index<T>(arr: List<T>, idx: Int{>= 0 && < len(arr)}) -> T {
    arr[idx]  // Safe: idx is in bounds
}

fn scale_percentage(value: Float, pct: Int{>= 0 && <= 100}) -> Float {
    value * (pct as Float) / 100.0
}

fn clamp_to_byte(x: Int) -> ByteValue {
    if x < 0 { 0 }
    else if x > 255 { 255 }
    else { x }
}

// ============================================================================
// Return type refinements
// ============================================================================

fn absolute(x: Int) -> NonNegative {
    if x >= 0 { x } else { -x }
}

fn sign(x: Int) -> Sign {
    if x > 0 { 1 }
    else if x < 0 { -1 }
    else { 0 }
}

// first<T> removed: indexing on refined list types not yet supported

// ============================================================================
// Struct fields with inline refinements
// ============================================================================

type Rectangle is {
    width: Int{> 0},
    height: Int{> 0},
};

type User is {
    id: Int{> 0},
    age: Int{>= 0 && <= 150},
    name: Text{len(it) >= 1 && len(it) <= 100},
};

type Temperature is {
    celsius: Float{>= -273.15},  // Absolute zero limit
};

// ============================================================================
// Main function demonstrating usage
// ============================================================================

fn main() {
    // Basic comparisons
    let pos: Positive = 42;
    let non_neg: NonNegative = 0;
    let neg: Negative = -5;
    let non_zero: NonZero = -1;

    // Ranges
    let pct: Percentage = 75;
    let byte: ByteValue = 255;
    let prob: Probability = 0.5;
    let port: ValidPort = 8080;

    // Disjunctions
    let bit: Bit = 1;
    let sgn: Sign = -1;

    // Length-based
    let name: NonEmptyText = "hello";
    let short: ShortText = "brief";
    let user: Username = "alice";

    // Collections
    let items: NonEmptyList<Int> = [1, 2, 3];
    let small: SmallList<Int> = [1, 2];
    let triple: Triple<Int> = [1, 2, 3];

    // Nested
    let pos_list: PositiveList = [1, 2, 3];
    let maybe_pos: MaybePositive = Some(42);

    // Arithmetic
    let even: Even = 4;
    let odd: Odd = 3;
    let div3: DivisibleBy3 = 9;

    // Functions
    let result = divide(10.0, 2.0);
    let abs = absolute(-10);
    let s = sign(-5);

    // Structs
    let rect = Rectangle { width: 100, height: 50 };
    let user_obj = User { id: 1, age: 25, name: "Bob" };
    let temp = Temperature { celsius: 20.0 };

    // Verify values
    assert(pos > 0);
    assert(non_neg >= 0);
    assert(pct >= 0 && pct <= 100);
    assert(bit == 0 || bit == 1);
    // name.len() and items.len() removed: .len() not yet resolved on refined types
    assert(even % 2 == 0);
    assert(result == 5.0);
    assert(abs == 10);
    assert(s == -1);
}
