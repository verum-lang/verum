// @test: verify-pass
// @tier: 0
// @level: L1
// @tags: contracts, loop-invariants
// @timeout: 5000

/// Loop invariants: conditions that hold at the start of each iteration.
/// Essential for verifying loops terminate with correct results.

// ============================================================================
// Basic loop with sum invariant
// ============================================================================

@verify(proof)
fn sum_to_n(n: Int{>= 0}) -> Int {
    contract#"
        ensures result == n * (n + 1) / 2;
    "

    let mut sum = 0;
    let mut i = 0;

    while i <= n {
        invariant sum == i * (i - 1) / 2 || i == 0;
        invariant i >= 0 && i <= n + 1;

        sum += i;
        i += 1;
    }

    sum
}

// ============================================================================
// Array sum with accumulator invariant
// ============================================================================

@verify(proof)
fn array_sum(arr: List<Int>) -> Int
    ensures result == arr.iter().sum()
{
    let mut sum = 0;
    let mut i = 0;

    while i < len(arr) {
        invariant i >= 0 && i <= len(arr);
        invariant sum == arr[0..i].iter().sum();

        sum += arr[i];
        i += 1;
    }

    sum
}

// ============================================================================
// Finding maximum with invariant
// ============================================================================

@verify(proof)
fn find_max(arr: List<Int>{len(it) > 0}) -> Int
    ensures forall x in arr => result >= x
    ensures exists x in arr => result == x
{
    let mut max = arr[0];
    let mut i = 1;

    while i < len(arr) {
        invariant i >= 1 && i <= len(arr);
        invariant forall j in 0..i => max >= arr[j];
        invariant exists j in 0..i => max == arr[j];

        if arr[i] > max {
            max = arr[i];
        }
        i += 1;
    }

    max
}

// ============================================================================
// Binary search with range invariant
// ============================================================================

@verify(proof)
fn binary_search(arr: List<Int>, target: Int) -> Maybe<Int>
    requires forall i in 0..(len(arr) - 1) => arr[i] <= arr[i + 1]
    ensures match result {
        Some(idx) => idx >= 0 && idx < len(arr) && arr[idx] == target,
        None => forall x in arr => x != target,
    }
{
    if len(arr) == 0 {
        return None;
    }

    let mut lo = 0;
    let mut hi = len(arr) - 1;

    while lo <= hi {
        invariant lo >= 0;
        invariant hi < len(arr);
        invariant forall j in 0..lo => arr[j] < target;
        invariant forall j in (hi + 1)..len(arr) => arr[j] > target;

        let mid = lo + (hi - lo) / 2;

        if arr[mid] == target {
            return Some(mid);
        } else if arr[mid] < target {
            lo = mid + 1;
        } else {
            if mid == 0 {
                return None;
            }
            hi = mid - 1;
        }
    }

    None
}

// ============================================================================
// Factorial with product invariant
// ============================================================================

@verify(proof)
fn factorial(n: Int{>= 0}) -> Int{> 0}
    ensures result == (1..=n).product()
{
    let mut result = 1;
    let mut i = 1;

    while i <= n {
        invariant i >= 1 && i <= n + 1;
        invariant result == (1..i).product();
        invariant result > 0;

        result *= i;
        i += 1;
    }

    result
}

// ============================================================================
// Exponentiation by squaring
// ============================================================================

@verify(proof)
fn power(base: Int, exp: Int{>= 0}) -> Int
    ensures result == base.pow(exp)
{
    let mut result = 1;
    let mut b = base;
    let mut e = exp;

    while e > 0 {
        invariant e >= 0;
        invariant result * b.pow(e) == base.pow(exp);

        if e % 2 == 1 {
            result *= b;
        }
        b *= b;
        e /= 2;
    }

    result
}

// ============================================================================
// GCD with Euclidean algorithm
// ============================================================================

@verify(proof)
@allow(unbounded_recursion)
fn gcd(a: Int{> 0}, b: Int{> 0}) -> Int{> 0}
    ensures result > 0
    ensures a % result == 0
    ensures b % result == 0
{
    let mut x = a;
    let mut y = b;

    while y != 0 {
        invariant x > 0;
        invariant y >= 0;
        invariant gcd(x, y) == gcd(a, b);

        let temp = y;
        y = x % y;
        x = temp;
    }

    x
}

// ============================================================================
// Sorting with order invariant
// ============================================================================

@verify(proof)
fn insertion_sort(arr: &mut List<Int>)
    ensures len(arr) == old(len(arr))
    ensures forall i in 0..(len(arr) - 1) => arr[i] <= arr[i + 1]
{
    let n = len(arr);
    let mut i = 1;

    while i < n {
        invariant i >= 1 && i <= n;
        invariant forall j in 0..(i - 1) => arr[j] <= arr[j + 1];

        let key = arr[i];
        let mut j = i;

        while j > 0 && arr[j - 1] > key {
            invariant j >= 0 && j <= i;
            invariant forall k in j..i => arr[k] >= key;

            arr[j] = arr[j - 1];
            j -= 1;
        }

        arr[j] = key;
        i += 1;
    }
}

// ============================================================================
// Partitioning with pivot invariant
// ============================================================================

@verify(proof)
fn partition(arr: &mut List<Int>, lo: Int{>= 0}, hi: Int{>= 0}) -> Int
    requires lo <= hi && hi < len(arr)
    ensures result >= lo && result <= hi
    ensures forall j in lo..result => arr[j] <= arr[result]
    ensures forall j in (result + 1)..=hi => arr[j] >= arr[result]
{
    let pivot = arr[hi];
    let mut i = lo;
    let mut j = lo;

    while j < hi {
        invariant i >= lo && i <= j;
        invariant j >= lo && j <= hi;
        invariant forall k in lo..i => arr[k] < pivot;
        invariant forall k in i..j => arr[k] >= pivot;

        if arr[j] < pivot {
            let temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
            i += 1;
        }
        j += 1;
    }

    let temp = arr[i];
    arr[i] = arr[hi];
    arr[hi] = temp;

    i
}

// ============================================================================
// Two-pointer technique
// ============================================================================

@verify(proof)
fn reverse_in_place<T>(arr: &mut List<T>)
    ensures len(arr) == old(len(arr))
    ensures forall i in 0..len(arr) => arr[i] == old(arr[len(arr) - 1 - i])
{
    if len(arr) <= 1 {
        return;
    }

    let mut left = 0;
    let mut right = len(arr) - 1;

    while left < right {
        invariant left >= 0 && right < len(arr);
        invariant left <= right + 1;

        let temp = arr[left];
        arr[left] = arr[right];
        arr[right] = temp;
        left += 1;
        right -= 1;
    }
}

// ============================================================================
// Nested loops with matrix invariant
// ============================================================================

@verify(proof)
fn matrix_sum(m: List<List<Int>>) -> Int
    requires forall row in m => len(row) == len(m[0])
{
    let mut total = 0;
    let mut i = 0;

    while i < len(m) {
        invariant i >= 0 && i <= len(m);
        invariant total == m[0..i].iter().flat_map(|r| r).sum();

        let mut j = 0;
        let mut row_sum = 0;

        while j < len(m[i]) {
            invariant j >= 0 && j <= len(m[i]);
            invariant row_sum == m[i][0..j].iter().sum();

            row_sum += m[i][j];
            j += 1;
        }

        total += row_sum;
        i += 1;
    }

    total
}

fn main() {
    // Sum to n
    let sum = sum_to_n(10);
    assert(sum == 55);

    // Array sum
    let arr = [1, 2, 3, 4, 5];
    let total = array_sum(arr);
    assert(total == 15);

    // Find max
    let max = find_max([3, 1, 4, 1, 5, 9, 2, 6]);
    assert(max == 9);

    // Binary search
    let sorted = [1, 2, 3, 4, 5];
    let found = binary_search(sorted, 3);
    assert(found == Some(2));

    // Factorial
    let fact = factorial(5);
    assert(fact == 120);

    // Power
    let p = power(2, 10);
    assert(p == 1024);

    // GCD
    let g = gcd(48, 18);
    assert(g == 6);
}
