// @test: verify-pass
// @tier: 0
// @level: L1
// @tags: contracts, termination, decreases
// @timeout: 5000

/// Decreases clauses: proving termination of loops and recursion.
/// Specifies a measure that strictly decreases on each iteration/call.

// ============================================================================
// Basic loop termination
// ============================================================================

@verify(proof)
fn countdown(n: Int{>= 0}) -> Int
    decreases n
{
    let mut count = n;
    let mut result = 0;

    while count > 0 {
        invariant count >= 0;
        decreases count;

        result += count;
        count -= 1;
    }

    result
}

@verify(proof)
fn count_down_to_zero(start: Int{>= 0}) {
    let mut n = start;

    while n > 0 {
        decreases n;
        n -= 1;
    }
    // Terminates because n decreases by 1 each iteration
}

// ============================================================================
// Recursive function termination
// ============================================================================

@verify(proof)
fn factorial(n: Int{>= 0}) -> Int{> 0}
    decreases n
{
    if n == 0 {
        1
    } else {
        n * factorial(n - 1)  // n - 1 < n, so terminates
    }
}

@verify(proof)
fn fibonacci(n: Int{>= 0}) -> Int{>= 0}
    decreases n
{
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)  // Both args < n
    }
}

@verify(proof)
fn sum_recursive(arr: List<Int>, idx: Int{>= 0}) -> Int
    requires idx <= len(arr)
    decreases len(arr) - idx
{
    if idx >= len(arr) {
        0
    } else {
        arr[idx] + sum_recursive(arr, idx + 1)
    }
}

// ============================================================================
// GCD with decreasing argument
// ============================================================================

@verify(proof)
fn gcd(a: Int{> 0}, b: Int{>= 0}) -> Int{> 0}
    decreases b
{
    if b == 0 {
        a
    } else {
        gcd(b, a % b)  // a % b < b when b > 0
    }
}

@verify(proof)
fn gcd_loop(a: Int{> 0}, b: Int{> 0}) -> Int{> 0} {
    let mut x = a;
    let mut y = b;

    while y != 0 {
        decreases y;

        let temp = y;
        y = x % y;
        x = temp;
    }

    x
}

// ============================================================================
// Binary search with shrinking range
// ============================================================================

@verify(proof)
fn binary_search(arr: List<Int>, target: Int, lo: Int{>= 0}, hi: Int) -> Maybe<Int>
    requires forall i in 0..(len(arr) - 1) => arr[i] <= arr[i + 1]
    requires hi < len(arr) as Int || hi == -1
    decreases max(0, hi - lo + 1)
{
    if lo > hi {
        return None;
    }

    let mid = lo + (hi - lo) / 2;

    if arr[mid] == target {
        Some(mid)
    } else if arr[mid] < target {
        binary_search(arr, target, mid + 1, hi)  // Range shrinks
    } else {
        binary_search(arr, target, lo, mid - 1)  // Range shrinks
    }
}

// ============================================================================
// Tuple decreases (lexicographic ordering)
// ============================================================================

@verify(proof)
fn ackermann(m: Int{>= 0}, n: Int{>= 0}) -> Int{> 0}
    decreases (m, n)  // Lexicographic: (m1, n1) < (m2, n2) if m1 < m2, or m1 == m2 && n1 < n2
{
    if m == 0 {
        n + 1
    } else if n == 0 {
        ackermann(m - 1, 1)  // m decreases
    } else {
        ackermann(m - 1, ackermann(m, n - 1))  // Outer: m decreases; Inner: n decreases, m same
    }
}

@verify(proof)
fn nested_countdown(outer: Int{>= 0}, inner: Int{>= 0}) -> Int
    decreases (outer, inner)
{
    if outer == 0 && inner == 0 {
        0
    } else if inner == 0 {
        1 + nested_countdown(outer - 1, outer - 1)  // outer decreases
    } else {
        1 + nested_countdown(outer, inner - 1)  // inner decreases, outer same
    }
}

// ============================================================================
// List length as decreasing measure
// ============================================================================

@verify(proof)
fn sum_list(lst: List<Int>) -> Int
    decreases len(lst)
{
    if len(lst) == 0 {
        0
    } else {
        lst[0] + sum_list(lst[1..])  // Tail has len - 1
    }
}

@verify(proof)
fn find_in_list<T: Eq>(lst: List<T>, target: T) -> Maybe<Int>
    decreases len(lst)
{
    if len(lst) == 0 {
        None
    } else if lst[0] == target {
        Some(0)
    } else {
        match find_in_list(lst[1..], target) {
            Some(idx) => Some(idx + 1),
            None => None,
        }
    }
}

@verify(proof)
fn merge(a: List<Int>, b: List<Int>) -> List<Int>
    requires forall i in 0..(len(a) - 1) => a[i] <= a[i + 1]
    requires forall i in 0..(len(b) - 1) => b[i] <= b[i + 1]
    ensures forall i in 0..(len(result) - 1) => result[i] <= result[i + 1]
    decreases len(a) + len(b)
{
    if len(a) == 0 {
        b
    } else if len(b) == 0 {
        a
    } else if a[0] <= b[0] {
        [a[0]] + merge(a[1..], b)  // len(a) decreases
    } else {
        [b[0]] + merge(a, b[1..])  // len(b) decreases
    }
}

// ============================================================================
// Tree depth as decreasing measure
// ============================================================================

type Tree<T> is
    | Leaf
    | Node { value: T, left: Heap<Tree<T>>, right: Heap<Tree<T>> };

fn tree_depth<T>(t: Tree<T>) -> Int{>= 0} {
    match t {
        Tree.Leaf => 0,
        Tree.Node { left, right, .. } => 1 + max(tree_depth(*left), tree_depth(*right)),
    }
}

@verify(proof)
fn tree_sum(t: Tree<Int>) -> Int
    decreases tree_depth(t)
{
    match t {
        Tree.Leaf => 0,
        Tree.Node { value, left, right } =>
            value + tree_sum(*left) + tree_sum(*right),  // Subtrees have smaller depth
    }
}

@verify(proof)
fn tree_size<T>(t: Tree<T>) -> Int{>= 0}
    decreases tree_depth(t)
{
    match t {
        Tree.Leaf => 0,
        Tree.Node { left, right, .. } =>
            1 + tree_size(*left) + tree_size(*right),
    }
}

// ============================================================================
// Mutual recursion with shared decreasing measure
// ============================================================================

@verify(proof)
fn is_even(n: Int{>= 0}) -> Bool
    decreases n
{
    if n == 0 {
        true
    } else {
        is_odd(n - 1)
    }
}

@verify(proof)
fn is_odd(n: Int{>= 0}) -> Bool
    decreases n
{
    if n == 0 {
        false
    } else {
        is_even(n - 1)
    }
}

// ============================================================================
// Loop with complex termination
// ============================================================================

@verify(proof)
fn collatz_steps(n: Int{> 0}) -> Int{>= 0}
    // Note: Collatz conjecture is unproven, so we'd need a bound or assumption
    decreases n  // This is optimistic; actual proof requires the conjecture
{
    let mut count = 0;
    let mut current = n;

    while current != 1 {
        // In practice, we'd need a proven upper bound
        decreases current;  // Hypothetical measure (Collatz conjecture)

        if current % 2 == 0 {
            current = current / 2;
        } else {
            current = 3 * current + 1;
        }
        count += 1;
    }

    count
}

fn main() {
    // Basic countdown
    let sum = countdown(5);
    assert(sum == 15);

    // Recursive functions
    let fact = factorial(5);
    assert(fact == 120);

    let fib = fibonacci(10);
    assert(fib == 55);

    // GCD
    let g = gcd(48, 18);
    assert(g == 6);

    // Ackermann (small values only!)
    let ack = ackermann(2, 2);
    assert(ack == 7);

    // List operations
    let lst = [1, 2, 3, 4, 5];
    let total = sum_list(lst);
    assert(total == 15);

    // Even/odd
    assert(is_even(4) == true);
    assert(is_odd(3) == true);
}
