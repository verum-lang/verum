/// Higher-kinded types: `F<_>` binds a type constructor of arity 1.
/// This is the canonical Functor signature and is the foundation for
/// every monadic / applicative abstraction in `core/math/category.vr`.

fn map<F<_>, A, B>(fa: F<A>, f: fn(A) -> B) -> F<B> {
    fa
}

fn main() {
    print("higher-kinded map parsed and type-checked");
}
