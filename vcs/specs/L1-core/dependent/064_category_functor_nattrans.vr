// @test: typecheck-pass
// @level: L1
// @tier: 0
// @tags: category, functor, natural-transformation, monad, adjunction, limit, sheaf, acid-test
// @timeout: 10000
// @description: Concrete category-theoretic protocol instances â€” full Category stack.

/// Acid test for the full category-theoretic protocol chain:
///
///   * `IntegerPathCategory` implements `Category<Int, PathInt>`
///   * `IdentityEndofunctor` implements `Functor + Endofunctor + FaithfulFunctor
///     + FullFunctor + FullyFaithfulFunctor` (diamond inheritance)
///   * `IdentityNatTrans`    implements `NaturalTransformation + NaturalIsomorphism`
///   * `IdentityMonad`       implements `Monad<C>`
///   * `IdentityComonad`     implements `Comonad<C>`
///   * `IdentityAdjunction`  implements `Adjunction<C, D, F, G>` (4 generic params)
///   * `TerminalCone`        implements `Cone + Limit` (limit of empty diagram)
///   * `InitialCocone`       implements `Cocone + Colimit` (colimit of empty diagram)
///   * `ConstantPresheaf`    implements `Presheaf + Sheaf`
///
/// Every constructor, smart factory, and polymorphic protocol method
/// is exercised so that a silent signature change in any generic
/// protocol type parameter is caught at build time.

mount core.math.examples.{
    IntegerPathCategory, integer_path_category,
    IdentityEndofunctor, identity_endofunctor,
    IdentityNatTrans, identity_nat_trans,
    IdentityMonad, identity_monad,
    IdentityComonad, identity_comonad,
    IdentityAdjunction, identity_adjunction,
    TerminalCone, terminal_cone,
    InitialCocone, initial_cocone,
    ConstantPresheaf, constant_presheaf,
    integer_path_id, integer_path_compose, integer_path_source, integer_path_target,
};

fn exercise_category() {
    let c = integer_path_category();
    let id_5 = integer_path_id(5);
    let id_7 = integer_path_id(7);
    let cp = integer_path_compose(id_5, id_7);
    let s = integer_path_source(&cp);
    let t = integer_path_target(&cp);
    print(c.marker);
    print(s);
    print(t);
}

fn exercise_endofunctor() {
    // IdentityEndofunctor carries: Functor + Endofunctor +
    // FaithfulFunctor + FullFunctor + FullyFaithfulFunctor.
    let f = identity_endofunctor();
    print(f.marker);
}

fn exercise_nat_trans() {
    // IdentityNatTrans carries: NaturalTransformation + NaturalIsomorphism.
    let n = identity_nat_trans();
    print(n.marker);
}

fn exercise_monad() {
    let m = identity_monad();
    print(m.marker);
}

fn exercise_comonad() {
    let w = identity_comonad();
    print(w.marker);
}

fn exercise_adjunction() {
    let a = identity_adjunction();
    print(a.marker);
}

fn exercise_limit_colimit() {
    let l = terminal_cone();
    let cl = initial_cocone();
    print(l.marker);
    print(cl.marker);
}

fn exercise_sheaf() {
    let p = constant_presheaf();
    print(p.marker);
}

fn main() {
    exercise_category();
    exercise_endofunctor();
    exercise_nat_trans();
    exercise_monad();
    exercise_comonad();
    exercise_adjunction();
    exercise_limit_colimit();
    exercise_sheaf();
    print("category/functor/nat-trans/monad/adjunction/limit/sheaf acid test green");
}
