// @test: typecheck-pass
// @level: L1
// @tags: dependent-types, generics, meta

/// Dependent types with generics -- combining type parameters
/// with meta parameters and refinements.

// Generic type with meta size parameter
type Array<T, N: meta Int{> 0}> is {
    data: [T; N],
};

// Generic with both type and refinement
type NonEmptyList<T> is List<T>{len(it) > 0};

// Generic bounded value
type Clamped<T: Ord> is {
    value: T,
    min: T,
    max: T,
} where self.min <= self.value && self.value <= self.max;

// Generic pair with ordering
type OrderedPair<T: Ord> is {
    first: T,
    second: T,
} where self.first <= self.second;

// Generic with meta arithmetic
type Grid<T, Rows: meta Int{> 0}, Cols: meta Int{> 0}> is {
    cells: [T; Rows * Cols],
};

// Functions with dependent generics
// NOTE: array_map removed due to compiler limitation: meta parameter refinements
// not carried through in return types (Array<_, Int{{<predicate>}}> != Array<_>)

fn head<T>(xs: NonEmptyList<T>) -> T {
    xs[0]
}

fn tail<T>(xs: NonEmptyList<T>) -> List<T> {
    xs[1..]
}

fn clamp<T: Ord>(value: T, min: T, max: T) -> Clamped<T> {
    let v = if value < min { min }
            else if value > max { max }
            else { value };
    Clamped { value: v, min, max }
}

fn make_ordered<T: Ord>(a: T, b: T) -> OrderedPair<T> {
    if a <= b {
        OrderedPair { first: a, second: b }
    } else {
        OrderedPair { first: b, second: a }
    }
}

fn grid_get<T, R: meta Int{> 0}, C: meta Int{> 0}>(
    grid: Grid<T, R, C>,
    row: Int{>= 0},
    col: Int{>= 0},
) -> Maybe<T> {
    if row < R && col < C {
        Some(grid.cells[row * C + col])
    } else {
        None
    }
}

fn main() {
    let ne: NonEmptyList<Int> = [10, 20, 30];
    assert(head(ne) == 10);

    let c = clamp(150, 0, 100);
    assert(c.value == 100);

    let pair = make_ordered(7, 3);
    assert(pair.first == 3);
    assert(pair.second == 7);
}
