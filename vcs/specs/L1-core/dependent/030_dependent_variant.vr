// @test: typecheck-pass
// @level: L1
// @tags: dependent-types, variant, refinement

/// Dependent variant types -- sum types with refined payloads
/// and type narrowing after matching.

// Variant with refined payloads
type Number is
    Natural(Int{>= 0})
  | Negative(Int{< 0})
  | Fraction { num: Int, den: Int{!= 0} };

// Variant where constructor constraints guarantee properties
type Token is
    Identifier(Text{len(it) > 0})
  | IntLiteral(Int)
  | FloatLiteral(Float)
  | Keyword(Text)
  | Eof;

// Variant with compile-time tag
type TypedValue is
    IntVal(Int)
  | FloatVal(Float)
  | BoolVal(Bool)
  | TextVal(Text)
  | ListVal(List<TypedValue>);

// After matching, payload carries its refinement
fn number_to_float(n: Number) -> Float {
    match n {
        Natural(v) => {
            // v: Int{>= 0} here
            assert(v >= 0);
            v as Float
        },
        Negative(v) => {
            // v: Int{< 0} here
            assert(v < 0);
            v as Float
        },
        Fraction { num, den } => {
            // den: Int{!= 0} here
            (num as Float) / (den as Float)
        },
    }
}

fn token_text(t: Token) -> Text {
    match t {
        Identifier(name) => {
            // name: Text{len(it) > 0}
            assert(name.len() > 0);
            name
        },
        IntLiteral(n) => f"{n}",
        FloatLiteral(f) => f"{f}",
        Keyword(kw) => kw,
        Eof => "<eof>",
    }
}

// Constructing refined variants
fn classify_int(x: Int) -> Number {
    if x >= 0 {
        Natural(x)  // x is known >= 0 here
    } else {
        Negative(x)  // x is known < 0 here
    }
}

fn make_fraction(num: Int, den: Int) -> Maybe<Number> {
    if den != 0 {
        Some(Fraction { num, den })
    } else {
        None
    }
}

// Recursive variant with refinement
fn eval(v: TypedValue) -> Float {
    match v {
        IntVal(n) => n as Float,
        FloatVal(f) => f,
        BoolVal(b) => if b { 1.0 } else { 0.0 },
        TextVal(s) => s.len() as Float,
        ListVal(items) => {
            let mut sum = 0.0;
            for item in items {
                sum = sum + eval(item);
            }
            sum
        },
    }
}

fn main() {
    let pos = classify_int(42);
    assert(number_to_float(pos) == 42.0);

    let neg = classify_int(-7);
    assert(number_to_float(neg) == -7.0);

    let frac = make_fraction(1, 3);
    match frac {
        Some(f) => {
            let val = number_to_float(f);
            assert(val > 0.0 && val < 1.0);
        },
        None => panic("should succeed"),
    }

    let tok = Identifier("foo");
    assert(token_text(tok) == "foo");

    let v = ListVal([IntVal(1), IntVal(2), IntVal(3)]);
    assert(eval(v) == 6.0);
}
