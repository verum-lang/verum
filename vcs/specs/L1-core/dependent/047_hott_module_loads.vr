// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: hott, stdlib, regression
// @timeout: 10000
// @description: The core.math.hott module loads and its types are usable.

/// Regression: the `core/math/hott.vr` module must parse, type-check,
/// and expose Equiv, IsContr, IsProp, IsSet, IsGroupoid, IsTrunc,
/// Fiber, PathInt, S1, Quotient, HedbergSet, plus the `univalence`
/// axiom and the `funext` theorem.
///
/// This file imports the module and exercises each exported type at a
/// shallow level to make sure no import path breaks.

mount core.math.hott.{Equiv, IsContr, IsProp, IsSet, Fiber, PathInt, refl_int};

fn make_equiv<A>() -> Equiv<A, A> {
    Equiv {
        forward: fn(x: A) -> A { x },
        backward: fn(x: A) -> A { x },
    }
}

fn make_contr_int() -> IsContr<Int> {
    IsContr {
        center: 0,
        contraction: fn(x: Int) -> Bool { true },
    }
}

fn make_path_int(x: Int) -> PathInt {
    refl_int(x)
}

fn main() {
    let e: Equiv<Int, Int> = make_equiv();
    let _c = make_contr_int();
    let _p = make_path_int(42);
    print("hott module loaded");
}
