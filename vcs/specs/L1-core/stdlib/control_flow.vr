// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: control-flow, if, while, for, match
// @timeout: 10000
// @expect: pass

/// Control flow mechanisms — if/else, while, match.

fn fibonacci(n: Int) -> Int {
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    }
}

fn factorial(n: Int) -> Int {
    let mut result = 1;
    let mut i = 2;
    while i <= n {
        result = result * i;
        i = i + 1;
    }
    result
}

fn classify(x: Int) -> Int {
    if x < 0 {
        -1
    } else if x == 0 {
        0
    } else {
        1
    }
}

fn main() {
    // Fibonacci
    assert_eq(fibonacci(0), 0);
    assert_eq(fibonacci(1), 1);
    assert_eq(fibonacci(10), 55);

    // Factorial
    assert_eq(factorial(1), 1);
    assert_eq(factorial(5), 120);
    assert_eq(factorial(10), 3628800);

    // Classify
    assert_eq(classify(-5), -1);
    assert_eq(classify(0), 0);
    assert_eq(classify(42), 1);

    // Nested control flow
    let mut count = 0;
    let mut i = 0;
    while i < 10 {
        if i % 2 == 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    assert_eq(count, 5);
}
