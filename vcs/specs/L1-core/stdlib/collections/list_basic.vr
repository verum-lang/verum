// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: stdlib, collections, list, basic
// @timeout: 10000
// @expect: pass

/// Basic List<T> operations — exercises the core stdlib collection API.

fn main() {
    // Construction
    let mut xs = [1, 2, 3];
    assert_eq(xs.len(), 3);

    // Push / pop
    xs.push(4);
    assert_eq(xs.len(), 4);
    assert_eq(xs[3], 4);

    // Indexing
    assert_eq(xs[0], 1);
    assert_eq(xs[1], 2);
    assert_eq(xs[2], 3);

    // Sum via loop
    let mut sum = 0;
    let mut i = 0;
    while i < xs.len() {
        sum = sum + xs[i];
        i = i + 1;
    }
    assert_eq(sum, 10);

    // Boolean checks
    assert(!xs.is_empty());

    // Arithmetic
    assert_eq(2 + 3, 5);
    assert_eq(10 - 3, 7);
    assert_eq(4 * 5, 20);
    assert_eq(10 / 3, 3);
}
