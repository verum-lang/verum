// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: closures, lambda, higher-order
// @timeout: 10000
// @expect: pass

fn apply_twice(f: fn(Int) -> Int, x: Int) -> Int {
    f(f(x))
}

fn make_adder(n: Int) -> fn(Int) -> Int {
    fn add(x: Int) -> Int { x + n }
    add
}

fn make_multiplier(factor: Int) -> fn(Int) -> Int {
    fn multiply(x: Int) -> Int { x * factor }
    multiply
}

fn main() {
    // Lambda basics
    let double = fn(x: Int) -> Int { x * 2 };
    assert_eq(double(5), 10);
    assert_eq(double(0), 0);

    // Higher-order function + lambda
    assert_eq(apply_twice(double, 3), 12);

    // Inline lambda
    let square = fn(x: Int) -> Int { x * x };
    assert_eq(apply_twice(square, 2), 16);

    // Closure capture — parameter capture
    let add5 = make_adder(5);
    assert_eq(add5(10), 15);
    assert_eq(add5(0), 5);

    // Closure capture — multiplier pattern
    let triple = make_multiplier(3);
    assert_eq(triple(7), 21);

    // Closure used as higher-order argument
    assert_eq(apply_twice(add5, 0), 10);
}
