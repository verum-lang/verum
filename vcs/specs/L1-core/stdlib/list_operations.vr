// @test: typecheck-pass
// @tier: 0
// @level: L1
// @tags: list, collections, push, indexing, length
// @timeout: 10000
// @expect: pass

fn main() {
    // Construction
    let xs = [1, 2, 3, 4, 5];
    assert_eq(xs.len(), 5);
    assert_eq(xs[0], 1);
    assert_eq(xs[4], 5);

    // Mutable list push
    let mut ys: List<Int> = [];
    ys.push(10);
    ys.push(20);
    ys.push(30);
    assert_eq(ys.len(), 3);
    assert_eq(ys[0], 10);
    assert_eq(ys[2], 30);

    // Index assignment
    let mut zs = [100, 200, 300];
    zs[1] = 999;
    assert_eq(zs[1], 999);
    assert_eq(zs[0], 100);
    assert_eq(zs[2], 300);

    // Building list in a loop
    let mut squares: List<Int> = [];
    let mut i = 0;
    while i < 10 {
        squares.push(i * i);
        i = i + 1;
    }
    assert_eq(squares.len(), 10);
    assert_eq(squares[0], 0);
    assert_eq(squares[3], 9);
    assert_eq(squares[9], 81);

    // Nested list operations
    let mut data = [5, 3, 8, 1, 9, 2, 7, 4, 6, 10];
    // Find max
    let mut max_val = data[0];
    let mut j = 1;
    while j < data.len() {
        if data[j] > max_val {
            max_val = data[j];
        }
        j = j + 1;
    }
    assert_eq(max_val, 10);

    // Find sum
    let mut total = 0;
    let mut k = 0;
    while k < data.len() {
        total = total + data[k];
        k = k + 1;
    }
    assert_eq(total, 55);
}
