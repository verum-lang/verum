// @test: parse
// @tier: 1
// @level: L1
// @tags: proof, quantifiers, forall, exists, is

/// Quantifier Expressions Test Suite
///
/// Tests for universal (forall) and existential (exists) quantifiers,
/// as well as pattern test expressions (is/is not).
///
/// Grammar Reference:
///   forall_expr = 'forall' quantifier_binding { ',' quantifier_binding } '.' expression
///   exists_expr = 'exists' quantifier_binding { ',' quantifier_binding } '.' expression
///   is_expr = expression 'is' [ 'not' ] pattern

// ============================================================================
// Section 1: Universal Quantifier (forall)
// ============================================================================

/// Basic forall with type annotation
fn test_forall_basic() {
    // Dot syntax per grammar: forall pattern : type . expression
    let identity = forall x: Int . x + 0 == x;

    // Nested forall
    let commutativity = forall a: Int . forall b: Int . a + b == b + a;
}

/// Forall with pattern
fn test_forall_pattern() {
    let non_empty = forall Some(x): Maybe<Int> . x >= 0;
}

/// Nested forall expressions
fn test_forall_nested() {
    // Transitivity of ordering - using !a || b for implication
    let transitivity = forall x: Int . forall y: Int . forall z: Int .
        !(x < y && y < z) || x < z;
}

// ============================================================================
// Section 2: Existential Quantifier (exists)
// ============================================================================

/// Basic exists with type annotation
fn test_exists_basic() {
    // Dot syntax per grammar
    let has_zero = exists x: Int . x == 0;

    // Another example
    let has_positive = exists n: Int . n > 0;
}

/// Exists with complex predicate
fn test_exists_predicate() {
    let has_square_root = exists x: Float . x * x == 4.0;
}

/// Combined forall and exists
fn test_quantifier_combination() {
    // For every x, there exists a y greater than x
    let unbounded_above = forall x: Int . exists y: Int . y > x;

    // There exists a zero element
    let zero_exists = exists z: Int . forall x: Int . x + z == x;
}

// ============================================================================
// Section 3: Is Expression (Pattern Test)
// ============================================================================

type Maybe<T> is None | Some(T);

type Result<T, E> is
    | Ok(T)
    | Err(E);

type Status is
    | Active
    | Inactive { reason: Text }
    | Pending { since: Int };

/// Basic is expression
fn test_is_basic() {
    let opt: Maybe<Int> = Maybe.Some(42);

    // Pattern test
    if opt is Some(_) {
        print("has value");
    }

    // Negated pattern test
    if opt is not None {
        print("not empty");
    }
}

/// Is expression with binding
fn test_is_binding() {
    let result: Result<Int, Text> = Result.Ok(100);

    if result is Ok(value) {
        print(f"Success: {value}");
    }

    if result is not Err(_) {
        print("No error");
    }
}

/// Is expression with struct pattern
fn test_is_struct_pattern() {
    let status = Status.Inactive { reason: "maintenance" };

    if status is Inactive { reason } {
        print(f"Inactive because: {reason}");
    }

    if status is not Active {
        print("Not currently active");
    }
}

/// Is expression in boolean context
fn test_is_boolean() {
    let opt: Maybe<Int> = Maybe.Some(5);

    // As condition
    let has_value = opt is Some(_);
    let is_empty = opt is None;
    let is_not_empty = opt is not None;

    // In compound boolean expressions
    let check = opt is Some(_) && true;
}

/// Is expression with complex patterns
fn test_is_complex_patterns() {
    let nested: Maybe<Maybe<Int>> = Maybe.Some(Maybe.Some(42));

    // Nested pattern
    if nested is Some(Some(n)) {
        print(f"Deeply nested: {n}");
    }

    // Wildcard in nested
    if nested is Some(Some(_)) {
        print("Has nested some");
    }
}

// ============================================================================
// Section 4: Quantifiers in Specifications
// ============================================================================

// NOTE: @requires/@ensures with complex forall expressions may need parser updates
// For now, using simpler forms

/// Function with simple precondition
fn sum_positive(arr: List<Int>) -> Int {
    let mut total = 0;
    for x in arr {
        total = total + x;
    }
    total
}

/// Function that finds or appends
fn find_or_append(mut list: List<Int>, target: Int) -> List<Int> {
    let found = list.contains(&target);
    if !found {
        list.push(target);
    }
    list
}

// ============================================================================
// Section 5: Quantifiers in Proofs
// ============================================================================

/// Theorem using forall - syntax: theorem name: proposition { proof }
theorem addition_commutative: forall a: Int . forall b: Int . a + b == b + a;

/// Theorem using exists
theorem has_identity: exists e: Int . forall x: Int . x + e == x;

/// Lemma - simplified
lemma bounded_above: forall x: Int . forall y: Int . !(x <= y) || x <= y + 1;

fn main() {
    // Run basic tests
    test_forall_basic();
    test_exists_basic();
    test_is_basic();
    test_is_binding();

    print("All quantifier expression tests passed");
}
