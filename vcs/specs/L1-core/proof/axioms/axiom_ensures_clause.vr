// @test: parse
// @level: L1
// @tier: 0
// @description: Axiom declarations accept `ensures` clauses (T1-Q).
//
// An axiom is a universally quantified proposition over its parameters.
// `ensures P` is the canonical way to state that proposition — it was
// previously only accepted on theorems/lemmas, forcing stdlib authors
// to encode axioms as `requires P` (backwards-compatible but
// semantically awkward). T1-Q adds direct `ensures` support.

// Pure ensures form — the natural way to write an axiom.
axiom add_comm_axiom(a: Int, b: Int)
    ensures a + b == b + a;

// Multiple ensures clauses are conjoined into a single proposition.
axiom group_laws(a: Int, b: Int, c: Int)
    ensures (a + b) + c == a + (b + c),
            0 + a == a,
            a + 0 == a;

// Combined requires + ensures: `requires R → ensures E` semantics.
axiom positive_square(x: Int)
    requires x > 0
    ensures x * x > 0;

// Legacy form: requires-only axiom still works (backwards compat).
axiom legacy_reflexivity(x: Int)
    requires x == x;

fn main() { }
