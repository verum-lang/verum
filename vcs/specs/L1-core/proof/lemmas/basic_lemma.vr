// @test: parse
// @level: L1
// @tags: proofs, verification, lemma
// @timeout: 5000

/// Lemma declarations — helper theorems.
/// Grammar: lemma_decl = 'lemma' identifier [generic_params] '(' [param_list] ')'
///          ['->' type_expr] [requires_clause] [ensures_clause] proof_body

// Basic lemma
lemma add_zero(n: Int)
    proof by simp;

// Lemma with precondition
lemma positive_sum(a: Int, b: Int)
    requires a >= 0, b >= 0
    proof by omega;

// Lemma with structured proof
lemma mul_positive(a: Int, b: Int)
    requires a > 0, b > 0
    proof {
        have h1: a > 0 by assumption;
        have h2: b > 0 by assumption;
        show a * b > 0 by ring;
    };

// Lemma with generic type
lemma list_nonempty<T>(lst: List<T>)
    requires lst.len() > 0
    proof by auto;

fn main() {
    print("Basic lemma tests parsed");
}
