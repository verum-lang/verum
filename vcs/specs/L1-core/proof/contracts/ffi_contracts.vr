/// FFI contracts with requires and ensures.

// FFI function declarations with contracts
extern "C" fn malloc(size: Int) -> Int
    requires size > 0;

extern "C" fn free(ptr: Int)
    requires ptr != 0;

extern "C" fn strlen(s: Int) -> Int
    requires s != 0;

