// @test: parse
// @level: L1
// @tags: meta, staged, multi-stage, metaprogramming
// @timeout: 5000

/// Multi-stage metaprogramming with meta(N) functions.
/// Stage 0 = runtime, Stage 1 = meta (compile-time), Stage N = meta-meta

// Stage 1 — generates runtime code
meta fn gen_runtime() {
    quote {
        fn hello() {
            print("Hello from generated code");
        }
    }
}

// Stage 2 — generates Stage 1 (meta) code
meta(2) fn gen_meta() {
    quote(1) {
        meta fn generated_meta() {
            quote(0) {
                fn deeply_nested() -> Int {
                    42
                }
            }
        }
    }
}

// Stage 3 — generates Stage 2 code
meta(3) fn gen_meta_meta() {
    quote(2) {
        meta(2) fn level2() {
            quote(1) {
                meta fn level1() {
                    quote(0) {
                        const DEEP: Int = 3;
                    }
                }
            }
        }
    }
}

// Meta expression block
fn test_meta_expr() {
    let compile_time = meta {
        let x = 2 + 3;
        x * 10
    };
}

fn main() {
    test_meta_expr();
    print("Multi-stage tests parsed");
}
