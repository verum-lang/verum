// @test: parse
// @level: L1
// @tags: meta, derive, builder, attributes
// @timeout: 5000

/// @derive(Builder) for builder pattern generation.
/// Field defaults specified with = in field definitions.

@derive(Builder)
type HttpRequest is {
    method: Text = "GET",
    url: Text,
    headers: Map<Text, Text> = Map.new(),
    body: Maybe<Text> = None,
    timeout: Int = 30,
};

@derive(Builder)
type DatabaseConfig is {
    host: Text = "localhost",
    port: Int = 5432,
    database: Text,
    username: Text,
    password: Text,
    max_connections: Int = 10,
    ssl: Bool = false,
};

fn main() {
    // Builder pattern usage (generated by derive)
    let req = HttpRequest {
        url: "https://example.com",
        method: "POST",
        body: Some("hello"),
        headers: Map.new(),
        timeout: 30,
    };
    assert_eq(req.method, "POST");

    let config = DatabaseConfig {
        database: "mydb",
        username: "admin",
        password: "secret",
        host: "localhost",
        port: 5432,
        max_connections: 10,
        ssl: false,
    };
    assert_eq(config.port, 5432);
    print("Derive builder tests parsed");
}
