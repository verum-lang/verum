// @test: parse
// @level: L1
// @tags: meta, quote, staged, multi-stage
// @timeout: 5000

/// Multi-stage metaprogramming with explicit quote stages.
/// Grammar: meta_modifier = 'meta' ['(' stage_level ')']
///          quote_stage = '(' stage_level ')'

// Stage 1 meta function (default)
meta fn stage1_gen() {
    quote {
        fn generated_fn() -> Int { 1 }
    }
}

// Explicit stage 1
meta(1) fn explicit_stage1() {
    quote(0) {
        fn runtime_fn() -> Int { 42 }
    }
}

// Stage 2 meta function — generates stage 1 code
meta(2) fn stage2_gen() {
    quote(1) {
        meta fn generated_meta() {
            quote(0) {
                fn deeply_generated() -> Int { 100 }
            }
        }
    }
}

// Stage escape within quote
meta fn with_stage_escape() {
    let compile_time_value = 42;
    quote {
        let x = $(stage 1){ compile_time_value };
    }
}

// Pure meta function
pure meta fn pure_codegen(n: Int) {
    quote {
        const N: Int = ${n};
    }
}

fn main() {
    print("Quote staged tests parsed");
}
