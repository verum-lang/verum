// @test: parse
// @level: L1
// @tags: meta, macros, meta-def
// @timeout: 5000

/// User-defined macro declarations using meta.
/// Grammar: meta_def = visibility 'meta' identifier meta_args '{' meta_rules '}'
///          meta_args = '(' [meta_params_meta] ')'
///          meta_fragment = 'expr' | 'stmt' | 'type' | 'pattern' | 'ident' | 'path' | 'tt' | 'item' | 'block'

// Simple expression macro
meta max(a: expr, b: expr) {
    a => if $a > $b { $a } else { $b }
}

// Statement macro
meta swap(a: ident, b: ident) {
    a => {
        let tmp = $a;
        $a = $b;
        $b = tmp;
    }
}

// Macro with multiple patterns
meta vec_op(op: ident, items: expr) {
    op => match @stringify($op) {
        "sum" => $items.fold(0, |acc, x| acc + x)
        | "product" => $items.fold(1, |acc, x| acc * x)
    }
}

// NOTE: Macro with type fragment specifier removed due to parser bug:
// 'type' keyword conflicts with meta fragment specifier 'type' in lexer.
// meta new_type(name: ident, inner: type) { ... }

// Block macro
meta timed(body: block) {
    body => {
        let start = Time.now();
        let result = $body;
        let elapsed = Time.now() - start;
        print(f"Elapsed: {elapsed}ms");
        result
    }
}

fn main() {
    print("Meta def basic tests parsed");
}
