// @test: verify-pass
// @tier: 3
// @level: L2
// @tags: proof-stability, smt, contracts, postconditions, ensures
// @timeout: 15000
// @expected-proof-time: <70ms

/// Description: Tests SMT stability for postcondition verification
/// Regression Detection: Postcondition verification requires path analysis
/// and should complete within 70ms. Proofs exceeding 140ms or showing
/// non-determinism indicate SMT regression.

// ============================================================================
// Simple Postconditions
// ============================================================================

/// Result equals input
@verify(proof)
fn identity(x: Int) -> Int {
    contract#"
        ensures result == x;
    "
    x
}

/// Result is non-negative
@verify(proof)
fn absolute_value(x: Int) -> Int {
    contract#"
        ensures result >= 0;
        ensures result == x || result == -x;
    "
    if x >= 0 { x } else { -x }
}

/// Result is bounded
@verify(proof)
fn clamp(value: Int, min: Int, max: Int) -> Int {
    contract#"
        requires min <= max;
        ensures result >= min;
        ensures result <= max;
        ensures result == value || result == min || result == max;
    "
    if value < min { min }
    else if value > max { max }
    else { value }
}

/// Result is within range of inputs
@verify(proof)
fn average(a: Int, b: Int) -> Int {
    contract#"
        ensures (a <= b) implies (result >= a && result <= b);
        ensures (b <= a) implies (result >= b && result <= a);
    "
    (a + b) / 2
}

// ============================================================================
// Relational Postconditions
// ============================================================================

/// Result is greater than input
@verify(proof)
fn increment(x: Int) -> Int {
    contract#"
        ensures result == x + 1;
        ensures result > x;
    "
    x + 1
}

/// Result is double of input
@verify(proof)
fn double(x: Int) -> Int {
    contract#"
        ensures result == x * 2;
        ensures x >= 0 implies result >= x;
    "
    x * 2
}

/// Result preserves sign
@verify(proof)
fn square_preserve_info(x: Int) -> (Int, Bool) {
    contract#"
        ensures result.0 == x * x;
        ensures result.0 >= 0;
        ensures result.1 == (x >= 0);
    "
    (x * x, x >= 0)
}

// ============================================================================
// Collection Postconditions
// ============================================================================

/// Length increases by one
@verify(proof)
fn push<T>(list: List<T>, item: T) -> List<T> {
    contract#"
        ensures result.len() == list.len() + 1;
        ensures result[result.len() - 1] == item;
    "
    list.push(item)
}

/// Length decreases by one
@verify(proof)
fn pop<T>(list: List<T>) -> (List<T>, T) {
    contract#"
        requires list.len() > 0;
        ensures result.0.len() == list.len() - 1;
        ensures result.1 == list[list.len() - 1];
    "
    list.pop()
}

/// Concatenation length
@verify(proof)
fn concat<T>(a: List<T>, b: List<T>) -> List<T> {
    contract#"
        ensures result.len() == a.len() + b.len();
    "
    a.concat(b)
}

/// Filter reduces length
@verify(proof)
fn filter<T>(list: List<T>, pred: fn(&T) -> Bool) -> List<T> {
    contract#"
        ensures result.len() <= list.len();
    "
    let mut filtered: List<T> = list![];
    for item in list {
        if pred(&item) {
            filtered = filtered.push(item);
        }
    }
    filtered
}

/// Map preserves length
@verify(proof)
fn map<T, U>(list: List<T>, f: fn(T) -> U) -> List<U> {
    contract#"
        ensures result.len() == list.len();
    "
    let mut mapped: List<U> = list![];
    for item in list {
        mapped = mapped.push(f(item));
    }
    mapped
}

// ============================================================================
// Conditional Postconditions
// ============================================================================

/// Different guarantees based on input
@verify(proof)
fn sign(x: Int) -> Int {
    contract#"
        ensures x > 0 implies result == 1;
        ensures x < 0 implies result == -1;
        ensures x == 0 implies result == 0;
        ensures result == -1 || result == 0 || result == 1;
    "
    if x > 0 { 1 }
    else if x < 0 { -1 }
    else { 0 }
}

/// Optional result conditions
@verify(proof)
fn find<T: Eq>(list: &List<T>, target: &T) -> Maybe<Int> {
    contract#"
        ensures match result {
            Some(idx) => idx >= 0 && idx < list.len() && list[idx] == *target,
            None => forall i. 0 <= i < list.len() implies list[i] != *target
        };
    "
    for i in 0..list.len() {
        if list[i] == *target {
            return Some(i);
        }
    }
    None
}

/// Result type conditions
@verify(proof)
fn safe_divide(a: Int, b: Int) -> Result<Int, Text> {
    contract#"
        ensures match result {
            Ok(q) => b != 0 && q == a / b,
            Err(_) => b == 0
        };
    "
    if b == 0 {
        Err("Division by zero")
    } else {
        Ok(a / b)
    }
}

// ============================================================================
// Preservation Postconditions
// ============================================================================

/// Preserves element values
@verify(proof)
fn reverse<T: Eq>(list: List<T>) -> List<T> {
    contract#"
        ensures result.len() == list.len();
        ensures forall i. 0 <= i < list.len() implies result[i] == list[list.len() - 1 - i];
    "
    let mut reversed: List<T> = list![];
    for i in (0..list.len()).rev() {
        reversed = reversed.push(list[i]);
    }
    reversed
}

/// Preserves sum
@verify(proof)
fn redistribute(a: Int, b: Int) -> (Int, Int) {
    contract#"
        ensures result.0 + result.1 == a + b;
    "
    let total = a + b;
    let half = total / 2;
    (half, total - half)
}

/// Preserves sorted property
@verify(proof)
fn insert_sorted(sorted: List<Int>, value: Int) -> List<Int> {
    contract#"
        requires forall i, j. 0 <= i < j < sorted.len() implies sorted[i] <= sorted[j];
        ensures result.len() == sorted.len() + 1;
        ensures forall i, j. 0 <= i < j < result.len() implies result[i] <= result[j];
    "
    let mut result: List<Int> = list![];
    let mut inserted = false;
    for item in sorted {
        if !inserted && value <= item {
            result = result.push(value);
            inserted = true;
        }
        result = result.push(item);
    }
    if !inserted {
        result = result.push(value);
    }
    result
}

// ============================================================================
// Quantified Postconditions
// ============================================================================

/// All elements satisfy property after transformation
@verify(proof)
fn make_positive(list: List<Int>) -> List<Int> {
    contract#"
        ensures result.len() == list.len();
        ensures forall i. 0 <= i < result.len() implies result[i] >= 0;
    "
    let mut result: List<Int> = list![];
    for x in list {
        result = result.push(if x >= 0 { x } else { -x });
    }
    result
}

/// Exists element with property
@verify(proof)
fn insert_unique<T: Eq>(list: List<T>, item: T) -> List<T> {
    contract#"
        ensures exists i. 0 <= i < result.len() && result[i] == item;
    "
    if list.contains(&item) {
        list
    } else {
        list.push(item)
    }
}

/// Minimum element property
@verify(proof)
fn find_min(list: &List<Int>) -> Maybe<Int> {
    contract#"
        requires list.len() > 0;
        ensures match result {
            Some(min) => forall i. 0 <= i < list.len() implies min <= list[i],
            None => list.len() == 0
        };
    "
    if list.is_empty() {
        return None;
    }
    let mut min = list[0];
    for i in 1..list.len() {
        if list[i] < min {
            min = list[i];
        }
    }
    Some(min)
}

// ============================================================================
// Old Value Postconditions
// ============================================================================

/// Increment preserves relative order
@verify(proof)
fn increment_all(list: &mut List<Int>) {
    contract#"
        ensures list.len() == old(list.len());
        ensures forall i. 0 <= i < list.len() implies list[i] == old(list[i]) + 1;
    "
    for i in 0..list.len() {
        list[i] += 1;
    }
}

/// Swap preserves values
@verify(proof)
fn swap<T>(a: T, b: T) -> (T, T) {
    contract#"
        ensures result.0 == b;
        ensures result.1 == a;
    "
    (b, a)
}

/// Counter increment
@verify(proof)
fn count_up(counter: Int) -> Int {
    contract#"
        ensures result == counter + 1;
        ensures result > counter;
    "
    counter + 1
}

// ============================================================================
// Frame Postconditions
// ============================================================================

type Point is { x: Int, y: Int };

/// Only x changes
@verify(proof)
fn move_x(p: Point, dx: Int) -> Point {
    contract#"
        ensures result.x == p.x + dx;
        ensures result.y == p.y;  // Frame: y unchanged
    "
    Point { x: p.x + dx, y: p.y }
}

/// Only y changes
@verify(proof)
fn move_y(p: Point, dy: Int) -> Point {
    contract#"
        ensures result.x == p.x;  // Frame: x unchanged
        ensures result.y == p.y + dy;
    "
    Point { x: p.x, y: p.y + dy }
}

/// Both change predictably
@verify(proof)
fn move_point(p: Point, dx: Int, dy: Int) -> Point {
    contract#"
        ensures result.x == p.x + dx;
        ensures result.y == p.y + dy;
    "
    Point { x: p.x + dx, y: p.y + dy }
}

// ============================================================================
// Derived Postconditions
// ============================================================================

/// Distance is non-negative
@verify(proof)
fn manhattan_distance(p1: &Point, p2: &Point) -> Int {
    contract#"
        ensures result >= 0;
    "
    let dx = if p1.x >= p2.x { p1.x - p2.x } else { p2.x - p1.x };
    let dy = if p1.y >= p2.y { p1.y - p2.y } else { p2.y - p1.y };
    dx + dy
}

/// Sum of list
@verify(proof)
fn sum(list: &List<Int>) -> Int {
    contract#"
        ensures forall i. 0 <= i < list.len() && list[i] >= 0 implies result >= list[i];
    "
    let mut total = 0;
    for x in list {
        total += *x;
    }
    total
}

/// Product of positive numbers
@verify(proof)
fn product_positive(list: &List<Int>) -> Int {
    contract#"
        requires list.len() > 0;
        requires forall i. 0 <= i < list.len() implies list[i] > 0;
        ensures result > 0;
    "
    let mut prod = 1;
    for x in list {
        prod *= *x;
    }
    prod
}

// ============================================================================
// Idempotency Postconditions
// ============================================================================

/// Sort is idempotent
@verify(proof)
fn sort(list: List<Int>) -> List<Int> {
    contract#"
        ensures forall i, j. 0 <= i < j < result.len() implies result[i] <= result[j];
        ensures result.len() == list.len();
        // Idempotency: sorting a sorted list returns same list
    "
    // Simple insertion sort for verification
    let mut sorted: List<Int> = list![];
    for x in list {
        sorted = insert_sorted_helper(sorted, x);
    }
    sorted
}

fn insert_sorted_helper(sorted: List<Int>, value: Int) -> List<Int> {
    let mut result: List<Int> = list![];
    let mut inserted = false;
    for item in sorted {
        if !inserted && value <= item {
            result = result.push(value);
            inserted = true;
        }
        result = result.push(item);
    }
    if !inserted {
        result = result.push(value);
    }
    result
}

/// Normalize is idempotent
@verify(proof)
fn normalize_path(path: Text) -> Text {
    contract#"
        ensures !result.contains("//");
        ensures !result.ends_with("/") || result == "/";
    "
    path.replace("//", "/").trim_end_matches("/").to_string()
}

// ============================================================================
// Main Test Entry
// ============================================================================

fn main() {
    // Simple postconditions
    assert(identity(42) == 42);
    assert(absolute_value(-5) == 5);
    assert(clamp(50, 0, 100) == 50);
    assert(average(10, 20) == 15);

    // Relational postconditions
    assert(increment(5) == 6);
    assert(double(7) == 14);
    let (sq, was_pos) = square_preserve_info(-3);
    assert(sq == 9 && !was_pos);

    // Collection postconditions
    let list = list![1, 2, 3];
    assert(push(list, 4).len() == 4);
    let (remaining, popped) = pop(list![1, 2, 3]);
    assert(remaining.len() == 2 && popped == 3);
    assert(concat(list![1, 2], list![3, 4]).len() == 4);

    // Conditional postconditions
    assert(sign(5) == 1);
    assert(sign(-3) == -1);
    assert(sign(0) == 0);
    assert(find(&list![1, 2, 3, 4, 5], &3) == Some(2));
    assert(safe_divide(10, 2) == Ok(5));
    assert(safe_divide(10, 0).is_err());

    // Preservation postconditions
    assert(reverse(list![1, 2, 3]) == list![3, 2, 1]);
    let (a, b) = redistribute(7, 3);
    assert(a + b == 10);
    assert(insert_sorted(list![1, 3, 5], 4) == list![1, 3, 4, 5]);

    // Quantified postconditions
    let positives = make_positive(list![-1, 2, -3, 4]);
    for p in positives {
        assert(p >= 0);
    }
    assert(find_min(&list![3, 1, 4, 1, 5]) == Some(1));

    // Frame postconditions
    let p = Point { x: 10, y: 20 };
    let moved = move_x(p, 5);
    assert(moved.x == 15 && moved.y == 20);

    // Derived postconditions
    let p1 = Point { x: 0, y: 0 };
    let p2 = Point { x: 3, y: 4 };
    assert(manhattan_distance(&p1, &p2) == 7);

    // Idempotency
    let sorted = sort(list![3, 1, 4, 1, 5]);
    assert(sorted == sort(sorted));

    println("All postcondition tests verified successfully!");
}
