// Recursion patterns edge case
// Tests compiler handling of recursive functions and types

// Direct recursion
fn factorial(n: Int) -> Int {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

// Tail recursion
fn factorial_tail(n: Int, acc: Int) -> Int {
    if n <= 1 {
        acc
    } else {
        factorial_tail(n - 1, n * acc)
    }
}

// Mutual recursion
fn is_even(n: Int) -> Bool {
    if n == 0 {
        true
    } else {
        is_odd(n - 1)
    }
}

fn is_odd(n: Int) -> Bool {
    if n == 0 {
        false
    } else {
        is_even(n - 1)
    }
}

// Recursive data type
type Tree is
    Leaf(Int) |
    Node(Heap<Tree>, Int, Heap<Tree>);

// Recursive function on recursive type
fn tree_sum(tree: Tree) -> Int {
    match tree {
        Tree.Leaf(n) => n,
        Tree.Node(left, value, right) => {
            tree_sum(*left) + value + tree_sum(*right)
        }
    }
}

fn tree_depth(tree: Tree) -> Int {
    match tree {
        Tree.Leaf(_) => 1,
        Tree.Node(left, _, right) => {
            1 + max(tree_depth(*left), tree_depth(*right))
        }
    }
}

// Fibonacci with multiple recursive calls
fn fibonacci(n: Int) -> Int {
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    }
}

// Ackermann function (grows extremely fast)
fn ackermann(m: Int, n: Int) -> Int {
    if m == 0 {
        n + 1
    } else if n == 0 {
        ackermann(m - 1, 1)
    } else {
        ackermann(m - 1, ackermann(m, n - 1))
    }
}

// Recursive list processing
type IntList is
    Nil |
    Cons(Int, Heap<IntList>);

fn list_length(list: IntList) -> Int {
    match list {
        IntList.Nil => 0,
        IntList.Cons(_, tail) => 1 + list_length(*tail)
    }
}

fn list_sum(list: IntList) -> Int {
    match list {
        IntList.Nil => 0,
        IntList.Cons(head, tail) => head + list_sum(*tail)
    }
}

fn list_map(list: IntList, f: function(Int) -> Int) -> IntList {
    match list {
        IntList.Nil => IntList.Nil,
        IntList.Cons(head, tail) => {
            IntList.Cons(f(head), Heap(list_map(*tail, f)))
        }
    }
}

// Continuation-passing style
fn factorial_cps(n: Int, k: function(Int) -> Int) -> Int {
    if n <= 1 {
        k(1)
    } else {
        factorial_cps(n - 1, |r| k(n * r))
    }
}

fn main() {
    // Test direct recursion
    assert factorial(5) == 120;
    assert factorial(0) == 1;
    assert factorial(1) == 1;

    // Test tail recursion
    assert factorial_tail(5, 1) == 120;

    // Test mutual recursion
    assert is_even(0) == true;
    assert is_even(1) == false;
    assert is_even(10) == true;
    assert is_odd(0) == false;
    assert is_odd(1) == true;
    assert is_odd(11) == true;

    // Test fibonacci
    assert fibonacci(0) == 0;
    assert fibonacci(1) == 1;
    assert fibonacci(10) == 55;

    // Test Ackermann (careful - grows fast!)
    assert ackermann(0, 0) == 1;
    assert ackermann(1, 1) == 3;
    assert ackermann(2, 2) == 7;
    // ackermann(3, 3) == 61
    // ackermann(4, 2) is already huge!
}
