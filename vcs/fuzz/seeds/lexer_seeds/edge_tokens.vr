// Punctuation edge cases
fn punctuation_edge_cases() {
    // Empty structures
    let empty_tuple = ();
    let empty_array: [Int; 0] = [];
    let empty_record = Unit {};

    // Deeply nested
    let deep = ((((1))));
    let deep_arr = [[[[1]]]];
    let deep_gen = List<List<List<Int>>>;

    // Trailing commas
    let tuple = (1, 2, 3,);
    let array = [1, 2, 3,];
    let record = Point { x: 1, y: 2, };
}

// Token boundary edge cases
fn token_boundary_tests() {
    // No space between tokens
    let ab=1;let cd=2;

    // Identifiers that look like keywords
    let letx = 1;
    let fnx = 2;
    let isx = 3;
    let typex = 4;
    let ifx = 5;
    let elsex = 6;

    // Keywords that are prefixes of identifiers
    let let_var = 7;
    let fn_ptr = 8;
    let is_valid = 9;
    let type_name = 10;
    let if_then = 11;

    // Numbers followed by identifiers
    let num = 123abc;        // Should be error or 123 then abc
}

