# LLVM build artifacts
# These are generated by build.sh and should not be committed

# Cloned LLVM source (large, ~1GB)
llvm-project/

# CMake build directory (very large, ~30GB)
build/

# Installed LLVM libraries and headers (~2-5GB)
# This is what gets used by verum_llvm_sys
install/

# Release archives (created by --package)
*.tar.xz
*.tar.gz
*.zip

# CMake cache files
CMakeCache.txt
CMakeFiles/

# Editor/IDE files
.vscode/
.idea/
*.swp
*~
