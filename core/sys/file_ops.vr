module sys.file_ops;

// =============================================================================
// sys/file_ops.vr - File Operations (replaces C verum_file_* functions)
// =============================================================================
// Layer: 1 (I/O)
// Dependencies: sys/raw
// =============================================================================
//

// Pure Verum implementation of file operations. Compiled through
// VBC → LLVM pipeline. No C runtime dependency.
//

// =============================================================================

mount core.*;
// Raw-intrinsic mount. The pre-migration `mount super.raw.*` pointed
// at a `core/sys/raw.vr` file that no longer exists — declarations
// migrated to `core/intrinsics/runtime/os.vr`. Same architectural fix
// as the one already landed for time_ops.vr.
mount core.intrinsics.runtime.os.{
    __file_open_raw,
    __file_close_raw,
    __file_read_to_string_raw,
    __file_write_string_raw,
    __file_write_text_raw,
    __file_delete_raw,
    __file_size_raw,
};

// =============================================================================
// Default file-creation mode
// =============================================================================
// rw-r--r-- — POSIX-canonical default for newly-created files.  Matches
// `core.io.file::DEFAULT_FILE_MODE` so the two file-creation paths
// (sys layer + io layer) cannot drift.
const DEFAULT_FILE_MODE: Int = 0o644;

// Open mode flags (matching POSIX O_* values)
public type OpenMode is {
    flags: Int,
};

implement OpenMode {
    /// Read-only
    public fn read() -> OpenMode { OpenMode { flags: 0 } }
    /// Write-only (create + truncate)
    public fn write() -> OpenMode { OpenMode { flags: 0x301 } }
    /// Read + write
    public fn read_write() -> OpenMode { OpenMode { flags: 2 } }
    /// Append
    public fn append() -> OpenMode { OpenMode { flags: 0x409 } }
    /// Create + write
    public fn create() -> OpenMode { OpenMode { flags: 0x241 } }
}

/// Read an entire file to Text.
public fn read_file(path: Text) -> Maybe<Text> {
    let content = __file_read_to_string_raw(path);
    if content.len() == 0 {
        // Check if file exists by trying to open
        let fd = __file_open_raw(path, 0, 0);
        if fd < 0 {
            return None;
        }
        __file_close_raw(fd);
        // File exists but is empty
        return Some("");
    }
    Some(content)
}

/// Write Text to file (create/truncate).
public fn write_file(path: Text, content: Text) -> Bool {
    let result = __file_write_string_raw(path, content);
    result >= 0
}

/// Append Text to file.
///
/// Opens the file with O_WRONLY|O_CREAT|O_APPEND (creating it if
/// absent) and writes `content` through the opened fd so O_APPEND
/// semantics survive.  Pre-fix this delegated to the path-based
/// `__file_write_string_raw` for the actual write — which silently
/// re-opened the file with O_TRUNC and clobbered the existing
/// contents.  Sister fix to the file_ops audit (§5 deferral closed).
public fn append_file(path: Text, content: Text) -> Bool {
    let fd = __file_open_raw(path, 0x409, DEFAULT_FILE_MODE);
    if fd < 0 {
        return false;
    }
    let written = __file_write_text_raw(fd, content);
    __file_close_raw(fd);
    written >= 0
}

/// Delete a file.
public fn delete_file(path: Text) -> Bool {
    __file_delete_raw(path) >= 0
}

/// Check if a file exists.
public fn file_exists(path: Text) -> Bool {
    let fd = __file_open_raw(path, 0, 0);
    if fd < 0 {
        return false;
    }
    __file_close_raw(fd);
    true
}

/// Get file size in bytes.
public fn file_size(path: Text) -> Int {
    let fd = __file_open_raw(path, 0, 0);
    if fd < 0 {
        return -1;
    }
    let size = __file_size_raw(fd);
    __file_close_raw(fd);
    size
}
