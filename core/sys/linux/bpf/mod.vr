// =============================================================================
// sys/linux/bpf/mod.vr — eBPF program + map userspace API
// =============================================================================
// Layer: 0 (Kernel — alongside sys/linux/io.vr)
// Spec: https://docs.kernel.org/bpf/
//       https://www.kernel.org/doc/html/latest/bpf/instruction-set.html
//       https://elixir.bootlin.com/linux/latest/source/include/uapi/linux/bpf.h
//
// This module wraps the `bpf()` syscall family with typed Verum APIs
// for program loading, map operations, and attachment to the standard
// attach points (XDP, TC, socket filter, tracepoint, kprobe, cgroup).
//
// The Verum → eBPF bytecode codegen path (for writing "eBPF hot-path
// predicates" directly in Verum) lives in verum_codegen; this module
// only covers the kernel-facing runtime API.
//
// # Module layout
//
// ```
// core.sys.linux.bpf
// ├── mod.vr       — re-exports + constants
// ├── program.vr   — Program types + load / attach
// ├── map.vr       — Map types + lookup / update / delete
// └── error.vr     — BpfError
// ```
// =============================================================================

module core.sys.linux.bpf;

public module error;
public module program;
public module map;

public mount .error.BpfError;

public mount .program.ProgramType;
public mount .program.AttachType;
public mount .program.ProgramDescriptor;
public mount .program.ProgramBytecode;
public mount .program.Link;
public mount .program.load_program;
public mount .program.attach_xdp;
public mount .program.attach_tc;
public mount .program.attach_cgroup;
public mount .program.attach_tracepoint;
public mount .program.attach_kprobe;

public mount .map.MapType;
public mount .map.MapDescriptor;
public mount .map.MapConfig;
public mount .map.create_map;
public mount .map.map_lookup;
public mount .map.map_update;
public mount .map.map_delete;
public mount .map.map_iterate;
