// =============================================================================
// Types
// =============================================================================

/// Timespec structure for nanosleep, clock_gettime, etc.
@repr(C)
public type Timespec is {
    tv_sec: Int64,
    tv_nsec: Int64,
};

// =============================================================================
// Safe Syscall Wrappers
// =============================================================================

/// Read from a file descriptor.
public fn read(fd: FileDesc, buf: &mut [Byte]) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(SYS_READ, fd.as_raw(), buf.as_ptr() as Int, buf.len(), 0, 0, 0)
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

/// Write to a file descriptor.
public fn write(fd: FileDesc, buf: &[Byte]) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(SYS_WRITE, fd.as_raw(), buf.as_ptr() as Int, buf.len(), 0, 0, 0)
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

/// Read at explicit `offset` without moving the file cursor (POSIX `pread`).
///
/// Atomic with respect to concurrent `pread` / `pwrite` on the same `fd`,
/// which is the contract `read + lseek` does NOT satisfy. Required by the
/// SQLite VFS layer (sqlite-native.md Gap 3) and by any code that needs
/// an explicit-offset read path — always prefer this over `read` + `lseek`.
/// Partial reads at EOF return `Ok(n)` where `n < buf.len()`.
public fn pread(fd: FileDesc, buf: &mut [Byte], offset: Int) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(
            SYS_PREAD64,
            fd.as_raw(),
            buf.as_ptr() as Int,
            buf.len(),
            offset,
            0,
            0,
        )
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

/// Write at explicit `offset` without moving the file cursor (POSIX `pwrite`).
/// See `pread` for the atomicity contract. Partial writes return `Ok(n)`
/// with `n < buf.len()` — callers must loop until the full buffer lands
/// if they require all-or-nothing semantics.
public fn pwrite(fd: FileDesc, buf: &[Byte], offset: Int) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(
            SYS_PWRITE64,
            fd.as_raw(),
            buf.as_ptr() as Int,
            buf.len(),
            offset,
            0,
            0,
        )
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

/// Close a file descriptor.
public fn close(fd: FileDesc) -> Result<(), OSError> {
    let result = unsafe {
        syscall_raw(SYS_CLOSE, fd.as_raw(), 0, 0, 0, 0, 0)
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
    }
}

/// Memory map a region.
public fn mmap(
    addr: Int,
    len: Int,
    prot: MemProt,
    flags: MapFlags,
    fd: FileDesc,
    offset: Int
) -> Result<&unsafe Byte, OSError> {
    let result = unsafe {
        syscall_raw(
            SYS_MMAP,
            addr,
            len,
            prot.to_unix_flags(),
            flags.to_unix_flags(),
            fd.as_raw(),
            offset
        )
    };
    // MAP_FAILED is typically -1, but syscall returns -errno
    if result < 0 && result > -4096 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result as &unsafe Byte)
    }
}

/// Unmap a memory region.
public fn munmap(addr: &unsafe Byte, len: Int) -> Result<(), OSError> {
    let result = unsafe {
        syscall_raw(SYS_MUNMAP, addr as Int, len, 0, 0, 0, 0)
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
    }
}

/// Get the current process ID.
public fn getpid() -> Int {
    unsafe { syscall_raw(SYS_GETPID, 0, 0, 0, 0, 0, 0) }
}

/// Get the current thread ID.
public fn gettid() -> Int {
    unsafe { syscall_raw(SYS_GETTID, 0, 0, 0, 0, 0, 0) }
}

/// Exit the current thread.
public fn exit(code: Int) -> ! {
    unsafe { syscall_raw(SYS_EXIT, code, 0, 0, 0, 0, 0) };
    // This should never return
    @unreachable()
}

/// Exit the process (all threads).
public fn exit_group(code: Int) -> ! {
    unsafe { syscall_raw(SYS_EXIT_GROUP, code, 0, 0, 0, 0, 0) };
    @unreachable()
}

/// Nanosleep (high-precision sleep).
/// Returns remaining time if interrupted.
public fn nanosleep(seconds: Int, nanoseconds: Int) -> Result<(Int, Int), OSError> {
    // timespec structure: [seconds: Int64, nanoseconds: Int64]
    let req: [Int; 2] = [seconds, nanoseconds];
    let rem: [Int; 2] = [0, 0];

    let result = unsafe {
        syscall_raw(SYS_NANOSLEEP, &req as Int, &rem as Int, 0, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok((rem[0], rem[1]))
    }
}

/// POSIX-style nanosleep accepting a Timespec struct reference.
/// The second parameter (remainder) is optional - pass null to ignore.
public fn nanosleep_ts(req: &Timespec, rem: Maybe<&mut Timespec>) -> Result<(), OSError> {
    let result = nanosleep(req.tv_sec, req.tv_nsec);
    match result {
        Ok((rem_sec, rem_nsec)) => {
            match rem {
                Some(r) => {
                    r.tv_sec = rem_sec;
                    r.tv_nsec = rem_nsec;
                },
                None => {},
            };
            Ok(())
        },
        Err(e) => Err(e),
    }
}

/// Get random bytes from the kernel.
public fn getrandom(buf: &mut [Byte], flags: Int) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(SYS_GETRANDOM, buf.as_ptr() as Int, buf.len(), flags, 0, 0, 0)
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

// =============================================================================
// Terminal ioctl Operations
// =============================================================================

/// Generic ioctl syscall wrapper.
public fn ioctl(fd: FileDesc, request: Int, arg: Int) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(SYS_IOCTL, fd.as_raw(), request, arg, 0, 0, 0)
    };
    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

/// Check if a file descriptor refers to a terminal.
public fn isatty(fd: FileDesc) -> Bool {
    // TIOCGWINSZ succeeds only on terminals
    let mut ws: [Byte; 8] = [0; 8];
    let result = unsafe {
        syscall_raw(SYS_IOCTL, fd.as_raw(), TIOCGWINSZ, &ws as Int, 0, 0, 0)
    };
    result == 0
}

// =============================================================================
// Futex Operations
// =============================================================================

/// Futex operation codes.
public const FUTEX_WAIT: Int = 0;
public const FUTEX_WAKE: Int = 1;
public const FUTEX_WAIT_PRIVATE: Int = 128;
public const FUTEX_WAKE_PRIVATE: Int = 129;

/// Futex wait operation.
public fn futex_wait(addr: &Int, expected: Int, timeout_ns: Maybe<Int>) -> Result<(), OSError> {
    let (timeout_ptr, timeout_sec, timeout_nsec) = match timeout_ns {
        Some(ns) => {
            let sec = ns / 1_000_000_000;
            let nsec = ns % 1_000_000_000;
            let ts: [Int; 2] = [sec, nsec];
            (&ts as Int, sec, nsec)
        }
        None => (0, 0, 0),
    };

    let result = unsafe {
        syscall_raw(SYS_FUTEX, addr as Int, FUTEX_WAIT_PRIVATE, expected, timeout_ptr, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
    }
}

/// Futex wake operation.
public fn futex_wake(addr: &Int, count: Int) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(SYS_FUTEX, addr as Int, FUTEX_WAKE_PRIVATE, count, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

