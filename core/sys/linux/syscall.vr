/// Create a directory.
public fn mkdir(path: &[Byte], mode: Int) -> Result<(), OSError> {
    // Ensure null-terminated path
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe {
        syscall_raw(SYS_MKDIR, path_buf.as_ptr() as Int, mode, 0, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
    }
}

/// Remove a directory.
public fn rmdir(path: &[Byte]) -> Result<(), OSError> {
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe {
        syscall_raw(SYS_RMDIR, path_buf.as_ptr() as Int, 0, 0, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
