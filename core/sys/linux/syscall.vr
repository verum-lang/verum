/// Duplicate a file descriptor.
public fn dup(oldfd: FileDesc) -> Result<FileDesc, OSError> {
    let result = unsafe {
        syscall_raw(SYS_DUP, oldfd.as_raw(), 0, 0, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
