/// Open flags for file operations.
public const O_RDONLY: Int = 0;       // Read only
public const O_WRONLY: Int = 1;       // Write only
public const O_RDWR: Int = 2;         // Read and write
public const O_CREAT: Int = 0o100;    // Create if not exists
public const O_EXCL: Int = 0o200;     // Error if exists
public const O_TRUNC: Int = 0o1000;   // Truncate file
public const O_APPEND: Int = 0o2000;  // Append mode
public const O_CLOEXEC: Int = 0o2000000; // Close on exec

/// Seek whence values.
public const SEEK_SET: Int = 0;  // From beginning
public const SEEK_CUR: Int = 1;  // From current position
public const SEEK_END: Int = 2;  // From end

/// Stat structure for fstat/stat.
@repr(C)
public type Stat is {
    st_dev: UInt64,
    st_ino: UInt64,
    st_nlink: UInt64,
    st_mode: UInt32,
    st_uid: UInt32,
    st_gid: UInt32,
    _pad0: UInt32,
    st_rdev: UInt64,
    st_size: Int64,
    st_blksize: Int64,
    st_blocks: Int64,
    st_atime_sec: Int64,
    st_atime_nsec: Int64,
    st_mtime_sec: Int64,
    st_mtime_nsec: Int64,
    st_ctime_sec: Int64,
    st_ctime_nsec: Int64,
    _unused: [Int64; 3],
};

/// Open a file.
public fn open(path: &[Byte], flags: Int, mode: Int) -> Result<FileDesc, OSError> {
    // Ensure null-terminated path
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe {
        syscall_raw(SYS_OPEN, path_buf.as_ptr() as Int, flags, mode, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(FileDesc.from_raw(result))
    }
}

/// Open a file relative to a directory file descriptor.
public fn openat(dirfd: FileDesc, path: &[Byte], flags: Int, mode: Int) -> Result<FileDesc, OSError> {
    // Ensure null-terminated path
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe {
        syscall_raw(SYS_OPENAT, dirfd.as_raw(), path_buf.as_ptr() as Int, flags, mode, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(FileDesc.from_raw(result))
    }
}

/// Seek within a file.
public fn lseek(fd: FileDesc, offset: Int, whence: Int) -> Result<Int, OSError> {
    let result = unsafe {
        syscall_raw(SYS_LSEEK, fd.as_raw(), offset, whence, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(result)
    }
}

/// Get file status.
public fn fstat(fd: FileDesc, stat: &mut Stat) -> Result<(), OSError> {
    let result = unsafe {
        syscall_raw(SYS_FSTAT, fd.as_raw(), stat as Int, 0, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
    }
}

/// Get file status by path.
public fn stat(path: &[Byte], stat_buf: &mut Stat) -> Result<(), OSError> {
    // Ensure null-terminated path
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe {
        syscall_raw(SYS_STAT, path_buf.as_ptr() as Int, stat_buf as Int, 0, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
    }
}

/// Get symbolic link status (doesn't follow symlinks).
public fn lstat(path: &[Byte], stat_buf: &mut Stat) -> Result<(), OSError> {
    // Ensure null-terminated path
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe {
        syscall_raw(SYS_LSTAT, path_buf.as_ptr() as Int, stat_buf as Int, 0, 0, 0, 0)
    };

    if result < 0 {
        Err(OSError.from_code(-result as Int))
    } else {
        Ok(())
