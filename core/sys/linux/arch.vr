module sys.linux.arch;

// =============================================================================
// sys/linux/arch.vr - Architecture-specific Linux syscall numbers
// =============================================================================
// Layer: 0 (Core)
// Dependencies: (none)
// Platform: Linux (x86_64, aarch64)
// =============================================================================
@cfg(target_os = "linux")
//
// Linux syscall numbers differ between CPU architectures:
//   - x86_64 uses the arch-specific table in arch/x86/entry/syscalls/syscall_64.tbl
//   - aarch64 uses the asm-generic unified table (include/uapi/asm-generic/unistd.h)
//
// Syscalls numbered >= 425 are typically aligned across both architectures
// (they are post-unification additions such as io_uring_*, clone3, openat2,
// epoll_pwait2, futex_waitv).
//
// When a syscall exists on both architectures, both values are exported
// under the same name, with @cfg(target_arch = "...") selecting one at
// compile time. When a syscall is present only on x86_64 (e.g., SYS_OPEN,
// SYS_STAT, SYS_ARCH_PRCTL), only the x86_64 variant is declared and the
// aarch64 code path must use the portable equivalent (openat, newfstatat,
// thread-pointer access via tpidr_el0, etc.).
//
// Authoritative source of numbers:
//   - x86_64: https://github.com/torvalds/linux/blob/master/arch/x86/entry/syscalls/syscall_64.tbl
//   - aarch64: https://github.com/torvalds/linux/blob/master/include/uapi/asm-generic/unistd.h
// =============================================================================

// -----------------------------------------------------------------------------
// File I/O — present on both architectures
// -----------------------------------------------------------------------------

@cfg(target_arch = "x86_64")
public const SYS_READ: Int = 0;
@cfg(target_arch = "aarch64")
public const SYS_READ: Int = 63;

