// SYS_STATX is a modern portable stat syscall; use it as the primary
// stat mechanism on both architectures. aarch64 has no legacy SYS_STAT.
@cfg(target_arch = "x86_64")
public const SYS_STATX: Int = 332;
@cfg(target_arch = "aarch64")
public const SYS_STATX: Int = 291;

// newfstatat (fstatat64) - portable replacement for stat/lstat/fstat.
@cfg(target_arch = "x86_64")
public const SYS_NEWFSTATAT: Int = 262;
@cfg(target_arch = "aarch64")
public const SYS_NEWFSTATAT: Int = 79;

// -----------------------------------------------------------------------------
// x86_64-only legacy file syscalls (absent on aarch64)
//
// On aarch64, use the portable *at variants with AT_FDCWD instead:
//   open       -> openat(AT_FDCWD, ...)
//   stat/lstat -> newfstatat / statx
//   access     -> faccessat(AT_FDCWD, ...)
//   poll       -> ppoll
//   pipe       -> pipe2
//   select     -> pselect6
//   mkdir      -> mkdirat(AT_FDCWD, ...)
//   rmdir      -> unlinkat(AT_FDCWD, path, AT_REMOVEDIR)
//   unlink     -> unlinkat(AT_FDCWD, path, 0)
//   symlink    -> symlinkat
//   readlink   -> readlinkat
//   rename     -> renameat
//   link       -> linkat
//   chmod      -> fchmodat
//   chown      -> fchownat
//   dup2       -> dup3(oldfd, newfd, 0)
// -----------------------------------------------------------------------------

@cfg(target_arch = "x86_64")
public const SYS_OPEN: Int = 2;

@cfg(target_arch = "x86_64")
public const SYS_STAT: Int = 4;

@cfg(target_arch = "x86_64")
public const SYS_FSTAT: Int = 5;
// aarch64 has no legacy SYS_FSTAT; use newfstatat(fd, "", &buf, AT_EMPTY_PATH).

