module sys.linux.io;

// =============================================================================
// sys/linux/io.vr - Linux Asynchronous I/O (io_uring + epoll fallback)
// =============================================================================
// Layer: 0 (Core)
// Dependencies: sys/linux/syscall, sys/common
// Platform: Linux x86_64
// =============================================================================
//
// This module provides completion-based I/O for Linux using:
// - io_uring (Linux 5.1+): Primary, highest performance
// - epoll: Fallback for older kernels, wrapped in completion semantics
//
// io_uring is a completion-based I/O interface that:
// - Batches multiple operations in single syscall
// - Provides async operation submission via shared memory rings
// - Minimizes kernel/userspace transitions
//
// Spec: docs/architecture/new-arch-spec.md Section 5.5 (Cross-Platform IOEngine)
// =============================================================================

mount sys.common.{OSError, FileDesc, IOVec};
mount core.intrinsics.{
    atomic_load_u32, atomic_store_u32,
    ORDERING_ACQUIRE, ORDERING_RELEASE,
};
mount sys.io_engine.{
    IOEngine, CompletionOp, CompletionResult, Duration,
    ValidFd, Fd, RawSocketAddr, TimeSpec, MsgHdr,
    IoError as EngineIoError,
};
mount sys.linux.syscall.{
    syscall_raw,
    SYS_IO_URING_SETUP, SYS_IO_URING_ENTER, SYS_IO_URING_REGISTER,
    SYS_EPOLL_CREATE1, SYS_EPOLL_CTL, SYS_EPOLL_PWAIT,
    SYS_MMAP, SYS_MUNMAP, SYS_CLOSE, SYS_EVENTFD, SYS_READ, SYS_WRITE,
    read, write,
};
mount sys.linux.errno.{EAGAIN, EINTR, ENOSYS};

// =============================================================================
// io_uring Constants
// =============================================================================

/// io_uring_setup flags
public const IORING_SETUP_IOPOLL: UInt32 = 1 << 0;      // Use polling for I/O completion
public const IORING_SETUP_SQPOLL: UInt32 = 1 << 1;      // Use kernel thread for SQ polling
public const IORING_SETUP_SQ_AFF: UInt32 = 1 << 2;      // Set SQ affinity
public const IORING_SETUP_CQSIZE: UInt32 = 1 << 3;      // Custom CQ size
public const IORING_SETUP_CLAMP: UInt32 = 1 << 4;       // Clamp sizes to limits
public const IORING_SETUP_ATTACH_WQ: UInt32 = 1 << 5;   // Attach to existing wq
public const IORING_SETUP_R_DISABLED: UInt32 = 1 << 6;  // Start with ring disabled
public const IORING_SETUP_SUBMIT_ALL: UInt32 = 1 << 7;  // Continue submit on error

/// io_uring_enter flags
public const IORING_ENTER_GETEVENTS: UInt32 = 1 << 0;   // Wait for completions
public const IORING_ENTER_SQ_WAKEUP: UInt32 = 1 << 1;   // Wake SQ polling thread
public const IORING_ENTER_SQ_WAIT: UInt32 = 1 << 2;     // Wait for SQ space
public const IORING_ENTER_EXT_ARG: UInt32 = 1 << 3;     // Extended argument support

/// io_uring_register opcodes
public const IORING_REGISTER_BUFFERS: UInt32 = 0;
public const IORING_UNREGISTER_BUFFERS: UInt32 = 1;
public const IORING_REGISTER_FILES: UInt32 = 2;
public const IORING_UNREGISTER_FILES: UInt32 = 3;
public const IORING_REGISTER_EVENTFD: UInt32 = 4;
public const IORING_UNREGISTER_EVENTFD: UInt32 = 5;
public const IORING_REGISTER_FILES_UPDATE: UInt32 = 6;
public const IORING_REGISTER_PROBE: UInt32 = 8;
/// Provided-buffer ring register (Linux 5.19+).
public const IORING_REGISTER_PBUF_RING: UInt32 = 22;
public const IORING_UNREGISTER_PBUF_RING: UInt32 = 23;

/// SQE opcodes
public const IORING_OP_NOP: UInt8 = 0;
public const IORING_OP_READV: UInt8 = 1;
public const IORING_OP_WRITEV: UInt8 = 2;
public const IORING_OP_FSYNC: UInt8 = 3;
public const IORING_OP_READ_FIXED: UInt8 = 4;
public const IORING_OP_WRITE_FIXED: UInt8 = 5;
public const IORING_OP_POLL_ADD: UInt8 = 6;
public const IORING_OP_POLL_REMOVE: UInt8 = 7;
public const IORING_OP_SYNC_FILE_RANGE: UInt8 = 8;
public const IORING_OP_SENDMSG: UInt8 = 9;
public const IORING_OP_RECVMSG: UInt8 = 10;
public const IORING_OP_TIMEOUT: UInt8 = 11;
public const IORING_OP_TIMEOUT_REMOVE: UInt8 = 12;
public const IORING_OP_ACCEPT: UInt8 = 13;
public const IORING_OP_ASYNC_CANCEL: UInt8 = 14;
public const IORING_OP_LINK_TIMEOUT: UInt8 = 15;
public const IORING_OP_CONNECT: UInt8 = 16;
public const IORING_OP_FALLOCATE: UInt8 = 17;
public const IORING_OP_OPENAT: UInt8 = 18;
public const IORING_OP_CLOSE: UInt8 = 19;
public const IORING_OP_READ: UInt8 = 22;
public const IORING_OP_WRITE: UInt8 = 23;
public const IORING_OP_SEND: UInt8 = 26;
public const IORING_OP_RECV: UInt8 = 27;
public const IORING_OP_OPENAT2: UInt8 = 28;
public const IORING_OP_SEND_ZC: UInt8 = 33;       // Zero-copy send (Linux 6.0+)
public const IORING_OP_SENDMSG_ZC: UInt8 = 35;    // Zero-copy sendmsg (Linux 6.1+)
public const IORING_OP_SOCKET: UInt8 = 45;

/// Op-specific flags
/// IORING_RECV_MULTISHOT — stay armed until peer closes (Linux 6.0+).
/// Passed in sqe.op_flags of IORING_OP_RECV.
public const IORING_RECV_MULTISHOT: UInt32 = 1 << 1;

/// IORING_ACCEPT_MULTISHOT — pass in sqe.op_flags of IORING_OP_ACCEPT
/// to keep posting new accept CQEs until cancelled (Linux 5.19+).
public const IORING_ACCEPT_MULTISHOT: UInt32 = 1 << 0;

/// IORING_SEND_ZC flags
public const IORING_SEND_ZC_REPORT_USAGE: UInt32 = 1 << 3;

/// SQE flags
public const IOSQE_FIXED_FILE: UInt8 = 1 << 0;
public const IOSQE_IO_DRAIN: UInt8 = 1 << 1;
public const IOSQE_IO_LINK: UInt8 = 1 << 2;
public const IOSQE_IO_HARDLINK: UInt8 = 1 << 3;
public const IOSQE_ASYNC: UInt8 = 1 << 4;
public const IOSQE_BUFFER_SELECT: UInt8 = 1 << 5;
public const IOSQE_CQE_SKIP_SUCCESS: UInt8 = 1 << 6;

/// CQE flags
public const IORING_CQE_F_BUFFER: UInt32 = 1 << 0;
public const IORING_CQE_F_MORE: UInt32 = 1 << 1;
public const IORING_CQE_F_SOCK_NONEMPTY: UInt32 = 1 << 2;

// =============================================================================
// io_uring Structures
// =============================================================================

/// Submission Queue Entry (64 bytes)
@repr(C)
public type IoUringSqe is {
    opcode: UInt8,           // Operation code (IORING_OP_*)
    flags: UInt8,            // SQE flags (IOSQE_*)
    ioprio: UInt16,          // I/O priority
    fd: Int32,               // File descriptor
    off_addr2: UInt64,       // Offset or addr2 (union)
    addr_splice: UInt64,     // Address or splice_off_in (union)
    len: UInt32,             // Length
    op_flags: UInt32,        // Operation-specific flags (union)
    user_data: UInt64,       // User data (passed to CQE)
    buf_index: UInt16,       // Buffer index for fixed buffers
    personality: UInt16,     // Personality for credentials
    splice_fd_in: Int32,     // Splice source fd
    addr3: UInt64,           // Additional address
    resv: [UInt64; 1],       // Reserved
};

/// Completion Queue Entry (16 bytes)
@repr(C)
public type IoUringCqe is {
    user_data: UInt64,       // Copied from SQE
    res: Int32,              // Result (bytes transferred or -errno)
    flags: UInt32,           // CQE flags
};

/// io_uring_params - returned by io_uring_setup
@repr(C)
public type IoUringParams is {
    sq_entries: UInt32,
    cq_entries: UInt32,
    flags: UInt32,
    sq_thread_cpu: UInt32,
    sq_thread_idle: UInt32,
    features: UInt32,
    wq_fd: UInt32,
    resv: [UInt32; 3],
    sq_off: IoUringSqRingOffsets,
    cq_off: IoUringCqRingOffsets,
};

/// SQ ring offsets
@repr(C)
public type IoUringSqRingOffsets is {
    head: UInt32,
    tail: UInt32,
    ring_mask: UInt32,
    ring_entries: UInt32,
    flags: UInt32,
    dropped: UInt32,
    array: UInt32,
    resv1: UInt32,
    resv2: UInt64,
};

/// CQ ring offsets
@repr(C)
public type IoUringCqRingOffsets is {
    head: UInt32,
    tail: UInt32,
    ring_mask: UInt32,
    ring_entries: UInt32,
    overflow: UInt32,
    cqes: UInt32,
    flags: UInt32,
    resv1: UInt32,
    resv2: UInt64,
};

// =============================================================================
// IoUring Driver
// =============================================================================

/// io_uring-based I/O driver.
public type IoUringDriver is {
    ring_fd: Int,
    params: IoUringParams,

    // Submission queue
    sq_ring_ptr: &unsafe Byte,
    sq_ring_size: USize,
    sq_head: &unsafe UInt32,
    sq_tail: &unsafe UInt32,
    sq_mask: UInt32,
    sq_array: &unsafe [UInt32],
    sqes: &unsafe [IoUringSqe],

    // Completion queue
    cq_ring_ptr: &unsafe Byte,
    cq_ring_size: USize,
    cq_head: &unsafe UInt32,
    cq_tail: &unsafe UInt32,
    cq_mask: UInt32,
    cqes: &unsafe [IoUringCqe],

    // Eventfd for waking blocked wait
    wake_fd: Int,
};

/// Re-export IoError from io_engine for convenience
public type IoError is EngineIoError;

/// I/O error types for Linux-specific io_uring/epoll drivers.
/// Named IoDriverError to avoid shadowing the general IoError from sys.io_engine.
public type IoDriverError is
    | UringSetupFailed { code: Int }
    | MmapFailed { code: Int }
    | SubmitFailed { code: Int }
    | WaitFailed { code: Int }
    | RegisterFailed { errno: Int }
    | QueueFull
    | Unsupported
    | EpollFailed { code: Int }
    | Cancelled
    | Timeout
    ;

implement IoUringDriver {
    /// Create a new io_uring driver.
    ///
    /// # Arguments
    /// * `entries` - Number of SQ entries (power of 2, max 4096)
    public fn new(entries: UInt32) -> Result<IoUringDriver, IoDriverError> {
        let mut params = IoUringParams.zeroed();

        // Setup io_uring
        let ring_fd = unsafe {
            syscall_raw(
                SYS_IO_URING_SETUP,
                entries as Int,
                &mut params as Int,
                0, 0, 0, 0
            )
        };

        if ring_fd < 0 {
            return Err(IoDriverError.UringSetupFailed { code: -ring_fd as Int });
        }

        // Map submission queue ring
        let sq_ring_size = params.sq_off.array + params.sq_entries * UInt32.size;
        let sq_ring_ptr = unsafe {
            syscall_raw(
                SYS_MMAP,
                0,
                sq_ring_size as Int,
                3,  // PROT_READ | PROT_WRITE
                1,  // MAP_SHARED
                ring_fd,
                0   // IORING_OFF_SQ_RING
            )
        };

        if sq_ring_ptr < 0 && sq_ring_ptr > -4096 {
            unsafe { syscall_raw(SYS_CLOSE, ring_fd, 0, 0, 0, 0, 0) };
            return Err(IoDriverError.MmapFailed { code: -sq_ring_ptr as Int });
        }

        // Map SQEs array
        let sqes_size = params.sq_entries * IoUringSqe.size;
        let sqes_ptr = unsafe {
            syscall_raw(
                SYS_MMAP,
                0,
                sqes_size as Int,
                3,  // PROT_READ | PROT_WRITE
                1,  // MAP_SHARED
                ring_fd,
                0x10000000  // IORING_OFF_SQES
            )
        };

        if sqes_ptr < 0 && sqes_ptr > -4096 {
            unsafe {
                syscall_raw(SYS_MUNMAP, sq_ring_ptr, sq_ring_size as Int, 0, 0, 0, 0);
                syscall_raw(SYS_CLOSE, ring_fd, 0, 0, 0, 0, 0);
            }
            return Err(IoDriverError.MmapFailed { code: -sqes_ptr as Int });
        }

        // Map completion queue ring (may overlap with SQ ring)
        let cq_ring_size = params.cq_off.cqes + params.cq_entries * IoUringCqe.size;
        let cq_ring_ptr = unsafe {
            syscall_raw(
                SYS_MMAP,
                0,
                cq_ring_size as Int,
                3,  // PROT_READ | PROT_WRITE
                1,  // MAP_SHARED
                ring_fd,
                0x8000000   // IORING_OFF_CQ_RING
            )
        };

        if cq_ring_ptr < 0 && cq_ring_ptr > -4096 {
            unsafe {
                syscall_raw(SYS_MUNMAP, sqes_ptr, sqes_size as Int, 0, 0, 0, 0);
                syscall_raw(SYS_MUNMAP, sq_ring_ptr, sq_ring_size as Int, 0, 0, 0, 0);
                syscall_raw(SYS_CLOSE, ring_fd, 0, 0, 0, 0, 0);
            }
            return Err(IoDriverError.MmapFailed { code: -cq_ring_ptr as Int });
        }

        // Create eventfd for wake notifications
        let wake_fd = unsafe { syscall_raw(SYS_EVENTFD, 0, 0, 0, 0, 0, 0) };
        if wake_fd < 0 {
            // Clean up and return error
            unsafe {
                syscall_raw(SYS_MUNMAP, cq_ring_ptr, cq_ring_size as Int, 0, 0, 0, 0);
                syscall_raw(SYS_MUNMAP, sqes_ptr, sqes_size as Int, 0, 0, 0, 0);
                syscall_raw(SYS_MUNMAP, sq_ring_ptr, sq_ring_size as Int, 0, 0, 0, 0);
                syscall_raw(SYS_CLOSE, ring_fd, 0, 0, 0, 0, 0);
            }
            return Err(IoDriverError.UringSetupFailed { code: -wake_fd as Int });
        }

        let sq_base = sq_ring_ptr as &unsafe Byte;
        let cq_base = cq_ring_ptr as &unsafe Byte;

        Ok(IoUringDriver {
            ring_fd: ring_fd,
            params: params,
            sq_ring_ptr: sq_base,
            sq_ring_size: sq_ring_size,
            sq_head: unsafe { sq_base.offset(params.sq_off.head as Int) } as &unsafe UInt32,
            sq_tail: unsafe { sq_base.offset(params.sq_off.tail as Int) } as &unsafe UInt32,
            sq_mask: unsafe { *(sq_base.offset(params.sq_off.ring_mask as Int) as &UInt32) },
            sq_array: unsafe { sq_base.offset(params.sq_off.array as Int) } as &unsafe [UInt32],
            sqes: sqes_ptr as &unsafe [IoUringSqe],
            cq_ring_ptr: cq_base,
            cq_ring_size: cq_ring_size,
            cq_head: unsafe { cq_base.offset(params.cq_off.head as Int) } as &unsafe UInt32,
            cq_tail: unsafe { cq_base.offset(params.cq_off.tail as Int) } as &unsafe UInt32,
            cq_mask: unsafe { *(cq_base.offset(params.cq_off.ring_mask as Int) as &UInt32) },
            cqes: unsafe { cq_base.offset(params.cq_off.cqes as Int) } as &unsafe [IoUringCqe],
            wake_fd: wake_fd,
        })
    }

    /// Get a free SQE slot.
    fn get_sqe(&mut self) -> Result<&mut IoUringSqe, IoDriverError> {
        let tail = unsafe { *self.sq_tail };
        let head = atomic_load_u32(self.sq_head, ORDERING_ACQUIRE);

        if tail - head >= self.params.sq_entries {
            return Err(IoDriverError.QueueFull);
        }

        let idx = tail & self.sq_mask;
        unsafe {
            self.sq_array[idx] = idx;
        }

        Ok(unsafe { &mut self.sqes[idx] })
    }

    /// Advance SQ tail after filling SQE.
    fn submit_sqe(&mut self) {
        unsafe {
            atomic_store_u32(self.sq_tail, *self.sq_tail + 1, ORDERING_RELEASE);
        }
    }

    /// Submit pending SQEs to the kernel.
    public fn submit(&mut self) -> Result<Int, IoDriverError> {
        let tail = unsafe { *self.sq_tail };
        let head = atomic_load_u32(self.sq_head, ORDERING_ACQUIRE);
        let to_submit = tail - head;

        if to_submit == 0 {
            return Ok(0);
        }

        let result = unsafe {
            syscall_raw(
                SYS_IO_URING_ENTER,
                self.ring_fd,
                to_submit as Int,
                0,  // min_complete
                0,  // flags
                0, 0
            )
        };

        if result < 0 {
            Err(IoDriverError.SubmitFailed { code: -result as Int })
        } else {
            Ok(result)
        }
    }

    /// Wait for completions.
    ///
    /// # Arguments
    /// * `min_complete` - Minimum completions to wait for
    /// * `timeout_ns` - Timeout in nanoseconds (0 = no timeout)
    public fn wait(&mut self, min_complete: UInt32, timeout_ns: UInt64) -> Result<Int, IoDriverError> {
        let flags = if min_complete > 0 { IORING_ENTER_GETEVENTS } else { 0 };

        let result = unsafe {
            syscall_raw(
                SYS_IO_URING_ENTER,
                self.ring_fd,
                0,  // to_submit
                min_complete as Int,
                flags as Int,
                0, 0
            )
        };

        if result < 0 && -result != EINTR {
            Err(IoDriverError.WaitFailed { code: -result as Int })
        } else {
            Ok(self.reap_completions())
        }
    }

    /// Reap completed CQEs.
    fn reap_completions(&mut self) -> Int {
        let mut count = 0;
        let head = unsafe { *self.cq_head };
        let tail = atomic_load_u32(self.cq_tail, ORDERING_ACQUIRE);

        // Just count for now - actual processing happens via peek_cqe
        count = (tail - head) as Int;
        count
    }

    /// Peek at the next CQE without consuming it.
    public fn peek_cqe(&self) -> Maybe<&IoUringCqe> {
        let head = unsafe { *self.cq_head };
        let tail = atomic_load_u32(self.cq_tail, ORDERING_ACQUIRE);

        if head == tail {
            None
        } else {
            let idx = head & self.cq_mask;
            Some(unsafe { &self.cqes[idx] })
        }
    }

    /// Consume a CQE (advance CQ head).
    public fn consume_cqe(&mut self) {
        unsafe {
            atomic_store_u32(self.cq_head, *self.cq_head + 1, ORDERING_RELEASE);
        }
    }

    /// Wake a blocked wait.
    public fn wake(&self) -> Result<(), IoDriverError> {
        let buf: [Byte; 8] = [1, 0, 0, 0, 0, 0, 0, 0];  // Write 1 to eventfd
        let result = unsafe {
            syscall_raw(
                SYS_WRITE,
                self.wake_fd,
                &buf as Int,
                8,
                0, 0, 0
            )
        };
        if result < 0 {
            Err(IoDriverError.WaitFailed { code: -result as Int })
        } else {
            Ok(())
        }
    }

    /// Prepare a read operation.
    public fn prep_read(&mut self, fd: Int, buf: &mut [Byte], offset: Int64, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_READ;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = offset as UInt64;
            (*sqe).addr_splice = buf.as_ptr() as UInt64;
            (*sqe).len = buf.len() as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a write operation.
    public fn prep_write(&mut self, fd: Int, buf: &[Byte], offset: Int64, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_WRITE;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = offset as UInt64;
            (*sqe).addr_splice = buf.as_ptr() as UInt64;
            (*sqe).len = buf.len() as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare an accept operation.
    public fn prep_accept(&mut self, fd: Int, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_ACCEPT;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = 0;  // addr
            (*sqe).op_flags = 0;     // addrlen
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a connect operation.
    public fn prep_connect(&mut self, fd: Int, addr: &Byte, addrlen: UInt32, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_CONNECT;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = addrlen as UInt64;
            (*sqe).addr_splice = addr as UInt64;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a close operation.
    public fn prep_close(&mut self, fd: Int, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_CLOSE;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a vectored read (readv) operation.
    ///
    /// Submits IORING_OP_READV which reads into multiple buffers
    /// described by the iovec array.
    public fn prep_readv(&mut self, fd: Int, iovecs: &[IOVec], user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_READV;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;  // offset = 0 (current position)
            (*sqe).addr_splice = iovecs.as_ptr() as UInt64;
            (*sqe).len = iovecs.len() as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a vectored write (writev) operation.
    ///
    /// Submits IORING_OP_WRITEV which writes from multiple buffers
    /// described by the iovec array.
    public fn prep_writev(&mut self, fd: Int, iovecs: &[IOVec], user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_WRITEV;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;  // offset = 0 (current position)
            (*sqe).addr_splice = iovecs.as_ptr() as UInt64;
            (*sqe).len = iovecs.len() as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a recv operation.
    public fn prep_recv(&mut self, fd: Int, buf: &mut [Byte], flags: Int32, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_RECV;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = buf.as_ptr() as UInt64;
            (*sqe).len = buf.len() as UInt32;
            (*sqe).op_flags = flags as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a send operation.
    public fn prep_send(&mut self, fd: Int, buf: &[Byte], flags: Int32, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_SEND;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = buf.as_ptr() as UInt64;
            (*sqe).len = buf.len() as UInt32;
            (*sqe).op_flags = flags as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a recvmsg operation.
    public fn prep_recvmsg(&mut self, fd: Int, msg: &mut MsgHdr, flags: Int32, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_RECVMSG;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = msg as UInt64;
            (*sqe).len = 1;  // number of messages
            (*sqe).op_flags = flags as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a sendmsg operation.
    public fn prep_sendmsg(&mut self, fd: Int, msg: &MsgHdr, flags: Int32, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_SENDMSG;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = msg as UInt64;
            (*sqe).len = 1;
            (*sqe).op_flags = flags as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a poll add operation.
    public fn prep_poll_add(&mut self, fd: Int, events: UInt32, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_POLL_ADD;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = 0;
            (*sqe).len = 0;
            (*sqe).op_flags = events;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare an fsync operation.
    public fn prep_fsync(&mut self, fd: Int, datasync: Bool, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_FSYNC;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = 0;
            (*sqe).len = 0;
            (*sqe).op_flags = if datasync { 1 } else { 0 };  // IORING_FSYNC_DATASYNC
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a cancel operation.
    public fn prep_cancel(&mut self, target_user_data: UInt64, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_ASYNC_CANCEL;
            (*sqe).flags = 0;
            (*sqe).fd = -1;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = target_user_data;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a multi-shot accept — one SQE produces unlimited CQEs
    /// (each with IORING_CQE_F_MORE set) until cancelled or the socket
    /// is closed. Requires Linux 5.19+.
    public fn prep_accept_multishot(&mut self, fd: Int, user_data: UInt64)
        -> Result<(), IoDriverError>
    {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_ACCEPT;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = 0;
            (*sqe).op_flags = IORING_ACCEPT_MULTISHOT;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a multi-shot recv with a provided-buffer group. The
    /// kernel pulls the next available buffer from the ring identified
    /// by `buf_group` and emits one CQE per incoming read. Requires
    /// Linux 6.0+. IOSQE_BUFFER_SELECT is set automatically.
    public fn prep_recv_multishot(
        &mut self,
        fd: Int,
        buf_group: UInt16,
        flags: Int32,
        user_data: UInt64,
    ) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_RECV;
            (*sqe).flags = IOSQE_BUFFER_SELECT;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = 0;
            (*sqe).len = 0;
            (*sqe).op_flags = (flags as UInt32) | IORING_RECV_MULTISHOT;
            (*sqe).buf_index = buf_group;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a zero-copy send (IORING_OP_SEND_ZC). The kernel emits
    /// TWO completions — the first with the byte count, the second
    /// (with IORING_CQE_F_NOTIF set) when the userspace buffer is safe
    /// to free. The caller MUST keep `buf` valid until the notification.
    /// Requires Linux 6.0+.
    public fn prep_send_zc(
        &mut self,
        fd: Int,
        buf: &[Byte],
        flags: Int32,
        user_data: UInt64,
    ) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_SEND_ZC;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = buf.as_ptr() as UInt64;
            (*sqe).len = buf.len() as UInt32;
            (*sqe).op_flags = flags as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a zero-copy sendmsg (IORING_OP_SENDMSG_ZC).
    /// Requires Linux 6.1+.
    public fn prep_sendmsg_zc(
        &mut self,
        fd: Int,
        msg: &MsgHdr,
        flags: Int32,
        user_data: UInt64,
    ) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_SENDMSG_ZC;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = 0;
            (*sqe).addr_splice = msg as UInt64;
            (*sqe).len = 1;
            (*sqe).op_flags = flags as UInt32;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a fixed-buffer read — references a previously registered
    /// buffer via `buf_index` instead of pinning a new one per op.
    public fn prep_read_fixed(
        &mut self,
        fd: Int,
        buf_index: UInt16,
        buf_ptr: UInt64,
        len: UInt32,
        offset: Int64,
        user_data: UInt64,
    ) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_READ_FIXED;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = offset as UInt64;
            (*sqe).addr_splice = buf_ptr;
            (*sqe).len = len;
            (*sqe).buf_index = buf_index;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Prepare a fixed-buffer write.
    public fn prep_write_fixed(
        &mut self,
        fd: Int,
        buf_index: UInt16,
        buf_ptr: UInt64,
        len: UInt32,
        offset: Int64,
        user_data: UInt64,
    ) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        unsafe {
            (*sqe).opcode = IORING_OP_WRITE_FIXED;
            (*sqe).flags = 0;
            (*sqe).fd = fd as Int32;
            (*sqe).off_addr2 = offset as UInt64;
            (*sqe).addr_splice = buf_ptr;
            (*sqe).len = len;
            (*sqe).buf_index = buf_index;
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Register a set of fixed buffers with the kernel. Pointers are
    /// pinned in memory; subsequent prep_read_fixed / prep_write_fixed
    /// reference them by buf_index. Caller must keep the backing
    /// iovec array alive for the lifetime of the registration.
    public fn register_buffers(&mut self, iovecs: &[IOVec]) -> Result<(), IoDriverError> {
        let ret = unsafe {
            syscall_raw(
                SYS_IO_URING_REGISTER,
                self.ring_fd,
                IORING_REGISTER_BUFFERS as Int,
                iovecs.as_ptr() as Int,
                iovecs.len() as Int,
                0, 0,
            )
        };
        if ret < 0 {
            return Err(IoDriverError.RegisterFailed { errno: -ret as Int });
        }
        Ok(())
    }

    public fn unregister_buffers(&mut self) -> Result<(), IoDriverError> {
        let ret = unsafe {
            syscall_raw(
                SYS_IO_URING_REGISTER,
                self.ring_fd,
                IORING_UNREGISTER_BUFFERS as Int,
                0, 0, 0, 0,
            )
        };
        if ret < 0 { return Err(IoDriverError.RegisterFailed { errno: -ret as Int }); }
        Ok(())
    }

    /// Register a fixed-size file-descriptor table. Slots can be updated
    /// later without unregistering the whole table.
    public fn register_files(&mut self, fds: &[Int32]) -> Result<(), IoDriverError> {
        let ret = unsafe {
            syscall_raw(
                SYS_IO_URING_REGISTER,
                self.ring_fd,
                IORING_REGISTER_FILES as Int,
                fds.as_ptr() as Int,
                fds.len() as Int,
                0, 0,
            )
        };
        if ret < 0 { return Err(IoDriverError.RegisterFailed { errno: -ret as Int }); }
        Ok(())
    }

    public fn unregister_files(&mut self) -> Result<(), IoDriverError> {
        let ret = unsafe {
            syscall_raw(
                SYS_IO_URING_REGISTER,
                self.ring_fd,
                IORING_UNREGISTER_FILES as Int,
                0, 0, 0, 0,
            )
        };
        if ret < 0 { return Err(IoDriverError.RegisterFailed { errno: -ret as Int }); }
        Ok(())
    }

    /// Register a provided-buffer ring of `entries` buffers under the
    /// chosen `group_id`. `reg_ptr` points at a `struct io_uring_buf_reg`
    /// — caller is responsible for its layout and for the backing ring
    /// memory. The kernel picks an unused buffer for each matching
    /// recv completion. Requires Linux 5.19+.
    public fn register_pbuf_ring(
        &mut self,
        reg_ptr: UInt64,
        entries: UInt32,
        group_id: UInt16,
    ) -> Result<(), IoDriverError> {
        let packed = (entries & 0xFFFF) | ((group_id as UInt32) << 16);
        let ret = unsafe {
            syscall_raw(
                SYS_IO_URING_REGISTER,
                self.ring_fd,
                IORING_REGISTER_PBUF_RING as Int,
                reg_ptr as Int,
                packed as Int,
                0, 0,
            )
        };
        if ret < 0 { return Err(IoDriverError.RegisterFailed { errno: -ret as Int }); }
        Ok(())
    }

    public fn unregister_pbuf_ring(&mut self, group_id: UInt16) -> Result<(), IoDriverError> {
        let ret = unsafe {
            syscall_raw(
                SYS_IO_URING_REGISTER,
                self.ring_fd,
                IORING_UNREGISTER_PBUF_RING as Int,
                0,
                group_id as Int,
                0, 0,
            )
        };
        if ret < 0 { return Err(IoDriverError.RegisterFailed { errno: -ret as Int }); }
        Ok(())
    }

    /// Prepare a timeout operation.
    public fn prep_timeout(&mut self, timeout_ns: UInt64, user_data: UInt64) -> Result<(), IoDriverError> {
        let sqe = self.get_sqe()?;
        // Timespec structure
        let ts_sec = timeout_ns / 1_000_000_000;
        let ts_nsec = timeout_ns % 1_000_000_000;
        // Note: In real implementation, this needs stable storage
        unsafe {
            (*sqe).opcode = IORING_OP_TIMEOUT;
            (*sqe).flags = 0;
            (*sqe).fd = -1;
            (*sqe).off_addr2 = 1;  // count (complete after 1 timeout)
            (*sqe).user_data = user_data;
        }
        self.submit_sqe();
        Ok(())
    }

    /// Clean up resources.
    public fn close(&mut self) {
        unsafe {
            syscall_raw(SYS_CLOSE, self.wake_fd, 0, 0, 0, 0, 0);
            syscall_raw(SYS_MUNMAP, self.cq_ring_ptr as Int, self.cq_ring_size as Int, 0, 0, 0, 0);
            syscall_raw(SYS_MUNMAP, self.sqes as Int, (self.params.sq_entries * IoUringSqe.size) as Int, 0, 0, 0, 0);
            syscall_raw(SYS_MUNMAP, self.sq_ring_ptr as Int, self.sq_ring_size as Int, 0, 0, 0, 0);
            syscall_raw(SYS_CLOSE, self.ring_fd, 0, 0, 0, 0, 0);
        }
    }
}

// =============================================================================
// Epoll Constants and Types (Fallback)
// =============================================================================

/// epoll_ctl operations
public const EPOLL_CTL_ADD: Int = 1;
public const EPOLL_CTL_DEL: Int = 2;
public const EPOLL_CTL_MOD: Int = 3;

/// epoll events
public const EPOLLIN: UInt32 = 0x001;
public const EPOLLOUT: UInt32 = 0x004;
public const EPOLLERR: UInt32 = 0x008;
public const EPOLLHUP: UInt32 = 0x010;
public const EPOLLRDHUP: UInt32 = 0x2000;
public const EPOLLET: UInt32 = 1 << 31;
public const EPOLLONESHOT: UInt32 = 1 << 30;

/// epoll_event structure
@repr(C)
public type EpollEvent is {
    events: UInt32,
    data: UInt64,  // User data (typically fd or pointer)
};

// =============================================================================
// Epoll Driver (Fallback for older kernels)
// =============================================================================

/// Epoll-based I/O driver.
/// Wraps readiness-based epoll in completion semantics.
public type EpollDriver is {
    epfd: Int,
    wake_fd: Int,
    pending_ops: Map<UInt64, PendingOp>,  // user_data -> operation
};

/// Pending operation waiting for readiness
type PendingOp is {
    fd: Int,
    op_type: OpType,
    buf: &unsafe Byte,
    len: USize,
    offset: Int64,
};

type OpType is Read | Write | Accept | Connect | Close;

implement EpollDriver {
    /// Create a new epoll driver.
    public fn new() -> Result<EpollDriver, IoDriverError> {
        let epfd = unsafe {
            syscall_raw(SYS_EPOLL_CREATE1, 0, 0, 0, 0, 0, 0)
        };

        if epfd < 0 {
            return Err(IoDriverError.EpollFailed { code: -epfd as Int });
        }

        // Create eventfd for wake notifications
        let wake_fd = unsafe { syscall_raw(SYS_EVENTFD, 0, 0, 0, 0, 0, 0) };
        if wake_fd < 0 {
            unsafe { syscall_raw(SYS_CLOSE, epfd, 0, 0, 0, 0, 0) };
            return Err(IoDriverError.EpollFailed { code: -wake_fd as Int });
        }

        // Register wake_fd with epoll
        let ev = EpollEvent {
            events: EPOLLIN | EPOLLET,
            data: 0,  // Special user_data for wake
        };

        let result = unsafe {
            syscall_raw(
                SYS_EPOLL_CTL,
                epfd,
                EPOLL_CTL_ADD,
                wake_fd,
                &ev as Int,
                0, 0
            )
        };

        if result < 0 {
            unsafe {
                syscall_raw(SYS_CLOSE, wake_fd, 0, 0, 0, 0, 0);
                syscall_raw(SYS_CLOSE, epfd, 0, 0, 0, 0, 0);
            }
            return Err(IoDriverError.EpollFailed { code: -result as Int });
        }

        Ok(EpollDriver {
            epfd: epfd,
            wake_fd: wake_fd,
            pending_ops: Map.new(),
        })
    }

    /// Add fd to epoll interest set.
    public fn add(&mut self, fd: Int, events: UInt32, user_data: UInt64) -> Result<(), IoDriverError> {
        let ev = EpollEvent {
            events: events | EPOLLET,
            data: user_data,
        };

        let result = unsafe {
            syscall_raw(
                SYS_EPOLL_CTL,
                self.epfd,
                EPOLL_CTL_ADD,
                fd,
                &ev as Int,
                0, 0
            )
        };

        if result < 0 {
            Err(IoDriverError.EpollFailed { code: -result as Int })
        } else {
            Ok(())
        }
    }

    /// Remove fd from epoll interest set.
    public fn remove(&mut self, fd: Int) -> Result<(), IoDriverError> {
        let result = unsafe {
            syscall_raw(
                SYS_EPOLL_CTL,
                self.epfd,
                EPOLL_CTL_DEL,
                fd,
                0,
                0, 0
            )
        };

        if result < 0 {
            Err(IoDriverError.EpollFailed { code: -result as Int })
        } else {
            Ok(())
        }
    }

    /// Wait for events.
    public fn wait(&mut self, events: &mut [EpollEvent], timeout_ms: Int) -> Result<Int, IoDriverError> {
        let result = unsafe {
            syscall_raw(
                SYS_EPOLL_PWAIT,
                self.epfd,
                events.as_ptr() as Int,
                events.len() as Int,
                timeout_ms,
                0,
                0
            )
        };

        if result < 0 && -result != EINTR {
            Err(IoDriverError.EpollFailed { code: -result as Int })
        } else if result < 0 {
            Ok(0)  // Interrupted, no events
        } else {
            Ok(result)
        }
    }

    /// Wake a blocked wait.
    public fn wake(&self) -> Result<(), IoDriverError> {
        let buf: [Byte; 8] = [1, 0, 0, 0, 0, 0, 0, 0];
        let result = unsafe {
            syscall_raw(
                SYS_WRITE,
                self.wake_fd,
                &buf as Int,
                8,
                0, 0, 0
            )
        };
        if result < 0 {
            Err(IoDriverError.EpollFailed { code: -result as Int })
        } else {
            Ok(())
        }
    }

    /// Close the driver.
    public fn close(&mut self) {
        unsafe {
            syscall_raw(SYS_CLOSE, self.wake_fd, 0, 0, 0, 0, 0);
            syscall_raw(SYS_CLOSE, self.epfd, 0, 0, 0, 0, 0);
        }
    }
}

// =============================================================================
// Platform IO Engine Factory
// =============================================================================

/// Check if io_uring is available on this system.
public fn is_io_uring_available() -> Bool {
    let mut params = IoUringParams.zeroed();
    let result = unsafe {
        syscall_raw(SYS_IO_URING_SETUP, 1, &mut params as Int, 0, 0, 0, 0)
    };

    if result >= 0 {
        // Close the test ring
        unsafe { syscall_raw(SYS_CLOSE, result, 0, 0, 0, 0, 0) };
        true
    } else {
        // ENOSYS means io_uring not available
        -result != ENOSYS
    }
}

/// Create the best available IO driver for this system.
///
/// Prefers io_uring (Linux 5.1+), falls back to epoll.
public fn create_io_driver() -> Result<IoDriver, IoDriverError> {
    // Try io_uring first
    if is_io_uring_available() {
        match IoUringDriver.new(256) {
            Ok(driver) => return Ok(IoDriver.Uring(driver)),
            Err(_) => {}  // Fall through to epoll
        }
    }

    // Fall back to epoll
    match EpollDriver.new() {
        Ok(driver) => Ok(IoDriver.Epoll(driver)),
        Err(e) => Err(e),
    }
}

/// Unified IO driver type.
public type IoDriver is
    | Uring(IoUringDriver)
    | Epoll(EpollDriver)
    ;

implement IoDriver {
    /// Wake a blocked wait.
    public fn wake(&self) -> Result<(), IoDriverError> {
        match self {
            Uring(d) => d.wake(),
            Epoll(d) => d.wake(),
        }
    }

    /// Close the driver.
    public fn close(&mut self) {
        match self {
            Uring(d) => d.close(),
            Epoll(d) => d.close(),
        }
    }

    /// Check if this is io_uring.
    public fn is_io_uring(&self) -> Bool {
        match self {
            Uring(_) => true,
            Epoll(_) => false,
        }
    }
}

// =============================================================================
// IOEngine Protocol Implementation
// =============================================================================
//
// This section implements the unified IOEngine protocol from sys/io_engine.vr
// for the Linux-specific IoDriver type.

/// Convert local IoDriverError to IOEngine's IoError
fn convert_error(err: IoDriverError) -> EngineIoError {
    match err {
        UringSetupFailed { code } => EngineIoError.Other("io_uring setup failed"),
        MmapFailed { code } => EngineIoError.Other("mmap failed"),
        SubmitFailed { code } => EngineIoError.from_errno(code as Int32),
        WaitFailed { code } => EngineIoError.from_errno(code as Int32),
        QueueFull => EngineIoError.SubmissionQueueFull,
        Unsupported => EngineIoError.NotSupported,
        EpollFailed { code } => EngineIoError.from_errno(code as Int32),
        Cancelled => EngineIoError.Cancelled,
        Timeout => EngineIoError.TimedOut,
    }
}

/// Implement IOEngine for IoUringDriver
implement IOEngine for IoUringDriver {
    fn submit(&mut self, ops: &[(CompletionOp, UInt64)]) -> Result<Int{>= 0}, EngineIoError> {
        let mut submitted = 0;

        for (op, user_data) in ops {
            let result = match op {
                CompletionOp.Read { fd, buf, offset } => {
                    self.prep_read(fd.as_raw() as Int, buf, offset, user_data)
                }
                CompletionOp.Write { fd, buf, offset } => {
                    self.prep_write(fd.as_raw() as Int, buf, offset, user_data)
                }
                CompletionOp.Accept { fd, .. } => {
                    self.prep_accept(fd.as_raw() as Int, user_data)
                }
                CompletionOp.Connect { fd, addr } => {
                    // Convert RawSocketAddr to raw bytes
                    let addr_ptr = addr as &Byte;
                    let addrlen = match addr {
                        RawSocketAddr.V4 { .. } => 16 as UInt32,  // sizeof(sockaddr_in)
                        RawSocketAddr.V6 { .. } => 28 as UInt32,  // sizeof(sockaddr_in6)
                    };
                    self.prep_connect(fd.as_raw() as Int, addr_ptr, addrlen, user_data)
                }
                CompletionOp.Close { fd } => {
                    self.prep_close(fd.as_raw() as Int, user_data)
                }
                CompletionOp.Timeout { ts } => {
                    let timeout_ns = (ts.tv_sec as UInt64) * 1_000_000_000 + (ts.tv_nsec as UInt64);
                    self.prep_timeout(timeout_ns, user_data)
                }
                CompletionOp.Recv { fd, buf, flags } => {
                    self.prep_recv(fd.as_raw() as Int, buf, flags, user_data)
                }
                CompletionOp.Send { fd, buf, flags } => {
                    self.prep_send(fd.as_raw() as Int, buf, flags, user_data)
                }
                CompletionOp.RecvMsg { fd, msg, flags } => {
                    self.prep_recvmsg(fd.as_raw() as Int, msg, flags, user_data)
                }
                CompletionOp.SendMsg { fd, msg, flags } => {
                    self.prep_sendmsg(fd.as_raw() as Int, msg, flags, user_data)
                }
                CompletionOp.Fsync { fd, datasync } => {
                    self.prep_fsync(fd.as_raw() as Int, datasync, user_data)
                }
                CompletionOp.Poll { fd, events } => {
                    self.prep_poll_add(fd.as_raw() as Int, events, user_data)
                }
                CompletionOp.Cancel { user_data: target_data } => {
                    self.prep_cancel(target_data, user_data)
                }
                CompletionOp.Nop => {
                    // Submit a NOP
                    match self.get_sqe() {
                        Ok(sqe) => {
                            unsafe {
                                (*sqe).opcode = IORING_OP_NOP;
                                (*sqe).flags = 0;
                                (*sqe).user_data = user_data;
                            }
                            self.submit_sqe();
                            Ok(())
                        }
                        Err(e) => Err(e),
                    }
                }
                CompletionOp.ReadV { fd, iovecs } => {
                    self.prep_readv(fd.as_raw() as Int, iovecs, user_data)
                }
                CompletionOp.WriteV { fd, iovecs } => {
                    self.prep_writev(fd.as_raw() as Int, iovecs, user_data)
                }
                _ => {
                    Err(IoDriverError.Unsupported)
                }
            };

            match result {
                Ok(()) => submitted += 1,
                Err(IoDriverError.QueueFull) => break,  // Stop on queue full
                Err(_) => {}  // Skip failed ops, continue with rest
            }
        }

        // Flush to kernel
        match self.submit() {
            Ok(_) => Ok(submitted),
            Err(e) => {
                if submitted > 0 {
                    Ok(submitted)  // Some submitted before error
                } else {
                    Err(convert_error(e))
                }
            }
        }
    }

    fn wait(
        &mut self,
        results: &mut [CompletionResult],
        min_complete: UInt32,
        timeout: Maybe<Duration>,
    ) -> Result<Int{>= 0}, EngineIoError> {
        let timeout_ns = match timeout {
            Some(d) => d.as_nanos(),
            None => 0,  // No timeout
        };

        match self.wait(min_complete, timeout_ns) {
            Ok(_) => {
                // Reap completions into results buffer
                let mut count = 0;
                while count < results.len() as Int {
                    match self.peek_cqe() {
                        Some(cqe) => {
                            results[count] = CompletionResult {
                                user_data: cqe.user_data,
                                result: cqe.res,
                                flags: cqe.flags,
                            };
                            self.consume_cqe();
                            count += 1;
                        }
                        None => break,
                    }
                }
                Ok(count)
            }
            Err(e) => Err(convert_error(e)),
        }
    }

    fn wake(&self) -> Result<(), EngineIoError> {
        self.wake().map_err(convert_error)
    }

    fn pending(&self) -> UInt32 {
        let tail = unsafe { *self.sq_tail };
        let head = atomic_load_u32(self.sq_head, ORDERING_ACQUIRE);
        (tail - head) as UInt32
    }

    fn flush(&mut self) -> Result<(), EngineIoError> {
        self.submit().map(|_| ()).map_err(convert_error)
    }

    fn shutdown(&mut self) -> Result<(), EngineIoError> {
        self.close();
        Ok(())
    }

    pure fn is_open(&self) -> Bool {
        self.ring_fd >= 0
    }
}

/// Implement IOEngine for EpollDriver (completion wrapping over readiness)
///
/// Epoll is readiness-based, so we wrap it in completion semantics:
/// 1. submit() registers fd interest with epoll_ctl
/// 2. wait() calls epoll_pwait and performs the actual I/O when fd is ready
/// 3. Returns CompletionResult with bytes transferred
implement IOEngine for EpollDriver {
    fn submit(&mut self, ops: &[(CompletionOp, UInt64)]) -> Result<Int{>= 0}, EngineIoError> {
        let mut submitted = 0;

        for (op, user_data) in ops {
            let result = match op {
                CompletionOp.Read { fd, buf, offset } => {
                    // Register EPOLLIN interest, store pending op
                    self.add(fd.as_raw() as Int, EPOLLIN | EPOLLET | EPOLLONESHOT, user_data)?;
                    self.pending_ops.insert(user_data, PendingOp {
                        fd: fd.as_raw() as Int,
                        op_type: OpType.Read,
                        buf: buf.as_ptr() as &unsafe Byte,
                        len: buf.len(),
                        offset: offset,
                    });
                    Ok(())
                }
                CompletionOp.Write { fd, buf, offset } => {
                    self.add(fd.as_raw() as Int, EPOLLOUT | EPOLLET | EPOLLONESHOT, user_data)?;
                    self.pending_ops.insert(user_data, PendingOp {
                        fd: fd.as_raw() as Int,
                        op_type: OpType.Write,
                        buf: buf.as_ptr() as &unsafe Byte,
                        len: buf.len(),
                        offset: offset,
                    });
                    Ok(())
                }
                CompletionOp.Accept { fd, .. } => {
                    self.add(fd.as_raw() as Int, EPOLLIN | EPOLLET | EPOLLONESHOT, user_data)?;
                    self.pending_ops.insert(user_data, PendingOp {
                        fd: fd.as_raw() as Int,
                        op_type: OpType.Accept,
                        buf: 0 as &unsafe Byte,
                        len: 0,
                        offset: 0,
                    });
                    Ok(())
                }
                CompletionOp.Connect { fd, .. } => {
                    self.add(fd.as_raw() as Int, EPOLLOUT | EPOLLET | EPOLLONESHOT, user_data)?;
                    self.pending_ops.insert(user_data, PendingOp {
                        fd: fd.as_raw() as Int,
                        op_type: OpType.Connect,
                        buf: 0 as &unsafe Byte,
                        len: 0,
                        offset: 0,
                    });
                    Ok(())
                }
                CompletionOp.Recv { fd, buf, .. } => {
                    self.add(fd.as_raw() as Int, EPOLLIN | EPOLLET | EPOLLONESHOT, user_data)?;
                    self.pending_ops.insert(user_data, PendingOp {
                        fd: fd.as_raw() as Int,
                        op_type: OpType.Read,
                        buf: buf.as_ptr() as &unsafe Byte,
                        len: buf.len(),
                        offset: 0,
                    });
                    Ok(())
                }
                CompletionOp.Send { fd, buf, .. } => {
                    self.add(fd.as_raw() as Int, EPOLLOUT | EPOLLET | EPOLLONESHOT, user_data)?;
                    self.pending_ops.insert(user_data, PendingOp {
                        fd: fd.as_raw() as Int,
                        op_type: OpType.Write,
                        buf: buf.as_ptr() as &unsafe Byte,
                        len: buf.len(),
                        offset: 0,
                    });
                    Ok(())
                }
                CompletionOp.Close { fd } => {
                    let _ = self.remove(fd.as_raw() as Int);
                    let close_result = unsafe {
                        syscall_raw(SYS_CLOSE, fd.as_raw() as Int, 0, 0, 0, 0, 0)
                    };
                    Ok(())
                }
                CompletionOp.Nop => Ok(()),
                _ => Err(IoDriverError.Unsupported),
            };

            match result {
                Ok(()) => submitted += 1,
                Err(_) => {}
            }
        }

        Ok(submitted)
    }

    fn wait(
        &mut self,
        results: &mut [CompletionResult],
        min_complete: UInt32,
        timeout: Maybe<Duration>,
    ) -> Result<Int{>= 0}, EngineIoError> {
        let timeout_ms = match timeout {
            Some(d) => d.as_millis() as Int,
            None => -1,
        };

        let actual_timeout = if min_complete == 0 { 0 } else { timeout_ms };

        let max_events = results.len().min(64) as Int;
        let mut epoll_events: [EpollEvent; 64] = [@zero<EpollEvent>(); 64];

        match self.wait(&mut epoll_events, actual_timeout) {
            Ok(count) => {
                let result_count = count.min(results.len() as Int);
                let mut filled = 0;

                for i in 0..result_count {
                    let ev = &epoll_events[i];
                    let user_data = ev.data;

                    // Look up the pending operation for this fd
                    match self.pending_ops.remove(&user_data) {
                        Some(pending) => {
                            // Perform the actual I/O now that fd is ready
                            let io_result = match pending.op_type {
                                OpType.Read => {
                                    unsafe {
                                        syscall_raw(SYS_READ, pending.fd, pending.buf as Int, pending.len as Int, 0, 0, 0)
                                    }
                                }
                                OpType.Write => {
                                    unsafe {
                                        syscall_raw(SYS_WRITE, pending.fd, pending.buf as Int, pending.len as Int, 0, 0, 0)
                                    }
                                }
                                _ => 0,  // Accept/Connect complete on readiness
                            };

                            results[filled] = CompletionResult {
                                user_data: user_data,
                                result: if io_result < 0 { -((-io_result) as Int32) } else { io_result as Int32 },
                                flags: 0,
                            };
                            filled += 1;
                        }
                        None => {
                            // Wake event or unknown — skip
                        }
                    }
                }

                Ok(filled)
            }
            Err(e) => Err(convert_error(e)),
        }
    }

    fn wake(&self) -> Result<(), EngineIoError> {
        self.wake().map_err(convert_error)
    }

    fn pending(&self) -> UInt32 {
        self.pending_ops.len() as UInt32
    }

    fn flush(&mut self) -> Result<(), EngineIoError> {
        Ok(())  // Epoll doesn't batch — registrations are immediate
    }

    fn shutdown(&mut self) -> Result<(), EngineIoError> {
        self.close();
        Ok(())
    }

    pure fn is_open(&self) -> Bool {
        self.epfd >= 0
    }
}

/// Implement IOEngine for IoDriver (unified driver)
implement IOEngine for IoDriver {
    fn submit(&mut self, ops: &[(CompletionOp, UInt64)]) -> Result<Int{>= 0}, EngineIoError> {
        match self {
            Uring(d) => d.submit(ops),
            Epoll(d) => d.submit(ops),
        }
    }

    fn wait(
        &mut self,
        results: &mut [CompletionResult],
        min_complete: UInt32,
        timeout: Maybe<Duration>,
    ) -> Result<Int{>= 0}, EngineIoError> {
        match self {
            Uring(d) => d.wait(results, min_complete, timeout),
            Epoll(d) => d.wait(results, min_complete, timeout),
        }
    }

    fn wake(&self) -> Result<(), EngineIoError> {
        match self {
            Uring(d) => d.wake(),
            Epoll(d) => d.wake().map_err(convert_error),
        }
    }

    fn pending(&self) -> UInt32 {
        match self {
            Uring(d) => d.pending(),
            Epoll(d) => d.pending(),
        }
    }

    fn flush(&mut self) -> Result<(), EngineIoError> {
        match self {
            Uring(d) => d.flush(),
            Epoll(d) => d.flush(),
        }
    }

    fn shutdown(&mut self) -> Result<(), EngineIoError> {
        match self {
            Uring(d) => d.shutdown(),
            Epoll(d) => d.shutdown(),
        }
    }

    pure fn is_open(&self) -> Bool {
        match self {
            Uring(d) => d.is_open(),
            Epoll(d) => d.is_open(),
        }
    }
}
