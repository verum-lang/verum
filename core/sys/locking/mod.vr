module sys.locking;

// =============================================================================
// core/sys/locking/mod.vr — Byte-range advisory file locking (public API)
// =============================================================================
// Layer: 0 (Core)
// Spec: internal/specs/sqlite-native.md §3.2 Gap 1
//
// High-level, typed wrapper around the per-platform fcntl/LockFileEx
// primitives in `core.sys.common`. Gives callers:
//
//   * `LockRegion`       — explicit start/length (length == -1 ≡ to EOF)
//   * `LockKind`         — Shared | Exclusive (no Unlock variant; unlock
//                          is expressed by consuming the affine handle)
//   * `LockError`        — Conflict(owner_pid) | IoError(OSError); the
//                          backend's EAGAIN/EWOULDBLOCK maps to Conflict
//   * `LockHandle`       — @affine RAII resource; `unlock` consumes it
//
// The 5-state SQLite locking protocol (SHARED / RESERVED / PENDING /
// EXCLUSIVE) is built on top of these primitives in
// `core/database/sqlite/native/l0_vfs/locking.vr`. Advisory-only on
// POSIX; mandatory on Windows. NFS is not supported (see SQLite docs).
// =============================================================================

mount core.sys.common;
mount core.base.maybe.Maybe;
mount core.base.result.Result;

// -----------------------------------------------------------------------------
// Public types
// -----------------------------------------------------------------------------

/// Caller-facing kind of a byte-range lock.
///
/// `Shared` — many holders permitted, compatible with other Shared.
/// `Exclusive` — sole holder, incompatible with any other lock.
///
/// There is no `Unlock` variant: unlocking is expressed by consuming
/// the affine `LockHandle` returned from `try_lock`.
public type LockKind is Shared | Exclusive;

/// Absolute byte range to lock.
///
/// `length == -1` means "from `start` to end-of-file" (forwarded to the
/// backend as the platform's "to EOF" sentinel — POSIX `l_len == 0`,
/// Windows `bytes_high:bytes_low == MAXUINT64`).
public type LockRegion is {
    start: Int,
    length: Int,
};

/// Errors from `try_lock` / `unlock`.
///
/// `Conflict(owner_pid)` — another holder has an incompatible lock.
/// The owning PID is `Some(pid)` when the platform can report it via
/// `F_GETLK` / `F_OFD_GETLK`, otherwise `None`. `IoError` wraps any
/// non-conflict OS failure (EBADF, ENOLCK, etc.).
public type LockError is
      Conflict(owner_pid: Maybe<Int>)
    | IoError(err: common.OSError);

/// RAII handle to an acquired byte-range lock.
///
/// Marked `affine`: may be moved, but not copied, and must be consumed
/// by exactly one call to `unlock`. Dropping the handle without calling
/// `unlock` is a compile error under the affine-checker — the lock
/// would otherwise leak on the underlying fd.
public type affine LockHandle is {
    fd: common.FileDesc,
    region: LockRegion,
    kind: LockKind,
    active: Bool,
};

// -----------------------------------------------------------------------------
// LockRegion constructors
// -----------------------------------------------------------------------------

implement LockRegion {
    /// Region covering `[start, start + length)`.
    public fn new(start: Int, length: Int) -> LockRegion {
        LockRegion { start: start, length: length }
    }

    /// Region covering `[start, EOF)`.
    public fn to_eof(start: Int) -> LockRegion {
        LockRegion { start: start, length: -1 }
    }

    /// Region covering a single byte at `offset`. Used heavily by the
    /// SQLite 5-state protocol (PENDING_BYTE, RESERVED_BYTE).
    public fn byte(offset: Int) -> LockRegion {
        LockRegion { start: offset, length: 1 }
    }

    public fn start(&self) -> Int { self.start }
    public fn length(&self) -> Int { self.length }

    /// Two regions overlap iff neither lies entirely before the other.
    /// Treats `length == -1` as +∞.
    public fn overlaps(&self, other: &LockRegion) -> Bool {
        let a_end: Int = if self.length < 0 { Int.MAX } else { self.start + self.length };
        let b_end: Int = if other.length < 0 { Int.MAX } else { other.start + other.length };
        !(a_end <= other.start || b_end <= self.start)
    }
}

// -----------------------------------------------------------------------------
// LockHandle
// -----------------------------------------------------------------------------

implement LockHandle {
    /// Private — handles are only constructed inside `try_lock`.
    fn new(fd: common.FileDesc, region: LockRegion, kind: LockKind) -> LockHandle {
        LockHandle { fd: fd, region: region, kind: kind, active: true }
    }

    public fn fd(&self) -> common.FileDesc { self.fd }
    public fn region(&self) -> &LockRegion { &self.region }
    public fn kind(&self) -> LockKind { self.kind }
    public fn is_active(&self) -> Bool { self.active }
}

// -----------------------------------------------------------------------------
// Public API
// -----------------------------------------------------------------------------

/// Non-blocking acquire of an advisory byte-range lock.
///
/// On success returns a fresh `LockHandle` that must be consumed by
/// `unlock`. On conflict (EAGAIN / EWOULDBLOCK / ERROR_LOCK_VIOLATION)
/// returns `Err(Conflict(...))`. Any other OS failure returns
/// `Err(IoError(OSError))`.
///
/// Implementation: dispatches to `core.sys.common.try_lock_region`,
/// which selects `F_OFD_SETLK` on Linux, `F_SETLK` on Darwin, and
/// `LockFileEx` on Windows.
public fn try_lock(
    fd: common.FileDesc,
    region: LockRegion,
    kind: LockKind,
) -> Result<LockHandle, LockError> {
    let backend_kind: common.LockKind = match kind {
        Shared    => common.Shared,
        Exclusive => common.Exclusive,
    };
    // common.try_lock_region treats `len == 0` as "to EOF". Our
    // LockRegion carries that intent as `length == -1`.
    let backend_len: Int = if region.length < 0 { 0 } else { region.length };

    match common.try_lock_region(fd, backend_kind, region.start, backend_len) {
        Ok(_)  => Ok(LockHandle.new(fd, region, kind)),
        Err(e) => {
            if e.would_block() {
                Err(Conflict(None))
            } else {
                Err(IoError(e))
            }
        }
    }
}

/// Release a held lock. Consumes the handle (affine).
///
/// Idempotent in the degenerate sense: if the handle was previously
/// invalidated (theoretically impossible under the affine checker, but
/// guarded defensively for FFI-adjacent use), this is a no-op.
public fn unlock(mut handle: LockHandle) -> Result<(), LockError> {
    if !handle.active {
        return Ok(());
    }
    let backend_len: Int = if handle.region.length < 0 { 0 } else { handle.region.length };
    let res = common.unlock_region(handle.fd, handle.region.start, backend_len);
    handle.active = false;
    match res {
        Ok(_)  => Ok(()),
        Err(e) => Err(IoError(e)),
    }
}

/// Convenience: acquire an exclusive lock on a single byte. SQLite's
/// PENDING_BYTE / RESERVED_BYTE map directly onto this pattern.
public fn try_lock_byte_exclusive(
    fd: common.FileDesc,
    offset: Int,
) -> Result<LockHandle, LockError> {
    try_lock(fd, LockRegion.byte(offset), Exclusive)
}

/// Convenience: acquire a shared lock on a single byte. SQLite's
/// SHARED_BYTE uses this to mark a connection as a reader.
public fn try_lock_byte_shared(
    fd: common.FileDesc,
    offset: Int,
) -> Result<LockHandle, LockError> {
    try_lock(fd, LockRegion.byte(offset), Shared)
}
