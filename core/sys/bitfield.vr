module sys.bitfield;

/// Verum Standard Library: Bitfield Support
///

/// This module provides first-class bitfield support for systems programming.
/// Unlike Rust (which requires external crates) or C (which has ABI-undefined behavior),
/// Verum bitfields are:
/// - Type-safe with compile-time verification
/// - C ABI compatible via @repr(C) + @bitfield
/// - Zero-cost with inlined accessors
///

/// # Core Concepts
///

/// ## @bits(N) Attribute
/// The @bits(N) attribute specifies the bit width of a field within a @bitfield type.
/// Fields are packed in declaration order, respecting endianness annotations.
///

/// ## Bitfield Constraints
/// - Bitfield fields CANNOT have their address taken (&field is forbidden)
/// - Total bits must align to byte boundaries (or use explicit @padding)
/// - Enum fields must have @repr(UIntN, bits = M) with M bits sufficient for variants
///

/// # Examples
///

/// ```verum
/// // TCP header flags - C ABI compatible
/// @repr(C)
/// @bitfield
/// public type TcpFlags is {
///  @bits(1) fin: Bool,
///  @bits(1) syn: Bool,
///  @bits(1) rst: Bool,
///  @bits(1) psh: Bool,
///  @bits(1) ack: Bool,
///  @bits(1) urg: Bool,
///  @bits(2) reserved: UInt8,
/// };
///

/// // Usage
/// let flags = TcpFlags { fin: true, syn: true, ..TcpFlags.zero() };
/// assert(flags.fin);
/// assert(flags.syn);
/// ```
///

/// Implementation Reference: docs/architecture/low-level-features.md Section 2

// =============================================================================
// BITFIELD TRAITS
// =============================================================================

/// Protocol for types that can be stored in bitfields.
///

/// Types implementing this protocol can be used as bitfield fields.
/// The compiler verifies that the type fits within the specified bit width.
public type BitfieldElement is protocol {
    /// Number of bits required to represent this type.
    const BIT_WIDTH: USize;

    /// Convert from raw bits to this type.
    fn from_bits(bits: USize) -> Self;

    /// Convert this type to raw bits.
    fn to_bits(self) -> USize;
};

/// Implement BitfieldElement for Bool (1 bit).
implement BitfieldElement for Bool {
    const BIT_WIDTH: USize = 1;

    @inline(always)
    fn from_bits(bits: USize) -> Bool {
        bits != 0
    }

    @inline(always)
    fn to_bits(self) -> USize {
        if self { 1 } else { 0 }
    }
}

/// Implement BitfieldElement for UInt8.
implement BitfieldElement for UInt8 {
    const BIT_WIDTH: USize = 8;

    @inline(always)
    fn from_bits(bits: USize) -> UInt8 {
        bits as UInt8
    }

    @inline(always)
    fn to_bits(self) -> USize {
        self as USize
    }
}

/// Implement BitfieldElement for UInt16.
implement BitfieldElement for UInt16 {
    const BIT_WIDTH: USize = 16;

    @inline(always)
    fn from_bits(bits: USize) -> UInt16 {
        bits as UInt16
    }

    @inline(always)
    fn to_bits(self) -> USize {
        self as USize
    }
}

/// Implement BitfieldElement for UInt32.
implement BitfieldElement for UInt32 {
    const BIT_WIDTH: USize = 32;

    @inline(always)
    fn from_bits(bits: USize) -> UInt32 {
        bits as UInt32
    }

    @inline(always)
    fn to_bits(self) -> USize {
        self as USize
    }
}

/// Implement BitfieldElement for UInt64.
implement BitfieldElement for UInt64 {
    const BIT_WIDTH: USize = 64;

    @inline(always)
    fn from_bits(bits: USize) -> UInt64 {
        bits as UInt64
    }

    @inline(always)
    fn to_bits(self) -> USize {
        self as USize
    }
}

// =============================================================================
// BITFIELD OPERATIONS
// =============================================================================

/// Protocol for bitfield types (types with @bitfield attribute).
///

/// The compiler automatically implements this protocol for any type
/// annotated with @bitfield. It provides:
/// - Zero initialization
/// - Raw byte access
/// - Bit manipulation primitives
public type Bitfield is protocol {
    /// Size of this bitfield in bytes.
    const SIZE_BYTES: USize;

    /// Total number of bits in this bitfield.
    const SIZE_BITS: USize;

    /// Create a zero-initialized bitfield.
    fn zero() -> Self;

    /// Get the raw bytes of this bitfield.
    fn as_bytes(&self) -> &[UInt8];

    /// Get mutable raw bytes of this bitfield.
    fn as_bytes_mut(&mut self) -> &mut [UInt8];
};

// =============================================================================
// ENDIANNESS SUPPORT
// =============================================================================

/// Endianness for bitfield layout.
///

/// Used with @endian(little|big|native) attribute.
public type Endianness is
    | Little   // Least significant byte first
    | Big      // Most significant byte first
    | Native;  // Platform default

/// Protocol for endian-aware bitfield operations.
public type EndianBitfield is protocol {
    /// The endianness of this bitfield.
    const ENDIAN: Endianness;

    /// Convert to little-endian byte order.
    fn to_le(self) -> Self;

    /// Convert to big-endian byte order.
    fn to_be(self) -> Self;

    /// Convert from little-endian byte order.
    fn from_le(bytes: &[UInt8]) -> Self;

    /// Convert from big-endian byte order.
    fn from_be(bytes: &[UInt8]) -> Self;
};

// =============================================================================
// BIT-MANIPULATION PRIMITIVES
// =============================================================================
//
// Free functions over `USize` — the canonical bit-storage unit used by
// `BitfieldElement.to_bits / from_bits`. Every operation is `pure` and
// `@inline(always)`; under monomorphisation each one collapses to one or
// two CPU instructions, making them suitable for hot-path codegen and
// constant folding when arguments are themselves constants.
//
// All operations are branchless except where a true width boundary
// (`width == 0` or `width == USIZE_BITS`) makes the generic shift path
// unsound — there a single `if` lifts the boundary out of the hot path,
// and the compiler proves both arms trivial under inlining when the
// width is statically known.
//
// Boundary table (let N = USIZE_BITS):
//
//   width      | extract / insert / field_mask
//   -----------+------------------------------------------------------------
//   0          | extract → 0; insert → value; field_mask → 0
//   1 .. N-1   | hot path: `((1 << width) - 1) << offset`
//   N (full)   | extract → value; insert → bits; field_mask → !0 (all ones)
//
// The `width >= USIZE_BITS` path exists because LLVM defines `shl ?, N`
// as poison when `N >= bit_width`; on x86_64 the silicon further masks
// the shift count to `N-1`, producing `1 << 0 = 1` instead of
// "all ones". The boundary lift makes the function total over
// `0..=USIZE_BITS` regardless of host instruction-set quirks.
//
// Caller contracts (NOT runtime-enforced):
//
//   * `n < USIZE_BITS`              for *_bit operations
//   * `offset + width <= USIZE_BITS` for *_bits / extract / insert
//   * `width <= USIZE_BITS`         for field_mask / extract / insert
//
// Violating these silently yields the LLVM-poison value of the
// underlying shift; downstream computations remain defined-but-garbage.
// Bitfield-codegen call sites prove these invariants from the
// surrounding `@bits(N)` annotations, so the runtime checks would be
// pure overhead.

/// Bit-width of a `USize` value (alias for `USize.bits`).
///
/// Re-exposed at the bitfield-API site so call sites validating
/// `offset` / `width` against the canonical bitfield word do not need to
/// import the `type_info` intrinsics directly.
public const USIZE_BITS: USize = USize.bits;

// --- Single-bit operations -------------------------------------------------

/// Test bit at position `n` in `value`.
///
/// Returns `true` iff bit `n` is set. `(value >> n) & 1 != 0`.
@inline(always)
public pure fn test_bit(value: USize, n: USize) -> Bool {
    (value & ((1 as USize) << n)) != (0 as USize)
}

/// Set bit at position `n` in `value`.
///
/// Idempotent: `set_bit(set_bit(v, n), n) == set_bit(v, n)`.
@inline(always)
public pure fn set_bit(value: USize, n: USize) -> USize {
    value | ((1 as USize) << n)
}

/// Clear bit at position `n` in `value`.
///
/// Idempotent: `clear_bit(clear_bit(v, n), n) == clear_bit(v, n)`.
@inline(always)
public pure fn clear_bit(value: USize, n: USize) -> USize {
    value & !((1 as USize) << n)
}

/// Toggle bit at position `n` in `value`.
///
/// Self-inverse: `toggle_bit(toggle_bit(v, n), n) == v`.
@inline(always)
public pure fn toggle_bit(value: USize, n: USize) -> USize {
    value ^ ((1 as USize) << n)
}

// --- Mask operations -------------------------------------------------------

/// Set every bit in `value` covered by `mask` (`value | mask`).
///
/// Idempotent in `mask`:
///   `set_bits(set_bits(v, m), m) == set_bits(v, m)`.
@inline(always)
public pure fn set_bits(value: USize, mask: USize) -> USize {
    value | mask
}

/// Clear every bit in `value` covered by `mask` (`value & !mask`).
///
/// Idempotent in `mask`:
///   `clear_bits(clear_bits(v, m), m) == clear_bits(v, m)`.
@inline(always)
public pure fn clear_bits(value: USize, mask: USize) -> USize {
    value & !mask
}

// --- Field operations ------------------------------------------------------

/// Build a contiguous-1 mask covering `width` bits starting at `offset`.
///
/// Boundary behaviour:
///
///   * `field_mask(_, 0)`              → `0`
///   * `field_mask(0, USIZE_BITS)`     → `!0` (all ones)
///   * `field_mask(o, w)` for `0 < w < USIZE_BITS`
///                                     → `((1 << w) - 1) << o`
///
/// Disjoint-union law (non-overlapping contiguous fields):
///   `field_mask(o, w) | field_mask(o + w, k) == field_mask(o, w + k)`
///   when `o + w + k <= USIZE_BITS`.
@inline(always)
public pure fn field_mask(offset: USize, width: USize) -> USize {
    if width == (0 as USize) {
        0 as USize
    } else if width >= USIZE_BITS {
        !(0 as USize)
    } else {
        (((1 as USize) << width) - (1 as USize)) << offset
    }
}

/// Extract `width` bits starting at `offset` from `value`. The returned
/// field is right-shifted so its low bit sits at position 0.
///
/// Equivalent to `(value & field_mask(offset, width)) >> offset`, but
/// the implementation drops the intermediate mask because the right-shift
/// already discards the high bits before the low-mask is applied.
///
/// Boundary behaviour:
///
///   * `extract_bits(_, _, 0)`              → `0`
///   * `extract_bits(value, 0, USIZE_BITS)` → `value` (full read-through)
@inline(always)
public pure fn extract_bits(value: USize, offset: USize, width: USize) -> USize {
    if width == (0 as USize) {
        0 as USize
    } else if width >= USIZE_BITS {
        value
    } else {
        (value >> offset) & (((1 as USize) << width) - (1 as USize))
    }
}

/// Insert the low `width` bits of `bits` into `value` at `offset`.
///
/// Bits in `bits` above position `width - 1` are silently masked away,
/// so the call cannot bleed into adjacent fields even when `bits` is
/// untrusted.
///
/// Round-trip law (for any `value`, `bits`, `offset`, `width` satisfying
/// `offset + width <= USIZE_BITS`):
///
///   extract_bits(
///       insert_bits(value, bits, offset, width),
///       offset, width)
///     == bits & field_mask(0, width)
///
/// Adjacent-field independence: `insert_bits(v, b, o, w)` leaves every
/// bit outside `[o, o + w)` unchanged.
///
/// Boundary behaviour:
///
///   * `insert_bits(value, _, _, 0)`            → `value` (no field, no change)
///   * `insert_bits(_, bits, 0, USIZE_BITS)`    → `bits`  (full overwrite)
@inline(always)
public pure fn insert_bits(value: USize, bits: USize, offset: USize, width: USize) -> USize {
    if width == (0 as USize) {
        value
    } else if width >= USIZE_BITS {
        bits
    } else {
        let low_mask: USize = ((1 as USize) << width) - (1 as USize);
        let field:    USize = low_mask << offset;
        (value & !field) | ((bits & low_mask) << offset)
    }
}

// =============================================================================
// BITFIELD VERIFICATION
// =============================================================================

/// Compile-time verification constraints for bitfields.
///

/// These meta functions are used by the compiler to verify bitfield layouts.
/// They are evaluated at compile time and produce errors if constraints are violated.

/// Verify that a bitfield's total bits align to byte boundaries.
///

/// # Compile-Time Error
/// If total_bits % 8 != 0, produces: "Bitfield must be byte-aligned, got N bits"
@const
public fn verify_byte_alignment<TOTAL_BITS: meta USize>() -> Bool
where TOTAL_BITS % 8 == 0
{
    true
}

/// Verify that a field's bit width fits within its backing type.
///

/// # Compile-Time Error
/// If field_bits > type_bits, produces: "Field requires N bits but type only provides M"
@const
public fn verify_field_width<FIELD_BITS: meta USize, TYPE_BITS: meta USize>() -> Bool
where FIELD_BITS <= TYPE_BITS
{
    true
}

/// Verify that an enum's variants fit within the specified bit width.
///

/// # Compile-Time Error
/// If max_variant > 2^bits - 1, produces: "Enum variant N exceeds bit width"
@const
public fn verify_enum_fits<MAX_VARIANT: meta USize, BITS: meta USize>() -> Bool
where MAX_VARIANT < (1 << BITS)
{
    true
}

// =============================================================================
// BITFIELD MACROS
// =============================================================================

/// Static assertion for bitfield properties.
///

/// Use @static_assert to verify bitfield layouts at compile time:
///

/// ```verum
/// @static_assert(TcpFlags.size == 1, "TcpFlags must be 1 byte")
/// @static_assert(TcpFlags.alignment == 1, "TcpFlags must be byte-aligned")
/// ```
///

/// The compiler evaluates these at compile time and produces an error
/// with the provided message if the condition is false.

// =============================================================================
// EXAMPLE TYPES
// =============================================================================

/// Example: GPIO configuration register.
///

/// Demonstrates enum bitfields with explicit bit representation.
@repr(UInt8, bits = 4)
public type GpioMode is
    | @value(0b0000) Input
    | @value(0b0001) OutputPushPull
    | @value(0b0010) OutputOpenDrain
    | @value(0b0011) AlternateFunction
    | @value(0b0100) Analog;

/// Example: GPIO speed setting.
@repr(UInt8, bits = 2)
public type GpioSpeed is
    | @value(0b00) Low
    | @value(0b01) Medium
    | @value(0b10) High
    | @value(0b11) VeryHigh;

/// Example: Complete GPIO configuration bitfield.
///

/// This type demonstrates all bitfield features:
/// - Enum fields with explicit bit representation
/// - Bool fields for single bits
/// - Reserved bits for hardware compatibility
/// - Explicit endianness annotation
@repr(C)
@bitfield
@endian(little)
public type GpioConfig is {
    @bits(4) mode: GpioMode,
    @bits(2) speed: GpioSpeed,
    @bits(1) pull_up: Bool,
    @bits(1) pull_down: Bool,
    @bits(4) alternate_function: UInt8,
    @bits(4) reserved: UInt8,
};

// Compile-time verification of GpioConfig layout
// Compile-time assertions for GpioConfig layout
// GpioConfig.SIZE_BYTES == 2 (2 bytes)
// GpioConfig.SIZE_BITS == 16 (16 bits)
