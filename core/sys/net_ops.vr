module sys.net_ops;

// =============================================================================
// sys/net_ops.vr - Network Operations (replaces C verum_tcp_*/verum_udp_*)
// =============================================================================
// Layer: 1 (I/O)
// Dependencies: sys/raw
// =============================================================================
//

// Pure Verum TCP/UDP operations. Compiled through VBC → LLVM.
// No C runtime dependency.
//

// =============================================================================

mount core.*;
// Raw-intrinsic mount. The pre-migration `mount super.raw.*` pointed
// at a `core/sys/raw.vr` file that no longer exists — declarations
// migrated to `core/intrinsics/runtime/os.vr`. Same architectural fix
// as the one already landed for time_ops.vr.
mount core.intrinsics.runtime.os.{
    __tcp_connect_raw,
    __tcp_listen_raw,
    __tcp_accept_raw,
    __tcp_send_raw,
    __tcp_recv_raw,
    __tcp_close_raw,
    __udp_bind_raw,
    __udp_send_raw,
    __udp_recv_raw,
    __udp_close_raw,
};

// Hostname resolution for `RawTcpStream.connect`. The `tcp_connect`
// intrinsic is IP-literal-only (libc-free `inet_pton`, no
// `getaddrinfo`) — turning a hostname into an IP is this layer's job.
// `lookup_host` short-circuits IP literals with zero network I/O and
// consults the static host DB (localhost, /etc/hosts) before any DNS
// query. Task #43 (last getaddrinfo member of the no-libc class).
mount core.net.dns.lookup_host;
mount core.net.addr.{IpAddr, Ipv4Addr, V4};

// =============================================================================
// TCP
// =============================================================================

// User-facing API lives in `core.net.tcp` / `core.net.udp` —
// `TcpStream` / `TcpListener` / `UdpSocket` there have rich
// async/CBGR/IoError surface. The types in *this* module are the
// raw FFI-only shape kept around as a fallback for code paths that
// don't go through the IOEngine. They were originally named
// `TcpStream`, `TcpListener`, `UdpSocket` — same as the
// user-facing API — which silently shadowed the rich
// `core.net.tcp.TcpListener` whenever both were transitively in
// scope, breaking method dispatch (`TcpListener.bind(addr:
// SocketAddr)` resolved to `Raw*` `bind(port: Int)` and produced
// "Type mismatch: expected 'Int'"). Renamed to `Raw*` so the
// shadow disappears. Tracked under #75.

/// A TCP connection (raw FFI-only fallback — prefer `core.net.tcp.TcpStream`).
public type RawTcpStream is {
    fd: Int,
};

/// A TCP server socket (raw FFI-only fallback — prefer `core.net.tcp.TcpListener`).
public type RawTcpListener is {
    fd: Int,
};

implement RawTcpStream {
    /// Connect to a remote host:port.
    ///
    /// `host` may be a hostname or an IP literal. It is resolved to an
    /// IPv4 literal HERE (via `lookup_host`) before reaching the
    /// `tcp_connect` intrinsic, which is IP-literal-only and libc-free
    /// (no `getaddrinfo`). `lookup_host` fast-paths IP literals with no
    /// network I/O, so the common `connect("127.0.0.1", ...)` call
    /// stays a straight parse. Task #43.
    ///
    /// IPv4-only: the intrinsic speaks `AF_INET` (`inet_pton`), so IPv6
    /// hosts/literals (e.g. `"::1"`, AAAA-only names) return `None`
    /// here — use `core.net.tcp.TcpStream` for dual-stack.
    public fn connect(host: Text, port: Int) -> Maybe<RawTcpStream> {
        let addrs = match lookup_host(&host) {
            Result.Ok(list) => list,
            Result.Err(_) => return Maybe.None,
        };
        // The intrinsic speaks IPv4 (AF_INET) only — select the first
        // V4 result and hand it over as a dotted-quad literal. `f"{v4}"`
        // routes through `Ipv4Addr`'s Display (one formatting authority,
        // same idiom as dns.vr's `A(ip) => f"{ip}"`).
        let mut ip: Maybe<Text> = Maybe.None;
        for addr in addrs {
            if let V4(v4) = addr {
                ip = Maybe.Some(f"{v4}");
                break;
            }
        }
        let ip_text = match ip {
            Maybe.Some(t) => t,
            Maybe.None => return Maybe.None,
        };
        let fd = __tcp_connect_raw(ip_text, port);
        if fd < 0 {
            Maybe.None
        } else {
            Maybe.Some(RawTcpStream { fd: fd })
        }
    }

    /// Send text data.
    public fn send(&self, data: Text) -> Int {
        __tcp_send_raw(self.fd, data)
    }

    /// Receive text data (up to max_len bytes).
    public fn recv(&self, max_len: Int) -> Text {
        __tcp_recv_raw(self.fd, max_len)
    }

    /// Close the connection.
    public fn close(&self) {
        __tcp_close_raw(self.fd);
    }

    /// Get the underlying file descriptor.
    public fn raw_fd(&self) -> Int {
        self.fd
    }
}

implement RawTcpListener {
    /// Bind and listen on a port. Returns listener.
    public fn bind(port: Int) -> Maybe<RawTcpListener> {
        let fd = __tcp_listen_raw(port);
        if fd < 0 {
            Maybe.None
        } else {
            Maybe.Some(RawTcpListener { fd: fd })
        }
    }

    /// Accept an incoming connection.
    public fn accept(&self) -> Maybe<RawTcpStream> {
        let client_fd = __tcp_accept_raw(self.fd);
        if client_fd < 0 {
            Maybe.None
        } else {
            Maybe.Some(RawTcpStream { fd: client_fd })
        }
    }

    /// Close the listener.
    public fn close(&self) {
        __tcp_close_raw(self.fd);
    }

    /// Get the underlying file descriptor.
    public fn raw_fd(&self) -> Int {
        self.fd
    }
}

// =============================================================================
// UDP
// =============================================================================

/// A UDP socket.
public type RawUdpSocket is {
    fd: Int,
};

implement RawUdpSocket {
    /// Bind to a local port.
    public fn bind(port: Int) -> Maybe<RawUdpSocket> {
        let fd = __udp_bind_raw(port);
        if fd < 0 {
            Maybe.None
        } else {
            Maybe.Some(RawUdpSocket { fd: fd })
        }
    }

    /// Send data to remote host:port.
    public fn send_to(&self, data: Text, host: Text, port: Int) -> Int {
        __udp_send_raw(self.fd, data, host, port)
    }

    /// Receive data.
    public fn recv(&self, max_len: Int) -> Text {
        __udp_recv_raw(self.fd, max_len)
    }

    /// Close the socket.
    public fn close(&self) {
        __udp_close_raw(self.fd);
    }
}
