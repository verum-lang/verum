module sys.net_ops;

// =============================================================================
// sys/net_ops.vr - Network Operations (replaces C verum_tcp_*/verum_udp_*)
// =============================================================================
// Layer: 1 (I/O)
// Dependencies: sys/raw
// =============================================================================
//
// Pure Verum TCP/UDP operations. Compiled through VBC → LLVM.
// No C runtime dependency.
//
// =============================================================================

mount core.*;
mount super.raw.*;

// =============================================================================
// TCP
// =============================================================================

// User-facing API lives in `core.net.tcp` / `core.net.udp` —
// `TcpStream` / `TcpListener` / `UdpSocket` there have rich
// async/CBGR/IoError surface. The types in *this* module are the
// raw FFI-only shape kept around as a fallback for code paths that
// don't go through the IOEngine. They were originally named
// `TcpStream`, `TcpListener`, `UdpSocket` — same as the
// user-facing API — which silently shadowed the rich
// `core.net.tcp.TcpListener` whenever both were transitively in
// scope, breaking method dispatch (`TcpListener.bind(addr:
// SocketAddr)` resolved to `Raw*` `bind(port: Int)` and produced
// "Type mismatch: expected 'Int'"). Renamed to `Raw*` so the
// shadow disappears. Tracked under #75.

/// A TCP connection (raw FFI-only fallback — prefer `core.net.tcp.TcpStream`).
public type RawTcpStream is {
    fd: Int,
};

/// A TCP server socket (raw FFI-only fallback — prefer `core.net.tcp.TcpListener`).
public type RawTcpListener is {
    fd: Int,
};

implement RawTcpStream {
    /// Connect to a remote host:port.
    public fn connect(host: Text, port: Int) -> Maybe<RawTcpStream> {
        let fd = __tcp_connect_raw(host, port);
        if fd < 0 {
            None
        } else {
            Some(RawTcpStream { fd: fd })
        }
    }

    /// Send text data.
    public fn send(&self, data: Text) -> Int {
        __tcp_send_raw(self.fd, data)
    }

    /// Receive text data (up to max_len bytes).
    public fn recv(&self, max_len: Int) -> Text {
        __tcp_recv_raw(self.fd, max_len)
    }

    /// Close the connection.
    public fn close(&self) {
        __tcp_close_raw(self.fd);
    }

    /// Get the underlying file descriptor.
    public fn raw_fd(&self) -> Int {
        self.fd
    }
}

implement RawTcpListener {
    /// Bind and listen on a port. Returns listener.
    public fn bind(port: Int) -> Maybe<RawTcpListener> {
        let fd = __tcp_listen_raw(port);
        if fd < 0 {
            None
        } else {
            Some(RawTcpListener { fd: fd })
        }
    }

    /// Accept an incoming connection.
    public fn accept(&self) -> Maybe<RawTcpStream> {
        let client_fd = __tcp_accept_raw(self.fd);
        if client_fd < 0 {
            None
        } else {
            Some(RawTcpStream { fd: client_fd })
        }
    }

    /// Close the listener.
    public fn close(&self) {
        __tcp_close_raw(self.fd);
    }

    /// Get the underlying file descriptor.
    public fn raw_fd(&self) -> Int {
        self.fd
    }
}

// =============================================================================
// UDP
// =============================================================================

/// A UDP socket.
public type RawUdpSocket is {
    fd: Int,
};

implement RawUdpSocket {
    /// Bind to a local port.
    public fn bind(port: Int) -> Maybe<RawUdpSocket> {
        let fd = __udp_bind_raw(port);
        if fd < 0 {
            None
        } else {
            Some(RawUdpSocket { fd: fd })
        }
    }

    /// Send data to remote host:port.
    public fn send_to(&self, data: Text, host: Text, port: Int) -> Int {
        __udp_send_raw(self.fd, data, host, port)
    }

    /// Receive data.
    public fn recv(&self, max_len: Int) -> Text {
        __udp_recv_raw(self.fd, max_len)
    }

    /// Close the socket.
    public fn close(&self) {
        __udp_close_raw(self.fd);
    }
}
