// =============================================================================
// NT Native API Functions (ntdll.dll)
// =============================================================================

/// Close an object handle
@extern("ntdll.dll")
public fn NtClose(handle: Handle) -> NtStatus;

/// Create or open a file
@extern("ntdll.dll")
public fn NtCreateFile(
    file_handle: &mut Handle,
    desired_access: UInt32,
    object_attributes: &ObjectAttributes,
    io_status_block: &mut IoStatusBlock,
    allocation_size: &LargeInteger,
    file_attributes: UInt32,
    share_access: UInt32,
    create_disposition: UInt32,
    create_options: UInt32,
    ea_buffer: &unsafe Byte,
    ea_length: UInt32,
) -> NtStatus;

/// Open an existing file
@extern("ntdll.dll")
public fn NtOpenFile(
    file_handle: &mut Handle,
    desired_access: UInt32,
    object_attributes: &ObjectAttributes,
    io_status_block: &mut IoStatusBlock,
    share_access: UInt32,
    open_options: UInt32,
) -> NtStatus;

/// Read from a file
@extern("ntdll.dll")
public fn NtReadFile(
    file_handle: Handle,
    event: Handle,
    apc_routine: &unsafe Byte,
    apc_context: &unsafe Byte,
    io_status_block: &mut IoStatusBlock,
    buffer: &unsafe mut Byte,
    length: UInt32,
    byte_offset: &LargeInteger,
    key: &UInt32,
) -> NtStatus;

/// Write to a file
@extern("ntdll.dll")
public fn NtWriteFile(
    file_handle: Handle,
    event: Handle,
    apc_routine: &unsafe Byte,
    apc_context: &unsafe Byte,
    io_status_block: &mut IoStatusBlock,
    buffer: &unsafe Byte,
    length: UInt32,
    byte_offset: &LargeInteger,
    key: &UInt32,
) -> NtStatus;

/// Query file information
@extern("ntdll.dll")
public fn NtQueryInformationFile(
    file_handle: Handle,
    io_status_block: &mut IoStatusBlock,
    file_information: &unsafe mut Byte,
    length: UInt32,
    file_information_class: UInt32,
) -> NtStatus;

/// Set file information
@extern("ntdll.dll")
public fn NtSetInformationFile(
    file_handle: Handle,
    io_status_block: &mut IoStatusBlock,
    file_information: &unsafe Byte,
    length: UInt32,
    file_information_class: UInt32,
) -> NtStatus;

