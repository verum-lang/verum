@extern("ntdll.dll")
public fn NtSetInformationFile(
    file_handle: Handle,
    io_status_block: &mut IoStatusBlock,
    file_information: &unsafe Byte,
    length: UInt32,
    file_information_class: UInt32,
) -> NtStatus;

// File information class for IOCP association
public const FileCompletionInformation: UInt32 = 30;

/// File completion information structure
public type FileCompletionInfo is {
    port: Handle,
    key: &unsafe Byte,
};

// =============================================================================
// Event Types
// =============================================================================

/// Notification event (auto-reset)
public const NotificationEvent: UInt32 = 0;

/// Synchronization event (manual-reset)
public const SynchronizationEvent: UInt32 = 1;

// =============================================================================
// Wait Types
// =============================================================================

/// Wait for all objects
public const WaitAll: UInt32 = 0;

/// Wait for any object
public const WaitAny: UInt32 = 1;

// =============================================================================
// Thread Creation Flags
// =============================================================================

public const THREAD_CREATE_FLAGS_CREATE_SUSPENDED: UInt32 = 0x00000001;
public const THREAD_CREATE_FLAGS_SKIP_THREAD_ATTACH: UInt32 = 0x00000002;
public const THREAD_CREATE_FLAGS_HIDE_FROM_DEBUGGER: UInt32 = 0x00000004;
public const THREAD_CREATE_FLAGS_HAS_SECURITY_DESCRIPTOR: UInt32 = 0x00000010;
public const THREAD_CREATE_FLAGS_ACCESS_CHECK_IN_TARGET: UInt32 = 0x00000020;
public const THREAD_CREATE_FLAGS_INITIAL_THREAD: UInt32 = 0x00000080;

// =============================================================================
// Safe Wrappers
// =============================================================================

/// Close a handle safely
public fn safe_close(handle: Handle) -> Result<(), NtStatus> {
    if !handle.is_valid() {
        return Ok(());
    }
    let status = NtClose(handle);
    if status.is_success() {
        Ok(())
    } else {
        Err(status)
    }
}

/// Allocate virtual memory safely
public fn safe_allocate(
    size: Int,
    protect: UInt32,
) -> Result<&unsafe Byte, NtStatus> {
    let mut base: &unsafe Byte = 0 as &unsafe Byte;
    let mut region_size = size;

    let status = NtAllocateVirtualMemory(
        nt_current_process(),
        &mut base,
        0,
        &mut region_size,
        MEM_COMMIT | MEM_RESERVE,
        protect,
    );

    if status.is_success() {
        Ok(base)
    } else {
        Err(status)
    }
}

/// Free virtual memory safely
public fn safe_free(base: &unsafe Byte) -> Result<(), NtStatus> {
    let mut base_mut = base;
    let mut region_size = 0;

    let status = NtFreeVirtualMemory(
        nt_current_process(),
        &mut base_mut,
        &mut region_size,
        MEM_RELEASE,
    );

    if status.is_success() {
        Ok(())
    } else {
        Err(status)
    }
}

/// Sleep for specified nanoseconds (negative = relative time)
public fn safe_delay(nanoseconds: Int64) -> Result<(), NtStatus> {
    // Convert to 100ns intervals (negative for relative time)
    let interval = LargeInteger(-(nanoseconds / 100));
    let status = NtDelayExecution(false, &interval);
    if status.is_success() {
        Ok(())
    } else {
        Err(status)
    }
}
