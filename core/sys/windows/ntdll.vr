module sys.windows.ntdll;

// =============================================================================
// sys/windows/ntdll.vr - NT Native API (ntdll.dll) FFI
// =============================================================================
// Layer: 0 (Core)
// Dependencies: sys/windows/ntstatus
// Platform: Windows (x86_64)
// =============================================================================
//
// This module provides direct access to NT Native API functions from
// ntdll.dll. These are the lowest-level userspace APIs on Windows.
//
// IMPORTANT: Uses IAT imports (@extern) not PEB walking, as specified
// in the architecture spec. This avoids AV heuristics and is the
// correct approach for non-malware code.
//
// Spec: docs/architecture/new-arch-spec.md Section 5.4
// Reference: experiments/ntapi
// =============================================================================

mount super.ntstatus.{NtStatus, STATUS_SUCCESS};

// =============================================================================
// Basic Types
// =============================================================================

/// Windows HANDLE type (opaque pointer)
public type Handle is (Int);

implement Handle {
    /// Invalid handle value
    public const INVALID: Handle = Handle(-1);

    /// Null handle
    public const NULL: Handle = Handle(0);

    /// Check if handle is valid
    @inline
    public fn is_valid(&self) -> Bool {
        self.0 != -1 && self.0 != 0
    }

    /// Get raw handle value
    @inline
    public fn raw(&self) -> Int {
        self.0
    }
}

/// Large integer (64-bit signed)
public type LargeInteger is (Int64);

/// Unsigned large integer (64-bit unsigned)
public type ULargeInteger is (UInt64);

/// Unicode string (Windows native)
public type UnicodeString is {
    length: UInt16,
    maximum_length: UInt16,
    buffer: &unsafe UInt16,
};

/// Object attributes for NT object creation
public type ObjectAttributes is {
    length: UInt32,
    root_directory: Handle,
    object_name: &UnicodeString,
    attributes: UInt32,
    security_descriptor: &unsafe Byte,
    security_quality_of_service: &unsafe Byte,
};

implement ObjectAttributes {
    /// Create null/empty object attributes
    public fn null() -> ObjectAttributes {
        ObjectAttributes {
            length: 48,  // sizeof(OBJECT_ATTRIBUTES) on x64
            root_directory: Handle.NULL,
            object_name: 0 as &UnicodeString,
            attributes: 0,
            security_descriptor: 0 as &unsafe Byte,
            security_quality_of_service: 0 as &unsafe Byte,
        }
    }

    /// Create with object name
    public fn with_name(name: &UnicodeString) -> ObjectAttributes {
        ObjectAttributes {
            length: 48,
            root_directory: Handle.NULL,
            object_name: name,
            attributes: OBJ_CASE_INSENSITIVE,
            security_descriptor: 0 as &unsafe Byte,
            security_quality_of_service: 0 as &unsafe Byte,
        }
    }
}

/// I/O status block for async I/O
public type IoStatusBlock is {
    /// Union: Status (NTSTATUS) or Pointer (PVOID)
    status_or_pointer: Int,
    /// Bytes transferred or file information
    information: Int,
};

implement IoStatusBlock {
    /// Create a zeroed I/O status block
    public fn new() -> IoStatusBlock {
        IoStatusBlock {
            status_or_pointer: 0,
            information: 0,
        }
    }

    /// Get the status code
    @inline
    public fn status(&self) -> NtStatus {
        NtStatus(self.status_or_pointer as Int32)
    }

    /// Get bytes transferred
    @inline
    public fn bytes_transferred(&self) -> Int {
        self.information
    }
}

/// Client ID (process + thread ID)
public type ClientId is {
    unique_process: Handle,
    unique_thread: Handle,
};

