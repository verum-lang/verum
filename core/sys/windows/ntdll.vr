    return_length: &mut Int,
) -> NtStatus;

// =============================================================================
// Process and Thread
// =============================================================================

/// Get current process handle (-1)
@inline
public fn nt_current_process() -> Handle {
    Handle(-1)
}

/// Get current thread handle (-2)
@inline
public fn nt_current_thread() -> Handle {
    Handle(-2)
}

/// Get current process ID
@extern("ntdll.dll")
public fn NtCurrentProcessId() -> Int;

/// Get current thread ID
@extern("ntdll.dll")
public fn NtCurrentThreadId() -> Int;

/// Create a new thread
@extern("ntdll.dll")
public fn NtCreateThreadEx(
    thread_handle: &mut Handle,
    desired_access: UInt32,
    object_attributes: &ObjectAttributes,
    process_handle: Handle,
    start_routine: &unsafe Byte,
    argument: &unsafe Byte,
    create_flags: UInt32,
    zero_bits: Int,
    stack_size: Int,
    maximum_stack_size: Int,
    attribute_list: &unsafe Byte,
) -> NtStatus;

/// Terminate a thread
@extern("ntdll.dll")
public fn NtTerminateThread(
    thread_handle: Handle,
    exit_status: NtStatus,
) -> NtStatus;

/// Suspend a thread
@extern("ntdll.dll")
public fn NtSuspendThread(
    thread_handle: Handle,
    previous_suspend_count: &mut UInt32,
) -> NtStatus;

/// Resume a thread
@extern("ntdll.dll")
public fn NtResumeThread(
    thread_handle: Handle,
    previous_suspend_count: &mut UInt32,
) -> NtStatus;

/// Wait for single object
@extern("ntdll.dll")
public fn NtWaitForSingleObject(
    handle: Handle,
    alertable: Bool,
    timeout: &LargeInteger,
) -> NtStatus;

/// Wait for multiple objects
@extern("ntdll.dll")
public fn NtWaitForMultipleObjects(
    count: UInt32,
    handles: &Handle,
    wait_type: UInt32,
    alertable: Bool,
    timeout: &LargeInteger,
) -> NtStatus;

/// Signal object and wait
@extern("ntdll.dll")
public fn NtSignalAndWaitForSingleObject(
    signal_handle: Handle,
    wait_handle: Handle,
    alertable: Bool,
    timeout: &LargeInteger,
) -> NtStatus;

/// Terminate current process
@extern("ntdll.dll")
public fn NtTerminateProcess(
    process_handle: Handle,
    exit_status: NtStatus,
) -> NtStatus;

