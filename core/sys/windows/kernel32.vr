// =============================================================================
// Process Creation
// =============================================================================

/// Startup info for CreateProcess (ANSI version, 104 bytes on x64)
public type StartupInfoA is {
    cb: UInt32,
    reserved: &unsafe Byte,
    desktop: &unsafe Byte,
    title: &unsafe Byte,
    x: UInt32,
    y: UInt32,
    x_size: UInt32,
    y_size: UInt32,
    x_count_chars: UInt32,
    y_count_chars: UInt32,
    fill_attribute: UInt32,
    flags: UInt32,
    show_window: UInt16,
    cb_reserved2: UInt16,
    reserved2: &unsafe Byte,
    std_input: Handle,
    std_output: Handle,
    std_error: Handle,
};

implement StartupInfoA {
    /// Create a zeroed StartupInfoA with cb set to the struct size.
    public fn new() -> StartupInfoA {
        StartupInfoA {
            cb: 104 as UInt32,  // sizeof(STARTUPINFOA) on x64
            reserved: 0 as &unsafe Byte,
            desktop: 0 as &unsafe Byte,
            title: 0 as &unsafe Byte,
            x: 0,
            y: 0,
            x_size: 0,
            y_size: 0,
            x_count_chars: 0,
            y_count_chars: 0,
            fill_attribute: 0,
            flags: 0,
            show_window: 0,
            cb_reserved2: 0,
            reserved2: 0 as &unsafe Byte,
            std_input: Handle.NULL,
            std_output: Handle.NULL,
            std_error: Handle.NULL,
        }
    }
}

/// Process information returned by CreateProcess
public type ProcessInformation is {
    process: Handle,
    thread: Handle,
    process_id: UInt32,
    thread_id: UInt32,
};

/// Create a new process (ANSI version)
@extern("kernel32.dll")
public fn CreateProcessA(
    application_name: &unsafe Byte,
    command_line: &unsafe Byte,
    process_attributes: &unsafe Byte,
    thread_attributes: &unsafe Byte,
    inherit_handles: Int32,
    creation_flags: UInt32,
    environment: &unsafe Byte,
    current_directory: &unsafe Byte,
    startup_info: &StartupInfoA,
    process_information: &mut ProcessInformation,
) -> Int32;

/// Create an anonymous pipe.
///
/// Returns read and write handles. `inherit_handles` in SecurityAttributes
/// controls whether the handles are inherited by child processes.
@extern("kernel32.dll")
public fn CreatePipe(
    read_pipe: &mut Handle,
    write_pipe: &mut Handle,
    pipe_attributes: &SecurityAttributes,
    size: UInt32,
) -> Int32;

/// Set handle information (used to control inheritance of pipe handles).
@extern("kernel32.dll")
public fn SetHandleInformation(
    object: Handle,
    mask: UInt32,
    flags: UInt32,
) -> Int32;

/// STARTF_USESTDHANDLES flag — use std_input/std_output/std_error from StartupInfo
