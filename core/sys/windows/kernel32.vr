public fn WakeAllConditionVariable(condition_variable: &unsafe Byte);

// =============================================================================
// Address-Based Waiting (Windows 8+ futex equivalent)
// =============================================================================

/// Block until the value at the address changes.
///
/// Compares *address with *compare_address (of `address_size` bytes).
/// If equal, blocks until WakeByAddressSingle/All is called on the address,
/// or the timeout expires. Returns true if woken, false on timeout/error.
///
/// This is the Windows equivalent of Linux futex(FUTEX_WAIT).
@extern("kernel32.dll")
public fn WaitOnAddress(
    address: &unsafe Byte,
    compare_address: &unsafe Byte,
    address_size: USize,
    timeout_ms: UInt32,
) -> Int32;

/// Wake a single thread waiting on the address.
///
/// This is the Windows equivalent of Linux futex(FUTEX_WAKE, 1).
@extern("kernel32.dll")
public fn WakeByAddressSingle(address: &unsafe Byte);

/// Wake all threads waiting on the address.
///
/// This is the Windows equivalent of Linux futex(FUTEX_WAKE, INT_MAX).
@extern("kernel32.dll")
public fn WakeByAddressAll(address: &unsafe Byte);

