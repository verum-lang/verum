// =============================================================================
// Overlapped Structure
// =============================================================================

/// Overlapped structure for async I/O
public type Overlapped is {
    internal: Int,
    internal_high: Int,
    offset: UInt32,
    offset_high: UInt32,
    event: Handle,
};

implement Overlapped {
    /// Create a new zeroed overlapped structure
    public fn new() -> Overlapped {
        Overlapped {
            internal: 0,
            internal_high: 0,
            offset: 0,
            offset_high: 0,
            event: Handle.NULL,
        }
    }

    /// Create with event handle
    public fn with_event(event: Handle) -> Overlapped {
        Overlapped {
            internal: 0,
            internal_high: 0,
            offset: 0,
            offset_high: 0,
            event: event,
        }
    }

    /// Set file offset
    public fn set_offset(&mut self, offset: UInt64) {
        self.offset = (offset & 0xFFFFFFFF) as UInt32;
        self.offset_high = (offset >> 32) as UInt32;
    }

    /// Get file offset
    public fn get_offset(&self) -> UInt64 {
        (self.offset as UInt64) | ((self.offset_high as UInt64) << 32)
    }
}

// =============================================================================
// Security Attributes
// =============================================================================

/// Security attributes structure
public type SecurityAttributes is {
    length: UInt32,
    security_descriptor: &unsafe Byte,
    inherit_handle: Int32,
};

implement SecurityAttributes {
    /// Create default security attributes
    public fn default() -> SecurityAttributes {
        SecurityAttributes {
            length: 24,  // sizeof on x64
            security_descriptor: 0 as &unsafe Byte,
            inherit_handle: false,
        }
    }
}

