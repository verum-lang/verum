/// CREATE_NO_WINDOW flag — don't create a console window
public const CREATE_NO_WINDOW: UInt32 = 0x08000000;

/// HANDLE_FLAG_INHERIT
public const HANDLE_FLAG_INHERIT: UInt32 = 0x00000001;

/// STILL_ACTIVE — process exit code when still running
public const STILL_ACTIVE: UInt32 = 259;

