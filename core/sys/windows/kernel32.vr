// =============================================================================
// WindowsThread Creation Flags
// =============================================================================

public const CREATE_SUSPENDED: UInt32 = 0x00000004;
public const STACK_SIZE_PARAM_IS_A_RESERVATION: UInt32 = 0x00010000;

// =============================================================================
// Safe Wrappers
// =============================================================================

/// Get standard output handle
public fn get_stdout() -> Handle {
    GetStdHandle(STD_OUTPUT_HANDLE)
}

/// Get standard input handle
public fn get_stdin() -> Handle {
    GetStdHandle(STD_INPUT_HANDLE)
}

/// Get standard error handle
public fn get_stderr() -> Handle {
    GetStdHandle(STD_ERROR_HANDLE)
}

/// Allocate memory with VirtualAlloc
public fn safe_alloc(size: Int, protect: UInt32) -> Maybe<&unsafe Byte> {
    let ptr = VirtualAlloc(
        0 as &unsafe Byte,
        size,
        super.ntdll.MEM_COMMIT | super.ntdll.MEM_RESERVE,
        protect,
    );
    if ptr as Int == 0 {
        None
    } else {
        Some(ptr)
    }
}

/// Free memory with VirtualFree
public fn safe_free(ptr: &unsafe Byte) -> Int32 {
    VirtualFree(ptr, 0, super.ntdll.MEM_RELEASE)
}

/// Decommit memory (release physical pages but keep virtual address reservation)
/// Equivalent to MADV_DONTNEED on Unix - decreases RSS immediately
/// Note: Memory must be recommitted before use
public fn mem_decommit(addr: &unsafe Byte, size: Int) -> Int32 {
    VirtualFree(addr, size, super.ntdll.MEM_DECOMMIT)
}

/// Reset memory (mark pages as not needed, may be discarded)
/// Equivalent to MADV_FREE on Unix - lazy, doesn't decrease RSS immediately
/// Note: Memory remains committed and accessible, but may be zeroed
public fn mem_reset(addr: &unsafe Byte, size: Int) -> Int32 {
    let result = VirtualAlloc(addr, size, super.ntdll.MEM_RESET, super.ntdll.PAGE_READWRITE);
    (result as Int) != 0
}

/// Recommit previously decommitted memory
/// Required after mem_decommit before memory can be used again
public fn mem_recommit(addr: &unsafe Byte, size: Int) -> Int32 {
    let result = VirtualAlloc(addr, size, super.ntdll.MEM_COMMIT, super.ntdll.PAGE_READWRITE);
    (result as Int) != 0
}

/// Close handle safely
public fn safe_close(handle: Handle) -> Int32 {
    if handle.is_valid() {
        CloseHandle(handle)
    } else {
        true
    }
}

