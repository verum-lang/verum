module sys.windows.kernel32;

// =============================================================================
// sys/windows/kernel32.vr - Windows API (kernel32.dll) FFI
// =============================================================================
// Layer: 0 (Core)
// Dependencies: sys/windows/ntstatus, sys/windows/ntdll
// Platform: Windows (x86_64)
// =============================================================================
//
// This module provides access to Windows API functions from kernel32.dll.
// These are higher-level APIs built on top of ntdll.dll.
//
// IMPORTANT: Uses IAT imports (@extern) for stable, supported API access.
//
// Spec: docs/architecture/new-arch-spec.md Section 5.4
// =============================================================================

mount super.ntstatus.NtStatus;
mount super.ntdll.{Handle, LargeInteger, IoStatusBlock};

// Re-export memory protection and allocation constants from ntdll for convenience
// Tests and user code commonly import these from kernel32 (the higher-level API layer)
public const MEM_COMMIT: UInt32 = 0x00001000;
public const MEM_RESERVE: UInt32 = 0x00002000;
public const MEM_DECOMMIT: UInt32 = 0x00004000;
public const MEM_RELEASE: UInt32 = 0x00008000;
public const MEM_RESET: UInt32 = 0x00080000;

public const PAGE_NOACCESS: UInt32 = 0x01;
public const PAGE_READONLY: UInt32 = 0x02;
public const PAGE_READWRITE: UInt32 = 0x04;
public const PAGE_WRITECOPY: UInt32 = 0x08;
public const PAGE_EXECUTE: UInt32 = 0x10;
public const PAGE_EXECUTE_READ: UInt32 = 0x20;
public const PAGE_EXECUTE_READWRITE: UInt32 = 0x40;
public const PAGE_EXECUTE_WRITECOPY: UInt32 = 0x80;
public const PAGE_GUARD: UInt32 = 0x100;

/// Sentinel value for invalid handles (as raw integer)
public const INVALID_HANDLE_VALUE: UInt64 = 0xFFFFFFFFFFFFFFFF;

