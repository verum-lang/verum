/// Create or open a file
@extern("kernel32.dll")
public fn CreateFileW(
    file_name: &UInt16,
    desired_access: UInt32,
    share_mode: UInt32,
    security_attributes: &SecurityAttributes,
    creation_disposition: UInt32,
    flags_and_attributes: UInt32,
    template_file: Handle,
) -> Handle;

// Win32 BOOL is `typedef int BOOL;` (Int32). Verum's `Bool` lowers to
// LLVM `i1`; an i1 truncation of i32 BOOL takes bit 0 only — correct
// for canonical 0/1 BOOL values but silent-failure for non-canonical
// even-non-zero returns (e.g., 2 → bit 0 = 0 → Verum false, BUG).
// Migrating to `Int32` at the extern boundary, with caller-side
// `result != 0` check, makes the BOOL → bool conversion ABI-correct.
// T0.4.5 closure — every Win32 BOOL parameter / return type in this
// file is now `Int32`; caller sites in core/sys/common.vr +
// core/term/raw/wincon.vr migrated from `if !ok` to `if ok == 0`.

/// Read from a file. C: `BOOL ReadFile(HANDLE, LPVOID, DWORD, LPDWORD,
/// LPOVERLAPPED);` — BOOL is `int`; non-zero return means success.
@extern("kernel32.dll")
public fn ReadFile(
    file: Handle,
    buffer: &unsafe mut Byte,
    number_of_bytes_to_read: UInt32,
    number_of_bytes_read: &mut UInt32,
    overlapped: &mut Overlapped,
) -> Int32;

/// Write to a file. C: `BOOL WriteFile(HANDLE, LPCVOID, DWORD, LPDWORD,
/// LPOVERLAPPED);` — same BOOL convention as `ReadFile`.
@extern("kernel32.dll")
public fn WriteFile(
    file: Handle,
    buffer: &unsafe Byte,
    number_of_bytes_to_write: UInt32,
    number_of_bytes_written: &mut UInt32,
    overlapped: &mut Overlapped,
) -> Int32;

/// Get overlapped result
@extern("kernel32.dll")
public fn GetOverlappedResult(
    file: Handle,
    overlapped: &Overlapped,
    number_of_bytes_transferred: &mut UInt32,
    wait: Int32,
) -> Int32;

/// Get overlapped result ex
@extern("kernel32.dll")
public fn GetOverlappedResultEx(
    file: Handle,
    overlapped: &Overlapped,
    number_of_bytes_transferred: &mut UInt32,
    milliseconds: UInt32,
    alertable: Int32,
) -> Int32;

/// Cancel I/O operations
@extern("kernel32.dll")
public fn CancelIo(file: Handle) -> Int32;

/// Cancel I/O operations ex
@extern("kernel32.dll")
public fn CancelIoEx(file: Handle, overlapped: &Overlapped) -> Int32;

/// Set file pointer ex
@extern("kernel32.dll")
public fn SetFilePointerEx(
    file: Handle,
    distance_to_move: LargeInteger,
    new_file_pointer: &mut LargeInteger,
    move_method: UInt32,
) -> Int32;

/// File seek origins
public const FILE_BEGIN: UInt32 = 0;
public const FILE_CURRENT: UInt32 = 1;
public const FILE_END: UInt32 = 2;

/// Get file size
@extern("kernel32.dll")
public fn GetFileSizeEx(
    file: Handle,
