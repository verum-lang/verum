// =============================================================================
// Environment Variables
// =============================================================================

/// Set an environment variable (ANSI version).
///
/// If value is null, the variable is deleted.
/// Returns true on success.
@extern("kernel32.dll")
public fn SetEnvironmentVariableA(
    name: &unsafe Byte,
    value: &unsafe Byte,
) -> Int32;

/// Get an environment variable (ANSI version).
///
/// Returns the number of characters written (excluding null),
/// or 0 on failure. If the buffer is too small, returns the
/// required size including the null terminator.
@extern("kernel32.dll")
public fn GetEnvironmentVariableA(
    name: &unsafe Byte,
    buffer: &unsafe Byte,
    size: UInt32,
) -> UInt32;
