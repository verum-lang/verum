// Console Mode Constants
// =============================================================================

/// Console input mode flags
public const ENABLE_PROCESSED_INPUT: UInt32 = 0x0001;
public const ENABLE_LINE_INPUT: UInt32 = 0x0002;
public const ENABLE_ECHO_INPUT: UInt32 = 0x0004;
public const ENABLE_WINDOW_INPUT: UInt32 = 0x0008;
public const ENABLE_MOUSE_INPUT: UInt32 = 0x0010;
public const ENABLE_INSERT_MODE: UInt32 = 0x0020;
public const ENABLE_QUICK_EDIT_MODE: UInt32 = 0x0040;
public const ENABLE_EXTENDED_FLAGS: UInt32 = 0x0080;
public const ENABLE_AUTO_POSITION: UInt32 = 0x0100;
public const ENABLE_VIRTUAL_TERMINAL_INPUT: UInt32 = 0x0200;

/// Console output mode flags
public const ENABLE_PROCESSED_OUTPUT: UInt32 = 0x0001;
public const ENABLE_WRAP_AT_EOL_OUTPUT: UInt32 = 0x0002;
public const ENABLE_VIRTUAL_TERMINAL_PROCESSING: UInt32 = 0x0004;
public const DISABLE_NEWLINE_AUTO_RETURN: UInt32 = 0x0008;
public const ENABLE_LVB_GRID_WORLDWIDE: UInt32 = 0x0010;

// =============================================================================
// Console Coordinate and Info Types
// =============================================================================

/// Console coordinate
public type Coord is {
    x: Int16,
    y: Int16,
};

/// Console small rect
public type SmallRect is {
    left: Int16,
    top: Int16,
    right: Int16,
    bottom: Int16,
};

/// Console screen buffer info
public type ConsoleScreenBufferInfo is {
    size: Coord,
    cursor_position: Coord,
    attributes: UInt16,
    window: SmallRect,
    maximum_window_size: Coord,
};

/// Console input record event type constants
public const KEY_EVENT: UInt16 = 0x0001;
public const MOUSE_EVENT: UInt16 = 0x0002;
public const WINDOW_BUFFER_SIZE_EVENT: UInt16 = 0x0004;
public const FOCUS_EVENT: UInt16 = 0x0008;
public const MENU_EVENT: UInt16 = 0x0010;

