// =============================================================================
// Time Re-exports
// =============================================================================

public mount time.{
    // Types
    Duration,
    Instant,
    Stopwatch,
    PerfCounter,
    DeadlineTimer,

    // Constants
    NANOS_PER_SEC,
    NANOS_PER_MILLI,
    NANOS_PER_MICRO,

    // Functions
    monotonic_nanos,
    monotonic_micros,
    monotonic_millis,
    sleep,
    sleep_ms,
    sleep_us,
    get_perf_freq,
    perf_counter_to_nanos,
};

// =============================================================================
// Winsock2 Re-exports
// =============================================================================

public mount winsock2.{
    // Socket operations (POSIX-compatible names)
    socket, connect, bind, listen, accept, accept4,
    send, recv, sendto, recvfrom,
    shutdown, close, read, write,
    getsockname, getpeername, fcntl,

    // Socket options
    setsockopt_int, getsockopt_error,
    set_nonblocking, set_reuseaddr, set_reuseport,
    set_tcp_nodelay, set_keepalive, set_broadcast,
    set_send_buffer_size, set_recv_buffer_size,
    set_socket_timeout,

    // Multicast
    join_multicast_v4, leave_multicast_v4,
    set_multicast_ttl_v4, set_multicast_loop_v4,

    // Peek / non-blocking
    peek, recv_nonblock, send_nonblock,

    // Types
    SockaddrIn, SockaddrIn6,

    // Constants
    AF_INET, AF_INET6,
    SOCK_STREAM, SOCK_DGRAM, SOCK_NONBLOCK, SOCK_CLOEXEC,
    IPPROTO_TCP, IPPROTO_UDP,
    SOL_SOCKET, SOL_TCP, SO_ERROR,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
    MSG_PEEK, MSG_DONTWAIT,
    SOCKET_ERROR, INVALID_SOCKET,
};
