module sys.mmio;

/// Verum Standard Library: Memory-Mapped I/O
///

/// This module provides type-safe memory-mapped I/O (MMIO) abstractions for
/// systems programming. Unlike C's simple `volatile` or Rust's external crates,
/// Verum MMIO provides:
/// - Type-safe register access with compile-time verification
/// - Access mode tracking (ReadOnly, WriteOnly, ReadWrite, etc.)
/// - Memory barrier integration for hardware protocols
/// - Zero-cost abstractions (all operations inline)
///

/// # Core Concepts
///

/// ## Volatile Pointer Type
/// The `*volatile T` pointer type is used for MMIO addresses. Unlike regular
/// pointers, volatile pointers:
/// - Prevent load/store elimination by the optimizer
/// - Prevent reordering with respect to other volatile operations
/// - Compile to single memory access instructions
///

/// ## Access Modes
/// Hardware registers often have specific access requirements:
/// - ReadOnly: Can only be read (status registers)
/// - WriteOnly: Can only be written (command registers)
/// - ReadWrite: Can be read and written (configuration registers)
/// - WriteOneToClear: Write 1 to clear bits (interrupt status)
/// - WriteOneToSet: Write 1 to set bits (interrupt enable)
///

/// # Examples
///

/// ```verum
/// // Define a peripheral register block
/// type UartRegisters is RegisterBlock<0x4001_0000> {
///  data: MmioRegister<UInt8, ReadWrite>,
///  status: MmioRegister<UInt8, ReadOnly>,
///  control: MmioRegister<UInt8, ReadWrite>,
/// };
///

/// // Access registers
/// let uart = UartRegisters.instance();
/// let status = uart.status.read();
/// uart.data.write(0x55);
/// ```
///

/// Implementation Reference: docs/architecture/low-level-features.md Section 3

// =============================================================================
// ACCESS MODE TYPES
// =============================================================================

/// MmioRegister access mode - determines allowed operations.
///

/// Access modes are phantom types (unit types) used as compile-time
/// type parameters to enforce correct usage patterns at the type level.
/// Each mode is a distinct type, enabling the type system to select
/// the correct implement block for each MmioRegister specialization.

/// Can only read (e.g., status registers).
public type ReadOnly is ();

/// Can only write (e.g., command registers).
public type WriteOnly is ();

/// Can read and write (e.g., config registers).
public type ReadWrite is ();

/// Write clears on read (rare).
public type ReadWriteOnce is ();

/// Write 1 to clear bits (e.g., interrupt status).
public type WriteOneToClear is ();

/// Write 1 to set bits (e.g., interrupt enable).
public type WriteOneToSet is ();

/// Union of all access mode types (for documentation/constraint purposes).
public type AccessMode is ReadOnly | WriteOnly | ReadWrite | ReadWriteOnce | WriteOneToClear | WriteOneToSet;

// =============================================================================
// VOLATILE INTRINSICS
// =============================================================================

/// Read from volatile memory location.
///

/// MMIO volatile load/store primitives — centralised in
/// `core/intrinsics/lowlevel/mmio.vr` (#66 Phase 1.6).
public mount core.intrinsics.lowlevel.mmio.{
    volatile_load,
    volatile_store,
    volatile_load_acquire,
    volatile_store_release,
};

// =============================================================================
// MEMORY BARRIERS
// =============================================================================

/// Memory barrier types for explicit ordering control.
public type BarrierKind is
    | Compiler    // Prevent compiler reordering only
    | Acquire     // Load barrier (loads before this cannot move after)
    | Release     // Store barrier (stores after this cannot move before)
    | AcqRel      // Both acquire and release
    | SeqCst;     // Full sequential consistency

/// Insert a memory barrier.
///

/// Memory barrier primitives — centralised in
/// `core/intrinsics/lowlevel/mmio.vr` (#66 Phase 1.6).
public mount core.intrinsics.lowlevel.mmio.{barrier, dsb, isb};

/// Compiler-only barrier (prevents optimization across this point).
@inline(always)
public fn compiler_barrier() {
    barrier(BarrierKind.Compiler);
}

/// Data memory barrier (ARM terminology).
@inline(always)
public fn dmb() {
    barrier(BarrierKind.AcqRel);
}

// =============================================================================
// REGISTER TYPE
// =============================================================================

/// Type-safe register wrapper.
///

/// Wraps a volatile pointer with access mode enforcement. The MODE
/// parameter is a compile-time (meta) type that determines which
/// operations are available.
///

/// # Type Parameters
/// - `T`: The data type of the register (must be Copy)
/// - `MODE`: Access mode (ReadOnly, WriteOnly, ReadWrite, etc.)
@repr(transparent)
public type MmioRegister<T: Copy, MODE> is {
    addr: *volatile mut T
};

/// Create a register at a fixed address.
///

/// This is a compile-time operation that creates a register wrapper
/// for a known hardware address.
implement<T: Copy, MODE> MmioRegister<T, MODE> {
    /// Create register at compile-time known address.
    @const
    public fn at(addr: USize) -> MmioRegister<T, MODE> {
        MmioRegister { addr: addr as *volatile mut T }
    }

    /// Get the raw address of this register.
    @inline(always)
    public fn address(&self) -> USize {
        self.addr as USize
    }
}

// =============================================================================
// READ OPERATIONS (for readable modes)
// =============================================================================

/// Read operations for ReadOnly registers.
implement<T: Copy> MmioRegister<T, ReadOnly> {
    /// Read the register value.
    @inline(always)
    public fn read(&self) -> T {
        volatile_load(self.addr as *volatile T)
    }
}

/// Read operations for ReadWrite registers.
implement<T: Copy> MmioRegister<T, ReadWrite> {
    /// Read the register value.
    @inline(always)
    public fn read(&self) -> T {
        volatile_load(self.addr as *volatile T)
    }
}

/// Read operations for WriteOneToClear registers.
implement<T: Copy> MmioRegister<T, WriteOneToClear> {
    /// Read the register value.
    @inline(always)
    public fn read(&self) -> T {
        volatile_load(self.addr as *volatile T)
    }
}

/// Read operations for WriteOneToSet registers.
implement<T: Copy> MmioRegister<T, WriteOneToSet> {
    /// Read the register value.
    @inline(always)
    public fn read(&self) -> T {
        volatile_load(self.addr as *volatile T)
    }
}

// =============================================================================
// WRITE OPERATIONS (for writable modes)
// =============================================================================

/// Write operations for WriteOnly registers.
implement<T: Copy> MmioRegister<T, WriteOnly> {
    /// Write a value to the register.
    @inline(always)
    public fn write(&self, value: T) {
        volatile_store(self.addr, value);
    }
}

/// Write operations for ReadWrite registers.
implement<T: Copy> MmioRegister<T, ReadWrite> {
    /// Write a value to the register.
    @inline(always)
    public fn write(&self, value: T) {
        volatile_store(self.addr, value);
    }

    /// Modify the register using a function.
    ///

    /// Reads the current value, applies the function, and writes back.
    /// NOT atomic - use with critical section if needed.
    ///

    /// Use `fn(T) -> T` as the parameter type rather than `F: Fn(T) -> T`
    /// — the type checker doesn't yet resolve closure-protocol bounds at the
    /// method-lookup stage, which previously hid this method behind a
    /// "no method named `modify`" diagnostic for plain `r.modify(|v| ...)`.
    @inline(always)
    public fn modify(&self, f: fn(T) -> T) {
        let value = volatile_load(self.addr as *volatile T);
        volatile_store(self.addr, f(value));
    }
}

// =============================================================================
// BIT MANIPULATION (for integer register types)
// =============================================================================

/// Bit manipulation for ReadWrite UInt32 registers.
implement MmioRegister<UInt32, ReadWrite> {
    /// Set bits using a mask (read-modify-write).
    @inline(always)
    public fn set_bits(&self, mask: UInt32) {
        let value = volatile_load(self.addr as *volatile UInt32);
        volatile_store(self.addr, value | mask);
    }

    /// Clear bits using a mask (read-modify-write).
    @inline(always)
    public fn clear_bits(&self, mask: UInt32) {
        let value = volatile_load(self.addr as *volatile UInt32);
        volatile_store(self.addr, value & ~mask);
    }

    /// Toggle bits using a mask (read-modify-write).
    @inline(always)
    public fn toggle_bits(&self, mask: UInt32) {
        let value = volatile_load(self.addr as *volatile UInt32);
        volatile_store(self.addr, value ^ mask);
    }

    /// Check if any bits in mask are set.
    @inline(always)
    public fn any_set(&self, mask: UInt32) -> Bool {
        (volatile_load(self.addr as *volatile UInt32) & mask) != 0
    }

    /// Check if all bits in mask are set.
    @inline(always)
    public fn all_set(&self, mask: UInt32) -> Bool {
        (volatile_load(self.addr as *volatile UInt32) & mask) == mask
    }
}

/// Write-one-to-clear operations (e.g., interrupt status).
implement MmioRegister<UInt32, WriteOneToClear> {
    /// Clear specific bits by writing 1s.
    @inline(always)
    public fn clear(&self, bits: UInt32) {
        volatile_store(self.addr, bits);
    }

    /// Clear all pending bits.
    @inline(always)
    public fn clear_all(&self) {
        volatile_store(self.addr, 0xFFFF_FFFF);
    }
}

/// Write-one-to-set operations (e.g., interrupt enable).
implement MmioRegister<UInt32, WriteOneToSet> {
    /// Set specific bits by writing 1s.
    @inline(always)
    public fn set(&self, bits: UInt32) {
        volatile_store(self.addr, bits);
    }
}

// =============================================================================
// REGISTER BLOCK
// =============================================================================

/// Protocol for register blocks (peripheral register structures).
///

/// A register block is a group of related registers at contiguous
/// addresses, typically representing a hardware peripheral.
public type RegisterBlock is protocol {
    /// Base address of this register block.
    const BASE_ADDRESS: USize;

    /// Get the singleton instance at the base address.
    fn instance() -> &'static Self;
};

/// Macro-like attribute for defining register blocks.
///

/// ```verum
/// @register_block(0x4001_0000)
/// type UartRegisters is {
///  @offset(0x00) data: MmioRegister<UInt8, ReadWrite>,
///  @offset(0x04) status: MmioRegister<UInt8, ReadOnly>,
///  @offset(0x08) control: MmioRegister<UInt8, ReadWrite>,
/// };
/// ```
///

/// The compiler generates:
/// - Correct field offsets matching hardware layout
/// - Singleton accessor at BASE_ADDRESS
/// - Debug printing with register names

// =============================================================================
// MEMORY REGION TYPES
// =============================================================================

/// Memory region descriptor for linker-defined sections.
public type MemoryRegion is {
    start: *const (),
    size: USize,
    flags: MemoryFlags,
};

/// Memory region flags (bitfield).
///

/// Usage: `MemoryFlags.READ | MemoryFlags.WRITE`
public type MemoryFlags is (UInt32);

implement MemoryFlags {
    /// Read permission
    public const READ: MemoryFlags  = MemoryFlags(0b0001);
    /// Write permission
    public const WRITE: MemoryFlags = MemoryFlags(0b0010);
    /// Execute permission
    public const EXEC: MemoryFlags  = MemoryFlags(0b0100);
    /// DMA access permission
    public const DMA: MemoryFlags   = MemoryFlags(0b1000);
}

implement MemoryRegion {
    /// Check if an address is within this region.
    @inline(always)
    public fn contains(&self, addr: USize) -> Bool {
        let start = self.start as USize;
        addr >= start && addr < start + self.size
    }

    /// Get end address (exclusive).
    @inline(always)
    public fn end(&self) -> USize {
        self.start as USize + self.size
    }
}

// =============================================================================
// VERIFICATION SUPPORT
// =============================================================================

/// Ghost state for formal verification of register protocols.
///

/// These types are erased at runtime but enable SMT verification
/// of correct register access sequences.

/// Verified register with ghost state tracking.
///

/// Use @verify(formal) to enable SMT verification of register protocols.
@verify(formal)
public type VerifiedRegister<T: Copy, MODE> is {
    reg: MmioRegister<T, MODE>,

    /// Ghost state: last value written (for WriteOnly verification)
    @ghost last_write: Maybe<T>,

    /// Ghost state: write count (for sequencing verification)
    @ghost write_count: USize,
};

implement<T: Copy> VerifiedRegister<T, WriteOnly> {
    /// Verified write - proves no read occurred.
    @ensures(self.write_count == old(self.write_count) + 1)
    @ensures(self.last_write == Some(value))
    public fn write(&mut self, value: T) {
        self.reg.write(value);
    }
}

// =============================================================================
// LINKER SYMBOL ACCESS
// =============================================================================

/// Access linker-defined symbols for memory layout.
///

/// ```verum
/// // Declare linker symbols
/// @link_symbol
/// extern {
///  static __text_start: USize;
///  static __text_end: USize;
///  static __data_start: USize;
///  static __data_end: USize;
///  static __bss_start: USize;
///  static __bss_end: USize;
/// }
///

/// // Use in code
/// fn text_region() -> MemoryRegion {
///  MemoryRegion {
///  start: &__text_start as *const _,
///  size: &__text_end - &__text_start,
///  flags: MemoryFlags.READ | MemoryFlags.EXEC,
///  }
/// }
/// ```
