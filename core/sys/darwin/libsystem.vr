// fcntl commands
public const F_DUPFD: Int = 0;
public const F_GETFD: Int = 1;
public const F_SETFD: Int = 2;
public const F_GETFL: Int = 3;
public const F_SETFL: Int = 4;
public const F_GETOWN: Int = 5;
public const F_SETOWN: Int = 6;
public const F_GETLK: Int = 7;
public const F_SETLK: Int = 8;
public const F_SETLKW: Int = 9;
/// `fcntl(fd, F_FULLFSYNC, 0)` — Darwin-specific command that forces the
/// disk to flush its write cache to persistent media. A plain `fsync`
/// on Darwin only flushes the kernel's dirty-page list to the disk,
/// which is insufficient for crash-safety on consumer-grade SSDs where
/// the drive itself buffers writes. Required by the SQLite VFS
/// (sqlite-native.md Gap 2) and by any workload that cares about
/// write-through semantics. Has no Linux equivalent (Linux `fsync`
/// already flushes the disk cache on modern kernels).
public const F_FULLFSYNC: Int = 51;
public const F_SETNOSIGPIPE: Int = 73;
public const F_GETNOSIGPIPE: Int = 74;

// FD flags
public const FD_CLOEXEC: Int = 1;

// VM allocation flags
public const VM_FLAGS_FIXED: Int = 0x0000;
public const VM_FLAGS_ANYWHERE: Int = 0x0001;
public const VM_FLAGS_PURGABLE: Int = 0x0002;
public const VM_FLAGS_RANDOM_ADDR: Int = 0x0008;

// =============================================================================
// Safe Wrapper Functions
// =============================================================================

/// Get the last error number
public fn errno() -> Int {
    // libc errno is C `int` (32-bit) but Verum's deref reads 64 bits.
    // The four bytes adjacent to the thread-local errno slot are
    // unrelated TLS data, which leak into the upper half. Mask to
    // 32 bits and sign-extend so callers see a clean small integer.
    // See #108 — generic AOT extern-call sign-extension.
    let raw = unsafe { *__error() };
    let lo32 = raw & 0xFFFFFFFF;
    if (lo32 & 0x80000000) != 0 {
        lo32 - 0x100000000
    } else {
        lo32
    }
}

/// Set the error number
public fn set_errno(err: Int) {
    unsafe { *__error() = err; }
}

/// Read from file descriptor (safe wrapper) - takes a mutable slice
public fn safe_read(fd: FileDesc, buf: &mut [Byte]) -> Result<Int, OSError> {
    let result = unsafe { read(fd.0, buf.as_mut_ptr() as &unsafe Byte, buf.len()) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Read from file descriptor (raw pointer API)
public fn safe_read_raw(fd: FileDesc, buf: &unsafe Byte, count: Int) -> Result<Int, OSError> {
    let result = unsafe { read(fd.0, buf, count) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Write to file descriptor (safe wrapper) - takes a slice
public fn safe_write(fd: FileDesc, buf: &[Byte]) -> Result<Int, OSError> {
    let result = unsafe { write(fd.0, buf.as_ptr(), buf.len()) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Write to file descriptor (low-level) - takes pointer and count
public fn safe_write_raw(fd: FileDesc, buf: &Byte, count: Int) -> Result<Int, OSError> {
    let result = unsafe { write(fd.0, buf, count) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Read at explicit `offset` without moving the file cursor (POSIX `pread`).
/// Atomic with respect to concurrent `pread`/`pwrite` on the same `fd`
/// (unlike `lseek`+`read`). Safe wrapper around the libSystem `pread`
/// FFI binding above. Required by the SQLite VFS layer
/// (sqlite-native.md Gap 3) and any other code that needs explicit-offset
/// reads. Partial reads at EOF return `Ok(n)` where `n < buf.len()`.
public fn safe_pread(fd: FileDesc, buf: &mut [Byte], offset: Int) -> Result<Int, OSError> {
    let result = unsafe { pread(fd.0, buf.as_mut_ptr() as &unsafe Byte, buf.len(), offset) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Write at explicit `offset` without moving the file cursor (POSIX `pwrite`).
/// See `safe_pread` for the atomicity contract. Partial writes return
/// `Ok(n)` with `n < buf.len()` — callers must loop until the full
/// buffer lands if they need all-or-nothing semantics.
public fn safe_pwrite(fd: FileDesc, buf: &[Byte], offset: Int) -> Result<Int, OSError> {
    let result = unsafe { pwrite(fd.0, buf.as_ptr(), buf.len(), offset) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Close file descriptor (safe wrapper)
public fn safe_close(fd: FileDesc) -> Result<(), OSError> {
    let result = unsafe { close(fd.0) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Memory map (safe wrapper) - returns typed pointer consistent with Linux
@intrinsic("sys_mmap")
@vbc_direct_lowering
public fn safe_mmap(
    addr: Int,
    len: Int,
    prot: MemProt,
    flags: MapFlags,
    fd: FileDesc,
    offset: Int,
) -> Result<&unsafe Byte, OSError> {
    let raw_result = unsafe { mmap_ffi(addr, len, prot.to_unix_flags(), flags.to_unix_flags(), fd.0, offset) };
    // MAP_FAILED is (void *)-1 which is -1 as Int on 64-bit
    if raw_result == -1 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        let ptr: &unsafe Byte = transmute(raw_result);
        Ok(ptr)
    }
}

/// Memory map (raw integer API) - returns raw address as Int
public fn safe_mmap_raw(
    addr: Int,
    len: Int,
    prot: MemProt,
    flags: MapFlags,
    fd: FileDesc,
    offset: Int,
) -> Result<Int, OSError> {
    let result = unsafe { mmap_ffi(addr, len, prot.to_unix_flags(), flags.to_unix_flags(), fd.0, offset) };
    if result == -1 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Memory unmap (safe wrapper)
@intrinsic("sys_munmap")
@vbc_direct_lowering
public fn safe_munmap(addr: Int, len: Int) -> Result<(), OSError> {
    let result = unsafe { munmap(addr, len) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Memory advise (safe wrapper)
/// Advise kernel about memory usage patterns
@intrinsic("sys_madvise")
@vbc_direct_lowering
public fn safe_madvise(addr: &unsafe Byte, len: Int, advice: Int) -> Result<(), OSError> {
    let result = unsafe { madvise(addr as Int, len, advice) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Advise kernel that memory will be needed soon (prefetch)
public fn madvise_willneed(addr: &unsafe Byte, len: Int) -> Result<(), OSError> {
    safe_madvise(addr, len, MADV_WILLNEED)
}

/// Advise kernel that memory will not be needed (may be freed/zeroed)
public fn madvise_dontneed(addr: &unsafe Byte, len: Int) -> Result<(), OSError> {
    safe_madvise(addr, len, MADV_DONTNEED)
}

/// Advise kernel that memory may be freed (more lazy than DONTNEED)
public fn madvise_free(addr: &unsafe Byte, len: Int) -> Result<(), OSError> {
    safe_madvise(addr, len, MADV_FREE)
}

/// Advise kernel that memory is reusable (can be reclaimed without swap)
public fn madvise_free_reusable(addr: &unsafe Byte, len: Int) -> Result<(), OSError> {
    safe_madvise(addr, len, MADV_FREE_REUSABLE)
}

/// Advise kernel that reusable memory is now in use again
public fn madvise_free_reuse(addr: &unsafe Byte, len: Int) -> Result<(), OSError> {
    safe_madvise(addr, len, MADV_FREE_REUSE)
}

/// Get process ID (always succeeds)
@intrinsic("sys_getpid")
@vbc_direct_lowering
public fn safe_getpid() -> Int {
    unsafe { getpid() }
}

/// Get thread ID
@intrinsic("sys_gettid")
@vbc_direct_lowering
public fn safe_gettid() -> UInt64 {
    let mut tid: UInt64 = 0;
    unsafe { pthread_threadid_np(PthreadT(0), &mut tid) };
    tid
}

/// Get entropy (cryptographic random bytes)
@intrinsic("sys_getentropy")
@vbc_direct_lowering
public fn safe_getentropy(buf: &unsafe Byte, len: Int) -> Result<(), OSError> {
    if len > 256 {
        return Err(OSError { code: 5, message: "getentropy: max 256 bytes" });
    }
    let result = unsafe { getentropy(buf, len) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Create kqueue (safe wrapper)
public fn safe_kqueue() -> Result<FileDesc, OSError> {
    let result = unsafe { kqueue() };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(FileDesc(result))
    }
}

/// Sleep for duration
public fn safe_nanosleep(seconds: Int, nanoseconds: Int) -> Result<(), OSError> {
    let req = DarwinTimespec { tv_sec: seconds, tv_nsec: nanoseconds };
    let mut rem = DarwinTimespec { tv_sec: 0, tv_nsec: 0 };
    let result = unsafe { nanosleep(&req, &mut rem) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Get monotonic time in nanoseconds (high performance)
public fn monotonic_nanos() -> UInt64 {
    static mut timebase_info: MachTimebaseInfo = MachTimebaseInfo { numer: 0, denom: 0 };
    static mut timebase_initialized: Bool = false;

    unsafe {
        if !timebase_initialized {
            mach_timebase_info(&mut timebase_info);
            timebase_initialized = true;
        }

        let ticks = mach_absolute_time();
        (ticks * timebase_info.numer as UInt64) / timebase_info.denom as UInt64
    }
}

/// Get monotonic time in microseconds (high performance)
public fn monotonic_micros() -> UInt64 {
    monotonic_nanos() / 1_000
}

/// Get monotonic time in milliseconds (high performance)
public fn monotonic_millis() -> UInt64 {
    monotonic_nanos() / 1_000_000
}

/// Get clock time
public fn safe_clock_gettime(clock_id: Int) -> Result<DarwinTimespec, OSError> {
    let mut ts = DarwinTimespec { tv_sec: 0, tv_nsec: 0 };
    let result = unsafe { clock_gettime(clock_id, &mut ts) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(ts)
    }
}

/// Open file (safe wrapper)
public fn safe_open(path: &[Byte], flags: Int, mode: Int) -> Result<FileDesc, OSError> {
    // Copy path and null-terminate
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe { open(path_buf.as_ptr() as &Byte, flags, mode) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(FileDesc(result))
    }
}

/// Seek file (safe wrapper)
public fn safe_lseek(fd: FileDesc, offset: Int, whence: Int) -> Result<Int, OSError> {
    let result = unsafe { lseek(fd.0, offset, whence) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Get file status (safe wrapper)
public fn safe_fstat(fd: FileDesc, stat_buf: &mut DarwinStat) -> Result<(), OSError> {
    let result = unsafe { fstat(fd.0, stat_buf as &unsafe DarwinStat) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Sync file to disk (safe wrapper)
/// Darwin `F_FULLFSYNC` wrapper — the only way to achieve true
/// write-through durability on macOS. On any other platform use the
/// cross-platform `core.sys.common.full_fsync` dispatcher instead of
/// calling this directly.
public fn safe_full_fsync(fd: FileDesc) -> Result<(), OSError> {
    let result = unsafe { fcntl(fd.0, F_FULLFSYNC, 0) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

public fn safe_fsync(fd: FileDesc) -> Result<(), OSError> {
    let result = unsafe { fsync(fd.0) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Truncate file (safe wrapper)
public fn safe_ftruncate(fd: FileDesc, length: Int) -> Result<(), OSError> {
    let result = unsafe { ftruncate(fd.0, length) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Duplicate file descriptor (safe wrapper)
public fn safe_dup(fd: FileDesc) -> Result<FileDesc, OSError> {
    let result = unsafe { dup(fd.0) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(FileDesc(result))
    }
}

