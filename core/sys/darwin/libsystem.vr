module sys.darwin.libsystem;
mount core.base.coercion.{IntCoercible};

// =============================================================================
// sys/darwin/libsystem.vr - macOS libSystem.B.dylib FFI bindings
// =============================================================================
// Layer: 0 (Core)
// Dependencies: sys/common
// Platform: macOS (x86_64, arm64)
// =============================================================================
//
// CRITICAL: macOS DOES NOT support stable syscalls.
// All system operations MUST go through libSystem.B.dylib.
//
// Apple explicitly states that syscall numbers are private implementation
// details and may change between OS versions without notice.
//
// This module provides FFI bindings to libSystem for stable system access.
//
// Spec: docs/architecture/new-arch-spec.md Section 5.4
// =============================================================================

mount super.super.common.{OSError, FileDesc, IOVec, MemProt, MapFlags};

// =============================================================================
// libSystem.B.dylib FFI Declarations
// =============================================================================

@ffi("libSystem.B.dylib")
extern {
    // =========================================================================
    // File I/O
    // =========================================================================

    /// Read from file descriptor
    public fn read(fd: Int, buf: &unsafe Byte, nbyte: Int) -> Int;

    /// Write to file descriptor
    public fn write(fd: Int, buf: &Byte, nbyte: Int) -> Int;

    /// Open file
    public fn open(path: &Byte, oflag: Int, mode: Int) -> Int;

    /// Close file descriptor
    public fn close(fd: Int) -> Int32;

    /// Read at offset (does not change file position)
    fn pread(fd: Int, buf: &unsafe Byte, nbyte: Int, offset: Int) -> Int;

    /// Write at offset (does not change file position)
    fn pwrite(fd: Int, buf: &Byte, nbyte: Int, offset: Int) -> Int;

    /// Reposition file offset
    fn lseek(fd: Int, offset: Int, whence: Int) -> Int;

    /// Duplicate file descriptor
    fn dup(fd: Int) -> Int;

    /// Duplicate file descriptor to specific number
    fn dup2(oldfd: Int, newfd: Int) -> Int;

    /// Create pipe (fds[0]=read end, fds[1]=write end)
    fn pipe(fds: &mut Int) -> Int;

    /// File control operations
    fn fcntl(fd: Int, cmd: Int, arg: Int) -> Int;

    /// Synchronize file to disk
    fn fsync(fd: Int) -> Int;

    /// Synchronize file data to disk
    fn fdatasync(fd: Int) -> Int;

    /// Truncate file to length
    fn ftruncate(fd: Int, length: Int) -> Int;

    /// Get file status
    fn fstat(fd: Int, buf: &unsafe DarwinStat) -> Int;

    /// Get file status (path)
    fn stat(path: &Byte, buf: &unsafe DarwinStat) -> Int;

    /// Get file status (symlink)
    fn lstat(path: &Byte, buf: &unsafe DarwinStat) -> Int;

    /// Scatter read
    fn readv(fd: Int, iov: &IOVec, iovcnt: Int) -> Int;

    /// Gather write
    fn writev(fd: Int, iov: &IOVec, iovcnt: Int) -> Int;

    // =========================================================================
    // Memory Management
    // =========================================================================

    /// Map memory
    @ffi_name("mmap")
    public fn mmap_ffi(addr: Int, len: Int, prot: Int, flags: Int, fd: Int, offset: Int) -> Int;

    /// Unmap memory
    public fn munmap(addr: Int, len: Int) -> Int;

    /// Change memory protection
    public fn mprotect(addr: Int, len: Int, prot: Int) -> Int;

    /// Memory advise
    public fn madvise(addr: Int, len: Int, advice: Int) -> Int;

    /// Lock memory
    fn mlock(addr: Int, len: Int) -> Int;

    /// Unlock memory
    fn munlock(addr: Int, len: Int) -> Int;

    /// Synchronize memory to storage
    fn msync(addr: Int, len: Int, flags: Int) -> Int;

    /// Get page size
    fn getpagesize() -> Int;

    // =========================================================================
    // Process Control
    // =========================================================================

    /// Get process ID
    fn getpid() -> Int;

    /// Get parent process ID
    fn getppid() -> Int;

    /// Get user ID
    fn getuid() -> Int;

    /// Get effective user ID
    fn geteuid() -> Int;

    /// Get group ID
    fn getgid() -> Int;

    /// Get effective group ID
    fn getegid() -> Int;

    /// Exit process
    fn exit(status: Int) -> !;

    /// Exit process (alternate)
    fn _exit(status: Int) -> !;

    /// Fork process
    fn fork() -> Int;

    /// Execute program (absolute path)
    fn execve(path: &Byte, argv: &(&Byte), envp: &(&Byte)) -> Int;

    /// Execute program (search PATH)
    fn execvp(file: &Byte, argv: &(&Byte)) -> Int;

    /// Wait for child process
    fn waitpid(pid: Int, status: &mut Int, options: Int) -> Int;

    /// Send signal
    fn kill(pid: Int, sig: Int) -> Int;

    // =========================================================================
    // kqueue - Event Notification
    // =========================================================================

    /// Create kqueue
    public fn kqueue() -> Int;

    /// Register/poll events
    public fn kevent(
        kq: Int,
        changelist: &KEvent,
        nchanges: Int,
        eventlist: &unsafe KEvent,
        nevents: Int,
        timeout: &DarwinTimespec,
    ) -> Int;

    /// kevent64 (extended)
    public fn kevent64(
        kq: Int,
        changelist: &KEvent64,
        nchanges: Int,
        eventlist: &unsafe KEvent64,
        nevents: Int,
        flags: USize,
        timeout: &DarwinTimespec,
    ) -> Int;

    // =========================================================================
    // pthread - Threading
    // =========================================================================

    /// Get current thread
    public fn pthread_self() -> PthreadT;

    /// Create thread
    public fn pthread_create(
        thread: &mut PthreadT,
        attr: &PthreadAttr,
        start_routine: fn(&unsafe Byte) -> &unsafe Byte,
        arg: &unsafe Byte,
    ) -> Int;

    /// Join thread
    public fn pthread_join(thread: PthreadT, value_ptr: &mut (&unsafe Byte)) -> Int;

    /// Detach thread
    public fn pthread_detach(thread: PthreadT) -> Int;

    /// Exit thread
    public fn pthread_exit(value_ptr: &unsafe Byte) -> !;

    /// Initialize mutex
    public fn pthread_mutex_init(mutex: &mut PthreadMutex, attr: &PthreadMutexAttr) -> Int;

    /// Destroy mutex
    public fn pthread_mutex_destroy(mutex: &mut PthreadMutex) -> Int;

    /// Lock mutex
    public fn pthread_mutex_lock(mutex: &mut PthreadMutex) -> Int;

    /// Try lock mutex
    public fn pthread_mutex_trylock(mutex: &mut PthreadMutex) -> Int;

    /// Unlock mutex
    public fn pthread_mutex_unlock(mutex: &mut PthreadMutex) -> Int;

    /// Initialize condition variable
    public fn pthread_cond_init(cond: &mut PthreadCond, attr: &PthreadCondAttr) -> Int;

    /// Destroy condition variable
    public fn pthread_cond_destroy(cond: &mut PthreadCond) -> Int;

    /// Wait on condition variable
    public fn pthread_cond_wait(cond: &mut PthreadCond, mutex: &mut PthreadMutex) -> Int;

    /// Timed wait on condition variable
    public fn pthread_cond_timedwait(
        cond: &mut PthreadCond,
        mutex: &mut PthreadMutex,
        abstime: &DarwinTimespec,
    ) -> Int;

    /// Signal condition variable
    public fn pthread_cond_signal(cond: &mut PthreadCond) -> Int;

    /// Broadcast condition variable
    public fn pthread_cond_broadcast(cond: &mut PthreadCond) -> Int;

    // =========================================================================
    // Low-level ulock (futex equivalent on macOS/XNU)
    // =========================================================================

    /// Wait on address if value matches (futex equivalent).
    /// operation: UL_COMPARE_AND_WAIT (1) | ULF_NO_ERRNO (0x01000000)
    /// addr: pointer to 32-bit word to compare
    /// value: expected value (compared as uint64_t, lower 32 bits used)
    /// timeout_us: timeout in microseconds (0 = infinite)
    /// Returns: 0 on success, negative errno on error (-ETIMEDOUT, -EFAULT, -EINTR)
    public fn __ulock_wait(operation: UInt32, addr: &unsafe Byte, value: UInt64, timeout_us: UInt32) -> Int;

    /// Wake threads waiting on address (futex wake equivalent).
    /// operation: UL_COMPARE_AND_WAIT (1) | ULF_WAKE_ALL (0x100) for all
    /// addr: pointer to word being waited on
    /// wake_value: not used for UL_COMPARE_AND_WAIT, pass 0
    /// Returns: 0 on success, negative errno on error
    public fn __ulock_wake(operation: UInt32, addr: &unsafe Byte, wake_value: UInt64) -> Int;

    /// TLS key create
    public fn pthread_key_create(key: &mut PthreadKey, destructor: fn(&unsafe Byte)) -> Int;

    /// TLS key delete
    public fn pthread_key_delete(key: PthreadKey) -> Int;

    /// TLS get specific
    public fn pthread_getspecific(key: PthreadKey) -> &unsafe Byte;

    /// TLS set specific
    public fn pthread_setspecific(key: PthreadKey, value: &unsafe Byte) -> Int;

    /// Get thread ID (macOS extension)
    public fn pthread_threadid_np(thread: PthreadT, thread_id: &mut UInt64) -> Int;

    // =========================================================================
    // Time
    // =========================================================================

    /// Get time of day
    public fn gettimeofday(tv: &mut DarwinTimeval, tz: &unsafe Byte) -> Int;

    /// Get clock time (POSIX)
    public fn clock_gettime(clk_id: Int, tp: &mut DarwinTimespec) -> Int;

    /// Sleep (nanoseconds)
    public fn nanosleep(rqtp: &DarwinTimespec, rmtp: &mut DarwinTimespec) -> Int;

    /// Get monotonic time (mach)
    public fn mach_absolute_time() -> UInt64;

    /// Get time base info (mach)
    public fn mach_timebase_info(info: &mut MachTimebaseInfo) -> Int;

    // =========================================================================
    // Sockets
    // =========================================================================

    /// Create socket. Returns C `int` (32-bit) — declared as `Int32`
    /// rather than `Int` so the AOT extern-call lowering picks the
    /// i32 return-type at the LLVM IR level. With `Int` (=i64) the
    /// AArch64 call site reads x0 as 64-bit and inherits whatever
    /// libSystem's epilogue left in the upper 32 bits — typically
    /// garbage that flips a small positive fd into a "negative" i64
    /// and trips the `< 0` error path. Tracked under #108.
    fn socket(domain: Int, socket_type: Int, protocol: Int) -> Int32;

    /// Bind socket
    fn bind(sockfd: Int, addr: &unsafe Byte, addrlen: Int) -> Int32;

    /// Listen on socket
    fn listen(sockfd: Int, backlog: Int) -> Int32;

    /// Accept connection
    fn accept(sockfd: Int, addr: &unsafe Byte, addrlen: &mut Int) -> Int32;

    /// Connect socket
    fn connect(sockfd: Int, addr: &unsafe Byte, addrlen: Int) -> Int32;

    /// Send data
    fn send(sockfd: Int, buf: &Byte, len: Int, flags: Int) -> Int;

    /// Receive data
    fn recv(sockfd: Int, buf: &unsafe Byte, len: Int, flags: Int) -> Int;

    /// Send to address
    fn sendto(
        sockfd: Int,
        buf: &Byte,
        len: Int,
        flags: Int,
        dest_addr: &unsafe Byte,
        addrlen: Int,
    ) -> Int;

    /// Receive from address
    @ffi_name("recvfrom")
    fn recvfrom_ffi(
        sockfd: Int,
        buf: &unsafe Byte,
        len: Int,
        flags: Int,
        src_addr: &unsafe Byte,
        addrlen: &mut Int,
    ) -> Int;

    /// Get socket option
    fn getsockopt(sockfd: Int, level: Int, optname: Int, optval: &unsafe Byte, optlen: &mut Int) -> Int32;

    /// Set socket option
    fn setsockopt(sockfd: Int, level: Int, optname: Int, optval: &Byte, optlen: Int) -> Int32;

    /// Shutdown socket
    fn shutdown(sockfd: Int, how: Int) -> Int32;

    /// Get socket name (local address)
    fn getsockname(sockfd: Int, addr: &unsafe Byte, addrlen: &mut Int) -> Int32;

    /// Get peer name (remote address)
    fn getpeername(sockfd: Int, addr: &unsafe Byte, addrlen: &mut Int) -> Int32;

    // =========================================================================
    // Directory Operations
    // =========================================================================

    /// Create directory
    fn mkdir(path: &Byte, mode: Int) -> Int;

    /// Remove directory
    fn rmdir(path: &Byte) -> Int;

    /// Change current directory
    fn chdir(path: &Byte) -> Int;

    /// Get current directory
    fn getcwd(buf: &unsafe Byte, size: Int) -> &Byte;

    /// Open directory
    public fn opendir(name: &Byte) -> &unsafe DIR;

    /// Read directory entry
    public fn readdir(dirp: &DIR) -> &Dirent;

    /// Close directory
    public fn closedir(dirp: &DIR) -> Int;

    // =========================================================================
    // Filesystem Operations
    // =========================================================================

    /// Remove a file
    fn unlink(path: &Byte) -> Int;

    /// Create a hard link
    fn link(src: &Byte, dst: &Byte) -> Int;

    /// Rename a file or directory
    @ffi_name("rename")
    fn rename_ffi(oldpath: &Byte, newpath: &Byte) -> Int;

    /// Create a symbolic link
    @ffi_name("symlink")
    fn symlink_ffi(src: &Byte, dst: &Byte) -> Int;

    /// Read a symbolic link
    fn readlink(path: &Byte, buf: &unsafe Byte, bufsize: Int) -> Int;

    /// Change file mode
    fn chmod(path: &Byte, mode: Int) -> Int;

    // =========================================================================
    // Environment Variables
    // =========================================================================

    /// Get environment variable (returns null if not set)
    fn getenv(name: &Byte) -> &Byte;

    /// Set environment variable (overwrite: 1 to replace existing, 0 to preserve)
    fn setenv(name: &Byte, value: &Byte, overwrite: Int) -> Int;

    /// Remove environment variable
    fn unsetenv(name: &Byte) -> Int;

    // =========================================================================
    // Command Line Arguments (macOS-specific)
    // =========================================================================

    /// Get pointer to argc (crt_externs.h)
    fn _NSGetArgc() -> &Int;

    /// Get pointer to argv (crt_externs.h)
    fn _NSGetArgv() -> &(&(&Byte));

    /// Get pointer to environ (crt_externs.h)
    fn _NSGetEnviron() -> &(&(&Byte));

    // =========================================================================
    // Signals
    // =========================================================================

    /// Set signal handler
    fn signal(signum: Int, handler: fn(Int)) -> fn(Int);

    /// Signal action
    fn sigaction(signum: Int, act: &Sigaction, oldact: &mut Sigaction) -> Int;

    /// Signal mask
    fn sigprocmask(how: Int, set: &Sigset, oldset: &mut Sigset) -> Int;

    // =========================================================================
    // Random
    // =========================================================================

    /// Get entropy (macOS 10.12+)
    fn getentropy(buffer: &unsafe Byte, length: Int) -> Int;

    /// arc4random (BSD)
    fn arc4random() -> UInt32;

    /// arc4random_buf (BSD)
    fn arc4random_buf(buf: &unsafe Byte, nbytes: Int);

    // =========================================================================
    // Error Handling
    // =========================================================================

    /// Get errno location
    fn __error() -> &mut Int;

    /// String error
    fn strerror(errnum: Int) -> &Byte;

    // =========================================================================
    // Dynamic Loading
    // =========================================================================

    /// Open dynamic library
    fn dlopen(filename: &Byte, flags: Int) -> &unsafe Byte;

    /// Get symbol
    fn dlsym(handle: &unsafe Byte, symbol: &Byte) -> &unsafe Byte;

    /// Close dynamic library
    fn dlclose(handle: &unsafe Byte) -> Int;

    /// Get error
    fn dlerror() -> &Byte;

    // =========================================================================
    // Mach Kernel Interface
    // =========================================================================

    /// Get Mach host port
    fn mach_host_self() -> MachPort;

    /// Get Mach task port
    fn mach_task_self() -> MachPort;

    /// Get Mach thread port
    fn mach_thread_self() -> MachPort;

    /// Allocate VM
    fn vm_allocate(
        target_task: MachPort,
        address: &mut Int,
        size: Int,
        flags: Int,
    ) -> Int;

    /// Deallocate VM
    fn vm_deallocate(target_task: MachPort, address: Int, size: Int) -> Int;

    /// Protect VM
    fn vm_protect(
        target_task: MachPort,
        address: Int,
        size: Int,
        set_maximum: Int,
        new_protection: Int,
    ) -> Int;
}

// =============================================================================
// Type Definitions
// =============================================================================

/// pthread_t type
public type PthreadT is (Int);

/// pthread_key_t type
public type PthreadKey is (Int);

/// pthread_attr_t (opaque)
public type PthreadAttr is {
    _opaque: [Int; 8],
};

/// pthread_mutex_t (opaque)
public type PthreadMutex is {
    _opaque: [Int; 8],
};

/// pthread_mutexattr_t (opaque)
public type PthreadMutexAttr is {
    _opaque: [Int; 2],
};

/// pthread_cond_t (opaque)
public type PthreadCond is {
    _opaque: [Int; 6],
};

/// pthread_condattr_t (opaque)
public type PthreadCondAttr is {
    _opaque: [Int; 2],
};

/// Mach port type
public type MachPort is (UInt32);

// IntCoercible: MachPort wraps UInt32 — coerce with Int in
// arithmetic / comparison contexts.
implement IntCoercible for MachPort {}

/// timespec structure
public type DarwinTimespec is {
    tv_sec: Int,
    tv_nsec: Int,
};

/// timeval structure
public type DarwinTimeval is {
    tv_sec: Int,
    tv_usec: Int,
};

/// mach_timebase_info structure
public type MachTimebaseInfo is {
    numer: UInt32,
    denom: UInt32,
};

/// kevent structure (32-bit ident)
public type KEvent is {
    ident: Int,
    filter: Int16,
    flags: UInt16,
    fflags: UInt32,
    data: Int,
    udata: &unsafe Byte,
};

/// kevent64 structure (64-bit ident)
public type KEvent64 is {
    ident: UInt64,
    filter: Int16,
    flags: UInt16,
    fflags: UInt32,
    data: Int64,
    udata: UInt64,
    ext: [UInt64; 2],
};

/// stat structure
public type DarwinStat is {
    st_dev: Int32,
    st_ino: UInt64,
    st_mode: UInt16,
    st_nlink: UInt16,
    st_uid: UInt32,
    st_gid: UInt32,
    st_rdev: Int32,
    st_atime: DarwinTimespec,
    st_mtime: DarwinTimespec,
    st_ctime: DarwinTimespec,
    st_birthtime: DarwinTimespec,
    st_size: Int64,
    st_blocks: Int64,
    st_blksize: Int32,
    st_flags: UInt32,
    st_gen: UInt32,
};

/// sockaddr (generic)
public type Sockaddr is {
    sa_len: UInt8,
    sa_family: UInt8,
    sa_data: [Byte; 14],
};

/// sockaddr_in (IPv4)
public type DarwinSockaddrIn is {
    sin_len: UInt8,
    sin_family: UInt8,
    sin_port: UInt16,
    sin_addr: UInt32,
    sin_zero: [Byte; 8],
};

/// sockaddr_in6 (IPv6)
public type DarwinSockaddrIn6 is {
    sin6_len: UInt8,
    sin6_family: UInt8,
    sin6_port: UInt16,
    sin6_flowinfo: UInt32,
    sin6_addr: [Byte; 16],
    sin6_scope_id: UInt32,
};

/// DIR opaque type
public type DIR is {
    _opaque: [Byte; 1],
};

/// dirent structure
public type Dirent is {
    d_ino: UInt64,
    d_seekoff: UInt64,
    d_reclen: UInt16,
    d_namlen: UInt16,
    d_type: UInt8,
    d_name: [Byte; 1024],
};

/// sigaction structure
public type Sigaction is {
    sa_handler: fn(Int),
    sa_mask: Sigset,
    sa_flags: Int,
};

/// sigset_t
public type Sigset is (UInt32);

// =============================================================================
// Constants
// =============================================================================

// Open flags
public const O_RDONLY: Int = 0x0000;
public const O_WRONLY: Int = 0x0001;
public const O_RDWR: Int = 0x0002;
public const O_NONBLOCK: Int = 0x0004;
public const O_APPEND: Int = 0x0008;
public const O_CREAT: Int = 0x0200;
public const O_TRUNC: Int = 0x0400;
public const O_EXCL: Int = 0x0800;
public const O_CLOEXEC: Int = 0x1000000;
public const O_DIRECTORY: Int = 0x100000;
public const O_SYMLINK: Int = 0x200000;

// Seek whence
public const SEEK_SET: Int = 0;
public const SEEK_CUR: Int = 1;
public const SEEK_END: Int = 2;

// Memory protection
public const PROT_NONE: Int = 0x00;
public const PROT_READ: Int = 0x01;
public const PROT_WRITE: Int = 0x02;
public const PROT_EXEC: Int = 0x04;

// Memory mapping flags
public const MAP_SHARED: Int = 0x0001;
public const MAP_PRIVATE: Int = 0x0002;
public const MAP_FIXED: Int = 0x0010;
public const MAP_ANON: Int = 0x1000;
public const MAP_ANONYMOUS: Int = 0x1000;
public const MAP_JIT: Int = 0x0800;
public const MAP_NOCACHE: Int = 0x0400;

// madvise advice
public const MADV_NORMAL: Int = 0;
public const MADV_RANDOM: Int = 1;
public const MADV_SEQUENTIAL: Int = 2;
public const MADV_WILLNEED: Int = 3;
public const MADV_DONTNEED: Int = 4;
public const MADV_FREE: Int = 5;
public const MADV_ZERO_WIRED_PAGES: Int = 6;
public const MADV_FREE_REUSABLE: Int = 7;
public const MADV_FREE_REUSE: Int = 8;
/// Linux compatibility stub - maps to MADV_NORMAL (no-op on macOS)
public const MADV_HUGEPAGE: Int = 0;

// msync flags
public const MS_ASYNC: Int = 0x0001;
public const MS_INVALIDATE: Int = 0x0002;
public const MS_SYNC: Int = 0x0010;

// kqueue filters
public const EVFILT_READ: Int16 = -1;
public const EVFILT_WRITE: Int16 = -2;
public const EVFILT_AIO: Int16 = -3;
public const EVFILT_VNODE: Int16 = -4;
public const EVFILT_PROC: Int16 = -5;
public const EVFILT_SIGNAL: Int16 = -6;
public const EVFILT_TIMER: Int16 = -7;
public const EVFILT_MACHPORT: Int16 = -8;
public const EVFILT_FS: Int16 = -9;
public const EVFILT_USER: Int16 = -10;
public const EVFILT_VM: Int16 = -12;
public const EVFILT_EXCEPT: Int16 = -15;

// kqueue flags
public const EV_ADD: UInt16 = 0x0001;
public const EV_DELETE: UInt16 = 0x0002;
public const EV_ENABLE: UInt16 = 0x0004;
public const EV_DISABLE: UInt16 = 0x0008;
public const EV_ONESHOT: UInt16 = 0x0010;
public const EV_CLEAR: UInt16 = 0x0020;
public const EV_RECEIPT: UInt16 = 0x0040;
public const EV_DISPATCH: UInt16 = 0x0080;
public const EV_UDATA_SPECIFIC: UInt16 = 0x0100;
public const EV_EOF: UInt16 = 0x8000;
public const EV_ERROR: UInt16 = 0x4000;

// kqueue fflags for EVFILT_VNODE
public const NOTE_DELETE: UInt32 = 0x00000001;
public const NOTE_WRITE: UInt32 = 0x00000002;
public const NOTE_EXTEND: UInt32 = 0x00000004;
public const NOTE_ATTRIB: UInt32 = 0x00000008;
public const NOTE_LINK: UInt32 = 0x00000010;
public const NOTE_RENAME: UInt32 = 0x00000020;
public const NOTE_REVOKE: UInt32 = 0x00000040;
public const NOTE_NONE: UInt32 = 0x00000080;
public const NOTE_FUNLOCK: UInt32 = 0x00000100;

// kqueue fflags for EVFILT_USER
public const NOTE_TRIGGER: UInt32 = 0x01000000;

// kqueue fflags for EVFILT_TIMER
public const NOTE_SECONDS: UInt32 = 0x00000001;
public const NOTE_USECONDS: UInt32 = 0x00000002;
public const NOTE_NSECONDS: UInt32 = 0x00000004;
public const NOTE_ABSOLUTE: UInt32 = 0x00000008;
public const NOTE_CRITICAL: UInt32 = 0x00000010;
public const NOTE_BACKGROUND: UInt32 = 0x00000020;
public const NOTE_LEEWAY: UInt32 = 0x00000040;

// Socket domains
public const AF_UNSPEC: Int = 0;
public const AF_UNIX: Int = 1;
public const AF_INET: Int = 2;
public const AF_INET6: Int = 30;

// Socket types
public const SOCK_STREAM: Int = 1;
public const SOCK_DGRAM: Int = 2;
public const SOCK_RAW: Int = 3;
public const SOCK_SEQPACKET: Int = 5;

// Socket options
public const SOL_SOCKET: Int = 0xFFFF;
public const SO_REUSEADDR: Int = 0x0004;
public const SO_KEEPALIVE: Int = 0x0008;
public const SO_BROADCAST: Int = 0x0020;
public const SO_LINGER: Int = 0x0080;
public const SO_RCVBUF: Int = 0x1002;
public const SO_SNDBUF: Int = 0x1001;
public const SO_RCVTIMEO: Int = 0x1006;
public const SO_SNDTIMEO: Int = 0x1005;
public const SO_ERROR: Int = 0x1007;
public const SO_NOSIGPIPE: Int = 0x1022;

// TCP options
public const IPPROTO_TCP: Int = 6;
public const TCP_NODELAY: Int = 0x01;
public const TCP_KEEPALIVE: Int = 0x10;

// IP options (IPPROTO_IP = 0)
public const IPPROTO_IP: Int = 0;
public const IP_MULTICAST_IF: Int = 9;
public const IP_MULTICAST_TTL: Int = 10;
public const IP_MULTICAST_LOOP: Int = 11;
public const IP_ADD_MEMBERSHIP: Int = 12;
public const IP_DROP_MEMBERSHIP: Int = 13;

// IPv4 TOS / ECN (RFC 3168). Darwin keeps the BSD-numbered constants:
// IP_TOS = 3 (Linux uses 1), IP_RECVTOS = 27.
public const IP_TOS: Int = 3;
public const IP_RECVTOS: Int = 27;

