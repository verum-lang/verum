public const CLOCK_MONOTONIC: Int = 6;
public const CLOCK_MONOTONIC_RAW: Int = 4;
public const CLOCK_UPTIME_RAW: Int = 8;
public const CLOCK_PROCESS_CPUTIME_ID: Int = 12;
public const CLOCK_THREAD_CPUTIME_ID: Int = 16;

// Signal numbers
public const SIGHUP: Int = 1;
public const SIGINT: Int = 2;
