public const IPV6_MULTICAST_HOPS: Int = 10;
public const IPV6_MULTICAST_LOOP: Int = 11;
public const IPV6_JOIN_GROUP: Int = 12;
public const IPV6_LEAVE_GROUP: Int = 13;

