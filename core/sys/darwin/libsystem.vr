module sys.darwin.libsystem;
mount core.base.coercion.{IntCoercible};

// =============================================================================
// sys/darwin/libsystem.vr - macOS libSystem.B.dylib FFI bindings
// =============================================================================
// Layer: 0 (Core)
// Dependencies: sys/common
// Platform: macOS (x86_64, arm64)
// =============================================================================
//
// CRITICAL: macOS DOES NOT support stable syscalls.
// All system operations MUST go through libSystem.B.dylib.
//
// Apple explicitly states that syscall numbers are private implementation
// details and may change between OS versions without notice.
//
// This module provides FFI bindings to libSystem for stable system access.
//
// Spec: docs/architecture/new-arch-spec.md Section 5.4
// =============================================================================

mount super.super.common.{OSError, FileDesc, IOVec, MemProt, MapFlags};

// =============================================================================
// libSystem.B.dylib FFI Declarations
// =============================================================================

@ffi("libSystem.B.dylib")
extern {
    // =========================================================================
    // File I/O
    // =========================================================================

    /// Read from file descriptor. C: `ssize_t read(int fd, void *buf, size_t nbyte)`.
    /// fd is `int` (i32); nbyte is `size_t` (i64 on 64-bit); return is `ssize_t` (i64). T0.4 fix.
    public fn read(fd: Int32, buf: &unsafe Byte, nbyte: Int) -> Int;

    /// Write to file descriptor. Same shape as `read`. T0.4 fix.
    public fn write(fd: Int32, buf: &Byte, nbyte: Int) -> Int;

    /// Open file. C: `int open(const char *path, int oflag, mode_t mode);`.
    /// `oflag` is `int` (Int32); `mode_t` is `uint32_t` on modern Darwin.
    /// Return is the new file descriptor (`int`, Int32).
    public fn open(path: &Byte, oflag: Int32, mode: UInt32) -> Int32;

    /// Close file descriptor.
    ///
    /// C signature: `int close(int fd)`. Both parameter and return are
    /// `int` (i32). Declaring `fd: Int` (=i64) at the FFI boundary breaks
    /// LLVM verification — the IR `call i32 @close(i64 %fd)` clashes with
    /// any call site emitting the canonical `call i32 @close(i32 %fd)`.
    /// Tracked under T0.4 / T0.4.1 (full POSIX C-ABI audit).
    public fn close(fd: Int32) -> Int32;

    /// Read at offset (does not change file position).
    /// C: `ssize_t pread(int fd, void *buf, size_t nbyte, off_t offset)`.
    /// T0.4.2: fd is C `int` (Int32), nbyte is `size_t` / off_t is `off_t`. Return is `ssize_t`.
    fn pread(fd: Int32, buf: &unsafe Byte, nbyte: Int, offset: Int) -> Int;

    /// Write at offset (does not change file position). T0.4.2 same shape as `pread`.
    fn pwrite(fd: Int32, buf: &Byte, nbyte: Int, offset: Int) -> Int;

    /// Reposition file offset.
    /// C: `off_t lseek(int fd, off_t offset, int whence)`. T0.4.2 fix.
    fn lseek(fd: Int32, offset: Int, whence: Int32) -> Int;

    /// Duplicate file descriptor. C: `int dup(int oldfd)`. T0.4.2 fix.
    fn dup(fd: Int32) -> Int32;

    /// Duplicate file descriptor to specific number.
    /// C: `int dup2(int oldfd, int newfd)`. T0.4.2 fix.
    fn dup2(oldfd: Int32, newfd: Int32) -> Int32;

    /// Create pipe (fds[0]=read end, fds[1]=write end).
    /// C: `int pipe(int pipefd[2])`. T0.4.2: fd-array element type is Int32.
    fn pipe(fds: &mut Int32) -> Int32;

    /// File control operations.
    /// C: `int fcntl(int fd, int cmd, ...)`. T0.4.2: cmd is C `int`,
    /// arg is variadic and varies per cmd; we keep `Int` for the
    /// generic-arg slot at the FFI boundary.
    fn fcntl(fd: Int32, cmd: Int32, arg: Int) -> Int32;

    /// Synchronize file to disk. C: `int fsync(int fd)`. T0.4.2 fix.
    fn fsync(fd: Int32) -> Int32;

    /// Synchronize file data to disk. C: `int fdatasync(int fd)`. T0.4.2 fix.
    fn fdatasync(fd: Int32) -> Int32;

    /// Truncate file to length. C: `int ftruncate(int fd, off_t length)`. T0.4.2 fix.
    fn ftruncate(fd: Int32, length: Int) -> Int32;

    /// Get file status.
    /// C: `int fstat(int fd, struct stat *buf)`. T0.4.2 fix.
    fn fstat(fd: Int32, buf: &unsafe DarwinStat) -> Int32;

    /// Get file status (path). C: `int stat(const char *path, struct stat *buf);`.
    fn stat(path: &Byte, buf: &unsafe DarwinStat) -> Int32;

    /// Get file status (symlink). C: `int lstat(const char *path,
    /// struct stat *buf);`.
    fn lstat(path: &Byte, buf: &unsafe DarwinStat) -> Int32;

    /// Probe path accessibility — `int access(const char *path, int amode)`.
    /// `amode` is `F_OK | R_OK | W_OK | X_OK`. Returns 0 on success, -1
    /// with errno on failure (EACCES means "no access").
    fn access(path: &Byte, amode: Int32) -> Int32;

    /// Scatter read. C: `ssize_t readv(int fd, const struct iovec *iov, int iovcnt)`.
    /// fd / iovcnt are POSIX `int` (32-bit); ssize_t is i64.
    fn readv(fd: Int32, iov: &IOVec, iovcnt: Int32) -> Int;

    /// Gather write. C: `ssize_t writev(int fd, const struct iovec *iov, int iovcnt)`.
    fn writev(fd: Int32, iov: &IOVec, iovcnt: Int32) -> Int;

    // =========================================================================
    // Memory Management
    // =========================================================================

    /// Map memory. C: `void *mmap(void *addr, size_t length, int prot, int flags, int fd, off_t offset)`.
    /// `prot`/`flags`/`fd` are POSIX `int` (Int32); `length` is size_t and
    /// `offset` is off_t — both 64-bit on POSIX 64-bit (kept as Int per the
    /// libsystem.vr convention for size_t/ssize_t).
    @ffi_name("mmap")
    public fn mmap_ffi(addr: Int, len: Int, prot: Int32, flags: Int32, fd: Int32, offset: Int) -> Int;

    /// Unmap memory. C: `int munmap(void *addr, size_t length);`.
    /// `addr` is a void* (kept Int as raw-pointer integer per file convention),
    /// `length` is size_t (Int), return is `int` (Int32).
    public fn munmap(addr: Int, len: Int) -> Int32;

    /// Change memory protection. C: `int mprotect(void *addr, size_t len,
    /// int prot);`. `prot` is `int` (Int32), return is `int` (Int32).
    public fn mprotect(addr: Int, len: Int, prot: Int32) -> Int32;

    /// Memory advise. C: `int madvise(void *addr, size_t len, int advice);`.
    /// `advice` is `int` (Int32), return is `int` (Int32).
    public fn madvise(addr: Int, len: Int, advice: Int32) -> Int32;

    /// Lock memory. C: `int mlock(const void *addr, size_t len);`.
    fn mlock(addr: Int, len: Int) -> Int32;

    /// Unlock memory. C: `int munlock(const void *addr, size_t len);`.
    fn munlock(addr: Int, len: Int) -> Int32;

    /// Synchronize memory to storage. C: `int msync(void *addr, size_t len,
    /// int flags);`. `flags` is `int` (Int32), return is `int` (Int32).
    fn msync(addr: Int, len: Int, flags: Int32) -> Int32;

    /// Get page size. C: `int getpagesize(void);`.
    fn getpagesize() -> Int32;

    // =========================================================================
    // Process Control
    // =========================================================================

    /// Get process ID. C: `pid_t getpid(void);` (`pid_t = int32_t`).
    fn getpid() -> Int32;

    /// Get parent process ID. C: `pid_t getppid(void);`.
    fn getppid() -> Int32;

    /// Get user ID. C: `uid_t getuid(void);` (`uid_t = uint32_t`).
    fn getuid() -> UInt32;

    /// Get effective user ID. C: `uid_t geteuid(void);`.
    fn geteuid() -> UInt32;

    /// Get group ID. C: `gid_t getgid(void);` (`gid_t = uint32_t`).
    fn getgid() -> UInt32;

    /// Get effective group ID. C: `gid_t getegid(void);`.
    fn getegid() -> UInt32;

    /// Exit process. C: `void exit(int status);`.
    fn exit(status: Int32) -> !;

    /// Exit process (alternate). C: `void _exit(int status);`.
    fn _exit(status: Int32) -> !;

    /// Fork process. C: `pid_t fork(void);` (`pid_t = int32_t`).
    fn fork() -> Int32;

    /// Execute program (absolute path).
    /// C: `int execve(const char *path, char *const argv[], char *const envp[]);`.
    fn execve(path: &Byte, argv: &(&Byte), envp: &(&Byte)) -> Int32;

    /// Execute program (search PATH).
    /// C: `int execvp(const char *file, char *const argv[]);`.
    fn execvp(file: &Byte, argv: &(&Byte)) -> Int32;

    /// Wait for child process.
    /// C: `pid_t waitpid(pid_t pid, int *status, int options);`.
    fn waitpid(pid: Int32, status: &mut Int32, options: Int32) -> Int32;

    /// Send signal. C: `int kill(pid_t pid, int sig);`.
    fn kill(pid: Int32, sig: Int32) -> Int32;

    // =========================================================================
    // kqueue - Event Notification
    // =========================================================================

    /// Create kqueue. C: `int kqueue(void);` (returns a file descriptor,
    /// POSIX `int`).
    public fn kqueue() -> Int32;

    /// Register/poll events.
    /// C: `int kevent(int kq, const struct kevent *changelist, int nchanges,
    ///                struct kevent *eventlist, int nevents,
    ///                const struct timespec *timeout);`
    /// All count parameters and return value are POSIX `int` (Int32).
    public fn kevent(
        kq: Int32,
        changelist: &KEvent,
        nchanges: Int32,
        eventlist: &unsafe KEvent,
        nevents: Int32,
        timeout: &DarwinTimespec,
    ) -> Int32;

    /// kevent64 (extended). Same `int`/Int32 discipline as `kevent`;
    /// `flags` is the size_t-shaped 64-bit `unsigned int` per the macOS
    /// kevent64.h declaration.
    public fn kevent64(
        kq: Int32,
        changelist: &KEvent64,
        nchanges: Int32,
        eventlist: &unsafe KEvent64,
        nevents: Int32,
        flags: USize,
        timeout: &DarwinTimespec,
    ) -> Int32;

    // =========================================================================
    // pthread - Threading
    // =========================================================================

    /// Get current thread
    public fn pthread_self() -> PthreadT;

    // pthread_* functions all return `int` (POSIX); 0 on success, an
    // errno-numbered value on failure. Migrated to Int32 for ABI honesty.
    /// Create thread
    public fn pthread_create(
        thread: &mut PthreadT,
        attr: &PthreadAttr,
        start_routine: fn(&unsafe Byte) -> &unsafe Byte,
        arg: &unsafe Byte,
    ) -> Int32;

    /// Join thread
    public fn pthread_join(thread: PthreadT, value_ptr: &mut (&unsafe Byte)) -> Int32;

    /// Detach thread
    public fn pthread_detach(thread: PthreadT) -> Int32;

    /// Exit thread
    public fn pthread_exit(value_ptr: &unsafe Byte) -> !;

    /// Initialize mutex
    public fn pthread_mutex_init(mutex: &mut PthreadMutex, attr: &PthreadMutexAttr) -> Int32;

    /// Destroy mutex
    public fn pthread_mutex_destroy(mutex: &mut PthreadMutex) -> Int32;

    /// Lock mutex
    public fn pthread_mutex_lock(mutex: &mut PthreadMutex) -> Int32;

    /// Try lock mutex
    public fn pthread_mutex_trylock(mutex: &mut PthreadMutex) -> Int32;

    /// Unlock mutex
    public fn pthread_mutex_unlock(mutex: &mut PthreadMutex) -> Int32;

    /// Initialize condition variable
    public fn pthread_cond_init(cond: &mut PthreadCond, attr: &PthreadCondAttr) -> Int32;

    /// Destroy condition variable
    public fn pthread_cond_destroy(cond: &mut PthreadCond) -> Int32;

    /// Wait on condition variable
    public fn pthread_cond_wait(cond: &mut PthreadCond, mutex: &mut PthreadMutex) -> Int32;

    /// Timed wait on condition variable
    public fn pthread_cond_timedwait(
        cond: &mut PthreadCond,
        mutex: &mut PthreadMutex,
        abstime: &DarwinTimespec,
    ) -> Int32;

    /// Signal condition variable
    public fn pthread_cond_signal(cond: &mut PthreadCond) -> Int32;

    /// Broadcast condition variable
    public fn pthread_cond_broadcast(cond: &mut PthreadCond) -> Int32;

    // =========================================================================
    // Low-level ulock (futex equivalent on macOS/XNU)
    // =========================================================================

    /// Wait on address if value matches (futex equivalent).
    /// operation: UL_COMPARE_AND_WAIT (1) | ULF_NO_ERRNO (0x01000000)
    /// addr: pointer to 32-bit word to compare
    /// value: expected value (compared as uint64_t, lower 32 bits used)
    /// timeout_us: timeout in microseconds (0 = infinite)
    /// Returns: 0 on success, negative errno on error (-ETIMEDOUT, -EFAULT, -EINTR)
    public fn __ulock_wait(operation: UInt32, addr: &unsafe Byte, value: UInt64, timeout_us: UInt32) -> Int;

    /// Wake threads waiting on address (futex wake equivalent).
    /// operation: UL_COMPARE_AND_WAIT (1) | ULF_WAKE_ALL (0x100) for all
    /// addr: pointer to word being waited on
    /// wake_value: not used for UL_COMPARE_AND_WAIT, pass 0
    /// Returns: 0 on success, negative errno on error
    public fn __ulock_wake(operation: UInt32, addr: &unsafe Byte, wake_value: UInt64) -> Int;

    /// TLS key create
    public fn pthread_key_create(key: &mut PthreadKey, destructor: fn(&unsafe Byte)) -> Int32;

    /// TLS key delete
    public fn pthread_key_delete(key: PthreadKey) -> Int32;

    /// TLS get specific
    public fn pthread_getspecific(key: PthreadKey) -> &unsafe Byte;

    /// TLS set specific
    public fn pthread_setspecific(key: PthreadKey, value: &unsafe Byte) -> Int32;

    /// Get thread ID (macOS extension). C: `int pthread_threadid_np(pthread_t,
    /// uint64_t *)`.
    public fn pthread_threadid_np(thread: PthreadT, thread_id: &mut UInt64) -> Int32;

    // =========================================================================
    // Time
    // =========================================================================

    /// Get time of day. C: `int gettimeofday(struct timeval *tv,
    /// struct timezone *tz);`.
    public fn gettimeofday(tv: &mut DarwinTimeval, tz: &unsafe Byte) -> Int32;

    /// Get clock time (POSIX). C: `int clock_gettime(clockid_t, struct timespec *)`.
    /// `clockid_t` is `int32` on macOS. T0.4 fix.
    public fn clock_gettime(clk_id: Int32, tp: &mut DarwinTimespec) -> Int32;

    /// Sleep (nanoseconds). C: `int nanosleep(const struct timespec *rqtp,
    /// struct timespec *rmtp);`.
    public fn nanosleep(rqtp: &DarwinTimespec, rmtp: &mut DarwinTimespec) -> Int32;

    /// Get monotonic time (mach)
    public fn mach_absolute_time() -> UInt64;

    /// Get time base info (mach). C: `kern_return_t mach_timebase_info(...)`.
    /// `kern_return_t` is `int32` on macOS.
    public fn mach_timebase_info(info: &mut MachTimebaseInfo) -> Int32;

    // =========================================================================
    // Sockets
    // =========================================================================

    /// Create socket. Returns C `int` (32-bit) — declared as `Int32`
    /// rather than `Int` so the AOT extern-call lowering picks the
    /// i32 return-type at the LLVM IR level. With `Int` (=i64) the
    /// AArch64 call site reads x0 as 64-bit and inherits whatever
    /// libSystem's epilogue left in the upper 32 bits — typically
    /// garbage that flips a small positive fd into a "negative" i64
    /// and trips the `< 0` error path. Tracked under #108.
    fn socket(domain: Int32, socket_type: Int32, protocol: Int32) -> Int32;

    /// Bind socket. socklen_t is uint32_t. T0.4 fix.
    fn bind(sockfd: Int32, addr: &unsafe Byte, addrlen: UInt32) -> Int32;

    /// Listen on socket. C: `int listen(int sockfd, int backlog)`. T0.4 fix.
    fn listen(sockfd: Int32, backlog: Int32) -> Int32;

    /// Accept connection. C signature uses `socklen_t *` (uint32_t) for
    /// addrlen — declared as `&mut UInt32` here. T0.4 fix.
    fn accept(sockfd: Int32, addr: &unsafe Byte, addrlen: &mut UInt32) -> Int32;

    /// Connect socket. socklen_t is uint32_t on macOS / Linux. T0.4 fix.
    fn connect(sockfd: Int32, addr: &unsafe Byte, addrlen: UInt32) -> Int32;

    /// Send data. C: `ssize_t send(int sockfd, const void *buf, size_t len, int flags)`.
    /// sockfd / flags are POSIX `int` (Int32); len is size_t (kept Int per file convention).
    fn send(sockfd: Int32, buf: &Byte, len: Int, flags: Int32) -> Int;

    /// Receive data. C: `ssize_t recv(int sockfd, void *buf, size_t len, int flags)`.
    fn recv(sockfd: Int32, buf: &unsafe Byte, len: Int, flags: Int32) -> Int;

    /// Send to address. C: `ssize_t sendto(int sockfd, const void *buf,
    /// size_t len, int flags, const struct sockaddr *dest_addr, socklen_t addrlen)`.
    /// `addrlen` is socklen_t (UInt32).
    fn sendto(
        sockfd: Int32,
        buf: &Byte,
        len: Int,
        flags: Int32,
        dest_addr: &unsafe Byte,
        addrlen: UInt32,
    ) -> Int;

    /// Receive from address. C: `ssize_t recvfrom(int sockfd, void *buf,
    /// size_t len, int flags, struct sockaddr *src_addr, socklen_t *addrlen)`.
    /// `addrlen` is `socklen_t *` (`&mut UInt32`); the kernel writes 4 bytes,
    /// so an `i64*` here would only have its low 4 bytes touched.
    @ffi_name("recvfrom")
    fn recvfrom_ffi(
        sockfd: Int32,
        buf: &unsafe Byte,
        len: Int,
        flags: Int32,
        src_addr: &unsafe Byte,
        addrlen: &mut UInt32,
    ) -> Int;

    /// Get socket option. C: `int getsockopt(int sockfd, int level, int optname,
    /// void *optval, socklen_t *optlen)`. `optlen` is `socklen_t *` (`&mut UInt32`).
    fn getsockopt(sockfd: Int32, level: Int32, optname: Int32, optval: &unsafe Byte, optlen: &mut UInt32) -> Int32;

    /// Set socket option. C: `int setsockopt(int, int, int, const void *, socklen_t)`.
    /// All four `int`-typed params + socklen_t (uint32_t). T0.4 fix.
    fn setsockopt(sockfd: Int32, level: Int32, optname: Int32, optval: &Byte, optlen: UInt32) -> Int32;

    /// Shutdown socket. C: `int shutdown(int sockfd, int how)`.
    fn shutdown(sockfd: Int32, how: Int32) -> Int32;

    /// Get socket name (local address). C: `int getsockname(int sockfd,
    /// struct sockaddr *addr, socklen_t *addrlen)`. `addrlen` is `socklen_t *`
    /// (uint32_t*) — the kernel writes 4 bytes, so an i64* here would leave
    /// the high 4 bytes unwritten / uninitialized.
    fn getsockname(sockfd: Int32, addr: &unsafe Byte, addrlen: &mut UInt32) -> Int32;

    /// Get peer name (remote address). Same socklen_t* invariant as
    /// `getsockname` — `addrlen` must be `&mut UInt32`.
    fn getpeername(sockfd: Int32, addr: &unsafe Byte, addrlen: &mut UInt32) -> Int32;

    // =========================================================================
    // Directory Operations
    // =========================================================================

    /// Create directory. C: `int mkdir(const char *path, mode_t mode);`.
    /// `mode_t` is `uint16_t` historically, `uint32_t` on modern Darwin —
    /// promoted to `UInt32` for ABI safety.
    fn mkdir(path: &Byte, mode: UInt32) -> Int32;

    /// Remove directory. C: `int rmdir(const char *path);`.
    fn rmdir(path: &Byte) -> Int32;

    /// Change current directory. C: `int chdir(const char *path);`.
    fn chdir(path: &Byte) -> Int32;

    /// Get current directory. C: `char *getcwd(char *buf, size_t size);`.
    /// `size` is size_t (kept Int per file convention).
    fn getcwd(buf: &unsafe Byte, size: Int) -> &Byte;

    /// Open directory
    public fn opendir(name: &Byte) -> &unsafe DIR;

    /// Read directory entry
    public fn readdir(dirp: &DIR) -> &Dirent;

    /// Close directory. C: `int closedir(DIR *dirp);`.
    public fn closedir(dirp: &DIR) -> Int32;

    // =========================================================================
    // Filesystem Operations
    // =========================================================================

    /// Remove a file. C: `int unlink(const char *pathname);`.
    fn unlink(path: &Byte) -> Int32;

    /// Create a hard link. C: `int link(const char *oldpath, const char *newpath);`.
    fn link(src: &Byte, dst: &Byte) -> Int32;

    /// Rename a file or directory. C: `int rename(const char *old,
    /// const char *new);`.
    @ffi_name("rename")
    fn rename_ffi(oldpath: &Byte, newpath: &Byte) -> Int32;

    /// Create a symbolic link. C: `int symlink(const char *target,
    /// const char *linkpath);`.
    @ffi_name("symlink")
    fn symlink_ffi(src: &Byte, dst: &Byte) -> Int32;

    /// Read a symbolic link. C: `ssize_t readlink(const char *pathname,
    /// char *buf, size_t bufsiz);`. Returns ssize_t (signed; -1 on error,
    /// kept as Int per file convention).
    fn readlink(path: &Byte, buf: &unsafe Byte, bufsize: Int) -> Int;

    /// Change file mode. C: `int chmod(const char *path, mode_t mode);`.
    fn chmod(path: &Byte, mode: UInt32) -> Int32;

    // =========================================================================
    // Environment Variables
    // =========================================================================

    /// Get environment variable (returns null if not set)
    fn getenv(name: &Byte) -> &Byte;

    /// Set environment variable (overwrite: 1 to replace existing, 0 to preserve).
    /// C: `int setenv(const char *name, const char *value, int overwrite);`.
    fn setenv(name: &Byte, value: &Byte, overwrite: Int32) -> Int32;

    /// Remove environment variable. C: `int unsetenv(const char *name);`.
    fn unsetenv(name: &Byte) -> Int32;

    // =========================================================================
    // Command Line Arguments (macOS-specific)
    // =========================================================================

    /// Get pointer to argc (crt_externs.h)
    fn _NSGetArgc() -> &Int;

    /// Get pointer to argv (crt_externs.h)
    fn _NSGetArgv() -> &(&(&Byte));

    /// Get pointer to environ (crt_externs.h)
    fn _NSGetEnviron() -> &(&(&Byte));

    // =========================================================================
    // Signals
    // =========================================================================

    /// Set signal handler. C: `sig_t signal(int sig, sig_t func);`
    /// (`sig_t = void (*)(int)`). All `int`-typed slots → Int32.
    fn signal(signum: Int32, handler: fn(Int32)) -> fn(Int32);

    /// Signal action. C: `int sigaction(int signum, const struct sigaction
    /// *act, struct sigaction *oldact);`.
    fn sigaction(signum: Int32, act: &Sigaction, oldact: &mut Sigaction) -> Int32;

    /// Signal mask. C: `int sigprocmask(int how, const sigset_t *set,
    /// sigset_t *oldset);`.
    fn sigprocmask(how: Int32, set: &Sigset, oldset: &mut Sigset) -> Int32;

    // =========================================================================
    // Random
    // =========================================================================

    /// Get entropy (macOS 10.12+). C: `int getentropy(void *buffer,
    /// size_t length);`. `length` is size_t (kept Int), return is `int`.
    fn getentropy(buffer: &unsafe Byte, length: Int) -> Int32;

    /// arc4random (BSD)
    fn arc4random() -> UInt32;

    /// arc4random_buf (BSD). C: `void arc4random_buf(void *buf, size_t nbytes);`.
    fn arc4random_buf(buf: &unsafe Byte, nbytes: Int);

    // =========================================================================
    // Error Handling
    // =========================================================================

    /// Get errno location. C: `int *__error(void);` (Darwin) — returns
    /// a pointer to the thread-local C `int` errno slot. Declaring as
    /// `&mut Int` would dereference 8 bytes including 4 bytes of unrelated
    /// adjacent TLS data; `&mut Int32` reads exactly the 4 bytes the C
    /// library writes.
    fn __error() -> &mut Int32;

    /// String error. C: `char *strerror(int errnum);`.
    fn strerror(errnum: Int32) -> &Byte;

    // =========================================================================
    // Dynamic Loading
    // =========================================================================

    /// Open dynamic library. C: `void *dlopen(const char *path, int mode);`.
    fn dlopen(filename: &Byte, flags: Int32) -> &unsafe Byte;

    /// Get symbol
    fn dlsym(handle: &unsafe Byte, symbol: &Byte) -> &unsafe Byte;

    /// Close dynamic library. C: `int dlclose(void *handle);`.
    fn dlclose(handle: &unsafe Byte) -> Int32;

    /// Get error
    fn dlerror() -> &Byte;

    // =========================================================================
    // Mach Kernel Interface
    // =========================================================================

    /// Get Mach host port
    fn mach_host_self() -> MachPort;

    /// Get Mach task port
    fn mach_task_self() -> MachPort;

    /// Get Mach thread port
    fn mach_thread_self() -> MachPort;

    /// Allocate VM. C: `kern_return_t vm_allocate(vm_map_t target_task,
    ///   vm_address_t *address, vm_size_t size, int flags);`
    /// `kern_return_t` and `flags` are `int` (Int32); `vm_address_t` and
    /// `vm_size_t` are pointer-width (Int on 64-bit Darwin).
    fn vm_allocate(
        target_task: MachPort,
        address: &mut Int,
        size: Int,
        flags: Int32,
    ) -> Int32;

    /// Deallocate VM. C: `kern_return_t vm_deallocate(vm_map_t,
    /// vm_address_t, vm_size_t);`
    fn vm_deallocate(target_task: MachPort, address: Int, size: Int) -> Int32;

    /// Protect VM. C: `kern_return_t vm_protect(vm_map_t, vm_address_t,
    /// vm_size_t, boolean_t set_maximum, vm_prot_t new_protection);`
    /// `boolean_t` and `vm_prot_t` are `int` (Int32).
    fn vm_protect(
        target_task: MachPort,
        address: Int,
        size: Int,
        set_maximum: Int32,
        new_protection: Int32,
    ) -> Int32;
}

// =============================================================================
// Type Definitions
// =============================================================================

/// pthread_t type
public type PthreadT is (Int);

/// pthread_key_t type
public type PthreadKey is (Int);

/// pthread_attr_t (opaque)
public type PthreadAttr is {
    _opaque: [Int; 8],
};

/// pthread_mutex_t (opaque)
public type PthreadMutex is {
    _opaque: [Int; 8],
};

/// pthread_mutexattr_t (opaque)
public type PthreadMutexAttr is {
    _opaque: [Int; 2],
};

/// pthread_cond_t (opaque)
public type PthreadCond is {
    _opaque: [Int; 6],
};

/// pthread_condattr_t (opaque)
public type PthreadCondAttr is {
    _opaque: [Int; 2],
};

/// Mach port type
public type MachPort is (UInt32);

// IntCoercible: MachPort wraps UInt32 — coerce with Int in
// arithmetic / comparison contexts.
implement IntCoercible for MachPort {}

/// timespec structure
public type DarwinTimespec is {
    tv_sec: Int,
    tv_nsec: Int,
};

/// timeval structure
public type DarwinTimeval is {
    tv_sec: Int,
    tv_usec: Int,
};

/// mach_timebase_info structure
public type MachTimebaseInfo is {
    numer: UInt32,
    denom: UInt32,
};

/// kevent structure (32-bit ident)
public type KEvent is {
    ident: Int,
    filter: Int16,
    flags: UInt16,
    fflags: UInt32,
    data: Int,
    udata: &unsafe Byte,
};

/// kevent64 structure (64-bit ident)
public type KEvent64 is {
    ident: UInt64,
    filter: Int16,
    flags: UInt16,
    fflags: UInt32,
    data: Int64,
    udata: UInt64,
    ext: [UInt64; 2],
};

/// stat structure
public type DarwinStat is {
    st_dev: Int32,
    st_ino: UInt64,
    st_mode: UInt16,
    st_nlink: UInt16,
    st_uid: UInt32,
    st_gid: UInt32,
    st_rdev: Int32,
    st_atime: DarwinTimespec,
    st_mtime: DarwinTimespec,
    st_ctime: DarwinTimespec,
    st_birthtime: DarwinTimespec,
    st_size: Int64,
    st_blocks: Int64,
    st_blksize: Int32,
    st_flags: UInt32,
    st_gen: UInt32,
};

/// sockaddr (generic)
public type Sockaddr is {
    sa_len: UInt8,
    sa_family: UInt8,
    sa_data: [Byte; 14],
};

/// sockaddr_in (IPv4)
public type DarwinSockaddrIn is {
    sin_len: UInt8,
    sin_family: UInt8,
    sin_port: UInt16,
    sin_addr: UInt32,
    sin_zero: [Byte; 8],
};

/// sockaddr_in6 (IPv6)
public type DarwinSockaddrIn6 is {
    sin6_len: UInt8,
    sin6_family: UInt8,
    sin6_port: UInt16,
    sin6_flowinfo: UInt32,
    sin6_addr: [Byte; 16],
    sin6_scope_id: UInt32,
};

/// DIR opaque type
public type DIR is {
    _opaque: [Byte; 1],
};

/// dirent structure
public type Dirent is {
    d_ino: UInt64,
    d_seekoff: UInt64,
    d_reclen: UInt16,
    d_namlen: UInt16,
    d_type: UInt8,
    d_name: [Byte; 1024],
};

/// sigaction structure
public type Sigaction is {
    sa_handler: fn(Int),
    sa_mask: Sigset,
    sa_flags: Int,
};

/// sigset_t
public type Sigset is (UInt32);

