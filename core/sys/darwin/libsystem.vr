/// Rename a file or directory
public fn safe_rename(oldpath: &[Byte], newpath: &[Byte]) -> Result<(), OSError> {
    let old_p: &Byte = transmute(oldpath);
    let new_p: &Byte = transmute(newpath);
    let result = unsafe { rename_ffi(old_p, new_p) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Create a symbolic link
public fn safe_symlink(src: &[Byte], dst: &[Byte]) -> Result<(), OSError> {
    let src_p: &Byte = transmute(src);
    let dst_p: &Byte = transmute(dst);
    let result = unsafe { symlink_ffi(src_p, dst_p) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Read a symbolic link
public fn safe_readlink(path: &[Byte], buf: &mut [Byte]) -> Result<Int, OSError> {
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe { readlink(path_buf.as_ptr() as &Byte, buf.as_mut_ptr() as &unsafe Byte, buf.len()) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Create a hard link
public fn safe_link(src: &[Byte], dst: &[Byte]) -> Result<(), OSError> {
    let mut src_buf = [0_u8; 4096];
    let src_len = src.len().min(4095);
    src_buf[..src_len].copy_from_slice(&src[..src_len]);
    src_buf[src_len] = 0;

    let mut dst_buf = [0_u8; 4096];
    let dst_len = dst.len().min(4095);
    dst_buf[..dst_len].copy_from_slice(&dst[..dst_len]);
    dst_buf[dst_len] = 0;

    let result = unsafe { link(src_buf.as_ptr() as &Byte, dst_buf.as_ptr() as &Byte) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Change file mode
public fn safe_chmod(path: &[Byte], mode: Int) -> Result<(), OSError> {
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe { chmod(path_buf.as_ptr() as &Byte, mode) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Get current working directory
public fn safe_getcwd(buf: &mut [Byte]) -> Result<Int, OSError> {
    let result = unsafe { getcwd(buf.as_mut_ptr() as &unsafe Byte, buf.len()) };
    if (result as Int) == 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        // Find the length of the null-terminated string
        let mut len = 0;
        while len < buf.len() && buf[len] != 0 {
            len = len + 1;
        }
        Ok(len)
    }
}

/// Change current working directory
public fn safe_chdir(path: &[Byte]) -> Result<(), OSError> {
    let mut path_buf = [0_u8; 4096];
    let len = path.len().min(4095);
    path_buf[..len].copy_from_slice(&path[..len]);
    path_buf[len] = 0;

    let result = unsafe { chdir(path_buf.as_ptr() as &Byte) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

// =============================================================================
// Environment Variable Safe Wrappers
// =============================================================================

/// Get environment variable value
///
/// Returns None if the variable is not set.
public fn safe_getenv(name: &[Byte]) -> Maybe<Text> {
    let mut name_buf = [0_u8; 256];
    let len = name.len().min(255);
    name_buf[..len].copy_from_slice(&name[..len]);
    name_buf[len] = 0;

    let result = unsafe { getenv(name_buf.as_ptr() as &Byte) };
    if result.is_null() {
        None
    } else {
        // Find length of null-terminated string
        let mut value_len = 0;
        unsafe {
            while *result.offset(value_len) != 0 {
                value_len = value_len + 1;
            }
            let value_bytes = core.slice.from_raw_parts(result as &Byte, value_len);
            Some(Text.from_utf8_lossy(value_bytes))
        }
    }
}

/// Set environment variable
///
/// If overwrite is true, replaces existing value. If false, does nothing if variable exists.
public fn safe_setenv(name: &[Byte], value: &[Byte], overwrite: Bool) -> Result<(), OSError> {
    let mut name_buf = [0_u8; 256];
    let name_len = name.len().min(255);
    name_buf[..name_len].copy_from_slice(&name[..name_len]);
    name_buf[name_len] = 0;

    let mut value_buf = [0_u8; 4096];
    let value_len = value.len().min(4095);
    value_buf[..value_len].copy_from_slice(&value[..value_len]);
    value_buf[value_len] = 0;

    let result = unsafe {
        setenv(
            name_buf.as_ptr() as &Byte,
            value_buf.as_ptr() as &Byte,
            if overwrite { 1 } else { 0 }
        )
    };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Remove environment variable
public fn safe_unsetenv(name: &[Byte]) -> Result<(), OSError> {
    let mut name_buf = [0_u8; 256];
    let len = name.len().min(255);
    name_buf[..len].copy_from_slice(&name[..len]);
    name_buf[len] = 0;

    let result = unsafe { unsetenv(name_buf.as_ptr() as &Byte) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

// =============================================================================
// Command Line Arguments Safe Wrappers
// =============================================================================

/// Get the number of command line arguments
public fn args_count() -> Int {
    unsafe { *_NSGetArgc() }
}

/// Get a command line argument by index
///
/// Returns None if index is out of bounds.
public fn args_get(index: Int) -> Maybe<Text> {
    let argc = args_count();
    if index < 0 || index >= argc {
        return None;
    }

    unsafe {
        let argv = *_NSGetArgv();
        let arg_ptr = *argv.offset(index);
        if arg_ptr.is_null() {
            return None;
        }

        // Find length of null-terminated string
        let mut len = 0;
        while *arg_ptr.offset(len) != 0 {
            len = len + 1;
        }
        let arg_bytes = core.slice.from_raw_parts(arg_ptr as &Byte, len);
        Some(Text.from_utf8_lossy(arg_bytes))
    }
}

// Helper function
fn errno_to_message(code: Int) -> Text {
    super.errno.errno_name(code)
}

// =============================================================================
// Socket Safe Wrappers
// =============================================================================

/// Create a socket (safe wrapper)
public fn safe_socket(domain: Int, sock_type: Int, protocol: Int) -> Result<FileDesc, OSError> {
    // libc `socket` returns C `int` (32-bit). The FFI extern declares
    // it as Verum `Int` (64-bit), and AOT extern-call lowering doesn't
    // currently sign-extend the i32 return to i64 — upper 32 bits of
    // x0 contain garbage from libSystem's epilogue. A successful fd
    // (small positive int) can read back as a large negative i64 and
    // wrongly trip the `< 0` error path. Manually sign-extend via bit
    // ops since `as Int32 as Int` doesn't reach AOT codegen as a
    // sign-extension (#108).
    let raw_i32: Int32 = unsafe { socket(domain, sock_type, protocol) };
    let result = raw_i32 as Int;
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(FileDesc(result))
    }
}

/// Bind a socket to an address (safe wrapper)
public fn safe_bind(fd: FileDesc, addr: &unsafe Byte, addr_len: Int) -> Result<(), OSError> {
    let result = unsafe { bind(fd.0, addr, addr_len) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Listen on a socket (safe wrapper)
public fn safe_listen(fd: FileDesc, backlog: Int) -> Result<(), OSError> {
    let result = unsafe { listen(fd.0, backlog) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Accept a connection (safe wrapper)
public fn safe_accept(fd: FileDesc, addr_buf: &mut [Byte], addr_len: &mut Int) -> Result<FileDesc, OSError> {
    let result = unsafe {
        accept(fd.0, addr_buf.as_mut_ptr() as &unsafe Byte, addr_len)
    };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        // accept returns C int (now declared Int32); FileDesc wraps Int.
        Ok(FileDesc(result as Int))
    }
}

/// Connect to an address (safe wrapper)
public fn safe_connect(fd: FileDesc, addr: &unsafe Byte, addr_len: Int) -> Result<(), OSError> {
    let result = unsafe { connect(fd.0, addr, addr_len) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Send data on a connected socket (safe wrapper)
public fn safe_send(fd: FileDesc, buf: &[Byte], flags: Int) -> Result<Int, OSError> {
    let result = unsafe { send(fd.0, buf.as_ptr(), buf.len(), flags) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Receive data from a connected socket (safe wrapper)
public fn safe_recv(fd: FileDesc, buf: &mut [Byte], flags: Int) -> Result<Int, OSError> {
    let result = unsafe { recv(fd.0, buf.as_mut_ptr() as &unsafe Byte, buf.len(), flags) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Send data to an address (safe wrapper)
public fn safe_sendto(
    fd: FileDesc,
    buf: &[Byte],
    flags: Int,
    dest_addr: &unsafe Byte,
    addr_len: Int
) -> Result<Int, OSError> {
    let result = unsafe {
        sendto(fd.0, buf.as_ptr(), buf.len(), flags, dest_addr, addr_len)
    };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Receive data with source address (safe wrapper)
public fn safe_recvfrom(
    fd: FileDesc,
    buf: &mut [Byte],
    flags: Int,
    src_addr: &mut [Byte],
    addr_len: &mut Int
) -> Result<Int, OSError> {
    let buf_ptr: &unsafe Byte = transmute(buf);
    let buf_len = buf.len();
    let src_ptr: &unsafe Byte = transmute(src_addr);
    let result = unsafe {
        recvfrom_ffi(fd.0, buf_ptr, buf_len, flags, src_ptr, addr_len)
    };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Set a socket option (safe wrapper)
public fn safe_setsockopt(
    fd: FileDesc,
    level: Int,
    optname: Int,
    optval: &unsafe Byte,
    optlen: Int
) -> Result<(), OSError> {
    let result = unsafe { setsockopt(fd.0, level, optname, optval as &Byte, optlen) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Set an integer socket option (convenience wrapper)
public fn safe_setsockopt_int(fd: FileDesc, level: Int, optname: Int, value: Int) -> Result<(), OSError> {
    let val: Int32 = value as Int32;
    safe_setsockopt(fd, level, optname, &val as &unsafe Byte, 4)
}

/// Get a socket option (safe wrapper)
public fn safe_getsockopt(
    fd: FileDesc,
    level: Int,
    optname: Int,
    optval: &mut [Byte],
    optlen: &mut Int
) -> Result<(), OSError> {
    let result = unsafe {
        getsockopt(fd.0, level, optname, optval.as_mut_ptr() as &unsafe Byte, optlen)
    };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Get socket error (convenience wrapper)
public fn safe_getsockopt_error(fd: FileDesc) -> Result<Int, OSError> {
    let mut buf = [0_u8; 4];
    let mut len = 4;
    safe_getsockopt(fd, SOL_SOCKET, SO_ERROR, &mut buf, &mut len)?;
    let error = (buf[0] as Int) | ((buf[1] as Int) << 8) |
                ((buf[2] as Int) << 16) | ((buf[3] as Int) << 24);
    Ok(error)
}

/// Shutdown a socket (safe wrapper)
public fn safe_shutdown(fd: FileDesc, how: Int) -> Result<(), OSError> {
    let result = unsafe { shutdown(fd.0, how) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Get local socket address (safe wrapper)
public fn safe_getsockname(fd: FileDesc, addr_buf: &mut [Byte], addr_len: &mut Int) -> Result<(), OSError> {
    let result = unsafe {
        getsockname(fd.0, addr_buf.as_mut_ptr() as &unsafe Byte, addr_len)
    };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// Get peer socket address (safe wrapper)
public fn safe_getpeername(fd: FileDesc, addr_buf: &mut [Byte], addr_len: &mut Int) -> Result<(), OSError> {
    let result = unsafe {
        getpeername(fd.0, addr_buf.as_mut_ptr() as &unsafe Byte, addr_len)
    };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(())
    }
}

/// File control operations (safe wrapper)
public fn safe_fcntl(fd: FileDesc, cmd: Int, arg: Int) -> Result<Int, OSError> {
    let result = unsafe { fcntl(fd.0, cmd, arg) };
    if result < 0 {
        let err = errno();
        Err(OSError { code: err, message: errno_to_message(err) })
    } else {
        Ok(result)
    }
}

/// Set file descriptor to non-blocking mode
public fn safe_set_nonblocking(fd: FileDesc, nonblocking: Bool) -> Result<(), OSError> {
    let flags = safe_fcntl(fd, F_GETFL, 0)?;
    let new_flags = if nonblocking {
        flags | O_NONBLOCK
    } else {
        flags & !O_NONBLOCK
    };
    safe_fcntl(fd, F_SETFL, new_flags)?;
    Ok(())
}

/// Set SO_REUSEADDR option
public fn safe_set_reuseaddr(fd: FileDesc, reuse: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, SOL_SOCKET, SO_REUSEADDR, if reuse { 1 } else { 0 })
}

/// Set TCP_NODELAY option (disable Nagle's algorithm)
public fn safe_set_tcp_nodelay(fd: FileDesc, nodelay: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, IPPROTO_TCP, TCP_NODELAY, if nodelay { 1 } else { 0 })
}

/// Set SO_KEEPALIVE option
public fn safe_set_keepalive(fd: FileDesc, keepalive: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, SOL_SOCKET, SO_KEEPALIVE, if keepalive { 1 } else { 0 })
}

/// Set SO_NOSIGPIPE option (macOS specific - prevents SIGPIPE on write to closed socket)
public fn safe_set_nosigpipe(fd: FileDesc, nosigpipe: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, SOL_SOCKET, SO_NOSIGPIPE, if nosigpipe { 1 } else { 0 })
}

/// Set socket send/receive timeout
/// timeout_ms: timeout in milliseconds, 0 to disable
public fn safe_set_socket_timeout(fd: FileDesc, timeout_ms: Int, is_recv: Bool) -> Result<(), OSError> {
    let tv_sec = timeout_ms / 1000;
    let tv_usec = (timeout_ms % 1000) * 1000;

    // struct timeval { time_t tv_sec; suseconds_t tv_usec; }
    // On macOS: 8 + 4 = 12 bytes (but may be padded to 16)
    let mut timeval = [0_u8; 16];

    // Write tv_sec (little-endian Int64)
    timeval[0] = (tv_sec & 0xFF) as UInt8;
    timeval[1] = ((tv_sec >> 8) & 0xFF) as UInt8;
    timeval[2] = ((tv_sec >> 16) & 0xFF) as UInt8;
    timeval[3] = ((tv_sec >> 24) & 0xFF) as UInt8;
    timeval[4] = ((tv_sec >> 32) & 0xFF) as UInt8;
    timeval[5] = ((tv_sec >> 40) & 0xFF) as UInt8;
    timeval[6] = ((tv_sec >> 48) & 0xFF) as UInt8;
    timeval[7] = ((tv_sec >> 56) & 0xFF) as UInt8;

    // Write tv_usec (little-endian Int32 on macOS)
    timeval[8] = (tv_usec & 0xFF) as UInt8;
    timeval[9] = ((tv_usec >> 8) & 0xFF) as UInt8;
    timeval[10] = ((tv_usec >> 16) & 0xFF) as UInt8;
    timeval[11] = ((tv_usec >> 24) & 0xFF) as UInt8;

    let optname = if is_recv { SO_RCVTIMEO } else { SO_SNDTIMEO };
    safe_setsockopt(fd, SOL_SOCKET, optname, timeval.as_ptr() as &unsafe Byte, 16)
}

/// Set SO_BROADCAST option (required for UDP broadcast)
public fn safe_set_broadcast(fd: FileDesc, broadcast: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, SOL_SOCKET, SO_BROADCAST, if broadcast { 1 } else { 0 })
}

/// Set send buffer size
public fn safe_set_send_buffer_size(fd: FileDesc, size: Int) -> Result<(), OSError> {
    safe_setsockopt_int(fd, SOL_SOCKET, SO_SNDBUF, size)
}

/// Set receive buffer size
public fn safe_set_recv_buffer_size(fd: FileDesc, size: Int) -> Result<(), OSError> {
    safe_setsockopt_int(fd, SOL_SOCKET, SO_RCVBUF, size)
}

/// struct ip_mreq for multicast membership
@repr(C)
public type DarwinIpMreq is {
    imr_multiaddr: UInt32,   // Multicast group address (network byte order)
    imr_interface: UInt32,   // Interface address (network byte order), 0 = default
};

/// Join an IPv4 multicast group
///
/// multiaddr: multicast group address (network byte order)
/// interface: local interface address (network byte order), 0 = default
public fn safe_join_multicast_v4(fd: FileDesc, multiaddr: UInt32, interface: UInt32) -> Result<(), OSError> {
    let mreq = DarwinIpMreq {
        imr_multiaddr: multiaddr,
        imr_interface: interface,
    };
    safe_setsockopt(fd, IPPROTO_IP, IP_ADD_MEMBERSHIP,
                    &mreq as &unsafe Byte, 8)  // sizeof(ip_mreq) = 8
}

/// Leave an IPv4 multicast group
public fn safe_leave_multicast_v4(fd: FileDesc, multiaddr: UInt32, interface: UInt32) -> Result<(), OSError> {
    let mreq = DarwinIpMreq {
        imr_multiaddr: multiaddr,
        imr_interface: interface,
    };
    safe_setsockopt(fd, IPPROTO_IP, IP_DROP_MEMBERSHIP,
                    &mreq as &unsafe Byte, 8)
}

/// Set multicast TTL for IPv4
public fn safe_set_multicast_ttl_v4(fd: FileDesc, ttl: Int) -> Result<(), OSError> {
    safe_setsockopt_int(fd, IPPROTO_IP, IP_MULTICAST_TTL, ttl)
}

/// Set multicast loopback for IPv4
public fn safe_set_multicast_loop_v4(fd: FileDesc, enabled: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, IPPROTO_IP, IP_MULTICAST_LOOP, if enabled { 1 } else { 0 })
}

/// Set the IPv4 TOS byte on outbound datagrams (RFC 3168). Low 2 bits
/// are the ECN codepoint QUIC stamps in support of §13.4 / §A.7.
public fn safe_set_ip_tos(fd: FileDesc, tos: Int) -> Result<(), OSError> {
    safe_setsockopt_int(fd, IPPROTO_IP, IP_TOS, tos)
}

/// Ask the kernel to surface IPv4 TOS via recvmsg cmsg — required for
/// inbound ECN processing.
public fn safe_set_ip_recvtos(fd: FileDesc, enable: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, IPPROTO_IP, IP_RECVTOS, if enable { 1 } else { 0 })
}

/// Set the IPv6 Traffic Class on outbound datagrams (RFC 3542).
public fn safe_set_ipv6_tclass(fd: FileDesc, tc: Int) -> Result<(), OSError> {
    safe_setsockopt_int(fd, IPPROTO_IPV6, IPV6_TCLASS, tc)
}

/// Ask the kernel to surface the IPv6 Traffic Class byte via recvmsg
/// cmsg.
public fn safe_set_ipv6_recvtclass(fd: FileDesc, enable: Bool) -> Result<(), OSError> {
    safe_setsockopt_int(fd, IPPROTO_IPV6, IPV6_RECVTCLASS, if enable { 1 } else { 0 })
}

/// Peek at data without consuming it (MSG_PEEK)
public fn safe_peek(fd: FileDesc, buf: &mut [Byte]) -> Result<Int, OSError> {
    safe_recv(fd, buf, MSG_PEEK)
}

/// Receive with MSG_DONTWAIT (non-blocking, even on blocking socket)
public fn safe_recv_nonblock(fd: FileDesc, buf: &mut [Byte]) -> Result<Int, OSError> {
    safe_recv(fd, buf, MSG_DONTWAIT)
}

/// Send with MSG_DONTWAIT (non-blocking, even on blocking socket)
public fn safe_send_nonblock(fd: FileDesc, buf: &[Byte]) -> Result<Int, OSError> {
    safe_send(fd, buf, MSG_DONTWAIT)
}

