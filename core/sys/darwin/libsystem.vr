public const SIGUSR2: Int = 31;

// dlopen flags
public const RTLD_LAZY: Int = 0x1;
public const RTLD_NOW: Int = 0x2;
public const RTLD_LOCAL: Int = 0x4;
public const RTLD_GLOBAL: Int = 0x8;
public const RTLD_NOLOAD: Int = 0x10;
public const RTLD_NODELETE: Int = 0x80;
