public const THREAD_IDENTIFIER_INFO: ThreadFlavor = ThreadFlavor(4);
public const THREAD_EXTENDED_INFO: ThreadFlavor = ThreadFlavor(5);

public const TASK_BASIC_INFO: TaskFlavor = TaskFlavor(5);
