public const THREAD_LATENCY_QOS_POLICY: ThreadPolicyFlavor = ThreadPolicyFlavor(7);
public const THREAD_THROUGHPUT_QOS_POLICY: ThreadPolicyFlavor = ThreadPolicyFlavor(8);

