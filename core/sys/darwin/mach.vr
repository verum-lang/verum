// =============================================================================

public const TH_STATE_RUNNING: Int = 1;
public const TH_STATE_STOPPED: Int = 2;
public const TH_STATE_WAITING: Int = 3;
public const TH_STATE_UNINTERRUPTIBLE: Int = 4;
public const TH_STATE_HALTED: Int = 5;

// =============================================================================
// Thread Flags
// =============================================================================

public const TH_FLAGS_SWAPPED: Int = 0x1;
public const TH_FLAGS_IDLE: Int = 0x2;
public const TH_FLAGS_GLOBAL_FORCED_IDLE: Int = 0x4;

