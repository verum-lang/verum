public const KERN_NOT_IN_SET: KernReturn = KernReturn(12);
public const KERN_NAME_EXISTS: KernReturn = KernReturn(13);
public const KERN_ABORTED: KernReturn = KernReturn(14);
public const KERN_INVALID_NAME: KernReturn = KernReturn(15);
public const KERN_INVALID_TASK: KernReturn = KernReturn(16);
public const KERN_INVALID_RIGHT: KernReturn = KernReturn(17);
public const KERN_INVALID_VALUE: KernReturn = KernReturn(18);
public const KERN_UREFS_OVERFLOW: KernReturn = KernReturn(19);
public const KERN_INVALID_CAPABILITY: KernReturn = KernReturn(20);
public const KERN_RIGHT_EXISTS: KernReturn = KernReturn(21);
public const KERN_INVALID_HOST: KernReturn = KernReturn(22);
public const KERN_MEMORY_PRESENT: KernReturn = KernReturn(23);
public const KERN_MEMORY_DATA_MOVED: KernReturn = KernReturn(24);
public const KERN_MEMORY_RESTART_COPY: KernReturn = KernReturn(25);
public const KERN_INVALID_PROCESSOR_SET: KernReturn = KernReturn(26);
public const KERN_POLICY_LIMIT: KernReturn = KernReturn(27);
public const KERN_INVALID_POLICY: KernReturn = KernReturn(28);
public const KERN_INVALID_OBJECT: KernReturn = KernReturn(29);
public const KERN_ALREADY_WAITING: KernReturn = KernReturn(30);
public const KERN_DEFAULT_SET: KernReturn = KernReturn(31);
public const KERN_EXCEPTION_PROTECTED: KernReturn = KernReturn(32);
