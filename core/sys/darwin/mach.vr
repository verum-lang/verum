public const MACH_RCV_SCATTER_SMALL: MachMsgReturn = MachMsgReturn(0x1000400e);
public const MACH_RCV_INVALID_TRAILER: MachMsgReturn = MachMsgReturn(0x1000400f);
public const MACH_RCV_IN_PROGRESS_TIMED: MachMsgReturn = MachMsgReturn(0x10004011);

// =============================================================================
// Safe Wrapper Functions
// =============================================================================

/// Get current task port
public fn current_task() -> MachPort {
    unsafe { mach_task_self() }
}

/// Get current thread port
public fn current_thread() -> MachPort {
    unsafe { mach_thread_self() }
}

/// Get host port
public fn host_self() -> MachPort {
    unsafe { mach_host_self() }
}

/// Allocate virtual memory (safe wrapper)
public fn safe_vm_allocate(size: VmSize, anywhere: Bool) -> Result<VmAddress, KernReturn> {
    let mut address: VmAddress = VmAddress(0);
    let mut vm_flags: Int = VM_FLAGS_FIXED;
    if anywhere {
        vm_flags = VM_FLAGS_ANYWHERE;
    }
    let kr = unsafe { vm_allocate_ffi(mach_task_self(), &mut address, size, vm_flags) };
    let kr_val = kr as Int;
    if kr_val == 0 {
        Ok(address)
    } else {
        Err(kr)
    }
}

/// Deallocate virtual memory (safe wrapper)
public fn safe_vm_deallocate(address: VmAddress, size: VmSize) -> Result<(), KernReturn> {
    let result = unsafe { vm_deallocate(mach_task_self(), address, size) };
    if result as Int == 0 {
        Result.Ok(())
    } else {
        Result.Err(result)
    }
}

/// Protect virtual memory (safe wrapper)
public fn safe_vm_protect(address: VmAddress, size: VmSize, prot: VmProt) -> Result<(), KernReturn> {
    let result = unsafe { vm_protect(mach_task_self(), address, size, false, prot) };
    if result as Int == 0 {
        Result.Ok(())
    } else {
        Result.Err(result)
    }
}

/// Get high-precision monotonic time in nanoseconds
public fn monotonic_nanos() -> UInt64 {
    static mut timebase_info: MachTimebaseInfo = MachTimebaseInfo { numer: 0, denom: 0 };
    static mut timebase_initialized: Bool = false;

    unsafe {
        if !timebase_initialized {
            mach_timebase_info(&mut timebase_info);
            timebase_initialized = true;
        }

        let ticks = mach_absolute_time();
        (ticks * timebase_info.numer as UInt64) / timebase_info.denom as UInt64
    }
}

/// Create semaphore (safe wrapper)
public fn safe_semaphore_create(initial_value: Int) -> Result<SemaphoreT, KernReturn> {
    let mut sem = SemaphoreT(MachPort(0));
    let result = unsafe {
        semaphore_create(mach_task_self(), &mut sem, SYNC_POLICY_FIFO, initial_value)
    };
    if result as Int == 0 {
        Result.Ok(sem)
    } else {
        Result.Err(result)
    }
}

/// Destroy semaphore (safe wrapper)
public fn safe_semaphore_destroy(sem: SemaphoreT) -> Result<(), KernReturn> {
    let result = unsafe { semaphore_destroy(mach_task_self(), sem) };
    if result as Int == 0 {
        Result.Ok(())
    } else {
        Result.Err(result)
    }
}

/// Signal semaphore (safe wrapper)
public fn safe_semaphore_signal(sem: SemaphoreT) -> Result<(), KernReturn> {
    let result = unsafe { semaphore_signal(sem) };
    if result as Int == 0 {
        Result.Ok(())
    } else {
        Result.Err(result)
    }
}

/// Wait on semaphore (safe wrapper)
public fn safe_semaphore_wait(sem: SemaphoreT) -> Result<(), KernReturn> {
    let result = unsafe { semaphore_wait(sem) };
    if result as Int == 0 {
        Result.Ok(())
    } else {
        Result.Err(result)
    }
}

/// Sleep until deadline (absolute mach time)
public fn sleep_until(deadline: UInt64) -> Result<(), KernReturn> {
    let result = unsafe { mach_wait_until(deadline) };
    if result as Int == 0 {
        Result.Ok(())
    } else {
        Result.Err(result)
    }
}

/// Get Mach error string
public fn error_string(kr: KernReturn) -> Text {
    unsafe {
        let ptr = mach_error_string(kr);
        // Convert C string to Text
        Text.from_cstr(ptr)
    }
}
