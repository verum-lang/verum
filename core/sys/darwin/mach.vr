public const KERN_TERMINATED: KernReturn = KernReturn(37);
public const KERN_LOCK_SET_DESTROYED: KernReturn = KernReturn(38);
public const KERN_LOCK_UNSTABLE: KernReturn = KernReturn(39);
public const KERN_LOCK_OWNED: KernReturn = KernReturn(40);
public const KERN_LOCK_OWNED_SELF: KernReturn = KernReturn(41);
public const KERN_SEMAPHORE_DESTROYED: KernReturn = KernReturn(42);
public const KERN_RPC_SERVER_TERMINATED: KernReturn = KernReturn(43);
public const KERN_RPC_TERMINATE_ORPHAN: KernReturn = KernReturn(44);
public const KERN_RPC_CONTINUE_ORPHAN: KernReturn = KernReturn(45);
public const KERN_NOT_SUPPORTED: KernReturn = KernReturn(46);
public const KERN_NODE_DOWN: KernReturn = KernReturn(47);
public const KERN_NOT_WAITING: KernReturn = KernReturn(48);
public const KERN_OPERATION_TIMED_OUT: KernReturn = KernReturn(49);
public const KERN_CODESIGN_ERROR: KernReturn = KernReturn(50);
public const KERN_POLICY_STATIC: KernReturn = KernReturn(51);
public const KERN_INSUFFICIENT_BUFFER_SIZE: KernReturn = KernReturn(52);

// =============================================================================
// VM Protection Flags
// =============================================================================

public const VM_PROT_NONE: VmProt = VmProt(0x00);
public const VM_PROT_READ: VmProt = VmProt(0x01);
public const VM_PROT_WRITE: VmProt = VmProt(0x02);
public const VM_PROT_EXECUTE: VmProt = VmProt(0x04);
public const VM_PROT_DEFAULT: VmProt = VmProt(0x03);  // READ | WRITE
public const VM_PROT_ALL: VmProt = VmProt(0x07);      // READ | WRITE | EXECUTE
public const VM_PROT_COPY: VmProt = VmProt(0x10);

// =============================================================================
// VM Allocation Flags
// =============================================================================

public const VM_FLAGS_FIXED: Int = 0x0000;
public const VM_FLAGS_ANYWHERE: Int = 0x0001;
public const VM_FLAGS_PURGABLE: Int = 0x0002;
public const VM_FLAGS_RANDOM_ADDR: Int = 0x0008;
public const VM_FLAGS_NO_PMAP_CHECK: Int = 0x0010;
public const VM_FLAGS_OVERWRITE: Int = 0x4000;
public const VM_FLAGS_SUPERPAGE_MASK: Int = 0x70000;
public const VM_FLAGS_SUPERPAGE_NONE: Int = 0x00000;
public const VM_FLAGS_SUPERPAGE_SIZE_2MB: Int = 0x10000;
public const VM_FLAGS_RETURN_DATA_ADDR: Int = 0x100000;
public const VM_FLAGS_RETURN_4K_DATA_ADDR: Int = 0x800000;

// =============================================================================
// VM Inheritance
// =============================================================================

public const VM_INHERIT_SHARE: VmInherit = VmInherit(0);
public const VM_INHERIT_COPY: VmInherit = VmInherit(1);
public const VM_INHERIT_NONE: VmInherit = VmInherit(2);
public const VM_INHERIT_DONATE_COPY: VmInherit = VmInherit(3);
public const VM_INHERIT_DEFAULT: VmInherit = VmInherit(1);

// =============================================================================
// Mach Port Rights
// =============================================================================

public const MACH_PORT_RIGHT_SEND: MachPortRight = MachPortRight(0);
public const MACH_PORT_RIGHT_RECEIVE: MachPortRight = MachPortRight(1);
public const MACH_PORT_RIGHT_SEND_ONCE: MachPortRight = MachPortRight(2);
public const MACH_PORT_RIGHT_PORT_SET: MachPortRight = MachPortRight(3);
public const MACH_PORT_RIGHT_DEAD_NAME: MachPortRight = MachPortRight(4);

// =============================================================================
// Semaphore Policies
// =============================================================================

public const SYNC_POLICY_FIFO: Int = 0x0;
public const SYNC_POLICY_FIXED_PRIORITY: Int = 0x1;
public const SYNC_POLICY_REVERSED: Int = 0x2;
public const SYNC_POLICY_ORDER_MASK: Int = 0x3;
public const SYNC_POLICY_LIFO: Int = 0x2;

