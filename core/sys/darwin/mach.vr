module sys.darwin.mach;
mount core.base.coercion.{IntCoercible};

// =============================================================================
// sys/darwin/mach.vr - Mach kernel interface for macOS
// =============================================================================
// Layer: 0 (Core)
// Dependencies: sys/common, sys/darwin/libsystem
// Platform: macOS (Darwin/XNU)
// =============================================================================
//
// macOS runs on the XNU kernel which combines:
// - Mach microkernel: VM, IPC, threads, scheduling
// - BSD layer: POSIX syscalls, networking, filesystems
//
// This module exposes Mach-specific functionality not available through BSD.
// Key features:
// - Mach ports (IPC)
// - VM operations (vm_allocate, vm_deallocate, vm_protect)
// - Mach semaphores
// - Mach time (high-precision timing)
// - Thread primitives
//
// All calls go through libSystem.B.dylib (stable API).
//
// Spec: docs/architecture/new-arch-spec.md (V-LLSI Bootstrap Kernel)
// =============================================================================

// Re-export MachPort for use by other modules
public mount super.libsystem.{MachPort, MachTimebaseInfo};

// =============================================================================
// Mach FFI Declarations
// =============================================================================

@ffi("libSystem.B.dylib")
extern {
    // =========================================================================
    // Task and Thread Ports
    // =========================================================================

    /// Get current task's Mach port
    fn mach_task_self() -> MachPort;

    /// Get current thread's Mach port
    fn mach_thread_self() -> MachPort;

    /// Get host Mach port
    fn mach_host_self() -> MachPort;

    /// Deallocate Mach port
    fn mach_port_deallocate(task: MachPort, name: MachPort) -> KernReturn;

    /// Allocate Mach port
    fn mach_port_allocate(task: MachPort, right: MachPortRight, name: &mut MachPort) -> KernReturn;

    /// Insert Mach port right
    fn mach_port_insert_right(
        task: MachPort,
        name: MachPort,
        poly: MachPort,
        polyPoly: MachMsgType,
    ) -> KernReturn;

    // =========================================================================
    // Virtual Memory
    // =========================================================================

    /// Allocate virtual memory
    @ffi_name("vm_allocate")
    fn vm_allocate_ffi(
        target_task: MachPort,
        address: &mut VmAddress,
        size: VmSize,
        flags: Int,
    ) -> KernReturn;

    /// Deallocate virtual memory
    fn vm_deallocate(
        target_task: MachPort,
        address: VmAddress,
        size: VmSize,
    ) -> KernReturn;

    /// Protect virtual memory
    fn vm_protect(
        target_task: MachPort,
        address: VmAddress,
        size: VmSize,
        set_maximum: Bool,
        new_protection: VmProt,
    ) -> KernReturn;

    /// Read virtual memory
    fn vm_read(
        target_task: MachPort,
        address: VmAddress,
        size: VmSize,
        data: &mut VmAddress,
        data_cnt: &mut MachMsgTypeNumber,
    ) -> KernReturn;

    /// Write virtual memory
    fn vm_write(
        target_task: MachPort,
        address: VmAddress,
        data: VmAddress,
        data_cnt: MachMsgTypeNumber,
    ) -> KernReturn;

    /// Copy virtual memory
    fn vm_copy(
        target_task: MachPort,
        source_address: VmAddress,
        size: VmSize,
        dest_address: VmAddress,
    ) -> KernReturn;

    /// Map virtual memory
    fn vm_map(
        target_task: MachPort,
        address: &mut VmAddress,
        size: VmSize,
        mask: VmAddress,
        flags: Int,
        object: MemoryObject,
        offset: MemoryObjectOffset,
        copy: Bool,
        cur_protection: VmProt,
        max_protection: VmProt,
        inheritance: VmInherit,
    ) -> KernReturn;

    /// Remap virtual memory
    fn vm_remap(
        target_task: MachPort,
        address: &mut VmAddress,
        size: VmSize,
        mask: VmAddress,
        flags: Int,
        src_task: MachPort,
        src_address: VmAddress,
        copy: Bool,
        cur_protection: &mut VmProt,
        max_protection: &mut VmProt,
        inheritance: VmInherit,
    ) -> KernReturn;

    /// Machine attribute
    fn vm_machine_attribute(
        target_task: MachPort,
        address: VmAddress,
        size: VmSize,
        attribute: VmMachineAttribute,
        value: &mut VmMachineAttributeVal,
    ) -> KernReturn;

    // =========================================================================
    // Mach Time
    // =========================================================================

    /// Get absolute time (high precision)
    fn mach_absolute_time() -> UInt64;

    /// Get time base info
    fn mach_timebase_info(info: &mut MachTimebaseInfo) -> KernReturn;

    /// Wait until absolute time
    fn mach_wait_until(deadline: UInt64) -> KernReturn;

    /// Continuous time (doesn't stop during sleep)
    fn mach_continuous_time() -> UInt64;

    /// Approximate time (faster, less precise)
    fn mach_approximate_time() -> UInt64;

    // =========================================================================
    // Mach Semaphores
    // =========================================================================

    /// Create semaphore
    fn semaphore_create(
        task: MachPort,
        semaphore: &mut SemaphoreT,
        policy: Int,
        value: Int,
    ) -> KernReturn;

    /// Destroy semaphore
    fn semaphore_destroy(task: MachPort, semaphore: SemaphoreT) -> KernReturn;

    /// Signal semaphore
    fn semaphore_signal(semaphore: SemaphoreT) -> KernReturn;

    /// Signal all waiters
    fn semaphore_signal_all(semaphore: SemaphoreT) -> KernReturn;

    /// Wait on semaphore
    fn semaphore_wait(semaphore: SemaphoreT) -> KernReturn;

    /// Timed wait on semaphore
    fn semaphore_timedwait(semaphore: SemaphoreT, wait_time: MachTimespec) -> KernReturn;

    /// Signal and wait atomically
    fn semaphore_timedwait_signal(
        wait_semaphore: SemaphoreT,
        signal_semaphore: SemaphoreT,
        wait_time: MachTimespec,
    ) -> KernReturn;

    // =========================================================================
    // Thread Control
    // =========================================================================

    /// Suspend thread
    fn thread_suspend(target_act: MachPort) -> KernReturn;

    /// Resume thread
    fn thread_resume(target_act: MachPort) -> KernReturn;

    /// Abort thread
    fn thread_abort(target_act: MachPort) -> KernReturn;

    /// Get thread info
    fn thread_info(
        target_act: MachPort,
        flavor: ThreadFlavor,
        thread_info_out: &mut ThreadBasicInfo,
        thread_info_outCnt: &mut MachMsgTypeNumber,
    ) -> KernReturn;

    /// Set thread policy
    fn thread_policy_set(
        thread: MachPort,
        flavor: ThreadPolicyFlavor,
        policy_info: &ThreadPolicyInfo,
        count: MachMsgTypeNumber,
    ) -> KernReturn;

    // =========================================================================
    // Task Control
    // =========================================================================

    /// Suspend task
    fn task_suspend(target_task: MachPort) -> KernReturn;

    /// Resume task
    fn task_resume(target_task: MachPort) -> KernReturn;

    /// Get task info
    fn task_info(
        target_task: MachPort,
        flavor: TaskFlavor,
        task_info_out: &mut TaskBasicInfo,
        task_info_outCnt: &mut MachMsgTypeNumber,
    ) -> KernReturn;

    /// Get task threads
    fn task_threads(
        target_task: MachPort,
        act_list: &mut (&mut MachPort),
        act_listCnt: &mut MachMsgTypeNumber,
    ) -> KernReturn;

    // =========================================================================
    // Host Info
    // =========================================================================

    /// Get host info
    fn host_info(
        host: MachPort,
        flavor: HostFlavor,
        host_info_out: &mut HostBasicInfo,
        host_info_outCnt: &mut MachMsgTypeNumber,
    ) -> KernReturn;

    /// Get host statistics
    fn host_statistics(
        host_priv: MachPort,
        flavor: HostFlavor,
        host_info_out: &mut VmStatistics,
        host_info_outCnt: &mut MachMsgTypeNumber,
    ) -> KernReturn;

    /// Get host page size
    fn host_page_size(host: MachPort, page_size: &mut VmSize) -> KernReturn;

    // =========================================================================
    // Mach Messages
    // =========================================================================

    /// Send Mach message
    fn mach_msg(
        msg: &mut MachMsgHeader,
        option: MachMsgOption,
        send_size: MachMsgSize,
        rcv_size: MachMsgSize,
        rcv_name: MachPort,
        timeout: MachMsgTimeout,
        notify: MachPort,
    ) -> MachMsgReturn;

    // =========================================================================
    // Error Handling
    // =========================================================================

    /// Get Mach error string
    fn mach_error_string(error_value: KernReturn) -> &Byte;
}

// =============================================================================
// Type Definitions
// =============================================================================

/// Kernel return type
public type KernReturn is (Int);

/// VM address type
public type VmAddress is (Int);

// IntCoercible: VmAddress / VmSize wrap Int — coerce in arithmetic /
// comparison contexts (`addr + offset`, `size > 4096`).
implement IntCoercible for VmAddress {}

/// VM size type
public type VmSize is (Int);

implement IntCoercible for VmSize {}

/// VM protection type
public type VmProt is (Int);

/// VM inheritance type
type VmInherit is (Int);

/// Memory object type
type MemoryObject is (MachPort);

/// Memory object offset
type MemoryObjectOffset is (UInt64);

/// VM machine attribute
type VmMachineAttribute is (Int);

/// VM machine attribute value
type VmMachineAttributeVal is (Int);

/// Semaphore type
public type SemaphoreT is (MachPort);

/// Mach message type number
type MachMsgTypeNumber is (UInt32);

/// Mach port right
type MachPortRight is (UInt32);

/// Mach message type
type MachMsgType is (UInt32);

/// Mach message option
type MachMsgOption is (Int);

/// Mach message size
type MachMsgSize is (UInt32);

/// Mach message timeout
type MachMsgTimeout is (UInt32);

/// Mach message return
type MachMsgReturn is (Int);

/// Thread flavor
type ThreadFlavor is (Int);

/// Thread policy flavor
type ThreadPolicyFlavor is (Int);

/// Task flavor
type TaskFlavor is (Int);

/// Host flavor
type HostFlavor is (Int);

/// Mach timespec
type MachTimespec is {
    tv_sec: UInt32,
    tv_nsec: Int,
};

/// Mach message header
public type MachMsgHeader is {
    msgh_bits: MachMsgBits,
    msgh_size: MachMsgSize,
    msgh_remote_port: MachPort,
    msgh_local_port: MachPort,
    msgh_voucher_port: MachPort,
    msgh_id: Int,
};

type MachMsgBits is (UInt32);

/// Thread basic info
type ThreadBasicInfo is {
    user_time: TimeValue,
    system_time: TimeValue,
    cpu_usage: Int,
    policy: Int,
    run_state: Int,
    flags: Int,
    suspend_count: Int,
    sleep_time: Int,
};

/// Time value
type TimeValue is {
    seconds: Int,
    microseconds: Int,
};

/// Thread policy info (generic)
type ThreadPolicyInfo is {
    data: [Int; 16],
};

/// Task basic info
type TaskBasicInfo is {
    suspend_count: Int,
    virtual_size: VmSize,
    resident_size: VmSize,
    user_time: TimeValue,
    system_time: TimeValue,
    policy: Int,
};

/// Host basic info
type HostBasicInfo is {
    max_cpus: Int,
    avail_cpus: Int,
    memory_size: UInt32,
    cpu_type: Int,
    cpu_subtype: Int,
    cpu_threadtype: Int,
    physical_cpu: Int,
    physical_cpu_max: Int,
    logical_cpu: Int,
    logical_cpu_max: Int,
    max_mem: UInt64,
};

/// VM statistics
type VmStatistics is {
    free_count: UInt32,
    active_count: UInt32,
    inactive_count: UInt32,
    wire_count: UInt32,
    zero_fill_count: UInt32,
    reactivations: UInt32,
    pageins: UInt32,
    pageouts: UInt32,
    faults: UInt32,
    cow_faults: UInt32,
    lookups: UInt32,
    hits: UInt32,
    purgeable_count: UInt32,
    purges: UInt32,
    speculative_count: UInt32,
};

