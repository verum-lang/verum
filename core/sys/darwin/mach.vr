// Kernel Return Codes
// =============================================================================

public const KERN_SUCCESS: KernReturn = KernReturn(0);
public const KERN_INVALID_ADDRESS: KernReturn = KernReturn(1);
public const KERN_PROTECTION_FAILURE: KernReturn = KernReturn(2);
