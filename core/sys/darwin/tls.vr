module sys.darwin.tls;

// =============================================================================
// sys/darwin/tls.vr - macOS Thread-Local Storage and Context System
// =============================================================================
// Layer: 0 (Core)
// Dependencies: sys/darwin/libsystem, sys/common
// Platform: macOS (x86_64, arm64)
// =============================================================================
//
// This module provides TLS-based context storage for the V-LLSI bootstrap
// kernel on macOS. Unlike Linux which uses arch_prctl(ARCH_SET_FS) for direct
// segment register access, macOS uses pthread_key_create/pthread_getspecific
// for TLS.
//
// The context system provides:
// - Fixed-size context slot array for O(1) lookup
// - Thread-safe context propagation
// - Stack-based context scoping (push/pop)
//
// Spec: docs/architecture/new-arch-spec.md Section 5.4, Appendix F.3.2.2
// =============================================================================

mount sys.common.OSError;
mount super.libsystem.{
    PthreadKey,
    pthread_key_create,
    pthread_key_delete,
    pthread_getspecific,
    pthread_setspecific,
    pthread_self,
    safe_getpid,
    safe_gettid,
    mmap_ffi,
    munmap,
    PROT_READ, PROT_WRITE, PROT_NONE,
    MAP_PRIVATE, MAP_ANON,
    errno,
};

// =============================================================================
// Constants
// =============================================================================

/// Maximum number of context slots (matches Linux implementation)
public const MAX_CONTEXT_SLOTS: Int = 256;

/// Size of the context stack per slot
public const CONTEXT_STACK_DEPTH: Int = 8;

/// Thread Control Block magic number for validation
public const TCB_MAGIC: UInt64 = 0x5645_5255_4D5F_5443;  // "VERUM_TC" in ASCII

/// Default stack size for threads (1MB)
public const DEFAULT_STACK_SIZE: Int = 1024 * 1024;

/// Guard page size (4KB)
public const GUARD_PAGE_SIZE: Int = 4096;

// =============================================================================
// TLS Error Type
// =============================================================================

/// TLS operation error
public type SysTlsError is
    | NotInitialized
    | AlreadyInitialized
    | AllocationFailed { code: Int }
    | InvalidSlot { slot: Int }
    | StackOverflow { slot: Int }
    | StackUnderflow { slot: Int }
    | InvalidTcb
    | PthreadError { code: Int }
    ;

/// Alias for convenience
public type TlsError is SysTlsError;

implement SysTlsError {
    public fn message(&self) -> Text {
        match self {
            NotInitialized => "TLS not initialized for this thread",
            AlreadyInitialized => "TLS already initialized for this thread",
            AllocationFailed { code } => f"Failed to allocate TLS memory (code={code})",
            InvalidSlot { slot } => f"Invalid context slot index: {slot}",
            StackOverflow { slot } => f"Context stack overflow at slot {slot}",
            StackUnderflow { slot } => f"Context stack underflow at slot {slot}",
            InvalidTcb => "Invalid or corrupted TCB",
            PthreadError { code } => f"pthread TLS operation failed (code={code})",
        }
    }

    public fn is_retryable(&self) -> Bool {
        false
    }
}

// =============================================================================
// Thread Control Block
// =============================================================================

/// Per-slot context entry with stack support
public type ContextEntry is {
    /// Current context value (opaque pointer)
    value: &unsafe Byte,
    /// Stack for nested contexts
    stack: [&unsafe Byte; 8],  // CONTEXT_STACK_DEPTH
    /// Current stack depth
    depth: Int,
};

/// Context slots array
public type ContextSlots is {
    /// Context entries indexed by slot
    slots: [ContextEntry; 256],  // MAX_CONTEXT_SLOTS
};

/// Thread Control Block (TCB)
///
/// This structure is allocated per-thread and contains all thread-local
/// state needed by the V-LLSI runtime.
public type ThreadControlBlock is {
    /// Magic number for validation (TCB_MAGIC)
    magic: UInt64,

    /// Thread ID (cached for fast access)
    tid: UInt64,

    /// Process ID (cached)
    pid: Int,

    /// Context slots for dependency injection
    context_slots: ContextSlots,

    /// Errno value for this thread (backup, usually use libSystem's)
    errno_value: Int,

    /// Stack canary for overflow detection
    stack_canary: UInt64,

    /// User data pointer
    user_data: &unsafe Byte,
};

// =============================================================================
// Global TLS Key
// =============================================================================

/// Global pthread key for TCB storage (initialized once)
static mut TLS_KEY: PthreadKey = PthreadKey(0);

/// Flag indicating if TLS key has been created
static mut TLS_KEY_INITIALIZED: Bool = false;

/// Destructor for TCB when thread exits
fn tcb_destructor(value: &unsafe Byte) {
    if value as Int != 0 {
        // Free the TCB memory
        let tcb = value as &mut ThreadControlBlock;

        // Clear magic to prevent use-after-free
        tcb.magic = 0;

        // Calculate allocation size (guard + TCB aligned)
        let tcb_size = ThreadControlBlock.size;
        let total_size = GUARD_PAGE_SIZE + tcb_size;

        // Unmap the entire allocation (guard page + TCB)
        let base_addr = (value as Int) - GUARD_PAGE_SIZE;
        unsafe { munmap(base_addr, total_size) };
    }
}

// =============================================================================
// TLS Initialization
// =============================================================================

/// Initialize the global TLS key (call once per process)
public fn init_tls_key() -> Result<(), SysTlsError> {
    unsafe {
        if TLS_KEY_INITIALIZED {
            return Ok(());
        }

        let result = pthread_key_create(&mut TLS_KEY, tcb_destructor);
        if result != 0 {
            return Err(PthreadError { code: result });
        }

        TLS_KEY_INITIALIZED = true;
        Ok(())
    }
}

/// Initialize TLS for the main thread.
///
/// Must be called once at program startup before any context operations.
public fn init_main_thread_tls() -> Result<&mut ThreadControlBlock, SysTlsError> {
    // Ensure TLS key is created
    init_tls_key()?;

    // Check if already initialized
    let existing = get_current_tcb_raw();
    if existing as Int != 0 {
        return Err(AlreadyInitialized);
    }

    // Create TCB for main thread
    create_thread_tls()
}

/// Create TLS for a new thread.
///
/// Called automatically for threads created via spawn, or manually
/// for threads created by other means.
public fn create_thread_tls() -> Result<&mut ThreadControlBlock, SysTlsError> {
    // Ensure TLS key exists
    init_tls_key()?;

    // Allocate TCB with guard page
    let tcb_size = ThreadControlBlock.size;
    let total_size = GUARD_PAGE_SIZE + tcb_size;

    // Allocate memory (guard page + TCB)
    let base = unsafe {
        mmap_ffi(0, total_size, PROT_READ | PROT_WRITE, MAP_PRIVATE | MAP_ANON, -1, 0)
    };

    if base == -1 {
        return Err(AllocationFailed { code: errno() });
    }

    // Make guard page inaccessible
    unsafe {
        let guard_result = super.libsystem.mprotect(base, GUARD_PAGE_SIZE, PROT_NONE);
        if guard_result != 0 {
            munmap(base, total_size);
            return Err(AllocationFailed { code: errno() });
        }
    };

    // TCB is after the guard page
    let tcb_addr = base + GUARD_PAGE_SIZE;
    let tcb = tcb_addr as &mut ThreadControlBlock;

    // Initialize TCB
    tcb.magic = TCB_MAGIC;
    tcb.tid = safe_gettid();
    tcb.pid = safe_getpid();
    tcb.errno_value = 0;
    tcb.stack_canary = generate_stack_canary();
    tcb.user_data = 0 as &unsafe Byte;

    // Initialize all context slots
    for i in 0..MAX_CONTEXT_SLOTS {
        tcb.context_slots.slots[i] = ContextEntry {
            value: 0 as &unsafe Byte,
            stack: [0 as &unsafe Byte; 8],
            depth: 0,
        };
    }

    // Store TCB in pthread TLS
    let set_result = unsafe { pthread_setspecific(TLS_KEY, tcb_addr as &unsafe Byte) };
    if set_result != 0 {
        unsafe { munmap(base, total_size) };
        return Err(PthreadError { code: set_result });
    }

    Ok(tcb)
}

/// Clean up TLS for the current thread.
public fn cleanup_thread_tls() -> Result<(), SysTlsError> {
    let tcb = get_current_tcb_raw();
    if tcb as Int == 0 {
        return Ok(());  // Nothing to clean up
    }

    // Clear the TLS slot (destructor will free memory)
    unsafe { pthread_setspecific(TLS_KEY, 0 as &unsafe Byte) };

    // Manually call destructor since setting to null won't trigger it
    tcb_destructor(tcb as &unsafe Byte);

    Ok(())
}

// =============================================================================
// TCB Access
// =============================================================================

/// Get raw TCB pointer (may be null)
fn get_current_tcb_raw() -> &mut ThreadControlBlock {
    unsafe {
        if !TLS_KEY_INITIALIZED {
            return 0 as &mut ThreadControlBlock;
        }
        pthread_getspecific(TLS_KEY) as &mut ThreadControlBlock
    }
}

/// Get the current thread's TCB.
///
/// Returns None if TLS is not initialized for this thread.
public fn get_current_tcb() -> Maybe<&mut ThreadControlBlock> {
    let tcb = get_current_tcb_raw();
    if tcb as Int == 0 {
        None
    } else if tcb.magic != TCB_MAGIC {
        None  // Corrupted TCB
    } else {
        Some(tcb)
    }
}

/// Get context slots for the current thread.
public fn get_context_slots() -> Maybe<&mut ContextSlots> {
    match get_current_tcb() {
        Some(tcb) => Some(&mut tcb.context_slots),
        None => None,
    }
}

/// Set context slots for the current thread.
public fn set_context_slots(slots: ContextSlots) -> Result<(), SysTlsError> {
    match get_current_tcb() {
        Some(tcb) => {
            tcb.context_slots = slots;
            Ok(())
        }
        None => Err(NotInitialized),
    }
}

/// Get errno for current thread.
public fn get_errno() -> Int {
    // Use libSystem's errno which is thread-local
    super.libsystem.errno()
}

/// Set errno for current thread.
public fn set_errno(err: Int) {
    super.libsystem.set_errno(err);
}

/// Get cached thread ID (fast path).
public fn get_tid_fast() -> Maybe<UInt64> {
    match get_current_tcb() {
        Some(tcb) => Some(tcb.tid),
        None => None,
    }
}

/// Check if stack canary is intact.
public fn check_stack_guard() -> Bool {
    match get_current_tcb() {
        Some(tcb) => tcb.stack_canary != 0,  // Basic check
        None => true,  // No TCB = no canary to check
    }
}

// =============================================================================
// Context Slot Operations
// =============================================================================

/// Get a context value from a slot.
public fn ctx_get(slot: Int) -> Maybe<&unsafe Byte> {
    if slot < 0 || slot >= MAX_CONTEXT_SLOTS {
        return None;
    }

    match get_context_slots() {
        Some(slots) => {
            let entry = &slots.slots[slot];
            if entry.value as Int == 0 {
                None
            } else {
                Some(entry.value)
            }
        }
        None => None,
    }
}

/// Get a mutable context value from a slot.
///
/// Returns the same raw pointer as ctx_get - the caller is responsible
/// for ensuring exclusive access when modifying the value.
public fn ctx_get_mut(slot: Int) -> Maybe<&unsafe Byte> {
    ctx_get(slot)
}

/// Set a context value in a slot.
public fn ctx_set(slot: Int, value: &unsafe Byte) -> Result<(), SysTlsError> {
    if slot < 0 || slot >= MAX_CONTEXT_SLOTS {
        return Err(InvalidSlot { slot: slot });
    }

    match get_context_slots() {
        Some(slots) => {
            slots.slots[slot].value = value;
            Ok(())
        }
        None => Err(NotInitialized),
    }
}

/// Clear a context slot.
public fn ctx_clear(slot: Int) -> Result<(), SysTlsError> {
    ctx_set(slot, 0 as &unsafe Byte)
}

/// Push a new context value onto a slot's stack.
///
/// The previous value is saved and can be restored with ctx_pop.
public fn ctx_push(slot: Int, value: &unsafe Byte) -> Result<(), SysTlsError> {
    if slot < 0 || slot >= MAX_CONTEXT_SLOTS {
        return Err(InvalidSlot { slot: slot });
    }

    match get_context_slots() {
        Some(slots) => {
            let entry = &mut slots.slots[slot];
            if entry.depth >= CONTEXT_STACK_DEPTH {
                let slot_idx = slot;
                return Err(SysTlsError.StackOverflow { slot: slot_idx });
            }

            // Save current value to stack
            entry.stack[entry.depth] = entry.value;
            entry.depth += 1;

            // Set new value
            entry.value = value;
            Ok(())
        }
        None => Err(NotInitialized),
    }
}

/// Pop a context value from a slot's stack.
///
/// Restores the previous value that was saved by ctx_push.
public fn ctx_pop(slot: Int) -> Result<&unsafe Byte, SysTlsError> {
    if slot < 0 || slot >= MAX_CONTEXT_SLOTS {
        return Err(InvalidSlot { slot: slot });
    }

    match get_context_slots() {
        Some(slots) => {
            let entry = &mut slots.slots[slot];
            if entry.depth == 0 {
                return Err(StackUnderflow { slot: slot });
            }

            // Get popped value
            let popped = entry.value;

            // Restore previous value
            entry.depth -= 1;
            entry.value = entry.stack[entry.depth];
            entry.stack[entry.depth] = 0 as &unsafe Byte;

            Ok(popped)
        }
        None => Err(NotInitialized),
    }
}

/// Get the current stack depth for a context slot.
public fn ctx_depth(slot: Int) -> Maybe<Int> {
    if slot < 0 || slot >= MAX_CONTEXT_SLOTS {
        return None;
    }

    match get_context_slots() {
        Some(slots) => Some(slots.slots[slot].depth),
        None => None,
    }
}

// =============================================================================
// Utility Functions
// =============================================================================

/// Generate a random stack canary value.
fn generate_stack_canary() -> UInt64 {
    let mut buf: [Byte; 8] = [0; 8];
    unsafe { super.libsystem.arc4random_buf(&mut buf as &unsafe Byte, 8) };

    // Convert bytes to UInt64
    let mut canary: UInt64 = 0;
    for i in 0..8 {
        canary |= (buf[i] as UInt64) << (i * 8);
    }
    canary
}

/// Check if TLS is initialized for the current thread.
public fn is_tls_initialized() -> Bool {
    match get_current_tcb() {
        Some(_) => true,
        None => false,
    }
}

/// Get user data pointer from TCB.
public fn get_user_data() -> Maybe<&unsafe Byte> {
    match get_current_tcb() {
        Some(tcb) => Some(tcb.user_data),
        None => None,
    }
}

/// Set user data pointer in TCB.
public fn set_user_data(data: &unsafe Byte) -> Result<(), SysTlsError> {
    match get_current_tcb() {
        Some(tcb) => {
            tcb.user_data = data;
            Ok(())
        }
        None => Err(NotInitialized),
    }
}
