// =============================================================================
// Cross-platform utilities
// =============================================================================

/// Get number of CPU cores (platform-independent).
/// Delegates to the core.intrinsics.runtime.time intrinsic.
public fn num_cpus() -> Int {
    core.intrinsics.num_cpus()
}

/// Get monotonic time in nanoseconds (platform-independent).
public fn monotonic_nanos() -> UInt64 {
    monotonic_time_ns()
}

/// Get monotonic time in milliseconds (platform-independent).
public fn monotonic_millis() -> UInt64 {
    monotonic_time_ns() / 1_000_000
}

/// Get page size (platform-independent)
public fn page_size() -> Int {
    @cfg(target_os = "linux")
    { return 4096; }  // Standard Linux page size

    @cfg(target_os = "macos")
    { return darwin.libsystem.getpagesize(); }

    // Fallback for all other platforms
    4096
}

/// Get monotonic time in nanoseconds (platform-independent)
public fn monotonic_time_ns() -> UInt64 {
    @cfg(target_os = "linux")
    {
        let mut ts = linux.syscall.Timespec { tv_sec: 0, tv_nsec: 0 };
        linux.syscall.clock_gettime(1, &mut ts);  // CLOCK_MONOTONIC = 1
        return (ts.tv_sec as UInt64) * 1_000_000_000 + (ts.tv_nsec as UInt64);
    }

    @cfg(target_os = "macos")
    { return darwin.time.monotonic_nanos(); }

    // Fallback
    0 as UInt64
}
