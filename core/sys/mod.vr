module sys;

// =============================================================================
// sys/mod.vr - System-level primitives module
// =============================================================================
// Layer: 0 (Core)
// Dependencies: None
// =============================================================================
//
// This module provides low-level system interface primitives for the
// V-LLSI (Verum Low-Level System Interface) bootstrap kernel.
//
// Platform-specific implementations:
// - linux/  - Linux direct syscalls (x86_64 + aarch64; see linux/arch.vr
//             for per-architecture syscall numbers)
// - darwin/ - macOS libSystem.B.dylib FFI (stable API)
// - windows/- Windows kernel32/ntdll bindings (IAT imports)
//
// IMPORTANT: macOS does NOT support stable syscalls. All Darwin system
// calls go through libSystem FFI. See docs/architecture/new-arch-spec.md
// Section 5.4 for details.
//
// Spec: docs/architecture/new-arch-spec.md (V-LLSI Bootstrap Kernel)
// =============================================================================

// Export common types
public module common;

// Export runtime initialization module
public module init;

// Export unified I/O engine interface
public module io_engine;

// Export raw syscall intrinsics (platform-independent bridge)
public module raw;          // Raw OS intrinsic declarations
public module file_ops;     // File operations (pure Verum)
public module time_ops;     // Time operations (pure Verum)
public module net_ops;      // TCP/UDP operations (pure Verum)
public module context_ops;  // Context system & TLS (pure Verum)
public module process_ops;  // Process management (pure Verum)
public module process_native; // Native pipe+fork+exec (no C runtime)
public module fs_watch;       // Native FS watch (kqueue/inotify/RDCW)
public module locking;      // Byte-range advisory file locking (SQLite Gap 1)
public module durability;   // Crash-safe persistence primitives (SQLite Gap 2)

// Export low-level hardware interface modules
public module bitfield;   // Bitfield manipulation support
public module mmio;       // Memory-mapped I/O and volatile access
public module interrupt;  // Interrupt handling infrastructure

// Embedded/bare-metal support (no heap, no threads, no async)
@cfg(runtime = "embedded")
public module embedded;   // Stack allocator, ring buffer, panic handler

// No-runtime mode (async→sync stubs, no-op mutex)
@cfg(runtime = "none")
public module no_runtime;
@cfg(runtime = "embedded")
public module no_runtime;

// Platform-specific modules
@cfg(target_os = "linux")
public module linux;

@cfg(target_os = "macos")
public module darwin;

@cfg(target_os = "windows")
public module windows;

// C-ABI integer type aliases for FFI declarations — `c_char`,
// `c_int`, `c_long`, etc. that platform-conditional compile to
// the native widths. Pre-fix the file shipped but had no
// umbrella declaration; downstream FFI mounts (`mount
// core.sys.cabi.c_int;`) worked via direct file lookup but the
// namespace was invisible.
public module cabi;

// POSIX-style signal handling primitives — sigaction wrappers,
// SIGINT / SIGTERM handlers, the self-pipe pattern that
// `core.signal` (the async wrapper) sits on top of. Reachable
// before via direct file mount; this declaration restores
// namespace visibility under `core.sys.*`.
public module signal;

