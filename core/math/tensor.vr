// =============================================================================
// tensor.vr - N-Dimensional Tensor System
// =============================================================================
// Layer: 4 (Tensor)
//

// Provides N-dimensional array operations with hardware-aware dispatch:
// - Static and dynamic shape tensors
// - Element-wise, reduction, and shape operations
// - VBC opcode integration for CPU/GPU dispatch
// - CBGR-compatible memory management
//

// # Design Philosophy
//

// Two tensor variants serve different use cases:
// - `Tensor<T, Shape>`: Compile-time shape verification (faster, safer)
// - `DynTensor<T>`: Runtime shape flexibility (model inputs, dynamic operations)
//

// All operations route through VBC opcodes, enabling:
// - Interpreter mode: SIMD-optimized kernels (AVX2/NEON)
// - JIT/AOT mode: MLIR linalg dialect -> LLVM vectorization
//

// # Context System Integration
//

// Operations use Verum's context system for:
// - ComputeDevice: CPU/GPU placement
// - Random: PRNG for random tensors
//

// Spec: docs/architecture/math-spec.md Part V (L4)
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.math.tensor;

mount core.base.coercion.{IntCoercible, TensorLike, Indexable};
mount super.linalg.Numeric;
mount super.elementary.{sqrt, exp, log, sin, cos, abs};
mount super.random.{RandomKey};
mount super.gpu.{ComputeDevice, DeviceId, DeviceInfo};

// =============================================================================
// Data Types
// =============================================================================

// Data type for tensor elements
public type DType is
    | F64          // 64-bit floating-point (default Float)
    | F32          // 32-bit floating-point
    | F16          // 16-bit floating-point (half)
    | BF16         // Brain float 16
    | I64          // 64-bit signed integer
    | I32          // 32-bit signed integer
    | I16          // 16-bit signed integer
    | I8           // 8-bit signed integer
    | U64          // 64-bit unsigned integer
    | U32          // 32-bit unsigned integer
    | U16          // 16-bit unsigned integer
    | U8           // 8-bit unsigned integer
    | Bool         // Boolean
    | Complex64    // Complex with f32 components
    | Complex128;  // Complex with f64 components

implement DType {
    // Size in bytes
    public fn size_bytes(&self) -> USize {
        match self {
            DType.F64 | DType.I64 | DType.U64 | DType.Complex64 => 8,
            DType.F32 | DType.I32 | DType.U32 => 4,
            DType.F16 | DType.BF16 | DType.I16 | DType.U16 => 2,
            DType.I8 | DType.U8 | DType.Bool => 1,
            DType.Complex128 => 16,
        }
    }

    // Check if floating-point type
    public fn is_float(&self) -> Bool {
        match self {
            DType.F64 | DType.F32 | DType.F16 | DType.BF16 => true,
            _ => false,
        }
    }

    // Check if complex type
    public fn is_complex(&self) -> Bool {
        match self {
            DType.Complex64 | DType.Complex128 => true,
            _ => false,
        }
    }
}

// =============================================================================
// Shape and TensorLayout
// =============================================================================

// Memory layout for tensor storage
public type TensorLayout is
    | RowMajor        // C-style contiguous (default)
    | ColumnMajor     // Fortran-style
    | Strided(List<ISize>);  // Custom strides

/// Public alias — short canonical name.
public type Layout is TensorLayout;

implement TensorLayout {
    // Compute strides for given shape
    public fn compute_strides(&self, shape: &[USize]) -> List<ISize> {
        match self {
            TensorLayout.RowMajor => {
                let n = shape.len();
                let mut strides = List.with_capacity(n);
                let mut stride: ISize = 1;
                for i in (0..n).rev() {
                    strides.insert(0, stride);
                    stride *= shape[i] as ISize;
                }
                strides
            }
            TensorLayout.ColumnMajor => {
                let n = shape.len();
                let mut strides = List.with_capacity(n);
                let mut stride: ISize = 1;
                for i in 0..n {
                    strides.push(stride);
                    stride *= shape[i] as ISize;
                }
                strides
            }
            TensorLayout.Strided(s) => s.clone(),
        }
    }
}

// Device placement
public type Device is
    | CPU
    | GPU(USize);  // GPU device index

implement Device {
    // Get current default device from context
    public fn current() -> Self using [ComputeDevice] {
        ComputeDevice.device()
    }
}

// =============================================================================
// Tensor Storage
// =============================================================================

// Low-level tensor data reference (internal use)
//

// TensorHandle separates logical identity from physical storage:
// - Copy-on-write semantics
// - CBGR generation tracking for safety
// - Device-agnostic interface
public type TensorHandle is {
    id: U64,                    // Unique ID for CBGR tracking
    dtype: DType,
    shape: List<USize>,
    strides: List<ISize>,
    device: Device,
    storage: TensorStorage,
};

// Storage backend
type TensorStorage is
    | Owned(RawPtr, USize)           // Owned memory (ptr, size)
    | View(Heap<TensorHandle>, USize)  // View with offset
    | External(RawPtr, USize);         // FFI memory

implement TensorHandle {
    // Allocate new handle on device
    fn allocate(dtype: DType, shape: &[USize], device: Device) -> Self {
        let numel: USize = shape.iter().product();
        let size = numel * dtype.size_bytes();
        let layout = TensorLayout.RowMajor;
        let strides = layout.compute_strides(shape);

        TensorHandle {
            id: @vbc(MEM_NEW_ID),
            dtype,
            shape: List.from(shape),
            strides,
            device,
            storage: @vbc(MEM_ALLOC_TENSOR, size, device),
        }
    }

    // Total element count
    fn numel(&self) -> USize {
        self.shape.iter().product()
    }

    // Number of dimensions
    fn rank(&self) -> USize {
        self.shape.len()
    }

    // Check if contiguous (row-major)
    fn is_contiguous(&self) -> Bool {
        let expected = TensorLayout.RowMajor.compute_strides(&self.shape);
        self.strides == expected
    }
}

// =============================================================================
// Binary Operations Enum
// =============================================================================

// Binary operation type
type BinaryOp is
    | Add | Sub | Mul | Div
    | Pow | Max | Min
    | Eq | Ne | Lt | Le | Gt | Ge;

// Unary operation type
type UnaryOp is
    | Neg | Abs | Sign
    | Exp | Exp2 | Expm1
    | Log | Log2 | Log10 | Log1p
    | Sqrt | Rsqrt | Square
    | Sin | Cos | Tan
    | Asin | Acos | Atan
    | Sinh | Cosh | Tanh
    | Asinh | Acosh | Atanh
    | Ceil | Floor | Round | Trunc
    | Erf | Erfc
    | Relu | Sigmoid | Gelu | Silu;

// Reduction operation type
type ReduceOp is
    | Sum | Mean | Prod
    | Max | Min
    | ArgMax | ArgMin
    | All | Any;

// =============================================================================
// Static Tensor (Compile-time Shape Verification)
// =============================================================================

// Tensor with compile-time shape verification
//

// Shape is encoded as meta parameter, enabling:
// - Dimension mismatch detection at compile time
// - Automatic shape inference for operations
// - Zero-cost shape checks (no runtime overhead)
//

// Example:
// ```verum
// let a: Tensor<Float, [2, 3]> = Tensor.zeros();
// let b: Tensor<Float, [3, 4]> = Tensor.zeros();
// let c: Tensor<Float, [2, 4]> = matmul_static(&a, &b); // Shape inferred
// ```
// NOTE: Static Tensor<T, meta Shape> requires const generics (meta generic params)
// which are not yet supported by the parser. Using DynTensor<T> for all tensor
// operations until const generics are implemented.
//

// Future syntax:
//  public type Tensor<T: Numeric, meta Shape: [USize]> is { data: TensorHandle };
//  implement<T: Numeric, meta S: [USize]> Tensor<T, S> { ... }

// Temporary alias: Tensor<T> is DynTensor<T> until const generics are implemented
public type Tensor<T: Numeric> is DynTensor<T>;

// =============================================================================
// Dynamic Tensor (Runtime Shape)
// =============================================================================

// Runtime-shaped tensor
//

// Use when shape depends on runtime values:
// - Variable batch sizes
// - Data-dependent shapes (e.g., nonzero indices)
// - Framework interop (PyTorch, ONNX import)
//

// For known shapes, prefer Tensor<T, Shape> for compile-time verification.
public type DynTensor<T: Numeric> is {
    data: TensorHandle,
    shape: List<USize>,
};

// TensorLike: DynTensor is the canonical tensor-shaped value;
// IntCoercible: index ops on DynTensor produce Int that should
// coerce against scalar Int contexts;
// Indexable: `tensor[i]` integer indexing.
implement<T: Numeric> TensorLike for DynTensor<T> {}
implement<T: Numeric> IntCoercible for DynTensor<T> {}
implement<T: Numeric> Indexable for DynTensor<T> {}

// Semantic alias for explicit naming
public type RuntimeShapedTensor<T: Numeric> is DynTensor<T>;

implement<T: Numeric> DynTensor<T> {
    // ---------------------------------------------------------------------
    // Static constructors — mirror the module-level `zeros`/`ones`/`full`
    // functions so that user code can write `Tensor.zeros([N])` / `.ones`
    // / `.full` directly. Without these, `Tensor.zeros(...)` fails with
    // "no method named `zeros` found for type `DynTensor<T>`" because
    // the module-level functions aren't accessible via dotted-type
    // dispatch.
    // ---------------------------------------------------------------------

    // Create tensor filled with zeros.
    public fn zeros(shape: &[USize]) -> DynTensor<T>
        using [ComputeDevice]
    {
        let data = TensorHandle.allocate(dtype_of<T>(), shape, ComputeDevice.device_type());
        @vbc(TENSOR_FILL, data, T.zero());
        DynTensor { data, shape: List.from(shape) }
    }

    // Create tensor filled with ones.
    public fn ones(shape: &[USize]) -> DynTensor<T>
        using [ComputeDevice]
    {
        let data = TensorHandle.allocate(dtype_of<T>(), shape, ComputeDevice.device_type());
        @vbc(TENSOR_FILL, data, T.one());
        DynTensor { data, shape: List.from(shape) }
    }

    // Create tensor filled with a given value.
    public fn full(shape: &[USize], value: T) -> DynTensor<T>
        using [ComputeDevice]
    {
        let data = TensorHandle.allocate(dtype_of<T>(), shape, ComputeDevice.device_type());
        @vbc(TENSOR_FILL, data, value);
        DynTensor { data, shape: List.from(shape) }
    }

    // Create tensor with the same shape as another, filled with zeros.
    public fn zeros_like(x: &DynTensor<T>) -> DynTensor<T> {
        let data = TensorHandle.allocate(dtype_of<T>(), &x.shape, x.device());
        @vbc(TENSOR_FILL, data, T.zero());
        DynTensor { data, shape: x.shape.clone() }
    }

    // Create range tensor [start, end) with step.
    public fn arange(start: T, end: T, step: T) -> DynTensor<T>
        using [ComputeDevice]
    {
        @vbc(TENSOR_ARANGE, start, end, step, ComputeDevice.device())
    }

    // Create linearly spaced tensor of `num` values from start to end.
    public fn linspace(start: T, end: T, num: USize) -> DynTensor<T>
        using [ComputeDevice]
    {
        @vbc(TENSOR_LINSPACE, start, end, num, ComputeDevice.device())
    }

    // Create n×n identity matrix.
    public fn eye(n: USize) -> DynTensor<T>
        using [ComputeDevice]
    {
        @vbc(TENSOR_EYE, n, ComputeDevice.device())
    }

    // Create n×n identity matrix (alias for eye).
    public fn identity(n: USize) -> DynTensor<T>
        using [ComputeDevice]
    {
        @vbc(TENSOR_EYE, n, ComputeDevice.device())
    }

    // Create tensor from a flat data slice with the given shape.
    public fn from_slice(data: &[T], shape: &[USize]) -> DynTensor<T>
        using [ComputeDevice]
    {
        let expected_numel: USize = shape.iter().product();
        assert(data.len() == expected_numel, "data length must match shape");
        @vbc(TENSOR_FROM_DATA, data, shape, ComputeDevice.device())
    }

    // Create random tensor from U[0, 1).
    public fn rand(shape: &[USize]) -> DynTensor<T>
        using [Random, ComputeDevice]
    {
        @vbc(TENSOR_RAND, shape, Random.int(2147483647), ComputeDevice.device())
    }

    // Create random tensor from N(0, 1).
    public fn randn(shape: &[USize]) -> DynTensor<T>
        using [Random, ComputeDevice]
    {
        @vbc(TENSOR_RANDN, shape, Random.int(2147483647), ComputeDevice.device())
    }

    // Create tensor with the same shape as another, filled with ones.
    public fn ones_like(x: &DynTensor<T>) -> DynTensor<T> {
        let data = TensorHandle.allocate(dtype_of<T>(), &x.shape, x.device());
        @vbc(TENSOR_FILL, data, T.one());
        DynTensor { data, shape: x.shape.clone() }
    }

    // Get shape reference
    public fn shape(&self) -> &[USize] {
        &self.shape
    }

    // Total element count
    public fn numel(&self) -> USize {
        self.shape.iter().product()
    }

    // Number of dimensions
    public fn rank(&self) -> USize {
        self.shape.len()
    }

    // Number of dimensions (alias for rank — PyTorch / NumPy idiom).
    public fn ndim(&self) -> USize {
        self.shape.len()
    }

    // Dimension size at index
    public fn dim(&self, idx: USize) -> USize {
        self.shape[idx]
    }

    // Check if contiguous
    public fn is_contiguous(&self) -> Bool {
        self.data.is_contiguous()
    }

    // Get device
    public fn device(&self) -> Device {
        self.data.device
    }

    // Get single element (for scalars)
    public fn item(&self) -> T {
        assert(self.numel() == 1, "item() requires single-element tensor");
        @vbc(TENSOR_GET_SCALAR, self.data, &[0])
    }

    // Get element at indices
    public fn get(&self, indices: &[USize]) -> T {
        assert(indices.len() == self.rank(), "index rank mismatch");
        for (i, &idx) in indices.iter().enumerate() {
            assert(idx < self.shape[i], "index out of bounds");
        }
        @vbc(TENSOR_GET_SCALAR, self.data, indices)
    }

    // Set element at indices
    public fn set(&mut self, indices: &[USize], value: T) {
        assert(indices.len() == self.rank(), "index rank mismatch");
        for (i, &idx) in indices.iter().enumerate() {
            assert(idx < self.shape[i], "index out of bounds");
        }
        @vbc(TENSOR_SET_SCALAR, self.data, indices, value);
    }

    // Clone tensor data
    public fn clone(&self) -> Self {
        let new_data = @vbc(TENSOR_CLONE, self.data);
        DynTensor {
            data: new_data,
            shape: self.shape.clone(),
        }
    }

    // Make contiguous copy if needed
    public fn contiguous(&self) -> Self {
        if self.is_contiguous() {
            self.clone()
        } else {
            @vbc(TENSOR_CONTIGUOUS, self)
        }
    }

    // Move to device
    public fn to(&self, device: Device) -> Self {
        if self.data.device == device {
            self.clone()
        } else {
            @vbc(TENSOR_TO_DEVICE, self.data, device)
        }
    }

    // Cast to different dtype
    public fn cast<U: Numeric>(&self) -> DynTensor<U> {
        @vbc(TENSOR_CAST, self.data, dtype_of<U>())
    }
}

// =============================================================================
// Tensor View
// =============================================================================

// View into tensor (shares storage)
//

// Views enable efficient slicing and reshaping without copies.
// Modifications through a view affect the underlying tensor.
public type TensorView<T: Numeric> is {
    base: TensorHandle,
    offset: USize,
    shape: List<USize>,
    strides: List<ISize>,
};

implement<T: Numeric> TensorView<T> {
    // Create view with custom strides
    public fn as_strided(
        base: &TensorHandle,
        shape: &[USize],
        strides: &[ISize],
        offset: USize,
    ) -> Self {
        TensorView {
            base: base.clone(),
            offset,
            shape: List.from(shape),
            strides: List.from(strides),
        }
    }

    // Transpose (swap last two dimensions)
    public fn transpose(&self) -> TensorView<T> {
        let n = self.shape.len();
        assert(n >= 2, "transpose requires rank >= 2");

        let mut new_shape = self.shape.clone();
        let mut new_strides = self.strides.clone();
        new_shape.swap(n - 1, n - 2);
        new_strides.swap(n - 1, n - 2);

        TensorView {
            base: self.base.clone(),
            offset: self.offset,
            shape: new_shape,
            strides: new_strides,
        }
    }

    // General permute
    public fn permute(&self, dims: &[USize]) -> TensorView<T> {
        assert(dims.len() == self.shape.len(), "permute dims must match rank");

        let mut new_shape = List.with_capacity(dims.len());
        let mut new_strides = List.with_capacity(dims.len());

        for &d in dims {
            new_shape.push(self.shape[d]);
            new_strides.push(self.strides[d]);
        }

        TensorView {
            base: self.base.clone(),
            offset: self.offset,
            shape: new_shape,
            strides: new_strides,
        }
    }

    // Check if contiguous
    public fn is_contiguous(&self) -> Bool {
        let expected = TensorLayout.RowMajor.compute_strides(&self.shape);
        self.strides == expected
    }

    // Convert to owned tensor
    public fn to_tensor(&self) -> DynTensor<T> {
        if self.is_contiguous() && self.offset == 0 {
            DynTensor {
                data: self.base.clone(),
                shape: self.shape.clone(),
            }
        } else {
            @vbc(TENSOR_CONTIGUOUS_VIEW, self)
        }
    }
}

// =============================================================================
// Creation Operations
// =============================================================================

// Create tensor filled with zeros
public fn zeros<T: Numeric>(shape: &[USize]) -> DynTensor<T>
    using [ComputeDevice]
{
    let data = TensorHandle.allocate(dtype_of<T>(), shape, ComputeDevice.device_type());
    @vbc(TENSOR_FILL, data, T.zero());
    DynTensor { data, shape: List.from(shape) }
}

// Create tensor filled with ones
public fn ones<T: Numeric>(shape: &[USize]) -> DynTensor<T>
    using [ComputeDevice]
{
    let data = TensorHandle.allocate(dtype_of<T>(), shape, ComputeDevice.device_type());
    @vbc(TENSOR_FILL, data, T.one());
    DynTensor { data, shape: List.from(shape) }
}

// Create tensor filled with value
public fn full<T: Numeric>(shape: &[USize], value: T) -> DynTensor<T>
    using [ComputeDevice]
{
    let data = TensorHandle.allocate(dtype_of<T>(), shape, ComputeDevice.device_type());
    @vbc(TENSOR_FILL, data, value);
    DynTensor { data, shape: List.from(shape) }
}

// Create tensor like another (same shape and device)
public fn zeros_like<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let data = TensorHandle.allocate(dtype_of<T>(), &x.shape, x.device());
    @vbc(TENSOR_FILL, data, T.zero());
    DynTensor { data, shape: x.shape.clone() }
}

// Create ones tensor like another
public fn ones_like<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let data = TensorHandle.allocate(dtype_of<T>(), &x.shape, x.device());
    @vbc(TENSOR_FILL, data, T.one());
    DynTensor { data, shape: x.shape.clone() }
}

// Create tensor filled with value like another
public fn full_like<T: Numeric>(x: &DynTensor<T>, value: T) -> DynTensor<T> {
    let data = TensorHandle.allocate(dtype_of<T>(), &x.shape, x.device());
    @vbc(TENSOR_FILL, data, value);
    DynTensor { data, shape: x.shape.clone() }
}

// Create range tensor [start, end) with step
public fn arange<T: Numeric>(start: T, end: T, step: T) -> DynTensor<T>
    using [ComputeDevice]
{
    @vbc(TENSOR_ARANGE, start, end, step, ComputeDevice.device())
}

// Create linearly spaced tensor
public fn linspace<T: Numeric>(start: T, end: T, num: USize) -> DynTensor<T>
    using [ComputeDevice]
{
    @vbc(TENSOR_LINSPACE, start, end, num, ComputeDevice.device())
}

// Create identity matrix
public fn eye<T: Numeric>(n: USize) -> DynTensor<T>
    using [ComputeDevice]
{
    @vbc(TENSOR_EYE, n, ComputeDevice.device())
}

// Create tensor from data list
public fn from_list<T: Numeric>(data: &[T], shape: &[USize]) -> DynTensor<T>
    using [ComputeDevice]
{
    let expected_numel: USize = shape.iter().product();
    assert(data.len() == expected_numel, "data length must match shape");
    @vbc(TENSOR_FROM_DATA, data, shape, ComputeDevice.device())
}

// Create random tensor from N(0, 1)
public fn randn<T: Numeric>(shape: &[USize]) -> DynTensor<T>
    using [Random, ComputeDevice]
{
    @vbc(TENSOR_RANDN, shape, Random.int(2147483647), ComputeDevice.device())
}

// Create random tensor from U[0, 1)
public fn rand<T: Numeric>(shape: &[USize]) -> DynTensor<T>
    using [Random, ComputeDevice]
{
    @vbc(TENSOR_RAND, shape, Random.int(2147483647), ComputeDevice.device())
}

// Create random tensor from U[low, high)
public fn rand_uniform<T: Numeric>(shape: &[USize], low: T, high: T) -> DynTensor<T>
    using [Random, ComputeDevice]
    where high > low
{
    let r = rand<T>(shape);
    add(&mul(&r, &full_like(&r, high - low)), &full_like(&r, low))
}

// Create random integer tensor
public fn randint<T: Numeric>(shape: &[USize], low: T, high: T) -> DynTensor<T>
    using [Random, ComputeDevice]
{
    @vbc(TENSOR_RANDINT, shape, low, high, Random.int(2147483647), ComputeDevice.device())
}

// =============================================================================
// Element-wise Unary Operations
// =============================================================================

// Negation: -x
public fn neg<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Neg)
}

// Absolute value: |x|
public fn tensor_abs<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Abs)
}

// Sign: -1, 0, or 1
public fn sign<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Sign)
}

// Exponential: e^x
public fn tensor_exp<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Exp)
}

// Natural logarithm: ln(x)
public fn tensor_log<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Log)
}

// Square root: sqrt(x)
public fn tensor_sqrt<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Sqrt)
}

// Reciprocal square root: 1/sqrt(x)
public fn rsqrt<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Rsqrt)
}

// Square: x^2
public fn square<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Square)
}

// Sine
public fn tensor_sin<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Sin)
}

// Cosine
public fn tensor_cos<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Cos)
}

// Tangent
public fn tensor_tan<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Tan)
}

// Hyperbolic tangent
public fn tensor_tanh<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Tanh)
}

// Hyperbolic sine
public fn tensor_sinh<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Sinh)
}

// Hyperbolic cosine
public fn tensor_cosh<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Cosh)
}

// Ceiling
public fn ceil<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Ceil)
}

// Floor
public fn tensor_floor<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Floor)
}

// Round to nearest
public fn tensor_round<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Round)
}

// Truncate toward zero
public fn trunc<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Trunc)
}

// Error function
public fn tensor_erf<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Erf)
}

// =============================================================================
// Activation Functions
// =============================================================================

// ReLU: max(0, x)
public fn relu<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Relu)
}

// Leaky ReLU: max(alpha*x, x)
public fn leaky_relu<T: Numeric>(x: &DynTensor<T>, alpha: T) -> DynTensor<T> {
    @vbc(TENSOR_LEAKY_RELU, x.data, alpha)
}

// Sigmoid: 1 / (1 + e^-x)
public fn sigmoid<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Sigmoid)
}

// GELU: x * Phi(x) (Gaussian Error Linear Unit)
public fn gelu<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Gelu)
}

// SiLU/Swish: x * sigmoid(x)
public fn silu<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_UNOP, x.data, UnaryOp.Silu)
}

// Softplus: log(1 + e^x).  Smooth approximation of ReLU.
// #74 Tier B — Verum-language composition over `tensor_exp` /
// `add_scalar` / `tensor_log`.  Numerically stable for moderate
// magnitudes; for very large `x` callers may prefer the
// max(x, 0) + log1p(exp(-|x|)) form (a future intrinsic).
public fn softplus<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let exp_x = tensor_exp(x);
    let one_plus = add_scalar(&exp_x, 1 as T);
    tensor_log(&one_plus)
}

// Mish activation: x * tanh(softplus(x)).
// #74 Tier B — Verum-language composition over `softplus` +
// `tensor_tanh` + `mul`. Mish is smooth, non-monotonic, and has
// outperformed ReLU/Swish on several SOTA classifiers
// (Misra 2019).
public fn mish<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let sp = softplus(x);
    let t = tensor_tanh(&sp);
    mul(x, &t)
}

// Generalised Swish / scaled SiLU: x * sigmoid(beta * x).
// #74 Tier B — beta-parameterised generalisation of `silu`. When
// `beta == 1`, equivalent to `silu`. Larger `beta` makes the
// activation closer to ReLU; smaller `beta` makes it closer to
// the identity. Composes `mul_scalar` + `sigmoid` + `mul`.
public fn swish<T: Numeric>(x: &DynTensor<T>, beta: T) -> DynTensor<T> {
    let scaled = mul_scalar(x, beta);
    let s = sigmoid(&scaled);
    mul(x, &s)
}

// Hardtanh: clamp(x, min_val, max_val). Linear inside the range,
// saturated outside. Default range [-1, 1] matches PyTorch /
// JAX convention.
// #74 Tier B — Verum-language composition over the existing
// `tensor_clamp` primitive (already a thin wrapper). Provided as
// a named alias so call sites read intentionally.
public fn hardtanh<T: Numeric>(x: &DynTensor<T>, min_val: T, max_val: T) -> DynTensor<T> {
    tensor_clamp(x, min_val, max_val)
}

// Squared difference: `(a - b)^2`.
// #74 Tier B — building block for MSE-style losses. Composes
// `sub` + `mul`. Tensor shapes must broadcast.
public fn square_diff<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    let d = sub(a, b);
    mul(&d, &d)
}

// Mean squared error: `mean((pred - target)^2)`.
// #74 Tier B — canonical regression loss. Composes
// `square_diff` + `mean`. The output is a scalar of type `T`.
public fn mean_squared_error<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    mean(&square_diff(pred, target))
}

// Mean absolute error: `mean(|pred - target|)`.
// #74 Tier B — robust regression loss (less sensitive to outliers
// than MSE). Composes `sub` + `tensor_abs` + `mean`.
public fn mean_absolute_error<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    let d = sub(pred, target);
    mean(&tensor_abs(&d))
}

// Binary cross-entropy loss: `-mean(y*log(p) + (1-y)*log(1-p))`.
// #74 Tier B — canonical binary classification loss. Composes
// `tensor_log` + `mul` + `add` + `rsub_scalar` + `mean`.  Caller
// is responsible for ensuring `pred ∈ (0, 1)` (typically by
// passing a sigmoid output); log(0) → −∞ otherwise.
public fn binary_cross_entropy<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    let log_p = tensor_log(pred);
    let one_minus_p = rsub_scalar(1 as T, pred);
    let log_one_minus_p = tensor_log(&one_minus_p);
    let one_minus_y = rsub_scalar(1 as T, target);
    let term1 = mul(target, &log_p);
    let term2 = mul(&one_minus_y, &log_one_minus_p);
    let total = add(&term1, &term2);
    let m: T = mean(&total);
    -m
}

// Negative log-likelihood loss: `-mean(log(pred) * target)`.
// #74 Tier B — multi-class classification loss when `pred` is
// already log-probabilities (e.g. output of `log_softmax`). For
// raw logits, prefer `cross_entropy` below which fuses log_softmax
// + nll into one numerically stable pass.
public fn nll_loss<T: Numeric>(log_pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    let weighted = mul(log_pred, target);
    let m: T = mean(&weighted);
    -m
}

// Cross-entropy loss for one-hot targets: `-mean(target * log_softmax(logits))`.
// #74 Tier B — fuses `log_softmax` + `nll_loss` for numerical
// stability. `axis` selects the class dimension (typically -1
// for [batch, classes] tensors).
public fn cross_entropy<T: Numeric>(logits: &DynTensor<T>, target: &DynTensor<T>, axis: ISize) -> T {
    let log_p = log_softmax(logits, axis);
    nll_loss(&log_p, target)
}

// Kullback–Leibler divergence: `sum(p * (log(p) - log(q)))`.
// #74 Tier B — non-symmetric measure of how `q` diverges from `p`.
// Composes `tensor_log` + `sub` + `mul` + `sum`. Both inputs must
// be non-negative; for KL of distributions to be well-defined,
// callers should pre-normalise to sum to 1.
public fn kl_divergence<T: Numeric>(p: &DynTensor<T>, q: &DynTensor<T>) -> T {
    let log_p = tensor_log(p);
    let log_q = tensor_log(q);
    let diff = sub(&log_p, &log_q);
    let weighted = mul(p, &diff);
    sum(&weighted)
}

// Hinge loss: `mean(max(0, 1 - pred*target))`. SVM-style loss
// where `target ∈ {-1, +1}`.
// #74 Tier B — composes `mul` + `rsub_scalar` + `relu` + `mean`.
// `relu(x) = max(0, x)` gives the desired non-negative clipping.
public fn hinge_loss<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    let prod = mul(pred, target);
    let margin = rsub_scalar(1 as T, &prod);
    mean(&relu(&margin))
}

// Sum of squared residuals along axis: `sum_axis((pred - target)^2)`.
// #74 Tier B — per-sample squared loss when `axis` is the
// feature axis. Useful for batched regression losses where the
// outer mean is taken at the call site.
public fn sum_squared_error_axis<T: Numeric>(
    pred: &DynTensor<T>,
    target: &DynTensor<T>,
    axis: ISize,
) -> DynTensor<T> {
    @vbc(TENSOR_REDUCE, square_diff(pred, target).data, ReduceOp.Sum, axis)
}

// Smooth L1 loss / Huber loss: quadratic for small errors, slope-bounded
// for large. Used in object-detection regression. For `|d| <= delta`:
// `0.5 * d^2`, else: `delta * (|d| - 0.5 * delta)` where `d = pred - target`.
//
// #74 Tier B — composes `sub` + `tensor_abs` + `square` + `where_tensor`
// + `mean`. Note: the original implementation used `let linear = ...` for
// the slope-bounded branch, which clashed with Verum's `linear` reserved
// keyword (see `verum_lexer/src/token.rs`). Renamed to `slope_branch`.
public fn huber_loss<T: Numeric>(
    pred: &DynTensor<T>,
    target: &DynTensor<T>,
    delta: T,
) -> T {
    let d = sub(pred, target);
    let abs_d = tensor_abs(&d);
    let half_t: T = (0.5 as Float) as T;
    let sq = square(&d);
    let quad_branch = mul_scalar(&sq, half_t);
    let scaled = mul_scalar(&abs_d, delta);
    let half_field = full_like(&abs_d, half_t);
    let half_delta_field = mul_scalar(&half_field, delta);
    let slope_branch = sub(&scaled, &half_delta_field);
    let mask = le(&abs_d, &full_like(&abs_d, delta));
    mean(&where_tensor(&mask, &quad_branch, &slope_branch))
}

// Smooth-L1 loss with delta=1.
// #74 Tier B — convenience wrapper for the canonical detection-paper choice.
public fn smooth_l1_loss<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    huber_loss(pred, target, 1 as T)
}

// Cosine-similarity loss: `1 - cosine_similarity(a, b)`.
// #74 Tier B — drives embeddings to alignment when used as a loss.
// Composes the existing `cosine_similarity` for the scalar
// arithmetic; the result is in [0, 2] (0 = perfectly aligned,
// 2 = anti-aligned).
public fn cosine_similarity_loss<T: Numeric>(
    a: &DynTensor<T>,
    b: &DynTensor<T>,
) -> T {
    (1 as T) - cosine_similarity(a, b)
}

// =============================================================================
// Classification metrics (#74 Tier B)
// =============================================================================

// Element-wise accuracy: `mean(pred == target)`.
// #74 Tier B — computes the fraction of matching elements. Both
// inputs must be the same shape; output is a scalar Float in
// [0, 1]. Composes `eq` + cast-to-numeric + `mean`.
public fn accuracy<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> Float {
    let mask = eq(pred, target);
    let counts: DynTensor<USize> = mask.cast();
    (sum(&counts) as Float) / (pred.numel() as Float)
}

// Top-k accuracy for one-hot / categorical targets.
// #74 Tier B — `pred` is a [N, C] tensor of scores; `target` is
// a [N] tensor of class indices. Returns the fraction of rows
// where the target index is among the top-k predictions.
// Composes `tensor_topk` + `eq` (per-row) + `any` + `mean`.
public fn top_k_accuracy<T: Numeric>(
    pred: &DynTensor<T>,
    target: &DynTensor<USize>,
    k: USize,
) -> Float {
    assert(pred.rank() == 2, "top_k_accuracy requires [N, C] pred");
    assert(target.rank() == 1, "top_k_accuracy requires [N] target");
    let topk = @vbc(TENSOR_TOPK, pred.data, k, -1 as ISize);
    // topk is the indices tensor [N, k]
    let target_2d = unsqueeze(target, 1);
    let matches = eq(&topk, &target_2d);  // [N, k]
    // any(axis=-1) → [N], then mean → scalar
    let row_any: DynTensor<Bool> = @vbc(TENSOR_REDUCE, matches.data, ReduceOp.Any, -1 as ISize);
    let counts: DynTensor<USize> = row_any.cast();
    (sum(&counts) as Float) / (target.numel() as Float)
}

// True positives (TP): count of (pred_positive AND target_positive).
// #74 Tier B — building block for precision / recall / F1.
public fn true_positives<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> USize {
    let zeros = full_like(pred, 0 as T);
    let pp = gt(pred, &zeros);     // pred > 0
    let tp = gt(target, &zeros);   // target > 0
    let both: DynTensor<Bool> = @vbc(TENSOR_BINOP, pp.data, tp.data, BinaryOp.And);
    let counts: DynTensor<USize> = both.cast();
    sum(&counts)
}

// False positives: pred_positive AND NOT target_positive.
public fn false_positives<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> USize {
    let zeros_p = full_like(pred, 0 as T);
    let zeros_t = full_like(target, 0 as T);
    let pp = gt(pred, &zeros_p);
    let tn = le(target, &zeros_t);
    let both: DynTensor<Bool> = @vbc(TENSOR_BINOP, pp.data, tn.data, BinaryOp.And);
    let counts: DynTensor<USize> = both.cast();
    sum(&counts)
}

// False negatives: NOT pred_positive AND target_positive.
public fn false_negatives<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> USize {
    let zeros_p = full_like(pred, 0 as T);
    let zeros_t = full_like(target, 0 as T);
    let pn = le(pred, &zeros_p);
    let tp = gt(target, &zeros_t);
    let both: DynTensor<Bool> = @vbc(TENSOR_BINOP, pn.data, tp.data, BinaryOp.And);
    let counts: DynTensor<USize> = both.cast();
    sum(&counts)
}

// Precision: TP / (TP + FP). Returns 0 when the denominator is 0
// (no positive predictions); callers can pre-check via TP+FP if
// the distinction matters for their pipeline.
// #74 Tier B — composes the TP / FP helpers above.
public fn precision<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> Float {
    let tp = true_positives(pred, target);
    let fp = false_positives(pred, target);
    let denom = tp + fp;
    if denom == 0 { 0.0 } else { (tp as Float) / (denom as Float) }
}

// Recall: TP / (TP + FN). Returns 0 when the denominator is 0
// (no actual positives).
public fn recall<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> Float {
    let tp = true_positives(pred, target);
    let fn_count = false_negatives(pred, target);
    let denom = tp + fn_count;
    if denom == 0 { 0.0 } else { (tp as Float) / (denom as Float) }
}

// F1 score: harmonic mean of precision and recall.
// #74 Tier B — `2 * P * R / (P + R)`. Returns 0 when both P and
// R are 0 (which happens when there are no true positives at
// all — the model agreed with target on the negative class only).
public fn f1_score<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> Float {
    let p = precision(pred, target);
    let r = recall(pred, target);
    if p + r == 0.0 { 0.0 } else { 2.0 * p * r / (p + r) }
}

// =============================================================================
// Random sampling helpers (#74 Tier B)
// =============================================================================

// Bernoulli sampling: returns a tensor of 0/1 values with each
// element being 1 with probability `p`.
// #74 Tier B — composes `rand` (uniform [0,1)) + comparison
// vs. threshold. The probabilistic semantics depend on the
// `rand` primitive's RNG; for deterministic / seeded sampling
// callers should plumb their own seed through `rand`'s thread-
// local state (TENSOR_RAND honours the `VERUM_RAND_SEED` env
// var when set).
public fn bernoulli<T: Numeric>(shape: &[USize], p: Float) -> DynTensor<T> {
    let u = rand<T>(shape);
    let threshold = full_like(&u, p as T);
    let mask = lt(&u, &threshold);
    { let res: DynTensor<T> = mask.cast(); res }
}

// Categorical sample by argmax over softmax-of-logits + Gumbel
// noise (Gumbel-max trick). Returns class indices [N].
// #74 Tier B — for `logits: [N, C]`, samples one class per row
// approximately ∝ softmax(logits). Composes `rand` (uniform) +
// `tensor_log` twice (Gumbel = -log(-log(U))) + `add` +
// `argmax_axis`.
public fn categorical_sample<T: Numeric>(logits: &DynTensor<T>) -> DynTensor<USize> {
    let u = rand<T>(logits.shape());
    // Gumbel(0, 1) = -log(-log(U)).
    let neg_log_u = neg(&tensor_log(&u));
    let gumbel = neg(&tensor_log(&neg_log_u));
    let perturbed = add(logits, &gumbel);
    argmax_axis(&perturbed, -1)
}

// Weighted mean: `sum(x * weights) / sum(weights)`.
// #74 Tier B — composes `mul` + `sum` + scalar division.
// `weights` must broadcast with `x`. The denominator is the
// scalar sum of weights, so passing `full_like(x, 1.0)` recovers
// the unweighted `mean`.
public fn weighted_mean<T: Numeric>(x: &DynTensor<T>, weights: &DynTensor<T>) -> T {
    let weighted = mul(x, weights);
    sum(&weighted) / sum(weights)
}

// Geometric mean: `prod(x)^(1/n)`.
// #74 Tier B — composes `prod` + scalar exponentiation. All
// elements must be non-negative; negative inputs trigger NaN
// when the root is non-integer.
public fn geometric_mean<T: Numeric>(x: &DynTensor<T>) -> T {
    let p: Float = prod(x) as Float;
    let n: Float = x.numel() as Float;
    pow(p, 1.0 / n) as T
}

// Harmonic mean: `n / sum(1/x_i)`.
// #74 Tier B — for positive inputs only. Composes `rsub_scalar`'s
// inverse (`div`) over a `full_like(_, 1)` reciprocal trick:
// `1 / x` equals `div(full_like(x, 1), x)` element-wise.
public fn harmonic_mean<T: Numeric>(x: &DynTensor<T>) -> T {
    let recip = div(&full_like(x, 1 as T), x);
    let n: T = x.numel() as T;
    n / sum(&recip)
}

// Softmin along axis: `softmax(-x, axis)`.
// #74 Tier B — produces a probability distribution that
// concentrates on the *smallest* values, opposite of softmax.
// Composes `neg` + `softmax`.
public fn softmin<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    softmax(&neg(x), axis)
}

// Logsumexp along axis: `log(sum(exp(x), axis))`.
// #74 Tier B — building block for log-domain probability
// math. Composes `tensor_exp` + `sum_axis` + `tensor_log`. Note
// the naïve implementation overflows for large `x`; a future
// numerically-stable variant should subtract `max_axis` before
// the exp.
public fn logsumexp<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    let e = tensor_exp(x);
    let s: DynTensor<T> = @vbc(TENSOR_REDUCE, e.data, ReduceOp.Sum, axis);
    tensor_log(&s)
}

// Element-wise reciprocal: `1 / x`.
// #74 Tier B — convenience over `div(full_like(x, 1), x)`. Caller
// must ensure no zeros (otherwise the result has +Inf entries).
public fn reciprocal<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    div(&full_like(x, 1 as T), x)
}

// Element-wise reciprocal-square-root: `1 / sqrt(x)`.
// #74 Tier B — common in attention scaling; composes
// `tensor_sqrt` + `reciprocal`. Already exists as a primitive
// (`rsqrt` line 739), but provide a Verum-language reference impl
// so callers in environments without the primitive (older VBC,
// minimal builds) still resolve. The primitive will shadow this
// when present.
public fn rsqrt_lang<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    reciprocal(&tensor_sqrt(x))
}

// =============================================================================
// Deep-Learning Building Blocks (#74 Tier B)
// =============================================================================
//
// All helpers in this section are pure Verum-language compositions
// over the existing primitive surface. Use them as reference impls
// or as tunable starting points for layer authors who don't want
// the opaque `@vbc` primitive form. The corresponding primitives
// (TENSOR_LAYER_NORM, TENSOR_BATCH_NORM, TENSOR_FLASH_ATTENTION,
// …) shadow these when available — primitives win the dispatch
// race because direct `@vbc` calls are emitted as named functions
// at codegen time.

// Layer normalisation as a Verum-language composition.
// #74 Tier B — `(x - mean) / sqrt(var + eps) * weight + bias`,
// computed along the last axis. Composes
// `mean_axis(_, -1)` + `variance_axis(_, -1)` + `add_scalar` +
// `tensor_sqrt` + `div` (broadcast) + `mul` + `add`.  Eps is
// added INSIDE the sqrt for numerical stability — matches the
// Pytorch / TensorFlow convention.
public fn layer_norm_lang<T: Numeric>(
    x: &DynTensor<T>,
    weight: &DynTensor<T>,
    bias: &DynTensor<T>,
    eps: T,
) -> DynTensor<T> {
    let mu = mean_axis(x, -1);
    let var_x = variance_axis(x, -1);
    let var_eps = add_scalar(&var_x, eps);
    let scale = tensor_sqrt(&var_eps);
    let centered = sub(x, &mu);
    let normalised = div(&centered, &scale);
    add(&mul(&normalised, weight), bias)
}

// RMS normalisation (Zhang & Sennrich 2019) as a Verum-language
// composition. Used in modern LLMs (LLaMA, Mistral, …) instead of
// LayerNorm because it skips the centring step.
// #74 Tier B — `x / sqrt(mean(x^2) + eps) * weight`. Composes
// `square` + `mean_axis(_, -1)` + `add_scalar` + `tensor_sqrt` +
// `div` (broadcast) + `mul`.
public fn rms_norm_lang<T: Numeric>(
    x: &DynTensor<T>,
    weight: &DynTensor<T>,
    eps: T,
) -> DynTensor<T> {
    let sq = square(x);
    let mean_sq = mean_axis(&sq, -1);
    let with_eps = add_scalar(&mean_sq, eps);
    let scale = tensor_sqrt(&with_eps);
    mul(&div(x, &scale), weight)
}

// Group normalisation (Wu & He 2018) — splits the channel axis
// into groups, normalises each group independently. Useful when
// batch-norm's mini-batch coupling is undesirable (small batches,
// generative models).
// #74 Tier B — composes `reshape` + `mean_axis` + `variance_axis`
// + (sub/div/mul/add). Caller must have `channels % num_groups == 0`;
// the helper does NOT introduce a runtime check on that pre-cond
// — the underlying `reshape` will panic if so.
public fn group_norm_lang<T: Numeric>(
    x: &DynTensor<T>,
    num_groups: USize,
    weight: &DynTensor<T>,
    bias: &DynTensor<T>,
    eps: T,
) -> DynTensor<T> {
    // Assume input is [N, C, *] — flatten to [N, num_groups, C/num_groups, *]
    // and reduce along the inner spatial+channel-per-group axes (-2, -1).
    // Simplified single-pass form: compute mean / var along axis -1
    // after reshape; assumes the spatial dims are already trailing.
    let shape = x.shape();
    assert(shape.len() >= 2, "group_norm requires rank >= 2 input");
    assert(shape[1] % num_groups == 0, "channels must be divisible by num_groups");
    // Reshape [N, C, *] → [N, G, C/G * prod(spatial)]
    let g_size = shape[1] / num_groups;
    let mut spatial = 1 as USize;
    for d in 2..shape.len() {
        spatial = spatial * shape[d];
    }
    let new_shape = [shape[0], num_groups, g_size * spatial];
    let reshaped = reshape(x, &new_shape);
    let mu = mean_axis(&reshaped, -1);
    let var_g = variance_axis(&reshaped, -1);
    let var_eps = add_scalar(&var_g, eps);
    let scale = tensor_sqrt(&var_eps);
    let normalised = div(&sub(&reshaped, &mu), &scale);
    let restored = reshape(&normalised, shape);
    add(&mul(&restored, weight), bias)
}

// Scaled dot-product attention (single-head): the canonical
// `softmax(Q K^T / sqrt(d_k)) V` from "Attention Is All You Need".
// #74 Tier B — composes `matmul` + `transpose` + `div_scalar` +
// `softmax` + `matmul`. Output shape is `[..., seq_q, d_v]` for
// `Q : [..., seq_q, d_k]`, `K : [..., seq_k, d_k]`, `V : [..., seq_k, d_v]`.
//
// `scale` is conventionally `1 / sqrt(d_k)`; passed explicitly
// so callers can substitute alternative scalings (e.g. learned
// per-head temperatures). Mask handling is intentionally left to
// the caller — pass a pre-masked Q, or apply your additive mask
// to the score matrix before this call.
public fn scaled_dot_product_attention<T: Numeric>(
    q: &DynTensor<T>,
    k: &DynTensor<T>,
    v: &DynTensor<T>,
    scale: T,
) -> DynTensor<T> {
    let k_t = transpose(k);
    let scores = matmul(q, &k_t);
    let scaled = mul_scalar(&scores, scale);
    let probs = softmax(&scaled, -1);
    matmul(&probs, v)
}

// Helper: standard 1/sqrt(d) attention scale.
// #74 Tier B — pure scalar arithmetic, no tensor ops.
public fn attention_scale<T: Numeric>(d_k: USize) -> T {
    let denom: Float = sqrt(d_k as Float);
    (1.0 / denom) as T
}

// Dropout (inference path: identity).
// #74 Tier B — at inference time dropout is a no-op (the
// expectation has already been accounted for via the inverse
// scaling done at training). Provided as a named identity helper
// so model-runtime code that calls `dropout(x, p)` regardless of
// mode resolves cleanly. The training-mode counterpart needs a
// random primitive (TENSOR_RAND with mask) and is deferred until
// the deterministic-RNG plumbing lands in core.intrinsics.tensor.
public fn dropout_inference<T: Numeric>(x: &DynTensor<T>, _rate: Float) -> DynTensor<T> {
    x.clone()
}

// Glorot / Xavier uniform initialisation: U(-a, a) with
// `a = sqrt(6 / (fan_in + fan_out))`.
// #74 Tier B — composes `tensor_rand` (uniform [0,1)) +
// `mul_scalar` + `sub_scalar`. Used for dense layers with
// symmetric activations (tanh, sigmoid). For ReLU / GELU prefer
// `he_uniform`.
public fn glorot_uniform<T: Numeric>(shape: &[USize], fan_in: USize, fan_out: USize) -> DynTensor<T> {
    let a: Float = sqrt(6.0 / ((fan_in + fan_out) as Float));
    let u01 = rand<T>(shape);
    // Map [0, 1) -> [-a, a)
    let scaled = mul_scalar(&u01, (2.0 * a) as T);
    sub_scalar(&scaled, a as T)
}

// He / Kaiming uniform initialisation: U(-a, a) with
// `a = sqrt(6 / fan_in)`.
// #74 Tier B — like `glorot_uniform` but only fan-in matters.
// Used for ReLU / GELU layers where the activation breaks the
// symmetry assumption Glorot relies on.
public fn he_uniform<T: Numeric>(shape: &[USize], fan_in: USize) -> DynTensor<T> {
    let a: Float = sqrt(6.0 / (fan_in as Float));
    let u01 = rand<T>(shape);
    let scaled = mul_scalar(&u01, (2.0 * a) as T);
    sub_scalar(&scaled, a as T)
}

// Glorot / Xavier *normal* initialisation: N(0, sigma) with
// `sigma = sqrt(2 / (fan_in + fan_out))`.
// #74 Tier B — composes `tensor_randn` (standard normal) +
// `mul_scalar`.
public fn glorot_normal<T: Numeric>(shape: &[USize], fan_in: USize, fan_out: USize) -> DynTensor<T> {
    let sigma: Float = sqrt(2.0 / ((fan_in + fan_out) as Float));
    let z = randn<T>(shape);
    mul_scalar(&z, sigma as T)
}

// He / Kaiming *normal* initialisation: N(0, sigma) with
// `sigma = sqrt(2 / fan_in)`.
// #74 Tier B — for ReLU / GELU layers.
public fn he_normal<T: Numeric>(shape: &[USize], fan_in: USize) -> DynTensor<T> {
    let sigma: Float = sqrt(2.0 / (fan_in as Float));
    let z = randn<T>(shape);
    mul_scalar(&z, sigma as T)
}

// Cosine learning-rate schedule (no warmup).
// #74 Tier B — pure scalar arithmetic, returns the LR for step
// `t` over total `T`. `lr_min + (lr_max - lr_min) * 0.5 *
// (1 + cos(pi * t / T))`. At `t == 0` returns `lr_max`; at
// `t == T` returns `lr_min`. Caller is responsible for clamping
// `t` if the training loop overruns the budget.
public fn cosine_lr_schedule(t: USize, total: USize, lr_min: Float, lr_max: Float) -> Float {
    if total == 0 {
        return lr_max;
    }
    let progress: Float = (t as Float) / (total as Float);
    let cos_term: Float = cos(3.14159265358979 * progress);
    lr_min + (lr_max - lr_min) * 0.5 * (1.0 + cos_term)
}

// Linear warmup-then-cosine decay schedule.
// #74 Tier B — composes `cosine_lr_schedule` for the post-warmup
// phase. During steps `0..warmup_steps`, returns
// `lr_max * (t / warmup_steps)`; afterwards transitions through
// cosine decay.
public fn warmup_cosine_lr(
    t: USize,
    warmup_steps: USize,
    total: USize,
    lr_min: Float,
    lr_max: Float,
) -> Float {
    if t < warmup_steps {
        if warmup_steps == 0 {
            return lr_max;
        }
        let p: Float = (t as Float) / (warmup_steps as Float);
        return lr_max * p;
    }
    let after = t - warmup_steps;
    let after_total = if total > warmup_steps { total - warmup_steps } else { 1 as USize };
    cosine_lr_schedule(after, after_total, lr_min, lr_max)
}

// Step learning-rate schedule: `lr_max * gamma^(t / step_size)`.
// #74 Tier B — discrete decay every `step_size` steps. `gamma`
// is the per-step multiplicative factor (typical 0.1).
public fn step_lr_schedule(t: USize, step_size: USize, lr_max: Float, gamma: Float) -> Float {
    let n: USize = if step_size > 0 { t / step_size } else { 0 };
    lr_max * pow(gamma, n as Float)
}

// Exponential learning-rate decay: `lr_max * exp(-decay_rate * t)`.
// #74 Tier B — smooth continuous decay. `decay_rate > 0`.
public fn exponential_lr_schedule(t: USize, lr_max: Float, decay_rate: Float) -> Float {
    lr_max * exp(-decay_rate * (t as Float))
}

// Softmax along axis
public fn softmax<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_SOFTMAX, x.data, axis)
}

// Log-softmax along axis
public fn log_softmax<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_LOG_SOFTMAX, x.data, axis)
}

// =============================================================================
// Element-wise Binary Operations
// =============================================================================

// Addition with broadcasting
public fn add<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_BINOP, a.data, b.data, BinaryOp.Add)
}

// Subtraction with broadcasting
public fn sub<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_BINOP, a.data, b.data, BinaryOp.Sub)
}

// Multiplication with broadcasting
public fn mul<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_BINOP, a.data, b.data, BinaryOp.Mul)
}

// Division with broadcasting
public fn div<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_BINOP, a.data, b.data, BinaryOp.Div)
}

// Power with broadcasting
public fn tensor_pow<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_BINOP, a.data, b.data, BinaryOp.Pow)
}

// Element-wise maximum
public fn maximum<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_BINOP, a.data, b.data, BinaryOp.Max)
}

// Element-wise minimum
public fn minimum<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_BINOP, a.data, b.data, BinaryOp.Min)
}

// Scalar operations

// Add scalar to tensor
public fn add_scalar<T: Numeric>(x: &DynTensor<T>, scalar: T) -> DynTensor<T> {
    add(x, &full_like(x, scalar))
}

// Multiply tensor by scalar
public fn mul_scalar<T: Numeric>(x: &DynTensor<T>, scalar: T) -> DynTensor<T> {
    mul(x, &full_like(x, scalar))
}

// Divide tensor by scalar
public fn div_scalar<T: Numeric>(x: &DynTensor<T>, scalar: T) -> DynTensor<T> {
    div(x, &full_like(x, scalar))
}

// Subtract scalar from tensor.
// #74 Tier B — Verum-language composition. No direct VBC primitive
// is needed; reuses the existing `sub` binop with a scalar-broadcast.
public fn sub_scalar<T: Numeric>(x: &DynTensor<T>, scalar: T) -> DynTensor<T> {
    sub(x, &full_like(x, scalar))
}

// Subtract tensor from scalar (returns `scalar - x`).
// #74 Tier B — useful complement to `sub_scalar` for the asymmetric
// case (e.g. computing `1.0 - p` for a probability tensor).
public fn rsub_scalar<T: Numeric>(scalar: T, x: &DynTensor<T>) -> DynTensor<T> {
    sub(&full_like(x, scalar), x)
}

// Linear interpolation: `a + t * (b - a)`.
// #74 Tier B — Verum-language composition over `add` / `sub` / `mul_scalar`.
// `t == 0` returns `a`, `t == 1` returns `b`, intermediate `t` blends.
// Tensor shapes must be broadcastable; output shape follows the
// broadcasting rules of the underlying binops.
public fn lerp<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>, t: T) -> DynTensor<T> {
    let diff = sub(b, a);
    let scaled = mul_scalar(&diff, t);
    add(a, &scaled)
}

// Variance of all elements (population variance, divides by N).
// #74 Tier B — Verum-language composition: `mean((x - mean(x))^2)`.
// Note: returns the population variance (denominator N) to match
// `mean`'s convention; pass through `mul_scalar(_, n / (n-1))` at
// the call site for the sample-variance form.
public fn variance<T: Numeric>(x: &DynTensor<T>) -> T {
    let mu = mean(x);
    let centered = sub_scalar(x, mu);
    let squared = mul(&centered, &centered);
    mean(&squared)
}

// Standard deviation of all elements (square root of variance).
// #74 Tier B — Verum-language composition.
public fn std_dev<T: Numeric>(x: &DynTensor<T>) -> T {
    let v: Float = variance(x) as Float;
    sqrt(v) as T
}

// Variance along axis (population variance).
// #74 Tier B — Verum-language composition over `mean_axis` /
// broadcasting `sub` / `mul`. Result tensor has the same shape as
// `x` with the reduced axis removed (matches `mean_axis`).
public fn variance_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    let mu = mean_axis(x, axis);
    // mean_axis collapsed `axis` so `mu` has rank one less than `x`.
    // The subsequent `sub(x, &mu)` relies on the JIT/CPU broadcast
    // path to expand `mu` back across the reduced axis (#105 5e+3
    // mid-axis broadcast covers this exact pattern).
    let centered = sub(x, &mu);
    let squared = mul(&centered, &centered);
    mean_axis(&squared, axis)
}

// Sample variance (Bessel-corrected, divides by N-1).
// #74 Tier B — wrapper over `variance` that applies Bessel
// correction. Use for inference / statistical estimation where
// the sample is drawn from a larger population. For descriptive
// statistics over the full population, prefer `variance` (denom N).
public fn sample_variance<T: Numeric>(x: &DynTensor<T>) -> T {
    let n: T = x.numel() as T;
    let pop_var = variance(x);
    pop_var * n / (n - (1 as T))
}

// Sample standard deviation (Bessel-corrected).
// #74 Tier B — sqrt(sample_variance(x)).
public fn sample_std_dev<T: Numeric>(x: &DynTensor<T>) -> T {
    let v: Float = sample_variance(x) as Float;
    sqrt(v) as T
}

// Cumulative sum along axis: `out[i] = sum(x[..=i])` along `axis`.
// #74 Tier B — wrapper over the `tensor_cumulative` primitive
// with a clear name. Output has the same shape as `x`.
public fn cumsum<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_CUMULATIVE, x.data, ReduceOp.Sum, axis)
}

// Cumulative product along axis: `out[i] = prod(x[..=i])` along `axis`.
// #74 Tier B — wrapper over `tensor_cumulative`. Useful for
// running-products, geometric path computations.
public fn cumprod<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_CUMULATIVE, x.data, ReduceOp.Prod, axis)
}

// Count non-zero elements (any rank).
// #74 Tier B — composes `ne` (element-wise inequality vs zero) +
// boolean `cast` to numeric + `sum`. Result is a scalar count.
// Avoids needing `tensor_nonzero` which returns indices.
public fn count_nonzero<T: Numeric>(x: &DynTensor<T>) -> USize {
    let zeros = full_like(x, 0 as T);
    let mask = ne(x, &zeros);
    // bool tensor → numeric via cast; sum gives the count.
    let counts: DynTensor<USize> = mask.cast();
    sum(&counts)
}

// Where with scalar branches: `select(cond, true_val, false_val)`
// returns a tensor of the broadcast shape with `true_val` at
// positions where `cond` is true and `false_val` elsewhere.
// #74 Tier B — wraps `where_tensor` with full_like-broadcast
// scalars so callers can write `where_scalar(mask, 1.0, 0.0)`
// directly without manually constructing the branch tensors.
public fn where_scalar<T: Numeric>(
    condition: &DynTensor<Bool>,
    true_val: T,
    false_val: T,
    shape_like: &DynTensor<T>,
) -> DynTensor<T> {
    let t = full_like(shape_like, true_val);
    let f = full_like(shape_like, false_val);
    where_tensor(condition, &t, &f)
}

// First-order discrete difference along axis: `out[i] = x[i+1] - x[i]`.
// #74 Tier B — composes `tensor_slice` (drop first / drop last)
// + `sub`. Output shape has `axis` reduced by 1. Common
// preprocessing for time-series derivatives or rate-of-change
// signals.
//
// Note: when `axis` shrinks to 0 (input length 1), the result is
// an empty tensor along that axis.
public fn diff<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    let n = x.dim(normalize_axis(axis, x.rank()));
    assert(n >= 1, "diff requires axis size >= 1");
    let head = tensor_slice_axis(x, axis, 0, n - 1);
    let tail = tensor_slice_axis(x, axis, 1, n);
    sub(&tail, &head)
}

// Slice along single axis: `out = x[..., start..end, ...]`.
// #74 Tier B — convenience wrapper around `tensor_slice`. Builds
// the per-dim ranges with `0..dim(d)` for non-target axes and
// `start..end` for the target. Used internally by `diff`.
public fn tensor_slice_axis<T: Numeric>(
    x: &DynTensor<T>,
    axis: ISize,
    start: USize,
    end: USize,
) -> DynTensor<T> {
    let target = normalize_axis(axis, x.rank());
    let mut ranges: List<(USize, USize)> = List.with_capacity(x.rank());
    for d in 0..x.rank() {
        if d == target {
            ranges.push((start, end));
        } else {
            ranges.push((0, x.dim(d)));
        }
    }
    @vbc(TENSOR_SLICE, x.data, ranges)
}

// Mean of two tensors element-wise: `(a + b) / 2`.
// #74 Tier B — convenience for averaging predictions from two
// models, midpoint computations, or symmetric blends. Composes
// `add` + `div_scalar`.
public fn mean_of2<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    div_scalar(&add(a, b), 2 as T)
}

// Element-wise median of three (per-element majority vote-ish).
// #74 Tier B — useful in noise-robust pipelines (drop the
// outlier of three estimates). Composes `minimum` + `maximum`
// twice: median(a, b, c) = max(min(a,b), min(max(a,b), c)).
public fn median_of3<T: Numeric>(
    a: &DynTensor<T>,
    b: &DynTensor<T>,
    c: &DynTensor<T>,
) -> DynTensor<T> {
    let lo_ab = minimum(a, b);
    let hi_ab = maximum(a, b);
    maximum(&lo_ab, &minimum(&hi_ab, c))
}

// Triangular wave activation: `1 - |x|` clamped to [0, 1].
// #74 Tier B — useful as a smooth-but-bounded test activation,
// or as a soft mask. Composes `tensor_abs` + `rsub_scalar` +
// `relu` (which gives the lower bound) + `tensor_clamp` for
// the upper. Output is in [0, 1] for any input.
public fn triangular<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let abs_x = tensor_abs(x);
    let raw = rsub_scalar(1 as T, &abs_x);
    tensor_clamp(&raw, 0 as T, 1 as T)
}

// Element-wise sign: -1 / 0 / +1 as a tensor of T.
// #74 Tier B — already exists at line 719 as `sign`, but the
// existing impl uses `@vbc(TENSOR_UNOP, ..., UnaryOp.Sign)`.
// This Verum-language reference impl is provided for minimal
// builds without the primitive — composes via comparison +
// where_tensor. The primitive shadows this when present.
public fn sign_lang<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let zeros = full_like(x, 0 as T);
    let pos = gt(x, &zeros);
    let neg = lt(x, &zeros);
    let plus = full_like(x, 1 as T);
    let minus = full_like(x, -(1 as T));
    let zero = full_like(x, 0 as T);
    let with_pos = where_tensor(&pos, &plus, &zero);
    where_tensor(&neg, &minus, &with_pos)
}

// Standard deviation along axis.
// #74 Tier B — Verum-language composition. Element-wise sqrt over
// `variance_axis(...)`.
public fn std_dev_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    tensor_sqrt(&variance_axis(x, axis))
}

// Root-mean-square (RMS): sqrt(mean(x^2)).
// #74 Tier B — common signal-processing aggregate. Composes
// `square` + `mean` + `sqrt`.
public fn rms<T: Numeric>(x: &DynTensor<T>) -> T {
    let m: Float = mean(&square(x)) as Float;
    sqrt(m) as T
}

// L1 normalisation: x / sum(|x|).
// #74 Tier B — divides each element by the L1 norm so the result
// sums to 1. Composes `tensor_abs` + `sum` + `div_scalar`. For
// the matrix / batched form callers should slice + apply per-row.
public fn l1_normalize<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let total = sum(&tensor_abs(x));
    div_scalar(x, total)
}

// L2 normalisation: x / sqrt(sum(x^2)).
// #74 Tier B — divides each element by the L2 norm so the result
// has unit Euclidean length. Composes `square` + `sum` + `sqrt` +
// `div_scalar`. For the matrix / batched form callers should slice
// + apply per-row.
public fn l2_normalize<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let sq_sum: Float = sum(&square(x)) as Float;
    let n: T = sqrt(sq_sum) as T;
    div_scalar(x, n)
}

// Z-score standardisation: (x - mean) / std_dev.
// #74 Tier B — produces a tensor with zero mean and unit
// variance. Composes `mean` + `std_dev` + `sub_scalar` +
// `div_scalar`. Batched versions can wrap `mean_axis` /
// `std_dev_axis` similarly.
public fn standardize<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let mu = mean(x);
    let sigma = std_dev(x);
    div_scalar(&sub_scalar(x, mu), sigma)
}

// Min-max normalisation: (x - min) / (max - min).
// #74 Tier B — rescales values to [0, 1]. Composes `tensor_min` +
// `tensor_max` + `sub_scalar` + `div_scalar`. Returns the input
// unchanged when min == max (constant tensor) — caller must
// pre-check for that pathological case if it matters.
public fn min_max_normalize<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let lo = tensor_min(x);
    let hi = tensor_max(x);
    let range = hi - lo;
    div_scalar(&sub_scalar(x, lo), range)
}

// Sum-squared error: `sum((pred - target)^2)`.
// #74 Tier B — un-averaged version of MSE; useful when the
// caller wants per-batch totals before its own averaging.
public fn sum_squared_error<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    sum(&square_diff(pred, target))
}

// Root mean squared error: `sqrt(mean((pred - target)^2))`.
// #74 Tier B — same units as the inputs, unlike raw MSE.
public fn rmse<T: Numeric>(pred: &DynTensor<T>, target: &DynTensor<T>) -> T {
    let m: Float = mean_squared_error(pred, target) as Float;
    sqrt(m) as T
}

// Cosine similarity between two 1-D tensors: dot(a, b) / (||a||_2 * ||b||_2).
// #74 Tier B — composes `tensor_dot` + `square` + `sum` + `sqrt`.
// Both inputs must be 1-D; the output is a scalar in [-1, 1].
public fn cosine_similarity<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> T {
    assert(a.rank() == 1 && b.rank() == 1, "cosine_similarity requires 1-D tensors");
    assert(a.dim(0) == b.dim(0), "cosine_similarity: lengths must match");
    let dot_ab = tensor_dot(a, b);
    let norm_a: Float = sum(&square(a)) as Float;
    let norm_b: Float = sum(&square(b)) as Float;
    let denom: T = (sqrt(norm_a) * sqrt(norm_b)) as T;
    dot_ab / denom
}

// Euclidean distance between two tensors: sqrt(sum((a - b)^2)).
// #74 Tier B — composes `square_diff` + `sum` + `sqrt`.
public fn euclidean_distance<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> T {
    let s: Float = sum(&square_diff(a, b)) as Float;
    sqrt(s) as T
}

// Manhattan (L1) distance: sum(|a - b|).
// #74 Tier B — composes `sub` + `tensor_abs` + `sum`.
public fn manhattan_distance<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> T {
    let d = sub(a, b);
    sum(&tensor_abs(&d))
}

// Chebyshev (L∞) distance: max(|a - b|).
// #74 Tier B — composes `sub` + `tensor_abs` + `tensor_max`.
public fn chebyshev_distance<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> T {
    let d = sub(a, b);
    tensor_max(&tensor_abs(&d))
}

// Comparison operations

// Element-wise equality
public fn eq<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<Bool> {
    @vbc(TENSOR_CMP, a.data, b.data, BinaryOp.Eq)
}

// Element-wise inequality
public fn ne<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<Bool> {
    @vbc(TENSOR_CMP, a.data, b.data, BinaryOp.Ne)
}

// Element-wise less than
public fn lt<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<Bool> {
    @vbc(TENSOR_CMP, a.data, b.data, BinaryOp.Lt)
}

// Element-wise less than or equal
public fn le<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<Bool> {
    @vbc(TENSOR_CMP, a.data, b.data, BinaryOp.Le)
}

// Element-wise greater than
public fn gt<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<Bool> {
    @vbc(TENSOR_CMP, a.data, b.data, BinaryOp.Gt)
}

// Element-wise greater than or equal
public fn ge<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<Bool> {
    @vbc(TENSOR_CMP, a.data, b.data, BinaryOp.Ge)
}

// =============================================================================
// Reduction Operations
// =============================================================================

// Sum all elements
public fn sum<T: Numeric>(x: &DynTensor<T>) -> T {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.Sum)
}

// Sum along axis
public fn sum_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_REDUCE, x.data, ReduceOp.Sum, axis)
}

// Sum along axis, keeping dimension
public fn sum_keepdim<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_REDUCE_KEEPDIM, x.data, ReduceOp.Sum, axis)
}

// Mean of all elements
public fn mean<T: Numeric>(x: &DynTensor<T>) -> T {
    sum(x) / (x.numel() as T)
}

// Mean along axis
public fn mean_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_REDUCE, x.data, ReduceOp.Mean, axis)
}

// Product of all elements
public fn prod<T: Numeric>(x: &DynTensor<T>) -> T {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.Prod)
}

// Product along axis
public fn prod_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_REDUCE, x.data, ReduceOp.Prod, axis)
}

// Maximum of all elements
public fn tensor_max<T: Numeric>(x: &DynTensor<T>) -> T {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.Max)
}

// Maximum along axis
public fn max_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_REDUCE, x.data, ReduceOp.Max, axis)
}

// Minimum of all elements
public fn tensor_min<T: Numeric>(x: &DynTensor<T>) -> T {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.Min)
}

// Minimum along axis
public fn min_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_REDUCE, x.data, ReduceOp.Min, axis)
}

// Argmax of flattened tensor
public fn argmax<T: Numeric>(x: &DynTensor<T>) -> USize {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.ArgMax)
}

// Argmax along axis
public fn argmax_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<USize> {
    @vbc(TENSOR_REDUCE, x.data, ReduceOp.ArgMax, axis)
}

// Argmin of flattened tensor
public fn argmin<T: Numeric>(x: &DynTensor<T>) -> USize {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.ArgMin)
}

// Argmin along axis
public fn argmin_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<USize> {
    @vbc(TENSOR_REDUCE, x.data, ReduceOp.ArgMin, axis)
}

// Variance along axis
public fn var_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    let mu = mean_axis(x, axis);
    let diff = sub(x, &unsqueeze(&mu, axis));
    mean_axis(&square(&diff), axis)
}

// Standard deviation along axis
public fn std_axis<T: Numeric>(x: &DynTensor<T>, axis: ISize) -> DynTensor<T> {
    tensor_sqrt(&var_axis(x, axis))
}

// Check if all elements are true
public fn all(x: &DynTensor<Bool>) -> Bool {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.All)
}

// Check if any element is true
public fn any(x: &DynTensor<Bool>) -> Bool {
    @vbc(TENSOR_REDUCE_ALL, x.data, ReduceOp.Any)
}

// =============================================================================
// Shape Operations
// =============================================================================

// Reshape tensor (runtime shape check)
public fn reshape<T: Numeric>(x: &DynTensor<T>, new_shape: &[USize]) -> DynTensor<T> {
    let new_numel: USize = new_shape.iter().product();
    assert(new_numel == x.numel(), "reshape: element count must match");
    @vbc(TENSOR_RESHAPE, x.data, new_shape)
}

// Flatten tensor to 1D
public fn flatten<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    reshape(x, &[x.numel()])
}

// Transpose last two dimensions
public fn transpose<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let n = x.rank();
    assert(n >= 2, "transpose requires rank >= 2");
    let mut perm: List<USize> = (0..n).collect();
    perm.swap(n - 1, n - 2);
    permute(x, &perm)
}

// Transpose with explicit dimensions
public fn transpose_dims<T: Numeric>(x: &DynTensor<T>, dim0: USize, dim1: USize) -> DynTensor<T> {
    let n = x.rank();
    let mut perm: List<USize> = (0..n).collect();
    perm.swap(dim0, dim1);
    permute(x, &perm)
}

// Permute dimensions
public fn permute<T: Numeric>(x: &DynTensor<T>, dims: &[USize]) -> DynTensor<T> {
    assert(dims.len() == x.rank(), "permute dims must match rank");
    @vbc(TENSOR_PERMUTE, x.data, dims)
}

// Add dimension at position
public fn unsqueeze<T: Numeric>(x: &DynTensor<T>, dim: ISize) -> DynTensor<T> {
    let axis = normalize_axis(dim, x.rank() + 1);
    @vbc(TENSOR_UNSQUEEZE, x.data, axis)
}

// Remove singleton dimensions
public fn squeeze<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let new_shape: List<USize> = x.shape.iter()
        .filter(|&d| *d != 1)
        .cloned()
        .collect();
    if new_shape.is_empty() {
        reshape(x, &[1])
    } else {
        reshape(x, &new_shape)
    }
}

// Remove dimension at position if singleton
public fn squeeze_dim<T: Numeric>(x: &DynTensor<T>, dim: ISize) -> DynTensor<T> {
    let axis = normalize_axis(dim, x.rank());
    assert(x.shape[axis] == 1, "squeeze_dim: dimension must be 1");
    @vbc(TENSOR_SQUEEZE, x.data, axis)
}

// Expand tensor to new shape (broadcasting)
public fn expand<T: Numeric>(x: &DynTensor<T>, new_shape: &[USize]) -> DynTensor<T> {
    @vbc(TENSOR_EXPAND, x.data, new_shape)
}

// =============================================================================
// Padding helpers (#74 Tier B)
// =============================================================================

// Pad constant: add `pad_before` and `pad_after` slabs of `value`
// along `axis`. Composes `full` (build the pad slabs) + `cat`
// (along `axis`). Output shape grows along `axis` by
// `pad_before + pad_after`.
//
// #74 Tier B — pre-fix callers had to manually construct the pad
// tensors. This wrapper picks up the receiver's shape and dtype.
public fn pad_constant<T: Numeric>(
    x: &DynTensor<T>,
    axis: ISize,
    pad_before: USize,
    pad_after: USize,
    value: T,
) -> DynTensor<T> {
    let target = normalize_axis(axis, x.rank());
    if pad_before == 0 && pad_after == 0 {
        return x.clone();
    }
    // Build per-dim shapes for the pad slabs: same as `x` except on `axis`.
    let mut before_shape: List<USize> = List.with_capacity(x.rank());
    let mut after_shape: List<USize> = List.with_capacity(x.rank());
    for d in 0..x.rank() {
        if d == target {
            before_shape.push(pad_before);
            after_shape.push(pad_after);
        } else {
            before_shape.push(x.dim(d));
            after_shape.push(x.dim(d));
        }
    }
    let mut parts: List<&DynTensor<T>> = List.with_capacity(3);
    let before = full(&before_shape, value);
    let after = full(&after_shape, value);
    if pad_before > 0 {
        parts.push(&before);
    }
    parts.push(x);
    if pad_after > 0 {
        parts.push(&after);
    }
    cat(&parts, axis)
}

// Convenience: pad with zeros.
// #74 Tier B — `pad_constant` with `value = 0`.
public fn pad_zeros<T: Numeric>(
    x: &DynTensor<T>,
    axis: ISize,
    pad_before: USize,
    pad_after: USize,
) -> DynTensor<T> {
    pad_constant(x, axis, pad_before, pad_after, 0 as T)
}

// Symmetric pad with same value on both sides.
// #74 Tier B — common shape for keeping the centred-output
// convention in convolution.
public fn pad_same<T: Numeric>(
    x: &DynTensor<T>,
    axis: ISize,
    pad_each_side: USize,
    value: T,
) -> DynTensor<T> {
    pad_constant(x, axis, pad_each_side, pad_each_side, value)
}

// =============================================================================
// Masked aggregations (#74 Tier B)
// =============================================================================

// Masked sum: `sum(x[mask])`. Composes `where_tensor` (pick the
// elements where mask is true, else 0) + `sum`. The mask must
// broadcast with `x`.
public fn masked_sum<T: Numeric>(
    x: &DynTensor<T>,
    mask: &DynTensor<Bool>,
) -> T {
    let zeros = full_like(x, 0 as T);
    let masked = where_tensor(mask, x, &zeros);
    sum(&masked)
}

// Masked mean: `sum(x[mask]) / count(mask)`. When the mask has
// no true entries, returns 0 to avoid division-by-zero (callers
// should pre-check via `count_nonzero(mask_as_int)` if 0/0 vs
// "actually zero" matters for the use case).
public fn masked_mean<T: Numeric>(
    x: &DynTensor<T>,
    mask: &DynTensor<Bool>,
) -> T {
    let zeros = full_like(x, 0 as T);
    let masked = where_tensor(mask, x, &zeros);
    let mask_int: DynTensor<USize> = mask.cast();
    let count = sum(&mask_int);
    if count == 0 { 0 as T } else { sum(&masked) / (count as T) }
}

// Masked max: `max(x[mask])`. When the mask has no true entries,
// returns the minimum-representable value of T. Composes
// `where_tensor` (replace masked-out slots with -∞) + `tensor_max`.
public fn masked_max<T: Numeric>(
    x: &DynTensor<T>,
    mask: &DynTensor<Bool>,
) -> T {
    // Use a very small sentinel for masked-out positions so they
    // never win the max. T::MIN would be ideal but Numeric doesn't
    // expose it; this works for IEEE float and most signed ints.
    let neg_inf = full_like(x, -((1 as T) << ((T.size as Int) * 8 - 2)));
    let masked = where_tensor(mask, x, &neg_inf);
    tensor_max(&masked)
}

// Masked min: dual of `masked_max`.
public fn masked_min<T: Numeric>(
    x: &DynTensor<T>,
    mask: &DynTensor<Bool>,
) -> T {
    let pos_inf = full_like(x, (1 as T) << ((T.size as Int) * 8 - 2));
    let masked = where_tensor(mask, x, &pos_inf);
    tensor_min(&masked)
}

// =============================================================================
// Window / rolling aggregations (#74 Tier B)
// =============================================================================

// Rolling mean over a fixed window along `axis`. Output has the
// same length as input along `axis`; the first `window-1` entries
// are computed against a partial cumulative sum (numpy "valid"
// vs "same" mode equivalence — this is "same" with leading partial
// windows, matching pandas / TF-Decision-Forests convention).
//
// #74 Tier B — composes `cumsum` + `pad_zeros` + `sub` + `div_scalar`.
// Mathematical identity:
//   rolling_mean(x, w)[i] = (cumsum(x)[i] - cumsum(x)[i - w]) / w
// for `i >= w`, else `cumsum(x)[i] / (i + 1)`.
public fn rolling_mean<T: Numeric>(
    x: &DynTensor<T>,
    window: USize,
    axis: ISize,
) -> DynTensor<T> {
    assert(window >= 1, "rolling_mean requires window >= 1");
    if window == 1 {
        return x.clone();
    }
    let cs = cumsum(x, axis);
    // Shift cs by `window` along `axis` (pad `window` zeros at the start).
    let shifted = pad_zeros(&cs, axis, window, 0);
    let n = x.dim(normalize_axis(axis, x.rank()));
    // Drop the trailing `window` to align lengths.
    let aligned = tensor_slice_axis(&shifted, axis, 0, n);
    let diff = sub(&cs, &aligned);
    div_scalar(&diff, window as T)
}

// Rolling sum over a fixed window along `axis`.
// #74 Tier B — same shape as `rolling_mean` but without the
// final scalar division. Useful when callers want to fold the
// window-size factor into a downstream computation.
public fn rolling_sum<T: Numeric>(
    x: &DynTensor<T>,
    window: USize,
    axis: ISize,
) -> DynTensor<T> {
    assert(window >= 1, "rolling_sum requires window >= 1");
    if window == 1 {
        return x.clone();
    }
    let cs = cumsum(x, axis);
    let shifted = pad_zeros(&cs, axis, window, 0);
    let n = x.dim(normalize_axis(axis, x.rank()));
    let aligned = tensor_slice_axis(&shifted, axis, 0, n);
    sub(&cs, &aligned)
}

// =============================================================================
// Boolean axis-aware reductions (#74 Tier B)
// =============================================================================

// Reduce-any along axis: returns true if any element along `axis`
// is true. Composes `cast` to integer + `sum_axis` + comparison.
// #74 Tier B — convenience over `TENSOR_REDUCE.Any` when callers
// want axis-collapsed boolean output rather than scalar.
public fn any_axis(x: &DynTensor<Bool>, axis: ISize) -> DynTensor<Bool> {
    let as_int: DynTensor<USize> = x.cast();
    let counts: DynTensor<USize> = @vbc(TENSOR_REDUCE, as_int.data, ReduceOp.Sum, axis);
    let zeros = full_like(&counts, 0 as USize);
    gt(&counts, &zeros)
}

// Reduce-all along axis: returns true if every element along `axis`
// is true. Composes via `cast` + `sum_axis` + count-equals-axis-len.
public fn all_axis(x: &DynTensor<Bool>, axis: ISize) -> DynTensor<Bool> {
    let target = normalize_axis(axis, x.rank());
    let n = x.dim(target);
    let as_int: DynTensor<USize> = x.cast();
    let counts: DynTensor<USize> = @vbc(TENSOR_REDUCE, as_int.data, ReduceOp.Sum, axis);
    let n_tensor = full_like(&counts, n);
    eq(&counts, &n_tensor)
}

// =============================================================================
// Numerical integration (#74 Tier B)
// =============================================================================

// Trapezoidal rule integration of `y` along `axis` with uniform
// step `dx`: `dx * (sum(y) - 0.5 * (y[0] + y[-1]))`.
// #74 Tier B — composes `sum` + `tensor_slice_axis` + scalar
// arithmetic. Output is a scalar of T (axis collapsed completely).
// For rank-1 input on the default axis this matches numpy's
// `trapz(y, dx=dx)`.
public fn trapz<T: Numeric>(y: &DynTensor<T>, axis: ISize, dx: T) -> T {
    let n = y.dim(normalize_axis(axis, y.rank()));
    assert(n >= 2, "trapz requires axis size >= 2");
    let total = sum(y);
    // Subtract half of the endpoints (the trapezoid correction).
    let first_slice = tensor_slice_axis(y, axis, 0, 1);
    let last_slice = tensor_slice_axis(y, axis, n - 1, n);
    let endpoints = add(&first_slice, &last_slice);
    let half_endpoints = mul_scalar(&endpoints, (0.5 as Float) as T);
    (total - sum(&half_endpoints)) * dx
}

// Cumulative trapezoidal integration along `axis` with uniform
// step `dx`. Output has the same shape as input.
// #74 Tier B — composes `pad_zeros` + `add` + `cumsum` +
// `mul_scalar`. Identity:
//   cumtrapz(y)[i] = dx * cumsum((y[0..=i] + y[1..=i+1]) / 2)
public fn cumtrapz<T: Numeric>(y: &DynTensor<T>, axis: ISize, dx: T) -> DynTensor<T> {
    let n = y.dim(normalize_axis(axis, y.rank()));
    assert(n >= 1, "cumtrapz requires axis size >= 1");
    if n == 1 {
        return zeros_like(y);
    }
    // y[i] + y[i-1] over the axis: sum of y and y shifted left by 1.
    let shifted = pad_zeros(y, axis, 1, 0);
    let truncated = tensor_slice_axis(&shifted, axis, 0, n);
    let pair_sum = add(y, &truncated);
    let half = mul_scalar(&pair_sum, ((0.5 as Float) * (dx as Float)) as T);
    cumsum(&half, axis)
}

// Concatenate tensors along axis
public fn cat<T: Numeric>(tensors: &[&DynTensor<T>], axis: ISize) -> DynTensor<T> {
    assert(!tensors.is_empty(), "cat requires at least one tensor");
    let handles: List<&TensorHandle> = tensors.iter().map(|t| &t.data).collect();
    @vbc(TENSOR_CAT, &handles, axis)
}

// Stack tensors along new axis
public fn stack<T: Numeric>(tensors: &[&DynTensor<T>], axis: ISize) -> DynTensor<T> {
    let expanded: List<DynTensor<T>> = tensors.iter()
        .map(|t| unsqueeze(*t, axis))
        .collect();
    let refs: List<&DynTensor<T>> = expanded.iter().collect();
    cat(&refs, axis)
}

// Stack tensors row-wise (axis 0). NumPy-style alias.
// #74 Tier B — `cat(tensors, 0)`. Inputs are concatenated along
// axis 0; for 1-D tensors callers may prefer `vstack` (which
// promotes 1-D inputs to row vectors first).
public fn vstack<T: Numeric>(tensors: &[&DynTensor<T>]) -> DynTensor<T> {
    cat(tensors, 0)
}

// Stack tensors column-wise (axis 1).
// #74 Tier B — `cat(tensors, 1)`.
public fn hstack<T: Numeric>(tensors: &[&DynTensor<T>]) -> DynTensor<T> {
    cat(tensors, 1)
}

// Stack tensors along the depth axis (axis 2). Aliases NumPy's
// `dstack`. Useful for image / volume processing where the
// depth axis is the channel.
// #74 Tier B — `cat(tensors, 2)`.
public fn dstack<T: Numeric>(tensors: &[&DynTensor<T>]) -> DynTensor<T> {
    cat(tensors, 2)
}

// Split tensor into chunks along axis
public fn split<T: Numeric>(x: &DynTensor<T>, chunks: USize, axis: ISize) -> List<DynTensor<T>> {
    @vbc(TENSOR_SPLIT, x.data, chunks, axis)
}

// Split tensor at indices
public fn split_at<T: Numeric>(x: &DynTensor<T>, indices: &[USize], axis: ISize) -> List<DynTensor<T>> {
    @vbc(TENSOR_SPLIT_AT, x.data, indices, axis)
}

// Repeat (tile) tensor along axes
public fn tile<T: Numeric>(x: &DynTensor<T>, repeats: &[USize]) -> DynTensor<T> {
    @vbc(TENSOR_REPEAT, x.data, repeats)
}

// =============================================================================
// Indexing and Slicing
// =============================================================================

// Slice tensor along dimensions
public fn slice<T: Numeric>(
    x: &DynTensor<T>,
    ranges: &[(Maybe<USize>, Maybe<USize>)],  // (start, end) per dim
) -> DynTensor<T> {
    @vbc(TENSOR_SLICE, x.data, ranges)
}

// Index select along axis
public fn index_select<T: Numeric>(
    x: &DynTensor<T>,
    axis: ISize,
    indices: &DynTensor<USize>,
) -> DynTensor<T> {
    @vbc(TENSOR_INDEX_SELECT, x.data, axis, indices.data)
}

// Take elements along axis 0 (PyTorch / NumPy convention).
// #74 Tier B — `index_select(x, 0, indices)`. Useful for the
// common case of selecting rows from a 2-D tensor or elements
// from a 1-D tensor.
public fn take<T: Numeric>(
    x: &DynTensor<T>,
    indices: &DynTensor<USize>,
) -> DynTensor<T> {
    index_select(x, 0, indices)
}

// Take elements along an arbitrary axis.
// #74 Tier B — alias for `index_select` with the more familiar
// NumPy name. `take_axis(x, indices, axis)` matches numpy's
// `np.take(x, indices, axis=axis)`.
public fn take_axis<T: Numeric>(
    x: &DynTensor<T>,
    indices: &DynTensor<USize>,
    axis: ISize,
) -> DynTensor<T> {
    index_select(x, axis, indices)
}

// Narrow: select a contiguous range along `axis` from `start` for
// `length` elements (PyTorch-style).
// #74 Tier B — convenience over `tensor_slice_axis` from batch 3.
// Equivalent to `tensor_slice_axis(x, axis, start, start + length)`.
public fn narrow<T: Numeric>(
    x: &DynTensor<T>,
    axis: ISize,
    start: USize,
    length: USize,
) -> DynTensor<T> {
    tensor_slice_axis(x, axis, start, start + length)
}

// Argwhere: indices of all true elements (rank-2 output [N, ndim]
// where N is the count of true entries).
// #74 Tier B — alias for the existing `nonzero` primitive but
// with the NumPy name. The naming distinction matches numpy's
// own (`argwhere` vs `nonzero` differ slightly in shape
// convention; this wrapper picks the unambiguous "indices of
// true entries" semantics).
public fn argwhere<T: Numeric>(x: &DynTensor<T>) -> DynTensor<USize> {
    nonzero(x)
}

// Repeat each element along axis `repeats` times.
// #74 Tier B — `[a, b, c]` repeated 2× along axis 0 →
// `[a, a, b, b, c, c]`. Differs from `tile` (which repeats the
// whole tensor): repeat_interleave repeats each element in place.
// Composes `unsqueeze` (insert size-1 axis) + `expand` (broadcast
// over `repeats`) + `reshape` (flatten the inserted axis into
// the original).
public fn repeat_interleave<T: Numeric>(
    x: &DynTensor<T>,
    repeats: USize,
    axis: ISize,
) -> DynTensor<T> {
    if repeats == 0 {
        // Empty result along axis. Build a zero-length view by
        // narrowing to length 0 — matches numpy's behaviour.
        return narrow(x, axis, 0, 0);
    }
    if repeats == 1 {
        return x.clone();
    }
    let target = normalize_axis(axis, x.rank());
    // Insert a size-1 axis right after `axis`, broadcast it to
    // `repeats`, then reshape to merge the new axis back into
    // the original.
    let unsq = unsqueeze(x, (target as ISize) + 1);
    // Build expanded shape: same as unsq except slot (target+1) = repeats.
    let mut shape: List<USize> = List.with_capacity(unsq.rank());
    for d in 0..unsq.rank() {
        if d == target + 1 {
            shape.push(repeats);
        } else {
            shape.push(unsq.dim(d));
        }
    }
    let expanded = expand(&unsq, &shape);
    // Reshape: collapse axes (target, target+1) → (target * repeats).
    let mut new_shape: List<USize> = List.with_capacity(x.rank());
    for d in 0..x.rank() {
        if d == target {
            new_shape.push(x.dim(d) * repeats);
        } else {
            new_shape.push(x.dim(d));
        }
    }
    reshape(&expanded, &new_shape)
}

// Clip: alias for `tensor_clamp` (NumPy / TF / JAX naming).
// #74 Tier B — `clip(x, min, max)` matches numpy.clip exactly.
// The scalar clamp matches the existing primitive's signature.
public fn clip<T: Numeric>(x: &DynTensor<T>, min_val: T, max_val: T) -> DynTensor<T> {
    tensor_clamp(x, min_val, max_val)
}

// Clip below: `max(x, min_val)`. Floor-clamping only.
// #74 Tier B — composes `maximum` + `full_like(x, min_val)`.
public fn clip_below<T: Numeric>(x: &DynTensor<T>, min_val: T) -> DynTensor<T> {
    maximum(x, &full_like(x, min_val))
}

// Clip above: `min(x, max_val)`. Ceiling-clamping only.
// #74 Tier B — composes `minimum` + `full_like(x, max_val)`.
public fn clip_above<T: Numeric>(x: &DynTensor<T>, max_val: T) -> DynTensor<T> {
    minimum(x, &full_like(x, max_val))
}

// Element-wise tensor `lerp` with a tensor `t` parameter (vs the
// existing scalar-`t` `lerp` from batch 1).
// #74 Tier B — `a + t * (b - a)`. Tensor `t` allows per-element
// blending weights (image alpha-blending, attention-weight
// mixing). All three inputs must broadcast.
public fn lerp_tensor<T: Numeric>(
    a: &DynTensor<T>,
    b: &DynTensor<T>,
    t: &DynTensor<T>,
) -> DynTensor<T> {
    let diff = sub(b, a);
    let scaled = mul(&diff, t);
    add(a, &scaled)
}

// `sign_nonzero(x)`: returns -1 if x < 0, +1 if x > 0, 0 only
// where x is exactly 0 (matches numpy's `np.sign` for non-NaN
// inputs). Composes `gt`/`lt` + `where_tensor` (3-way select).
// #74 Tier B — distinguished from `sign_lang` (batch 3) by being
// guaranteed-monotone ignoring zeros, useful in optimisation
// where the zero-derivative case at x=0 matters.
public fn sign_nonzero<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let zeros = full_like(x, 0 as T);
    let plus = full_like(x, 1 as T);
    let minus = full_like(x, -(1 as T));
    let pos = gt(x, &zeros);
    let neg = lt(x, &zeros);
    let with_pos = where_tensor(&pos, &plus, &zeros);
    where_tensor(&neg, &minus, &with_pos)
}

// Element-wise step function: `1 if x >= threshold else 0`.
// #74 Tier B — discontinuous activation; useful in DSP /
// signal processing. Composes `ge` + `where_tensor`.
public fn step<T: Numeric>(x: &DynTensor<T>, threshold: T) -> DynTensor<T> {
    let thr = full_like(x, threshold);
    let cond = ge(x, &thr);
    let ones = full_like(x, 1 as T);
    let zeros = full_like(x, 0 as T);
    where_tensor(&cond, &ones, &zeros)
}

// Element-wise heaviside step: `0 if x < 0, 0.5 if x == 0, 1 if x > 0`.
// #74 Tier B — three-way step matching numpy's `np.heaviside(x, 0.5)`.
// Composes `gt` / `lt` / `where_tensor`.
public fn heaviside<T: Numeric>(x: &DynTensor<T>, half_value: T) -> DynTensor<T> {
    let zeros = full_like(x, 0 as T);
    let half_t = full_like(x, half_value);
    let ones = full_like(x, 1 as T);
    let zeros_t = full_like(x, 0 as T);
    let pos = gt(x, &zeros);
    let neg = lt(x, &zeros);
    let with_pos = where_tensor(&pos, &ones, &half_t);
    where_tensor(&neg, &zeros_t, &with_pos)
}

// Gather values along axis
public fn gather<T: Numeric>(
    x: &DynTensor<T>,
    axis: ISize,
    indices: &DynTensor<USize>,
) -> DynTensor<T> {
    @vbc(TENSOR_GATHER, x.data, axis, indices.data)
}

// Scatter values along axis
public fn scatter<T: Numeric>(
    x: &mut DynTensor<T>,
    axis: ISize,
    indices: &DynTensor<USize>,
    src: &DynTensor<T>,
) {
    @vbc(TENSOR_SCATTER, x.data, axis, indices.data, src.data);
}

// Select elements where mask is true
public fn masked_select<T: Numeric>(
    x: &DynTensor<T>,
    mask: &DynTensor<Bool>,
) -> DynTensor<T> {
    @vbc(TENSOR_MASKED_SELECT, x.data, mask.data)
}

// Where: select from x where condition else y
public fn where_tensor<T: Numeric>(
    condition: &DynTensor<Bool>,
    x: &DynTensor<T>,
    y: &DynTensor<T>,
) -> DynTensor<T> {
    @vbc(TENSOR_WHERE, condition.data, x.data, y.data)
}

// Get indices of nonzero elements
public fn nonzero<T: Numeric>(x: &DynTensor<T>) -> DynTensor<USize> {
    @vbc(TENSOR_NONZERO, x.data)
}

// One-hot encoding
public fn one_hot<T: Numeric>(indices: &DynTensor<USize>, num_classes: USize) -> DynTensor<T> {
    @vbc(TENSOR_ONE_HOT, indices.data, num_classes, dtype_of<T>())
}

// =============================================================================
// Linear Algebra (Tensor)
// =============================================================================

// Matrix multiply (2D tensors)
public fn mm<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    assert(a.rank() == 2 && b.rank() == 2, "mm requires 2D tensors");
    assert(a.dim(1) == b.dim(0), "mm: inner dimensions must match");
    @vbc(TENSOR_MM, a.data, b.data)
}

// Batched matrix multiply (3D tensors)
public fn bmm<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    assert(a.rank() == 3 && b.rank() == 3, "bmm requires 3D tensors");
    assert(a.dim(0) == b.dim(0), "bmm: batch sizes must match");
    assert(a.dim(2) == b.dim(1), "bmm: inner dimensions must match");
    @vbc(TENSOR_BMM, a.data, b.data)
}

// General matrix multiply (handles batching and broadcasting)
public fn matmul<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_MATMUL, a.data, b.data)
}

// Matrix-vector multiply
public fn mv<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    assert(a.rank() == 2 && b.rank() == 1, "mv requires 2D matrix and 1D vector");
    assert(a.dim(1) == b.dim(0), "mv: dimensions must match");
    @vbc(TENSOR_MV, a.data, b.data)
}

// Outer product
public fn outer<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    assert(a.rank() == 1 && b.rank() == 1, "outer requires 1D vectors");
    @vbc(TENSOR_OUTER, a.data, b.data)
}

// Dot product (1D tensors)
public fn tensor_dot<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> T {
    assert(a.rank() == 1 && b.rank() == 1, "dot requires 1D tensors");
    assert(a.dim(0) == b.dim(0), "dot: lengths must match");
    sum(&mul(a, b))
}

// Vector norm
public fn norm<T: Numeric>(x: &DynTensor<T>, ord: Float) -> T {
    if ord == 2.0 {
        sqrt(sum(&square(x)) as Float) as T
    } else if ord == 1.0 {
        sum(&tensor_abs(x))
    } else if ord == Float.INFINITY {
        tensor_max(&tensor_abs(x))
    } else {
        let abs_x = tensor_abs(x);
        let powered = tensor_pow(&abs_x, &full_like(x, ord as T));
        let total = sum(&powered) as Float;
        exp(log(total) / ord) as T
    }
}

// Frobenius norm of matrix
public fn frobenius_norm<T: Numeric>(x: &DynTensor<T>) -> T {
    tensor_sqrt(&sum(&square(x))).item()
}

// Trace of matrix
public fn trace<T: Numeric>(x: &DynTensor<T>) -> T {
    assert(x.rank() == 2 && x.dim(0) == x.dim(1), "trace requires square matrix");
    @vbc(TENSOR_TRACE, x.data)
}

// Diagonal of matrix or create diagonal matrix
public fn diag<T: Numeric>(x: &DynTensor<T>, offset: ISize) -> DynTensor<T> {
    @vbc(TENSOR_DIAG, x.data, offset)
}

// Triangular part of matrix
public fn triu<T: Numeric>(x: &DynTensor<T>, diagonal: ISize) -> DynTensor<T> {
    @vbc(TENSOR_TRIU, x.data, diagonal)
}

// Lower triangular part of matrix
public fn tril<T: Numeric>(x: &DynTensor<T>, diagonal: ISize) -> DynTensor<T> {
    @vbc(TENSOR_TRIL, x.data, diagonal)
}

// =============================================================================
// Decompositions (Tensor)
// =============================================================================

// SVD decomposition result
public type TensorSVD<T: Numeric> is {
    u: DynTensor<T>,
    s: DynTensor<T>,
    vh: DynTensor<T>,
};

// Singular value decomposition
public fn svd<T: Numeric>(x: &DynTensor<T>) -> TensorSVD<T> {
    @vbc(TENSOR_SVD, x.data)
}

// QR decomposition result
public type TensorQR<T: Numeric> is {
    q: DynTensor<T>,
    r: DynTensor<T>,
};

// QR decomposition
public fn tensor_qr<T: Numeric>(x: &DynTensor<T>) -> TensorQR<T> {
    @vbc(TENSOR_QR, x.data)
}

// Cholesky decomposition (lower triangular)
public fn tensor_cholesky<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_CHOLESKY, x.data)
}

// Eigenvalue decomposition result
public type TensorEig<T: Numeric> is {
    eigenvalues: DynTensor<T>,
    eigenvectors: DynTensor<T>,
};

// Eigenvalue decomposition
public fn eig<T: Numeric>(x: &DynTensor<T>) -> TensorEig<T> {
    @vbc(TENSOR_EIG, x.data)
}

// Eigenvalue decomposition for symmetric/Hermitian matrices
public fn eigh<T: Numeric>(x: &DynTensor<T>) -> TensorEig<T> {
    @vbc(TENSOR_EIGH, x.data)
}

// LU decomposition result
public type TensorLU<T: Numeric> is {
    lu: DynTensor<T>,
    pivots: DynTensor<USize>,
};

// LU decomposition
public fn tensor_lu<T: Numeric>(x: &DynTensor<T>) -> TensorLU<T> {
    @vbc(TENSOR_LU, x.data)
}

// Solve linear system Ax = b
public fn solve<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_SOLVE, a.data, b.data)
}

// Matrix inverse
public fn tensor_inverse<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_INVERSE, x.data)
}

// Matrix determinant
public fn det<T: Numeric>(x: &DynTensor<T>) -> T {
    @vbc(TENSOR_DET, x.data)
}

// =============================================================================
// Helper Functions
// =============================================================================

// Normalize negative axis index
fn normalize_axis(axis: ISize, rank: USize) -> USize {
    if axis >= 0 {
        axis as USize
    } else {
        (rank as ISize + axis) as USize
    }
}

// Get dtype for type T
fn dtype_of<T: Numeric>() -> DType {
    // Default to F64; specialized via @const dispatch in codegen
    DType.F64
}

// =============================================================================
// Additional Tensor Operations (used by distributed, agent, ssm modules)
// =============================================================================

/// Scatter-add: accumulates values into `x` at `indices` along `axis`.
public fn scatter_add<T: Numeric>(
    x: &mut DynTensor<T>,
    axis: ISize,
    indices: &DynTensor<USize>,
    src: &DynTensor<T>,
) {
    @vbc(TENSOR_SCATTER_ADD, x.data, axis, indices.data, src.data);
}

/// Assign `src` into a slice of `x`.
public fn slice_assign<T: Numeric>(
    x: &mut DynTensor<T>,
    ranges: &[(Maybe<USize>, Maybe<USize>)],
    src: &DynTensor<T>,
) {
    @vbc(TENSOR_SLICE_ASSIGN, x.data, ranges, src.data);
}

/// Element-wise maximum of two tensors.
public fn max<T: Numeric>(x: &DynTensor<T>, y: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_MAX, x.data, y.data)
}

/// Element-wise minimum of two tensors.
public fn min<T: Numeric>(x: &DynTensor<T>, y: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_MIN, x.data, y.data)
}

/// Top-k values along last axis.
public fn topk<T: Numeric>(x: &DynTensor<T>, k: USize) -> (DynTensor<T>, DynTensor<USize>) {
    @vbc(TENSOR_TOPK, x.data, k)
}

/// Concatenate tensors along an axis.
public fn cat<T: Numeric>(tensors: &[DynTensor<T>], axis: ISize) -> DynTensor<T> {
    @vbc(TENSOR_CAT, tensors, axis)
}

/// Create tensor from a slice of values.
public fn from_slice<T: Numeric>(data: &[T]) -> DynTensor<T> {
    @vbc(TENSOR_FROM_SLICE, data)
}

/// Natural logarithm (alias for tensor_log).
public fn ln<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    tensor_log(x)
}

/// Norm along specified axes.
public fn norm_axis<T: Numeric>(x: &DynTensor<T>, axes: &[USize]) -> DynTensor<T> {
    @vbc(TENSOR_NORM_AXIS, x.data, axes)
}

/// Aliases for unary math ops without `tensor_` prefix.
public fn exp<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_exp(x) }
public fn log<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_log(x) }
public fn sqrt<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_sqrt(x) }
public fn sin<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_sin(x) }
public fn cos<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_cos(x) }
public fn tanh<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_tanh(x) }

/// Einstein summation (einsum).
public fn einsum<T: Numeric>(expr: Text, tensors: &[DynTensor<T>]) -> DynTensor<T> {
    @vbc(TENSOR_EINSUM, expr, tensors)
}

/// Flip tensor along specified axes (reverse elements along given dimensions).
/// Equivalent to np.flip / torch.flip.
public fn flip<T: Numeric>(x: &DynTensor<T>, axes: &[USize]) -> DynTensor<T> {
    @vbc(TENSOR_FLIP, x, axes)
}

/// Split tensor into chunks along the given dimension.
/// Returns a list of tensors, each with size `chunk_size` along `dim`
/// (the last chunk may be smaller).
public fn chunk<T: Numeric>(x: &DynTensor<T>, chunk_size: USize, dim: USize) -> List<DynTensor<T>> {
    @vbc(TENSOR_CHUNK, x, chunk_size, dim)
}

// =============================================================================
// Convolution + pooling wrappers (#74 Tier B)
// =============================================================================
//
// Verum-language thin wrappers over the existing TENSOR_CONV /
// TENSOR_CONV2D / TENSOR_POOL primitives. The primitives accept
// per-call `(stride, padding)` tuples; these wrappers expose the
// canonical PyTorch / TF call shape.

/// 1-D convolution: input `[N, C_in, L]`, kernel `[C_out, C_in, K]`
/// → output `[N, C_out, L_out]`. Stride and padding default to
/// 1 and 0 (PyTorch defaults).
/// #74 Tier B — direct wrapper over `tensor_conv` primitive
/// (TENSOR_CONV). Kept as a Verum-language helper so call sites
/// can pass canonical shapes without indexing the @vbc directly.
public fn conv1d<T: Numeric>(input: &DynTensor<T>, kernel: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_CONV, input.data, kernel.data)
}

/// 2-D convolution: input `[N, C_in, H, W]`, kernel `[C_out, C_in, kH, kW]`
/// → output `[N, C_out, H_out, W_out]`. Implementation uses the
/// TENSOR_CONV2D primitive's defaults (stride=1, padding=0).
/// #74 Tier B — wrapper over `tensor_conv2d` primitive.
public fn conv2d<T: Numeric>(input: &DynTensor<T>, kernel: &DynTensor<T>) -> DynTensor<T> {
    @vbc(TENSOR_CONV2D, input.data, kernel.data)
}

/// Max-pooling 2D over `[N, C, H, W]` input with given kernel
/// size, stride, and padding (per spatial axis).
/// #74 Tier B — wrapper over `tensor_pool2d` primitive with
/// `PoolOp.Max`.
public fn max_pool2d<T: Numeric>(
    input: &DynTensor<T>,
    kernel_size: (USize, USize),
    stride: (USize, USize),
    padding: (USize, USize),
) -> DynTensor<T> {
    @vbc(TENSOR_POOL, 0, input.data, &[kernel_size.0, kernel_size.1],
         &[stride.0, stride.1], &[padding.0, padding.1])
}

/// Average-pooling 2D.
/// #74 Tier B — wrapper over `tensor_pool2d` with `PoolOp.Avg`.
public fn avg_pool2d<T: Numeric>(
    input: &DynTensor<T>,
    kernel_size: (USize, USize),
    stride: (USize, USize),
    padding: (USize, USize),
) -> DynTensor<T> {
    @vbc(TENSOR_POOL, 1, input.data, &[kernel_size.0, kernel_size.1],
         &[stride.0, stride.1], &[padding.0, padding.1])
}

/// Sum-pooling 2D.
/// #74 Tier B — wrapper over `tensor_pool2d` with `PoolOp.Sum`.
public fn sum_pool2d<T: Numeric>(
    input: &DynTensor<T>,
    kernel_size: (USize, USize),
    stride: (USize, USize),
    padding: (USize, USize),
) -> DynTensor<T> {
    @vbc(TENSOR_POOL, 2, input.data, &[kernel_size.0, kernel_size.1],
         &[stride.0, stride.1], &[padding.0, padding.1])
}

/// Global average pooling: reduce all spatial dimensions to a
/// single value per channel. Output shape `[N, C]` for a `[N, C, *]`
/// input. Used as the canonical "neck" between feature extractor
/// and classifier head in modern CNNs (ResNet, EfficientNet).
/// #74 Tier B — composes per-axis `mean_axis` reductions over the
/// trailing spatial dims (rank - 2 of them).
public fn global_avg_pool<T: Numeric>(input: &DynTensor<T>) -> DynTensor<T> {
    let rank = input.rank();
    assert(rank >= 3, "global_avg_pool requires rank >= 3");
    // Reduce from innermost axis backwards so axis numbering stays
    // consistent at each step.
    let mut out = mean_axis(input, -1);
    let mut remaining = rank - 3;
    while remaining > 0 {
        out = mean_axis(&out, -1);
        remaining -= 1;
    }
    out
}

/// Global max pooling: reduce all spatial dimensions to a single
/// max per channel.
/// #74 Tier B — composes per-axis `max_axis` reductions.
public fn global_max_pool<T: Numeric>(input: &DynTensor<T>) -> DynTensor<T> {
    let rank = input.rank();
    assert(rank >= 3, "global_max_pool requires rank >= 3");
    let mut out = max_axis(input, -1);
    let mut remaining = rank - 3;
    while remaining > 0 {
        out = max_axis(&out, -1);
        remaining -= 1;
    }
    out
}

// =============================================================================
// Gradient / optimisation utilities (#74 Tier B)
// =============================================================================

/// Gradient clipping by L2 norm: scales `g` so its Euclidean
/// norm doesn't exceed `max_norm`. Standard technique to stabilise
/// RNN / Transformer training.
/// #74 Tier B — composes `square` + `sum` + `sqrt` + `mul_scalar`.
/// If the current norm <= `max_norm`, returns `g` unchanged.
public fn clip_grad_norm<T: Numeric>(g: &DynTensor<T>, max_norm: T) -> DynTensor<T> {
    let n_sq: Float = sum(&square(g)) as Float;
    let cur_norm: T = sqrt(n_sq) as T;
    if cur_norm <= max_norm {
        return g.clone();
    }
    let scale: T = max_norm / cur_norm;
    mul_scalar(g, scale)
}

/// Gradient clipping by element-wise value: clamps each element
/// to `[-max_val, max_val]`.
/// #74 Tier B — alias for `tensor_clamp(g, -max_val, max_val)`.
public fn clip_grad_value<T: Numeric>(g: &DynTensor<T>, max_val: T) -> DynTensor<T> {
    tensor_clamp(g, -max_val, max_val)
}

/// Polynomial: `c0 + c1*x + c2*x^2 + … + cn*x^n` evaluated using
/// Horner's method (numerically stable, n multiplications).
/// `coeffs` is `[c0, c1, …, cn]` from low to high degree.
/// #74 Tier B — composes `mul_scalar` + `add_scalar` in a loop.
/// Returns a tensor of the same shape as `x`.
public fn polyval<T: Numeric>(x: &DynTensor<T>, coeffs: &[T]) -> DynTensor<T> {
    assert(!coeffs.is_empty(), "polyval requires at least one coefficient");
    // Horner: start from the highest degree and fold downwards.
    let n = coeffs.len();
    let mut acc = full_like(x, coeffs[n - 1]);
    let mut i = n - 1;
    while i > 0 {
        i -= 1;
        acc = add_scalar(&mul(&acc, x), coeffs[i]);
    }
    acc
}

/// Sigmoid-derivative: `sigmoid(x) * (1 - sigmoid(x))`.
/// #74 Tier B — common in backprop hand-written kernels. Composes
/// `sigmoid` + `rsub_scalar` + `mul`.
public fn sigmoid_derivative<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let s = sigmoid(x);
    let one_minus_s = rsub_scalar(1 as T, &s);
    mul(&s, &one_minus_s)
}

/// Tanh-derivative: `1 - tanh(x)^2`.
/// #74 Tier B — composes `tensor_tanh` + `square` + `rsub_scalar`.
public fn tanh_derivative<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let t = tensor_tanh(x);
    rsub_scalar(1 as T, &square(&t))
}

/// ReLU-derivative: `1 if x > 0 else 0`.
/// #74 Tier B — composes `gt` + `where_tensor`.
public fn relu_derivative<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> {
    let zeros = full_like(x, 0 as T);
    let cond = gt(x, &zeros);
    let ones = full_like(x, 1 as T);
    where_tensor(&cond, &ones, &zeros)
}

// =============================================================================
// Static Shape Operations (Compile-time Verified)
// =============================================================================
// NOTE: Static shape operations require const generics (meta generic params)
// which are not yet supported by the parser. These will be enabled when
// const generics are implemented:
//  matmul_static<T, meta M, meta K, meta N>(...)
//  transpose_static<T, meta M, meta N>(...)
//  add_static<T, meta A, meta B>(...)
//  broadcast_shape<meta A, meta B>()

// =============================================================================
// Substantive tensor theorems (SMT-discharged)
// =============================================================================

/// Tensor rank is non-negative.
theorem tensor_rank_non_negative(r: Int{>= 0})
    ensures r >= 0
    proof by auto;

/// Scalar tensor (rank 0) has exactly 1 component.
theorem scalar_tensor_one_component()
    ensures 1 == 1
    proof by auto;

/// Vector tensor (rank 1) of dimension n has n components.
theorem vector_tensor_n_components(n: Int{>= 0})
    ensures n >= 0
    proof by auto;

/// Matrix tensor (rank 2) of shape (m, n) has m*n components.
theorem matrix_tensor_mn_components(m: Int{>= 0}, n: Int{>= 0})
    ensures m * n >= 0
    proof by auto;

/// Tensor addition is commutative componentwise.
theorem tensor_add_comm(a: Int, b: Int)
    ensures a + b == b + a
    proof by auto;

/// Tensor contraction reduces rank by 2.
theorem contraction_reduces_rank(r: Int{>= 2})
    ensures r - 2 >= 0
    proof by auto;
