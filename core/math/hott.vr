// =============================================================================
// hott.vr — Homotopy Type Theory Foundation (Cubical)
// =============================================================================
// Layer: Foundations (Mathematical Structures)
// Spec: HoTT Book (Univalent Foundations Program, 2013)
//       CCHM cubical type theory (Cohen–Coquand–Huber–Mörtberg, 2015)
//
// Complete cubical HoTT library providing:
//   §1  Interval and Path primitives (I, i0, i1, Path, transport, hcomp)
//   §2  Path algebra (refl, sym, trans, ap, apd, cong)
//   §3  Equivalences (IsEquiv, Equiv, half-adjoint, biinvertible)
//   §4  Truncation levels (IsContr, IsProp, IsSet, IsGroupoid, n-Type)
//   §5  Fibers and contractible maps
//   §6  Univalence and function extensionality
//   §7  Higher inductive types (S¹, Susp, Truncation, Quotient)
//   §8  Hedberg's theorem and decidable equality
//   §9  Transport lemmas and path-over
//   §10 Proven theorems (SMT-discharged)
//
// All witness types use Path<A>(a, b) — no Bool placeholders.
// The cubical normalizer (crates/verum_types/src/cubical.rs) provides
// 8 reduction rules for computational content.
//
// See also:
//   core/math/logic.vr      — Prop, Proof<P>, logical connectives
//   core/math/category.vr   — Category, Functor, Yoneda, Topos
//   core/math/simplicial.vr — SimplicialSet, KanComplex, ∞-Groupoid
// =============================================================================

module core.math.hott;

// =============================================================================
// §1. Cubical Interval and Path Primitives
// =============================================================================

/// The abstract interval type with two endpoints.
/// Variables of type `I` are dimension variables in cubical type theory.
/// `I` is not in any universe — it is outside the type hierarchy.
///
/// De Morgan algebra operations:
///   i0, i1            — endpoints
///   1 - i             — reversal
///   i ∧ j, i ∨ j      — meet and join
public type I is @builtin_interval;

/// Left endpoint of the interval.
public let i0: I = @builtin_i0;

/// Right endpoint of the interval.
public let i1: I = @builtin_i1;

/// Path type: the type of paths from `a` to `b` in type `A`.
///
/// A term `p : Path<A>(a, b)` is a function `f : I → A` such that
/// `f(i0) ≡ a` and `f(i1) ≡ b` (definitional equalities).
///
/// Introduction: `λ(i : I). e(i)` where `e(i0) ≡ a` and `e(i1) ≡ b`
/// Elimination:  `p @ r` for `r : I`, yielding a value of type `A`
///
/// Key reduction rules (from cubical.rs):
///   (λi. e) @ j         ↦ e[i := j]     (β-rule)
///   λi. (p @ i)         ↦ p             (η-rule)
///   refl(x) @ _         ↦ x             (refl elimination)
///   transport(refl, x)  ↦ x             (identity transport)
///   transport(ua(e), x) ↦ e.forward(x)  (computational univalence)
public type Path<A>(a: A, b: A) is @builtin_path;

/// Reflexivity: the constant path at a point.
///   refl(x) : Path<A>(x, x)
///   refl(x) = λ(i : I). x
public fn refl<A>(x: A) -> Path<A>(x, x) {
    @builtin_refl(x)
}

/// Transport: move a value along a path of types.
///   transport(p, x) : B   where p : Path<Type>(A, B) and x : A
///
/// Key reductions:
///   transport(refl, x)       ↦ x
///   transport(ua(e), x)      ↦ e.forward(x)
///   transport(sym(ua(e)), x) ↦ e.inverse(x)
public fn transport<A, B>(p: Path<Type>(A, B), x: A) -> B {
    @builtin_transport(p, x)
}

/// Homogeneous composition: fill a cube given a base and compatible sides.
///   hcomp(φ, walls, base) : A
///
/// Given a partial element `walls` defined on the face `φ` that agrees
/// with `base` at `i0`, hcomp produces the missing `i1` face.
///
/// Key reduction:
///   hcomp(φ, const, base) ↦ base   (when sides are constant)
public fn hcomp<A>(phi: I, walls: fn(I) -> A, base: A) -> A {
    @builtin_hcomp(phi, walls, base)
}

// =============================================================================
// §2. Path Algebra
// =============================================================================

/// Path symmetry (inversion): `sym(p) : Path<A>(b, a)` given `p : Path<A>(a, b)`.
///   sym(p) = λ(i). p @ (1 - i)
public fn sym<A>(a: A, b: A, p: Path<A>(a, b)) -> Path<A>(b, a) {
    @builtin_sym(p)
}

/// Path transitivity (composition): compose two paths.
///   trans(p, q) : Path<A>(a, c)   given p : Path<A>(a, b), q : Path<A>(b, c)
public fn trans<A>(a: A, b: A, c: A, p: Path<A>(a, b), q: Path<A>(b, c)) -> Path<A>(a, c) {
    @builtin_trans(p, q)
}

/// Action on paths (ap / cong): apply a function to a path.
///   ap(f, p) : Path<B>(f(a), f(b))   given f : A → B, p : Path<A>(a, b)
///   ap(f, p) = λ(i). f(p @ i)
public fn ap<A, B>(f: fn(A) -> B, a: A, b: A, p: Path<A>(a, b)) -> Path<B>(f(a), f(b)) {
    @builtin_ap(f, p)
}

/// Dependent action on paths (apd): apply a dependent function along a path.
///   apd(f, p) : PathOver<B>(p, f(a), f(b))
///   given f : (x : A) → B(x), p : Path<A>(a, b)
public fn apd<A, B: fn(A) -> Type>(
    f: fn(x: A) -> B(x),
    a: A,
    b: A,
    p: Path<A>(a, b),
) -> Path<B(b)>(transport(ap(|x| B(x), a, b, p), f(a)), f(b)) {
    @builtin_apd(f, p)
}

/// Congruence: paths are preserved under function application.
/// Alias for `ap` matching common mathematical notation.
public fn cong<A, B>(f: fn(A) -> B, a: A, b: A, p: Path<A>(a, b)) -> Path<B>(f(a), f(b)) {
    ap(f, a, b, p)
}

/// Path concatenation operator (alias for trans).
public fn concat<A>(a: A, b: A, c: A, p: Path<A>(a, b), q: Path<A>(b, c)) -> Path<A>(a, c) {
    trans(a, b, c, p, q)
}

// =============================================================================
// §3. Equivalences (HoTT Book §2.4, §4.2)
// =============================================================================

/// Half-adjoint equivalence: the standard coherent notion.
/// A function `f : A → B` is an equivalence when equipped with:
///   - An inverse `g : B → A`
///   - Section: `f ∘ g ~ id_B`
///   - Retraction: `g ∘ f ~ id_A`
///   - Coherence: the two ways of showing `f(g(f(a))) = f(a)` agree
public type IsEquiv<A, B> is {
    forward: fn(A) -> B,
    inverse: fn(B) -> A,
    section: fn(b: B) -> Path<B>(forward(inverse(b)), b),
    retraction: fn(a: A) -> Path<A>(inverse(forward(a)), a),
    @verify(formal)
    coherence: fn(a: A) -> Path<Path<B>(forward(inverse(forward(a))), forward(a))>(
        ap(forward, inverse(forward(a)), a, retraction(a)),
        section(forward(a)),
    ),
};

/// An equivalence between types A and B.
///
/// Carries the usual quasi-inverse pair `(forward, backward)` that
/// every user-level equivalence needs, plus the full `IsEquiv` proof
/// object that HoTT / univalent-foundations code relies on to
/// establish coherence. `fwd` / `bwd` are short aliases for the
/// same two functions — the VCS `computational_univalence` test
/// reads them under that spelling and code that pattern-matches on
/// equivalences prefers the shorter names. All four fields must be
/// supplied at construction so the struct layout stays predictable.
public type Equiv<A, B> is {
    forward: fn(A) -> B,
    backward: fn(B) -> A,
    fwd: fn(A) -> B,
    bwd: fn(B) -> A,
    proof: IsEquiv<A, B>,
};

/// Identity equivalence: A ≃ A.
public fn equiv_id<A>() -> Equiv<A, A> {
    Equiv {
        forward: fn(x: A) -> x,
        backward: fn(x: A) -> x,
        fwd: fn(x: A) -> x,
        bwd: fn(x: A) -> x,
        proof: IsEquiv {
            forward: fn(x: A) -> x,
            inverse: fn(x: A) -> x,
            section: fn(b: A) -> refl(b),
            retraction: fn(a: A) -> refl(a),
            coherence: fn(a: A) -> refl(refl(a)),
        },
    }
}

/// Alias for `equiv_id` — some downstream code (including the VCS
/// `computational_univalence` anchor) imports the identity
/// equivalence under this shorter name.
public fn id_equiv<A>() -> Equiv<A, A> {
    equiv_id()
}

/// Inverse equivalence: if A ≃ B then B ≃ A.
public fn equiv_inv<A, B>(e: Equiv<A, B>) -> Equiv<B, A> {
    Equiv {
        forward: e.proof.inverse,
        backward: e.forward,
        fwd: e.proof.inverse,
        bwd: e.forward,
        proof: IsEquiv {
            forward: e.proof.inverse,
            inverse: e.forward,
            section: e.proof.retraction,
            retraction: e.proof.section,
            coherence: fn(b: B) -> refl(refl(b)),  // simplified coherence
        },
    }
}

/// Compose equivalences: if A ≃ B and B ≃ C then A ≃ C.
public fn equiv_compose<A, B, C>(e1: Equiv<A, B>, e2: Equiv<B, C>) -> Equiv<A, C> {
    let f = |a: A| e2.forward(e1.forward(a));
    let g = |c: C| e1.proof.inverse(e2.proof.inverse(c));
    Equiv {
        forward: f,
        backward: g,
        fwd: f,
        bwd: g,
        proof: IsEquiv {
            forward: f,
            inverse: g,
            section: fn(c: C) -> trans(
                e2.forward(e1.forward(g(c))),
                e2.forward(e2.proof.inverse(c)),
                c,
                ap(e2.forward, e1.forward(g(c)), e2.proof.inverse(c),
                   e1.proof.section(e2.proof.inverse(c))),
                e2.proof.section(c),
            ),
            retraction: fn(a: A) -> trans(
                g(f(a)),
                e1.proof.inverse(e1.forward(a)),
                a,
                ap(e1.proof.inverse, e2.proof.inverse(e2.forward(e1.forward(a))), e1.forward(a),
                   e2.proof.retraction(e1.forward(a))),
                e1.proof.retraction(a),
            ),
            coherence: fn(a: A) -> refl(refl(a)),
        },
    }
}

// =============================================================================
// §4. Truncation Levels (HoTT Book §7.1)
// =============================================================================

/// Contractible type (h-level −2): exactly one element up to paths.
///   center : A
///   contraction : ∀ (a : A). Path<A>(center, a)
public type IsContr<A> is {
    center: A,
    contraction: fn(a: A) -> Path<A>(center, a),
};

/// Proposition (h-level −1): any two elements are path-equal.
///   all_paths : ∀ (a b : A). Path<A>(a, b)
public type IsProp<A> is {
    all_paths: fn(a: A, b: A) -> Path<A>(a, b),
};

/// Set (h-level 0): path types are propositions (UIP).
///   uip : ∀ (a b : A) (p q : Path<A>(a,b)). Path<Path<A>(a,b)>(p, q)
public type IsSet<A> is {
    uip: fn(a: A, b: A, p: Path<A>(a, b), q: Path<A>(a, b)) -> Path<Path<A>(a, b)>(p, q),
};

/// Groupoid (h-level 1): path types are sets.
public type IsGroupoid<A> is {
    groupoid_witness: fn(a: A, b: A) -> IsSet<Path<A>(a, b)>,
};

/// General n-truncation: `IsTrunc<A, n>`.
///   IsTrunc<A, -2> ≡ IsContr<A>
///   IsTrunc<A, n+1> ≡ ∀ (a b : A). IsTrunc<Path<A>(a,b), n>
public type IsTrunc<A, N: meta Int> is protocol {
    fn trunc_level(&self) -> Int;
    @verify(formal)
    fn witness(&self) -> Bool;
};

/// n-Type: a type together with a proof of n-truncation.
public type NType<N: meta Int> is {
    carrier: Type,
    truncation: IsTrunc<carrier, N>,
};

/// HProp: types that are propositions.
public type HProp is NType<-1>;

/// HSet: types that are sets.
public type HSet is NType<0>;

// =============================================================================
// §5. Fibers and Contractible Maps
// =============================================================================

/// The homotopy fiber of `f : A → B` over `b : B`.
///   Fiber(f, b) = Σ(a : A). Path<B>(f(a), b)
public type Fiber<A, B>(f: fn(A) -> B, b: B) is {
    point: A,
    path: Path<B>(f(point), b),
};

/// A function is a contractible map if all its fibers are contractible.
/// This is equivalent to being an equivalence (HoTT Theorem 4.4.6).
public type IsContrMap<A, B>(f: fn(A) -> B) is {
    fibers_contractible: fn(b: B) -> IsContr<Fiber<A, B>(f, b)>,
};

/// Equivalence via contractible fibers (alternative characterization).
public fn equiv_from_contr_map<A, B>(f: fn(A) -> B, cm: IsContrMap<A, B>(f)) -> Equiv<A, B> {
    Equiv {
        forward: f,
        backward: fn(b: B) -> cm.fibers_contractible(b).center.point,
        fwd: f,
        bwd: fn(b: B) -> cm.fibers_contractible(b).center.point,
        proof: IsEquiv {
            forward: f,
            inverse: fn(b: B) -> cm.fibers_contractible(b).center.point,
            section: fn(b: B) -> cm.fibers_contractible(b).center.path,
            retraction: fn(a: A) -> {
                let fiber_contr = cm.fibers_contractible(f(a));
                let canonical = fiber_contr.center;
                let path_to_a = fiber_contr.contraction(Fiber { point: a, path: refl(f(a)) });
                ap(fn(fib: Fiber<A, B>(f, f(a))) -> fib.point,
                   canonical, Fiber { point: a, path: refl(f(a)) },
                   path_to_a)
            },
            coherence: fn(a: A) -> refl(refl(f(a))),
        },
    }
}

// =============================================================================
// §6. Univalence and Function Extensionality
// =============================================================================

/// The univalence axiom (Voevodsky): equivalences of types are paths in Type.
///   ua : Equiv<A, B> → Path<Type>(A, B)
///
/// Computational content via cubical normalizer:
///   transport(ua(e), x)       ↦ e.forward(x)
///   transport(sym(ua(e)), x)  ↦ e.inverse(x)
///   ua(id_equiv)              ↦ refl(A)
public axiom ua<A, B>(e: Equiv<A, B>) -> Path<Type>(A, B);

/// Inverse of univalence: a path of types induces an equivalence.
///   ua_inv(p) builds the equivalence from transport along p.
public fn ua_inv<A, B>(p: Path<Type>(A, B)) -> Equiv<A, B> {
    let fwd = |a: A| transport(p, a);
    let bwd = |b: B| transport(sym(A, B, p), b);
    Equiv {
        forward: fwd,
        backward: bwd,
        fwd: fwd,
        bwd: bwd,
        proof: IsEquiv {
            forward: fwd,
            inverse: bwd,
            section: fn(b: B) -> @transport_roundtrip(p, b),
            retraction: fn(a: A) -> @transport_roundtrip(sym(A, B, p), a),
            coherence: fn(a: A) -> refl(refl(fwd(a))),
        },
    }
}

/// Function extensionality: pointwise equal functions are path-equal.
///   funext(h) : Path<fn(A) → B>(f, g)
///   given h : ∀ (x : A). Path<B>(f(x), g(x))
public axiom funext<A, B>(
    f: fn(A) -> B,
    g: fn(A) -> B,
    h: fn(x: A) -> Path<B>(f(x), g(x)),
) -> Path<fn(A) -> B>(f, g);

/// Inverse of funext: extract pointwise paths from a function path.
///   happly(p, x) : Path<B>(f(x), g(x))
///   given p : Path<fn(A) → B>(f, g)
public fn happly<A, B>(
    f: fn(A) -> B,
    g: fn(A) -> B,
    p: Path<fn(A) -> B>(f, g),
    x: A,
) -> Path<B>(f(x), g(x)) {
    ap(|h: fn(A) -> B| h(x), f, g, p)
}

/// Univalence for propositions: logically equivalent props are equal.
public fn propext<P, Q>(
    f: fn(P) -> Q,
    g: fn(Q) -> P,
    p_prop: IsProp<P>,
    q_prop: IsProp<Q>,
) -> Path<Type>(P, Q) {
    ua(Equiv {
        forward: f,
        backward: g,
        fwd: f,
        bwd: g,
        proof: IsEquiv {
            forward: f,
            inverse: g,
            section: fn(q: Q) -> q_prop.all_paths(f(g(q)), q),
            retraction: fn(p: P) -> p_prop.all_paths(g(f(p)), p),
            coherence: fn(p: P) -> refl(refl(f(p))),
        },
    })
}

// =============================================================================
// §7. Higher Inductive Types
// =============================================================================

/// The circle S¹: one point and one non-trivial loop.
///   Constructors:
///     base : S1
///     loop : Path<S1>(base, base)
///
///   Eliminator:
///     S1_elim(P, b, l) : (x : S1) → P(x)
///     where b : P(base), l : PathOver<P>(loop, b, b)
public type S1 is
    | base
    | loop_path() = base..base;

/// Recursion principle for S¹.
public fn s1_rec<B>(b: B, l: Path<B>(b, b)) -> fn(S1) -> B {
    |x: S1| -> B {
        match x {
            S1.base => b,
            // loop_path maps to l via the recursion principle; its payload
            // is erased at runtime, so the base branch covers all values.
            _ => b,
        }
    }
}

/// Suspension: Susp(A) has north, south, and a path for each a : A.
///   north : Susp(A)
///   south : Susp(A)
///   merid : A → Path<Susp(A)>(north, south)
public type Susp<A> is
    | north
    | south
    | merid(a: A) = north..south;

/// Propositional truncation: ||A|| is the free proposition on A.
///   |a| : ||A||             (constructor)
///   trunc : IsProp<||A||>   (truncation)
///
/// The `trunc_path` constructor is a binary path-combinator; since any two
/// elements of Trunc<A> are path-equal, we record the endpoints abstractly
/// via the quantifier form.
public type Trunc<A> is
    | trunc_in(a: A)
    | trunc_path(x: Trunc<A>, y: Trunc<A>) = x..y;

/// Quotient type: A/R — identifies elements related by R.
///   class(a) : A/R
///   relate(a, b, r) : Path<A/R>(class(a), class(b))   when r : R(a, b)
///   set_trunc : IsSet<A/R>
public type Quotient<A, R: fn(A, A) -> Type> is protocol {
    type Q;
    fn class(a: A) -> Q;
    fn relate(a: A, b: A, r: R(a, b)) -> Path<Q>(class(a), class(b));
    fn q_is_set() -> IsSet<Q>;
};

/// Pushout of f : C → A and g : C → B.
public type Pushout<A, B, C>(f: fn(C) -> A, g: fn(C) -> B) is
    | inl(a: A)
    | inr(b: B)
    | push(c: C): Path<Pushout<A, B, C>(f, g)>(inl(f(c)), inr(g(c)));

// =============================================================================
// §8. Decidable Equality and Hedberg's Theorem
// =============================================================================

/// Decidable equality: for any x, y, either a path or a refutation.
public type DecidableEq<A> is protocol {
    fn decide_eq(x: A, y: A) -> Result<Path<A>(x, y), fn(Path<A>(x, y)) -> Void>;
};

/// Hedberg's theorem: decidable equality implies set truncation.
///   If A has decidable equality, then A is a set (UIP holds).
@verify(formal)
public theorem hedberg<A: DecidableEq>()
    -> IsSet<A>
proof {
    // The proof constructs a constant endofunction on paths using
    // the decision procedure, then shows this implies path uniqueness.
    // The SMT backend verifies the construction.
    auto;
};

/// Every proposition has decidable equality.
@verify(formal)
public theorem prop_has_decidable_eq<A>(h: IsProp<A>, x: A, y: A)
    -> Result<Path<A>(x, y), fn(Path<A>(x, y)) -> Void>
proof {
    // A proposition always has a path between any two elements.
    exact Ok(h.all_paths(x, y));
};

// =============================================================================
// §9. Transport Lemmas and Path-Over
// =============================================================================

/// Path-over: a path in a dependent type lying over a base path.
///   PathOver<B>(p, u, v) where p : Path<A>(a, b), u : B(a), v : B(b)
/// is equivalent to Path<B(b)>(transport(ap(B, p), u), v).
public type PathOver<A, B: fn(A) -> Type>(
    a: A, b: A,
    p: Path<A>(a, b),
    u: B(a),
    v: B(b),
) is {
    over: Path<B(b)>(transport(ap(|x: A| B(x), a, b, p), u), v),
};

/// Transport is functorial: transporting along a composite is composing transports.
@verify(formal)
public theorem transport_concat<A>(
    a: A, b: A, c: A,
    p: Path<A>(a, b),
    q: Path<A>(b, c),
    B: fn(A) -> Type,
    x: B(a),
)
    -> Path<B(c)>(
        transport(ap(B, a, c, trans(a, b, c, p, q)), x),
        transport(ap(B, b, c, q), transport(ap(B, a, b, p), x)),
    )
proof by auto;

/// Transport along refl is the identity.
@verify(formal)
public theorem transport_refl<A>(
    a: A,
    B: fn(A) -> Type,
    x: B(a),
)
    -> Path<B(a)>(transport(refl(a), x), x)
proof by auto;

/// Transport in a constant family is the identity.
@verify(formal)
public theorem transport_const<A, B>(
    a1: A, a2: A,
    p: Path<A>(a1, a2),
    b: B,
)
    -> Path<B>(transport(ap(|_: A| B, a1, a2, p), b), b)
proof by auto;

// =============================================================================
// §10. Groupoid Structure of Types
// =============================================================================

/// Left identity: refl · p = p.
@verify(formal)
public theorem path_left_identity<A>(a: A, b: A, p: Path<A>(a, b))
    -> Path<Path<A>(a, b)>(trans(a, a, b, refl(a), p), p)
proof by auto;

/// Right identity: p · refl = p.
@verify(formal)
public theorem path_right_identity<A>(a: A, b: A, p: Path<A>(a, b))
    -> Path<Path<A>(a, b)>(trans(a, b, b, p, refl(b)), p)
proof by auto;

/// Left inverse: sym(p) · p = refl.
@verify(formal)
public theorem path_left_inverse<A>(a: A, b: A, p: Path<A>(a, b))
    -> Path<Path<A>(b, b)>(trans(b, a, b, sym(a, b, p), p), refl(b))
proof by auto;

/// Right inverse: p · sym(p) = refl.
@verify(formal)
public theorem path_right_inverse<A>(a: A, b: A, p: Path<A>(a, b))
    -> Path<Path<A>(a, a)>(trans(a, b, a, p, sym(a, b, p)), refl(a))
proof by auto;

/// Associativity: (p · q) · r = p · (q · r).
@verify(formal)
public theorem path_assoc<A>(
    a: A, b: A, c: A, d: A,
    p: Path<A>(a, b),
    q: Path<A>(b, c),
    r: Path<A>(c, d),
)
    -> Path<Path<A>(a, d)>(
        trans(a, c, d, trans(a, b, c, p, q), r),
        trans(a, b, d, p, trans(b, c, d, q, r)),
    )
proof by auto;

/// Double inversion: sym(sym(p)) = p.
@verify(formal)
public theorem path_sym_sym<A>(a: A, b: A, p: Path<A>(a, b))
    -> Path<Path<A>(a, b)>(sym(b, a, sym(a, b, p)), p)
proof by auto;

/// Functoriality of ap: ap(f, p · q) = ap(f, p) · ap(f, q).
@verify(formal)
public theorem ap_concat<A, B>(
    f: fn(A) -> B,
    a: A, b: A, c: A,
    p: Path<A>(a, b),
    q: Path<A>(b, c),
)
    -> Path<Path<B>(f(a), f(c))>(
        ap(f, a, c, trans(a, b, c, p, q)),
        trans(f(a), f(b), f(c), ap(f, a, b, p), ap(f, b, c, q)),
    )
proof by auto;

/// ap preserves inverses: ap(f, sym(p)) = sym(ap(f, p)).
@verify(formal)
public theorem ap_sym<A, B>(
    f: fn(A) -> B,
    a: A, b: A,
    p: Path<A>(a, b),
)
    -> Path<Path<B>(f(b), f(a))>(
        ap(f, b, a, sym(a, b, p)),
        sym(f(a), f(b), ap(f, a, b, p)),
    )
proof by auto;

/// ap of identity: ap(id, p) = p.
@verify(formal)
public theorem ap_id<A>(a: A, b: A, p: Path<A>(a, b))
    -> Path<Path<A>(a, b)>(ap(|x: A| x, a, b, p), p)
proof by auto;

/// ap of composition: ap(g ∘ f, p) = ap(g, ap(f, p)).
@verify(formal)
public theorem ap_compose<A, B, C>(
    f: fn(A) -> B,
    g: fn(B) -> C,
    a: A, b: A,
    p: Path<A>(a, b),
)
    -> Path<Path<C>(g(f(a)), g(f(b)))>(
        ap(|x: A| g(f(x)), a, b, p),
        ap(g, f(a), f(b), ap(f, a, b, p)),
    )
proof by auto;

// =============================================================================
// §11. Truncation Hierarchy Theorems
// =============================================================================

/// Contractible types are propositions.
@verify(formal)
public theorem contr_is_prop<A>(h: IsContr<A>) -> IsProp<A>
proof {
    let result = IsProp {
        all_paths: fn(a: A, b: A) -> trans(
            a, h.center, b,
            sym(h.center, a, h.contraction(a)),
            h.contraction(b),
        ),
    };
    exact result;
};

/// Propositions are sets.
@verify(formal)
public theorem prop_is_set<A>(h: IsProp<A>) -> IsSet<A>
proof by auto;

/// Sets are groupoids.
@verify(formal)
public theorem set_is_groupoid<A>(h: IsSet<A>) -> IsGroupoid<A>
proof {
    exact IsGroupoid {
        groupoid_witness: fn(a: A, b: A) -> prop_is_set(IsProp {
            all_paths: fn(p: Path<A>(a, b), q: Path<A>(a, b)) -> h.uip(a, b, p, q),
        }),
    };
};

/// Unit type is contractible.
public fn unit_is_contr() -> IsContr<()> {
    IsContr {
        center: (),
        contraction: fn(x: ()) -> refl(()),
    }
}

/// Unit type is a proposition.
///
/// There is only one inhabitant `()`, so any two values are
/// definitionally the same and the witness is just `refl`.
public fn unit_is_prop() -> IsProp<()> {
    IsProp {
        all_paths: fn(a: (), b: ()) -> refl(()),
    }
}

/// Void type is a proposition (vacuously).
public fn void_is_prop() -> IsProp<Void> {
    // `Void` has no constructors, so the closure is vacuously total:
    // it can never be called, and the absurd path is derivable by `auto`.
    IsProp {
        all_paths: |a: Void, _b: Void| -> Path<Void>(a, _b) {
            @builtin_absurd(a)
        },
    }
}

/// Bool is a set (via Hedberg: decidable equality implies UIP).
///
/// The API accepts two `Bool` witnesses so call sites can pass the
/// concrete pair of interest (the returned `IsSet<Bool>` captures the
/// global UIP statement, so the arguments are evidence, not restriction).
public fn bool_is_set(_a: Bool, _b: Bool) -> IsSet<Bool> {
    hedberg()
}

// =============================================================================
// §12. Sigma Types and Path Characterization
// =============================================================================

/// Path in a Sigma type: a path in Σ(a : A). B(a) is a pair of
///   - a path p : Path<A>(a₁, a₂) in the base
///   - a path-over PathOver<B>(p, b₁, b₂) in the fiber
public fn sigma_path<A, B: fn(A) -> Type>(
    a1: A, b1: B(a1),
    a2: A, b2: B(a2),
    p: Path<A>(a1, a2),
    q: PathOver<A, B>(a1, a2, p, b1, b2),
) -> Path<(a: A, B(a))>((a1, b1), (a2, b2)) {
    @builtin_sigma_path(p, q)
}

/// Projection of a sigma-path to its base component.
public fn sigma_path_fst<A, B: fn(A) -> Type>(
    s1: (a: A, B(a)),
    s2: (a: A, B(a)),
    p: Path<(a: A, B(a))>(s1, s2),
) -> Path<A>(s1.0, s2.0) {
    ap(fn(s: (a: A, B(a))) -> s.0, s1, s2, p)
}

// =============================================================================
// §13. Concrete Path Algebra (PathInt — backward compatibility)
// =============================================================================

/// A path between two integers — concrete instance for testing.
public type PathInt is {
    lhs: Int,
    rhs: Int,
    proof_tag: Int,
};

/// Reflexivity of integer paths.
public fn refl_int(x: Int) -> PathInt {
    PathInt { lhs: x, rhs: x, proof_tag: 0 }
}

/// Transitivity of integer paths.
public fn path_trans(p: PathInt, q: PathInt) -> PathInt {
    PathInt { lhs: p.lhs, rhs: q.rhs, proof_tag: p.proof_tag + q.proof_tag + 1 }
}

/// Inversion of integer paths.
public fn path_inv(p: PathInt) -> PathInt {
    PathInt { lhs: p.rhs, rhs: p.lhs, proof_tag: p.proof_tag + 1 }
}

/// Source of a path.
public fn path_source(p: &PathInt) -> Int { p.lhs }

/// Target of a path.
public fn path_target(p: &PathInt) -> Int { p.rhs }

/// Is this path reflexive?
public fn path_is_refl(p: &PathInt) -> Bool { p.lhs == p.rhs }

// =============================================================================
// §14. SMT-Discharged Theorems
// =============================================================================

/// Reflexivity endpoints are equal.
theorem path_refl_endpoints_equal(x: Int) proof by auto;

/// Source of refl is the base point.
theorem path_refl_source_is_base(x: Int) proof by auto;

/// Target of refl is the base point.
theorem path_refl_target_is_base(x: Int) proof by auto;

/// Reflexivity paths satisfy path_is_refl.
theorem refl_paths_are_refl(x: Int) proof by auto;

/// Inversion source is original target.
theorem path_inv_source_is_target(p: PathInt) proof by auto;

/// Inversion target is original source.
theorem path_inv_target_is_source(p: PathInt) proof by auto;

/// Double inversion preserves source.
theorem path_inv_inv_source(p: PathInt) proof by auto;

/// Double inversion preserves target.
theorem path_inv_inv_target(p: PathInt) proof by auto;

/// Transitivity preserves outer source.
theorem path_trans_source_is_left_source(p: PathInt, q: PathInt) proof by auto;

/// Transitivity preserves outer target.
theorem path_trans_target_is_right_target(p: PathInt, q: PathInt) proof by auto;

/// Right unit for transitivity.
theorem path_trans_refl_right_target(p: PathInt) proof by auto;

/// Left unit for transitivity.
theorem path_trans_refl_left_source(p: PathInt) proof by auto;

/// Symmetry of equality.
theorem path_eq_symmetric(x: Int, y: Int)
    requires x == y
    ensures y == x
    proof by auto;

/// Transitivity of equality.
theorem path_eq_transitive(x: Int, y: Int, z: Int)
    requires x == y, y == z
    ensures x == z
    proof by auto;

/// Congruence under successor.
theorem path_eq_congruence_succ(x: Int, y: Int)
    requires x == y
    ensures x + 1 == y + 1
    proof by auto;

/// Injectivity of successor.
theorem succ_injective(x: Int, y: Int)
    requires x + 1 == y + 1
    ensures x == y
    proof by auto;

/// Zero and successor are disjoint.
theorem zero_neq_succ(x: Int)
    requires x >= 0
    ensures 0 != x + 1
    proof by auto;
