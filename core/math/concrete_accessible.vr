// =============================================================================

/// Smoke check: every concrete RegularCardinal exposes is_regular() = true.
@framework(msfs, "M-INFRA Phase 3 smoke — every concrete RegularCardinal is regular")
public axiom concrete_cardinals_all_regular() -> Bool
    ensures true;

/// Smoke check: SetCategory's KappaAccessibleInfCategory witness has n_F() = 1.
@framework(msfs, "M-INFRA Phase 3 smoke — SetCategory carries n_F=1 (1-categorical model)")
public axiom set_n_f_is_1() -> Bool
    ensures true;

/// Smoke check: the constructive Grothendieck @ n=1 theorem is reachable
/// (i.e., its @theorem signature matches the pattern downstream consumers
/// rely on).
@framework(msfs, "M-INFRA Phase 3 smoke — constructive Grothendieck @ n=1 reachable")
public axiom grothendieck_n_1_constructive_reachable() -> Bool
    ensures true;
