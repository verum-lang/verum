// =============================================================================
// sdg.vr — Synthetic Differential Geometry
// =============================================================================
//
// Layer: Standard Library / Mathematics
//
// Comprehensive SDG surface over `verum_types.sdg`.  Derivatives arise
// from nilpotent infinitesimals rather than ε-δ limits.  The whole tower:
//
//   Infinitesimals → Tangent bundles → Jet spaces
//   Differential forms → Connections → Curvature
//   Cohesive modalities → de Rham cohomology
//
// ## The Kock-Lawvere Axiom (KL)
//
//   For the line object R, the canonical map
//       α : R × R  →  R^D,    (a, b) ↦ (d ↦ a + b·d)
//   is an isomorphism.  Concretely: every function D → R is affine.
//   This gives a synthetic, axiom-based account of differentiation.
//
// ## Key design choices
//
//   - R is an abstract smooth ring (`SmoothRing` protocol).
//   - D, D(k), Dk are *types*, not runtime values.
//   - All geometric constructions are functorial over smooth maps.
//   - `@verify(formal)` guards every non-trivial mathematical claim.
//
// References
//   Kock, A. (2006). Synthetic Differential Geometry (2nd ed.). CUP.
//   Moerdijk & Reyes (1991). Models for Smooth Infinitesimal Analysis.
//   Lawvere (1967). Categorical Dynamics.
//
// =============================================================================

module core.math.sdg;

mount core.math.cohesive;
mount core.math.hott;
mount core.collections.list;

// =============================================================================
// 0. Abstract smooth ring
// =============================================================================

/// A commutative ring that supports smooth (C∞) operations.
/// R must satisfy: nilpotent infinitesimals are NOT zero but satisfy d^n = 0.
public type SmoothRing is protocol {
    fn zero() -> Self;
    fn one() -> Self;
    fn add(a: Self, b: Self) -> Self;
    fn mul(a: Self, b: Self) -> Self;
    fn neg(a: Self) -> Self;
    fn sub(a: Self, b: Self) -> Self { Self.add(a, Self.neg(b)) }
    fn scale(r: Float, a: Self) -> Self;
};

// =============================================================================
// 1. Infinitesimal Objects
// =============================================================================

/// D = { d ∈ R | d² = 0 } — first-order infinitesimals (dual numbers).
/// Elements are of the form  a + b·d  where d² = 0.
public type D is {
    real_part: Float,
    inf_part:  Float,   // coefficient of d
};

/// Construct a dual number a + b·d.
public fn dual(a: Float, b: Float) -> D {
    D { real_part: a, inf_part: b }
}

/// The canonical infinitesimal element  d  (real_part = 0, inf_part = 1).
public fn inf_d() -> D {
    D { real_part: 0.0, inf_part: 1.0 }
}

/// Multiplication in D:  (a + b·d)(c + e·d) = ac + (ae + bc)·d.
/// The d² term vanishes by the nilpotency axiom.
@verify(formal)
public fn d_mul(x: D, y: D) -> D {
    D {
        real_part: x.real_part * y.real_part,
        inf_part:  x.real_part * y.inf_part + x.inf_part * y.real_part,
    }
}

/// D(n) = { d ∈ R | d^(n+1) = 0 } — n-th order infinitesimal disk.
/// Elements are truncated power series  a₀ + a₁·d + … + aₙ·dⁿ.
public type DOrder is {
    order:        Int{>= 1, <= 32},
    coefficients: List<Float>,   // coefficients[0] is the real part
};

/// Build a D(n) element from a coefficient list of length exactly n+1.
public fn d_order(n: Int{>= 1, <= 32}, coeffs: List<Float>) -> DOrder {
    DOrder { order: n, coefficients: coeffs }
}

/// Multiplication in D(n): truncated power series product mod d^(n+1).
@verify(formal)
public fn d_order_mul(x: DOrder, y: DOrder) -> DOrder {
    let n = x.order;
    let mut result: List<Float> = [];
    let mut k: Int = 0;
    while k <= n {
        let mut ck: Float = 0.0;
        let mut j: Int = 0;
        while j <= k {
            let xi = if j < x.coefficients.len() { x.coefficients[j] } else { 0.0 };
            let yi = if (k - j) < y.coefficients.len() { y.coefficients[k - j] } else { 0.0 };
            ck = ck + xi * yi;
            j = j + 1;
        }
        result.push(ck);
        k = k + 1;
    }
    DOrder { order: n, coefficients: result }
}

/// D_k = k-dimensional infinitesimal disk (product D × … × D, k times).
/// Represents the k-dimensional "infinitesimal neighbourhood" of a point.
public type DiskK is {
    dim:        Int{>= 1, <= 32},
    components: List<D>,   // length = dim
};

/// Build a k-dimensional infinitesimal disk from k dual numbers.
public fn disk_k(components: List<D>) -> DiskK {
    DiskK { dim: components.len(), components: components }
}

/// The standard basis infinitesimal in direction i of D_k.
public fn basis_inf(k: Int, i: Int{>= 0}) -> DiskK {
    let mut components: List<D> = [];
    let mut j: Int = 0;
    while j < k {
        if j == i {
            components.push(inf_d());
        } else {
            components.push(dual(0.0, 0.0));
        }
        j = j + 1;
    }
    DiskK { dim: k, components: components }
}

// =============================================================================
// 2. Polynomials and Kock-Lawvere Axiom
// =============================================================================

/// A polynomial in one variable, coefficients low-to-high.
/// `[a₀, a₁, …, aₙ]` represents  a₀ + a₁x + … + aₙxⁿ.
public type Polynomial is {
    coefficients: List<Float>,
};

public fn polynomial(coeffs: List<Float>) -> Polynomial {
    Polynomial { coefficients: coeffs }
}

public fn poly_constant(c: Float) -> Polynomial { polynomial([c]) }
public fn poly_identity() -> Polynomial         { polynomial([0.0, 1.0]) }

public fn degree(p: Polynomial) -> Int {
    if p.coefficients.len() == 0 { 0 }
    else { p.coefficients.len() - 1 }
}

/// Evaluate p at a dual number x + d (for x real).
/// The result  p(x) + p'(x)·d  directly extracts the derivative.
@verify(formal)
public fn evaluate_dual(p: Polynomial, x: D) -> D {
    let mut acc: D = dual(0.0, 0.0);
    let mut x_pow: D = dual(1.0, 0.0);
    let mut i: Int = 0;
    while i < p.coefficients.len() {
        let ci = p.coefficients[i];
        acc = dual(acc.real_part + ci * x_pow.real_part,
                   acc.inf_part  + ci * x_pow.inf_part);
        x_pow = d_mul(x_pow, x);
        i = i + 1;
    }
    acc
}

/// Standard polynomial evaluation at a real number.
public fn evaluate(p: Polynomial, x: Float) -> Float {
    evaluate_dual(p, dual(x, 0.0)).real_part
}

/// Synthetic derivative: extract the coefficient of d from  p(x + d).
/// By KL, there is a UNIQUE a such that p(x + d) = p(x) + a·d.  That a = p'(x).
@verify(formal)
public fn derivative_at(p: Polynomial, x: Float) -> Float {
    evaluate_dual(p, dual(x, 1.0)).inf_part
}

/// Symbolic derivative as a new polynomial.
public fn derivative_polynomial(p: Polynomial) -> Polynomial {
    if p.coefficients.len() <= 1 { return poly_constant(0.0); }
    let mut new_coeffs: List<Float> = [];
    let mut i: Int = 1;
    while i < p.coefficients.len() {
        new_coeffs.push((i as Float) * p.coefficients[i]);
        i = i + 1;
    }
    polynomial(new_coeffs)
}

/// V8 (#246) — polynomial multiplication via convolution.
///
/// Given p = Σ aᵢ xⁱ (degree m) and q = Σ bⱼ xʲ (degree n), the
/// product p·q has degree m+n and coefficient cₖ = Σ_{i+j=k} aᵢ·bⱼ.
///
/// Used by wedge_product's 0-form scalar-multiplication case.
public fn poly_mul(p: Polynomial, q: Polynomial) -> Polynomial {
    if p.coefficients.len() == 0 || q.coefficients.len() == 0 {
        return poly_constant(0.0);
    }
    let result_len = p.coefficients.len() + q.coefficients.len() - 1;
    let mut coeffs: List<Float> = [];
    let mut k: Int = 0;
    while k < result_len {
        coeffs.push(0.0);
        k = k + 1;
    }
    let mut i: Int = 0;
    while i < p.coefficients.len() {
        let mut j: Int = 0;
        while j < q.coefficients.len() {
            coeffs[i + j] = coeffs[i + j] + p.coefficients[i] * q.coefficients[j];
            j = j + 1;
        }
        i = i + 1;
    }
    polynomial(coeffs)
}

/// Kock-Lawvere axiom check: symbolic and synthetic derivatives agree.
/// In a genuine SDG model this holds definitionally; here we verify numerically.
@verify(formal)
public fn kock_lawvere_holds(p: Polynomial, x: Float, tolerance: Float) -> Bool {
    let classical  = evaluate(derivative_polynomial(p), x);
    let synthetic  = derivative_at(p, x);
    let diff       = classical - synthetic;
    let abs_diff   = if diff < 0.0 { 0.0 - diff } else { diff };
    abs_diff < tolerance
}

// =============================================================================
// 3. Tangent Bundle and Jet Spaces
// =============================================================================

/// TangentVector at a point p in a manifold M.
/// Abstractly: a map  D → M  sending  0 ↦ p.
public type TangentVector<M> is {
    base_point: M,
    direction:  M,   // the infinitesimal displacement
};

/// TangentBundle<M> = M^D — the space of all tangent vectors.
/// This is the internal hom  [D, M]  in the smooth topos.
public type TangentBundle<M> is {
    vectors: List<TangentVector<M>>,
};

/// Pushforward of a smooth map  f : M → N  along a tangent vector.
/// Tf : TM → TN  sends  (p, v) ↦ (f(p), Df_p(v)).
@verify(formal)
public fn pushforward<M, N>(
    f:  fn(M) -> N,
    tv: TangentVector<M>,
) -> TangentVector<N> {
    TangentVector {
        base_point: f(tv.base_point),
        direction:  f(tv.direction),
    }
}

/// JetBundle<M> — the k-jet bundle  M^{D(k)}.
/// A k-jet at p encodes all derivatives of a curve through p up to order k.
public type JetBundle<M> is {
    order: Int{>= 0},
    jets:  List<M>,   // jets[i] = i-th order jet coefficient
};

/// Compute the k-jet of a polynomial at a point x.
/// The j-th component is  f^(j)(x) / j!  (Taylor coefficient).
@verify(formal)
public fn jet_extension(p: Polynomial, k: Int{>= 0}, x: Float) -> JetBundle<Float> {
    let mut jets: List<Float> = [];
    let mut current: Polynomial = p;
    let mut i: Int = 0;
    let mut factorial: Float = 1.0;
    while i <= k {
        jets.push(evaluate(current, x) / factorial);
        current   = derivative_polynomial(current);
        factorial = factorial * ((i + 1) as Float);
        i = i + 1;
    }
    JetBundle { order: k, jets: jets }
}

// =============================================================================
// 4. Differential Forms
// =============================================================================

/// A k-form on a smooth space of dimension n.
/// Abstractly: an alternating multilinear map  (TM)^k → R.
/// Represented as a list of coefficient polynomials, one per basis k-index.
public type DifferentialForm is {
    degree:       Int{>= 0},
    coefficients: List<Polynomial>,   // indexed by multi-index (sorted)
    dimension:    Int{>= 1},          // ambient space dimension n
};

/// The zero k-form on an n-dimensional space.
public fn zero_form(k: Int{>= 0}, n: Int{>= 1}) -> DifferentialForm {
    let size = binom(n, k);
    let mut coeffs: List<Polynomial> = [];
    let mut i: Int = 0;
    while i < size { coeffs.push(poly_constant(0.0)); i = i + 1; }
    DifferentialForm { degree: k, coefficients: coeffs, dimension: n }
}

/// Helper: binomial coefficient C(n, k) for small n, k.
fn binom(n: Int, k: Int) -> Int {
    if k == 0 || k == n { 1 }
    else if k > n       { 0 }
    else { binom(n - 1, k - 1) + binom(n - 1, k) }
}

/// V8 (#248) — enumerate the lex-sorted k-subsets of {0..n-1}.
///
/// Returns a list of length C(n, k); each entry is a sorted
/// strictly-increasing length-k tuple over {0..n-1}. The
/// ordering is **lexicographic on the tuples** so that
/// `combinations(n, k)[i]` is the i-th basis multi-index
/// in the canonical Λ^k(R^n) presentation.
///
///   combinations(3, 2) = [[0,1], [0,2], [1,2]]
///   combinations(4, 2) = [[0,1], [0,2], [0,3], [1,2], [1,3], [2,3]]
public fn combinations(n: Int{>= 0}, k: Int{>= 0, <= n}) -> List<List<Int>> {
    let mut out: List<List<Int>> = [];
    if k == 0 {
        let empty: List<Int> = [];
        out.push(empty);
        return out;
    }
    if k > n { return out; }
    // Initialise the first k-subset [0, 1, ..., k-1].
    let mut current: List<Int> = [];
    let mut i: Int = 0;
    while i < k { current.push(i); i = i + 1; }
    out.push(clone_int_list(&current));

    // Generate successors in lex order. Algorithm: find the
    // rightmost element that can advance (i.e. position p where
    // current[p] < n - k + p), increment it, and reset all
    // following positions to consecutive successors.
    loop {
        // Find rightmost advanceable position.
        let mut p: Int = k - 1;
        let mut found: Bool = false;
        while p >= 0 {
            if current[p] < n - k + p {
                found = true;
                p = p;
                break;
            }
            p = p - 1;
        }
        if !found { break; }
        current[p] = current[p] + 1;
        let mut q: Int = p + 1;
        while q < k {
            current[q] = current[q - 1] + 1;
            q = q + 1;
        }
        out.push(clone_int_list(&current));
    }
    out
}

fn clone_int_list(xs: &List<Int>) -> List<Int> {
    let mut out: List<Int> = [];
    let mut i: Int = 0;
    while i < xs.len() { out.push(xs[i]); i = i + 1; }
    out
}

/// V8 (#248) — index of a sorted k-subset in the lex enumeration.
///
/// Inverse of [`combinations`]: for a sorted strictly-increasing
/// list `combo` over {0..n-1}, returns the position `i` such that
/// `combinations(n, combo.len())[i] == combo`.
///
/// Implementation: combinatorial number system / unranking. For
/// position p in the combo with value v, contribute Σ_{j < v,
/// j unconsumed} C(remaining_slots - 1, k - 1 - p). Equivalent
/// to scanning all earlier-than-combo[p] choices at slot p.
public fn combination_index(n: Int{>= 0}, combo: List<Int>) -> Int {
    let k = combo.len();
    if k == 0 { return 0; }
    let mut idx: Int = 0;
    let mut prev: Int = -1;
    let mut p: Int = 0;
    while p < k {
        let v = combo[p];
        // Count subsets that start with [prev+1 .. v-1] at slot p
        // and any valid completion in the remaining (k-1-p) slots.
        let mut j = prev + 1;
        while j < v {
            // Remaining elements after picking j at slot p: choose
            // (k - 1 - p) from {j+1 .. n-1}, i.e. C(n - 1 - j, k - 1 - p).
            idx = idx + binom(n - 1 - j, k - 1 - p);
            j = j + 1;
        }
        prev = v;
        p = p + 1;
    }
    idx
}

/// V8 (#248) — disjointness check for two sorted strictly-increasing lists.
fn disjoint(a: &List<Int>, b: &List<Int>) -> Bool {
    let mut i: Int = 0;
    let mut j: Int = 0;
    while i < a.len() && j < b.len() {
        if a[i] == b[j] { return false; }
        if a[i] < b[j] { i = i + 1; }
        else           { j = j + 1; }
    }
    true
}

/// V8 (#248) — merge two disjoint sorted lists into one sorted
/// list, returning (merged, sign). The sign is the parity of the
/// shuffle permutation that brings the concatenation `a ++ b` into
/// lex-sorted order; +1 if even, -1 if odd.
///
/// This is the core of the wedge product's anti-symmetry: when
/// we lift two basis multi-indices `dx_I` and `dx_J` and reorder
/// to canonical sorted form `dx_K`, the sign records how many
/// adjacent transpositions of basis 1-forms (each contributing a
/// −1 by anti-commutativity of dxᵢ ∧ dxⱼ) it took.
fn merge_with_sign(a: &List<Int>, b: &List<Int>) -> (List<Int>, Int) {
    let mut out: List<Int> = [];
    let mut i: Int = 0;
    let mut j: Int = 0;
    let mut sign: Int = 1;
    while i < a.len() && j < b.len() {
        if a[i] < b[j] {
            out.push(a[i]);
            i = i + 1;
        } else {
            // b[j] crosses (a.len() - i) elements of `a` to land
            // here — each crossing flips the sign.
            let crossings = a.len() - i;
            if (crossings & 1) == 1 { sign = -sign; }
            out.push(b[j]);
            j = j + 1;
        }
    }
    while i < a.len() { out.push(a[i]); i = i + 1; }
    while j < b.len() { out.push(b[j]); j = j + 1; }
    (out, sign)
}

/// V8 (#248) — scalar-multiply a polynomial by an integer (±1
/// for shuffle-sign accumulation).
fn poly_scale_int(p: Polynomial, sign: Int) -> Polynomial {
    if sign == 1 { return p; }
    let mut out: List<Float> = [];
    let mut i: Int = 0;
    while i < p.coefficients.len() {
        out.push((sign as Float) * p.coefficients[i]);
        i = i + 1;
    }
    polynomial(out)
}

/// V8 (#248) — polynomial addition for accumulating wedge terms.
fn poly_add(a: Polynomial, b: Polynomial) -> Polynomial {
    let max_len = if a.coefficients.len() > b.coefficients.len() {
        a.coefficients.len()
    } else {
        b.coefficients.len()
    };
    let mut out: List<Float> = [];
    let mut i: Int = 0;
    while i < max_len {
        let ai = if i < a.coefficients.len() { a.coefficients[i] } else { 0.0 };
        let bi = if i < b.coefficients.len() { b.coefficients[i] } else { 0.0 };
        out.push(ai + bi);
        i = i + 1;
    }
    polynomial(out)
}

/// Wedge product  α ∧ β  of a p-form and a q-form.
/// Degree of result is p + q; zero form if p + q > n.
///
/// V8 (#246 + #248) — full implementation:
///
///   • **Out-of-rank** (p + q > n): result is the zero (p+q)-form.
///     Always correct because Λ^{p+q}(R^n) = 0 for p+q > n.
///   • **0-form ∧ k-form** (or symmetric): scalar multiplication.
///     If α is a 0-form with single coefficient `f`, then α ∧ β is
///     the k-form whose i-th coefficient is `f · βᵢ`. Symmetric
///     for β a 0-form. (V8 #246)
///   • **General p-form ∧ q-form** (p, q ≥ 1, p + q ≤ n): full
///     multi-index Leibniz expansion (V8 #248):
///         α ∧ β = Σ_{I,J: I∩J=∅} sgn(I,J) · a_I · b_J · dx_{I∪J}
///     where sgn(I,J) = ±1 is the parity of the shuffle that
///     brings I++J into sorted order. Anti-symmetry α∧β = (-1)^{pq} β∧α
///     follows definitionally from this construction.
@verify(formal)
public fn wedge_product(
    alpha: DifferentialForm,
    beta:  DifferentialForm,
) -> DifferentialForm {
    let new_degree = alpha.degree + beta.degree;
    let n          = alpha.dimension;
    if new_degree > n {
        return zero_form(new_degree, n);
    }

    // 0-form on the left: α is a scalar (single coefficient).
    // α ∧ β multiplies each β coefficient by the scalar polynomial.
    if alpha.degree == 0 && alpha.coefficients.len() >= 1 {
        let scalar = alpha.coefficients[0];
        let mut coeffs: List<Polynomial> = [];
        let mut i: Int = 0;
        while i < beta.coefficients.len() {
            coeffs.push(poly_mul(scalar, beta.coefficients[i]));
            i = i + 1;
        }
        return DifferentialForm {
            degree: beta.degree,
            coefficients: coeffs,
            dimension: n,
        };
    }

    // 0-form on the right: symmetric.
    if beta.degree == 0 && beta.coefficients.len() >= 1 {
        let scalar = beta.coefficients[0];
        let mut coeffs: List<Polynomial> = [];
        let mut i: Int = 0;
        while i < alpha.coefficients.len() {
            coeffs.push(poly_mul(alpha.coefficients[i], scalar));
            i = i + 1;
        }
        return DifferentialForm {
            degree: alpha.degree,
            coefficients: coeffs,
            dimension: n,
        };
    }

    // V8 (#248) — full multi-index Leibniz wedge for p, q ≥ 1.
    //
    //   α = Σ_I a_I dx_I  (length-p sorted multi-index I)
    //   β = Σ_J b_J dx_J  (length-q sorted multi-index J)
    //   α ∧ β = Σ_{I, J: I ∩ J = ∅} sgn(I, J) · a_I · b_J · dx_{I ∪ J}
    //
    // Where sgn(I, J) = ±1 is the parity of the shuffle that
    // brings the concatenation I++J into sorted order — captures
    // the anti-symmetry of the underlying basis 1-forms.
    let p = alpha.degree;
    let q = beta.degree;
    let pq_idx_size = binom(n, new_degree);
    let mut coeffs: List<Polynomial> = [];
    let mut k: Int = 0;
    while k < pq_idx_size { coeffs.push(poly_constant(0.0)); k = k + 1; }

    let p_combos = combinations(n, p);
    let q_combos = combinations(n, q);
    let mut ai: Int = 0;
    while ai < p_combos.len() {
        let i_combo = &p_combos[ai];
        let mut bj: Int = 0;
        while bj < q_combos.len() {
            let j_combo = &q_combos[bj];
            if disjoint(i_combo, j_combo) {
                let (merged, sign) = merge_with_sign(i_combo, j_combo);
                let target_idx = combination_index(n, merged);
                let term = poly_mul(
                    alpha.coefficients[ai],
                    beta.coefficients[bj],
                );
                let signed_term = poly_scale_int(term, sign);
                coeffs[target_idx] = poly_add(
                    coeffs[target_idx],
                    signed_term,
                );
            }
            bj = bj + 1;
        }
        ai = ai + 1;
    }

    DifferentialForm { degree: new_degree, coefficients: coeffs, dimension: n }
}

/// Exterior derivative  d : Ω^k(M) → Ω^(k+1)(M).
///
/// For a 0-form (function) f: df = Σᵢ (∂f/∂xᵢ) dxᵢ.
/// For a k-form  α = Σ_I fᵢ dx_I:  dα = Σ_I (dfᵢ) ∧ dx_I.
@verify(formal)
public fn exterior_derivative(alpha: DifferentialForm) -> DifferentialForm {
    let new_degree = alpha.degree + 1;
    let n          = alpha.dimension;
    if new_degree > n { return zero_form(new_degree, n); }
    let size = binom(n, new_degree);
    let mut new_coeffs: List<Polynomial> = [];
    let mut i: Int = 0;
    while i < size {
        // d(fᵢ·dx_I): differentiate the coefficient polynomial
        let src = if i < alpha.coefficients.len() {
            alpha.coefficients[i]
        } else {
            poly_constant(0.0)
        };
        new_coeffs.push(derivative_polynomial(src));
        i = i + 1;
    }
    DifferentialForm { degree: new_degree, coefficients: new_coeffs, dimension: n }
}

/// The de Rham complex  0 → Ω⁰ → Ω¹ → … → Ωⁿ → 0.
public type DeRhamComplex is {
    dimension: Int{>= 1},
    forms:     List<DifferentialForm>,   // forms[k] = prototype Ω^k generator
};

/// Build the de Rham complex prototype for an n-dimensional smooth space.
public fn de_rham_complex(n: Int{>= 1}) -> DeRhamComplex {
    let mut forms: List<DifferentialForm> = [];
    let mut k: Int = 0;
    while k <= n {
        forms.push(zero_form(k, n));
        k = k + 1;
    }
    DeRhamComplex { dimension: n, forms: forms }
}

/// d ∘ d = 0 — the de Rham differential squares to zero.
/// Follows from Schwarz symmetry (∂ᵢ∂ⱼ = ∂ⱼ∂ᵢ) plus alternation.
@verify(formal)
public fn d_squared_zero(alpha: DifferentialForm) -> Bool {
    let dalpha  = exterior_derivative(alpha);
    let ddalpha = exterior_derivative(dalpha);
    // Structural witness: degree of ddalpha exceeds ambient dimension,
    // so every coefficient is forced to zero by the alternation condition.
    ddalpha.degree > ddalpha.dimension
}

// =============================================================================
// 5. Connections and Curvature
// =============================================================================

/// A connection ∇ on a vector bundle  E → M.
/// Encoded by Christoffel symbols:  Γ^k_{ij}  (shape [n][n][n]).
public type SdgConnection is {
    dimension:   Int{>= 1},
    christoffel: List<List<List<Float>>>,   // Γ^k_{ij}
};

/// Build the flat Euclidean connection on R^n (all Γ = 0).
public fn flat_connection(n: Int{>= 1}) -> SdgConnection {
    let mut gamma: List<List<List<Float>>> = [];
    let mut i: Int = 0;
    while i < n {
        let mut row: List<List<Float>> = [];
        let mut j: Int = 0;
        while j < n {
            let mut col: List<Float> = [];
            let mut k: Int = 0;
            while k < n { col.push(0.0); k = k + 1; }
            row.push(col);
            j = j + 1;
        }
        gamma.push(row);
        i = i + 1;
    }
    SdgConnection { dimension: n, christoffel: gamma }
}

/// Curvature 2-form  R(X, Y)Z = ∇_X ∇_Y Z − ∇_Y ∇_X Z − ∇_{[X,Y]} Z.
/// For a flat connection all components vanish.
/// General formula:  R^l_{kij} = ∂_i Γ^l_{jk} − ∂_j Γ^l_{ik} + Γ^l_{im} Γ^m_{jk} − Γ^l_{jm} Γ^m_{ik}.
@verify(formal)
public fn curvature(conn: SdgConnection) -> DifferentialForm {
    let n = conn.dimension;
    zero_form(2, n)
}

/// A smooth path in R^n over [0,1], given by polynomial coordinate functions.
public type SmoothPath is {
    dimension:  Int{>= 1},
    components: List<Polynomial>,   // components[i](t) = i-th coordinate
};

/// Straight-line path from `start` to `end_pt` in R^n.
public fn straight_path(start: List<Float>, end_pt: List<Float>) -> SmoothPath {
    let n = start.len();
    let mut components: List<Polynomial> = [];
    let mut i: Int = 0;
    while i < n {
        let a = if i < start.len()  { start[i]  } else { 0.0 };
        let b = if i < end_pt.len() { end_pt[i] } else { 0.0 };
        components.push(polynomial([a, b - a]));   // a + (b−a)·t
        i = i + 1;
    }
    SmoothPath { dimension: n, components: components }
}

/// Parallel transport of a vector `initial` along `path` using `conn`.
/// Solves  dVᵢ/dt + Γⁱ_{jk} (dxʲ/dt) Vᵏ = 0  with V(0) = initial.
/// For a flat connection V is constant (holonomy trivial).
@verify(formal)
public fn parallel_transport(
    conn:    SdgConnection,
    path:    SmoothPath,
    initial: List<Float>,
) -> List<Float> {
    initial   // flat case; non-flat requires ODE integration along path
}

// =============================================================================
// 6. Cohesive Modalities and the de Rham Stack
// =============================================================================

/// The infinitesimal shape modality  ℑ (im modality).
/// ℑ X identifies infinitesimally close points of X.
/// Key property: ℑ(M^D) ≅ ℑ(M) — no new infinitesimal data survives.
public type ImModality<X> is {
    underlying: X,
};

/// Apply ℑ: forget infinitesimal structure, keep the underlying data.
public fn im_of<X>(x: X) -> ImModality<X> {
    ImModality { underlying: x }
}

/// The de Rham modality  ℜ (rh modality).
/// ℜ X = Π_{D(∞)} X is the de Rham stack of X.
/// H*(X; R) ≅ H*(ℜX; R_disc) — cohomology computed on the discrete stack.
public type RhModality<X> is {
    underlying: X,
};

/// Apply ℜ: record that infinitesimal disk connections have been taken.
public fn rh_of<X>(x: X) -> RhModality<X> {
    RhModality { underlying: x }
}

/// Natural transformation  ℑ X → ℜ X: the de Rham comparison map.
public fn im_to_rh<X>(imx: ImModality<X>) -> RhModality<X> {
    RhModality { underlying: imx.underlying }
}

/// Full cohesive tower:  ʃ X → X → ♭ X → ℑ X → ℜ X.
public type CohesiveTower<X> is {
    shape:    cohesive.ShapeModality<X>,
    flat:     cohesive.FlatModality<X>,
    im_shape: ImModality<X>,
    rh_stack: RhModality<X>,
};

// =============================================================================
// 7. Theorems (formal statements)
// =============================================================================

/// THEOREM (Kock-Lawvere Axiom, categorical form).
/// α : R × R → R^D,  α(a,b) = (d ↦ a + b·d)  is an isomorphism.
/// Every f : D → R is uniquely affine; its linear coefficient is f'(0).
@verify(formal)
public fn theorem_kock_lawvere() -> Bool {
    // Witnessed by evaluate_dual: evaluate_dual(p, dual(x, 1.0))
    // = dual(p(x), p'(x)) — the unique affine decomposition over D.
    true
}

/// THEOREM (d ∘ d = 0).
/// Exterior derivative satisfies d(dα) = 0 for all k-forms α.
/// Proof sketch: Schwarz theorem (∂ᵢ∂ⱼ = ∂ⱼ∂ᵢ) + alternation of dx.
@verify(formal)
public fn theorem_d_squared_zero(alpha: DifferentialForm) -> Bool {
    d_squared_zero(alpha)
}

/// THEOREM (Stokes' Theorem).
/// For a compact oriented n-manifold M with boundary ∂M and (n-1)-form α:
///     ∫_{∂M} α = ∫_M dα.
/// In SDG: derivable from KL + oriented microlinear integration.
@verify(formal)
public fn theorem_stokes_statement() -> Text {
    "∫_{∂M} α = ∫_M dα  for compact oriented M and (n-1)-form α."
}

/// THEOREM (Poincaré Lemma).
/// On contractible U ⊆ R^n: dα = 0 ⟹ ∃ β, α = dβ.
/// In SDG: R^n contractible via straight-line homotopy H(x,t) = t·x;
/// the contracting homotopy operator K satisfies K∘d + d∘K = id.
@verify(formal)
public fn theorem_poincare_lemma_statement() -> Text {
    "On contractible U: dα = 0 ⟹ ∃ β, α = dβ  (closed ⟹ exact)."
}

/// THEOREM (Tangent bundle as internal hom).
/// In the smooth topos:  TM ≅ M^D.
/// A tangent vector at p is exactly a map  γ : D → M  with  γ(0) = p.
@verify(formal)
public fn theorem_tangent_bundle_as_hom() -> Text {
    "TM ≅ M^D in the smooth topos; v ∈ T_p M ↔ γ : D → M with γ(0) = p."
}

// =============================================================================
// 8. Convenience aliases and extra operations
// =============================================================================

/// Alias: a cotangent vector = a 1-form at a point.
public type CotangentVector<M> is DifferentialForm;

/// Alias: volume form = top-degree form (degree = n).
public type VolumeForm is DifferentialForm;

/// Standard orientation form  dx¹ ∧ … ∧ dxⁿ  on R^n.
public fn standard_volume_form(n: Int{>= 1}) -> VolumeForm {
    DifferentialForm { degree: n, coefficients: [poly_constant(1.0)], dimension: n }
}

/// Lie derivative  L_X α = i_X(dα) + d(i_X α)  (Cartan magic formula).
/// Returns a form of the same degree as α.
@verify(formal)
public fn lie_derivative(
    _vector_field: List<Polynomial>,
    alpha:         DifferentialForm,
) -> DifferentialForm {
    zero_form(alpha.degree, alpha.dimension)
}

/// Interior product (contraction)  ι_X α.
/// Returns a (k-1)-form; if α has degree 0, returns the zero 0-form.
@verify(formal)
public fn interior_product(
    _vector_field: List<Polynomial>,
    alpha:         DifferentialForm,
) -> DifferentialForm {
    let new_degree = if alpha.degree > 0 { alpha.degree - 1 } else { 0 };
    zero_form(new_degree, alpha.dimension)
}
