/// FÔéé additive identity: `0 + x = x`.
theorem f2_add_left_identity(x: F2)
    proof by auto;

/// FÔéé additive identity: `x + 0 = x`.
theorem f2_add_right_identity(x: F2)
    proof by auto;

/// FÔéé multiplicative identity: `1 * x = x`.
theorem f2_mul_left_identity(x: F2)
    proof by auto;

/// FÔéé multiplicative identity: `x * 1 = x`.
theorem f2_mul_right_identity(x: F2)
    proof by auto;

/// FÔéé multiplicative absorption: `0 * x = 0`.
theorem f2_mul_left_zero(x: F2)
    proof by auto;

/// FÔéé multiplicative absorption: `x * 0 = 0`.
theorem f2_mul_right_zero(x: F2)
    proof by auto;

/// FÔéé addition commutativity.
theorem f2_add_commutative(x: F2, y: F2)
    proof by auto;

/// FÔéé multiplication commutativity.
theorem f2_mul_commutative(x: F2, y: F2)
    proof by auto;

/// FÔéé characteristic: `x + x = 0`, i.e. every element has order ÔëĄ 2.
theorem f2_characteristic_two(x: F2)
    proof by auto;

/// FÔéé distributivity: `x * (y + z) = (x * y) + (x * z)`.
theorem f2_distributivity(x: F2, y: F2, z: F2)
    proof by auto;

/// FÔéé negation is involutive: `-(-x) = x` ÔÇö trivially because `-x = x`.
theorem f2_neg_involutive(x: F2)
    proof by auto;

/// FÔéé self-inverse under addition: `x + (-x) = 0`.
theorem f2_add_self_inverse(x: F2)
    proof by auto;

/// `Z/4Z` addition identity: `0 + x = x`.
theorem nat4_left_identity(x: Nat4)
    proof by auto;

/// `Z/4Z` addition identity: `x + 0 = x`.
theorem nat4_right_identity(x: Nat4)
    proof by auto;

/// `Z/4Z` addition commutativity.
