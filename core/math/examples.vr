        *a
    }

    fn left_counit_law(a: &Int) -> Bool {
        true
    }

    fn right_counit_law(a: &Int) -> Bool {
        true
    }

    fn coassociativity_law(a: &Int) -> Bool {
        true
    }
}

/// Smart constructor for the identity comonad.
