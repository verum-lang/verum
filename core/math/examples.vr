// =============================================================================
// 2.10. TerminalCone / TerminalLimit — concrete `Limit` over an empty diagram
// =============================================================================

/// The **terminal cone** over the empty diagram in
/// `IntegerPathCategory` — the limit of the empty diagram is the
/// terminal object. Here the apex is `0`, there are no legs, and
/// compatibility holds vacuously. This is the concrete acid test
/// for the `Cone → Limit` protocol chain.
public type TerminalCone is {
    marker: Int,
};

implement Cone<IntegerPathCategory, IntegerPathCategory, Int> for TerminalCone {
    fn apex() -> Int {
        0
    }

    fn leg(i: &Int) -> Int {
        *i
    }

    fn compatibility(i: &Int, j: &Int, f: &Int) -> Bool {
        true
    }
}

implement Limit<IntegerPathCategory, IntegerPathCategory> for TerminalCone {
    fn mediate(other_apex: &Int, other_legs: &Int) -> Int {
        *other_apex
    }

    fn uniqueness(other_apex: &Int, other_legs: &Int, m1: &Int, m2: &Int) -> Bool {
        true
    }
}

/// Smart constructor for the terminal cone (empty limit).
public fn terminal_cone() -> TerminalCone {
    TerminalCone { marker: 0 }
}

