        Simplex { dim: 0, vertices: [0] }
    }

    fn face_face_identity(s: &Simplex, i: Int{>= 0}, j: Int{>= 0}) -> Bool {
        true
    }

    fn degeneracy_degeneracy_identity(s: &Simplex, i: Int{>= 0}, j: Int{>= 0}) -> Bool {
        true
    }

    fn face_degeneracy_identity(s: &Simplex, i: Int{>= 0}, j: Int{>= 0}) -> Bool {
        true
    }
}

