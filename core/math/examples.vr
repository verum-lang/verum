// A KanComplex fills *all* horns, including inner ones, so the
// PointSimplicialSet is trivially a quasi-category — hence an
// ∞-category. Closes the `SimplicialSet → QuasiCategory → ∞-Category`
// chain at the concrete-instance level.

implement QuasiCategory for PointSimplicialSet {
    fn fill_inner_horn(h: &Horn) -> Simplex {
        Simplex { dim: 0, vertices: [0] }
    }
}

implement InfinityCategory for PointSimplicialSet {}

// =============================================================================
// 2.31. IdentityInfinityFunctor — concrete `InfinityFunctor` on PointSimplicialSet
// =============================================================================

/// The **identity ∞-functor** on `PointSimplicialSet`: sends every
/// n-simplex to itself, preserves faces and degeneracies trivially.
/// Concrete acid test for the `InfinityFunctor<C, D>` protocol with
/// two generic parameters — and by composition this also gives a
/// concrete `Endofunctor` in the ∞-categorical sense on a fully
/// instantiated ∞-category.
public type IdentityInfinityFunctor is {
    marker: Int,
};

implement InfinityFunctor<PointSimplicialSet, PointSimplicialSet> for IdentityInfinityFunctor {
    fn map_simplex(s: &Simplex) -> Simplex {
        Simplex { dim: s.dim, vertices: s.vertices.clone() }
    }

    fn preserves_faces(s: &Simplex, i: Int{>= 0}) -> Bool {
        true
    }

    fn preserves_degeneracies(s: &Simplex, i: Int{>= 0}) -> Bool {
        true
    }
}

/// Smart constructor for the identity ∞-functor.
public fn identity_infinity_functor() -> IdentityInfinityFunctor {
    IdentityInfinityFunctor { marker: 0 }
}

// =============================================================================
// 2.32. Fibration chain — GrothendieckFibration / Opfibration / Bifibration
// =============================================================================
//
// The IdentityInfinityFunctor is trivially a Grothendieck fibration
// (every morphism is its own cartesian lift), an opfibration (dually),
// and therefore a bifibration. It also satisfies the Kan-complex
// fibre condition vacuously, so it is both a left and right fibration.
// This closes the full fibration-hierarchy at the concrete-instance
// level, exercising the deepest protocol chain in `fibration.vr`.

implement GrothendieckFibration<PointSimplicialSet, PointSimplicialSet>
    for IdentityInfinityFunctor {
    fn cartesian_lift(f: &Int, y: &Int) -> Int {
        *f
    }

    fn lift_is_cartesian(f: &Int, y: &Int) -> Bool {
        true
    }

    fn lift_covers_base(f: &Int, y: &Int) -> Bool {
        true
    }
}

implement Opfibration<PointSimplicialSet, PointSimplicialSet>
    for IdentityInfinityFunctor {
    fn cocartesian_lift(f: &Int, y: &Int) -> Int {
        *f
    }

    fn lift_is_cocartesian(f: &Int, y: &Int) -> Bool {
        true
    }

    fn lift_covers_base(f: &Int, y: &Int) -> Bool {
        true
    }
}

implement Bifibration<PointSimplicialSet, PointSimplicialSet>
    for IdentityInfinityFunctor {}

implement LeftFibration<PointSimplicialSet, PointSimplicialSet>
    for IdentityInfinityFunctor {
    fn fibres_are_kan_complexes(b: &Int) -> Bool {
        true
    }
}

implement RightFibration<PointSimplicialSet, PointSimplicialSet>
    for IdentityInfinityFunctor {
    fn fibres_are_kan_complexes(b: &Int) -> Bool {
        true
    }
}

// =============================================================================
// 3. DiscreteSimplicialSet — the simplest simplicial set
// =============================================================================

/// A **discrete simplicial set** on a single 0-simplex. All
/// n-simplices for n > 0 are degenerate (generated by applying
/// degeneracy maps to the unique 0-simplex). Used as a starter
/// kit for simplicial constructions and for the canonical
/// discrete ∞-groupoid on a singleton.
public type DiscreteSimplicialSet is {
    /// The single underlying point identifier.
    point: Int,
};

/// Smart constructor producing the discrete simplicial set on the
/// given point.
public fn discrete_simplicial_set(p: Int) -> DiscreteSimplicialSet {
    DiscreteSimplicialSet { point: p }
}

/// The unique n-simplex of a discrete simplicial set — always the
/// degeneracy of the base point.
public fn discrete_n_simplex(d: &DiscreteSimplicialSet, n: Int{>= 0}) -> Simplex {
    Simplex {
        dim: n,
        vertices: [d.point],
    }
}

// =============================================================================
// 4. Walking-arrow example
// =============================================================================

/// The **walking arrow** [1] is the simplest non-trivial ∞-category:
/// two objects (0 and 1) and a single non-identity morphism from 0
/// to 1. Its nerve is `Δ[1]`. This is the initial category
/// containing an arrow.
public type WalkingArrow is {
    /// Flag distinguishing 0 from 1 (source from target).
    marker: Int,
};

/// The source object (0) of the walking arrow.
public fn walking_arrow_source() -> WalkingArrow {
    WalkingArrow { marker: 0 }
}

/// The target object (1) of the walking arrow.
public fn walking_arrow_target() -> WalkingArrow {
    WalkingArrow { marker: 1 }
}

/// The unique non-identity morphism `0 → 1` in the walking arrow.
/// Its underlying simplex is `simplex_one()`.
public fn walking_arrow_morphism() -> Simplex {
    simplex_one()
}

// =============================================================================
// 5. Two-element free monoid (reference `Monoid` instance)
// =============================================================================

/// The free monoid on a 2-element generating set `{a, b}`, represented
/// by natural-number pairs `(count_a, count_b)` — a concrete,
/// computable monoid that exercises the algebraic protocol surface.
///
/// The monoid operation is componentwise addition with identity
/// `(0, 0)`. It is the simplest abelian free monoid and the prototype
/// for free constructions in the Phase C algebra stack.
public type TwoFreeMonoid is {
    count_a: Int,
    count_b: Int,
};

/// The identity element `(0, 0)` of the two-element free monoid.
public fn two_free_monoid_identity() -> TwoFreeMonoid {
    TwoFreeMonoid { count_a: 0, count_b: 0 }
}

/// The generator `a`, represented as `(1, 0)`.
public fn two_free_monoid_gen_a() -> TwoFreeMonoid {
    TwoFreeMonoid { count_a: 1, count_b: 0 }
}

/// The generator `b`, represented as `(0, 1)`.
public fn two_free_monoid_gen_b() -> TwoFreeMonoid {
    TwoFreeMonoid { count_a: 0, count_b: 1 }
}

/// Monoid multiplication: componentwise addition.
/// `(a1, b1) · (a2, b2) = (a1 + a2, b1 + b2)`.
public fn two_free_monoid_mul(x: &TwoFreeMonoid, y: &TwoFreeMonoid) -> TwoFreeMonoid {
    TwoFreeMonoid {
        count_a: x.count_a + y.count_a,
        count_b: x.count_b + y.count_b,
    }
}

/// The "length" (total generator count) of a monoid element.
public fn two_free_monoid_length(x: &TwoFreeMonoid) -> Int {
    x.count_a + x.count_b
}

// Full `Monoid` instance for `TwoFreeMonoid` — the acid test that
// the `Magma → Semigroup → Monoid` protocol chain from `algebra.vr`
// can actually be implemented on a concrete Verum type. The
// `@verify(formal)` obligations (associativity + left/right identity)
// are discharged by `proof by auto` at the theorem level below.

implement Magma for TwoFreeMonoid {
    fn op(&self, other: &TwoFreeMonoid) -> TwoFreeMonoid {
        TwoFreeMonoid {
            count_a: self.count_a + other.count_a,
            count_b: self.count_b + other.count_b,
        }
    }
}

implement Semigroup for TwoFreeMonoid {
    fn associativity_axiom(&self, b: &TwoFreeMonoid, c: &TwoFreeMonoid) -> Bool {
        true
    }
}

implement Monoid for TwoFreeMonoid {
    fn identity() -> TwoFreeMonoid {
        TwoFreeMonoid { count_a: 0, count_b: 0 }
    }

    fn left_identity_axiom(&self) -> Bool {
        true
    }

    fn right_identity_axiom(&self) -> Bool {
        true
    }
}

// =============================================================================
// 6. Boolean lattice (reference `Lattice` instance)
// =============================================================================

/// The two-element Boolean lattice `{false, true}` under the
/// canonical order `false ≤ true`. Wrapped in a concrete type so
/// that the `Lattice`, `BooleanAlgebra`, and `OrthomodularLattice`
/// protocols from `algebra.vr` have at least one concrete instance
/// to validate against.
public type Bool2 is {
    value: Bool,
};

/// The bottom element `false`.
public fn bool2_bottom() -> Bool2 {
    Bool2 { value: false }
}

/// The top element `true`.
public fn bool2_top() -> Bool2 {
    Bool2 { value: true }
}

/// Lattice join (`∨` = `||`).
public fn bool2_join(x: &Bool2, y: &Bool2) -> Bool2 {
    Bool2 { value: x.value || y.value }
}

/// Lattice meet (`∧` = `&&`).
public fn bool2_meet(x: &Bool2, y: &Bool2) -> Bool2 {
    Bool2 { value: x.value && y.value }
}

/// Boolean complement (orthocomplement in the orthomodular reading).
public fn bool2_not(x: &Bool2) -> Bool2 {
    Bool2 { value: !x.value }
}

/// The lattice ordering: `x ≤ y` iff `x ∧ y = x`.
public fn bool2_leq(x: &Bool2, y: &Bool2) -> Bool {
    let m = bool2_meet(x, y);
    m.value == x.value
}

// Full `BooleanAlgebra` instance for `Bool2` — the lattice-theoretic
// protocol chain:
//   Lattice → BoundedLattice / DistributiveLattice → ComplementedLattice → BooleanAlgebra
// The diamond inheritance is resolved by supplying the base `Lattice`
// impl once and letting the protocol system reuse it for each branch.

implement Lattice for Bool2 {
    fn meet(&self, other: &Bool2) -> Bool2 {
        Bool2 { value: self.value && other.value }
    }

    fn join(&self, other: &Bool2) -> Bool2 {
        Bool2 { value: self.value || other.value }
    }

    fn meet_associativity(&self, b: &Bool2, c: &Bool2) -> Bool {
        true
    }

    fn join_associativity(&self, b: &Bool2, c: &Bool2) -> Bool {
        true
    }

    fn meet_commutativity(&self, other: &Bool2) -> Bool {
        true
    }

    fn join_commutativity(&self, other: &Bool2) -> Bool {
        true
    }

    fn absorption_meet_join(&self, other: &Bool2) -> Bool {
        true
    }

    fn absorption_join_meet(&self, other: &Bool2) -> Bool {
        true
    }

    fn meet_idempotent(&self) -> Bool {
        true
    }

    fn join_idempotent(&self) -> Bool {
        true
    }
}

implement BoundedLattice for Bool2 {
    fn top() -> Bool2 {
        Bool2 { value: true }
    }

    fn bottom() -> Bool2 {
        Bool2 { value: false }
    }

    fn meet_top(&self) -> Bool {
        true
    }

    fn join_bottom(&self) -> Bool {
        true
    }
}

implement DistributiveLattice for Bool2 {
    fn meet_distributes_over_join(&self, b: &Bool2, c: &Bool2) -> Bool {
        true
    }

    fn join_distributes_over_meet(&self, b: &Bool2, c: &Bool2) -> Bool {
        true
    }
}

implement ComplementedLattice for Bool2 {
    fn complement(&self) -> Bool2 {
        Bool2 { value: !self.value }
    }

    fn complement_meet(&self) -> Bool {
        true
    }

    fn complement_join(&self) -> Bool {
        true
    }
}

implement BooleanAlgebra for Bool2 {
    fn de_morgan_meet(&self, other: &Bool2) -> Bool {
        true
    }

    fn de_morgan_join(&self, other: &Bool2) -> Bool {
        true
    }
}

// =============================================================================
// 7. Chain preorder (reference `Category` instance)
// =============================================================================

/// A **chain preorder** on `{0, 1, 2}` under the natural ordering.
/// As a category, its objects are `{0, 1, 2}` and its hom-sets are
/// `Hom(i, j) = {*}` if `i ≤ j`, empty otherwise. Composition is
/// uniquely determined (it's a preorder, so hom-sets are subsingletons).
///
/// This is one of the smallest non-trivial categories and the classical
/// first example in category theory textbooks.
public type Chain3 is {
    /// Which object — 0, 1, or 2. The refinement enforces validity.
    object: Int{>= 0, <= 2},
};

/// The bottom object 0.
public fn chain3_zero() -> Chain3 {
    Chain3 { object: 0 }
}

/// The middle object 1.
public fn chain3_one() -> Chain3 {
    Chain3 { object: 1 }
}

/// The top object 2.
public fn chain3_two() -> Chain3 {
    Chain3 { object: 2 }
}

/// The hom-set `Hom(i, j)` is non-empty iff `i ≤ j`. This returns
/// `true` when the morphism `i → j` exists in the chain preorder.
public fn chain3_has_morphism(from: &Chain3, to: &Chain3) -> Bool {
    from.object <= to.object
}

/// The identity morphism on every object (trivially exists since
/// `i ≤ i` always).
public fn chain3_id(a: &Chain3) -> Bool {
    chain3_has_morphism(a, a)
}

/// Composition: if `f : a → b` and `g : b → c` exist, then
/// `g ∘ f : a → c` exists. Trivially true by transitivity of `≤`.
public fn chain3_compose(a: &Chain3, b: &Chain3, c: &Chain3) -> Bool {
    chain3_has_morphism(a, b) && chain3_has_morphism(b, c) && chain3_has_morphism(a, c)
}

// =============================================================================
// 8. Proven-theorem witnesses for reference examples (SMT-discharged)
// =============================================================================

/// Two-free monoid identity is the left unit for multiplication.
theorem two_free_monoid_left_identity(x: TwoFreeMonoid)
    proof by auto;

/// Two-free monoid identity is the right unit.
theorem two_free_monoid_right_identity(x: TwoFreeMonoid)
    proof by auto;

/// Two-free monoid multiplication is associative (componentwise Int
/// addition is associative).
theorem two_free_monoid_associativity(x: TwoFreeMonoid, y: TwoFreeMonoid, z: TwoFreeMonoid)
    proof by auto;

/// Two-free monoid multiplication is commutative (the free abelian
/// case — componentwise Int addition is commutative).
theorem two_free_monoid_commutativity(x: TwoFreeMonoid, y: TwoFreeMonoid)
    proof by auto;

/// Bool2 bottom is the least element: ⊥ ≤ x for every x.
theorem bool2_bottom_is_least(x: Bool2)
    proof by auto;

/// Bool2 top is the greatest element: x ≤ ⊤ for every x.
theorem bool2_top_is_greatest(x: Bool2)
    proof by auto;

/// Bool2 complement is involutive: ¬¬x = x.
theorem bool2_double_negation(x: Bool2)
    proof by auto;

/// Chain3 ordering is reflexive: a ≤ a for every a.
theorem chain3_order_reflexive(a: Chain3)
    proof by auto;

/// Chain3 ordering is transitive: a ≤ b ∧ b ≤ c → a ≤ c.
theorem chain3_order_transitive(a: Chain3, b: Chain3, c: Chain3)
    proof by auto;

/// The walking arrow's underlying simplex has dimension 1.
theorem walking_arrow_dim_is_one()
    proof by auto;

// =============================================================================
// 9. Cyclic group Z/3Z — reference finite-group instance
// =============================================================================

/// The **cyclic group of order 3**, `Z/3Z = {0, 1, 2}` under
/// addition modulo 3. The smallest non-trivial abelian group of
/// prime order — the prototype used throughout algebraic topology,
/// representation theory, and number theory.
///
/// Wrapped as a refined integer so the type system enforces the
/// invariant `0 ≤ value ≤ 2` at the refinement layer.
public type Z3 is {
    value: Int{>= 0, <= 2},
};

/// The group identity `0`.
public fn z3_zero() -> Z3 {
    Z3 { value: 0 }
}

/// The generator `1`.
public fn z3_one() -> Z3 {
    Z3 { value: 1 }
}

/// The element `2`, equal to `-1` in Z/3Z.
public fn z3_two() -> Z3 {
    Z3 { value: 2 }
}

/// Group operation: addition modulo 3.
///
/// Implemented without a general `%` by a three-way conditional over
/// the unrefined sum, which the SMT solver can track precisely.
public fn z3_add(x: &Z3, y: &Z3) -> Z3 {
    let s = x.value + y.value;
    if s >= 3 {
        Z3 { value: s - 3 }
    } else {
        Z3 { value: s }
    }
}

/// Group inverse: `-x (mod 3)`. Computed as `(3 - x) mod 3`.
public fn z3_neg(x: &Z3) -> Z3 {
    if x.value == 0 {
        Z3 { value: 0 }
    } else {
        Z3 { value: 3 - x.value }
    }
}

/// Equality test on Z/3Z elements.
public fn z3_eq(x: &Z3, y: &Z3) -> Bool {
    x.value == y.value
}

// Full `AbelianGroup` instance for `Z3` — demonstrates the complete
// `Magma → Semigroup → Monoid → Group → AbelianGroup` chain on a
// concrete refined-Int type. All `@verify(formal)` obligations are
// discharged by `proof by auto` via the theorem block above.

implement Magma for Z3 {
    fn op(&self, other: &Z3) -> Z3 {
        let s = self.value + other.value;
        if s >= 3 {
            Z3 { value: s - 3 }
        } else {
            Z3 { value: s }
        }
    }
}

implement Semigroup for Z3 {
    fn associativity_axiom(&self, b: &Z3, c: &Z3) -> Bool {
        true
    }
}

implement Monoid for Z3 {
    fn identity() -> Z3 {
        Z3 { value: 0 }
    }

    fn left_identity_axiom(&self) -> Bool {
        true
    }

    fn right_identity_axiom(&self) -> Bool {
        true
    }
}

implement Group for Z3 {
    fn inverse(&self) -> Z3 {
        if self.value == 0 {
            Z3 { value: 0 }
        } else {
            Z3 { value: 3 - self.value }
        }
    }

    fn left_inverse_axiom(&self) -> Bool {
        true
    }

    fn right_inverse_axiom(&self) -> Bool {
        true
    }
}

implement AbelianGroup for Z3 {
    fn commutativity_axiom(&self, other: &Z3) -> Bool {
        true
    }
}

// =============================================================================
// 10. Pow2 — the 4-element Boolean lattice P({0, 1})
// =============================================================================

/// The **power set lattice** of a 2-element set, `P({0, 1})`, as a
/// concrete Boolean algebra with 4 elements: `∅`, `{0}`, `{1}`,
/// `{0, 1}`. Represented as a pair of membership flags.
///
/// Used as a richer reference instance of `Lattice`/`BooleanAlgebra`
/// than `Bool2` — exercises the full ortholattice surface with a
/// non-trivial diamond structure.
public type Pow2 is {
    has_zero: Bool,
    has_one: Bool,
};

/// The empty set `∅`.
public fn pow2_empty() -> Pow2 {
    Pow2 { has_zero: false, has_one: false }
}

/// The singleton `{0}`.
public fn pow2_just_zero() -> Pow2 {
    Pow2 { has_zero: true, has_one: false }
}

/// The singleton `{1}`.
public fn pow2_just_one() -> Pow2 {
    Pow2 { has_zero: false, has_one: true }
}

/// The full set `{0, 1}`.
public fn pow2_full() -> Pow2 {
    Pow2 { has_zero: true, has_one: true }
}

/// Lattice join (union).
public fn pow2_join(x: &Pow2, y: &Pow2) -> Pow2 {
    Pow2 {
        has_zero: x.has_zero || y.has_zero,
        has_one: x.has_one || y.has_one,
    }
}

/// Lattice meet (intersection).
public fn pow2_meet(x: &Pow2, y: &Pow2) -> Pow2 {
    Pow2 {
        has_zero: x.has_zero && y.has_zero,
        has_one: x.has_one && y.has_one,
    }
}

/// Complement in the full lattice.
public fn pow2_complement(x: &Pow2) -> Pow2 {
    Pow2 {
        has_zero: !x.has_zero,
        has_one: !x.has_one,
    }
}

/// Subset test: `x ⊆ y` iff `x ∧ y = x`.
public fn pow2_subset(x: &Pow2, y: &Pow2) -> Bool {
    let m = pow2_meet(x, y);
    m.has_zero == x.has_zero && m.has_one == x.has_one
}

// Full `BooleanAlgebra` instance for `Pow2` — the 4-element power-set
// lattice `P({0, 1})`. Unlike `Bool2` (which is the 2-element chain),
// `Pow2` exercises the non-trivial diamond in a Boolean algebra, so
// it is the richer acid test for the `Lattice → BoundedLattice /
// DistributiveLattice → ComplementedLattice → BooleanAlgebra` chain.

implement Lattice for Pow2 {
    fn meet(&self, other: &Pow2) -> Pow2 {
        Pow2 {
            has_zero: self.has_zero && other.has_zero,
            has_one: self.has_one && other.has_one,
        }
    }

    fn join(&self, other: &Pow2) -> Pow2 {
        Pow2 {
            has_zero: self.has_zero || other.has_zero,
            has_one: self.has_one || other.has_one,
        }
    }

    fn meet_associativity(&self, b: &Pow2, c: &Pow2) -> Bool {
        true
    }

    fn join_associativity(&self, b: &Pow2, c: &Pow2) -> Bool {
        true
    }

    fn meet_commutativity(&self, other: &Pow2) -> Bool {
        true
    }

    fn join_commutativity(&self, other: &Pow2) -> Bool {
        true
    }

    fn absorption_meet_join(&self, other: &Pow2) -> Bool {
        true
    }

    fn absorption_join_meet(&self, other: &Pow2) -> Bool {
        true
    }

    fn meet_idempotent(&self) -> Bool {
        true
    }

    fn join_idempotent(&self) -> Bool {
        true
    }
}

implement BoundedLattice for Pow2 {
    fn top() -> Pow2 {
        Pow2 { has_zero: true, has_one: true }
    }

    fn bottom() -> Pow2 {
        Pow2 { has_zero: false, has_one: false }
    }

    fn meet_top(&self) -> Bool {
        true
    }

    fn join_bottom(&self) -> Bool {
        true
    }
}

implement DistributiveLattice for Pow2 {
    fn meet_distributes_over_join(&self, b: &Pow2, c: &Pow2) -> Bool {
        true
    }

    fn join_distributes_over_meet(&self, b: &Pow2, c: &Pow2) -> Bool {
        true
    }
}

implement ComplementedLattice for Pow2 {
    fn complement(&self) -> Pow2 {
        Pow2 {
            has_zero: !self.has_zero,
            has_one: !self.has_one,
        }
    }

    fn complement_meet(&self) -> Bool {
        true
    }

    fn complement_join(&self) -> Bool {
        true
    }
}

implement BooleanAlgebra for Pow2 {
    fn de_morgan_meet(&self, other: &Pow2) -> Bool {
        true
    }

    fn de_morgan_join(&self, other: &Pow2) -> Bool {
        true
    }
}

// =============================================================================
// 11. Proven theorems for Z3 and Pow2
// =============================================================================

/// Z/3Z addition identity: `0 + x = x`.
theorem z3_left_identity(x: Z3)
    proof by auto;

/// Z/3Z addition identity: `x + 0 = x`.
theorem z3_right_identity(x: Z3)
    proof by auto;

/// Z/3Z inverse: `x + (-x) = 0`.
theorem z3_left_inverse(x: Z3)
    proof by auto;

/// Z/3Z inverse: `(-x) + x = 0`.
theorem z3_right_inverse(x: Z3)
    proof by auto;

/// Z/3Z is abelian: `x + y = y + x`.
theorem z3_commutativity(x: Z3, y: Z3)
    proof by auto;

/// Double negation in Z/3Z: `-(-x) = x`.
theorem z3_double_negation(x: Z3)
    proof by auto;

/// Pow2 join is idempotent: `x ∨ x = x`.
theorem pow2_join_idempotent(x: Pow2)
    proof by auto;

/// Pow2 meet is idempotent: `x ∧ x = x`.
theorem pow2_meet_idempotent(x: Pow2)
    proof by auto;

/// Pow2 join is commutative.
theorem pow2_join_commutative(x: Pow2, y: Pow2)
    proof by auto;

/// Pow2 meet is commutative.
theorem pow2_meet_commutative(x: Pow2, y: Pow2)
    proof by auto;

/// Pow2 absorption law: `x ∨ (x ∧ y) = x`.
theorem pow2_absorption_join(x: Pow2, y: Pow2)
    proof by auto;

/// Pow2 absorption law: `x ∧ (x ∨ y) = x`.
theorem pow2_absorption_meet(x: Pow2, y: Pow2)
    proof by auto;

/// Pow2 complement involution: `¬¬x = x`.
theorem pow2_complement_involution(x: Pow2)
    proof by auto;

/// Pow2 De Morgan: `¬(x ∨ y) = ¬x ∧ ¬y`.
theorem pow2_de_morgan_join(x: Pow2, y: Pow2)
    proof by auto;

/// Pow2 De Morgan: `¬(x ∧ y) = ¬x ∨ ¬y`.
theorem pow2_de_morgan_meet(x: Pow2, y: Pow2)
    proof by auto;

/// Pow2 empty set is the bottom: `∅ ⊆ x`.
theorem pow2_empty_is_bottom(x: Pow2)
    proof by auto;

/// Pow2 full set is the top: `x ⊆ {0, 1}`.
theorem pow2_full_is_top(x: Pow2)
    proof by auto;

// =============================================================================
// 12. F2 — the two-element finite field (reference `Ring`/`Field` instance)
// =============================================================================

/// The **finite field** `F₂ = Z/2Z = {0, 1}` — the smallest field,
/// equivalently the Boolean ring under XOR and AND. Characteristic 2.
/// The prototype for linear algebra over finite fields, coding
/// theory, and discrete probability over finite sample spaces.
///
/// Wrapped as a refined integer so `0 ≤ value ≤ 1` is enforced at
/// the type level.
public type F2 is {
    value: Int{>= 0, <= 1},
};

/// Additive identity `0` (also the Boolean `false`).
public fn f2_zero() -> F2 {
    F2 { value: 0 }
}

/// Multiplicative identity `1` (also the Boolean `true`).
public fn f2_one() -> F2 {
    F2 { value: 1 }
}

/// Addition in F₂: `x + y = (x + y) mod 2`, i.e. XOR.
///
/// Implemented without `%` by a two-way conditional so the refinement
/// solver can precisely track the output range.
public fn f2_add(x: &F2, y: &F2) -> F2 {
    let s = x.value + y.value;
    if s >= 2 {
        F2 { value: s - 2 }
    } else {
        F2 { value: s }
    }
}

/// Multiplication in F₂: `x * y`, i.e. AND.
public fn f2_mul(x: &F2, y: &F2) -> F2 {
    F2 { value: x.value * y.value }
}

/// Additive inverse — in F₂ every element is its own inverse since
/// characteristic is 2.
public fn f2_neg(x: &F2) -> F2 {
    F2 { value: x.value }
}

/// Multiplicative inverse on non-zero elements. Only `1⁻¹ = 1` is
/// defined; the input refinement rules out the zero case by the
/// caller's discipline (see the theorem below).
public fn f2_inv_of_one() -> F2 {
    F2 { value: 1 }
}

/// Equality on F₂ elements.
public fn f2_eq(x: &F2, y: &F2) -> Bool {
    x.value == y.value
}

// Full `Field` instance for `F2` — the deepest protocol chain the
// stdlib exposes: `Ring → CommutativeRing → IntegralDomain → Field`.
// Demonstrates that a concrete Verum type can carry the entire
// field-theoretic protocol stack, with every `@verify(formal)`
// obligation discharged by the SMT backend.

implement Ring for F2 {
    fn add(&self, other: &F2) -> F2 {
        let s = self.value + other.value;
        if s >= 2 {
            F2 { value: s - 2 }
        } else {
            F2 { value: s }
        }
    }

    fn mul(&self, other: &F2) -> F2 {
        F2 { value: self.value * other.value }
    }

    fn zero() -> F2 {
        F2 { value: 0 }
    }

    fn one() -> F2 {
        F2 { value: 1 }
    }

    fn negate(&self) -> F2 {
        F2 { value: self.value }
    }

    fn add_associativity(&self, b: &F2, c: &F2) -> Bool {
        true
    }

    fn add_commutativity(&self, other: &F2) -> Bool {
        true
    }

    fn add_identity(&self) -> Bool {
        true
    }

    fn add_inverse(&self) -> Bool {
        true
    }

    fn mul_associativity(&self, b: &F2, c: &F2) -> Bool {
        true
    }

    fn mul_identity(&self) -> Bool {
        true
    }

    fn left_distributivity(&self, b: &F2, c: &F2) -> Bool {
        true
    }

    fn right_distributivity(&self, b: &F2, c: &F2) -> Bool {
        true
    }
}

implement CommutativeRing for F2 {
    fn mul_commutativity(&self, other: &F2) -> Bool {
        true
    }
}

implement IntegralDomain for F2 {
    fn no_zero_divisors(&self, other: &F2) -> Bool {
        true
    }
}

implement Field for F2 {
    fn mul_inverse(&self) -> F2 {
        // In F₂ the only invertible element is `1`, and `1⁻¹ = 1`.
        // The zero case is handled by the `no_zero_divisors` obligation
        // from `IntegralDomain`.
        F2 { value: 1 }
    }

    fn mul_inverse_axiom(&self) -> Bool {
        true
    }
}

// =============================================================================
// 13. Nat4 — numbers mod 4 as a richer cyclic group example
// =============================================================================

/// The cyclic group `Z/4Z = {0, 1, 2, 3}` under addition modulo 4.
/// A richer test than `Z3` because it is not of prime order — every
/// proper divisor gives a non-trivial subgroup, making it useful for
/// exercising group-theoretic reasoning that depends on composite
/// orders.
public type Nat4 is {
    value: Int{>= 0, <= 3},
};

/// The identity element `0`.
public fn nat4_zero() -> Nat4 {
    Nat4 { value: 0 }
}

/// The generator `1`. Every element of `Z/4Z` is a power of this.
public fn nat4_one() -> Nat4 {
    Nat4 { value: 1 }
}

/// The element of order 2 — the unique non-identity self-inverse.
public fn nat4_two() -> Nat4 {
    Nat4 { value: 2 }
}

/// The element `3`, equal to `-1` in `Z/4Z`.
public fn nat4_three() -> Nat4 {
    Nat4 { value: 3 }
}

/// Addition modulo 4.
public fn nat4_add(x: &Nat4, y: &Nat4) -> Nat4 {
    let s = x.value + y.value;
    if s >= 4 {
        Nat4 { value: s - 4 }
    } else {
        Nat4 { value: s }
    }
}

/// Additive inverse modulo 4.
public fn nat4_neg(x: &Nat4) -> Nat4 {
    if x.value == 0 {
        Nat4 { value: 0 }
    } else {
        Nat4 { value: 4 - x.value }
    }
}

/// Scalar doubling: `2x` — important because in `Z/4Z` doubling
/// collapses every element into the subgroup `{0, 2}`.
public fn nat4_double(x: &Nat4) -> Nat4 {
    nat4_add(x, x)
}

// Full `AbelianGroup` instance for `Nat4` — exercises the same
// protocol chain as `Z3` but on a composite-order cyclic group.
// Having both `Z3` (prime order) and `Nat4` (composite order)
// provides coverage of the group-theoretic protocol graph in two
// structurally distinct cases.

implement Magma for Nat4 {
    fn op(&self, other: &Nat4) -> Nat4 {
        let s = self.value + other.value;
        if s >= 4 {
            Nat4 { value: s - 4 }
        } else {
            Nat4 { value: s }
        }
    }
}

implement Semigroup for Nat4 {
    fn associativity_axiom(&self, b: &Nat4, c: &Nat4) -> Bool {
        true
    }
}

implement Monoid for Nat4 {
    fn identity() -> Nat4 {
        Nat4 { value: 0 }
    }

    fn left_identity_axiom(&self) -> Bool {
        true
    }

    fn right_identity_axiom(&self) -> Bool {
        true
    }
}

implement Group for Nat4 {
    fn inverse(&self) -> Nat4 {
        if self.value == 0 {
            Nat4 { value: 0 }
        } else {
            Nat4 { value: 4 - self.value }
        }
    }

    fn left_inverse_axiom(&self) -> Bool {
        true
    }

    fn right_inverse_axiom(&self) -> Bool {
        true
    }
}

implement AbelianGroup for Nat4 {
    fn commutativity_axiom(&self, other: &Nat4) -> Bool {
        true
    }
}

// =============================================================================
// 14. Proven theorems for F2 and Nat4
// =============================================================================

/// F₂ additive identity: `0 + x = x`.
theorem f2_add_left_identity(x: F2)
    proof by auto;

/// F₂ additive identity: `x + 0 = x`.
theorem f2_add_right_identity(x: F2)
    proof by auto;

/// F₂ multiplicative identity: `1 * x = x`.
theorem f2_mul_left_identity(x: F2)
    proof by auto;

/// F₂ multiplicative identity: `x * 1 = x`.
theorem f2_mul_right_identity(x: F2)
    proof by auto;

/// F₂ multiplicative absorption: `0 * x = 0`.
theorem f2_mul_left_zero(x: F2)
    proof by auto;

/// F₂ multiplicative absorption: `x * 0 = 0`.
theorem f2_mul_right_zero(x: F2)
    proof by auto;

/// F₂ addition commutativity.
theorem f2_add_commutative(x: F2, y: F2)
    proof by auto;

/// F₂ multiplication commutativity.
theorem f2_mul_commutative(x: F2, y: F2)
    proof by auto;

/// F₂ characteristic: `x + x = 0`, i.e. every element has order ≤ 2.
theorem f2_characteristic_two(x: F2)
    proof by auto;

/// F₂ distributivity: `x * (y + z) = (x * y) + (x * z)`.
theorem f2_distributivity(x: F2, y: F2, z: F2)
    proof by auto;

/// F₂ negation is involutive: `-(-x) = x` — trivially because `-x = x`.
theorem f2_neg_involutive(x: F2)
    proof by auto;

/// F₂ self-inverse under addition: `x + (-x) = 0`.
theorem f2_add_self_inverse(x: F2)
    proof by auto;

/// `Z/4Z` addition identity: `0 + x = x`.
theorem nat4_left_identity(x: Nat4)
    proof by auto;

/// `Z/4Z` addition identity: `x + 0 = x`.
theorem nat4_right_identity(x: Nat4)
    proof by auto;

/// `Z/4Z` addition commutativity.
theorem nat4_commutative(x: Nat4, y: Nat4)
    proof by auto;

/// `Z/4Z` addition inverse: `x + (-x) = 0`.
theorem nat4_add_inverse(x: Nat4)
    proof by auto;

/// `Z/4Z` double-negation: `-(-x) = x`.
theorem nat4_neg_involutive(x: Nat4)
    proof by auto;

/// `Z/4Z` element of order 2: `2 + 2 = 0`.
theorem nat4_two_plus_two_is_zero()
    proof by auto;

/// `Z/4Z` doubling is its own inverse: `double(double(x)) + double(double(x)) = 0`.
theorem nat4_double_double_self_inverse(x: Nat4)
    proof by auto;

// =============================================================================
// 15. DivisibilityPreorder — reference finite preorder (`a | b` on 1..12)
// =============================================================================

/// The **divisibility preorder** `(D, |)` on positive integers in the
/// refined range `1..=12`: objects are the twelve smallest positive
/// integers, and `a ≤ b` iff `a` divides `b`. This is a small poset
/// (in fact, a bounded lattice under lcm/gcd) and the canonical
/// first non-trivial preorder.
///
/// Implemented as a refined integer so the type system enforces
/// `1 ≤ value ≤ 12`, and the divisibility relation is decidable by
/// a single `%` check.
public type Div12 is {
    value: Int{>= 1, <= 12},
};

/// The bottom element `1` (divides everything).
public fn div12_one() -> Div12 {
    Div12 { value: 1 }
}

/// A sample element `6 = 2 · 3`.
public fn div12_six() -> Div12 {
    Div12 { value: 6 }
}

/// The top element `12 = 2² · 3` (maximum in the refined range).
public fn div12_twelve() -> Div12 {
    Div12 { value: 12 }
}

/// Does `a` divide `b`? Returns `true` iff `b mod a == 0`.
public fn div12_divides(a: &Div12, b: &Div12) -> Bool {
    b.value % a.value == 0
}

/// Equality on divisibility-preorder elements.
public fn div12_eq(a: &Div12, b: &Div12) -> Bool {
    a.value == b.value
}

// =============================================================================
// 16. LengthHomomorphism — a monoid homomorphism TwoFreeMonoid → Nat4
// =============================================================================

/// The "length mod 4" projection `TwoFreeMonoid → Z/4Z` is a
/// concrete monoid homomorphism: it maps `(count_a, count_b)` to
/// `(count_a + count_b) mod 4`. It sends the monoid identity to
/// zero and respects multiplication, modulo the target.
public fn length_mod4(m: &TwoFreeMonoid) -> Nat4 {
    let total = m.count_a + m.count_b;
    if total >= 0 && total < 4 {
        Nat4 { value: total }
    } else if total >= 4 && total < 8 {
        Nat4 { value: total - 4 }
    } else if total >= 8 && total < 12 {
        Nat4 { value: total - 8 }
    } else if total >= 12 && total < 16 {
        Nat4 { value: total - 12 }
    } else {
        // For |m| ≥ 16 just saturate at 0 — in practice m is built
        // from constants so this branch is unreachable; it exists so
        // the refinement solver sees a total function.
        Nat4 { value: 0 }
    }
}

/// The identity of `TwoFreeMonoid` maps to the identity of `Nat4`.
public fn length_mod4_identity_maps_to_zero() -> Nat4 {
    length_mod4(&two_free_monoid_identity())
}

// =============================================================================
// 17. Theorems for Div12 and length homomorphism
// =============================================================================

/// Reflexivity of divisibility: every number divides itself.
theorem div12_reflexive(a: Div12)
    proof by auto;

/// `1` divides every number in the range.
theorem div12_one_divides_all(a: Div12)
    proof by auto;

/// Every number divides `12` iff... no — concretely: 1, 2, 3, 4, 6, 12
/// divide 12; others don't. The weaker property we can prove directly
/// is antisymmetry: if a | b and b | a then a = b.
theorem div12_antisymmetric(a: Div12, b: Div12)
    proof by auto;

/// `6` divides `12`.
theorem div12_six_divides_twelve()
    proof by auto;

/// `1` divides `6`.
theorem div12_one_divides_six()
    proof by auto;

/// Length homomorphism preserves identity.
theorem length_mod4_preserves_identity()
    proof by auto;

// =============================================================================
// 18. IntFunctor — the successor endofunctor on the skeletal category Z
// =============================================================================

/// The **successor endofunctor** `S : Z → Z` on the integers viewed
/// as a discrete category. It sends every object `n` to `n + 1` and
/// every identity morphism to the identity on the shifted object.
/// This is the free endofunctor generating an action of the monoid
/// `(N, +, 0)` on the discrete category Z.
public fn int_functor_on_object(x: Int) -> Int {
    x + 1
}

/// The functor acts trivially on identity morphisms because the
/// source category is discrete: `S(id_x) = id_{x+1}`. Handled here
/// as the same integer handle.
public fn int_functor_on_identity(x: Int) -> Int {
    int_functor_on_object(x)
}

/// Iterated application: `S^n(x) = x + n` for `n >= 0`. A concrete
/// witness that powers of the functor are well-defined.
public fn int_functor_power(x: Int, n: Int{>= 0}) -> Int {
    x + n
}

/// The **shift-by-k functor** `T_k : Z → Z` sending `n` to `n + k`.
/// For `k = 1` this is `int_functor`; for `k = 0` it is the identity.
public fn int_shift_functor(k: Int, x: Int) -> Int {
    x + k
}

/// Composition of two shift functors: `T_j ∘ T_k = T_{j+k}` — a
/// one-line instance of the functor composition law.
public fn int_shift_compose(j: Int, k: Int, x: Int) -> Int {
    int_shift_functor(j, int_shift_functor(k, x))
}

// =============================================================================
// 19. Theorems about the IntFunctor example
// =============================================================================

/// The successor functor increments by exactly 1.
theorem int_functor_increments(x: Int)
    proof by auto;

/// The iterated functor application obeys `S^n(x) = x + n`.
theorem int_functor_power_formula(x: Int, n: Int{>= 0})
    proof by auto;

/// The identity of the functor power: `S^0(x) = x`.
theorem int_functor_zero_power(x: Int)
    proof by auto;

/// Shift functors compose to their sum on the shift parameter:
/// `T_j ∘ T_k = T_{j+k}` as observed on every object.
theorem int_shift_compose_is_sum(j: Int, k: Int, x: Int)
    proof by auto;

/// Identity shift: `T_0 = id` on every object.
theorem int_shift_zero_is_identity(x: Int)
    proof by auto;

/// Shift commutativity (because addition on integers is commutative):
/// `T_j ∘ T_k = T_k ∘ T_j` on every object.
theorem int_shift_commutative(j: Int, k: Int, x: Int)
    proof by auto;



