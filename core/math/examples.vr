/// The **identity monad** `Id` on `IntegerPathCategory`: the
/// functorial action is the identity, unit is the identity morphism,
/// multiplication is the identity. It satisfies all three monad laws
/// trivially and is the initial object in the category of monads.
/// This is the concrete acid test for the `Monad` protocol.
public type IdentityMonad is {
    /// Placeholder — all behaviour is in the impl block.
    marker: Int,
};

implement Monad<IntegerPathCategory> for IdentityMonad {
    fn map_obj(a: &Int) -> Int {
        *a
    }

    fn map_mor(f: &Int) -> Int {
        *f
    }

    fn unit(a: &Int) -> Int {
        *a
    }

    fn join(a: &Int) -> Int {
        *a
    }

    fn left_unit_law(a: &Int) -> Bool {
        true
    }

    fn right_unit_law(a: &Int) -> Bool {
        true
    }

    fn associativity_law(a: &Int) -> Bool {
        true
    }
}

/// Smart constructor for the identity monad.
public fn identity_monad() -> IdentityMonad {
    IdentityMonad { marker: 0 }
}

// =============================================================================
// 2.8. IdentityAdjunction — concrete `Adjunction` Id ⊣ Id
// =============================================================================

/// The **identity adjunction** `Id ⊣ Id` on `IntegerPathCategory`:
/// the trivial adjunction where both the left and right adjoint are
/// the identity endofunctor, unit and counit are both the identity
/// natural transformation. Triangle identities hold trivially.
/// Concrete acid test for the 4-parameter `Adjunction<C, D, F, G>`
/// protocol.
public type IdentityAdjunction is {
    /// Placeholder — all behaviour is in the impl block.
    marker: Int,
};

implement Adjunction<
    IntegerPathCategory,
    IntegerPathCategory,
    IdentityEndofunctor,
    IdentityEndofunctor,
> for IdentityAdjunction {
    fn unit(a: &Int) -> Int {
        *a
    }

    fn counit(b: &Int) -> Int {
        *b
    }

    fn triangle_identity_left(a: &Int) -> Bool {
        true
    }

    fn triangle_identity_right(b: &Int) -> Bool {
        true
    }

    fn transpose_left(a: &Int, b: &Int, f: &Int) -> Int {
        *f
    }

    fn transpose_right(a: &Int, b: &Int, g: &Int) -> Int {
        *g
    }

    fn transpose_inverse(a: &Int, b: &Int, f: &Int) -> Bool {
        true
    }
}

/// Smart constructor for the identity adjunction.
public fn identity_adjunction() -> IdentityAdjunction {
    IdentityAdjunction { marker: 0 }
}

