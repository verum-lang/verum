    fn component(a: &Int) -> Int {
        *a
    }

    fn naturality(a: &Int, b: &Int, f: &Int) -> Bool {
        true
    }
}

/// Smart constructor for the identity natural transformation.
public fn identity_nat_trans() -> IdentityNatTrans {
    IdentityNatTrans { marker: 0 }
}

// =============================================================================
// 2.7. IdentityMonad ÔÇö concrete `Monad` on IntegerPathCategory
// =============================================================================

/// The **identity monad** `Id` on `IntegerPathCategory`: the
/// functorial action is the identity, unit is the identity morphism,
/// multiplication is the identity. It satisfies all three monad laws
/// trivially and is the initial object in the category of monads.
/// This is the concrete acid test for the `Monad` protocol.
public type IdentityMonad is {
    /// Placeholder ÔÇö all behaviour is in the impl block.
    marker: Int,
};

implement Monad<IntegerPathCategory> for IdentityMonad {
    fn map_obj(a: &Int) -> Int {
        *a
    }

    fn map_mor(f: &Int) -> Int {
        *f
    }

    fn unit(a: &Int) -> Int {
        *a
    }

    fn join(a: &Int) -> Int {
        *a
    }

    fn left_unit_law(a: &Int) -> Bool {
        true
    }

    fn right_unit_law(a: &Int) -> Bool {
        true
    }

    fn associativity_law(a: &Int) -> Bool {
        true
    }
}

/// Smart constructor for the identity monad.
public fn identity_monad() -> IdentityMonad {
    IdentityMonad { marker: 0 }
}

