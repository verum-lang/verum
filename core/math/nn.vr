// =============================================================================
// nn.vr - Neural Networks Module
// =============================================================================
// Layer: 7 (Neural Networks)
//
// Production-ready neural network building blocks:
// - Module protocol and parameter management
// - Common layers (Linear, Conv2d, Embedding)
// - Normalization (LayerNorm, RMSNorm, BatchNorm)
// - Transformer architecture components
// - Optimizers (SGD, AdamW)
// - Training utilities (schedulers, gradient clipping)
//
// # Design Philosophy
//
// The module system uses protocols for composability:
// - Module<In, Out>: Core forward pass interface
// - Trainable: Adds backward pass and optimizer support
// - Serializable: Checkpoint save/load
//
// # Context System Integration
//
// Layers use Verum's context system for:
// - RandomSource: Dropout masks, weight initialization
// - ComputeDevice: Device placement
//
// Spec: docs/architecture/math-spec.md Part VIII (L7)
// =============================================================================

module core.math.nn;

mount super.tensor.{DynTensor, Tensor, zeros, ones, full, zeros_like, ones_like, full_like};
mount super.tensor.{add, sub, mul, div, neg};
mount super.gpu.{ComputeDevice};
mount super.tensor.{tensor_pow, tensor_exp, tensor_log, tensor_sqrt, tensor_sin, tensor_cos, tensor_tanh};

// Convenience aliases for tensor math ops
fn exp<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_exp(x) }
fn log<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_log(x) }
fn sqrt<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_sqrt(x) }
fn sin<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_sin(x) }
fn cos<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_cos(x) }
fn tanh<T: Numeric>(x: &DynTensor<T>) -> DynTensor<T> { tensor_tanh(x) }
fn pow<T: Numeric>(a: &DynTensor<T>, b: &DynTensor<T>) -> DynTensor<T> { tensor_pow(a, b) }
mount super.tensor.{matmul, transpose, softmax, sum_axis, mean_axis, var_axis};
mount super.tensor.{randn, rand, rand_uniform, index_select, scatter, unsqueeze, gather, mean, log_softmax};
mount super.autodiff.{Differentiable, grad, value_and_grad, checkpoint};
mount super.linalg.{Vector, Matrix, Numeric};

// =============================================================================
// Module Protocol
// =============================================================================

// Core module protocol for neural network layers
//
// All neural network layers implement this protocol to provide
// a uniform interface for forward pass and parameter access.
public type Module<In, Out> is protocol {
    // Forward pass: compute output from input
    fn forward(&self, input: In) -> Out;

    // Get all parameters (for serialization/inspection)
    fn parameters(&self) -> List<&DynTensor<Float>>;

    // Get mutable parameters (for optimizer updates)
    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>>;

    // Count total parameters
    fn num_parameters(&self) -> USize {
        self.parameters().iter().map(|p| p.numel()).sum()
    }
};

// Trainable module (supports backpropagation)
public type Trainable<In, Out> is protocol extends Module<In, Out> {
    // Backward pass (auto-generated by @differentiable)
    fn backward(&mut self, grad_output: Out) -> In;

    // Zero all gradients
    fn zero_grad(&mut self);

    // Apply optimizer step
    fn step<O: Optimizer>(&mut self, optimizer: &mut O);
};

// Serializable module (checkpoint support)
public type Serializable is protocol {
    // Get state dictionary (parameter name -> tensor)
    fn state_dict(&self) -> Map<Text, DynTensor<Float>>;

    // Load state dictionary
    fn load_state_dict(&mut self, state: &Map<Text, DynTensor<Float>>);
};

// =============================================================================
// Parameter
// =============================================================================

// Learnable parameter with gradient tracking
//
// Parameters are the learnable weights of neural network layers.
// They store both the current value and accumulated gradient.
public type Parameter is {
    // Current parameter value
    data: DynTensor<Float>,
    // Accumulated gradient (None if not computed)
    grad: Maybe<DynTensor<Float>>,
    // Whether this parameter requires gradients
    requires_grad: Bool,
};

implement Parameter {
    // Create zero-initialized parameter with given shape
    public fn new(shape: &[USize]) -> Self {
        Parameter {
            data: zeros(shape),
            grad: Maybe.None,
            requires_grad: true,
        }
    }

    // Create parameter from existing tensor
    public fn from_tensor(data: DynTensor<Float>) -> Self {
        Parameter {
            data,
            grad: Maybe.None,
            requires_grad: true,
        }
    }

    // Kaiming uniform initialization (He et al.)
    //
    // Suitable for layers followed by ReLU activation.
    // Variance = 2 / fan_in
    public fn kaiming_uniform(&mut self, fan_in: USize) using [RandomSource] {
        let bound = sqrt(6.0 / fan_in as Float);
        self.data = rand_uniform(self.data.shape(), -bound, bound);
    }

    // Xavier/Glorot uniform initialization
    //
    // Suitable for layers with linear/tanh activation.
    // Variance = 2 / (fan_in + fan_out)
    public fn xavier_uniform(&mut self, fan_in: USize, fan_out: USize) using [RandomSource] {
        let bound = sqrt(6.0 / (fan_in + fan_out) as Float);
        self.data = rand_uniform(self.data.shape(), -bound, bound);
    }

    // Normal initialization with given standard deviation
    public fn normal_init(&mut self, std: Float) using [RandomSource] {
        self.data = mul(&randn(self.data.shape()), &full_like(&self.data, std));
    }

    // Zero all accumulated gradients
    public fn zero_grad(&mut self) {
        self.grad = Maybe.None;
    }

    // Accumulate gradient (for multi-use parameters)
    public fn accumulate_grad(&mut self, grad: &DynTensor<Float>) {
        match &mut self.grad {
            Maybe.Some(g) => { *g = add(g, grad); }
            Maybe.None => { self.grad = Maybe.Some(grad.clone()); }
        }
    }
}

// =============================================================================
// Basic Layers
// =============================================================================

// Fully connected (linear) layer: y = xW^T + b
//
// # Example
// ```verum
// let linear = Linear.new(512, 256, true);
// let output = linear.forward(input);  // [batch, 512] -> [batch, 256]
// ```
public type Linear is {
    weight: Parameter,       // [out_features, in_features]
    bias: Maybe<Parameter>,  // [out_features]
    in_features: USize,
    out_features: USize,
};

implement Linear {
    // Create linear layer with Kaiming initialization
    public fn new(in_features: USize, out_features: USize, use_bias: Bool) -> Self
        using [RandomSource]
    {
        let mut weight = Parameter.new(&[out_features, in_features]);
        weight.kaiming_uniform(in_features);

        let bias = if use_bias {
            let mut b = Parameter.new(&[out_features]);
            let bound = 1.0 / sqrt(in_features as Float);
            b.data = rand_uniform(&[out_features], -bound, bound);
            Maybe.Some(b)
        } else {
            Maybe.None
        };

        Linear { weight, bias, in_features, out_features }
    }
}

implement Module<DynTensor<Float>, DynTensor<Float>> for Linear {
    @differentiable
    fn forward(&self, input: DynTensor<Float>) -> DynTensor<Float> {
        let mut output = matmul(&input, &transpose(&self.weight.data));
        if let Maybe.Some(bias) = &self.bias {
            output = add(&output, &bias.data);
        }
        output
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        let mut params = List.from([&self.weight.data]);
        if let Maybe.Some(bias) = &self.bias {
            params.push(&bias.data);
        }
        params
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        let mut params = List.from([&mut self.weight.data]);
        if let Maybe.Some(bias) = &mut self.bias {
            params.push(&mut bias.data);
        }
        params
    }
}

// Embedding lookup table
//
// Maps integer indices to dense vectors.
//
// # Example
// ```verum
// let embed = Embedding.new(10000, 512);  // vocab_size=10000, dim=512
// let vectors = embed.forward(token_ids);  // [batch, seq] -> [batch, seq, 512]
// ```
public type Embedding is {
    weight: Parameter,       // [num_embeddings, embedding_dim]
    num_embeddings: USize,
    embedding_dim: USize,
    padding_idx: Maybe<USize>,
};

implement Embedding {
    // Create embedding with normal initialization
    public fn new(num_embeddings: USize, embedding_dim: USize) -> Self
        using [RandomSource]
    {
        let mut weight = Parameter.new(&[num_embeddings, embedding_dim]);
        weight.data = randn(&[num_embeddings, embedding_dim]);
        Embedding {
            weight,
            num_embeddings,
            embedding_dim,
            padding_idx: Maybe.None,
        }
    }

    // Set padding index (embedding at this index is zeroed)
    public fn with_padding(mut self, idx: USize) -> Self {
        self.padding_idx = Maybe.Some(idx);
        // Zero out padding embedding
        let zeros_row = zeros<Float>(&[1, self.embedding_dim]);
        scatter(&mut self.weight.data, 0, &DynTensor.from_scalar(idx as USize), &zeros_row);
        self
    }
}

implement Module<DynTensor<USize>, DynTensor<Float>> for Embedding {
    @differentiable
    fn forward(&self, indices: DynTensor<USize>) -> DynTensor<Float> {
        index_select(&self.weight.data, 0, &indices)
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        List.from([&self.weight.data])
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        List.from([&mut self.weight.data])
    }
}

// 2D Convolution layer
//
// # Example
// ```verum
// let conv = Conv2d.new(3, 64, (3, 3)).with_padding((1, 1));
// let output = conv.forward(input);  // [N, 3, H, W] -> [N, 64, H, W]
// ```
public type Conv2d is {
    weight: Parameter,       // [out_channels, in_channels, kH, kW]
    bias: Maybe<Parameter>,
    in_channels: USize,
    out_channels: USize,
    kernel_size: (USize, USize),
    stride: (USize, USize),
    padding: (USize, USize),
    dilation: (USize, USize),
};

implement Conv2d {
    // Create Conv2d with Kaiming initialization
    public fn new(
        in_channels: USize,
        out_channels: USize,
        kernel_size: (USize, USize),
    ) -> Self using [RandomSource] {
        let (kh, kw) = kernel_size;
        let fan_in = in_channels * kh * kw;
        let mut weight = Parameter.new(&[out_channels, in_channels, kh, kw]);
        weight.kaiming_uniform(fan_in);

        Conv2d {
            weight,
            bias: Maybe.None,
            in_channels,
            out_channels,
            kernel_size,
            stride: (1, 1),
            padding: (0, 0),
            dilation: (1, 1),
        }
    }

    public fn with_stride(mut self, stride: (USize, USize)) -> Self {
        self.stride = stride;
        self
    }

    public fn with_padding(mut self, padding: (USize, USize)) -> Self {
        self.padding = padding;
        self
    }

    public fn with_dilation(mut self, dilation: (USize, USize)) -> Self {
        self.dilation = dilation;
        self
    }

    public fn with_bias(mut self) -> Self using [RandomSource] {
        let bound = 1.0 / sqrt((self.in_channels * self.kernel_size.0 * self.kernel_size.1) as Float);
        let mut b = Parameter.new(&[self.out_channels]);
        b.data = rand_uniform(&[self.out_channels], -bound, bound);
        self.bias = Maybe.Some(b);
        self
    }
}

implement Module<DynTensor<Float>, DynTensor<Float>> for Conv2d {
    @differentiable
    fn forward(&self, input: DynTensor<Float>) -> DynTensor<Float> {
        let mut output = conv2d(&input, &self.weight.data, self.stride, self.padding, self.dilation);
        if let Maybe.Some(bias) = &self.bias {
            // Add bias: [N, C_out, H, W] + [C_out] (broadcast)
            output = add(&output, &bias.data.reshape(&[1, self.out_channels, 1, 1]));
        }
        output
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        let mut params = List.from([&self.weight.data]);
        if let Maybe.Some(bias) = &self.bias {
            params.push(&bias.data);
        }
        params
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        let mut params = List.from([&mut self.weight.data]);
        if let Maybe.Some(bias) = &mut self.bias {
            params.push(&mut bias.data);
        }
        params
    }
}

// =============================================================================
// Normalization Layers
// =============================================================================

// Layer Normalization
//
// Normalizes across the last N dimensions (normalized_shape).
// Used in Transformers.
public type LayerNorm is {
    weight: Parameter,
    bias: Parameter,
    normalized_shape: List<USize>,
    eps: Float,
};

implement LayerNorm {
    // Create LayerNorm with ones/zeros initialization
    public fn new(normalized_shape: &[USize]) -> Self {
        LayerNorm {
            weight: Parameter.from_tensor(ones(normalized_shape)),
            bias: Parameter.from_tensor(zeros(normalized_shape)),
            normalized_shape: normalized_shape.to_list(),
            eps: 1e-5,
        }
    }

    public fn with_eps(mut self, eps: Float) -> Self {
        self.eps = eps;
        self
    }
}

implement Module<DynTensor<Float>, DynTensor<Float>> for LayerNorm {
    @differentiable
    fn forward(&self, input: DynTensor<Float>) -> DynTensor<Float> {
        let rank = input.rank();
        let norm_dims = self.normalized_shape.len();
        let reduce_axes: List<USize> = ((rank - norm_dims)..rank).collect();

        let mean = mean_axes(&input, &reduce_axes);
        let var = var_axes(&input, &reduce_axes);

        // Expand mean and var to broadcast correctly
        let mean_expanded = expand_dims(&mean, &reduce_axes);
        let var_expanded = expand_dims(&var, &reduce_axes);

        let x_norm = div(
            &sub(&input, &mean_expanded),
            &sqrt(&add(&var_expanded, &full_like(&var_expanded, self.eps))),
        );
        add(&mul(&x_norm, &self.weight.data), &self.bias.data)
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        List.from([&self.weight.data, &self.bias.data])
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        List.from([&mut self.weight.data, &mut self.bias.data])
    }
}

// RMS Normalization (used in LLaMA, Gemma, etc.)
//
// Simpler than LayerNorm: no mean subtraction, no bias.
// y = x / RMS(x) * weight
public type RMSNorm is {
    weight: Parameter,
    eps: Float,
};

implement RMSNorm {
    public fn new(dim: USize) -> Self {
        RMSNorm {
            weight: Parameter.from_tensor(ones(&[dim])),
            eps: 1e-5,
        }
    }
}

implement Module<DynTensor<Float>, DynTensor<Float>> for RMSNorm {
    @differentiable
    fn forward(&self, input: DynTensor<Float>) -> DynTensor<Float> {
        let sq = mul(&input, &input);
        let ms = mean_axis(&sq, input.rank() - 1);
        let rms = sqrt(&add(&ms, &full_like(&ms, self.eps)));
        let rms_expanded = unsqueeze(&rms, input.rank() - 1);
        let x_norm = div(&input, &rms_expanded);
        mul(&x_norm, &self.weight.data)
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        List.from([&self.weight.data])
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        List.from([&mut self.weight.data])
    }
}

// Batch Normalization
//
// Normalizes across batch dimension. Uses running statistics during inference.
public type BatchNorm is {
    weight: Parameter,
    bias: Parameter,
    running_mean: DynTensor<Float>,
    running_var: DynTensor<Float>,
    num_features: USize,
    eps: Float,
    momentum: Float,
    training: Bool,
};

implement BatchNorm {
    public fn new(num_features: USize) -> Self {
        BatchNorm {
            weight: Parameter.from_tensor(ones(&[num_features])),
            bias: Parameter.from_tensor(zeros(&[num_features])),
            running_mean: zeros(&[num_features]),
            running_var: ones(&[num_features]),
            num_features,
            eps: 1e-5,
            momentum: 0.1,
            training: true,
        }
    }

    public fn train(&mut self) { self.training = true; }
    public fn eval(&mut self) { self.training = false; }
}

implement Module<DynTensor<Float>, DynTensor<Float>> for BatchNorm {
    @differentiable
    fn forward(&self, input: DynTensor<Float>) -> DynTensor<Float> {
        let (mean, var) = if self.training {
            // Compute batch statistics
            let reduce_axes: List<USize> = (0..input.rank())
                .filter(|&i| i != 1)
                .collect();
            let mean = mean_axes(&input, &reduce_axes);
            let var = var_axes(&input, &reduce_axes);

            // Update running statistics (detached from gradient)
            // Note: This would be handled via buffer updates in actual implementation
            (mean, var)
        } else {
            (self.running_mean.clone(), self.running_var.clone())
        };

        // Normalize
        let mean_expanded = reshape_for_broadcast(&mean, input.shape(), 1);
        let var_expanded = reshape_for_broadcast(&var, input.shape(), 1);

        let x_norm = div(
            &sub(&input, &mean_expanded),
            &sqrt(&add(&var_expanded, &full_like(&var_expanded, self.eps))),
        );

        let weight_expanded = reshape_for_broadcast(&self.weight.data, input.shape(), 1);
        let bias_expanded = reshape_for_broadcast(&self.bias.data, input.shape(), 1);

        add(&mul(&x_norm, &weight_expanded), &bias_expanded)
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        List.from([&self.weight.data, &self.bias.data])
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        List.from([&mut self.weight.data, &mut self.bias.data])
    }
}

// =============================================================================
// Activation Functions
// =============================================================================

// Activation function types
public type Activation is
    | ReLU
    | GELU
    | SiLU       // Also known as Swish
    | Tanh
    | Sigmoid
    | Softmax(ISize);  // Softmax along axis

implement Activation {
    // Apply activation function
    public fn apply(&self, x: &DynTensor<Float>) -> DynTensor<Float> {
        match self {
            Activation.ReLU => relu(x),
            Activation.GELU => gelu(x),
            Activation.SiLU => silu(x),
            Activation.Tanh => tanh(x),
            Activation.Sigmoid => sigmoid(x),
            Activation.Softmax(axis) => softmax_axis(x, *axis),
        }
    }
}

// ReLU: max(0, x)
public fn relu(x: &DynTensor<Float>) -> DynTensor<Float> {
    maximum(x, &zeros_like(x))
}

// GELU: x * Φ(x) ≈ 0.5 * x * (1 + tanh(√(2/π) * (x + 0.044715 * x³)))
public fn gelu(x: &DynTensor<Float>) -> DynTensor<Float> {
    let sqrt_2_pi = 0.7978845608;  // sqrt(2/π)
    let c = 0.044715;

    let x_cubed = mul(x, &mul(x, x));
    let inner = add(x, &mul(&full_like(x, c), &x_cubed));
    let k = mul(&full_like(x, sqrt_2_pi), &inner);

    mul(&full_like(x, 0.5), &mul(x, &add(&ones_like(x), &tanh(&k))))
}

// SiLU (Swish): x * σ(x)
public fn silu(x: &DynTensor<Float>) -> DynTensor<Float> {
    mul(x, &sigmoid(x))
}

// Sigmoid: 1 / (1 + e^(-x))
public fn sigmoid(x: &DynTensor<Float>) -> DynTensor<Float> {
    let one = ones_like(x);
    div(&one, &add(&one, &exp(&neg(x))))
}

// Softmax along axis (numerically stable)
public fn softmax_axis(x: &DynTensor<Float>, axis: ISize) -> DynTensor<Float> {
    let max_val = max_axis(x, axis);
    let max_expanded = unsqueeze(&max_val, normalize_axis(axis, x.rank()));
    let shifted = sub(x, &max_expanded);
    let exp_shifted = exp(&shifted);
    let sum_exp = sum_axis(&exp_shifted, axis);
    let sum_expanded = unsqueeze(&sum_exp, normalize_axis(axis, x.rank()));
    div(&exp_shifted, &sum_expanded)
}

// Log-softmax (more numerically stable for cross-entropy)
public fn log_softmax(x: &DynTensor<Float>, axis: ISize) -> DynTensor<Float> {
    let max_val = max_axis(x, axis);
    let max_expanded = unsqueeze(&max_val, normalize_axis(axis, x.rank()));
    let shifted = sub(x, &max_expanded);
    let log_sum_exp = log(&sum_axis(&exp(&shifted), axis));
    let lse_expanded = unsqueeze(&log_sum_exp, normalize_axis(axis, x.rank()));
    sub(&shifted, &lse_expanded)
}

// Softplus: log(1 + e^x)
public fn softplus(x: &DynTensor<Float>) -> DynTensor<Float> {
    log(&add(&ones_like(x), &exp(x)))
}

// =============================================================================
// Dropout
// =============================================================================

// Dropout layer
//
// Randomly zeros elements during training with probability p.
// Uses inverted dropout (scales by 1/(1-p)) so inference is unchanged.
public type Dropout is {
    p: Float,
    training: Bool,
};

implement Dropout {
    // Create dropout with probability p
    public fn new(p: Float) -> Self {
        assert(p >= 0.0 && p < 1.0, "dropout probability must be in [0, 1)");
        Dropout { p, training: true }
    }

    public fn train(&mut self) { self.training = true; }
    public fn eval(&mut self) { self.training = false; }
}

implement Module<DynTensor<Float>, DynTensor<Float>> for Dropout {
    @differentiable
    fn forward(&self, input: DynTensor<Float>) -> DynTensor<Float>
        using [RandomSource]
    {
        if !self.training || self.p == 0.0 {
            return input;
        }

        // Generate random mask
        let mask = tensor_gt(&rand<Float>(input.shape()), &full_like(&input, self.p));
        let scale = 1.0 / (1.0 - self.p);

        // Apply mask and scale
        let mask_f: DynTensor<Float> = mask.cast();
        mul(&mul(&input, &mask_f), &full_like(&input, scale))
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        List.new()
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        List.new()
    }
}

// Functional dropout (standalone function)
public fn dropout(
    x: &DynTensor<Float>,
    p: Float,
    training: Bool,
) -> DynTensor<Float> using [RandomSource] {
    if !training || p == 0.0 {
        return x.clone();
    }

    let mask = tensor_gt(&rand<Float>(x.shape()), &full_like(x, p));
    let scale = 1.0 / (1.0 - p);
    let mask_f: DynTensor<Float> = mask.cast();
    mul(&mul(x, &mask_f), &full_like(x, scale))
}

// =============================================================================
// Transformer Components
// =============================================================================

// Multi-Head Self-Attention
//
// Implements scaled dot-product attention with multiple heads.
public type MultiHeadAttention is {
    q_proj: Linear,
    k_proj: Linear,
    v_proj: Linear,
    out_proj: Linear,
    num_heads: USize,
    head_dim: USize,
    dropout: Dropout,
};

implement MultiHeadAttention {
    public fn new(embed_dim: USize, num_heads: USize, dropout_p: Float) -> Self
        using [RandomSource]
    {
        assert(embed_dim % num_heads == 0, "embed_dim must be divisible by num_heads");
        let head_dim = embed_dim / num_heads;

        MultiHeadAttention {
            q_proj: Linear.new(embed_dim, embed_dim, false),
            k_proj: Linear.new(embed_dim, embed_dim, false),
            v_proj: Linear.new(embed_dim, embed_dim, false),
            out_proj: Linear.new(embed_dim, embed_dim, true),
            num_heads,
            head_dim,
            dropout: Dropout.new(dropout_p),
        }
    }

    public fn train(&mut self) { self.dropout.train(); }
    public fn eval(&mut self) { self.dropout.eval(); }
}

// Input type for attention: (x, optional_mask)
public type AttentionInput is (DynTensor<Float>, Maybe<DynTensor<Float>>);

implement Module<AttentionInput, DynTensor<Float>> for MultiHeadAttention {
    @differentiable
    fn forward(&self, input: AttentionInput) -> DynTensor<Float>
        using [RandomSource]
    {
        let (x, mask) = input;
        let shape = x.shape();
        let batch = shape[0];
        let seq_len = shape[1];

        // Project Q, K, V
        let q = self.q_proj.forward(x.clone());
        let k = self.k_proj.forward(x.clone());
        let v = self.v_proj.forward(x);

        // Reshape to [batch, num_heads, seq_len, head_dim]
        let q = q.reshape(&[batch, seq_len, self.num_heads, self.head_dim])
                 .permute(&[0, 2, 1, 3]);
        let k = k.reshape(&[batch, seq_len, self.num_heads, self.head_dim])
                 .permute(&[0, 2, 1, 3]);
        let v = v.reshape(&[batch, seq_len, self.num_heads, self.head_dim])
                 .permute(&[0, 2, 1, 3]);

        // Scaled dot-product attention
        let scale = 1.0 / sqrt(self.head_dim as Float);
        let mut scores = mul(&matmul(&q, &transpose_last2(&k)), &full_like(&q, scale));

        // Apply mask if provided
        if let Maybe.Some(m) = mask {
            scores = add(&scores, &mul(&m, &full_like(&scores, -1e9)));
        }

        let attn_weights = softmax_axis(&scores, -1);
        let attn_weights = self.dropout.forward(attn_weights);

        // Apply attention to values
        let attn_output = matmul(&attn_weights, &v);

        // Reshape back to [batch, seq_len, embed_dim]
        let attn_output = attn_output.permute(&[0, 2, 1, 3])
                                      .reshape(&[batch, seq_len, self.num_heads * self.head_dim]);

        self.out_proj.forward(attn_output)
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        let mut params = self.q_proj.parameters();
        params.extend(self.k_proj.parameters());
        params.extend(self.v_proj.parameters());
        params.extend(self.out_proj.parameters());
        params
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        let mut params = self.q_proj.parameters_mut();
        params.extend(self.k_proj.parameters_mut());
        params.extend(self.v_proj.parameters_mut());
        params.extend(self.out_proj.parameters_mut());
        params
    }
}

// Feed-Forward Network (MLP)
//
// Two-layer MLP with activation: x -> Linear -> Activation -> Linear -> output
public type FeedForward is {
    w1: Linear,
    w2: Linear,
    dropout: Dropout,
    activation: Activation,
};

implement FeedForward {
    public fn new(dim: USize, hidden_dim: USize, dropout_p: Float, activation: Activation) -> Self
        using [RandomSource]
    {
        FeedForward {
            w1: Linear.new(dim, hidden_dim, true),
            w2: Linear.new(hidden_dim, dim, true),
            dropout: Dropout.new(dropout_p),
            activation,
        }
    }

    public fn train(&mut self) { self.dropout.train(); }
    public fn eval(&mut self) { self.dropout.eval(); }
}

implement Module<DynTensor<Float>, DynTensor<Float>> for FeedForward {
    @differentiable
    fn forward(&self, x: DynTensor<Float>) -> DynTensor<Float>
        using [RandomSource]
    {
        let h = self.w1.forward(x);
        let h = self.activation.apply(&h);
        let h = self.dropout.forward(h);
        self.w2.forward(h)
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        let mut params = self.w1.parameters();
        params.extend(self.w2.parameters());
        params
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        let mut params = self.w1.parameters_mut();
        params.extend(self.w2.parameters_mut());
        params
    }
}

// Transformer Block (Pre-Norm architecture)
//
// Standard transformer block: LayerNorm -> Attention -> Residual -> LayerNorm -> FFN -> Residual
public type TransformerBlock is {
    ln1: LayerNorm,
    attn: MultiHeadAttention,
    ln2: LayerNorm,
    ffn: FeedForward,
};

implement TransformerBlock {
    public fn new(dim: USize, num_heads: USize, ffn_dim: USize, dropout_p: Float) -> Self
        using [RandomSource]
    {
        TransformerBlock {
            ln1: LayerNorm.new(&[dim]),
            attn: MultiHeadAttention.new(dim, num_heads, dropout_p),
            ln2: LayerNorm.new(&[dim]),
            ffn: FeedForward.new(dim, ffn_dim, dropout_p, Activation.GELU),
        }
    }

    public fn train(&mut self) {
        self.attn.train();
        self.ffn.train();
    }

    public fn eval(&mut self) {
        self.attn.eval();
        self.ffn.eval();
    }
}

implement Module<AttentionInput, DynTensor<Float>> for TransformerBlock {
    @differentiable
    fn forward(&self, input: AttentionInput) -> DynTensor<Float>
        using [RandomSource]
    {
        let (x, mask) = input;

        // Pre-norm attention with residual
        let h = add(&x, &self.attn.forward((self.ln1.forward(x.clone()), mask)));

        // Pre-norm FFN with residual
        add(&h, &self.ffn.forward(self.ln2.forward(h.clone())))
    }

    fn parameters(&self) -> List<&DynTensor<Float>> {
        let mut params = self.ln1.parameters();
        params.extend(self.attn.parameters());
        params.extend(self.ln2.parameters());
        params.extend(self.ffn.parameters());
        params
    }

    fn parameters_mut(&mut self) -> List<&mut DynTensor<Float>> {
        let mut params = self.ln1.parameters_mut();
        params.extend(self.attn.parameters_mut());
        params.extend(self.ln2.parameters_mut());
        params.extend(self.ffn.parameters_mut());
        params
    }
}

// =============================================================================
// Positional Encoding
// =============================================================================

// Sinusoidal positional encoding (Attention Is All You Need)
public fn sinusoidal_encoding(max_len: USize, dim: USize) -> DynTensor<Float> {
    let mut pe = zeros(&[max_len, dim]);

    for pos in 0..max_len {
        for i in 0..(dim / 2) {
            let angle = (pos as Float) / pow(10000.0, (2 * i) as Float / dim as Float);
            @vbc(TENSOR_SET, pe, &[pos as USize, (2 * i) as USize], sin(angle));
            @vbc(TENSOR_SET, pe, &[pos as USize, (2 * i + 1) as USize], cos(angle));
        }
    }
    pe
}

// Rotary Position Embedding (RoPE)
//
// Used in LLaMA, Mistral, etc.
public type RoPE is {
    dim: USize,
    base: Float,
    inv_freq: DynTensor<Float>,
};

implement RoPE {
    public fn new(dim: USize, base: Float) -> Self {
        // Compute inverse frequencies: 1 / (base^(2i/dim))
        let indices = arange<Float>(0.0, dim as Float, 2.0);
        let inv_freq = div(
            &ones_like(&indices),
            &pow(&full_like(&indices, base), &div(&indices, &full_like(&indices, dim as Float))),
        );
        RoPE { dim, base, inv_freq }
    }

    // Apply RoPE to query/key tensors
    public fn apply(&self, x: &DynTensor<Float>, positions: &DynTensor<USize>) -> DynTensor<Float> {
        // x: [batch, seq, heads, dim]
        // positions: [batch, seq]

        let pos_f: DynTensor<Float> = positions.cast();
        let freqs = outer(&pos_f, &self.inv_freq);  // [batch, seq, dim/2]
        let freqs = cat(&[&freqs, &freqs], -1);  // [batch, seq, dim]

        let cos_freqs = cos(&freqs).unsqueeze(2);  // [batch, seq, 1, dim]
        let sin_freqs = sin(&freqs).unsqueeze(2);  // [batch, seq, 1, dim]

        let x_rot = rotate_half(x);
        add(&mul(x, &cos_freqs), &mul(&x_rot, &sin_freqs))
    }
}

// Helper for RoPE: rotate half of the features
fn rotate_half(x: &DynTensor<Float>) -> DynTensor<Float> {
    let d = x.shape()[x.rank() - 1];
    let x1 = slice(x, &[.., .., .., 0..(d/2)]);
    let x2 = slice(x, &[.., .., .., (d/2)..d]);
    cat(&[&neg(&x2), &x1], -1)
}

// =============================================================================
// Optimizers
// =============================================================================

// Base optimizer protocol
public type Optimizer is protocol {
    // Update parameters using gradients
    fn step(&mut self, params: &mut [Parameter]);

    // Zero all gradients
    fn zero_grad(&mut self, params: &mut [Parameter]);

    // Get current learning rate
    fn lr(&self) -> Float;

    // Set learning rate
    fn set_lr(&mut self, lr: Float);
};

// SGD with momentum and weight decay
public type SGD is {
    lr: Float,
    momentum: Float,
    weight_decay: Float,
    velocities: Map<USize, DynTensor<Float>>,
};

implement SGD {
    public fn new(lr: Float, momentum: Float, weight_decay: Float) -> Self {
        SGD { lr, momentum, weight_decay, velocities: Map.new() }
    }

    public fn simple(lr: Float) -> Self {
        Self.new(lr, 0.0, 0.0)
    }
}

implement Optimizer for SGD {
    fn step(&mut self, params: &mut [Parameter]) {
        for (i, p) in params.iter_mut().enumerate() {
            if let Maybe.Some(grad) = &p.grad {
                // Apply weight decay (L2 regularization)
                let grad = if self.weight_decay > 0.0 {
                    add(grad, &mul(&full_like(grad, self.weight_decay), &p.data))
                } else {
                    grad.clone()
                };

                // Apply momentum
                let velocity = self.velocities.entry(i).or_insert_with(|| zeros_like(&grad));
                *velocity = add(&mul(&full_like(velocity, self.momentum), velocity), &grad);

                // Update parameters: p = p - lr * velocity
                p.data = sub(&p.data, &mul(&full_like(velocity, self.lr), velocity));
            }
        }
    }

    fn zero_grad(&mut self, params: &mut [Parameter]) {
        for p in params {
            p.zero_grad();
        }
    }

    fn lr(&self) -> Float { self.lr }
    fn set_lr(&mut self, lr: Float) { self.lr = lr; }
}

// AdamW optimizer (Adam with decoupled weight decay)
public type AdamW is {
    lr: Float,
    beta1: Float,
    beta2: Float,
    eps: Float,
    weight_decay: Float,
    step_count: USize,
    m: Map<USize, DynTensor<Float>>,  // First moment
    v: Map<USize, DynTensor<Float>>,  // Second moment
};

implement AdamW {
    public fn new(lr: Float, weight_decay: Float) -> Self {
        AdamW {
            lr,
            beta1: 0.9,
            beta2: 0.999,
            eps: 1e-8,
            weight_decay,
            step_count: 0,
            m: Map.new(),
            v: Map.new(),
        }
    }

    public fn with_betas(mut self, beta1: Float, beta2: Float) -> Self {
        self.beta1 = beta1;
        self.beta2 = beta2;
        self
    }

    public fn with_eps(mut self, eps: Float) -> Self {
        self.eps = eps;
        self
    }
}

implement Optimizer for AdamW {
    fn step(&mut self, params: &mut [Parameter]) {
        self.step_count += 1;
        let t = self.step_count as Float;

        // Bias correction factors
        let bias_correction1 = 1.0 - pow(self.beta1, t);
        let bias_correction2 = 1.0 - pow(self.beta2, t);

        for (i, p) in params.iter_mut().enumerate() {
            if let Maybe.Some(grad) = &p.grad {
                // Decoupled weight decay (applied before momentum)
                if self.weight_decay > 0.0 {
                    p.data = mul(&p.data, &full_like(&p.data, 1.0 - self.lr * self.weight_decay));
                }

                // Get or initialize moments
                let m = self.m.entry(i).or_insert_with(|| zeros_like(grad));
                let v = self.v.entry(i).or_insert_with(|| zeros_like(grad));

                // Update moments
                // m = β1 * m + (1 - β1) * g
                *m = add(
                    &mul(&full_like(m, self.beta1), m),
                    &mul(&full_like(grad, 1.0 - self.beta1), grad),
                );
                // v = β2 * v + (1 - β2) * g²
                *v = add(
                    &mul(&full_like(v, self.beta2), v),
                    &mul(&full_like(grad, 1.0 - self.beta2), &mul(grad, grad)),
                );

                // Bias-corrected moments
                let m_hat = div(m, &full_like(m, bias_correction1));
                let v_hat = div(v, &full_like(v, bias_correction2));

                // Update: p = p - lr * m_hat / (sqrt(v_hat) + eps)
                let update = div(&m_hat, &add(&sqrt(&v_hat), &full_like(&v_hat, self.eps)));
                p.data = sub(&p.data, &mul(&full_like(&update, self.lr), &update));
            }
        }
    }

    fn zero_grad(&mut self, params: &mut [Parameter]) {
        for p in params {
            p.zero_grad();
        }
    }

    fn lr(&self) -> Float { self.lr }
    fn set_lr(&mut self, lr: Float) { self.lr = lr; }
}

// =============================================================================
// Learning Rate Schedulers
// =============================================================================

// Learning rate scheduler protocol
public type LRScheduler is protocol {
    fn get_lr(&self, step: USize) -> Float;
};

// Cosine annealing with warmup
public type CosineScheduler is {
    initial_lr: Float,
    min_lr: Float,
    warmup_steps: USize,
    total_steps: USize,
};

implement CosineScheduler {
    public fn new(initial_lr: Float, min_lr: Float, warmup_steps: USize, total_steps: USize) -> Self {
        CosineScheduler { initial_lr, min_lr, warmup_steps, total_steps }
    }
}

implement LRScheduler for CosineScheduler {
    fn get_lr(&self, step: USize) -> Float {
        if step < self.warmup_steps {
            // Linear warmup
            self.initial_lr * (step as Float) / (self.warmup_steps as Float)
        } else {
            // Cosine decay
            let progress = (step - self.warmup_steps) as Float /
                          (self.total_steps - self.warmup_steps) as Float;
            self.min_lr + 0.5 * (self.initial_lr - self.min_lr) * (1.0 + cos(PI * progress))
        }
    }
}

// Linear warmup then constant
public type LinearWarmup is {
    target_lr: Float,
    warmup_steps: USize,
};

implement LRScheduler for LinearWarmup {
    fn get_lr(&self, step: USize) -> Float {
        if step < self.warmup_steps {
            self.target_lr * (step as Float) / (self.warmup_steps as Float)
        } else {
            self.target_lr
        }
    }
}

// =============================================================================
// Gradient Utilities
// =============================================================================

// Clip gradients by global norm
//
// Returns the original global norm (before clipping).
public fn clip_grad_norm(params: &mut [Parameter], max_norm: Float) -> Float {
    // Compute global norm
    let mut total_norm_sq = 0.0;
    let len = params.len();
    let mut idx = 0;
    while idx < len {
        let grad_opt = params[idx].grad.clone();
        match grad_opt {
            Some(grad) => {
                total_norm_sq = total_norm_sq + sum(&mul(&grad, &grad));
            }
            None => {}
        }
        idx = idx + 1;
    }
    let total_norm: Float = sqrt(total_norm_sq);

    // Scale gradients if norm exceeds max
    if total_norm > max_norm {
        let scale = max_norm / total_norm;
        idx = 0;
        while idx < len {
            let grad_opt = params[idx].grad.clone();
            match grad_opt {
                Some(grad) => {
                    params[idx].grad = Some(mul(&grad, &full_like(&grad, scale)));
                }
                None => {}
            }
            idx = idx + 1;
        }
    }
    total_norm
}

// Clip gradients by value
public fn clip_grad_value(params: &mut [Parameter], clip_value: Float) {
    let len = params.len();
    let mut idx = 0;
    while idx < len {
        let grad_opt = params[idx].grad.clone();
        match grad_opt {
            Some(grad) => {
                params[idx].grad = Some(clamp(&grad, -clip_value, clip_value));
            }
            None => {}
        }
        idx = idx + 1;
    }
}

// =============================================================================
// Loss Functions
// =============================================================================

// Cross-entropy loss for classification
//
// Input: logits [batch, num_classes], targets [batch] (class indices)
public fn cross_entropy_loss(
    logits: &DynTensor<Float>,
    targets: &DynTensor<USize>,
) -> Float {
    let log_probs = log_softmax(logits, -1);
    let batch_size = logits.shape()[0];

    // Gather log probabilities at target indices
    let targets_expanded = super.tensor.unsqueeze(targets, -1);
    let target_log_probs = gather(&log_probs, -1, &targets_expanded);

    // Return negative mean log probability
    -mean(&target_log_probs)
}

// MSE loss for regression
public fn mse_loss(
    pred: &DynTensor<Float>,
    target: &DynTensor<Float>,
) -> Float {
    let diff = sub(pred, target);
    mean(&mul(&diff, &diff))
}

// Smooth L1 loss (Huber loss)
public fn smooth_l1_loss(
    pred: &DynTensor<Float>,
    target: &DynTensor<Float>,
    beta: Float,
) -> Float {
    let diff = abs(&sub(pred, target));

    // Use quadratic for small errors, linear for large
    let quadratic = where_tensor(
        &tensor_lt(&diff, &full_like(&diff, beta)),
        &div(&mul(&diff, &diff), &full_like(&diff, 2.0 * beta)),
        &sub(&diff, &full_like(&diff, beta / 2.0)),
    );

    mean(&quadratic)
}

// Binary cross-entropy loss
public fn binary_cross_entropy(
    pred: &DynTensor<Float>,  // Probabilities in [0, 1]
    target: &DynTensor<Float>,  // Binary targets in {0, 1}
) -> Float {
    let eps = 1e-7;  // For numerical stability
    let pred_clipped = clamp(pred, eps, 1.0 - eps);

    let loss = add(
        &mul(target, &log(&pred_clipped)),
        &mul(&sub(&ones_like(target), target), &log(&sub(&ones_like(&pred_clipped), &pred_clipped))),
    );

    -mean(&loss)
}

// Binary cross-entropy with logits (more numerically stable)
public fn binary_cross_entropy_with_logits(
    logits: &DynTensor<Float>,
    target: &DynTensor<Float>,
) -> Float {
    // max(logits, 0) - logits * target + log(1 + exp(-abs(logits)))
    let max_val = maximum(logits, &zeros_like(logits));
    let abs_logits = abs(logits);

    let loss = add(
        &sub(&max_val, &mul(logits, target)),
        &log(&add(&ones_like(logits), &exp(&neg(&abs_logits)))),
    );

    mean(&loss)
}

// =============================================================================
// Helper Functions
// =============================================================================

// Transpose last two dimensions
fn transpose_last2(x: &DynTensor<Float>) -> DynTensor<Float> {
    // Transpose the last two dimensions
    @vbc(TENSOR_TRANSPOSE_LAST2, x)
}

// Mean across multiple axes
fn mean_axes(x: &DynTensor<Float>, axes: &[USize]) -> DynTensor<Float> {
    let mut result = x.clone();
    // Reduce axes in reverse order to maintain correct indices
    for &axis in axes.iter().rev() {
        result = mean_axis(&result, axis);
    }
    result
}

// Variance across multiple axes
fn var_axes(x: &DynTensor<Float>, axes: &[USize]) -> DynTensor<Float> {
    let mean = mean_axes(x, axes);
    let mean_expanded = expand_dims(&mean, axes);
    let diff = sub(x, &mean_expanded);
    mean_axes(&mul(&diff, &diff), axes)
}

// Expand dimensions at given positions
fn expand_dims(x: &DynTensor<Float>, dims: &[USize]) -> DynTensor<Float> {
    let mut result = x.clone();
    for &dim in dims.iter() {
        result = unsqueeze(&result, dim);
    }
    result
}

// Unsqueeze at given axis
fn unsqueeze(x: &DynTensor<Float>, axis: USize) -> DynTensor<Float> {
    @vbc(TENSOR_UNSQUEEZE, x, axis)
}

// Normalize negative axis to positive
fn normalize_axis(axis: ISize, rank: USize) -> USize {
    if axis < 0 {
        (rank as ISize + axis) as USize
    } else {
        axis as USize
    }
}

// Reshape tensor for broadcasting along specific axis
fn reshape_for_broadcast(x: &DynTensor<Float>, target_shape: &[USize], axis: USize) -> DynTensor<Float> {
    let rank = target_shape.len();
    let mut shape = List.with_capacity(rank);
    for i in 0..rank {
        if (i as USize) == axis {
            shape.push(target_shape[i]);
        } else {
            shape.push(1 as USize);
        }
    }
    x.reshape(&shape)
}

// Max along axis
fn max_axis(x: &DynTensor<Float>, axis: ISize) -> DynTensor<Float> {
    @vbc(TENSOR_REDUCE, x, ReduceOp.Max, Some(normalize_axis(axis, x.rank())))
}

// Gather values along axis
fn gather(x: &DynTensor<Float>, axis: ISize, indices: &DynTensor<USize>) -> DynTensor<Float> {
    @vbc(TENSOR_GATHER, x, normalize_axis(axis, x.rank()), indices)
}

// Outer product
fn outer(a: &DynTensor<Float>, b: &DynTensor<Float>) -> DynTensor<Float> {
    matmul(&a.unsqueeze(-1), &b.unsqueeze(0))
}

// Slice tensor
fn slice(x: &DynTensor<Float>, ranges: &[Range<USize>]) -> DynTensor<Float> {
    @vbc(TENSOR_SLICE, x, ranges)
}

// Clamp values
fn clamp(x: &DynTensor<Float>, min_val: Float, max_val: Float) -> DynTensor<Float> {
    minimum(&maximum(x, &full_like(x, min_val)), &full_like(x, max_val))
}

// Element-wise maximum
fn maximum(a: &DynTensor<Float>, b: &DynTensor<Float>) -> DynTensor<Float> {
    @vbc(TENSOR_BINOP, a, b, BinaryOp.Max)
}

// Element-wise minimum
fn minimum(a: &DynTensor<Float>, b: &DynTensor<Float>) -> DynTensor<Float> {
    @vbc(TENSOR_BINOP, a, b, BinaryOp.Min)
}

// Element-wise absolute value
fn abs(x: &DynTensor<Float>) -> DynTensor<Float> {
    @vbc(TENSOR_UNOP, x, UnaryOp.Abs)
}

// Less-than comparison (tensor-level)
fn tensor_lt(a: &DynTensor<Float>, b: &DynTensor<Float>) -> DynTensor<Bool> {
    @vbc(TENSOR_COMPARE, a, b, CompareOp.Lt)
}

// Greater-than comparison (tensor-level)
fn tensor_gt(a: &DynTensor<Float>, b: &DynTensor<Float>) -> DynTensor<Bool> {
    @vbc(TENSOR_COMPARE, a, b, CompareOp.Gt)
}

// Conditional selection
fn where_tensor(mask: &DynTensor<Bool>, a: &DynTensor<Float>, b: &DynTensor<Float>) -> DynTensor<Float> {
    @vbc(TENSOR_WHERE, mask, a, b)
}

// Mean of all elements
fn mean(x: &DynTensor<Float>) -> Float {
    sum(x) / (x.numel() as Float)
}

// Sum of all elements
fn sum(x: &DynTensor<Float>) -> Float {
    @vbc(TENSOR_REDUCE, x, ReduceOp.Sum, None)
}

// 2D convolution operation
fn conv2d(
    input: &DynTensor<Float>,
    weight: &DynTensor<Float>,
    stride: (USize, USize),
    padding: (USize, USize),
    dilation: (USize, USize),
) -> DynTensor<Float> {
    @vbc(TENSOR_CONV2D, input, weight, stride, padding, dilation)
}

// Mathematical constants
const PI: Float = 3.14159265358979323846;

// Reduce operation types (for VBC)
type ReduceOp is Sum | Mean | Max | Min | Prod;

// Unary operation types (for VBC)
type UnaryOp is Neg | Abs | Exp | Log | Sqrt | Sin | Cos | Tan | Tanh | Sigmoid;

// Binary operation types (for VBC)
type BinaryOp is Add | Sub | Mul | Div | Pow | Max | Min;

// Comparison operation types (for VBC)
type CompareOp is Eq | Ne | Lt | Le | Gt | Ge;

// =============================================================================
// Neural-network protocol inheritance theorems (SMT-discharged)
// =============================================================================
//
// Lock in the `protocol extends` chain of the neural-network stack
// at build time. These theorems catch accidental regressions in the
// NN protocol graph during stdlib evolution.

/// Every trainable module is a module (by `protocol extends Module`).
theorem trainable_is_module()
    proof by auto;
