// =============================================================================
// owl2_fs.data_range — Shkotin 2019 Table 3 (Data Ranges)
// =============================================================================
//
// §2.2.2 of OWL 2 Functional-Style Syntax (W3C Rec 2012); 5 operators
// constructing the data-value side of OWL 2 (the `d` sort).
// =============================================================================

/// `DataIntersectionOf(DR1 ... DRn)` — intersection of n data ranges.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.2 Table 3: DataIntersectionOf")
public axiom DataIntersectionOf() -> Bool ensures true;

/// `DataUnionOf(DR1 ... DRn)` — union of n data ranges.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.2 Table 3: DataUnionOf")
public axiom DataUnionOf() -> Bool ensures true;

/// `DataComplementOf(DR)` — complement of a data range with respect
/// to the value space of its datatype.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.2 Table 3: DataComplementOf")
public axiom DataComplementOf() -> Bool ensures true;

/// `DataOneOf(lit1 ... litn)` — finite enumeration of literals.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.2 Table 3: DataOneOf")
public axiom DataOneOf() -> Bool ensures true;

/// `DatatypeRestriction(DT facets...)` — datatype with constraining
/// facets such as xsd:minInclusive / xsd:pattern.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.2 Table 3: DatatypeRestriction")
public axiom DatatypeRestriction() -> Bool ensures true;
