// =============================================================================
// owl2_fs.count — count_o quantifier-of-quantity primitive (VVA §21.5 / C9 V1)
// =============================================================================
//

// Shkotin 2019 introduces a quantifier of quantity `#y:o P(y)` that
// returns the number of OWL 2 Individuals satisfying the predicate
// P. The HOL semantics is `|{y : Individual | P(y)}|` — only
// well-defined when the comprehension set is finite.
//

// V1 (this commit) ships:
//  * the `count_o(domain, pred)` Verum-side function — a *bounded*
//  fold over a user-supplied finite domain witness;
//  * the `count_o_unbounded` companion that returns a Maybe<Int>
//  when the SMT backend cannot decide finiteness;
//  * the `E_OWL2_UNBOUNDED_COUNT` diagnostic *name* (compile-time
//  guard surfaced by user code via `assert_finite_domain`).
//

// V2 (landed) wires CVC5 Finite Model Finding into the SMT routing
// via `crates/verum_smt/src/count_o_dispatch.rs`. When the surrounding
// refinement type carries an explicit cardinality bound (e.g.
// `{ x : Int | x ≤ K ∧ x = count_o(_, P) }`) the verifier constructs
// a `CountOQuery`, emits an `FmfQuery` over an uninterpreted
// individual sort with cardinality ≤ K, and asks CVC5 to enumerate
// the satisfying interpretations. The model's count of `pred(d) = true`
// slots is the recovered `count_o` value; the V1 `Maybe.None` path
// remains as the stub-mode fallback when CVC5 is not linked.
//

// This file deliberately keeps `count_o` as a *parameterised* fold
// over an explicit domain `List<Individual>` — V1 chooses
// constructive correctness (the user supplies the universe) over
// black-box SMT decidability . Production code mounts the
// closed-domain helper from `core.math.frameworks.owl2_fs.types`.
// =============================================================================

mount core.math.frameworks.owl2_fs.types;

/// `E_OWL2_UNBOUNDED_COUNT` diagnostic name. Returned as part of
/// `Maybe.None` from `count_o_unbounded` when the user does not
/// supply a finite-domain witness for the comprehension.
///
/// **OWA-only stance.** OWL 2 Direct Semantics is open-world per
/// W3C §5.6 — there is no per-class CWA opt-in at the framework
/// layer. A `count_o` query needs a `List<Individual>` witness
/// because the HOL comprehension `|{y : Individual | P(y)}|` is
/// only well-defined when the bound set is finite. Code that
/// calls `count_o` without a witness must accept `Maybe.None`
/// or wrap the call in `assert_finite_domain` to fail loudly.
public let E_OWL2_UNBOUNDED_COUNT: Text = "E_OWL2_UNBOUNDED_COUNT";

/// Bounded count: walks `domain` and returns the number of
/// individuals for which `pred` holds. Total because `domain` is
/// finite by construction (`List<I>` has a finite length).
///

/// Generic over any `Individual` implementor — concrete consumers
/// instantiate `I` with their own NamedIndividual / AnonymousID type.
///

/// The fold is the constructive image of Shkotin's `#y:o P(y)`:
/// when the OWL 2 universe is presented as an explicit list of
/// individuals (the closed-domain assumption per VVA §21.4), the
/// count is decidable in linear time.
public fn count_o<I: Individual>(
    domain: List<I>,
    pred:   fn(I) -> Bool,
) -> Int {
    let mut hits: Int = 0;
    let mut i: Int = 0;
    while i < domain.len() as Int {
        let x: I = (*domain.get(i as Int)
            .expect("count_o: i < domain.len() by while-condition")).clone();
        if pred(x) {
            hits = hits + 1;
        }
        i = i + 1;
    }
    hits
}

/// Unbounded count: returns `Maybe.Some(n)` iff the domain
/// witness can be supplied; otherwise `Maybe.None` to signal
/// `E_OWL2_UNBOUNDED_COUNT`. The witness is always required at
/// the call site — OWL 2 Direct Semantics is open-world (W3C
/// §5.6), so no implicit closure of the universe is performed
/// at this layer.
///
/// V2 (landed): when the witness is `Maybe.None` AND the
/// surrounding refinement type carries an explicit finite-
/// cardinality bound, the verifier dispatches to CVC5 Finite
/// Model Finding via `verum_smt::count_o_dispatch`. The
/// dispatcher constructs a `CountOQuery`, asks CVC5 to enumerate
/// satisfying interpretations, and recovers the count from the
/// model. In stub mode (CVC5 not linked) the dispatcher returns
/// `CountOResult::Unsupported`, and this function's
/// `Maybe.None` branch is the honest fallback.
public fn count_o_unbounded<I: Individual>(
    domain: Maybe<List<I>>,
    pred:   fn(I) -> Bool,
) -> Maybe<Int> {
    match domain {
        Maybe.Some(d) => Maybe.Some(count_o(d, pred)),
        Maybe.None    => Maybe.None,   // E_OWL2_UNBOUNDED_COUNT
    }
}

/// Compile-time-style guard: panics with `E_OWL2_UNBOUNDED_COUNT`
/// if the count's domain is not bounded. Use at the top of a
/// function that issues a `count_o` query so the failure mode
/// is loud.
///
/// The panic body's remediation is to *supply the witness* —
/// pass an explicit `List<I>` enumerating the relevant
/// individuals. There is no OWL-level CWA flag to set; OWL 2
/// Direct Semantics is OWA-only by W3C §5.6, and finite-domain
/// reasoning is a witness-level concern.
public fn assert_finite_domain<I: Individual>(domain: Maybe<List<I>>) -> List<I> {
    match domain {
        Maybe.Some(d) => d,
        Maybe.None    => {
            panic(E_OWL2_UNBOUNDED_COUNT.clone());
        }
    }
}
