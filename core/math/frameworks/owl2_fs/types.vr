// =============================================================================
// owl2_fs.types — primitive sorts of the OWL 2 Direct Semantics
// =============================================================================
//
// Shkotin 2019 (`internal/OWL2.DS2HOL.pdf`) §Notation: the DS2HOL
// translation rests on two carrier sorts and one metric:
//
//   o  — Individual (the carrier of the OWL 2 universe ΔᴵO)
//   d  — Literal    (the carrier of typed data values)
//   #  — quantifier of quantity (count_o)
//
// We surface these as Verum types so every framework axiom in
// `core.math.frameworks.owl2_fs.*` can name them by the canonical
// Shkotin spelling.  The types are *abstract* — concrete encodings
// (IRI for Individual, RDF literal-shape for Literal) live at
// `core.math.frameworks.owl2_fs.encoding` (V2).
//
// `count_o` (Shkotin's # quantifier-of-quantity) is shipped here as
// the smallest ergonomic site rather than as a one-axiom file.  See
// VUVA §21.5 — V1 ships the signature, V2 wires CVC5 Finite Model
// Finding and the `E_OWL2_UNBOUNDED_COUNT` diagnostic.
// =============================================================================

/// The carrier sort `o` of the OWL 2 Direct Semantics universe ΔᴵO.
/// Shkotin 2019 treats it as an opaque set; concrete OWL 2 reasoners
/// instantiate `o` with IRIs (NamedIndividual) or anonymous IDs.
public type Individual is protocol {
    /// Discriminator — every OWL 2 individual is either named (an
    /// IRI) or anonymous (a local _:b identifier).
    fn is_named(self) -> Bool;
};

/// The carrier sort `d` of OWL 2 data values (Literals).  Shkotin's
/// "d" sort; concrete RDF literals factor through the lexical-form +
/// datatype-IRI representation.
public type Literal is protocol {
    fn datatype_iri(self) -> Text;
    fn lexical_form(self) -> Text;
};

/// VUVA §21.5 — quantifier of quantity.  `count_o(pred)` is the
/// number of `Individual`s satisfying `pred`.  Returns `Int >= 0`
/// at runtime.  When the domain is not finite, the V2 SMT dispatch
/// returns `E_OWL2_UNBOUNDED_COUNT`.  V1 ships the axiom with a
/// `true` placeholder body; V2 will replace it with the full HOL
/// definition `#y:o P(y) ≡ |{y : Individual | P(y)}|` plus the
/// finite-domain side condition.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §Notation (quantifier of quantity #)")
public axiom count_o_spec() -> Bool
    ensures true;

// ─── #134 / C7 V2 — Direct-Semantics carrier sorts ──────────────────
//
// W3C OWL 2 Direct Semantics §3.1 defines an interpretation `I` over
// two carrier sets:
//
//   ΔᴵO  — the "object domain", where Individuals and class members
//          live (sort `o`)
//   Δᴵᴰ  — the "data domain", a fixed superset of all RDF datatype
//          value spaces, where Literals live (sort `d`)
//
// The interpretation function `⟦·⟧^I` maps:
//
//   • Individual → ΔᴵO          (§3.1, "individual interpretation")
//   • Class      → 𝒫(ΔᴵO)        (§3.1, "class interpretation")
//   • OPE        → 𝒫(ΔᴵO × ΔᴵO)  (§3.1, "object-property interpretation")
//   • DPE        → 𝒫(ΔᴵO × Δᴵᴰ)  (§3.1, "data-property interpretation")
//   • DR  / DT   → 𝒫(Δᴵᴰ)        (§3.1, "data-range interpretation")
//   • Literal    → Δᴵᴰ           (§3.1, "literal interpretation")
//
// Every assertion / class / property axiom of OWL 2 DS is a Boolean
// proposition over these mappings. V2 axiom bodies in this package
// state those propositions via `ensures` clauses on
// `Interpretation::contains_*` predicates. The predicates are
// *abstract* — concrete reasoners instantiate `Interpretation` with
// the specific domain witness (Pellet, HermiT, Z3-based, …) at
// `verum verify --owl2-reasoner=…` ship time.

/// Generic class expression — anything that can stand to the right
/// of `ClassAssertion`. The trusted-boundary axioms in this file
/// treat it opaquely; concrete encodings (NamedClass / ObjectIntersectionOf / …)
/// live at `core.math.frameworks.owl2_fs.class_expr`.
public type ClassExpression is protocol {};

/// Generic object-property expression — `OPE` in W3C parlance.
public type ObjectPropertyExpression is protocol {};

/// Generic data-property expression.
public type DataPropertyExpression is protocol {};

/// Generic data range — anything that interprets to a subset of Δᴵᴰ.
public type DataRange is protocol {};

/// W3C OWL 2 DS §3.1 interpretation function. The protocol exposes
/// the four membership predicates that every DS axiom body refers to.
/// Each method's contract is: "true iff the named entity's
/// interpretation under I contains the given tuple/value".
///
/// V1 (this commit) ships the protocol as a trusted boundary —
/// concrete reasoners furnish their own witness implementation
/// when they invoke a V2 axiom. V2 SMT dispatch will discharge
/// goals over `Interpretation` via Z3/CVC5 first-order encodings.
public type Interpretation is protocol {
    /// `a^I ∈ ⟦CE⟧^I`: individual `a` is a member of class CE under I.
    fn class_member<C: ClassExpression>(self, ce: C, a: Individual) -> Bool;

    /// `(a^I, b^I) ∈ ⟦OPE⟧^I`: pair (a, b) is in the OPE relation under I.
    fn object_property_pair<P: ObjectPropertyExpression>(
        self, ope: P, a: Individual, b: Individual,
    ) -> Bool;

    /// `(a^I, lt^I) ∈ ⟦DPE⟧^I`: pair (a, lt) is in the DPE relation under I.
    fn data_property_pair<P: DataPropertyExpression>(
        self, dpe: P, a: Individual, lt: Literal,
    ) -> Bool;

    /// `a^I = b^I`: individuals a and b denote the same element of ΔᴵO.
    fn same_individual(self, a: Individual, b: Individual) -> Bool;

    /// `⟦CE₁⟧^I ⊆ ⟦CE₂⟧^I`: every member of CE₁ is also a member of
    /// CE₂ under I (W3C §5.1 SubClassOf).
    fn class_subset<C: ClassExpression>(self, sub: C, sup: C) -> Bool;

    /// `⟦CE₁⟧^I = ⟦CE₂⟧^I`: equal class extensions under I (§5.2
    /// EquivalentClasses, binary core).
    fn class_equal<C: ClassExpression>(self, a: C, b: C) -> Bool;

    /// `⟦CE₁⟧^I ∩ ⟦CE₂⟧^I = ∅`: disjoint class extensions under I
    /// (§5.3 DisjointClasses, binary core).
    fn class_disjoint<C: ClassExpression>(self, a: C, b: C) -> Bool;

    /// `⟦OPE₁⟧^I = (⟦OPE₂⟧^I)⁻¹`: OPE₁ is the inverse relation of
    /// OPE₂ under I (W3C §3.1 ObjectInverseOf). Equivalently:
    /// (a^I, b^I) ∈ ⟦OPE₁⟧^I  iff  (b^I, a^I) ∈ ⟦OPE₂⟧^I
    /// for all individuals a, b.
    fn object_property_inverse<P: ObjectPropertyExpression>(
        self, ope1: P, ope2: P,
    ) -> Bool;

    /// `⟦OPE₁⟧^I ⊆ ⟦OPE₂⟧^I`: every pair in OPE₁ is also in OPE₂
    /// (W3C §5.5.1 SubObjectPropertyOf).
    fn object_property_subset<P: ObjectPropertyExpression>(
        self, sub: P, sup: P,
    ) -> Bool;

    /// `⟦OPE₁⟧^I = ⟦OPE₂⟧^I`: equal extensions (W3C §5.5.4
    /// EquivalentObjectProperties, binary core).
    fn object_property_equal<P: ObjectPropertyExpression>(
        self, a: P, b: P,
    ) -> Bool;

    /// `⟦OPE₁⟧^I ∩ ⟦OPE₂⟧^I = ∅`: disjoint extensions (W3C §5.5.5
    /// DisjointObjectProperties, binary core).
    fn object_property_disjoint<P: ObjectPropertyExpression>(
        self, a: P, b: P,
    ) -> Bool;

    /// `for all (a, b) ∈ ⟦OPE⟧^I, a ∈ ⟦CE⟧^I` (W3C §5.5.6
    /// ObjectPropertyDomain): the domain of OPE is contained in CE.
    fn object_property_domain<P: ObjectPropertyExpression, C: ClassExpression>(
        self, ope: P, ce: C,
    ) -> Bool;

    /// `for all (a, b) ∈ ⟦OPE⟧^I, b ∈ ⟦CE⟧^I` (W3C §5.5.7
    /// ObjectPropertyRange): the range of OPE is contained in CE.
    fn object_property_range<P: ObjectPropertyExpression, C: ClassExpression>(
        self, ope: P, ce: C,
    ) -> Bool;

    /// W3C §5.5.8 FunctionalObjectProperty: every individual has at
    /// most one OPE-successor under I.
    fn object_property_functional<P: ObjectPropertyExpression>(
        self, ope: P,
    ) -> Bool;

    /// W3C §5.5.9 InverseFunctionalObjectProperty: every individual
    /// has at most one OPE-predecessor under I.
    fn object_property_inverse_functional<P: ObjectPropertyExpression>(
        self, ope: P,
    ) -> Bool;

    /// W3C §5.5.10 ReflexiveObjectProperty: (a, a) ∈ ⟦OPE⟧^I for
    /// every a ∈ ΔᴵO.
    fn object_property_reflexive<P: ObjectPropertyExpression>(
        self, ope: P,
    ) -> Bool;

    /// W3C §5.5.11 IrreflexiveObjectProperty: (a, a) ∉ ⟦OPE⟧^I for
    /// every a ∈ ΔᴵO.
    fn object_property_irreflexive<P: ObjectPropertyExpression>(
        self, ope: P,
    ) -> Bool;

    /// W3C §5.5.12 SymmetricObjectProperty: (a,b) ∈ ⟦OPE⟧^I  iff
    /// (b,a) ∈ ⟦OPE⟧^I.
    fn object_property_symmetric<P: ObjectPropertyExpression>(
        self, ope: P,
    ) -> Bool;

    /// W3C §5.5.13 AsymmetricObjectProperty: (a,b) ∈ ⟦OPE⟧^I implies
    /// (b,a) ∉ ⟦OPE⟧^I.
    fn object_property_asymmetric<P: ObjectPropertyExpression>(
        self, ope: P,
    ) -> Bool;

    /// W3C §5.5.14 TransitiveObjectProperty: (a,b) ∈ ⟦OPE⟧^I ∧ (b,c)
    /// ∈ ⟦OPE⟧^I imply (a,c) ∈ ⟦OPE⟧^I.
    fn object_property_transitive<P: ObjectPropertyExpression>(
        self, ope: P,
    ) -> Bool;

    /// W3C §5.5.2/§5.5.3 SubObjectPropertyOfChain (binary core):
    /// ⟦OPE₁⟧^I ∘ ⟦OPE₂⟧^I ⊆ ⟦OPE_super⟧^I (relation composition).
    /// V2 ships the binary-chain core; n-ary chains via Verum-level
    /// fold over consecutive pairs.
    fn object_property_chain<P: ObjectPropertyExpression>(
        self, first: P, second: P, sup: P,
    ) -> Bool;

    // ─── Data-property predicates (§5.6) ────────────────────────────

    /// W3C §5.6.1 SubDataPropertyOf: ⟦DPE₁⟧^I ⊆ ⟦DPE₂⟧^I.
    fn data_property_subset<D: DataPropertyExpression>(
        self, sub: D, sup: D,
    ) -> Bool;

    /// W3C §5.6.2 EquivalentDataProperties (binary core).
    fn data_property_equal<D: DataPropertyExpression>(
        self, a: D, b: D,
    ) -> Bool;

    /// W3C §5.6.3 DisjointDataProperties (binary core).
    fn data_property_disjoint<D: DataPropertyExpression>(
        self, a: D, b: D,
    ) -> Bool;

    /// W3C §5.6.4 DataPropertyDomain: ∀(a, lt) ∈ ⟦DPE⟧^I, a ∈ ⟦CE⟧^I.
    fn data_property_domain<D: DataPropertyExpression, C: ClassExpression>(
        self, dpe: D, ce: C,
    ) -> Bool;

    /// W3C §5.6.5 DataPropertyRange: ∀(a, lt) ∈ ⟦DPE⟧^I, lt ∈ ⟦DR⟧^I.
    fn data_property_range<D: DataPropertyExpression, R: DataRange>(
        self, dpe: D, dr: R,
    ) -> Bool;

    /// W3C §5.6.6 FunctionalDataProperty: every individual has at most
    /// one DPE-value under I.
    fn data_property_functional<D: DataPropertyExpression>(
        self, dpe: D,
    ) -> Bool;

    /// W3C §5.7 DatatypeDefinition: ⟦DT⟧^I = ⟦DR⟧^I (the named
    /// datatype DT has the same value space as the data range DR).
    fn datatype_definition<R: DataRange>(
        self, dt: R, dr: R,
    ) -> Bool;

    /// W3C §5.8 HasKey (NAMED restriction): if every property in the
    /// key list (object + data) gives the SAME value when applied to
    /// two NamedIndividuals a, b that are members of CE under I, then
    /// a^I = b^I.
    /// V2 ships the binary-key core (one OPE + one DPE); n-ary lists
    /// fold via Verum-level helper.
    fn has_key_named<C: ClassExpression, P: ObjectPropertyExpression, D: DataPropertyExpression>(
        self, ce: C, ope: P, dpe: D,
    ) -> Bool;

    // ─── Data-range constructor predicates (§3.4) ────────────────

    /// W3C §3.4 DataIntersectionOf (binary core):
    /// ⟦DataIntersectionOf(DR₁, DR₂)⟧^I = ⟦DR₁⟧^I ∩ ⟦DR₂⟧^I.
    fn data_intersection<R: DataRange>(
        self, result: R, a: R, b: R,
    ) -> Bool;

    /// W3C §3.4 DataUnionOf (binary core):
    /// ⟦DataUnionOf(DR₁, DR₂)⟧^I = ⟦DR₁⟧^I ∪ ⟦DR₂⟧^I.
    fn data_union<R: DataRange>(
        self, result: R, a: R, b: R,
    ) -> Bool;

    /// W3C §3.4 DataComplementOf:
    /// ⟦DataComplementOf(DR)⟧^I = Δᴵᴰ ∖ ⟦DR⟧^I.
    fn data_complement<R: DataRange>(
        self, result: R, base: R,
    ) -> Bool;

    /// W3C §3.4 DataOneOf (singleton core):
    /// ⟦DataOneOf(lt)⟧^I = { lt^I }.
    /// V2 ships the singleton; n-ary enumerations via Verum-level fold.
    fn data_one_of<R: DataRange>(
        self, result: R, lt: Literal,
    ) -> Bool;

    /// W3C §3.4 DatatypeRestriction:
    /// ⟦DatatypeRestriction(DT, F₁ v₁, ..., Fₙ vₙ)⟧^I
    ///    =  ⟦DT⟧^I  ∩  facet-conjunction(F₁ v₁, ..., Fₙ vₙ).
    /// V2 ships a single-facet form `(DT, facet_iri, value)`; n-ary
    /// facet conjunction via Verum-level fold.
    fn datatype_restriction<R: DataRange>(
        self, result: R, base: R, facet: Text, value: Literal,
    ) -> Bool;

    // ─── Class-expression constructor predicates (§3.2) ──────────

    /// W3C §3.2 ObjectIntersectionOf (binary core):
    /// ⟦…⟧^I = ⟦CE₁⟧^I ∩ ⟦CE₂⟧^I.
    fn class_intersection<C: ClassExpression>(
        self, result: C, a: C, b: C,
    ) -> Bool;

    /// W3C §3.2 ObjectUnionOf (binary core).
    fn class_union<C: ClassExpression>(
        self, result: C, a: C, b: C,
    ) -> Bool;

    /// W3C §3.2 ObjectComplementOf:
    /// ⟦…⟧^I = ΔᴵO ∖ ⟦CE⟧^I.
    fn class_complement<C: ClassExpression>(
        self, result: C, base: C,
    ) -> Bool;

    /// W3C §3.2 ObjectOneOf (singleton core):
    /// ⟦…⟧^I = { a^I }. n-ary at helper.
    fn class_one_of<C: ClassExpression>(
        self, result: C, a: Individual,
    ) -> Bool;

    // ─── Object-property class-expression restrictions (§3.3) ────

    /// W3C §3.3 ObjectSomeValuesFrom: ⟦…⟧^I =
    /// { x : ∃y. (x,y) ∈ ⟦OPE⟧^I ∧ y ∈ ⟦CE⟧^I }.
    fn class_object_some_values_from<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, ope: P, filler: C,
    ) -> Bool;

    /// W3C §3.3 ObjectAllValuesFrom: ⟦…⟧^I =
    /// { x : ∀y. (x,y) ∈ ⟦OPE⟧^I → y ∈ ⟦CE⟧^I }.
    fn class_object_all_values_from<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, ope: P, filler: C,
    ) -> Bool;

    /// W3C §3.3 ObjectHasValue: ⟦…⟧^I = { x : (x, a^I) ∈ ⟦OPE⟧^I }.
    fn class_object_has_value<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, ope: P, a: Individual,
    ) -> Bool;

    /// W3C §3.3 ObjectHasSelf: ⟦…⟧^I = { x : (x, x) ∈ ⟦OPE⟧^I }.
    fn class_object_has_self<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, ope: P,
    ) -> Bool;

    /// W3C §3.3 ObjectMinCardinality(n, OPE): ⟦…⟧^I =
    /// { x : #{y : (x,y) ∈ ⟦OPE⟧^I} ≥ n }.
    fn class_object_min_cardinality<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, n: Int, ope: P,
    ) -> Bool;

    /// W3C §3.3 ObjectMaxCardinality(n, OPE): #{…} ≤ n.
    fn class_object_max_cardinality<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, n: Int, ope: P,
    ) -> Bool;

    /// W3C §3.3 ObjectExactCardinality(n, OPE): #{…} = n.
    fn class_object_exact_cardinality<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, n: Int, ope: P,
    ) -> Bool;

    /// W3C §3.3 ObjectQualifiedExactCardinality(n, OPE, CE):
    /// #{y : (x,y) ∈ ⟦OPE⟧^I ∧ y ∈ ⟦CE⟧^I} = n.
    fn class_object_qualified_exact_cardinality<C: ClassExpression, P: ObjectPropertyExpression>(
        self, result: C, n: Int, ope: P, filler: C,
    ) -> Bool;

    // ─── Data-property class-expression restrictions (§3.3) ──────

    /// W3C §3.3 DataSomeValuesFrom: ⟦…⟧^I =
    /// { x : ∃lt. (x,lt) ∈ ⟦DPE⟧^I ∧ lt ∈ ⟦DR⟧^I }.
    fn class_data_some_values_from<C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
        self, result: C, dpe: D, filler: R,
    ) -> Bool;

    /// W3C §3.3 DataAllValuesFrom: ⟦…⟧^I =
    /// { x : ∀lt. (x,lt) ∈ ⟦DPE⟧^I → lt ∈ ⟦DR⟧^I }.
    fn class_data_all_values_from<C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
        self, result: C, dpe: D, filler: R,
    ) -> Bool;

    /// W3C §3.3 DataHasValue: ⟦…⟧^I = { x : (x, lt^I) ∈ ⟦DPE⟧^I }.
    fn class_data_has_value<C: ClassExpression, D: DataPropertyExpression>(
        self, result: C, dpe: D, lt: Literal,
    ) -> Bool;

    /// W3C §3.3 DataMinCardinality / DataMaxCardinality /
    /// DataExactCardinality / DataQualified*: counting predicates over
    /// DPE-values per individual under I. V2 ships them as separate
    /// predicates so SMT dispatch can pick the most specific encoding.
    fn class_data_min_cardinality<C: ClassExpression, D: DataPropertyExpression>(
        self, result: C, n: Int, dpe: D,
    ) -> Bool;

    fn class_data_max_cardinality<C: ClassExpression, D: DataPropertyExpression>(
        self, result: C, n: Int, dpe: D,
    ) -> Bool;

    fn class_data_exact_cardinality<C: ClassExpression, D: DataPropertyExpression>(
        self, result: C, n: Int, dpe: D,
    ) -> Bool;

    fn class_data_qualified_min_cardinality<C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
        self, result: C, n: Int, dpe: D, filler: R,
    ) -> Bool;

    fn class_data_qualified_max_cardinality<C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
        self, result: C, n: Int, dpe: D, filler: R,
    ) -> Bool;

    fn class_data_qualified_exact_cardinality<C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
        self, result: C, n: Int, dpe: D, filler: R,
    ) -> Bool;
};
