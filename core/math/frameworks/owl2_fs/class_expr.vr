// =============================================================================
// owl2_fs.class_expr — Shkotin 2019 Table 4 (Class Expressions)
// =============================================================================
//
// §2.2.3 of OWL 2 Functional-Style Syntax (W3C Rec 2012); 25
// operators forming class expressions. The largest single OWL 2
// surface; covers Boolean class constructors, restrictions on object
// properties (existential, universal, value, self, cardinality), and
// restrictions on data properties.
//
// V2 status (#134, 2026-04-25): all 25 class-expression
// constructors ship verbatim W3C OWL 2 DS §3.2 / §3.3 bodies.
// =============================================================================

mount core.math.frameworks.owl2_fs.types.{
    ClassExpression,
    ObjectPropertyExpression,
    DataPropertyExpression,
    DataRange,
    Individual,
    Literal,
    Interpretation,
};

// --- Boolean class constructors (3) ---

/// `ObjectIntersectionOf(CE₁, CE₂)` (W3C §3.2): ⟦…⟧^I = ⟦CE₁⟧^I ∩
/// ⟦CE₂⟧^I. V2 ships the binary core; n-ary at helper layer.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectIntersectionOf")
public axiom ObjectIntersectionOf<I: Interpretation, C: ClassExpression>(
    interp: I, result: C, a: C, b: C,
) -> Bool
    ensures interp.class_intersection(result, a, b);

/// `ObjectUnionOf(CE₁, CE₂)` (W3C §3.2).
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectUnionOf")
public axiom ObjectUnionOf<I: Interpretation, C: ClassExpression>(
    interp: I, result: C, a: C, b: C,
) -> Bool
    ensures interp.class_union(result, a, b);

/// `ObjectComplementOf(CE)` (W3C §3.2): ⟦…⟧^I = ΔᴵO ∖ ⟦CE⟧^I.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectComplementOf")
public axiom ObjectComplementOf<I: Interpretation, C: ClassExpression>(
    interp: I, result: C, base: C,
) -> Bool
    ensures interp.class_complement(result, base);

// --- Enumeration (1) ---

/// `ObjectOneOf(a₁ ... aₙ)` (W3C §3.2): ⟦…⟧^I = { aᵢ^I : i ∈ 1..n }.
/// V2 ships the singleton core; n-ary enumerations via helper.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectOneOf")
public axiom ObjectOneOf<I: Interpretation, C: ClassExpression>(
    interp: I, result: C, a: Individual,
) -> Bool
    ensures interp.class_one_of(result, a);

// --- Object-property restrictions (8) ---

/// `ObjectSomeValuesFrom(OPE, CE)` (W3C §3.3): ⟦…⟧^I =
/// { x : ∃y. (x,y) ∈ ⟦OPE⟧^I ∧ y ∈ ⟦CE⟧^I }.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectSomeValuesFrom")
public axiom ObjectSomeValuesFrom<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, ope: P, filler: C,
) -> Bool
    ensures interp.class_object_some_values_from(result, ope, filler);

/// `ObjectAllValuesFrom(OPE, CE)` (W3C §3.3): ⟦…⟧^I =
/// { x : ∀y. (x,y) ∈ ⟦OPE⟧^I → y ∈ ⟦CE⟧^I }.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectAllValuesFrom")
public axiom ObjectAllValuesFrom<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, ope: P, filler: C,
) -> Bool
    ensures interp.class_object_all_values_from(result, ope, filler);

/// `ObjectHasValue(OPE, a)` (W3C §3.3):
/// ⟦…⟧^I = { x : (x, a^I) ∈ ⟦OPE⟧^I }.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectHasValue")
public axiom ObjectHasValue<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, ope: P, a: Individual,
) -> Bool
    ensures interp.class_object_has_value(result, ope, a);

/// `ObjectHasSelf(OPE)` (W3C §3.3):
/// ⟦…⟧^I = { x : (x, x) ∈ ⟦OPE⟧^I }.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectHasSelf")
public axiom ObjectHasSelf<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, ope: P,
) -> Bool
    ensures interp.class_object_has_self(result, ope);

/// `ObjectMinCardinality(n, OPE)` (W3C §3.3):
/// ⟦…⟧^I = { x : #{y : (x,y) ∈ ⟦OPE⟧^I} ≥ n }.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectMinCardinality")
public axiom ObjectMinCardinality<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, n: Int, ope: P,
) -> Bool
    ensures interp.class_object_min_cardinality(result, n, ope);

/// `ObjectMaxCardinality(n, OPE)` (W3C §3.3): #{…} ≤ n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectMaxCardinality")
public axiom ObjectMaxCardinality<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, n: Int, ope: P,
) -> Bool
    ensures interp.class_object_max_cardinality(result, n, ope);

/// `ObjectExactCardinality(n, OPE)` (W3C §3.3): #{…} = n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectExactCardinality")
public axiom ObjectExactCardinality<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, n: Int, ope: P,
) -> Bool
    ensures interp.class_object_exact_cardinality(result, n, ope);

/// `ObjectQualifiedExactCardinality(n, OPE, CE)` (W3C §3.3):
/// #{y : (x,y) ∈ ⟦OPE⟧^I ∧ y ∈ ⟦CE⟧^I} = n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: ObjectQualifiedExactCardinality")
public axiom ObjectQualifiedExactCardinality<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I, result: C, n: Int, ope: P, filler: C,
) -> Bool
    ensures interp.class_object_qualified_exact_cardinality(result, n, ope, filler);

// --- Data-property restrictions (8) ---

/// `DataSomeValuesFrom(DPE, DR)` (W3C §3.3): ⟦…⟧^I =
/// { x : ∃lt. (x,lt) ∈ ⟦DPE⟧^I ∧ lt ∈ ⟦DR⟧^I }.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataSomeValuesFrom")
public axiom DataSomeValuesFrom<I: Interpretation, C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
    interp: I, result: C, dpe: D, filler: R,
) -> Bool
    ensures interp.class_data_some_values_from(result, dpe, filler);

/// `DataAllValuesFrom(DPE, DR)` (W3C §3.3).
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataAllValuesFrom")
public axiom DataAllValuesFrom<I: Interpretation, C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
    interp: I, result: C, dpe: D, filler: R,
) -> Bool
    ensures interp.class_data_all_values_from(result, dpe, filler);

/// `DataHasValue(DPE, lt)` (W3C §3.3).
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataHasValue")
public axiom DataHasValue<I: Interpretation, C: ClassExpression, D: DataPropertyExpression>(
    interp: I, result: C, dpe: D, lt: Literal,
) -> Bool
    ensures interp.class_data_has_value(result, dpe, lt);

/// `DataMinCardinality(n, DPE)` (W3C §3.3): #{lt : (x,lt) ∈ ⟦DPE⟧^I} ≥ n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataMinCardinality")
public axiom DataMinCardinality<I: Interpretation, C: ClassExpression, D: DataPropertyExpression>(
    interp: I, result: C, n: Int, dpe: D,
) -> Bool
    ensures interp.class_data_min_cardinality(result, n, dpe);

/// `DataMaxCardinality(n, DPE)` (W3C §3.3): #{…} ≤ n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataMaxCardinality")
public axiom DataMaxCardinality<I: Interpretation, C: ClassExpression, D: DataPropertyExpression>(
    interp: I, result: C, n: Int, dpe: D,
) -> Bool
    ensures interp.class_data_max_cardinality(result, n, dpe);

/// `DataExactCardinality(n, DPE)` (W3C §3.3): #{…} = n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataExactCardinality")
public axiom DataExactCardinality<I: Interpretation, C: ClassExpression, D: DataPropertyExpression>(
    interp: I, result: C, n: Int, dpe: D,
) -> Bool
    ensures interp.class_data_exact_cardinality(result, n, dpe);

/// `DataQualifiedMinCardinality(n, DPE, DR)` (W3C §3.3):
/// #{lt : (x,lt) ∈ ⟦DPE⟧^I ∧ lt ∈ ⟦DR⟧^I} ≥ n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataQualifiedMinCardinality")
public axiom DataQualifiedMinCardinality<I: Interpretation, C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
    interp: I, result: C, n: Int, dpe: D, filler: R,
) -> Bool
    ensures interp.class_data_qualified_min_cardinality(result, n, dpe, filler);

/// `DataQualifiedMaxCardinality(n, DPE, DR)` (W3C §3.3): #{…} ≤ n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataQualifiedMaxCardinality")
public axiom DataQualifiedMaxCardinality<I: Interpretation, C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
    interp: I, result: C, n: Int, dpe: D, filler: R,
) -> Bool
    ensures interp.class_data_qualified_max_cardinality(result, n, dpe, filler);

/// `DataQualifiedExactCardinality(n, DPE, DR)` (W3C §3.3): #{…} = n.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: DataQualifiedExactCardinality")
public axiom DataQualifiedExactCardinality<I: Interpretation, C: ClassExpression, D: DataPropertyExpression, R: DataRange>(
    interp: I, result: C, n: Int, dpe: D, filler: R,
) -> Bool
    ensures interp.class_data_qualified_exact_cardinality(result, n, dpe, filler);

// --- Negative range constraints (4) ---
//
// Shkotin 2019 Table 4 includes the four "negative" forms — explicit
// duals of SomeValuesFrom / AllValuesFrom / HasValue / HasSelf
// expressed as `class_complement` of the corresponding positive
// restriction. They aren't in W3C OWL 2 DS as primitive constructors
// but are derivable: `NegativeX(...) ≡ ObjectComplementOf(X(...))`.
// V2 encodes them via the same complement+restriction composition;
// the `result` parameter is the complement, `filler_pos` (or the
// remaining args) define the restriction body that is being
// complemented.

/// `NegativeObjectSomeValuesFrom(OPE, CE)`: ObjectComplementOf the
/// corresponding ObjectSomeValuesFrom restriction.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: NegativeObjectSomeValuesFrom")
public axiom NegativeObjectSomeValuesFrom<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,           // the complement class
    inner:  C,           // the ObjectSomeValuesFrom result being complemented
    ope:    P,
    filler: C,
) -> Bool
    ensures interp.class_object_some_values_from(inner, ope, filler)
        && interp.class_complement(result, inner);

/// `NegativeObjectAllValuesFrom(OPE, CE)`: ObjectComplementOf
/// ObjectAllValuesFrom.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: NegativeObjectAllValuesFrom")
public axiom NegativeObjectAllValuesFrom<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,
    inner:  C,
    ope:    P,
    filler: C,
) -> Bool
    ensures interp.class_object_all_values_from(inner, ope, filler)
        && interp.class_complement(result, inner);

/// `NegativeObjectHasValue(OPE, a)`: ObjectComplementOf
/// ObjectHasValue.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: NegativeObjectHasValue")
public axiom NegativeObjectHasValue<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,
    inner:  C,
    ope:    P,
    a:      Individual,
) -> Bool
    ensures interp.class_object_has_value(inner, ope, a)
        && interp.class_complement(result, inner);

/// `NegativeObjectHasSelf(OPE)`: ObjectComplementOf ObjectHasSelf.
@framework(owl2_fs, "Shkotin 2019. DS2HOL-1 §2.2.3 Table 4: NegativeObjectHasSelf")
public axiom NegativeObjectHasSelf<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,
    inner:  C,
    ope:    P,
) -> Bool
    ensures interp.class_object_has_self(inner, ope)
        && interp.class_complement(result, inner);
