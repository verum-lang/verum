// =============================================================================
// Baez–Dolan + Gordon–Power–Street — higher-coherence framework axioms
// =============================================================================
//
// Source: R. Gordon, A. J. Power, R. Street, "Coherence for
// tricategories", Memoirs AMS 117 (1995). J. Baez, J. Dolan,
// "Higher-dimensional algebra and topological quantum field theory"
// (1995). J. Lurie, "On the classification of topological field
// theories" (2009), arXiv:0905.0465, develops the Baez–Dolan
// cobordism hypothesis.
//
// Postulates the canonical coherence theorems for 2-, 3-, and higher
// n-category theories that make explicit proof-theoretic work
// feasible without chasing every pentagon / octahedron by hand.
// =============================================================================

/// A tricategory — a 3-dimensional analogue of a category with
/// coherent associators and interchangers.
public type Tricategory is protocol {
    fn is_cocomplete(self) -> Bool;
};

/// A fully dualizable object in a symmetric monoidal (∞, n)-category —
/// the input datum for the Baez–Dolan cobordism hypothesis.
public type FullyDualizable is protocol {
    fn dimension(self) -> Int;
    fn admits_duals_up_to_level(self, k: Int) -> Bool;
};


// =============================================================================
// Gordon–Power–Street coherence
// =============================================================================

/// GPS 1995 Theorem 10.4 — every tricategory is triequivalent to a
/// Gray-category (a tricategory whose interchange is strict up to
/// explicit isomorphism). The canonical presentation eliminates
/// higher-dimensional associativity bookkeeping.
@framework(baez_dolan, "GPS 1995 Theorem 10.4 (tricategory coherence)")
public axiom gps_coherence<T: Tricategory>(t: T) -> Bool
    ensures true;

/// GPS 1995 — three-types are triequivalent to tricategories. Maps
/// higher homotopy types into strict algebraic structures.
@framework(baez_dolan, "GPS 1995 (3-types ≃ tricategories)")
public axiom three_types_tricategories<T: Tricategory>(t: T) -> Bool
    ensures true;


// =============================================================================
// Baez–Dolan cobordism hypothesis (after Lurie 2009)
// =============================================================================

/// Baez–Dolan 1995 / Lurie 2009 Theorem 2.4.6 — the cobordism
/// hypothesis. The (∞, n)-category of framed cobordisms is freely
/// generated as a symmetric monoidal (∞, n)-category with duals by
/// the point. Equivalently, a framed topological field theory is
/// classified by its value on the point.
@framework(baez_dolan, "Lurie 2009 Theorem 2.4.6 (cobordism hypothesis)")
public axiom cobordism_hypothesis<D: FullyDualizable>(d: D) -> Bool
    requires d.dimension() >= 1
    ensures  true;

/// Baez–Dolan tangle hypothesis — the n-category of tangles is the
/// free braided n-category with duals on one object.
@framework(baez_dolan, "Baez–Dolan 1995 (tangle hypothesis)")
public axiom tangle_hypothesis<D: FullyDualizable>(d: D) -> Bool
    requires d.dimension() >= 1
    ensures  true;
