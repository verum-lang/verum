// =============================================================================
// Lurie, Higher Topos Theory — framework axiom package
// =============================================================================
//
// Source: Jacob Lurie, "Higher Topos Theory", Annals of Mathematics
// Studies 170, Princeton University Press (2009), arXiv:math/0608040.
//
// Every axiom in this file is a direct postulate of a theorem in HTT.
// None are re-proved here — HTT has never been fully mechanised in any
// proof assistant. The @framework(lurie_htt, "<citation>") attribute
// makes the dependency visible to `verum audit --framework-axioms`
// and to certificate consumers.
//
// Downstream code that cites these axioms is *rigorous in Verum modulo
// HTT* — an auditor can check Lurie's original proofs against these
// citations and decide whether to admit the dependency.
// =============================================================================

/// An abstract ∞-site — the setting for HTT's descent / sheafification.
public type Site is protocol {
    /// Presentability is a size-smallness condition on the site.
    fn is_presentable(self) -> Bool;
};

/// An abstract ∞-topos. Witnesses the conclusion of HTT 6.2.2.7
/// (sheafification) and several downstream closure properties.
public type InfinityTopos is protocol {
    fn is_presentable(self) -> Bool;
    fn is_cocartesian_closed(self) -> Bool;
};

/// A left-adjoint-preserving-limits ∞-functor. Used to state the
/// Adjoint Functor Theorem.
public type AccessibleFunctor is protocol {
    fn preserves_filtered_colimits(self) -> Bool;
};


// =============================================================================
// §6 ∞-Topoi
// =============================================================================

/// HTT 6.2.2.7 — the headline result. If `c` is a presentable ∞-site,
/// then the ∞-category of sheaves on `c` is an ∞-topos.
@framework(lurie_htt, "HTT 6.2.2.7")
public axiom sheafification_is_infinity_topos<C: Site>(c: C) -> Bool
    requires c.is_presentable()
    ensures  true;

/// HTT 6.1.0.6 — an ∞-category is an ∞-topos iff it is a left exact
/// accessible localization of some presheaf ∞-category.
@framework(lurie_htt, "HTT 6.1.0.6")
public axiom infinity_topos_characterization<E: InfinityTopos>(e: E) -> Bool
    ensures  e.is_presentable();

/// HTT 5.2.7 — adjoint functor theorem for presentable ∞-categories.
/// Every accessible functor between presentable ∞-categories that
/// preserves all small colimits admits a right adjoint.
@framework(lurie_htt, "HTT 5.2.7 (Adjoint Functor Theorem)")
public axiom adjoint_functor_theorem<F: AccessibleFunctor>(f: F) -> Bool
    requires f.preserves_filtered_colimits()
    ensures  true;


// =============================================================================
// §5 Presentable ∞-Categories
// =============================================================================

/// HTT 5.5.4.15 — every accessible localization of a presentable
/// ∞-category is again presentable.
@framework(lurie_htt, "HTT 5.5.4.15")
public axiom accessible_localization_presentable<E: InfinityTopos>(e: E) -> Bool
    requires e.is_presentable()
    ensures  e.is_cocartesian_closed();

/// HTT 5.5.2.9 — presentable ∞-categories are closed under small
/// limits and colimits.
@framework(lurie_htt, "HTT 5.5.2.9")
public axiom presentable_closed_under_limits<E: InfinityTopos>(e: E) -> Bool
    requires e.is_presentable()
    ensures  true;


// =============================================================================
// §4 Limits and Colimits
// =============================================================================

/// HTT 4.3.3.7 — the Kan extension along a fully-faithful functor exists
/// and is fully faithful whenever the target category has the
/// appropriate completeness.
@framework(lurie_htt, "HTT 4.3.3.7 (Kan extension)")
public axiom kan_extension_exists<F: AccessibleFunctor>(f: F) -> Bool
    ensures true;


// =============================================================================
// §6.5 Classifying Topoi
// =============================================================================

/// HTT 6.5.2.14 — a functor of ∞-topoi is a geometric morphism iff its
/// left adjoint is left exact.
@framework(lurie_htt, "HTT 6.5.2.14 (geometric morphism)")
public axiom geometric_morphism_characterization<F: AccessibleFunctor>(f: F) -> Bool
    ensures true;
