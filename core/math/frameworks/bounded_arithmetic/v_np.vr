// =============================================================================
// V_NP — bounded-arithmetic system at the NP stratum (ν^weak = 3)
// =============================================================================

/// V_NP — Cook-Nguyen's theory whose provably total functions are
/// exactly the NP-search problems with deterministic verification.
/// Bounded comprehension over Σ^B_2-formulas; this is the smallest
/// theory beyond P-time. ν^weak = 3.
@framework(bounded_arithmetic_v_np, "V_NP (Cook-Nguyen 2010 §V): NP-search")
public axiom v_np_provability_np_search() -> Bool ensures true;

/// Witness-extraction at NP-stratum is non-deterministic polynomial-
/// time: every Σ^B_2-theorem has a witness produced by a non-
/// deterministic P-time machine.
@framework(bounded_arithmetic_v_np, "V_NP witness extraction is NP")
public axiom v_np_witness_is_np() -> Bool ensures true;
