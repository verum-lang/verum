// =============================================================================
// V_1 — bounded-arithmetic system at the P-time stratum (ν^weak = 1)
// =============================================================================

/// V_1 — Cook-Nguyen's two-sorted theory whose provably total functions
/// are exactly the polynomial-time computable functions. ν^weak = 1.
/// V3: parameterised over a complexity-class index (1 = P-time).
@framework(bounded_arithmetic_v_1, "V_1 (Cook-Nguyen 2010 §V): P-time")
public axiom v_1_provability_p_time(complexity_class_index: Int) -> Bool
    requires complexity_class_index == 1   // 1 = P-time
    ensures  complexity_class_index == 1;

/// V_1 is the natural target for cryptographic / real-time
/// verification. V3: parameterised over the polynomial degree bound.
@framework(bounded_arithmetic_v_1, "V_1 witness extraction is P-time")
public axiom v_1_witness_extraction_polynomial(poly_degree_bound: Int) -> Bool
    requires poly_degree_bound >= 0
    ensures  poly_degree_bound >= 0;
