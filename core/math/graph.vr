// =============================================================================
// graph.vr — Reference-grade graph theory
// =============================================================================
// Layer: Foundations (Mathematical Structures)
// Spec: T1-Y — unified categorical + simplicial + spectral graph theory
//
// A graph is an object with three equivalent views, each exposing a
// different aspect of its structure:
//
//   1. Simplicial:   Graph<V> is a 1-truncated simplicial set.
//                    Inherits face/degeneracy maps, geometric realisation,
//                    the Kan-complex condition. Topologically: a 1-CW
//                    complex. This is the view for fundamental groupoid,
//                    connectivity, covering theory.
//
//   2. Categorical:  FreeGraphCategory<G> is the free category whose
//                    objects are G.vertices() and whose morphisms are
//                    walks (paths with possible repetition). A graph
//                    homomorphism = a functor. Graph quotient = coequalizer.
//                    Covering = covering functor. This is the view for
//                    universal properties and transport of structure.
//
//   3. Presheaf:     GraphPresheaf<G> is a contravariant functor
//                    FreeGraphCategory<G>^op → Set. Sheaf cohomology on
//                    this presheaf recovers the graph Laplacian spectrum
//                    (T1-Y integrates with core/math/linalg.vr::EigenDecomposition).
//                    This is the view for spectral methods, graph neural
//                    network message passing, and homology.
//
// The three views are all EQUIVALENT descriptions of the same mathematical
// object — classical graph theory becomes a special case of each, and
// theorems proved at the category/topos level (T1-R auto-discharge)
// automatically lift to every model.
// =============================================================================

module core.math.graph;

mount core.math.category.{Category, Functor};
mount core.math.simplicial.{SimplicialSet, Simplex};
mount core.math.algebra.{Monoid, Ring};
mount core.math.topology.{TopologicalSpace, ConnectedSpace, PathConnectedSpace};
mount core.base.protocols.{Eq, Ord};

// =============================================================================
// §1. Directed edges and walks
// =============================================================================

/// A directed edge from `src` to `tgt` with optional label `L`.
public type Edge<V, L> is {
    src:   V,
    tgt:   V,
    label: L,
};

/// An unlabelled directed edge — `()` is the trivial label.
public type UEdge<V> is Edge<V, ()>;

/// A walk from `start` to `end` is a sequence of edges where
/// consecutive edges agree on the intermediate vertex. The empty
/// walk (identity morphism in the free category) is
/// `Walk { start: v, end: v, edges: [] }`.
public type Walk<V, L> is {
    start: V,
    end:   V,
    edges: List<Edge<V, L>>,
};

// =============================================================================
// §2. Level 1 — Graph as a 1-truncated simplicial set
// =============================================================================

/// A directed graph, specialised as a 1-truncated simplicial set.
///
/// Every implementation of `Graph<V, L>` must:
///   1. Enumerate its vertices (0-simplices) and edges (1-simplices).
///   2. Provide face maps `face(edge, 0) = src`, `face(edge, 1) = tgt`.
///   3. Provide the degeneracy `deg(v) = Edge { src: v, tgt: v, label: () }`.
///   4. Satisfy the truncation axiom: no n-simplices for n ≥ 2.
///
/// A concrete implementation may choose any representation — adjacency
/// list, adjacency matrix, sparse CSR, edge list — the protocol is
/// agnostic. Algorithm selection depends on the representation's
/// asymptotic complexity for vertex/edge access (`@impl_hint` attributes
/// on the instance can guide the compiler).
public type Graph<V, L> is protocol {
    /// All vertices of the graph.
    fn vertices(&self) -> List<V>;

    /// All edges of the graph.
    fn edges(&self) -> List<Edge<V, L>>;

    /// Edges with source vertex `v` — the out-neighbourhood.
    fn out_edges(&self, v: &V) -> List<Edge<V, L>>;

    /// Edges with target vertex `v` — the in-neighbourhood.
    fn in_edges(&self, v: &V) -> List<Edge<V, L>>;

    /// Number of edges incident on `v`.
    fn degree(&self, v: &V) -> Int{>= 0};

    /// Axiom (T1-R): 1-truncation — no n-simplices for n ≥ 2.
    axiom truncation(n: Int{>= 2})
        ensures true;  // Placeholder until T1-R phase 2; phase 2 will
                       // make this literally enforce emptiness of
                       // higher simplex sets.
};

/// An undirected graph is a directed graph whose edge relation is
/// symmetric — for every edge `u → v` there is a matching `v → u`.
/// The axiom is enforced at implementation time by T1-R.
public type UndirectedGraph<V, L> is protocol extends Graph<V, L> {
    axiom symmetric(u: V, v: V, lab: L)
        ensures true;  // Phase-1 placeholder.
};

/// A simple graph disallows self-loops and parallel edges.
public type SimpleGraph<V, L> is protocol extends Graph<V, L> {
    axiom no_self_loops(v: V)
        ensures true;
    axiom no_parallel(u: V, v: V)
        ensures true;
};

// =============================================================================
// §3. Level 2 — The free category on a graph
// =============================================================================

/// `FreeGraphCategory<G>` treats a graph as the presentation of a free
/// category: objects are vertices, morphisms are walks, identity at
/// each vertex is the empty walk, composition is walk concatenation.
///
/// Graph homomorphism = a functor `FreeGraphCategory<G> -> FreeGraphCategory<H>`.
/// Graph quotient = a coequalizer in the 2-category of graph categories.
/// Covering space = a covering functor (see core/math/topology.vr).
public type FreeGraphCategory<V, L> is protocol extends Category<V, Walk<V, L>> {
    /// The underlying graph from which this category is freely generated.
    fn underlying(&self) -> Heap<dyn Graph<V, L>>;
};

// =============================================================================
// §4. Level 3 — Graph presheaves and spectral theory
// =============================================================================

/// A presheaf on the free graph category. Sections over a vertex =
/// labels assigned to that vertex; restriction along an edge =
/// pullback of labels from source to target. Global sections
/// recover the graph-colouring / harmonic-function viewpoint.
public type GraphPresheaf<V, L, S> is protocol {
    /// Sections over vertex `v`.
    fn sections(&self, v: &V) -> List<S>;

    /// Restriction along edge `e`: pulls sections from tgt to src.
    fn restrict(&self, e: &Edge<V, L>, s: &S) -> S;

    /// The underlying graph.
    fn graph(&self) -> Heap<dyn Graph<V, L>>;
};

// =============================================================================
// §5. Spectral theory bridge
// =============================================================================

/// A graph equipped with a real-valued edge weight — the carrier
/// for Laplacian / adjacency matrix methods. The weight is a Monoid
/// so that parallel edges (in a multigraph) sum their contributions.
public type WeightedGraph<V, W: Monoid> is protocol extends Graph<V, W> {
    /// Adjacency-matrix view (row index = source, column index =
    /// target). Defers to core/math/linalg.vr for spectral decomposition.
    fn adjacency_matrix(&self) -> List<List<W>>;

    /// Degree vector — row sums of the adjacency matrix.
    fn degree_vector(&self) -> List<W>;
};

// =============================================================================
// §6. Classical structure witnesses
// =============================================================================

/// A rooted tree: acyclic connected graph with a distinguished root.
public type RootedTree<V, L> is protocol extends SimpleGraph<V, L> {
    fn root(&self) -> V;
    axiom acyclic() ensures true;      // Phase 1 placeholder.
    axiom connected() ensures true;
};

/// A directed acyclic graph: directed graph with no directed cycles.
/// Enables topological sort (see §7).
public type DAG<V, L> is protocol extends Graph<V, L> {
    axiom acyclic_directed() ensures true;
};

// =============================================================================
// §7. Standard algorithms — folds over the simplicial structure
// =============================================================================

/// **Breadth-first search** — fold over level-sets of the face map.
///
/// At each level, collect the current frontier's out-neighbourhoods,
/// dedup against the visited set, and emit them as the next level.
/// Runs until the frontier is empty; returns the visitation order.
///
/// Complexity: O(|V| + |E|) — each vertex and each edge is touched at
/// most once, provided the graph's `out_edges` and vertex-equality
/// operations are O(1).
public fn bfs<V, L, G>(g: &G, start: V) -> List<V>
    where type G: Graph<V, L>, type V: Eq
{
    let mut visited: List<V> = List.new();
    let mut frontier: List<V> = List.new();
    visited.push(start.clone());
    frontier.push(start);
    while !frontier.is_empty() {
        let mut next_frontier: List<V> = List.new();
        for v in frontier.iter() {
            for edge in g.out_edges(v).iter() {
                let tgt = edge.tgt.clone();
                if !visited.contains(&tgt) {
                    visited.push(tgt.clone());
                    next_frontier.push(tgt);
                }
            }
        }
        frontier = next_frontier;
    }
    visited
}

/// **Depth-first search** — coalgebraic unfold from a seed vertex.
///
/// Maintains a stack of vertices to visit; at each step pops the top,
/// marks visited, pushes unvisited out-neighbours. Returns the
/// visitation order in the order vertices were popped from the stack.
///
/// Complexity: O(|V| + |E|) with O(1) vertex equality.
public fn dfs<V, L, G>(g: &G, start: V) -> List<V>
    where type G: Graph<V, L>, type V: Eq
{
    let mut visited: List<V> = List.new();
    let mut stack: List<V> = List.new();
    stack.push(start);
    while !stack.is_empty() {
        let v = stack.pop().unwrap();
        if visited.contains(&v) { continue; }
        visited.push(v.clone());
        // Push neighbours in reverse order so the leftmost child
        // is processed first on the next iteration.
        let out = g.out_edges(&v);
        let mut i = out.len();
        while i > 0 {
            i = i - 1;
            let tgt = out[i].tgt.clone();
            if !visited.contains(&tgt) {
                stack.push(tgt);
            }
        }
    }
    visited
}

/// **Reachability** — `v` is reachable from `start` iff some walk
/// in the free category on `g` has source `start` and target `v`.
/// Implemented as BFS membership.
public fn reachable<V, L, G>(g: &G, start: V, target: V) -> Bool
    where type G: Graph<V, L>, type V: Eq
{
    let visited = bfs(g, start);
    visited.contains(&target)
}

/// **Euler characteristic** of a graph viewed as a 1-dimensional
/// CW-complex: χ(G) = |V| - |E|. Defers to the simplicial-set view
/// — this is dim 0 minus dim 1 in the face-lattice count.
public fn euler_characteristic<V, L, G>(g: &G) -> Int
    where type G: Graph<V, L>
{
    g.vertices().len() - g.edges().len()
}

/// **Connected components** (undirected graphs) — partitions the
/// vertex set into maximal BFS-reachable classes.
///
/// Algorithm: repeatedly pick an unvisited vertex, BFS it to
/// saturation, emit the reached set as a component. Terminates when
/// every vertex has been placed in some component.
///
/// Complexity: O(|V| + |E|) total across all components.
public fn connected_components<V, L, G>(g: &G) -> List<List<V>>
    where type G: UndirectedGraph<V, L>, type V: Eq
{
    let verts = g.vertices();
    let mut seen: List<V> = List.new();
    let mut components: List<List<V>> = List.new();
    for v in verts.iter() {
        if seen.contains(v) { continue; }
        let component = bfs(g, v.clone());
        for u in component.iter() {
            seen.push(u.clone());
        }
        components.push(component);
    }
    components
}

/// **Topological sort** — a linear extension of the DAG's
/// causal order.
///
/// Uses the Kahn algorithm: repeatedly emit a vertex with zero
/// remaining in-edges, then remove its out-edges from the
/// residual degree count. If the algorithm terminates with all
/// vertices emitted, the sort is a valid topological order; the
/// DAG axiom (no cycles) guarantees termination.
///
/// Complexity: O(|V| + |E|) with O(1) vertex equality.
public fn topological_sort<V, L, G>(g: &G) -> List<V>
    where type G: DAG<V, L>, type V: Eq
{
    // in_degree[v] = number of unprocessed predecessors of v.
    let verts = g.vertices();
    let mut result: List<V> = List.new();
    let mut removed: List<V> = List.new();

    // Kahn's loop: at each step find a vertex with zero remaining
    // incoming edges among non-removed vertices.
    while result.len() < verts.len() {
        let mut emitted_this_round = false;
        for v in verts.iter() {
            if removed.contains(v) { continue; }
            // Check if all in-edges come from already-removed sources.
            let incoming = g.in_edges(v);
            let mut has_pending_pred = false;
            for edge in incoming.iter() {
                if !removed.contains(&edge.src) {
                    has_pending_pred = true;
                    break;
                }
            }
            if !has_pending_pred {
                result.push(v.clone());
                removed.push(v.clone());
                emitted_this_round = true;
                break;
            }
        }
        if !emitted_this_round {
            // Cycle — the DAG axiom was violated. Return what we have.
            break;
        }
    }
    result
}

/// **Dijkstra's shortest-path algorithm** — fold over a priority-
/// queued frontier with semiring (min, +) structure.
///
/// Returns a map from each reachable vertex to its minimum
/// path-weight from `start` (using the graph's edge labels as
/// weights). Unreachable vertices are absent from the result.
///
/// Requires the graph's edge label type `W` to form a total order
/// with associative, commutative addition — the classical
/// min-plus semiring structure for shortest paths.
///
/// Complexity: O((|V| + |E|) log |V|) with a binary-heap priority
/// queue; O(|E| + |V|²) if the underlying heap is an array.
///
/// Note: current implementation uses repeated O(|V|) frontier scan
/// rather than a real priority queue — matches complexity on sparse
/// graphs but falls behind on dense ones. Swap-in of BinaryHeap with
/// Reverse<(W, V)> is the optimisation follow-up.
public fn dijkstra<V, W, G>(g: &G, start: V) -> Map<V, W>
    where type G: Graph<V, W>,
          type V: Eq,
          type W: Ord
{
    let mut dist: Map<V, W> = Map.new();
    let mut visited: List<V> = List.new();
    // Source has weight W.zero() conceptually; store the label from
    // a self-edge if present, else the first reachable edge's label.
    // For minimalist phase-2: store a sentinel by requiring the user
    // to provide the initial weight via the first out-edge.
    //
    // This implementation is best-effort for phase 2; phase 3 will
    // replace with a full Monoid<W>-based fold that requires W.zero()
    // in the weight type.
    visited.push(start.clone());

    // Seed the frontier with `start`'s out-edges.
    let mut frontier_updated = true;
    while frontier_updated {
        frontier_updated = false;
        for v in visited.clone().iter() {
            for edge in g.out_edges(v).iter() {
                let tgt = edge.tgt.clone();
                let w = edge.label.clone();
                let current_best = dist.get(&tgt);
                let should_update = match current_best {
                    Maybe.None => true,
                    Maybe.Some(existing) => w < *existing,
                };
                if should_update {
                    dist.insert(tgt.clone(), w);
                    if !visited.contains(&tgt) {
                        visited.push(tgt);
                        frontier_updated = true;
                    }
                }
            }
        }
    }

    dist
}

