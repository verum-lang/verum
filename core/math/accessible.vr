// =============================================================================
// accessible.vr вЂ” Accessible Categories (AdГЎmekвЂ“RosickГЅ theory)
// =============================================================================
// Layer: Foundations (Mathematical Structures)
// Spec: J. AdГЎmek + J. RosickГЅ, "Locally Presentable and Accessible
//       Categories", London Math. Soc. Lecture Notes 189, CUP 1994.
// Spec: J. Lurie, "Higher Topos Theory" В§5.4 (presentable в€ћ-categories).
//
// **Foundational module вЂ” M-INFRA Phase 2.**
//
// The MSFS verification chain transitively cites "S_S^global is
// Оє_1-accessible" at multiple sites (paper В§3.3 вЂ” Definition 3.3
// closure + (R5a) accessibility; В§6 Theorem 6.1 вЂ” colimit construction
// inheriting Оє_1-accessibility from the diagram by AdГЎmekвЂ“RosickГЅ
// 1.26). Pre-this-module, accessibility was admitted via paper-citation
// axioms with no underlying type-level surface; this module surfaces
// the structural content.
//
// Architecture:
//
//   вЂў RegularCardinal вЂ” opaque carrier for the regular cardinal Оє
//     parameter. Concrete instances П‰, Оє_1, Оє_2 admit-axioms ship in
//     `core.math.cardinals` (TODO follow-up); for now the protocol
//     captures the identity-only surface.
//   вЂў LambdaFiltered<Оє> вЂ” the "О»-filtered diagram" predicate; the
//     building block for AdГЎmekвЂ“RosickГЅ's accessibility framework.
//   вЂў LambdaPresentable<C, О»> вЂ” an object `x : C` is О»-presentable
//     when Hom(x, -) preserves О»-filtered colimits.
//   вЂў AccessibleCategory<Оє> вЂ” a category C is Оє-accessible iff
//     (i) it has all Оє-filtered colimits, (ii) it has a small dense
//     subcategory of Оє-presentable objects.
//   вЂў Accessibleв€ћCategory вЂ” the в€ћ-categorical lift (Lurie HTT 5.4).
//
// The module is protocol-only at this layer (M-INFRA Phase 2); Phase 3
// will land concrete instances (Set is П‰-accessible, Cat is П‰-accessible,
// the Оє_1-accessible witness for S_S^global from MSFS В§3.3).
// =============================================================================

module core.math.accessible;

mount core.math.category.{Category};
mount core.math.infinity_category.{InfinityCategory};

// =============================================================================
// 1. Regular cardinals
// =============================================================================

/// A **regular cardinal** is an infinite cardinal `Оє` such that every
/// `Оє`-small union of `Оє`-small sets is `Оє`-small. The standard
/// inhabited examples used throughout MSFS are:
///
///   - `П‰` вЂ” the first infinite cardinal (countable). Used for "П‰-
///     filtered" diagrams в‰Ў "filtered" diagrams in the classical sense.
///   - `Оє_1` вЂ” the first inaccessible cardinal of MSFS Convention 1.1
///     (Grothendieck universe `U_1`).
///   - `Оє_2` вЂ” the second inaccessible (Grothendieck universe `U_2`).
///
/// The protocol exposes the regularity property as an opaque
/// witness вЂ” concrete cardinal arithmetic lives in
/// `core.math.cardinals` (forthcoming).
public type RegularCardinal is protocol {
    /// Witness that this cardinal is regular: every smaller-than-Оє
    /// union of smaller-than-Оє sets stays smaller than Оє.
    fn is_regular(&self) -> Bool;

    /// The underlying ordinal rank вЂ” used for the lex ordering when
    /// comparing filteredness levels (Оє-filtered вџ№ О»-filtered for Оє в‰Ґ О»).
    fn ordinal_rank(&self) -> Int;
};

// =============================================================================
// 2. О»-filtered diagrams
// =============================================================================

/// A small category `J` is **О»-filtered** (for a regular cardinal О»)
/// when every diagram `D : I в†’ J` of size `< О»` admits a cocone in
/// `J`. The standard О» = П‰ case recovers the classical "filtered"
/// notion: every finite diagram extends to a cocone.
///
/// AdГЎmekвЂ“RosickГЅ 1.4 gives the equivalent characterisation: J is
/// О»-filtered iff it is non-empty AND every parallel-pair fork of
/// size `< О»` admits a coequaliser cocone.
///
/// **Why this matters for MSFS.** MSFS Definition 3.3 closure O3
/// (small limits and colimits) lands the closure inside `S_S^global`
/// at strictly greater depth; the AdГЎmekвЂ“RosickГЅ invariant is that
/// Оє_1-accessibility is preserved by Оє_1-filtered colimits but NOT
/// by arbitrary colimits. The witness exposed here distinguishes the
/// two cases at the type level.
public type LambdaFilteredDiagram<J, lambda: RegularCardinal> is protocol {
    /// Witness that the indexing category J is О»-filtered.
    fn is_lambda_filtered(&self) -> Bool;

    /// Witness that the diagram is small relative to О» вЂ” i.e.
    /// |Ob(J)| < О» AND |Mor(J)| < О». Smallness is required by the
    /// AR theorem to prevent set-theoretic blow-up.
    fn is_lambda_small(&self) -> Bool;
};

/// **AdГЎmekвЂ“RosickГЅ 1.4 (b)** вЂ” О»-filtered в‡’ Ој-filtered for Ој в‰¤ О».
/// The filteredness levels form a descending chain.
@framework(adamek_rosicky, "AR 1.4 (b) вЂ” О»-filtered в‡’ Ој-filtered for Ој в‰¤ О»")
public axiom lambda_filtered_descends<J, lambda: RegularCardinal, mu: RegularCardinal>(
    diagram: &LambdaFilteredDiagram<J, lambda>,
    mu_param: &mu,
) -> Bool
    requires mu_param.ordinal_rank() <= lambda.ordinal_rank()
    ensures  diagram.is_lambda_filtered();

// =============================================================================
// 3. О»-presentable objects
// =============================================================================

/// An object `x : C` is **О»-presentable** in `C` when the
/// representable functor `Hom_C(x, -) : C в†’ Set` preserves
/// О»-filtered colimits. Equivalently: every morphism `x в†’ colim D`
/// from a О»-filtered diagram `D` factors through some `D(j)` for
/// `j в€€ J`, and the factorisation is essentially unique.
///
/// **Examples (paper-cited).** In the category of sets, a set `X` is
/// П‰-presentable iff `|X| < П‰` (finite). In the category of groups,
/// a group is П‰-presentable iff it is finitely presented in the
/// classical sense. This generalises: О»-presentable в‰… "definable by
/// fewer than О» generators and relations" in the appropriate sense.
public type LambdaPresentable<C: Category, lambda: RegularCardinal> is protocol {
    /// The object x : C exposed as an opaque integer handle (the
    /// concrete object lives in C's surface).
    fn underlying_object(&self) -> Int;

    /// Witness that Hom(x, -) preserves О»-filtered colimits.
    fn preserves_lambda_filtered_colimits(&self) -> Bool;
};

/// **AdГЎmekвЂ“RosickГЅ 1.16** вЂ” every О»-presentable object is
/// Ој-presentable for Ој в‰Ґ О». Presentability levels form an ascending
/// chain (dual to the filteredness chain).
@framework(adamek_rosicky, "AR 1.16 вЂ” О»-presentable в‡’ Ој-presentable for Ој в‰Ґ О»")
public axiom lambda_presentable_ascends<C: Category, lambda: RegularCardinal, mu: RegularCardinal>(
    obj: &LambdaPresentable<C, lambda>,
    mu_param: &mu,
) -> Bool
    requires mu_param.ordinal_rank() >= lambda.ordinal_rank()
    ensures  obj.preserves_lambda_filtered_colimits();

// =============================================================================
// 4. Accessible categories
// =============================================================================

/// A category `C` is **Оє-accessible** (for a regular cardinal Оє) iff:
///
///   (i)  C has all Оє-filtered colimits.
///   (ii) C has a small dense subcategory `C_Оє вЉ† C` whose objects are
///        all Оє-presentable, in the sense that every object of C is
///        a Оє-filtered colimit of objects in `C_Оє`.
///
/// **AdГЎmekвЂ“RosickГЅ 1.26** is the key structural result: Оє-accessible
/// categories are closed under Оє-filtered colimits, accessible
/// reindexing, and accessible localisation. This is the load-bearing
/// invariant for MSFS Lemma 3.4 вЂ” `S_S^global` inherits its
/// Оє_1-accessibility from the closure operations of Definition 3.3.
public type AccessibleCategory<kappa: RegularCardinal> is protocol extends Category {
    /// Witness that C has all Оє-filtered colimits.
    fn has_kappa_filtered_colimits(&self) -> Bool;

    /// Witness that C has a small dense subcategory of
    /// Оє-presentable objects.
    fn has_kappa_presentable_dense_subcategory(&self) -> Bool;

    /// Cardinality bound: |Ob(C_Оє) / iso| < Оє. (AR Theorem 1.20 вЂ” the
    /// dense subcategory of Оє-presentable objects is essentially
    /// small; this method exposes the smallness explicitly so the
    /// kernel can re-check it during accessible-localisation
    /// reasoning.)
    fn dense_subcat_essentially_small(&self) -> Bool;
};

/// **AdГЎmekвЂ“RosickГЅ 1.26** вЂ” Оє-accessible categories are closed
/// under Оє-filtered colimits in the larger category they sit inside.
/// This is the technical lemma that makes MSFS Theorem 6.1's ОІ-part
/// argument work: the colimit of an S_S^global-valued tower stays
/// in S_S^global at appropriately bumped depth.
@framework(adamek_rosicky, "AR 1.26 вЂ” Оє-accessible cats closed under Оє-filtered colimits")
public axiom accessible_closed_under_kappa_filtered_colimits<kappa: RegularCardinal>(
    cat: &AccessibleCategory<kappa>,
) -> Bool
    requires cat.has_kappa_filtered_colimits()
    ensures  cat.has_kappa_filtered_colimits()
          && cat.has_kappa_presentable_dense_subcategory();

/// **AdГЎmekвЂ“RosickГЅ 2.45** вЂ” every accessible category is the
/// 2-category of models of an accessible 2-theory (LairвЂ“MakkaiвЂ“ParГ©
/// representation). Used at MSFS Definition 3.3 to characterise
/// the closure operations O1вЂ“O6 as accessible-functor compositions.
@framework(lair_makkai_pare, "Lair-MP 2.45 вЂ” accessible cats в‰ѓ 2-models of accessible 2-theory")
public axiom accessible_eq_models_of_accessible_theory<kappa: RegularCardinal>(
    cat: &AccessibleCategory<kappa>,
) -> Bool
    requires cat.has_kappa_presentable_dense_subcategory()
    ensures  cat.has_kappa_filtered_colimits();

// =============================================================================
// 5. Accessible в€ћ-categories (Lurie HTT 5.4)
// =============================================================================

/// **Accessible в€ћ-category** вЂ” the homotopy-coherent generalisation
/// of AccessibleCategory. An в€ћ-category C is Оє-accessible iff it has
/// all Оє-filtered в€ћ-colimits AND a small dense full subcategory of
/// Оє-compact objects (the в€ћ-categorical analogue of Оє-presentable).
///
/// Per Lurie HTT 5.4.2.1, every presentable в€ћ-category is accessible
/// (the converse uses the additional cocompleteness assumption). The
/// MSFS Convention 1.1 setup with `U_1 вЉ‚ U_2` Grothendieck universes
/// is precisely the Оє_1-accessible / Оє_2-accessible split; see the
/// `KappaAccessibleInfCategory` alias below for the accessor used by
/// `core.math.syn_mod.GrothendieckOverMod::is_kappa_S_accessible()`.
public type AccessibleInfCategory<kappa: RegularCardinal> is protocol extends InfinityCategory {
    /// Witness that C has all Оє-filtered в€ћ-colimits.
    fn has_kappa_filtered_infinity_colimits(&self) -> Bool;

    /// Witness that C has a small dense full sub-в€ћ-category of
    /// Оє-compact objects.
    fn has_kappa_compact_dense_subcategory(&self) -> Bool;
};

/// Convenience alias used by syn_mod.vr's
/// `GrothendieckOverMod::is_kappa_S_accessible` вЂ” the accessibility
/// view at the (в€ћ, n)-level. n_F is the categorical depth from the
/// underlying Rich-S Lambek-Scott data.
public type KappaAccessibleInfCategory<kappa: RegularCardinal> is protocol
    extends AccessibleInfCategory<kappa> {
    /// The intrinsic categorical depth n_F at which the accessibility
    /// witness lives (1 for first-order Rich-S, в€ћ for HoTT etc.).
    fn n_F(&self) -> Int;
};

/// **Lurie HTT 5.4.2.1** вЂ” every presentable в€ћ-category is
/// Оє-accessible for some regular Оє. This is the structural anchor
/// the MSFS В§6 transfinite-tower argument relies on: the colimit of
/// the tower lands in some `(в€ћ, n_F)`-accessible category at depth
/// в‰Ґ 1, witnessing the inheritance from the diagram per AR 1.26.
@framework(lurie_htt, "HTT 5.4.2.1 вЂ” presentable в€ћ-cat в‡’ Оє-accessible for some regular Оє")
public axiom presentable_implies_accessible<C, kappa: RegularCardinal>(
    cat: &AccessibleInfCategory<kappa>,
) -> Bool
    requires cat.has_kappa_filtered_infinity_colimits()
    ensures  cat.has_kappa_filtered_infinity_colimits()
          && cat.has_kappa_compact_dense_subcategory();

// =============================================================================
// 6. Bridge: AccessibleInfCategory в†’ S_S^global membership
// =============================================================================

/// Bridge axiom: any object of a Оє-accessible (в€ћ, n)-category at
/// depth в‰Ґ 1 produces an `SSMembership` witness in `S_S^global` at
/// the same depth. This is the kernel-side surface for MSFS
/// Definition 3.3 closure O2's "Grothendieck-construction lands in
/// `S_S^global`" claim вЂ” the underlying construction is built on
/// (в€ћ, n)-categorical accessibility, not on the bare paper citation.
///
/// **Why this matters.** Pre-this-module the bridge from "Lurie HTT
/// 5.1.4 Grothendieck construction" to "S_S^global at depth в‰Ґ 1"
/// was a single witness axiom (`msfs_definition_3_3_o2_lands_in_global`)
/// that took the GrothendieckOverMod witness on faith. With the
/// accessibility surface in place, downstream consumers can demand
/// the underlying KappaAccessibleInfCategory witness and re-check
/// the depth-bound contract through THIS axiom plus the AR 1.26
/// closure law вЂ” two structural axioms instead of one paper-citation
/// black box.
@framework(msfs, "MSFS В§3.3 bridge вЂ” KappaAccessibleInfCategory at depth в‰Ґ 1 в†’ S_S^global membership")
public axiom kappa_accessible_lands_in_s_s_global<kappa: RegularCardinal>(
    cat: &KappaAccessibleInfCategory<kappa>,
) -> Bool
    requires cat.has_kappa_filtered_infinity_colimits()
          && cat.has_kappa_compact_dense_subcategory()
          && cat.n_F() >= -1
    ensures  cat.has_kappa_filtered_infinity_colimits()
          && cat.has_kappa_compact_dense_subcategory();
