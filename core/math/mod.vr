// =============================================================================
// mod.vr - Verum Scientific Computing Module
// =============================================================================
// Layer: 0-9 (Mathematical Computing Stack)
//
// This module provides production-ready scientific computing organized into
// hierarchical layers (L0-L9), from bare-metal IEEE 754 operations to
// distributed tensor computations.
//
// # Architecture
//
// ```
// Layer 9: Agent       - LLM integration, inference optimization, agents
// Layer 8: Distributed - Multi-node distributed compute, FSDP, DDP
// Layer 8: SSM         - State Space Models, Mamba, MoE
// Layer 7: Neural Nets - Layers, optimizers, training
// Layer 6: Autodiff    - Automatic differentiation, VJP/JVP
// Layer 5: GPU         - Accelerator compute, device abstraction
// Layer 4: Tensor      - N-dimensional arrays, static/dynamic shape
// Layer 3: Analysis    - Numerical analysis, ODEs, calculus, random
// Layer 2: Linear      - Linear algebra, BLAS operations
// Layer 1: Scalar      - Elementary & special functions
// Layer 0: Foundation  - IEEE 754, integers, bits, SIMD (→ core/simd, core/intrinsics)
// ```
//
// # Usage
//
// ```verum
// mount core.math.*;           // Full math library
// mount core.math.simple.*;    // Simple API for prototyping
// mount core.math.linalg.*;    // Linear algebra only
// ```
//
// # Refinement Types
//
// The math library uses refinement types to provide compile-time verification
// of mathematical preconditions and postconditions:
//
// ```verum
// fn sqrt(x: Float{>= 0.0}) -> Float{>= 0.0}
// fn log(x: Float{> 0.0}) -> Float
// fn asin(x: Float{it >= -1.0 && it <= 1.0}) -> Float
// ```
//
// # Context System
//
// Mathematical operations use Verum's context system for cross-cutting concerns:
// - Random: Pseudorandom number generation
// - ComputeDevice: Device selection (CPU, GPU)
// - PrecisionMode: Numerical precision control
// - GradientTape: Autodiff recording
//
// Spec: docs/architecture/math-spec.md
// =============================================================================

module core.math;

// =============================================================================
// Submodule declarations (Layered Architecture)
// =============================================================================

// Layer 0: Foundation (primitives, IEEE 754, bits)
// Note: SIMD types are in core/simd, intrinsics in core/intrinsics
public module ieee754;      // IEEE 754 floating-point utilities
public module integers;     // Integer operations and division modes
public module bits;         // Bit manipulation operations
public module checked;      // Overflow-checked arithmetic
public module libm;         // Software math library (pure Verum, replaces libc libm)

// Layer 1: Scalar Mathematics
public module constants;    // Mathematical constants (PI, E, etc.)
public module elementary;   // sin, cos, exp, log, pow, sqrt, etc.
public module special;      // gamma, erf, bessel, etc.
public module hyperbolic;   // sinh, cosh, tanh, asinh, acosh, atanh

// Layer 2: Linear Algebra
public module linalg;       // Vectors, matrices, BLAS

// Layer 3: Numerical Analysis
public module calculus;     // Integration, differentiation, ODEs

// Layer 3 (continued): Random Numbers
public module random;       // PRNG, distributions

// Layer 4: Tensor System
public module tensor;       // N-dimensional arrays, static/dynamic shape

// Layer 5: GPU/Accelerator
public module gpu;          // Device abstraction, kernels, memory, streams

// Layer 6: Automatic Differentiation
public module autodiff;     // VJP/JVP, gradients, checkpointing

// Layer 7: Neural Networks
public module nn;           // Layers, optimizers, training utilities

// Layer 8: State Space Models
public module ssm;          // S4, Mamba, BiMamba, Jamba, MoE

// Layer 8: Distributed Training
public module distributed;  // DDP, FSDP, tensor/pipeline parallelism, actor mesh

// Layer 9: Agent Systems
public module agent;        // LLM integration, tokenization, KV cache, inference, agents
public module guardrails;   // Content filtering, safety constraints, PII redaction
public module rag;          // Retrieval-Augmented Generation, vector stores, chunking

// =============================================================================
// Mathematical Foundations (Pure Mathematics)
// =============================================================================

// Abstract algebra: groups, rings, fields, lattices, Boolean algebras
public module algebra;

// Category theory: categories, functors, natural transformations,
// adjunctions, monads, limits, colimits, toposes, sheaves, Kan extensions
public module category;

// Point-set and algebraic topology: spaces, continuity, compactness,
// manifolds, fundamental group, homology
public module topology;

// Real and functional analysis: sequences, limits, continuity,
// differentiability, measure theory, Banach/Hilbert spaces
public module analysis;

// Formal logic: propositions-as-types, proof terms, connectives,
// quantifiers, decidability, classical vs constructive logic
public module logic;

// Homotopy Type Theory (cubical): Path types, transport, hcomp,
// equivalences, truncation levels, fibres, univalence (computational),
// function extensionality, HITs (S¹, Susp, Trunc, Quotient, Pushout).
// Full cubical model with 8 reduction rules.
public module hott;

// Cubical primitives: interval operations (rev, meet, join), face lattice,
// Glue types, connection operations, comp (heterogeneous composition).
// Extends hott.vr with the full cubical surface.
public module cubical;

// Simplicial sets and Kan complexes: Simplex, SimplicialSet, Horn,
// KanComplex, InfinityGroupoid, Nerve. Combinatorial substrate for
// ∞-categories and ∞-topoi.
public module simplicial;

// ∞-categories in the Joyal quasi-category model: QuasiCategory,
// InfinityCategory, InfinityFunctor, MappingSpace, HomotopyCategory,
// OppositeInfCategory, FunctorInfCategory, InfTerminal/InfInitial.
public module infinity_category;

// ∞-topoi: Sieve, GrothendieckTopology, Site, InfPresheaf, InfSheaf,
// InfinityTopos, SheafInfinityTopos, InfSubobjectClassifier,
// GeometricMorphism. The centerpiece of Phase C — built on top of
// infinity_category, simplicial, category, and hott.
public module infinity_topos;

// Grothendieck fibrations: CartesianMorphism, GrothendieckFibration,
// Opfibration, Bifibration, Fibre, StraighteningEquivalence,
// BaseChange, LeftFibration, RightFibration.
public module fibration;

// ∞-categorical Kan extensions: InfLeftKanExtension,
// InfRightKanExtension, KanExtensionTriple, PointwiseKanExtension,
// KanPreservingFunctor. Companion to the 1-categorical Kan
// extensions in category.vr.
public module kan_extension;

// Quillen model categories: WeakEquivalenceClass, CofibrationClass,
// FibrationClass, QuillenModelStructure, Trivial{Co}Fibration,
// {Co}FibrantObject, ModelHomotopyCategory, Quillen{Adjunction,
// Equivalence}, HomotopyEquivalentAsInfCat.
public module model_category;

// Operads, multicategories, algebras over operads, E_n operads,
// ∞-operads. Controls algebraic operations of all arities with
// coherent composition — from ordinary monoids to E_∞-rings.
public module operad;

// Reference implementations of Phase B/C protocols:
// TerminalOperad, IntegerPathCategory, DiscreteSimplicialSet,
// WalkingArrow. Concrete, usable starter kits with proven
// correctness theorems. Doubles as documentation-by-example.
public module examples;

// Number theory: Peano naturals, primes, divisibility, modular arithmetic,
// GCD/LCM, Euler/Fermat/FTA theorem statements
public module number_theory;

// =============================================================================
// Mathesis Foundation (Phase C — verum-ext-2.md §3)
// =============================================================================

// Quantum epistemic logic: Birkhoff–von Neumann orthomodular lattice,
// Hilbert space epistemic states, density matrices, quantum measurement
// (Lüders rule), commutator, compatibility, fidelity. 7-level UHM
// status system with superposition.
public module quantum_logic;

// Giry monad: probability measures on measurable spaces, Dirac delta,
// Markov kernel (marginalization), LLM oracle for stochastic functor
// proposals, sampling with confidence threshold.
public module giry;

// Formal epistemology: EpistemicStatus (7 variants), Theory type,
// EpistemicTopology (Grothendieck with joint faithfulness), theory site,
// Mathesis ∞-topos, BFS status propagation, Kan extension algorithms,
// obstruction computation.
public module epistemic;

// Cohesive modalities (Schreiber 2013): CohesiveStructure with the
// quadruple adjunction Π ⊣ Disc ⊣ Γ ⊣ coDisc, shape/flat/sharp
// modalities. DifferentiallyCohesive adds Im ⊣ & ⊣ Rh for
// infinitesimal structure.
public module cohesive;

// Day convolution on presheaf categories of symmetric monoidal
// categories. Coend formula, cognitive extension H_ext = H_bio ⊗_Day H_M
// for Mathesis integration.
public module day_convolution;

// Tactic library: category law simplification, descent checking,
// algebraic manipulation tactics callable from proof blocks.
public module tactics;

// Complex numbers and arithmetic.
public module complex;

// Finite categories for concrete computations.
public module category_finite;

// Synthetic Differential Geometry: infinitesimal objects (D, D(n)),
// Kock-Lawvere axiom, tangent/jet bundles, differential forms,
// de Rham complex, connections, curvature. Integration with cohesive
// modalities (Im ⊣ & ⊣ Rh).
public module sdg;

// Observational Type Theory: type-directed equality alternative to
// cubical. Equality defined by observation (products decompose,
// functions use funext, decidable types decide directly).
public module observational;

// Bit vectors for verified hardware and cryptography.
public module bitvec;

// =============================================================================
// Progressive API Disclosure
// =============================================================================

// Level 1: Simple API - high-level, convenience-focused, no generics required
public module simple;

// Level 3: Advanced API - fine-grained control, explicit tiling, custom kernels
public module advanced;

// Level 4: Internal API - library internals, requires @allow(internal_api)
// Note: Do not import directly unless developing low-level extensions
@internal
public module internal;

