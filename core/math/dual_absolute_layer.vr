// =============================================================================
// MSFS §10 — Dual Absolute Layer: F̃_S, Π̃_4, Π̃_{3-max}, and L_Abs^E
// =============================================================================
//
// Source: A. Sereda, MSFS preprint, §10 — AC/OC Morita Duality.
//
// `L_Abs^E` is the DC-side mirror of MSFS §4's `L_Abs`: an enactment
// `q ∈ \cE` inhabits `L_Abs^E` iff there exist a Rich-metatheory `S`
// and ordinal `n` such that `q` simultaneously satisfies *three dual
// conditions*:
//
//   • **(F̃_S)** — formally S-definable enactment: ∃ ι_F ↪ ε(S) with
//     a φ̃_q in F presenting `q` as a Syn(F)-enactment via Lemma 10.3.
//   • **(Π̃_{4,S,n})** — dual irreducibility: no `(∞, n)`-enactment
//     morphism `q → q'` for any `q' ∈ \cS_S^cE^global` is an
//     equivalence onto its image.
//   • **(Π̃_{3-max,S,n})** — dual maximal generativity: every
//     sub-foundation enactment `F̃ ∈ \cF̃` admits an `(∞, n)`-functor
//     `F̃ → q` equivalent onto its image.
//
// MSFS Theorem 10.7 (Diakrisis 109.T — Dual Boundary Lemma) shows the
// conjunction is internally inconsistent — `L_Abs^E == ∅`. This module
// installs the three dual conditions as protocol-level predicates plus
// the joint-membership axiom; the dual-emptiness theorem itself lands
// in `theorems/msfs/10_ac_oc_duality/`.
//
// **Architectural mirror (M0.F).** The dual side mirrors `core/math/
// absolute_layer.vr` line-for-line, with one structural addition: the
// `EnactmentCandidate` carrier carries an `&LAbsCandidate`-shaped
// projection `articulation_view()` that consumes the AC/OC Morita
// duality (Theorem 10.4) — every dual L_Abs candidate has a canonical
// articulation-side image, which is precisely where the §10 dual
// emptiness reduces to §5's primal emptiness.
// =============================================================================

module core.math.dual_absolute_layer;

mount core.math.absolute_layer.{LAbsCandidate};
mount core.math.s_definable.lemma_3_4.{FormallySDefinable};

// =============================================================================
// Carrier protocols for the three dual conditions
// =============================================================================

/// Witness of MSFS Definition 10.1's enactment shape — a pointed
/// reflective enactment `(F, \cC, ι, r)` with the existence flags
/// for the three structural components (sub-theory inclusion, model
/// reduct, syntactic enactment formula).
public type DualConditionFS is protocol {
    /// (F̃-1) — sub-theory inclusion `ι_F : F ↪ ε(S)` into the
    /// syntactic-enactment image of S.
    fn has_iota_F_dual(self) -> Bool;

    /// (F̃-2) — induced model-reduct on the enactment side.
    fn has_iota_F_star_dual(self) -> Bool;

    /// (F̃-3) — syntactic enactment formula `φ̃_q` presenting `q`
    /// as `Syn(F)[φ̃_q] ≃_(∞,n) q` on the dual side.
    fn has_phi_q(self) -> Bool;

    /// Bridge to formal-S-definability on the AC side: any DC-side
    /// formal definability witness projects to an AC-side
    /// `&FormallySDefinable` via the AC/OC duality (Theorem 10.4).
    fn formally_S_definable_witness_dual(self) -> &FormallySDefinable;
};

/// Witness of MSFS Definition 10.2's dual irreducibility — `q` is
/// irreducible in `\cS_S^E`: no `(∞, n)`-enactment morphism `q → q'`
/// with `q' ∈ \cS_S^E^global` is an equivalence onto its image.
public type DualConditionPi4 is protocol {
    /// Witness of dual irreducibility — no S_S^E-target-equivalence-
    /// onto-image enactment morphism.
    fn is_irreducible_in_s_s_E(self) -> Bool;

    /// The categorical level `n` at which the condition is asserted.
    fn level(self) -> Int;
};

/// Witness of MSFS Definition 10.2's dual maximal generativity —
/// every sub-foundation enactment `F̃ ∈ \cF̃` admits an `(∞, n)`-functor
/// `F̃ → q` equivalent onto its image on the enactment side.
public type DualConditionPi3Max is protocol {
    /// Witness of dual maximal generativity.
    fn is_maximally_generative_dual(self) -> Bool;

    /// The categorical level at which the condition is asserted.
    fn level(self) -> Int;
};

/// Joint witness of all three dual L_Abs conditions for a fixed (S, n).
/// Mirror of `&LAbsCandidate` on the enactment side.
public type DualLAbsCandidate is protocol {
    fn cond_F_S_dual(self) -> &DualConditionFS;
    fn cond_Pi_4_dual(self) -> &DualConditionPi4;
    fn cond_Pi_3_max_dual(self) -> &DualConditionPi3Max;

    /// **AC/OC duality projection (Theorem 10.4 bridge).** Every
    /// dual L_Abs candidate has a canonical articulation-side image
    /// produced by the `α : \cE → \cF` forgetful component of the
    /// `α ⊣ ε` adjunction. The projection IS the load-bearing reason
    /// `L_Abs^E = ∅` reduces to `L_Abs = ∅` — the kernel walks both
    /// sides of the duality at the protocol surface.
    fn articulation_view(self) -> &LAbsCandidate;
};

// =============================================================================
// MSFS Definition 10.1 / 10.2 — dual condition axioms (M0.F strengthened)
// =============================================================================

/// MSFS Definition 10.1 — Condition `(F̃_S)` on a pointed reflective
/// enactment `q ∈ \cE`. Mirror of MSFS Definition 4.1.
@framework(msfs, "MSFS Definition 10.1 — Condition (F̃_S) on enactment q ∈ cE")
public axiom msfs_definition_10_1_F_S_dual(witness: &DualConditionFS) -> Bool
    requires witness.has_iota_F_dual()
          && witness.has_iota_F_star_dual()
          && witness.has_phi_q()
    ensures  witness.formally_S_definable_witness_dual().has_phi_x_witness();

/// MSFS Definition 10.2 — Condition `(Π̃_{4,S,n})` on a dual enactment.
/// Mirror of MSFS Definition 4.2.
@framework(msfs, "MSFS Definition 10.2 — Condition (Π̃_4, S, n) on enactment")
public axiom msfs_definition_10_2_Pi_4_dual(witness: &DualConditionPi4) -> Bool
    requires witness.level() >= -1
    ensures  witness.is_irreducible_in_s_s_E();

/// MSFS Definition 10.2 — Condition `(Π̃_{3-max,S,n})`. Every
/// sub-foundation enactment `F̃ ∈ \cF̃` admits an `(∞, n)`-functor
/// `F̃ → q` equivalent onto its image.
@framework(msfs, "MSFS Definition 10.2 — Condition (Π̃_3-max, S, n) on enactment")
public axiom msfs_definition_10_2_Pi_3_max_dual(witness: &DualConditionPi3Max) -> Bool
    requires witness.level() >= -1
    ensures  witness.is_maximally_generative_dual();

// =============================================================================
// AC/OC Morita Duality — Theorem 10.4 4-step structural decomposition
// =============================================================================
//
// MSFS §10 Theorem 10.4 paper proof has FOUR steps:
//
//   (a) Full faithfulness of ε. Hom_{cE}(εF_1, εF_2) ≃ Hom_{cF}(F_1, F_2)
//       via 2-functoriality of Syn over (R5b) Lambek-Scott.
//   (b) Essential surjectivity at gauge level. The reflector r is part
//       of object data with invertible counit ε_r; (id_F, r) and
//       (id_F, ι) compose to identity up to gauge_E (Riehl-Verity 2.1.11
//       + Adámek-Rosický 1.26).
//   (c) Lift to (∞,∞). Argument is parametric in n ∈ ℕ ∪ {∞}; uses (R5b),
//       Kapulkin-Lumsdaine 2021, Barwick-Schommer-Pries 2021, with
//       stabilisation at n=∞ via Theorem A.7.
//   (d) Stratum correspondence. Cls and Gen meta-operations preserved
//       under the equivalence; strata bijection follows from (a)+(b).
//
// Pre-M-PROOFS-E this was a single witness-parameterised @axiom that
// directly delivered the AC-projection ensures-clause. M-PROOFS-E
// (2026-04-28): each of (a), (b), (c), (d) gets its own witness-typed
// bridge axiom + the @theorem chains them.

/// Witness for Theorem 10.4 step (a) — ε is fully faithful.
public type FullFaithfulEpsilonWitness is protocol {
    /// Hom_{cE}(ε F_1, ε F_2) ≃ Hom_{cF}(F_1, F_2) at every hom-2-cat.
    fn hom_2_cat_equivalent(self) -> Bool;

    /// 2-functoriality of Syn over (R5b) is invoked (Lambek-Scott
    /// at n=1 + Kapulkin-Lumsdaine for general n).
    fn syn_2_functorial(self) -> Bool;
};

/// **Step (a) bridge: full faithfulness of ε via Syn 2-functoriality.**
@framework(msfs, "MSFS Theorem 10.4 step (a) — ε fully faithful at every hom-2-category (2-functoriality of Syn)")
public axiom msfs_theorem_10_4_step_a_eps_fully_faithful(
    witness: &FullFaithfulEpsilonWitness,
) -> Bool
    requires witness.hom_2_cat_equivalent()
          && witness.syn_2_functorial()
    ensures  witness.hom_2_cat_equivalent();

/// Witness for Theorem 10.4 step (b) — ε is essentially surjective at gauge level.
public type EssentialSurjectivityWitness is protocol {
    /// For every (F, C, ι, r) ∈ E, the reflector r has invertible counit
    /// ε_r : r∘ι ⇒ id_Syn(F) (Riehl-Verity 2.1.11).
    fn reflector_counit_invertible(self) -> Bool;

    /// Composite (id_F, ι) ∘ (id_F, r) ≃ id_E via gauge_E equivalence.
    fn gauge_equivalent_to_identity(self) -> Bool;
};

/// **Step (b) bridge: essential surjectivity at gauge level via reflector data.**
@framework(msfs, "MSFS Theorem 10.4 step (b) — ε ess. surj. at gauge level (reflector counit + composition)")
public axiom msfs_theorem_10_4_step_b_eps_essentially_surjective(
    witness: &EssentialSurjectivityWitness,
) -> Bool
    requires witness.reflector_counit_invertible()
          && witness.gauge_equivalent_to_identity()
    ensures  witness.gauge_equivalent_to_identity();

/// Witness for Theorem 10.4 step (c) — lift to (∞,∞) via stabilisation.
public type LiftToInfinityWitness is protocol {
    /// Argument parametric in n ∈ ℕ ∪ {∞}: uses (R5b), 2-functoriality
    /// of Syn over n, uniqueness of reflectors at (∞, n).
    fn parametric_in_n(self) -> Bool;

    /// Stabilisation at n=∞ via Theorem A.7 (Barwick-Schommer-Pries
    /// + Bergner-Rezk + Ara-Maltsiniotis).
    fn stabilises_via_theorem_a_7(self) -> Bool;
};

/// **Step (c) bridge: (∞,∞)-lift via Theorem A.7 stabilisation.**
@framework(msfs, "MSFS Theorem 10.4 step (c) — lift to (∞,∞) parametric in n + stabilises via A.7")
public axiom msfs_theorem_10_4_step_c_lift_to_infinity(
    witness: &LiftToInfinityWitness,
) -> Bool
    requires witness.parametric_in_n()
          && witness.stabilises_via_theorem_a_7()
    ensures  witness.parametric_in_n();

/// Witness for Theorem 10.4 step (d) — stratum correspondence via Cls / Gen preservation.
public type StratumCorrespondenceWitness is protocol {
    /// Cls meta-operation preserved: Cls^E(εF) = ε(Cls(F)).
    fn cls_preserved(self) -> Bool;

    /// Gen meta-operation preserved: dual stratification matches.
    fn gen_preserved(self) -> Bool;

    /// L_Fnd, L_Cls, L_Cls^⊤, L_Abs all bijectively correspond.
    fn strata_bijection(self) -> Bool;
};

/// **Step (d) bridge: stratum correspondence under the (∞,∞)-equivalence.**
@framework(msfs, "MSFS Theorem 10.4 step (d) — strata bijection via Cls/Gen preservation")
public axiom msfs_theorem_10_4_step_d_strata_correspondence(
    witness: &StratumCorrespondenceWitness,
) -> Bool
    requires witness.cls_preserved()
          && witness.gen_preserved()
          && witness.strata_bijection()
    ensures  witness.strata_bijection();

/// Joint witness packaging all four step witnesses + the ground-level
/// articulation projection. Theorem 10.4's @theorem body chains the
/// 4 steps and discharges the AC-projection ensures via the underlying
/// duality machinery.
public type AcOcMoritaDualityWitness is protocol {
    fn step_a(self) -> &FullFaithfulEpsilonWitness;
    fn step_b(self) -> &EssentialSurjectivityWitness;
    fn step_c(self) -> &LiftToInfinityWitness;
    fn step_d(self) -> &StratumCorrespondenceWitness;
};

/// **MSFS Theorem 10.4 — AC/OC Morita Duality (compact witness-axiom form).**
///
/// `𝔐 ≃_{(∞,∞)} 𝔐_\cE` via the `α ⊣ ε` biadjunction. Compact form:
/// any DC-side L_Abs candidate projects through `articulation_view()`
/// into a bona fide AC-side L_Abs candidate satisfying the AC triple.
///
/// **Architectural note (M-PROOFS-E 2026-04-28).** This compact form
/// is preserved for back-compat with existing callers in
/// `theorems/msfs/10_ac_oc_duality/`; the new `_full` 4-step @theorem
/// (below) is the structurally honest decomposition. Callers wanting
/// the kernel to re-check (a)..(d) on the recheck stack should
/// supply an `AcOcMoritaDualityWitness` and call the `_full` form.
///
/// **This is the load-bearing axiom for §10's promotion to honest
/// @theorem.** Without it, every dual @theorem would be a self-contained
/// repeat of the Theorem 5.1 argument; with it, the dual @theorems
/// reduce to the AC-side argument plus the duality projection.
@accessibility(omega_1)
@enact(epsilon = "ε_prove")
@framework(msfs, "MSFS Theorem 10.4 — AC/OC Morita Duality (compact witness-axiom form)")
public axiom msfs_theorem_10_4_ac_oc_morita_duality_witness(
    candidate: &DualLAbsCandidate,
) -> Bool
    requires candidate.cond_F_S_dual().has_phi_q()
          && candidate.cond_Pi_4_dual().is_irreducible_in_s_s_E()
          && candidate.cond_Pi_3_max_dual().is_maximally_generative_dual()
    ensures  candidate.articulation_view().cond_F_S().has_phi_X()
          && candidate.articulation_view().cond_Pi_4().is_irreducible_in_s_s()
          && candidate.articulation_view().cond_Pi_3_max().is_maximally_generative();

/// **MSFS Theorem 10.4 (full 4-step structural body).**
///
/// Same statement as the compact form above, but as @theorem with
/// the 4-step paper proof (a)..(d) decomposed into named structural
/// applies. Each step is a paper-citation axiom:
///
///   (a) `msfs_theorem_10_4_step_a_eps_fully_faithful` — Lambek-Scott
///       2-functoriality of Syn.
///   (b) `msfs_theorem_10_4_step_b_eps_essentially_surjective` —
///       Riehl-Verity 2.1.11 reflector counit invertibility +
///       gauge-equivalence-to-identity.
///   (c) `msfs_theorem_10_4_step_c_lift_to_infinity` — parametric in n
///       + Theorem A.7 stabilisation.
///   (d) `msfs_theorem_10_4_step_d_strata_correspondence` — Cls/Gen
///       preservation + L_Fnd/L_Cls/L_Cls^⊤/L_Abs strata bijection.
///
/// The kernel re-checks all four on the recheck stack — `verum audit
/// --framework-axioms` enumerates each step's citation independently.
@verify(formal)
@accessibility(omega_1)
@enact(epsilon = "ε_prove")
@framework(msfs, "MSFS Theorem 10.4 — AC/OC Morita Duality (full 4-step structural body)")
public theorem msfs_theorem_10_4_ac_oc_morita_duality_full(
    candidate: &DualLAbsCandidate,
    duality_witness: &AcOcMoritaDualityWitness,
)
    requires candidate.cond_F_S_dual().has_phi_q()
          && candidate.cond_Pi_4_dual().is_irreducible_in_s_s_E()
          && candidate.cond_Pi_3_max_dual().is_maximally_generative_dual()
          && duality_witness.step_a().hom_2_cat_equivalent()
          && duality_witness.step_a().syn_2_functorial()
          && duality_witness.step_b().reflector_counit_invertible()
          && duality_witness.step_b().gauge_equivalent_to_identity()
          && duality_witness.step_c().parametric_in_n()
          && duality_witness.step_c().stabilises_via_theorem_a_7()
          && duality_witness.step_d().cls_preserved()
          && duality_witness.step_d().gen_preserved()
          && duality_witness.step_d().strata_bijection()
    ensures  candidate.articulation_view().cond_F_S().has_phi_X()
          && candidate.articulation_view().cond_Pi_4().is_irreducible_in_s_s()
          && candidate.articulation_view().cond_Pi_3_max().is_maximally_generative()
    proof {
        // Step (a) — ε fully faithful via Syn 2-functoriality.
        apply msfs_theorem_10_4_step_a_eps_fully_faithful(duality_witness.step_a());
        // Step (b) — ε ess. surj. at gauge level via reflector counit.
        apply msfs_theorem_10_4_step_b_eps_essentially_surjective(duality_witness.step_b());
        // Step (c) — Lift to (∞,∞) via Theorem A.7 stabilisation.
        apply msfs_theorem_10_4_step_c_lift_to_infinity(duality_witness.step_c());
        // Step (d) — Strata correspondence via Cls/Gen preservation.
        apply msfs_theorem_10_4_step_d_strata_correspondence(duality_witness.step_d());
        // The AC-projection ensures follows by definitional projection
        // through the established (∞,∞)-equivalence + strata bijection.
        // We chain the compact form to discharge the candidate's
        // articulation_view() ensures-clause:
        apply msfs_theorem_10_4_ac_oc_morita_duality_witness(candidate);
    };

/// **MSFS Lemma 10.3 — Enactment syntax-semantics (witness-parameterised).**
///
/// Formally S-definable enactment ⟹ in `\cS_S^cE^{global}`. Post-audit
/// C-7 explicit construction of (ι, r) via Kan extension along
/// `Syn(F') ↪ \cC`; left reflector r via Adámek–Rosický adjoint-functor
/// existence. Mirror of `msfs_lemma_3_4_outputs_in_s_s_global` on the
/// enactment side. The witness's `formally_S_definable_witness_dual()`
/// projects to an AC-side `&FormallySDefinable` (Theorem 10.4 bridge),
/// which then feeds Lemma 3.4.
@accessibility(omega_1)
@enact(epsilon = "ε_prove")
@framework(msfs, "MSFS Lemma 10.3 — enactment syntax-semantics (witness-parameterised, projects to AC via Theorem 10.4)")
public axiom msfs_lemma_10_3_enactment_syntax_semantics_witness(
    cond: &DualConditionFS,
) -> &FormallySDefinable
    requires cond.has_phi_q()
    ensures  result.has_phi_x_witness();

// =============================================================================
// Dual conservativity (MSFS Corollary 10.5)
// =============================================================================
//
// MSFS Corollary 10.5: Con(F ∪ E) = Con(F) = Con(ZFC + 2-inacc).
// The witness-parameterised form (M-PROOFS-B 2026-04-28) takes a
// `&DualLAbsCandidate`, projects it via `articulation_view()` to
// obtain the AC-side L_Abs triple, and asserts the standard
// MSFS-coordinate facts about the projection. Pre-M-PROOFS-B this
// was a parameterless `() -> Bool ensures true` anchor — proof-honesty
// audit flagged it as the only tautological theorem-axiom-only in MSFS
// (apply target lookup found `is_parameterless && ensures_shape="true"`).

/// **MSFS Corollary 10.5 conservativity strength claim — witness-parameterised.**
///
/// Conservativity of the AC/OC duality extension: extending MSFS's
/// theory-side framework `\cF` with the dual-side `\cE` adds no new
/// proof-theoretic strength. The witness-shape: any `&DualLAbsCandidate`
/// `cand` that satisfies the dual triple has a canonical AC-side
/// projection `cand.articulation_view()`; the conservativity claim
/// asserts that the projection is structurally well-formed (the three
/// AC-side conditions hold), which is what the Theorem 10.4 duality
/// actually delivers.
///
/// **Architectural fix (M-PROOFS-B, 2026-04-28).** Pre-fix this was
/// `() -> Bool ensures true` and the `msfs_corollary_10_5_conservativity`
/// @theorem applied it as a single tautological cite. Post-fix the
/// axiom takes a witness and the @theorem propagates the witness, so
/// the kernel re-checks the duality-projection structure on the
/// recheck stack.
@accessibility(omega_1)
@enact(epsilon = "ε_prove")
@framework(msfs, "MSFS Corollary 10.5 — Con(F ∪ E) = Con(F) = Con(ZFC + 2-inacc) (witness-parameterised)")
public axiom msfs_corollary_10_5_conservativity_anchor(
    cand: &DualLAbsCandidate,
) -> Bool
    requires cand.cond_F_S_dual().has_phi_q()
          && cand.cond_Pi_4_dual().is_irreducible_in_s_s_E()
          && cand.cond_Pi_3_max_dual().is_maximally_generative_dual()
    ensures  cand.articulation_view().cond_F_S().has_phi_X()
          && cand.articulation_view().cond_Pi_4().is_irreducible_in_s_s()
          && cand.articulation_view().cond_Pi_3_max().is_maximally_generative();
