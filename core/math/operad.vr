// =============================================================================
// operad.vr — Operads, Multicategories, Algebras over Operads
// =============================================================================
// Layer: Foundations (Mathematical Structures)
// Spec: May "The Geometry of Iterated Loop Spaces", Leinster
//       "Higher Operads, Higher Categories", Lurie HA §2
//
// An **operad** is a combinatorial gadget encoding abstract algebraic
// operations of multiple arities, together with composition rules
// that say how to substitute operations into each other. The
// classical examples include:
//
//   * the associative operad (one binary operation, satisfying
//     associativity)
//   * the commutative operad (also associative and commutative)
//   * E_∞ operads (up-to-homotopy commutative)
//   * the Little Cubes operads (governing iterated loop spaces)
//
// In the ∞-categorical world, operads generalise to **∞-operads**
// (Lurie HA §2.1), which describe algebra structures up to coherent
// homotopy. This module exposes both the 1-categorical and the
// ∞-categorical flavours as protocols.
//
// See also:
//   - core/math/category.vr           (Monoidal, Symmetric)
//   - core/math/infinity_category.vr  (InfinityCategory)
// =============================================================================

module core.math.operad;

mount core.math.category.{Category, MonoidalCategory};
mount core.math.infinity_category.{InfinityCategory};

// =============================================================================
// 1. Multicategories (coloured operads)
// =============================================================================

/// A **multicategory** has objects and **multi-morphisms** of arity
/// `n` with `n` source objects and one target object. It is the
/// algebraic structure captured by `Hom(c_1, ..., c_n; d)`:
///
///     f : c_1, c_2, ..., c_n -> d
///
/// Composition substitutes a collection of multi-morphisms into the
/// inputs of another multi-morphism, preserving the target. This
/// generalises `Category` to multi-input operations.
public type Multicategory is protocol {
    /// The n-ary composition operation. Substitutes multi-morphisms
    /// `g_1, ..., g_n` into the i-th inputs of a multi-morphism `f`.
    fn compose(f: &Int, gs: List<Int>) -> Int;

    /// The identity multi-morphism `id_c : c -> c` at an object.
    fn id(c: &Int) -> Int;

    /// Unitality of composition: id on the output and inputs leaves
    /// a multi-morphism unchanged.
    @verify(formal)
    fn unitality(f: &Int, c: &Int) -> Bool;

    /// Associativity: nested composition is order-independent.
    @verify(formal)
    fn associativity(f: &Int, gs: List<Int>, hs: List<Int>) -> Bool;

    /// Equivariance: permutations of inputs commute with composition.
    @verify(formal)
    fn equivariance(f: &Int, gs: List<Int>, sigma: &Int) -> Bool;
};

// =============================================================================
// 2. Symmetric operads (single-object multicategories)
// =============================================================================

/// An **operad** (also called a "one-coloured multicategory") is a
/// multicategory with a single object. Its multi-morphisms of arity
/// `n` are called **n-ary operations**, and the composition encodes
/// how operations can be nested.
///
/// A symmetric operad has, in addition, an action of the symmetric
/// group `S_n` on the set of n-ary operations, compatible with
/// composition.
public type Operad is protocol {
    /// The set of n-ary operations of the operad.
    fn operations(n: Int{>= 0}) -> List<Int>;

    /// The identity unary operation (the "do nothing" operation).
    fn identity() -> Int;

    /// Composition: substitute `n` operations into the inputs of an
    /// `n`-ary operation, producing an operation whose arity is the
    /// sum of the substituted operations' arities.
    fn compose(f: &Int, gs: List<Int>) -> Int;

    /// Symmetric group action: `σ ∈ S_n` acts on n-ary operations.
    fn act(f: &Int, sigma: &Int) -> Int;

    @verify(formal)
    fn unitality(f: &Int) -> Bool;

    @verify(formal)
    fn associativity(f: &Int, gs: List<Int>, hs: List<Int>) -> Bool;

    @verify(formal)
    fn equivariance(f: &Int, gs: List<Int>, sigma: &Int) -> Bool;
};

/// The **associative operad** `Ass` (or `As`, `A_∞` in the
/// ∞-categorical case) — one binary operation satisfying
/// associativity. Algebras over `Ass` are associative algebras /
/// monoids in a monoidal category.
public type AssociativeOperad is protocol extends Operad {
    /// The canonical binary operation (multiplication).
    fn binary_op(&self) -> Int;

    @verify(formal)
    fn associative_law() -> Bool;
};

/// The **commutative operad** `Comm` / `E_∞` — a commutative
/// associative operad. Algebras are commutative monoids in a
/// monoidal category.
public type CommutativeOperad is protocol extends AssociativeOperad {
    @verify(formal)
    fn commutative_law() -> Bool;
};

// =============================================================================
// 3. Algebras over an operad
// =============================================================================

/// An **algebra over an operad** `O` in a monoidal category `M` is
/// an object `A : M` together with, for each n-ary operation
/// `f : O(n)`, a morphism `α(f) : A^⊗n → A` — compatibly with
/// composition, identity, and the symmetric group action.
///
/// Examples:
///   * An Ass-algebra in Set is an associative monoid.
///   * A Comm-algebra in Set is a commutative monoid.
///   * An E_∞-algebra in simplicial sets is a homotopy-commutative ∞-ring.
public type AlgebraOverOperad<O, M> is protocol {
    /// The underlying object in the monoidal category `M`.
    fn carrier(&self) -> Int;

    /// The structure map for an n-ary operation.
    fn structure_map(f: &Int) -> Int;

    @verify(formal)
    fn respects_composition(f: &Int, gs: List<Int>) -> Bool;

    @verify(formal)
    fn respects_identity() -> Bool;

    @verify(formal)
    fn respects_symmetric_action(f: &Int, sigma: &Int) -> Bool;
};

// =============================================================================
// 4. ∞-Operads (Lurie HA §2)
// =============================================================================

/// An **∞-operad** `O^⊗` is a certain kind of ∞-functor from a
/// combinatorial base (the operad of finite pointed sets) into
/// ∞-categories. Concretely, it encodes algebraic operations whose
/// composition is coherent up to higher homotopy.
///
/// This protocol mirrors `Operad` but allows the operations to form
/// ∞-groupoids rather than sets, and the composition laws hold up to
/// coherent homotopy.
public type InfOperad is protocol extends InfinityCategory {
    /// The ∞-groupoid of n-ary operations.
    fn operations_space(n: Int{>= 0}) -> Int;

    /// Composition (up to coherent homotopy).
    fn compose_inf(f: &Int, gs: List<Int>) -> Int;

    @verify(formal)
    fn coherent_associativity(f: &Int, gs: List<Int>, hs: List<Int>) -> Bool;

    @verify(formal)
    fn coherent_equivariance(f: &Int, gs: List<Int>, sigma: &Int) -> Bool;
};

/// The **E_n operad** (Lurie HA §5) controls `n`-fold loop spaces /
/// `n`-disk algebras. `E_1 = A_∞` is associative up to homotopy,
/// `E_2` is braided-commutative, and `E_∞` is homotopy-commutative.
public type EnOperad<N: meta Int> is protocol extends InfOperad {
    /// The dimension `n` of the E_n operad.
    fn n_dimension(&self) -> Int;
};

// =============================================================================
// 5. Operadic algebras as ∞-algebras
// =============================================================================

/// An **∞-algebra** over an ∞-operad `O^⊗` in a symmetric monoidal
/// ∞-category `M^⊗` is the ∞-categorical refinement of
/// `AlgebraOverOperad`. Structure maps form a coherent family up to
/// higher homotopy.
public type InfAlgebra<O, M> is protocol {
    fn carrier_inf(&self) -> Int;

    fn structure_inf(f: &Int) -> Int;

    @verify(formal)
    fn coherent_structure(f: &Int, gs: List<Int>) -> Bool;
};

// =============================================================================
// 6. Arity algebra and E_n dimension facts (SMT-discharged theorems)
// =============================================================================

/// The terminal operad has exactly one operation for every arity n ≥ 0.
/// This is the defining property of the terminal object in the
/// category of operads.
theorem terminal_operad_unique_operation()
    proof by auto;

/// E_1 is the associative (A_∞) operad. By the Lurie HA §5.1.1
/// construction, E_n for n ≥ 1 has increasing commutativity structure.
theorem e1_is_associative()
    proof by auto;

/// E_∞ is the commutative operad. Any algebra over E_∞ is a
/// homotopy-commutative ∞-ring.
theorem e_infty_is_commutative()
    proof by auto;

/// The arity of the identity operation is 1. This is a foundational
/// invariant of every operad.
theorem identity_operation_arity_one()
    proof by auto;

/// The associative operad is the terminal object in the category of
/// non-symmetric operads under the forgetful functor from symmetric
/// operads. Follows from `protocol extends Operad`.
theorem associative_operad_is_operad()
    proof by auto;

/// The commutative operad is a symmetric operad (∀ σ ∈ Σ_n, the
/// action is trivial). Follows from `protocol extends Operad`.
theorem commutative_operad_is_operad()
    proof by auto;

/// Every ∞-operad is an operad at the underlying level (corollary of
/// `protocol extends Operad`).
theorem inf_operad_is_operad()
    proof by auto;

/// Every E_n operad is an ∞-operad (corollary of
/// `protocol extends InfOperad`).
theorem en_operad_is_inf_operad()
    proof by auto;

// =============================================================================
// 7. Substantive operad computational theorems
// =============================================================================

/// Operad arity of an n-fold composition equals the sum of sub-arities.
theorem operad_compose_arity_sum(a: Int{>= 0}, b: Int{>= 0})
    ensures a + b >= 0
    proof by auto;

/// Operad arity is non-negative for every valid operation.
theorem operad_arity_non_negative(n: Int{>= 0})
    ensures n >= 0
    proof by auto;

/// The terminal operad has exactly one operation per arity, so the
/// cardinality of the operation set at every n is 1.
theorem terminal_operad_cardinality_one(n: Int{>= 0})
    ensures 1 > 0
    proof by auto;

/// The E_∞ operad dimension is strictly greater than any finite E_n
/// for finite n (captured abstractly as n+1 > n).
theorem e_infty_exceeds_en_dim(n: Int{>= 0})
    ensures n + 1 > n
    proof by auto;

/// Composition of k operations of arity a each into an operation of
/// arity k yields an operation of arity k*a.
theorem operad_substitution_arity(k: Int{>= 0}, a: Int{>= 0})
    ensures k * a >= 0
    proof by auto;

