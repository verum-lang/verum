module core.math.s_definable;

// Public module declarations — namespace-tree visibility for the
// 2 child files. Pre-fix `mod.vr` only forwarded specific symbols
// via `mount {...}`; the children weren't addressable through the
// umbrella's namespace tree.
public module class_s_s;
public module lemma_3_4;

mount core.math.s_definable.class_s_s.{
    SSMembership,
    RefinedSSMembership,
    msfs_s_s_local_base,
    msfs_s_s_closed_under_kan_extensions,
    msfs_s_s_closed_under_grothendieck,
    msfs_s_s_closed_under_limits_colimits,
    msfs_s_s_closed_under_slice_comma_opposite,
    msfs_s_s_closed_under_derived_functors,
    msfs_s_s_closed_under_monoidal,
    msfs_s_s_global_kappa_1_accessible,
    msfs_s_s_global_u_2_small,
    msfs_s_s_local_subset_global,
    msfs_s_s_equals_global,
    msfs_ss_local_implies_global,
    msfs_ss_either_flag_implies_global,
    msfs_refined_ss_depth_nonneg,
};

mount core.math.s_definable.lemma_3_4.{
