// =============================================================================
// observational.vr — Observational Type Theory (OTT)
// =============================================================================
//
// Layer: Standard Library / Mathematics
//
// Surface for `verum_types::observational_equality`. Type-directed
// equality alternative to cubical: two values' equality is
// *defined by what we can observe about them*. Products decompose
// into component equality; functions decompose into pointwise
// (funext); decidable types decide directly.
//
// =============================================================================

module core.math.observational;

/// Simplified type for OTT equality computations.
public type OttType is
    | OttBool
    | OttNat
    | OttUnit
    | OttProduct { left: Heap<OttType>, right: Heap<OttType> }
    | OttFunction { domain: Heap<OttType>, codomain: Heap<OttType> }
    | OttOpaque { name: Text };

/// A simplified OTT value.
public type OttValue is
    | OttBoolVal { value: Bool }
    | OttNatVal { value: Int }
    | OttUnitVal
    | OttPair { first: Heap<OttValue>, second: Heap<OttValue> }
    | OttOpaqueVal { name: Text };

/// Equality decision result.
public type OttEqResult is
    | OttTrue
    | OttFalse
    | OttStuck;

/// Type-directed equality on first-order values. Decomposes
/// products into component-wise equality (V8 #245); decides
/// Bool/Nat/Unit directly; returns Stuck on opaque types with
/// different names. Functions return Stuck — funext is
/// undecidable for arbitrary functions; the type-checker uses
/// observational equality on functions only via η-expansion at
/// the elaborator layer.
///
/// Per VVA OTT §observational: equality at a product type is
/// decidable iff equality at each component type is decidable.
/// `OttStuck` propagates: if either component returns Stuck,
/// the pair returns Stuck (we cannot decide the conjunction
/// without deciding both clauses).
public fn ott_decide(ty: OttType, lhs: OttValue, rhs: OttValue) -> OttEqResult {
    match (ty, lhs, rhs) {
        (OttType.OttBool, OttValue.OttBoolVal { value: a }, OttValue.OttBoolVal { value: b }) =>
            if a == b { OttEqResult.OttTrue } else { OttEqResult.OttFalse },
        (OttType.OttNat, OttValue.OttNatVal { value: a }, OttValue.OttNatVal { value: b }) =>
            if a == b { OttEqResult.OttTrue } else { OttEqResult.OttFalse },
        (OttType.OttUnit, OttValue.OttUnitVal, OttValue.OttUnitVal) =>
            OttEqResult.OttTrue,
        (OttType.OttOpaque { name: _ }, OttValue.OttOpaqueVal { name: a }, OttValue.OttOpaqueVal { name: b }) =>
            if a == b { OttEqResult.OttTrue } else { OttEqResult.OttStuck },

        // V8 (#245) — Product decomposition. (l1,l2) =_AxB (r1,r2)
        // iff l1 =_A r1 AND l2 =_B r2. False propagates eagerly
        // (one mismatch is enough to refute); Stuck propagates
        // when either component is undecidable.
        (
            OttType.OttProduct { left: ty_a, right: ty_b },
            OttValue.OttPair { first: la, second: lb },
            OttValue.OttPair { first: ra, second: rb },
        ) => {
            let left_eq = ott_decide(*ty_a, *la, *ra);
            match left_eq {
                OttEqResult.OttFalse => OttEqResult.OttFalse,
                _ => {
                    let right_eq = ott_decide(*ty_b, *lb, *rb);
                    match (left_eq, right_eq) {
                        (OttEqResult.OttTrue, OttEqResult.OttTrue) => OttEqResult.OttTrue,
                        (_, OttEqResult.OttFalse)                  => OttEqResult.OttFalse,
                        _                                          => OttEqResult.OttStuck,
                    }
                }
            }
        },

        (_, _, _) => OttEqResult.OttStuck,
    }
}
