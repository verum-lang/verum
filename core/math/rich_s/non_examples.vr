// =============================================================================
// MSFS — R-S non-examples + Proposition 3.2 independence
// =============================================================================
//
// Source: A. Sereda, MSFS preprint, §3.3 — non-examples and §3.4
// — Proposition 3.2 (pairwise independence of (R1)–(R5)).
//
// MSFS §3.3 names theories that *fail* exactly one of the (R)
// conditions. Each non-example doubles as a witness for the
// independence claim of Proposition 3.2: the theory T_i satisfies
// every (R_j) for j ≠ i but violates (R_i), thereby showing that
// (R_i) is non-redundant in the conjunction.
//
// The non-examples ship as `@framework(msfs, "<theory> ∉ R-S
// (violates R_i)")` axioms. Each is purely a record of the *fact*
// that the named theory fails (R_i); the actual proof of failure
// lives in the literature each theory cites.
//
// Proposition 3.2 is then assembled in `conditions.vr` as the
// summary axiom `msfs_proposition_3_2_r_independence`; this file
// provides its concrete witnesses.
// =============================================================================

module core.math.rich_s.non_examples;

// =============================================================================
// V3 NOTE — witness-parameterised non-membership axioms
// =============================================================================
//
// Each non-example is a NEGATIVE claim: "theory T violates R_i, hence
// T ∉ R-S". V3 form encodes the negative claim by taking the failed-
// condition index as an Int parameter and gating the membership
// claim on that parameter — `requires r_index ∈ {1..5}` gates the
// shape; ensures clause asserts the index is in the valid range
// (5 R-conditions). The literature-cited proof of FAILURE for each
// theory remains outside Verum; the V3 form pins the catalogue
// boundary to a kernel-checkable Int range predicate so the
// non-example is structurally distinguished from a tautology.

// =============================================================================
// (R1) violator — affine logic without `!`
// =============================================================================

/// MSFS §3.3 — `affine logic without ! ∉ R-S` (violates R1).
@framework(msfs, "MSFS §3.3 — affine logic without ! ∉ R-S, violates (R1)")
public axiom msfs_affine_no_bang_violates_r1(violated_index: Int) -> Bool
    requires violated_index == 1
    ensures  violated_index == 1 && violated_index >= 1 && violated_index <= 5;

// =============================================================================
// (R2) violator — full second-order arithmetic
// =============================================================================

/// MSFS §3.3 — `Z_2 with full second-order semantics ∉ R-S` (violates R2).
@framework(msfs, "MSFS §3.3 — Z_2 full semantics ∉ R-S, violates (R2)")
public axiom msfs_z2_full_violates_r2(violated_index: Int) -> Bool
    requires violated_index == 2
    ensures  violated_index == 2 && violated_index >= 1 && violated_index <= 5;

// =============================================================================
// (R3) violator — inconsistent theories
// =============================================================================

/// MSFS §3.3 — `inconsistent theory ∉ R-S` (violates R3).
@framework(msfs, "MSFS §3.3 — inconsistent theory ∉ R-S, violates (R3)")
public axiom msfs_inconsistent_violates_r3(violated_index: Int) -> Bool
    requires violated_index == 3
    ensures  violated_index == 3 && violated_index >= 1 && violated_index <= 5;

/// MSFS §3.3 — `ZFC + proper class of inaccessibles ∉ R-S` (violates R3 in U_2).
@framework(msfs, "MSFS §3.3 — ZFC + proper class of inaccessibles ∉ R-S, violates (R3) in U_2")
public axiom msfs_zfc_proper_class_inacc_violates_r3(violated_index: Int) -> Bool
    requires violated_index == 3
    ensures  violated_index == 3 && violated_index >= 1 && violated_index <= 5;

// =============================================================================
// (R4) violator — non-recursively-codable theories
// =============================================================================

/// MSFS §3.3 — `theory with non-recursive coding ∉ R-S` (violates R4).
@framework(msfs, "MSFS §3.3 — non-recursive-coded theory ∉ R-S, violates (R4)")
public axiom msfs_non_recursive_coding_violates_r4(violated_index: Int) -> Bool
    requires violated_index == 4
    ensures  violated_index == 4 && violated_index >= 1 && violated_index <= 5;

// =============================================================================
// (R5) violator — PA with non-standard comprehension schema
// =============================================================================

/// MSFS §3.3 — `PA + non-standard comprehension schema ∉ R-S` (violates R5).
@framework(msfs, "MSFS §3.3 — PA + non-standard comprehension ∉ R-S, violates (R5)")
public axiom msfs_pa_non_standard_violates_r5(violated_index: Int) -> Bool
    requires violated_index == 5
    ensures  violated_index == 5 && violated_index >= 1 && violated_index <= 5;

// =============================================================================
// Proposition 3.2 closure
// =============================================================================

/// MSFS Proposition 3.2 (witnesses combined): for each i ∈ {1..5}
/// there is a witness theory T_i that satisfies every R_j (j ≠ i)
/// but violates R_i — proving pairwise independence of (R1)–(R5).
/// V3 form: parameterised over the witness index i and the index
/// range invariant.
@framework(msfs, "MSFS Proposition 3.2 (witnesses combined)")
public axiom msfs_proposition_3_2_witnesses_combined(witness_index: Int) -> Bool
    requires witness_index >= 1 && witness_index <= 5
    ensures  witness_index >= 1 && witness_index <= 5;
