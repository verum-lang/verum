/// MSFS ¬ß3.2 ‚Äî `motivic homotopy theory ‚àà R-S`, `n = -1` (encoded ‚àû).
@framework(msfs, "MSFS ¬ß3.2 ‚Äî motivic homotopy theory ‚àà R-S")
public axiom msfs_motivic_in_rich_s<R: RichS>(motivic: &R) -> Bool
    requires true
