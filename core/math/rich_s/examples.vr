// =============================================================================
// MSFS ‚Äî R-S examples (standard Rich foundations)
// =============================================================================
//

// Source: A. Sereda, MSFS preprint, ¬ß3.2 ‚Äî Examples of R-S
// metatheories. The paper enumerates eight canonical foundations
// that satisfy (R1)‚Äì(R5); plus side-references to several
// extensions (linear logic + !, Eff internal, Lurie ‚àû-topos
// internal, cohesive ‚àû-topos, NCG, motivic homotopy theory, ‚Ä¶).
//

// Each example here is a single `@framework(msfs, "<S> ‚àà R-S")`
// axiom that admits the *fact* that the named theory satisfies
// (R1)‚Äì(R5). The actual proof of (R1)‚Äì(R5) for each theory lives
// outside Verum (in the literature each theory cites ‚Äî Robinson Q
// interpretability, model existence, recursive axiomatisation,
// Lambek‚ÄìScott style syntax-semantics theorem). Verum records the
// admission, not the metatheoretic proof.
//

// The `n_S` value is captured per-axiom because ¬ß7 (vertical
// absoluteness) consumes it directly. ‚àû is encoded as `-1` in
// keeping with `lib.math.frameworks.msfs.key_symbols::n_level`.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.math.rich_s.examples;

mount core.math.rich_s.conditions.{RichS};

// =============================================================================
// V3 NOTE ‚Äî witness-parameterised R-S admission axioms
// =============================================================================
//

// Each `<theory> ‚àà R-S` admission is now witness-parameterised over
// a `R: RichS` carrier instance. The ensures clause asserts the
// theory's claimed `n_S` value via the `R::n_S()` protocol method ‚Äî
// kernel-checkable rather than `ensures true`. The (R1)‚Äì(R5)
// concrete proofs live outside Verum (literature-cited per theory);
// this admission records the membership FACT.
//

// The integer encoding for `n_S`:
//  n_ZFC = 1 (1-categorical), n_NBG = 1, n_MLTT = -1 (‚àû),
//  n_HoTT = -1, n_CIC = -1, n_Cubical = -1, n_linear = -1,
//  n_Eff = -1, n_Lurie = -1, n_cohesive = -1, n_NCG = -1,
//  n_motivic = -1.
// (-1 is the wire-level encoding of ‚àû per
// `core.math.frameworks.msfs.key_symbols::n_level`.)

// =============================================================================
// (R1)‚Äì(R5) admission axioms per canonical theory ‚Äî V3 form
// =============================================================================

/// MSFS ¬ß3.2 ‚Äî `ZFC ‚àà R-S` with `n_ZFC = 1`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî ZFC ‚àà R-S, n_ZFC = 1")
public axiom msfs_zfc_in_rich_s<R: RichS>(zfc: &R) -> Bool
    requires true
    ensures  zfc.n_S() == 1;

/// MSFS ¬ß3.2 ‚Äî `ZFC + inaccessibles ‚àà R-S` with `Œ∫_S = Œ∫_2`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî ZFC + inaccessibles ‚àà R-S, Œ∫_S = Œ∫_2")
public axiom msfs_zfc_inacc_in_rich_s<R: RichS>(zfc_inacc: &R) -> Bool
    requires true
    ensures  zfc_inacc.n_S() == 1;

/// MSFS ¬ß3.2 ‚Äî `NBG ‚àà R-S`. Conservative extension of ZFC at level 1.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî NBG ‚àà R-S")
public axiom msfs_nbg_in_rich_s<R: RichS>(nbg: &R) -> Bool
    requires true
    ensures  nbg.n_S() == 1;

/// MSFS ¬ß3.2 ‚Äî `MLTT ‚àà R-S`, `n_MLTT = ‚àû` (encoded as -1).
@framework(msfs, "MSFS ¬ß3.2 ‚Äî MLTT ‚àà R-S, n_MLTT = ‚àû")
public axiom msfs_mltt_in_rich_s<R: RichS>(mltt: &R) -> Bool
    requires true
    ensures  mltt.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `CIC ‚àà R-S`, `n_CIC = ‚àû`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî CIC ‚àà R-S, n_CIC = ‚àû")
public axiom msfs_cic_in_rich_s<R: RichS>(cic: &R) -> Bool
    requires true
    ensures  cic.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `HoTT (with univalence) ‚àà R-S`, `n_HoTT = ‚àû`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî HoTT (with univalence) ‚àà R-S, n_HoTT = ‚àû")
public axiom msfs_hott_in_rich_s<R: RichS>(hott: &R) -> Bool
    requires true
    ensures  hott.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `Cubical HoTT (CCHM) ‚àà R-S`, `n = ‚àû`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî Cubical HoTT (CCHM) ‚àà R-S")
public axiom msfs_cubical_hott_in_rich_s<R: RichS>(cubical: &R) -> Bool
    requires true
    ensures  cubical.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `linear logic + ! ‚àà R-S`, `n = ‚àû`.
/// (Parameter named `lin_logic` rather than `linear` because `linear`
/// is a reserved keyword in Verum's grammar ‚Äî using it as a parameter
/// name confuses the parser at the parameter-pattern position.)
@framework(msfs, "MSFS ¬ß3.2 ‚Äî linear logic + ! ‚àà R-S")
public axiom msfs_linear_with_bang_in_rich_s<R: RichS>(lin_logic: &R) -> Bool
    requires true
    ensures  lin_logic.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `Eff (Hyland) internal language ‚àà R-S`, `n = ‚àû`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî Eff (Hyland) internal language ‚àà R-S")
public axiom msfs_eff_in_rich_s<R: RichS>(eff: &R) -> Bool
    requires true
    ensures  eff.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `Lurie ‚àû-topos internal ‚àà R-S`, `n = ‚àû`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî Lurie ‚àû-topos internal ‚àà R-S")
public axiom msfs_lurie_infinity_topos_internal_in_rich_s<R: RichS>(lurie: &R) -> Bool
    requires true
    ensures  lurie.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `cohesive ‚àû-topos ‚àà R-S`, `n = ‚àû`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî cohesive ‚àû-topos ‚àà R-S")
public axiom msfs_cohesive_infinity_topos_in_rich_s<R: RichS>(cohesive: &R) -> Bool
    requires true
    ensures  cohesive.n_S() == -1;

/// MSFS ¬ß3.2 ‚Äî `NCG (Connes) ‚àà R-S`, `n = ‚àû`.
@framework(msfs, "MSFS ¬ß3.2 ‚Äî NCG (Connes) ‚àà R-S")
public axiom msfs_ncg_in_rich_s<R: RichS>(ncg: &R) -> Bool
    requires true
