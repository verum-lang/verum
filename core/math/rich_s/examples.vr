// =============================================================================
// MSFS — R-S examples (standard Rich foundations)
// =============================================================================
//
// Source: A. Sereda, MSFS preprint, §3.2 — Examples of R-S
// metatheories. The paper enumerates eight canonical foundations
// that satisfy (R1)–(R5); plus side-references to several
// extensions (linear logic + !, Eff internal, Lurie ∞-topos
// internal, cohesive ∞-topos, NCG, motivic homotopy theory, …).
//
// Each example here is a single `@framework(msfs, "<S> ∈ R-S")`
// axiom that admits the *fact* that the named theory satisfies
// (R1)–(R5). The actual proof of (R1)–(R5) for each theory lives
// outside Verum (in the literature each theory cites — Robinson Q
// interpretability, model existence, recursive axiomatisation,
// Lambek–Scott style syntax-semantics theorem). Verum records the
// admission, not the metatheoretic proof.
//
// The `n_S` value is captured per-axiom because §7 (vertical
// absoluteness) consumes it directly. ∞ is encoded as `-1` in
// keeping with `lib.math.frameworks.msfs.key_symbols::n_level`.
// =============================================================================

module core.math.rich_s.examples;

mount core.math.rich_s.conditions.{RichS};

// =============================================================================
// V3 NOTE — witness-parameterised R-S admission axioms
// =============================================================================
//
// Each `<theory> ∈ R-S` admission is now witness-parameterised over
// a `R: RichS` carrier instance. The ensures clause asserts the
// theory's claimed `n_S` value via the `R::n_S()` protocol method —
// kernel-checkable rather than `ensures true`. The (R1)–(R5)
// concrete proofs live outside Verum (literature-cited per theory);
// this admission records the membership FACT.
//
// The integer encoding for `n_S`:
//   n_ZFC = 1 (1-categorical), n_NBG = 1, n_MLTT = -1 (∞),
//   n_HoTT = -1, n_CIC = -1, n_Cubical = -1, n_linear = -1,
//   n_Eff = -1, n_Lurie = -1, n_cohesive = -1, n_NCG = -1,
//   n_motivic = -1.
// (-1 is the wire-level encoding of ∞ per
// `core.math.frameworks.msfs.key_symbols::n_level`.)

// =============================================================================
// (R1)–(R5) admission axioms per canonical theory — V3 form
// =============================================================================

/// MSFS §3.2 — `ZFC ∈ R-S` with `n_ZFC = 1`.
@framework(msfs, "MSFS §3.2 — ZFC ∈ R-S, n_ZFC = 1")
public axiom msfs_zfc_in_rich_s<R: RichS>(zfc: &R) -> Bool
    requires true
    ensures  zfc.n_S() == 1;

/// MSFS §3.2 — `ZFC + inaccessibles ∈ R-S` with `κ_S = κ_2`.
@framework(msfs, "MSFS §3.2 — ZFC + inaccessibles ∈ R-S, κ_S = κ_2")
public axiom msfs_zfc_inacc_in_rich_s<R: RichS>(zfc_inacc: &R) -> Bool
    requires true
    ensures  zfc_inacc.n_S() == 1;

/// MSFS §3.2 — `NBG ∈ R-S`. Conservative extension of ZFC at level 1.
@framework(msfs, "MSFS §3.2 — NBG ∈ R-S")
public axiom msfs_nbg_in_rich_s<R: RichS>(nbg: &R) -> Bool
    requires true
    ensures  nbg.n_S() == 1;

/// MSFS §3.2 — `MLTT ∈ R-S`, `n_MLTT = ∞` (encoded as -1).
@framework(msfs, "MSFS §3.2 — MLTT ∈ R-S, n_MLTT = ∞")
public axiom msfs_mltt_in_rich_s<R: RichS>(mltt: &R) -> Bool
    requires true
    ensures  mltt.n_S() == -1;

/// MSFS §3.2 — `CIC ∈ R-S`, `n_CIC = ∞`.
@framework(msfs, "MSFS §3.2 — CIC ∈ R-S, n_CIC = ∞")
public axiom msfs_cic_in_rich_s<R: RichS>(cic: &R) -> Bool
    requires true
    ensures  cic.n_S() == -1;

/// MSFS §3.2 — `HoTT (with univalence) ∈ R-S`, `n_HoTT = ∞`.
@framework(msfs, "MSFS §3.2 — HoTT (with univalence) ∈ R-S, n_HoTT = ∞")
public axiom msfs_hott_in_rich_s<R: RichS>(hott: &R) -> Bool
    requires true
    ensures  hott.n_S() == -1;

/// MSFS §3.2 — `Cubical HoTT (CCHM) ∈ R-S`, `n = ∞`.
@framework(msfs, "MSFS §3.2 — Cubical HoTT (CCHM) ∈ R-S")
public axiom msfs_cubical_hott_in_rich_s<R: RichS>(cubical: &R) -> Bool
    requires true
    ensures  cubical.n_S() == -1;

/// MSFS §3.2 — `linear logic + ! ∈ R-S`, `n = ∞`.
/// (Parameter named `lin_logic` rather than `linear` because `linear`
/// is a reserved keyword in Verum's grammar — using it as a parameter
/// name confuses the parser at the parameter-pattern position.)
@framework(msfs, "MSFS §3.2 — linear logic + ! ∈ R-S")
public axiom msfs_linear_with_bang_in_rich_s<R: RichS>(lin_logic: &R) -> Bool
    requires true
    ensures  lin_logic.n_S() == -1;

/// MSFS §3.2 — `Eff (Hyland) internal language ∈ R-S`, `n = ∞`.
@framework(msfs, "MSFS §3.2 — Eff (Hyland) internal language ∈ R-S")
public axiom msfs_eff_in_rich_s<R: RichS>(eff: &R) -> Bool
    requires true
    ensures  eff.n_S() == -1;

/// MSFS §3.2 — `Lurie ∞-topos internal ∈ R-S`, `n = ∞`.
@framework(msfs, "MSFS §3.2 — Lurie ∞-topos internal ∈ R-S")
public axiom msfs_lurie_infinity_topos_internal_in_rich_s<R: RichS>(lurie: &R) -> Bool
    requires true
    ensures  lurie.n_S() == -1;

/// MSFS §3.2 — `cohesive ∞-topos ∈ R-S`, `n = ∞`.
@framework(msfs, "MSFS §3.2 — cohesive ∞-topos ∈ R-S")
public axiom msfs_cohesive_infinity_topos_in_rich_s<R: RichS>(cohesive: &R) -> Bool
    requires true
    ensures  cohesive.n_S() == -1;

/// MSFS §3.2 — `NCG (Connes) ∈ R-S`, `n = ∞`.
@framework(msfs, "MSFS §3.2 — NCG (Connes) ∈ R-S")
public axiom msfs_ncg_in_rich_s<R: RichS>(ncg: &R) -> Bool
    requires true
    ensures  ncg.n_S() == -1;

/// MSFS §3.2 — `motivic homotopy theory ∈ R-S`, `n = -1` (encoded ∞).
@framework(msfs, "MSFS §3.2 — motivic homotopy theory ∈ R-S")
public axiom msfs_motivic_in_rich_s<R: RichS>(motivic: &R) -> Bool
    requires true
    ensures  motivic.n_S() == -1;
