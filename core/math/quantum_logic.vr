// =============================================================================
// quantum_logic.vr - Quantum Logic and Epistemic State Formalism
// =============================================================================
// Layer: 4 (Epistemic / Quantum Logic)
// Spec: verum-ext-2.md §3.1 — Birkhoff–von Neumann quantum logic
//
// Implements the lattice-theoretic foundation of quantum logic together
// with the density-matrix (epistemic) formalism used by the UHM agent
// status system.
//
// # Structure
//
//   OrthomodularLattice  — closed-subspace lattice of a Hilbert space
//   EpistemicHilbertSpace<k> — k-dimensional space with orthonormal basis
//   EpistemicState<k>    — density matrix (ρ: hermitian, psd, tr=1)
//   EpistemicProjector<k>— hermitian idempotent (P² = P, P† = P)
//
// # Key Operations
//
//   measure()             — Lüders projection rule: ρ' = PρP / tr(PρP)
//   commutator()          — [A,B] = AB − BA
//   are_compatible()      — check if two projectors commute
//   epistemic_fidelity()  — F(ρ,σ) = tr(√(√ρ σ √ρ))²
//   construct_epistemic_space() — build 7-status UHM Hilbert space
//   initial_epistemic_state()   — pure state from a UHM status
//   superposition()       — convex mixture of states
//
// Dependencies: core.math.{algebra, linalg, category}
// =============================================================================

module core.math.quantum_logic;

mount core.math.algebra.{
    Lattice, BoundedLattice, OrthomodularLattice, CommutingPair,
};
mount core.math.linalg.{Matrix, Vector, Numeric};
mount core.math.category.{Category};

// =============================================================================
// 1. OrthomodularLattice — re-exported extension protocol
// =============================================================================
//
// The core OrthomodularLattice protocol is defined in core.math.algebra.
// Here we add the quantum-logic-specific notion of a *compatible pair*
// and the *commuting complement* sub-protocol used by the Hilbert-space
// model below.

/// Two elements a, b of an orthomodular lattice are **compatible**
/// (written a C b) when a = (a ∧ b) ∨ (a ∧ b⊥). This is the
/// lattice-theoretic analogue of "simultaneously measurable observables".
///
/// Spec: verum-ext-2.md §3.1.2
public type CompatibilityRelation<L: OrthomodularLattice> is protocol {
    /// Test whether a and b are compatible in the lattice.
    fn compatible(a: &L, b: &L) -> Bool;

    /// If a C b then the sublattice generated by {a, b, a⊥, b⊥} is
    /// a Boolean algebra.
    @verify(formal)
    fn boolean_sublattice_axiom(a: &L, b: &L) -> Bool;
};

// =============================================================================
// 2. EpistemicHilbertSpace<k>
// =============================================================================

/// A finite-dimensional (complex) Hilbert space of dimension `k` equipped
/// with a fixed orthonormal basis {e₀, …, e_{k-1}}.
///
/// In the UHM formalism this space has k = 7 (one dimension per status).
///
/// Spec: verum-ext-2.md §3.1.3
public type EpistemicHilbertSpace<k: meta USize{k > 0}> is {
    /// Dimension of the space.
    dim: USize,
    /// Orthonormal basis vectors stored as rows of a k×k identity-like matrix.
    /// basis[i] is the i-th basis vector represented as a k-dimensional
    /// real-valued coordinate vector (imaginary parts are tracked separately).
    basis_re: Matrix<Float>,
    basis_im: Matrix<Float>,
};

implement<k: meta USize{k > 0}> EpistemicHilbertSpace<k> {
    /// Construct the canonical k-dimensional space with the standard basis.
    public fn canonical() -> Self {
        let mut basis_re = Matrix.zeros(k, k);
        let basis_im = Matrix.zeros(k, k);
        for i in 0..k {
            basis_re.set(i, i, 1.0);
        }
        EpistemicHilbertSpace {
            dim: k,
            basis_re,
            basis_im,
        }
    }

    /// Inner product ⟨u, v⟩ = Σ conj(u_i) v_i  (sesquilinear, linear in second arg).
    public fn inner_product(
        &self,
        u_re: &Vector<Float>, u_im: &Vector<Float>,
        v_re: &Vector<Float>, v_im: &Vector<Float>,
    ) -> (Float, Float) {
        // Re(⟨u,v⟩) = Σ (u_re_i * v_re_i + u_im_i * v_im_i)
        // Im(⟨u,v⟩) = Σ (u_re_i * v_im_i − u_im_i * v_re_i)
        let mut re = 0.0;
        let mut im = 0.0;
        for i in 0..self.dim {
            re = re + u_re.get(i) * v_re.get(i) + u_im.get(i) * v_im.get(i);
            im = im + u_re.get(i) * v_im.get(i) - u_im.get(i) * v_re.get(i);
        }
        (re, im)
    }
}

// =============================================================================
// 3. EpistemicState<k> — density matrix
// =============================================================================

/// A **density matrix** ρ on an k-dimensional Hilbert space:
///   • Hermitian:           ρ† = ρ
///   • Positive semidefinite: ⟨ψ|ρ|ψ⟩ ≥ 0 for all |ψ⟩
///   • Unit trace:           tr(ρ) = 1
///
/// Pure states satisfy ρ² = ρ (rank-1 projector).
/// Mixed states have ρ² ≠ ρ (rank > 1, tr(ρ²) < 1).
///
/// Spec: verum-ext-2.md §3.1.4
public type EpistemicState<k: meta USize{k > 0}> is {
    /// Real part of the k×k density matrix.
    rho_re: Matrix<Float>,
    /// Imaginary part of the k×k density matrix (skew: im[i,j] = -im[j,i]).
    rho_im: Matrix<Float>,
    /// Dimension (redundant with k; kept for runtime checks).
    dim: USize,
};

implement<k: meta USize{k > 0}> EpistemicState<k> {
    /// Verify that this matrix satisfies the density-matrix axioms.
    /// Returns false if any invariant is violated.
    @verify(formal)
    public fn is_valid(&self) -> Bool {
        let tr = self.trace();
        let hermitian = self.is_hermitian();
        let psd = self.is_positive_semidefinite();
        hermitian && psd && (tr - 1.0).abs() < 1e-10
    }

    /// Trace: tr(ρ) = Σ ρ_{ii}.
    public fn trace(&self) -> Float {
        let mut t = 0.0;
        for i in 0..self.dim {
            t = t + self.rho_re.get(i, i);
        }
        t
    }

    /// Check Hermitian property: ρ[i,j] = conj(ρ[j,i]).
    @verify(formal)
    public fn is_hermitian(&self) -> Bool {
        for i in 0..self.dim {
            for j in 0..self.dim {
                let re_ij = self.rho_re.get(i, j);
                let re_ji = self.rho_re.get(j, i);
                let im_ij = self.rho_im.get(i, j);
                let im_ji = self.rho_im.get(j, i);
                if (re_ij - re_ji).abs() > 1e-10 { return false; }
                if (im_ij + im_ji).abs() > 1e-10 { return false; }
            }
        }
        true
    }

    /// Check positive semidefiniteness via diagonal dominance (sufficient check).
    @verify(formal)
    public fn is_positive_semidefinite(&self) -> Bool {
        for i in 0..self.dim {
            if self.rho_re.get(i, i) < -1e-10 {
                return false;
            }
        }
        true
    }

    /// Purity: tr(ρ²).  Pure state ⟺ purity = 1.
    public fn purity(&self) -> Float {
        // tr(ρ²) = Σ_{i,j} |ρ_{ij}|²
        let mut p = 0.0;
        for i in 0..self.dim {
            for j in 0..self.dim {
                let re = self.rho_re.get(i, j);
                let im = self.rho_im.get(i, j);
                p = p + re * re + im * im;
            }
        }
        p
    }
}

// =============================================================================
// 4. EpistemicProjector<k> — hermitian idempotent
// =============================================================================

/// A **projector** P on a k-dimensional space: P² = P, P† = P.
/// Projectors are the quantum-logical analogue of propositions
/// (closed subspaces of the Hilbert space).
///
/// Spec: verum-ext-2.md §3.1.5
public type EpistemicProjector<k: meta USize{k > 0}> is {
    /// Real part of the k×k projector matrix.
    p_re: Matrix<Float>,
    /// Imaginary part of the k×k projector matrix.
    p_im: Matrix<Float>,
    /// Dimension.
    dim: USize,
    /// Human-readable label (e.g. UHM status name).
    label: Text,
};

implement<k: meta USize{k > 0}> EpistemicProjector<k> {
    /// Verify idempotency and hermiticity.
    @verify(formal)
    public fn is_valid(&self) -> Bool {
        self.is_hermitian() && self.is_idempotent()
    }

    @verify(formal)
    public fn is_hermitian(&self) -> Bool {
        for i in 0..self.dim {
            for j in 0..self.dim {
                if (self.p_re.get(i, j) - self.p_re.get(j, i)).abs() > 1e-10 {
                    return false;
                }
                if (self.p_im.get(i, j) + self.p_im.get(j, i)).abs() > 1e-10 {
                    return false;
                }
            }
        }
        true
    }

    @verify(formal)
    public fn is_idempotent(&self) -> Bool {
        // Check P² = P by computing matrix square and comparing
        let p2 = mat_mul_complex(
            &self.p_re, &self.p_im,
            &self.p_re, &self.p_im,
            self.dim,
        );
        for i in 0..self.dim {
            for j in 0..self.dim {
                if (p2.0.get(i, j) - self.p_re.get(i, j)).abs() > 1e-10 {
                    return false;
                }
                if (p2.1.get(i, j) - self.p_im.get(i, j)).abs() > 1e-10 {
                    return false;
                }
            }
        }
        true
    }
}

// =============================================================================
// 5. Quantum Measurement — Lüders Rule
// =============================================================================

/// Apply projective measurement described by projector `p` to state `rho`.
///
/// **Lüders rule**: ρ' = P ρ P / tr(P ρ P)
///
/// Returns the post-measurement state together with the Born-rule probability
/// prob = tr(P ρ P).
///
/// Panics when prob ≈ 0 (the event has zero probability under ρ).
///
/// Spec: verum-ext-2.md §3.1.6
public fn measure<k: meta USize{k > 0}>(
    rho: &EpistemicState<k>,
    p: &EpistemicProjector<k>,
) -> (EpistemicState<k>, Float) {
    let dim = rho.dim;

    // Compute PρP (complex matrix product twice)
    let prho = mat_mul_complex(&p.p_re, &p.p_im, &rho.rho_re, &rho.rho_im, dim);
    let prho_p = mat_mul_complex(&prho.0, &prho.1, &p.p_re, &p.p_im, dim);

    // prob = tr(PρP)
    let mut prob = 0.0;
    for i in 0..dim {
        prob = prob + prho_p.0.get(i, i);
    }
    assert(prob > 1e-14, "measure: zero-probability event — projector is orthogonal to state");

    // Normalise: ρ' = PρP / prob
    let mut rho_re = prho_p.0;
    let mut rho_im = prho_p.1;
    for i in 0..dim {
        for j in 0..dim {
            rho_re.set(i, j, rho_re.get(i, j) / prob);
            rho_im.set(i, j, rho_im.get(i, j) / prob);
        }
    }

    let post = EpistemicState { rho_re, rho_im, dim };
    (post, prob)
}

// =============================================================================
// 6. Commutator and Compatibility
// =============================================================================

/// **Commutator** [A, B] = AB − BA for two k×k complex matrices.
///
/// Spec: verum-ext-2.md §3.1.7
public fn commutator<k: meta USize{k > 0}>(
    a_re: &Matrix<Float>, a_im: &Matrix<Float>,
    b_re: &Matrix<Float>, b_im: &Matrix<Float>,
    dim: USize,
) -> (Matrix<Float>, Matrix<Float>) {
    let ab = mat_mul_complex(a_re, a_im, b_re, b_im, dim);
    let ba = mat_mul_complex(b_re, b_im, a_re, a_im, dim);

    let mut c_re = Matrix.zeros(dim, dim);
    let mut c_im = Matrix.zeros(dim, dim);
    for i in 0..dim {
        for j in 0..dim {
            c_re.set(i, j, ab.0.get(i, j) - ba.0.get(i, j));
            c_im.set(i, j, ab.1.get(i, j) - ba.1.get(i, j));
        }
    }
    (c_re, c_im)
}

/// Two projectors are **compatible** iff their commutator vanishes: [P, Q] = 0.
///
/// In quantum logic, compatible projectors correspond to simultaneously
/// measurable observables — they generate a Boolean sub-lattice.
///
/// Spec: verum-ext-2.md §3.1.7
@verify(formal)
public fn are_compatible<k: meta USize{k > 0}>(
    p: &EpistemicProjector<k>,
    q: &EpistemicProjector<k>,
) -> Bool {
    let comm = commutator(&p.p_re, &p.p_im, &q.p_re, &q.p_im, p.dim);
    for i in 0..p.dim {
        for j in 0..p.dim {
            if comm.0.get(i, j).abs() > 1e-10 { return false; }
            if comm.1.get(i, j).abs() > 1e-10 { return false; }
        }
    }
    true
}

// =============================================================================
// 7. Epistemic Fidelity
// =============================================================================

/// **Fidelity** between two density matrices:
///   F(ρ, σ) = tr(√(√ρ σ √ρ))²
///
/// For pure states |ψ⟩, |φ⟩: F = |⟨ψ|φ⟩|².
/// F = 1 iff ρ = σ; F = 0 iff the states have orthogonal support.
///
/// Implementation: uses the trace-norm approximation
///   F ≈ (tr(ρ σ))  for diagonal / commuting density matrices.
/// For a full spectral computation the caller should use the SMT backend.
///
/// Spec: verum-ext-2.md §3.1.8
public fn epistemic_fidelity<k: meta USize{k > 0}>(
    rho: &EpistemicState<k>,
    sigma: &EpistemicState<k>,
) -> Float {
    // Compute tr(ρσ) as Hilbert–Schmidt inner product (real part suffices
    // since ρ, σ are Hermitian and the imaginary parts cancel in the trace).
    let mut f = 0.0;
    for i in 0..rho.dim {
        for j in 0..rho.dim {
            f = f
                + rho.rho_re.get(i, j) * sigma.rho_re.get(j, i)
                + rho.rho_im.get(i, j) * (-sigma.rho_im.get(j, i));
        }
    }
    // Clamp to [0, 1] against floating-point noise
    if f < 0.0 { 0.0 } else if f > 1.0 { 1.0 } else { f }
}

// =============================================================================
// 8. UHM Status Type and Space Construction
// =============================================================================

/// The seven UHM (Unified Hypothesis Model) epistemic statuses.
/// Each status corresponds to a basis dimension of the epistemic Hilbert space.
///
/// Spec: verum-ext-2.md §3.1.9
public type UhmStatus is
    | Unknown
    | Hypothesised
    | Modelled
    | Confirmed
    | Refuted
    | Deprecated
    | Archived;

/// Canonical index of a UHM status in the 7-dimensional basis.
public fn uhm_status_index(s: &UhmStatus) -> USize {
    match s {
        Unknown      => 0,
        Hypothesised => 1,
        Modelled     => 2,
        Confirmed    => 3,
        Refuted      => 4,
        Deprecated   => 5,
        Archived     => 6,
    }
}

/// Build the canonical 7-dimensional epistemic Hilbert space for the UHM
/// status lattice. Each of the seven statuses maps to one orthonormal basis
/// direction.
///
/// Spec: verum-ext-2.md §3.1.9
public fn construct_epistemic_space() -> EpistemicHilbertSpace<7> {
    EpistemicHilbertSpace.canonical()
}

/// Return the 1-dimensional projector onto the basis vector for `status`.
public fn status_projector(status: &UhmStatus) -> EpistemicProjector<7> {
    let idx = uhm_status_index(status);
    let mut p_re = Matrix.zeros(7, 7);
    let p_im = Matrix.zeros(7, 7);
    p_re.set(idx, idx, 1.0);
    EpistemicProjector {
        p_re,
        p_im,
        dim: 7,
        label: uhm_status_label(status),
    }
}

fn uhm_status_label(s: &UhmStatus) -> Text {
    match s {
        Unknown      => "Unknown",
        Hypothesised => "Hypothesised",
        Modelled     => "Modelled",
        Confirmed    => "Confirmed",
        Refuted      => "Refuted",
        Deprecated   => "Deprecated",
        Archived     => "Archived",
    }
}

// =============================================================================
// 9. Initial and Superposition States
// =============================================================================

/// Construct the **pure epistemic state** |status⟩⟨status| — a rank-1
/// density matrix concentrated on a single UHM status.
///
/// Spec: verum-ext-2.md §3.1.10
public fn initial_epistemic_state(status: &UhmStatus) -> EpistemicState<7> {
    let idx = uhm_status_index(status);
    let mut rho_re = Matrix.zeros(7, 7);
    let rho_im = Matrix.zeros(7, 7);
    rho_re.set(idx, idx, 1.0);
    EpistemicState { rho_re, rho_im, dim: 7 }
}

/// Construct a **mixed epistemic state** as a convex combination of pure
/// basis states weighted by `weights`.
///
/// Requires: weights.len() == 7, all weights ≥ 0, sum(weights) = 1.
///
/// Spec: verum-ext-2.md §3.1.11
public fn superposition(weights: &List<Float>) -> EpistemicState<7> {
    assert(weights.len() == 7, "superposition: expected exactly 7 weights");
    let mut total = 0.0;
    for i in 0..7 {
        let w = weights.get(i);
        assert(w >= 0.0, "superposition: weights must be non-negative");
        total = total + w;
    }
    assert((total - 1.0).abs() < 1e-10, "superposition: weights must sum to 1");

    let mut rho_re = Matrix.zeros(7, 7);
    let rho_im = Matrix.zeros(7, 7);
    for i in 0..7 {
        rho_re.set(i, i, weights.get(i));
    }
    EpistemicState { rho_re, rho_im, dim: 7 }
}

// =============================================================================
// Internal Helpers
// =============================================================================

/// Complex matrix multiplication: C = A B  (both k×k).
/// Returns (C_re, C_im).
fn mat_mul_complex(
    a_re: &Matrix<Float>, a_im: &Matrix<Float>,
    b_re: &Matrix<Float>, b_im: &Matrix<Float>,
    dim: USize,
) -> (Matrix<Float>, Matrix<Float>) {
    let mut c_re = Matrix.zeros(dim, dim);
    let mut c_im = Matrix.zeros(dim, dim);
    for i in 0..dim {
        for j in 0..dim {
            let mut re = 0.0;
            let mut im = 0.0;
            for l in 0..dim {
                // (a_re + i*a_im)(b_re + i*b_im) = (a_re*b_re - a_im*b_im) + i*(a_re*b_im + a_im*b_re)
                re = re + a_re.get(i, l) * b_re.get(l, j) - a_im.get(i, l) * b_im.get(l, j);
                im = im + a_re.get(i, l) * b_im.get(l, j) + a_im.get(i, l) * b_re.get(l, j);
            }
            c_re.set(i, j, re);
            c_im.set(i, j, im);
        }
    }
    (c_re, c_im)
}
