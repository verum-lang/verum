// =============================================================================
// MSFS ‚Äî Absolute Layer: (F_S), (ŒÝ_4), (ŒÝ_3-max), and L_Abs
// =============================================================================
//
// Source: A. Sereda, MSFS preprint, ¬ß4 ‚Äî Definitions 4.1‚Äì4.4.
//
// `L_Abs` is the bottom (= empty) stratum of the moduli space ùîê of
// formal systems. An object `X` inhabits `L_Abs` iff there exist a
// Rich-metatheory `S` and ordinal `n` such that `X` simultaneously
// satisfies *three* conditions:
//
//   ‚Ä¢ **(F_S)** ‚Äî formally S-definable with an explicit sub-theory
//     inclusion Œπ_F : F ‚Ü™ S, an induced model reduct Œπ_F^*, and a
//     formula œÜ_X presenting X via Syn(F)[œÜ_X] ‚âÉ_(‚àû,n) X.
//
//   ‚Ä¢ **(ŒÝ_{4,S,n})** ‚Äî irreducible: no (‚àû, n)-functor X ‚Üí Y for any
//     Y in S_S<S> is an equivalence onto its image.
//
//   ‚Ä¢ **(ŒÝ_{3-max,S,n})** ‚Äî maximally generative: for every sub-theory
//     F ‚àà \cF there exists an (‚àû, n)-functor F ‚Üí X that is an
//     equivalence onto its image.
//
// MSFS Theorem 5.1 (AFN-T Œ±-part) shows the conjunction (F_S) ‚àß
// (ŒÝ_4) ‚àß (ŒÝ_3-max) is internally inconsistent ‚Äî `L_Abs == ‚àÖ`. This
// module installs the three conditions as protocol-level predicates
// plus the joint-membership axiom; the emptiness theorem itself
// lands in `theorems/msfs/05_afnt_alpha/`.
// =============================================================================

module core.math.absolute_layer;

mount core.math.strata.{MathObject};
mount core.math.s_definable.lemma_3_4.{FormallySDefinable};

// =============================================================================
// Carrier protocols for the three conditions
// =============================================================================

/// Witness of MSFS Definition 4.1 ‚Äî Condition `(F_S)`. The protocol
/// records the *existence* of (a) a sub-theory inclusion Œπ_F : F ‚Ü™
/// S, (b) the induced model reduct Œπ_F^* : Mod(S) ‚Üí Mod(F), and (c)
/// a formula œÜ_X in F presenting X as a Syn(F)-object.
public type ConditionFS is protocol {
    /// (F-1) ‚Äî sub-theory inclusion Œπ_F : F ‚Ü™ S exists.
    fn has_iota_F(self) -> Bool;

    /// (F-2) ‚Äî induced model reduct Œπ_F^* : Mod(S) ‚Üí Mod(F) exists.
    fn has_iota_F_star(self) -> Bool;

    /// (F-3) ‚Äî syntactic presentation œÜ_X with
    /// `Syn(F)[œÜ_X] ‚âÉ_(‚àû,n) X` exists.
    fn has_phi_X(self) -> Bool;

    /// Bridge to formal-S-definability: Definition 4.1 strictly
    /// implies the formal-S-definability hypothesis of Lemma 3.4.
    fn formally_S_definable_witness(self) -> &FormallySDefinable;
};

/// Witness of MSFS Definition 4.2 ‚Äî Condition `(ŒÝ_{4,S,n})`. The
/// object `X` is *irreducible* in `S_S<S>`: no (‚àû, n)-functor
/// `F : X ‚Üí Y` with `Y ‚àà S_S<S>` is an equivalence onto its image.
public type ConditionPi4 is protocol {
    /// Witness of irreducibility ‚Äî no S_S-target-equivalence-onto-image.
    fn is_irreducible_in_s_s(self) -> Bool;

    /// The categorical level n at which the condition is asserted.
    fn level(self) -> Int;
};

/// Witness of MSFS Definition 4.3 ‚Äî Condition `(ŒÝ_{3-max,S,n})`. The
/// object `X` is *maximally generative*: every sub-theory `F ‚àà \cF`
/// admits an (‚àû, n)-functor `F ‚Üí X` that is an equivalence onto its
/// image.
public type ConditionPi3Max is protocol {
    /// Witness of maximal generativity.
    fn is_maximally_generative(self) -> Bool;

    /// The categorical level n at which the condition is asserted.
    fn level(self) -> Int;
};

/// Joint witness of all three L_Abs conditions for a fixed (S, n).
public type LAbsCandidate is protocol {
    fn cond_F_S(self) -> &ConditionFS;
    fn cond_Pi_4(self) -> &ConditionPi4;
    fn cond_Pi_3_max(self) -> &ConditionPi3Max;
};

// =============================================================================
// Definitions 4.1‚Äì4.4
// =============================================================================

/// MSFS Definition 4.1 ‚Äî Condition `(F_S)`. An object `X ‚àà \cS_S<S>`
/// satisfies `(F_S)` iff there exist a sub-theory `\iota_F : F ‚Ü™ S`
/// with `F ‚àà \cF`, the induced model reduct `\iota_F^* : Mod(S) ‚Üí
/// Mod(F)`, and a formula `œÜ_X` in `F` such that `Syn(F)[œÜ_X]`
/// is `(‚àû, n)`-equivalent to `X`.
@framework(msfs, "MSFS Definition 4.1 ‚Äî Condition (F_S)")
public axiom msfs_definition_4_1_f_s(witness: &ConditionFS) -> Bool
    requires witness.has_iota_F() && witness.has_iota_F_star() && witness.has_phi_X()
    ensures  witness.formally_S_definable_witness().has_phi_x_witness();

/// MSFS Definition 4.2 ‚Äî Condition `(ŒÝ_{4,S,n})`. The object is
/// irreducible: no `(‚àû, n)`-functor `X ‚Üí Y` for any
/// `Y ‚àà \cS_S<S>` is an equivalence onto its image.
@framework(msfs, "MSFS Definition 4.2 ‚Äî Condition (ŒÝ_4, S, n)")
public axiom msfs_definition_4_2_pi_4(witness: &ConditionPi4) -> Bool
    requires witness.level() >= -1
    ensures  witness.is_irreducible_in_s_s();

/// MSFS Definition 4.3 ‚Äî Condition `(ŒÝ_{3-max,S,n})`. Every
/// sub-theory `F ‚àà \cF` admits an `(‚àû, n)`-functor `F ‚Üí X`
/// equivalent onto its image.
@framework(msfs, "MSFS Definition 4.3 ‚Äî Condition (ŒÝ_3-max, S, n)")
public axiom msfs_definition_4_3_pi_3_max(witness: &ConditionPi3Max) -> Bool
    requires witness.level() >= -1
    ensures  witness.is_maximally_generative();

/// MSFS Definition 4.4 ‚Äî `L_Abs` membership. `X ‚àà L_Abs` iff there
/// exist `S ‚àà \RS` and ordinal `n` such that `X` jointly satisfies
/// `(F_S) ‚àß (ŒÝ_{4,S,n}) ‚àß (ŒÝ_{3-max,S,n})`.
///
/// Definitionally vacuous *until* Theorem 5.1 (AFN-T Œ±-part) shows
/// the joint conjunction is internally inconsistent. The framework
/// axiom here records only the joint-membership requirement; the
/// emptiness corollary `msfs_L_abs_empty` lives in
/// `lib.math.strata` (cited from `theorems/msfs/05_afnt_alpha/`).
@framework(msfs, "MSFS Definition 4.4 ‚Äî L_Abs := { X : ‚àÉ(S, n). (F_S) ‚àß (ŒÝ_4) ‚àß (ŒÝ_3-max) }")
public axiom msfs_definition_4_4_l_abs(candidate: &LAbsCandidate) -> Bool
    ensures candidate.cond_F_S().has_iota_F()
         && candidate.cond_F_S().has_iota_F_star()
         && candidate.cond_F_S().has_phi_X()
         && candidate.cond_Pi_4().is_irreducible_in_s_s()
         && candidate.cond_Pi_3_max().is_maximally_generative();

// =============================================================================
// Bridge to Lemma 3.4
// =============================================================================

/// Operational bridge: (F_S) implies the hypothesis of Lemma 3.4
/// (formal S-definability). This is the key inferential link
/// driving Theorem 5.1's contradiction ‚Äî the joint-membership
/// witness of L_Abs immediately invokes Lemma 3.4 on its (F_S)
/// component, placing X in S_S<S> and contradicting (ŒÝ_4).
@framework(msfs, "MSFS ¬ß4 ‚Äî (F_S) ‚üπ formal S-definability (Lemma 3.4 hypothesis)")
public axiom msfs_f_s_implies_formal_s_definable(
    cond: &ConditionFS,
) -> &FormallySDefinable
    requires cond.has_phi_X()
    ensures  true;
