// =============================================================================
// MSFS — Absolute Layer: (F_S), (Π_4), (Π_3-max), and L_Abs
// =============================================================================
//
// Source: A. Sereda, MSFS preprint, §4 — Definitions 4.1–4.4.
//
// `L_Abs` is the bottom (= empty) stratum of the moduli space 𝔐 of
// formal systems. An object `X` inhabits `L_Abs` iff there exist a
// Rich-metatheory `S` and ordinal `n` such that `X` simultaneously
// satisfies *three* conditions:
//
//   • **(F_S)** — formally S-definable with an explicit sub-theory
//     inclusion ι_F : F ↪ S, an induced model reduct ι_F^*, and a
//     formula φ_X presenting X via Syn(F)[φ_X] ≃_(∞,n) X.
//
//   • **(Π_{4,S,n})** — irreducible: no (∞, n)-functor X → Y for any
//     Y in S_S<S> is an equivalence onto its image.
//
//   • **(Π_{3-max,S,n})** — maximally generative: for every sub-theory
//     F ∈ \cF there exists an (∞, n)-functor F → X that is an
//     equivalence onto its image.
//
// MSFS Theorem 5.1 (AFN-T α-part) shows the conjunction (F_S) ∧
// (Π_4) ∧ (Π_3-max) is internally inconsistent — `L_Abs == ∅`. This
// module installs the three conditions as protocol-level predicates
// plus the joint-membership axiom; the emptiness theorem itself
// lands in `theorems/msfs/05_afnt_alpha/`.
// =============================================================================

module core.math.absolute_layer;

mount core.math.strata.{MathObject};
mount core.math.s_definable.class_s_s.{SSMembership};
mount core.math.s_definable.lemma_3_4.{FormallySDefinable};

// =============================================================================
// Carrier protocols for the three conditions
// =============================================================================

/// Witness of MSFS Definition 4.1 — Condition `(F_S)`. The protocol
/// records the *existence* of (a) a sub-theory inclusion ι_F : F ↪
/// S, (b) the induced model reduct ι_F^* : Mod(S) → Mod(F), and (c)
/// a formula φ_X in F presenting X as a Syn(F)-object.
public type ConditionFS is protocol {
    /// (F-1) — sub-theory inclusion ι_F : F ↪ S exists.
    fn has_iota_F(self) -> Bool;

    /// (F-2) — induced model reduct ι_F^* : Mod(S) → Mod(F) exists.
    fn has_iota_F_star(self) -> Bool;

    /// (F-3) — syntactic presentation φ_X with
    /// `Syn(F)[φ_X] ≃_(∞,n) X` exists.
    fn has_phi_X(self) -> Bool;

    /// Bridge to formal-S-definability: Definition 4.1 strictly
    /// implies the formal-S-definability hypothesis of Lemma 3.4.
    fn formally_S_definable_witness(self) -> &FormallySDefinable;
};

/// Witness of MSFS Definition 4.2 — Condition `(Π_{4,S,n})`. The
/// object `X` is *irreducible* in `S_S<S>`: no (∞, n)-functor
/// `F : X → Y` with `Y ∈ S_S<S>` is an equivalence onto its image.
public type ConditionPi4 is protocol {
    /// Witness of irreducibility — no S_S-target-equivalence-onto-image.
    fn is_irreducible_in_s_s(self) -> Bool;

    /// The categorical level n at which the condition is asserted.
    fn level(self) -> Int;
};

/// Witness of MSFS Definition 4.3 — Condition `(Π_{3-max,S,n})`. The
/// object `X` is *maximally generative*: every sub-theory `F ∈ \cF`
/// admits an (∞, n)-functor `F → X` that is an equivalence onto its
/// image.
public type ConditionPi3Max is protocol {
    /// Witness of maximal generativity.
    fn is_maximally_generative(self) -> Bool;

    /// The categorical level n at which the condition is asserted.
    fn level(self) -> Int;
};

/// Joint witness of all three L_Abs conditions for a fixed (S, n).
public type LAbsCandidate is protocol {
    fn cond_F_S(self) -> &ConditionFS;
    fn cond_Pi_4(self) -> &ConditionPi4;
    fn cond_Pi_3_max(self) -> &ConditionPi3Max;
};

// =============================================================================
// Definitions 4.1–4.4
// =============================================================================

/// MSFS Definition 4.1 — Condition `(F_S)`. An object `X ∈ \cS_S<S>`
/// satisfies `(F_S)` iff there exist a sub-theory `\iota_F : F ↪ S`
/// with `F ∈ \cF`, the induced model reduct `\iota_F^* : Mod(S) →
/// Mod(F)`, and a formula `φ_X` in `F` such that `Syn(F)[φ_X]`
/// is `(∞, n)`-equivalent to `X`.
@framework(msfs, "MSFS Definition 4.1 — Condition (F_S)")
public axiom msfs_definition_4_1_f_s(witness: &ConditionFS) -> Bool
    requires witness.has_iota_F() && witness.has_iota_F_star() && witness.has_phi_X()
    ensures  witness.formally_S_definable_witness().has_phi_x_witness();

/// MSFS Definition 4.2 — Condition `(Π_{4,S,n})`. The object is
/// irreducible: no `(∞, n)`-functor `X → Y` for any
/// `Y ∈ \cS_S<S>` is an equivalence onto its image.
@framework(msfs, "MSFS Definition 4.2 — Condition (Π_4, S, n)")
public axiom msfs_definition_4_2_pi_4(witness: &ConditionPi4) -> Bool
    requires witness.level() >= -1
    ensures  witness.is_irreducible_in_s_s();

/// MSFS Definition 4.3 — Condition `(Π_{3-max,S,n})`. Every
/// sub-theory `F ∈ \cF` admits an `(∞, n)`-functor `F → X`
/// equivalent onto its image.
@framework(msfs, "MSFS Definition 4.3 — Condition (Π_3-max, S, n)")
public axiom msfs_definition_4_3_pi_3_max(witness: &ConditionPi3Max) -> Bool
    requires witness.level() >= -1
    ensures  witness.is_maximally_generative();

/// MSFS Definition 4.4 — `L_Abs` membership. `X ∈ L_Abs` iff there
/// exist `S ∈ \RS` and ordinal `n` such that `X` jointly satisfies
/// `(F_S) ∧ (Π_{4,S,n}) ∧ (Π_{3-max,S,n})`.
///
/// Definitionally vacuous *until* Theorem 5.1 (AFN-T α-part) shows
/// the joint conjunction is internally inconsistent. The framework
/// axiom here records only the joint-membership requirement; the
/// emptiness corollary `msfs_L_abs_empty` lives in
/// `lib.math.strata` (cited from `theorems/msfs/05_afnt_alpha/`).
@framework(msfs, "MSFS Definition 4.4 — L_Abs := { X : ∃(S, n). (F_S) ∧ (Π_4) ∧ (Π_3-max) }")
public axiom msfs_definition_4_4_l_abs(candidate: &LAbsCandidate) -> Bool
    ensures candidate.cond_F_S().has_iota_F()
         && candidate.cond_F_S().has_iota_F_star()
         && candidate.cond_F_S().has_phi_X()
         && candidate.cond_Pi_4().is_irreducible_in_s_s()
         && candidate.cond_Pi_3_max().is_maximally_generative();

// =============================================================================
// VVA §2.2 / §5 — Refinement-typed surface (M0.B demonstration)
// =============================================================================
//
// The protocol-typed `ConditionFS / ConditionPi4 / ConditionPi3Max`
// above use boolean accessor methods; their level / predicate state
// lives outside the type-level surface. M0.B introduces a parallel
// **refinement-typed** surface that lifts the level invariants into
// the type itself, exercising the K-Refine rule (VVA §4.4) and
// demonstrating Verum's inline refinement form (VVA §5).
//
// Why this matters for the corpus: with the refinement-typed surface
// active, the L_Abs candidate's level invariant `n >= -1` is checked
// at type-construction time rather than via a `requires` clause on
// every theorem. The kernel rejects ill-formed candidates *before*
// any theorem applies — ν=ω ν=ω+1 verifications never see negative
// levels.
//
// ## Inline form (VVA §5, three-form refinement)
//
//   `CategoricalLevel = Int{>= -1}`
//
// Reads as "Int whose value is at least -1". The kernel constructs
// `Refined(Int, x, x >= -1)` and K-Refine checks the depth invariant
// `dp(x >= -1) < dp(Int) + 1` (trivially: dp = 0 on both sides).
//
// ## Refined witness records — refinement on field type
//
//   `FSWitness    = { level: Int{>= -1}, ... }`
//   `Pi4Witness   = { level: Int{>= -1}, ... }`
//   `Pi3MaxWitness= { level: Int{>= -1}, ... }`
//
// Each constructor application checks `level` against the inline
// refinement; the type system rejects `Pi4Witness { level: -2, ... }`
// at the point of construction. Downstream theorems can drop the
// `level >= -1` requires clause that protocol-form theorems carried.

/// Categorical level for the L_Abs conditions — `n ∈ ℕ ∪ {-1}` per
/// MSFS Definition 4.2 / 4.3 footnote on the (∞, n)-Cat extension.
/// Inline refinement form (VVA §5): the predicate `it >= -1` is part
/// of the type identity and K-Refine-checked at construction.
public type CategoricalLevel is Int{>= -1};

/// Refinement-typed witness of (F_S). The `level` field carries the
/// inline-refined invariant `>= -1`; the boolean flags record the
/// three existence assertions of Definition 4.1.
public type FSWitness is {
    level: CategoricalLevel,
    has_iota_F: Bool,
    has_iota_F_star: Bool,
    has_phi_X: Bool,
};

/// Refinement-typed witness of (Π_4). Same level-refinement
/// discipline as `FSWitness`.
public type Pi4Witness is {
    level: CategoricalLevel,
    is_irreducible_in_s_s: Bool,
};

/// Refinement-typed witness of (Π_3-max). Same level-refinement
/// discipline as `FSWitness`.
public type Pi3MaxWitness is {
    level: CategoricalLevel,
    is_maximally_generative: Bool,
};

/// Joint refinement-typed L_Abs witness — the three condition
/// witnesses bundled. This is the canonical refinement form for
/// downstream theorems that want the type-level guarantee that all
/// component levels satisfy `n >= -1`.
public type RefinedLAbsWitness is {
    fs_witness: FSWitness,
    pi_4_witness: Pi4Witness,
    pi_3_max_witness: Pi3MaxWitness,
};

/// Pure predicate variant of (F_S) over a refinement-typed witness.
/// Extracts the three existence flags + S-definability bridge.
public pure fn fs_witness_predicate(w: &FSWitness) -> Bool {
    w.has_iota_F && w.has_iota_F_star && w.has_phi_X
}

/// Pure predicate variant of (Π_4) over a refinement-typed witness.
public pure fn pi_4_witness_predicate(w: &Pi4Witness) -> Bool {
    w.is_irreducible_in_s_s
}

/// Pure predicate variant of (Π_3-max) over a refinement-typed witness.
public pure fn pi_3_max_witness_predicate(w: &Pi3MaxWitness) -> Bool {
    w.is_maximally_generative
}

/// Joint condition predicate — the conjunction of the three component
/// predicates. Theorem 5.1 (AFN-T α-part) shows this is unsatisfiable
/// over any consistent (S, n).
public pure fn refined_l_abs_predicate(w: &RefinedLAbsWitness) -> Bool {
    fs_witness_predicate(&w.fs_witness)
        && pi_4_witness_predicate(&w.pi_4_witness)
        && pi_3_max_witness_predicate(&w.pi_3_max_witness)
}

/// **Refinement→protocol bridge — witness construction (M0.B-A).**
///
/// A `&RefinedLAbsWitness` saturating `refined_l_abs_predicate` projects
/// onto a protocol-form `&LAbsCandidate` whose three condition methods
/// already deliver the conjunction Theorem 5.1's `requires` clause
/// expects. The bridge is **shape translation only** — it asserts no
/// inferential content beyond the obvious correspondence between the
/// two surface forms (refined record fields ↔ protocol method results).
/// Theorem 5.1 itself remains the load-bearing argument that forecloses
/// any such candidate; the bridge merely translates the input format.
///
/// **Why an axiom and not a @theorem.** Constructing a `&LAbsCandidate`
/// from refinement-typed fields requires the kernel to allocate the
/// protocol-witness object, which sits beyond the propositional proof
/// DSL (same architectural class as `msfs_lemma_3_4_s_definability`).
/// When kernel V3 lands first-class refinement-to-protocol coercion
/// (T0.1 follow-up), this axiom is promoted to a @derive-style
/// generated implementation.
///
/// The pre-M0.7-A signature was `-> Bool ensures false` — i.e., the
/// bridge axiom itself directly delivered the goal of the
/// refinement-form theorem, making the @theorem statement vacuous (a
/// one-line `apply` against a tautological axiom). The current shape
/// makes the bridge a honest type-translator: it produces a candidate,
/// and the ensures asserts only the field-to-method correspondence.
@accessibility(omega_1)
@enact(epsilon = "ε_prove")
@framework(msfs, "MSFS §4 refinement bridge — RefinedLAbsWitness ⟹ LAbsCandidate (shape-translation, witness-constructor)")
public axiom msfs_refined_to_protocol_l_abs_bridge(
    w: &RefinedLAbsWitness,
) -> &LAbsCandidate
    requires refined_l_abs_predicate(w)
    ensures  result.cond_F_S().has_phi_X()
          && result.cond_Pi_4().is_irreducible_in_s_s()
          && result.cond_Pi_3_max().is_maximally_generative();

// =============================================================================
// Bridge to Lemma 3.4
// =============================================================================

/// Operational bridge: (F_S) implies the hypothesis of Lemma 3.4
/// (formal S-definability). This is the key inferential link
/// driving Theorem 5.1's contradiction — the joint-membership
/// witness of L_Abs immediately invokes Lemma 3.4 on its (F_S)
/// component, placing X in S_S<S> and contradicting (Π_4).
///
/// Postcondition load-bearing: the returned `&FormallySDefinable`
/// satisfies `has_phi_x_witness()`, which is *exactly* the precondition
/// of `msfs_lemma_3_4_s_definability` and `msfs_lemma_3_4_outputs_in_s_s_global`.
/// Without this stronger ensures the bridge would deliver a witness the
/// kernel cannot feed into Lemma 3.4 — Theorem 5.1's structured proof
/// would have to re-axiomatise the property at the call site.
@accessibility(omega_1)
@enact(epsilon = "ε_prove")
@framework(msfs, "MSFS §4 — (F_S) ⟹ formal S-definability (Lemma 3.4 hypothesis)")
public axiom msfs_f_s_implies_formal_s_definable(
    cond: &ConditionFS,
) -> &FormallySDefinable
    requires cond.has_phi_X()
    ensures  result.has_phi_x_witness();

// =============================================================================
// Step-2 intermediate axiom for Theorem 5.1's structured proof body
// =============================================================================
//
// Theorem 5.1's paper proof (paper §5, single paragraph):
//
//   Assume X satisfies (F_S) ∧ (Π_{4, S, n}). Then X ∈ S_S^global ⊆ S_S
//   by Lemma 3.4, and id_X : X → X is an (∞, n)-equivalence onto its
//   image with target in S_S, violating (Π_{4, S, n}).
//
// The proof has three logical steps:
//
//   Step 1 — apply Lemma 3.4 to (F_S) ⟹ SSMembership witness in S_S^global.
//   Step 2 — the identity morphism id_X : X → X is an (∞, n)-equivalence
//            onto its image; combined with the Step-1 SSMembership witness,
//            the existence of (Y := X) ∈ S_S<S> + (F := id_X) :
//            (∞, n)-equivalence onto image *contradicts* (Π_{4, S, n}).
//   Step 3 — contradiction propagates to the joint conjunction.
//
// Steps 1 and 3 are mechanical apply / propositional unfolding. Step 2
// is the (∞, n)-equivalence reasoning that requires kernel-V3 infra
// (T0.1). For the M0.7 structured-proof phase, we capture step 2 as
// the intermediate axiom below — when T0.1 lands, this axiom is
// promoted to a `@theorem` with its own proof body and the chain
// becomes fully machine-verified.

/// **Step-2 intermediate** for Theorem 5.1's structured proof.
///
/// Given:
///   * `candidate: &LAbsCandidate` satisfying (F_S) ∧ (Π_4) (the
///     Theorem 5.1 hypotheses), and
///   * `ss_witness: &SSMembership` placing the candidate's underlying
///     X in S_S^global ⊆ S_S — produced by `msfs_lemma_3_4_s_definability`
///     (constructor) and certified by `msfs_lemma_3_4_outputs_in_s_s_global`
///     (operational @theorem) at the call site,
///
/// the identity morphism `id_X : X → X` is an `(∞, n)`-equivalence
/// onto its image with target Y := X ∈ S_S<S>, *which is exactly the
/// pattern that (Π_{4, S, n}) forbids*. Hence `false`.
///
/// **Architectural note (M0.7-A).** The signature here consumes the
/// concrete S_S^global membership predicate — `is_in_s_s_global() &&
/// closure_depth() >= 1` — rather than only the formal-S-definability
/// witness. This makes the kernel-recheck trail honest: Theorem 5.1's
/// proof body must produce an SSMembership AND discharge the Lemma 3.4
/// operational corollary BEFORE the Π_4-violation step can fire. The
/// pre-M0.7-A signature trivially accepted any FormallySDefinable
/// witness without ever observing the S_S-membership content that the
/// paper proof's "id_X has target in S_S" depends on.
///
/// **Soundness scope.** This axiom captures step 2 of the paper proof
/// verbatim. The (∞, n)-equivalence reasoning is the kernel-V3
/// infrastructure tracked under T0.1; once that lands, this axiom is
/// promoted to a `@theorem` with a constructive proof body invoking
/// the kernel's `(∞, n)`-equivalence introduction rule. Until then it
/// is an honest paper-cited axiom — the inference Theorem 5.1
/// reduces to "Lemma 3.4 + this axiom + propositional contradiction",
/// and *both* lemma-applications appear in the call chain.
/// **Kernel-discharged** via Whitehead-promote at level n + n-truncation
/// for level descent.  The two-intrinsic discharge surfaces the empty
/// `BridgeAudit` invariant of `verum_kernel::whitehead::whitehead_promote`
/// (no preprint admit) plus the level-descent step from
/// `verum_kernel::truncation::truncate_to_level`.  Both are
/// machine-checked by `verum audit --kernel-discharged-axioms`.
@accessibility(omega_1)
@enact(epsilon = "ε_prove")
@framework(msfs, "MSFS Theorem 5.1 step 2 — id_X is (∞,n)-equivalence onto image with target in S_S^global, violating (Π_4)")
@kernel_discharge("kernel_whitehead_promote_strict")
@kernel_discharge("kernel_truncate_to_level_strict")
public axiom msfs_id_x_violates_pi_4(
    candidate: &LAbsCandidate,
    ss_witness: &SSMembership,
) -> Bool
    requires candidate.cond_F_S().has_phi_X()
          && candidate.cond_Pi_4().is_irreducible_in_s_s()
          && ss_witness.is_in_s_s_global()
          && ss_witness.closure_depth() >= 1
    ensures false;
