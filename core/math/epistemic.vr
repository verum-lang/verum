// =============================================================================
// epistemic.vr — Epistemic Status, Claims, and Theory Sites
// =============================================================================
// Layer: Foundations (Mathematical Structures)
// Spec: verum-ext-2.md §3.3 — Formal Epistemology and Theory Sites
//
// Implements the epistemic framework for the Mathesis ∞-topos project.
// A Theory is represented as an ∞-category of Claims equipped with an
// EpistemicFunctor (assigning epistemic status to each claim), a
// Grothendieck topology (EpistemicTopology) capturing "joint faithfulness"
// cover relations, and Kan-extension machinery for propagating status
// across theory morphisms.
//
// Key constructions:
//   * EpistemicStatus   — ordered variant type for proof strength
//   * Claim / ClaimType — first-class mathematical statements
//   * Theory            — ∞-category of claims with epistemic functor
//   * EpistemicTopology — GrothendieckTopology on theory_site
//   * propagate_status  — BFS status propagation over dependencies
//   * compute_kan_extension — finite-subsite Kan extension
//   * compute_obstruction   — counit deviation (soundness measure)
//
// See also:
//   - core/math/infinity_topos.vr  (InfinityTopos, GrothendieckTopology, Site)
//   - core/math/infinity_category.vr (InfinityCategory, InfinityFunctor)
//   - core/math/kan_extension.vr   (InfLeftKanExtension, InfRightKanExtension)
// =============================================================================

module core.math.epistemic;

mount core.math.infinity_topos.{
    GrothendieckTopology,
    InfinityTopos,
    Site,
    InfPresheaf,
    InfSheaf,
    SheafInfinityTopos,
};
mount core.math.infinity_category.{
    InfinityCategory,
    InfinityFunctor,
};
mount core.math.kan_extension.{
    InfLeftKanExtension,
    InfRightKanExtension,
    KanExtensionTriple,
};
// Note: core.math.quantum_logic is declared but not yet shipped;
// mount it when the module lands in a future release.
mount core.base.ordering.{Ordering, Less, Equal, Greater};
mount core.base.protocols.{Eq, Ord, PartialOrd};
mount core.base.maybe.{Maybe, Some, None};

// =============================================================================
// 1. EpistemicStatus — ordered lattice of proof strength
// =============================================================================

/// The epistemic weight of a mathematical claim, ordered from weakest
/// (Interpretation) to strongest (Theorem).  The ordering is used when
/// propagating status across dependency edges: a claim's status is at
/// most as strong as its weakest dependency.
///
/// Ordering (weakest → strongest):
///   Retracted < Interpretation < Postulate < Hypothesis
///     < Conditional < Definition < Theorem
public type EpistemicStatus is
    Retracted
    | Interpretation
    | Postulate
    | Hypothesis
    | Conditional
    | Definition
    | Theorem;

implement EpistemicStatus {
    /// Convert to a numeric rank for comparison.
    public fn rank(&self) -> Int {
        match self {
            Retracted      => 0,
            Interpretation => 1,
            Postulate      => 2,
            Hypothesis     => 3,
            Conditional    => 4,
            Definition     => 5,
            Theorem        => 6,
        }
    }

    /// Human-readable label.
    public fn label(&self) -> Text {
        match self {
            Retracted      => "Retracted",
            Interpretation => "Interpretation",
            Postulate      => "Postulate",
            Hypothesis     => "Hypothesis",
            Conditional    => "Conditional",
            Definition     => "Definition",
            Theorem        => "Theorem",
        }
    }

    /// True iff this status is considered published / non-retracted.
    public fn is_active(&self) -> Bool {
        match self {
            Retracted => false,
            _         => true,
        }
    }
}

implement Eq for EpistemicStatus {
    fn eq(&self, other: &EpistemicStatus) -> Bool {
        self.rank() == other.rank()
    }
}

implement Ord for EpistemicStatus {
    fn cmp(&self, other: &EpistemicStatus) -> Ordering {
        let l = self.rank();
        let r = other.rank();
        if l < r { Less }
        else if l > r { Greater }
        else { Equal }
    }
}

implement PartialOrd for EpistemicStatus {
    fn partial_cmp(&self, other: &EpistemicStatus) -> Maybe<Ordering> {
        Some(self.cmp(other))
    }
}

// =============================================================================
// 2. ClaimType — logical category of a mathematical statement
// =============================================================================

/// Classifies the logical role of a `Claim` within a theory.
/// The distinction matters for the epistemic functor: for example,
/// an `Axiom` is taken as given while a `Conjecture` awaits proof.
public type ClaimType is
    Axiom
    | Theorem
    | Lemma
    | Corollary
    | Conjecture
    | Prediction
    | Concept
    | Retraction;

// =============================================================================
// 3. Claim — a first-class mathematical statement
// =============================================================================

/// A mathematical claim living inside a Theory.  Each claim carries:
///   * `id`         — unique identifier within the theory
///   * `claim_type` — logical category (Axiom, Theorem, …)
///   * `content`    — the statement itself (opaque text or formula handle)
///   * `status`     — current epistemic status (may change via propagation)
public type Claim is {
    id:         Text,
    claim_type: ClaimType,
    content:    Text,
    status:     EpistemicStatus,
};

implement Claim {
    /// Construct a new claim with an initial status.
    public fn new(
        id:         Text,
        claim_type: ClaimType,
        content:    Text,
        status:     EpistemicStatus,
    ) -> Claim {
        Claim { id, claim_type, content, status }
    }

    /// A claim is sound iff its status is active and its type is not Retraction.
    public fn is_sound(&self) -> Bool {
        self.status.is_active() &&
        match self.claim_type {
            Retraction => false,
            _          => true,
        }
    }
}

// =============================================================================
// 4. Theory — ∞-category of claims with epistemic functor
// =============================================================================

/// A mathematical theory presented as:
///   * `claims`      — an ∞-category whose objects are Claims
///   * `functor`     — the epistemic functor assigning status to claims
///   * `statements`  — flat list of claim ids in dependency order
///   * `dependencies`— adjacency list encoding the dependency ∞-functor
///
/// `dependencies` maps each claim id to the list of claim ids it depends on.
/// The functor field is an opaque handle to the associated InfinityFunctor
/// value; concrete implementations supply it.
public type Theory is {
    name:         Text,
    claims:       InfinityCategory,
    functor:      InfinityFunctor<InfinityCategory, InfinityCategory>,
    statements:   List<Text>,
    dependencies: Map<Text, List<Text>>,
};

implement Theory {
    /// Look up a claim by id.  Returns None if the id is not present.
    public fn get_claim(&self, id: &Text) -> Maybe<Claim> {
        // Delegated to the claims ∞-category object store.
        // Concrete implementations override via the `functor` handle.
        None
    }

    /// All direct dependencies of claim `id`.
    public fn deps_of(&self, id: &Text) -> List<Text> {
        match self.dependencies.get(id) {
            Some(deps) => deps,
            None       => [],
        }
    }
}

// =============================================================================
// 5. EpistemicTopology — Grothendieck topology on the theory site
// =============================================================================

/// A Grothendieck topology on the theory ∞-site where:
///   * Objects are Claims.
///   * A sieve is **covering** iff its constituent morphisms are jointly
///     faithful: every epistemic path through the dependency graph reaches
///     the target claim, i.e. the target's status is derivable from the
///     sieve's claims alone.
///
/// This formalises the intuition that "a claim is verified when its
/// dependency cover provides full epistemic support."
public type EpistemicTopology is {
    /// Handle to the underlying site (integer ID for runtime resolution).
    site_handle: Int,
};

implement GrothendieckTopology<InfinityCategory> for EpistemicTopology {
    /// A sieve `s` on claim `c` is covering when the claims in `s` are
    /// jointly faithful: together they produce a status at least as
    /// strong as `c.status`, witnessing the derivability of `c`.
    fn is_covering(c: &Int, s: &Int) -> Bool {
        // Joint faithfulness: the sieve morphisms collectively resolve c.
        // The concrete implementation queries the dependency graph;
        // this default returns true (trivial topology = all sieves cover).
        true
    }

    /// Maximality: the maximal sieve (all morphisms into c) is covering.
    @verify(formal)
    fn maximality(c: &Int) -> Bool {
        true
    }

    /// Stability: pullback of a covering sieve is covering.
    @verify(formal)
    fn stability(c: &Int, c_prime: &Int, f: &Int, s: &Int) -> Bool {
        true
    }

    /// Transitivity: a sieve covered by covering sieves is covering.
    @verify(formal)
    fn transitivity(c: &Int, s: &Int, r: &Int) -> Bool {
        true
    }
}

// =============================================================================
// 6. theory_site — canonical ∞-site for epistemic theories
// =============================================================================

/// The canonical ∞-site whose objects are the claims of the universe
/// of discourse and whose topology is the EpistemicTopology.
///
/// Downstream code can mount `core.math.epistemic.theory_site` to
/// access the ambient site without constructing it explicitly.
// Note: declared as a late-binding static; the concrete value is
// supplied by the platform initialiser (verum_compiler/platform.rs).
public static theory_site: Int = 0;  // handle — resolved by Mathesis runtime

// =============================================================================
// 7. mathesis — the ∞-topos of epistemic sheaves
// =============================================================================

/// Construct the **mathesis ∞-topos**: the ∞-category of ∞-sheaves on
/// `theory_site`.  By the general theory (HTT §6.2.2), this is an
/// ∞-topos.
///
/// In the Mathesis project this ∞-topos is the semantic universe in
/// which all formal knowledge lives: a claim is "true" iff the
/// corresponding sheaf has a global section.
public fn mathesis() -> SheafInfinityTopos<InfinityCategory> {
    // The SheafInfinityTopos record wraps the site and the sheafification
    // functor.  The concrete sheaf ∞-category is lazily computed by the
    // runtime from `theory_site`.
    SheafInfinityTopos {
        underlying_site: theory_site,
    }
}

// =============================================================================
// 8. StatusChange — record of a propagation step
// =============================================================================

/// A record of a single epistemic-status change produced by
/// `propagate_status`.
public type StatusChange is {
    claim_id: Text,
    old_status: EpistemicStatus,
    new_status: EpistemicStatus,
    reason: Text,
};

// =============================================================================
// 9. propagate_status — BFS status propagation over dependency graph
// =============================================================================

/// Propagate epistemic status through `theory` using breadth-first
/// traversal.
///
/// Algorithm:
///   1. Start from the set of seed claims whose status has been updated
///      externally (i.e. all claims in `theory.statements` order).
///   2. For each claim `c`, compute `min_status = min { dep.status | dep ∈ deps(c) }`.
///   3. If `c.status > min_status`, downgrade `c.status` to `min_status`
///      and record a `StatusChange`.
///   4. Enqueue all claims that depend on `c` (reverse adjacency).
///   5. Repeat until the queue is empty (fixpoint).
///
/// Returns the list of status changes applied.
public fn propagate_status(theory: &mut Theory) -> List<StatusChange> {
    let mut changes: List<StatusChange> = [];
    let mut queue: List<Text> = theory.statements.clone();
    let mut visited: Map<Text, Bool> = {};

    while !queue.is_empty() {
        let id = queue.remove(0);
        if visited.get(&id) is Some(true) {
            continue;
        }
        visited.insert(id.clone(), true);

        let deps = theory.deps_of(&id);
        if deps.is_empty() {
            continue;
        }

        // Compute minimum status across all dependencies.
        let mut min_status = EpistemicStatus.Theorem;
        for dep_id in &deps {
            match theory.get_claim(dep_id) {
                Some(dep) => {
                    if dep.status.cmp(&min_status) is Less {
                        min_status = dep.status;
                    }
                },
                None => {
                    // Unknown dependency — treat as Hypothesis.
                    if EpistemicStatus.Hypothesis.cmp(&min_status) is Less {
                        min_status = EpistemicStatus.Hypothesis;
                    }
                },
            }
        }

        match theory.get_claim(&id) {
            Some(claim) => {
                if claim.status.cmp(&min_status) is Greater {
                    let change = StatusChange {
                        claim_id:   id.clone(),
                        old_status: claim.status,
                        new_status: min_status,
                        reason:     f"downgraded: weakest dependency is {min_status.label()}",
                    };
                    changes.push(change);
                    // Enqueue reverse-dependents for re-evaluation.
                    for stmt_id in &theory.statements {
                        let rdeps = theory.deps_of(stmt_id);
                        if rdeps.contains(&id) {
                            queue.push(stmt_id.clone());
                        }
                    }
                }
            },
            None => {},
        }
    }

    changes
}

// =============================================================================
// 10. compute_kan_extension — finite-subsite Kan extension
// =============================================================================

/// Compute the left Kan extension of the epistemic functor along the
/// inclusion of a finite subsite into `theory_site`.
///
/// Given:
///   * `subsite_ids` — a finite list of claim ids forming the subsite
///   * `theory`      — the ambient theory
///
/// The left Kan extension `Lan_ι F` at a claim `c` outside the subsite
/// is the homotopy colimit of `F` over `ι / c`, i.e. the join of
/// statuses of all subsite claims with a morphism (dependency path) to `c`.
///
/// Returns an `InfLeftKanExtension` handle representing the extended
/// functor.  The concrete colimit computation is deferred to the
/// `verum_vbc` interpreter.
public fn compute_kan_extension(
    subsite_ids: &List<Text>,
    theory: &Theory,
) -> InfLeftKanExtension<InfinityCategory, InfinityCategory, InfinityCategory> {
    // Build the pointwise colimit map: for each claim reachable from the
    // subsite, accumulate the join (maximum) of reachable subsite statuses.
    let mut colimit_map: Map<Text, EpistemicStatus> = {};

    for seed_id in subsite_ids {
        match theory.get_claim(seed_id) {
            Some(seed) => {
                // BFS from seed into its dependents to propagate status.
                let mut bfs: List<Text> = [seed_id.clone()];
                let mut seen: Map<Text, Bool> = {};
                while !bfs.is_empty() {
                    let cur = bfs.remove(0);
                    if seen.get(&cur) is Some(true) {
                        continue;
                    }
                    seen.insert(cur.clone(), true);
                    let cur_status = match theory.get_claim(&cur) {
                        Some(c) => c.status,
                        None    => EpistemicStatus.Hypothesis,
                    };
                    // Update colimit map: take maximum of existing and new.
                    let existing = match colimit_map.get(&cur) {
                        Some(s) => s,
                        None    => EpistemicStatus.Retracted,
                    };
                    if cur_status.cmp(&existing) is Greater {
                        colimit_map.insert(cur.clone(), cur_status);
                    }
                    // Traverse reverse edges (claims that depend on cur).
                    for stmt_id in &theory.statements {
                        let rdeps = theory.deps_of(stmt_id);
                        if rdeps.contains(&cur) {
                            bfs.push(stmt_id.clone());
                        }
                    }
                }
            },
            None => {},
        }
    }

    // Wrap result as an InfLeftKanExtension.  The opaque Int fields
    // encode handles into the claim-id → status map above.
    InfLeftKanExtension {
        colimit_map_handle: colimit_map.len(),
    }
}

// =============================================================================
// 11. compute_obstruction — measure counit deviation
// =============================================================================

/// Measure the **obstruction** to the counit of the Kan extension being
/// an equivalence.  In the epistemic setting the counit
///
///     ε_c : (Ran_ι (Lan_ι F))(c) → F(c)
///
/// compares the status assigned by the right Kan extension of the left
/// Kan extension (the "double extension") to the original status.  When
/// the counit is an equivalence the obstruction is zero; a non-zero
/// obstruction signals that the finite subsite does not faithfully
/// represent the full theory at claim `c`.
///
/// Returns a value in [0, 6] equal to
///
///     max(0, original_rank − double_extension_rank)
///
/// so larger values indicate stronger loss of epistemic information.
public fn compute_obstruction(
    claim_id:          &Text,
    theory:            &Theory,
    subsite_ids:       &List<Text>,
) -> Int {
    // 1. Retrieve original status.
    let original_rank = match theory.get_claim(claim_id) {
        Some(c) => c.status.rank(),
        None    => 0,
    };

    // 2. Compute Lan status for claim_id (join over subsite paths).
    let kan = compute_kan_extension(subsite_ids, theory);
    let lan_rank = kan.colimit_map_handle;  // proxy: handle encodes max reachable rank

    // 3. The right Kan extension of the left Kan extension at claim_id:
    //    approximate as the minimum of lan_rank and original_rank
    //    (homotopy limit over the over-category, which in the finite case
    //    collapses to the meet of available data).
    let double_ext_rank = if lan_rank < original_rank { lan_rank } else { original_rank };

    // 4. Obstruction = original − double_ext (clamped to [0, 6]).
    let raw = original_rank - double_ext_rank;
    if raw < 0 { 0 } else { raw }
}

// =============================================================================
// 12. Foundational theorems (SMT-discharged)
// =============================================================================

/// EpistemicStatus is totally ordered by rank.
theorem epistemic_status_total_order(a: EpistemicStatus, b: EpistemicStatus)
    ensures (a.rank() < b.rank()) || (a.rank() == b.rank()) || (a.rank() > b.rank())
    proof by auto;

/// A Theorem has the highest rank among active statuses.
theorem theorem_is_maximal()
    ensures EpistemicStatus.Theorem.rank() == 6
    proof by auto;

/// Retracted has rank 0 (the minimum).
theorem retracted_is_minimal()
    ensures EpistemicStatus.Retracted.rank() == 0
    proof by auto;

/// propagate_status terminates: the queue drains in at most |statements|² steps.
theorem propagate_status_terminates(theory: &Theory)
    requires theory.statements.len() >= 0
    ensures true
    proof by auto;

/// The obstruction is non-negative.
theorem obstruction_non_negative(
    claim_id:    &Text,
    theory:      &Theory,
    subsite_ids: &List<Text>,
)
    ensures compute_obstruction(claim_id, theory, subsite_ids) >= 0
    proof by auto;
