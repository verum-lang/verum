// =============================================================================
// day_convolution.vr — Day Convolution and Cognitive Extension
// =============================================================================
// Layer: Foundations (Mathematical Structures)
// Spec: Day "On closed categories of functors" (1970),
//       Loregian "This is the (co)end, my only (co)friend",
//       verum-ext-2.md §3.5 (cognitive extension via Day convolution)
//
// **Day convolution** gives the presheaf category PSh(V) = [V^op, Set]
// a symmetric monoidal structure when the base category V is itself a
// small symmetric monoidal category.  The tensor product of two
// presheaves F, G : V^op → Set is the coend
//
//     (F ⊗_Day G)(c) = ∫^{a,b : V} V(a ⊗ b, c) × F(a) × G(b)
//
// Concretely, this is computed as the set of *factorization triples*
//
//     { (a, b, mor : a ⊗ b → c, fa : F(a), gb : G(b)) } / ~
//
// where ~ identifies two triples when they are related by re-indexing
// along a morphism in V (the coend coequalization).
//
// This turns [V^op, Set] into a symmetric monoidal category.  The
// monoidal unit is the Yoneda presheaf y(e) = V(–, e) where e is the
// monoidal unit of V.
//
// ## Cognitive extension (verum-ext-2.md §3.5)
//
// The Mathesis cognitive architecture fuses the biological information
// channel H_bio (sensory–hippocampal memory) with the mechanical
// channel H_M (abstract mathematical structure) via Day convolution:
//
//     H_ext = H_bio ⊗_Day H_M
//
// The coend formula is the formal definition: at each cognitive
// "object" c (a conceptual type / attention context), the fused
// representation is the colimit over all factorings a ⊗ b → c of the
// paired biological–mechanical states F(a) × G(b), weighted by the
// structural morphisms of the base category.
//
// See also:
//   - core/math/category.vr            (MonoidalCategory, SymmetricMonoidalCategory)
//   - core/math/infinity_category.vr   (InfinityCategory, InfinityFunctor)
//   - core/math/kan_extension.vr       (coend as a Kan extension)
// =============================================================================

module core.math.day_convolution;

mount core.math.category.{
    Category,
    Functor,
    MonoidalCategory,
    SymmetricMonoidalCategory,
    NaturalTransformation,
    NaturalIsomorphism,
};
mount core.math.infinity_category.{
    InfinityCategory,
    InfinityFunctor,
    FunctorInfCategory,
};

// =============================================================================
// 1. SymmetricMonoidalCategory protocol (full coherence data)
// =============================================================================
//
// `core.math.category` already exports the base `SymmetricMonoidalCategory<C>`
// with tensor, unit, associator, left/right unitors, braiding, pentagon,
// triangle and hexagon.  Here we introduce a *refined* version that makes
// all coherence axioms explicit as `@verify(formal)` obligations and exposes
// the unit object as a callable accessor, so that the Day convolution unit
// (Yoneda at e) can be stated precisely.
//
// The name `SmcFull` ("full SMC data") avoids name collision with the
// 1-categorical version already in scope.

/// Full symmetric monoidal category with explicit coherence obligations.
///
/// Extends `SymmetricMonoidalCategory<C>` from `core.math.category` and
/// adds verified versions of all five Mac Lane coherence diagrams.
public type SmcFull<C: Category<Int, Int>> is protocol
    extends SymmetricMonoidalCategory<C>
{
    // --- structural data ---------------------------------------------------

    /// The monoidal unit object e : C.
    fn unit_object(&self) -> Int;

    /// Tensor of objects: a ⊗ b.
    fn tensor_obj(a: &Int, b: &Int) -> Int;

    /// Tensor of morphisms: f ⊗ g.
    fn tensor_mor(f: &Int, g: &Int) -> Int;

    /// Associator α_{a,b,c} : (a ⊗ b) ⊗ c → a ⊗ (b ⊗ c).
    fn associator(a: &Int, b: &Int, c: &Int) -> Int;

    /// Left unitor λ_a : e ⊗ a → a.
    fn left_unitor(a: &Int) -> Int;

    /// Right unitor ρ_a : a ⊗ e → a.
    fn right_unitor(a: &Int) -> Int;

    /// Braiding β_{a,b} : a ⊗ b → b ⊗ a.
    fn braiding(a: &Int, b: &Int) -> Int;

    // --- hom-set accessor --------------------------------------------------

    /// The hom-set V(a, b) represented as a list of morphism handles.
    fn hom(a: &Int, b: &Int) -> List<Int>;

    /// All objects of the category (finite / computable).
    fn objects(&self) -> List<Int>;

    // --- coherence axioms --------------------------------------------------

    /// Pentagon coherence:
    ///   α_{a⊗b,c,d} . α_{a,b,c⊗d}
    ///   = (id_a ⊗ α_{b,c,d}) . α_{a,b⊗c,d} . (α_{a,b,c} ⊗ id_d)
    @verify(formal)
    fn pentagon_coherence(a: &Int, b: &Int, c: &Int, d: &Int) -> Bool;

    /// Triangle coherence:
    ///   (id_a ⊗ λ_b) . α_{a,e,b} = ρ_a ⊗ id_b
    @verify(formal)
    fn triangle_coherence(a: &Int, b: &Int) -> Bool;

    /// Hexagon coherence (first):
    ///   α_{b,c,a} . β_{a,b⊗c} . α_{a,b,c}
    ///   = (id_b ⊗ β_{a,c}) . α_{b,a,c} . (β_{a,b} ⊗ id_c)
    @verify(formal)
    fn hexagon_coherence_1(a: &Int, b: &Int, c: &Int) -> Bool;

    /// Hexagon coherence (second):
    ///   α⁻¹_{c,a,b} . β_{a⊗b,c} . α⁻¹_{a,b,c}
    ///   = (β_{a,c} ⊗ id_b) . α⁻¹_{a,c,b} . (id_a ⊗ β_{b,c})
    @verify(formal)
    fn hexagon_coherence_2(a: &Int, b: &Int, c: &Int) -> Bool;

    /// Braiding involution: β_{b,a} ∘ β_{a,b} = id_{a⊗b}.
    @verify(formal)
    fn braiding_involution(a: &Int, b: &Int) -> Bool;
};

// =============================================================================
// 2. Presheaf type — a functor V^op → Set
// =============================================================================
//
// A presheaf F on V assigns:
//   * To each object c : V    a set F(c)       (the "sections at c")
//   * To each morphism f : a → b in V  a restriction map F(f) : F(b) → F(a)
//     (contravariant: f goes a→b, so restriction goes F(b)→F(a))
//
// Functoriality: F(id) = id and F(g ∘ f) = F(f) ∘ F(g).
//
// Here we represent sections as handles (Int), and restriction as a
// function from a morphism handle and a section handle to a new section
// handle.  Concrete presheaves are given by implementing `PresheafImpl`.

/// A presheaf on V: a contravariant functor V^op → Set.
///
/// `sections(c)` is the set (represented as handle) of sections over c.
/// `restrict(f, s)` pulls back a section s over target(f) to one over source(f).
public type Presheaf<V: SmcFull<Int>> is {
    /// The section-set at object c, as a handle encoding the type/set.
    sections: fn(c: Int) -> Int,

    /// Restriction map: given f : a → b and s ∈ F(b), produce F(f)(s) ∈ F(a).
    restrict: fn(f: Int, s: Int) -> Int,

    /// Functoriality: F(id_c)(s) = s  (identity preservation).
    @verify(formal)
    functoriality_id: fn(c: Int, s: Int) -> Bool,

    /// Functoriality: F(g ∘ f)(s) = F(f)(F(g)(s))  (composition preservation).
    @verify(formal)
    functoriality_comp: fn(f: Int, g: Int, s: Int) -> Bool,
};

// =============================================================================
// 3. Factorization triple — witness for the coend formula
// =============================================================================
//
// A *factorization triple* for c ∈ V under presheaves F and G is a tuple
//
//     (a : V, b : V, mor : a ⊗ b → c, fa : F(a), gb : G(b))
//
// The coend (F ⊗_Day G)(c) is the *quotient* of the set of all such
// triples by the coend coequalization relation:
//
//   (a, b, (f ⊗ g) ; mor, fa, gb)  ~  (a', b', mor', F(f)(fa), G(g)(gb))
//
// In a finite / computable category we enumerate all factorizations.

/// A single factorization triple witnessing that a ⊗ b maps into c.
public type FactorizationTriple is {
    /// The first factor object a.
    obj_a: Int,
    /// The second factor object b.
    obj_b: Int,
    /// Morphism handle for  mor : a ⊗ b → c.
    mor: Int,
    /// Section fa ∈ F(a), encoded as a handle.
    fa: Int,
    /// Section gb ∈ G(b), encoded as a handle.
    gb: Int,
};

/// Build a factorization triple from its five components.
public fn factorization(
    a: Int, b: Int,
    mor: Int,
    fa: Int, gb: Int,
) -> FactorizationTriple {
    FactorizationTriple {
        obj_a: a,
        obj_b: b,
        mor:   mor,
        fa:    fa,
        gb:    gb,
    }
}

// =============================================================================
// 4. Day Convolution — the coend
// =============================================================================
//
// (F ⊗_Day G)(c) = ∫^{a,b} V(a ⊗ b, c) × F(a) × G(b)
//
// Computed on finite V as: collect all factorization triples (a, b, mor)
// and pair them with sections fa : F(a) and gb : G(b).
//
// The result type is a list of `FactorizationTriple`; the actual coend
// value is this list *modulo* the coequalization relation.  For a
// concrete implementation, the caller can further quotient or use the
// list directly as a free colimit presentation.

/// The Day convolution data for a pair of presheaves F, G on V.
public type DayConvolution<V: SmcFull<Int>> is {
    /// Handle identifying the base symmetric monoidal category V.
    base_cat: Int,
    /// The first presheaf F.
    presheaf_f: Presheaf<V>,
    /// The second presheaf G.
    presheaf_g: Presheaf<V>,
};

/// Build a Day convolution record.
public fn day_conv<V: SmcFull<Int>>(
    base: Int,
    f: Presheaf<V>,
    g: Presheaf<V>,
) -> DayConvolution<V> {
    DayConvolution {
        base_cat:    base,
        presheaf_f:  f,
        presheaf_g:  g,
    }
}

/// Compute (F ⊗_Day G)(c) on a *finite* category V.
///
/// Returns the list of all factorization triples
///
///   { (a, b, mor : a ⊗ b → c, fa ∈ F(a), gb ∈ G(b)) }
///
/// This is a free presentation of the coend; the coend proper is the
/// quotient by the coequalization relation (which collapses triples
/// related by re-indexing morphisms in V).
///
/// Parameters:
///   conv   — the Day convolution data (base category + F + G)
///   cat    — the concrete SmcFull instance (needed for objects/hom)
///   c      — the target object at which to evaluate
///   sections_f — a function mapping each object a to a list of F(a) handles
///   sections_g — a function mapping each object b to a list of G(b) handles
public fn convolve<V: SmcFull<Int>>(
    conv: &DayConvolution<V>,
    cat: &V,
    c: Int,
    sections_f: fn(Int) -> List<Int>,
    sections_g: fn(Int) -> List<Int>,
) -> List<FactorizationTriple> {
    let mut result: List<FactorizationTriple> = List.new();
    let objs: List<Int> = cat.objects();

    // Enumerate all pairs (a, b) of objects
    for a in objs {
        for b in objs {
            let tensor_ab: Int = cat.tensor_obj(&a, &b);
            // All morphisms tensor_ab → c
            let mors: List<Int> = cat.hom(&tensor_ab, &c);
            for mor in mors {
                // Pair with all sections fa ∈ F(a) and gb ∈ G(b)
                let fas: List<Int> = sections_f(a);
                let gbs: List<Int> = sections_g(b);
                for fa in fas {
                    for gb in gbs {
                        let triple: FactorizationTriple =
                            factorization(a, b, mor, fa, gb);
                        result = result.push(triple);
                    }
                }
            }
        }
    }
    result
}

// =============================================================================
// 5. Yoneda presheaf — monoidal unit of Day convolution
// =============================================================================
//
// The monoidal unit for the Day convolution tensor product on [V^op, Set]
// is the *Yoneda presheaf* at the monoidal unit e of V:
//
//     y(e)(c) = V(c, e)          (the hom-set from c to e)
//
// Restriction along f : a → b acts by precomposition:
//
//     y(e).restrict(f, mor) = mor ∘ f
//
// Here morphism composition is encoded at the handle level.

/// The Yoneda presheaf y(e) : V^op → Set.
///
/// y(e)(c) = V(c, e)  — representable presheaf at the unit object e.
public type YonedaPresheaf<V: SmcFull<Int>> is {
    /// The representing object (= monoidal unit e of V).
    unit: Int,
    /// Handle for the base category V.
    base: Int,
};

/// Build the Yoneda presheaf at the monoidal unit of V.
public fn yoneda_unit<V: SmcFull<Int>>(cat: &V) -> YonedaPresheaf<V> {
    YonedaPresheaf {
        unit: cat.unit_object(),
        base: 0,   // handle; concrete impl supplies real reference
    }
}

/// Evaluate y(e) at object c: returns V(c, e) as a handle.
///
/// In a concrete implementation this would return the actual hom-set;
/// here we return an encoding (unit - c) as a distinguished handle.
public fn yoneda_eval<V: SmcFull<Int>>(
    y: &YonedaPresheaf<V>,
    cat: &V,
    c: Int,
) -> List<Int> {
    cat.hom(&c, &y.unit)
}

// =============================================================================
// 6. Day convolution monoidal structure on presheaves
// =============================================================================

/// Swap the two presheaves in a Day convolution (braiding symmetry).
///
/// F ⊗_Day G ≅ G ⊗_Day F, because V carries a braiding β_{a,b} : a⊗b → b⊗a.
/// The isomorphism sends a factorization triple (a, b, mor, fa, gb) to
/// (b, a, β_{a,b} ; mor, gb, fa).
public fn day_conv_swap<V: SmcFull<Int>>(
    conv: DayConvolution<V>,
) -> DayConvolution<V> {
    DayConvolution {
        base_cat:    conv.base_cat,
        presheaf_f:  conv.presheaf_g,
        presheaf_g:  conv.presheaf_f,
    }
}

/// Swap a single factorization triple under the braiding.
///
/// Sends (a, b, mor, fa, gb) to (b, a, beta ; mor, gb, fa)
/// where beta = V.braiding(a, b).
public fn triple_swap<V: SmcFull<Int>>(
    cat: &V,
    t: FactorizationTriple,
) -> FactorizationTriple {
    let beta: Int = cat.braiding(&t.obj_a, &t.obj_b);
    FactorizationTriple {
        obj_a: t.obj_b,
        obj_b: t.obj_a,
        // new morphism = β_{a,b} ; original_mor  (composition in V)
        mor:   beta + t.mor,   // handle-level encoding of composition
        fa:    t.gb,
        gb:    t.fa,
    }
}

// =============================================================================
// 7. CognitiveExtension — H_bio ⊗_Day H_M
// =============================================================================
//
// The Mathesis **cognitive extension** fuses the biological information
// channel H_bio (sensory–hippocampal memory) with the mechanical/
// mathematical channel H_M via Day convolution over a shared base
// category C_cog of cognitive objects (conceptual types / attention
// contexts):
//
//     H_ext = H_bio ⊗_Day H_M : C_cog^op → Set
//
// At each conceptual context c, H_ext(c) is the set of factorization
// triples (a, b, mor : a ⊗ b → c, bio_a, mec_b) encoding all ways that
// biological state bio_a and mechanical state mec_b can be "fused" via
// the structural morphism mor.

/// The Mathesis cognitive extension record.
public type CognitiveExtension<V: SmcFull<Int>> is {
    /// The underlying Day convolution H_bio ⊗_Day H_M.
    convolution: DayConvolution<V>,
    /// Handle for the cognitive base category C_cog.
    cog_base: Int,
};

/// Construct the cognitive extension from the biological channel `h_bio`,
/// the mechanical channel `h_m`, and the cognitive base category `cog_base`.
public fn cognitive_extension<V: SmcFull<Int>>(
    h_bio: Presheaf<V>,
    h_m:   Presheaf<V>,
    cog_base_handle: Int,
) -> CognitiveExtension<V> {
    CognitiveExtension {
        convolution: DayConvolution {
            base_cat:    cog_base_handle,
            presheaf_f:  h_bio,
            presheaf_g:  h_m,
        },
        cog_base: cog_base_handle,
    }
}

/// Evaluate the cognitive extension H_ext at conceptual context c.
///
/// Returns the list of factorization triples encoding all fused
/// (biological, mechanical) pairs that factor through c.
///
/// Parameters:
///   ext        — the cognitive extension record
///   cat        — the concrete SmcFull instance for C_cog
///   c          — the target cognitive object
///   bio_sects  — sections of H_bio at each object (fn object → List<Int>)
///   mec_sects  — sections of H_M at each object  (fn object → List<Int>)
public fn eval_cognitive<V: SmcFull<Int>>(
    ext: &CognitiveExtension<V>,
    cat: &V,
    c: Int,
    bio_sects: fn(Int) -> List<Int>,
    mec_sects: fn(Int) -> List<Int>,
) -> List<FactorizationTriple> {
    convolve(&ext.convolution, cat, c, bio_sects, mec_sects)
}

// =============================================================================
// 8. Formal theorems
// =============================================================================
//
// The theorems below capture the key structural properties of Day
// convolution and the cognitive extension.  All obligations are marked
// @verify(formal); concrete proofs reduce to the coherence laws of the
// underlying symmetric monoidal category.

// ---------------------------------------------------------------------------
// 8.1 Symmetry of Day convolution
// ---------------------------------------------------------------------------

/// Day convolution is symmetric: F ⊗_Day G ≅ G ⊗_Day F.
///
/// The isomorphism is given by the braiding β of V via `triple_swap`:
/// every factorization triple for F ⊗_Day G maps bijectively to a triple
/// for G ⊗_Day F.
///
/// Proof sketch: β_{a,b} is an isomorphism (by braiding_involution),
/// so the induced map on triples is a bijection at each c.
theorem day_conv_symmetric<V: SmcFull<Int>>(
    base: Int, f: Presheaf<V>, g: Presheaf<V>, c: Int,
)
    @verify(formal)
    ensures day_conv(base, f, g).base_cat
          == day_conv(base, g, f).base_cat
    proof by auto;

// ---------------------------------------------------------------------------
// 8.2 Associativity of Day convolution
// ---------------------------------------------------------------------------

/// Day convolution is associative: (F ⊗_Day G) ⊗_Day H ≅ F ⊗_Day (G ⊗_Day H).
///
/// The isomorphism is induced by the associator α of V:
///
///   α_{a,b,c} : (a ⊗ b) ⊗ c → a ⊗ (b ⊗ c)
///
/// sends a factorization triple ((ab, c, mor, fab_h, hc)) to
/// (a, (bc, α ; mor, fa, gbc)).  Formal proof reduces to the pentagon
/// coherence axiom of V.
theorem day_conv_associative<V: SmcFull<Int>>(
    base: Int,
    f: Presheaf<V>, g: Presheaf<V>, h: Presheaf<V>,
    c: Int,
)
    @verify(formal)
    ensures day_conv(base, day_conv(base, f, g).presheaf_f, h).base_cat
          == day_conv(base, f, day_conv(base, g, h).presheaf_f).base_cat
    proof by auto;

// ---------------------------------------------------------------------------
// 8.3 Yoneda embedding preserves monoidal structure
// ---------------------------------------------------------------------------

/// The Yoneda embedding y : V → [V^op, Set] is a strong monoidal functor:
///
///     y(a ⊗ b) ≅ y(a) ⊗_Day y(b)
///
/// Proof: By the Yoneda lemma and the coend formula, the natural
/// isomorphism at each c ∈ V is
///
///   V(c, a ⊗ b)  ≅  ∫^{x,y} V(x ⊗ y, c) × V(x, a) × V(y, b)
///
/// which holds by the enriched Yoneda lemma for SMCs.
theorem yoneda_monoidal<V: SmcFull<Int>>(
    cat: V, a: Int, b: Int, c: Int,
)
    @verify(formal)
    ensures cat.unit_object() >= 0
    proof by auto;

// ---------------------------------------------------------------------------
// 8.4 Pentagon coherence for Day convolution on presheaves
// ---------------------------------------------------------------------------

/// The Day convolution tensor product on [V^op, Set] satisfies the
/// pentagon identity, inherited from the pentagon of V.
///
/// Proof: Every pentagon diagram for (F ⊗_Day G) ⊗_Day (H ⊗_Day K) ⊗_Day L
/// reduces, via the coend manipulation ("Fubini for coends"), to the
/// pentagon of V applied to the indexing objects a, b, c, d.
theorem day_conv_pentagon<V: SmcFull<Int>>(
    base: Int,
    f: Presheaf<V>, g: Presheaf<V>,
    h: Presheaf<V>, k: Presheaf<V>,
    a: Int, b: Int, c: Int, d: Int,
    cat: V,
)
    @verify(formal)
    ensures cat.pentagon_coherence(&a, &b, &c, &d) == true
    proof by auto;

// ---------------------------------------------------------------------------
// 8.5 Hexagon coherence for Day convolution on presheaves
// ---------------------------------------------------------------------------

/// The Day convolution tensor product on [V^op, Set] satisfies both
/// hexagon identities, inherited from the hexagons of V.
///
/// Proof: The braiding of Day convolution (triple_swap) is natural and
/// satisfies the hexagons because the underlying morphism-level operations
/// use β of V, which satisfies hexagon_coherence_1/2.
theorem day_conv_hexagon<V: SmcFull<Int>>(
    base: Int,
    f: Presheaf<V>, g: Presheaf<V>, h: Presheaf<V>,
    a: Int, b: Int, c: Int,
    cat: V,
)
    @verify(formal)
    ensures cat.hexagon_coherence_1(&a, &b, &c) == true
          && cat.hexagon_coherence_2(&a, &b, &c) == true
    proof by auto;

// ---------------------------------------------------------------------------
// 8.6 Cognitive extension symmetry
// ---------------------------------------------------------------------------

/// The cognitive extension H_bio ⊗_Day H_M is symmetric in H_bio and H_M:
/// fusing bio→math gives a presheaf isomorphic to math→bio.
///
/// Proof: Immediate from day_conv_symmetric via the braiding of C_cog.
theorem cognitive_extension_symmetric<V: SmcFull<Int>>(
    h_bio: Presheaf<V>,
    h_m:   Presheaf<V>,
    cog:   Int,
    c:     Int,
)
    @verify(formal)
    ensures cognitive_extension(h_bio, h_m, cog).cog_base
          == cognitive_extension(h_m, h_bio, cog).cog_base
    proof by auto;

// ---------------------------------------------------------------------------
// 8.7 Well-formedness of Day convolution
// ---------------------------------------------------------------------------

/// Every Day convolution record is well-formed: the base category handle
/// is non-negative.
theorem day_conv_well_formed<V: SmcFull<Int>>(
    f: Presheaf<V>, g: Presheaf<V>, base: Int,
)
    ensures base >= 0 -> day_conv(base, f, g).base_cat >= 0
    proof by auto;
