// =============================================================================
// linalg.vr - Linear Algebra Module
// =============================================================================
// Layer: 2 (Linear Algebra)
//
// Provides vectors, matrices, and linear algebra operations:
// - Vector and Matrix types (dynamic and static variants)
// - BLAS Level 1: Vector-vector operations (dot, nrm2, axpy, etc.)
// - BLAS Level 2: Matrix-vector operations (gemv, trsv, etc.)
// - BLAS Level 3: Matrix-matrix operations (gemm, trsm, etc.)
// - Matrix decompositions: LU, QR, Cholesky, SVD
// - Eigenvalue computations
//
// # Design Philosophy
//
// This module provides both dynamic (runtime-sized) and static (compile-time
// sized) variants. Static variants enable shape verification at compile time
// through refinement types.
//
// # Type Aliases
//
// - Vector<T>: Dynamic vector with runtime size
// - StaticVector<T, N>: Static vector with compile-time size N
// - Matrix<T>: Dynamic matrix with runtime dimensions
// - StaticMatrix<T, M, N>: Static matrix with compile-time dimensions M×N
//
// Spec: docs/architecture/math-spec.md Section 7-8
// =============================================================================

module core.math.linalg;

mount super.constants.{EPSILON};
mount super.elementary.{sqrt, hypot, abs, fma};
mount super.ieee754.{is_nan, copysign};

// =============================================================================
// Numeric Protocol
// =============================================================================

// Protocol for numeric types usable in linear algebra
public type Numeric is protocol {
    fn zero() -> Self;
    fn one() -> Self;
    fn epsilon() -> Self;
    fn abs(self) -> Self;
    fn sqrt(self) -> Self;
    fn conj(self) -> Self;  // Complex conjugate (identity for reals)
};

implement Numeric for Float {
    fn zero() -> Self { 0.0 }
    fn one() -> Self { 1.0 }
    fn epsilon() -> Self { EPSILON }
    fn abs(self) -> Self { super.super.elementary.abs(self) }
    fn sqrt(self) -> Self { super.super.elementary.sqrt(self) }
    fn conj(self) -> Self { self }
}

implement Numeric for Float32 {
    fn zero() -> Self { 0.0f32 }
    fn one() -> Self { 1.0f32 }
    fn epsilon() -> Self { 1.19209290e-7f32 }
    fn abs(self) -> Self { if self < 0.0f32 { -self } else { self } }
    fn sqrt(self) -> Self { @intrinsic("llvm.sqrt.f32", self) }
    fn conj(self) -> Self { self }
}

// =============================================================================
// Type Definitions
// =============================================================================

// Dynamic vector with runtime size
public type Vector<T: Numeric> is {
    data: List<T>,
    len: Int,
};

// Static vector with compile-time size
public type StaticVector<T: Numeric, N: meta USize{N > 0}> is {
    data: [T; N],
};

// Dynamic matrix (row-major storage)
public type Matrix<T: Numeric> is {
    data: List<T>,
    rows: Int,
    cols: Int,
};

// Static matrix with compile-time dimensions (row-major storage)
public type StaticMatrix<T: Numeric, M: meta USize{M > 0}, N: meta USize{N > 0}> is {
    data: [T; M * N],
};

// =============================================================================
// BLAS Enums
// =============================================================================

// Transpose operation mode
public type Transpose is
    | NoTrans    // No transpose
    | Trans      // Transpose
    | ConjTrans; // Conjugate transpose

// Matrix triangular part
public type TriangularType is
    | Upper
    | Lower;

// Diagonal type
public type DiagonalType is
    | Unit      // Diagonal assumed to be 1
    | NonUnit;  // Use actual diagonal values

// Operation side
public type Side is
    | Left
    | Right;

// =============================================================================
// Vector Implementation
// =============================================================================

implement<T: Numeric> Vector<T> {
    // Create a zero vector of given length
    public fn zeros(n: Int) -> Self {
        let data = List.with_capacity(n);
        for _ in 0..n {
            data.push(T.zero());
        }
        Vector { data, len: n }
    }

    // Create a vector filled with a value
    public fn filled(n: Int, value: T) -> Self {
        let data = List.with_capacity(n);
        for _ in 0..n {
            data.push(value);
        }
        Vector { data, len: n }
    }

    // Create from a list
    public fn from_list(data: List<T>) -> Self {
        let len = data.len();
        Vector { data, len }
    }

    // Length of the vector
    @inline(always)
    public fn len(&self) -> Int {
        self.len
    }

    // Get element at index
    @inline(always)
    public fn get(&self, i: Int) -> T {
        assert(i < self.len, "index out of bounds");
        self.data[i]
    }

    // Set element at index
    @inline(always)
    public fn set(&mut self, i: Int, value: T) {
        assert(i < self.len, "index out of bounds");
        self.data[i] = value;
    }

    // Clone the vector
    public fn clone(&self) -> Self {
        Vector { data: self.data.clone(), len: self.len }
    }

    // Scale vector by scalar: x := α*x
    public fn scale(&mut self, alpha: T) {
        for i in 0..self.len {
            self.data[i] = self.data[i] * alpha;
        }
    }

    // AXPY: y := α*x + y
    public fn axpy(&mut self, alpha: T, x: &Vector<T>) {
        assert(self.len == x.len, "dimension mismatch");
        for i in 0..self.len {
            self.data[i] = fma(alpha, x.data[i], self.data[i]);
        }
    }

    // Dot product: x · y
    public fn dot(&self, y: &Vector<T>) -> T {
        assert(self.len == y.len, "dimension mismatch");
        let mut sum = T.zero();
        for i in 0..self.len {
            sum = fma(self.data[i], y.data[i], sum);
        }
        sum
    }

    // L2 norm: ||x||₂
    public fn norm_l2(&self) -> T {
        self.dot(self).sqrt()
    }

    // L1 norm: Σ|xᵢ|
    public fn norm_l1(&self) -> T {
        let mut sum = T.zero();
        for i in 0..self.len {
            sum = sum + self.data[i].abs();
        }
        sum
    }

    // Infinity norm: max|xᵢ|
    public fn norm_inf(&self) -> T {
        let mut max_val = T.zero();
        for i in 0..self.len {
            let abs_val = self.data[i].abs();
            if abs_val > max_val {
                max_val = abs_val;
            }
        }
        max_val
    }

    // Index of maximum absolute value (IAMAX)
    public fn iamax(&self) -> Int {
        let mut max_idx = 0;
        let mut max_val = T.zero();
        for i in 0..self.len {
            let abs_val = self.data[i].abs();
            if abs_val > max_val {
                max_val = abs_val;
                max_idx = i;
            }
        }
        max_idx
    }

    // Swap contents with another vector
    public fn swap(&mut self, other: &mut Vector<T>) {
        assert(self.len == other.len, "dimension mismatch");
        for i in 0..self.len {
            let tmp = self.data[i];
            self.data[i] = other.data[i];
            other.data[i] = tmp;
        }
    }

    // Copy from another vector
    public fn copy_from(&mut self, src: &Vector<T>) {
        assert(self.len == src.len, "dimension mismatch");
        for i in 0..self.len {
            self.data[i] = src.data[i];
        }
    }

    // Element-wise addition
    public fn add(&self, other: &Vector<T>) -> Vector<T> {
        assert(self.len == other.len, "dimension mismatch");
        let mut result = Vector.zeros(self.len);
        for i in 0..self.len {
            result.data[i] = self.data[i] + other.data[i];
        }
        result
    }

    // Element-wise subtraction
    public fn sub(&self, other: &Vector<T>) -> Vector<T> {
        assert(self.len == other.len, "dimension mismatch");
        let mut result = Vector.zeros(self.len);
        for i in 0..self.len {
            result.data[i] = self.data[i] - other.data[i];
        }
        result
    }

    // Element-wise multiplication (Hadamard product)
    public fn hadamard(&self, other: &Vector<T>) -> Vector<T> {
        assert(self.len == other.len, "dimension mismatch");
        let mut result = Vector.zeros(self.len);
        for i in 0..self.len {
            result.data[i] = self.data[i] * other.data[i];
        }
        result
    }
}

// =============================================================================
// Matrix Implementation
// =============================================================================

implement<T: Numeric> Matrix<T> {
    // Create a zero matrix
    public fn zeros(rows: Int, cols: Int) -> Self {
        let size = rows * cols;
        let data = List.with_capacity(size);
        for _ in 0..size {
            data.push(T.zero());
        }
        Matrix { data, rows, cols }
    }

    // Create an identity matrix
    public fn eye(n: Int) -> Self {
        let mut m = Matrix.zeros(n, n);
        for i in 0..n {
            m.set(i, i, T.one());
        }
        m
    }

    // Create a diagonal matrix from a vector
    public fn diag(v: &Vector<T>) -> Self {
        let n = v.len();
        let mut m = Matrix.zeros(n, n);
        for i in 0..n {
            m.set(i, i, v.get(i));
        }
        m
    }

    // Create from a list with dimensions
    public fn from_data(data: List<T>, rows: Int, cols: Int) -> Self {
        assert(data.len() == rows * cols, "data size mismatch");
        Matrix { data, rows, cols }
    }

    // Number of rows
    @inline(always)
    public fn rows(&self) -> Int {
        self.rows
    }

    // Number of columns
    @inline(always)
    public fn cols(&self) -> Int {
        self.cols
    }

    // Get element at (i, j)
    @inline(always)
    public fn get(&self, i: Int, j: Int) -> T {
        assert(i < self.rows && j < self.cols, "index out of bounds");
        self.data[i * self.cols + j]
    }

    // Set element at (i, j)
    @inline(always)
    public fn set(&mut self, i: Int, j: Int, value: T) {
        assert(i < self.rows && j < self.cols, "index out of bounds");
        self.data[i * self.cols + j] = value;
    }

    // Clone the matrix
    public fn clone(&self) -> Self {
        Matrix { data: self.data.clone(), rows: self.rows, cols: self.cols }
    }

    // Transpose
    public fn transpose(&self) -> Matrix<T> {
        let mut result = Matrix.zeros(self.cols, self.rows);
        for i in 0..self.rows {
            for j in 0..self.cols {
                result.set(j, i, self.get(i, j));
            }
        }
        result
    }

    // Get row as vector
    public fn row(&self, i: Int) -> Vector<T> {
        assert(i < self.rows, "row index out of bounds");
        let mut v = Vector.zeros(self.cols);
        for j in 0..self.cols {
            v.set(j, self.get(i, j));
        }
        v
    }

    // Get column as vector
    public fn col(&self, j: Int) -> Vector<T> {
        assert(j < self.cols, "column index out of bounds");
        let mut v = Vector.zeros(self.rows);
        for i in 0..self.rows {
            v.set(i, self.get(i, j));
        }
        v
    }

    // Set row from vector
    public fn set_row(&mut self, i: Int, v: &Vector<T>) {
        assert(i < self.rows && v.len() == self.cols, "dimension mismatch");
        for j in 0..self.cols {
            self.set(i, j, v.get(j));
        }
    }

    // Set column from vector
    public fn set_col(&mut self, j: Int, v: &Vector<T>) {
        assert(j < self.cols && v.len() == self.rows, "dimension mismatch");
        for i in 0..self.rows {
            self.set(i, j, v.get(i));
        }
    }

    // Matrix-vector multiplication: y = A*x
    public fn matvec(&self, x: &Vector<T>) -> Vector<T> {
        assert(self.cols == x.len(), "dimension mismatch");
        let mut y = Vector.zeros(self.rows);
        for i in 0..self.rows {
            let mut sum = T.zero();
            for j in 0..self.cols {
                sum = fma(self.get(i, j), x.get(j), sum);
            }
            y.set(i, sum);
        }
        y
    }

    // Matrix-matrix multiplication: C = A*B
    public fn matmul(&self, b: &Matrix<T>) -> Matrix<T> {
        assert(self.cols == b.rows, "dimension mismatch");
        let mut c = Matrix.zeros(self.rows, b.cols);
        for i in 0..self.rows {
            for j in 0..b.cols {
                let mut sum = T.zero();
                for k in 0..self.cols {
                    sum = fma(self.get(i, k), b.get(k, j), sum);
                }
                c.set(i, j, sum);
            }
        }
        c
    }

    // Frobenius norm: ||A||_F
    public fn norm_frobenius(&self) -> T {
        let mut sum = T.zero();
        for i in 0..self.rows {
            for j in 0..self.cols {
                let v = self.get(i, j);
                sum = fma(v, v, sum);
            }
        }
        sum.sqrt()
    }

    // Trace (sum of diagonal elements)
    public fn trace(&self) -> T {
        let n = self.rows.min(self.cols);
        let mut sum = T.zero();
        for i in 0..n {
            sum = sum + self.get(i, i);
        }
        sum
    }

    // Element-wise addition
    public fn add(&self, other: &Matrix<T>) -> Matrix<T> {
        assert(self.rows == other.rows && self.cols == other.cols, "dimension mismatch");
        let mut result = Matrix.zeros(self.rows, self.cols);
        for i in 0..self.rows {
            for j in 0..self.cols {
                result.set(i, j, self.get(i, j) + other.get(i, j));
            }
        }
        result
    }

    // Element-wise subtraction
    public fn sub(&self, other: &Matrix<T>) -> Matrix<T> {
        assert(self.rows == other.rows && self.cols == other.cols, "dimension mismatch");
        let mut result = Matrix.zeros(self.rows, self.cols);
        for i in 0..self.rows {
            for j in 0..self.cols {
                result.set(i, j, self.get(i, j) - other.get(i, j));
            }
        }
        result
    }

    // Scale matrix by scalar
    public fn scale(&mut self, alpha: T) {
        for i in 0..(self.rows * self.cols) {
            self.data[i] = self.data[i] * alpha;
        }
    }

    // Scaled copy
    public fn scaled(&self, alpha: T) -> Matrix<T> {
        let mut result = self.clone();
        result.scale(alpha);
        result
    }

    // Swap rows i and j
    public fn swap_rows(&mut self, i: Int, j: Int) {
        if i == j { return; }
        for k in 0..self.cols {
            let tmp = self.get(i, k);
            self.set(i, k, self.get(j, k));
            self.set(j, k, tmp);
        }
    }
}

// =============================================================================
// BLAS Level 1: Vector-Vector Operations
// =============================================================================

// DOT: x · y
public fn dot<T: Numeric>(x: &Vector<T>, y: &Vector<T>) -> T {
    x.dot(y)
}

// NRM2: ||x||₂
public fn nrm2<T: Numeric>(x: &Vector<T>) -> T {
    x.norm_l2()
}

// ASUM: Σ|xᵢ|
public fn asum<T: Numeric>(x: &Vector<T>) -> T {
    x.norm_l1()
}

// IAMAX: argmax|xᵢ|
public fn iamax<T: Numeric>(x: &Vector<T>) -> Int {
    x.iamax()
}

// SCAL: x := α*x
public fn scal<T: Numeric>(alpha: T, x: &mut Vector<T>) {
    x.scale(alpha);
}

// AXPY: y := α*x + y
public fn axpy<T: Numeric>(alpha: T, x: &Vector<T>, y: &mut Vector<T>) {
    y.axpy(alpha, x);
}

// COPY: y := x
public fn copy<T: Numeric>(x: &Vector<T>, y: &mut Vector<T>) {
    y.copy_from(x);
}

// SWAP: x ↔ y
public fn swap<T: Numeric>(x: &mut Vector<T>, y: &mut Vector<T>) {
    x.swap(y);
}

// ROTG: Givens rotation parameters
// Returns (r, z, c, s) where:
//   [c  s] [a]   [r]
//   [-s c] [b] = [0]
public fn rotg<T: Numeric>(a: T, b: T) -> (T, T, T, T) {
    let r = hypot(a, b);
    if r == T.zero() {
        return (T.zero(), T.zero(), T.one(), T.zero());
    }
    let c = a / r;
    let s = b / r;
    let z = if a.abs() > b.abs() {
        s
    } else if c != T.zero() {
        T.one() / c
    } else {
        T.one()
    };
    (r, z, c, s)
}

// ROT: Apply Givens rotation
// [x_i]   [c  s] [x_i]
// [y_i] = [-s c] [y_i]
public fn rot<T: Numeric>(x: &mut Vector<T>, y: &mut Vector<T>, c: T, s: T) {
    assert(x.len() == y.len(), "dimension mismatch");
    for i in 0..x.len() {
        let xi = x.get(i);
        let yi = y.get(i);
        x.set(i, c * xi + s * yi);
        y.set(i, -s * xi + c * yi);
    }
}

// =============================================================================
// BLAS Level 2: Matrix-Vector Operations
// =============================================================================

// GEMV: y := α*op(A)*x + β*y
public fn gemv<T: Numeric>(
    trans: Transpose,
    alpha: T,
    a: &Matrix<T>,
    x: &Vector<T>,
    beta: T,
    y: &mut Vector<T>,
) {
    let (m, n) = match trans {
        Transpose.NoTrans => (a.rows, a.cols),
        _ => (a.cols, a.rows),
    };
    assert(n == x.len() && m == y.len(), "dimension mismatch");

    // y := β*y
    scal(beta, y);

    // y := y + α*op(A)*x
    match trans {
        Transpose.NoTrans => {
            for i in 0..m {
                let mut sum = T.zero();
                for j in 0..n {
                    sum = fma(a.get(i, j), x.get(j), sum);
                }
                y.set(i, y.get(i) + alpha * sum);
            }
        }
        Transpose.Trans | Transpose.ConjTrans => {
            for j in 0..n {
                let mut sum = T.zero();
                for i in 0..m {
                    let a_val = match trans {
                        Transpose.ConjTrans => a.get(j, i).conj(),
                        _ => a.get(j, i),
                    };
                    sum = fma(a_val, x.get(i), sum);
                }
                y.set(j, y.get(j) + alpha * sum);
            }
        }
    }
}

// TRSV: Solve op(A)*x = b where A is triangular
public fn trsv<T: Numeric>(
    uplo: TriangularType,
    trans: Transpose,
    diag: DiagonalType,
    a: &Matrix<T>,
    x: &mut Vector<T>,
) {
    let n = a.rows;
    assert(a.rows == a.cols && n == x.len(), "dimension mismatch");

    // Determine effective triangular structure based on transpose
    let effective_uplo = match (uplo, trans) {
        (TriangularType.Upper, Transpose.NoTrans) => TriangularType.Upper,
        (TriangularType.Lower, Transpose.NoTrans) => TriangularType.Lower,
        (TriangularType.Upper, _) => TriangularType.Lower,  // Transposed upper becomes lower
        (TriangularType.Lower, _) => TriangularType.Upper,  // Transposed lower becomes upper
    };

    match effective_uplo {
        TriangularType.Lower => {
            // Forward substitution
            for i in 0..n {
                let mut sum = x.get(i);
                for j in 0..i {
                    let a_val = match trans {
                        Transpose.NoTrans => a.get(i, j),
                        Transpose.ConjTrans => a.get(j, i).conj(),
                        Transpose.Trans => a.get(j, i),
                    };
                    sum = sum - a_val * x.get(j);
                }
                match diag {
                    DiagonalType.NonUnit => {
                        let diag_val = match trans {
                            Transpose.ConjTrans => a.get(i, i).conj(),
                            _ => a.get(i, i),
                        };
                        x.set(i, sum / diag_val);
                    }
                    DiagonalType.Unit => x.set(i, sum),
                }
            }
        }
        TriangularType.Upper => {
            // Backward substitution
            for i in (0..n).rev() {
                let mut sum = x.get(i);
                for j in (i + 1)..n {
                    let a_val = match trans {
                        Transpose.NoTrans => a.get(i, j),
                        Transpose.ConjTrans => a.get(j, i).conj(),
                        Transpose.Trans => a.get(j, i),
                    };
                    sum = sum - a_val * x.get(j);
                }
                match diag {
                    DiagonalType.NonUnit => {
                        let diag_val = match trans {
                            Transpose.ConjTrans => a.get(i, i).conj(),
                            _ => a.get(i, i),
                        };
                        x.set(i, sum / diag_val);
                    }
                    DiagonalType.Unit => x.set(i, sum),
                }
            }
        }
    }
}

// GER: A := α*x*yᵀ + A (rank-1 update)
public fn ger<T: Numeric>(alpha: T, x: &Vector<T>, y: &Vector<T>, a: &mut Matrix<T>) {
    assert(a.rows == x.len() && a.cols == y.len(), "dimension mismatch");
    for i in 0..a.rows {
        for j in 0..a.cols {
            a.set(i, j, fma(alpha * x.get(i), y.get(j), a.get(i, j)));
        }
    }
}

// SYR: A := α*x*xᵀ + A (symmetric rank-1 update)
public fn syr<T: Numeric>(uplo: TriangularType, alpha: T, x: &Vector<T>, a: &mut Matrix<T>) {
    let n = x.len();
    assert(a.rows == n && a.cols == n, "dimension mismatch");

    match uplo {
        TriangularType.Upper => {
            for i in 0..n {
                for j in i..n {
                    a.set(i, j, fma(alpha * x.get(i), x.get(j), a.get(i, j)));
                }
            }
        }
        TriangularType.Lower => {
            for i in 0..n {
                for j in 0..=i {
                    a.set(i, j, fma(alpha * x.get(i), x.get(j), a.get(i, j)));
                }
            }
        }
    }
}

// =============================================================================
// BLAS Level 3: Matrix-Matrix Operations
// =============================================================================

// GEMM: C := α*op(A)*op(B) + β*C
public fn gemm<T: Numeric>(
    trans_a: Transpose,
    trans_b: Transpose,
    alpha: T,
    a: &Matrix<T>,
    b: &Matrix<T>,
    beta: T,
    c: &mut Matrix<T>,
) {
    let (m, k_a) = match trans_a {
        Transpose.NoTrans => (a.rows, a.cols),
        _ => (a.cols, a.rows),
    };
    let (k_b, n) = match trans_b {
        Transpose.NoTrans => (b.rows, b.cols),
        _ => (b.cols, b.rows),
    };
    assert(k_a == k_b && c.rows == m && c.cols == n, "dimension mismatch");
    let k = k_a;

    // C := β*C
    c.scale(beta);

    // C := C + α*op(A)*op(B)
    for i in 0..m {
        for j in 0..n {
            let mut sum = T.zero();
            for l in 0..k {
                let a_il = match trans_a {
                    Transpose.NoTrans => a.get(i, l),
                    Transpose.Trans => a.get(l, i),
                    Transpose.ConjTrans => a.get(l, i).conj(),
                };
                let b_lj = match trans_b {
                    Transpose.NoTrans => b.get(l, j),
                    Transpose.Trans => b.get(j, l),
                    Transpose.ConjTrans => b.get(j, l).conj(),
                };
                sum = fma(a_il, b_lj, sum);
            }
            c.set(i, j, c.get(i, j) + alpha * sum);
        }
    }
}

// TRSM: Solve op(A)*X = α*B or X*op(A) = α*B
public fn trsm<T: Numeric>(
    side: Side,
    uplo: TriangularType,
    trans_a: Transpose,
    diag: DiagonalType,
    alpha: T,
    a: &Matrix<T>,
    b: &mut Matrix<T>,
) {
    let m = b.rows;
    let n = b.cols;

    // Scale B by alpha
    b.scale(alpha);

    match side {
        Side.Left => {
            // Solve A*X = B column by column
            for j in 0..n {
                let mut col = b.col(j);
                trsv(uplo, trans_a, diag, a, &mut col);
                b.set_col(j, &col);
            }
        }
        Side.Right => {
            // Solve X*A = B row by row (transpose to column form)
            let at = a.transpose();
            for i in 0..m {
                let mut row = b.row(i);
                trsv(uplo, trans_a, diag, &at, &mut row);
                b.set_row(i, &row);
            }
        }
    }
}

// SYRK: C := α*A*Aᵀ + β*C or α*Aᵀ*A + β*C (symmetric rank-k update)
public fn syrk<T: Numeric>(
    uplo: TriangularType,
    trans: Transpose,
    alpha: T,
    a: &Matrix<T>,
    beta: T,
    c: &mut Matrix<T>,
) {
    let (n, k) = match trans {
        Transpose.NoTrans => (a.rows, a.cols),
        _ => (a.cols, a.rows),
    };
    assert(c.rows == n && c.cols == n, "dimension mismatch");

    // Scale C by beta
    c.scale(beta);

    // C := C + α*A*Aᵀ or α*Aᵀ*A
    match uplo {
        TriangularType.Upper => {
            for i in 0..n {
                for j in i..n {
                    let mut sum = T.zero();
                    for l in 0..k {
                        let a_il = match trans {
                            Transpose.NoTrans => a.get(i, l),
                            _ => a.get(l, i),
                        };
                        let a_jl = match trans {
                            Transpose.NoTrans => a.get(j, l),
                            _ => a.get(l, j),
                        };
                        sum = fma(a_il, a_jl, sum);
                    }
                    c.set(i, j, c.get(i, j) + alpha * sum);
                }
            }
        }
        TriangularType.Lower => {
            for i in 0..n {
                for j in 0..=i {
                    let mut sum = T.zero();
                    for l in 0..k {
                        let a_il = match trans {
                            Transpose.NoTrans => a.get(i, l),
                            _ => a.get(l, i),
                        };
                        let a_jl = match trans {
                            Transpose.NoTrans => a.get(j, l),
                            _ => a.get(l, j),
                        };
                        sum = fma(a_il, a_jl, sum);
                    }
                    c.set(i, j, c.get(i, j) + alpha * sum);
                }
            }
        }
    }
}

// =============================================================================
// Matrix Decompositions
// =============================================================================

// LU decomposition result with partial pivoting
public type LUDecomposition<T: Numeric> is {
    lu: Matrix<T>,         // L (below diagonal) and U (diagonal and above)
    pivots: List<Int>,     // Pivot indices
    num_swaps: Int,        // Number of row swaps (for determinant sign)
};

// Compute PA = LU decomposition with partial pivoting
public fn lu<T: Numeric>(a: &Matrix<T>) -> LUDecomposition<T> {
    let m = a.rows;
    let n = a.cols;
    let mut lu = a.clone();
    let mut pivots = List.with_capacity(m);
    for i in 0..m {
        pivots.push(i);
    }
    let mut num_swaps = 0;
    let min_mn = m.min(n);

    for k in 0..min_mn {
        // Find pivot (maximum absolute value in column k, rows k..m)
        let mut max_val = lu.get(k, k).abs();
        let mut max_idx = k;
        for i in (k + 1)..m {
            let val = lu.get(i, k).abs();
            if val > max_val {
                max_val = val;
                max_idx = i;
            }
        }

        // Swap rows if needed
        if max_idx != k {
            lu.swap_rows(k, max_idx);
            let tmp = pivots[k];
            pivots[k] = pivots[max_idx];
            pivots[max_idx] = tmp;
            num_swaps += 1;
        }

        // Skip if pivot is too small (singular matrix)
        let pivot = lu.get(k, k);
        if pivot.abs() < T.epsilon() {
            continue;
        }

        // Eliminate below
        for i in (k + 1)..m {
            let factor = lu.get(i, k) / pivot;
            lu.set(i, k, factor);  // Store L factor
            for j in (k + 1)..n {
                lu.set(i, j, lu.get(i, j) - factor * lu.get(k, j));
            }
        }
    }

    LUDecomposition { lu, pivots, num_swaps }
}

// Solve Ax = b using LU decomposition
public fn lu_solve<T: Numeric>(decomp: &LUDecomposition<T>, b: &Vector<T>) -> Vector<T> {
    let n = decomp.lu.rows;
    assert(n == b.len(), "dimension mismatch");

    // Apply permutation: x = P*b
    let mut x = Vector.zeros(n);
    for i in 0..n {
        x.set(i, b.get(decomp.pivots[i]));
    }

    // Forward substitution: Ly = Pb (L has unit diagonal)
    for i in 1..n {
        let mut sum = x.get(i);
        for j in 0..i {
            sum = sum - decomp.lu.get(i, j) * x.get(j);
        }
        x.set(i, sum);
    }

    // Backward substitution: Ux = y
    for i in (0..n).rev() {
        let mut sum = x.get(i);
        for j in (i + 1)..n {
            sum = sum - decomp.lu.get(i, j) * x.get(j);
        }
        x.set(i, sum / decomp.lu.get(i, i));
    }

    x
}

// Determinant via LU decomposition
public fn determinant<T: Numeric>(a: &Matrix<T>) -> T {
    assert(a.rows == a.cols, "matrix must be square");
    let decomp = lu(a);
    let mut det = if decomp.num_swaps % 2 == 0 { T.one() } else { -T.one() };
    for i in 0..a.rows {
        det = det * decomp.lu.get(i, i);
    }
    det
}

// QR decomposition result: A = Q*R
public type QRDecomposition<T: Numeric> is {
    q: Matrix<T>,  // Orthogonal matrix Q
    r: Matrix<T>,  // Upper triangular matrix R
};

// QR decomposition via Householder reflections
public fn qr<T: Numeric>(a: &Matrix<T>) -> QRDecomposition<T> {
    let m = a.rows;
    let n = a.cols;
    let mut q = Matrix.eye(m);
    let mut r = a.clone();

    for k in 0..n.min(m - 1) {
        // Extract column k below diagonal
        let mut v = Vector.zeros(m - k);
        for i in k..m {
            v.set(i - k, r.get(i, k));
        }

        // Compute Householder vector
        let norm = v.norm_l2();
        if norm < T.epsilon() {
            continue;
        }

        let sign = if v.get(0) >= T.zero() { T.one() } else { -T.one() };
        v.set(0, v.get(0) + sign * norm);

        let v_norm = v.norm_l2();
        if v_norm > T.epsilon() {
            scal(T.one() / v_norm, &mut v);
        }

        // Apply H = I - 2vvᵀ to R
        for j in k..n {
            let mut dot_val = T.zero();
            for i in k..m {
                dot_val = fma(v.get(i - k), r.get(i, j), dot_val);
            }
            let two = T.one() + T.one();
            for i in k..m {
                r.set(i, j, r.get(i, j) - two * dot_val * v.get(i - k));
            }
        }

        // Apply H to Q
        for j in 0..m {
            let mut dot_val = T.zero();
            for i in k..m {
                dot_val = fma(v.get(i - k), q.get(i, j), dot_val);
            }
            let two = T.one() + T.one();
            for i in k..m {
                q.set(i, j, q.get(i, j) - two * dot_val * v.get(i - k));
            }
        }
    }

    QRDecomposition { q: q.transpose(), r }
}

// Solve least squares min||Ax - b||² using QR
public fn qr_solve<T: Numeric>(decomp: &QRDecomposition<T>, b: &Vector<T>) -> Vector<T> {
    let m = decomp.q.rows;
    let n = decomp.r.cols;
    assert(b.len() == m, "dimension mismatch");

    // Compute Qᵀb
    let qt_b = decomp.q.transpose().matvec(b);

    // Solve Rx = Qᵀb by back-substitution
    let mut x = Vector.zeros(n);
    for i in (0..n).rev() {
        let mut sum = qt_b.get(i);
        for j in (i + 1)..n {
            sum = sum - decomp.r.get(i, j) * x.get(j);
        }
        let diag = decomp.r.get(i, i);
        if diag.abs() > T.epsilon() {
            x.set(i, sum / diag);
        }
    }

    x
}

// Cholesky decomposition result: A = L*Lᵀ
public type CholeskyDecomposition<T: Numeric> is {
    l: Matrix<T>,  // Lower triangular matrix L
};

// Cholesky decomposition for symmetric positive definite matrices
// Returns Maybe.None if matrix is not positive definite
public fn cholesky<T: Numeric>(a: &Matrix<T>) -> Maybe<CholeskyDecomposition<T>> {
    let n = a.rows;
    assert(a.rows == a.cols, "matrix must be square");

    let mut l = Matrix.zeros(n, n);

    for i in 0..n {
        for j in 0..=i {
            let mut sum = a.get(i, j);
            for k in 0..j {
                sum = sum - l.get(i, k) * l.get(j, k);
            }

            if i == j {
                if sum <= T.zero() {
                    return Maybe.None;  // Not positive definite
                }
                l.set(i, j, sum.sqrt());
            } else {
                let diag = l.get(j, j);
                if diag.abs() < T.epsilon() {
                    return Maybe.None;
                }
                l.set(i, j, sum / diag);
            }
        }
    }

    Maybe.Some(CholeskyDecomposition { l })
}

// Solve Ax = b using Cholesky (A = LLᵀ)
public fn cholesky_solve<T: Numeric>(decomp: &CholeskyDecomposition<T>, b: &Vector<T>) -> Vector<T> {
    let n = decomp.l.rows;
    assert(n == b.len(), "dimension mismatch");

    let mut x = b.clone();

    // Forward substitution: Ly = b
    for i in 0..n {
        let mut sum = x.get(i);
        for j in 0..i {
            sum = sum - decomp.l.get(i, j) * x.get(j);
        }
        x.set(i, sum / decomp.l.get(i, i));
    }

    // Backward substitution: Lᵀx = y
    for i in (0..n).rev() {
        let mut sum = x.get(i);
        for j in (i + 1)..n {
            sum = sum - decomp.l.get(j, i) * x.get(j);
        }
        x.set(i, sum / decomp.l.get(i, i));
    }

    x
}

// =============================================================================
// Eigenvalue Computations
// =============================================================================

// Eigendecomposition result
public type EigenDecomposition<T: Numeric> is {
    values: Vector<T>,    // Eigenvalues
    vectors: Matrix<T>,   // Eigenvectors (columns)
};

// Power iteration to find dominant eigenvalue/eigenvector
public fn power_iteration<T: Numeric>(
    a: &Matrix<T>,
    max_iter: Int,
    tol: T,
) -> (T, Vector<T>) {
    let n = a.rows;
    assert(a.rows == a.cols, "matrix must be square");

    // Start with random-ish vector
    let mut v = Vector.filled(n, T.one());
    let norm = v.norm_l2();
    scal(T.one() / norm, &mut v);

    let mut eigenvalue = T.zero();

    for _ in 0..max_iter {
        // w = A*v
        let w = a.matvec(&v);

        // Rayleigh quotient: λ = vᵀAv / vᵀv = vᵀw
        let new_eigenvalue = v.dot(&w);

        // Check convergence
        let diff = (new_eigenvalue - eigenvalue).abs();
        if diff < tol {
            eigenvalue = new_eigenvalue;
            break;
        }
        eigenvalue = new_eigenvalue;

        // Normalize
        let w_norm = w.norm_l2();
        if w_norm < T.epsilon() {
            break;
        }
        v = w;
        scal(T.one() / w_norm, &mut v);
    }

    (eigenvalue, v)
}

// Inverse iteration to find eigenvector for given eigenvalue estimate
public fn inverse_iteration<T: Numeric>(
    a: &Matrix<T>,
    sigma: T,
    max_iter: Int,
    tol: T,
) -> Vector<T> {
    let n = a.rows;
    assert(a.rows == a.cols, "matrix must be square");

    // Form A - σI
    let mut shifted = a.clone();
    for i in 0..n {
        shifted.set(i, i, shifted.get(i, i) - sigma);
    }

    // LU decompose shifted matrix
    let decomp = lu(&shifted);

    // Start with unit vector
    let mut v = Vector.filled(n, T.one());
    let norm = v.norm_l2();
    scal(T.one() / norm, &mut v);

    for _ in 0..max_iter {
        // Solve (A - σI)w = v
        let w = lu_solve(&decomp, &v);

        // Normalize
        let w_norm = w.norm_l2();
        if w_norm < T.epsilon() {
            break;
        }

        // Check convergence
        let mut diff = T.zero();
        for i in 0..n {
            let d = (w.get(i) / w_norm - v.get(i)).abs();
            if d > diff {
                diff = d;
            }
        }

        v = w;
        scal(T.one() / w_norm, &mut v);

        if diff < tol {
            break;
        }
    }

    v
}

// =============================================================================
// Utility Functions
// =============================================================================

// Matrix inverse via LU decomposition
public fn inverse<T: Numeric>(a: &Matrix<T>) -> Maybe<Matrix<T>> {
    let n = a.rows;
    assert(a.rows == a.cols, "matrix must be square");

    let decomp = lu(a);

    // Check if singular (any zero diagonal in U)
    for i in 0..n {
        if decomp.lu.get(i, i).abs() < T.epsilon() {
            return Maybe.None;
        }
    }

    // Solve A*X = I column by column
    let mut inv = Matrix.zeros(n, n);
    for j in 0..n {
        let mut e_j = Vector.zeros(n);
        e_j.set(j, T.one());
        let col = lu_solve(&decomp, &e_j);
        inv.set_col(j, &col);
    }

    Maybe.Some(inv)
}

// Solve linear system Ax = b
public fn solve<T: Numeric>(a: &Matrix<T>, b: &Vector<T>) -> Maybe<Vector<T>> {
    assert(a.rows == a.cols && a.rows == b.len(), "dimension mismatch");

    let decomp = lu(a);

    // Check if singular
    for i in 0..a.rows {
        if decomp.lu.get(i, i).abs() < T.epsilon() {
            return Maybe.None;
        }
    }

    Maybe.Some(lu_solve(&decomp, b))
}

// Matrix condition number (2-norm) approximation
// Uses power iteration to estimate largest/smallest singular values
public fn cond<T: Numeric>(a: &Matrix<T>) -> T {
    // Estimate largest singular value via A*Aᵀ
    let aat = a.matmul(&a.transpose());
    let (max_sq, _) = power_iteration(&aat, 100, T.epsilon());

    // For smallest singular value, we'd need inverse iteration
    // This is a simplified approximation
    let max_sv = max_sq.sqrt();

    // Use Frobenius norm heuristic for condition estimate
    let frob = a.norm_frobenius();
    let n = a.rows.min(a.cols) as Float;

    max_sv * n.sqrt() as T / frob
}

// Rank of matrix (via QR decomposition)
public fn rank<T: Numeric>(a: &Matrix<T>, tol: T) -> Int {
    let decomp = qr(a);
    let n = a.rows.min(a.cols);
    let mut r = 0;
    for i in 0..n {
        if decomp.r.get(i, i).abs() > tol {
            r += 1;
        }
    }
    r
}

// Null space basis (kernel) via QR decomposition
// Returns columns that span null(A)
public fn null_space<T: Numeric>(a: &Matrix<T>, tol: T) -> Matrix<T> {
    let decomp = qr(&a.transpose());
    let m = a.cols;
    let n = a.rows;
    let r = rank(a, tol);
    let null_dim = m - r;

    if null_dim == 0 {
        return Matrix.zeros(m, 0);
    }

    // Extract columns of Q corresponding to zero rows of R
    let mut null_basis = Matrix.zeros(m, null_dim);
    let mut col_idx = 0;
    for j in r..m {
        for i in 0..m {
            null_basis.set(i, col_idx, decomp.q.get(i, j));
        }
        col_idx += 1;
    }

    null_basis
}

// =============================================================================
// Singular Value Decomposition (SVD)
// =============================================================================

// SVD decomposition result: A = U * Σ * Vᵀ
// - U: m×m orthogonal matrix (left singular vectors)
// - s: min(m,n) vector of non-negative singular values (descending)
// - Vt: n×n orthogonal matrix (right singular vectors, transposed)
public type SVDDecomposition<T: Numeric> is {
    u: Matrix<T>,
    s: Vector<T>,
    vt: Matrix<T>,
};

// Singular Value Decomposition via Jacobi method
// Returns A = U * diag(s) * Vᵀ where s contains non-negative singular values
// in descending order
//
// # Algorithm
// Uses one-sided Jacobi rotations for numerical stability.
// Complexity: O(m*n*min(m,n)) for m×n matrix
//
// # Example
// ```verum
// let a = Matrix.from_data(list![3.0, 2.0, 2.0, 3.0], 2, 2);
// let decomp = svd(&a);
// // decomp.s contains [5.0, 1.0] (singular values)
// ```
public fn svd<T: Numeric>(a: &Matrix<T>) -> SVDDecomposition<T> {
    let m = a.rows;
    let n = a.cols;
    let k = m.min(n);

    // Initialize V as identity
    let mut v = Matrix.eye(n);
    let mut b = a.clone();

    // Jacobi iteration on BᵀB
    let max_iter = 100 * k * k;
    let tol = T.epsilon() * T.epsilon();

    for _ in 0..max_iter {
        let mut converged = true;

        // Sweep through all pairs
        for i in 0..(n-1) {
            for j in (i+1)..n {
                // Compute Gram matrix elements
                let mut aii = T.zero();
                let mut ajj = T.zero();
                let mut aij = T.zero();

                for l in 0..m {
                    let bi = b.get(l, i);
                    let bj = b.get(l, j);
                    aii = aii + bi * bi;
                    ajj = ajj + bj * bj;
                    aij = aij + bi * bj;
                }

                // Check for convergence
                if aij.abs() * aij.abs() > tol * aii * ajj {
                    converged = false;

                    // Compute Jacobi rotation angle
                    let tau = (ajj - aii) / (aij + aij);
                    let t = if tau.abs() < T.one() / T.epsilon() {
                        copysign(T.one(), tau) / (tau.abs() + (T.one() + tau * tau).sqrt())
                    } else {
                        T.one() / (tau + tau)
                    };
                    let c = T.one() / (T.one() + t * t).sqrt();
                    let s = c * t;

                    // Apply rotation to B (B = B * J)
                    for l in 0..m {
                        let bi = b.get(l, i);
                        let bj = b.get(l, j);
                        b.set(l, i, c * bi - s * bj);
                        b.set(l, j, s * bi + c * bj);
                    }

                    // Apply rotation to V (V = V * J)
                    for l in 0..n {
                        let vi = v.get(l, i);
                        let vj = v.get(l, j);
                        v.set(l, i, c * vi - s * vj);
                        v.set(l, j, s * vi + c * vj);
                    }
                }
            }
        }

        if converged { break; }
    }

    // Extract singular values and form U
    let mut singular_values = Vector.zeros(k);
    let mut u = Matrix.zeros(m, k);

    for j in 0..k {
        let mut sigma = T.zero();
        for i in 0..m {
            sigma = sigma + b.get(i, j) * b.get(i, j);
        }
        sigma = sigma.sqrt();
        singular_values.set(j, sigma);

        // U column j = B column j / sigma
        if sigma > T.epsilon() {
            for i in 0..m {
                u.set(i, j, b.get(i, j) / sigma);
            }
        }
    }

    // Sort singular values in descending order
    for i in 0..(k-1) {
        let mut max_idx = i;
        for j in (i+1)..k {
            if singular_values.get(j) > singular_values.get(max_idx) {
                max_idx = j;
            }
        }
        if max_idx != i {
            // Swap singular values
            let tmp = singular_values.get(i);
            singular_values.set(i, singular_values.get(max_idx));
            singular_values.set(max_idx, tmp);

            // Swap U columns
            for l in 0..m {
                let ui = u.get(l, i);
                u.set(l, i, u.get(l, max_idx));
                u.set(l, max_idx, ui);
            }

            // Swap V columns
            for l in 0..n {
                let vi = v.get(l, i);
                v.set(l, i, v.get(l, max_idx));
                v.set(l, max_idx, vi);
            }
        }
    }

    SVDDecomposition {
        u: u,
        s: singular_values,
        vt: v.transpose(),
    }
}

// =============================================================================
// Full Eigenvalue Decomposition
// =============================================================================

// Compute eigenvalues and eigenvectors of a symmetric matrix via Jacobi method
// Returns eigenvalues in descending order with corresponding eigenvectors
//
// # Requirements
// Input matrix must be symmetric (A = Aᵀ)
//
// # Example
// ```verum
// let a = Matrix.from_data(list![4.0, 1.0, 1.0, 3.0], 2, 2);
// let decomp = eigh(&a);
// // decomp.values contains eigenvalues in descending order
// ```
public fn eigh<T: Numeric>(a: &Matrix<T>) -> EigenDecomposition<T> {
    let n = a.rows;
    assert(n == a.cols, "Matrix must be square");

    // Initialize: A -> working matrix, V -> eigenvectors (starts as identity)
    let mut d = a.clone();
    let mut v = Matrix.eye(n);

    let max_iter = 100 * n * n;
    let tol = T.epsilon() * a.norm_frobenius();

    for _ in 0..max_iter {
        // Find largest off-diagonal element
        let mut max_val = T.zero();
        let mut p = 0;
        let mut q = 1;

        for i in 0..(n-1) {
            for j in (i+1)..n {
                let val = d.get(i, j).abs();
                if val > max_val {
                    max_val = val;
                    p = i;
                    q = j;
                }
            }
        }

        // Check convergence
        if max_val < tol { break; }

        // Compute rotation angle for Jacobi
        let app = d.get(p, p);
        let aqq = d.get(q, q);
        let apq = d.get(p, q);

        let theta = (aqq - app) / (apq + apq);
        let t = copysign(T.one(), theta) / (theta.abs() + (T.one() + theta * theta).sqrt());
        let c = T.one() / (T.one() + t * t).sqrt();
        let s = c * t;

        // Apply rotation: D' = JᵀDJ
        d.set(p, p, app - t * apq);
        d.set(q, q, aqq + t * apq);
        d.set(p, q, T.zero());
        d.set(q, p, T.zero());

        for i in 0..n {
            if i != p && i != q {
                let dip = d.get(i, p);
                let diq = d.get(i, q);
                d.set(i, p, c * dip - s * diq);
                d.set(p, i, c * dip - s * diq);
                d.set(i, q, s * dip + c * diq);
                d.set(q, i, s * dip + c * diq);
            }
        }

        // Update eigenvector matrix: V' = VJ
        for i in 0..n {
            let vip = v.get(i, p);
            let viq = v.get(i, q);
            v.set(i, p, c * vip - s * viq);
            v.set(i, q, s * vip + c * viq);
        }
    }

    // Extract eigenvalues from diagonal
    let mut eigenvalues = Vector.zeros(n);
    for i in 0..n {
        eigenvalues.set(i, d.get(i, i));
    }

    // Sort eigenvalues in descending order (with eigenvectors)
    for i in 0..(n-1) {
        let mut max_idx = i;
        for j in (i+1)..n {
            if eigenvalues.get(j) > eigenvalues.get(max_idx) {
                max_idx = j;
            }
        }
        if max_idx != i {
            // Swap eigenvalues
            let tmp = eigenvalues.get(i);
            eigenvalues.set(i, eigenvalues.get(max_idx));
            eigenvalues.set(max_idx, tmp);

            // Swap eigenvector columns
            for l in 0..n {
                let vi = v.get(l, i);
                v.set(l, i, v.get(l, max_idx));
                v.set(l, max_idx, vi);
            }
        }
    }

    EigenDecomposition {
        values: eigenvalues,
        vectors: v,
    }
}

// Compute eigenvalues of a general (non-symmetric) matrix via QR algorithm
// Returns complex eigenvalues as (real_part, imag_part) vectors
//
// # Note
// For symmetric matrices, use `eigh` which is more efficient.
public type ComplexEigenDecomposition<T: Numeric> is {
    real_parts: Vector<T>,
    imag_parts: Vector<T>,
};

public fn eig<T: Numeric>(a: &Matrix<T>) -> ComplexEigenDecomposition<T> {
    let n = a.rows;
    assert(n == a.cols, "Matrix must be square");

    // Reduce to upper Hessenberg form first
    let mut h = a.clone();

    // Householder reduction to Hessenberg
    for k in 0..(n-2) {
        // Compute Householder vector for column k
        let mut norm_sq = T.zero();
        for i in (k+1)..n {
            norm_sq = norm_sq + h.get(i, k) * h.get(i, k);
        }

        if norm_sq > T.epsilon() {
            let alpha = -(copysign(norm_sq.sqrt(), h.get(k+1, k)));
            let beta = norm_sq - h.get(k+1, k) * alpha;

            // v = [h[k+1,k] - alpha, h[k+2,k], ..., h[n-1,k]]
            let mut v = Vector.zeros(n - k - 1);
            v.set(0, h.get(k+1, k) - alpha);
            for i in (k+2)..n {
                v.set(i - k - 1, h.get(i, k));
            }

            // Normalize
            for i in 0..(n-k-1) {
                v.set(i, v.get(i) / beta.sqrt());
            }

            // Apply H = I - 2vvᵀ from left: H * A
            for j in k..n {
                let mut dot = T.zero();
                for i in (k+1)..n {
                    dot = dot + v.get(i - k - 1) * h.get(i, j);
                }
                for i in (k+1)..n {
                    h.set(i, j, h.get(i, j) - v.get(i - k - 1) * dot * (T.one() + T.one()));
                }
            }

            // Apply from right: A * H
            for i in 0..n {
                let mut dot = T.zero();
                for j in (k+1)..n {
                    dot = dot + h.get(i, j) * v.get(j - k - 1);
                }
                for j in (k+1)..n {
                    h.set(i, j, h.get(i, j) - dot * v.get(j - k - 1) * (T.one() + T.one()));
                }
            }
        }
    }

    // QR iteration on Hessenberg matrix
    let max_iter = 100 * n;
    let mut real_parts = Vector.zeros(n);
    let mut imag_parts = Vector.zeros(n);

    let mut p = n;
    for _ in 0..max_iter {
        if p <= 0 { break; }

        // Check for deflation
        while p > 1 {
            if h.get(p-1, p-2).abs() < T.epsilon() * (h.get(p-2, p-2).abs() + h.get(p-1, p-1).abs()) {
                h.set(p-1, p-2, T.zero());
                p = p - 1;
            } else {
                break;
            }
        }

        if p <= 1 {
            if p == 1 {
                real_parts.set(0, h.get(0, 0));
                imag_parts.set(0, T.zero());
            }
            break;
        }

        // Wilkinson shift
        let a11 = h.get(p-2, p-2);
        let a12 = h.get(p-2, p-1);
        let a21 = h.get(p-1, p-2);
        let a22 = h.get(p-1, p-1);

        let trace = a11 + a22;
        let det = a11 * a22 - a12 * a21;
        let disc = trace * trace / (T.one() + T.one() + T.one() + T.one()) - det;

        if disc < T.zero() {
            // Complex eigenvalues - extract 2x2 block
            real_parts.set(p-1, trace / (T.one() + T.one()));
            real_parts.set(p-2, trace / (T.one() + T.one()));
            let imag = (-disc).sqrt();
            imag_parts.set(p-1, imag);
            imag_parts.set(p-2, -imag);
            p = p - 2;
        } else {
            // Real shift - single QR step
            let shift = trace / (T.one() + T.one()) + copysign(disc.sqrt(), trace / (T.one() + T.one()) - a22);

            // Implicit QR step
            let mut x = h.get(0, 0) - shift;
            let mut z = h.get(1, 0);

            for k in 0..(p-1) {
                // Givens rotation
                let r = hypot(x, z);
                let c = if r > T.epsilon() { x / r } else { T.one() };
                let s = if r > T.epsilon() { z / r } else { T.zero() };

                // Apply from left
                for j in k..n.min(k+4) {
                    let hkj = h.get(k, j);
                    let hk1j = h.get(k+1, j);
                    h.set(k, j, c * hkj + s * hk1j);
                    h.set(k+1, j, -s * hkj + c * hk1j);
                }

                // Apply from right
                for i in 0..n.min(k+3) {
                    let hik = h.get(i, k);
                    let hik1 = h.get(i, k+1);
                    h.set(i, k, c * hik + s * hik1);
                    h.set(i, k+1, -s * hik + c * hik1);
                }

                if k < p - 2 {
                    x = h.get(k+1, k);
                    z = h.get(k+2, k);
                }
            }
        }
    }

    // Extract remaining eigenvalues from diagonal
    for i in 0..p {
        if imag_parts.get(i).abs() < T.epsilon() {
            real_parts.set(i, h.get(i, i));
            imag_parts.set(i, T.zero());
        }
    }

    ComplexEigenDecomposition {
        real_parts: real_parts,
        imag_parts: imag_parts,
    }
}

// =============================================================================
// Schur Decomposition
// =============================================================================

// Schur decomposition result: A = Z * T * Zᵀ
// - T: Upper quasi-triangular (real eigenvalues on diagonal, 2x2 blocks for complex pairs)
// - Z: Orthogonal matrix (Schur vectors)
public type SchurDecomposition<T: Numeric> is {
    t: Matrix<T>,   // Upper quasi-triangular
    z: Matrix<T>,   // Orthogonal Schur vectors
};

// Compute real Schur decomposition: A = Z * T * Zᵀ
// where T is upper quasi-triangular and Z is orthogonal
//
// # Algorithm
// Uses QR iteration with implicit double shifts.
// The matrix T has real eigenvalues on diagonal and 2x2 blocks
// for complex conjugate eigenvalue pairs.
//
// # Example
// ```verum
// let a = Matrix.from_data(list![0.0, -1.0, 1.0, 0.0], 2, 2);
// let decomp = schur(&a);
// // decomp.t is quasi-triangular, decomp.z is orthogonal
// ```
public fn schur<T: Numeric>(a: &Matrix<T>) -> SchurDecomposition<T> {
    let n = a.rows;
    assert(n == a.cols, "Matrix must be square");

    // Initialize T = A, Z = I
    let mut t = a.clone();
    let mut z = Matrix.eye(n);

    // Reduce to upper Hessenberg form while accumulating transformations in Z
    for k in 0..(n-2) {
        let mut norm_sq = T.zero();
        for i in (k+1)..n {
            norm_sq = norm_sq + t.get(i, k) * t.get(i, k);
        }

        if norm_sq > T.epsilon() {
            let alpha = -(copysign(norm_sq.sqrt(), t.get(k+1, k)));
            let r = ((alpha - t.get(k+1, k)) * alpha).sqrt();

            if r > T.epsilon() {
                let mut v = Vector.zeros(n - k - 1);
                v.set(0, (t.get(k+1, k) - alpha) / r);
                for i in (k+2)..n {
                    v.set(i - k - 1, t.get(i, k) / r);
                }

                // Apply H = I - 2vvᵀ from left: T = H * T
                for j in k..n {
                    let mut dot = T.zero();
                    for i in (k+1)..n {
                        dot = dot + v.get(i - k - 1) * t.get(i, j);
                    }
                    for i in (k+1)..n {
                        t.set(i, j, t.get(i, j) - v.get(i - k - 1) * dot * (T.one() + T.one()));
                    }
                }

                // Apply from right: T = T * H
                for i in 0..n {
                    let mut dot = T.zero();
                    for j in (k+1)..n {
                        dot = dot + t.get(i, j) * v.get(j - k - 1);
                    }
                    for j in (k+1)..n {
                        t.set(i, j, t.get(i, j) - dot * v.get(j - k - 1) * (T.one() + T.one()));
                    }
                }

                // Accumulate in Z: Z = Z * H
                for i in 0..n {
                    let mut dot = T.zero();
                    for j in (k+1)..n {
                        dot = dot + z.get(i, j) * v.get(j - k - 1);
                    }
                    for j in (k+1)..n {
                        z.set(i, j, z.get(i, j) - dot * v.get(j - k - 1) * (T.one() + T.one()));
                    }
                }
            }
        }
    }

    // QR iteration on Hessenberg form
    let max_iter = 100 * n;
    let mut p = n;

    for _ in 0..max_iter {
        if p <= 1 { break; }

        // Check for deflation
        while p > 1 {
            if t.get(p-1, p-2).abs() < T.epsilon() * (t.get(p-2, p-2).abs() + t.get(p-1, p-1).abs()) {
                t.set(p-1, p-2, T.zero());
                p = p - 1;
            } else {
                break;
            }
        }

        if p <= 1 { break; }

        // Double shift QR step
        let a11 = t.get(p-2, p-2);
        let a12 = t.get(p-2, p-1);
        let a21 = t.get(p-1, p-2);
        let a22 = t.get(p-1, p-1);

        let trace = a11 + a22;
        let det = a11 * a22 - a12 * a21;

        // Implicit double shift
        let mut x = t.get(0, 0) * t.get(0, 0) + t.get(0, 1) * t.get(1, 0) - trace * t.get(0, 0) + det;
        let mut y = t.get(1, 0) * (t.get(0, 0) + t.get(1, 1) - trace);
        let mut w = if p > 2 { t.get(2, 1) * t.get(1, 0) } else { T.zero() };

        for k in 0..(p-1) {
            // Householder to eliminate y, w
            let r = (x * x + y * y + w * w).sqrt();
            if r > T.epsilon() {
                let beta = copysign(r, x);
                let v0 = x + beta;
                let v1 = y;
                let v2 = w;
                let norm = (v0 * v0 + v1 * v1 + v2 * v2).sqrt();

                if norm > T.epsilon() {
                    let u0 = v0 / norm;
                    let u1 = v1 / norm;
                    let u2 = v2 / norm;

                    let j_start = if k > 0 { k - 1 } else { 0 };
                    let j_end = n;
                    let i_end = n.min(k + 4);

                    // Apply from left
                    for j in j_start..j_end {
                        let t0 = t.get(k, j);
                        let t1 = if k + 1 < n { t.get(k + 1, j) } else { T.zero() };
                        let t2 = if k + 2 < n && k + 2 < p { t.get(k + 2, j) } else { T.zero() };
                        let dot = u0 * t0 + u1 * t1 + u2 * t2;
                        t.set(k, j, t0 - dot * u0 * (T.one() + T.one()));
                        if k + 1 < n { t.set(k + 1, j, t1 - dot * u1 * (T.one() + T.one())); }
                        if k + 2 < n && k + 2 < p { t.set(k + 2, j, t2 - dot * u2 * (T.one() + T.one())); }
                    }

                    // Apply from right
                    for i in 0..i_end {
                        let t0 = t.get(i, k);
                        let t1 = if k + 1 < n { t.get(i, k + 1) } else { T.zero() };
                        let t2 = if k + 2 < n && k + 2 < p { t.get(i, k + 2) } else { T.zero() };
                        let dot = u0 * t0 + u1 * t1 + u2 * t2;
                        t.set(i, k, t0 - dot * u0 * (T.one() + T.one()));
                        if k + 1 < n { t.set(i, k + 1, t1 - dot * u1 * (T.one() + T.one())); }
                        if k + 2 < n && k + 2 < p { t.set(i, k + 2, t2 - dot * u2 * (T.one() + T.one())); }
                    }

                    // Accumulate in Z
                    for i in 0..n {
                        let z0 = z.get(i, k);
                        let z1 = if k + 1 < n { z.get(i, k + 1) } else { T.zero() };
                        let z2 = if k + 2 < n && k + 2 < p { z.get(i, k + 2) } else { T.zero() };
                        let dot = u0 * z0 + u1 * z1 + u2 * z2;
                        z.set(i, k, z0 - dot * u0 * (T.one() + T.one()));
                        if k + 1 < n { z.set(i, k + 1, z1 - dot * u1 * (T.one() + T.one())); }
                        if k + 2 < n && k + 2 < p { z.set(i, k + 2, z2 - dot * u2 * (T.one() + T.one())); }
                    }
                }
            }

            // Set up for next iteration
            if k < p - 2 {
                x = t.get(k + 1, k);
                y = t.get(k + 2, k);
                w = if k + 3 < p { t.get(k + 3, k) } else { T.zero() };
            }
        }
    }

    // Clean up subdiagonal (set small elements to zero)
    for i in 1..n {
        if t.get(i, i-1).abs() < T.epsilon() * (t.get(i-1, i-1).abs() + t.get(i, i).abs()) {
            t.set(i, i-1, T.zero());
        }
    }

    SchurDecomposition {
        t: t,
        z: z,
    }
}

