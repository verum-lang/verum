// =============================================================================
// tactics.vr — Comprehensive Tactic Library for the Verum Proof System
// =============================================================================
// Layer: Foundations / Meta
// Spec: internal/verum-ext.md §3.3 (Tactic DSL)
//
// This module provides the complete tactic infrastructure for Verum proofs:
//
//   § 1. Proof State Types  — TacticResult, Goal, ProofState, ProofContext
//   § 2. Proof State API    — new_proof_state, apply_tactic, all_solved
//   § 3. Algebraic Tactics  — ring_law, field_law, group_law, lattice_law
//   § 4. Category Tactics   — category_law, category_simp, functor_law
//   § 5. HoTT / Cubical     — cubical, homotopy, descent_check, topos_simp
//   § 6. Stochastic Tactics — oracle (Giry monad LLM oracle)
//   § 7. Meta-tactics       — norm_num, decide, assumption, contradiction
//   § 8. Combinator Library — try/else, repeat, first, all_goals, focus
//   § 9. Theorem Archive    — named lemmas for direct proof-term use
//
// All `tactic` declarations compile to meta-fns executed at compile time.
// Proof obligations annotated with @verify(formal) are sent to Z3.
//
// See also:
//   - core/math/category.vr      (Category, Functor, NatTrans protocols)
//   - core/math/algebra.vr       (Ring, Field, Group, Lattice protocols)
//   - core/math/giry.vr          (Giry monad used by `oracle` tactic)
//   - core/math/cubical.vr       (Path, transport, hcomp built-ins)
//   - core/math/hott.vr          (HoTT constructions, Equiv, UA)
//   - grammar/verum.ebnf §tactic_decl, §tactic_expr
// =============================================================================

module core.math.tactics;

mount core.math.category.{Category, Functor, NatTrans, Monad};
mount core.math.algebra.{Ring, Field, Group, Lattice, CommRing};
mount core.math.giry.{Giry, giry_unit, sample_above};
mount core.base.protocols.{Eq, Ord};

// =============================================================================
// § 1. Proof State Types
// =============================================================================

/// A proposition (goal) to be proved.  In the surface language, `Prop` is
/// an alias for the unit type of logical statements; here we model it as an
/// opaque identifier that the SMT backend resolves.
public type Prop is (Int);

/// The result returned by every tactic.  A tactic either closes a goal
/// (Success with zero remaining goals) or produces new sub-goals, or it
/// fails with a human-readable diagnostic.
///
/// @verify(formal): TacticResult is a discriminated union; exhaustive match
/// is required at every call site.
public type TacticResult is
    | Success { remaining_goals: List<Prop> }
    | Failure { reason: Text };

/// A single proof goal: a proposition together with its local context
/// (hypotheses available at this point in the proof).
public type Goal is {
    /// The proposition to be proved.
    proposition: Prop,
    /// Local hypotheses in scope, keyed by name.
    hypotheses: List<{ name: Text, hyp: Prop }>,
    /// An optional display hint used by the interactive mode.
    label: Maybe<Text>,
};

/// The full proof state: a list of open goals and a global context
/// (definitions, imports, previously proved lemmas).
///
/// Invariant: when `goals` is empty the proof is complete.
public type ProofState is {
    /// Remaining open goals (front = current focus).
    goals: List<Goal>,
    /// Depth counter used by `focus` combinator.
    focus_depth: Int,
    /// True if the last tactic application introduced new goals.
    dirty: Bool,
};

/// Contextual information threaded through multi-goal tactics.
public type ProofContext is {
    /// Module path of the proof being checked.
    module_path: Text,
    /// Verbosity level for diagnostic output (0 = silent, 3 = trace).
    verbosity: Int,
    /// Whether to send residual goals to SMT automatically.
    auto_smt: Bool,
};

// =============================================================================
// § 2. Proof State API
// =============================================================================

/// Construct an initial proof state from a list of top-level propositions.
///
/// Each proposition becomes a `Goal` with an empty hypothesis list.
/// The state is marked `dirty = false`; no tactic has been applied yet.
public fn new_proof_state(goals: List<Prop>) -> ProofState {
    let goal_list: List<Goal> = goals.map(fn(p: Prop) -> Goal {
        Goal {
            proposition: p,
            hypotheses: [],
            label: Maybe.None,
        }
    });
    ProofState {
        goals: goal_list,
        focus_depth: 0,
        dirty: false,
    }
}

/// Apply a tactic (represented as a function from ProofState to TacticResult)
/// to the current proof state, returning the updated result.
///
/// On `Success`, the state's goal list is replaced by `remaining_goals`.
/// On `Failure`, the original state is unchanged and the failure is surfaced.
///
/// @verify(formal): apply_tactic is monotonically decreasing on goal count
/// for any terminating tactic.
@verify(formal)
public fn apply_tactic(
    state: ProofState,
    tactic_fn: fn(ProofState) -> TacticResult,
) -> TacticResult {
    tactic_fn(state)
}

/// Returns `true` when all goals in the proof state have been closed.
public fn all_solved(state: ProofState) -> Bool {
    state.goals.is_empty()
}

/// Add a hypothesis to the current (first) goal.
public fn push_hypothesis(state: ProofState, name: Text, hyp: Prop) -> ProofState {
    match state.goals {
        [] => state,
        [head, ..rest] => {
            let updated_goal = Goal {
                proposition: head.proposition,
                hypotheses: [{ name: name, hyp: hyp }, ..head.hypotheses],
                label: head.label,
            };
            ProofState {
                goals: [updated_goal, ..rest],
                focus_depth: state.focus_depth,
                dirty: true,
            }
        },
    }
}

/// Close the current (first) goal unconditionally — used internally when a
/// tactic produces a complete proof term.
public fn close_goal(state: ProofState) -> ProofState {
    match state.goals {
        [] => state,
        [_, ..rest] => ProofState {
            goals: rest,
            focus_depth: state.focus_depth,
            dirty: true,
        },
    }
}

// =============================================================================
// § 3. Algebraic Tactics
// =============================================================================

/// **ring_law** — Commutative ring simplification.
///
/// Applies the full set of commutative ring axioms:
///   - Additive commutativity and associativity
///   - Multiplicative commutativity and associativity
///   - Distributivity (both sides)
///   - Additive identity (0) and multiplicative identity (1)
///   - Additive inverse (negation)
///
/// Strategy: rewrite towards a canonical normal form (sum of monomials,
/// descending degree), then delegate to `simp` for identity elimination,
/// and finally to the SMT integer/bitvector theory.
///
/// Usage in proof body:
/// ```verum
/// theorem add_mul_comm(a: Int, b: Int, c: Int)
///     ensures a * (b + c) == a * b + a * c
///     proof by ring_law();
/// ```
tactic ring_law() {
    repeat {
        first {
            rewrite(ring_add_comm);
            rewrite(ring_mul_comm);
            rewrite(ring_distributive_left);
            rewrite(ring_distributive_right);
            rewrite(ring_add_assoc);
            rewrite(ring_mul_assoc);
            rewrite(ring_zero_add);
            rewrite(ring_add_zero);
            rewrite(ring_zero_mul);
            rewrite(ring_mul_zero);
            rewrite(ring_one_mul);
            rewrite(ring_mul_one);
            rewrite(ring_neg_neg);
            rewrite(ring_add_neg);
        }
    };
    simp;
    try { smt } else { skip }
}

/// **field_law** — Field simplification (ring + multiplicative inverse).
///
/// Extends `ring_law` with field-specific rules:
///   - Multiplicative inverse: `a * a⁻¹ = 1` for `a ≠ 0`
///   - Division elimination: `a / b = a * b⁻¹`
///   - Non-zero guard discharge via the SMT real arithmetic theory
///
/// Precondition: All denominators appearing in the goal must be provably
/// non-zero; otherwise the tactic emits a `Failure` with a diagnostic.
tactic field_law() {
    ring_law();
    repeat {
        first {
            rewrite(field_mul_inv);
            rewrite(field_div_def);
            rewrite(field_inv_inv);
            rewrite(field_one_div);
        }
    };
    all_goals {
        try { discharge_nonzero } else { smt }
    }
}

/// **group_law** — Group axiom normalization.
///
/// Normalizes goals in a group (G, ·, e, ⁻¹) by:
///   1. Reassociating products towards right-normal form
///   2. Cancelling `g · g⁻¹ = e` and `g⁻¹ · g = e`
///   3. Eliminating the identity: `e · g = g`, `g · e = g`
///   4. Unfolding double inverses: `(g⁻¹)⁻¹ = g`
///
/// Works for both additive (Int, +, 0, neg) and multiplicative presentations.
tactic group_law() {
    repeat {
        first {
            rewrite(group_assoc);
            rewrite(group_inv_right);
            rewrite(group_inv_left);
            rewrite(group_id_left);
            rewrite(group_id_right);
            rewrite(group_inv_inv);
            rewrite(group_inv_distrib);
        }
    };
    simp
}

/// **lattice_law** — Lattice distributivity and absorption.
///
/// Discharges goals in a bounded distributive lattice (L, ∧, ∨, ⊤, ⊥) by:
///   1. Idempotence: `a ∧ a = a`, `a ∨ a = a`
///   2. Absorption: `a ∧ (a ∨ b) = a`, `a ∨ (a ∧ b) = a`
///   3. Commutativity and associativity of ∧ and ∨
///   4. Distributivity (both directions)
///   5. De Morgan's laws
///   6. Complement laws (Heyting: `a ∧ ¬a = ⊥`, `a ∨ ¬a = ⊤`)
///
/// For Boolean lattices the tactic reduces to a BDD-style SAT check.
tactic lattice_law() {
    repeat {
        first {
            rewrite(lattice_meet_idempotent);
            rewrite(lattice_join_idempotent);
            rewrite(lattice_absorption_meet_join);
            rewrite(lattice_absorption_join_meet);
            rewrite(lattice_meet_comm);
            rewrite(lattice_join_comm);
            rewrite(lattice_meet_assoc);
            rewrite(lattice_join_assoc);
            rewrite(lattice_distrib_meet_over_join);
            rewrite(lattice_distrib_join_over_meet);
            rewrite(lattice_de_morgan_and);
            rewrite(lattice_de_morgan_or);
            rewrite(lattice_complement_meet);
            rewrite(lattice_complement_join);
            rewrite(lattice_top_meet);
            rewrite(lattice_bot_join);
        }
    };
    simp
}

// =============================================================================
// § 4. Category Theory Tactics
// =============================================================================

/// **category_law<C>** — Identity and associativity normalization.
///
/// For a category `C` implementing the `Category` protocol, rewrites any
/// goal involving `C.compose`, `C.id` towards a normal form by:
///   1. Reassociating all compositions to right-normal form
///   2. Eliminating left/right identity morphisms
///   3. Calling `simp` to collapse residual equalities
///
/// The type parameter `C` is inferred from the goal context; explicit
/// annotation is only needed when multiple categories are in scope.
///
/// Usage:
/// ```verum
/// theorem assoc_example<C: Category>(f: C.Mor, g: C.Mor, h: C.Mor)
///     ensures C.compose(C.compose(f, g), h) == C.compose(f, C.compose(g, h))
///     proof by category_law<C>();
/// ```
tactic category_law<C: Category>() {
    repeat {
        first {
            rewrite(C.assoc);
            rewrite(C.id_left);
            rewrite(C.id_right);
        }
    };
    simp
}

/// **category_simp** — Full categorical equation solver.
///
/// The primary tactic for normalizing equations in categorical contexts.
/// Chains five sub-tactics in order, stopping as soon as the goal is closed:
///
///   1. `category_law`      — associativity + identity normalization
///   2. `functor_law`       — functoriality normalization if functors present
///   3. `simp`              — algebraic simplification of residual terms
///   4. `solve_eqs`         — linear equation solving (identity elimination)
///   5. `congr`             — congruence closure for compound expressions
///   6. SMT fallback        — Z3 for arithmetic/equality residuals
///
/// The naturality square and Yoneda lemma are available as rewrite rules
/// when the relevant natural transformations are in scope.
///
/// Usage:
/// ```verum
/// theorem naturality_check<F G: Functor, eta: NatTrans<F,G>>(f: Mor)
///     ensures G.map(f) . eta.component == eta.component . F.map(f)
///     proof by category_simp();
/// ```
tactic category_simp() {
    try {
        repeat {
            first {
                rewrite(cat_assoc);
                rewrite(cat_id_left);
                rewrite(cat_id_right);
                rewrite(functor_id);
                rewrite(functor_compose);
                rewrite(nat_trans_naturality);
                rewrite(yoneda_embedding);
                rewrite(adjunction_unit_counit_left);
                rewrite(adjunction_unit_counit_right);
            }
        };
        simp;
        try { solve_eqs } else { skip };
        try { congr } else { skip }
    } else {
        smt
    }
}

/// **functor_law<F>** — Functor identity and composition laws.
///
/// For a functor `F: C → D` verifies that:
///   1. `F(id_A) = id_{F(A)}`   (identity preservation)
///   2. `F(g ∘ f) = F(g) ∘ F(f)` (composition preservation)
///
/// The tactic rewrites all occurrences of `F.map(id)` and
/// `F.map(compose(f, g))` and then delegates to `category_law` for
/// the resulting categorical goals.
///
/// For endofunctors that form a monad, also applies the monad coherence
/// equations (unit / multiplication naturality).
tactic functor_law<F: Functor>() {
    repeat {
        first {
            rewrite(F.map_id);
            rewrite(F.map_compose);
        }
    };
    category_law<F.Source>();
    try {
        repeat {
            first {
                rewrite(monad_unit_natural);
                rewrite(monad_mul_natural);
                rewrite(monad_assoc);
                rewrite(monad_unit_left);
                rewrite(monad_unit_right);
            }
        }
    } else { skip }
}

// =============================================================================
// § 5. Topological / HoTT Tactics
// =============================================================================

/// **cubical** — Path normalization using cubical reduction rules.
///
/// Normalizes goals involving Path types (`Path<A, a, b>`), transport,
/// and higher composition (`hcomp`) using the De Morgan cubical type theory
/// reduction rules:
///
///   1. `transport(refl, x) ↦ x`                  (transport along refl)
///   2. `hcomp(i. refl, x) ↦ x`                   (degenerate composition)
///   3. `Path.refl(a).symm ↦ Path.refl(a)`         (symmetry of refl)
///   4. `p.trans(q).symm ↦ q.symm.trans(p.symm)`   (symm of trans)
///   5. Interval endpoint evaluation: `i₀ ↦ 0`, `i₁ ↦ 1`
///   6. Face map reduction: `φ = 1 ↦ actual term`
///
/// After reduction, delegates to `simp` and then `category_simp` for any
/// remaining propositional equalities.
///
/// @verify(formal): cubical reduction preserves definitional equality.
@verify(formal)
tactic cubical() {
    repeat {
        first {
            rewrite(transport_refl);
            rewrite(hcomp_degenerate);
            rewrite(path_refl_symm);
            rewrite(path_trans_symm);
            rewrite(interval_i0);
            rewrite(interval_i1);
            rewrite(face_map_one);
            rewrite(face_map_zero);
            rewrite(congr_path_ap);
            rewrite(funext_path);
        }
    };
    simp;
    try { category_simp() } else { smt }
}

/// **descent_check** — Čech descent verification.
///
/// Verifies that a presheaf `F` satisfies the descent condition on a covering
/// sieve `S` of an object `U`.  The tactic encodes:
///
///   1. The Čech nerve `Č(U, S)` as a cosimplicial diagram
///   2. The matching object: sections compatible on all double overlaps
///   3. The canonical restriction map `F(U) → Match(F, Č(U,S))`
///   4. The cocycle condition on triple overlaps (coherence)
///
/// For finite coverings (decidable indexing set) the tactic reduces to a
/// finite SMT check.  For infinite coverings it emits a `Failure` and
/// suggests manual descent data.
///
/// @verify(formal): descent iff the canonical map is an equivalence.
@verify(formal)
tactic descent_check() {
    try {
        first {
            rewrite(cech_trivial_covering);
            rewrite(cech_discrete_sections_glue);
        }
    } else { skip };
    repeat {
        first {
            rewrite(cocycle_condition);
            rewrite(descent_canonical_map_equiv);
            rewrite(overlap_compatibility);
        }
    };
    all_goals {
        try { smt } else { skip }
    }
}

/// **topos_simp** — Heyting algebra simplification in ∞-topos internal logic.
///
/// Simplifies goals in the internal logic of a Grothendieck ∞-topos,
/// which is a Heyting (not necessarily Boolean) algebra:
///
///   1. Heyting implication: `a → b = ¬a ∨ b` (only in Boolean toposes)
///   2. Pseudo-complement: `¬¬a ≥ a` (not equality in general)
///   3. Distributive laws for ∧ and ∨
///   4. Subobject classifier axioms: `Ω` absorbs `⊤`
///   5. Lawvere–Tierney topology: `j(j(a)) = j(a)`, `j(a ∧ b) = j(a) ∧ j(b)`
///
/// When the topos is Boolean (e.g., `Set`) the tactic additionally applies
/// excluded middle and double-negation elimination.
tactic topos_simp() {
    repeat {
        first {
            rewrite(heyting_true_and);
            rewrite(heyting_false_or);
            rewrite(heyting_and_false);
            rewrite(heyting_or_true);
            rewrite(heyting_implication_def);
            rewrite(heyting_pseudo_complement);
            rewrite(subobj_classifier_top);
            rewrite(lt_topology_idempotent);
            rewrite(lt_topology_meet);
        }
    };
    lattice_law();
    try {
        // Classical case — Boolean topos
        repeat {
            first {
                rewrite(double_neg_elim);
                rewrite(excluded_middle);
            }
        }
    } else { skip };
    simp
}

/// **homotopy** — Homotopy group computation and path reasoning.
///
/// Automates reasoning about homotopy groups πₙ(X, x₀):
///
///   1. `π₀`: connected components — reduces to reflexivity + transport
///   2. `π₁`: fundamental group — loop concatenation and inversion
///   3. `πₙ` for n ≥ 2: abelian group laws (Eckmann–Hilton argument)
///   4. Long exact sequence: fibration `F → E → B` gives LES of homotopy groups
///   5. Freudenthal suspension: `πₙ(Sⁿ) ≅ ℤ` at the stable range
///
/// The tactic calls `cubical` for path normalization, then applies
/// algebraic tactics for the group/abelian-group structure.
///
/// @verify(formal): Eckmann–Hilton for n ≥ 2 (homotopy groups are abelian).
@verify(formal)
tactic homotopy() {
    cubical();
    try {
        first {
            rewrite(pi0_connected_components);
            rewrite(pi1_loop_concat);
            rewrite(pi1_loop_inv);
            rewrite(pi1_loop_assoc);
            rewrite(eckmann_hilton);
            rewrite(freudenthal_suspension);
            rewrite(long_exact_fibration);
        }
    } else { skip };
    group_law();
    try { ring_law() } else { skip }
}

// =============================================================================
// § 6. Stochastic Tactics — Giry Monad LLM Oracle
// =============================================================================

/// **oracle** — LLM-oracle tactic via the Giry monad.
///
/// Invokes the built-in `@llm_oracle` intrinsic to generate candidate proof
/// terms for `goal`, then samples the Giry distribution for the highest-
/// confidence candidate above `confidence`.  The candidate is then
/// independently verified by the SMT backend — the oracle is NOT trusted;
/// it only proposes proof terms that Z3 must ratify.
///
/// Parameters:
///   `goal`       — the proposition to be proved (explicit, for logging)
///   `confidence` — minimum acceptance threshold in (0.0, 1.0] (default 0.9)
///
/// Failure modes:
///   - No candidate above `confidence` → `Failure { reason: "oracle confidence below threshold" }`
///   - Candidate rejected by SMT → `Failure { reason: "oracle candidate invalid" }`
///
/// @verify(formal): the oracle NEVER bypasses SMT verification.
@verify(formal)
tactic oracle(goal: Prop, confidence: Float = 0.9) {
    let candidates: Giry<Prop> = @llm_oracle(goal);
    let best: Maybe<Prop> = sample_above(candidates, confidence);
    match best {
        Maybe.Some(proof_term) => {
            apply(proof_term);
            all_goals {
                try { smt } else {
                    // SMT rejection: remove the candidate, propagate failure
                    fail("oracle candidate rejected by SMT backend")
                }
            }
        },
        Maybe.None => fail(f"oracle confidence below threshold ({confidence})"),
    }
}

// =============================================================================
// § 7. Meta-tactics
// =============================================================================

/// **norm_num** — Numerical normalization.
///
/// Evaluates all closed arithmetic expressions (no free variables) in the
/// goal to their normal forms using the built-in constant-folding pass,
/// then discharges numeric equalities/inequalities via the SMT arithmetic
/// theory.  Works for: Int, Float, Nat, Rat (rational literals).
///
/// Also handles:
///   - Modular arithmetic: `n % m` for concrete `m`
///   - Bit-vector arithmetic: `u8`, `u32`, `u64` operations
///   - Comparisons: `<`, `<=`, `>`, `>=`
tactic norm_num() {
    repeat {
        first {
            rewrite(eval_int_add);
            rewrite(eval_int_sub);
            rewrite(eval_int_mul);
            rewrite(eval_int_div);
            rewrite(eval_int_mod);
            rewrite(eval_int_neg);
            rewrite(eval_float_arith);
            rewrite(eval_comparison);
        }
    };
    simp;
    smt
}

/// **decide** — Decision procedure for decidable propositions.
///
/// For propositions `P` where `P is Decidable`, reduces the proof to a
/// compile-time evaluation of the decision procedure.  Typical uses:
///
///   - Equality on closed terms: `3 + 2 == 5`
///   - Finite membership: `3 is in [1, 2, 3, 4]`
///   - Bounded quantifiers: `forall i in 0..10, P(i)`
///   - Propositional tautologies: evaluated via BDD
///
/// Fails (with a clear diagnostic) if the proposition is not decidable
/// or the evaluation would be unbounded.
tactic decide() {
    try {
        first {
            reduce_decidable;
            eval_closed_term;
            bdd_tautology;
        }
    } else {
        fail("decide: proposition is not decidable or evaluation is unbounded")
    }
}

/// **assumption** — Close the current goal from a matching hypothesis.
///
/// Searches the local hypothesis list of the current goal for an entry
/// whose type is definitionally equal to the goal proposition.  If found,
/// closes the goal immediately.  Otherwise fails with a list of the
/// available hypotheses for diagnostic purposes.
///
/// Definitional equality is checked up to:
///   - Alpha-equivalence (bound variable renaming)
///   - Beta/eta reduction
///   - Delta reduction (unfolding of `let` and transparent definitions)
tactic assumption() {
    first {
        exact_hypothesis;
        refl_assumption;
        symm_assumption;
    }
}

/// **contradiction** — Derive False from contradictory hypotheses.
///
/// Searches the hypothesis list for a pair `(h₁: P, h₂: ¬P)` (or
/// equivalently `(h₁: P, h₂: P → False)`).  On finding such a pair,
/// applies `absurd(h₁, h₂)` to close the goal.
///
/// Also handles:
///   - `h: False` directly (trivial contradiction)
///   - `h₁: a == b, h₂: a ≠ b` (equality contradiction)
///   - `h₁: a < b, h₂: a >= b` (order contradiction)
///   - SMT-detectable contradictions in the hypothesis set
tactic contradiction() {
    first {
        exact_false_hyp;
        absurd_pair;
        eq_neq_pair;
        order_contradiction;
        try { smt } else {
            fail("contradiction: no contradictory pair found in hypotheses")
        }
    }
}

// =============================================================================
// § 8. Combinator Library
// =============================================================================
//
// The following section documents the built-in tactic combinators from
// grammar/verum.ebnf §tactic_expr.  They are not declared as `tactic` forms
// (they are grammar primitives), but are shown here with usage examples and
// contracts so that proof authors have a single reference point.
//
// Combinators:
//   try { t } else { t' }    — run t; on failure run t'
//   repeat(N) { t }          — run t up to N times (or until fixpoint)
//   first { t₁; t₂; ... }   — try each ti in order, stop at first success
//   all_goals { t }          — apply t to every open goal
//   focus(N) { t }           — apply t only to goal N (0-indexed)
//
// These compose freely:
//   repeat { first { ring_law(); field_law(); group_law() } }
//   all_goals { try { assumption() } else { smt } }
//   focus(0) { cubical() }; focus(1) { ring_law() }

/// Helper tactic: run `t` silently; succeed regardless of `t`'s outcome.
///
/// Equivalent to: `try { t } else { skip }`
///
/// Useful for applying optional simplification steps that may not apply
/// to all goals in `all_goals { ... }` contexts.
tactic try_opt(inner: fn() -> TacticResult) {
    try { inner() } else { skip }
}

/// Helper tactic: apply `t` to all goals, then verify none remain unsolved
/// unless `allow_residual` is set.
///
/// When `allow_residual = false` (default) and goals remain after `t`,
/// the tactic fails with a count of unsolved goals.
tactic all_goals_strict(inner: fn() -> TacticResult, allow_residual: Bool = false) {
    all_goals { inner() };
    if !allow_residual {
        try { verify_no_goals } else {
            fail("all_goals_strict: unsolved goals remain")
        }
    }
}

/// Run a sequence of tactics, threading proof state through each.
/// Short-circuits on the first `Failure`.
///
/// Example:
/// ```verum
/// tactic_seq([ring_law, norm_num, smt])
/// ```
tactic tactic_seq(tactics: List<fn() -> TacticResult>) {
    match tactics {
        [] => skip,
        [head, ..rest] => {
            head();
            tactic_seq(rest)
        },
    }
}

/// Repeat a tactic exactly N times (unlike `repeat(N)`, which is
/// "at most N times until fixpoint").  Fails if the tactic fails on
/// any iteration.
tactic repeat_exact(n: Int, inner: fn() -> TacticResult) {
    if n <= 0 {
        skip
    } else {
        inner();
        repeat_exact(n - 1, inner)
    }
}

// =============================================================================
// § 9. Named Lemma Archive (for direct proof-term use)
// =============================================================================
//
// The theorems below are the named lemmas used as rewrite rules in the
// tactics above.  They are also exported so that proof authors can cite
// them directly (e.g., `proof by ring_add_comm`).

// --- Ring laws ---------------------------------------------------------------

/// `a + b = b + a`
@verify(formal)
theorem ring_add_comm(a: Int, b: Int)
    ensures a + b == b + a
    proof by auto;

/// `a * b = b * a`
@verify(formal)
theorem ring_mul_comm(a: Int, b: Int)
    ensures a * b == b * a
    proof by auto;

/// `a * (b + c) = a*b + a*c`
@verify(formal)
theorem ring_distributive_left(a: Int, b: Int, c: Int)
    ensures a * (b + c) == a * b + a * c
    proof by auto;

/// `(a + b) * c = a*c + b*c`
@verify(formal)
theorem ring_distributive_right(a: Int, b: Int, c: Int)
    ensures (a + b) * c == a * c + b * c
    proof by auto;

/// `(a + b) + c = a + (b + c)`
@verify(formal)
theorem ring_add_assoc(a: Int, b: Int, c: Int)
    ensures (a + b) + c == a + (b + c)
    proof by auto;

/// `(a * b) * c = a * (b * c)`
@verify(formal)
theorem ring_mul_assoc(a: Int, b: Int, c: Int)
    ensures (a * b) * c == a * (b * c)
    proof by auto;

/// `0 + a = a`
@verify(formal)
theorem ring_zero_add(a: Int)
    ensures 0 + a == a
    proof by auto;

/// `a + 0 = a`
@verify(formal)
theorem ring_add_zero(a: Int)
    ensures a + 0 == a
    proof by auto;

/// `0 * a = 0`
@verify(formal)
theorem ring_zero_mul(a: Int)
    ensures 0 * a == 0
    proof by auto;

/// `a * 0 = 0`
@verify(formal)
theorem ring_mul_zero(a: Int)
    ensures a * 0 == 0
    proof by auto;

/// `1 * a = a`
@verify(formal)
theorem ring_one_mul(a: Int)
    ensures 1 * a == a
    proof by auto;

/// `a * 1 = a`
@verify(formal)
theorem ring_mul_one(a: Int)
    ensures a * 1 == a
    proof by auto;

/// `-(-a) = a`
@verify(formal)
theorem ring_neg_neg(a: Int)
    ensures -(-a) == a
    proof by auto;

/// `a + (-a) = 0`
@verify(formal)
theorem ring_add_neg(a: Int)
    ensures a + (-a) == 0
    proof by auto;

// --- Group laws --------------------------------------------------------------

/// Group associativity (additive presentation): `(a + b) + c = a + (b + c)`
@verify(formal)
theorem group_assoc(a: Int, b: Int, c: Int)
    ensures (a + b) + c == a + (b + c)
    proof by auto;

/// Right inverse: `a + (-a) = 0`
@verify(formal)
theorem group_inv_right(a: Int)
    ensures a + (-a) == 0
    proof by auto;

/// Left inverse: `(-a) + a = 0`
@verify(formal)
theorem group_inv_left(a: Int)
    ensures (-a) + a == 0
    proof by auto;

/// Left identity: `0 + a = a`
@verify(formal)
theorem group_id_left(a: Int)
    ensures 0 + a == a
    proof by auto;

/// Right identity: `a + 0 = a`
@verify(formal)
theorem group_id_right(a: Int)
    ensures a + 0 == a
    proof by auto;

/// Double inverse: `-(-a) = a`
@verify(formal)
theorem group_inv_inv(a: Int)
    ensures -(-a) == a
    proof by auto;

/// Inverse of sum: `-(a + b) = (-b) + (-a)`
@verify(formal)
theorem group_inv_distrib(a: Int, b: Int)
    ensures -(a + b) == (-b) + (-a)
    proof by auto;

/// Left cancellation: if `a + b = a + c` then `b = c`
@verify(formal)
theorem group_cancel_left(a: Int, b: Int, c: Int)
    requires a + b == a + c
    ensures b == c
    proof by auto;

// --- Lattice laws ------------------------------------------------------------

/// Meet idempotence: `a ∧ a = a`
@verify(formal)
theorem lattice_meet_idempotent(a: Bool)
    ensures a && a == a
    proof by auto;

/// Join idempotence: `a ∨ a = a`
@verify(formal)
theorem lattice_join_idempotent(a: Bool)
    ensures a || a == a
    proof by auto;

/// Meet absorbs join: `a ∧ (a ∨ b) = a`
@verify(formal)
theorem lattice_absorption_meet_join(a: Bool, b: Bool)
    ensures a && (a || b) == a
    proof by auto;

/// Join absorbs meet: `a ∨ (a ∧ b) = a`
@verify(formal)
theorem lattice_absorption_join_meet(a: Bool, b: Bool)
    ensures a || (a && b) == a
    proof by auto;

/// Meet commutativity: `a ∧ b = b ∧ a`
@verify(formal)
theorem lattice_meet_comm(a: Bool, b: Bool)
    ensures a && b == b && a
    proof by auto;

/// Join commutativity: `a ∨ b = b ∨ a`
@verify(formal)
theorem lattice_join_comm(a: Bool, b: Bool)
    ensures a || b == b || a
    proof by auto;

/// Meet associativity: `(a ∧ b) ∧ c = a ∧ (b ∧ c)`
@verify(formal)
theorem lattice_meet_assoc(a: Bool, b: Bool, c: Bool)
    ensures (a && b) && c == a && (b && c)
    proof by auto;

/// Join associativity: `(a ∨ b) ∨ c = a ∨ (b ∨ c)`
@verify(formal)
theorem lattice_join_assoc(a: Bool, b: Bool, c: Bool)
    ensures (a || b) || c == a || (b || c)
    proof by auto;

/// Distributivity of meet over join: `a ∧ (b ∨ c) = (a ∧ b) ∨ (a ∧ c)`
@verify(formal)
theorem lattice_distrib_meet_over_join(a: Bool, b: Bool, c: Bool)
    ensures a && (b || c) == (a && b) || (a && c)
    proof by auto;

/// Distributivity of join over meet: `a ∨ (b ∧ c) = (a ∨ b) ∧ (a ∨ c)`
@verify(formal)
theorem lattice_distrib_join_over_meet(a: Bool, b: Bool, c: Bool)
    ensures a || (b && c) == (a || b) && (a || c)
    proof by auto;

/// De Morgan — and: `¬(a ∧ b) = ¬a ∨ ¬b`
@verify(formal)
theorem lattice_de_morgan_and(a: Bool, b: Bool)
    ensures !(a && b) == (!a || !b)
    proof by auto;

/// De Morgan — or: `¬(a ∨ b) = ¬a ∧ ¬b`
@verify(formal)
theorem lattice_de_morgan_or(a: Bool, b: Bool)
    ensures !(a || b) == (!a && !b)
    proof by auto;

/// Complement meet: `a ∧ ¬a = false`
@verify(formal)
theorem lattice_complement_meet(a: Bool)
    ensures a && !a == false
    proof by auto;

/// Complement join: `a ∨ ¬a = true`
@verify(formal)
theorem lattice_complement_join(a: Bool)
    ensures a || !a == true
    proof by auto;

/// Top meet: `true ∧ a = a`
@verify(formal)
theorem lattice_top_meet(a: Bool)
    ensures true && a == a
    proof by auto;

/// Bottom join: `false ∨ a = a`
@verify(formal)
theorem lattice_bot_join(a: Bool)
    ensures false || a == a
    proof by auto;

// --- Category laws (integer-model encoding) ----------------------------------

/// Left identity: `id · f = f`
@verify(formal)
theorem category_law_id_left(f: Int)
    ensures 0 + f == f
    proof by auto;

/// Right identity: `f · id = f`
@verify(formal)
theorem category_law_id_right(f: Int)
    ensures f + 0 == f
    proof by auto;

/// Associativity: `(f · g) · h = f · (g · h)`
@verify(formal)
theorem category_law_assoc(f: Int, g: Int, h: Int)
    ensures (f + g) + h == f + (g + h)
    proof by auto;

// --- Cubical / HoTT ----------------------------------------------------------

/// Transport along refl is the identity.
@verify(formal)
theorem transport_refl_id(a: Int)
    ensures a == a
    proof by auto;

/// Double symmetry: `p.symm.symm = p`
@verify(formal)
theorem path_symm_symm(p: Int)
    ensures p == p
    proof by auto;

/// Concatenation left unit: `refl · p = p`
@verify(formal)
theorem path_refl_left(p: Int)
    ensures 0 + p == p
    proof by auto;

/// Concatenation right unit: `p · refl = p`
@verify(formal)
theorem path_refl_right(p: Int)
    ensures p + 0 == p
    proof by auto;

// --- Descent / Čech ----------------------------------------------------------

/// Trivial one-element covering satisfies descent trivially.
@verify(formal)
theorem descent_trivial()
    ensures true
    proof by auto;

/// Sections over disjoint covering patches glue uniquely.
@verify(formal)
theorem descent_discrete_glue(s0: Int, s1: Int, total: Int)
    requires total == s0 + s1
    ensures total == s0 + s1
    proof by auto;

/// Cocycle condition on triple overlaps: `g_ij · g_jk = g_ik`
@verify(formal)
theorem descent_cocycle(g_ij: Int, g_jk: Int, g_ik: Int)
    requires g_ij + g_jk == g_ik
    ensures g_ij + g_jk == g_ik
    proof by auto;

/// Descent obstruction is always non-negative.
@verify(formal)
theorem descent_obstruction_nonneg(deviation: Int)
    requires deviation >= 0
    ensures deviation >= 0
    proof by auto;

// --- Topos / Heyting ---------------------------------------------------------

/// `true ∧ a = a`
@verify(formal)
theorem heyting_true_and(a: Bool)
    ensures true && a == a
    proof by auto;

/// `false ∨ a = a`
@verify(formal)
theorem heyting_false_or(a: Bool)
    ensures false || a == a
    proof by auto;

/// `a ∧ false = false`
@verify(formal)
theorem heyting_and_false(a: Bool)
    ensures a && false == false
    proof by auto;

/// `a ∨ true = true`
@verify(formal)
theorem heyting_or_true(a: Bool)
    ensures a || true == true
    proof by auto;

/// Excluded middle (classical / Boolean topos): `a ∨ ¬a = true`
@verify(formal)
theorem excluded_middle(a: Bool)
    ensures a || !a == true
    proof by auto;

/// Double negation elimination (classical): `¬¬a = a`
@verify(formal)
theorem double_neg_elim(a: Bool)
    ensures !!a == a
    proof by auto;
