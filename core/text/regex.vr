// =============================================================================
// text/regex.vr - Regular Expression Support
// =============================================================================
// Layer: 1 (Text)
// Dependencies: core
// =============================================================================
//
// Provides the Regex type for pattern matching on text. Regex values are
// typically created from `re#"..."` or `rx#"..."` tagged literals, which the
// parser desugars to `Regex.new(pattern).unwrap_or_else(...)`.
//
// # Runtime
//
// Each operation forwards to a Verum intrinsic backed by the `regex` 1.x
// crate inside the VBC interpreter (and by the same engine after AOT
// lowering). Pattern compilation happens **per call**: today we do not cache
// the compiled DFA across calls. That is a deliberate v1 trade-off — the
// `regex` crate's `is_match` of a small pre-validated pattern runs in single-
// digit microseconds, and most callers reuse a small set of literal
// patterns where the DFA cache inside the crate already absorbs the cost.
// A v2 may introduce a per-Regex compiled handle once we surface a
// fallible `Regex.compile` returning a runtime-side handle.
//
// # Available operations
//
// All seven core intrinsics are wired end-to-end:
//   * `is_match` — boolean test
//   * `find_all` — all matches as a list
//   * `replace_all` — replace every match
//   * `split` — split on the pattern
//   * `find` — first match only (`Maybe<Text>`)
//   * `replace` — replace first match only
//   * `captures` — capture groups of the first match
//
// The interpreter kernel (verum_vbc/src/interpreter/kernel/mod.rs) hosts the
// dispatchers; the intrinsic registry (verum_vbc/src/intrinsics/registry.rs)
// advertises them under the canonical lowercase names. The bulk variants
// occupy `TensorSubOpcode` 0xE0..=0xE3; the single-match variants live in
// `TensorExtSubOpcode` 0x0A..=0x0C because the regex-dedicated 0xE4 slot in
// `TensorSubOpcode` was filled by tensor-creation ops before they landed.
// =============================================================================

module regex;

mount core.*;

// =============================================================================
// Regex Type
// =============================================================================

/// A compiled regular expression pattern. Internally stores the pattern
/// string only; the runtime compiles a fresh `regex.Regex` on each call.
public type Regex is {
    /// The original pattern string.
    pattern: Text,
};

/// Error returned when a pattern string cannot be compiled into a `Regex`.
/// The current runtime defers structural validation to match-time — every
/// `Regex.new` succeeds — so this error is reserved for callers that
/// pre-validate via a future `Regex.compile`.
public type RegexError is { message: Text };

implement Display for RegexError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.message.as_str())
    }
}

implement Debug for RegexError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"RegexError {{ message: {self.message} }}".as_str())
    }
}

implement Eq for RegexError {
    fn eq(&self, other: &RegexError) -> Bool {
        self.message == other.message
    }
}

// =============================================================================
// Regex Methods
// =============================================================================

implement Regex {
    /// Construct a `Regex` from a pattern string.
    ///
    /// Returns `Result<Regex, RegexError>` for forward compatibility with a
    /// future fallible compile; today every call is `Ok` because compilation
    /// is deferred to match-time. Catches malformed patterns at compile-time
    /// will land alongside the cached-handle migration.
    public fn new(pattern: Text) -> Result<Regex, RegexError> {
        Ok(Regex { pattern: pattern })
    }

    /// Test whether the pattern matches anywhere in the given text.
    public fn is_match(&self, text: Text) -> Bool {
        regex_is_match(self.pattern, text)
    }

    /// Find all non-overlapping matches of the pattern in the text.
    /// Returns an empty list if no match.
    public fn find_all(&self, text: Text) -> List<Text> {
        regex_find_all(self.pattern, text)
    }

    /// Replace all matches with the replacement string. Replacement supports
    /// `$N` (1-indexed) capture-group back-references — `regex` crate
    /// semantics.
    public fn replace_all(&self, text: Text, replacement: Text) -> Text {
        regex_replace_all(self.pattern, text, replacement)
    }

    /// Split the text by every match of the pattern.
    public fn split(&self, text: Text) -> List<Text> {
        regex_split(self.pattern, text)
    }

    /// Find the first match of the pattern in the text.
    /// Returns `None` if no match.
    public fn find(&self, text: Text) -> Maybe<Text> {
        regex_find(self.pattern, text)
    }

    /// Replace the first match with the replacement string.
    /// Returns the input unchanged if no match. Supports `$N`
    /// capture-group back-references in `replacement`.
    public fn replace(&self, text: Text, replacement: Text) -> Text {
        regex_replace(self.pattern, text, replacement)
    }

    /// Run the pattern against `text` and return the ordered group
    /// captures of the first match.
    ///
    /// Layout: `result[0]` is always the whole match; `result[i]`
    /// for `i >= 1` is the i-th `(group)` capture. Non-participating
    /// groups appear as empty strings — callers that want
    /// `Maybe<Text>` per group should re-check membership against
    /// the pattern's group count. Returns `None` if no match.
    public fn captures(&self, text: Text) -> Maybe<List<Text>> {
        regex_captures(self.pattern, text)
    }

    /// Returns the original pattern string.
    public fn as_str(&self) -> Text {
        self.pattern
    }
}

// =============================================================================
// Intrinsic Declarations
// =============================================================================
// These names match the registry entries in
// verum_vbc/src/intrinsics/registry.rs, lowercase-with-underscores per the
// canonical `@intrinsic("…")` convention used elsewhere in core/intrinsics/.

@intrinsic("regex_is_match")
public fn regex_is_match(pattern: Text, text: Text) -> Bool;

@intrinsic("regex_find_all")
public fn regex_find_all(pattern: Text, text: Text) -> List<Text>;

@intrinsic("regex_replace_all")
public fn regex_replace_all(pattern: Text, text: Text, replacement: Text) -> Text;

@intrinsic("regex_split")
public fn regex_split(pattern: Text, text: Text) -> List<Text>;

@intrinsic("regex_find")
public fn regex_find(pattern: Text, text: Text) -> Maybe<Text>;

@intrinsic("regex_replace")
public fn regex_replace(pattern: Text, text: Text, replacement: Text) -> Text;

@intrinsic("regex_captures")
public fn regex_captures(pattern: Text, text: Text) -> Maybe<List<Text>>;
