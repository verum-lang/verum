// =============================================================================
// text/regex.vr - Regular Expression Support
// =============================================================================
// Layer: 1 (Text)
// Dependencies: core
// =============================================================================
//

// Provides the Regex type for pattern matching on text. Regex values are
// typically created from `re#"..."` or `rx#"..."` tagged literals, which the
// parser desugars to `Regex.new(pattern).unwrap_or_else(...)`.
//

// # Runtime
//

// Every operation delegates to the PURE-VERUM engine in
// `core/text/regex_engine.vr` (task #47 / AOT-REGEX-RUNTIME-1) — ONE
// implementation compiled like any other stdlib code, identical on the
// Tier-0 interpreter and Tier-1 AOT binaries. The previous intrinsic
// forwarding (Rust `regex` crate inside the interpreter) had NO Tier-1
// counterpart: standalone AOT binaries answered `is_match=false` where
// the interpreter answered true, and the single-match intrinsics
// mislowered through the 0xFF ext-opcode envelope into batch-norm calls.
// Pattern compilation is still per call (the documented v1 trade-off);
// `rx_parse` returns a plain `RxProg` value, so a future fallible
// `Regex.compile` can cache the parsed program without engine changes.
//

// # Available operations
//

// All seven core intrinsics are wired end-to-end:
//  * `is_match` — boolean test
//  * `find_all` — all matches as a list
//  * `replace_all` — replace every match
//  * `split` — split on the pattern
//  * `find` — first match only (`Maybe<Text>`)
//  * `replace` — replace first match only
//  * `captures` — capture groups of the first match
//

// Pattern surface (engine v2; malformed constructs are REJECTED at
// parse, never mis-accepted): literals + escapes, `[...]`/`[^...]`
// classes with ranges and in-class escapes, ASCII `\d \w \s` (+ negated
// uppercase forms), `.`, greedy `* + ? {m} {m,} {m,n}` over any atom
// INCLUDING capture groups, alternation `|` (top level and grouped,
// leftmost-first), anchors `^ $`, positional capture groups with
// last-repetition semantics. See core/text/regex_engine.vr.
// =============================================================================

module regex;

mount core.*;
mount .regex_engine.{
    rxe_is_match, rxe_find, rxe_find_all,
    rxe_replace, rxe_replace_all, rxe_split, rxe_captures,
    rx_parse, RxProg,
};

// =============================================================================
// Regex Type
// =============================================================================

/// A compiled regular expression pattern. Internally stores the pattern
/// string only; the runtime compiles a fresh `regex.Regex` on each call.
public type Regex is {
    /// The original pattern string.
    pattern: Text,
};

/// Error returned when a pattern string cannot be compiled into a `Regex`.
/// The current runtime defers structural validation to match-time — every
/// `Regex.new` succeeds — so this error is reserved for callers that
/// pre-validate via a future `Regex.compile`.
public type RegexError is { message: Text };

implement Display for RegexError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.message.as_str())
    }
}

implement Debug for RegexError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"RegexError {{ message: {self.message} }}".as_str())
    }
}

implement Eq for RegexError {
    fn eq(&self, other: &RegexError) -> Bool {
        self.message == other.message
    }
}

// =============================================================================
// Regex Methods
// =============================================================================

implement Regex {
    /// Construct a `Regex` from a pattern string.
    ///

    /// Returns `Err(RegexError)` when the pattern fails to parse
    /// (unclosed group/class, dangling quantifier, v2-only construct);
    /// well-formed patterns always construct. Matching re-parses per
    /// call (documented v1 trade-off) — a cached-handle `Regex.compile`
    /// can layer on top of `rx_parse`'s plain-value `RxProg`.
    public fn new(pattern: Text) -> Result<Regex, RegexError> {
        // Real structural validation — the pure-Verum engine's parser
        // rejects malformed patterns (unclosed groups/classes, dangling
        // quantifiers, v2-only constructs) instead of deferring every
        // failure to match time.
        let prog = rx_parse(&pattern);
        if !prog.ok {
            return Result.Err(RegexError { message: f"invalid pattern: {pattern}" });
        }
        Result.Ok(Regex { pattern: pattern })
    }

    /// Test whether the pattern matches anywhere in the given text.
    public fn is_match(&self, text: Text) -> Bool {
        rxe_is_match(&self.pattern, &text)
    }

    /// Find all non-overlapping matches of the pattern in the text.
    /// Returns an empty list if no match.
    public fn find_all(&self, text: Text) -> List<Text> {
        rxe_find_all(&self.pattern, &text)
    }

    /// Replace all matches with the replacement string. Replacement supports
    /// `$N` (1-indexed) capture-group back-references — `regex` crate
    /// semantics.
    public fn replace_all(&self, text: Text, replacement: Text) -> Text {
        rxe_replace_all(&self.pattern, &text, &replacement)
    }

    /// Split the text by every match of the pattern.
    public fn split(&self, text: Text) -> List<Text> {
        rxe_split(&self.pattern, &text)
    }

    /// Find the first match of the pattern in the text.
    /// Returns `Maybe.None` if no match.
    public fn find(&self, text: Text) -> Maybe<Text> {
        rxe_find(&self.pattern, &text)
    }

    /// Replace the first match with the replacement string.
    /// Returns the input unchanged if no match. Supports `$N`
    /// capture-group back-references in `replacement`.
    public fn replace(&self, text: Text, replacement: Text) -> Text {
        rxe_replace(&self.pattern, &text, &replacement)
    }

    /// Run the pattern against `text` and return the ordered group
    /// captures of the first match.
    ///

    /// Layout: `result[0]` is always the whole match; `result[i]`
    /// for `i >= 1` is the i-th `(group)` capture. Non-participating
    /// groups appear as empty strings — callers that want
    /// `Maybe<Text>` per group should re-check membership against
    /// the pattern's group count. Returns `Maybe.None` if no match.
    public fn captures(&self, text: Text) -> Maybe<List<Text>> {
        rxe_captures(&self.pattern, &text)
    }

    /// Returns the original pattern string.
    public fn as_str(&self) -> Text {
        self.pattern
    }
}

// =============================================================================
// Retired: intrinsic declarations
// =============================================================================
// The seven `@intrinsic("regex_*")` forward declarations that previously
// lived here are GONE — they were the tier-divergence surface (Tier-0-only
// Rust `regex` intercepts; no Tier-1 runtime). The engine that replaced
// them is ordinary Verum code in `core/text/regex_engine.vr`; the
// interpreter-side dispatchers and the TensorSubOpcode 0xE0-0xE3 /
// TensorExtSubOpcode 0x0A-0x0C intrinsic slots remain in the crates only
// for archive back-compat and can be reclaimed once no baked artifact
// references them (tracked in task #47).
