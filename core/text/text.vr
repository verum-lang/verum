implement FromIterator<Char> for Text {
    fn from_iter<I: Iterator<Item = Char>>(mut iter: I) -> Text {
        let mut t = Text.new();
        loop {
            match iter.next() {
                None => break,
                Some(ch) => {
                    t.push(ch);
                }
            }
        }
        t
    }
}

implement Extend<Char> for Text {
    fn extend<I: Iterator<Item = Char>>(&mut self, iter: I) {
        for ch in iter {
            self.push(ch);
        }
    }
}

implement Extend<Text> for Text {
    fn extend<I: Iterator<Item = Text>>(&mut self, iter: I) {
        for s in iter {
            self.push_str(&s);
        }
    }
}

// =============================================================================
// Iterators
// =============================================================================

/// Character iterator.
public type Chars is {
    bytes: &[Byte],
    pos: Int,
};

implement Iterator for Chars {
    type Item = Char;

    fn next(&mut self) -> Maybe<Char> {
        if self.pos >= self.bytes.len() {
            return None;
        }

        let (ch, len) = utf8_decode_char_len(self.bytes, self.pos);
        self.pos = self.pos + len;
        Some(ch)
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let remaining = self.bytes.len() - self.pos;
        // At least remaining/4 chars (4 bytes max per char)
        // At most remaining chars (1 byte min per char)
        ((remaining + 3) / 4, Some(remaining))
    }
}

/// Byte iterator.
public type ByteIter is {
    bytes: &[Byte],
    pos: Int,
};

implement Iterator for ByteIter {
    type Item = Byte;

    fn next(&mut self) -> Maybe<Byte> {
        if self.pos >= self.bytes.len() {
            return None;
        }
        let b = self.bytes[self.pos];
        self.pos = self.pos + 1;
        Some(b)
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let remaining = self.bytes.len() - self.pos;
        (remaining, Some(remaining))
    }
}

/// Character indices iterator.
public type CharIndices is {
    bytes: &[Byte],
    pos: Int,
};

implement Iterator for CharIndices {
    type Item = (Int, Char);

    fn next(&mut self) -> Maybe<(Int, Char)> {
        if self.pos >= self.bytes.len() {
            return None;
        }

        let start = self.pos;
        let (ch, len) = utf8_decode_char_len(self.bytes, self.pos);
        self.pos = self.pos + len;
        Some((start, ch))
    }
}

/// Lines iterator.
public type Lines is {
    text: &Text,
    pos: Int,
};

implement Iterator for Lines {
    type Item = Text;

    fn next(&mut self) -> Maybe<Text> {
        let bytes = self.text.as_bytes();
        if self.pos >= bytes.len() {
            return None;
        }

        let start = self.pos;
        let mut end = start;

        // Find end of line
        while end < bytes.len() && bytes[end] != 10 {
            end = end + 1;
        }

        // Skip \r if present (Windows line endings)
        let line_end = if end > start && bytes[end - 1] == 13 {
            end - 1
        } else {
            end
        };

        // Move past newline
        self.pos = if end < bytes.len() { end + 1 } else { end };

        Some(self.text.slice(start, line_end))
    }
}

// =============================================================================
// IntoIterator implementations for text iterators
// =============================================================================
// These explicit implementations ensure for loops work even if blanket impl
// resolution has issues across module boundaries.

implement IntoIterator for Chars {
    type Item = Char;
    type IntoIter = Chars;

    fn into_iter(self) -> Chars {
        self
    }
}

implement IntoIterator for ByteIter {
    type Item = Byte;
    type IntoIter = ByteIter;

    fn into_iter(self) -> ByteIter {
        self
    }
}

implement IntoIterator for CharIndices {
    type Item = (Int, Char);
    type IntoIter = CharIndices;

    fn into_iter(self) -> CharIndices {
        self
    }
}

implement IntoIterator for Lines {
    type Item = Text;
    type IntoIter = Lines;

    fn into_iter(self) -> Lines {
        self
    }
}

// =============================================================================
// FusedIterator implementations for text iterators
// =============================================================================

implement FusedIterator for Chars {}
implement FusedIterator for CharIndices {}
implement FusedIterator for Lines {}
implement FusedIterator for ByteIter {}

// =============================================================================
// Error Types
// =============================================================================

/// UTF-8 validation error.
public type Utf8Error is {
    valid_up_to: Int,
};

implement Utf8Error {
    fn new(valid_up_to: Int) -> Utf8Error {
        Utf8Error { valid_up_to: valid_up_to }
    }
}

implement Debug for Utf8Error {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&f"Utf8Error {{ valid_up_to: {self.valid_up_to} }}")
    }
}

implement Display for Utf8Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("invalid utf-8: error at byte index ")?;
        f.write_str(&self.valid_up_to.to_text())
    }
}

implement Eq for Utf8Error {
    fn eq(&self, other: &Utf8Error) -> Bool {
        self.valid_up_to == other.valid_up_to
    }
}

/// UTF-16 decoding error.
///
/// Indicates an invalid surrogate pair at the given index in the input slice.
public type Utf16Error is {
    index: Int,
};

implement Debug for Utf16Error {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&f"Utf16Error {{ index: {self.index} }}")
    }
}

implement Display for Utf16Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("invalid utf-16: unpaired surrogate at index ")?;
        f.write_str(&self.index.to_text())
    }
}

implement Eq for Utf16Error {
    fn eq(&self, other: &Utf16Error) -> Bool {
        self.index == other.index
    }
}

/// Parse error.
public type ParseError is {
    message: Text,
};

implement ParseError {
    fn new(msg: &Text) -> ParseError {
        ParseError { message: msg.clone() }
    }
}

implement Debug for ParseError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("ParseError: ")?;
        f.write_str(&self.message)
    }
}

implement Display for ParseError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(&self.message)
    }
}

implement Eq for ParseError {
    fn eq(&self, other: &ParseError) -> Bool {
        self.message == other.message
    }
}

// =============================================================================
// Helper Functions
// =============================================================================

/// Check if byte is a UTF-8 char boundary.
fn is_utf8_char_boundary(byte: Byte) -> Bool {
    // UTF-8 continuation bytes are 10xxxxxx
    (byte as Int) & 0xC0 != 0x80
}
