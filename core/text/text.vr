implement FromStr for UInt128 {
    type ParseError = ParseError;

    fn from_str(s: &Text) -> Result<UInt128, ParseError> {
        let n = s.parse_int();
        match n {
            Err(e) => Err(e),
            Ok(val) => {
                if val < 0 {
                    Err(ParseError.new(&"value out of range for UInt128"))
                } else {
                    Ok(val as UInt128)
                }
            },
        }
    }
}

