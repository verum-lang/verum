// =============================================================================
// text/tagged_literals.vr - Tagged Literal Validators
// =============================================================================
// Layer: 2 (Standard)
// Dependencies: core
// =============================================================================
//

// Compile-time and runtime validators for tagged string literals:
//  json#"{"key": "value"}" → validates JSON syntax
//  sql#"SELECT * FROM users" → validates SQL syntax
//  regex#"[a-z]+" → validates regex pattern
//  uri#"https://example.com" → validates URI format
//

// =============================================================================

module tagged_literals;

mount core.*;

// =============================================================================
// JSON Validation
// =============================================================================

/// Validate JSON string at runtime (basic structural check).
///
/// Pre-fix, the body compared `first == 123` where `first: Maybe<Byte>`,
/// relying on a cross-type Maybe<Byte> == Int PartialEq that silently
/// returns false at Tier-0 (no implicit Maybe-unwrap in `==`).  Unwrap
/// the Maybe via `match` so the comparison happens on the unwrapped
/// `Byte` against the literal `Int` — the canonical Byte == Int
/// comparison works correctly.  Closes audit tagged_literals §B.
public fn validate_json(s: Text) -> Bool {
    if s.len() == 0 { return false; }
    let first: Int = match s.byte_at(0) {
        Some(b) => b as Int,
        None => return false,
    };
    let last: Int = match s.byte_at(s.len() - 1) {
        Some(b) => b as Int,
        None => return false,
    };
    // Must start with { or [ and end with matching bracket / quote.
    (first == 123 && last == 125) ||  // `{ }`
    (first == 91  && last == 93)  ||  // `[ ]`
    (first == 34  && last == 34)      // `" "` (string literal)
}

// =============================================================================
// URI Validation
// =============================================================================

/// Validate URI format (basic scheme://authority check).
public fn validate_uri(s: Text) -> Bool {
    s.contains("://")
}

// =============================================================================
// SQL Validation
// =============================================================================

/// Validate SQL statement (basic keyword check).
public fn validate_sql(s: Text) -> Bool {
    let upper = s.to_upper();
    upper.starts_with("SELECT") ||
    upper.starts_with("INSERT") ||
    upper.starts_with("UPDATE") ||
    upper.starts_with("DELETE") ||
    upper.starts_with("CREATE") ||
    upper.starts_with("DROP") ||
    upper.starts_with("ALTER") ||
    upper.starts_with("WITH")
}
