// =============================================================================
// core/text/regex_engine.vr — pure-Verum regular-expression engine
// =============================================================================
// Layer: 1 (Text)
// Dependencies: core
// =============================================================================
//
// ONE regex implementation for BOTH execution tiers (task #47 /
// AOT-REGEX-RUNTIME-1).  The previous design forwarded every operation to
// Rust-side intrinsics that existed only in the Tier-0 interpreter — Tier-1
// binaries either lacked the runtime symbols entirely (standalone builds:
// is_match answered false where the interpreter answered true) or
// mislowered the single-match ops through the 0xFF ext-opcode envelope
// (regex_find compiled into a batch-norm runtime call).  A pure-Verum
// engine executes as ordinary VBC on Tier 0 and ordinary machine code on
// Tier 1: no intrinsics, no runtime symbols, no per-tier divergence
// surface.
//
// # Engine (v2)
//
// Backtracking matcher over a tree program (flat item/sequence arenas —
// no recursive record types needed):
//   * byte-oriented; `\d` `\w` `\s` (and negations `\D` `\W` `\S`)
//     are ASCII; `.` matches any byte except `\n`;
//   * literals + escaped literals (`\.` `\$` `\\` `\n` `\t` `\r`),
//     classes `[a-z]` / negated `[^...]` with ranges and in-class escapes;
//   * greedy quantifiers `*` `+` `?` `{m}` `{m,}` `{m,n}` over ANY atom,
//     including capture groups (`(ab)+`, `(ha)*`, `(ab){2,3}`) with
//     last-repetition capture semantics and a zero-width-repetition
//     guard (an empty group body under `*` terminates, never loops);
//   * alternation `|` at top level and inside groups, leftmost-first;
//   * anchors `^` `$`; positional capture groups (group 0 = whole match;
//     non-participating groups capture as empty Text).
//   * Malformed patterns (unclosed group/class, dangling or anchored
//     quantifier, stray `)`) are REJECTED at parse — `RxProg.ok = false`
//     — never mis-accepted.
//
// Pattern compilation is per call (the documented Regex v1 trade-off);
// `RxProg` is a plain value, so a future `Regex.compile` can cache it
// without engine changes.
//
// Complexity: worst-case exponential like every backtracker; the stdlib
// conformance corpus and typical validation patterns are linear-ish.  A
// lazy-DFA can replace the `match_seq` core behind the same `rx_search`
// surface.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.text.regex_engine;

mount core.*;

public type RxItem is {
    kind: Int,
    data0: Int,
    cls_lo: List<Int>,
    cls_hi: List<Int>,
    qmin: Int,
    qmax: Int,
    alt_starts: List<Int>,
};

public type RxProg is {
    items: List<RxItem>,
    seqs: List<List<Int>>,
    top_alts: List<Int>,
    group_count: Int,
    ok: Bool,
};

fn mk_item(kind: Int, data0: Int) -> RxItem {
    RxItem { kind: kind, data0: data0, cls_lo: [], cls_hi: [], qmin: 1, qmax: 1, alt_starts: [] }
}

fn bytes_of(t: &Text) -> List<Int> {
    let bs = t.as_bytes();
    let n = bs.len();
    let mut out: List<Int> = [];
    let mut i: Int = 0;
    while i < n {
        out.push(bs[i] as Int);
        i = i + 1;
    }
    out
}

// ---------- Parser ----------

fn cls_push_range(item: &mut RxItem, lo: Int, hi: Int) {
    item.cls_lo.push(lo);
    item.cls_hi.push(hi);
}

fn cls_push_escape(item: &mut RxItem, c: Int) {
    if c == 100 { // d
        cls_push_range(item, 48, 57);
    } else if c == 119 { // w
        cls_push_range(item, 48, 57);
        cls_push_range(item, 65, 90);
        cls_push_range(item, 97, 122);
        cls_push_range(item, 95, 95);
    } else if c == 115 { // s
        cls_push_range(item, 32, 32);
        cls_push_range(item, 9, 13);
    }
}

fn is_escape_class(c: Int) -> Bool {
    c == 100 || c == 119 || c == 115
}

public type RxBounds is { pos: Int, lo: Int, hi: Int, ok: Bool };

fn parse_bounds(p: &List<Int>, start: Int) -> RxBounds {
    let n = p.len();
    let mut i = start;
    let mut lo: Int = 0;
    let mut saw_lo: Bool = false;
    while i < n && p[i] >= 48 && p[i] <= 57 {
        lo = lo * 10 + (p[i] - 48);
        saw_lo = true;
        i = i + 1;
    }
    if !saw_lo {
        return RxBounds { pos: start, lo: 0, hi: 0, ok: false };
    }
    if i < n && p[i] == 125 {
        return RxBounds { pos: i + 1, lo: lo, hi: lo, ok: true };
    }
    if i < n && p[i] == 44 {
        i = i + 1;
        if i < n && p[i] == 125 {
            return RxBounds { pos: i + 1, lo: lo, hi: 0 - 1, ok: true };
        }
        let mut hi: Int = 0;
        let mut saw_hi: Bool = false;
        while i < n && p[i] >= 48 && p[i] <= 57 {
            hi = hi * 10 + (p[i] - 48);
            saw_hi = true;
            i = i + 1;
        }
        if saw_hi && i < n && p[i] == 125 {
            return RxBounds { pos: i + 1, lo: lo, hi: hi, ok: true };
        }
    }
    RxBounds { pos: start, lo: 0, hi: 0, ok: false }
}

// Parser state threaded through recursion (arena builder).
public type RxParser is {
    p: List<Int>,
    pos: Int,
    items: List<RxItem>,
    seqs: List<List<Int>>,
    group_count: Int,
    failed: Bool,
};

// Parse a single atom (possibly followed by a quantifier) into the arena;
// returns the item id, or -1 on hard error / when the caller should stop
// (')' or '|' or end — WITHOUT consuming those).
fn parse_atom(st: &mut RxParser) -> Int {
    let n = st.p.len();
    if st.pos >= n {
        return 0 - 1;
    }
    let c = st.p[st.pos];
    if c == 41 || c == 124 { // ')' '|'
        return 0 - 1;
    }
    let mut item = mk_item(0, 0);
    if c == 94 { // ^
        item = mk_item(5, 0);
        st.pos = st.pos + 1;
    } else if c == 36 { // $
        item = mk_item(6, 0);
        st.pos = st.pos + 1;
    } else if c == 46 { // .
        item = mk_item(1, 0);
        st.pos = st.pos + 1;
    } else if c == 40 { // '(' — group with alternatives
        st.pos = st.pos + 1;
        st.group_count = st.group_count + 1;
        let gidx = st.group_count;
        item = mk_item(3, gidx);
        // parse alternatives until ')'
        let mut done: Bool = false;
        while !done {
            let seq_id = parse_seq(st);
            if st.failed {
                return 0 - 1;
            }
            item.alt_starts.push(seq_id);
            if st.pos < st.p.len() && st.p[st.pos] == 124 { // '|'
                st.pos = st.pos + 1;
            } else if st.pos < st.p.len() && st.p[st.pos] == 41 { // ')'
                st.pos = st.pos + 1;
                done = true;
            } else {
                st.failed = true; // unclosed group
                return 0 - 1;
            }
        }
    } else if c == 91 { // '['
        item = mk_item(2, 0);
        st.pos = st.pos + 1;
        if st.pos < n && st.p[st.pos] == 94 {
            item.data0 = 1;
            st.pos = st.pos + 1;
        }
        let mut first: Bool = true;
        let mut closed: Bool = false;
        while st.pos < n {
            let cc = st.p[st.pos];
            if cc == 93 && !first {
                closed = true;
                st.pos = st.pos + 1;
                break;
            }
            first = false;
            if cc == 92 && st.pos + 1 < n {
                let e = st.p[st.pos + 1];
                if is_escape_class(e) {
                    cls_push_escape(&mut item, e);
                } else if e == 110 {
                    cls_push_range(&mut item, 10, 10);
                } else if e == 116 {
                    cls_push_range(&mut item, 9, 9);
                } else {
                    cls_push_range(&mut item, e, e);
                }
                st.pos = st.pos + 2;
            } else if st.pos + 2 < n && st.p[st.pos + 1] == 45 && st.p[st.pos + 2] != 93 {
                cls_push_range(&mut item, cc, st.p[st.pos + 2]);
                st.pos = st.pos + 3;
            } else {
                cls_push_range(&mut item, cc, cc);
                st.pos = st.pos + 1;
            }
        }
        if !closed {
            st.failed = true;
            return 0 - 1;
        }
    } else if c == 92 { // '\'
        if st.pos + 1 >= n {
            st.failed = true;
            return 0 - 1;
        }
        let e = st.p[st.pos + 1];
        if is_escape_class(e) {
            item = mk_item(2, 0);
            cls_push_escape(&mut item, e);
        } else if e == 68 || e == 87 || e == 83 {
            item = mk_item(2, 1);
            cls_push_escape(&mut item, e + 32);
        } else if e == 110 {
            item = mk_item(0, 10);
        } else if e == 116 {
            item = mk_item(0, 9);
        } else if e == 114 {
            item = mk_item(0, 13);
        } else {
            item = mk_item(0, e);
        }
        st.pos = st.pos + 2;
    } else if c == 42 || c == 43 || c == 63 || c == 123 {
        // dangling quantifier
        st.failed = true;
        return 0 - 1;
    } else {
        item = mk_item(0, c);
        st.pos = st.pos + 1;
    }

    // Optional quantifier — applies to ANY atom incl. groups (v2).
    if st.pos < n {
        let q = st.p[st.pos];
        if item.kind == 5 || item.kind == 6 {
            // quantified anchor is malformed
            if q == 42 || q == 43 || q == 63 {
                st.failed = true;
                return 0 - 1;
            }
        } else if q == 42 { // *
            item.qmin = 0;
            item.qmax = 0 - 1;
            st.pos = st.pos + 1;
        } else if q == 43 { // +
            item.qmin = 1;
            item.qmax = 0 - 1;
            st.pos = st.pos + 1;
        } else if q == 63 { // ?
            item.qmin = 0;
            item.qmax = 1;
            st.pos = st.pos + 1;
        } else if q == 123 { // {
            let b = parse_bounds(&st.p, st.pos + 1);
            if b.ok {
                item.qmin = b.lo;
                item.qmax = b.hi;
                st.pos = b.pos;
            }
            // not ok → literal '{' handled as its own atom next round
        }
    }

    st.items.push(item);
    st.items.len() - 1
}

// Parse a sequence (until ')' / '|' / end); returns seq id.
fn parse_seq(st: &mut RxParser) -> Int {
    let mut seq: List<Int> = [];
    while !st.failed {
        if st.pos >= st.p.len() {
            break;
        }
        let c = st.p[st.pos];
        if c == 41 || c == 124 {
            break;
        }
        let id = parse_atom(st);
        if id < 0 {
            break;
        }
        seq.push(id);
    }
    st.seqs.push(seq);
    st.seqs.len() - 1
}

public fn rx_parse(pattern: &Text) -> RxProg {
    let mut st = RxParser {
        p: bytes_of(pattern),
        pos: 0,
        items: [],
        seqs: [],
        group_count: 0,
        failed: false,
    };
    let mut top_alts: List<Int> = [];
    let mut done: Bool = false;
    while !done && !st.failed {
        let seq_id = parse_seq(&mut st);
        top_alts.push(seq_id);
        if st.pos < st.p.len() && st.p[st.pos] == 124 {
            st.pos = st.pos + 1;
        } else if st.pos < st.p.len() && st.p[st.pos] == 41 {
            st.failed = true; // stray ')'
        } else {
            done = true;
        }
    }
    if st.failed {
        return RxProg { items: [], seqs: [], top_alts: [], group_count: 0, ok: false };
    }
    RxProg {
        items: st.items,
        seqs: st.seqs,
        top_alts: top_alts,
        group_count: st.group_count,
        ok: true,
    }
}

// ---------- Matcher ----------

fn class_matches(item: &RxItem, b: Int) -> Bool {
    let n = item.cls_lo.len();
    let mut hit: Bool = false;
    let mut i: Int = 0;
    while i < n {
        if b >= item.cls_lo[i] && b <= item.cls_hi[i] {
            hit = true;
        }
        i = i + 1;
    }
    if item.data0 == 1 { !hit } else { hit }
}

fn single_matches(item: &RxItem, t: &List<Int>, pos: Int) -> Bool {
    if pos >= t.len() {
        return false;
    }
    let b = t[pos];
    if item.kind == 0 {
        b == item.data0
    } else if item.kind == 1 {
        b != 10
    } else if item.kind == 2 {
        class_matches(item, b)
    } else {
        false
    }
}

// Match items of seq (by id) starting at seq-index si, text position pos.
// On success returns end position; else -1. Backtracking via recursion.
fn match_seq(prog: &RxProg, seq_id: Int, si: Int, t: &List<Int>, pos: Int, caps: &mut List<Int>) -> Int {
    let seq_len = prog.seqs[seq_id].len();
    if si >= seq_len {
        return pos;
    }
    let item_id = prog.seqs[seq_id][si];
    let kind = prog.items[item_id].kind;

    if kind == 5 { // ^
        if pos == 0 { return match_seq(prog, seq_id, si + 1, t, pos, caps); }
        return 0 - 1;
    }
    if kind == 6 { // $
        if pos == t.len() { return match_seq(prog, seq_id, si + 1, t, pos, caps); }
        return 0 - 1;
    }

    let qmin = prog.items[item_id].qmin;
    let qmax = prog.items[item_id].qmax;

    if kind == 3 { // group with alternatives, quantified
        return match_group_rep(prog, seq_id, si, item_id, t, pos, 0, qmin, qmax, caps);
    }

    // Single-byte matcher with greedy quantifier + backtracking.
    let mut count: Int = 0;
    let mut cursor = pos;
    while (qmax < 0 || count < qmax) && single_matches(&prog.items[item_id], t, cursor) {
        cursor = cursor + 1;
        count = count + 1;
    }
    while count >= qmin {
        let r = match_seq(prog, seq_id, si + 1, t, pos + count, caps);
        if r >= 0 {
            return r;
        }
        count = count - 1;
    }
    0 - 1
}

// Match `reps`-th repetition of a quantified GROUP item, then the rest of
// the sequence. Greedy: try one-more-repetition first (when allowed),
// falling back to continuing the sequence once reps >= qmin.
fn match_group_rep(prog: &RxProg, seq_id: Int, si: Int, item_id: Int, t: &List<Int>, pos: Int, reps: Int, qmin: Int, qmax: Int, caps: &mut List<Int>) -> Int {
    // Try to consume one more repetition (if under the cap).
    if qmax < 0 || reps < qmax {
        let gidx = prog.items[item_id].data0;
        let alt_count = prog.items[item_id].alt_starts.len();
        let mut ai: Int = 0;
        while ai < alt_count {
            let alt_seq = prog.items[item_id].alt_starts[ai];
            let saved_s = caps[gidx * 2];
            let saved_e = caps[gidx * 2 + 1];
            caps[gidx * 2] = pos;
            let inner_end = match_seq(prog, alt_seq, 0, t, pos, caps);
            if inner_end >= 0 {
                caps[gidx * 2 + 1] = inner_end;
                // Zero-width repetition guard: an empty group match can
                // recur forever under `*`; only allow progress-free
                // continuation, never progress-free repetition.
                if inner_end > pos {
                    let r = match_group_rep(prog, seq_id, si, item_id, t, inner_end, reps + 1, qmin, qmax, caps);
                    if r >= 0 {
                        return r;
                    }
                } else if reps + 1 >= qmin {
                    let r = match_seq(prog, seq_id, si + 1, t, inner_end, caps);
                    if r >= 0 {
                        return r;
                    }
                }
            }
            caps[gidx * 2] = saved_s;
            caps[gidx * 2 + 1] = saved_e;
            ai = ai + 1;
        }
    }
    // Continue past the group when the repetition count satisfies qmin.
    if reps >= qmin {
        return match_seq(prog, seq_id, si + 1, t, pos, caps);
    }
    0 - 1
}

public type RxMatch is {
    found: Bool,
    start: Int,
    end: Int,
    caps: List<Int>,
};

fn no_match() -> RxMatch {
    RxMatch { found: false, start: 0, end: 0, caps: [] }
}

public fn rx_search(prog: &RxProg, t: &List<Int>, from: Int) -> RxMatch {
    if !prog.ok {
        return no_match();
    }
    let n = t.len();
    let mut start = from;
    while start <= n {
        let alt_count = prog.top_alts.len();
        let mut ai: Int = 0;
        while ai < alt_count {
            let mut caps: List<Int> = [];
            let cap_slots = (prog.group_count + 1) * 2;
            let mut ci: Int = 0;
            while ci < cap_slots {
                caps.push(0 - 1);
                ci = ci + 1;
            }
            let end = match_seq(prog, prog.top_alts[ai], 0, t, start, &mut caps);
            if end >= 0 {
                caps[0] = start;
                caps[1] = end;
                return RxMatch { found: true, start: start, end: end, caps: caps };
            }
            ai = ai + 1;
        }
        start = start + 1;
    }
    no_match()
}

// ---------- Public operations (same surface as v1) ----------

public fn rxe_is_match(pattern: &Text, text: &Text) -> Bool {
    let prog = rx_parse(pattern);
    let bytes = bytes_of(text);
    rx_search(&prog, &bytes, 0).found
}

public fn rxe_find(pattern: &Text, text: &Text) -> Maybe<Text> {
    let prog = rx_parse(pattern);
    let bytes = bytes_of(text);
    let m = rx_search(&prog, &bytes, 0);
    if m.found {
        Maybe.Some(text.slice(m.start, m.end))
    } else {
        Maybe.None
    }
}

public fn rxe_find_all(pattern: &Text, text: &Text) -> List<Text> {
    let prog = rx_parse(pattern);
    let bytes = bytes_of(text);
    let mut out: List<Text> = [];
    let mut pos: Int = 0;
    let n = bytes.len();
    while pos <= n {
        let m = rx_search(&prog, &bytes, pos);
        if !m.found {
            break;
        }
        out.push(text.slice(m.start, m.end));
        if m.end > m.start {
            pos = m.end;
        } else {
            pos = m.end + 1;
        }
    }
    out
}

fn append_replacement(out: &mut Text, replacement: &Text, text: &Text, caps: &List<Int>, group_count: Int) {
    let rb = bytes_of(replacement);
    let n = rb.len();
    let mut i: Int = 0;
    while i < n {
        let c = rb[i];
        if c == 36 && i + 1 < n && rb[i + 1] >= 48 && rb[i + 1] <= 57 {
            let mut gi: Int = 0;
            let mut j = i + 1;
            while j < n && rb[j] >= 48 && rb[j] <= 57 {
                gi = gi * 10 + (rb[j] - 48);
                j = j + 1;
            }
            if gi <= group_count {
                let s = caps[gi * 2];
                let e = caps[gi * 2 + 1];
                if s >= 0 && e >= 0 {
                    out.push_str(&text.slice(s, e));
                }
            }
            i = j;
        } else {
            out.push_byte(c as Byte);
            i = i + 1;
        }
    }
}

public fn rxe_replace(pattern: &Text, text: &Text, replacement: &Text) -> Text {
    let prog = rx_parse(pattern);
    let bytes = bytes_of(text);
    let m = rx_search(&prog, &bytes, 0);
    if !m.found {
        return text.clone();
    }
    let mut out = Text.with_capacity(text.len());
    out.push_str(&text.slice(0, m.start));
    append_replacement(&mut out, replacement, text, &m.caps, prog.group_count);
    out.push_str(&text.slice(m.end, text.len()));
    out
}

public fn rxe_replace_all(pattern: &Text, text: &Text, replacement: &Text) -> Text {
    let prog = rx_parse(pattern);
    let bytes = bytes_of(text);
    let n = bytes.len();
    let mut out = Text.with_capacity(text.len());
    let mut pos: Int = 0;
    while pos <= n {
        let m = rx_search(&prog, &bytes, pos);
        if !m.found {
            break;
        }
        out.push_str(&text.slice(pos, m.start));
        append_replacement(&mut out, replacement, text, &m.caps, prog.group_count);
        if m.end > m.start {
            pos = m.end;
        } else {
            if m.end < n {
                out.push_str(&text.slice(m.end, m.end + 1));
            }
            pos = m.end + 1;
        }
    }
    if pos <= n {
        out.push_str(&text.slice(pos, n));
    }
    out
}

public fn rxe_split(pattern: &Text, text: &Text) -> List<Text> {
    let prog = rx_parse(pattern);
    let bytes = bytes_of(text);
    let n = bytes.len();
    let mut out: List<Text> = [];
    let mut pos: Int = 0;
    let mut seg_start: Int = 0;
    while pos <= n {
        let m = rx_search(&prog, &bytes, pos);
        if !m.found {
            break;
        }
        if m.end == m.start {
            pos = m.end + 1;
            continue;
        }
        out.push(text.slice(seg_start, m.start));
        seg_start = m.end;
        pos = m.end;
    }
    out.push(text.slice(seg_start, n));
    out
}

public fn rxe_captures(pattern: &Text, text: &Text) -> Maybe<List<Text>> {
    let prog = rx_parse(pattern);
    let bytes = bytes_of(text);
    let m = rx_search(&prog, &bytes, 0);
    if !m.found {
        return Maybe.None;
    }
    let mut out: List<Text> = [];
    let mut gi: Int = 0;
    while gi <= prog.group_count {
        let s = m.caps[gi * 2];
        let e = m.caps[gi * 2 + 1];
        if s >= 0 && e >= 0 && e >= s {
            out.push(text.slice(s, e));
        } else {
            out.push(Text.new());
        }
        gi = gi + 1;
    }
    Maybe.Some(out)
}

