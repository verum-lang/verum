// =============================================================================
// format.vr - Formatting system
// =============================================================================
// Layer: 1 (Text)
// Dependencies: core (protocols, maybe, result, primitives), sys/
// =============================================================================
//

// # V-LLSI Migration Status
//

// This module has been migrated to use native V-LLSI system interfaces:
// - Linux: Uses sys/linux/syscall.write direct syscalls
// - macOS: Uses sys/darwin/libsystem.safe_write via libSystem.B.dylib
// - Windows: Uses sys/windows/kernel32.write via kernel32.dll
// - Native integer/float to string conversion (no FFI)
// - No FFI dependencies on verum_runtime
//

// =============================================================================
//

// This module provides the formatting infrastructure for Verum:
// - Extended Formatter with width, precision, alignment options
// - Write protocol for output targets
// - print/println/eprint/eprintln functions
// - Debug && Display helper implementations
//

// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.text.format;
mount core.*;
// TWIN-TYPE MERGE (task #48): the alias target must be locally
// visible (braced) for the ALIAS-VS-MARKER scope gate.
public mount core.base.protocols.{Formatter, TextFormatter, FormatSpec, TextAlignment, Sign, int_to_string, float_to_string};

// =============================================================================
// V-LLSI Native I/O Imports
// =============================================================================
// Uses native platform syscalls instead of verum_runtime FFI.
// =============================================================================

@cfg(target_os = "linux")
mount sys.linux.syscall.{
    write as sys_write,
    FileDesc,
};

@cfg(target_os = "macos")
mount sys.darwin.libsystem.{
    safe_write as sys_write,
};
@cfg(target_os = "macos")
mount sys.common.FileDesc;

@cfg(target_os = "windows")
mount sys.windows.kernel32.{
    write as sys_write,
};
@cfg(target_os = "windows")
mount sys.common.FileDesc;

// Standard file descriptors
const STDOUT_FD: Int = 1;
const STDERR_FD: Int = 2;

// =============================================================================
// Native Number-to-String Conversion
// =============================================================================

/// Convert an integer to decimal string representation.
/// Returns the number of bytes written to the buffer.
///

/// Correctly handles `Int.MIN` (= -9223372036854775808): the
/// previous `let val = if negative { -value }` pattern silently
/// overflowed back to `Int.MIN` in two's-complement and the
/// `while val > 0` loop skipped — producing "-" with no digits.
/// This site is THE canonical integer formatter for the entire
/// stdlib (used by `Formatter.write_int_decimal`,
/// `panic_fmt`, every `Display for Int` / `Debug for Int`
/// path), so the fix here cascades broadly.
///

/// Magnitude is accumulated in `UInt64` so every `Int`'s
/// absolute value is exactly representable.
@inline

// =============================================================================
// Write Protocol
// =============================================================================

// Protocol for types that can receive formatted output.
public type Write is protocol {
    // Write a byte slice.
    fn write(&mut self, bytes: &[Byte]) -> Result<Int, WriteError>;



    // ==== Canonical writing surface (moved from core/text/format.vr — task #48) ====


    // Write a string.
    fn write_str(&mut self, s: &Text) -> Result<(), WriteError> {
        self.write(s.as_bytes())?;
        Result.Ok(())
    }



    // Write a single character.
    fn write_char(&mut self, c: Char) -> Result<(), WriteError> {
        let mut buf = [0_u8; 4];
        let len = c.encode_utf8(&mut buf);
        self.write(slice_from_raw_parts(&buf[0], len))?;
        Result.Ok(())
    }

    // Flush output.
    fn flush(&mut self) -> Result<(), WriteError>;
};

// Write error type.
public type WriteError is {
    kind: WriteErrorKind,
};

// Write error kinds.
public type WriteErrorKind is
    | Io              // I/O error
    | BufferFull      // Buffer capacity exceeded
    | Encoding;       // Encoding error

implement WriteError {
    fn io() -> WriteError {
        WriteError { kind: Io }
    }

    fn buffer_full() -> WriteError {
        WriteError { kind: BufferFull }
    }
}

implement Debug for WriteError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self.kind {
            Io => f.write_str("WriteError.Io"),
            BufferFull => f.write_str("WriteError.BufferFull"),
            Encoding => f.write_str("WriteError.Encoding"),
        }
    }
}

implement Display for WriteError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self.kind {
            Io         => f.write_str("write: I/O error"),
            BufferFull => f.write_str("write: buffer full"),
            Encoding   => f.write_str("write: encoding error"),
        }
    }
}

implement Eq for WriteErrorKind {
    fn eq(&self, other: &WriteErrorKind) -> Bool {
        match (self, other) {
            (Io,         Io)         => true,
            (BufferFull, BufferFull) => true,
            (Encoding,   Encoding)   => true,
            _ => false,
        }
    }
}

implement Display for WriteErrorKind {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Io         => f.write_str("io"),
            BufferFull => f.write_str("buffer-full"),
            Encoding   => f.write_str("encoding"),
        }
    }
}

implement Debug for WriteErrorKind {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Io         => f.write_str("Io"),
            BufferFull => f.write_str("BufferFull"),
            Encoding   => f.write_str("Encoding"),
        }
    }
}

implement Eq for WriteError {
    fn eq(&self, other: &WriteError) -> Bool {
        self.kind == other.kind
    }
}

// =============================================================================
// FormatResult - Standard formatting result type
// =============================================================================

/// Result type for formatting operations.
/// This is the standard return type for Display.fmt and similar methods.
public type FormatResult is Result<(), FormatError>;

// =============================================================================
// Formatter writing surface (canonical spec-aware bodies)
// =============================================================================
//
// TWIN-TYPE MERGE (task #48): the 2-field `Formatter { buffer, spec }`
// type now lives in `core/base/protocols.vr` (single canonical
// formatter — the old 1-field protocol-side `Formatter` and this
// module's `Formatter` were layout-incompatible twins, and
// bake-time name resolution mixing their method sets wrote `spec`
// into 1-field objects: heap corruption / SIGBUS across the poll
// suite). Constructors (`new` / `with_spec`) live next to the type;
// every WRITING method keeps its single canonical body here.
// `Formatter` remains as a transparent alias below for source
// compatibility.

implement Formatter {

    // =========================================================================
    // Debug Formatting
    // =========================================================================

    // Format as debug output.
    public fn debug<T: Debug>(&mut self, value: &T) -> Result<(), FormatError> {
        value.fmt_debug(self)
    }

    // Start a debug struct.
    public fn debug_struct(&mut self, name: &Text) -> DebugStruct {
        DebugStruct {
            formatter: self,
            name: name.clone(),
            fields: List.new(),
        }
    }

    // Start a debug tuple.
    public fn debug_tuple(&mut self, name: &Text) -> DebugTuple {
        DebugTuple {
            formatter: self,
            name: name.clone(),
            fields: List.new(),
        }
    }

    // Start a debug list.
    public fn debug_list(&mut self) -> DebugList {
        DebugList {
            formatter: self,
            items: List.new(),
        }
    }

    // Start a debug map.
    public fn debug_map(&mut self) -> DebugMap {
        DebugMap {
            formatter: self,
            entries: List.new(),
        }
    }
}

// =============================================================================
// Debug Helpers
// =============================================================================

// Helper for formatting structs.
public type DebugStruct is {
    formatter: &mut Formatter,
    name: Text,
    fields: List<(Text, Text)>,
};

implement DebugStruct {
    // Add a field.
    public fn field<T: Debug>(&mut self, name: &Text, value: &T) -> &mut DebugStruct {
        let mut buf = Text.new();
        let mut f = Formatter.new(&mut buf);
        value.fmt_debug(&mut f);
        self.fields.push((name.clone(), buf));
        self
    }

    // Finish && write output.
    public fn finish(&mut self) -> Result<(), FormatError> {
        self.formatter.write_str(&self.name)?;
        self.formatter.write_str(" { ")?;

        for (i, (name, value)) in self.fields.iter().enumerate() {
            if i > 0 {
                self.formatter.write_str(", ")?;
            }
            self.formatter.write_str(name)?;
            self.formatter.write_str(": ")?;
            self.formatter.write_str(value)?;
        }

        self.formatter.write_str(" }")
    }
}

// Helper for formatting tuples.
public type DebugTuple is {
    formatter: &mut Formatter,
    name: Text,
    fields: List<Text>,
};

implement DebugTuple {
    // Add a field.
    public fn field<T: Debug>(&mut self, value: &T) -> &mut DebugTuple {
        let mut buf = Text.new();
        let mut f = Formatter.new(&mut buf);
        value.fmt_debug(&mut f);
        self.fields.push(buf);
        self
    }

    // Finish && write output.
    public fn finish(&mut self) -> Result<(), FormatError> {
        self.formatter.write_str(&self.name)?;
        self.formatter.write_char('(')?;

        for (i, value) in self.fields.iter().enumerate() {
            if i > 0 {
                self.formatter.write_str(", ")?;
            }
            self.formatter.write_str(value)?;
        }

        self.formatter.write_char(')')
    }
}

// Helper for formatting lists.
public type DebugList is {
    formatter: &mut Formatter,
    items: List<Text>,
};

implement DebugList {
    // Add an item.
    public fn entry<T: Debug>(&mut self, value: &T) -> &mut DebugList {
        let mut buf = Text.new();
        let mut f = Formatter.new(&mut buf);
        value.fmt_debug(&mut f);
        self.items.push(buf);
        self
    }

    // Add multiple items from iterator.
    public fn entries<I: Iterator>(&mut self, iter: I) -> &mut DebugList
    where I.Item: Debug
    {
        for item in iter {
            self.entry(&item);
        }
        self
    }

    // Finish && write output.
    public fn finish(&mut self) -> Result<(), FormatError> {
        self.formatter.write_char('[')?;

        for (i, value) in self.items.iter().enumerate() {
            if i > 0 {
                self.formatter.write_str(", ")?;
            }
            self.formatter.write_str(value)?;
        }

        self.formatter.write_char(']')
    }
}

// Helper for formatting maps.
public type DebugMap is {
    formatter: &mut Formatter,
    entries: List<(Text, Text)>,
};

implement DebugMap {
    // Add an entry.
    public fn entry<K: Debug, V: Debug>(&mut self, key: &K, value: &V) -> &mut DebugMap {
        let mut key_buf = Text.new();
        let mut key_f = Formatter.new(&mut key_buf);
        key.fmt_debug(&mut key_f);

        let mut val_buf = Text.new();
        let mut val_f = Formatter.new(&mut val_buf);
        value.fmt_debug(&mut val_f);

        self.entries.push((key_buf, val_buf));
        self
    }

    // Finish && write output.
    public fn finish(&mut self) -> Result<(), FormatError> {
        self.formatter.write_char('{')?;

        for (i, (key, value)) in self.entries.iter().enumerate() {
            if i > 0 {
                self.formatter.write_str(", ")?;
            }
            self.formatter.write_str(key)?;
            self.formatter.write_str(": ")?;
            self.formatter.write_str(value)?;
        }

        self.formatter.write_char('}')
    }
}

// =============================================================================
// Print Functions
// =============================================================================

// Print text to stdout (no newline).
public fn print(s: &Text) {
    let fd = FileDesc.from_raw(STDOUT_FD);
    let _ = sys_write(fd, s.as_bytes());
}

// Print text to stdout with newline.
public fn println(s: &Text) {
    let fd = FileDesc.from_raw(STDOUT_FD);
    let _ = sys_write(fd, s.as_bytes());
    let _ = sys_write(fd, b"\n");
}

// Print empty line to stdout.
public fn println_empty() {
    let fd = FileDesc.from_raw(STDOUT_FD);
    let _ = sys_write(fd, b"\n");
}

// Print text to stderr (no newline).
public fn eprint(s: &Text) {
    let fd = FileDesc.from_raw(STDERR_FD);
    let _ = sys_write(fd, s.as_bytes());
}

// Print text to stderr with newline.
public fn eprintln(s: &Text) {
    let fd = FileDesc.from_raw(STDERR_FD);
    let _ = sys_write(fd, s.as_bytes());
    let _ = sys_write(fd, b"\n");
}

// =============================================================================
// Format Functions
// =============================================================================

// Format a Debug value to Text.
//
// §J close — the formatter argument MUST match the protocol-declared
// type (`Formatter` from `core.base.protocols`, NOT the
// implementation-side `Formatter` from this module).  Pre-fix
// `Formatter.new(&mut buf)` was used here, producing a
// `Formatter` value, but every `Debug for T` impl in the stdlib
// declares `fn fmt_debug(&self, f: &mut Formatter) -> …`.  At
// dispatch time the type mismatch silently routed the call away
// from the user-defined Debug.fmt_debug body (the formatter
// receiver-kind classification fell back to a ToString-shape path
// that just emitted the underlying value), so
// `format_debug(&"hi")` produced `hi` instead of `"\"hi\""`.
//
// Using `Formatter.new(&mut buf)` matches the protocol contract
// exactly: the resolver sees `(&self, &mut Formatter)` on both the
// trait-method side and the argument side, and the Debug.fmt_debug
// body runs with `f.write_char('"')` actually writing into `buf`.
//
// Pinned by `regression_j_debug_format_quotes_pinned` +
// `regression_j_debug_format_newline_escape_pinned` in
// `core-tests/text/text/regression_test.vr`.
public fn format_debug<T: Debug>(value: &T) -> Text {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    value.fmt_debug(&mut f);
    buf
}

// Format a Display value to Text.
//
// Same type-match rule as `format_debug` — `Display` protocol takes
// `&mut Formatter`, so we construct the canonical `Formatter` here
// rather than `Formatter`.
public fn format_display<T: Display>(value: &T) -> Text {
    let mut buf = Text.new();
    let mut f = Formatter.new(&mut buf);
    value.fmt(&mut f);
    buf
}

// Debug print with file/line info (for debugging).
public fn dbg<T: Debug>(value: T) -> T {
    let formatted = format_debug(&value);
    eprintln(&formatted);
    value
}

// NOTE: Display and Debug implementations for primitives (Int, Float, Bool,
// Char, Byte) are defined in core/base/primitives.vr as the canonical source.
// Do NOT duplicate them here.

// =============================================================================
// Debug Implementations for Common Types
// =============================================================================

// NOTE: Debug for Maybe<T> is defined in core/base/maybe.vr (canonical source).
// NOTE: Debug for Result<T, E> is defined in core/base/result.vr (canonical source).
// Do NOT duplicate them here.

implement<T: Debug> Debug for &T {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        (*self).fmt_debug(f)
    }
}

implement<T: Debug> Debug for &mut T {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        (**self).fmt_debug(f)
    }
}

// Tuple implementations
implement<A: Debug> Debug for (A,) {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_char('(')?;
        self.0.fmt_debug(f)?;
        f.write_str(",)")
    }
}

implement<A: Debug, B: Debug> Debug for (A, B) {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_char('(')?;
        self.0.fmt_debug(f)?;
        f.write_str(", ")?;
        self.1.fmt_debug(f)?;
        f.write_char(')')
    }
}

implement<A: Debug, B: Debug, C: Debug> Debug for (A, B, C) {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_char('(')?;
        self.0.fmt_debug(f)?;
        f.write_str(", ")?;
        self.1.fmt_debug(f)?;
        f.write_str(", ")?;
        self.2.fmt_debug(f)?;
        f.write_char(')')
    }
}

// Slice/array debug
implement<T: Debug> Debug for [T] {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_char('[')?;
        for (i, item) in self.iter().enumerate() {
            if i > 0 {
                f.write_str(", ")?;
            }
            item.fmt_debug(f)?;
        }
        f.write_char(']')
    }
}

// =============================================================================
// Specialized Format Protocols
// =============================================================================

/// Format a value as lowercase hexadecimal (e.g., "ff", "deadbeef").
///

/// Types implementing this protocol support `{:x}` formatting.
public type LowerHex is protocol {
    fn fmt_lower_hex(&self, f: &mut Formatter) -> Result<(), FormatError>;
};

/// Format a value as uppercase hexadecimal (e.g., "FF", "DEADBEEF").
///

/// Types implementing this protocol support `{:X}` formatting.
public type UpperHex is protocol {
    fn fmt_upper_hex(&self, f: &mut Formatter) -> Result<(), FormatError>;
};

/// Format a value as binary (e.g., "1010", "11111111").
///

/// Types implementing this protocol support `{:b}` formatting.
public type Binary is protocol {
    fn fmt_binary(&self, f: &mut Formatter) -> Result<(), FormatError>;
};

/// Format a value as octal (e.g., "77", "377").
///

/// Types implementing this protocol support `{:o}` formatting.
public type Octal is protocol {
    fn fmt_octal(&self, f: &mut Formatter) -> Result<(), FormatError>;
};

/// Format a value in lowercase exponential notation (e.g., "1.5e2").
///

/// Types implementing this protocol support `{:e}` formatting.
public type LowerExp is protocol {
    fn fmt_lower_exp(&self, f: &mut Formatter) -> Result<(), FormatError>;
};

/// Format a value in uppercase exponential notation (e.g., "1.5E2").
///

/// Types implementing this protocol support `{:E}` formatting.
public type UpperExp is protocol {
    fn fmt_upper_exp(&self, f: &mut Formatter) -> Result<(), FormatError>;
};

// =============================================================================
// LowerHex / UpperHex / Binary / Octal for Int
// =============================================================================
// These use the Formatter's write_int_base method for the actual conversion.

implement LowerHex for Int {
    fn fmt_lower_hex(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_int_base(*self, 16, false)
    }
}

implement UpperHex for Int {
    fn fmt_upper_hex(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_int_base(*self, 16, true)
    }
}

implement Binary for Int {
    fn fmt_binary(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_int_base(*self, 2, false)
    }
}

implement Octal for Int {
    fn fmt_octal(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_int_base(*self, 8, false)
    }
}

// =============================================================================
// LowerExp / UpperExp for Float
// =============================================================================

implement LowerExp for Float {
    fn fmt_lower_exp(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let precision = f.precision().unwrap_or(6);
        let s = float_to_exp(*self, precision, false);
        f.write_str(&s)
    }
}

implement UpperExp for Float {
    fn fmt_upper_exp(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let precision = f.precision().unwrap_or(6);
        let s = float_to_exp(*self, precision, true);
        f.write_str(&s)
    }
}

/// Convert a float to exponential notation string.
/// `uppercase` controls whether 'E' or 'e' is used.
fn float_to_exp(value: Float, precision: Int, uppercase: Bool) -> Text {
    // Handle special cases
    if value.is_nan() {
        if uppercase { "NAN" } else { "NaN" }
    } else if value.is_infinite() {
        if value < 0.0 {
            if uppercase { "-INF" } else { "-inf" }
        } else {
            if uppercase { "INF" } else { "inf" }
        }
    } else if value == 0.0 {
        let mut result: Text = if value.is_sign_negative() { "-0." } else { "0." };
        let mut i = 0;
        while i < precision {
            result = result + "0";
            i = i + 1;
        }
        if uppercase { result = result + "E0"; } else { result = result + "e0"; }
        result
    } else {
        let negative = value < 0.0;
        let abs_val: Float = if negative { 0.0 - value } else { value };

        // Calculate exponent: floor(log10(abs_val))
        let log_val: Float = abs_val.log10();
        let exponent: Int = log_val.floor() as Int;

        // Normalize mantissa to [1.0, 10.0)
        let mut mantissa: Float = abs_val / 10.0.powi(exponent);
        // Correct for floating point imprecision
        if mantissa >= 10.0 {
            mantissa = mantissa / 10.0;
        }

        // Build the string
        let mut result: Text = if negative { "-" } else { "" };

        // Integer part of mantissa (always a single digit)
        let int_digit = mantissa.floor() as Int;
        result = result + int_digit.to_text();

        // Fractional part
        if precision > 0 {
            result = result + ".";
            let mut frac: Float = mantissa - (int_digit as Float);
            let mut i = 0;
            while i < precision {
                frac = frac * 10.0;
                let digit = frac.floor() as Int;
                result = result + digit.to_text();
                frac = frac - (digit as Float);
                i = i + 1;
            }
        }

        // Exponent part
        if uppercase {
            result = result + "E";
        } else {
            result = result + "e";
        }
        if exponent >= 0 {
            result = result + exponent.to_text();
        } else {
            result = result + "-";
            result = result + (0 - exponent).to_text();
        }
        result
    }
}

// =============================================================================
// Canonical integer-to-text conversion (#100, task #16)
// =============================================================================
//

// These two functions are the canonical entry-points for any
// caller that needs a `Text` from an `Int` (decimal or
// arbitrary radix). They route through `int_to_string` (the
// `Int.MIN`-safe `UInt64`-magnitude implementation) and the
// `format_radix_signed` style backend, eliminating the
// per-file `int_to_text` / `append_int` / `push_pad` /
// `int_to_decimal` helpers scattered across `core/database`,
// `core/database/sqlite`, `core/base/primitives` etc. Each of
// those previously carried its own copy of the negate-and-loop
// idiom, which silently produced "-" with no digits for
// `Int.MIN` (the `-Int.MIN ⇒ Int.MIN` two's-complement
// asymmetry — see commits b274ab8b / 985336e3 / 35066491 /
// f17f34ca for the per-site fixes).
//

// New code should use these helpers directly; the per-file
// copies in stdlib subgraphs will be migrated to call into
// them as task #16 follow-up.

/// Format `n` as a decimal `Text` (sign-prefixed for
/// negatives). Handles every `Int` including `Int.MIN`.
public fn int_to_text(n: Int) -> Text {
    let mut buf: [Byte; 20] = [0; 20];
    let len = int_to_string(n, &mut buf);
    Text.from_utf8_unchecked(&buf[..len])
}

/// Format `n` in the given `radix` (2..=36) as `Text`, math
/// convention for negatives (`-magnitude`, not two's-complement
/// bits). Lowercase digits.
public fn int_to_text_radix(n: Int, radix: Int) -> Text {
    if radix < 2 || radix > 36 {
        return "".clone();
    }
    if n == 0 { return "0".clone(); }

    let digits = "0123456789abcdefghijklmnopqrstuvwxyz";
    let negative = n < 0;
    let mut mag: UInt64 = if negative {
        (((!n) as UInt64) + 1_u64)
    } else {
        n as UInt64
    };
    let radix_u: UInt64 = radix as UInt64;

    // Worst case: radix 2 over 64-bit unsigned ⇒ 64 digits.
    let mut buf: [Byte; 64] = [0; 64];
    let mut i: Int = 63;
    while mag > 0_u64 {
        let digit = (mag % radix_u) as Int;
        buf[i] = digits.nth_char(digit).unwrap() as Byte;
        mag = mag / radix_u;
        i = i - 1;
    }

    let mut out = Text.new();
    if negative { out.push('-'); }
    let start = i + 1;
    let digit_str = Text.from_utf8_unchecked(&buf[start..64]);
    out.push_str(&digit_str);
    out
}

// =============================================================================
// Convenience formatting functions
// =============================================================================

/// Format a value as lowercase hexadecimal string.
///
/// The `let v: Int = *value` local-binding deref is load-bearing
/// (NOT just `(*value).to_hex()` which the Tier-0 codegen folds
/// back into the bare-receiver dispatch path): the
/// value-receiver method `Int.to_hex(self)` dispatched against
/// the `&Int` receiver lands at the raw-pointer bits (not the
/// pointee value).  Materialising the deref into a fresh local
/// `Int` register makes the dispatch unambiguous.  See
/// `core-tests/text/format/regression_test.vr` §H for the pin.
/// The sibling `format_lower_exp` / `format_upper_exp` already
/// carry the explicit-deref discipline via `float_to_exp(*value, …)`.
public fn format_hex(value: &Int) -> Text {
    let v: Int = *value;
    v.to_hex()
}

/// Format a value as binary string. (See `format_hex` for the
/// local-binding-deref discipline rationale.)
public fn format_binary(value: &Int) -> Text {
    let v: Int = *value;
    v.to_binary()
}

/// Format a value as octal string. (See `format_hex` for the
/// local-binding-deref discipline rationale.)
public fn format_octal(value: &Int) -> Text {
    let v: Int = *value;
    v.to_octal()
}

/// Format a float in lowercase exponential notation.
public fn format_lower_exp(value: &Float) -> Text {
    float_to_exp(*value, 6, false)
}

/// Format a float in uppercase exponential notation.
public fn format_upper_exp(value: &Float) -> Text {
    float_to_exp(*value, 6, true)
}
