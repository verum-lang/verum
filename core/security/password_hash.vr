// =============================================================================
// security/password_hash.vr — typed password hashing (PHC modular format)
// =============================================================================
// Layer: 3 (Security)
// Dependencies: core, core.encoding.base64, core.security.kdf.pbkdf2,
//               core.security.util.{constant_time, rng}
// =============================================================================
//
// The user-level password-stretching interface. Two pieces:
//
//   * `PasswordHasher` protocol — "hash this password, verify later".
//     One method each, same shape every backend implements.
//
//   * `Pbkdf2Sha256Hasher` — a reference implementation backed by
//     the just-landed `pbkdf2_hmac_sha256`. Encodes the stretched
//     hash in the PHC string format so the verifier doesn't need
//     side-channel knowledge of the parameters used.
//
// PHC string layout (https://github.com/P-H-C/phc-string-format):
//
//   $<id>$<params>$<salt_b64>$<hash_b64>
//
// Example for PBKDF2-HMAC-SHA256:
//
//   $pbkdf2-sha256$i=600000$<base64u-salt>$<base64u-hash>
//
// Argon2id and scrypt backends will plug in behind the same
// `PasswordHasher` protocol without caller changes.
//
// # Security defaults
//
//   * Iterations default = 600_000 (NIST SP 800-63B, 2024 revision).
//   * Salt length = 16 bytes (CSPRNG-sourced).
//   * Output length = 32 bytes (matches HMAC-SHA256 output).
//   * Verification uses constant-time comparison.
//
// =============================================================================

module core.security.password_hash;

mount core.*;
mount core.collections.List;
mount core.encoding.base64.{encode_url as b64u_encode, decode_url as b64u_decode};
mount core.security.kdf.pbkdf2.{pbkdf2_hmac_sha256, Pbkdf2Error};
mount core.security.util.rng.{fill_secure};
mount core.security.util.constant_time.{constant_time_eq};

// =============================================================================
// Error surface
// =============================================================================

public type PasswordHashError is
      WeakParameters(Text)
    | EncodingError
    | UnsupportedBackend(Text)
    | MalformedHash;

// =============================================================================
// Protocol
// =============================================================================

public type PasswordHasher is protocol {
    /// Hash `password` into a self-describing PHC-format string.
    fn hash(&self, password: &[Byte]) -> Result<Text, PasswordHashError>;

    /// Verify `password` against a previously-produced PHC hash.
    /// Returns `Ok(true)` on match, `Ok(false)` on mismatch,
    /// `Err(...)` on malformed hash or backend mismatch.
    fn verify(&self, password: &[Byte], phc_hash: &Text) -> Result<Bool, PasswordHashError>;
};

// =============================================================================
// PBKDF2-HMAC-SHA256 backend
// =============================================================================

public const PBKDF2_SHA256_ID: &str = "pbkdf2-sha256";
public const DEFAULT_PBKDF2_ITERATIONS: UInt32 = 600_000_u32;
public const DEFAULT_SALT_BYTES: Int = 16;
public const DEFAULT_OUTPUT_BYTES: Int = 32;
/// Hard floor: refuse to hash with fewer iterations than this even
/// when the caller explicitly asked for it. 2026 baseline is
/// 100_000.
public const MIN_PBKDF2_ITERATIONS: UInt32 = 100_000_u32;

/// Hard ceiling: refuse to hash or verify with more iterations than
/// this.  Without this cap, a hostile PHC hash like
/// `$pbkdf2-sha256$i=4294967295$...$...` would force the verifier
/// to run ~4 billion HMAC-SHA-256 rounds on every login attempt — a
/// trivial CPU-DoS amplifier (small attacker-controlled string,
/// massive verifier cost).
///
/// 10_000_000 is well above OWASP 2023 recommendations (600k for
/// SHA-256) and any realistic deployment, but bounded enough to
/// keep verify-time on the order of seconds rather than hours.
public const MAX_PBKDF2_ITERATIONS: UInt32 = 10_000_000_u32;

public type Pbkdf2Sha256Hasher is {
    iterations:    UInt32,
    salt_bytes:    Int,
    output_bytes:  Int,
};

implement Pbkdf2Sha256Hasher {
    /// Use NIST 2024 defaults.
    public fn with_defaults() -> Pbkdf2Sha256Hasher {
        Pbkdf2Sha256Hasher {
            iterations:   DEFAULT_PBKDF2_ITERATIONS,
            salt_bytes:   DEFAULT_SALT_BYTES,
            output_bytes: DEFAULT_OUTPUT_BYTES,
        }
    }

    /// Tune parameters; iteration counts below `MIN_PBKDF2_ITERATIONS`
    /// are rejected with `WeakParameters`.
    public fn with_iterations(mut self, n: UInt32) -> Pbkdf2Sha256Hasher {
        self.iterations = n; self
    }

    public fn with_salt_bytes(mut self, n: Int) -> Pbkdf2Sha256Hasher {
        self.salt_bytes = n; self
    }

    public fn with_output_bytes(mut self, n: Int) -> Pbkdf2Sha256Hasher {
        self.output_bytes = n; self
    }

    fn guard_params(&self) -> Result<(), PasswordHashError> {
        if self.iterations < MIN_PBKDF2_ITERATIONS {
            return Err(PasswordHashError.WeakParameters(
                Text.from("iterations below MIN_PBKDF2_ITERATIONS"),
            ));
        }
        if self.salt_bytes < 8 {
            return Err(PasswordHashError.WeakParameters(
                Text.from("salt must be ≥ 8 bytes"),
            ));
        }
        if self.output_bytes < 16 {
            return Err(PasswordHashError.WeakParameters(
                Text.from("output must be ≥ 16 bytes"),
            ));
        }
        Ok(())
    }
}

implement PasswordHasher for Pbkdf2Sha256Hasher {
    fn hash(&self, password: &[Byte]) -> Result<Text, PasswordHashError> {
        self.guard_params()?;

        let mut salt: List<Byte> = [];
        let mut tmp: [Byte; 32] = [0_u8; 32];
        while salt.len() < self.salt_bytes {
            fill_secure(&mut tmp);
            let take = if (self.salt_bytes - salt.len()) >= 32 { 32 } else { self.salt_bytes - salt.len() };
            let mut i: Int = 0;
            while i < take { salt.push(tmp[i]); i = i + 1; }
        }

        let derived = pbkdf2_hmac_sha256(password, salt.as_slice(), self.iterations, self.output_bytes)
            .map_err(|_| PasswordHashError.EncodingError)?;

        let phc = encode_phc_pbkdf2_sha256(self.iterations, salt.as_slice(), derived.as_slice());
        Ok(phc)
    }

    fn verify(&self, password: &[Byte], phc_hash: &Text) -> Result<Bool, PasswordHashError> {
        let parsed = parse_phc_pbkdf2_sha256(phc_hash)?;
        let derived = pbkdf2_hmac_sha256(
            password, parsed.salt.as_slice(), parsed.iterations, parsed.hash.len(),
        ).map_err(|_| PasswordHashError.EncodingError)?;
        Ok(constant_time_eq(derived.as_slice(), parsed.hash.as_slice()))
    }
}

// =============================================================================
// PHC encoder / parser for pbkdf2-sha256
// =============================================================================

type Pbkdf2Parsed is {
    iterations: UInt32,
    salt:       List<Byte>,
    hash:       List<Byte>,
};

fn encode_phc_pbkdf2_sha256(iterations: UInt32, salt: &[Byte], hash: &[Byte]) -> Text {
    let salt_b64 = b64u_encode(salt);
    let hash_b64 = b64u_encode(hash);
    let mut buf: List<Byte> = [];
    push_bytes(&mut buf, b"$pbkdf2-sha256$i=");
    push_u32(&mut buf, iterations);
    push_bytes(&mut buf, b"$");
    push_bytes(&mut buf, salt_b64.as_bytes());
    push_bytes(&mut buf, b"$");
    push_bytes(&mut buf, hash_b64.as_bytes());
    Text.from_utf8_unchecked(buf.as_slice())
}

fn parse_phc_pbkdf2_sha256(phc: &Text) -> Result<Pbkdf2Parsed, PasswordHashError> {
    let b = phc.as_bytes();
    // $pbkdf2-sha256$i=<N>$<salt_b64>$<hash_b64>
    if b.len() == 0 || b[0] != ('$' as Byte) { return Err(PasswordHashError.MalformedHash); }
    // Split at '$' boundaries.
    let parts = split_dollars(b);
    if parts.len() != 5 { return Err(PasswordHashError.MalformedHash); }
    // parts[0] is "" (leading $), parts[1]="pbkdf2-sha256", parts[2]="i=<N>",
    // parts[3]=salt_b64, parts[4]=hash_b64.
    let id = &parts[1];
    if !bytes_eq(id.as_slice(), b"pbkdf2-sha256") {
        return Err(PasswordHashError.UnsupportedBackend(
            Text.from_utf8_unchecked(id.as_slice())));
    }

    let iter_seg = &parts[2];
    if iter_seg.len() < 3 || iter_seg[0] != ('i' as Byte) || iter_seg[1] != ('=' as Byte) {
        return Err(PasswordHashError.MalformedHash);
    }
    let mut iters: UInt32 = 0_u32;
    let mut i: Int = 2;
    while i < iter_seg.len() {
        let c = iter_seg[i];
        if c < ('0' as Byte) || c > ('9' as Byte) { return Err(PasswordHashError.MalformedHash); }
        iters = iters * 10_u32 + ((c - ('0' as Byte)) as UInt32);
        i = i + 1;
    }

    // SOUNDNESS: cap attacker-controlled iteration count.  The PHC
    // string is parseable input; without this bound, a hostile hash
    // claiming i=4294967295 forces the verifier to run ~4 billion
    // HMAC-SHA-256 rounds on every login attempt — trivial CPU-DoS
    // amplifier where the attacker pays a tiny string-construction
    // cost and the verifier pays days/weeks/years of CPU.
    if iters < MIN_PBKDF2_ITERATIONS || iters > MAX_PBKDF2_ITERATIONS {
        return Err(PasswordHashError.WeakParameters(
            Text.from("iteration count outside [MIN, MAX] range")));
    }

    let salt = b64u_decode(&Text.from_utf8_unchecked(parts[3].as_slice()))
        .map_err(|_| PasswordHashError.EncodingError)?;
    let hash = b64u_decode(&Text.from_utf8_unchecked(parts[4].as_slice()))
        .map_err(|_| PasswordHashError.EncodingError)?;

    Ok(Pbkdf2Parsed { iterations: iters, salt: salt, hash: hash })
}

fn split_dollars(b: &[Byte]) -> List<List<Byte>> {
    let mut out: List<List<Byte>> = [];
    let mut cur: List<Byte> = [];
    let mut i: Int = 0;
    while i < b.len() {
        if b[i] == ('$' as Byte) {
            out.push(cur);
            cur = [];
        } else {
            cur.push(b[i]);
        }
        i = i + 1;
    }
    out.push(cur);
    out
}

// =============================================================================
// Helpers
// =============================================================================

fn push_bytes(dst: &mut List<Byte>, src: &[Byte]) {
    let mut i: Int = 0;
    while i < src.len() { dst.push(src[i]); i = i + 1; }
}

fn push_u32(dst: &mut List<Byte>, n: UInt32) {
    if n == 0_u32 { dst.push('0' as Byte); return; }
    let mut buf: List<Byte> = [];
    let mut x = n;
    while x > 0_u32 {
        let d = (x % 10_u32) as Byte;
        buf.push(('0' as Byte) + d);
        x = x / 10_u32;
    }
    let mut i: Int = buf.len() - 1;
    while i >= 0 { dst.push(buf[i]); i = i - 1; }
}

fn bytes_eq(a: &[Byte], b: &[Byte]) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        if a[i] != b[i] { return false; }
        i = i + 1;
    }
    true
}
