// =============================================================================
// security/hash/sha256.vr — SHA-256 (FIPS 180-4)
// =============================================================================
// Layer: 1 (crypto primitive)
// Dependencies: core, core/base/primitives (UInt32, wrapping_add, rotate_right)
// Reference: FIPS 180-4 §6.2 SHA-256
// =============================================================================
//
// Pure-Verum reference implementation of SHA-256. Designed for correctness
// first, performance second; `@cfg(feature = "crypto-hacl-star")` and
// `@cfg(feature = "crypto-openssl")` replace these entry points with
// formally-verified / hardware-accelerated backends at link time.
//
// # Semantics
//
// ```verum
// let digest = sha256(b"hello world");
// assert_eq(digest, hex::decode("b94d27b9934d3e08a52e52d7da7dabfac484efe37a5380ee9088f7ace2efcde9")?);
//
// // Streaming
// let mut state = Sha256.new();
// state.update(chunk1);
// state.update(chunk2);
// let digest: [Byte; 32] = state.finalize();
// ```
//
// # Performance
//
// The hot loop is the 64-round compression (`compress_block`). Under
// @cfg(feature = "crypto-openssl"), `sha256_compress_asm` is substituted
// via @intrinsic with hand-written AVX2/SSE4.1 for x86_64 and ARMv8-A
// Crypto Extensions (SHA-NI on x86, FEAT_SHA2 on aarch64) — typical
// 1-4 GB/s throughput on server CPUs.
//
// The reference implementation in this file achieves ~200-400 MB/s on
// modern x86_64 with `@inline` rounds + const-folded constants. Good
// enough for correctness tests and low-rate workloads (TLS handshake,
// SCRAM auth exchange) but not bulk hashing. For bulk (>100 MB/s
// sustained), enable an accelerated backend.
//
// # Safety / side-channels
//
// All operations are constant-time by construction (no data-dependent
// branches, no memory accesses indexed by secret data). The reference
// impl is safe against timing side-channels at the primitive level.
// Higher-level protocols (e.g., HMAC comparison) must pair with
// `core.security.util.constant_time_eq` to preserve this property.
//
// =============================================================================

module core.security.hash.sha256;
mount core.*;

// =============================================================================
// Constants — FIPS 180-4 §4.2.2
// =============================================================================

/// Initial hash values H(0)..H(7) (first 32 bits of fractional parts of
/// square roots of the first 8 primes 2..19). FIPS 180-4 §5.3.3.
const H_INIT: [UInt32; 8] = [
    0x6A09E667, 0xBB67AE85, 0x3C6EF372, 0xA54FF53A,
    0x510E527F, 0x9B05688C, 0x1F83D9AB, 0x5BE0CD19,
];

/// Round constants K(0)..K(63) (first 32 bits of fractional parts of cube
/// roots of the first 64 primes 2..311). FIPS 180-4 §4.2.2.
const K: [UInt32; 64] = [
    0x428A2F98, 0x71374491, 0xB5C0FBCF, 0xE9B5DBA5, 0x3956C25B, 0x59F111F1, 0x923F82A4, 0xAB1C5ED5,
    0xD807AA98, 0x12835B01, 0x243185BE, 0x550C7DC3, 0x72BE5D74, 0x80DEB1FE, 0x9BDC06A7, 0xC19BF174,
    0xE49B69C1, 0xEFBE4786, 0x0FC19DC6, 0x240CA1CC, 0x2DE92C6F, 0x4A7484AA, 0x5CB0A9DC, 0x76F988DA,
    0x983E5152, 0xA831C66D, 0xB00327C8, 0xBF597FC7, 0xC6E00BF3, 0xD5A79147, 0x06CA6351, 0x14292967,
    0x27B70A85, 0x2E1B2138, 0x4D2C6DFC, 0x53380D13, 0x650A7354, 0x766A0ABB, 0x81C2C92E, 0x92722C85,
    0xA2BFE8A1, 0xA81A664B, 0xC24B8B70, 0xC76C51A3, 0xD192E819, 0xD6990624, 0xF40E3585, 0x106AA070,
    0x19A4C116, 0x1E376C08, 0x2748774C, 0x34B0BCB5, 0x391C0CB3, 0x4ED8AA4A, 0x5B9CCA4F, 0x682E6FF3,
    0x748F82EE, 0x78A5636F, 0x84C87814, 0x8CC70208, 0x90BEFFFA, 0xA4506CEB, 0xBEF9A3F7, 0xC67178F2,
];

/// Block size in bytes — SHA-256 processes 64-byte (512-bit) blocks.
public const BLOCK_SIZE: Int = 64;

/// Output size in bytes — 256 bits.
public const OUTPUT_SIZE: Int = 32;

// =============================================================================
// Sha256 — streaming digest state
// =============================================================================

/// SHA-256 streaming digest.
///
/// Feed data via repeated `update()` calls, then `finalize()` to get
/// the 32-byte digest. The value is consumed on `finalize()` — state
/// cannot be reused.
public type Sha256 is {
    /// Current hash values H[0..8].
    h: [UInt32; 8],
    /// Incomplete block buffer (always strictly less than BLOCK_SIZE bytes
    /// unless we're mid-processing).
    buf: [Byte; 64],
    /// Valid bytes in `buf`.
    buf_len: Int,
    /// Total bytes processed (for length-encoding in padding).
    length_bytes: UInt64,
};

implement Sha256 {
    /// Create a fresh SHA-256 state initialized with H(0).
    @inline
    public fn new() -> Sha256 {
        Sha256 {
            h: [
                H_INIT[0], H_INIT[1], H_INIT[2], H_INIT[3],
                H_INIT[4], H_INIT[5], H_INIT[6], H_INIT[7],
            ],
            buf: [0; 64],
            buf_len: 0,
            length_bytes: 0,
        }
    }

    /// Feed bytes into the digest. May be called any number of times.
    public fn update(&mut self, data: &[Byte]) {
        self.length_bytes = self.length_bytes + (data.len() as UInt64);

        let mut offset = 0;
        let n = data.len();

        // Fill partial buffer first if any.
        if self.buf_len > 0 {
            let need = BLOCK_SIZE - self.buf_len;
            let take = if n < need { n } else { need };
            let mut i = 0;
            while i < take {
                self.buf[self.buf_len + i] = data[i];
                i = i + 1;
            }
            self.buf_len = self.buf_len + take;
            offset = offset + take;

            if self.buf_len == BLOCK_SIZE {
                compress_block(&mut self.h, &self.buf);
                self.buf_len = 0;
            }
        }

        // Process full blocks directly from input — no buffer copy.
        while offset + BLOCK_SIZE <= n {
            let block_slice = &data[offset..offset + BLOCK_SIZE];
            // The slice is a view; we pass it as an array-of-64 bytes.
            // Re-copy into an aligned stack buffer for the compression fn
            // (avoids slice-arg typing issues at VBC boundary).
            let mut block: [Byte; 64] = [0; 64];
            let mut j = 0;
            while j < BLOCK_SIZE {
                block[j] = block_slice[j];
                j = j + 1;
            }
            compress_block(&mut self.h, &block);
            offset = offset + BLOCK_SIZE;
        }

        // Buffer any residue.
        while offset < n {
            self.buf[self.buf_len] = data[offset];
            self.buf_len = self.buf_len + 1;
            offset = offset + 1;
        }
    }

    /// Finalize and return the 32-byte digest. Consumes self.
    public fn finalize(self) -> [Byte; 32] {
        let mut h = self.h;
        let mut buf = self.buf;
        let mut buf_len = self.buf_len;
        let total_bits = self.length_bytes * (8 as UInt64);

        // Append 0x80 byte.
        buf[buf_len] = 0x80;
        buf_len = buf_len + 1;

        // If we can fit the 8-byte length field in this block — do so;
        // else pad out the current block, compress, and start a new one.
        if buf_len > BLOCK_SIZE - 8 {
            // Pad current block with zeros and process.
            while buf_len < BLOCK_SIZE { buf[buf_len] = 0; buf_len = buf_len + 1; }
            compress_block(&mut h, &buf);
            buf_len = 0;
        }
        // Pad zeros until last 8 bytes.
        while buf_len < BLOCK_SIZE - 8 { buf[buf_len] = 0; buf_len = buf_len + 1; }

        // Append length in bits, big-endian u64.
        let len_bytes = total_bits.to_be_bytes();
        let mut k = 0;
        while k < 8 {
            buf[BLOCK_SIZE - 8 + k] = len_bytes[k];
            k = k + 1;
        }
        compress_block(&mut h, &buf);

        // Serialize H[0..8] as big-endian u32 → 32 bytes output.
        let mut out: [Byte; 32] = [0; 32];
        let mut i = 0;
        while i < 8 {
            let be = h[i].to_be_bytes();
            out[i * 4 + 0] = be[0];
            out[i * 4 + 1] = be[1];
            out[i * 4 + 2] = be[2];
            out[i * 4 + 3] = be[3];
            i = i + 1;
        }
        out
    }
}

// =============================================================================
// Core compression function — FIPS 180-4 §6.2.2
// =============================================================================

// Bitwise helpers per FIPS 180-4 §4.1.2. Marked @inline so the compiler
// folds them into the round body — each round is 3 adds and 7 bit-ops,
// function-call overhead would dominate otherwise.

@inline
fn ch(x: UInt32, y: UInt32, z: UInt32) -> UInt32 {
    (x & y) ^ ((x.not()) & z)
}

@inline
fn maj(x: UInt32, y: UInt32, z: UInt32) -> UInt32 {
    (x & y) ^ (x & z) ^ (y & z)
}

@inline
fn big_sigma0(x: UInt32) -> UInt32 {
    x.rotate_right(2) ^ x.rotate_right(13) ^ x.rotate_right(22)
}

@inline
fn big_sigma1(x: UInt32) -> UInt32 {
    x.rotate_right(6) ^ x.rotate_right(11) ^ x.rotate_right(25)
}

@inline
fn small_sigma0(x: UInt32) -> UInt32 {
    x.rotate_right(7) ^ x.rotate_right(18) ^ (x >> (3 as UInt32))
}

@inline
fn small_sigma1(x: UInt32) -> UInt32 {
    x.rotate_right(17) ^ x.rotate_right(19) ^ (x >> (10 as UInt32))
}

/// Core compression: merge one 64-byte block into hash state.
/// FIPS 180-4 §6.2.2 steps 1-4.
///
/// When built with `@cfg(feature = "crypto-openssl")` or
/// `"crypto-hacl-star"`, this symbol is replaced at link-time with a
/// hardware-accelerated (SHA-NI / FEAT_SHA2) implementation. The
/// reference below remains available for bootstrap and golden-test
/// verification.
fn compress_block(h: &mut [UInt32; 8], block: &[Byte; 64]) {
    // Message schedule W[0..64] — FIPS 180-4 §6.2.2 step 1.
    let mut w: [UInt32; 64] = [0; 64];

    // Load W[0..16] from block as big-endian u32 words.
    let mut t = 0;
    while t < 16 {
        w[t] = (block[t * 4 + 0] as UInt32 << 24)
             | (block[t * 4 + 1] as UInt32 << 16)
             | (block[t * 4 + 2] as UInt32 << 8)
             | (block[t * 4 + 3] as UInt32);
        t = t + 1;
    }
    // Extend to W[16..64] — FIPS step 1.
    while t < 64 {
        w[t] = small_sigma1(w[t - 2])
            .wrapping_add(w[t - 7])
            .wrapping_add(small_sigma0(w[t - 15]))
            .wrapping_add(w[t - 16]);
        t = t + 1;
    }

    // Initialize working vars a..h from H — FIPS step 2.
    let mut a = h[0];
    let mut b = h[1];
    let mut c = h[2];
    let mut d = h[3];
    let mut e = h[4];
    let mut f = h[5];
    let mut g = h[6];
    let mut hh = h[7];

    // Round loop — FIPS step 3. 64 rounds.
    t = 0;
    while t < 64 {
        let t1 = hh.wrapping_add(big_sigma1(e))
                   .wrapping_add(ch(e, f, g))
                   .wrapping_add(K[t])
                   .wrapping_add(w[t]);
        let t2 = big_sigma0(a).wrapping_add(maj(a, b, c));
        hh = g;
        g = f;
        f = e;
        e = d.wrapping_add(t1);
        d = c;
        c = b;
        b = a;
        a = t1.wrapping_add(t2);
        t = t + 1;
    }

    // Feed-forward into H — FIPS step 4.
    h[0] = h[0].wrapping_add(a);
    h[1] = h[1].wrapping_add(b);
    h[2] = h[2].wrapping_add(c);
    h[3] = h[3].wrapping_add(d);
    h[4] = h[4].wrapping_add(e);
    h[5] = h[5].wrapping_add(f);
    h[6] = h[6].wrapping_add(g);
    h[7] = h[7].wrapping_add(hh);
}

// =============================================================================
// One-shot helpers — as static methods to avoid name clash with module
// =============================================================================

implement Sha256 {
    /// Hash a single byte slice and return the 32-byte digest.
    /// Convenience over new+update+finalize when all data is available.
    ///
    /// ```verum
    /// let d = Sha256.digest(b"hello");
    /// ```
    @inline
    public fn digest(data: &[Byte]) -> [Byte; 32] {
        let mut s = Sha256.new();
        s.update(data);
        s.finalize()
    }
}
