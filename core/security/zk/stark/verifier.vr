// =============================================================================
// security/zk/stark/verifier.vr — STARK verifier (FRI-based)
// =============================================================================
//

// `verify(air_vk, proof, public_inputs, params) → Bool`. The verifier:
//
//   1. Fiat-Shamir-derives all challenges from the BLAKE3 transcript.
//   2. Checks Merkle inclusion proofs at the queried indices.
//   3. Runs the FRI verifier (logarithmic-many fold-and-verify steps).
//   4. Cross-checks that each committed value is consistent with the
//      prover's claimed transition + boundary constraints.
//
// Verifier runtime is `O(polylog N)` — independent of the trace length.
// In practice ~5-15 ms for typical params on commodity CPUs.
//
// `verify_batch` runs N verifies but pools the FRI random-linear-
// combination so the dominant pairing-equation cost amortises.
// ~1.5-2× faster than N independent verifies for N ≥ 4.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Conditional([
        "STARK stdlib parent module conditions hold",
    ]),
    at_tier: Tier.MultiTier([Tier.Aot, Tier.Interp]),
)
module core.security.zk.stark.verifier;
mount core.*;
mount core.security.zk.stark.air.{Air, ProofParams};
mount core.security.zk.stark.prover.{Proof};

// =============================================================================
// AirVk — verifier-side digest of an AIR
// =============================================================================

/// Verifier-side AIR digest. Bit-for-bit content-addressed digest
/// of the canonical AIR encoding (BLAKE3). The chain commits to
/// `vk.digest` as the public statement of "what's being proved";
/// the proof + public_inputs decide "whether the prover proved it".
public type AirVk is {
    digest: [Byte; 32],
    /// Cached AIR object — the verifier needs the structural data
    /// (transition / boundary constraint expressions) to reconstruct
    /// challenges deterministically.
    air:    Air,
};

implement AirVk {
    public fn from_air(air: Air) -> AirVk {
        let digest = @intrinsic("verum.crypto.stark_air_digest", &air);
        let mut d: [Byte; 32] = [0; 32];
        let mut i: Int = 0; while i < 32 { d[i] = digest[i]; i = i + 1; }
        AirVk { digest: d, air }
    }
}

// =============================================================================
// Errors
// =============================================================================

public type VerifierError is
    | PublicInputArity { expected: Int, got: Int }
    | MalformedProof(Text)
    | AirVkMismatch
    | VerificationFailed
    | BackendError(Text);

implement Display for VerifierError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            PublicInputArity { expected, got } =>
                f.write_str(f"stark.verifier: public-input arity expected={expected} got={got}".as_str()),
            MalformedProof(why)    => f.write_str(f"stark.verifier: malformed proof ({why})".as_str()),
            AirVkMismatch          => f.write_str("stark.verifier: AIR digest mismatch"),
            VerificationFailed     => f.write_str("stark.verifier: verification failed"),
            BackendError(why)      => f.write_str(f"stark.verifier: backend ({why})".as_str()),
        }
    }
}

// =============================================================================
// Verify
// =============================================================================

public fn verify(
    vk:            &AirVk,
    proof:         &Proof,
    public_inputs: &List<List<Byte>>,
    params:        &ProofParams,
) -> Result<(), VerifierError> {
    if public_inputs.len() != vk.air.public_input_arity {
        return Err(PublicInputArity {
            expected: vk.air.public_input_arity,
            got: public_inputs.len(),
        });
    }
    match @intrinsic(
        "verum.crypto.stark_verify",
        vk, proof, public_inputs, params,
    ) {
        VerifyResult.Accepted        => Ok(()),
        VerifyResult.Rejected        => Err(VerificationFailed),
        VerifyResult.Malformed(why)  => Err(MalformedProof(why)),
        VerifyResult.AirMismatch     => Err(AirVkMismatch),
        VerifyResult.Backend(why)    => Err(BackendError(why)),
    }
}

/// Batch-verify N proofs sharing a single `vk`. FRI random-linear-
/// combination across all `proof`s reduces work; soundness preserved
/// (Ben-Sasson 2018 §4).
public fn verify_batch(
    vk:                 &AirVk,
    proofs_with_inputs: &List<(Proof, List<List<Byte>>)>,
    params:             &ProofParams,
) -> Result<(), VerifierError> {
    if proofs_with_inputs.is_empty() {
        return Ok(());
    }
    match @intrinsic(
        "verum.crypto.stark_verify_batch",
        vk, proofs_with_inputs, params,
    ) {
        VerifyResult.Accepted        => Ok(()),
        VerifyResult.Rejected        => Err(VerificationFailed),
        VerifyResult.Malformed(why)  => Err(MalformedProof(why)),
        VerifyResult.AirMismatch     => Err(AirVkMismatch),
        VerifyResult.Backend(why)    => Err(BackendError(why)),
    }
}

// =============================================================================
// Internal — backend response variants
// =============================================================================

type VerifyResult is
    | Accepted
    | Rejected
    | Malformed(Text)
    | AirMismatch
    | Backend(Text);
