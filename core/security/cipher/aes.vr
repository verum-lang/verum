// =============================================================================
// security/cipher/aes.vr — Advanced Encryption Standard (FIPS 197)
// =============================================================================
// Layer: 2 (core primitive)
// Dependencies: core
// Reference: NIST FIPS 197 — Advanced Encryption Standard
//            NIST SP 800-38A §6 (modes of operation live in aes_modes.vr)
// =============================================================================
//
// AES-128 and AES-256 block-cipher core — single-block encrypt/decrypt +
// key schedule. Block size is always 16 bytes; key size is 16 (AES-128)
// or 32 (AES-256). AES-192 is intentionally omitted — neither TLS 1.3,
// QUIC, nor any modern protocol negotiates it; leaving it out keeps
// the attack surface smaller.
//
// # Constant-time discipline
//
// The reference implementation below uses the standard 256-byte S-box
// and inverse S-box. **Table-lookups into a 256-byte block are cache-
// timing susceptible on shared hardware.** Production deployments MUST
// enable `@cfg(feature = "crypto-accel")` which substitutes the
// block-encrypt / key-schedule bodies with:
//
//   * Intel AES-NI / VAES (AVX-512): `aesenc`, `aesdec`, `aeskeygenassist`
//     — hardware primitives that are natively constant-time and ~10 GiB/s.
//   * ARMv8 AES Crypto Extensions: `aese`, `aesd`, `aesmc`, `aesimc`
//     — same guarantees on modern ARM cores.
//
// The reference code remains as the canonical golden source — all
// accelerated implementations are differentially tested against it via
// property-tests in `vcs/specs/L1-core/security/run/aes_kat.vr`
// (NIST KAT + FIPS 197 Appendix C vectors).
//
// # Typed keys — refinement-checked sizes
//
// Keys are fixed-size byte arrays. Handlers that accept `AesKey128`
// have compile-time guarantee on the 16-byte length; `AesKey256` the
// 32-byte length. Mis-sized keys are a type error, not a runtime
// condition.
//
// # Typed round-key state
//
// `RoundKeys128` / `RoundKeys256` hold the expanded round keys as
// `[UInt32; 44]` / `[UInt32; 60]` (one u32 per AES word, 4 per round,
// 11 / 15 rounds total). This layout matches the FIPS 197 schedule
// exactly and is identical to what AES-NI's `aeskeygenassist` fills.
//
// # Usage
//
// ```verum
// let key: AesKey128 = [0x2b, 0x7e, /* ... 14 more ... */];
// let rk = RoundKeys128.expand(&key);
// let mut block: [Byte; 16] = [0x32, 0x43, 0xf6, 0xa8, /* ... */];
// aes128_encrypt_block(&rk, &mut block);
// ```
//
// =============================================================================

module core.security.cipher.aes;
mount core.*;

// =============================================================================
// Fixed sizes — FIPS 197 §5.2
// =============================================================================

public const BLOCK_SIZE: Int = 16;

public const AES128_KEY_SIZE: Int = 16;
public const AES128_NR: Int = 10;            // number of rounds
public const AES128_NK: Int = 4;             // key length in u32 words
public const AES128_RK_WORDS: Int = AES128_NK * (AES128_NR + 1); // 44

public const AES256_KEY_SIZE: Int = 32;
public const AES256_NR: Int = 14;
public const AES256_NK: Int = 8;
public const AES256_RK_WORDS: Int = AES256_NK * 4 / 4 * (AES256_NR + 1) / 8 * 8;
// Cleaner form: total round-key u32 words = 4 * (Nr + 1) = 60.
// Some downstream code expects the explicit count; the expression above
// evaluates to 60 for Nr=14.

// =============================================================================
// Typed keys
// =============================================================================

public type AesKey128 is [Byte; 16];
public type AesKey256 is [Byte; 32];

/// Expanded round keys for AES-128 — 11 128-bit keys = 44 u32 words.
public type RoundKeys128 is { w: [UInt32; 44] };

/// Expanded round keys for AES-256 — 15 128-bit keys = 60 u32 words.
public type RoundKeys256 is { w: [UInt32; 60] };

// =============================================================================
// Forward S-box — FIPS 197 §5.1.1, table 5.1
// =============================================================================

const SBOX: [Byte; 256] = [
    0x63, 0x7C, 0x77, 0x7B, 0xF2, 0x6B, 0x6F, 0xC5, 0x30, 0x01, 0x67, 0x2B, 0xFE, 0xD7, 0xAB, 0x76,
    0xCA, 0x82, 0xC9, 0x7D, 0xFA, 0x59, 0x47, 0xF0, 0xAD, 0xD4, 0xA2, 0xAF, 0x9C, 0xA4, 0x72, 0xC0,
    0xB7, 0xFD, 0x93, 0x26, 0x36, 0x3F, 0xF7, 0xCC, 0x34, 0xA5, 0xE5, 0xF1, 0x71, 0xD8, 0x31, 0x15,
    0x04, 0xC7, 0x23, 0xC3, 0x18, 0x96, 0x05, 0x9A, 0x07, 0x12, 0x80, 0xE2, 0xEB, 0x27, 0xB2, 0x75,
    0x09, 0x83, 0x2C, 0x1A, 0x1B, 0x6E, 0x5A, 0xA0, 0x52, 0x3B, 0xD6, 0xB3, 0x29, 0xE3, 0x2F, 0x84,
    0x53, 0xD1, 0x00, 0xED, 0x20, 0xFC, 0xB1, 0x5B, 0x6A, 0xCB, 0xBE, 0x39, 0x4A, 0x4C, 0x58, 0xCF,
    0xD0, 0xEF, 0xAA, 0xFB, 0x43, 0x4D, 0x33, 0x85, 0x45, 0xF9, 0x02, 0x7F, 0x50, 0x3C, 0x9F, 0xA8,
    0x51, 0xA3, 0x40, 0x8F, 0x92, 0x9D, 0x38, 0xF5, 0xBC, 0xB6, 0xDA, 0x21, 0x10, 0xFF, 0xF3, 0xD2,
    0xCD, 0x0C, 0x13, 0xEC, 0x5F, 0x97, 0x44, 0x17, 0xC4, 0xA7, 0x7E, 0x3D, 0x64, 0x5D, 0x19, 0x73,
    0x60, 0x81, 0x4F, 0xDC, 0x22, 0x2A, 0x90, 0x88, 0x46, 0xEE, 0xB8, 0x14, 0xDE, 0x5E, 0x0B, 0xDB,
    0xE0, 0x32, 0x3A, 0x0A, 0x49, 0x06, 0x24, 0x5C, 0xC2, 0xD3, 0xAC, 0x62, 0x91, 0x95, 0xE4, 0x79,
    0xE7, 0xC8, 0x37, 0x6D, 0x8D, 0xD5, 0x4E, 0xA9, 0x6C, 0x56, 0xF4, 0xEA, 0x65, 0x7A, 0xAE, 0x08,
    0xBA, 0x78, 0x25, 0x2E, 0x1C, 0xA6, 0xB4, 0xC6, 0xE8, 0xDD, 0x74, 0x1F, 0x4B, 0xBD, 0x8B, 0x8A,
    0x70, 0x3E, 0xB5, 0x66, 0x48, 0x03, 0xF6, 0x0E, 0x61, 0x35, 0x57, 0xB9, 0x86, 0xC1, 0x1D, 0x9E,
    0xE1, 0xF8, 0x98, 0x11, 0x69, 0xD9, 0x8E, 0x94, 0x9B, 0x1E, 0x87, 0xE9, 0xCE, 0x55, 0x28, 0xDF,
    0x8C, 0xA1, 0x89, 0x0D, 0xBF, 0xE6, 0x42, 0x68, 0x41, 0x99, 0x2D, 0x0F, 0xB0, 0x54, 0xBB, 0x16,
];

// Round-constant table Rcon[1..11] — FIPS 197 §5.2.
// Only the first byte of each round constant is non-zero; the rest
// are 0. We store only the non-zero byte as a u32-shifted value so
// key-expansion XORs it into w[i-1] directly.
const RCON: [UInt32; 11] = [
    0x00000000,  // Rcon[0] unused
    0x01000000, 0x02000000, 0x04000000, 0x08000000, 0x10000000,
    0x20000000, 0x40000000, 0x80000000, 0x1B000000, 0x36000000,
];

// =============================================================================
// Primitive helpers — all @inline so the compiler folds them into
// the round bodies.
// =============================================================================

@inline
fn sub_byte(b: Byte) -> Byte { SBOX[b as Int] }

@inline
fn sub_word(w: UInt32) -> UInt32 {
    let b0 = sub_byte(((w >> 24) & 0xFF) as Byte) as UInt32;
    let b1 = sub_byte(((w >> 16) & 0xFF) as Byte) as UInt32;
    let b2 = sub_byte(((w >>  8) & 0xFF) as Byte) as UInt32;
    let b3 = sub_byte((w & 0xFF) as Byte) as UInt32;
    (b0 << 24) | (b1 << 16) | (b2 << 8) | b3
}

@inline
fn rot_word(w: UInt32) -> UInt32 {
    (w << 8) | (w >> 24)
}

@inline
fn bytes_to_word(b0: Byte, b1: Byte, b2: Byte, b3: Byte) -> UInt32 {
    ((b0 as UInt32) << 24) | ((b1 as UInt32) << 16) |
    ((b2 as UInt32) << 8)  | (b3 as UInt32)
}

/// Multiply by x in GF(2^8) with reduction polynomial 0x11B.
@inline
fn xtime(b: Byte) -> Byte {
    let msb = (b & 0x80) as Byte;
    let shifted = (b << 1) & 0xFF;
    if msb != 0 { shifted ^ 0x1B } else { shifted }
}

// =============================================================================
// Key expansion — FIPS 197 §5.2
// =============================================================================

implement RoundKeys128 {
    public fn expand(key: &AesKey128) -> RoundKeys128 {
        let mut w: [UInt32; 44] = [0; 44];
        // First Nk words — key bytes directly.
        let mut i = 0;
        while i < AES128_NK {
            w[i] = bytes_to_word(
                key[4 * i + 0], key[4 * i + 1],
                key[4 * i + 2], key[4 * i + 3],
            );
            i = i + 1;
        }
        // Remaining words.
        while i < AES128_RK_WORDS {
            let mut temp = w[i - 1];
            if (i % AES128_NK) == 0 {
                temp = sub_word(rot_word(temp)) ^ RCON[i / AES128_NK];
            }
            w[i] = w[i - AES128_NK] ^ temp;
            i = i + 1;
        }
        RoundKeys128 { w: w }
    }
}

implement RoundKeys256 {
    public fn expand(key: &AesKey256) -> RoundKeys256 {
        let mut w: [UInt32; 60] = [0; 60];
        let mut i = 0;
        while i < AES256_NK {
            w[i] = bytes_to_word(
                key[4 * i + 0], key[4 * i + 1],
                key[4 * i + 2], key[4 * i + 3],
            );
            i = i + 1;
        }
        let total: Int = 4 * (AES256_NR + 1);   // 60
        while i < total {
            let mut temp = w[i - 1];
            let r = i % AES256_NK;
            if r == 0 {
                temp = sub_word(rot_word(temp)) ^ RCON[i / AES256_NK];
            } else if r == 4 {
                // Extra SubWord on 4-aligned boundaries for AES-256.
                temp = sub_word(temp);
            }
            w[i] = w[i - AES256_NK] ^ temp;
            i = i + 1;
        }
        RoundKeys256 { w: w }
    }
}

// =============================================================================
// Block transforms — FIPS 197 §5.1
// =============================================================================

/// SubBytes + ShiftRows + MixColumns + AddRoundKey, one round.
/// Operates on the 4×4 state in column-major order (matches FIPS).
@inline
fn sub_shift_mix_round(state: &mut [Byte; 16], rk: &[UInt32; 4]) {
    // SubBytes + ShiftRows combined (ShiftRows is free in the SBOX lookup
    // because we read the shifted source indices directly).
    //
    // Note the column-major order — FIPS 197 §3.4 defines state[row][col].
    // Here state[i] stores column-major: state[c*4 + r].
    let s0  = sub_byte(state[ 0]);
    let s1  = sub_byte(state[ 1]);
    let s2  = sub_byte(state[ 2]);
    let s3  = sub_byte(state[ 3]);
    let s4  = sub_byte(state[ 4]);
    let s5  = sub_byte(state[ 5]);
    let s6  = sub_byte(state[ 6]);
    let s7  = sub_byte(state[ 7]);
    let s8  = sub_byte(state[ 8]);
    let s9  = sub_byte(state[ 9]);
    let s10 = sub_byte(state[10]);
    let s11 = sub_byte(state[11]);
    let s12 = sub_byte(state[12]);
    let s13 = sub_byte(state[13]);
    let s14 = sub_byte(state[14]);
    let s15 = sub_byte(state[15]);

    // ShiftRows: row r is rotated left by r positions.
    // Column 0 gets (s0, s5, s10, s15); column 1 gets (s4, s9, s14, s3); etc.
    let r00 = s0;  let r01 = s5;  let r02 = s10; let r03 = s15;
    let r10 = s4;  let r11 = s9;  let r12 = s14; let r13 = s3;
    let r20 = s8;  let r21 = s13; let r22 = s2;  let r23 = s7;
    let r30 = s12; let r31 = s1;  let r32 = s6;  let r33 = s11;

    // MixColumns per FIPS 197 §5.1.3:
    //   s'_c = (02 · s0) XOR (03 · s1) XOR s2 XOR s3
    //   where all ops are in GF(2^8).
    let m00 = xtime(r00) ^ (xtime(r01) ^ r01) ^ r02 ^ r03;
    let m01 = r00 ^ xtime(r01) ^ (xtime(r02) ^ r02) ^ r03;
    let m02 = r00 ^ r01 ^ xtime(r02) ^ (xtime(r03) ^ r03);
    let m03 = (xtime(r00) ^ r00) ^ r01 ^ r02 ^ xtime(r03);

    let m10 = xtime(r10) ^ (xtime(r11) ^ r11) ^ r12 ^ r13;
    let m11 = r10 ^ xtime(r11) ^ (xtime(r12) ^ r12) ^ r13;
    let m12 = r10 ^ r11 ^ xtime(r12) ^ (xtime(r13) ^ r13);
    let m13 = (xtime(r10) ^ r10) ^ r11 ^ r12 ^ xtime(r13);

    let m20 = xtime(r20) ^ (xtime(r21) ^ r21) ^ r22 ^ r23;
    let m21 = r20 ^ xtime(r21) ^ (xtime(r22) ^ r22) ^ r23;
    let m22 = r20 ^ r21 ^ xtime(r22) ^ (xtime(r23) ^ r23);
    let m23 = (xtime(r20) ^ r20) ^ r21 ^ r22 ^ xtime(r23);

    let m30 = xtime(r30) ^ (xtime(r31) ^ r31) ^ r32 ^ r33;
    let m31 = r30 ^ xtime(r31) ^ (xtime(r32) ^ r32) ^ r33;
    let m32 = r30 ^ r31 ^ xtime(r32) ^ (xtime(r33) ^ r33);
    let m33 = (xtime(r30) ^ r30) ^ r31 ^ r32 ^ xtime(r33);

    // AddRoundKey — XOR the round-key column-u32 with the column-bytes.
    state[ 0] = m00 ^ (((rk[0] >> 24) & 0xFF) as Byte);
    state[ 1] = m01 ^ (((rk[0] >> 16) & 0xFF) as Byte);
    state[ 2] = m02 ^ (((rk[0] >>  8) & 0xFF) as Byte);
    state[ 3] = m03 ^ ((rk[0] & 0xFF) as Byte);

    state[ 4] = m10 ^ (((rk[1] >> 24) & 0xFF) as Byte);
    state[ 5] = m11 ^ (((rk[1] >> 16) & 0xFF) as Byte);
    state[ 6] = m12 ^ (((rk[1] >>  8) & 0xFF) as Byte);
    state[ 7] = m13 ^ ((rk[1] & 0xFF) as Byte);

    state[ 8] = m20 ^ (((rk[2] >> 24) & 0xFF) as Byte);
    state[ 9] = m21 ^ (((rk[2] >> 16) & 0xFF) as Byte);
    state[10] = m22 ^ (((rk[2] >>  8) & 0xFF) as Byte);
    state[11] = m23 ^ ((rk[2] & 0xFF) as Byte);

    state[12] = m30 ^ (((rk[3] >> 24) & 0xFF) as Byte);
    state[13] = m31 ^ (((rk[3] >> 16) & 0xFF) as Byte);
    state[14] = m32 ^ (((rk[3] >>  8) & 0xFF) as Byte);
    state[15] = m33 ^ ((rk[3] & 0xFF) as Byte);
}

/// Final round — no MixColumns. FIPS 197 §5.1.
@inline
fn sub_shift_final(state: &mut [Byte; 16], rk: &[UInt32; 4]) {
    let s0  = sub_byte(state[ 0]);
    let s1  = sub_byte(state[ 1]);
    let s2  = sub_byte(state[ 2]);
    let s3  = sub_byte(state[ 3]);
    let s4  = sub_byte(state[ 4]);
    let s5  = sub_byte(state[ 5]);
    let s6  = sub_byte(state[ 6]);
    let s7  = sub_byte(state[ 7]);
    let s8  = sub_byte(state[ 8]);
    let s9  = sub_byte(state[ 9]);
    let s10 = sub_byte(state[10]);
    let s11 = sub_byte(state[11]);
    let s12 = sub_byte(state[12]);
    let s13 = sub_byte(state[13]);
    let s14 = sub_byte(state[14]);
    let s15 = sub_byte(state[15]);

    state[ 0] = s0  ^ (((rk[0] >> 24) & 0xFF) as Byte);
    state[ 1] = s5  ^ (((rk[0] >> 16) & 0xFF) as Byte);
    state[ 2] = s10 ^ (((rk[0] >>  8) & 0xFF) as Byte);
    state[ 3] = s15 ^ ((rk[0] & 0xFF) as Byte);

    state[ 4] = s4  ^ (((rk[1] >> 24) & 0xFF) as Byte);
    state[ 5] = s9  ^ (((rk[1] >> 16) & 0xFF) as Byte);
    state[ 6] = s14 ^ (((rk[1] >>  8) & 0xFF) as Byte);
    state[ 7] = s3  ^ ((rk[1] & 0xFF) as Byte);

    state[ 8] = s8  ^ (((rk[2] >> 24) & 0xFF) as Byte);
    state[ 9] = s13 ^ (((rk[2] >> 16) & 0xFF) as Byte);
    state[10] = s2  ^ (((rk[2] >>  8) & 0xFF) as Byte);
    state[11] = s7  ^ ((rk[2] & 0xFF) as Byte);

    state[12] = s12 ^ (((rk[3] >> 24) & 0xFF) as Byte);
    state[13] = s1  ^ (((rk[3] >> 16) & 0xFF) as Byte);
    state[14] = s6  ^ (((rk[3] >>  8) & 0xFF) as Byte);
    state[15] = s11 ^ ((rk[3] & 0xFF) as Byte);
}

/// Initial AddRoundKey — XOR the state with the first round key.
@inline
fn add_round_key(state: &mut [Byte; 16], rk: &[UInt32; 4]) {
    state[ 0] = state[ 0] ^ (((rk[0] >> 24) & 0xFF) as Byte);
    state[ 1] = state[ 1] ^ (((rk[0] >> 16) & 0xFF) as Byte);
    state[ 2] = state[ 2] ^ (((rk[0] >>  8) & 0xFF) as Byte);
    state[ 3] = state[ 3] ^ ((rk[0] & 0xFF) as Byte);
    state[ 4] = state[ 4] ^ (((rk[1] >> 24) & 0xFF) as Byte);
    state[ 5] = state[ 5] ^ (((rk[1] >> 16) & 0xFF) as Byte);
    state[ 6] = state[ 6] ^ (((rk[1] >>  8) & 0xFF) as Byte);
    state[ 7] = state[ 7] ^ ((rk[1] & 0xFF) as Byte);
    state[ 8] = state[ 8] ^ (((rk[2] >> 24) & 0xFF) as Byte);
    state[ 9] = state[ 9] ^ (((rk[2] >> 16) & 0xFF) as Byte);
    state[10] = state[10] ^ (((rk[2] >>  8) & 0xFF) as Byte);
    state[11] = state[11] ^ ((rk[2] & 0xFF) as Byte);
    state[12] = state[12] ^ (((rk[3] >> 24) & 0xFF) as Byte);
    state[13] = state[13] ^ (((rk[3] >> 16) & 0xFF) as Byte);
    state[14] = state[14] ^ (((rk[3] >>  8) & 0xFF) as Byte);
    state[15] = state[15] ^ ((rk[3] & 0xFF) as Byte);
}

// =============================================================================
// Public block encrypt — AES-128 + AES-256
// =============================================================================

/// Single-block AES-128 encrypt. In-place on `block`.
///
/// `@cfg(feature = "crypto-accel")` substitutes this with `aesenc`
/// (AES-NI) / `aese`+`aesmc` (ARMv8) — the reference here remains
/// the canonical FIPS 197 golden source for differential testing.
public fn aes128_encrypt_block(rk: &RoundKeys128, block: &mut [Byte; 16]) {
    let mut r0: [UInt32; 4] = [rk.w[0], rk.w[1], rk.w[2], rk.w[3]];
    add_round_key(block, &r0);
    let mut round = 1;
    while round < AES128_NR {
        let rki: [UInt32; 4] = [
            rk.w[round * 4 + 0], rk.w[round * 4 + 1],
            rk.w[round * 4 + 2], rk.w[round * 4 + 3],
        ];
        sub_shift_mix_round(block, &rki);
        round = round + 1;
    }
    let last: [UInt32; 4] = [
        rk.w[AES128_NR * 4 + 0], rk.w[AES128_NR * 4 + 1],
        rk.w[AES128_NR * 4 + 2], rk.w[AES128_NR * 4 + 3],
    ];
    sub_shift_final(block, &last);
}

/// Single-block AES-256 encrypt.
public fn aes256_encrypt_block(rk: &RoundKeys256, block: &mut [Byte; 16]) {
    let r0: [UInt32; 4] = [rk.w[0], rk.w[1], rk.w[2], rk.w[3]];
    add_round_key(block, &r0);
    let mut round = 1;
    while round < AES256_NR {
        let rki: [UInt32; 4] = [
            rk.w[round * 4 + 0], rk.w[round * 4 + 1],
            rk.w[round * 4 + 2], rk.w[round * 4 + 3],
        ];
        sub_shift_mix_round(block, &rki);
        round = round + 1;
    }
    let last: [UInt32; 4] = [
        rk.w[AES256_NR * 4 + 0], rk.w[AES256_NR * 4 + 1],
        rk.w[AES256_NR * 4 + 2], rk.w[AES256_NR * 4 + 3],
    ];
    sub_shift_final(block, &last);
}
