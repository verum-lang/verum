// =============================================================================
// security/cipher/chacha20.vr — ChaCha20 stream cipher (RFC 8439)
// =============================================================================
// Layer: 2 (core primitive)
// Dependencies: core
// Reference: RFC 8439 (replaces RFC 7539) — ChaCha20 and Poly1305 for
//            IETF Protocols
//            DJ Bernstein — "ChaCha, a variant of Salsa20" (2008)
// =============================================================================
//
// ChaCha20 block function + counter-mode keystream generator. This
// module provides:
//
//   * `chacha20_block(key, counter, nonce) -> [Byte; 64]` — the raw
//     block function; produces one 64-byte keystream block.
//
//   * `chacha20_xor(key, counter, nonce, data, out)` — stream-encrypt
//     (or decrypt, identical operation since XOR is self-inverse) any
//     length of data starting at the given counter.
//
// ChaCha20 is the "Plan B" AEAD for TLS 1.3 / QUIC on hosts without
// AES hardware acceleration (embedded, mobile SoCs, attacker-free
// analyser setups). It is also the primitive Google uses in its QUIC
// deployment where AES-NI isn't universally available.
//
// # Constant-time by construction
//
// The ChaCha20 round function uses only addition, XOR, and rotation
// on 32-bit words — no table lookups, no data-dependent branches.
// Unlike AES, the software reference is naturally constant-time.
//
// # Parameters (RFC 8439 §2.3)
//
//   * Key:     256 bits = 32 bytes.
//   * Nonce:   96 bits  = 12 bytes (IETF variant; original Bernstein
//                         ChaCha20 used 64-bit nonce).
//   * Counter: 32 bits  — caller-supplied. Poly1305 key derivation
//                         uses counter=0; encryption starts at
//                         counter=1.
//   * Block:   512 bits = 64 bytes.
//
// # Performance
//
// Reference ~250-400 MiB/s on modern x86_64 with `@inline` rounds.
// `@cfg(feature = "crypto-accel")` substitutes the inner loop with
// AVX2 / AVX-512 vectorised variants — the quarter-round naturally
// parallelises across four columns. Typical accelerated throughput:
// 3-6 GiB/s.
//
// =============================================================================

module core.security.cipher.chacha20;
mount core.*;

// =============================================================================
// Sizes
// =============================================================================

public const KEY_SIZE: Int = 32;
public const NONCE_SIZE: Int = 12;
public const BLOCK_SIZE: Int = 64;

public type ChaChaKey is [Byte; 32];
public type ChaChaNonce is [Byte; 12];

// =============================================================================
// Constants — "expand 32-byte k" in little-endian u32 form
// =============================================================================

const SIGMA: [UInt32; 4] = [
    0x61707865, 0x3320646E, 0x79622D32, 0x6B206574,
];

// =============================================================================
// Quarter round — RFC 8439 §2.1
// =============================================================================

@inline
fn quarter_round(s: &mut [UInt32; 16], a: Int, b: Int, c: Int, d: Int) {
    s[a] = s[a].wrapping_add(s[b]); s[d] = (s[d] ^ s[a]).rotate_left(16);
    s[c] = s[c].wrapping_add(s[d]); s[b] = (s[b] ^ s[c]).rotate_left(12);
    s[a] = s[a].wrapping_add(s[b]); s[d] = (s[d] ^ s[a]).rotate_left(8);
    s[c] = s[c].wrapping_add(s[d]); s[b] = (s[b] ^ s[c]).rotate_left(7);
}

// =============================================================================
// Block function — RFC 8439 §2.3.1
// =============================================================================

/// Produce one 64-byte ChaCha20 keystream block for the given
/// `(key, counter, nonce)` tuple.
///
/// The state is a 4×4 matrix of u32:
///   cccc cccc cccc cccc   — constants "expand 32-byte k"
///   kkkk kkkk kkkk kkkk   — 256-bit key (little-endian words 0..8)
///   cccc nnnn nnnn nnnn   — 32-bit counter + 96-bit nonce
public fn chacha20_block(
    key: &ChaChaKey,
    counter: UInt32,
    nonce: &ChaChaNonce,
) -> [Byte; 64] {
    // Build initial state.
    let mut state: [UInt32; 16] = [0; 16];
    state[0] = SIGMA[0]; state[1] = SIGMA[1];
    state[2] = SIGMA[2]; state[3] = SIGMA[3];

    let mut i = 0;
    while i < 8 {
        state[4 + i] =
              (key[i * 4 + 0] as UInt32)
            | ((key[i * 4 + 1] as UInt32) <<  8)
            | ((key[i * 4 + 2] as UInt32) << 16)
            | ((key[i * 4 + 3] as UInt32) << 24);
        i = i + 1;
    }

    state[12] = counter;
    state[13] =
          (nonce[0] as UInt32)
        | ((nonce[1] as UInt32) <<  8)
        | ((nonce[2] as UInt32) << 16)
        | ((nonce[3] as UInt32) << 24);
    state[14] =
          (nonce[4] as UInt32)
        | ((nonce[5] as UInt32) <<  8)
        | ((nonce[6] as UInt32) << 16)
        | ((nonce[7] as UInt32) << 24);
    state[15] =
          (nonce[ 8] as UInt32)
        | ((nonce[ 9] as UInt32) <<  8)
        | ((nonce[10] as UInt32) << 16)
        | ((nonce[11] as UInt32) << 24);

    // Working copy — 10 double-rounds = 20 rounds.
    let mut w: [UInt32; 16] = [0; 16];
    let mut k = 0;
    while k < 16 { w[k] = state[k]; k = k + 1; }

    let mut round = 0;
    while round < 10 {
        // Column rounds
        quarter_round(&mut w, 0, 4,  8, 12);
        quarter_round(&mut w, 1, 5,  9, 13);
        quarter_round(&mut w, 2, 6, 10, 14);
        quarter_round(&mut w, 3, 7, 11, 15);
        // Diagonal rounds
        quarter_round(&mut w, 0, 5, 10, 15);
        quarter_round(&mut w, 1, 6, 11, 12);
        quarter_round(&mut w, 2, 7,  8, 13);
        quarter_round(&mut w, 3, 4,  9, 14);
        round = round + 1;
    }

    // Feed-forward: out = w + state (wrapping add per word), serialized
    // little-endian.
    let mut out: [Byte; 64] = [0; 64];
    let mut j = 0;
    while j < 16 {
        let v = w[j].wrapping_add(state[j]);
        let base = j * 4;
        out[base + 0] = (v & 0xFF) as Byte;
        out[base + 1] = ((v >> 8)  & 0xFF) as Byte;
        out[base + 2] = ((v >> 16) & 0xFF) as Byte;
        out[base + 3] = ((v >> 24) & 0xFF) as Byte;
        j = j + 1;
    }
    out
}

// =============================================================================
// Stream XOR — encrypt/decrypt any length
// =============================================================================

/// Encrypt or decrypt `data` by XORing with the ChaCha20 keystream
/// starting at the given 32-bit counter. `out` is appended to — caller
/// can pre-reserve capacity.
///
/// Encrypt and decrypt are the same operation (XOR is self-inverse).
public fn chacha20_xor(
    key: &ChaChaKey,
    initial_counter: UInt32,
    nonce: &ChaChaNonce,
    data: &[Byte],
    out: &mut List<Byte>,
) {
    let n = data.len();
    let mut off: Int = 0;
    let mut ctr = initial_counter;

    while off < n {
        let ks = chacha20_block(key, ctr, nonce);
        let chunk = if n - off < BLOCK_SIZE { n - off } else { BLOCK_SIZE };
        let mut i = 0;
        while i < chunk {
            out.push(data[off + i] ^ ks[i]);
            i = i + 1;
        }
        off = off + chunk;
        // Counter increment. Per RFC 8439 §2.3, counter is 32-bit;
        // wraparound is a protocol error but not handled here —
        // caller (typically TLS/QUIC) enforces the 2^32 × 64-byte
        // max plaintext per nonce.
        ctr = ctr.wrapping_add(1);
    }
}
