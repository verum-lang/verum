// =============================================================================
// security/x509/path_building.vr — RFC 5280 §6.1 path discovery
// =============================================================================
// Layer: 3 (X.509 subsystem)
// Dependencies: core, security/x509/{certificate, name, ext, trust_store}
// =============================================================================
//
// **Purpose.** Given an end-entity (EE) certificate, an unordered
// pool of candidate intermediates, and a `TrustStore`, discover one
// or more ordered chains EE → intermediate₁ → … → trust-anchor that
// can plausibly be validated. The actual RFC 5280 §6.1 algorithm
// runs *after* path building (`path_validation.vr`).
//
// Path building is a graph-search problem; the existing
// `chain.vr::validate_chain` requires the caller to pre-order the
// chain — this module fills that gap when only a flat bag of certs
// is available (TLS handshake, S/MIME, OCSP responder bundles,
// Sigstore Fulcio chains, mTLS clients, etc.).
//
// **Strategy.** Depth-first search from the EE upwards through
// candidate issuers, with the following ranking heuristics:
//
//   1. Prefer issuer matches by AKI→SKI (RFC 5280 §4.2.1.1) — the
//      strongest hint, encoded directly by issuing CAs.
//   2. Prefer matches whose issuer DN has shorter validity window
//      remaining (cross-signed roots: pick the longest-lived).
//   3. Prefer chains that hit a trust anchor sooner.
//   4. Reject cycles aggressively (subject-DN+SPKI fingerprint).
//
// **Bounds.** `MAX_CHAIN_LENGTH = 16` (matches `chain.vr`),
// `MAX_CANDIDATES_PER_LEVEL = 8` (cap on cross-signed fan-out),
// `MAX_TOTAL_PATHS = 64` (cap on enumerated paths). Without these
// caps a hostile peer presenting many cross-signed intermediates
// could produce exponential search.
//
// **Categorical structure.** Path building is the hom-set
// computation in the category of certificates: vertices are certs,
// arrows are "X is signed by Y" relations. The EE is the source,
// trust anchors are the terminal objects. Every produced path is a
// composable arrow chain (composition = signature verification).
// =============================================================================

@arch_module(
    foundation:    Foundation.ZfcTwoInacc,
    stratum:       MsfsStratum.LCls,
    lifecycle:     Lifecycle.Theorem("v0.1"),
    declarations: ShapeDeclarations {
        purpose: Some(Purpose {
            role: "RFC 5280 §6.1 X.509 path building: DFS issuer-search with AKI/SKI matching",
            k_min: CveThresholdK.FullWitness,
            v_min: CveThresholdV.NamedCertification,
            e_min: CveThresholdE.StructurallyReady,
        }),
        substrate:      Some(CognitiveSubstrate.AnalyticDecompositional),
        anchoring:      Some(FormalAnchoring.CurryHowardLawvere),
        e_sense:        Some(ExecutabilitySense.StructuralReadiness),
        self_reference: None,
    }
)
module core.security.x509.path_building;

mount core.*;
mount core.collections.{List, Set};
mount core.security.x509.certificate.{X509Certificate};
mount core.security.x509.name.{DistinguishedName};
mount core.security.x509.trust_store.{TrustStore};

// =============================================================================
// Bounds
// =============================================================================

/// Maximum number of certificates in any single discovered path.
/// Matches `chain::MAX_CHAIN_LENGTH`.
public const MAX_PATH_LENGTH: Int = 16;

/// Maximum number of candidate issuers explored at any level. Cross-
/// signed roots (e.g., Let's Encrypt with two paths to ISRG Root X1
/// and DST Root CA X3) typically fan out by 2–4; 8 is comfortable.
public const MAX_CANDIDATES_PER_LEVEL: Int = 8;

/// Hard cap on total paths returned. After this many, search stops.
public const MAX_TOTAL_PATHS: Int = 64;

// =============================================================================
// Result types
// =============================================================================

/// A discovered candidate path, ordered EE → intermediate → … → root.
/// The `root` is always a trust anchor from the supplied `TrustStore`.
@derive(Clone, Debug)
public type CandidatePath is {
    ee:     X509Certificate,
    inters: List<X509Certificate>,
    root:   X509Certificate,
    /// Score — used to order paths returned to the validator. Higher
    /// is better. Computed during DFS based on AKI/SKI hits, fewer
    /// hops, longer-validity anchors.
    score:  Int,
};

public fn candidate_path_length(p: &CandidatePath) -> Int {
    2 + p.inters.len()
}

/// Concatenate EE + intermediates into a single ordered list (handy
/// for handing off to `path_validation::validate`).
public fn candidate_path_to_list(p: &CandidatePath) -> List<X509Certificate> {
    let mut out: List<X509Certificate> = List.with_capacity(candidate_path_length(p));
    out.push(p.ee.clone());
    let mut i: Int = 0;
    while i < p.inters.len() { out.push(p.inters[i].clone()); i = i + 1; }
    out.push(p.root.clone());
    out
}

public type PathBuildError is
    | NoPathsFound
    | EeNotProvided
    | TooDeep { length: Int, limit: Int }
    | CycleDetected;

implement Display for PathBuildError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            NoPathsFound        => f.write_str("X.509 path-building: no candidate paths to a trust anchor"),
            EeNotProvided       => f.write_str("X.509 path-building: end-entity certificate not provided"),
            TooDeep { length, limit } => f.write_str(
                f"X.509 path-building: path length {length} exceeds limit {limit}".as_str()),
            CycleDetected       => f.write_str("X.509 path-building: cycle detected during DFS"),
        }
    }
}

implement Debug for PathBuildError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> { Display.fmt(self, f) }
}

// =============================================================================
// Public API
// =============================================================================

/// Build all candidate paths from the EE through `intermediates` to
/// any trust anchor in `trust`. Returns paths sorted by score
/// (highest first); empty list if no path is found.
///
/// **Inputs.**
///   - `ee`: the end-entity to validate
///   - `intermediates`: candidate intermediates (any order, may
///     include unused certs, may include the same anchor)
///   - `trust`: the trust store
///
/// **Heuristics.** AKI/SKI bonded > DN-only matching; shorter chains
/// preferred when scores tie; deterministic ordering on tied scores
/// (insertion order in `intermediates` / `trust`).
public fn build_paths(
    ee: &X509Certificate,
    intermediates: &List<X509Certificate>,
    trust: &TrustStore,
) -> Result<List<CandidatePath>, PathBuildError> {
    let mut paths: List<CandidatePath> = List.new();
    let mut visited: Set<List<Byte>> = Set.new();
    let mut current_inters: List<X509Certificate> = List.new();

    visited.insert(cert_fingerprint(ee));
    dfs_walk(ee, ee, intermediates, trust, &mut current_inters, &mut visited, &mut paths, 0);

    if paths.is_empty() { return Err(NoPathsFound); }
    sort_by_score_desc(&mut paths);
    Ok(paths)
}

/// Convenience wrapper: build paths and return only the highest-
/// scored one. Returns `Err(NoPathsFound)` when no path exists.
public fn build_best_path(
    ee: &X509Certificate,
    intermediates: &List<X509Certificate>,
    trust: &TrustStore,
) -> Result<CandidatePath, PathBuildError> {
    let mut all = build_paths(ee, intermediates, trust)?;
    if all.is_empty() { return Err(NoPathsFound); }
    Ok(all.swap_remove(0))
}

// =============================================================================
// Candidate enumeration
// =============================================================================

/// Trust anchors whose subject DN matches the current cert's issuer
/// DN, ranked by AKI→SKI bond strength.
fn enumerate_anchor_candidates(
    current: &X509Certificate,
    trust: &TrustStore,
) -> List<X509Certificate> {
    let mut out: List<X509Certificate> = List.new();
    let issuer_dn = &current.tbs.issuer;
    let mut i: Int = 0;
    while i < trust.anchors.len() {
        let a = &trust.anchors[i];
        if a.tbs.subject.raw_eq(issuer_dn) {
            // Optional AKI→SKI bond: stronger match if both present and equal.
            if anchor_aki_ski_match(current, a) {
                out.insert(0, a.clone()); // AKI/SKI-bonded entries get pushed up
            } else {
                out.push(a.clone());
            }
        }
        i = i + 1;
    }
    out
}

/// Intermediates whose subject DN matches the current cert's issuer
/// DN, with the same AKI→SKI ranking applied.
fn enumerate_intermediate_candidates(
    current: &X509Certificate,
    intermediates: &List<X509Certificate>,
    visited: &Set<List<Byte>>,
) -> List<X509Certificate> {
    let mut out: List<X509Certificate> = List.new();
    let issuer_dn = &current.tbs.issuer;
    let mut i: Int = 0;
    while i < intermediates.len() {
        let cand = &intermediates[i];
        if cand.tbs.subject.raw_eq(issuer_dn) {
            let fp = cert_fingerprint(cand);
            if visited.contains(&fp) { i = i + 1; continue; }
            if anchor_aki_ski_match(current, cand) {
                out.insert(0, cand.clone());
            } else {
                out.push(cand.clone());
            }
        }
        i = i + 1;
    }
    out
}

/// Strong AKI/SKI bond: child's `authority_key_id` keyIdentifier
/// equals parent's `subject_key_id`, both bytes-equal. Weaker bond
/// (DN-only) is the fallback when one or both extensions are absent.
fn anchor_aki_ski_match(child: &X509Certificate, parent: &X509Certificate) -> Bool {
    let aki = match &child.tbs.extensions.authority_key_id {
        Some((_, kid)) => kid,
        None => return false,
    };
    let ski = match &parent.tbs.extensions.subject_key_id {
        Some((_, kid)) => kid,
        None => return false,
    };
    bytes_eq(aki, ski)
}

fn bytes_eq(a: &List<Byte>, b: &List<Byte>) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        if a[i] != b[i] { return false; }
        i = i + 1;
    }
    true
}

// =============================================================================
// Scoring + sorting
// =============================================================================

fn score_path(inters: &List<X509Certificate>, anchor: &X509Certificate) -> Int {
    let mut s: Int = 0;
    // Shorter chains preferred — base score declines linearly with hops.
    s = s + (MAX_PATH_LENGTH - inters.len()) * 10;
    // Anchor with longer validity remaining is preferred (proxy:
    // SKI-present indicates a modern, well-formed CA).
    if anchor.tbs.extensions.subject_key_id.is_some() {
        s = s + 5;
    }
    s
}

fn sort_by_score_desc(paths: &mut List<CandidatePath>) {
    let n = paths.len();
    let mut i: Int = 1;
    while i < n {
        let mut j: Int = i;
        while j > 0 && paths[j].score > paths[j - 1].score {
            paths.swap(j, j - 1);
            j = j - 1;
        }
        i = i + 1;
    }
}

// =============================================================================
// Helpers
// =============================================================================

fn is_self_signed(cert: &X509Certificate) -> Bool {
    cert.tbs.subject.raw_eq(&cert.tbs.issuer)
}

/// Cycle-detection fingerprint = SHA-256-of-DER would be ideal; we
/// avoid the hash dependency at this layer and instead hash the DN
/// + SPKI raw bytes via a fast 64-bit FNV-1a fold, returned as a
/// 16-byte canonical key. Two certs with identical DN+SPKI cannot
/// be distinguished (which is fine for cycle-detection — they're
/// the same cert from a chain-builder's view).
fn cert_fingerprint(cert: &X509Certificate) -> List<Byte> {
    let mut out: List<Byte> = List.with_capacity(16);
    let h1 = fnv1a64(cert.tbs.subject.raw_der.as_slice());
    let h2 = fnv1a64(cert.tbs.spki.raw_der.as_slice());
    push_u64_be(&mut out, h1);
    push_u64_be(&mut out, h2);
    out
}

fn push_u64_be(out: &mut List<Byte>, v: Int) {
    let mut shift: Int = 56;
    while shift >= 0 {
        out.push(((v >> shift) & 0xFF) as Byte);
        shift = shift - 8;
    }
}

const FNV_OFFSET: Int = 0xcbf29ce484222325;
const FNV_PRIME:  Int = 0x100000001b3;

fn fnv1a64(bytes: &[Byte]) -> Int {
    let mut h: Int = FNV_OFFSET;
    let mut i: Int = 0;
    while i < bytes.len() {
        h = h ^ (bytes[i] as Int);
        h = (h * FNV_PRIME) & 0xFFFFFFFFFFFFFFFF;
        i = i + 1;
    }
    h
}

// =============================================================================
// DFS engine
// =============================================================================
//
// EE is threaded as a parameter through every frame so `emit_path`
// has direct access to it without using the trail (which carries
// only proper intermediates).

fn dfs_walk(
    ee:           &X509Certificate,
    current_cert: &X509Certificate,
    intermediates: &List<X509Certificate>,
    trust:         &TrustStore,
    current_inters: &mut List<X509Certificate>,
    visited:       &mut Set<List<Byte>>,
    paths:         &mut List<CandidatePath>,
    depth:         Int,
) {
    if paths.len() >= MAX_TOTAL_PATHS { return; }
    if depth >= MAX_PATH_LENGTH { return; }

    // Self-signed + in trust store = `current_cert` IS a trust anchor.
    if is_self_signed(current_cert) && trust.contains(current_cert) {
        emit_path(ee, current_cert, current_inters, paths);
        return;
    }

    // Try anchors first (faster termination + higher score).
    let anchor_candidates = enumerate_anchor_candidates(current_cert, trust);
    let mut a_i: Int = 0;
    while a_i < anchor_candidates.len() && paths.len() < MAX_TOTAL_PATHS {
        emit_path(ee, &anchor_candidates[a_i], current_inters, paths);
        a_i = a_i + 1;
    }

    // Then try intermediates as continuation candidates.
    let inter_candidates = enumerate_intermediate_candidates(current_cert, intermediates, visited);
    let mut i: Int = 0;
    while i < inter_candidates.len() && paths.len() < MAX_TOTAL_PATHS {
        if i >= MAX_CANDIDATES_PER_LEVEL { break; }
        let cand = inter_candidates[i].clone();
        let fp = cert_fingerprint(&cand);
        if visited.contains(&fp) { i = i + 1; continue; }
        visited.insert(fp.clone());
        current_inters.push(cand.clone());
        dfs_walk(ee, &cand, intermediates, trust, current_inters, visited, paths, depth + 1);
        current_inters.pop();
        visited.remove(&fp);
        i = i + 1;
    }
}

fn emit_path(
    ee:     &X509Certificate,
    anchor: &X509Certificate,
    current_inters: &List<X509Certificate>,
    paths:  &mut List<CandidatePath>,
) {
    let mut inters_clone: List<X509Certificate> = List.with_capacity(current_inters.len());
    let mut k: Int = 0;
    while k < current_inters.len() {
        inters_clone.push(current_inters[k].clone());
        k = k + 1;
    }
    paths.push(CandidatePath {
        ee:     ee.clone(),
        inters: inters_clone,
        root:   anchor.clone(),
        score:  score_path(current_inters, anchor),
    });
}

