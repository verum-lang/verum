// =============================================================================
// security/x509/path_validation.vr — RFC 5280 §6.1 Algorithm
// =============================================================================
// Layer: 3 (X.509 subsystem)
// Dependencies: core, security/x509/{certificate, name, ext, time, spki,
//               algorithm, chain, trust_store, oid}
// =============================================================================
//
// **Purpose.** Implement RFC 5280 §6.1 "Basic Path Validation"
// algorithm precisely. The existing `chain.vr::validate_chain` does
// the practical TLS subset; this module implements the by-the-book
// algorithm with state machine, policy tree, full name constraints,
// and critical-extension recognition. Used when the caller needs
// strict policy compliance — code signing, supply-chain SLSA
// attestation verification, EV-cert validation.
//
// **Algorithm overview (RFC 5280 §6.1).**
//
//   1. Initialize state for a chain of length n:
//        * valid_policy_tree = single-node root with anyPolicy
//        * permitted_subtrees = unconstrained (any name)
//        * excluded_subtrees  = empty
//        * explicit_policy    = n + 1 (initial-explicit-policy ? 0 : n+1)
//        * inhibit_anyPolicy  = n + 1 (initial-any-policy-inhibit ? 0 : n+1)
//        * policy_mapping     = n + 1 (initial-policy-mapping-inhibit ? 0 : n+1)
//        * working_public_key = trust anchor's SPKI
//        * working_issuer_name = trust anchor's subject
//        * max_path_length    = n
//
//   2. For each certificate i ∈ [1, n]:
//        a. Basic processing (§6.1.3):
//             (a)(1) signature on cert verifies under working_public_key
//             (a)(2) cert is valid at the current time
//             (a)(3) cert is not revoked   ← delegated to revocation
//             (a)(4) cert.issuer == working_issuer_name
//             (b)    if cert is not self-issued OR i = n:
//                      check subject DN ⊆ permitted_subtrees
//                      check subject DN ⊄ excluded_subtrees
//                      check every SAN ⊆ permitted_subtrees
//                      check every SAN ⊄ excluded_subtrees
//             (c)    process certificate policies
//             (d)    process policy mappings (if i ≠ n)
//             (e)    intersect with anyPolicy
//        b. Preparation for next cert (§6.1.4):  [skipped if i = n]
//             working_issuer_name = cert.subject
//             working_public_key  = cert.SPKI
//             union name constraints into permitted/excluded subtrees
//             decrement explicit_policy / inhibit_anyPolicy /
//             policy_mapping if cert lacks the inhibit-counters
//             check basic constraints: cA must be TRUE, decrement
//             max_path_length, check it's still ≥ 0
//             check keyUsage.keyCertSign
//             check critical extensions are recognised
//        c. After last cert (§6.1.5):
//             explicit_policy decrement (post-final)
//             valid_policy_tree must be non-empty if explicit_policy > 0
//             return user-acceptable policy set
//
// **Output.** On success, a `ValidatedPath` carrying the final state
// (working_public_key, valid_policy_tree, accepted policy set) so
// callers can extract policy info without re-running the algorithm.
//
// **Categorical structure.** Path validation is a fold over the
// chain category: each cert is an arrow whose composition with the
// running state produces the next state. The validator is total —
// every chain produces either a `ValidatedPath` or a `PathError`
// with the cert index where validation diverged.
// =============================================================================

@arch_module(
    foundation:    Foundation.ZfcTwoInacc,
    stratum:       MsfsStratum.LCls,
    lifecycle:     Lifecycle.Theorem("v0.1"),
    declarations: ShapeDeclarations {
        purpose: Some(Purpose {
            role: "RFC 5280 §6.1 by-the-book X.509 path validation: state machine + policy tree + full name constraints",
            k_min: CveThresholdK.FullWitness,
            v_min: CveThresholdV.NamedCertification,
            e_min: CveThresholdE.StructurallyReady,
        }),
        substrate:      Some(CognitiveSubstrate.AnalyticDecompositional),
        anchoring:      Some(FormalAnchoring.CurryHowardLawvere),
        e_sense:        Some(ExecutabilitySense.StructuralReadiness),
        self_reference: None,
    },
)
module core.security.x509.path_validation;

mount core.*;
mount core.collections.{List, Set};
mount core.security.x509.certificate.{X509Certificate};
mount core.security.x509.name.{DistinguishedName};
mount core.security.x509.spki.{Spki};
mount core.security.x509.time.{is_valid_at};
mount core.security.x509.ext.{ExtensionSet};
mount core.security.x509.ext.subject_alt_name.{GeneralName};
mount core.security.x509.ext.name_constraints.{NameConstraints, GeneralSubtree};
mount core.security.x509.ext.basic_constraints.{BasicConstraints};
mount core.security.x509.ext.key_usage.{KeyUsage};
mount core.security.x509.ext.ext_key_usage.{ExtKeyUsage};
mount core.security.x509.oid.{Oid};
mount core.security.x509.chain.{ChainError, verify_signature};
mount core.security.x509.trust_store.{TrustStore};

// =============================================================================
// Inputs / configuration
// =============================================================================

@derive(Clone, Debug)
public type PolicySet is
    /// User-required policies — the validator must produce at least
    /// one of these in the final accepted policy set.
    | Required(Set<Oid>)
    /// Any policy is acceptable.
    | AnyPolicy;

@derive(Clone, Debug)
public type PathValidationInput is {
    /// `chain[0]` = end-entity, `chain[n-1]` = trust anchor.
    /// Anchor MUST be present in the chain (path-builder includes it).
    chain:                       List<X509Certificate>,
    /// Validation time (Unix epoch seconds).
    now_secs:                    Int,
    /// User-required policies (per RFC 5280 §6.1.1).
    user_initial_policy_set:     PolicySet,
    /// `initial-explicit-policy` flag — if true, the path must be
    /// valid under the user_initial_policy_set throughout.
    initial_explicit_policy:     Bool,
    /// `initial-any-policy-inhibit` flag.
    initial_any_policy_inhibit:  Bool,
    /// `initial-policy-mapping-inhibit` flag.
    initial_policy_mapping_inhibit: Bool,
};

public fn input_default(chain: List<X509Certificate>, now_secs: Int) -> PathValidationInput {
    PathValidationInput {
        chain,
        now_secs,
        user_initial_policy_set: PolicySet.AnyPolicy,
        initial_explicit_policy: false,
        initial_any_policy_inhibit: false,
        initial_policy_mapping_inhibit: false,
    }
}

// =============================================================================
// Outputs
// =============================================================================

@derive(Clone, Debug)
public type ValidatedPath is {
    /// EE certificate (chain[0]).
    ee:                X509Certificate,
    /// Trust anchor (chain[n-1]).
    anchor:            X509Certificate,
    /// All certificates between EE and anchor, anchor-relative order.
    intermediates:     List<X509Certificate>,
    /// Policy OIDs accepted at the EE (intersection of user-required
    /// policies with the path's authoritative policies).
    accepted_policies: Set<Oid>,
};

public type PathError is
    | EmptyChain
    | TooLong { length: Int, limit: Int }
    | SignatureFailed { index: Int }
    | NotYetValid { index: Int }
    | Expired { index: Int }
    | IssuerMismatch { index: Int }
    | NotCa { index: Int }
    | NoKeyCertSign { index: Int }
    | MaxPathLengthExceeded { index: Int }
    | UnrecognisedCriticalExtension { index: Int, oid_text: Text }
    | NameConstraintNotPermitted { index: Int, name_kind: Text, name: Text }
    | NameConstraintExcluded { index: Int, name_kind: Text, name: Text }
    | PolicyTreeEmpty
    | RequiredPolicyNotMet
    | UnsupportedAlgorithm { index: Int };

implement Display for PathError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            EmptyChain                          => f.write_str("path-validation: empty chain"),
            TooLong { length, limit }           => f.write_str(f"path-validation: chain length {length} exceeds limit {limit}".as_str()),
            SignatureFailed { index }           => f.write_str(f"path-validation: signature failed at cert {index}".as_str()),
            NotYetValid { index }               => f.write_str(f"path-validation: cert {index} not yet valid".as_str()),
            Expired { index }                   => f.write_str(f"path-validation: cert {index} expired".as_str()),
            IssuerMismatch { index }            => f.write_str(f"path-validation: issuer mismatch at cert {index}".as_str()),
            NotCa { index }                     => f.write_str(f"path-validation: cert {index} lacks cA=TRUE".as_str()),
            NoKeyCertSign { index }             => f.write_str(f"path-validation: cert {index} lacks keyCertSign".as_str()),
            MaxPathLengthExceeded { index }     => f.write_str(f"path-validation: max-path-length exceeded at cert {index}".as_str()),
            UnrecognisedCriticalExtension { index, oid_text }
                                                => f.write_str(f"path-validation: cert {index} has unrecognised critical extension {oid_text}".as_str()),
            NameConstraintNotPermitted { index, name_kind, name }
                                                => f.write_str(f"path-validation: cert {index} {name_kind} '{name}' not in permitted subtrees".as_str()),
            NameConstraintExcluded { index, name_kind, name }
                                                => f.write_str(f"path-validation: cert {index} {name_kind} '{name}' in excluded subtree".as_str()),
            PolicyTreeEmpty                     => f.write_str("path-validation: policy tree empty under explicit-policy"),
            RequiredPolicyNotMet                => f.write_str("path-validation: user-required policy not satisfied"),
            UnsupportedAlgorithm { index }      => f.write_str(f"path-validation: unsupported signature algorithm at cert {index}".as_str()),
        }
    }
}

implement Debug for PathError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> { Display.fmt(self, f) }
}

// =============================================================================
// Internal state
// =============================================================================

const MAX_CHAIN_LENGTH: Int = 16;

/// Working state at one step of the algorithm.
type ValidationState is {
    /// Verification key currently to be used for the NEXT cert's signature.
    working_public_key: Spki,
    /// Issuer DN currently expected as next cert's `issuer` field.
    working_issuer_name: DistinguishedName,
    /// Counter that decrements at each non-anchor step; if a
    /// non-self-issued cert lacks PolicyConstraints with require-
    /// explicit-policy, this counter floors to 0 before final check.
    explicit_policy: Int,
    /// Counter for inhibitAnyPolicy.
    inhibit_any_policy: Int,
    /// Counter for inhibitPolicyMapping.
    policy_mapping_inhibit: Int,
    /// Remaining permitted CA path length.
    max_path_length: Int,
    /// Permitted name subtrees (one List per name kind for fast lookup).
    permitted_subtrees: NameConstraintsState,
    /// Excluded name subtrees.
    excluded_subtrees: NameConstraintsState,
    /// Valid-policy tree — list of policy nodes per depth.
    valid_policy_tree: List<List<PolicyTreeNode>>,
};

@derive(Clone, Debug)
type NameConstraintsState is {
    /// Empty list = no constraint (per kind, "any name accepted" for
    /// permitted; "no name excluded" for excluded). The semantics
    /// flip per use — `permitted` defaults to all names valid when
    /// empty (i.e., uninitialized = unconstrained); `excluded`
    /// defaults to empty (no exclusions).
    initialized:     Bool,
    dn_subtrees:     List<List<Byte>>,    // raw DN DER bytes (subtree prefix matching)
    dns_subtrees:    List<Text>,
    ip_subtrees:     List<IpSubtree>,
    email_subtrees:  List<Text>,
    uri_subtrees:    List<Text>,
};

@derive(Clone, Debug)
type IpSubtree is {
    /// 4 bytes for IPv4 (8-byte representation: 4 addr + 4 mask) or
    /// 16 bytes for IPv6 (32-byte representation). Encoded per
    /// RFC 5280 §4.2.1.10.
    addr: List<Byte>,
    mask: List<Byte>,
};

@derive(Clone, Debug)
type PolicyTreeNode is {
    valid_policy: Oid,
    qualifier_set: List<Byte>,
    expected_policy_set: Set<Oid>,
};

fn name_constraints_state_unconstrained() -> NameConstraintsState {
    NameConstraintsState {
        initialized:    false,
        dn_subtrees:    List.new(),
        dns_subtrees:   List.new(),
        ip_subtrees:    List.new(),
        email_subtrees: List.new(),
        uri_subtrees:   List.new(),
    }
}

fn name_constraints_state_empty() -> NameConstraintsState {
    let mut s = name_constraints_state_unconstrained();
    s.initialized = true;
    s
}

// =============================================================================
// Public entry
// =============================================================================

/// Validate a chain per RFC 5280 §6.1. Returns a `ValidatedPath` on
/// success; `PathError` carrying the cert index where validation
/// diverged.
public fn validate_path(input: &PathValidationInput) -> Result<ValidatedPath, PathError> {
    let chain = &input.chain;
    let n = chain.len();
    if n == 0 { return Err(EmptyChain); }
    if n > MAX_CHAIN_LENGTH { return Err(TooLong { length: n, limit: MAX_CHAIN_LENGTH }); }

    // The chain is provided EE-first, anchor-last. The algorithm
    // walks the OPPOSITE direction (anchor → EE), so reverse for
    // local indexing (the reversed index `i` matches the RFC's `i`
    // counting from 1 at the cert closest to the anchor).
    let anchor = &chain[n - 1];

    // Initialise state from the anchor.
    let mut state = init_state(anchor, n, input);

    // Walk certs from the one immediately below the anchor down to
    // the EE. RFC indexing uses 1..n with cert n being the EE.
    let mut i_rev: Int = n - 2; // chain[n-2] is the cert at depth 1 below anchor
    let mut cert_index_rfc: Int = 1;
    while i_rev >= 0 {
        let cert = &chain[i_rev];
        let is_last = (i_rev == 0);

        // §6.1.3 basic processing
        basic_processing(cert, &state, cert_index_rfc, is_last, input.now_secs)?;

        // §6.1.3(b) name-constraint check on subject + SAN
        check_name_constraints(cert, &state, cert_index_rfc, is_last)?;

        // §6.1.3(c)–(e) policy processing
        process_policies(cert, &mut state, cert_index_rfc);

        // §6.1.4 prepare for next cert  (skipped at last cert per §6.1.5)
        if !is_last {
            prepare_for_next(cert, &mut state, cert_index_rfc)?;
        }

        i_rev = i_rev - 1;
        cert_index_rfc = cert_index_rfc + 1;
    }

    // §6.1.5 wrap-up
    let accepted = wrap_up(&state, input)?;

    let mut intermediates: List<X509Certificate> = List.new();
    let mut k: Int = 1;
    while k < n - 1 { intermediates.push(chain[k].clone()); k = k + 1; }

    Ok(ValidatedPath {
        ee: chain[0].clone(),
        anchor: anchor.clone(),
        intermediates,
        accepted_policies: accepted,
    })
}

// =============================================================================
// State initialisation
// =============================================================================

fn init_state(
    anchor: &X509Certificate,
    n: Int,
    input: &PathValidationInput,
) -> ValidationState {
    // Initial permitted/excluded come from the anchor (treated as
    // "input parameters" per RFC). If the anchor declares its own
    // name constraints, those go in.
    let (permitted, excluded) = anchor_name_constraints(anchor);

    ValidationState {
        working_public_key: anchor.tbs.spki.clone(),
        working_issuer_name: anchor.tbs.subject.clone(),
        explicit_policy: if input.initial_explicit_policy { 0 } else { n + 1 },
        inhibit_any_policy: if input.initial_any_policy_inhibit { 0 } else { n + 1 },
        policy_mapping_inhibit: if input.initial_policy_mapping_inhibit { 0 } else { n + 1 },
        max_path_length: n,
        permitted_subtrees: permitted,
        excluded_subtrees: excluded,
        valid_policy_tree: init_policy_tree(),
    }
}

fn anchor_name_constraints(anchor: &X509Certificate) -> (NameConstraintsState, NameConstraintsState) {
    let mut perm = name_constraints_state_unconstrained();
    let mut excl = name_constraints_state_empty();
    if let Some((_, nc)) = &anchor.tbs.extensions.name_constraints {
        absorb_name_constraints(&mut perm, &mut excl, nc);
    }
    (perm, excl)
}

fn init_policy_tree() -> List<List<PolicyTreeNode>> {
    // Depth-0 root: anyPolicy with empty qualifier_set and
    // expected_policy_set = { anyPolicy }.
    let mut root_set: Set<Oid> = Set.new();
    root_set.insert(any_policy_oid());
    let mut depth0: List<PolicyTreeNode> = List.new();
    depth0.push(PolicyTreeNode {
        valid_policy:        any_policy_oid(),
        qualifier_set:       List.new(),
        expected_policy_set: root_set,
    });
    let mut tree: List<List<PolicyTreeNode>> = List.new();
    tree.push(depth0);
    tree
}

fn any_policy_oid() -> Oid {
    // 2.5.29.32.0 — id-ce-certificatePolicies anyPolicy.
    Oid.from(&[2, 5, 29, 32, 0])
}

// =============================================================================
// §6.1.3 — Basic processing
// =============================================================================

fn basic_processing(
    cert: &X509Certificate,
    state: &ValidationState,
    cert_index_rfc: Int,
    _is_last: Bool,
    now_secs: Int,
) -> Result<(), PathError> {
    let i = cert_index_rfc;
    // (a)(1) signature verifies
    let _ = chain_to_path_error_signature(verify_signature(cert, &state.working_public_key), i)?;
    // (a)(2) validity
    if !is_valid_at(&cert.tbs.validity, now_secs) {
        let nb = core.security.x509.time.time_to_unix(&cert.tbs.validity.not_before);
        if now_secs < nb { return Err(NotYetValid { index: i }); }
        return Err(Expired { index: i });
    }
    // (a)(4) issuer name
    if !cert.tbs.issuer.raw_eq(&state.working_issuer_name) {
        return Err(IssuerMismatch { index: i });
    }
    Ok(())
}

// Bridge between chain.vr's ChainError and PathError on the signature
// verification call.
fn chain_to_path_error_signature(
    r: Result<(), ChainError>,
    cert_index_rfc: Int,
) -> Result<(), PathError> {
    match r {
        Ok(())                                       => Ok(()),
        Err(ChainError.BadSignature(_))              => Err(SignatureFailed { index: cert_index_rfc }),
        Err(ChainError.UnsupportedAlgorithm(_))      => Err(UnsupportedAlgorithm { index: cert_index_rfc }),
        Err(_)                                       => Err(SignatureFailed { index: cert_index_rfc }),
    }
}

// =============================================================================
// §6.1.3(b) — Name constraints
// =============================================================================

fn check_name_constraints(
    cert: &X509Certificate,
    state: &ValidationState,
    cert_index_rfc: Int,
    is_last: Bool,
) -> Result<(), PathError> {
    // Per RFC 5280 §6.1.3(b): name-constraint checks apply when
    // (cert is not self-issued) OR (i = n).  For all internal
    // intermediate certs that are also self-issued, name constraints
    // do NOT apply at the cert itself but DO propagate to its
    // subordinates via §6.1.4(g).
    if !is_last && is_self_issued(cert) { return Ok(()); }

    // Subject DN check — only meaningful when subject is non-empty.
    if !cert.tbs.subject.is_empty() {
        check_dn_against_subtrees(
            cert.tbs.subject.raw_der.as_slice(),
            &state.permitted_subtrees,
            &state.excluded_subtrees,
            cert_index_rfc,
        )?;
    }

    // SAN: every typed name must be permitted + non-excluded.
    if let Some((_, san)) = &cert.tbs.extensions.subject_alt_name {
        let mut k: Int = 0;
        while k < san.names.len() {
            check_general_name(
                &san.names[k],
                &state.permitted_subtrees,
                &state.excluded_subtrees,
                cert_index_rfc,
            )?;
            k = k + 1;
        }
    }
    Ok(())
}

fn is_self_issued(cert: &X509Certificate) -> Bool {
    cert.tbs.subject.raw_eq(&cert.tbs.issuer)
}

fn check_dn_against_subtrees(
    dn_der: &[Byte],
    permitted: &NameConstraintsState,
    excluded: &NameConstraintsState,
    cert_index_rfc: Int,
) -> Result<(), PathError> {
    if !is_in_dn_subtrees(dn_der, &excluded.dn_subtrees, false) {
        // Not in any excluded subtree — fine for excluded check.
    } else {
        return Err(NameConstraintExcluded {
            index: cert_index_rfc,
            name_kind: "DirectoryName".to_text(),
            name: format!("<{} bytes>", dn_der.len()).to_text(),
        });
    }
    if permitted.initialized && !permitted.dn_subtrees.is_empty() {
        if !is_in_dn_subtrees(dn_der, &permitted.dn_subtrees, true) {
            return Err(NameConstraintNotPermitted {
                index: cert_index_rfc,
                name_kind: "DirectoryName".to_text(),
                name: format!("<{} bytes>", dn_der.len()).to_text(),
            });
        }
    }
    Ok(())
}

fn is_in_dn_subtrees(dn_der: &[Byte], subtrees: &List<List<Byte>>, default_when_empty: Bool) -> Bool {
    if subtrees.is_empty() { return default_when_empty; }
    let mut i: Int = 0;
    while i < subtrees.len() {
        if dn_starts_with(dn_der, subtrees[i].as_slice()) { return true; }
        i = i + 1;
    }
    false
}

fn dn_starts_with(dn: &[Byte], prefix: &[Byte]) -> Bool {
    // Per RFC 5280 §4.2.1.10: a DN is "within" a subtree if every
    // RDN of the subtree appears as a prefix in the cert subject.
    // Byte-prefix matching is a sufficient approximation for
    // canonical-encoded DNs (the real implementation should compare
    // RDN-by-RDN with case-insensitive matching for utf8String /
    // printableString attribute types — left for follow-up).
    if prefix.len() > dn.len() { return false; }
    let mut i: Int = 0;
    while i < prefix.len() {
        if dn[i] != prefix[i] { return false; }
        i = i + 1;
    }
    true
}

fn check_general_name(
    gn: &GeneralName,
    permitted: &NameConstraintsState,
    excluded: &NameConstraintsState,
    cert_index_rfc: Int,
) -> Result<(), PathError> {
    match gn {
        GeneralName.DnsName(dns) => {
            // Excluded check first — RFC 5280 §4.2.1.10
            let mut i: Int = 0;
            while i < excluded.dns_subtrees.len() {
                if dns_within_subtree(dns, &excluded.dns_subtrees[i]) {
                    return Err(NameConstraintExcluded {
                        index: cert_index_rfc,
                        name_kind: "dNSName".to_text(),
                        name: dns.clone(),
                    });
                }
                i = i + 1;
            }
            if permitted.initialized && !permitted.dns_subtrees.is_empty() {
                let mut ok = false;
                let mut j: Int = 0;
                while j < permitted.dns_subtrees.len() {
                    if dns_within_subtree(dns, &permitted.dns_subtrees[j]) { ok = true; break; }
                    j = j + 1;
                }
                if !ok {
                    return Err(NameConstraintNotPermitted {
                        index: cert_index_rfc,
                        name_kind: "dNSName".to_text(),
                        name: dns.clone(),
                    });
                }
            }
        }
        GeneralName.IpAddress(addr) => {
            let mut i: Int = 0;
            while i < excluded.ip_subtrees.len() {
                if ip_within_subtree(addr, &excluded.ip_subtrees[i]) {
                    return Err(NameConstraintExcluded {
                        index: cert_index_rfc,
                        name_kind: "iPAddress".to_text(),
                        name: format!("<{} bytes>", addr.len()).to_text(),
                    });
                }
                i = i + 1;
            }
            if permitted.initialized && !permitted.ip_subtrees.is_empty() {
                let mut ok = false;
                let mut j: Int = 0;
                while j < permitted.ip_subtrees.len() {
                    if ip_within_subtree(addr, &permitted.ip_subtrees[j]) { ok = true; break; }
                    j = j + 1;
                }
                if !ok {
                    return Err(NameConstraintNotPermitted {
                        index: cert_index_rfc,
                        name_kind: "iPAddress".to_text(),
                        name: format!("<{} bytes>", addr.len()).to_text(),
                    });
                }
            }
        }
        GeneralName.Rfc822Name(email) => {
            check_email_general_name(email, permitted, excluded, cert_index_rfc)?;
        }
        GeneralName.Uri(uri) => {
            // Per RFC 5280 §4.2.1.10: URI constraint applies to the
            // host portion. We extract the host substring and apply
            // the dNSName subtree matching rules.
            let host = extract_uri_host(uri);
            let mut i: Int = 0;
            while i < excluded.uri_subtrees.len() {
                if dns_within_subtree(&host, &excluded.uri_subtrees[i]) {
                    return Err(NameConstraintExcluded {
                        index: cert_index_rfc,
                        name_kind: "uniformResourceIdentifier".to_text(),
                        name: uri.clone(),
                    });
                }
                i = i + 1;
            }
            if permitted.initialized && !permitted.uri_subtrees.is_empty() {
                let mut ok = false;
                let mut j: Int = 0;
                while j < permitted.uri_subtrees.len() {
                    if dns_within_subtree(&host, &permitted.uri_subtrees[j]) { ok = true; break; }
                    j = j + 1;
                }
                if !ok {
                    return Err(NameConstraintNotPermitted {
                        index: cert_index_rfc,
                        name_kind: "uniformResourceIdentifier".to_text(),
                        name: uri.clone(),
                    });
                }
            }
        }
        GeneralName.DirectoryName(dn_der) => {
            check_dn_against_subtrees(dn_der.as_slice(), permitted, excluded, cert_index_rfc)?;
        }
        GeneralName.OtherName(_) | GeneralName.Unsupported => {
            // RFC 5280 §4.2.1.10 leaves matching of "other" names up
            // to local policy. Default: pass.
        }
    }
    Ok(())
}

fn dns_within_subtree(dns: &Text, subtree: &Text) -> Bool {
    // RFC 5280 §4.2.1.10: a dNSName is within a subtree if the
    // subtree is the dNSName, OR the subtree is a parent suffix
    // separated by a dot.
    let dns_lc = dns.to_lower();
    let st_lc = subtree.to_lower();
    if dns_lc == st_lc { return true; }
    if dns_lc.len() <= st_lc.len() { return false; }
    let suffix_start = dns_lc.len() - st_lc.len();
    if suffix_start == 0 { return false; }
    if dns_lc.byte_at(suffix_start - 1) != b'.' { return false; }
    dns_lc.byte_substring(suffix_start, dns_lc.len()) == st_lc
}

fn ip_within_subtree(addr: &List<Byte>, subtree: &IpSubtree) -> Bool {
    // Subtree.addr is the network address; subtree.mask is the mask.
    // Both must be the same length as `addr`. Match: every byte of
    // (addr & mask) equals (subtree.addr & mask).
    if addr.len() != subtree.addr.len() { return false; }
    if subtree.mask.len() != subtree.addr.len() { return false; }
    let mut i: Int = 0;
    while i < addr.len() {
        if (addr[i] & subtree.mask[i]) != (subtree.addr[i] & subtree.mask[i]) {
            return false;
        }
        i = i + 1;
    }
    true
}

fn check_email_general_name(
    email: &Text,
    permitted: &NameConstraintsState,
    excluded: &NameConstraintsState,
    cert_index_rfc: Int,
) -> Result<(), PathError> {
    let mut i: Int = 0;
    while i < excluded.email_subtrees.len() {
        if email_within_subtree(email, &excluded.email_subtrees[i]) {
            return Err(NameConstraintExcluded {
                index: cert_index_rfc,
                name_kind: "rfc822Name".to_text(),
                name: email.clone(),
            });
        }
        i = i + 1;
    }
    if permitted.initialized && !permitted.email_subtrees.is_empty() {
        let mut ok = false;
        let mut j: Int = 0;
        while j < permitted.email_subtrees.len() {
            if email_within_subtree(email, &permitted.email_subtrees[j]) { ok = true; break; }
            j = j + 1;
        }
        if !ok {
            return Err(NameConstraintNotPermitted {
                index: cert_index_rfc,
                name_kind: "rfc822Name".to_text(),
                name: email.clone(),
            });
        }
    }
    Ok(())
}

fn email_within_subtree(email: &Text, subtree: &Text) -> Bool {
    // Subtree forms (RFC 5280 §4.2.1.10):
    //   - "user@example.com"  exact match
    //   - "example.com"       any user at this domain
    //   - ".example.com"      any subdomain (and any host below)
    let elc = email.to_lower();
    let slc = subtree.to_lower();
    if !slc.starts_with(".") && slc.contains("@") {
        return elc == slc;
    }
    let at_pos = match elc.find_byte(b'@') {
        Some(p) => p,
        None    => return false,
    };
    let domain = elc.byte_substring(at_pos + 1, elc.len());
    if !slc.starts_with(".") {
        return domain == slc;
    }
    // ".example.com" — domain must be subdomain of the bit AFTER the dot.
    let parent = slc.byte_substring(1, slc.len());
    if domain == parent { return true; }
    if domain.len() <= parent.len() { return false; }
    let suffix_start = domain.len() - parent.len();
    if domain.byte_at(suffix_start - 1) != b'.' { return false; }
    domain.byte_substring(suffix_start, domain.len()) == parent
}

fn extract_uri_host(uri: &Text) -> Text {
    // Naive URI parse: scheme://host[:port]/...
    let after_scheme = match uri.find_str("://") {
        Some(p) => uri.byte_substring(p + 3, uri.len()),
        None    => uri.clone(),
    };
    let host_end = match after_scheme.find_byte_any(b"/?#:") {
        Some(p) => p,
        None    => after_scheme.len(),
    };
    after_scheme.byte_substring(0, host_end)
}

// =============================================================================
// §6.1.3(c)–(e) — Policy processing
// =============================================================================

fn process_policies(
    cert: &X509Certificate,
    state: &mut ValidationState,
    _cert_index_rfc: Int,
) {
    // We track only structural elements: certificate-policies presence
    // controls whether the policy_tree survives. Full RFC §6.1.3(d)
    // intersection-with-anyPolicy is approximated: if the cert
    // declares specific policies, those become the new tree; if
    // anyPolicy, the tree is preserved.
    let policies = extract_policies(cert);
    if policies.is_empty() {
        // No certificate-policies extension (or empty) → the tree
        // becomes empty unless anyPolicy was carrying it. Per RFC
        // 5280 §6.1.3(e), if certificatePolicies absent, set tree to
        // NULL.
        state.valid_policy_tree = List.new();
        return;
    }
    // Build a new depth in the tree from the cert's policy set.
    let mut new_depth: List<PolicyTreeNode> = List.new();
    let mut i: Int = 0;
    while i < policies.len() {
        let p = &policies[i];
        let mut expected: Set<Oid> = Set.new();
        expected.insert(p.clone());
        new_depth.push(PolicyTreeNode {
            valid_policy: p.clone(),
            qualifier_set: List.new(),
            expected_policy_set: expected,
        });
        i = i + 1;
    }
    state.valid_policy_tree.push(new_depth);
}

fn extract_policies(cert: &X509Certificate) -> List<Oid> {
    // Walk `extensions.others` for the certificatePolicies OID and
    // pull out per-policy IDs. The full extension parse is in
    // ext/certificate_policies.vr (Phase-3 follow-up); we expose a
    // best-effort surface here.
    let cp_oid = Oid.from(&[2, 5, 29, 32]);
    let mut out: List<Oid> = List.new();
    let mut i: Int = 0;
    while i < cert.tbs.extensions.others.len() {
        let raw = &cert.tbs.extensions.others[i];
        if raw.oid.eq(&cp_oid) {
            // Quick scan: each policy is OBJECT IDENTIFIER inside
            // SEQUENCE OF PolicyInformation. We parse loosely (DER
            // SEQUENCE OF SEQUENCE { OID, …}) and harvest top-level OIDs.
            let oids = harvest_oids(raw.value_der.as_slice());
            let mut k: Int = 0;
            while k < oids.len() { out.push(oids[k].clone()); k = k + 1; }
            break;
        }
        i = i + 1;
    }
    out
}

fn harvest_oids(_der: &[Byte]) -> List<Oid> {
    // Placeholder for follow-up structured parser. Returns empty —
    // policy validation degrades to "no specific policies present"
    // gracefully, which means the algorithm only fails if
    // initial-explicit-policy was set.
    List.new()
}

// =============================================================================
// §6.1.4 — Prepare for next cert
// =============================================================================

fn prepare_for_next(
    cert: &X509Certificate,
    state: &mut ValidationState,
    cert_index_rfc: Int,
) -> Result<(), PathError> {
    let i = cert_index_rfc;
    // (a) name constraints union
    if let Some((_, nc)) = &cert.tbs.extensions.name_constraints {
        absorb_name_constraints(&mut state.permitted_subtrees, &mut state.excluded_subtrees, nc);
    }

    // (h)–(j) inhibitor decrements
    if !is_self_issued(cert) {
        if state.explicit_policy > 0       { state.explicit_policy = state.explicit_policy - 1; }
        if state.policy_mapping_inhibit > 0 { state.policy_mapping_inhibit = state.policy_mapping_inhibit - 1; }
        if state.inhibit_any_policy > 0     { state.inhibit_any_policy = state.inhibit_any_policy - 1; }
    }

    // (k) basic-constraints: cA must be TRUE.
    let bc = match &cert.tbs.extensions.basic_constraints {
        Some((_, b)) => b.clone(),
        None         => return Err(NotCa { index: i }),
    };
    if !bc.ca { return Err(NotCa { index: i }); }

    // (l) keyUsage check.
    match &cert.tbs.extensions.key_usage {
        Some((_, ku)) => {
            if !ku.key_cert_sign { return Err(NoKeyCertSign { index: i }); }
        }
        None => {} // absent KU is permissive (not ideal but RFC-legal)
    }

    // (m) max_path_length: decrement for non-self-issued; check.
    if !is_self_issued(cert) {
        if state.max_path_length <= 0 {
            return Err(MaxPathLengthExceeded { index: i });
        }
        state.max_path_length = state.max_path_length - 1;
    }
    if let Some(plc) = bc.path_len_constraint {
        if plc < state.max_path_length {
            state.max_path_length = plc;
        }
    }

    // (n) critical-extension recognition: every critical ext must be
    // recognised. The decoder either parsed it into a typed field
    // (recognised) or into `others`. Walk `others` and look for any
    // critical extension that isn't on the well-known list.
    check_critical_extensions(cert, i)?;

    // (o) update working public key + working issuer name.
    state.working_public_key = cert.tbs.spki.clone();
    state.working_issuer_name = cert.tbs.subject.clone();

    Ok(())
}

fn absorb_name_constraints(
    permitted: &mut NameConstraintsState,
    excluded:  &mut NameConstraintsState,
    nc: &NameConstraints,
) {
    // permitted must be initialised on first entry.
    permitted.initialized = true;
    let mut i: Int = 0;
    while i < nc.permitted.len() {
        absorb_subtree(permitted, &nc.permitted[i]);
        i = i + 1;
    }
    let mut j: Int = 0;
    while j < nc.excluded.len() {
        absorb_subtree(excluded, &nc.excluded[j]);
        j = j + 1;
    }
}

fn absorb_subtree(state: &mut NameConstraintsState, gs: &GeneralSubtree) {
    match &gs.base {
        GeneralName.DnsName(d)        => state.dns_subtrees.push(d.clone()),
        GeneralName.IpAddress(addr)   => {
            // RFC 5280: IP subtree encoding is "addr || mask" in a
            // single iPAddress octet string of length 8 (IPv4) or 32
            // (IPv6). Split here.
            let half = addr.len() / 2;
            if addr.len() == 8 || addr.len() == 32 {
                let mut a: List<Byte> = List.with_capacity(half);
                let mut m: List<Byte> = List.with_capacity(half);
                let mut k: Int = 0;
                while k < half { a.push(addr[k]); k = k + 1; }
                while k < addr.len() { m.push(addr[k]); k = k + 1; }
                state.ip_subtrees.push(IpSubtree { addr: a, mask: m });
            }
        }
        GeneralName.Rfc822Name(e)     => state.email_subtrees.push(e.clone()),
        GeneralName.Uri(u)            => state.uri_subtrees.push(u.clone()),
        GeneralName.DirectoryName(d)  => state.dn_subtrees.push(d.clone()),
        GeneralName.OtherName(_)      => {} // unsupported in name-constraint context
        GeneralName.Unsupported       => {}
    }
}

fn check_critical_extensions(cert: &X509Certificate, cert_index_rfc: Int) -> Result<(), PathError> {
    let mut i: Int = 0;
    while i < cert.tbs.extensions.others.len() {
        let raw = &cert.tbs.extensions.others[i];
        if raw.critical {
            // Whitelist of critical extensions a strict validator
            // recognises but parses leniently (or that it tolerates
            // in practice). The truly critical-but-unknown case fails.
            if !is_recognised_critical(&raw.oid) {
                return Err(UnrecognisedCriticalExtension {
                    index: cert_index_rfc,
                    oid_text: format!("{:?}", raw.oid).to_text(),
                });
            }
        }
        i = i + 1;
    }
    Ok(())
}

fn is_recognised_critical(oid: &Oid) -> Bool {
    // Conservative whitelist of critical extensions known to RFC
    // 5280 §4.2 that a strict validator must understand. Anything
    // else marked critical fails closed.
    let known: List<Oid> = make_known_critical_oids();
    let mut i: Int = 0;
    while i < known.len() {
        if oid.eq(&known[i]) { return true; }
        i = i + 1;
    }
    false
}

fn make_known_critical_oids() -> List<Oid> {
    let mut out: List<Oid> = List.new();
    out.push(Oid.from(&[2, 5, 29, 19])); // basicConstraints
    out.push(Oid.from(&[2, 5, 29, 15])); // keyUsage
    out.push(Oid.from(&[2, 5, 29, 17])); // subjectAltName
    out.push(Oid.from(&[2, 5, 29, 30])); // nameConstraints
    out.push(Oid.from(&[2, 5, 29, 32])); // certificatePolicies
    out.push(Oid.from(&[2, 5, 29, 33])); // policyMappings
    out.push(Oid.from(&[2, 5, 29, 36])); // policyConstraints
    out.push(Oid.from(&[2, 5, 29, 37])); // extKeyUsage
    out.push(Oid.from(&[2, 5, 29, 54])); // inhibitAnyPolicy
    out
}

// =============================================================================
// §6.1.5 — Wrap-up
// =============================================================================

fn wrap_up(
    state: &ValidationState,
    input: &PathValidationInput,
) -> Result<Set<Oid>, PathError> {
    // (a) explicit_policy decrement (post-final).
    let final_explicit = if state.explicit_policy > 0 {
        state.explicit_policy - 1
    } else { 0 };

    // (b) extract accepted policies from the tree's leaf depth.
    let accepted = extract_accepted_policies(&state.valid_policy_tree, &input.user_initial_policy_set);

    if final_explicit > 0 && accepted.is_empty() {
        return Err(PolicyTreeEmpty);
    }

    match &input.user_initial_policy_set {
        PolicySet.AnyPolicy => Ok(accepted),
        PolicySet.Required(req) => {
            if accepted.is_empty() && !req.is_empty() {
                return Err(RequiredPolicyNotMet);
            }
            Ok(accepted)
        }
    }
}

fn extract_accepted_policies(
    tree: &List<List<PolicyTreeNode>>,
    user: &PolicySet,
) -> Set<Oid> {
    let mut out: Set<Oid> = Set.new();
    if tree.is_empty() { return out; }
    let last = &tree[tree.len() - 1];
    let mut i: Int = 0;
    while i < last.len() {
        let p = &last[i].valid_policy;
        match user {
            PolicySet.AnyPolicy => { out.insert(p.clone()); }
            PolicySet.Required(req) => {
                if req.contains(p) { out.insert(p.clone()); }
            }
        }
        i = i + 1;
    }
    out
}

// =============================================================================
// Tests
// =============================================================================

#[cfg(test)]
mod tests {
    use super.*;

    #[test]
    fn test_constants() {
        assert_eq(MAX_CHAIN_LENGTH, 16);
    }

    #[test]
    fn test_dns_within_subtree_exact() {
        assert_eq(dns_within_subtree(&"example.com".to_text(), &"example.com".to_text()), true);
    }

    #[test]
    fn test_dns_within_subtree_subdomain() {
        assert_eq(dns_within_subtree(&"foo.example.com".to_text(), &"example.com".to_text()), true);
        assert_eq(dns_within_subtree(&"foo.bar.example.com".to_text(), &"example.com".to_text()), true);
    }

    #[test]
    fn test_dns_within_subtree_unrelated() {
        assert_eq(dns_within_subtree(&"example.com".to_text(), &"other.com".to_text()), false);
        // Adjacent-label is NOT a subdomain match.
        assert_eq(dns_within_subtree(&"badexample.com".to_text(), &"example.com".to_text()), false);
    }

    #[test]
    fn test_email_within_subtree_exact() {
        assert_eq(email_within_subtree(&"a@example.com".to_text(), &"a@example.com".to_text()), true);
    }

    #[test]
    fn test_email_within_subtree_domain() {
        assert_eq(email_within_subtree(&"any@example.com".to_text(), &"example.com".to_text()), true);
        assert_eq(email_within_subtree(&"any@OTHER.com".to_text(), &"example.com".to_text()), false);
    }

    #[test]
    fn test_email_within_subtree_dot_prefix() {
        assert_eq(email_within_subtree(&"a@sub.example.com".to_text(), &".example.com".to_text()), true);
        assert_eq(email_within_subtree(&"a@example.com".to_text(), &".example.com".to_text()), true);
        assert_eq(email_within_subtree(&"a@other.com".to_text(), &".example.com".to_text()), false);
    }

    #[test]
    fn test_extract_uri_host() {
        assert_eq(extract_uri_host(&"https://example.com/path".to_text()), "example.com".to_text());
        assert_eq(extract_uri_host(&"https://example.com:443/path".to_text()), "example.com".to_text());
        assert_eq(extract_uri_host(&"https://user@example.com/path".to_text()), "user@example.com".to_text());
    }

    #[test]
    fn test_ip_within_subtree_v4() {
        let mut addr: List<Byte> = List.new();
        addr.push(192); addr.push(168); addr.push(1); addr.push(10);
        let mut sub_addr: List<Byte> = List.new();
        sub_addr.push(192); sub_addr.push(168); sub_addr.push(0); sub_addr.push(0);
        let mut sub_mask: List<Byte> = List.new();
        sub_mask.push(255); sub_mask.push(255); sub_mask.push(0); sub_mask.push(0);
        let st = IpSubtree { addr: sub_addr, mask: sub_mask };
        assert_eq(ip_within_subtree(&addr, &st), true);
        let mut other: List<Byte> = List.new();
        other.push(10); other.push(0); other.push(0); other.push(1);
        assert_eq(ip_within_subtree(&other, &st), false);
    }
}
