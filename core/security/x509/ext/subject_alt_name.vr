// =============================================================================
// security/x509/ext/subject_alt_name.vr — RFC 5280 §4.2.1.6
// =============================================================================
//
// SubjectAltName ::= GeneralNames
// GeneralNames ::= SEQUENCE SIZE (1..MAX) OF GeneralName
// GeneralName ::= CHOICE {
//     otherName                       [0]     OtherName,
//     rfc822Name                      [1]     IA5String,
//     dNSName                         [2]     IA5String,
//     x400Address                     [3]     ORAddress,
//     directoryName                   [4]     Name,
//     ediPartyName                    [5]     EDIPartyName,
//     uniformResourceIdentifier       [6]     IA5String,
//     iPAddress                       [7]     OCTET STRING,
//     registeredID                    [8]     OBJECT IDENTIFIER
// }
//
// For TLS 1.3 / HTTPS identity matching (RFC 6125), only `dNSName`
// and `iPAddress` matter. We parse the rest enough to skip; the
// discriminated values we care about are kept as typed variants.
//
// =============================================================================

module core.security.x509.ext.subject_alt_name;

mount core.*;
mount core.collections.List;
mount core.encoding.der.{DerReader, DerError, DerErrorKind, Tag, TagClass};

public type GeneralName is
      DnsName(Text)            // [2]
    | IpAddress(List<Byte>)    // [7] — 4 bytes IPv4 or 16 bytes IPv6
    | Rfc822Name(Text)         // [1]
    | Uri(Text)                // [6]
    | DirectoryName(List<Byte>)// [4] — byte-exact DER of Name
    | OtherName(List<Byte>)    // [0] — raw for future decoding
    | Unsupported;

public type SubjectAltName is {
    names: List<GeneralName>,
};

implement SubjectAltName {
    /// Match a DNS hostname against the SAN per RFC 6125 §6.4.
    /// Wildcard handling: a leftmost `*.` label matches one DNS label;
    /// `*` alone is forbidden; mid-label wildcards (`foo*.bar`) are
    /// not supported (neither does Chrome).
    public fn matches_dns(&self, hostname: &Text) -> Bool {
        let mut i: Int = 0;
        while i < self.names.len() {
            match &self.names[i] {
                GeneralName.DnsName(san) => {
                    if match_dns_pattern(san, hostname) { return true; }
                },
                _ => {},
            }
            i = i + 1;
        }
        false
    }

    /// Match a parsed IP address (4 or 16 bytes) against SAN iPAddress.
    public fn matches_ip(&self, addr: &[Byte]) -> Bool {
        let mut i: Int = 0;
        while i < self.names.len() {
            match &self.names[i] {
                GeneralName.IpAddress(san_addr) => {
                    if san_addr.len() == addr.len() {
                        let mut eq = true;
                        let mut j: Int = 0;
                        while j < addr.len() {
                            if san_addr[j] != addr[j] { eq = false; break; }
                            j = j + 1;
                        }
                        if eq { return true; }
                    }
                },
                _ => {},
            }
            i = i + 1;
        }
        false
    }
}

public fn parse(value: &[Byte]) -> Result<SubjectAltName, DerError> {
    let mut r = DerReader.new(value);
    let mut seq = r.read_sequence()?;
    let mut names: List<GeneralName> = [];
    while !seq.is_at_end() {
        let gn = parse_general_name(&mut seq)?;
        names.push(gn);
    }
    seq.expect_end()?;
    r.expect_end()?;
    Ok(SubjectAltName { names: names })
}

public fn parse_general_name(r: &mut DerReader) -> Result<GeneralName, DerError> {
    let save = r.position();
    let (tag, len, val_start, elem_end) = r.peek_element_span()?;
    let is_ctx = match tag.class_ { TagClass.ContextSpecific => true, _ => false };
    if !is_ctx {
        // Per RFC 5280, every GeneralName alternative is context-tagged.
        // Reject non-context.
        return Err(DerError {
            kind: DerErrorKind.UnexpectedTag,
            position: save,
            message: "GeneralName not context-specific",
        });
    }
    // Consume the tag+length; cursor now at value.
    let _ = r.read_tag_length()?;

    match tag.number {
        0_u32 => {
            // OtherName — preserve raw DER of the [0] explicit value.
            let raw = r.take_bytes(len)?;
            let _ = val_start; let _ = elem_end;
            Ok(GeneralName.OtherName(raw))
        },
        1_u32 => {
            let bytes = r.take_bytes(len)?;
            Ok(GeneralName.Rfc822Name(Text.from_utf8_lossy(bytes.as_slice())))
        },
        2_u32 => {
            let bytes = r.take_bytes(len)?;
            Ok(GeneralName.DnsName(Text.from_utf8_lossy(bytes.as_slice())))
        },
        4_u32 => {
            // directoryName is [4] EXPLICIT Name; value contains full
            // SEQUENCE Name DER.
            let bytes = r.take_bytes(len)?;
            Ok(GeneralName.DirectoryName(bytes))
        },
        6_u32 => {
            let bytes = r.take_bytes(len)?;
            Ok(GeneralName.Uri(Text.from_utf8_lossy(bytes.as_slice())))
        },
        7_u32 => {
            let bytes = r.take_bytes(len)?;
            if bytes.len() != 4 && bytes.len() != 16 {
                return Err(DerError {
                    kind: DerErrorKind.MalformedDer,
                    position: save,
                    message: "iPAddress must be 4 or 16 bytes",
                });
            }
            Ok(GeneralName.IpAddress(bytes))
        },
        _ => {
            // Skip unsupported kinds (x400Address, ediPartyName, registeredID).
            let _ = r.take_bytes(len)?;
            Ok(GeneralName.Unsupported)
        },
    }
}

// =============================================================================
// Hostname matching (RFC 6125 §6.4)
// =============================================================================

fn match_dns_pattern(pattern: &Text, hostname: &Text) -> Bool {
    // Case-insensitive ASCII compare. RFC 6125 / WebPKI restricts DNS
    // names to ASCII; non-ASCII (IDN) names are converted to A-labels
    // (Punycode, ASCII-only) before reaching this matcher. The ASCII
    // fast path suffices — fold-and-compare in place, no allocation.
    // Previous version called `pattern.to_lowercase()` and
    // `hostname.to_lowercase()` per match attempt — allocator pressure
    // on every TLS handshake's SAN check.
    let pb = pattern.as_bytes();
    let hb = hostname.as_bytes();

    // Wildcard rule: the leftmost label of `pattern` may be exactly "*"
    // (e.g. "*.example.com"). Wildcard matches exactly one DNS label,
    // non-empty, no dots. Multi-level wildcards ("*.*.example.com") are
    // forbidden in WebPKI.
    if pb.len() >= 2 && pb[0] == ('*' as Byte) && pb[1] == ('.' as Byte) {
        // Find the first '.' in hostname — everything before it is the
        // wildcard label; after must match pattern[2..] exactly.
        let mut i: Int = 0;
        while i < hb.len() && hb[i] != ('.' as Byte) { i = i + 1; }
        if i == 0 || i >= hb.len() { return false; }         // empty or no dot
        let host_tail = &hb[(i + 1)..];
        let pat_tail  = &pb[2..];
        return ascii_eq_ci(host_tail, pat_tail);
    }

    ascii_eq_ci(pb, hb)
}

/// ASCII-only case-insensitive byte equality. Folds 'A'..'Z' → 'a'..'z'
/// inline per byte, no allocation. Caller invariant: both inputs are
/// ASCII (DNS / WebPKI names are pre-converted to A-labels).
fn ascii_eq_ci(a: &[Byte], b: &[Byte]) -> Bool {
    if a.len() != b.len() { return false; }
    let mut i: Int = 0;
    while i < a.len() {
        let ai = a[i];
        let bi = b[i];
        let af = if ai >= (0x41 as Byte) && ai <= (0x5A as Byte) {
            ai + (0x20 as Byte)
        } else { ai };
        let bf = if bi >= (0x41 as Byte) && bi <= (0x5A as Byte) {
            bi + (0x20 as Byte)
        } else { bi };
        if af != bf { return false; }
        i = i + 1;
    }
    true
}
