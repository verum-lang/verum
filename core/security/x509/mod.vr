// =============================================================================
// security/x509/mod.vr — X.509 certificate subsystem (RFC 5280)
// =============================================================================
// Layer: 3 (Certificate layer — sits above encoding.der + security.{sig, ecc})
// Dependencies: core, collections, encoding.der, security.{sig, hash, ecc}
// Spec: internal/specs/tls-quic.md §6.5, §12 Phase 1
// =============================================================================
//
// Pure-Verum X.509 certificate parser + chain validator, built on top
// of `core.encoding.der` for wire parsing and
// `core.security.{sig, hash, ecc}` for signature verification.
//
// # Minimal usage (WebPKI TLS server verify)
//
// ```verum
// mount core.security.x509.*;
//
// fn verify_server(chain_der: &List<List<Byte>>, hostname: Text) -> Result<(), ChainError> {
//     let trust = TrustStore.system().map_err(|_| ChainError.UnknownIssuer)?;
//
//     let mut certs: List<Certificate> = [];
//     let mut i: Int = 0;
//     while i < chain_der.len() {
//         certs.push(parse_certificate(chain_der[i].as_slice())
//             .map_err(|_| ChainError.BadSignature(i))?);
//         i = i + 1;
//     }
//
//     let now_secs = current_time_unix();
//     let _ = validate_chain(&certs, &trust, Some(&hostname), now_secs)?;
//     Ok(())
// }
// ```
//
// # Status — v0.1
//
// Complete wire-level parser + RFC 5280 §6.1 validator. Covers the
// WebPKI sigspec (Ed25519, ECDSA P-256/P-384, RSA PKCS#1 v1.5, RSA-PSS).
// Revocation checks (CRL, OCSP) live in `ocsp.vr` + future `crl.vr`.
//
// =============================================================================

module core.security.x509;

public module oid;
public module time;
public module algorithm;
public module name;
public module spki;
public module ext;
public module certificate;
public module chain;
public module trust_store;
public module server_identity;

// Re-exports — OID
public mount .oid.Oid;

// Re-exports — time
public mount .time.{CertValidity, time_cmp, time_eq, time_lt, time_le, time_gt, time_ge, time_to_unix, is_valid_at};

// Re-exports — algorithm
public mount .algorithm.{
    SignatureAlg, RsaPssParams, RsaPssHash,
    PublicKeyAlg, EcNamedCurve,
};

// Re-exports — name
public mount .name.{DistinguishedName, RelativeDistinguishedName, NameAttribute, NameAttributeKind};

// Re-exports — SPKI
public mount .spki.{
    Spki, SubjectPublicKey,
    RsaPublicKey, EcPublicKeyBytes,
    Ed25519PublicKeyBytes, Ed448PublicKeyBytes,
    X25519PublicKeyBytes,  X448PublicKeyBytes,
};

// Re-exports — extensions
public mount .ext.{
    ExtensionSet, RawExtension,
    BasicConstraints, KeyUsage,
    ExtKeyUsage, ExtKeyUsagePurpose,
    SubjectAltName, GeneralName,
    NameConstraints, GeneralSubtree,
};

// Re-exports — certificate
public mount .certificate.{Certificate, TbsCertificate, X509Version, parse_certificate};

// Re-exports — chain validation
public mount .chain.{ChainError, VerifiedChain, validate_chain};

// Re-exports — trust store
public mount .trust_store.{TrustStore, TrustError};

// Re-exports — server-identity verification (RFC 6125)
public mount .server_identity.{ServerIdentityError, verify_server_identity};
