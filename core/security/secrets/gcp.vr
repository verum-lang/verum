// =============================================================================
// security/secrets/gcp.vr — Google Cloud Secret Manager client
// =============================================================================
// Transport: HTTPS to secretmanager.googleapis.com.
// Auth: OAuth2 bearer token from one of:
//   - Service Account JSON (GOOGLE_APPLICATION_CREDENTIALS)
//   - GCE / GKE Workload Identity (metadata server at 169.254.169.254)
//   - Explicit bearer token (tests / local impersonation)
// Methods: AccessSecretVersion, AddSecretVersion, DeleteSecret,
//          ListSecrets.
// =============================================================================

module core.security.secrets.gcp;

mount core.*;
mount core.security.secrets.core_protocol.{
    Secret, SecretError, SecretStore, SecretReference, SecretVersion,
};

public type GcpAuth is
    /// Path to a service-account JSON key file.
    | ServiceAccountJson(Text)
    /// Rely on the metadata server (GCE / GKE Workload Identity).
    | ApplicationDefault
    /// Raw bearer token (OAuth2 access token).
    | Bearer(Text);

public type GcpSecretsClient is {
    handle: UInt64,
    project: Text,
}

implement GcpSecretsClient {
    pub async fn connect(project: Text, auth: GcpAuth)
        -> Result<GcpSecretsClient, SecretError>
    {
        @intrinsic("verum.gcp.secret_manager_connect", project, &auth).await
    }

    pub async fn access_secret_version(&self, reference: &SecretReference)
        -> Result<Secret, SecretError>
    {
        @intrinsic("verum.gcp.secret_manager_access", self.handle, reference).await
    }

    pub async fn add_secret_version(&self, name: &Text, value: &[Byte])
        -> Result<SecretVersion, SecretError>
    {
        @intrinsic("verum.gcp.secret_manager_add", self.handle, name, value).await
    }

    pub async fn delete_secret(&self, name: &Text) -> Result<(), SecretError> {
        @intrinsic("verum.gcp.secret_manager_delete", self.handle, name).await
    }

    pub async fn list_secrets(&self, prefix: &Text) -> Result<List<Text>, SecretError> {
        @intrinsic("verum.gcp.secret_manager_list", self.handle, prefix).await
    }

    pub async fn close(&self) -> Result<(), SecretError> {
        @intrinsic("verum.gcp.secret_manager_close", self.handle).await
    }
}

implement SecretStore for GcpSecretsClient {
    async fn get(&self, reference: &SecretReference) -> Result<Secret, SecretError> {
        self.access_secret_version(reference).await
    }

    async fn put(&self, name: &Text, value: &[Byte]) -> Result<SecretVersion, SecretError> {
        self.add_secret_version(name, value).await
    }

    async fn delete(&self, name: &Text) -> Result<(), SecretError> {
        self.delete_secret(name).await
    }

    async fn list(&self, prefix: &Text) -> Result<List<Text>, SecretError> {
        self.list_secrets(prefix).await
    }

    fn description(&self) -> Text {
        f"gcp:secret-manager({self.project})"
    }
}
