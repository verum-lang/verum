// =============================================================================
// security/secrets/core_protocol.vr — SecretStore protocol + shared types
// =============================================================================

module core.security.secrets.core_protocol;

mount core.*;
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};

// =============================================================================
// Shared error model
// =============================================================================

public type SecretError is
    /// Requested secret does not exist / was deleted.
    | NotFound { name: Text }
    /// Caller is not authorised (403 / 401 / IAM-denied).
    | PermissionDenied(Text)
    /// Backend is unavailable (network / 5xx / throttled).
    | Unavailable(Text)
    /// Local auth could not be obtained (missing env / expired token).
    | AuthenticationFailed(Text)
    /// Payload shape didn't match — version not a number, JSON malformed.
    | Malformed(Text)
    /// Rate-limited by backend; `retry_after` gives the suggested delay.
    | RateLimited { retry_after: Duration }
    /// The secret is known but the requested version is unavailable.
    | VersionNotFound { name: Text, version: SecretVersion }
    /// Cryptographic failure (decryption / KMS unwrap).
    | CryptoError(Text)
    /// Other backend-specific error — surfaces the raw message.
    | Backend(Text);

// Display + Debug + Eq for SecretError — uses
// SecretVersion's protocol impls for the
// VersionNotFound nested case.  PermissionDenied /
// CryptoError messages are surfaced verbatim — these
// errors are operator-facing diagnostics, not values
// that flow back to untrusted callers, so backend
// detail in messages is appropriate.

implement Display for SecretError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            SecretError.NotFound { name } => {
                f.write_str("secret not found: ")?;
                f.write_str(name.as_str())
            },
            SecretError.PermissionDenied(msg) => {
                f.write_str("secret access denied: ")?;
                f.write_str(msg.as_str())
            },
            SecretError.Unavailable(msg) => {
                f.write_str("secret backend unavailable: ")?;
                f.write_str(msg.as_str())
            },
            SecretError.AuthenticationFailed(msg) => {
                f.write_str("secret auth failed: ")?;
                f.write_str(msg.as_str())
            },
            SecretError.Malformed(msg) => {
                f.write_str("malformed secret payload: ")?;
                f.write_str(msg.as_str())
            },
            SecretError.RateLimited { retry_after } =>
                f.write_str(f"secret backend rate-limited; retry_after={retry_after:?}".as_str()),
            SecretError.VersionNotFound { name, version } => {
                f.write_str("secret version not found: ")?;
                f.write_str(name.as_str())?;
                f.write_str("@")?;
                version.fmt(f)
            },
            SecretError.CryptoError(msg) => {
                f.write_str("secret crypto error: ")?;
                f.write_str(msg.as_str())
            },
            SecretError.Backend(msg) => {
                f.write_str("secret backend error: ")?;
                f.write_str(msg.as_str())
            },
        }
    }
}

implement Debug for SecretError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            SecretError.NotFound { name } => {
                f.write_str("NotFound { name: ")?;
                f.write_str(name.as_str())?;
                f.write_str(" }")
            },
            SecretError.PermissionDenied(msg) => {
                f.write_str("PermissionDenied(")?;
                f.write_str(msg.as_str())?;
                f.write_str(")")
            },
            SecretError.Unavailable(msg) => {
                f.write_str("Unavailable(")?;
                f.write_str(msg.as_str())?;
                f.write_str(")")
            },
            SecretError.AuthenticationFailed(msg) => {
                f.write_str("AuthenticationFailed(")?;
                f.write_str(msg.as_str())?;
                f.write_str(")")
            },
            SecretError.Malformed(msg) => {
                f.write_str("Malformed(")?;
                f.write_str(msg.as_str())?;
                f.write_str(")")
            },
            SecretError.RateLimited { retry_after } =>
                f.write_str(f"RateLimited {{ retry_after: {retry_after:?} }}".as_str()),
            SecretError.VersionNotFound { name, version } => {
                f.write_str("VersionNotFound { name: ")?;
                f.write_str(name.as_str())?;
                f.write_str(", version: ")?;
                version.fmt_debug(f)?;
                f.write_str(" }")
            },
            SecretError.CryptoError(msg) => {
                f.write_str("CryptoError(")?;
                f.write_str(msg.as_str())?;
                f.write_str(")")
            },
            SecretError.Backend(msg) => {
                f.write_str("Backend(")?;
                f.write_str(msg.as_str())?;
                f.write_str(")")
            },
        }
    }
}

implement Eq for SecretError {
    fn eq(&self, other: &SecretError) -> Bool {
        match (self, other) {
            (SecretError.NotFound { name: a }, SecretError.NotFound { name: b }) => a == b,
            (SecretError.PermissionDenied(a), SecretError.PermissionDenied(b)) => a == b,
            (SecretError.Unavailable(a), SecretError.Unavailable(b)) => a == b,
            (SecretError.AuthenticationFailed(a), SecretError.AuthenticationFailed(b)) => a == b,
            (SecretError.Malformed(a), SecretError.Malformed(b)) => a == b,
            (
                SecretError.RateLimited { retry_after: a },
                SecretError.RateLimited { retry_after: b },
            ) => a == b,
            (
                SecretError.VersionNotFound { name: na, version: va },
                SecretError.VersionNotFound { name: nb, version: vb },
            ) => na == nb && va == vb,
            (SecretError.CryptoError(a), SecretError.CryptoError(b)) => a == b,
            (SecretError.Backend(a), SecretError.Backend(b)) => a == b,
            _ => false,
        }
    }
}

// =============================================================================
// Versioned reference + payload
// =============================================================================

public type SecretVersion is
    /// Latest published version.
    | Latest
    /// A specific numeric version (Vault KV v2, GCP).
    | Number(UInt64)
    /// A named version alias (AWS SecretsManager VersionStage).
    | Stage(Text);

// Display + Debug + Eq for SecretVersion — needed both as
// a standalone diagnostic surface and as the foundation
// for SecretError's nested VersionNotFound { version }
// comparison.

implement Display for SecretVersion {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            SecretVersion.Latest      => f.write_str("Latest"),
            SecretVersion.Number(n)   => f.write_str(f"v{n}".as_str()),
            SecretVersion.Stage(s)    => f.write_str(s.as_str()),
        }
    }
}

implement Debug for SecretVersion {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            SecretVersion.Latest      => f.write_str("Latest"),
            SecretVersion.Number(n)   => f.write_str(f"Number({n})".as_str()),
            SecretVersion.Stage(s)    => {
                f.write_str("Stage(")?;
                f.write_str(s.as_str())?;
                f.write_str(")")
            },
        }
    }
}

implement Eq for SecretVersion {
    fn eq(&self, other: &SecretVersion) -> Bool {
        match (self, other) {
            (SecretVersion.Latest, SecretVersion.Latest)         => true,
            (SecretVersion.Number(a), SecretVersion.Number(b))   => a == b,
            (SecretVersion.Stage(a), SecretVersion.Stage(b))     => a == b,
            _ => false,
        }
    }
}

public type SecretReference is {
    /// Backend-specific path ("secret/data/db" for Vault KV v2,
    /// "prod/redis/auth" for AWS, "projects/p/secrets/s" for GCP).
    name: Text,
    version: SecretVersion,
}

implement SecretReference {
    public fn latest(name: Text) -> SecretReference {
        SecretReference { name: name, version: SecretVersion.Latest }
    }

    public fn at(name: Text, version: SecretVersion) -> SecretReference {
        SecretReference { name: name, version: version }
    }
}

/// A secret returned by a SecretStore lookup. `data` is the payload;
/// `metadata` is opaque backend-specific JSON describing rotation
/// state and audit metadata.
public type Secret is {
    reference: SecretReference,
    data: List<Byte>,
    metadata: Text,
    created_at: Instant,
    /// For token-based secrets, the lease / TTL deadline. Instant.max
    /// for never-expiring values.
    expires_at: Instant,
}

implement Secret {
    public fn reference(&self) -> &SecretReference { &self.reference }
    public fn data(&self) -> &List<Byte> { &self.data }
    public fn metadata(&self) -> &Text { &self.metadata }
    public fn created_at(&self) -> Instant { self.created_at }
    public fn expires_at(&self) -> Instant { self.expires_at }

    public fn as_text(&self) -> Result<Text, SecretError> {
        match Text.from_utf8(&self.data) {
            Ok(t) => Ok(t),
            Err(_) => Err(SecretError.Malformed("secret is not valid UTF-8".into())),
        }
    }
}

// =============================================================================
// SecretStore protocol
// =============================================================================

public type SecretStore is protocol {
    /// Fetch a secret by reference.
    async fn get(&self, reference: &SecretReference) -> Result<Secret, SecretError>;

    /// Write a new version of a secret (idempotent versions are backend-
    /// specific; Vault overwrites at `name` into a new numeric version,
    /// AWS assigns a fresh VersionId).
    async fn put(&self, name: &Text, value: &[Byte]) -> Result<SecretVersion, SecretError>;

    /// Delete a secret (soft-delete in Vault; mark-for-deletion in AWS;
    /// destroy in GCP). Callers that want permanent destruction invoke
    /// the backend-specific API directly.
    async fn delete(&self, name: &Text) -> Result<(), SecretError>;

    /// List available secret names under an optional prefix.
    async fn list(&self, prefix: &Text) -> Result<List<Text>, SecretError>;

    /// Short human-readable identifier for telemetry.
    fn description(&self) -> Text;
};
