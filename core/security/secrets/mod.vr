// =============================================================================
// security/secrets/mod.vr — Secret-manager client surface
// =============================================================================
// Layer: 4.8 (Security)
// Dependencies: core, core.net.http, core.net.tls, core.time
//
// Unified `SecretStore` protocol with three in-tree backends:
//
//   - HashiCorp Vault (KV v2 + transit + lease renewal)
//   - AWS Secrets Manager (SigV4-signed HTTP)
//   - Google Cloud Secret Manager (OAuth2 bearer)
//
// The common `SecretStore` protocol lets Weft / Spindle wire any
// backend through the same interface and rotate between them without
// application changes.
// =============================================================================

module core.security.secrets;

public module core_protocol;
public module vault;
public module aws;
public module gcp;

public mount .core_protocol.SecretStore;
public mount .core_protocol.Secret;
public mount .core_protocol.SecretError;
public mount .core_protocol.SecretVersion;
public mount .core_protocol.SecretReference;

public mount .vault.VaultClient;
public mount .vault.VaultConfig;
public mount .vault.VaultError;
public mount .vault.VaultAuth;

public mount .aws.AwsSecretsClient;
public mount .aws.AwsRegion;
public mount .aws.AwsCredentials;

public mount .gcp.GcpSecretsClient;
public mount .gcp.GcpAuth;
