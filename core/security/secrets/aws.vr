// =============================================================================
// security/secrets/aws.vr — AWS Secrets Manager client
// =============================================================================
// Transport: HTTPS to secretsmanager.<region>.amazonaws.com.
// Auth: AWS SigV4 over core.net.http. Credentials sourced from env
//       (AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN),
//       IMDSv2 (EC2), or explicit construction.
// Methods: GetSecretValue, PutSecretValue, DeleteSecret, ListSecrets.
// =============================================================================

module core.security.secrets.aws;

mount core.*;
mount core.time.duration.{Duration};
mount core.security.secrets.core_protocol.{
    Secret, SecretError, SecretStore, SecretReference, SecretVersion,
};

// =============================================================================
// Region + credentials
// =============================================================================

public type AwsRegion is {
    code: Text,   // e.g. "us-east-1"
}

implement AwsRegion {
    pub fn new(code: Text) -> AwsRegion { AwsRegion { code: code } }
    pub fn code(&self) -> &Text { &self.code }
    pub fn us_east_1() -> AwsRegion { AwsRegion { code: "us-east-1".into() } }
    pub fn eu_west_1() -> AwsRegion { AwsRegion { code: "eu-west-1".into() } }
}

public type AwsCredentials is {
    access_key_id: Text,
    secret_access_key: Text,
    session_token: Maybe<Text>,
}

implement AwsCredentials {
    pub fn new(access_key_id: Text, secret_access_key: Text) -> AwsCredentials {
        AwsCredentials {
            access_key_id: access_key_id,
            secret_access_key: secret_access_key,
            session_token: None,
        }
    }

    pub fn with_session_token(mut self, t: Text) -> AwsCredentials {
        self.session_token = Some(t); self
    }
}

// =============================================================================
// Credential provider chain
// =============================================================================

public type AwsCredentialProvider is
    /// Explicit (from arguments or secure config).
    | Explicit(AwsCredentials)
    /// Environment variables.
    | Environment
    /// IMDSv2 on EC2 / task-role on ECS / Fargate.
    | InstanceMetadata
    /// IRSA — Kubernetes IAM Roles for Service Accounts.
    | IRSA
    /// Try in order, returning the first successful one.
    | Chain(List<AwsCredentialProvider>);

// =============================================================================
// Client
// =============================================================================

public type AwsSecretsClient is {
    handle: UInt64,
    region: AwsRegion,
}

implement AwsSecretsClient {
    pub async fn connect(
        region: AwsRegion,
        provider: AwsCredentialProvider,
    ) -> Result<AwsSecretsClient, SecretError> {
        @intrinsic("verum.aws.secretsmanager_connect", &region, &provider).await
    }

    pub async fn get_secret_value(&self, reference: &SecretReference)
        -> Result<Secret, SecretError>
    {
        @intrinsic("verum.aws.secretsmanager_get", self.handle, reference).await
    }

    pub async fn put_secret_value(&self, name: &Text, value: &[Byte])
        -> Result<SecretVersion, SecretError>
    {
        @intrinsic("verum.aws.secretsmanager_put", self.handle, name, value).await
    }

    pub async fn delete_secret(&self, name: &Text, recovery_window: Duration)
        -> Result<(), SecretError>
    {
        @intrinsic("verum.aws.secretsmanager_delete", self.handle, name, recovery_window).await
    }

    pub async fn list_secrets(&self, prefix: &Text) -> Result<List<Text>, SecretError> {
        @intrinsic("verum.aws.secretsmanager_list", self.handle, prefix).await
    }

    pub async fn close(&self) -> Result<(), SecretError> {
        @intrinsic("verum.aws.secretsmanager_close", self.handle).await
    }
}

implement SecretStore for AwsSecretsClient {
    async fn get(&self, reference: &SecretReference) -> Result<Secret, SecretError> {
        self.get_secret_value(reference).await
    }

    async fn put(&self, name: &Text, value: &[Byte]) -> Result<SecretVersion, SecretError> {
        self.put_secret_value(name, value).await
    }

    async fn delete(&self, name: &Text) -> Result<(), SecretError> {
        self.delete_secret(name, Duration.from_secs(30 * 86400)).await
    }

    async fn list(&self, prefix: &Text) -> Result<List<Text>, SecretError> {
        self.list_secrets(prefix).await
    }

    fn description(&self) -> Text {
        f"aws:secretsmanager({self.region.code})"
    }
}
