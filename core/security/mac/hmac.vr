// =============================================================================
// security/mac/hmac.vr — HMAC (RFC 2104)
// =============================================================================
// Layer: 2 (depends on hash primitive)
// Dependencies: core.security.hash.sha256
// Reference: RFC 2104, RFC 4231 (test vectors)
// =============================================================================
//
// Keyed-hash message authentication code. The output of `hmac_sha256(key, data)`
// is a 32-byte tag that a receiver with the same `key` can verify.
//
// # Algorithm (RFC 2104)
//
// ```
// Let B = hash block size (64 for SHA-256)
// Let L = hash output size (32 for SHA-256)
//
// 1. If len(key) > B:     key = hash(key)
// 2. If len(key) < B:     key = key || 0x00-pad to B bytes
// 3. K_ipad = key XOR 0x36-repeated-B-times
// 4. K_opad = key XOR 0x5C-repeated-B-times
// 5. Output = hash(K_opad || hash(K_ipad || data))
// ```
//
// # Usage
//
// ```verum
// let mac = hmac_sha256(&key, &message);
// // Verify:
// let expected = hmac_sha256(&key, &message);
// assert!(constant_time_eq(&mac, &expected));   // always constant-time!
// ```
//
// # Streaming
//
// ```verum
// let mut h = HmacSha256.new(&key);
// h.update(chunk1);
// h.update(chunk2);
// let mac: [Byte; 32] = h.finalize();
// ```
//
// =============================================================================

module core.security.mac.hmac;
mount core.*;
mount core.security.hash.sha256.{Sha256, BLOCK_SIZE as SHA256_BLOCK, OUTPUT_SIZE as SHA256_OUTPUT};

// =============================================================================
// HMAC constants — RFC 2104
// =============================================================================

const IPAD: Byte = 0x36;
const OPAD: Byte = 0x5C;

// =============================================================================
// HmacSha256 — streaming HMAC-SHA-256
// =============================================================================

/// Streaming HMAC-SHA-256 — call `update()` zero or more times, then
/// `finalize()` to get the 32-byte MAC.
public type HmacSha256 is {
    /// Inner hash state — accumulates `hash(K_ipad || data)`.
    inner: Sha256,
    /// Outer key (K_opad) kept around until finalize.
    outer_key: [Byte; 64],
};

implement HmacSha256 {
    /// Initialize with `key`. Any key length is accepted — keys longer
    /// than the hash block are pre-hashed per RFC 2104 §2.
    public fn new(key: &[Byte]) -> HmacSha256 {
        // Step 1-2: normalize key to exactly BLOCK_SIZE bytes.
        let mut k: [Byte; 64] = [0; 64];
        if key.len() > SHA256_BLOCK {
            let digest = Sha256.digest(key);
            let mut i = 0;
            while i < SHA256_OUTPUT { k[i] = digest[i]; i = i + 1; }
            // remainder zero-padded (already zeroed)
        } else {
            let mut i = 0;
            while i < key.len() { k[i] = key[i]; i = i + 1; }
            // remainder zero-padded
        }

        // Step 3-4: derive K_ipad, K_opad.
        let mut ipad: [Byte; 64] = [0; 64];
        let mut opad: [Byte; 64] = [0; 64];
        let mut i = 0;
        while i < SHA256_BLOCK {
            ipad[i] = k[i] ^ IPAD;
            opad[i] = k[i] ^ OPAD;
            i = i + 1;
        }

        // Pre-seed inner with K_ipad.
        let mut inner = Sha256.new();
        inner.update(&ipad);

        HmacSha256 {
            inner: inner,
            outer_key: opad,
        }
    }

    /// Feed message bytes into the MAC.
    @inline
    public fn update(&mut self, data: &[Byte]) {
        self.inner.update(data);
    }

    /// Finalize and produce the 32-byte MAC. Consumes self.
    public fn finalize(self) -> [Byte; 32] {
        let inner_digest = self.inner.finalize();
        let mut outer = Sha256.new();
        outer.update(&self.outer_key);
        outer.update(&inner_digest);
        outer.finalize()
    }
}

// =============================================================================
// One-shot helper
// =============================================================================

/// HMAC-SHA-256 over `data` with `key`. Returns 32-byte MAC.
///
/// RFC 4231 test vectors pass byte-exact.
@inline
public fn hmac_sha256(key: &[Byte], data: &[Byte]) -> [Byte; 32] {
    let mut h = HmacSha256.new(key);
    h.update(data);
    h.finalize()
}
