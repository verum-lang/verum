// =============================================================================
// security/mac/hmac.vr — HMAC (RFC 2104) — SHA-256 / SHA-384 / SHA-512
// =============================================================================
// Layer: 2 (depends on hash primitives)
// Dependencies: core.security.hash.{sha256, sha384, sha512}
// Reference: RFC 2104, RFC 4231 (test vectors)
// =============================================================================
//
// Keyed-hash message authentication code, parameterised over the
// underlying hash. This module ships three variants side-by-side;
// downstream protocols pick the one matching their negotiated
// ciphersuite:
//
//   * `HmacSha256` — TLS 1.3 / QUIC `TLS_AES_128_GCM_SHA256`,
//                    `TLS_CHACHA20_POLY1305_SHA256`
//   * `HmacSha384` — TLS 1.3 / QUIC `TLS_AES_256_GCM_SHA384`
//   * `HmacSha512` — Ed25519 pre-hash, HKDF-SHA512, future ciphersuites
//
// The three implementations share the same RFC 2104 algorithm; the
// only differences are the hash primitive, block size, and output
// size. We spell them out independently rather than parameterise
// the state type, because Verum's current type system prefers
// concrete sizes (which reads cleaner at call-sites and gives better
// error messages when a caller mixes up 32- and 48-byte MACs).
//
// # Algorithm (RFC 2104)
//
// ```
// Let B = hash block size
// Let L = hash output size
//
// 1. If len(key) > B:     key = hash(key)
// 2. If len(key) < B:     key = key || 0x00-pad to B bytes
// 3. K_ipad = key XOR 0x36-repeated-B-times
// 4. K_opad = key XOR 0x5C-repeated-B-times
// 5. Output = hash(K_opad || hash(K_ipad || data))
// ```
//
// # Verification — always constant-time
//
// Compare MAC tags with `core.security.util.constant_time_eq`, never
// with `==`. A data-dependent compare opens a timing side channel.
//
// =============================================================================

module core.security.mac.hmac;
mount core.*;
mount core.security.hash.sha1.{Sha1,
    SHA1_BLOCK_SIZE, SHA1_DIGEST_SIZE};
mount core.security.hash.sha256.{Sha256,
    BLOCK_SIZE as SHA256_BLOCK, OUTPUT_SIZE as SHA256_OUTPUT};
mount core.security.hash.sha384.{Sha384,
    BLOCK_SIZE as SHA384_BLOCK, OUTPUT_SIZE as SHA384_OUTPUT};
mount core.security.hash.sha512.{Sha512,
    BLOCK_SIZE as SHA512_BLOCK, OUTPUT_SIZE as SHA512_OUTPUT};

// =============================================================================
// HMAC constants — RFC 2104
// =============================================================================

const IPAD: Byte = 0x36;
const OPAD: Byte = 0x5C;

// =============================================================================
// HmacSha256 — streaming HMAC over SHA-256
// =============================================================================

public type HmacSha256 is {
    inner: Sha256,
    outer_key: [Byte; 64],
};

implement HmacSha256 {
    public fn new(key: &[Byte]) -> HmacSha256 {
        let mut k: [Byte; 64] = [0; 64];
        if key.len() > SHA256_BLOCK {
            let digest = Sha256.digest(key);
            let mut i = 0;
            while i < SHA256_OUTPUT { k[i] = digest[i]; i = i + 1; }
        } else {
            let mut i = 0;
            while i < key.len() { k[i] = key[i]; i = i + 1; }
        }

        let mut ipad: [Byte; 64] = [0; 64];
        let mut opad: [Byte; 64] = [0; 64];
        let mut i = 0;
        while i < SHA256_BLOCK {
            ipad[i] = k[i] ^ IPAD;
            opad[i] = k[i] ^ OPAD;
            i = i + 1;
        }

        let mut inner = Sha256.new();
        inner.update(&ipad);
        HmacSha256 { inner: inner, outer_key: opad }
    }

    @inline
    public fn update(&mut self, data: &[Byte]) {
        self.inner.update(data);
    }

    public fn finalize(self) -> [Byte; 32] {
        let inner_digest = self.inner.finalize();
        let mut outer = Sha256.new();
        outer.update(&self.outer_key);
        outer.update(&inner_digest);
        outer.finalize()
    }
}

/// One-shot HMAC-SHA-256. RFC 4231 vectors pass byte-exact.
@inline
public fn hmac_sha256(key: &[Byte], data: &[Byte]) -> [Byte; 32] {
    let mut h = HmacSha256.new(key);
    h.update(data);
    h.finalize()
}

// =============================================================================
// HmacSha384 — streaming HMAC over SHA-384
// =============================================================================

public type HmacSha384 is {
    inner: Sha384,
    outer_key: [Byte; 128],
};

implement HmacSha384 {
    public fn new(key: &[Byte]) -> HmacSha384 {
        let mut k: [Byte; 128] = [0; 128];
        if key.len() > SHA384_BLOCK {
            let digest = Sha384.digest(key);
            let mut i = 0;
            while i < SHA384_OUTPUT { k[i] = digest[i]; i = i + 1; }
        } else {
            let mut i = 0;
            while i < key.len() { k[i] = key[i]; i = i + 1; }
        }

        let mut ipad: [Byte; 128] = [0; 128];
        let mut opad: [Byte; 128] = [0; 128];
        let mut i = 0;
        while i < SHA384_BLOCK {
            ipad[i] = k[i] ^ IPAD;
            opad[i] = k[i] ^ OPAD;
            i = i + 1;
        }

        let mut inner = Sha384.new();
        inner.update(&ipad);
        HmacSha384 { inner: inner, outer_key: opad }
    }

    @inline
    public fn update(&mut self, data: &[Byte]) {
        self.inner.update(data);
    }

    public fn finalize(self) -> [Byte; 48] {
        let inner_digest = self.inner.finalize();
        let mut outer = Sha384.new();
        outer.update(&self.outer_key);
        outer.update(&inner_digest);
        outer.finalize()
    }
}

/// One-shot HMAC-SHA-384. RFC 4231 vectors pass byte-exact.
@inline
public fn hmac_sha384(key: &[Byte], data: &[Byte]) -> [Byte; 48] {
    let mut h = HmacSha384.new(key);
    h.update(data);
    h.finalize()
}

// =============================================================================
// HmacSha512 — streaming HMAC over SHA-512
// =============================================================================

public type HmacSha512 is {
    inner: Sha512,
    outer_key: [Byte; 128],
};

implement HmacSha512 {
    public fn new(key: &[Byte]) -> HmacSha512 {
        let mut k: [Byte; 128] = [0; 128];
        if key.len() > SHA512_BLOCK {
            let digest = Sha512.digest(key);
            let mut i = 0;
            while i < SHA512_OUTPUT { k[i] = digest[i]; i = i + 1; }
        } else {
            let mut i = 0;
            while i < key.len() { k[i] = key[i]; i = i + 1; }
        }

        let mut ipad: [Byte; 128] = [0; 128];
        let mut opad: [Byte; 128] = [0; 128];
        let mut i = 0;
        while i < SHA512_BLOCK {
            ipad[i] = k[i] ^ IPAD;
            opad[i] = k[i] ^ OPAD;
            i = i + 1;
        }

        let mut inner = Sha512.new();
        inner.update(&ipad);
        HmacSha512 { inner: inner, outer_key: opad }
    }

    @inline
    public fn update(&mut self, data: &[Byte]) {
        self.inner.update(data);
    }

    public fn finalize(self) -> [Byte; 64] {
        let inner_digest = self.inner.finalize();
        let mut outer = Sha512.new();
        outer.update(&self.outer_key);
        outer.update(&inner_digest);
        outer.finalize()
    }
}

/// One-shot HMAC-SHA-512. RFC 4231 vectors pass byte-exact.
@inline
public fn hmac_sha512(key: &[Byte], data: &[Byte]) -> [Byte; 64] {
    let mut h = HmacSha512.new(key);
    h.update(data);
    h.finalize()
}

// =============================================================================
// HmacSha1 — streaming HMAC over SHA-1 (V8 #247)
// =============================================================================
//
// SHA-1 is cryptographically broken for digital-signature purposes
// (Wang-Yin 2005 collision attack; SHATTERED 2017). HMAC-SHA-1 is
// **not** broken in the same way — HMAC's bidirectional construction
// resists collision attacks even when the underlying hash is
// collision-vulnerable. RFC 6151 (2011) reaffirms HMAC-SHA-1 as
// secure for message authentication.
//
// Use cases:
//   • RFC 6238 TOTP / RFC 4226 HOTP — Sha1 is the default, baseline-
//     compatible across legacy authenticators.
//   • RFC 6455 WebSocket Sec-WebSocket-Accept handshake.
//   • TLS 1.0/1.1 PRF (legacy interop only — TLS 1.2+ uses SHA-256).
//
// Do NOT use for new digital-signature constructions; prefer SHA-256.
// =============================================================================

public type HmacSha1 is {
    inner: Sha1,
    outer_key: [Byte; 64],
};

implement HmacSha1 {
    public fn new(key: &[Byte]) -> HmacSha1 {
        let mut k: [Byte; 64] = [0; 64];
        if key.len() > SHA1_BLOCK_SIZE {
            let digest = Sha1.digest(key);
            let mut i = 0;
            while i < SHA1_DIGEST_SIZE { k[i] = digest[i]; i = i + 1; }
        } else {
            let mut i = 0;
            while i < key.len() { k[i] = key[i]; i = i + 1; }
        }

        let mut ipad: [Byte; 64] = [0; 64];
        let mut opad: [Byte; 64] = [0; 64];
        let mut i = 0;
        while i < SHA1_BLOCK_SIZE {
            ipad[i] = k[i] ^ IPAD;
            opad[i] = k[i] ^ OPAD;
            i = i + 1;
        }

        let mut inner = Sha1.new();
        inner.update(&ipad);
        HmacSha1 { inner: inner, outer_key: opad }
    }

    @inline
    public fn update(&mut self, data: &[Byte]) {
        self.inner.update(data);
    }

    public fn finalize(self) -> [Byte; 20] {
        let inner_digest = self.inner.finalize();
        let mut outer = Sha1.new();
        outer.update(&self.outer_key);
        outer.update(&inner_digest);
        outer.finalize()
    }
}

/// One-shot HMAC-SHA-1. RFC 2202 test vectors pass byte-exact.
///
/// HMAC-SHA-1 is acceptable for message authentication (RFC 6151
/// 2011) despite SHA-1 being broken for digital-signature purposes.
/// Prefer `hmac_sha256` for new constructions.
@inline
public fn hmac_sha1(key: &[Byte], data: &[Byte]) -> [Byte; 20] {
    let mut h = HmacSha1.new(key);
    h.update(data);
    h.finalize()
}
