// =============================================================================
// security/kdf/pbkdf2.vr — PBKDF2 (RFC 2898 / RFC 8018)
// =============================================================================
// Layer: 3 (Security — key derivation)
// Dependencies: core, core.collections, core.security.mac.hmac
// =============================================================================
//
// RFC 8018 §5.2 — Password-Based Key Derivation Function 2. The
// FIPS-approved baseline KDF; still dominant for WPA2, WebCrypto,
// and in-database password stretching (SCRAM family).
//
// Memory-hard alternatives (Argon2id, scrypt) are stronger against
// GPU/ASIC attacks and are what new deployments should reach for —
// but PBKDF2 remains the required fallback under FIPS 140.
//
// # API
//
//   pbkdf2_hmac_sha256(password, salt, iterations, out_len) -> List<Byte>
//   pbkdf2_hmac_sha384(password, salt, iterations, out_len) -> List<Byte>
//   pbkdf2_hmac_sha512(password, salt, iterations, out_len) -> List<Byte>
//
// # Recommended parameters (NIST SP 800-63B, as of 2026)
//
//   HMAC-SHA256 — ≥ 600_000 iterations for interactive auth.
//   HMAC-SHA512 — ≥ 210_000 iterations (one hash block larger).
//
// =============================================================================

module core.security.kdf.pbkdf2;

mount core.*;
mount core.collections.List;
mount core.security.mac.hmac.{hmac_sha256, hmac_sha384, hmac_sha512};

public type Pbkdf2Error is
      OutputTooLong
    | BadIterations
    | BadOutputLength;

// Display + Debug + Eq for Pbkdf2Error — standard
// stdlib protocol impls.  Pre-fix had no impls; callers
// wanting to log/format/compare these errors had to roll
// their own match block.

implement Display for Pbkdf2Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Pbkdf2Error.OutputTooLong   =>
                f.write_str("PBKDF2 output length exceeds platform limit"),
            Pbkdf2Error.BadIterations   =>
                f.write_str("PBKDF2 iteration count outside permitted range"),
            Pbkdf2Error.BadOutputLength =>
                f.write_str("PBKDF2 output length must be > 0"),
        }
    }
}

implement Debug for Pbkdf2Error {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Pbkdf2Error.OutputTooLong   => f.write_str("OutputTooLong"),
            Pbkdf2Error.BadIterations   => f.write_str("BadIterations"),
            Pbkdf2Error.BadOutputLength => f.write_str("BadOutputLength"),
        }
    }
}

implement Eq for Pbkdf2Error {
    fn eq(&self, other: &Pbkdf2Error) -> Bool {
        match (self, other) {
            (Pbkdf2Error.OutputTooLong,   Pbkdf2Error.OutputTooLong)   => true,
            (Pbkdf2Error.BadIterations,   Pbkdf2Error.BadIterations)   => true,
            (Pbkdf2Error.BadOutputLength, Pbkdf2Error.BadOutputLength) => true,
            _ => false,
        }
    }
}

/// Max output length per RFC 8018 §5.2: (2^32 - 1) × hLen bytes.
/// For HMAC-SHA256 (hLen = 32) this is ~137 GiB — we cap at
/// 1 MiB in this API to keep List<Byte> allocation sane.
const MAX_OUT_LEN: Int = 1_048_576;

/// Maximum permitted iteration count.  Without this, callers passing
/// attacker-controlled iteration counts (e.g. parsed from a PHC
/// string, JWT header, or wire-format key descriptor) could pin
/// CPU on a single derive call.  10M is well above OWASP 2023
/// recommendations (600k for SHA-256, 210k for SHA-512) and any
/// realistic deployment, but bounded enough to keep verify-time
/// on the order of seconds.  Mirrors the matching cap at the
/// password_hash wrapper layer (fe510d3d).
public const MAX_PBKDF2_ITERATIONS: UInt32 = 10_000_000_u32;

// =============================================================================
// HMAC-SHA256
// =============================================================================

public fn pbkdf2_hmac_sha256(
    password:   &[Byte],
    salt:       &[Byte],
    iterations: UInt32,
    out_len:    Int,
) -> Result<List<Byte>, Pbkdf2Error> {
    if out_len <= 0 || out_len > MAX_OUT_LEN { return Err(Pbkdf2Error.BadOutputLength); }
    if iterations == 0_u32 || iterations > MAX_PBKDF2_ITERATIONS {
        return Err(Pbkdf2Error.BadIterations);
    }
    pbkdf2_inner(password, salt, iterations, out_len, PRF.Sha256)
}

public fn pbkdf2_hmac_sha384(
    password:   &[Byte],
    salt:       &[Byte],
    iterations: UInt32,
    out_len:    Int,
) -> Result<List<Byte>, Pbkdf2Error> {
    if out_len <= 0 || out_len > MAX_OUT_LEN { return Err(Pbkdf2Error.BadOutputLength); }
    if iterations == 0_u32 || iterations > MAX_PBKDF2_ITERATIONS {
        return Err(Pbkdf2Error.BadIterations);
    }
    pbkdf2_inner(password, salt, iterations, out_len, PRF.Sha384)
}

public fn pbkdf2_hmac_sha512(
    password:   &[Byte],
    salt:       &[Byte],
    iterations: UInt32,
    out_len:    Int,
) -> Result<List<Byte>, Pbkdf2Error> {
    if out_len <= 0 || out_len > MAX_OUT_LEN { return Err(Pbkdf2Error.BadOutputLength); }
    if iterations == 0_u32 || iterations > MAX_PBKDF2_ITERATIONS {
        return Err(Pbkdf2Error.BadIterations);
    }
    pbkdf2_inner(password, salt, iterations, out_len, PRF.Sha512)
}

// =============================================================================
// Core engine
// =============================================================================

type PRF is Sha256 | Sha384 | Sha512;

fn hlen(prf: &PRF) -> Int {
    match prf {
        PRF.Sha256 => 32,
        PRF.Sha384 => 48,
        PRF.Sha512 => 64,
    }
}

fn prf_eval(prf: &PRF, key: &[Byte], msg: &[Byte]) -> List<Byte> {
    match prf {
        PRF.Sha256 => {
            let d = hmac_sha256(key, msg);
            bytes_of(&d[..])
        },
        PRF.Sha384 => {
            let d = hmac_sha384(key, msg);
            bytes_of(&d[..])
        },
        PRF.Sha512 => {
            let d = hmac_sha512(key, msg);
            bytes_of(&d[..])
        },
    }
}

fn pbkdf2_inner(
    password:   &[Byte],
    salt:       &[Byte],
    iterations: UInt32,
    out_len:    Int,
    prf:        PRF,
) -> Result<List<Byte>, Pbkdf2Error> {
    let h_len = hlen(&prf);
    // Number of blocks required.
    let num_blocks = (out_len + h_len - 1) / h_len;

    let mut out: List<Byte> = [];
    let mut block_idx: UInt32 = 1_u32;
    while (block_idx as Int) <= num_blocks {
        // U_1 = PRF(password, salt || INT(block_idx))
        let mut salt_with_idx: List<Byte> = List.with_capacity(salt.len() + 4);
        salt_with_idx.extend_from_slice(salt);
        salt_with_idx.push(((block_idx >> 24_u32) & 0xFF_u32) as Byte);
        salt_with_idx.push(((block_idx >> 16_u32) & 0xFF_u32) as Byte);
        salt_with_idx.push(((block_idx >>  8_u32) & 0xFF_u32) as Byte);
        salt_with_idx.push((block_idx & 0xFF_u32) as Byte);

        let mut u = prf_eval(&prf, password, salt_with_idx.as_slice());
        let mut t_block = clone_bytes(u.as_slice());

        // U_i = PRF(password, U_{i-1}); T_j = U_1 XOR U_2 XOR ... XOR U_c.
        let mut i: UInt32 = 1_u32;
        while i < iterations {
            u = prf_eval(&prf, password, u.as_slice());
            xor_into(&mut t_block, u.as_slice());
            i = i + 1_u32;
        }

        // Append up to hLen bytes (last block may truncate).
        let start = out.len();
        let remaining = out_len - start;
        let take = if remaining < h_len { remaining } else { h_len };
        out.extend_from_slice(&t_block.as_slice()[..take]);

        block_idx = block_idx + 1_u32;
    }
    Ok(out)
}

// =============================================================================
// Helpers
// =============================================================================

fn bytes_of(src: &[Byte]) -> List<Byte> {
    let mut out: List<Byte> = List.with_capacity(src.len());
    out.extend_from_slice(src);
    out
}

fn clone_bytes(src: &[Byte]) -> List<Byte> { bytes_of(src) }

fn xor_into(dst: &mut List<Byte>, src: &[Byte]) {
    let mut i: Int = 0;
    while i < dst.len() && i < src.len() {
        dst[i] = dst[i] ^ src[i];
        i = i + 1;
    }
}
