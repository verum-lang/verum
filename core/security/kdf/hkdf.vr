// =============================================================================
// security/kdf/hkdf.vr — HKDF (RFC 5869) — SHA-256 / SHA-384 / SHA-512
// =============================================================================
// Layer: 2 (depends on HMAC primitive)
// Dependencies: core.security.mac.hmac
// Reference: RFC 5869, NIST SP 800-56C Rev.2
// =============================================================================
//
// Two-stage HMAC-based key-derivation function:
//
//   1. `hkdf_extract_*(salt, ikm)` — compresses low-entropy input
//      keying material (IKM) into a fixed-length pseudorandom key
//      (PRK). `salt` can be empty (treated as an all-zeros HashLen
//      salt per RFC 5869 §2.2).
//
//   2. `hkdf_expand_*(prk, info, length, out)` — expands the PRK into
//      `length` bytes of output keyed by the optional `info` context
//      string. Up to 255 × HashLen bytes total.
//
// # Three variants, one algorithm
//
// The algorithm is identical across hash primitives; only the HashLen
// output size varies. We ship explicit entry-points per variant
// because call-sites benefit from the fixed-size return type of the
// `extract` stage:
//
//   | Hash     | HashLen | hkdf_extract_* | Extract return    |
//   |----------|---------|----------------|-------------------|
//   | SHA-256  | 32      | _sha256        | [Byte; 32]        |
//   | SHA-384  | 48      | _sha384        | [Byte; 48]        |
//   | SHA-512  | 64      | _sha512        | [Byte; 64]        |
//
// `expand` consumes the PRK by slice + writes to `List<Byte>`, so it
// is variant-aware only through its `HashLen` constant.
//
// # TLS 1.3 + QUIC HKDF-Expand-Label
//
// Both protocols layer a "HKDF-Expand-Label" macro on top of
// `hkdf_expand` — a fixed label-schema that gets hashed with the
// context to form the `info` parameter. That macro lives in
// `core/net/tls.vr` (and will be re-used by `core/net/quic/crypto`)
// because the label set is protocol-specific; this file keeps the
// primitive pure.
//
// =============================================================================

module core.security.kdf.hkdf;
mount core.*;
mount core.security.mac.hmac.{
    HmacSha256, hmac_sha256,
    HmacSha384, hmac_sha384,
    HmacSha512, hmac_sha512,
};
mount core.security.hash.sha256.OUTPUT_SIZE as SHA256_LEN;
mount core.security.hash.sha384.OUTPUT_SIZE as SHA384_LEN;
mount core.security.hash.sha512.OUTPUT_SIZE as SHA512_LEN;

// =============================================================================
// Common errors
// =============================================================================

public type HkdfError is
    | OutputTooLong { requested: Int, limit: Int }
    | InvalidPrk { len: Int };

// =============================================================================
// SHA-256 variant
// =============================================================================

/// Maximum expand output — RFC 5869 §2.3: 255 × HashLen.
pub const MAX_EXPAND_OUTPUT_256: Int = 255 * 32;

public fn hkdf_extract_sha256(salt: &[Byte], ikm: &[Byte]) -> [Byte; 32] {
    if salt.len() == 0 {
        let zero: [Byte; 32] = [0; 32];
        hmac_sha256(&zero, ikm)
    } else {
        hmac_sha256(salt, ikm)
    }
}

public fn hkdf_expand_sha256(
    prk: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    if prk.len() < SHA256_LEN {
        return Err(HkdfError.InvalidPrk { len: prk.len() });
    }
    if length > MAX_EXPAND_OUTPUT_256 {
        return Err(HkdfError.OutputTooLong { requested: length, limit: MAX_EXPAND_OUTPUT_256 });
    }
    if length <= 0 { return Ok(()); }

    let n_blocks = (length + SHA256_LEN - 1) / SHA256_LEN;
    let mut t_prev: [Byte; 32] = [0; 32];
    let mut produced = 0;

    let mut i = 1;
    while i <= n_blocks {
        let mut mac = HmacSha256.new(prk);
        if i > 1 { mac.update(&t_prev); }
        mac.update(info);
        let ctr: [Byte; 1] = [i as Byte];
        mac.update(&ctr);
        let t_i = mac.finalize();

        let take = if produced + SHA256_LEN > length { length - produced } else { SHA256_LEN };
        let mut j = 0;
        while j < take { out.push(t_i[j]); j = j + 1; }
        produced = produced + take;

        let mut k = 0;
        while k < SHA256_LEN { t_prev[k] = t_i[k]; k = k + 1; }
        i = i + 1;
    }
    Ok(())
}

/// Combined HKDF-SHA-256 — extract + expand in one call.
public fn hkdf_sha256(
    salt: &[Byte],
    ikm: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    let prk = hkdf_extract_sha256(salt, ikm);
    hkdf_expand_sha256(&prk, info, length, out)
}

// =============================================================================
// SHA-384 variant
// =============================================================================

pub const MAX_EXPAND_OUTPUT_384: Int = 255 * 48;

public fn hkdf_extract_sha384(salt: &[Byte], ikm: &[Byte]) -> [Byte; 48] {
    if salt.len() == 0 {
        let zero: [Byte; 48] = [0; 48];
        hmac_sha384(&zero, ikm)
    } else {
        hmac_sha384(salt, ikm)
    }
}

public fn hkdf_expand_sha384(
    prk: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    if prk.len() < SHA384_LEN {
        return Err(HkdfError.InvalidPrk { len: prk.len() });
    }
    if length > MAX_EXPAND_OUTPUT_384 {
        return Err(HkdfError.OutputTooLong { requested: length, limit: MAX_EXPAND_OUTPUT_384 });
    }
    if length <= 0 { return Ok(()); }

    let n_blocks = (length + SHA384_LEN - 1) / SHA384_LEN;
    let mut t_prev: [Byte; 48] = [0; 48];
    let mut produced = 0;

    let mut i = 1;
    while i <= n_blocks {
        let mut mac = HmacSha384.new(prk);
        if i > 1 { mac.update(&t_prev); }
        mac.update(info);
        let ctr: [Byte; 1] = [i as Byte];
        mac.update(&ctr);
        let t_i = mac.finalize();

        let take = if produced + SHA384_LEN > length { length - produced } else { SHA384_LEN };
        let mut j = 0;
        while j < take { out.push(t_i[j]); j = j + 1; }
        produced = produced + take;

        let mut k = 0;
        while k < SHA384_LEN { t_prev[k] = t_i[k]; k = k + 1; }
        i = i + 1;
    }
    Ok(())
}

public fn hkdf_sha384(
    salt: &[Byte],
    ikm: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    let prk = hkdf_extract_sha384(salt, ikm);
    hkdf_expand_sha384(&prk, info, length, out)
}

// =============================================================================
// SHA-512 variant
// =============================================================================

pub const MAX_EXPAND_OUTPUT_512: Int = 255 * 64;

public fn hkdf_extract_sha512(salt: &[Byte], ikm: &[Byte]) -> [Byte; 64] {
    if salt.len() == 0 {
        let zero: [Byte; 64] = [0; 64];
        hmac_sha512(&zero, ikm)
    } else {
        hmac_sha512(salt, ikm)
    }
}

public fn hkdf_expand_sha512(
    prk: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    if prk.len() < SHA512_LEN {
        return Err(HkdfError.InvalidPrk { len: prk.len() });
    }
    if length > MAX_EXPAND_OUTPUT_512 {
        return Err(HkdfError.OutputTooLong { requested: length, limit: MAX_EXPAND_OUTPUT_512 });
    }
    if length <= 0 { return Ok(()); }

    let n_blocks = (length + SHA512_LEN - 1) / SHA512_LEN;
    let mut t_prev: [Byte; 64] = [0; 64];
    let mut produced = 0;

    let mut i = 1;
    while i <= n_blocks {
        let mut mac = HmacSha512.new(prk);
        if i > 1 { mac.update(&t_prev); }
        mac.update(info);
        let ctr: [Byte; 1] = [i as Byte];
        mac.update(&ctr);
        let t_i = mac.finalize();

        let take = if produced + SHA512_LEN > length { length - produced } else { SHA512_LEN };
        let mut j = 0;
        while j < take { out.push(t_i[j]); j = j + 1; }
        produced = produced + take;

        let mut k = 0;
        while k < SHA512_LEN { t_prev[k] = t_i[k]; k = k + 1; }
        i = i + 1;
    }
    Ok(())
}

public fn hkdf_sha512(
    salt: &[Byte],
    ikm: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    let prk = hkdf_extract_sha512(salt, ikm);
    hkdf_expand_sha512(&prk, info, length, out)
}
