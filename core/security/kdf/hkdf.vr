// =============================================================================
// security/kdf/hkdf.vr — HKDF-SHA-256 (RFC 5869)
// =============================================================================
// Layer: 3 (depends on hmac)
// Dependencies: core.security.mac.hmac
// Reference: RFC 5869, Appendix A (test vectors)
// =============================================================================
//
// HMAC-based Key Derivation Function. Two-step: extract (compress high-
// entropy input to a uniform pseudorandom key) + expand (generate
// arbitrary-length output from that key). Used in TLS 1.3 key schedule,
// QUIC-TLS, Noise Protocol, SPIFFE JWT validation.
//
// # Algorithm (RFC 5869)
//
// ```
// extract:
//     salt := salt or zero-filled(HASH_LEN)
//     PRK := HMAC-Hash(salt, IKM)
//
// expand:
//     N = ceil(L / HASH_LEN)
//     T[0] = ""
//     T[i] = HMAC-Hash(PRK, T[i-1] || info || i)    for i = 1..N
//     OKM = T[1] || T[2] || ... || T[N]  (truncated to L bytes)
// ```
//
// # Usage
//
// ```verum
// // Common pattern — do both in one call:
// let mut out: List<Byte> = List.with_capacity(42);
// hkdf_sha256(&salt, &ikm, &info, 42, &mut out)?;
//
// // Or step-by-step for efficiency when reusing PRK:
// let prk: [Byte; 32] = hkdf_extract_sha256(&salt, &ikm);
// hkdf_expand_sha256(&prk, &info_1, &mut out_1, 32)?;
// hkdf_expand_sha256(&prk, &info_2, &mut out_2, 48)?;
// ```
//
// =============================================================================

module core.security.kdf.hkdf;
mount core.*;
mount core.security.mac.hmac.{HmacSha256, hmac_sha256};
mount core.security.hash.sha256.OUTPUT_SIZE as HASH_LEN;

// =============================================================================
// HKDF-Extract — compress IKM to uniform PRK
// =============================================================================

/// RFC 5869 §2.2 — compress input keying material to a 32-byte
/// pseudorandom key. `salt` may be empty (uses an all-zeros salt
/// per the spec).
public fn hkdf_extract_sha256(salt: &[Byte], ikm: &[Byte]) -> [Byte; 32] {
    if salt.len() == 0 {
        let zero_salt: [Byte; 32] = [0; 32];
        hmac_sha256(&zero_salt, ikm)
    } else {
        hmac_sha256(salt, ikm)
    }
}

// =============================================================================
// HKDF-Expand — derive output of arbitrary length
// =============================================================================

/// Maximum output length per RFC 5869 §2.3: 255 × HashLen.
/// For SHA-256: 255 × 32 = 8160 bytes.
public const MAX_EXPAND_OUTPUT: Int = 255 * 32;

public type HkdfError is
    | OutputTooLong { requested: Int, limit: Int }
    | InvalidPrk { len: Int };

/// RFC 5869 §2.3 — expand `prk` into `out` with optional context `info`.
/// `out.len()` determines how much material is produced, up to 8160 bytes.
///
/// The output buffer is appended to (push_back); callers can reserve
/// capacity upfront for zero-allocation expansion.
public fn hkdf_expand_sha256(
    prk: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    if prk.len() < HASH_LEN {
        return Err(HkdfError.InvalidPrk { len: prk.len() });
    }
    if length > MAX_EXPAND_OUTPUT {
        return Err(HkdfError.OutputTooLong {
            requested: length,
            limit: MAX_EXPAND_OUTPUT,
        });
    }
    if length <= 0 { return Ok(()); }

    // N = ceil(length / HASH_LEN)
    let n_blocks = (length + HASH_LEN - 1) / HASH_LEN;

    // T(i) chain.
    let mut t_prev: [Byte; 32] = [0; 32];
    let mut produced = 0;

    let mut i = 1;
    while i <= n_blocks {
        // T(i) = HMAC(PRK, T(i-1) || info || counter_byte)
        let mut mac = HmacSha256.new(prk);
        if i > 1 {
            mac.update(&t_prev);
        }
        mac.update(info);
        // Single-byte counter; i is always 1..=255 guaranteed by
        // the N ≤ 255 check in the length-limit logic above.
        let ctr: [Byte; 1] = [i as Byte];
        mac.update(&ctr);
        let t_i = mac.finalize();

        // Append to output, truncating last block if needed.
        let take = if produced + HASH_LEN > length {
            length - produced
        } else {
            HASH_LEN
        };
        let mut j = 0;
        while j < take { out.push(t_i[j]); j = j + 1; }
        produced = produced + take;

        // Chain: T(i) becomes T(i-1) for next iteration.
        let mut k = 0;
        while k < HASH_LEN { t_prev[k] = t_i[k]; k = k + 1; }

        i = i + 1;
    }

    Ok(())
}

// =============================================================================
// One-shot HKDF (extract + expand combined)
// =============================================================================

/// RFC 5869 §2 combined extract+expand. Convenience wrapper when PRK
/// is single-use.
public fn hkdf_sha256(
    salt: &[Byte],
    ikm: &[Byte],
    info: &[Byte],
    length: Int,
    out: &mut List<Byte>,
) -> Result<(), HkdfError> {
    let prk = hkdf_extract_sha256(salt, ikm);
    hkdf_expand_sha256(&prk, info, length, out)
}
