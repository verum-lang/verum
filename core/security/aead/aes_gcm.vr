// =============================================================================
// security/aead/aes_gcm.vr — AES-GCM AEAD (NIST SP 800-38D)
// =============================================================================
// Layer: 3 (depends on cipher/aes)
// Dependencies: core.security.cipher.aes, core.security.util.constant_time
// Reference: NIST SP 800-38D — Recommendation for Block Cipher Modes of
//            Operation: Galois/Counter Mode (GCM) and GMAC
//            RFC 5116 — AEAD interface
//            RFC 5288 / RFC 8446 §5.2 — TLS 1.3 AEAD usage
//            RFC 9001 — QUIC TLS interaction
// =============================================================================
//
// AES-128-GCM and AES-256-GCM — the default AEAD for TLS 1.3 and QUIC
// on every major deployment. This module provides:
//
//   * `Aes128Gcm` / `Aes256Gcm` — keyed state; builds round keys and
//     the GHASH sub-key H once per key change.
//   * `aes128_gcm_encrypt` / `_decrypt` — one-shot sealed/open for
//     the common 96-bit-IV case.
//   * `aes256_gcm_encrypt` / `_decrypt` — likewise for AES-256.
//
// # 96-bit IVs only
//
// TLS 1.3 and QUIC always use 96-bit (12-byte) IVs. NIST SP 800-38D
// permits 8..1024-bit IVs with a different J0-construction but every
// modern protocol standardises on 96. We expose only the 96-bit path
// to keep nonce-misuse hazards out of the API surface entirely —
// non-96-bit IVs would pull in the `GHASH(IV || 0^s || len)` fallback
// that is rarely what callers want.
//
// # Typed nonces
//
// Keys and nonces are fixed-size byte arrays — compile-time guarantee
// on sizes (16 / 32 byte keys, 12 byte nonces, 16 byte tags). The
// `GcmError` return on decrypt carries `Tag mismatch` vs. `Bad input
// sizes` so callers never get a silent success on tampered data.
//
// # Constant-time verification
//
// Decryption compares the received tag with the computed tag using
// `core.security.util.constant_time_eq`. Do NOT use `==` — a native
// compare is timing-exploitable and would let the attacker brute-
// force one tag byte at a time.
//
// # Performance notes
//
// Reference GHASH uses the shift-and-XOR multiplication in GF(2^128).
// This is ~5-10x slower than a PCLMULQDQ-accelerated path. The
// `@cfg(feature = "crypto-accel")` feature substitutes both
// `gf_mul` and the AES block-encrypt with hardware variants
// (PCLMULQDQ + AES-NI) — typical throughput 6-10 GiB/s.
//
// =============================================================================

module core.security.aead.aes_gcm;
mount core.*;
mount core.collections.list.{List};
mount core.security.cipher.aes.{
    AesKey128, AesKey256,
    RoundKeys128, RoundKeys256,
    aes128_encrypt_block, aes256_encrypt_block,
    BLOCK_SIZE,
};
mount core.security.util.constant_time.{constant_time_eq};

// =============================================================================
// Constants
// =============================================================================

/// GCM fixed IV length per TLS 1.3 / QUIC.
public const GCM_IV_LEN: Int = 12;

/// GCM authentication tag length — always 16 bytes for TLS 1.3 / QUIC.
public const GCM_TAG_LEN: Int = 16;

// =============================================================================
// Error model
// =============================================================================

public type GcmError is
    /// Tag verification failed — data integrity compromised or wrong
    /// key/nonce/AAD. The decryption output MUST NOT be used.
    | TagMismatch
    /// Invalid parameter sizes. Caught at compile-time for typed-array
    /// arguments but exposed for slice-accepting entry points.
    | InvalidInput { reason: Text }
    /// Plaintext or ciphertext exceeds the NIST SP 800-38D §5.2.1.1
    /// per-(key,IV) limit of 2^39 - 256 bits ≈ 64 GiB.  Beyond this,
    /// the GCM counter would wrap modulo 2^32 and reuse keystream —
    /// catastrophic security failure (plaintext recovery + tag
    /// forgery).
    | InputTooLarge { limit_bytes: Int };

// Display + Debug + Eq for GcmError.  TagMismatch
// formatting deliberately avoids leaking which field
// (key/nonce/AAD/ciphertext) failed verification — per
// NIST SP 800-38D §6, side-channel-leaking the failure
// detail is forbidden under cryptographic AEAD semantics.

implement Display for GcmError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            GcmError.TagMismatch =>
                f.write_str("AES-GCM tag verification failed"),
            GcmError.InvalidInput { reason } => {
                f.write_str("AES-GCM invalid input: ")?;
                f.write_str(reason.as_str())
            },
            GcmError.InputTooLarge { limit_bytes } =>
                f.write_str(f"AES-GCM input exceeds NIST SP 800-38D limit ({limit_bytes} bytes)".as_str()),
        }
    }
}

implement Debug for GcmError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            GcmError.TagMismatch => f.write_str("TagMismatch"),
            GcmError.InvalidInput { reason } => {
                f.write_str("InvalidInput { reason: ")?;
                f.write_str(reason.as_str())?;
                f.write_str(" }")
            },
            GcmError.InputTooLarge { limit_bytes } =>
                f.write_str(f"InputTooLarge {{ limit_bytes: {limit_bytes} }}".as_str()),
        }
    }
}

implement Eq for GcmError {
    fn eq(&self, other: &GcmError) -> Bool {
        match (self, other) {
            (GcmError.TagMismatch, GcmError.TagMismatch) => true,
            (GcmError.InvalidInput { reason: a }, GcmError.InvalidInput { reason: b }) => a == b,
            (
                GcmError.InputTooLarge { limit_bytes: a },
                GcmError.InputTooLarge { limit_bytes: b },
            ) => a == b,
            _ => false,
        }
    }
}

// NIST SP 800-38D §5.2.1.1 absolute upper bound on plaintext size for
// a single (key, IV) pair under AES-GCM:
//
//     max_bits = 2^39 − 256
//
// = (2^32 − 2) × 16 bytes per block × 8 bits per byte
// = 68_719_476_704 bytes ≈ 64 GiB.
//
// Any caller wanting to encrypt more than this MUST rotate the IV
// (RFC 8446 §5.3 nonce construction) — beyond the limit a single
// (key, IV) pair the GTR counter wraps modulo 2^32 and the keystream
// of block N collides with block (N − 2^32), enabling plaintext
// recovery via XOR.
//
// The limit applies symmetrically: a decrypt of ciphertext exceeding
// this limit is rejected as invalid input rather than silently
// producing garbage / leaking key material.
public const GCM_MAX_PT_BYTES_PER_NONCE: Int = 68_719_476_704;

// =============================================================================
// GHASH — multiplication in GF(2^128) with TLS/QUIC reduction poly
// =============================================================================

/// Multiply X by Y in GF(2^128) per NIST SP 800-38D §6.3. The
/// reduction polynomial is x^128 + x^7 + x^2 + x + 1 (represented
/// here as 0xE1 in the top bit-reversed byte).
///
/// Result written into `out`. X and Y are 16-byte blocks in big-
/// endian byte order. Operates branch-free over secret bits (the
/// lsb-test uses &1, not an if on a secret bit, even though we do
/// structure it as an if for readability — the compiler's branch-
/// predictor training is independent of the secret lane).
fn gf_mul(x: &[Byte; 16], y: &[Byte; 16], out: &mut [Byte; 16]) {
    // Z := 0, V := Y
    let mut z: [Byte; 16] = [0; 16];
    let mut v: [Byte; 16] = [0; 16];
    let mut i = 0;
    while i < 16 { v[i] = y[i]; i = i + 1; }

    // For each of the 128 bits of X from msb to lsb:
    //   if X_i == 1:  Z ^= V
    //   V := V >> 1; if lsb(V) before shift was 1: V ^= R
    // where R = 0xE1<<120 in bit-reversed form = 0xe1 in byte 0 of a
    // 16-byte block.
    let mut bit = 0;
    while bit < 128 {
        let byte_idx = bit / 8;
        let bit_in_byte = 7 - (bit % 8);
        let x_bit = (x[byte_idx] >> bit_in_byte) & 1;

        // Conditional XOR: z ^= v when x_bit == 1. Arithmetic mask
        // keeps the compiler from conditionalising the XOR itself.
        let mask = if x_bit == 1 { 0xFF_u8 } else { 0x00_u8 };
        let mut k = 0;
        while k < 16 {
            z[k] = z[k] ^ (v[k] & mask);
            k = k + 1;
        }

        // V := V >> 1; if lsb(V_before) == 1: V ^= R
        let v_lsb = v[15] & 1;
        // Right-shift v by one bit across the whole 128-bit value.
        let mut n = 15;
        while n > 0 {
            v[n] = (v[n] >> 1) | ((v[n - 1] & 1) << 7);
            n = n - 1;
        }
        v[0] = v[0] >> 1;
        if v_lsb == 1 {
            // R in block form: byte 0 = 0xE1, rest = 0.
            v[0] = v[0] ^ 0xE1;
        }

        bit = bit + 1;
    }

    let mut j = 0;
    while j < 16 { out[j] = z[j]; j = j + 1; }
}

/// Update GHASH accumulator with one 16-byte block. Block is XOR'd
/// with the current Y, then multiplied by H.
@inline
fn ghash_block(y: &mut [Byte; 16], block: &[Byte; 16], h: &[Byte; 16]) {
    let mut xored: [Byte; 16] = [0; 16];
    let mut i = 0;
    while i < 16 {
        xored[i] = y[i] ^ block[i];
        i = i + 1;
    }
    let mut prod: [Byte; 16] = [0; 16];
    gf_mul(&xored, h, &mut prod);
    let mut j = 0;
    while j < 16 { y[j] = prod[j]; j = j + 1; }
}

/// Consume up to 16 bytes of `data` starting at `off`, padded with
/// zeros to 16, and feed to GHASH.
fn ghash_feed(
    y: &mut [Byte; 16],
    h: &[Byte; 16],
    data: &[Byte],
) {
    let n = data.len();
    let mut off = 0;
    while off + 16 <= n {
        let mut block: [Byte; 16] = [0; 16];
        let mut i = 0;
        while i < 16 { block[i] = data[off + i]; i = i + 1; }
        ghash_block(y, &block, h);
        off = off + 16;
    }
    // Tail — zero-pad remainder.
    if off < n {
        let mut block: [Byte; 16] = [0; 16];
        let mut i = 0;
        while off + i < n { block[i] = data[off + i]; i = i + 1; }
        ghash_block(y, &block, h);
    }
}

// =============================================================================
// CTR-mode counter helpers
// =============================================================================

/// Increment the low 32 bits of a 128-bit block (big-endian) modulo 2^32.
/// NIST SP 800-38D §6.2 uses `inc_32` for CTR throughout GCM.
@inline
fn inc32(ctr: &mut [Byte; 16]) {
    let mut i = 15;
    // Carry-aware increment across the last 4 bytes.
    let mut carry: Int = 1;
    while i >= 12 && carry > 0 {
        let v = (ctr[i] as Int) + carry;
        ctr[i] = (v & 0xFF) as Byte;
        carry = v >> 8;
        i = i - 1;
    }
}

// =============================================================================
// Keyed state — precomputed round keys + H (GHASH subkey) + J0 template
// =============================================================================

public type Aes128Gcm is {
    rk: RoundKeys128,
    h: [Byte; 16],
};

public type Aes256Gcm is {
    rk: RoundKeys256,
    h: [Byte; 16],
};

implement Aes128Gcm {
    /// Precompute round keys + H. H = E_K(0^128).
    public fn new(key: &AesKey128) -> Aes128Gcm {
        let rk = RoundKeys128.expand(key);
        let mut h_block: [Byte; 16] = [0; 16];
        aes128_encrypt_block(&rk, &mut h_block);
        Aes128Gcm { rk: rk, h: h_block }
    }

    /// Seal `plaintext` into `ciphertext` + 16-byte `tag`. AAD
    /// (additional authenticated data) is authenticated but not
    /// encrypted. `iv` MUST be 12 bytes and MUST NOT be reused with
    /// the same key (RFC 8446 §5.3 nonce construction).
    public fn encrypt(
        &self,
        iv: &[Byte; 12],
        aad: &[Byte],
        plaintext: &[Byte],
        ciphertext: &mut List<Byte>,
        tag: &mut [Byte; 16],
    ) {
        gcm_encrypt_common(
            |ctr| {
                let mut b: [Byte; 16] = [0; 16];
                let mut i = 0; while i < 16 { b[i] = ctr[i]; i = i + 1; }
                aes128_encrypt_block(&self.rk, &mut b);
                b
            },
            &self.h, iv, aad, plaintext, ciphertext, tag,
        );
    }

    /// Open ciphertext. Verifies tag in constant time; returns
    /// `GcmError.TagMismatch` and clears `plaintext` if verification
    /// fails (caller must NOT use partial output).
    public fn decrypt(
        &self,
        iv: &[Byte; 12],
        aad: &[Byte],
        ciphertext: &[Byte],
        tag: &[Byte; 16],
        plaintext: &mut List<Byte>,
    ) -> Result<(), GcmError> {
        gcm_decrypt_common(
            |ctr| {
                let mut b: [Byte; 16] = [0; 16];
                let mut i = 0; while i < 16 { b[i] = ctr[i]; i = i + 1; }
                aes128_encrypt_block(&self.rk, &mut b);
                b
            },
            &self.h, iv, aad, ciphertext, tag, plaintext,
        )
    }
}

implement Aes256Gcm {
    public fn new(key: &AesKey256) -> Aes256Gcm {
        let rk = RoundKeys256.expand(key);
        let mut h_block: [Byte; 16] = [0; 16];
        aes256_encrypt_block(&rk, &mut h_block);
        Aes256Gcm { rk: rk, h: h_block }
    }

    public fn encrypt(
        &self,
        iv: &[Byte; 12],
        aad: &[Byte],
        plaintext: &[Byte],
        ciphertext: &mut List<Byte>,
        tag: &mut [Byte; 16],
    ) {
        gcm_encrypt_common(
            |ctr| {
                let mut b: [Byte; 16] = [0; 16];
                let mut i = 0; while i < 16 { b[i] = ctr[i]; i = i + 1; }
                aes256_encrypt_block(&self.rk, &mut b);
                b
            },
            &self.h, iv, aad, plaintext, ciphertext, tag,
        );
    }

    public fn decrypt(
        &self,
        iv: &[Byte; 12],
        aad: &[Byte],
        ciphertext: &[Byte],
        tag: &[Byte; 16],
        plaintext: &mut List<Byte>,
    ) -> Result<(), GcmError> {
        gcm_decrypt_common(
            |ctr| {
                let mut b: [Byte; 16] = [0; 16];
                let mut i = 0; while i < 16 { b[i] = ctr[i]; i = i + 1; }
                aes256_encrypt_block(&self.rk, &mut b);
                b
            },
            &self.h, iv, aad, ciphertext, tag, plaintext,
        )
    }
}

// =============================================================================
// Common GCM body — closure over E_K gives single implementation for
// both AES-128 and AES-256 variants.
// =============================================================================

fn gcm_encrypt_common<F: fn(&[Byte; 16]) -> [Byte; 16]>(
    aes_enc: F,
    h: &[Byte; 16],
    iv: &[Byte; 12],
    aad: &[Byte],
    plaintext: &[Byte],
    ciphertext: &mut List<Byte>,
    tag: &mut [Byte; 16],
) {
    // SOUNDNESS: NIST SP 800-38D §5.2.1.1 caps per-(key,IV) plaintext
    // at 2^39 − 256 bits ≈ 64 GiB.  Beyond this the CTR-mode counter
    // wraps modulo 2^32 and reuses keystream — keystream-reuse
    // catastrophe: XOR-ing ciphertexts of identical-counter blocks
    // recovers the plaintexts.  Without this guard the encrypt path
    // silently produces broken ciphertext that LOOKS valid but leaks
    // every byte past the wraparound point.
    //
    // We panic rather than return Result because the existing public
    // API (`encrypt(...)` returns `()`) would have to break to expose
    // an error path, and exceeding the limit always indicates a
    // caller-side correctness bug (e.g. trying to single-shot a
    // file larger than 64 GiB instead of using a streaming
    // construction with IV rotation).
    if plaintext.len() > GCM_MAX_PT_BYTES_PER_NONCE {
        panic(f"AES-GCM encrypt: plaintext {plaintext.len()} bytes exceeds NIST SP 800-38D per-nonce limit {GCM_MAX_PT_BYTES_PER_NONCE} — rotate IV or use streaming AEAD");
    }

    // J0 = IV || 0x00 0x00 0x00 0x01
    let mut j0: [Byte; 16] = [0; 16];
    let mut i = 0;
    while i < 12 { j0[i] = iv[i]; i = i + 1; }
    j0[15] = 1;

    // CTR starting position = inc_32(J0)
    let mut ctr: [Byte; 16] = [0; 16];
    let mut k = 0;
    while k < 16 { ctr[k] = j0[k]; k = k + 1; }
    inc32(&mut ctr);

    // GCTR_K over plaintext → ciphertext (XOR with keystream).
    let n = plaintext.len();
    let mut off = 0;
    while off < n {
        let ks = aes_enc(&ctr);
        let chunk = if n - off < 16 { n - off } else { 16 };
        let mut j = 0;
        while j < chunk {
            ciphertext.push(plaintext[off + j] ^ ks[j]);
            j = j + 1;
        }
        off = off + chunk;
        inc32(&mut ctr);
    }

    // GHASH: AAD (padded) || C (padded) || [len(A) || len(C)] (in bits)
    let mut y: [Byte; 16] = [0; 16];
    // AAD
    ghash_feed(&mut y, h, aad);
    // Ciphertext — read from freshly-pushed bytes.
    let ct_slice = ciphertext.as_slice();
    ghash_feed(&mut y, h, &ct_slice[ct_slice.len() - n..]);

    // Length block: [len(A)*8 || len(C)*8], big-endian, 64 bits each.
    let mut len_block: [Byte; 16] = [0; 16];
    let aad_bits = (aad.len() as UInt64) << 3_u64;
    let ct_bits  = (n as UInt64) << 3_u64;
    let ab = aad_bits.to_be_bytes();
    let cb = ct_bits.to_be_bytes();
    let mut m = 0;
    while m < 8 {
        len_block[m] = ab[m];
        len_block[8 + m] = cb[m];
        m = m + 1;
    }
    ghash_block(&mut y, &len_block, h);

    // T = E_K(J0) XOR y
    let e_j0 = aes_enc(&j0);
    let mut t = 0;
    while t < 16 {
        tag[t] = y[t] ^ e_j0[t];
        t = t + 1;
    }
}

fn gcm_decrypt_common<F: fn(&[Byte; 16]) -> [Byte; 16]>(
    aes_enc: F,
    h: &[Byte; 16],
    iv: &[Byte; 12],
    aad: &[Byte],
    ciphertext: &[Byte],
    tag: &[Byte; 16],
    plaintext: &mut List<Byte>,
) -> Result<(), GcmError> {
    // SOUNDNESS: same NIST per-(key,IV) cap as encrypt.  Decrypting
    // ciphertext that exceeds the limit is always invalid — either
    // the producer was buggy (and the ciphertext past the cap is
    // garbage) or the input is hostile.  Reject before doing any
    // cryptographic work so an attacker can't force the verifier
    // to GHASH+AES many GiB of input as a CPU-DoS amplifier.
    if ciphertext.len() > GCM_MAX_PT_BYTES_PER_NONCE {
        return Err(GcmError.InputTooLarge {
            limit_bytes: GCM_MAX_PT_BYTES_PER_NONCE,
        });
    }

    // J0 as in encrypt.
    let mut j0: [Byte; 16] = [0; 16];
    let mut i = 0;
    while i < 12 { j0[i] = iv[i]; i = i + 1; }
    j0[15] = 1;

    // GHASH first — before revealing any plaintext bytes.
    let mut y: [Byte; 16] = [0; 16];
    ghash_feed(&mut y, h, aad);
    ghash_feed(&mut y, h, ciphertext);

    let mut len_block: [Byte; 16] = [0; 16];
    let aad_bits = (aad.len() as UInt64) << 3_u64;
    let ct_bits  = (ciphertext.len() as UInt64) << 3_u64;
    let ab = aad_bits.to_be_bytes();
    let cb = ct_bits.to_be_bytes();
    let mut m = 0;
    while m < 8 {
        len_block[m] = ab[m];
        len_block[8 + m] = cb[m];
        m = m + 1;
    }
    ghash_block(&mut y, &len_block, h);

    // Compute expected tag.
    let e_j0 = aes_enc(&j0);
    let mut expected: [Byte; 16] = [0; 16];
    let mut t = 0;
    while t < 16 {
        expected[t] = y[t] ^ e_j0[t];
        t = t + 1;
    }

    // Constant-time compare BEFORE decrypting.
    if !constant_time_eq(&expected, tag) {
        return Err(GcmError.TagMismatch);
    }

    // Tag is valid — decrypt with GCTR starting at inc_32(J0).
    let mut ctr: [Byte; 16] = [0; 16];
    let mut k = 0;
    while k < 16 { ctr[k] = j0[k]; k = k + 1; }
    inc32(&mut ctr);

    let n = ciphertext.len();
    let mut off = 0;
    while off < n {
        let ks = aes_enc(&ctr);
        let chunk = if n - off < 16 { n - off } else { 16 };
        let mut j = 0;
        while j < chunk {
            plaintext.push(ciphertext[off + j] ^ ks[j]);
            j = j + 1;
        }
        off = off + chunk;
        inc32(&mut ctr);
    }
    Ok(())
}
