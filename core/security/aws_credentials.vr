// =============================================================================
// security/aws_credentials.vr — AWS credential material (single authority)
// =============================================================================
// Long-lived IAM-user keys or temporary STS session credentials. This lives in
// a neutral leaf module because two independent subsystems need the exact same
// shape and neither may depend on the other (T0155):
//
//   - `core.security.secrets.aws`  — AWS Secrets Manager client
//   - `core.storage.s3.signing`    — SigV4 canonical-request signing
//
// The module mounts nothing but `base`, so it adds no dependency-graph edge
// beyond the `-> core.security` ones that already exist.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.security.aws_credentials;

mount core.*;
mount base.{Maybe, Some, None, Text};

@derive(Eq, Clone, Debug)
public type AwsCredentials is {
    access_key_id: Text,
    secret_access_key: Text,
    /// IAM-role / STS session token. `Maybe.None` for permanent IAM-user keys.
    session_token: Maybe<Text>,
};

implement AwsCredentials {
    /// Permanent IAM-user credentials — no STS session token.
    public fn new(access_key_id: Text, secret_access_key: Text) -> AwsCredentials {
        AwsCredentials {
            access_key_id: access_key_id,
            secret_access_key: secret_access_key,
            session_token: Maybe.None,
        }
    }

    /// Attach an STS session token (assumed role / IRSA / IMDSv2).
    public fn with_session_token(mut self, t: Text) -> AwsCredentials {
        self.session_token = Maybe.Some(t); self
    }
}
