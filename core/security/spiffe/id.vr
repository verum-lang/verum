// =============================================================================
// security/spiffe/id.vr — SPIFFE ID parsing + validation
// =============================================================================
// Spec: https://github.com/spiffe/spiffe/blob/main/standards/SPIFFE-ID.md
//
// A SPIFFE ID has the form:
//   spiffe://<trust-domain>/<path>
//
//   trust-domain : lowercase DNS-like label set, no trailing dot
//   path         : URL-safe path, '/'-separated segments, empty is
//                  allowed (trust-domain only)
// =============================================================================

module core.security.spiffe.id;

mount core.*;

public type SpiffeId is {
    trust_domain: Text,
    path: Text,
}

public type SpiffeIdError is
    | Empty
    | MissingScheme
    | InvalidScheme(Text)
    | EmptyTrustDomain
    | InvalidTrustDomain { reason: Text }
    | PathTooLong { len: Int }
    | InvalidCharacters { at: Int, character: Byte };

implement Display for SpiffeIdError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Empty                              => f.write_str("SPIFFE ID: empty"),
            MissingScheme                      => f.write_str("SPIFFE ID: missing scheme"),
            InvalidScheme(s)                   => f.write_str(f"SPIFFE ID: invalid scheme ({s})".as_str()),
            EmptyTrustDomain                   => f.write_str("SPIFFE ID: empty trust domain"),
            InvalidTrustDomain { reason }      => f.write_str(f"SPIFFE ID: invalid trust domain ({reason})".as_str()),
            PathTooLong { len }                => f.write_str(f"SPIFFE ID: path too long ({len} bytes)".as_str()),
            InvalidCharacters { at, character }=> f.write_str(f"SPIFFE ID: invalid character at {at} (byte {character})".as_str()),
        }
    }
}

implement Debug for SpiffeIdError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Empty                              => f.write_str("Empty"),
            MissingScheme                      => f.write_str("MissingScheme"),
            InvalidScheme(s)                   => f.write_str(f"InvalidScheme({s})".as_str()),
            EmptyTrustDomain                   => f.write_str("EmptyTrustDomain"),
            InvalidTrustDomain { reason }      => f.write_str(f"InvalidTrustDomain {{ reason: {reason} }}".as_str()),
            PathTooLong { len }                => f.write_str(f"PathTooLong {{ len: {len} }}".as_str()),
            InvalidCharacters { at, character }=> f.write_str(f"InvalidCharacters {{ at: {at}, character: {character} }}".as_str()),
        }
    }
}

implement Eq for SpiffeIdError {
    fn eq(&self, other: &SpiffeIdError) -> Bool {
        match (self, other) {
            (Empty,                Empty)                => true,
            (MissingScheme,        MissingScheme)        => true,
            (InvalidScheme(a),     InvalidScheme(b))     => a == b,
            (EmptyTrustDomain,     EmptyTrustDomain)     => true,
            (InvalidTrustDomain { reason: a }, InvalidTrustDomain { reason: b }) => a == b,
            (PathTooLong { len: a }, PathTooLong { len: b }) => a == b,
            (InvalidCharacters { at: aa, character: ca },
             InvalidCharacters { at: ab, character: cb }) => aa == ab && ca == cb,
            _ => false,
        }
    }
}

public const MAX_SPIFFE_ID_LENGTH: Int = 2048;
public const SPIFFE_SCHEME: &'static Text = "spiffe://";

implement SpiffeId {
    public fn new(trust_domain: Text, path: Text) -> Result<SpiffeId, SpiffeIdError> {
        validate_trust_domain(&trust_domain)?;
        validate_path(&path)?;
        Ok(SpiffeId { trust_domain: trust_domain, path: path })
    }

    /// Trust-domain-only SPIFFE ID (e.g. "spiffe://example.org").
    public fn from_trust_domain(trust_domain: Text) -> Result<SpiffeId, SpiffeIdError> {
        validate_trust_domain(&trust_domain)?;
        Ok(SpiffeId { trust_domain: trust_domain, path: "".into() })
    }

    /// Parse from canonical URI form.
    public fn parse(input: &Text) -> Result<SpiffeId, SpiffeIdError> {
        if input.is_empty() { return Err(SpiffeIdError.Empty); }
        if input.len() > MAX_SPIFFE_ID_LENGTH {
            return Err(SpiffeIdError.PathTooLong { len: input.len() });
        }
        let bytes = input.as_bytes();
        // Require "spiffe://" prefix.
        if !starts_with_ci(bytes, SPIFFE_SCHEME.as_bytes()) {
            return Err(SpiffeIdError.MissingScheme);
        }
        let rest = &bytes[9..];  // "spiffe://".len()
        // Split at first '/'.
        let mut slash: Int = -1;
        let mut i = 0;
        while i < rest.len() {
            if rest[i] == 0x2F { slash = i; break; }
            i = i + 1;
        }
        let (td_bytes, path_bytes) = if slash < 0 {
            (rest, &rest[rest.len()..])   // no path
        } else {
            (&rest[..slash], &rest[slash..])
        };
        if td_bytes.len() == 0 { return Err(SpiffeIdError.EmptyTrustDomain); }
        let trust_domain = Text.from_utf8(td_bytes).map_err(|_| SpiffeIdError.InvalidTrustDomain {
            reason: "non-utf8".into(),
        })?;
        let path = Text.from_utf8(path_bytes).map_err(|_| SpiffeIdError.InvalidTrustDomain {
            reason: "non-utf8".into(),
        })?;
        SpiffeId.new(trust_domain, path)
    }

    public fn trust_domain(&self) -> &Text { &self.trust_domain }
    public fn path(&self) -> &Text { &self.path }

    /// True if this is a trust-domain-only ID (no path component).
    public fn is_trust_domain_id(&self) -> Bool { self.path.is_empty() }

    /// Return "spiffe://td/path" canonical form.
    public fn to_uri(&self) -> Text {
        let mut out = Text.with_capacity(SPIFFE_SCHEME.len() + self.trust_domain.len() + self.path.len());
        out.push_str(SPIFFE_SCHEME);
        out.push_str(&self.trust_domain);
        out.push_str(&self.path);
        out
    }

    /// Does this ID belong to the given trust domain?
    public fn is_member_of(&self, trust_domain: &Text) -> Bool {
        self.trust_domain == *trust_domain
    }
}

// =============================================================================
// Validation helpers
// =============================================================================

fn validate_trust_domain(td: &Text) -> Result<(), SpiffeIdError> {
    if td.is_empty() { return Err(SpiffeIdError.EmptyTrustDomain); }
    if td.len() > 255 {
        return Err(SpiffeIdError.InvalidTrustDomain { reason: "exceeds 255 chars".into() });
    }
    let bytes = td.as_bytes();
    let mut i = 0;
    while i < bytes.len() {
        let b = bytes[i];
        // Allowed: a-z, 0-9, '-', '.', '_'
        let ok = (b >= 0x61 && b <= 0x7A)   // a-z
            || (b >= 0x30 && b <= 0x39)     // 0-9
            || b == 0x2D || b == 0x2E || b == 0x5F;  // - . _
        if !ok {
            return Err(SpiffeIdError.InvalidCharacters { at: i, character: b });
        }
        i = i + 1;
    }
    Ok(())
}

fn validate_path(path: &Text) -> Result<(), SpiffeIdError> {
    if path.is_empty() { return Ok(()); }
    if path.len() > MAX_SPIFFE_ID_LENGTH {
        return Err(SpiffeIdError.PathTooLong { len: path.len() });
    }
    let bytes = path.as_bytes();
    if bytes[0] != 0x2F {
        return Err(SpiffeIdError.InvalidCharacters { at: 0, character: bytes[0] });
    }
    // Permitted: alpha, digits, `-`, `.`, `_`, `~`, sub-delims, `:`, `@`.
    let mut i = 1;
    while i < bytes.len() {
        let b = bytes[i];
        let ok = (b >= 0x61 && b <= 0x7A)
            || (b >= 0x41 && b <= 0x5A)
            || (b >= 0x30 && b <= 0x39)
            || b == 0x2D || b == 0x2E || b == 0x5F || b == 0x7E
            || b == 0x2F
            || b == 0x3A || b == 0x40
            || b == 0x25 /* % */;
        if !ok {
            return Err(SpiffeIdError.InvalidCharacters { at: i, character: b });
        }
        i = i + 1;
    }
    Ok(())
}

fn starts_with_ci(haystack: &[Byte], needle: &[Byte]) -> Bool {
    // Fold only A-Z to a-z. Naive `b | 0x20` folds non-letters too
    // (`\r` | 0x20 = `-`, `@` | 0x20 = `` ` ``, etc.) producing
    // false-positive equality across bit-5 pair-shifts. SPIFFE IDs
    // can carry path segments with `-`, `.`, `_` — folding those
    // bytes would make `spiffe:\r/...` match the spiffe:// prefix.
    if haystack.len() < needle.len() { return false; }
    let mut i = 0;
    while i < needle.len() {
        let rh = haystack[i];
        let rn = needle[i];
        let h = if rh >= 0x41_u8 && rh <= 0x5A_u8 { rh | 0x20_u8 } else { rh };
        let n = if rn >= 0x41_u8 && rn <= 0x5A_u8 { rn | 0x20_u8 } else { rn };
        if h != n { return false; }
        i = i + 1;
    }
    true
}
