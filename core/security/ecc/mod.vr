// =============================================================================
// core/security/ecc/mod.vr — Elliptic-curve cryptography primitives
// =============================================================================
// Layer: Standard Library / Security / ECC
// =============================================================================
//
// Elliptic-curve point arithmetic + protocol-level operations. All
// implementations are constant-time on every CPU; no timing
// channels through the secret key.
//
//   * `ed25519.vr`  — Ed25519 signature scheme (RFC 8032). The
//                     default modern signature primitive; small
//                     keys (32 bytes), small signatures (64 bytes),
//                     fast verification.
//   * `p256.vr`     — NIST P-256 (secp256r1, prime256v1) per FIPS
//                     186-4. Required for FIPS-validated
//                     deployments + JWS ES256 / TLS ECDSA suites.
//   * `x25519.vr`   — X25519 key-agreement (RFC 7748). The default
//                     ECDH primitive; pairs with Ed25519 for the
//                     "X3DH"-style triple Diffie-Hellman flows.
//
// Higher-level signature combinators (multi-sig, threshold,
// blind) are V1.5 follow-ups; V0 ships the foundational
// primitives only.
// =============================================================================

module core.security.ecc;

public module ed25519;
public module p256;
public module x25519;
