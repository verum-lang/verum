// =============================================================================
// security/mod.vr — Security primitives module
// =============================================================================
// Layer: 1 (crypto primitives + capability labels)
// =============================================================================
//

// Organization:
//

// - `hash/` — hash functions (SHA-256, SHA-512 (planned), SHA-3 (planned))
// - `mac/` — message authentication codes (HMAC-SHA-256, HMAC-SHA-512)
// - `kdf/` — key derivation functions (HKDF-SHA-256, PBKDF2 (planned))
// - `util/` — timing-safe primitives (constant_time_eq), etc.
// - `labels.vr` — capability labels (information-flow)
// - `regions.vr` — region-based memory safety
//

// Backends:
//

// Current implementations are pure-Verum reference code. Industrial
// deployments should enable a hardware-accelerated / formally-verified
// backend at link-time via one of:
//

//  `@cfg(feature = "crypto-hacl-star")` — Project Everest HACL*
//  (formally verified)
//  `@cfg(feature = "crypto-openssl")` — OpenSSL 3.x FFI
//  `@cfg(feature = "crypto-ring")` — ring 0.17+ FFI
//

// Reference implementations remain available for bootstrap, cross-check,
// and golden-test vectors regardless of backend choice.
//

// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.security;

// Crypto primitive submodules.
public module hash {
    public module sha256;
    public module sha1;
    public module crc32c;
    public module xxhash;
    public module murmur3;
    public module fnv;
    /// BLAKE3 — modern fast cryptographic hash. Default for content
    /// addressing, modern Merkle commitment, fast XOF.
    public module blake3;
}

public module mac {
    public module hmac;
}

public module kdf {
    public module hkdf;
    public module pbkdf2;
}

public module util {
    public module constant_time;
}

// SPIFFE workload identity (SVID + Workload API client).
public module spiffe;

// Secret-manager clients (Vault / AWS Secrets Manager / GCP Secret Manager)
// + the shared SecretStore protocol.
public module secrets;

// Post-quantum cryptography — FIPS 203 ML-KEM + FIPS 204 ML-DSA + FIPS 205 SLH-DSA.
public module pq;

/// Zero-knowledge proof systems — Halo2+KZG10 (pre-quantum, short proofs)
/// and STARK+FRI (post-quantum, transparent setup). Both expose circuit-
/// DSL builders + prove/verify; backends route through `verum.crypto.*`
/// intrinsics so SIMD/GPU acceleration is opt-in via runtime feature flags.
public module zk;

// X.509 certificate subsystem (RFC 5280) — DER parser + chain validation +
// trust store. Ships as a subtree; see x509/mod.vr for internals.
public module x509;

// Hybrid Public Key Encryption (RFC 9180) — one-suite reference impl
// behind ECH, MLS, Privacy Pass.
public module hpke;

// HOTP (RFC 4226) + TOTP (RFC 6238) one-time passwords.
public module otp;

// JSON Web Tokens (RFC 7519 + RFC 7515).
public module jwt;

// CBOR Object Signing and Encryption (RFC 9052) — WebAuthn, CWT, mDoc.
public module cose;

// Password hashing (PHC modular format) — PBKDF2-HMAC-SHA256 backend.
public module password_hash;

// Binary Merkle tree + inclusion proofs (RFC 6962 §2.1).
public module merkle;

// Transparency log (RFC 6962 + RFC 9162) — sumdb-style append-only
// log with Merkle commitment, signed tree heads, tile-addressed
// proofs, consistency proofs. Composed by the registry's sumdb,
// Sigstore Rekor adapters, supply-chain provenance auditors.
public module transparency_log;

// Software supply-chain provenance — SLSA Build L3 attestations
// wrapped in in-toto Statements, signed via DSSE envelopes,
// optionally bundled in Sigstore-compatible form. Each layer
// (DSSE / in-toto / SLSA / Bundle) is independently composable.
public module provenance;

// TUF (The Update Framework) — compromise-resilient software-
// distribution framework used by PyPI, Docker Notary, Sigstore
// root, the Verum registry. Threshold-signed Root anchors trust;
// Timestamp + Snapshot detect freeze + mix-and-match; Targets
// resolve paths via delegation graph; full §5 client workflow
// with rollback / freeze / fast-forward / endless-data detection.
public module tuf;

// Sigstore — keyless code-signing infrastructure built on Rekor
// (transparency log), Fulcio (ephemeral CSR-based CA), and OIDC
// (identity provider). End-to-end keyless verification combining
// cert chain → tlog → DSSE envelope → OIDC identity binding.
// Composes against tuf (trust root), x509 (chain validation),
// provenance (DSSE), oidc (token verify).
public module sigstore;

// WebAuthn / FIDO2 — phishing-resistant passwordless authentication
// built on public-key cryptography. Server-side relying-party
// implementation: registration ceremony (clientData + attestationObject
// → VerifiedCredential), authentication ceremony (clientData +
// authData + signature → AuthenticationResult with cloning detection
// via signCount). Supports COSE_Key formats (Ed25519, EC2 P-256/384/521,
// RSA) and attestation formats (none, packed, fido-u2f, apple).
public module webauthn;

// OpenID Connect (OIDC) — discovery (.well-known/openid-configuration),
// JWKS cache with TTL, token validation. For trusted-publishing
// flows where CI runners (GitHub Actions / GitLab / Sigstore)
// authenticate via signed JWT instead of long-lived API keys.
public module oidc;

// =============================================================================
// AEAD / cipher / ECC / sig sub-umbrellas
// =============================================================================
//

// Each sub-umbrella ships 1–3 cryptographic primitives. Pre-fix
// each shipped its `.vr` files but had no `mod.vr` and no
// declaration here — `mount core.security.aead.aes_gcm;` worked
// only via direct file lookup, the umbrella tree was invisible
// to namespace enumeration, and downstream wildcard re-exports
// (`mount core.security.aead.*;`) silently produced an empty
// import list. This commit creates the missing `mod.vr` files
// (4 new files) AND adds the umbrella declarations below.

// AEAD (Authenticated Encryption with Associated Data): AES-GCM,
// ChaCha20-Poly1305. Default modern symmetric encryption choice.
public module aead;

// Raw symmetric ciphers (confidentiality only — prefer AEAD for
// most uses): AES, ChaCha20. Surfaced for callers composing with
// externally-managed authentication.
public module cipher;

// Elliptic-curve cryptography: Ed25519 signatures, P-256 (FIPS),
// X25519 key-agreement.
public module ecc;

// Non-EC signature schemes: RSA (+ PKCS#1 v1.5 / PSS encodings).
// Legacy / interop only — prefer Ed25519 for new applications.
public module sig;

// Public-key encryption (RSA-OAEP and friends). Distinct from
// `sig` (signing) and `aead` (symmetric encryption).
public module encrypt;

// Cryptographic random token generator (URL-safe / hex / numeric).
public module token;

// Legacy capability / region modules (pre-crypto).
public module labels;
public module regions;

// Runtime capability gating surface bridging the
// `PermissionRouter` on `InterpreterState`. Every gated
// intrinsic short-circuits through `check_permission` before
// the gated operation runs (#12 / P3.2).
public module permission;

// Re-exports of most-used surface.
//

// NOTE: module `hash.sha256` and a free function `sha256` would collide
// at import site — `Sha256.digest(bytes)` is the idiomatic one-shot form.
// The streaming `Sha256.new() / update / finalize` is the general form.
public mount .hash.sha256.Sha256;
public mount .hash.sha1.Sha1;
public mount .hash.blake3.{Blake3, blake3, blake3_keyed, blake3_derive_key};
public mount .mac.hmac.{HmacSha256, hmac_sha256};
public mount .kdf.hkdf.{hkdf_extract_sha256, hkdf_expand_sha256, hkdf_sha256, HkdfError};
public mount .util.constant_time.{constant_time_eq, constant_time_compare};
