// =============================================================================
// mod.vr — Theory Interoperation: ∞-Topos of Formally Represented Theories
// =============================================================================
// Layer: Application
//
// A computational ∞-topos where formally-represented theories
// live as sheaves, translations between theories are Kan
// extensions, and coherence across translation chains is
// verified through descent conditions.
//
// This module tree provides:
//
//   core.vr      — Theory loading (Yoneda), translation (Kan),
//                  coherence (descent), audit
//   protocol.vr  — JSON-RPC wire protocol for external tooling
//                  (IDE plugins, theorem-prover bridges,
//                  LLM-driven translators)
//
// # Quick Start
//
// ```verum
// mount core.theory_interop.*;
//
// // Load two theories
// let mut reg = new_registry();
// let a = load_theory(&mut reg, first_theory);
// let b = load_theory(&mut reg, second_theory);
//
// // Translate with partial mapping
// let result = translate(&a, &b, &partial_map);
// print(f"Translation quality: {result.quality}");
//
// // Check coherence across translations
// let coherence = check_coherence(&reg, &pairs);
// match coherence {
//     CoherenceResult.Coherent { global_quality } =>
//         print(f"Coherent! Quality: {global_quality}"),
//     CoherenceResult.Obstruction { violations, severity } =>
//         print(f"Incoherent: {violations.len()} violations, \
//                severity {severity}"),
// }
// ```
//
// # Architecture
//
// ```
// Theory-interop application layer
// ├── core.vr      — load_theory, translate, check_coherence, audit
// └── protocol.vr  — JSON-RPC server (theory/list, claim/translate, …)
//         │
//         ▼
// Mathematical foundation (core/math/)
// ├── epistemic.vr     — EpistemicStatus, Theory, EpistemicTopology
// ├── infinity_topos.vr— ∞-Topos, descent, coherence violations
// ├── kan_extension.vr — Lan/Ran, comma categories, obstruction
// ├── quantum_logic.vr — Quantum epistemic states, density matrices
// ├── giry.vr          — Giry monad, LLM oracle
// ├── cohesive.vr      — Cohesive modalities (Π ⊣ Disc ⊣ Γ ⊣ coDisc)
// ├── day_convolution.vr — Day ⊗, cognitive extension
// └── hott.vr          — Cubical HoTT, Path types, equivalences
// ```
// =============================================================================

module core.theory_interop;

// Theory-interop core — theory loading, translation, coherence
public module core;

// VVA §10.2 obstruction verdict + §10.4 MSFS coordinate
public module coord;

// VVA §21.7 canonical cross-framework bridges (owl2_fs → lurie_htt
// shipped today; VVA §16.6 F6 catalogue is the V2 destination).
public module bridges;

// Congruence-closure decision procedure — Nelson-Oppen style
// equality reasoning over uninterpreted function symbols, used
// by the descent-coherence checker to decide whether two
// translation chains agree on every common axiom. Pre-fix
// `congruence_closure.vr` shipped production code but had no
// declaration here, so `mount core.theory_interop.
// congruence_closure;` (the only way to use the module) silently
// failed to resolve through the umbrella.
public module congruence_closure;

// JSON-RPC wire protocol for external tooling
public module protocol;

// =============================================================================
// Prelude re-exports
// =============================================================================

// Core operations
public mount .core.{
    // Registry
    TheoryRegistry, new_registry,
    // Theory operations
    LoadedTheory, load_theory, find_theory, list_theories,
    // Translation
    TranslationResult, TranslationRecord,
    translate, translate_with_oracle,
    // Coherence
    CoherenceResult, check_coherence,
    // Auditing
    AuditResult, audit_theory, audit_meta,
    // §242 audit-helper layer
    translation_verdict, translation_admits,
    is_coherent, coherence_quality,
};

// VVA §10.2 obstruction verdict + §10.4 MSFS coordinate
public mount .coord.{
    TranslationVerdict, verdict_of, verdict_as_text, verdict_admits,
    MsfsCoord, msfs_coord, coord_of, coord_as_text, coord_eq,
    MsfsTheoremCoord, theorem_coord, theorem_coord_as_text,
    Ordinal, ord_zero, ord_finite, ord_omega, ord_max, ord_lt,
    ord_eq, ord_as_text,
};

// Protocol operations
public mount .protocol.{
    JsonRpcRequest, JsonRpcResponse, JsonRpcError,
    TheoryInteropServer, new_server, serve_request,
};
