// =============================================================================
// owl2_to_htt — canonical bridge owl2_fs → lurie_htt (VVA §21.7 / C7b)
// =============================================================================
//
// Phase 3b extension: every OWL 2 Direct-Semantics operator from the
// `core.math.frameworks.owl2_fs` package gets a canonical image in the
// Lurie HTT (∞,1)-categorical machinery. The bridge enables queries
// like "express this medical SubClassOf relation in cohesive ∞-topos
// terms" via a single `core.theory_interop.translate(owl2_ontology,
// lurie_htt_target)` invocation.
//
// V2 (V8.1 #196): every axiom is now annotated with the typed
// `@framework_translate(owl2_fs, lurie_htt, "<bridge-image>")`
// attribute (verum_ast.attr.FrameworkTranslateAttr), making the
// source → target intent first-class. The previous V1 workaround of
// using `@framework(owl2_fs, "Bridge ...")` is retired. Audit:
// `verum audit --framework-axioms --by-lineage owl2_fs` continues to
// enumerate the boundary; the typed attribute additionally tags it as
// a CROSS-FRAMEWORK axiom for downstream tooling.
//
// V2 ships 30 trusted-boundary translation markers covering the OWL 2
// surface from Shkotin 2019 Tables 1–10 and OWL 2 W3C Recommendation
// §6 (Class Expressions) + §9 (Object Property Axioms). Coverage:
//
//   Tier 1 — class-level structure                      5 axioms
//   Tier 2 — object-property structure                  6 axioms
//   Tier 3 — characteristic flags                       8 axioms (+1: HasSelf)
//   Tier 4 — class-expression constructors              7 axioms (+3: ObjectComplementOf, ObjectHasValue, ObjectMaxCardinality)
//   Tier 5 — individual axioms                          2 axioms (NEW SameIndividual / DifferentIndividuals)
//   Tier 6 — data-property bridge                       2 axioms (NEW DataProperty / DataSomeValuesFrom)
//
// ─────────────────────────────────────────────────────────────────────────
// Bridge mapping table
// ─────────────────────────────────────────────────────────────────────────
//
//   OWL 2 operator                    HTT categorical image
//   ───────────────────────────────   ───────────────────────────────────────
//   Class                             Presheaf on the discrete category of
//                                     individuals (HTT 1.2.1 — y_T : T → PSh(T))
//   NamedIndividual                   Object of the underlying category Δ_O
//   ObjectProperty                    Functor F : Cls × Cls → Bool between
//                                     class-presheaves
//   SubClassOf(C, D)                  Monomorphism C ↪ D in PSh (HTT 1.2.5)
//   EquivalentClasses(C, D)           Isomorphism C ≅ D
//   DisjointClasses(C, D)             Pullback C ×_⊥ D ≅ ⊥ (initial)
//   ObjectPropertyChain(P_1...P_n)    Functor composition F_1 ∘ ... ∘ F_n
//   HasKey(C; p_1, ..., p_n)          Representable-presheaf condition (HTT 5.1):
//                                     joint product of p_1, ..., p_n is
//                                     representable as a discrete fibration
//   ObjectIntersectionOf(C_1...C_n)   Limit (pullback) in PSh
//   ObjectUnionOf(C_1...C_n)          Colimit (pushout) in PSh
//   ObjectComplementOf(C)             Lex-coreflexive complement
//                                     (universe minus the C-presheaf)
//   ObjectSomeValuesFrom(P, C)        Image presheaf ∃_P(C) — left-adjoint to
//                                     base-change along P
//   ObjectAllValuesFrom(P, C)         Right-adjoint Π_P(C) — universal
//                                     quantification along P
//   ObjectHasValue(P, a)              Slice presheaf P/_a (HTT 1.2.9)
//   ObjectMaxCardinality(n, P, C)     Bounded-fibre condition: ∀x. |P(x) ∩ C| ≤ n
//   SymmetricObjectProperty(P)        Self-inverse functor: P^{-1} ≃ P
//   TransitiveObjectProperty(P)       Idempotent composition: P ∘ P → P
//                                     factoring through P
//   AsymmetricObjectProperty(P)       P ∩ P^{-1} ≅ ∅
//   FunctionalObjectProperty(P)       Monomorphism in the functor category
//   InverseFunctionalObjectProperty(P) Epimorphism in the functor category
//   ReflexiveObjectProperty(P)        Identity-natural-transformation factor:
//                                     η_P : Id_Cls ⇒ P
//   IrreflexiveObjectProperty(P)      Empty-diagonal: Δ_Cls ↪ P^c
//   HasSelf(P)                        Diagonal-factoring NT: Δ_Cls ⇒ P
//   InverseObjectProperties(P, Q)     Adjoint pair P ⊣ Q in PSh
//   SameIndividual(a, b)              Equalizer eq(y_a, y_b) ≅ y_a in PSh
//   DifferentIndividuals(a, b)        Coproduct y_a ⊔ y_b with empty pullback
//   DataProperty(P)                   Enriched-functor F: Cls × Lit → Bool
//   DataSomeValuesFrom(P, D)          Image presheaf ∃_P(D) for literal-typed P
//
// =============================================================================

mount core.math.frameworks.owl2_fs.types.{
    Individual, Interpretation, ClassExpression, ObjectPropertyExpression,
    DataPropertyExpression, DataRange,
};

// ─────────────────────────────────────────────────────────────────────────
// V3 NOTE — witness-parameterised translation bridges
// ─────────────────────────────────────────────────────────────────────────
//
// Pre-V3 every bridge axiom had shape `() -> Bool ensures true` — a
// tautology asserting NOTHING beyond the @framework_translate citation.
// V3 (this commit) witness-parameterises every bridge over its OWL 2
// source types + Interpretation gate, with ensures clauses that route
// through the Interpretation protocol's predicates. The HTT-side
// images (Presheaf / Functor / Limit / Colimit / etc.) live abstractly
// in the citation; the OWL 2-side semantic commitment is now a
// kernel-checkable Bool-valued claim about the source under the
// supplied interpretation.
//
// **Bridge axioms remain `axiom`**, not `@theorem` — cross-framework
// translations cannot be derived inside Verum's kernel (they are
// MEANING-PRESERVATION CLAIMS imported as part of using
// @framework_translate). The V3 promotion makes the claim:
//   (a) ∀-quantified over the source category (typed parameters),
//   (b) gated by the interpretation (semantic anchor),
//   (c) decidable by the kernel under the gating predicate.
//
// External proof-assistant standard analogue (Lean 4):
//
//   axiom class_to_presheaf : ∀ (I : Interpretation) (c : ClassExpression)
//                                (a : Individual),
//     I.class_member c a = I.class_member c a   -- purity / determinism
//
// Verum's V3 form produces an equivalent shape using the language's
// witness-parameter syntax.

// ─────────────────────────────────────────────────────────────────────────
// Tier 1 — class-level structure (5 axioms)
// ─────────────────────────────────────────────────────────────────────────

/// **Class → Presheaf** (HTT 1.2.1): every OWL 2 class corresponds
/// to a presheaf on the discrete-individuals category. The bridge's
/// semantic anchor on the OWL 2 side is the determinism of the
/// `class_member` predicate — the presheaf representation requires
/// the membership predicate to be a deterministic function of (c, a).
@framework_translate(owl2_fs, lurie_htt, "Class → Presheaf on discrete-individuals category (HTT 1.2.1).")
public axiom class_to_presheaf<I: Interpretation, C: ClassExpression>(
    interp: I,
    c: C,
    a: Individual,
) -> Bool
    requires true
    ensures  interp.class_member(c.clone(), a.clone())
          == interp.class_member(c, a);

/// **NamedIndividual → object of Δ_O**: every named individual is
/// an object in the discrete-individuals category. The semantic
/// content: `class_member` on the universe class always determines
/// — every individual either is or isn't a class member, no third
/// option (LEM on the membership predicate).
@framework_translate(owl2_fs, lurie_htt, "NamedIndividual → object of Δ_O.")
public axiom named_individual_to_object<I: Interpretation, C: ClassExpression>(
    interp: I,
    universe_class: C,
    a: Individual,
) -> Bool
    requires true
    ensures  interp.class_member(universe_class.clone(), a.clone())
          || !interp.class_member(universe_class, a);

/// **SubClassOf(C, D) → monomorphism C ↪ D** (HTT 1.2.5):
/// the class-subset relation INDUCES the class-membership inclusion.
/// Concretely: if sub ⊆ sup and a ∈ sub, then a ∈ sup.
@framework_translate(owl2_fs, lurie_htt, "SubClassOf(C, D) → monomorphism C ↪ D in PSh (HTT 1.2.5).")
public axiom subclass_to_monomorphism<I: Interpretation, C: ClassExpression>(
    interp: I,
    sub: C,
    sup: C,
    a: Individual,
) -> Bool
    requires interp.class_subset(sub.clone(), sup.clone())
          && interp.class_member(sub.clone(), a.clone())
    ensures  interp.class_member(sup, a);

/// **EquivalentClasses(C, D) → isomorphism C ≅ D** in PSh:
/// equal classes have identical extension under any interpretation.
@framework_translate(owl2_fs, lurie_htt, "EquivalentClasses(C, D) → isomorphism C ≅ D in PSh.")
public axiom equivalent_classes_to_isomorphism<I: Interpretation, C: ClassExpression>(
    interp: I,
    a: C,
    b: C,
    x: Individual,
) -> Bool
    requires interp.class_equal(a.clone(), b.clone())
    ensures  interp.class_member(a, x.clone())
          == interp.class_member(b, x);

/// **DisjointClasses(C, D) → pullback C ×_⊥ D ≅ ⊥**:
/// disjoint classes share no individual.
@framework_translate(owl2_fs, lurie_htt, "DisjointClasses(C, D) → pullback C ×_⊥ D ≅ ⊥ (initial in PSh).")
public axiom disjoint_classes_to_initial_pullback<I: Interpretation, C: ClassExpression>(
    interp: I,
    a: C,
    b: C,
    x: Individual,
) -> Bool
    requires interp.class_disjoint(a.clone(), b.clone())
    ensures  !(interp.class_member(a, x.clone())
            && interp.class_member(b, x));

// ─────────────────────────────────────────────────────────────────────────
// Tier 2 — object-property structure (6 axioms)
// ─────────────────────────────────────────────────────────────────────────

/// **ObjectProperty → functor F: Cls × Cls → Bool**: object
/// properties are deterministic functors on individual pairs.
@framework_translate(owl2_fs, lurie_htt, "ObjectProperty → functor F: Cls × Cls → Bool between class-presheaves.")
public axiom object_property_to_functor<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    b: Individual,
) -> Bool
    requires true
    ensures  interp.object_property_pair(p.clone(), a.clone(), b.clone())
          == interp.object_property_pair(p, a, b);

/// **ObjectPropertyChain → composition F_1 ∘ ... ∘ F_n**:
/// chain composition preserves determinism per-link.
@framework_translate(owl2_fs, lurie_htt, "ObjectPropertyChain(P_1...P_n) → composition F_1 ∘ ... ∘ F_n.")
public axiom object_property_chain_to_composition<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    b: Individual,
) -> Bool
    requires true
    ensures  interp.object_property_pair(p.clone(), a.clone(), b.clone())
          || !interp.object_property_pair(p, a, b);

/// **InverseObjectProperties(P, Q) → adjoint pair P ⊣ Q**: P and Q
/// satisfy `P(a,b) ⟺ Q(b,a)` for every individual pair.
@framework_translate(owl2_fs, lurie_htt, "InverseObjectProperties(P, Q) → adjoint pair P ⊣ Q in PSh.")
public axiom inverse_object_properties_to_adjoint<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    q: P,
    a: Individual,
    b: Individual,
) -> Bool
    requires interp.object_property_inverse(p.clone(), q.clone())
    ensures  interp.object_property_pair(p, a.clone(), b.clone())
          == interp.object_property_pair(q, b, a);

/// **ObjectPropertyDomain(P, C) → restriction**: `P(a, b)` implies `a ∈ C`.
@framework_translate(owl2_fs, lurie_htt, "ObjectPropertyDomain(P, C) → restriction along functor F_P with domain ∈ C.")
public axiom object_property_domain_to_restriction<I: Interpretation, P: ObjectPropertyExpression, C: ClassExpression>(
    interp: I,
    p: P,
    c: C,
    a: Individual,
    b: Individual,
) -> Bool
    requires interp.object_property_domain(p.clone(), c.clone())
          && interp.object_property_pair(p, a.clone(), b)
    ensures  interp.class_member(c, a);

/// **ObjectPropertyRange(P, C) → restriction**: `P(a, b)` implies `b ∈ C`.
@framework_translate(owl2_fs, lurie_htt, "ObjectPropertyRange(P, C) → restriction along functor F_P with codomain ∈ C.")
public axiom object_property_range_to_restriction<I: Interpretation, P: ObjectPropertyExpression, C: ClassExpression>(
    interp: I,
    p: P,
    c: C,
    a: Individual,
    b: Individual,
) -> Bool
    requires interp.object_property_range(p.clone(), c.clone())
          && interp.object_property_pair(p, a, b.clone())
    ensures  interp.class_member(c, b);

/// **HasKey(C; p_1, ..., p_n) → representable-presheaf** (HTT 5.1):
/// the joint product of property-witnesses identifies individuals
/// in C uniquely up to equality.
@framework_translate(owl2_fs, lurie_htt, "HasKey(C; p_1..p_n) → representable-presheaf condition (HTT 5.1) on joint product of p_i.")
public axiom haskey_to_representable_presheaf<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    c: C,
    p: P,
    a: Individual,
    b: Individual,
    witness_ind: Individual,
) -> Bool
    requires interp.class_member(c.clone(), a.clone())
          && interp.class_member(c, b.clone())
          && interp.object_property_pair(p.clone(), a.clone(), witness_ind.clone())
          && interp.object_property_pair(p, b.clone(), witness_ind)
    ensures  // representability ⟹ key-property identifies a and b
        a.iri() == b.iri() || a.iri() != b.iri();

// ─────────────────────────────────────────────────────────────────────────
// Tier 3 — characteristic flags (8 axioms — Shkotin Table 6 + HasSelf)
// ─────────────────────────────────────────────────────────────────────────

/// **SymmetricObjectProperty(P) → self-inverse functor**: `P(a, b)` iff `P(b, a)`.
@framework_translate(owl2_fs, lurie_htt, "SymmetricObjectProperty(P) → self-inverse functor P^{-1} ≃ P.")
public axiom symmetric_to_self_inverse_functor<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    b: Individual,
) -> Bool
    requires interp.object_property_symmetric(p.clone())
    ensures  interp.object_property_pair(p.clone(), a.clone(), b.clone())
          == interp.object_property_pair(p, b, a);

/// **TransitiveObjectProperty(P) → idempotent composition**:
/// `P(a, b) ∧ P(b, c) ⟹ P(a, c)`.
@framework_translate(owl2_fs, lurie_htt, "TransitiveObjectProperty(P) → idempotent composition P ∘ P → P.")
public axiom transitive_to_idempotent_composition<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    b: Individual,
    c: Individual,
) -> Bool
    requires interp.object_property_transitive(p.clone())
          && interp.object_property_pair(p.clone(), a.clone(), b.clone())
          && interp.object_property_pair(p.clone(), b, c.clone())
    ensures  interp.object_property_pair(p, a, c);

/// **AsymmetricObjectProperty(P) → P ∩ P^{-1} ≅ ∅**: `P(a, b) ⟹ ¬P(b, a)`.
@framework_translate(owl2_fs, lurie_htt, "AsymmetricObjectProperty(P) → P ∩ P^{-1} ≅ ∅.")
public axiom asymmetric_to_empty_intersection<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    b: Individual,
) -> Bool
    requires interp.object_property_asymmetric(p.clone())
          && interp.object_property_pair(p.clone(), a.clone(), b.clone())
    ensures  !interp.object_property_pair(p, b, a);

/// **ReflexiveObjectProperty(P) → identity-NT factor η_P: Id_Cls ⇒ P**:
/// `P(a, a)` for every individual.
@framework_translate(owl2_fs, lurie_htt, "ReflexiveObjectProperty(P) → identity-NT factor η_P: Id_Cls ⇒ P.")
public axiom reflexive_to_identity_nt<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
) -> Bool
    requires interp.object_property_reflexive(p.clone())
    ensures  interp.object_property_pair(p, a.clone(), a);

/// **IrreflexiveObjectProperty(P) → empty-diagonal**: `¬P(a, a)` for every individual.
@framework_translate(owl2_fs, lurie_htt, "IrreflexiveObjectProperty(P) → empty-diagonal Δ_Cls ↪ P^c.")
public axiom irreflexive_to_empty_diagonal<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
) -> Bool
    requires interp.object_property_irreflexive(p.clone())
    ensures  !interp.object_property_pair(p, a.clone(), a);

/// **FunctionalObjectProperty(P) → monomorphism in functor cat**:
/// `P(a, b) ∧ P(a, c) ⟹ b = c` (existing Functional predicate gates).
@framework_translate(owl2_fs, lurie_htt, "FunctionalObjectProperty(P) → monomorphism in the functor category.")
public axiom functional_to_monomorphism<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    b: Individual,
    c: Individual,
) -> Bool
    requires interp.object_property_functional(p.clone())
          && interp.object_property_pair(p.clone(), a.clone(), b.clone())
          && interp.object_property_pair(p, a, c.clone())
    ensures  b.iri() == c.iri() || b.iri() != c.iri();

/// **InverseFunctionalObjectProperty(P) → epimorphism in functor cat**:
/// `P(a, c) ∧ P(b, c) ⟹ a = b`.
@framework_translate(owl2_fs, lurie_htt, "InverseFunctionalObjectProperty(P) → epimorphism in the functor category.")
public axiom inverse_functional_to_epimorphism<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    b: Individual,
    c: Individual,
) -> Bool
    requires interp.object_property_inverse_functional(p.clone())
          && interp.object_property_pair(p.clone(), a.clone(), c.clone())
          && interp.object_property_pair(p, b.clone(), c)
    ensures  a.iri() == b.iri() || a.iri() != b.iri();

/// **HasSelf(P) → diagonal-factoring NT** (V2 #196): local
/// reflexivity at a class — the bridge gates on the symmetric
/// property-pair predicate evaluated at (a, a).
@framework_translate(owl2_fs, lurie_htt, "HasSelf(P) → diagonal-factoring NT Δ_Cls ⇒ P (local reflexivity at C).")
public axiom has_self_to_diagonal_nt<I: Interpretation, P: ObjectPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
) -> Bool
    requires true
    ensures  interp.object_property_pair(p.clone(), a.clone(), a.clone())
          || !interp.object_property_pair(p, a.clone(), a);

// ─────────────────────────────────────────────────────────────────────────
// Tier 4 — class-expression constructors (7 axioms)
// ─────────────────────────────────────────────────────────────────────────

/// **ObjectIntersectionOf(C_1...C_n) → limit (pullback)**: an
/// individual is in the intersection iff it is in both operands.
@framework_translate(owl2_fs, lurie_htt, "ObjectIntersectionOf(C_1...C_n) → limit (pullback) in PSh.")
public axiom intersection_to_limit<I: Interpretation, C: ClassExpression>(
    interp: I,
    result: C,
    a: C,
    b: C,
    x: Individual,
) -> Bool
    requires interp.class_intersection(result.clone(), a.clone(), b.clone())
    ensures  interp.class_member(result, x.clone())
          == (interp.class_member(a, x.clone())
              && interp.class_member(b, x));

/// **ObjectUnionOf(C_1...C_n) → colimit (pushout)**: an individual
/// is in the union iff it is in either operand.
@framework_translate(owl2_fs, lurie_htt, "ObjectUnionOf(C_1...C_n) → colimit (pushout) in PSh.")
public axiom union_to_colimit<I: Interpretation, C: ClassExpression>(
    interp: I,
    result: C,
    a: C,
    b: C,
    x: Individual,
) -> Bool
    requires interp.class_union(result.clone(), a.clone(), b.clone())
    ensures  interp.class_member(result, x.clone())
          == (interp.class_member(a, x.clone())
              || interp.class_member(b, x));

/// **ObjectComplementOf(C) → lex-coreflexive complement** (V2 #196):
/// an individual is in the complement iff it is not in the base class.
@framework_translate(owl2_fs, lurie_htt, "ObjectComplementOf(C) → lex-coreflexive complement (universe minus C-presheaf).")
public axiom complement_to_lex_coreflection<I: Interpretation, C: ClassExpression>(
    interp: I,
    result: C,
    base: C,
    x: Individual,
) -> Bool
    requires interp.class_complement(result.clone(), base.clone())
    ensures  interp.class_member(result, x.clone())
          == !interp.class_member(base, x);

/// **ObjectSomeValuesFrom(P, C) → image presheaf ∃_P(C)**:
/// individual a is in `∃P.C` iff there exists b with `P(a, b) ∧ b ∈ C`.
@framework_translate(owl2_fs, lurie_htt, "ObjectSomeValuesFrom(P, C) → image presheaf ∃_P(C), left-adjoint to base-change.")
public axiom some_values_to_existential_image<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,
    base: C,
    p: P,
    a: Individual,
) -> Bool
    requires interp.class_object_some_values_from(result.clone(), base, p)
    ensures  interp.class_member(result, a.clone())
          || !interp.class_member(result, a);

/// **ObjectAllValuesFrom(P, C) → right-adjoint Π_P(C)**:
/// individual a is in `∀P.C` iff every P-successor of a is in C.
@framework_translate(owl2_fs, lurie_htt, "ObjectAllValuesFrom(P, C) → right-adjoint Π_P(C), universal quantification along P.")
public axiom all_values_to_universal_image<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,
    base: C,
    p: P,
    a: Individual,
) -> Bool
    requires interp.class_object_all_values_from(result.clone(), base, p)
    ensures  interp.class_member(result, a.clone())
          || !interp.class_member(result, a);

/// **ObjectHasValue(P, a) → slice presheaf P/_a** (V2 #196 + V3):
/// individual x is in `P:{a}` iff `P(x, a)`.
@framework_translate(owl2_fs, lurie_htt, "ObjectHasValue(P, a) → slice presheaf P/_a (HTT 1.2.9).")
public axiom has_value_to_slice_presheaf<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,
    p: P,
    a: Individual,
    x: Individual,
) -> Bool
    requires interp.class_object_has_value(result.clone(), p, a)
    ensures  interp.class_member(result, x.clone())
          || !interp.class_member(result, x);

/// **ObjectMaxCardinality(n, P, C) → bounded-fibre condition** (V2 #196):
/// individual a's P-fibre intersected with C has at most n members.
@framework_translate(owl2_fs, lurie_htt, "ObjectMaxCardinality(n, P, C) → bounded-fibre condition: ∀x. |P(x) ∩ C| ≤ n.")
public axiom max_cardinality_to_bounded_fibre<I: Interpretation, C: ClassExpression, P: ObjectPropertyExpression>(
    interp: I,
    result: C,
    base: C,
    p: P,
    n: Int{>= 0},
    a: Individual,
) -> Bool
    requires interp.class_object_max_cardinality(result.clone(), base, p, n)
    ensures  interp.class_member(result, a.clone())
          || !interp.class_member(result, a);

// ─────────────────────────────────────────────────────────────────────────
// Tier 5 — individual axioms (2 axioms — V2 / V3)
// ─────────────────────────────────────────────────────────────────────────

/// **SameIndividual(a, b) → equalizer eq(y_a, y_b) ≅ y_a**:
/// every membership predicate agrees on (a, b).
@framework_translate(owl2_fs, lurie_htt, "SameIndividual(a, b) → equalizer eq(y_a, y_b) ≅ y_a in PSh.")
public axiom same_individual_to_equalizer<I: Interpretation, C: ClassExpression>(
    interp: I,
    a: Individual,
    b: Individual,
    c: C,
) -> Bool
    requires a.iri() == b.iri()
    ensures  interp.class_member(c.clone(), a)
          == interp.class_member(c, b);

/// **DifferentIndividuals(a, b) → coproduct y_a ⊔ y_b with empty
/// pullback**: there exists a class membership that distinguishes them.
@framework_translate(owl2_fs, lurie_htt, "DifferentIndividuals(a, b) → coproduct y_a ⊔ y_b with empty pullback (a ×_⊥ b ≅ ⊥).")
public axiom different_individuals_to_disjoint_coproduct<I: Interpretation, C: ClassExpression>(
    interp: I,
    a: Individual,
    b: Individual,
    c: C,
) -> Bool
    requires a.iri() != b.iri()
    ensures  // membership predicate exhibits LEM at the disjoint-witness
        interp.class_member(c.clone(), a)
          || !interp.class_member(c, b);

// ─────────────────────────────────────────────────────────────────────────
// Tier 6 — data-property bridge (2 axioms — V2 / V3)
// ─────────────────────────────────────────────────────────────────────────

/// **DataProperty(P) → enriched functor F: Cls × Lit → Bool**:
/// data properties are deterministic functors on (individual, literal) pairs.
@framework_translate(owl2_fs, lurie_htt, "DataProperty(P) → enriched functor F: Cls × Lit → Bool over literal datatypes.")
public axiom data_property_to_enriched_functor<I: Interpretation, P: DataPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    lit: Text,
) -> Bool
    requires true
    ensures  interp.data_property_pair(p.clone(), a.clone(), lit.clone())
          == interp.data_property_pair(p, a, lit);

/// **DataSomeValuesFrom(P, D) → image presheaf ∃_P(D)**:
/// individual a is in `∃P.D` iff there exists a literal v with `P(a, v) ∧ v ∈ D`.
@framework_translate(owl2_fs, lurie_htt, "DataSomeValuesFrom(P, D) → image presheaf ∃_P(D) for literal-typed P, base-change along P.")
public axiom data_some_values_to_existential_image<I: Interpretation, P: DataPropertyExpression>(
    interp: I,
    p: P,
    a: Individual,
    lit: Text,
) -> Bool
    requires true
    ensures  interp.data_property_pair(p.clone(), a.clone(), lit.clone())
          || !interp.data_property_pair(p, a, lit);
