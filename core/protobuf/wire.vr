// =============================================================================
// protobuf/wire.vr — Varint, tag, wire-type codec
// =============================================================================

module core.protobuf.wire;

mount core.*;
mount core.protobuf.error.{ProtobufError, DecodeResult};

// =============================================================================
// Hostile-input safety caps
// =============================================================================

/// Per-field maximum on length-delimited fields (string / bytes /
/// embedded-message). Without this cap a peer can send a varint
/// length up to 2^64 - 1 and trigger gigabyte-scale allocations on
/// `read_string` / `read_bytes` / `read_message`. 32 MiB matches the
/// HTTP Content-Length cap from #77 and Google's reference protoc
/// default ballpark.
///
/// Applications that legitimately need larger fields should split
/// payloads into multiple messages or use streaming APIs above the
/// wire layer.
public const MAX_LENGTH_DELIM: Int = 32 * 1024 * 1024;

// =============================================================================
// WireType
// =============================================================================

public type WireType is
    | Varint
    | Fixed64
    | LengthDelim
    | Fixed32;

implement WireType {
    public fn to_u8(&self) -> UInt8 {
        match self {
            WireType.Varint      => 0,
            WireType.Fixed64     => 1,
            WireType.LengthDelim => 2,
            WireType.Fixed32     => 5,
        }
    }

    public fn from_u8(b: UInt8) -> Result<WireType, ProtobufError> {
        match b {
            0 => Ok(WireType.Varint),
            1 => Ok(WireType.Fixed64),
            2 => Ok(WireType.LengthDelim),
            3 => Err(ProtobufError.UnsupportedGroup),
            4 => Err(ProtobufError.UnsupportedGroup),
            5 => Ok(WireType.Fixed32),
            _ => Err(ProtobufError.InvalidWireType(b)),
        }
    }
}

// =============================================================================
// Tag — (field_number << 3) | wire_type
// =============================================================================

/// Encode a (field_number, wire_type) tag as a varint tag-value.
@inline
public fn tag_value(field_number: UInt32, wire_type: WireType) -> UInt32 {
    (field_number << 3) | (wire_type.to_u8() as UInt32)
}

public fn write_tag(out: &mut List<Byte>, field_number: UInt32, wire_type: WireType) {
    write_varint(out, tag_value(field_number, wire_type) as UInt64);
}

// =============================================================================
// Varint encode / decode
// =============================================================================

/// Write an unsigned 64-bit varint. Maximum 10 bytes.
public fn write_varint(out: &mut List<Byte>, value: UInt64) {
    let mut v = value;
    while v >= 0x80 {
        out.push(((v & 0x7F) | 0x80) as Byte);
        v = v >> 7;
    }
    out.push((v & 0x7F) as Byte);
}

/// Read an unsigned 64-bit varint. Consumes up to 10 bytes.
///
/// Rejects non-canonical encodings where the 10th byte carries
/// data bits that would overflow `UInt64`. Bytes 0..8 each
/// contribute 7 data bits (= 63 bits total); the 10th byte
/// contributes only one final bit at position 63. Its data bits
/// 1..6 (mask `0x7E`) cannot be represented in 64 bits and a
/// `(byte & 0x7F) << 63` would silently truncate them — letting a
/// hostile peer submit multiple distinct encodings that decode to
/// the same `UInt64`. Matches Google protobuf's reference
/// validation (see `google/protobuf/io/coded_stream.cc`).
public fn read_varint(buf: &[Byte], pos: Int) -> Result<(UInt64, Int), ProtobufError> {
    let mut v: UInt64 = 0;
    let mut shift = 0;
    let mut p = pos;
    let mut bytes_read = 0;
    while bytes_read < 10 {
        if p >= buf.len() { return Err(ProtobufError.UnexpectedEof); }
        let b = buf[p] as UInt64;
        if bytes_read == 9 && (b & 0x7F) > 1 {
            // Tenth byte must encode at most bit 63 of the result.
            return Err(ProtobufError.VarintOverflow);
        }
        v = v | ((b & 0x7F) << shift);
        p = p + 1;
        bytes_read = bytes_read + 1;
        if (b & 0x80) == 0 {
            return Ok((v, p));
        }
        shift = shift + 7;
    }
    // 10 bytes with MSB still set → overflow (u64 max fits in 10 varint bytes).
    Err(ProtobufError.VarintOverflow)
}

// =============================================================================
// ZigZag — signed-varint encoding
// =============================================================================

@inline
public fn encode_zigzag_32(n: Int32) -> UInt32 {
    ((n << 1) ^ (n >> 31)) as UInt32
}

@inline
public fn encode_zigzag_64(n: Int64) -> UInt64 {
    ((n << 1) ^ (n >> 63)) as UInt64
}

@inline
public fn decode_zigzag_32(n: UInt32) -> Int32 {
    ((n >> 1) as Int32) ^ -((n & 1) as Int32)
}

@inline
public fn decode_zigzag_64(n: UInt64) -> Int64 {
    ((n >> 1) as Int64) ^ -((n & 1) as Int64)
}

public fn write_sint32(out: &mut List<Byte>, value: Int32) {
    write_varint(out, encode_zigzag_32(value) as UInt64);
}

public fn write_sint64(out: &mut List<Byte>, value: Int64) {
    write_varint(out, encode_zigzag_64(value));
}

public fn read_sint32(buf: &[Byte], pos: Int) -> Result<(Int32, Int), ProtobufError> {
    let (v, p) = read_varint(buf, pos)?;
    Ok((decode_zigzag_32(v as UInt32), p))
}

public fn read_sint64(buf: &[Byte], pos: Int) -> Result<(Int64, Int), ProtobufError> {
    let (v, p) = read_varint(buf, pos)?;
    Ok((decode_zigzag_64(v), p))
}

// =============================================================================
// Fixed-width encode / decode (little-endian)
// =============================================================================

public fn write_fixed32(out: &mut List<Byte>, value: UInt32) {
    out.push((value & 0xFF) as Byte);
    out.push(((value >> 8) & 0xFF) as Byte);
    out.push(((value >> 16) & 0xFF) as Byte);
    out.push(((value >> 24) & 0xFF) as Byte);
}

public fn write_fixed64(out: &mut List<Byte>, value: UInt64) {
    let mut i = 0;
    while i < 8 {
        out.push(((value >> (i * 8)) & 0xFF) as Byte);
        i = i + 1;
    }
}

public fn read_fixed32(buf: &[Byte], pos: Int) -> Result<(UInt32, Int), ProtobufError> {
    if pos + 4 > buf.len() { return Err(ProtobufError.UnexpectedEof); }
    let v = (buf[pos] as UInt32)
        | ((buf[pos + 1] as UInt32) << 8)
        | ((buf[pos + 2] as UInt32) << 16)
        | ((buf[pos + 3] as UInt32) << 24);
    Ok((v, pos + 4))
}

public fn read_fixed64(buf: &[Byte], pos: Int) -> Result<(UInt64, Int), ProtobufError> {
    if pos + 8 > buf.len() { return Err(ProtobufError.UnexpectedEof); }
    let mut v: UInt64 = 0;
    let mut i = 0;
    while i < 8 {
        v = v | ((buf[pos + i] as UInt64) << (i * 8));
        i = i + 1;
    }
    Ok((v, pos + 8))
}

public fn write_float32(out: &mut List<Byte>, value: Float) {
    write_fixed32(out, @intrinsic("verum.float.f32_to_bits", value) as UInt32);
}

public fn write_float64(out: &mut List<Byte>, value: Float) {
    write_fixed64(out, @intrinsic("verum.float.f64_to_bits", value) as UInt64);
}

// =============================================================================
// Bool / String / Bytes
// =============================================================================

public fn write_bool(out: &mut List<Byte>, value: Bool) {
    write_varint(out, if value { 1_u64 } else { 0_u64 });
}

public fn write_string(out: &mut List<Byte>, value: &Text) {
    let bytes = value.as_bytes();
    write_varint(out, bytes.len() as UInt64);
    let mut i = 0;
    while i < bytes.len() {
        out.push(bytes[i]);
        i = i + 1;
    }
}

public fn write_bytes(out: &mut List<Byte>, value: &[Byte]) {
    write_varint(out, value.len() as UInt64);
    let mut i = 0;
    while i < value.len() {
        out.push(value[i]);
        i = i + 1;
    }
}

// =============================================================================
// ProtobufCursor — streaming reader
// =============================================================================

public type ProtobufCursor is {
    buf: List<Byte>,
    pos: Int,
}

implement ProtobufCursor {
    public fn new(buf: &[Byte]) -> ProtobufCursor {
        let mut copy = List.with_capacity(buf.len());
        copy.extend_from_slice(buf);
        ProtobufCursor { buf: copy, pos: 0 }
    }

    public fn at_end(&self) -> Bool { self.pos >= self.buf.len() }
    public fn position(&self) -> Int { self.pos }

    /// Read a tag — returns (field_number, wire_type).
    public fn read_tag(&mut self) -> Result<(UInt32, WireType), ProtobufError> {
        let (tag, new_pos) = read_varint(&self.buf, self.pos)?;
        self.pos = new_pos;
        let wire_type = WireType.from_u8((tag & 0x07) as UInt8)?;
        let field_number = (tag >> 3) as UInt32;
        if field_number == 0 {
            return Err(ProtobufError.InvalidFieldNumber(field_number as UInt64));
        }
        Ok((field_number, wire_type))
    }

    public fn read_varint(&mut self) -> Result<UInt64, ProtobufError> {
        let (v, p) = read_varint(&self.buf, self.pos)?;
        self.pos = p;
        Ok(v)
    }

    public fn read_sint32(&mut self) -> Result<Int32, ProtobufError> {
        let (v, p) = read_sint32(&self.buf, self.pos)?;
        self.pos = p;
        Ok(v)
    }

    public fn read_sint64(&mut self) -> Result<Int64, ProtobufError> {
        let (v, p) = read_sint64(&self.buf, self.pos)?;
        self.pos = p;
        Ok(v)
    }

    public fn read_fixed32(&mut self) -> Result<UInt32, ProtobufError> {
        let (v, p) = read_fixed32(&self.buf, self.pos)?;
        self.pos = p;
        Ok(v)
    }

    public fn read_fixed64(&mut self) -> Result<UInt64, ProtobufError> {
        let (v, p) = read_fixed64(&self.buf, self.pos)?;
        self.pos = p;
        Ok(v)
    }

    public fn read_bool(&mut self) -> Result<Bool, ProtobufError> {
        let v = self.read_varint()?;
        Ok(v != 0)
    }

    /// Read a length-delimited slice. Returns (start, len) offsets into
    /// the buffer (no copy).
    ///
    /// Defends against hostile inputs in three layers:
    ///
    ///  1. Reject `len` values where the cast UInt64 → Int produced
    ///     a negative number — that means the wire varint encoded
    ///     a value > Int.MAX (2^63 - 1), which can never fit in a
    ///     practical buffer regardless.
    ///  2. Reject `len > MAX_LENGTH_DELIM` so callers (`read_string`,
    ///     `read_bytes`, `read_message`) cannot pre-allocate gigabyte-
    ///     scale buffers from a single malicious varint.
    ///  3. Use overflow-checked addition for `pos + len` so a peer
    ///     can't underflow `self.pos + len > self.buf.len()` via
    ///     i64 wraparound and subsequently corrupt the read cursor.
    public fn read_length_delim_view(&mut self) -> Result<(Int, Int), ProtobufError> {
        let len_u64 = self.read_varint()?;
        // Layer 1: reject sign-overflow on the UInt64 → Int cast.
        if len_u64 > (Int.MAX as UInt64) {
            return Err(ProtobufError.LengthTooLarge {
                declared: -1,            // unrepresentable in Int
                limit: MAX_LENGTH_DELIM,
            });
        }
        let len = len_u64 as Int;
        // Layer 2: enforce per-field cap.
        if len > MAX_LENGTH_DELIM {
            return Err(ProtobufError.LengthTooLarge {
                declared: len,
                limit: MAX_LENGTH_DELIM,
            });
        }
        // Layer 3: overflow-checked pos + len. Both operands are
        // non-negative Ints and len is bounded by MAX_LENGTH_DELIM,
        // so this cannot overflow in practice — but the explicit
        // check documents the invariant and survives future cap
        // increases.
        let end = self.pos + len;
        if end < self.pos || end > self.buf.len() {
            return Err(ProtobufError.InvalidLength {
                declared: len,
                available: self.buf.len() - self.pos,
            });
        }
        let start = self.pos;
        self.pos = end;
        Ok((start, len))
    }

    /// Read a string (validates UTF-8).
    public fn read_string(&mut self) -> Result<Text, ProtobufError> {
        let (start, len) = self.read_length_delim_view()?;
        let mut copy = List.with_capacity(len);
        copy.extend_from_slice(&self.buf.as_slice()[start..start + len]);
        match Text.from_utf8(&copy) {
            Ok(t) => Ok(t),
            Err(_) => Err(ProtobufError.InvalidUtf8),
        }
    }

    /// Read a `bytes` field as an owned List.
    public fn read_bytes(&mut self) -> Result<List<Byte>, ProtobufError> {
        let (start, len) = self.read_length_delim_view()?;
        let mut out = List.with_capacity(len);
        out.extend_from_slice(&self.buf.as_slice()[start..start + len]);
        Ok(out)
    }

    /// Skip an entire field of the given wire type. Used for unknown
    /// fields that the receiver doesn't care about.
    public fn skip(&mut self, wire_type: WireType) -> Result<(), ProtobufError> {
        match wire_type {
            WireType.Varint => { let _ = self.read_varint()?; Ok(()) }
            WireType.Fixed64 => { let _ = self.read_fixed64()?; Ok(()) }
            WireType.Fixed32 => { let _ = self.read_fixed32()?; Ok(()) }
            WireType.LengthDelim => {
                let _ = self.read_length_delim_view()?;
                Ok(())
            }
        }
    }
}
