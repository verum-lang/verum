// =============================================================================
// protobuf/error.vr — ProtobufError
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.protobuf.error;

mount core.*;

public type ProtobufError is
    /// Buffer ended mid-field — streamed reader should read more.
    | UnexpectedEof
    /// Varint exceeded 10 bytes.
    | VarintOverflow
    /// Unrecognised wire-type tag bits.
    | InvalidWireType(UInt8)
    /// Length-delimited field claims a length larger than the buffer.
    | InvalidLength { declared: Int, available: Int }
    /// Length-delimited field's declared length exceeds the per-field
    /// safety cap MAX_LENGTH_DELIM. Defends against hostile peers
    /// sending a varint length up to 2^64 - 1 to trigger OOM.
    | LengthTooLarge { declared: Int, limit: Int }
    /// UTF-8 validation failed on a `string` field.
    | InvalidUtf8
    /// Field number out of range — fields must be 1..=2^29-1.
    | InvalidFieldNumber(UInt64)
    /// Deprecated start-group / end-group wire types encountered.
    | UnsupportedGroup;

implement Display for ProtobufError {
    /// Qualify variants to dodge task #17/#39 bare-name first-wins.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ProtobufError.UnexpectedEof                    => f.write_str("protobuf: unexpected EOF"),
            ProtobufError.VarintOverflow                   => f.write_str("protobuf: varint exceeded 10 bytes"),
            ProtobufError.InvalidWireType(b)               => f.write_str(f"protobuf: invalid wire-type tag {b}".as_str()),
            ProtobufError.InvalidLength { declared, available } =>
                f.write_str(f"protobuf: declared length {declared} exceeds available {available}".as_str()),
            ProtobufError.LengthTooLarge { declared, limit } =>
                f.write_str(f"protobuf: declared length {declared} exceeds safety limit {limit}".as_str()),
            ProtobufError.InvalidUtf8                      => f.write_str("protobuf: invalid UTF-8 in string field"),
            ProtobufError.InvalidFieldNumber(n)            => f.write_str(f"protobuf: invalid field number {n}".as_str()),
            ProtobufError.UnsupportedGroup                 => f.write_str("protobuf: deprecated group wire type"),
        }
    }
}

implement Debug for ProtobufError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ProtobufError.UnexpectedEof                    => f.write_str("UnexpectedEof"),
            ProtobufError.VarintOverflow                   => f.write_str("VarintOverflow"),
            ProtobufError.InvalidWireType(b)               => f.write_str(f"InvalidWireType({b})".as_str()),
            ProtobufError.InvalidLength { declared, available } =>
                f.write_str(f"InvalidLength {{ declared: {declared}, available: {available} }}".as_str()),
            ProtobufError.LengthTooLarge { declared, limit } =>
                f.write_str(f"LengthTooLarge {{ declared: {declared}, limit: {limit} }}".as_str()),
            ProtobufError.InvalidUtf8                      => f.write_str("InvalidUtf8"),
            ProtobufError.InvalidFieldNumber(n)            => f.write_str(f"InvalidFieldNumber({n})".as_str()),
            ProtobufError.UnsupportedGroup                 => f.write_str("UnsupportedGroup"),
        }
    }
}

implement Eq for ProtobufError {
    fn eq(&self, other: &ProtobufError) -> Bool {
        match (self, other) {
            (ProtobufError.UnexpectedEof,                  ProtobufError.UnexpectedEof)                  => true,
            (ProtobufError.VarintOverflow,                 ProtobufError.VarintOverflow)                 => true,
            (ProtobufError.InvalidWireType(a),             ProtobufError.InvalidWireType(b))             => a == b,
            (ProtobufError.InvalidLength { declared: da, available: aa },
             ProtobufError.InvalidLength { declared: db, available: ab }) => da == db && aa == ab,
            (ProtobufError.LengthTooLarge { declared: da, limit: la },
             ProtobufError.LengthTooLarge { declared: db, limit: lb })   => da == db && la == lb,
            (ProtobufError.InvalidUtf8,                    ProtobufError.InvalidUtf8)                    => true,
            (ProtobufError.InvalidFieldNumber(a),          ProtobufError.InvalidFieldNumber(b))          => a == b,
            (ProtobufError.UnsupportedGroup,               ProtobufError.UnsupportedGroup)               => true,
            _ => false,
        }
    }
}

public type DecodeResult<T> is Result<T, ProtobufError>;
