// =============================================================================
// storage/s3/client.vr — S3-compatible object store
// =============================================================================
// Layer: 4 (Storage)
// Dependencies: core, base, collections, encoding/{hex, xml-style},
//               net/http, security/hash/sha256, time/system_time,
//               storage/{types, s3/signing}
// =============================================================================
//
// **Purpose.** Production-grade client for AWS S3 + S3-compatible
// object stores (MinIO, Cloudflare R2, Wasabi, GCS S3-mode, Backblaze
// B2 S3 endpoint). Implements `core.storage.types::ObjectStore`.
//
// **Authentication.** AWS Signature V4 via
// `core.storage.s3.signing`. Supports permanent IAM-user keys + STS
// session credentials (with `X-Amz-Security-Token`).
//
// **Multipart upload.** Single-shot `put` works up to 5 GiB; for
// larger objects, callers use the multipart helpers
// (`init_multipart` / `upload_part` / `complete_multipart`).
//
// **Endpoint flavours.** Path-style (`<endpoint>/<bucket>/<key>`)
// + virtual-hosted-style (`<bucket>.<endpoint>/<key>`). MinIO +
// some S3-compatible deployments require path-style; modern AWS
// uses virtual-hosted by default. Configurable via `path_style`.
// =============================================================================

@arch_module(
    foundation:    Foundation.ZfcTwoInacc,
    stratum:       MsfsStratum.LCls,
    lifecycle:     Lifecycle.Theorem("v0.1"),
    declarations: ShapeDeclarations {
        purpose: Some(Purpose {
            role: "S3-compatible object-store client implementing ObjectStore (SigV4-authenticated)".to_text(),
            k_min: CveThresholdK.FullWitness,
            v_min: CveThresholdV.NamedCertification,
            e_min: CveThresholdE.StructurallyReady,
        }),
        substrate:      Some(CognitiveSubstrate.AnalyticDecompositional),
        anchoring:      Some(FormalAnchoring.CurryHowardLawvere),
        e_sense:        Some(ExecutabilitySense.StructuralReadiness),
        self_reference: None,
    },
)
module core.storage.s3.client;

mount core.*;
mount base.{Result, Ok, Err, Maybe, Some, None, Text, Bool, Int};
mount collections.{List, Map};
mount encoding.hex.{encode as hex_encode};
mount net.http.{HttpClient, Request, Response, Method, StatusCode, HttpError};
mount security.hash.sha256.{Sha256, digest as sha256_digest};
mount time.system_time.epoch_seconds;
mount time.rfc3339.{Rfc3339Time, parse_rfc3339};

mount core.storage.types.{
    ObjectStore, StorageError, ObjectMetadata,
    PutOptions, GetOptions, ListOptions, ListPage,
    PresignOptions, PresignMethod,
    put_options_default, get_options_default,
};
mount core.storage.s3.signing.{
    AwsCredentials, sign_request, presign as sigv4_presign,
};

// =============================================================================
// Configuration
// =============================================================================

@derive(Clone, Debug)
public type S3Config is {
    /// Endpoint base URL — `https://s3.us-west-2.amazonaws.com` for
    /// AWS, `https://minio.local:9000` for MinIO, etc.
    endpoint:    Text,
    region:      Text,
    bucket:      Text,
    credentials: AwsCredentials,
    /// Use path-style addressing (`<endpoint>/<bucket>/...`). Set
    /// to true for MinIO / older AWS regions; false for modern AWS.
    path_style:  Bool,
    timeout_ms:  Int { >= 1 },
};

pub fn s3_config(
    endpoint: Text, region: Text, bucket: Text, creds: AwsCredentials,
) -> S3Config {
    S3Config {
        endpoint,
        region,
        bucket,
        credentials: creds,
        path_style:  false,
        timeout_ms:  30_000,
    }
}

// =============================================================================
// Client
// =============================================================================

@derive(Clone, Debug)
public type S3Client<C: HttpClient> is {
    config: S3Config,
    http:   C,
};

pub fn s3_client<C: HttpClient>(config: S3Config, http: C) -> S3Client<C> {
    S3Client { config, http }
}

// =============================================================================
// ObjectStore implementation
// =============================================================================

implement<C: HttpClient> ObjectStore for S3Client<C> {
    async fn put(
        &self,
        key:     &Text,
        data:    &List<Byte>,
        options: &PutOptions,
    ) -> Result<ObjectMetadata, StorageError> {
        let url = compose_object_url(&self.config, key);
        let path = compose_object_path(&self.config, key);
        let host = extract_host(&self.config.endpoint);
        let now = current_iso8601_basic();

        let mut headers: Map<Text, Text> = Map.new();
        headers.insert("host".to_text(), host.clone());
        headers.insert("content-type".to_text(), options.content_type.clone());
        headers.insert("content-length".to_text(), f"{data.len()}");
        if options.if_none_match {
            headers.insert("if-none-match".to_text(), "*".to_text());
        }
        if let Some(et) = &options.if_match_etag {
            headers.insert("if-match".to_text(), et.clone());
        }
        for (k, v) in options.user_metadata.iter() {
            headers.insert(format!("x-amz-meta-{}", k.to_lower()).to_text(), v.clone());
        }

        let signed = sign_request(
            &"PUT".to_text(),
            &path,
            &List.new(),
            &headers,
            data,
            &self.config.credentials,
            &self.config.region,
            &"s3".to_text(),
            &now,
        ).map_err(|e| StorageError.Backend(e))?;
        for (k, v) in signed.headers.iter() { headers.insert(k.clone(), v.clone()); }

        let req = Request {
            method:  Method.Put,
            url:     url.clone(),
            headers,
            body:    data.clone(),
        };
        let resp = self.http.send(&req).await
            .map_err(|e| StorageError.Network(format!("{e}").to_text()))?;
        if resp.status.is_409() {
            return Err(StorageError.Conflict(extract_error_message(&resp)));
        }
        if resp.status.is_403() {
            return Err(StorageError.AccessDenied(extract_error_message(&resp)));
        }
        if !resp.status.is_success() {
            return Err(StorageError.Backend(format!("PUT HTTP {} {}", resp.status, extract_error_message(&resp)).to_text()));
        }
        let etag = resp.headers.get(&"etag".to_text())
            .map(|v| strip_quotes(v))
            .unwrap_or_else(|| "".to_text());
        Ok(ObjectMetadata {
            key:           key.clone(),
            content_length: data.len(),
            content_type:  options.content_type.clone(),
            etag,
            last_modified: now_rfc3339(),
            user_metadata: options.user_metadata.clone(),
        })
    }

    async fn get(
        &self,
        key:     &Text,
        options: &GetOptions,
    ) -> Result<(ObjectMetadata, List<Byte>), StorageError> {
        let url = compose_object_url(&self.config, key);
        let path = compose_object_path(&self.config, key);
        let host = extract_host(&self.config.endpoint);
        let now = current_iso8601_basic();

        let mut headers: Map<Text, Text> = Map.new();
        headers.insert("host".to_text(), host.clone());
        if let Some((start, end)) = options.range {
            headers.insert("range".to_text(), format!("bytes={}-{}", start, end).to_text());
        }
        if let Some(etag) = &options.if_none_match {
            headers.insert("if-none-match".to_text(), etag.clone());
        }

        let empty_body: List<Byte> = List.new();
        let signed = sign_request(
            &"GET".to_text(),
            &path,
            &List.new(),
            &headers,
            &empty_body,
            &self.config.credentials,
            &self.config.region,
            &"s3".to_text(),
            &now,
        ).map_err(|e| StorageError.Backend(e))?;
        for (k, v) in signed.headers.iter() { headers.insert(k.clone(), v.clone()); }

        let req = Request {
            method:  Method.Get,
            url:     url.clone(),
            headers,
            body:    List.new(),
        };
        let resp = self.http.send(&req).await
            .map_err(|e| StorageError.Network(format!("{e}").to_text()))?;
        if resp.status.is_404() {
            return Err(StorageError.NotFound(key.clone()));
        }
        if !resp.status.is_success() {
            return Err(StorageError.Backend(format!("GET HTTP {} {}", resp.status, extract_error_message(&resp)).to_text()));
        }
        let meta = parse_metadata_from_headers(key, &resp.headers, resp.body.len());
        Ok((meta, resp.body))
    }

    async fn head(&self, key: &Text) -> Result<ObjectMetadata, StorageError> {
        let url = compose_object_url(&self.config, key);
        let path = compose_object_path(&self.config, key);
        let host = extract_host(&self.config.endpoint);
        let now = current_iso8601_basic();

        let mut headers: Map<Text, Text> = Map.new();
        headers.insert("host".to_text(), host.clone());
        let empty_body: List<Byte> = List.new();
        let signed = sign_request(
            &"HEAD".to_text(),
            &path,
            &List.new(),
            &headers,
            &empty_body,
            &self.config.credentials,
            &self.config.region,
            &"s3".to_text(),
            &now,
        ).map_err(|e| StorageError.Backend(e))?;
        for (k, v) in signed.headers.iter() { headers.insert(k.clone(), v.clone()); }

        let req = Request {
            method:  Method.Head,
            url:     url.clone(),
            headers,
            body:    List.new(),
        };
        let resp = self.http.send(&req).await
            .map_err(|e| StorageError.Network(format!("{e}").to_text()))?;
        if resp.status.is_404() { return Err(StorageError.NotFound(key.clone())); }
        if !resp.status.is_success() {
            return Err(StorageError.Backend(format!("HEAD HTTP {}", resp.status).to_text()));
        }
        let cl = resp.headers.get(&"content-length".to_text())
            .and_then(|v| Int.parse(v).ok()).unwrap_or(0);
        Ok(parse_metadata_from_headers(key, &resp.headers, cl))
    }

    async fn delete(&self, key: &Text) -> Result<(), StorageError> {
        let url = compose_object_url(&self.config, key);
        let path = compose_object_path(&self.config, key);
        let host = extract_host(&self.config.endpoint);
        let now = current_iso8601_basic();

        let mut headers: Map<Text, Text> = Map.new();
        headers.insert("host".to_text(), host.clone());
        let empty_body: List<Byte> = List.new();
        let signed = sign_request(
            &"DELETE".to_text(),
            &path,
            &List.new(),
            &headers,
            &empty_body,
            &self.config.credentials,
            &self.config.region,
            &"s3".to_text(),
            &now,
        ).map_err(|e| StorageError.Backend(e))?;
        for (k, v) in signed.headers.iter() { headers.insert(k.clone(), v.clone()); }

        let req = Request {
            method:  Method.Delete,
            url:     url.clone(),
            headers,
            body:    List.new(),
        };
        let resp = self.http.send(&req).await
            .map_err(|e| StorageError.Network(format!("{e}").to_text()))?;
        // S3 delete is idempotent — 204 even on missing keys.
        if !resp.status.is_success() {
            return Err(StorageError.Backend(format!("DELETE HTTP {}", resp.status).to_text()));
        }
        Ok(())
    }

    async fn list(&self, options: &ListOptions) -> Result<ListPage, StorageError> {
        let mut q: List<(Text, Text)> = List.new();
        q.push(("list-type".to_text(), "2".to_text()));
        if let Some(p) = &options.prefix {
            q.push(("prefix".to_text(), p.clone()));
        }
        if let Some(d) = &options.delimiter {
            q.push(("delimiter".to_text(), d.clone()));
        }
        if let Some(t) = &options.continuation_token {
            q.push(("continuation-token".to_text(), t.clone()));
        }
        q.push(("max-keys".to_text(), f"{options.max_keys}"));

        let path = compose_bucket_path(&self.config);
        let url  = format!("{}?{}", compose_bucket_url(&self.config), encode_query(&q)).to_text();
        let host = extract_host(&self.config.endpoint);
        let now  = current_iso8601_basic();

        let mut headers: Map<Text, Text> = Map.new();
        headers.insert("host".to_text(), host.clone());
        let empty_body: List<Byte> = List.new();
        let signed = sign_request(
            &"GET".to_text(),
            &path,
            &q,
            &headers,
            &empty_body,
            &self.config.credentials,
            &self.config.region,
            &"s3".to_text(),
            &now,
        ).map_err(|e| StorageError.Backend(e))?;
        for (k, v) in signed.headers.iter() { headers.insert(k.clone(), v.clone()); }

        let req = Request {
            method:  Method.Get,
            url:     url,
            headers,
            body:    List.new(),
        };
        let resp = self.http.send(&req).await
            .map_err(|e| StorageError.Network(format!("{e}").to_text()))?;
        if !resp.status.is_success() {
            return Err(StorageError.Backend(format!("LIST HTTP {} {}", resp.status, extract_error_message(&resp)).to_text()));
        }
        parse_list_v2_response(&resp.body)
    }

    fn presign(
        &self,
        key:     &Text,
        options: &PresignOptions,
    ) -> Result<Text, StorageError> {
        let path = compose_object_path(&self.config, key);
        let host = extract_host(&self.config.endpoint);
        let now = current_iso8601_basic();
        let method = match options.method {
            PresignMethod.Get    => "GET".to_text(),
            PresignMethod.Put    => "PUT".to_text(),
            PresignMethod.Head   => "HEAD".to_text(),
            PresignMethod.Delete => "DELETE".to_text(),
        };
        let mut q: List<(Text, Text)> = List.new();
        for (k, v) in options.extra_query.iter() { q.push((k.clone(), v.clone())); }

        let signed_q = sigv4_presign(
            &method, &path, &q, &host,
            &self.config.credentials,
            &self.config.region,
            &"s3".to_text(),
            &now,
            options.expires_seconds,
        ).map_err(|e| StorageError.Backend(e))?;

        let url = format!("{}?{}",
            compose_object_url(&self.config, key),
            encode_query(&signed_q),
        ).to_text();
        Ok(url)
    }

    async fn head_bucket(&self) -> Result<(), StorageError> {
        let url = compose_bucket_url(&self.config);
        let path = compose_bucket_path(&self.config);
        let host = extract_host(&self.config.endpoint);
        let now = current_iso8601_basic();

        let mut headers: Map<Text, Text> = Map.new();
        headers.insert("host".to_text(), host.clone());
        let empty_body: List<Byte> = List.new();
        let signed = sign_request(
            &"HEAD".to_text(),
            &path,
            &List.new(),
            &headers,
            &empty_body,
            &self.config.credentials,
            &self.config.region,
            &"s3".to_text(),
            &now,
        ).map_err(|e| StorageError.Backend(e))?;
        for (k, v) in signed.headers.iter() { headers.insert(k.clone(), v.clone()); }

        let req = Request {
            method:  Method.Head,
            url:     url,
            headers,
            body:    List.new(),
        };
        let resp = self.http.send(&req).await
            .map_err(|e| StorageError.Network(format!("{e}").to_text()))?;
        if resp.status.is_404() { return Err(StorageError.NotFound(self.config.bucket.clone())); }
        if resp.status.is_403() { return Err(StorageError.AccessDenied("HEAD bucket".to_text())); }
        if !resp.status.is_success() {
            return Err(StorageError.Backend(format!("HEAD bucket HTTP {}", resp.status).to_text()));
        }
        Ok(())
    }
}

// =============================================================================
// Helpers — URL composition
// =============================================================================

fn compose_object_url(cfg: &S3Config, key: &Text) -> Text {
    if cfg.path_style {
        format!("{}/{}/{}",
            trim_trailing_slash(&cfg.endpoint),
            cfg.bucket,
            key,
        ).to_text()
    } else {
        let mut endpoint = cfg.endpoint.clone();
        // Insert bucket as a hostname prefix.
        let after_scheme = match endpoint.find_str("://") {
            Some(i) => i + 3,
            None    => 0,
        };
        let scheme = endpoint.byte_substring(0, after_scheme);
        let rest   = endpoint.byte_substring(after_scheme, endpoint.len());
        format!("{}{}.{}/{}",
            scheme, cfg.bucket, trim_trailing_slash(&rest), key,
        ).to_text()
    }
}

fn compose_bucket_url(cfg: &S3Config) -> Text {
    if cfg.path_style {
        format!("{}/{}",
            trim_trailing_slash(&cfg.endpoint),
            cfg.bucket,
        ).to_text()
    } else {
        let endpoint = &cfg.endpoint;
        let after_scheme = match endpoint.find_str("://") {
            Some(i) => i + 3,
            None    => 0,
        };
        let scheme = endpoint.byte_substring(0, after_scheme);
        let rest   = endpoint.byte_substring(after_scheme, endpoint.len());
        format!("{}{}.{}",
            scheme, cfg.bucket, trim_trailing_slash(&rest),
        ).to_text()
    }
}

fn compose_object_path(cfg: &S3Config, key: &Text) -> Text {
    if cfg.path_style {
        format!("/{}/{}", cfg.bucket, key).to_text()
    } else {
        format!("/{}", key).to_text()
    }
}

fn compose_bucket_path(cfg: &S3Config) -> Text {
    if cfg.path_style { format!("/{}", cfg.bucket).to_text() }
    else { "/".to_text() }
}

fn extract_host(endpoint: &Text) -> Text {
    let after_scheme = match endpoint.find_str("://") {
        Some(i) => i + 3,
        None    => 0,
    };
    let rest = endpoint.byte_substring(after_scheme, endpoint.len());
    let host_end = match rest.find_byte_any(b"/?#") {
        Some(p) => p,
        None    => rest.len(),
    };
    rest.byte_substring(0, host_end)
}

fn trim_trailing_slash(s: &Text) -> Text {
    if s.ends_with("/") { s.byte_substring(0, s.len() - 1) }
    else { s.clone() }
}

fn encode_query(pairs: &List<(Text, Text)>) -> Text {
    let mut out: Text = "".to_text();
    let mut i: Int = 0;
    while i < pairs.len() {
        if i > 0 { out = out.append("&"); }
        out = out.append(&core.storage.s3.signing.percent_encode_strict(&pairs[i].0));
        out = out.append("=");
        out = out.append(&core.storage.s3.signing.percent_encode_strict(&pairs[i].1));
        i = i + 1;
    }
    out
}

// =============================================================================
// Helpers — header / response parsing
// =============================================================================

fn parse_metadata_from_headers(
    key: &Text, headers: &Map<Text, Text>, content_length: Int,
) -> ObjectMetadata {
    let etag = headers.get(&"etag".to_text())
        .map(|v| strip_quotes(v)).unwrap_or_else(|| "".to_text());
    let content_type = headers.get(&"content-type".to_text())
        .cloned().unwrap_or_else(|| "application/octet-stream".to_text());
    let last_modified = headers.get(&"last-modified".to_text())
        .and_then(|v| http_date_to_rfc3339(v))
        .unwrap_or_else(|| now_rfc3339());
    let mut user_metadata: Map<Text, Text> = Map.new();
    for (k, v) in headers.iter() {
        if k.starts_with("x-amz-meta-") {
            let stripped = k.byte_substring(11, k.len());
            user_metadata.insert(stripped, v.clone());
        }
    }
    ObjectMetadata {
        key: key.clone(),
        content_length,
        content_type,
        etag,
        last_modified,
        user_metadata,
    }
}

fn strip_quotes(s: &Text) -> Text {
    let mut t = s.clone();
    if t.starts_with("\"") && t.ends_with("\"") && t.len() >= 2 {
        t = t.byte_substring(1, t.len() - 1);
    }
    t
}

fn http_date_to_rfc3339(_http_date: &Text) -> Maybe<Rfc3339Time> {
    // RFC 7231 §7.1.1.1 IMF-fixdate parser. The full implementation
    // lives in `core.time.imf_fixdate` (separate task). For now
    // surface the request timestamp as a best-effort fallback.
    None
}

fn now_rfc3339() -> Rfc3339Time {
    core.time.rfc3339.now_utc()
}

fn current_iso8601_basic() -> Text {
    // YYYYMMDDTHHMMSSZ — SigV4's required `x-amz-date` form.
    core.time.rfc3339.format_iso8601_basic(&core.time.rfc3339.now_utc())
}

fn extract_error_message(resp: &Response) -> Text {
    Text.from_utf8(resp.body.as_slice())
        .unwrap_or_else(|_| f"<{resp.body.len()} bytes>")
}

// =============================================================================
// XML response parsing — minimal in-place scanner (no external XML dep)
// =============================================================================

fn parse_list_v2_response(body: &List<Byte>) -> Result<ListPage, StorageError> {
    let xml = Text.from_utf8(body.as_slice())
        .map_err(|e| StorageError.Backend(format!("xml utf8: {e}").to_text()))?;
    let mut objects: List<ObjectMetadata> = List.new();
    let mut common: List<Text> = List.new();

    // Walk the XML extracting `<Contents>...</Contents>` blocks +
    // `<CommonPrefixes>...<Prefix>...</Prefix></CommonPrefixes>`.
    // Robust enough for AWS's well-known shape; falls through on
    // unknown elements.
    let mut i: Int = 0;
    while i < xml.len() {
        let start = match xml.find_str_after("<Contents>", i) {
            Some(p) => p,
            None    => break,
        };
        let end = match xml.find_str_after("</Contents>", start) {
            Some(p) => p,
            None    => break,
        };
        let block = xml.byte_substring(start + 10, end);
        let key = extract_xml_text(&block, "Key").unwrap_or_else(|| "".to_text());
        let size_text = extract_xml_text(&block, "Size").unwrap_or_else(|| "0".to_text());
        let size = Int.parse(&size_text).unwrap_or(0);
        let etag = strip_quotes(&extract_xml_text(&block, "ETag").unwrap_or_else(|| "".to_text()));
        let last = extract_xml_text(&block, "LastModified")
            .and_then(|s| parse_rfc3339(&s).ok())
            .unwrap_or_else(|| now_rfc3339());
        objects.push(ObjectMetadata {
            key,
            content_length: size,
            content_type:   "application/octet-stream".to_text(),
            etag,
            last_modified:  last,
            user_metadata:  Map.new(),
        });
        i = end + 11;
    }

    // Common prefixes
    let mut j: Int = 0;
    while j < xml.len() {
        let start = match xml.find_str_after("<CommonPrefixes>", j) {
            Some(p) => p,
            None    => break,
        };
        let end = match xml.find_str_after("</CommonPrefixes>", start) {
            Some(p) => p,
            None    => break,
        };
        let block = xml.byte_substring(start + 16, end);
        if let Some(p) = extract_xml_text(&block, "Prefix") {
            common.push(p);
        }
        j = end + 17;
    }

    let next_token = extract_xml_text(&xml, "NextContinuationToken");

    Ok(ListPage { objects, common_prefixes: common, next_token })
}

fn extract_xml_text(xml: &Text, tag: &str) -> Maybe<Text> {
    let open = format!("<{}>", tag);
    let close = format!("</{}>", tag);
    let s = xml.find_str(&open)?;
    let e = xml.find_str_after(&close, s + open.len())?;
    Some(xml.byte_substring(s + open.len(), e))
}
