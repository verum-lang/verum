// =============================================================================
// storage/s3/mod.vr — S3 adapter facade
// =============================================================================

@arch_module(
    foundation:    Foundation.ZfcTwoInacc,
    stratum:       MsfsStratum.LCls,
    lifecycle:     Lifecycle.Theorem("v0.1"),
    declarations: ShapeDeclarations {
        purpose: Maybe.Some(Purpose {
            role: "S3 / S3-compatible object-store adapter facade".to_text(),
            k_min: CveThresholdK.FullWitness,
            v_min: CveThresholdV.NamedCertification,
            e_min: CveThresholdE.StructurallyReady,
        }),
        substrate: Maybe.Some(CognitiveSubstrate.AnalyticDecompositional),
        anchoring: Maybe.Some(FormalAnchoring.CurryHowardLawvere),
        e_sense:   Maybe.Some(ExecutabilitySense.StructuralReadiness),
        self_reference: Maybe.None,
    }
)
module core.storage.s3;

public module signing;
public module client;

public mount .signing.{sign_request, presign as sigv4_presign};
// Straight from the authority, not through `.signing`: metadata re-export
// chains are followed ONE hop only (T0155).
public mount security.aws_credentials.{AwsCredentials};
public mount .client.{S3Config, S3Client, s3_config, s3_client};
