// =============================================================================
// continuation.vr — Delimited Continuations (shift/reset)
// =============================================================================
//
// Layer: Standard Library / Control
//
// User-facing surface for the continuation-calculus analysis core
// (`verum_types.continuation_calculus`). Delimited control as a
// first-class computational primitive: `reset { e }` installs a
// prompt; `shift k. e` captures the surrounding computation up to
// the nearest reset and binds it to `k`.
//
// With shift/reset, programmers can express coroutines,
// non-deterministic search, backtracking, and full algebraic-
// effect handlers as a library — without language-level effect
// machinery.
//
// Verum chose contexts + specialized constructs (async / fn* /
// Result) over general handlers. This module exposes the
// continuation calculus as data structures + reduction so
// callers that want to *model* handler-style code, prove
// properties about it, or translate other languages with shift/
// reset can do so within Verum.
//
// ## Reductions
//
// ```text
//     (λx. M) N                  ↦  M[x := N]                (β)
//     reset v                    ↦  v                         (reset-value)
//     reset (shift k. M)         ↦  reset (M[k := λx. reset x])  (shift)
// ```
//
// =============================================================================

module core.control.continuation;

// =============================================================================
// 1. Continuation-calculus terms
// =============================================================================

/// A continuation-calculus term.
public type CcTerm is
    /// Opaque value-level constant.
    | Const { payload: Text }
    /// Variable reference.
    | Var { name: Text }
    /// `λx. body`.
    | Lam { param: Text, body: Heap<CcTerm> }
    /// `f arg`.
    | App { func: Heap<CcTerm>, arg: Heap<CcTerm> }
    /// `reset M` — install a delimiter.
    | Reset { inner: Heap<CcTerm> }
    /// `shift k. M` — capture the continuation up to the nearest reset.
    | Shift { binder: Text, body: Heap<CcTerm> };

// =============================================================================
// 2. Smart constructors
// =============================================================================

public fn cc_const(payload: Text) -> CcTerm {
    CcTerm.Const { payload }
}

public fn cc_var(name: Text) -> CcTerm {
    CcTerm.Var { name }
}

public fn cc_lam(param: Text, body: CcTerm) -> CcTerm {
    CcTerm.Lam { param, body: Heap(body) }
}

public fn cc_app(f: CcTerm, x: CcTerm) -> CcTerm {
    CcTerm.App { func: Heap(f), arg: Heap(x) }
}

public fn cc_reset(m: CcTerm) -> CcTerm {
    CcTerm.Reset { inner: Heap(m) }
}

public fn cc_shift(binder: Text, body: CcTerm) -> CcTerm {
    CcTerm.Shift { binder, body: Heap(body) }
}

// =============================================================================
// 3. Predicates
// =============================================================================

/// Constants and lambdas are values — they cannot reduce further
/// on their own.
public fn cc_is_value(t: CcTerm) -> Bool {
    match t {
        CcTerm.Const { payload: _ } => true,
        CcTerm.Lam { param: _, body: _ } => true,
        _ => false,
    }
}

// =============================================================================
// 4. Free-variable analysis
// =============================================================================

/// Check whether `name` occurs as a FREE variable in `t` — that is,
/// not bound by any enclosing `Lam` or `Shift` with the same name.
/// Required by capture-avoiding substitution to decide when α-renaming
/// is necessary.
public fn cc_occurs_free(t: CcTerm, name: Text) -> Bool {
    match t {
        CcTerm.Const { payload: _ } => false,
        CcTerm.Var { name: n } => n == name,
        CcTerm.Lam { param, body } => {
            if param == name {
                false  // shadowed by inner binder
            } else {
                cc_occurs_free(*body, name)
            }
        },
        CcTerm.App { func, arg } =>
            cc_occurs_free(*func, name) || cc_occurs_free(*arg, name),
        CcTerm.Reset { inner } => cc_occurs_free(*inner, name),
        CcTerm.Shift { binder, body } => {
            if binder == name {
                false  // shadowed by inner binder
            } else {
                cc_occurs_free(*body, name)
            }
        },
    }
}

/// Generate a fresh variable name based on `base` that does not
/// occur free in `t1` or `t2`. Appends "'" repeatedly until a free
/// name is found. Used during α-renaming inside `cc_substitute` to
/// avoid capture.
fn cc_fresh_name(base: Text, t1: CcTerm, t2: CcTerm) -> Text {
    let mut name = base;
    while cc_occurs_free(t1, name) || cc_occurs_free(t2, name) {
        name = name + "'";
    }
    name
}

// =============================================================================
// 5. Capture-avoiding substitution
// =============================================================================

/// Substitute `from` with `to` everywhere it appears free in `t`.
///
/// CAPTURE-AVOIDING: when descending under a binder `λparam. body` (or
/// `shift param. body`), if `param` would capture a free variable in
/// `to`, the binder is first α-renamed to a fresh name. Without this
/// step, substituting `Var("y")` for `x` in `λy. x` would naively
/// yield `λy. y` — the outer `y` capturing the substituted-in `y` —
/// silently changing the meaning of the term. This was the bug in
/// the previous implementation, which only handled the simpler case
/// of shadowing (skipping substitution under a binder of the same
/// name as `from`) but never α-renamed.
public fn cc_substitute(t: CcTerm, from: Text, to: CcTerm) -> CcTerm {
    match t {
        CcTerm.Const { payload } => CcTerm.Const { payload },
        CcTerm.Var { name } => {
            if name == from { to } else { CcTerm.Var { name } }
        },
        CcTerm.Lam { param, body } => {
            if param == from {
                // Shadowed: `from` cannot occur free under this binder.
                CcTerm.Lam { param, body }
            } else if cc_occurs_free(to, param) {
                // Capture would occur: α-rename `param` to a fresh
                // name before substituting under it.
                let fresh = cc_fresh_name(param, *body, to);
                let renamed_body = cc_substitute(*body, param, cc_var(fresh));
                cc_lam(fresh, cc_substitute(renamed_body, from, to))
            } else {
                cc_lam(param, cc_substitute(*body, from, to))
            }
        },
        CcTerm.App { func, arg } =>
            cc_app(cc_substitute(*func, from, to), cc_substitute(*arg, from, to)),
        CcTerm.Reset { inner } => cc_reset(cc_substitute(*inner, from, to)),
        CcTerm.Shift { binder, body } => {
            if binder == from {
                CcTerm.Shift { binder, body }
            } else if cc_occurs_free(to, binder) {
                let fresh = cc_fresh_name(binder, *body, to);
                let renamed_body = cc_substitute(*body, binder, cc_var(fresh));
                cc_shift(fresh, cc_substitute(renamed_body, from, to))
            } else {
                cc_shift(binder, cc_substitute(*body, from, to))
            }
        },
    }
}

// =============================================================================
// 6. Small-step reduction (β / reset-value / shift)
// =============================================================================

/// Outcome of one reduction attempt.
///
/// Returns the term back in either branch so the caller can iterate
/// without cloning — the `CcTerm` ADT has Heap<T> children and no
/// `@derive(Clone)`, matching the convention of this module.
public type CcStep is
    /// Reduction fired; `next` is the term after the step.
    | Stepped { next: CcTerm }
    /// No redex anywhere — `term` is the unchanged input.
    | Normal { term: CcTerm };

/// One reduction step in left-to-right delimited-control order:
///
/// ```text
///     (λx. M) N                ↦  M[x := N]                       (β)
///     reset v                  ↦  v                               (reset-value)
///     reset (shift k. M)       ↦  reset (M[k := λx. reset x])     (shift)
/// ```
///
/// Reduction proceeds beneath congruences: under `App` head, then
/// argument; under `Reset`. The `Shift` reduction only fires when
/// `Shift` is in the immediate scope of a `Reset` — outside any
/// reset, a `shift` is stuck (matching the operational semantics
/// of delimited control).
///
/// The captured continuation `λx. reset x` is the standard
/// reification: a one-argument λ that re-installs the prompt at
/// the call site so the captured context is replayable.
public fn cc_step(t: CcTerm) -> CcStep {
    match t {
        // β: (λx. body) N  ↦  body[x := N]
        CcTerm.App { func, arg } => {
            match *func {
                CcTerm.Lam { param, body } =>
                    CcStep.Stepped {
                        next: cc_substitute(*body, param, *arg),
                    },
                f => match cc_step(f) {
                    CcStep.Stepped { next } =>
                        CcStep.Stepped { next: cc_app(next, *arg) },
                    CcStep.Normal { term: f_norm } =>
                        match cc_step(*arg) {
                            CcStep.Stepped { next: a_next } =>
                                CcStep.Stepped { next: cc_app(f_norm, a_next) },
                            CcStep.Normal { term: a_norm } =>
                                CcStep.Normal { term: cc_app(f_norm, a_norm) },
                        },
                },
            }
        },
        // reset v             ↦ v                       (reset-value)
        // reset (shift k. M)  ↦ reset (M[k := …])       (shift)
        CcTerm.Reset { inner } => {
            match *inner {
                CcTerm.Shift { binder, body } => {
                    // Reify the captured continuation as
                    //     λx. reset x
                    // — pick a fresh `x` so we don't accidentally
                    // shadow a free variable inside `body`.
                    let x = cc_fresh_name(
                        Text.from("x"),
                        *body,
                        CcTerm.Var { name: binder.clone() },
                    );
                    let cont = cc_lam(x.clone(), cc_reset(cc_var(x)));
                    CcStep.Stepped {
                        next: cc_reset(cc_substitute(*body, binder, cont)),
                    }
                },
                v => {
                    if cc_is_value(v) {
                        // reset over a value reduces to the value.
                        CcStep.Stepped { next: v }
                    } else {
                        match cc_step(v) {
                            CcStep.Stepped { next } =>
                                CcStep.Stepped { next: cc_reset(next) },
                            CcStep.Normal { term } =>
                                CcStep.Normal { term: cc_reset(term) },
                        }
                    }
                }
            }
        },
        // Constants, Vars, Lams, and Shifts (outside reset) are normal.
        normal => CcStep.Normal { term: normal },
    }
}

/// Drive [`cc_step`] to a normal form with a hard step budget.
/// `gas` bounds the number of reduction steps to guarantee
/// termination on inputs whose reduction diverges.
///
/// Returns `(final, steps)`; `steps < gas` means a normal form was
/// reached.
public fn cc_normalise(t: CcTerm, gas: Int) -> (CcTerm, Int) {
    let mut current = t;
    let mut steps: Int = 0;
    while steps < gas {
        match cc_step(current) {
            CcStep.Stepped { next } => {
                current = next;
                steps = steps + 1;
            },
            CcStep.Normal { term } => {
                current = term;
                break;
            },
        }
    }
    (current, steps)
}

// =============================================================================
// 7. α-equivalence
// =============================================================================

/// One entry of an α-renaming context: at the time the binder was
/// introduced, the depth was `index`. Variable lookup in the
/// matching context reduces to a "de Bruijn level" comparison.
type CcAlphaEntry is { name: Text, index: Int };

fn cc_alpha_lookup(ctx: List<CcAlphaEntry>, name: Text) -> Int {
    let mut i: Int = 0;
    while i < ctx.len() as Int {
        let e: CcAlphaEntry = (*ctx.get(i as Int).unwrap()).clone();
        if e.name == name {
            return e.index;
        }
        i = i + 1;
    }
    -1
}

/// α-equivalence on continuation-calculus terms: two terms are
/// equal up to consistent renaming of bound variables (Lam, Shift).
/// Free variables must agree by name; bound variables are compared
/// by binding-depth as in [`cbpv_alpha_eq`].
public fn cc_alpha_eq(a: CcTerm, b: CcTerm) -> Bool {
    let ctx_a: List<CcAlphaEntry> = List.new();
    let ctx_b: List<CcAlphaEntry> = List.new();
    cc_alpha_eq_ctx(a, b, ctx_a, ctx_b, 0)
}

fn cc_alpha_eq_ctx(
    a: CcTerm,
    b: CcTerm,
    ctx_a: List<CcAlphaEntry>,
    ctx_b: List<CcAlphaEntry>,
    depth: Int,
) -> Bool {
    match (a, b) {
        (CcTerm.Const { payload: pa }, CcTerm.Const { payload: pb }) => pa == pb,
        (CcTerm.Var { name: na }, CcTerm.Var { name: nb }) => {
            let ia = cc_alpha_lookup(ctx_a, na.clone());
            let ib = cc_alpha_lookup(ctx_b, nb.clone());
            if ia == -1 && ib == -1 {
                na == nb
            } else {
                ia == ib
            }
        },
        (CcTerm.Lam { param: pa, body: ba },
         CcTerm.Lam { param: pb, body: bb }) => {
            let mut ca: List<CcAlphaEntry> = ctx_a;
            let mut cb: List<CcAlphaEntry> = ctx_b;
            ca.push(CcAlphaEntry { name: pa, index: depth });
            cb.push(CcAlphaEntry { name: pb, index: depth });
            cc_alpha_eq_ctx(*ba, *bb, ca, cb, depth + 1)
        },
        (CcTerm.App { func: fa, arg: aa },
         CcTerm.App { func: fb, arg: ab }) =>
            cc_alpha_eq_ctx(*fa, *fb, ctx_a.clone(), ctx_b.clone(), depth)
                && cc_alpha_eq_ctx(*aa, *ab, ctx_a, ctx_b, depth),
        (CcTerm.Reset { inner: ia }, CcTerm.Reset { inner: ib }) =>
            cc_alpha_eq_ctx(*ia, *ib, ctx_a, ctx_b, depth),
        (CcTerm.Shift { binder: bna, body: ba },
         CcTerm.Shift { binder: bnb, body: bb }) => {
            let mut ca: List<CcAlphaEntry> = ctx_a;
            let mut cb: List<CcAlphaEntry> = ctx_b;
            ca.push(CcAlphaEntry { name: bna, index: depth });
            cb.push(CcAlphaEntry { name: bnb, index: depth });
            cc_alpha_eq_ctx(*ba, *bb, ca, cb, depth + 1)
        },
        _ => false,
    }
}
