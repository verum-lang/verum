// =============================================================================
// mem/header.vr - Allocation Header for CBGR System
// =============================================================================
// Layer: 0 (Core)
// Dependencies: mem/capability
// =============================================================================
//
// This module defines the AllocationHeader structure prepended to every
// heap allocation in the CBGR system.
//
// # Memory Layout (32 bytes, cache-line optimized)
//
// ```
// Offset  Size  Field           Description
// ──────────────────────────────────────────────────────────────────────
// 0       4     generation      Current generation counter (atomic) — HOT
// 4       4     epoch_and_caps  Packed: epoch (i16) + capabilities (i16)
// 8       4     size            Allocation size in bytes (excluding header)
// 12      4     alignment       Alignment requirement
// 16      4     type_id         Runtime type identifier
// 20      4     flags           Allocation state flags
// 24      4     ref_count       Reference count (atomic)
// 28      4     reserved        Reserved for future use
// ──────────────────────────────────────────────────────────────────────
// Total: 32 bytes (half cache line, 32-byte aligned)
// ```
//
// # Thread Safety
//
// The generation, epoch_and_caps, and ref_count fields are atomic and
// can be safely accessed from multiple threads.
//
// # Performance
//
// Hot path optimization: generation is at offset 0 for cache-line-aligned
// first access. Generation + epoch_and_caps form the first 8 bytes,
// enabling combined 64-bit atomic load for ~15ns validation.
//
// Spec: docs/architecture/new-arch-spec.md Section 6.1
// =============================================================================

mount core.intrinsics.atomic.{ORDERING_RELAXED, ORDERING_ACQUIRE, ORDERING_RELEASE, ORDERING_ACQ_REL, ORDERING_SEQ_CST};

module core.mem.header;
mount super.capability.{CAP_READ, CAP_WRITE, CAP_OWNED};

// Import intrinsics as functions (from submodules directly for reliable resolution)
mount core.intrinsics.memory.{ptr_offset};
mount core.intrinsics.atomic.{
    atomic_load_u32, atomic_store_u32, atomic_fetch_add_u32, atomic_fetch_and_u32,
    atomic_fetch_sub_u32, atomic_cas_u32,
    atomic_load_u16, atomic_store_u16, atomic_fetch_add_u16, atomic_fetch_and_u16,
    atomic_load_u64,
};

// Audit-log writers — emit a CapEvent on every successful CBGR state
// transition.  When `cap_audit_is_enabled()` returns false (default
// production state), each helper short-circuits with a relaxed-load +
// branch (~1-2 ns) and the CBGR hot path stays within budget.
mount super.cap_audit.{
    record_revoke,
    record_attenuate,
    record_ref_incr,
    record_ref_decr,
    record_gen_bump,
};

// =============================================================================
// Constants
// =============================================================================

/// Header size in bytes.
public const HEADER_SIZE: Int = 32;

/// Header alignment (cache-line half).
public const HEADER_ALIGN: Int = 32;

/// Initial generation value.
public const GEN_INITIAL: UInt32 = 1;

/// Maximum generation before wraparound.
public const GEN_MAX: UInt32 = 0xFFFF_FFFE;

/// Unallocated generation marker.
public const GEN_UNALLOCATED: UInt32 = 0;

// =============================================================================
// Allocation Flags
// =============================================================================

/// Allocation cannot be moved by GC/compaction.
public const FLAG_PINNED: UInt32 = 1 << 0;

/// Intentionally leaked (permanent allocation, never freed).
public const FLAG_LEAKED: UInt32 = 1 << 1;

/// Has shared ownership (Shared<T>).
public const FLAG_SHARED: UInt32 = 1 << 2;

/// Has weak references.
public const FLAG_WEAK: UInt32 = 1 << 3;

/// Has capability restrictions.
public const FLAG_CAPABILITY: UInt32 = 1 << 4;

/// Allocation is from arena (bulk dealloc).
public const FLAG_ARENA: UInt32 = 1 << 5;

/// NUMA-pinned allocation.
public const FLAG_NUMA_PINNED: UInt32 = 1 << 6;

/// Large allocation (direct mmap).
public const FLAG_LARGE: UInt32 = 1 << 7;

/// Borrowed reference active.
public const FLAG_BORROWED: UInt32 = 1 << 8;

/// Allocation flags container.
public type AllocationFlags is (UInt32);

implement AllocationFlags {
    /// Create empty flags.
    public fn none() -> AllocationFlags {
        AllocationFlags(0)
    }

    /// Check if pinned.
    public fn is_pinned(&self) -> Bool {
        (self.0 & FLAG_PINNED) != 0
    }

    /// Check if leaked.
    public fn is_leaked(&self) -> Bool {
        (self.0 & FLAG_LEAKED) != 0
    }

    /// Check if shared.
    public fn is_shared(&self) -> Bool {
        (self.0 & FLAG_SHARED) != 0
    }

    /// Check if has weak refs.
    public fn has_weak(&self) -> Bool {
        (self.0 & FLAG_WEAK) != 0
    }

    /// Check if large allocation.
    public fn is_large(&self) -> Bool {
        (self.0 & FLAG_LARGE) != 0
    }

    /// Check if arena allocation.
    public fn is_arena(&self) -> Bool {
        (self.0 & FLAG_ARENA) != 0
    }
}

// =============================================================================
// Allocation Header
// =============================================================================

/// Allocation header prepended to every heap allocation.
///
/// This structure is 32 bytes, cache-line optimized for half cache line
/// alignment on most architectures.

/// Error type for reference validation failures.
public type MemValidationError is
    | GenerationMismatch { expected: UInt32, actual: UInt32 }
    | EpochMismatch { expected: UInt16, actual: UInt16 };

implement MemValidationError {
    public fn generation_mismatch(expected: UInt32, actual: UInt32) -> MemValidationError {
        MemValidationError.GenerationMismatch { expected: expected, actual: actual }
    }

    public fn epoch_mismatch(expected: UInt16, actual: UInt16) -> MemValidationError {
        MemValidationError.EpochMismatch { expected: expected, actual: actual }
    }
}

implement Debug for MemValidationError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            GenerationMismatch { expected, actual } =>
                f.write_str(f"GenerationMismatch(expected={expected}, actual={actual})"),
            EpochMismatch { expected, actual } =>
                f.write_str(f"EpochMismatch(expected={expected}, actual={actual})"),
        }
    }
}

implement Display for MemValidationError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            GenerationMismatch { expected, actual } =>
                f.write_str(f"generation mismatch: expected {expected}, got {actual}"),
            EpochMismatch { expected, actual } =>
                f.write_str(f"epoch mismatch: expected {expected}, got {actual}"),
        }
    }
}

@repr(C, align(32))
public type AllocationHeader is {
    /// Current generation counter (atomic) — HOT: checked on every deref.
    /// Starts at GEN_INITIAL (1), increments on deallocation/revocation.
    generation: UInt32,  // Offset 0, AtomicU32 semantics via intrinsics

    /// Packed epoch (lower 16 bits) + capabilities (upper 16 bits) (atomic).
    /// Epoch: wraparound protection counter. Capabilities: access control flags.
    epoch_and_caps: UInt32,  // Offset 4, AtomicU32 semantics

    /// Allocation size in bytes (excluding header).
    size: UInt32,  // Offset 8

    /// Alignment requirement for the allocation.
    alignment: UInt32,  // Offset 12

    /// Runtime type identifier (for debugging and profiling).
    type_id: UInt32,  // Offset 16

    /// Allocation state flags.
    flags: UInt32,  // Offset 20

    /// Reference count (atomic).
    ref_count: UInt32,  // Offset 24

    /// Reserved for future use.
    reserved: UInt32,  // Offset 28
};

implement AllocationHeader {
    /// Create a new allocation header.
    public fn new(
        size: UInt32,
        alignment: UInt32,
        type_id: UInt32,
        capabilities: UInt16,
    ) -> AllocationHeader {
        let epoch_and_caps = (capabilities as UInt32) << 16;
        AllocationHeader {
            generation: GEN_INITIAL,
            epoch_and_caps: epoch_and_caps,
            size: size,
            alignment: alignment,
            type_id: type_id,
            flags: 0,
            ref_count: 0,
            reserved: 0,
        }
    }

    /// Create header for a typed allocation.
    ///
    /// SOUNDNESS: validates that T's static size / alignment fit in
    /// UInt32 (the on-disk header field type).  A type whose size
    /// exceeds 4 GiB silently truncating to UInt32 would mis-sized
    /// the allocation and corrupt subsequent CBGR validation
    /// (the size field gates pointer-derivation bounds).
    public fn for_type<T>(capabilities: UInt16) -> AllocationHeader {
        if T.size > 0xFFFF_FFFF {
            panic("AllocationHeader::for_type<T>: T.size exceeds UInt32.MAX (header size field is UInt32-bounded)");
        }
        if T.alignment > 0xFFFF_FFFF {
            panic("AllocationHeader::for_type<T>: T.alignment exceeds UInt32.MAX");
        }
        let size = T.size as UInt32;
        let alignment = T.alignment as UInt32;
        let type_id = T.id as UInt32;
        AllocationHeader.new(size, alignment, type_id, capabilities)
    }

    /// Create header with explicit type_id (uses CAP_OWNED by default).
    public fn new_with_type(size: UInt32, alignment: UInt32, type_id: UInt32) -> AllocationHeader {
        AllocationHeader.new(size, alignment, type_id, CAP_OWNED)
    }

    /// Load generation counter atomically.
    @inline
    public fn load_generation(&self) -> UInt32 {
        atomic_load_u32(&self.generation, ORDERING_ACQUIRE)
    }

    /// Store generation counter atomically.
    @inline
    public fn store_generation(&mut self, gen: UInt32) {
        atomic_store_u32(&mut self.generation, gen, ORDERING_RELEASE)
    }

    /// Revoke the allocation iff the current generation matches
    /// `expected_gen`.  This is the load-bearing primitive for
    /// `ThinRef::revoke`-style APIs: the verify-then-increment is
    /// performed as a single CAS so two concurrent revokers can't
    /// both succeed, and a stale revoker can't double-bump the
    /// generation past a successor's freshly-issued reference.
    ///
    /// Returns:
    ///   - `Some(new_gen)` if this thread successfully revoked.
    ///   - `None` if the generation no longer matches
    ///     `expected_gen` (someone else revoked first; caller
    ///     should report `already_revoked`).
    ///
    /// Wraparound is handled identically to `increment_generation`:
    /// after a successful CAS that lands at GEN_MAX, the epoch is
    /// CAS-bumped and the generation is reset to GEN_INITIAL.
    /// Stable allocation identity as UInt64.  Used by audit-log
    /// callers to correlate CapEvent records back to specific
    /// allocations.  The address is the AllocationHeader's own
    /// position in memory; the user data starts HEADER_SIZE bytes
    /// later, but observers grouping events by allocation just need
    /// any stable, unique-per-allocation identifier.
    @inline
    public fn address(&self) -> UInt64 {
        unsafe { (self as *const AllocationHeader) as Int as UInt64 }
    }

    @inline
    public fn try_revoke(&mut self, expected_gen: UInt32) -> Maybe<UInt32> {
        let new_gen = if expected_gen >= GEN_MAX - 1 {
            // Wraparound boundary — caller's expected_gen is already
            // saturated; any further increment must go through the
            // wraparound path.  CAS to GEN_INITIAL directly here.
            GEN_INITIAL
        } else {
            expected_gen + 1
        };

        let (_observed, swapped) = atomic_cas_u32(
            &mut self.generation,
            expected_gen,
            new_gen,
            ORDERING_ACQ_REL,
            ORDERING_ACQUIRE,
        );
        if !swapped {
            // Snapshot stale → another thread revoked first.
            return None;
        }

        // If we crossed the wraparound boundary, bump the epoch
        // exactly once.  Mirrors the wraparound branch of
        // `increment_generation`.
        if expected_gen >= GEN_MAX - 1 {
            loop {
                let old_packed = atomic_load_u32(&self.epoch_and_caps, ORDERING_ACQUIRE);
                let old_epoch = (old_packed & 0xFFFF) as UInt16;
                let caps_bits = old_packed & 0xFFFF_0000;
                if old_epoch == 0xFFFF {
                    panic("AllocationHeader epoch overflow during try_revoke — exceeded UInt16 wraparound budget");
                }
                let new_epoch = old_epoch + 1;
                let new_packed = caps_bits | (new_epoch as UInt32);
                let (_obs, ok) = atomic_cas_u32(
                    &mut self.epoch_and_caps,
                    old_packed,
                    new_packed,
                    ORDERING_ACQ_REL,
                    ORDERING_ACQUIRE,
                );
                if ok { break; }
            }
            super.epoch.GLOBAL_EPOCH.on_wraparound();
        }

        // Emit audit event after the revoke is fully committed.  The
        // runtime gate (`cap_audit_is_enabled`) keeps this O(1) when
        // audit is off; observers never see speculative or torn state.
        let caps = self.load_capabilities();
        record_revoke(self.address(), expected_gen, new_gen, caps, 0);

        Some(new_gen)
    }

    /// Increment generation and return old value.
    /// Handles wraparound by incrementing epoch.
    ///
    /// Concurrency contract: under contention, multiple threads
    /// may simultaneously hit the wraparound branch. Earlier
    /// revisions performed a non-atomic load+store on
    /// `epoch_and_caps` and a non-CAS reset of `generation`,
    /// which let two concurrent wraparounds *both* execute the
    /// epoch-increment path — double-incrementing the epoch and
    /// double-resetting the generation. The fix uses:
    ///
    ///   * a CAS-loop on `epoch_and_caps` that retries until the
    ///     epoch increment commits exactly once;
    ///   * a CAS reset of `generation` from `GEN_MAX` (or higher
    ///     if multiple wraparounds ran) back to `GEN_INITIAL`,
    ///     so concurrent threads observe a single net reset;
    ///   * a hard panic on `UInt16` epoch overflow — silently
    ///     wrapping past 65535 would create ABA aliasing of
    ///     reference identities.
    @inline
    public fn increment_generation(&mut self) -> UInt32 {
        let old_gen = atomic_fetch_add_u32(&mut self.generation, 1, ORDERING_ACQ_REL);

        // Wraparound iff the value we read is in the top-2 of the
        // generation domain — after fetch_add the generation may
        // have already wrapped past GEN_MAX, but only the thread
        // that *observed* the boundary value performs the
        // recovery work.
        if old_gen >= GEN_MAX - 1 {
            // CAS-loop: increment the epoch (lower 16 bits)
            // exactly once, preserving the upper-16 capabilities.
            // Concurrent wraparound threads either succeed on the
            // first iter or retry against the just-incremented
            // packed value — the loop converges in O(threads)
            // attempts and increments epoch exactly once per
            // wraparound boundary.
            loop {
                let old_packed = atomic_load_u32(&self.epoch_and_caps, ORDERING_ACQUIRE);
                let old_epoch = (old_packed & 0xFFFF) as UInt16;
                let caps_bits = old_packed & 0xFFFF_0000;

                // Hard fail on UInt16 epoch overflow: silently
                // wrapping to 0 would let a future generation
                // collide with a long-dead reference's
                // (generation, epoch) pair.
                if old_epoch == 0xFFFF {
                    panic("AllocationHeader epoch overflow — exceeded UInt16 wraparound budget; allocation must be retired and re-stamped via the heap manager");
                }

                let new_epoch = old_epoch + 1;
                let new_packed = caps_bits | (new_epoch as UInt32);
                let (_observed, swapped) = atomic_cas_u32(
                    &mut self.epoch_and_caps,
                    old_packed,
                    new_packed,
                    ORDERING_ACQ_REL,
                    ORDERING_ACQUIRE,
                );
                if swapped { break; }
                // CAS lost — another thread updated the packed
                // field; reload and retry. This is bounded by
                // the number of concurrent wraparound threads,
                // typically 1.
            }

            // Reset generation back to GEN_INITIAL.  Use CAS so
            // late-arriving fetch_adds from concurrent threads
            // don't accidentally reset a freshly-stamped
            // post-wraparound generation back to INITIAL again.
            // We only reset if generation is still in the
            // wraparound zone (>= GEN_MAX - 1) — otherwise some
            // other thread has already done the reset.
            loop {
                let cur = atomic_load_u32(&self.generation, ORDERING_ACQUIRE);
                if cur < GEN_MAX - 1 { break; }
                let (_observed, swapped) = atomic_cas_u32(
                    &mut self.generation,
                    cur,
                    GEN_INITIAL,
                    ORDERING_ACQ_REL,
                    ORDERING_ACQUIRE,
                );
                if swapped { break; }
            }

            // Notify epoch manager.
            super.epoch.GLOBAL_EPOCH.on_wraparound();
        }

        // Audit-log the generation bump.  Note: `old_gen` is the value
        // *before* fetch_add, so the post-bump value is `old_gen + 1`
        // (wraparound resets to GEN_INITIAL — we record what the caller
        // sees, the new generation after the transition).
        let new_gen = if old_gen >= GEN_MAX - 1 { GEN_INITIAL } else { old_gen + 1 };
        let caps = self.load_capabilities();
        record_gen_bump(self.address(), old_gen, new_gen, caps, 0);

        old_gen
    }

    /// Load epoch counter atomically (lower 16 bits of epoch_and_caps).
    @inline
    public fn load_epoch(&self) -> UInt16 {
        let packed = atomic_load_u32(&self.epoch_and_caps, ORDERING_ACQUIRE);
        (packed & 0xFFFF) as UInt16
    }

    /// Store epoch counter atomically (preserves capabilities in upper 16 bits).
    ///
    /// SOUNDNESS: this MUST be a CAS-loop, not a load-then-store.
    /// Earlier revisions did `let p = load(); let new = (p & caps_mask) | epoch; store(new)`
    /// — which races with `attenuate_capabilities` / `store_capabilities`
    /// running on another thread.  If the two stores interleave, the
    /// epoch-store overwrites the capability-attenuation, silently
    /// RESTORING capabilities that the attenuator just removed.  That
    /// is a security violation: capability removal must be monotone
    /// from the caller's perspective.  The CAS-loop guarantees the
    /// two halves see a consistent transition.
    @inline
    public fn store_epoch(&mut self, epoch: UInt16) {
        loop {
            let old_packed = atomic_load_u32(&self.epoch_and_caps, ORDERING_ACQUIRE);
            let caps_bits = old_packed & 0xFFFF_0000;
            let new_packed = caps_bits | (epoch as UInt32);
            let (_observed, swapped) = atomic_cas_u32(
                &mut self.epoch_and_caps,
                old_packed,
                new_packed,
                ORDERING_ACQ_REL,
                ORDERING_ACQUIRE,
            );
            if swapped { break; }
        }
    }

    /// Load generation and epoch in optimized sequential access.
    /// This is the HOT PATH - ~15ns for validation.
    /// Generation is at offset 0 for optimal cache access.
    @inline
    public fn load_generation_epoch_fast(&self) -> (UInt32, UInt16) {
        // Load generation with Acquire ordering (provides memory fence)
        let generation = atomic_load_u32(&self.generation, ORDERING_ACQUIRE);
        // Epoch is lower 16 bits of epoch_and_caps; Relaxed since generation provides fence
        let packed = atomic_load_u32(&self.epoch_and_caps, ORDERING_RELAXED);
        let epoch = (packed & 0xFFFF) as UInt16;
        (generation, epoch)
    }

    /// Load generation and epoch in a SINGLE 64-bit access (faster).
    /// Generation (offset 0) + epoch_and_caps (offset 4) are adjacent,
    /// enabling a combined 64-bit atomic load.
    @inline
    public unsafe fn load_generation_epoch_combined(&self) -> (UInt32, UInt16) {
        // Cast generation field address to UInt64 pointer and load
        let ptr = &self.generation as &unsafe UInt64;
        let combined = atomic_load_u64(ptr, ORDERING_ACQUIRE);

        // Extract generation (lower 32 bits) and epoch (bits 32-47)
        let generation = (combined & 0xFFFF_FFFF) as UInt32;
        let epoch = ((combined >> 32) & 0xFFFF) as UInt16;

        (generation, epoch)
    }

    /// Load capabilities atomically (upper 16 bits of epoch_and_caps).
    @inline
    public fn load_capabilities(&self) -> UInt16 {
        let packed = atomic_load_u32(&self.epoch_and_caps, ORDERING_ACQUIRE);
        ((packed >> 16) & 0xFFFF) as UInt16
    }

    /// Store capabilities atomically (preserves epoch in lower 16 bits).
    ///
    /// SOUNDNESS: CAS-loop for the same race-with-store_epoch /
    /// fetch_add(generation-wraparound) reason as `store_epoch`.
    ///
    /// SECURITY: this method should be used sparingly — it can
    /// REPLACE the capabilities mask (granting access).  Prefer
    /// `attenuate_capabilities` for the common case of removing
    /// rights, since attenuation is monotone and cannot
    /// accidentally re-grant.
    @inline
    public fn store_capabilities(&mut self, caps: UInt16) {
        loop {
            let old_packed = atomic_load_u32(&self.epoch_and_caps, ORDERING_ACQUIRE);
            let epoch_bits = old_packed & 0xFFFF;
            let new_packed = ((caps as UInt32) << 16) | epoch_bits;
            let (_observed, swapped) = atomic_cas_u32(
                &mut self.epoch_and_caps,
                old_packed,
                new_packed,
                ORDERING_ACQ_REL,
                ORDERING_ACQUIRE,
            );
            if swapped { break; }
        }
    }

    /// Attenuate (reduce) capabilities using AND mask.
    /// Once capabilities are removed, they cannot be restored.
    @inline
    public fn attenuate_capabilities(&mut self, mask: UInt16) -> UInt16 {
        // AND the upper 16 bits (caps) while preserving lower 16 bits (epoch)
        let u32_mask = ((mask as UInt32) << 16) | 0xFFFF;
        let old_packed = atomic_fetch_and_u32(&mut self.epoch_and_caps, u32_mask, ORDERING_ACQ_REL);
        let caps_before = ((old_packed >> 16) & 0xFFFF) as UInt16;

        // Audit-log the attenuation.  caps_after = caps_before AND mask
        // (monotonic narrowing).  Generation is unaffected.
        let caps_after = caps_before & mask;
        let gen = self.load_generation();
        record_attenuate(self.address(), gen, caps_before, caps_after, 0);

        caps_before
    }

    /// Check if a specific capability is set.
    @inline
    public fn has_capability(&self, cap: UInt16) -> Bool {
        (self.load_capabilities() & cap) == cap
    }

    /// Load reference count atomically.
    @inline
    public fn load_ref_count(&self) -> UInt32 {
        atomic_load_u32(&self.ref_count, ORDERING_ACQUIRE)
    }

    /// Increment reference count and return old value.
    ///
    /// SOUNDNESS: hard panic on overflow.  A naive `fetch_add(1)` would
    /// silently wrap from UInt32.MAX to 0, after which a subsequent
    /// drop would race the dealloc through 0 → UInt32.MAX → 0 again,
    /// or worse — drop the live object while another thread still
    /// holds a clone.  Reaching UInt32.MAX requires ~4 billion live
    /// clones; in practice this is unreachable, but loud failure is
    /// the right behaviour if it ever occurs.
    @inline
    public fn increment_ref_count(&mut self) -> UInt32 {
        let old = atomic_fetch_add_u32(&mut self.ref_count, 1, ORDERING_ACQ_REL);
        if old == 0xFFFF_FFFF {
            panic("AllocationHeader::increment_ref_count overflow — ref_count exceeded UInt32.MAX; allocation has too many concurrent owners (clone leak likely)");
        }
        // Audit-log the ref_count increment.  Slow path only — fast-
        // path `&checked` borrows do not touch ref_count and are not
        // audited.  The runtime gate keeps this O(1) when off.
        let gen = self.load_generation();
        let caps = self.load_capabilities();
        record_ref_incr(self.address(), gen, caps, 0);
        old
    }

    /// Decrement reference count and return new value.
    /// Caller must handle deallocation when this returns 0.
    ///
    /// Panics on underflow (ref_count was already 0). Earlier
    /// revisions used `atomic_fetch_add_u32(0xFFFF_FFFF)` (i.e.
    /// `+= -1` via wrapping) and returned `old - 1`; if a buggy
    /// caller decremented past zero the in-memory ref_count
    /// silently wrapped to `UInt32.MAX`, preventing every
    /// subsequent dealloc from firing — a permanent leak that's
    /// hard to diagnose because the count appears huge instead
    /// of negative.  Detecting the underflow loudly means leaks
    /// surface at the actual misuse site instead of as a far-
    /// removed OOM.
    @inline
    public fn decrement_ref_count(&mut self) -> UInt32 {
        let old = atomic_fetch_sub_u32(&mut self.ref_count, 1, ORDERING_ACQ_REL);
        if old == 0 {
            panic("AllocationHeader::decrement_ref_count underflow — ref_count was already 0; caller decrement-balance is broken");
        }
        // Audit-log the ref_count decrement.
        let gen = self.load_generation();
        let caps = self.load_capabilities();
        record_ref_decr(self.address(), gen, caps, 0);
        old - 1
    }

    /// Validate that a reference's generation/epoch match this header.
    /// Returns Ok(()) if valid, Err with validation error if not.
    @inline
    public fn validate_reference(&self, expected_gen: UInt32, expected_epoch: UInt16) -> Result<(), MemValidationError> {
        let actual_gen = self.load_generation();
        let actual_epoch = self.load_epoch();
        if expected_gen != actual_gen {
            Result.Err(MemValidationError.generation_mismatch(expected_gen, actual_gen))
        } else if expected_epoch != actual_epoch {
            Result.Err(MemValidationError.epoch_mismatch(expected_epoch, actual_epoch))
        } else {
            Result.Ok(())
        }
    }

    /// Fast validation using combined atomic load.
    /// Returns Ok(()) if valid, Err with validation error if not.
    @inline
    public unsafe fn validate_reference_fast(&self, expected_gen: UInt32, expected_epoch: UInt16) -> Result<(), MemValidationError> {
        let (actual_gen, actual_epoch) = self.load_generation_epoch_combined();
        if expected_gen != actual_gen {
            Result.Err(MemValidationError.generation_mismatch(expected_gen, actual_gen))
        } else if expected_epoch != actual_epoch {
            Result.Err(MemValidationError.epoch_mismatch(expected_epoch, actual_epoch))
        } else {
            Result.Ok(())
        }
    }

    /// Get pointer to user data (after header).
    @inline
    public unsafe fn user_ptr(&self) -> &unsafe Byte {
        let self_ptr = self as &unsafe Byte;
        ptr_offset(self_ptr, HEADER_SIZE)
    }

    /// Get header from user pointer.
    @inline
    public unsafe fn from_user_ptr(ptr: &unsafe Byte) -> &AllocationHeader {
        let header_ptr = ptr_offset(ptr, -HEADER_SIZE);
        header_ptr as &AllocationHeader
    }

    /// Get mutable header from user pointer.
    @inline
    public unsafe fn from_user_ptr_mut(ptr: &unsafe Byte) -> &mut AllocationHeader {
        let header_ptr = ptr_offset(ptr, -HEADER_SIZE);
        header_ptr as &mut AllocationHeader
    }

    /// Check if allocation is pinned.
    @inline
    public fn is_pinned(&self) -> Bool {
        (self.flags & FLAG_PINNED) != 0
    }

    /// Check if allocation is leaked.
    @inline
    public fn is_leaked(&self) -> Bool {
        (self.flags & FLAG_LEAKED) != 0
    }

    /// Check if allocation has shared ownership.
    @inline
    public fn is_shared(&self) -> Bool {
        (self.flags & FLAG_SHARED) != 0
    }

    /// Check if allocation has weak references.
    @inline
    public fn has_weak_refs(&self) -> Bool {
        (self.flags & FLAG_WEAK) != 0
    }

    /// Mark allocation as pinned.
    @inline
    public fn set_pinned(&mut self) {
        self.flags = self.flags | FLAG_PINNED;
    }

    /// Mark allocation as leaked.
    @inline
    public fn set_leaked(&mut self) {
        self.flags = self.flags | FLAG_LEAKED;
    }

    /// Mark allocation as shared.
    @inline
    public fn set_shared(&mut self) {
        self.flags = self.flags | FLAG_SHARED;
    }

    /// Set weak reference flag.
    @inline
    public fn set_has_weak(&mut self) {
        self.flags = self.flags | FLAG_WEAK;
    }

    /// Set an arbitrary flag.
    @inline
    public fn set_flag(&mut self, flag: UInt32) {
        self.flags = self.flags | flag;
    }

    /// Check if an arbitrary flag is set.
    @inline
    public fn has_flag(&self, flag: UInt32) -> Bool {
        (self.flags & flag) != 0
    }

    /// Clear an arbitrary flag.
    @inline
    public fn clear_flag(&mut self, flag: UInt32) {
        self.flags = self.flags & !flag;
    }

    /// Get allocation size.
    @inline
    public fn get_size(&self) -> UInt32 {
        self.size
    }

    /// Get alignment.
    @inline
    public fn get_alignment(&self) -> UInt32 {
        self.alignment
    }

    /// Get type ID.
    @inline
    public fn get_type_id(&self) -> UInt32 {
        self.type_id
    }

    /// Get total allocation size (header + data).
    @inline
    public fn total_size(&self) -> Int {
        HEADER_SIZE + self.size as Int
    }
}

// =============================================================================
// Validation Functions
// =============================================================================

/// Validate that a reference's generation/epoch match the header.
@inline
public fn validate_reference(
    header: &AllocationHeader,
    expected_gen: UInt32,
    expected_epoch: UInt16,
) -> Bool {
    let (actual_gen, actual_epoch) = header.load_generation_epoch_fast();
    expected_gen == actual_gen && expected_epoch == actual_epoch
}

/// Fast validation using combined load.
@inline
public unsafe fn validate_reference_fast(
    header: &AllocationHeader,
    expected_gen: UInt32,
    expected_epoch: UInt16,
) -> Bool {
    let (actual_gen, actual_epoch) = header.load_generation_epoch_combined();
    expected_gen == actual_gen && expected_epoch == actual_epoch
}
