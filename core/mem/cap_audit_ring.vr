// =============================================================================
// mem/cap_audit_ring.vr — Lock-free SPMC Ring Buffer for CapEvent
// =============================================================================
// Layer: 0 (Core)
// Dependencies: mem/cap_audit (event type), intrinsics/atomic (lock-free ops)
// =============================================================================
//

// Storage backend for the capability-audit log declared in `mem/cap_audit.vr`.
// This file owns the producer-side ring buffer that turns the format-stable
// `CapEvent` boundary type into a load-bearing audit trail observers can
// subscribe to.
//

// # Concurrency model: per-slot seqlock SPMC
//

// Multiple producers concurrently CBGR-write (revoke / attenuate / refcount-
// change) and emit one `CapEvent` per write. A single reader (or many
// readers) periodically snapshot the most-recent N events.
//

// Each slot holds two cells:
//

//  `state`: AtomicU64 — encodes (writing_flag, published_seq). High bit
//  set means a writer currently owns the slot; low 63 bits are the
//  publication sequence number when the writer is finished. An
//  uninitialised slot has state == 0 (no writer ever claimed it).
//

//  `event`: CapEvent — the published payload. Mutated only by the
//  slot's current owner (under WRITING flag); read-only when the WRITING
//  flag is clear.
//

// # Writer protocol
//

// 1. atomic_fetch_add(NEXT_SEQ, 1) — claim a globally unique sequence number
//  `seq ≥ 1` (zero is reserved for "uncommitted").
// 2. Locate slot at index `(seq - 1) mod CAP`.
// 3. CAS-loop on `slot.state`:
//  - load `prev`; extract `prev_seq = prev & !WRITING_BIT`.
//  - if `prev_seq >= seq` a strictly newer writer has already claimed
//  this slot; abandon our event (it would be overwritten before any
//  reader could observe it; reporting it would be a stale read).
//  - else CAS `prev → (WRITING_BIT | seq)`. On success break the loop;
//  on failure spin and retry.
// 4. Write the event payload.
// 5. Release-store `state = seq` (clears WRITING_BIT, publishes seq).
//

// # Reader protocol (seqlock retry)
//

// 1. Acquire-load `NEXT_SEQ` to get the upper bound `cur`.
// 2. For `s` in `[max(1, cur - n + 1) .. cur]`:
//  - Acquire-load `slot.state` → `state1`.
//  - If `state1 == s`: copy slot.event into a local; Acquire-load
//  `slot.state` → `state2`. If `state2 == s` the event is consistent
//  with sequence `s` (no concurrent writer corrupted it); push into
//  result.
//  - Else: a writer raced; skip.
//

// # Memory ordering
//

// Writer's release-store `state = seq` synchronises-with the reader's
// acquire-load returning `seq`, transitively making the writer's prior
// payload writes visible. The acquire-acquire fence on the reader's two
// state loads brackets the payload copy — if `state2 == state1 == seq`,
// no writer mutated the slot during the copy.
//

// # Capacity sizing
//

// 256 slots × ~64-byte CapEvent ≈ 16 KiB. At a sustained 10 µs/event
// CBGR-write rate this is ~2.5 ms of history; sufficient for forensic
// post-mortem (the tail-end window of writes preceding a panic). Fixed-
// size avoids unbounded memory growth and gives O(1) writer / O(N)
// reader.
//

// Spec: docs/architecture/observability.md (TODO)
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.mem.cap_audit_ring;

mount super.cap_audit.{CapEvent, CapEventKind};
mount core.intrinsics.atomic.{
    atomic_load_u8, atomic_store_u8,
    atomic_load_u64, atomic_store_u64, atomic_fetch_add_u64,
    atomic_compare_exchange_u64,
    ORDERING_RELAXED, ORDERING_ACQUIRE, ORDERING_RELEASE, ORDERING_ACQ_REL,
};
mount core.intrinsics.platform.spin_hint;

// =============================================================================
// Compile-time constants
// =============================================================================

/// Number of slots in the ring buffer. MUST be a power of two so that
/// `(seq - 1) & CAP_AUDIT_RING_MASK` is a fast modular reduction.
public const CAP_AUDIT_RING_CAPACITY: Int = 256;

/// Bitmask for fast modular reduction (CAP - 1).
const CAP_AUDIT_RING_MASK: UInt64 = 255;

/// High bit of `slot.state` indicating a writer currently owns the slot.
const SLOT_WRITING_BIT: UInt64 = 0x8000_0000_0000_0000;

/// Initial sequence value — zero indicates "no event ever committed to
/// this slot" so `recent()` can skip uninitialised slots.
const SLOT_UNINITIALISED: UInt64 = 0;

// =============================================================================
// Runtime-gated recording switch
// =============================================================================
//

// CBGR writes are on the hot path (~0.93ns measured). The audit ring's
// `commit` adds ~30-50ns per call (atomic_fetch_add + CAS-loop + struct
// memcpy + release-store), which would 30-50× the CBGR budget if always
// active.
//

// The runtime gate lets the audit be turned off by default and toggled
// on at process start (debug builds, observability mode) or per-test
// scope. When disabled, `record_*` helpers in `cap_audit.vr` early-
// return without touching the ring — the cost is a single relaxed
// atomic load + branch (~1-2ns) rather than the full commit.
//

// Order semantics:
//  * `enable()` / `disable()` use Release so subsequent calls in the
//  enabling thread observe the flag set before any audit work runs.
//  * `is_enabled()` uses Relaxed because the producer has already
//  synchronised through the per-slot seqlock acquire — the flag
//  check is a fast-path filter, not a synchronisation point.
//

// This is *not* the eventual `@cfg(feature = "cbgr_audit")` compile-
// time gate (which would compile every audit call to a literal no-op).
// The runtime gate is the bootstrap mechanism: ships today, exercises
// the audit pipeline end-to-end in tests, and stays useful as a per-
// process toggle even after the compile-time gate lands.
// =============================================================================

/// Recording-enabled flag. Zero = audit ring is disabled (commits
/// short-circuit at the helper level); non-zero = recording.
public static mut CAP_AUDIT_ENABLED: UInt8 = 0;

// =============================================================================
// Slot layout — one cell of the ring
// =============================================================================

/// One ring slot. Two cache-aligned cells: a 64-bit seqlock state and
/// the published CapEvent payload. No padding needed — CapEvent is
/// already by-value with all-integer fields.
type CapAuditSlot is {
    /// Seqlock state. Encoding:
    ///  - 0 → uninitialised
    ///  - WRITING_BIT | seq → writer currently in-flight, seq pending
    ///  - seq (low 63 bits) → stable, payload reflects this seq
    state: UInt64,

    /// Published payload. Read-only when `state` is stable.
    event: CapEvent,
};

// =============================================================================
// Global ring storage
// =============================================================================

/// Monotonic global sequence counter. Each commit() reserves `++NEXT_SEQ`
/// before locating its slot, so sequences are globally unique even when
/// they collide on the same slot index.
public static mut CAP_AUDIT_NEXT_SEQ: UInt64 = 0;

/// Ring buffer of slots. Initialised at module load with all-zero state
/// (uninitialised) and a placeholder CapEvent that observers will never
/// see (filtered out by `state == 0` check in `recent()`).
public static mut CAP_AUDIT_RING: [CapAuditSlot; 256] = [
    CapAuditSlot {
        state: 0,
        event: CapEvent {
            kind: CapEventKind.Revoke,
            seq: 0,
            ptr_id: 0,
            generation_before: 0,
            generation_after: 0,
            capabilities_before: 0,
            capabilities_after: 0,
            timestamp_ns: 0,
        },
    };
    256
];

// =============================================================================
// Writer API
// =============================================================================

/// Commit a CapEvent into the ring. Assigns a globally unique sequence
/// number, claims the target slot via CAS-loop, writes the payload, and
/// publishes the new sequence with a release store.
///

/// The caller's `event.seq` is overwritten with the assigned sequence
/// before publication; callers should pass `event.seq = 0` (the
/// `CapEvent.new` default) and read back the assigned seq from
/// `recent()` snapshots.
///

/// # Returns
///

/// The assigned sequence number. Useful for tests that want to verify
/// monotonicity or correlate other operations with the audit event.
///

/// # Concurrency
///

/// Lock-free for any number of writers. No reader-blocking — readers
/// detect concurrent writers via the seqlock retry protocol and skip
/// torn slots.
public fn commit(event: CapEvent) -> UInt64 {
    // Runtime gate: when audit is disabled, short-circuit before
    // touching any ring state. Cost is one relaxed-load + branch
    // (~1-2 ns); the full commit body only runs when audit is on.
    //

    // Placing the gate inside `commit` rather than at each `record_*`
    // call site centralises the predicate (callers don't need to
    // know to check) and sidesteps the codegen lenient-SKIP gap on
    // qualified `super.cap_audit_ring.is_enabled()` calls from
    // sibling modules (#166).
    let enabled_ptr = unsafe { &CAP_AUDIT_ENABLED as *const UInt8 };
    if atomic_load_u8(enabled_ptr, ORDERING_RELAXED) == 0 {
        return 0;
    }

    let next_seq_ptr = unsafe { &CAP_AUDIT_NEXT_SEQ as *mut UInt64 };
    let seq = atomic_fetch_add_u64(next_seq_ptr, 1, ORDERING_ACQ_REL) + 1;

    let idx = ((seq - 1) & CAP_AUDIT_RING_MASK) as Int;
    let slot_ptr = unsafe { &mut CAP_AUDIT_RING[idx] as *mut CapAuditSlot };
    let state_ptr = unsafe { &mut (*slot_ptr).state as *mut UInt64 };

    // Stamp the event with the assigned sequence before publication so
    // observers reading the published payload see the correct seq.
    let mut stamped = event;
    stamped.seq = seq;

    // Claim the slot. CAS until we either win or observe a strictly
    // newer writer (in which case our event is stale and we drop it).
    let claim = SLOT_WRITING_BIT | seq;
    loop {
        let prev = atomic_load_u64(state_ptr, ORDERING_ACQUIRE);
        let prev_seq = prev & !SLOT_WRITING_BIT;
        if prev_seq >= seq {
            // A writer with a higher seq has already taken this slot;
            // our event would be overwritten before any reader could
            // see it. Abandon to keep the audit log advancing.
            return seq;
        }
        let (_, ok) = atomic_compare_exchange_u64(
            state_ptr, prev, claim,
            ORDERING_ACQ_REL, ORDERING_RELAXED,
        );
        if ok {
            break;
        }
        spin_hint();
    }

    // We own the slot. Write the payload (single struct assignment).
    unsafe {
        (*slot_ptr).event = stamped;
    }

    // Publish: release-store seq with WRITING_BIT cleared. This makes
    // the payload writes visible to readers performing acquire-loads.
    atomic_store_u64(state_ptr, seq, ORDERING_RELEASE);

    seq
}

// =============================================================================
// Reader API
// =============================================================================

/// Snapshot the most recent `n` committed events. Returns events in
/// ascending seq order (oldest first). The returned list may have
/// fewer than `n` elements if:
///

/// - Fewer than `n` events have ever been committed.
/// - One or more slots in the requested window were torn-read (a
///  concurrent writer mutated the slot during the reader's pass).
///  These are filtered out rather than reported as garbage.
///

/// Performance: O(n) atomic loads + O(n) struct copies. No
/// allocations beyond the result list.
public fn recent(n: Int) -> List<CapEvent> {
    let next_seq_ptr = unsafe { &CAP_AUDIT_NEXT_SEQ as *const UInt64 };
    let cur = atomic_load_u64(next_seq_ptr, ORDERING_ACQUIRE);

    let mut result: List<CapEvent> = List.with_capacity(n);
    if cur == 0 || n <= 0 {
        return result;
    }

    let n_u64 = n as UInt64;
    let start: UInt64 = if cur > n_u64 { cur - n_u64 + 1 } else { 1 };

    let mut s = start;
    while s <= cur {
        let idx = ((s - 1) & CAP_AUDIT_RING_MASK) as Int;
        let slot_ptr = unsafe { &CAP_AUDIT_RING[idx] as *const CapAuditSlot };
        let state_ptr = unsafe { &(*slot_ptr).state as *const UInt64 };

        let state1 = atomic_load_u64(state_ptr, ORDERING_ACQUIRE);
        if state1 == s {
            // Slot is stable and reflects exactly the seq we want.
            // Copy the payload, then re-check state to detect a torn
            // read against a concurrent writer.
            let ev = unsafe { (*slot_ptr).event };
            let state2 = atomic_load_u64(state_ptr, ORDERING_ACQUIRE);
            if state2 == s {
                result.push(ev);
            }
            // Else: writer raced; skip this seq.
        }
        // Else: slot was overwritten by a higher seq, or the writer
        // for this seq never finished publishing — skip.
        s = s + 1;
    }

    result
}

/// Total number of events ever committed to the ring (including those
/// since overwritten by wraparound). Equal to the most-recent assigned
/// sequence number.
public fn count() -> UInt64 {
    let next_seq_ptr = unsafe { &CAP_AUDIT_NEXT_SEQ as *const UInt64 };
    atomic_load_u64(next_seq_ptr, ORDERING_ACQUIRE)
}

// =============================================================================
// Runtime gate API
// =============================================================================

/// Enable audit recording. Subsequent CBGR write events will be
/// committed to the ring. Idempotent.
///

/// Release-store ensures that any setup work (e.g. clearing the ring,
/// initialising observers) performed by the calling thread before
/// `enable()` happens-before any `record_*` call running concurrently
/// after the flag becomes visible.
public fn enable() {
    let ptr = unsafe { &CAP_AUDIT_ENABLED as *mut UInt8 };
    atomic_store_u8(ptr, 1, ORDERING_RELEASE);
}

/// Disable audit recording. Subsequent `record_*` calls short-circuit
/// without touching the ring. Already-published events remain in the
/// ring and are still observable via `recent()`.
public fn disable() {
    let ptr = unsafe { &CAP_AUDIT_ENABLED as *mut UInt8 };
    atomic_store_u8(ptr, 0, ORDERING_RELEASE);
}

/// True iff recording is currently enabled. Hot-path predicate used
/// by `record_*` helpers to skip the commit work when audit is off.
///

/// Uses Relaxed ordering — a missed transition (writer sees stale
/// "disabled" briefly after `enable()`) is acceptable for a forensic
/// log; the next CBGR write picks up the new state. The atomic load
/// is ~1-2 ns vs ~30-50 ns for a full commit, so the early-return
/// path keeps the CBGR hot path within budget when audit is off.
@inline
public fn is_enabled() -> Bool {
    let ptr = unsafe { &CAP_AUDIT_ENABLED as *const UInt8 };
    atomic_load_u8(ptr, ORDERING_RELAXED) != 0
}

/// Reset the ring to the empty state. Intended for tests; production
/// code should never call this because it discards forensic history.
///

/// Not safe to call concurrently with `commit()` — the reset clears
/// the global counter and per-slot states without coordinating with
/// in-flight writers, so a writer mid-publication could corrupt a
/// reset slot. Callers must establish a quiescent point before
/// resetting (e.g. test setup with no live producers).
public fn reset_for_tests() {
    // Reset the next-seq scalar.  This alone is sufficient for the
    // `regression_recent_zero_returns_empty` and
    // `regression_disabled_record_does_not_advance_count` surfaces
    // because (a) the static-mut declaration zero-initialises every
    // slot's `state` at module load, and (b) those tests only assert
    // on `recent(0).is_empty()` / `disabled-state-no-count-advance`.
    //
    // The per-slot reset loop is deferred until array-static-mut
    // codegen lands (currently the `&mut CAP_AUDIT_RING[i]` expression
    // surfaces `NullPointerAt 0x78` because the array's static cell
    // isn't allocated by the unimplemented array-static-mut codegen
    // path; see task #24 / static-mut record-and-array cluster).
    //
    // Architectural rule pinned: every per-slot test that requires
    // a clean array state MUST be gated on a separate
    // `@cfg(feature = "static_mut_array_codegen_landed")` flag once
    // the feature lands.  For now, this function is the minimal
    // surface that survives compilation and exercises the scalar path.
    let next_seq_ptr = unsafe { &CAP_AUDIT_NEXT_SEQ as *mut UInt64 };
    atomic_store_u64(next_seq_ptr, 0, ORDERING_RELEASE);
}


// =============================================================================
// Semantic record helpers
// =============================================================================
//

// Thin convenience wrappers over `cap_audit_ring.commit` that build
// the `CapEvent` from per-writer arguments. These are the entry points
// CBGR write sites in `header.vr` (try_revoke, attenuate_capabilities,
// increment_ref_count, decrement_ref_count, increment_generation) call
// after their atomic state transition succeeds — so the ring captures
// the *committed* delta, not a speculative attempt.
//

// All helpers are `@inline` and call into the ring buffer's lock-free
// `commit` path. Future hot-path optimisation: gate the body with
// `@cfg(feature = "diagnostics")` so non-audit builds compile to a
// literal no-op (preserves the ~0.93ns CBGR hot-path budget).
// =============================================================================


/// Record a successful `try_revoke` event (generation bumped, no
/// capability change — the revoke caps clear is a separate
/// transition). Caller passes the user-pointer address as `ptr_id`
/// for stable allocation identity.
///

/// `timestamp_ns` is `0` when the platform's monotonic clock is
/// unsupported or the recorder opted out.
@inline
public fn record_revoke(
    ptr_id: UInt64,
    generation_before: UInt32,
    generation_after: UInt32,
    capabilities: UInt16,
    timestamp_ns: UInt64,
) -> UInt64 {
    let event = CapEvent.new(
        CapEventKind.Revoke,
        ptr_id,
        generation_before,
        generation_after,
        capabilities,        // before
        capabilities,        // after — revoke does not modify caps mask
        timestamp_ns,
    );
    commit(event)
}

/// Record a successful `attenuate_capabilities` event (capabilities
/// narrowed monotonically, generation unchanged).
@inline
public fn record_attenuate(
    ptr_id: UInt64,
    generation: UInt32,
    capabilities_before: UInt16,
    capabilities_after: UInt16,
    timestamp_ns: UInt64,
) -> UInt64 {
    let event = CapEvent.new(
        CapEventKind.Attenuate,
        ptr_id,
        generation,         // before
        generation,         // after — attenuate does not bump generation
        capabilities_before,
        capabilities_after,
        timestamp_ns,
    );
    commit(event)
}

/// Record an `increment_ref_count` event (slow path only — fast-path
/// `&checked` borrows do not touch ref_count and are not audited).
@inline
public fn record_ref_incr(
    ptr_id: UInt64,
    generation: UInt32,
    capabilities: UInt16,
    timestamp_ns: UInt64,
) -> UInt64 {
    let event = CapEvent.new(
        CapEventKind.RefIncr,
        ptr_id,
        generation,
        generation,
        capabilities,
        capabilities,
        timestamp_ns,
    );
    commit(event)
}

/// Record a `decrement_ref_count` event.
@inline
public fn record_ref_decr(
    ptr_id: UInt64,
    generation: UInt32,
    capabilities: UInt16,
    timestamp_ns: UInt64,
) -> UInt64 {
    let event = CapEvent.new(
        CapEventKind.RefDecr,
        ptr_id,
        generation,
        generation,
        capabilities,
        capabilities,
        timestamp_ns,
    );
    commit(event)
}

/// Record an explicit `increment_generation` event (segment reuse
/// path — distinct from revoke, which is generation-bumping but
/// semantically a different transition).
@inline
public fn record_gen_bump(
    ptr_id: UInt64,
    generation_before: UInt32,
    generation_after: UInt32,
    capabilities: UInt16,
    timestamp_ns: UInt64,
) -> UInt64 {
    let event = CapEvent.new(
        CapEventKind.GenBump,
        ptr_id,
        generation_before,
        generation_after,
        capabilities,
        capabilities,
        timestamp_ns,
    );
    commit(event)
}

/// Record an `epoch_advance` event (epoch counter advanced past the
/// generation-wraparound watermark). The single global epoch event
/// is independent of any specific allocation, so `ptr_id` is `0`.
@inline
public fn record_epoch_advance(
    epoch_before: UInt16,
    epoch_after: UInt16,
    timestamp_ns: UInt64,
) -> UInt64 {
    let event = CapEvent.new(
        CapEventKind.EpochAdvance,
        0,                   // ptr_id — global event
        0,                   // generation_before — N/A
        0,                   // generation_after — N/A
        epoch_before,        // reuse caps slots to carry epoch delta
        epoch_after,
        timestamp_ns,
    );
    commit(event)
}
