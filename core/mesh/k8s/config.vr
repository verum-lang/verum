// =============================================================================
// mesh/k8s/config.vr — kubeconfig + in-cluster auth resolution
// =============================================================================

module core.mesh.k8s.config;

mount core.*;

public type KubeConfigError is
    | NotFound(Text)
    | InvalidYaml(Text)
    | ContextNotFound(Text)
    | NoAuth(Text)
    | IoError(Text);

implement Display for KubeConfigError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            NotFound(p)         => f.write_str(f"kubeconfig not found: {p}".as_str()),
            InvalidYaml(reason) => f.write_str(f"kubeconfig invalid YAML: {reason}".as_str()),
            ContextNotFound(c)  => f.write_str(f"kubeconfig context not found: {c}".as_str()),
            NoAuth(reason)      => f.write_str(f"kubeconfig: no resolvable auth ({reason})".as_str()),
            IoError(reason)     => f.write_str(f"kubeconfig I/O error: {reason}".as_str()),
        }
    }
}

implement Debug for KubeConfigError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            NotFound(p)         => f.write_str(f"NotFound({p})".as_str()),
            InvalidYaml(reason) => f.write_str(f"InvalidYaml({reason})".as_str()),
            ContextNotFound(c)  => f.write_str(f"ContextNotFound({c})".as_str()),
            NoAuth(reason)      => f.write_str(f"NoAuth({reason})".as_str()),
            IoError(reason)     => f.write_str(f"IoError({reason})".as_str()),
        }
    }
}

implement Eq for KubeConfigError {
    fn eq(&self, other: &KubeConfigError) -> Bool {
        match (self, other) {
            (NotFound(a),         NotFound(b))         => a == b,
            (InvalidYaml(a),      InvalidYaml(b))      => a == b,
            (ContextNotFound(a),  ContextNotFound(b))  => a == b,
            (NoAuth(a),           NoAuth(b))           => a == b,
            (IoError(a),          IoError(b))          => a == b,
            _ => false,
        }
    }
}

// =============================================================================
// Cluster endpoint
// =============================================================================

public type ClusterEndpoint is {
    server: Text,                            // https://<addr>:6443
    ca_bundle_pem: Maybe<Text>,
    insecure_skip_verify: Bool,
}

// =============================================================================
// Auth
// =============================================================================

public type AuthInfo is
    /// Bearer token (service-account / static).
    | Token(Text)
    /// Client-cert + private key pair.
    | ClientCertificate { cert_pem: Text, key_pem: Text }
    /// Exec plugin (kubectl-style).
    | ExecPlugin { command: Text, args: List<Text>, env_json: Text }
    /// In-cluster — read /var/run/secrets/kubernetes.io/serviceaccount.
    | InCluster;

// =============================================================================
// KubeConfig — resolved context
// =============================================================================

public type KubeConfig is {
    cluster: ClusterEndpoint,
    auth: AuthInfo,
    namespace: Maybe<Text>,
}

implement KubeConfig {
    /// Load the first available source in preference order:
    ///   1. $KUBECONFIG env var (:-separated paths)
    ///   2. ~/.kube/config
    ///   3. /var/run/secrets/kubernetes.io/serviceaccount (in-cluster)
    pub async fn load_default() -> Result<KubeConfig, KubeConfigError> {
        @intrinsic("verum.k8s.load_default_kubeconfig").await
    }

    /// Load a specific context from an explicit kubeconfig path.
    pub async fn load_context(path: &Text, context: &Text)
        -> Result<KubeConfig, KubeConfigError>
    {
        @intrinsic("verum.k8s.load_kubeconfig_context", path, context).await
    }

    /// Construct from an explicit endpoint + auth.
    public fn from_endpoint(cluster: ClusterEndpoint, auth: AuthInfo) -> KubeConfig {
        KubeConfig { cluster: cluster, auth: auth, namespace: None }
    }

    public fn with_namespace(mut self, namespace: Text) -> KubeConfig {
        self.namespace = Some(namespace); self
    }

    public fn cluster(&self) -> &ClusterEndpoint { &self.cluster }
    public fn auth(&self) -> &AuthInfo { &self.auth }
    public fn namespace(&self) -> &Maybe<Text> { &self.namespace }
}
