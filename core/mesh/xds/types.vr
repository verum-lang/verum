// =============================================================================
// mesh/xds/types.vr — xDS v3 canonical TypeUrls + XdsNode + config
// =============================================================================

module core.mesh.xds.types;

mount core.*;
mount core.time.duration.{Duration};

// =============================================================================
// Canonical type URLs (RFC-style, matching protobuf Any)
// =============================================================================

public type TypeUrl is {
    url: Text,
}

implement TypeUrl {
    public const LISTENER: &'static Text =
        "type.googleapis.com/envoy.config.listener.v3.Listener";
    public const CLUSTER: &'static Text =
        "type.googleapis.com/envoy.config.cluster.v3.Cluster";
    public const ROUTE_CONFIGURATION: &'static Text =
        "type.googleapis.com/envoy.config.route.v3.RouteConfiguration";
    public const CLUSTER_LOAD_ASSIGNMENT: &'static Text =
        "type.googleapis.com/envoy.config.endpoint.v3.ClusterLoadAssignment";
    public const SECRET: &'static Text =
        "type.googleapis.com/envoy.extensions.transport_sockets.tls.v3.Secret";
    public const SCOPED_ROUTE_CONFIGURATION: &'static Text =
        "type.googleapis.com/envoy.config.route.v3.ScopedRouteConfiguration";
    public const VIRTUAL_HOST: &'static Text =
        "type.googleapis.com/envoy.config.route.v3.VirtualHost";
    public const RUNTIME: &'static Text =
        "type.googleapis.com/envoy.service.runtime.v3.Runtime";

    public fn new(url: Text) -> TypeUrl { TypeUrl { url: url } }
    public fn value(&self) -> &Text { &self.url }
}

// =============================================================================
// XdsResource naming
// =============================================================================

public type ResourceName is {
    name: Text,
}

implement ResourceName {
    public fn new(name: Text) -> ResourceName { ResourceName { name: name } }
    public fn value(&self) -> &Text { &self.name }

    /// "xdstp://authority/type/path?context" resource names per
    /// https://github.com/cncf/xds/blob/main/proposals/TP1-xds-transport-next.md
    public fn xdstp(authority: &Text, type_: &Text, path: &Text) -> ResourceName {
        let mut s = Text.with_capacity(9 + authority.len() + 1 + type_.len() + 1 + path.len());
        s.push_str("xdstp://");
        s.push_str(authority);
        s.push('/');
        s.push_str(type_);
        s.push('/');
        s.push_str(path);
        ResourceName { name: s }
    }
}

// =============================================================================
// XdsNode identity (sent in every DiscoveryRequest)
// =============================================================================

public type XdsNode is {
    id: Text,
    cluster: Text,
    locality_region: Maybe<Text>,
    locality_zone: Maybe<Text>,
    locality_subzone: Maybe<Text>,
    user_agent_name: Text,
    user_agent_version: Text,
    metadata_json: Text,
}

implement XdsNode {
    public fn new(id: Text, cluster: Text) -> XdsNode {
        XdsNode {
            id: id,
            cluster: cluster,
            locality_region: None,
            locality_zone: None,
            locality_subzone: None,
            user_agent_name: "verum-xds".into(),
            user_agent_version: "0.1".into(),
            metadata_json: "{}".into(),
        }
    }

    public fn with_locality(
        mut self,
        region: Text,
        zone: Text,
        subzone: Maybe<Text>,
    ) -> XdsNode {
        self.locality_region = Some(region);
        self.locality_zone = Some(zone);
        self.locality_subzone = subzone;
        self
    }

    public fn with_user_agent(mut self, name: Text, version: Text) -> XdsNode {
        self.user_agent_name = name;
        self.user_agent_version = version;
        self
    }

    public fn with_metadata_json(mut self, json: Text) -> XdsNode {
        self.metadata_json = json; self
    }
}

// =============================================================================
// AdsConfig — control-plane connection + backoff + auth
// =============================================================================

public type AdsAuth is
    /// Raw gRPC, no auth (test / local).
    | None
    /// mTLS — cert chain + private key. Compatible with SPIFFE SVIDs.
    | MutualTls { cert_chain_pem: Text, private_key_pem: Text, ca_bundle_pem: Text }
    /// JWT bearer token (Istio JWT-SVIDs, Asset-Credentials).
    | Bearer(Text);

public type AdsConfig is {
    address: Text,                       // e.g. "istiod.istio-system:15010"
    node: XdsNode,
    auth: AdsAuth,
    /// Use DeltaAggregatedResources stream instead of legacy ADS.
    use_delta: Bool,
    initial_reconnect_backoff: Duration,
    max_reconnect_backoff: Duration,
    keepalive_interval: Duration,
    initial_request_timeout: Duration,
}

implement AdsConfig {
    public fn new(address: Text, node: XdsNode) -> AdsConfig {
        AdsConfig {
            address: address,
            node: node,
            auth: AdsAuth.None,
            use_delta: true,   // prefer delta-xDS since Envoy 1.15 / Istio 1.8
            initial_reconnect_backoff: Duration.from_millis(500),
            max_reconnect_backoff: Duration.from_secs(30),
            keepalive_interval: Duration.from_secs(15),
            initial_request_timeout: Duration.from_secs(30),
        }
    }

    public fn with_auth(mut self, auth: AdsAuth) -> AdsConfig {
        self.auth = auth; self
    }

    public fn with_use_delta(mut self, delta: Bool) -> AdsConfig {
        self.use_delta = delta; self
    }

    public fn with_keepalive(mut self, interval: Duration) -> AdsConfig {
        self.keepalive_interval = interval; self
    }
}
