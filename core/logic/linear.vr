// =============================================================================
// linear.vr — Linear Logic Connectives
// =============================================================================
//
// Layer: Standard Library / Logic
//
// User-facing surface for the linear-logic analysis core
// (`verum_types.linear_logic`). Full Girard-style propositional
// linear logic with multiplicative, additive, and exponential
// connectives — a richer foundation than QTT alone for resource
// reasoning.
//
// ## Connective summary
//
// ```text
//     A ⊗ B    multiplicative conjunction (tensor)   "both, paired"
//     A ⅋ B    multiplicative disjunction (par)      "both, parallel"
//     A & B    additive conjunction (with)           "external choice"
//     A ⊕ B    additive disjunction (plus)           "internal choice"
//     A ⊸ B    linear function                       defined as A^⊥ ⅋ B
//     !A       of-course / bang                       unrestricted use
//     ?A       why-not                                weakenable
//     1, ⊥, ⊤, 0    units                            (multiplicative + additive)
//     A^⊥      linear negation (involutive)
// ```
//
// ## Example
//
// ```verum
// // (A ⊗ B)^⊥ ↦ A^⊥ ⅋ B^⊥  (de Morgan)
// let f: LinForm = lin_tensor(lin_atom("A"), lin_atom("B"));
// let neg: LinForm = lin_dual(f);
// // After NNF, neg is A^⊥ ⅋ B^⊥
// ```
//
// =============================================================================

module core.logic.linear;

// =============================================================================
// 1. Linear logic formula
// =============================================================================

/// A linear logic formula. Constructed via the `lin_*` smart
/// constructors below.
public type LinForm is
    /// Atomic proposition.
    | Atom { name: Text }
    /// `A ⊗ B` — multiplicative conjunction (tensor product).
    ///
    /// Named `MTensor` (multiplicative tensor) rather than bare `Tensor`
    /// to avoid an unqualified-name collision with `core.math.tensor.Tensor`
    /// in user code. `Tensor.zeros([N])` used to resolve to this variant's
    /// constructor instead of the intended Tensor type.
    | MTensor { left: Heap<LinForm>, right: Heap<LinForm> }
    /// `A ⅋ B` — multiplicative disjunction.
    | Par { left: Heap<LinForm>, right: Heap<LinForm> }
    /// `A & B` — additive conjunction.
    | With { left: Heap<LinForm>, right: Heap<LinForm> }
    /// `A ⊕ B` — additive disjunction.
    | Plus { left: Heap<LinForm>, right: Heap<LinForm> }
    /// `!A` — of-course (unrestricted use).
    | OfCourse { inner: Heap<LinForm> }
    /// `?A` — why-not (weakenable).
    | WhyNot { inner: Heap<LinForm> }
    /// `1` — multiplicative truth.
    | One
    /// `⊥` — multiplicative false.
    | Bottom
    /// `⊤` — additive truth.
    | Top
    /// `0` — additive false.
    | Zero
    /// `A^⊥` — linear negation.
    | Dual { inner: Heap<LinForm> };

// =============================================================================
// 2. Smart constructors
// =============================================================================

public fn lin_atom(name: Text) -> LinForm {
    LinForm.Atom { name }
}

public fn lin_tensor(a: LinForm, b: LinForm) -> LinForm {
    LinForm.MTensor { left: Heap(a), right: Heap(b) }
}

public fn lin_par(a: LinForm, b: LinForm) -> LinForm {
    LinForm.Par { left: Heap(a), right: Heap(b) }
}

public fn lin_with(a: LinForm, b: LinForm) -> LinForm {
    LinForm.With { left: Heap(a), right: Heap(b) }
}

public fn lin_plus(a: LinForm, b: LinForm) -> LinForm {
    LinForm.Plus { left: Heap(a), right: Heap(b) }
}

public fn lin_of_course(a: LinForm) -> LinForm {
    LinForm.OfCourse { inner: Heap(a) }
}

public fn lin_why_not(a: LinForm) -> LinForm {
    LinForm.WhyNot { inner: Heap(a) }
}

public fn lin_dual(a: LinForm) -> LinForm {
    LinForm.Dual { inner: Heap(a) }
}

/// Linear implication `A ⊸ B := A^⊥ ⅋ B`.
public fn lin_lolli(a: LinForm, b: LinForm) -> LinForm {
    lin_par(lin_dual(a), b)
}

// =============================================================================
// 3. Classification predicates
// =============================================================================

/// `f` admits both weakening and contraction — usable any number
/// of times, including zero. The unrestricted-shape set in
/// classical linear logic:
///
/// - `!A` (`OfCourse`) admits weakening + contraction on the LHS
///   — the bang's exponential structural rules.
/// - `?A` (`WhyNot`) admits weakening + contraction on the RHS
///   — the dual why-not modality.
/// - `⊤` (`Top`) is the additive truth: `⊢ Δ, ⊤` absorbs any
///   surrounding context, so it admits both structural rules
///   trivially.
///
/// `1` (`One`) is the unit of `⊗` — it has exactly one proof and
/// admits **no** structural rules. The previous implementation
/// claimed `One` was unrestricted; that was a soundness defect
/// that would let a resource analyser silently relax linearity
/// for tensor-units. `⊥`, `0`, and bare atoms / connectives also
/// admit no exponential structure and stay false.
public fn is_unrestricted(f: LinForm) -> Bool {
    match f {
        LinForm.OfCourse { inner: _ } => true,
        LinForm.WhyNot { inner: _ } => true,
        LinForm.Top => true,
        _ => false,
    }
}

/// `f` admits weakening — usable zero times. In classical linear
/// logic weakening and contraction travel together as the
/// exponential-modality structural-rule package, so weakenable and
/// unrestricted classify the same set. The surface is preserved
/// as a distinct predicate so callers that only care about the
/// "discardable without use" aspect read clearly. The previous
/// implementation excluded `OfCourse`, which forced callers to
/// special-case `!A` even though `!A` admits weakening by
/// dereliction-and-discard.
public fn is_weakenable(f: LinForm) -> Bool {
    is_unrestricted(f)
}

// =============================================================================
// 4. Negation-normal form (NNF) — push every Dual to the leaves
// =============================================================================

/// One-step duality: compute `(f)^⊥` by the standard de Morgan /
/// involutivity rewrites for full classical linear logic. The
/// returned form is structurally one level denser than `f` (the
/// surrounding `Dual` consumed); recursive callers will continue
/// pushing duals through the children if needed.
///
/// ```text
///     (A ⊗ B)^⊥  ↦  A^⊥ ⅋ B^⊥
///     (A ⅋ B)^⊥  ↦  A^⊥ ⊗ B^⊥
///     (A & B)^⊥  ↦  A^⊥ ⊕ B^⊥
///     (A ⊕ B)^⊥  ↦  A^⊥ & B^⊥
///     (!A)^⊥     ↦  ?(A^⊥)
///     (?A)^⊥     ↦  !(A^⊥)
///     1^⊥        ↦  ⊥
///     ⊥^⊥        ↦  1
///     ⊤^⊥        ↦  0
///     0^⊥        ↦  ⊤
///     (A^⊥)^⊥    ↦  A         (involutivity)
///     atom^⊥     ↦  Dual(atom) (atom dual stays as a leaf)
/// ```
fn lin_negate(f: LinForm) -> LinForm {
    match f {
        LinForm.Atom { name } => LinForm.Dual { inner: Heap(LinForm.Atom { name }) },
        LinForm.MTensor { left, right } =>
            lin_par(lin_negate(*left), lin_negate(*right)),
        LinForm.Par { left, right } =>
            lin_tensor(lin_negate(*left), lin_negate(*right)),
        LinForm.With { left, right } =>
            lin_plus(lin_negate(*left), lin_negate(*right)),
        LinForm.Plus { left, right } =>
            lin_with(lin_negate(*left), lin_negate(*right)),
        LinForm.OfCourse { inner } => lin_why_not(lin_negate(*inner)),
        LinForm.WhyNot { inner } => lin_of_course(lin_negate(*inner)),
        LinForm.One => LinForm.Bottom,
        LinForm.Bottom => LinForm.One,
        LinForm.Top => LinForm.Zero,
        LinForm.Zero => LinForm.Top,
        // Dual of Dual collapses by involutivity — but we then
        // *recursively normalise* the inner form so the result is
        // in NNF (in case the inner had its own duals to push).
        LinForm.Dual { inner } => lin_to_nnf(*inner),
    }
}

/// Negation-normal form: every `Dual` constructor in the result
/// wraps an atomic leaf only; all other connectives appear with
/// positive (non-dualised) arguments. Idempotent — `lin_to_nnf`
/// applied to an already-NNF formula returns it unchanged.
///
/// This is the standard preprocessing step for sequent-calculus
/// search and proof-net construction in linear logic.
public fn lin_to_nnf(f: LinForm) -> LinForm {
    match f {
        LinForm.Atom { name } => LinForm.Atom { name },
        LinForm.MTensor { left, right } =>
            lin_tensor(lin_to_nnf(*left), lin_to_nnf(*right)),
        LinForm.Par { left, right } =>
            lin_par(lin_to_nnf(*left), lin_to_nnf(*right)),
        LinForm.With { left, right } =>
            lin_with(lin_to_nnf(*left), lin_to_nnf(*right)),
        LinForm.Plus { left, right } =>
            lin_plus(lin_to_nnf(*left), lin_to_nnf(*right)),
        LinForm.OfCourse { inner } => lin_of_course(lin_to_nnf(*inner)),
        LinForm.WhyNot { inner } => lin_why_not(lin_to_nnf(*inner)),
        LinForm.One => LinForm.One,
        LinForm.Bottom => LinForm.Bottom,
        LinForm.Top => LinForm.Top,
        LinForm.Zero => LinForm.Zero,
        // Push the dual through the inner form — `lin_negate`
        // handles every connective and recurses via `lin_to_nnf`
        // for nested duals (involutivity).
        LinForm.Dual { inner } => lin_negate(*inner),
    }
}

/// True iff every `Dual` constructor in `f` wraps an `Atom`.
/// Used by tests and as a postcondition for `lin_to_nnf` —
/// `lin_is_nnf(lin_to_nnf(g))` should hold for every input `g`.
public fn lin_is_nnf(f: LinForm) -> Bool {
    match f {
        LinForm.Atom { name: _ } => true,
        LinForm.Dual { inner } => match *inner {
            LinForm.Atom { name: _ } => true,
            _ => false,
        },
        LinForm.MTensor { left, right } =>
            lin_is_nnf(*left) && lin_is_nnf(*right),
        LinForm.Par { left, right } =>
            lin_is_nnf(*left) && lin_is_nnf(*right),
        LinForm.With { left, right } =>
            lin_is_nnf(*left) && lin_is_nnf(*right),
        LinForm.Plus { left, right } =>
            lin_is_nnf(*left) && lin_is_nnf(*right),
        LinForm.OfCourse { inner } => lin_is_nnf(*inner),
        LinForm.WhyNot { inner } => lin_is_nnf(*inner),
        LinForm.One => true,
        LinForm.Bottom => true,
        LinForm.Top => true,
        LinForm.Zero => true,
    }
}

// =============================================================================
// 5. Structural equality + size
// =============================================================================

/// Structural equality on linear-logic formulas.
///
/// LinForm has no binders, so this is a pure recursive walk over
/// the constructor tree. Two formulas compare equal iff every
/// constructor matches and the leaf atoms / units are identical.
///
/// Note: this is *syntactic* equality. Two formulas may be
/// equivalent under the linear-logic proof theory yet differ
/// here (e.g. `A ⊗ (B ⊗ C)` vs `(A ⊗ B) ⊗ C`). For semantic
/// equivalence pass through `lin_to_nnf` first and rely on the
/// canonical shape produced there.
public fn lin_eq(a: LinForm, b: LinForm) -> Bool {
    match (a, b) {
        (LinForm.Atom { name: na }, LinForm.Atom { name: nb }) => na == nb,
        (LinForm.MTensor { left: la, right: ra },
         LinForm.MTensor { left: lb, right: rb }) =>
            lin_eq(*la, *lb) && lin_eq(*ra, *rb),
        (LinForm.Par { left: la, right: ra },
         LinForm.Par { left: lb, right: rb }) =>
            lin_eq(*la, *lb) && lin_eq(*ra, *rb),
        (LinForm.With { left: la, right: ra },
         LinForm.With { left: lb, right: rb }) =>
            lin_eq(*la, *lb) && lin_eq(*ra, *rb),
        (LinForm.Plus { left: la, right: ra },
         LinForm.Plus { left: lb, right: rb }) =>
            lin_eq(*la, *lb) && lin_eq(*ra, *rb),
        (LinForm.OfCourse { inner: ia }, LinForm.OfCourse { inner: ib }) =>
            lin_eq(*ia, *ib),
        (LinForm.WhyNot { inner: ia }, LinForm.WhyNot { inner: ib }) =>
            lin_eq(*ia, *ib),
        (LinForm.Dual { inner: ia }, LinForm.Dual { inner: ib }) =>
            lin_eq(*ia, *ib),
        (LinForm.One, LinForm.One) => true,
        (LinForm.Bottom, LinForm.Bottom) => true,
        (LinForm.Top, LinForm.Top) => true,
        (LinForm.Zero, LinForm.Zero) => true,
        _ => false,
    }
}

/// Size of a formula: count of non-leaf connectives. Each binary
/// connective (⊗, ⅋, &, ⊕) contributes 1; each unary modality
/// (!, ?, _^⊥) contributes 1; atoms and units contribute 0.
///
/// Used as a termination metric for proof-search heuristics and as
/// a complexity bound for proof-net construction (the number of
/// internal nodes is bounded by the size of the formula tree).
public fn lin_size(f: LinForm) -> Int {
    match f {
        LinForm.Atom { name: _ } => 0,
        LinForm.One => 0,
        LinForm.Bottom => 0,
        LinForm.Top => 0,
        LinForm.Zero => 0,
        LinForm.MTensor { left, right } => 1 + lin_size(*left) + lin_size(*right),
        LinForm.Par { left, right } => 1 + lin_size(*left) + lin_size(*right),
        LinForm.With { left, right } => 1 + lin_size(*left) + lin_size(*right),
        LinForm.Plus { left, right } => 1 + lin_size(*left) + lin_size(*right),
        LinForm.OfCourse { inner } => 1 + lin_size(*inner),
        LinForm.WhyNot { inner } => 1 + lin_size(*inner),
        LinForm.Dual { inner } => 1 + lin_size(*inner),
    }
}

/// Atomic count: number of `Atom` leaves in the formula. Useful
/// alongside `lin_size` for proof-search bookkeeping.
public fn lin_atom_count(f: LinForm) -> Int {
    match f {
        LinForm.Atom { name: _ } => 1,
        LinForm.One => 0,
        LinForm.Bottom => 0,
        LinForm.Top => 0,
        LinForm.Zero => 0,
        LinForm.MTensor { left, right } =>
            lin_atom_count(*left) + lin_atom_count(*right),
        LinForm.Par { left, right } =>
            lin_atom_count(*left) + lin_atom_count(*right),
        LinForm.With { left, right } =>
            lin_atom_count(*left) + lin_atom_count(*right),
        LinForm.Plus { left, right } =>
            lin_atom_count(*left) + lin_atom_count(*right),
        LinForm.OfCourse { inner } => lin_atom_count(*inner),
        LinForm.WhyNot { inner } => lin_atom_count(*inner),
        LinForm.Dual { inner } => lin_atom_count(*inner),
    }
}
