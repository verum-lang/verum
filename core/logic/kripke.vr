// =============================================================================
// kripke.vr — Kripke Semantics for Modal Logic
// =============================================================================
//
// Layer: Standard Library / Logic
//
// User-facing surface for the Kripke-semantics analysis core
// (`verum_types.kripke`). A Kripke frame is a set of *worlds*
// plus an *accessibility* relation; modal formulas `□φ` and `◇φ`
// are evaluated over the frame.
//
// ## Frame classes
//
// Different modal logics correspond to constraints on
// accessibility:
//
//   K    no constraints
//   T    reflexive               (every world sees itself)
//   B    symmetric
//   4    transitive               (S4 = T + 4)
//   5    Euclidean
//   S5   equivalence              (refl + sym + trans)
//
// ## Example
//
// ```verum
// // p holds at w1; w0 → w1, so □p holds at w0.
// let f: KripkeFrame = ...;
// let v: Valuation = ...;
// assert(evaluate(modal_box(modal_atom("p")), f, v, world("0")));
// ```
//
// =============================================================================

module core.logic.kripke;

// =============================================================================
// 1. Worlds and frames
// =============================================================================

/// A world in a Kripke frame.
public type World is { id: Text };

public fn world(id: Text) -> World {
    World { id }
}

/// An accessibility edge `from → to`.
public type KripkeEdge is { from: World, to: World };

public fn edge(from: World, to: World) -> KripkeEdge {
    KripkeEdge { from, to }
}

/// A Kripke frame: worlds + accessibility edges.
public type KripkeFrame is {
    worlds: List<World>,
    edges: List<KripkeEdge>,
};

public fn frame(worlds: List<World>, edges: List<KripkeEdge>) -> KripkeFrame {
    KripkeFrame { worlds, edges }
}

/// Worlds accessible from `w` in the frame.
public fn accessible(f: KripkeFrame, w: World) -> List<World> {
    let mut out: List<World> = [];
    let mut i: Int = 0;
    while i < f.edges.len() {
        if f.edges[i].from.id == w.id {
            out.push(f.edges[i].to);
        }
        i = i + 1;
    }
    out
}

// =============================================================================
// 1b. Kripke frame as a canonical Graph<World, ()>
// =============================================================================
//
// A Kripke frame IS a labelled directed graph — the accessibility
// relation is its edge set. Exposing the frame through
// `core.math.graph.Graph<World, ()>` means every graph algorithm
// (BFS, DFS, reachable, topological_sort, dijkstra) immediately
// applies to modal-logic semantics without bespoke traversal code.
//
// The wiring is a small shim because the field names differ:
// Kripke's `KripkeEdge { from, to }` vs graph.vr's `KripkeEdge<V, L> { src, tgt, label }`.
// The shim converts on the fly; concrete `impl Graph for KripkeFrame`
// is available via a companion `implement Graph for KripkeFrame {…}`
// wrapper once the modal-logic library promotes the frame to a
// full Graph instance; the shim functions below cover the interim.
//
// For now, expose the graph view as a free function.

/// Convert a Kripke edge to the canonical graph KripkeEdge shape.
public fn kripke_edge_to_graph(e: KripkeEdge) -> core.math.graph.KripkeEdge<World, ()> {
    core.math.graph.KripkeEdge { src: e.from, tgt: e.to, label: () }
}

/// Graph-view of a Kripke frame: edges in the canonical `core.math.graph.KripkeEdge`
/// shape. This lets `bfs`, `dfs`, `reachable`, etc. from `core.math.graph`
/// apply directly to the frame's accessibility relation.
public fn kripke_edges_as_graph(f: &KripkeFrame) -> List<core.math.graph.KripkeEdge<World, ()>> {
    let mut out: List<core.math.graph.KripkeEdge<World, ()>> = [];
    let mut i: Int = 0;
    while i < f.edges.len() {
        out.push(core.math.graph.KripkeEdge {
            src: f.edges[i].from,
            tgt: f.edges[i].to,
            label: (),
        });
        i = i + 1;
    }
    out
}

/// The out-neighbourhood of a world in the frame, returned as
/// canonical graph edges. Mirrors `Graph<World, ()>.out_edges`.
public fn kripke_out_edges(f: &KripkeFrame, w: &World) -> List<core.math.graph.KripkeEdge<World, ()>> {
    let mut out: List<core.math.graph.KripkeEdge<World, ()>> = [];
    let mut i: Int = 0;
    while i < f.edges.len() {
        if f.edges[i].from.id == w.id {
            out.push(core.math.graph.KripkeEdge {
                src: f.edges[i].from,
                tgt: f.edges[i].to,
                label: (),
            });
        }
        i = i + 1;
    }
    out
}

// =============================================================================
// 2. Valuation
// =============================================================================

/// A single fact: atom `name` holds at world `world` with value
/// `truth`.
public type WorldFact is {
    world_id: Text,
    atom: Text,
    truth: Bool,
};

/// Truth-value assignment per (world, atom) pair.
public type Valuation is { facts: List<WorldFact> };

public fn valuation(facts: List<WorldFact>) -> Valuation {
    Valuation { facts }
}

/// Look up the truth value of `atom` at `w`. Defaults to `false`
/// if no entry is present.
public fn lookup(v: Valuation, w: World, atom: Text) -> Bool {
    let mut i: Int = 0;
    while i < v.facts.len() {
        let fact = v.facts[i];
        if fact.world_id == w.id && fact.atom == atom {
            return fact.truth;
        }
        i = i + 1;
    }
    false
}

// =============================================================================
// 3. Modal formulas
// =============================================================================

/// A modal-logic formula over Kripke frames.
public type ModalForm is
    | True
    | False
    | Atom { name: Text }
    | Not { inner: Heap<ModalForm> }
    | And { left: Heap<ModalForm>, right: Heap<ModalForm> }
    | Or { left: Heap<ModalForm>, right: Heap<ModalForm> }
    | Implies { left: Heap<ModalForm>, right: Heap<ModalForm> }
    /// `□φ` — necessity (holds at every accessible world).
    | Box { inner: Heap<ModalForm> }
    /// `◇φ` — possibility (holds at some accessible world).
    | Diamond { inner: Heap<ModalForm> };

public fn modal_atom(name: Text) -> ModalForm {
    ModalForm.Atom { name }
}

public fn modal_not(inner: ModalForm) -> ModalForm {
    ModalForm.Not { inner: Heap(inner) }
}

public fn modal_and(a: ModalForm, b: ModalForm) -> ModalForm {
    ModalForm.And { left: Heap(a), right: Heap(b) }
}

public fn modal_or(a: ModalForm, b: ModalForm) -> ModalForm {
    ModalForm.Or { left: Heap(a), right: Heap(b) }
}

public fn modal_implies(a: ModalForm, b: ModalForm) -> ModalForm {
    ModalForm.Implies { left: Heap(a), right: Heap(b) }
}

public fn modal_box(inner: ModalForm) -> ModalForm {
    ModalForm.Box { inner: Heap(inner) }
}

public fn modal_diamond(inner: ModalForm) -> ModalForm {
    ModalForm.Diamond { inner: Heap(inner) }
}

// =============================================================================
// 4. Evaluator
// =============================================================================

/// Recursive modal-logic evaluator. Vacuous-truth for □ when
/// no worlds are accessible; ◇ requires at least one witness.
public fn evaluate(formula: ModalForm, f: KripkeFrame, v: Valuation, w: World) -> Bool {
    match formula {
        ModalForm.True => true,
        ModalForm.False => false,
        ModalForm.Atom { name } => lookup(v, w, name),
        ModalForm.Not { inner } => !evaluate(*inner, f, v, w),
        ModalForm.And { left, right } =>
            evaluate(*left, f, v, w) && evaluate(*right, f, v, w),
        ModalForm.Or { left, right } =>
            evaluate(*left, f, v, w) || evaluate(*right, f, v, w),
        ModalForm.Implies { left, right } =>
            !evaluate(*left, f, v, w) || evaluate(*right, f, v, w),
        ModalForm.Box { inner } => {
            let succs = accessible(f, w);
            let mut i: Int = 0;
            while i < succs.len() {
                if !evaluate(*inner, f, v, succs[i]) {
                    return false;
                }
                i = i + 1;
            }
            true
        },
        ModalForm.Diamond { inner } => {
            let succs = accessible(f, w);
            let mut i: Int = 0;
            while i < succs.len() {
                if evaluate(*inner, f, v, succs[i]) {
                    return true;
                }
                i = i + 1;
            }
            false
        },
    }
}

// =============================================================================
// 5. Validity + semantic equivalence
// =============================================================================

/// True iff `formula` evaluates to `true` at every world of `f`
/// under the valuation `v`. The standard "valid in frame" judgement.
///
/// Cost: O(|worlds| · evaluate_cost(formula)).
public fn valid_in_frame(f: KripkeFrame, v: Valuation, formula: ModalForm) -> Bool {
    let mut i: Int = 0;
    while i < f.worlds.len() {
        if !evaluate(formula.clone(), f.clone(), v.clone(), f.worlds[i].clone()) {
            return false;
        }
        i = i + 1;
    }
    true
}

/// True iff `a` and `b` evaluate to the same truth value at every
/// world of the frame under the valuation. Use this to check
/// semantic equivalence over a fixed model — the syntactic
/// equality of the two formulas is neither sufficient (different
/// shapes can have the same semantics) nor necessary (the same
/// formula always works).
public fn semantically_equivalent(
    f: KripkeFrame,
    v: Valuation,
    a: ModalForm,
    b: ModalForm,
) -> Bool {
    let mut i: Int = 0;
    while i < f.worlds.len() {
        let w = f.worlds[i].clone();
        if evaluate(a.clone(), f.clone(), v.clone(), w.clone())
            != evaluate(b.clone(), f.clone(), v.clone(), w)
        {
            return false;
        }
        i = i + 1;
    }
    true
}

// =============================================================================
// 6. Frame-property predicates (axiom-system identification)
// =============================================================================
//
// Modal-logic axioms each correspond to a structural property of
// the accessibility relation. The classical correspondence:
//
//     T  (□p → p)            reflexive frames
//     4  (□p → □□p)          transitive frames
//     5  (◇p → □◇p)          euclidean frames
//     B  (p → □◇p)           symmetric frames
//     D  (□p → ◇p)           serial frames
//
// Identifying a frame's properties tells you which axiom system
// it validates, which is the bridge from `evaluate` to formal
// proof obligations.

/// True iff every world has at least one accessible world
/// (∀w. ∃w'. wRw'). The frame property behind axiom D.
public fn is_serial(f: KripkeFrame) -> Bool {
    let mut i: Int = 0;
    while i < f.worlds.len() {
        let w = f.worlds[i].clone();
        let succs = accessible(f.clone(), w);
        if succs.len() == 0 {
            return false;
        }
        i = i + 1;
    }
    true
}

/// True iff every world is accessible from itself (∀w. wRw).
/// Frame property behind axiom T.
public fn is_reflexive(f: KripkeFrame) -> Bool {
    let mut i: Int = 0;
    while i < f.worlds.len() {
        let w = f.worlds[i].clone();
        if !has_edge(f.clone(), w.clone(), w) {
            return false;
        }
        i = i + 1;
    }
    true
}

/// True iff `wRv ∧ vRu ⇒ wRu` for all worlds. Frame property
/// behind axiom 4.
public fn is_transitive(f: KripkeFrame) -> Bool {
    let mut i: Int = 0;
    while i < f.edges.len() {
        let e1 = f.edges[i].clone();
        let mut j: Int = 0;
        while j < f.edges.len() {
            let e2 = f.edges[j].clone();
            if e1.to.id == e2.from.id {
                if !has_edge(f.clone(), e1.from.clone(), e2.to.clone()) {
                    return false;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    true
}

/// True iff `wRv ⇒ vRw` for all edges. Frame property behind
/// axiom B.
public fn is_symmetric(f: KripkeFrame) -> Bool {
    let mut i: Int = 0;
    while i < f.edges.len() {
        let e = f.edges[i].clone();
        if !has_edge(f.clone(), e.to.clone(), e.from.clone()) {
            return false;
        }
        i = i + 1;
    }
    true
}

/// True iff `wRv ∧ wRu ⇒ vRu` for all triples. Frame property
/// behind axiom 5 (euclidean).
public fn is_euclidean(f: KripkeFrame) -> Bool {
    let mut i: Int = 0;
    while i < f.edges.len() {
        let e1 = f.edges[i].clone();
        let mut j: Int = 0;
        while j < f.edges.len() {
            let e2 = f.edges[j].clone();
            if e1.from.id == e2.from.id {
                if !has_edge(f.clone(), e1.to.clone(), e2.to.clone()) {
                    return false;
                }
            }
            j = j + 1;
        }
        i = i + 1;
    }
    true
}

/// Helper: does `f` contain an edge from `a` to `b`?
fn has_edge(f: KripkeFrame, a: World, b: World) -> Bool {
    let mut i: Int = 0;
    while i < f.edges.len() {
        if f.edges[i].from.id == a.id && f.edges[i].to.id == b.id {
            return true;
        }
        i = i + 1;
    }
    false
}

/// Convenience: a frame is an S5 model iff its accessibility
/// relation is reflexive, transitive, AND symmetric (equivalently,
/// reflexive AND euclidean — the classical equivalence). Useful
/// for epistemic-logic readers ("knowledge as S5 modality").
public fn is_s5(f: KripkeFrame) -> Bool {
    is_reflexive(f.clone()) && is_transitive(f.clone()) && is_symmetric(f)
}
