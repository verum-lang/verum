// =============================================================================
// io/engine.vr - Async I/O Engine (kqueue / epoll / IOCP)
// =============================================================================
// Layer: 3 (I/O)
// Dependencies: core
// =============================================================================
//

// Platform-native async I/O engine:
//  - macOS: kqueue
//  - Linux: epoll
//  - Windows: IOCP (via sys/windows/io.vr IocpDriver)
//

// The IoEngine allows registering file descriptors for readiness
// notification, polling for events, and performing async socket operations.
//

// Usage:
//  let engine = IoEngine.new();
//  engine.register(fd, IoEvent.Read); // Watch for readability
//  let n = engine.poll(64, 5_000_000); // Poll with 5ms timeout
//  engine.deregister(fd);
//  engine.destroy();
//

// =============================================================================

module engine;

mount core.*;

// =============================================================================
// Event Types
// =============================================================================

/// I/O event interest flags.
public type IoEvent is {
    flags: Int,
};

implement IoEvent {
    /// Interest in read readiness (EPOLLIN / EVFILT_READ).
    public fn Read() -> IoEvent { IoEvent { flags: 1 } }

    /// Interest in write readiness (EPOLLOUT / EVFILT_WRITE).
    public fn Write() -> IoEvent { IoEvent { flags: 2 } }

    /// Interest in both read and write readiness.
    public fn ReadWrite() -> IoEvent { IoEvent { flags: 3 } }
}

// =============================================================================
// I/O Engine
// =============================================================================

/// Platform-native async I/O multiplexer.
///

/// Wraps kqueue (macOS), epoll (Linux), or IOCP (Windows).
/// Zero-allocation polling with bounded event buffers.
public type IoEngine is {
    handle: Int,
};

/// Default event-buffer capacity used by `IoEngine.new()`.
public const IO_ENGINE_DEFAULT_CAPACITY: Int = 256;

/// Hard upper bound on per-engine event-buffer capacity. The kernel
/// allocates ~32 bytes per event (kqueue/epoll/IOCP). 65536 ≈ 2 MiB
/// per engine is a generous ceiling and is also above the highest
/// kernel-imposed cap on any current platform.
public const IO_ENGINE_MAX_CAPACITY: Int = 65536;

/// Maximum events returnable in a single `poll` call. Larger values
/// just stall the caller longer — capping keeps tail latency bounded.
public const IO_ENGINE_MAX_POLL_EVENTS: Int = 4096;

// Raw intrinsics — centralised in core/intrinsics/runtime/io.vr (#63).
mount core.intrinsics.runtime.io.{
    __io_engine_new_raw,
    __io_engine_destroy_raw,
    __io_submit_raw,
    __io_poll_raw,
    __io_remove_raw,
    __io_modify_raw,
    __io_is_ready_raw,
    __io_take_ready_raw,
};

implement IoEngine {
    /// Create a new I/O engine with the default event capacity (256).
    public fn new() -> IoEngine {
        let h = __io_engine_new_raw(IO_ENGINE_DEFAULT_CAPACITY);
        IoEngine { handle: h }
    }

    /// Create with a custom event-buffer capacity.
    ///

    /// Out-of-range capacity (≤ 0 or > IO_ENGINE_MAX_CAPACITY) is clamped
    /// rather than failed, since this is a perf knob, not a contract:
    ///  - capacity ≤ 0 → use the default (256)
    ///  - capacity > IO_ENGINE_MAX_CAPACITY → cap at the maximum
    public fn with_capacity(capacity: Int) -> IoEngine {
        let cap = if capacity <= 0 {
            IO_ENGINE_DEFAULT_CAPACITY
        } else if capacity > IO_ENGINE_MAX_CAPACITY {
            IO_ENGINE_MAX_CAPACITY
        } else {
            capacity
        };
        let h = __io_engine_new_raw(cap);
        IoEngine { handle: h }
    }

    /// Register a file descriptor for event notification.
    /// Returns 0 on success, -1 on error or invalid input.
    public fn register(&self, fd: Int, event: IoEvent) -> Int {
        if self.handle == 0 || fd < 0 {
            return -1;
        }
        __io_submit_raw(self.handle, fd, event.flags)
    }

    /// Deregister a file descriptor.
    public fn deregister(&self, fd: Int) -> Int {
        if self.handle == 0 || fd < 0 {
            return -1;
        }
        __io_remove_raw(self.handle, fd)
    }

    /// Modify the event interest for a registered fd.
    public fn modify(&self, fd: Int, event: IoEvent) -> Int {
        if self.handle == 0 || fd < 0 {
            return -1;
        }
        __io_modify_raw(self.handle, fd, event.flags)
    }

    /// Poll for ready events.
    ///

    /// max: maximum number of events to return (clamped to
    /// `IO_ENGINE_MAX_POLL_EVENTS`).
    /// timeout_ns: timeout in nanoseconds (-1 = block forever, 0 = non-blocking).
    /// Returns: number of ready events, 0 on invalid input, or -1 on error.
    public fn poll(&self, max: Int, timeout_ns: Int) -> Int {
        if self.handle == 0 || max <= 0 || timeout_ns < -1 {
            return 0;
        }
        let m = if max > IO_ENGINE_MAX_POLL_EVENTS {
            IO_ENGINE_MAX_POLL_EVENTS
        } else {
            max
        };
        __io_poll_raw(self.handle, m, timeout_ns)
    }

    /// Destroy the engine, closing the underlying kqueue/epoll fd.
    /// Idempotent: safe to call on a zero handle.
    public fn destroy(&self) {
        if self.handle != 0 {
            __io_engine_destroy_raw(self.handle);
        }
    }

    /// Check if the engine is valid (non-null handle).
    public fn is_valid(&self) -> Bool {
        self.handle != 0
    }

    /// Non-consuming check: has `fd` fired for `event` since the
    /// last `poll`?  Used by `core/net/tcp.vr::AsyncIoReady.poll`
    /// to drive Future readiness without removing the entry from
    /// the session's ready queue (so subsequent re-polls see it
    /// until the caller explicitly consumes via `take_ready`).
    public fn is_ready(&self, fd: Int, event: IoEvent) -> Bool {
        if self.handle == 0 || fd < 0 {
            return false;
        }
        __io_is_ready_raw(self.handle, fd, event.flags) != 0
    }

    /// Consuming variant of `is_ready` — atomically checks AND
    /// removes the matching entry from the session's ready queue.
    /// Returns true if a matching entry was present (and consumed),
    /// false otherwise.
    public fn take_ready(&self, fd: Int, event: IoEvent) -> Bool {
        if self.handle == 0 || fd < 0 {
            return false;
        }
        __io_take_ready_raw(self.handle, fd, event.flags) != 0
    }
}

// =============================================================================
// Async Socket Operations
// =============================================================================

/// Socket configuration utilities.
public type Socket is ();

// Socket option + async I/O intrinsics — centralised in
// core/intrinsics/runtime/io.vr (#63).
mount core.intrinsics.runtime.io.{
    __socket_set_nonblocking_raw,
    __socket_set_blocking_raw,
    __socket_set_reuseaddr_raw,
    __socket_set_nodelay_raw,
    __socket_set_keepalive_raw,
    __socket_get_error_raw,
    __async_accept_raw,
    __async_read_raw,
    __async_write_raw,
};

implement Socket {
    /// Set a socket to non-blocking mode.
    public fn set_nonblocking(fd: Int) -> Int {
        __socket_set_nonblocking_raw(fd)
    }

    /// Set a socket to blocking mode.
    public fn set_blocking(fd: Int) -> Int {
        __socket_set_blocking_raw(fd)
    }

    /// Enable SO_REUSEADDR on a socket.
    public fn set_reuseaddr(fd: Int) -> Int {
        __socket_set_reuseaddr_raw(fd)
    }

    /// Enable TCP_NODELAY (disable Nagle's algorithm).
    public fn set_nodelay(fd: Int) -> Int {
        __socket_set_nodelay_raw(fd)
    }

    /// Enable SO_KEEPALIVE.
    public fn set_keepalive(fd: Int) -> Int {
        __socket_set_keepalive_raw(fd)
    }

    /// Get pending socket error (SO_ERROR).
    public fn get_error(fd: Int) -> Int {
        __socket_get_error_raw(fd)
    }
}

/// Async socket operations using an IoEngine.
public type AsyncSocket is {
    engine: IoEngine,
};

implement AsyncSocket {
    /// Create an async socket context with a shared IoEngine.
    public fn new(engine: IoEngine) -> AsyncSocket {
        AsyncSocket { engine: engine }
    }

    /// Async accept: waits for a connection on listen_fd.
    /// timeout_ns: -1 = block forever, 0 = non-blocking.
    /// Returns new fd on success, -1 on error or invalid input.
    public fn accept(&self, listen_fd: Int, timeout_ns: Int) -> Int {
        if !self.engine.is_valid() || listen_fd < 0 || timeout_ns < -1 {
            return -1;
        }
        __async_accept_raw(self.engine.handle, listen_fd, timeout_ns)
    }

    /// Async read: waits for data on fd, reads into buffer.
    /// Returns bytes read, or -1 on error or invalid input.
    public fn read(&self, fd: Int, buf: Int, len: Int, timeout_ns: Int) -> Int {
        if !self.engine.is_valid() || fd < 0 || buf == 0 || len < 0 || timeout_ns < -1 {
            return -1;
        }
        if len == 0 {
            return 0;
        }
        __async_read_raw(self.engine.handle, fd, buf, len, timeout_ns)
    }

    /// Async write: waits for writability on fd, writes from buffer.
    /// Returns bytes written, or -1 on error or invalid input.
    public fn write(&self, fd: Int, buf: Int, len: Int, timeout_ns: Int) -> Int {
        if !self.engine.is_valid() || fd < 0 || buf == 0 || len < 0 || timeout_ns < -1 {
            return -1;
        }
        if len == 0 {
            return 0;
        }
        __async_write_raw(self.engine.handle, fd, buf, len, timeout_ns)
    }
}
