// =============================================================================
// process.vr - Child process management
// =============================================================================
// Layer: 3 (I/O)
// Dependencies: core, io/protocols, sys/{darwin,linux}/syscall
// =============================================================================
//
// Provides high-level API for spawning child processes, capturing output,
// and waiting for completion. Critical for self-hosting compiler (invoking
// linker, assembler, and the compiler itself).
//
// =============================================================================

module core.io.process;
mount core.*;

// Windows-native process creation via kernel32.dll
@cfg(target_os = "windows")
mount sys.windows.kernel32.{
    Handle,
    SecurityAttributes,
    StartupInfoA,
    ProcessInformation,
    CreateProcessA,
    CreatePipe,
    SetHandleInformation,
    CloseHandle,
    ReadFile,
    WaitForSingleObject,
    GetExitCodeProcess,
    GetLastError,
    STARTF_USESTDHANDLES,
    CREATE_NO_WINDOW,
    HANDLE_FLAG_INHERIT,
    INFINITE,
    WAIT_FAILED,
};

// =============================================================================
// Stdio Configuration
// =============================================================================

/// How to handle a standard I/O stream for a child process.
type Stdio is
    /// Inherit parent's stream (default).
    | Inherit
    /// Capture the stream into a pipe.
    | Piped
    /// Discard output (redirect to /dev/null).
    | Null;

// =============================================================================
// ExitStatus
// =============================================================================

/// Exit status of a child process.
type ExitStatus is {
    /// Raw status value from waitpid.
    raw: Int,
};

implement ExitStatus {
    /// Returns true iff the process exited normally with code 0.
    /// A child terminated by a signal — even SIGTERM — is *not* a success;
    /// callers that treat such a child as having exited 0 will mis-classify
    /// SIGSEGV / SIGKILL as "succeeded", masking real crashes.
    fn success(&self) -> Bool {
        self.is_exited() && self.code() == 0
    }

    /// Returns true iff the process exited normally (POSIX WIFEXITED).
    /// On Windows there is no signal/exit distinction, so this is always true.
    fn is_exited(&self) -> Bool {
        @cfg(any(target_os = "linux", target_os = "macos"))
        { (self.raw & 0x7F) == 0 }

        @cfg(target_os = "windows")
        { true }
    }

    /// Returns true iff the process was terminated by a signal (POSIX WIFSIGNALED).
    /// Always false on Windows.
    fn is_signaled(&self) -> Bool {
        @cfg(any(target_os = "linux", target_os = "macos"))
        {
            let low = self.raw & 0x7F;
            low != 0 && low != 0x7F
        }

        @cfg(target_os = "windows")
        { false }
    }

    /// Returns the signal number that terminated the process (POSIX WTERMSIG),
    /// or 0 if the process was not signal-terminated. Always 0 on Windows.
    fn signal(&self) -> Int {
        @cfg(any(target_os = "linux", target_os = "macos"))
        {
            if self.is_signaled() { self.raw & 0x7F } else { 0 }
        }

        @cfg(target_os = "windows")
        { 0 }
    }

    /// Returns the WEXITSTATUS exit code. Only meaningful when
    /// `is_exited()` is true; for signal-terminated processes the
    /// caller should consult `signal()` instead.
    fn code(&self) -> Int {
        // Unix: raw is waitpid status — WEXITSTATUS = (status >> 8) & 0xFF
        // Windows: raw is the exit code directly
        @cfg(any(target_os = "linux", target_os = "macos"))
        { (self.raw >> 8) & 255 }

        @cfg(target_os = "windows")
        { self.raw & 0xFFFF }
    }
}

implement Display for ExitStatus {
    fn fmt(&self, f: &mut Formatter) -> Result<(), Text> {
        if self.is_signaled() {
            f.write_str(f"signal: {self.signal()}")
        } else if self.success() {
            f.write_str("exit status: 0")
        } else {
            f.write_str(f"exit status: {self.code()}")
        }
    }
}

// =============================================================================
// Output
// =============================================================================

/// Captured output from a child process.
type Output is {
    /// Exit status.
    status: ExitStatus,
    /// Captured stdout bytes.
    stdout_bytes: List<Byte>,
    /// Captured stderr bytes.
    stderr_bytes: List<Byte>,
};

implement Output {
    /// Returns stdout as a Text string.
    fn stdout(&self) -> Text {
        Text.from_utf8_lossy(&self.stdout_bytes)
    }

    /// Returns stderr as a Text string.
    fn stderr(&self) -> Text {
        Text.from_utf8_lossy(&self.stderr_bytes)
    }
}

// =============================================================================
// Command Builder
// =============================================================================

/// A process builder, providing fine-grained control over how a new process
/// should be spawned.
type Command is {
    /// Program to execute.
    program: Text,
    /// Arguments to pass to the program.
    args: List<Text>,
    /// Environment variable overrides (key, value).
    env_vars: List<(Text, Text)>,
    /// Working directory (None = inherit parent's).
    working_dir: Maybe<Text>,
    /// Stdin handling.
    stdin_cfg: Stdio,
    /// Stdout handling.
    stdout_cfg: Stdio,
    /// Stderr handling.
    stderr_cfg: Stdio,
};

implement Command {
    /// Creates a new Command for the given program.
    fn new(program: Text) -> Command {
        Command {
            program: program,
            args: [],
            env_vars: [],
            working_dir: None,
            stdin_cfg: Stdio.Inherit,
            stdout_cfg: Stdio.Inherit,
            stderr_cfg: Stdio.Inherit,
        }
    }

    /// Adds an argument.
    fn arg(&mut self, arg: Text) -> &mut Command {
        self.args.push(arg);
        self
    }

    /// Adds multiple arguments.
    fn args(&mut self, new_args: &[Text]) -> &mut Command {
        let mut i = 0;
        while i < new_args.len() {
            self.args.push(new_args[i]);
            i = i + 1;
        }
        self
    }

    /// Sets an environment variable.
    fn env(&mut self, key: Text, val: Text) -> &mut Command {
        self.env_vars.push((key, val));
        self
    }

    /// Sets the working directory.
    fn current_dir(&mut self, dir: Text) -> &mut Command {
        self.working_dir = Some(dir);
        self
    }

    /// Configures stdout handling.
    fn stdout(&mut self, cfg: Stdio) -> &mut Command {
        self.stdout_cfg = cfg;
        self
    }

    /// Configures stderr handling.
    fn stderr(&mut self, cfg: Stdio) -> &mut Command {
        self.stderr_cfg = cfg;
        self
    }

    /// Configures stdin handling.
    fn stdin(&mut self, cfg: Stdio) -> &mut Command {
        self.stdin_cfg = cfg;
        self
    }

    /// Executes the command, waits for it to finish, and collects output.
    /// Stdout and stderr are captured (overrides any previous stdio config).
    fn output(&mut self) -> Result<Output, Text> {
        self.stdout_cfg = Stdio.Piped;
        self.stderr_cfg = Stdio.Piped;
        self.spawn_and_wait_with_output()
    }

    /// Executes the command and returns just the exit status.
    fn status(&mut self) -> Result<ExitStatus, Text> {
        let child = self.spawn()?;
        child.wait()
    }

    /// Spawns the command as a child process.
    fn spawn(&self) -> Result<Child, Text> {
        spawn_child(self)
    }

    /// Internal: spawn and wait, capturing stdout/stderr.
    fn spawn_and_wait_with_output(&self) -> Result<Output, Text> {
        spawn_child_with_output(self)
    }
}

// =============================================================================
// Child Process
// =============================================================================

/// A handle to a running child process.
type Child is {
    /// Process ID.
    pid: Int,
    /// Pipe fd for reading child's stdout (if piped).
    stdout_fd: Maybe<Int>,
    /// Pipe fd for reading child's stderr (if piped).
    stderr_fd: Maybe<Int>,
    /// Pipe fd for writing to child's stdin (if piped).
    stdin_fd: Maybe<Int>,
};

implement Child {
    /// Waits for the child to finish and returns its exit status.
    fn wait(&self) -> Result<ExitStatus, Text> {
        wait_for_child(self.pid)
    }

    /// Waits and collects all output.
    fn wait_with_output(&self) -> Result<Output, Text> {
        // Read stdout and stderr before waiting
        let mut out_bytes: List<Byte> = [];
        let mut err_bytes: List<Byte> = [];

        match self.stdout_fd {
            Some(fd) => {
                out_bytes = read_all_from_fd(fd);
                close_fd(fd);
            }
            None => {}
        }

        match self.stderr_fd {
            Some(fd) => {
                err_bytes = read_all_from_fd(fd);
                close_fd(fd);
            }
            None => {}
        }

        let exit_status = wait_for_child(self.pid)?;
        Ok(Output {
            status: exit_status,
            stdout_bytes: out_bytes,
            stderr_bytes: err_bytes,
        })
    }
}

// =============================================================================
// Platform Implementation — Low-level C runtime bridge
// =============================================================================
// These __*_raw functions map directly to C runtime functions via LLVM Call
// intercept in instruction.rs. Their Verum bodies are fallbacks for the
// interpreter path. In AOT, the LLVM lowering replaces the Call with a
// direct call to the C runtime function.

/// Low-level exec: run program with args, wait, return exit code.
/// In AOT: calls verum_process_exec(program, args_list_ptr).
/// Returns exit code (0-255), or -1 on error.
fn __process_exec_raw(program: Text, args: List<Text>) -> Int {
    -1
}

/// Low-level wait: returns raw waitpid status, or -1 on error.
/// In AOT: calls verum_process_wait(pid).
fn __process_wait_raw(pid: Int) -> Int {
    -1
}

/// Low-level fd read: returns bytes read from fd until EOF.
/// In AOT: calls verum_fd_read_all(fd).
fn __fd_read_all_raw(fd: Int) -> List<Byte> {
    []
}

/// Low-level fd close.
/// In AOT: calls verum_fd_close(fd).
fn __fd_close_raw(fd: Int) {
}

/// Low-level spawn (no wait): fork+exec.
/// Returns pointer to [pid, stdout_fd, stderr_fd] (3 x Int), or 0 on error.
/// In AOT: calls verum_process_spawn_cmd in C runtime.
fn __process_spawn_raw(program: Text, args: List<Text>, capture_stdout: Int, capture_stderr: Int) -> Int {
    -1
}

/// Read an Int from a raw pointer at a given index (i64 array indexing).
/// In AOT: emits GEP + load. Used to extract fields from C-allocated structs.
fn __ptr_read_i64(ptr: Int, index: Int) -> Int {
    0
}

/// Free a raw pointer allocated by C runtime.
fn __ptr_free(ptr: Int) -> Int {
    0
}

// =============================================================================
// Unix Implementation (Linux / macOS) — C runtime bridge
// =============================================================================

@cfg(any(target_os = "linux", target_os = "macos"))
fn spawn_child(cmd: &Command) -> Result<Child, Text> {
    let stdout_val: Stdio = cmd.stdout_cfg;
    let stderr_val: Stdio = cmd.stderr_cfg;
    let cap_stdout = if stdout_val is Piped { 1 } else { 0 };
    let cap_stderr = if stderr_val is Piped { 1 } else { 0 };

    let result_ptr = __process_spawn_raw(cmd.program, cmd.args, cap_stdout, cap_stderr);

    if (result_ptr == 0) {
        return Err("failed to spawn child process");
    }

    let pid = __ptr_read_i64(result_ptr, 0);
    let stdout_fd_raw = __ptr_read_i64(result_ptr, 1);
    let stderr_fd_raw = __ptr_read_i64(result_ptr, 2);
    __ptr_free(result_ptr);

    let stdout_fd = if (stdout_fd_raw >= 0) { Some(stdout_fd_raw) } else { None };
    let stderr_fd = if (stderr_fd_raw >= 0) { Some(stderr_fd_raw) } else { None };

    Ok(Child {
        pid: pid,
        stdout_fd: stdout_fd,
        stderr_fd: stderr_fd,
        stdin_fd: None,
    })
}

@cfg(any(target_os = "linux", target_os = "macos"))
fn spawn_child_with_output(cmd: &Command) -> Result<Output, Text> {
    let result_ptr = __process_spawn_raw(cmd.program, cmd.args, 1, 1);

    if (result_ptr == 0) {
        return Err("failed to spawn child process");
    }

    let pid = __ptr_read_i64(result_ptr, 0);
    let stdout_fd = __ptr_read_i64(result_ptr, 1);
    let stderr_fd = __ptr_read_i64(result_ptr, 2);
    __ptr_free(result_ptr);

    let stdout_bytes = if (stdout_fd >= 0) { read_all_from_fd(stdout_fd) } else { [] };
    let stderr_bytes = if (stderr_fd >= 0) { read_all_from_fd(stderr_fd) } else { [] };

    if (stdout_fd >= 0) { close_fd(stdout_fd); }
    if (stderr_fd >= 0) { close_fd(stderr_fd); }

    let raw_status = __process_wait_raw(pid);
    if (raw_status < 0) {
        return Err("failed to wait for child process");
    }

    Ok(Output {
        status: ExitStatus { raw: raw_status },
        stdout_bytes: stdout_bytes,
        stderr_bytes: stderr_bytes,
    })
}

@cfg(any(target_os = "linux", target_os = "macos"))
fn wait_for_child(pid: Int) -> Result<ExitStatus, Text> {
    let raw_status = __process_wait_raw(pid);
    if (raw_status < 0) {
        return Err("failed to wait for child process");
    }
    Ok(ExitStatus { raw: raw_status })
}

@cfg(any(target_os = "linux", target_os = "macos"))
fn read_all_from_fd(fd: Int) -> List<Byte> {
    __fd_read_all_raw(fd)
}

@cfg(any(target_os = "linux", target_os = "macos"))
fn close_fd(fd: Int) {
    __fd_close_raw(fd);
}

// =============================================================================
// Windows Implementation — Native Win32 API
// =============================================================================
//
// Uses CreateProcessA + CreatePipe for process spawning with I/O redirection.
// No C runtime dependency — direct kernel32.dll calls.
//
// Architecture:
// - Build command line string from program + args (quoting as needed)
// - Create pipes for stdout/stderr capture (inheritable write ends)
// - CreateProcessA with STARTF_USESTDHANDLES
// - Read from pipe read-ends until EOF
// - WaitForSingleObject + GetExitCodeProcess for exit status
//
// Performance:
// - CreateProcessA: ~2ms (includes process/address space creation)
// - Pipe throughput: limited by 4KB default buffer, adequate for most use cases
// =============================================================================

@cfg(target_os = "windows")
fn spawn_child(cmd: &Command) -> Result<Child, Text> {
    let cmd_line = build_command_line(cmd);
    let cmd_bytes = cmd_line.as_null_terminated_bytes();

    let capture_stdout = cmd.stdout_cfg is Piped;
    let capture_stderr = cmd.stderr_cfg is Piped;

    // Inheritable security attributes for pipe ends passed to child
    let sa = SecurityAttributes {
        length: 24 as UInt32,  // sizeof(SECURITY_ATTRIBUTES) on x64
        security_descriptor: 0 as &unsafe Byte,
        inherit_handle: true,
    };

    // Create stdout pipe if needed
    let mut stdout_read = Handle.NULL;
    let mut stdout_write = Handle.NULL;
    if capture_stdout {
        if !CreatePipe(&mut stdout_read, &mut stdout_write, &sa, 0) {
            return Err(f"CreatePipe for stdout failed (error {GetLastError()})");
        }
        // Ensure the read end is NOT inherited by child
        SetHandleInformation(stdout_read, HANDLE_FLAG_INHERIT, 0);
    }

    // Create stderr pipe if needed
    let mut stderr_read = Handle.NULL;
    let mut stderr_write = Handle.NULL;
    if capture_stderr {
        if !CreatePipe(&mut stderr_read, &mut stderr_write, &sa, 0) {
            if capture_stdout { CloseHandle(stdout_read); CloseHandle(stdout_write); }
            return Err(f"CreatePipe for stderr failed (error {GetLastError()})");
        }
        SetHandleInformation(stderr_read, HANDLE_FLAG_INHERIT, 0);
    }

    // Configure startup info with redirected handles
    let mut si = StartupInfoA.new();
    if capture_stdout || capture_stderr {
        si.flags = STARTF_USESTDHANDLES;
        si.std_input = Handle.NULL;
        si.std_output = if capture_stdout { stdout_write } else { Handle.NULL };
        si.std_error = if capture_stderr { stderr_write } else { Handle.NULL };
    }

    let mut pi = ProcessInformation {
        process: Handle.NULL,
        thread: Handle.NULL,
        process_id: 0,
        thread_id: 0,
    };

    let success = CreateProcessA(
        0 as &unsafe Byte,                    // Use command line for program name
        cmd_bytes.as_ptr() as &unsafe Byte,   // Command line
        0 as &unsafe Byte,                    // Process security attributes
        0 as &unsafe Byte,                    // Thread security attributes
        true,                                  // Inherit handles (for pipes)
        CREATE_NO_WINDOW,                      // Don't create console window
        0 as &unsafe Byte,                    // Inherit environment
        match &cmd.working_dir {               // Working directory
            Some(dir) => dir.as_null_terminated_bytes().as_ptr() as &unsafe Byte,
            None => 0 as &unsafe Byte,
        },
        &si,
        &mut pi,
    );

    // Close the write ends of pipes (now owned by child process)
    if capture_stdout { CloseHandle(stdout_write); }
    if capture_stderr { CloseHandle(stderr_write); }

    if !success {
        if capture_stdout { CloseHandle(stdout_read); }
        if capture_stderr { CloseHandle(stderr_read); }
        return Err(f"CreateProcessA failed (error {GetLastError()})");
    }

    // Close the child's primary thread handle (we only need the process handle)
    CloseHandle(pi.thread);

    Ok(Child {
        pid: pi.process.as_raw() as Int,
        stdout_fd: if capture_stdout { Some(stdout_read.as_raw() as Int) } else { None },
        stderr_fd: if capture_stderr { Some(stderr_read.as_raw() as Int) } else { None },
        stdin_fd: None,
    })
}

@cfg(target_os = "windows")
fn spawn_child_with_output(cmd: &Command) -> Result<Output, Text> {
    let mut piped_cmd = Command {
        program: cmd.program,
        args: cmd.args.clone(),
        env_vars: cmd.env_vars.clone(),
        working_dir: cmd.working_dir.clone(),
        stdin_cfg: cmd.stdin_cfg,
        stdout_cfg: Stdio.Piped,
        stderr_cfg: Stdio.Piped,
    };

    let child = spawn_child(&piped_cmd)?;

    // Read output from pipes before waiting (avoids deadlock if child fills buffer)
    let stdout_bytes = match child.stdout_fd {
        Some(fd) => {
            let bytes = read_all_from_fd(fd);
            close_fd(fd);
            bytes
        }
        None => [],
    };

    let stderr_bytes = match child.stderr_fd {
        Some(fd) => {
            let bytes = read_all_from_fd(fd);
            close_fd(fd);
            bytes
        }
        None => [],
    };

    let exit_status = wait_for_child(child.pid)?;

    Ok(Output {
        status: exit_status,
        stdout_bytes: stdout_bytes,
        stderr_bytes: stderr_bytes,
    })
}

@cfg(target_os = "windows")
fn wait_for_child(process_handle_raw: Int) -> Result<ExitStatus, Text> {
    let handle = Handle.from_raw(process_handle_raw as UInt64);

    let wait_result = WaitForSingleObject(handle, INFINITE);
    if wait_result == WAIT_FAILED {
        CloseHandle(handle);
        return Err(f"WaitForSingleObject failed (error {GetLastError()})");
    }

    let mut exit_code: UInt32 = 0;
    if !GetExitCodeProcess(handle, &mut exit_code) {
        CloseHandle(handle);
        return Err(f"GetExitCodeProcess failed (error {GetLastError()})");
    }

    CloseHandle(handle);
    Ok(ExitStatus { raw: exit_code as Int })
}

@cfg(target_os = "windows")
fn read_all_from_fd(handle_raw: Int) -> List<Byte> {
    let handle = Handle.from_raw(handle_raw as UInt64);
    let mut result = List.new();
    let mut buf = List.with_capacity(4096);
    buf.resize(4096, 0);

    loop {
        let mut bytes_read: UInt32 = 0;
        let ok = ReadFile(
            handle,
            buf.as_mut_ptr() as &unsafe Byte,
            4096,
            &mut bytes_read,
            0 as &unsafe Byte,  // No overlapped I/O
        );

        if !ok || bytes_read == 0 {
            break;
        }

        result.extend_from_slice(&buf[..(bytes_read as Int)]);
    }

    result
}

@cfg(target_os = "windows")
fn close_fd(handle_raw: Int) {
    let handle = Handle.from_raw(handle_raw as UInt64);
    CloseHandle(handle);
}

/// Build a Windows command line string from program and arguments.
///
/// Follows the Windows command-line argument quoting convention:
/// - Arguments containing spaces, tabs, or double quotes are enclosed in double quotes
/// - Backslashes before double quotes are escaped
/// - The entire string is null-terminated for CreateProcessA
@cfg(target_os = "windows")
fn build_command_line(cmd: &Command) -> Text {
    let mut line = quote_arg(&cmd.program);

    for arg in &cmd.args {
        line.push(' ');
        line.push_str(&quote_arg(arg));
    }

    line
}

/// Quote a single argument for Windows command line if needed.
@cfg(target_os = "windows")
fn quote_arg(arg: &Text) -> Text {
    // If arg contains no special characters, return as-is
    let needs_quoting = arg.is_empty()
        || arg.contains(' ')
        || arg.contains('\t')
        || arg.contains('"');

    if !needs_quoting {
        return arg.clone();
    }

    let mut result = Text.new();
    result.push('"');

    let mut num_backslashes: Int = 0;

    for ch in arg.chars() {
        if ch == '\\' {
            num_backslashes += 1;
        } else if ch == '"' {
            // Double the backslashes before a quote, then add escaped quote
            for _ in 0..num_backslashes {
                result.push('\\');
            }
            result.push('\\');
            result.push('"');
            num_backslashes = 0;
        } else {
            num_backslashes = 0;
            result.push(ch);
        }
    }

    // Double trailing backslashes (they precede the closing quote)
    for _ in 0..num_backslashes {
        result.push('\\');
    }

    result.push('"');
    result
}

// =============================================================================
// Convenience Functions
// =============================================================================

/// Runs a command string and returns its output.
/// Example: `let out = run("ls", ["-la", "/tmp"])?;`
fn run(program: Text, args: List<Text>) -> Result<Output, Text> {
    let mut cmd = Command.new(program);
    cmd.args(&args);
    cmd.output()
}
