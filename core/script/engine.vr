// =============================================================================
// core/script/engine.vr - Embedded Scripting Engine (ergonomic API)
// =============================================================================
// Layer: Stdlib (4)
// Dependencies: core.intrinsics.runtime.scripting
//
// The user-facing API for embedding Verum as a scripting language inside a
// Verum host application — the capability a game engine gets from embedding
// Lua, built on Verum's own VBC interpreter.
//
//   let engine = Engine.new();
//   match engine.eval("fn main() -> Int { 7 * 6 }") {
//       ScriptResult.Ok(ScriptValue.Int(n)) => print(f"script returned {n}"),
//       ScriptResult.Err => print("script failed"),
//       _ => {},
//   };
//
// This is a thin, safe veneer over the `script_*` intrinsics: it owns the
// engine/outcome handles and frees them deterministically (the engine via
// Drop, each outcome at the end of `eval`).  No second VM, heap, or sandbox
// is introduced — `Engine` drives the same VBC interpreter the host runs on.
//
// Scalars (Unit/Bool/Int/Float), Text, List, and Map marshal fully and to
// arbitrary nesting depth, in BOTH directions (host<->script); host-function
// callbacks, sandboxing, a shared World, named-function calls, and a zero-copy
// linked Session are all wired.
//
// Spec: docs/detailed/05-syntax-grammar.md
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LApp,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.script.engine;

mount core.intrinsics.runtime.scripting.*;

// =============================================================================
// Values crossing the host <-> script boundary
// =============================================================================

/// A value returned by a script, marshaled into the host.
///
/// Scalars, `Text`, `List`, and `Map` marshal fully, and nested collections
/// recurse to arbitrary depth. `Unknown` stands in only for records /
/// references (and any future kind not yet mapped).
public type ScriptValue is
    | Nil
    | Bool(Bool)
    | Int(Int)
    | Float(Float)
    | Text(Text)
    | List(List<ScriptValue>)
    | Map(List<(ScriptValue, ScriptValue)>)
    | Unknown;

/// The result of evaluating a script. `Err` carries the failure message.
public type ScriptResult is
    | Ok(ScriptValue)
    | Err(Text);

// =============================================================================
// Engine
// =============================================================================

/// An isolated script-execution world.  Owns a host-side `ScriptEngine`
/// handle; freed automatically when the `Engine` goes out of scope.
// `affine`: an Engine uniquely owns a boxed native handle freed by its Drop, so
// it must be move-only — copying it would free the same handle twice.
public type affine Engine is {
    raw: RawScriptEngine,
};

implement Engine {
    /// Create an engine with default (permissive) limits.
    public fn new() -> Engine {
        Engine { raw: script_engine_new() }
    }

    /// Create a sandboxed engine with resource limits (each `0` = unlimited):
    /// `memory_limit` bytes, `instruction_limit` fuel, `time_limit_ms`
    /// wall-clock. A script that exceeds a limit fails with an error outcome.
    public fn sandboxed(
        memory_limit: USize,
        instruction_limit: UInt64,
        time_limit_ms: UInt64,
    ) -> Engine {
        Engine {
            raw: script_engine_new_sandboxed(memory_limit, instruction_limit, time_limit_ms),
        }
    }

    /// Set an `Int` global the next `eval` can read (via the script-side
    /// `script_global_int(name)`). The host's channel for passing data in.
    public fn set_int(&self, name: Text, value: Int) {
        script_engine_set_global_int(self.raw, name, value);
    }

    /// Set a `Text` global the next `eval` can read (via the script-side
    /// `script_global_text(name)`).
    public fn set_text(&self, name: Text, value: Text) {
        script_engine_set_global_text(self.raw, name, value);
    }

    /// Set a `Bool` global the next `eval` can read (via the script-side
    /// `script_global_bool(name)`).
    public fn set_bool(&self, name: Text, value: Bool) {
        script_engine_set_global_bool(self.raw, name, value);
    }

    /// Set a `Float` global the next `eval` can read (via the script-side
    /// `script_global_float(name)`).
    public fn set_float(&self, name: Text, value: Float) {
        script_engine_set_global_float(self.raw, name, value);
    }

    /// Register a host `fn(Int) -> Int` callback that scripts can call by name
    /// (via the script-side `script_host_call_int(name, arg)`). The callback
    /// runs on the host, so it sees the host's state.
    public fn register(&self, name: Text, f: fn(Int) -> Int) {
        script_engine_register(self.raw, name, f);
    }

    /// Compile and run `source` (entry `main`), returning its marshaled value
    /// or an error message.  The intermediate outcome handle is freed before
    /// return.
    public fn eval(&self, source: Text) -> ScriptResult {
        let outcome = script_engine_eval(self.raw, source);
        let result = if script_outcome_is_ok(outcome) {
            ScriptResult.Ok(marshal_outcome(outcome))
        } else {
            ScriptResult.Err(script_outcome_error(outcome))
        };
        script_outcome_free(outcome);
        result
    }

    /// Compile `source` and invoke a specific `fn_name` (instead of `main`),
    /// returning its marshaled value or an error. Pass arguments beforehand with
    /// the `set_*` methods (the entry reads them via `script_global_*`). Lets a
    /// host drive a script's individual functions, not only its entry point.
    public fn call(&self, source: Text, fn_name: Text) -> ScriptResult {
        let outcome = script_engine_call(self.raw, source, fn_name);
        let result = if script_outcome_is_ok(outcome) {
            ScriptResult.Ok(marshal_outcome(outcome))
        } else {
            ScriptResult.Err(script_outcome_error(outcome))
        };
        script_outcome_free(outcome);
        result
    }

    /// Compile `source` and invoke `fn_name` with positional `args` passed as
    /// its parameters (scalars). Returns its marshaled value or an error.
    public fn call_args<T>(&self, source: Text, fn_name: Text, args: List<T>) -> ScriptResult {
        let outcome = script_engine_call_args(self.raw, source, fn_name, args);
        let result = if script_outcome_is_ok(outcome) {
            ScriptResult.Ok(marshal_outcome(outcome))
        } else {
            ScriptResult.Err(script_outcome_error(outcome))
        };
        script_outcome_free(outcome);
        result
    }

    /// Merge two scripts into a persistent [`Session`] with a SHARED heap — the
    /// zero-copy interop tier. Functions invoked through `session.call` share
    /// data by reference across calls (what one stores, a later one reads),
    /// which copy-at-the-boundary engines can't do; CBGR keeps it safe.
    public fn link2(&self, source_a: Text, source_b: Text) -> Session {
        Session { raw: script_engine_link2(self.raw, source_a, source_b) }
    }

    /// Merge a whole list of scripts into one persistent [`Session`] with a
    /// shared heap — the zero-copy tier for a set of scripts (e.g. loading many
    /// plugin scripts into one shared world).
    public fn link(&self, sources: List<Text>) -> Session {
        Session { raw: script_engine_link(self.raw, sources) }
    }

    /// The text this engine's most recent `eval` / `call` wrote to stdout
    /// (empty before any run). Read it right after an `eval`/`call` to capture
    /// a script's printed output — the `ScriptResult` carries only the value.
    public fn stdout(&self) -> Text {
        script_engine_stdout(self.raw)
    }

    /// The real compile/link diagnostic of the most recent `link`/`link2`
    /// failure (empty otherwise). A failed link yields a Session whose `call`
    /// reports a generic error; read this for the actual reason.
    public fn last_error(&self) -> Text {
        script_engine_last_error(self.raw)
    }
}

// =============================================================================
// Session — zero-copy interop tier (persistent linked scripts)
// =============================================================================

/// A persistent session over two linked scripts sharing one heap. Obtain one
/// from [`Engine.link2`]; run functions on it with `call`. State (globals, heap)
/// written by an earlier `call` is visible to later ones — shared by reference.
// `affine` (move-only): uniquely owns a boxed native session freed by its Drop.
public type affine Session is {
    raw: RawScriptSession,
};

implement Session {
    /// Run `fn_name` on the session, returning its marshaled value or an error.
    /// Shares state with earlier calls on the same session.
    public fn call(&self, fn_name: Text) -> ScriptResult {
        let outcome = script_session_call(self.raw, fn_name);
        let result = if script_outcome_is_ok(outcome) {
            ScriptResult.Ok(marshal_outcome(outcome))
        } else {
            ScriptResult.Err(script_outcome_error(outcome))
        };
        script_outcome_free(outcome);
        result
    }
}

implement Drop for Session {
    fn drop(&mut self) {
        script_session_free(self.raw);
    }
}

implement Drop for Engine {
    fn drop(&mut self) {
        script_engine_free(self.raw);
    }
}

// =============================================================================
// World — zero-copy interop between scripts (P2)
// =============================================================================

/// A shared world for interop between scripts.  Scripts run in the same world
/// share data through its persistent shared table: a value one script writes
/// via `script_set_int` / `script_set_text` is read by another via
/// `script_global_int` / `script_global_text`.  The table persists across
/// evals, so scripts cooperate over shared state.
///
/// (The full zero-overhead tier links cooperating scripts into one module via
/// the runtime linker so large structures are shared truly by-reference, with
/// CBGR keeping the shared references safe — the differentiator copy-at-the-
/// boundary engines like Wasm/BEAM/V8 cannot offer. Scalars and Text share
/// correctly today through the table.)
// `affine` (move-only): uniquely owns a boxed native world freed by its Drop.
public type affine World is {
    raw: RawScriptWorld,
};

implement World {
    /// Create an empty shared world.
    public fn new() -> World {
        World { raw: script_world_new() }
    }

    /// Compile and run `source` (entry `main`) on the world's persistent
    /// interpreter.  The world heap + shared table carry over from prior evals.
    public fn eval(&self, source: Text) -> ScriptResult {
        let outcome = script_world_eval(self.raw, source);
        let result = if script_outcome_is_ok(outcome) {
            ScriptResult.Ok(marshal_outcome(outcome))
        } else {
            ScriptResult.Err(script_outcome_error(outcome))
        };
        script_outcome_free(outcome);
        result
    }
}

implement Drop for World {
    fn drop(&mut self) {
        script_world_free(self.raw);
    }
}

// =============================================================================
// Internal: outcome -> ScriptValue
// =============================================================================

/// Map a successful outcome's value to a `ScriptValue` using its kind tag.
fn marshal_outcome(outcome: RawScriptOutcome) -> ScriptValue {
    let kind = script_outcome_kind(outcome);
    if kind == 1 {
        ScriptValue.Bool(script_outcome_as_bool(outcome))
    } else if kind == 2 {
        ScriptValue.Int(script_outcome_as_int(outcome))
    } else if kind == 3 {
        ScriptValue.Float(script_outcome_as_float(outcome))
    } else if kind == 4 {
        ScriptValue.Text(script_outcome_as_text(outcome))
    } else if kind == 5 {
        ScriptValue.List(marshal_list(outcome))
    } else if kind == 6 {
        ScriptValue.Map(marshal_map(outcome))
    } else if kind == 0 {
        ScriptValue.Nil
    } else {
        ScriptValue.Unknown
    }
}

/// Build a `ScriptValue` for a map key/value from its kind tag plus the typed
/// accessors. Reused for both sides of an entry via a leading `is_key` flag.
fn marshal_map_side(outcome: RawScriptOutcome, i: Int, is_key: Bool) -> ScriptValue {
    let k = if is_key {
        script_outcome_map_key_kind(outcome, i)
    } else {
        script_outcome_map_value_kind(outcome, i)
    };
    if k == 1 {
        let b = if is_key { script_outcome_map_key_bool(outcome, i) } else { script_outcome_map_value_bool(outcome, i) };
        ScriptValue.Bool(b)
    } else if k == 2 {
        let n = if is_key { script_outcome_map_key_int(outcome, i) } else { script_outcome_map_value_int(outcome, i) };
        ScriptValue.Int(n)
    } else if k == 3 {
        let f = if is_key { script_outcome_map_key_float(outcome, i) } else { script_outcome_map_value_float(outcome, i) };
        ScriptValue.Float(f)
    } else if k == 4 {
        let t = if is_key { script_outcome_map_key_text(outcome, i) } else { script_outcome_map_value_text(outcome, i) };
        ScriptValue.Text(t)
    } else if (k == 5) || (k == 6) {
        // Nested List/Map: recurse on a sub-outcome handle.
        let sub = if is_key { script_outcome_map_key_sub(outcome, i) } else { script_outcome_map_value_sub(outcome, i) };
        let nested = marshal_outcome(sub);
        script_outcome_free(sub);
        nested
    } else if k == 0 {
        ScriptValue.Nil
    } else {
        ScriptValue.Unknown
    }
}

/// Rebuild a map's `(key, value)` pairs from a map outcome, entry by entry.
fn marshal_map(outcome: RawScriptOutcome) -> List<(ScriptValue, ScriptValue)> {
    let len = script_outcome_map_len(outcome);
    let mut entries: List<(ScriptValue, ScriptValue)> = List.new();
    let mut i = 0;
    while i < len {
        let key = marshal_map_side(outcome, i, true);
        let value = marshal_map_side(outcome, i, false);
        entries.push((key, value));
        i = i + 1;
    }
    entries
}

/// Rebuild a `List<ScriptValue>` from a list outcome, element by element. Each
/// element's own kind tag selects the typed accessor; a nested `List`/`Map`
/// element recurses through a sub-outcome handle (arbitrary depth).
fn marshal_list(outcome: RawScriptOutcome) -> List<ScriptValue> {
    let len = script_outcome_list_len(outcome);
    let mut items: List<ScriptValue> = List.new();
    let mut i = 0;
    while i < len {
        let k = script_outcome_list_elem_kind(outcome, i);
        let elem = if k == 1 {
            ScriptValue.Bool(script_outcome_list_elem_bool(outcome, i))
        } else if k == 2 {
            ScriptValue.Int(script_outcome_list_elem_int(outcome, i))
        } else if k == 3 {
            ScriptValue.Float(script_outcome_list_elem_float(outcome, i))
        } else if k == 4 {
            ScriptValue.Text(script_outcome_list_elem_text(outcome, i))
        } else if (k == 5) || (k == 6) {
            // Nested List/Map: recurse on a sub-outcome handle.
            let sub = script_outcome_list_elem_sub(outcome, i);
            let nested = marshal_outcome(sub);
            script_outcome_free(sub);
            nested
        } else if k == 0 {
            ScriptValue.Nil
        } else {
            ScriptValue.Unknown
        };
        items.push(elem);
        i = i + 1;
    }
    items
}
