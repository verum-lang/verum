// =============================================================================
// Meta Function Marker Protocol
// =============================================================================

/// Marker protocol for meta function return types
///
/// Types implementing this protocol can be returned from meta functions
/// and will be properly processed by the compiler.
///
/// Built-in implementations:
/// - `TokenStream` - generates code
/// - `()` - no output (side-effect only via CompileDiag)
/// - `Result<T, E>` where T: MetaOutput - fallible meta functions
public type MetaOutput is protocol {
    /// Emit this output to the compiler (compile-time only)
    meta fn emit(&self) using AstAccess;
};

// =============================================================================
// Error Types
// =============================================================================

/// Meta function error type
///
/// These errors can be returned from meta functions during compile-time execution.
/// The compiler maps its internal errors to these stdlib-visible error types.
@repr(UInt8)
public type MetaError is
    /// Asset not found
    | AssetNotFound { path: Text }
    /// Asset read error
    | AssetReadError { path: Text, reason: Text }
    /// Syntax error in AST manipulation
    | SyntaxError { message: Text, span: Span }
    /// Parse failed with multiple errors (from recovery parsing)
    | ParseFailed(List<ParseError>)
    /// Type error in reflection
    | TypeError { expected: Text, found: Text }
    /// Recursion limit exceeded
    | RecursionLimit { depth: Int, limit: Int }
    /// Iteration limit exceeded
    | IterationLimit { count: Int, limit: Int }
    /// Memory limit exceeded
    | MemoryLimit { used: Int, limit: Int }
    /// Timeout exceeded
    | Timeout { elapsed_ms: Int, limit_ms: Int }
    /// Invalid operation for context
    | InvalidOperation { operation: Text, reason: Text }
    /// Cache error
    | CacheError { key: Text, reason: Text }
    /// Method not found
    | MethodNotFound { type_name: Text, method_name: Text }
    /// Generic error with message
    | Other { message: Text };

implement MetaError {
    /// Get human-readable error message
    public fn message(&self) -> Text {
        match self {
            AssetNotFound { path } =>
                f"Asset not found: {path}",
            AssetReadError { path, reason } =>
                f"Failed to read asset '{path}': {reason}",
            SyntaxError { message, span } =>
                f"Syntax error at {span}: {message}",
            ParseFailed(errors) => {
                let count = errors.len();
                f"Parse failed with {count} error(s)"
            },
            TypeError { expected, found } =>
                f"Type error: expected {expected}, found {found}",
            RecursionLimit { depth, limit } =>
                f"Recursion limit exceeded: depth {depth} > limit {limit}",
            IterationLimit { count, limit } =>
                f"Iteration limit exceeded: {count} > {limit}",
            MemoryLimit { used, limit } =>
                f"Memory limit exceeded: {used} bytes > {limit} bytes",
            Timeout { elapsed_ms, limit_ms } =>
                f"Timeout: {elapsed_ms}ms > {limit_ms}ms limit",
            InvalidOperation { operation, reason } =>
                f"Invalid operation '{operation}': {reason}",
            CacheError { key, reason } =>
                f"Cache error for key '{key}': {reason}",
            MethodNotFound { type_name, method_name } =>
                f"Method '{method_name}' not found on type '{type_name}'",
            Other { message } =>
                message.clone(),
        }
    }
}

/// Result type for meta functions
public type MetaResult<T> is Result<T, MetaError>;

// =============================================================================
// Compile-Time Constants
// =============================================================================

/// Default recursion limit for meta functions
public const DEFAULT_RECURSION_LIMIT: Int = 256;

/// Default iteration limit for meta function loops
public const DEFAULT_ITERATION_LIMIT: Int = 1_000_000;

/// Default memory limit for meta functions (64 MB)
public const DEFAULT_MEMORY_LIMIT: Int = 64 * 1024 * 1024;

/// Default timeout for meta functions (30 seconds)
public const DEFAULT_TIMEOUT_MS: Int = 30_000;

// =============================================================================
// Version Information
// =============================================================================

/// Meta system version
public const VERSION: &Text = "0.1.0";

/// Meta system version tuple
public const VERSION_INFO: (Int, Int, Int) = (0, 1, 0);
