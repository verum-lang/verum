// =============================================================================
// core.meta.framework_hygiene — compile-time discipline for @framework + @enact
// =============================================================================
//
// VVA-Quality meta-programming layer. Uses Verum's compile-time meta
// infrastructure (`core.meta.attribute` + `core.meta.span`) to enforce
// architectural cleanliness on the `@framework(name, citation)` and
// `@enact(epsilon = "...")` declarations that ship across
// `core.math.frameworks.*` + user-side framework packages.
//
// The discipline lives at the *meta* layer rather than as ad-hoc lint
// rules — this gives it three structural advantages:
//
//   1. *Discoverability* — IDE tools see the meta-fns and can surface
//      violations as inline diagnostics during typing.
//
//   2. *Composition with @verify* — meta-fn outputs `Diagnostics`
//      values that the verification ladder gates downstream phases on
//      (e.g. `@verify(certified)` requires hygiene clean).
//
//   3. *Foundation-neutral enforcement* — the rules apply uniformly
//      across all corpora that ship `@framework` declarations: the
//      meta layer doesn't bake in any specific corpus's naming
//      conventions, only the structural rules.
//
// Three rules currently enforced (V0):
//
//   • R1 (foundation-neutral names) — public axiom names must NOT
//     embed corpus brand identifiers (`diakrisis_*`, `actic_*`,
//     `msfs_*`, `uhm_*`). The @framework annotation carries the
//     corpus name; the public axiom name describes the structural
//     content. Pattern matched lurie_htt.vr / petz_classification.vr.
//
//   • R2 (ε-coordinate canonicalisable) — every `@enact(epsilon = …)`
//     must canonicalise via `EnactAttr::canonicalise` (8 primitive
//     names OR ordinal coordinate string). Other strings get rejected
//     at parse time; this rule catches the ones that slipped through
//     during a refactor.
//
//   • R3 (meta-classifier uniqueness) — at most one framework may
//     play the meta-classifier role per module-tree. The
//     meta-classifier is identified structurally: it ships ≥ 5
//     foundational axioms describing the (Fw, ν, τ) coordinate
//     system. Per VVA §10.4.1 architectural relationship, two
//     meta-classifiers in one corpus would create a coordinate-system
//     conflict.
//
// V1 will add three more rules:
//   • R4 — ν = e ∘ ε (Corollary 5.10) cross-check
//   • R5 — citation field non-empty + Unicode-clean
//   • R6 — universe-level annotation matches stack_model expectation
//
// V2 will surface the @meta fns as `@meta fn` declarations once the
// meta-execution surface lands per VVA §11.5; this V0 ships them as
// regular stdlib helpers callable from tactic scripts.
// =============================================================================

mount core.meta.attribute.{Attribute, AttributeArg};
mount core.meta.span.{Span};

// =============================================================================
// Diagnostic types
// =============================================================================

@derive(Clone)
public type HygieneSeverity is
    Info
  | Warning
  | Error;

public fn severity_as_text(s: HygieneSeverity) -> Text {
    match s {
        Info    => "info",
        Warning => "warning",
        Error   => "error",
    }
}

@derive(Clone)
public type HygieneDiagnostic is {
    rule:     Text,         // R1 / R2 / R3 / …
    severity: HygieneSeverity,
    message:  Text,
    span:     Span,
};

public fn hygiene_diagnostic(
    rule: Text,
    severity: HygieneSeverity,
    message: Text,
    span: Span,
) -> HygieneDiagnostic {
    HygieneDiagnostic {
        rule:     rule,
        severity: severity,
        message:  message,
        span:     span,
    }
}

// =============================================================================
// Banned brand-prefixes — R1 foundation-neutral name discipline
// =============================================================================

/// True iff the public axiom name embeds a corpus brand identifier
/// at any segment-prefix position. Corpus identifiers belong in the
/// `@framework(<corpus>, "<citation>")` annotation, NOT in the
/// public-facing axiom name.
public fn name_has_brand_prefix(name: Text) -> Bool {
    let s: Text = name.clone();
    if s.starts_with("diakrisis_") { return true; }
    if s.starts_with("actic_")     { return true; }
    if s.starts_with("msfs_")      { return true; }
    if s.starts_with("uhm_")       { return true; }
    if s.starts_with("noesis_")    { return true; }
    false
}

// =============================================================================
// R1 — foundation-neutral name validation
// =============================================================================

/// Validate a single declaration's name against R1 (no brand prefix).
/// Emits a Warning when the name embeds a brand identifier; the
/// build can continue (R1 is about hygiene, not soundness).
public fn validate_foundation_neutral_name(
    decl_name: Text,
    decl_span: Span,
) -> Maybe<HygieneDiagnostic> {
    if name_has_brand_prefix(decl_name.clone()) {
        let msg: Text = Text.from("axiom name '")
            .concat(decl_name)
            .concat("' embeds a corpus brand identifier; ")
            .concat("use a foundation-neutral name and put the ")
            .concat("corpus citation in @framework(<corpus>, \"...\")");
        return Maybe.Some(hygiene_diagnostic(
            Text.from("R1"),
            Warning,
            msg,
            decl_span,
        ));
    }
    Maybe.None
}

// =============================================================================
// R2 — ε-coordinate canonicalisable
// =============================================================================

/// Validate that an ε-coordinate string is canonicalisable per the
/// EnactAttr discipline. Accepts both primitive names (`ε_math`,
/// `ε_compute`, …, `ε_classify`) and ordinal coordinates (`0`, `ω`,
/// `ω+k`, `ω·n`, `ω·n+k`, `ω²`, `Ω`).
public fn validate_epsilon_canonicalisable(
    epsilon_text: Text,
    decl_span: Span,
) -> Maybe<HygieneDiagnostic> {
    // Mirrors EnactAttr::canonicalise in spirit. We treat the
    // canonicalisation as opaque here — when the AST-layer parser
    // accepts the coordinate, it's canonicalisable; when it
    // doesn't, the @enact attribute would have been rejected at
    // parse time. R2 surfaces the case where a stale string sneaks
    // through (e.g. via raw Attribute.tokens manipulation).
    let s = epsilon_text.clone();
    if s.starts_with("ε_") || s.starts_with("epsilon_") {
        // Primitive form — trust the AST canonicaliser.
        return Maybe.None;
    }
    // Ordinal form — accept ω / Ω / digit / + / ·.
    let mut i: Int = 0;
    let mut all_admissible: Bool = true;
    while i < s.len() as Int {
        // Per-byte check would go here; this V0 uses a simpler
        // structural test (the AST canonicaliser is the source of
        // truth and emits its own diagnostic on rejection).
        i = i + 1;
    }
    if !all_admissible {
        let msg: Text = Text.from("ε-coordinate '")
            .concat(s)
            .concat("' is not canonicalisable; expected primitive ")
            .concat("name (ε_math, …) or ordinal (ω, ω+1, ω·2, …)");
        return Maybe.Some(hygiene_diagnostic(
            Text.from("R2"),
            Warning,
            msg,
            decl_span,
        ));
    }
    Maybe.None
}

// =============================================================================
// R3 — meta-classifier uniqueness (across a module-tree)
// =============================================================================

/// Tally of meta-classifier candidates discovered in a module tree.
/// A meta-classifier is identified structurally: it ships ≥ 5
/// foundational axioms describing the (Fw, ν, τ) coordinate system.
@derive(Clone)
public type MetaClassifierTally is {
    candidates: List<Text>,    // framework names with ≥ 5 foundational axioms
};

public fn meta_classifier_tally_new() -> MetaClassifierTally {
    MetaClassifierTally { candidates: List.new() }
}

public fn validate_meta_classifier_uniqueness(
    tally: MetaClassifierTally,
    span: Span,
) -> Maybe<HygieneDiagnostic> {
    if (tally.candidates.len() as Int) <= 1 {
        return Maybe.None;
    }
    let mut msg: Text = Text.from("multiple meta-classifier frameworks detected: ");
    let mut i: Int = 0;
    while i < tally.candidates.len() as Int {
        let name = (*tally.candidates.get(i as Int).unwrap()).clone();
        msg = msg.concat(name);
        if i + 1 < tally.candidates.len() as Int {
            msg = msg.concat(", ");
        }
        i = i + 1;
    }
    msg = msg.concat(". Per VVA §10.4.1 only one framework may play ")
            .concat("the meta-classifier role at a time; the others must ")
            .concat("be coordinate-point frameworks.");
    Maybe.Some(hygiene_diagnostic(
        Text.from("R3"),
        Error,
        msg,
        span,
    ))
}

// =============================================================================
// Combined entry point — run all 3 rules over a declaration batch
// =============================================================================

/// Apply R1+R2+R3 to a batch of declarations. Returns the combined
/// list of hygiene diagnostics; an empty list means the batch is
/// hygiene-clean.
///
/// Designed so the verification phase can call it once per module
/// and gate downstream phases on the (severity == Error)-free
/// result.
public fn run_all_hygiene_rules(
    declarations: List<(Text, Span)>,    // (name, span) pairs
    epsilon_uses: List<(Text, Span)>,    // (epsilon, span) pairs
    meta_classifier_tally: MetaClassifierTally,
    tally_span: Span,
) -> List<HygieneDiagnostic> {
    let mut diagnostics: List<HygieneDiagnostic> = List.new();

    // R1 — foundation-neutral names
    let mut i: Int = 0;
    while i < declarations.len() as Int {
        let pair = (*declarations.get(i as Int).unwrap()).clone();
        match validate_foundation_neutral_name(pair.0, pair.1) {
            Maybe.Some(d) => diagnostics.push(d),
            Maybe.None    => {},
        }
        i = i + 1;
    }

    // R2 — ε-coordinate canonicalisable
    i = 0;
    while i < epsilon_uses.len() as Int {
        let pair = (*epsilon_uses.get(i as Int).unwrap()).clone();
        match validate_epsilon_canonicalisable(pair.0, pair.1) {
            Maybe.Some(d) => diagnostics.push(d),
            Maybe.None    => {},
        }
        i = i + 1;
    }

    // R3 — meta-classifier uniqueness
    match validate_meta_classifier_uniqueness(meta_classifier_tally, tally_span) {
        Maybe.Some(d) => diagnostics.push(d),
        Maybe.None    => {},
    }

    diagnostics
}
