// =============================================================================
// executor.vr - Production-grade async executor with native V-LLSI integration
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core, collections, sync, async/future, async/waker, async/task
// Spec: docs/architecture/new-arch-spec.md Section 7 (Async AsyncRuntime)
// =============================================================================
//

// This module provides a production-quality async executor using native V-LLSI
// infrastructure. Key features:
//

// - Context propagation via native TLS context system (sys.common)
// - Completion-based I/O via IOEngine (io_uring/kqueue/IOCP)
// - Native monotonic time from sys platform layer
// - Lock-free task queue with work-stealing support
//

// As of V-LLSI migration, this module no longer depends on verum_runtime FFI.
// All async operations use the native sys layer.
//

// # Performance Targets
//

// | Operation | Target | V-LLSI Improvement |
// |-----------|--------|-------------------|
// | Task spawn | <200ns | ~150ns (no FFI) |
// | Context lookup | <30ns | ~2ns (array vs hashmap) |
// | Env fork | <70ns | ~50ns (memcpy) |
// | Wake | <50ns | ~30ns (eventfd) |
//

// =============================================================================

module core.async.executor;
mount core.*;
mount collections.*;
mount sync.*;
mount core.intrinsics.atomic.{atomic_fence, MemoryOrder};
mount .poll.*;
mount .waker.*;
mount .future.*;
mount .task.*;
mount .diagnostics.{TaskInfo, TaskLifecycleState};
mount core.intrinsics.atomic.{compiler_fence};
mount core.intrinsics.platform.{spin_hint};
// Phase 1B (#325): worker-pool thread spawning. Pulls in
// `Thread.spawn` + `ThreadBuilder` + `ThreadJoinHandle` so
// `start_worker_pool` can fan out the configured worker count.
// `ThreadError::SpawnFailed` is the runtime-observable signal
// that triggers the graceful single-threaded fallback (Hazard 4
// — Tier 0 interpreter mode + any platform / resource failure).
mount core.runtime.thread.{Thread, ThreadBuilder, ThreadJoinHandle, ThreadError};

// =============================================================================
// Native System Layer Imports (V-LLSI)
// =============================================================================

// Cross-platform context system
mount sys.common.{
    ctx_get, ctx_set, ctx_clear, ctx_has,
    ctx_push_frame, ctx_pop_frame,
    MAX_CONTEXT_SLOTS, SysContextError,
};

// Platform-specific time functions
@cfg(target_os = "linux")
mount sys.linux.time.{monotonic_nanos, Instant as SysInstant, Duration as SysDuration};

@cfg(target_os = "macos")
mount sys.darwin.time.{monotonic_nanos, Instant as SysInstant, Duration as SysDuration};

@cfg(target_os = "windows")
mount sys.windows.time.{monotonic_nanos, Instant as SysInstant, Duration as SysDuration};

// Platform-specific I/O engine
mount sys.io_engine.{
    IOEngine, CompletionOp, CompletionResult, Duration as IoDuration,
    create_io_engine, DEFAULT_SQ_ENTRIES, WAKE_TOKEN,
    IoError, POLLIN, POLLOUT,
};

// =============================================================================
// Context Slot Assignments
// =============================================================================

/// Context slot for the current async runtime.
const SLOT_RUNTIME: UInt8 = 0;

/// Context slot for the current task.
const SLOT_CURRENT_TASK: UInt8 = 1;

/// Context slot for the I/O engine.
const SLOT_IO_ENGINE: UInt8 = 2;

/// Context slot for user-defined database context.
const SLOT_DATABASE: UInt8 = 10;

/// Context slot for user-defined logger context.
const SLOT_LOGGER: UInt8 = 11;

// =============================================================================
// AsyncRuntime Configuration
// =============================================================================

/// Maximum number of tasks to poll per executor tick.
/// Prevents starvation when many tasks are ready simultaneously.
const DEFAULT_POLL_BUDGET: Int = 256;

/// Configuration for the async runtime.
public type AsyncRuntimeConfig is {
    /// Maximum number of tasks that can be spawned
    max_tasks: Int,
    /// Enable work-stealing scheduler (multi-threaded)
    enable_work_stealing: Bool,
    /// Stack size for spawned tasks in bytes
    task_stack_size: Int,
    /// Number of OS worker threads in the work-stealing scheduler.
    /// 0 = auto-detect via `num_cpus::get()` (the documented
    /// default). >0 = manifest-pinned override from
    /// `[runtime].async_worker_threads` in Verum.toml. Currently
    /// the executor is single-threaded cooperative — this field
    /// becomes load-bearing when the multi-threaded scheduler
    /// lands (#258 follow-up). The bridge to read the manifest
    /// value already exists (#261); only the consumer is
    /// forward-looking.
    async_worker_threads: Int,
    /// Enable I/O driver for async file/network operations
    enable_io: Bool,
    /// Enable timer driver for sleep/timeout operations
    enable_time: Bool,
    /// Number of I/O submission queue entries
    io_sq_entries: UInt32,
    /// Maximum tasks to poll per executor tick (cooperative budget)
    poll_budget: Int,
};

// Manifest→runtime bridge (#261). Each getter loads from a
// const-initialised LLVM global emitted by
// `platform_ir.rs::emit_runtime_globals` whose initial value flows
// from `LanguageFeatures.runtime` in Verum.toml at codegen time.
// Returning 0 means "use stdlib auto-detect" (num_cpus, platform
// stack size); >0 overrides the historical default.
//

// The functions are emitted with internal linkage; LTO folds the
// loads to constants at every call site after global-DCE — zero
// runtime overhead vs hardcoded defaults.
extern {
    /// Manifest-driven `[runtime].async_worker_threads`. 0 ≡
    /// auto-detect via `num_cpus::get()`; >0 overrides.
    fn verum_get_runtime_async_worker_threads() -> Int;
    /// Manifest-driven `[runtime].task_stack_size` (bytes). 0 ≡
    /// platform default (~8 MiB on Unix, 1 MiB on Windows); >0
    /// overrides per-spawned-task stack size.
    fn verum_get_runtime_task_stack_size() -> Int;
}

implement AsyncRuntimeConfig {
    /// Create default configuration optimized for general use.
    ///

    /// Honours the manifest-driven runtime bridge: when
    /// `[runtime].task_stack_size` in Verum.toml is non-zero the
    /// override flows through `verum_get_runtime_task_stack_size`
    /// → this constructor → every spawned task. Default 0 keeps
    /// the historical 1 MiB stack. Closes the manifest-side gap
    /// in #259.
    public fn default() -> AsyncRuntimeConfig {
        let manifest_stack = verum_get_runtime_task_stack_size();
        let stack = if manifest_stack > 0 { manifest_stack } else { 1024 * 1024 };
        // Read manifest worker-threads override. 0 stays in the
        // config field as "auto-detect"; the future multi-threaded
        // scheduler resolves 0 via `num_cpus::get()` at startup.
        let workers = verum_get_runtime_async_worker_threads();
        AsyncRuntimeConfig {
            max_tasks: 10000,
            enable_work_stealing: true,
            task_stack_size: stack,
            async_worker_threads: workers,
            enable_io: true,
            enable_time: true,
            io_sq_entries: DEFAULT_SQ_ENTRIES,
            poll_budget: DEFAULT_POLL_BUDGET,
        }
    }

    /// Create configuration for CPU-bound workloads.
    ///

    /// Honours the manifest-driven runtime bridge for both
    /// `task_stack_size` and `async_worker_threads` — explicit
    /// overrides take precedence over the cpu-bound preset
    /// (512 KiB stack), so a CPU-bound deployment that needs a
    /// larger stack for deep recursion can still pin it via
    /// Verum.toml without losing the rest of the cpu-bound
    /// tuning.
    public fn cpu_bound() -> AsyncRuntimeConfig {
        let manifest_stack = verum_get_runtime_task_stack_size();
        let stack = if manifest_stack > 0 { manifest_stack } else { 512 * 1024 };
        let workers = verum_get_runtime_async_worker_threads();
        AsyncRuntimeConfig {
            max_tasks: 1000,
            enable_work_stealing: true,
            task_stack_size: stack,
            async_worker_threads: workers,
            enable_io: false,
            enable_time: false,
            io_sq_entries: 64,  // Minimal I/O
            poll_budget: DEFAULT_POLL_BUDGET,
        }
    }

    /// Create configuration for I/O-bound workloads.
    ///

    /// Same manifest-bridge consultation as `cpu_bound` /
    /// `default` — explicit `[runtime].task_stack_size` /
    /// `async_worker_threads` overrides take precedence over
    /// the io-bound preset (256 KiB stack).
    public fn io_bound() -> AsyncRuntimeConfig {
        let manifest_stack = verum_get_runtime_task_stack_size();
        let stack = if manifest_stack > 0 { manifest_stack } else { 256 * 1024 };
        let workers = verum_get_runtime_async_worker_threads();
        AsyncRuntimeConfig {
            max_tasks: 100000,
            enable_work_stealing: true,
            task_stack_size: stack,
            async_worker_threads: workers,
            enable_io: true,
            enable_time: true,
            io_sq_entries: 1024,  // More I/O capacity
            poll_budget: 512,  // More budget for many I/O tasks
        }
    }

    /// Set maximum tasks.
    public fn max_tasks(mut self, n: Int) -> AsyncRuntimeConfig {
        self.max_tasks = n;
        self
    }

    /// Set task stack size.
    public fn task_stack_size(mut self, size: Int) -> AsyncRuntimeConfig {
        self.task_stack_size = size;
        self
    }

    /// Enable || disable work stealing.
    public fn work_stealing(mut self, enabled: Bool) -> AsyncRuntimeConfig {
        self.enable_work_stealing = enabled;
        self
    }

    /// Set the per-tick poll budget.
    public fn poll_budget(mut self, budget: Int) -> AsyncRuntimeConfig {
        self.poll_budget = budget;
        self
    }
}

implement Default for AsyncRuntimeConfig {
    fn default() -> AsyncRuntimeConfig {
        AsyncRuntimeConfig.default()
    }
}

// =============================================================================
// Task State
// =============================================================================

/// Internal task state wrapper for executor.
/// Stores both the future and its result once completed.
type TaskState<F: Future> is {
    future: F,
    task_id: Int,
    completed: Bool,
    /// Result storage - populated when future completes
    result: Maybe<F.Output>,
};

implement<F: Future> TaskState<F> {
    fn new(future: F, task_id: Int) -> TaskState<F> {
        TaskState {
            future: future,
            task_id: task_id,
            completed: false,
            result: None,
        }
    }

    /// Take the result out of the task state.
    /// Panics if res is not available.
    fn take_result(&mut self) -> F.Output {
        match self.result.take() {
            Some(r) => r,
            None => panic("TaskState.take_result called before completion"),
        }
    }
}

// =============================================================================
// WorkerPool — Phase 1 of #271 (multi-threaded async scheduler)
// =============================================================================
//

// Foundation data structure for the multi-threaded async scheduler.
// Phase 1A (THIS commit): type definition + AsyncRuntime field +
//  `worker_pool_size()` accessor. No threads
//  are actually spawned yet; `num_workers`
//  remains 0 even when the manifest configures
//  a non-zero `async_worker_threads`.
// Phase 1B (followup): `start_worker_pool()` actually spawns N
//  workers via `core.runtime.thread.Thread.spawn`,
//  workers loop on `process_ready_tasks` +
//  park via Condvar.
// Phase 2: Per-worker local deques + work-stealing
//  (see #278).
//

// Architecture: docs/architecture/multi-threaded-async-scheduler.md
//

// Zero-overhead default contract: when `async_worker_threads = 0`
// (the manifest default) `worker_pool_size()` returns 0 and no
// concurrent state is touched. Programs see bit-identical
// behaviour to today's single-threaded loop.

// =============================================================================
// Phase 4 (#280) — Chase-Lev lock-free work-stealing deque
// =============================================================================
//
// Single-producer / multi-consumer deque after Chase & Lev (2005)
// refined for the C11 memory model by Lê, Pop, Cohen & Nardelli
// (2013). Replaces the Phase 2 `Mutex<Deque<...>>` backend with a
// lock-free implementation: owner-side push/pop are pure atomic
// operations (no Mutex acquire), stealer-side uses a single CAS
// per attempt.
//
// The contract on the WorkerSlot surface is unchanged from Phase 2
// (`push_local`, `pop_local`, `try_steal`) — Phase 2→Phase 4 is a
// transparent backend swap from the caller's perspective.
//
// Reference: D. Chase, Y. Lev. "Dynamic Circular Work-Stealing
// Deque" SPAA'05.  N. M. Lê et al. "Correct and Efficient
// Work-Stealing for Weak Memory Models" PPoPP'13.
//
// Same algorithm Tokio's tokio-runtime, Rayon, .NET TPL,
// Go scheduler ship in production.

/// Phase 4 (#280): Chase-Lev local-deque capacity. Power-of-2
/// (`CAPACITY & MASK == 0`) so `idx & MASK == idx % CAPACITY`
/// — single-instruction modulo. 256 covers >99% of real
/// async-task bursts; overflow returns false from push_local
/// and the caller (spawn) falls through to the global injector.
const CHASE_LEV_CAPACITY: Int = 256;
const CHASE_LEV_MASK: Int = 255;

/// Phase 4 (#280): Chase-Lev work-stealing deque. Lock-free
/// single-producer / multi-consumer ring buffer.
///
/// **Operations**:
///   * `push_local(task) -> Bool` — owner only. Pure atomic
///     write; no CAS. Returns false on overflow.
///   * `pop_local() -> Maybe<task>` — owner only. Single CAS
///     only when the deque has exactly one element (the
///     boundary race with stealers).
///   * `try_steal() -> Maybe<task>` — any thread. Always one
///     CAS; returns None on empty OR race-lost.
///
/// **Memory ordering** (load-bearing fences from Lê et al §3.1):
///   * `push_local`: Release fence between slot-store and
///     bottom-update — stealers see a fully-published task
///     before the bottom advance becomes visible.
///   * `pop_local`: SeqCst fence between bottom-decrement and
///     top-load — without this, the owner can read a stale
///     top value after a stealer already advanced it, and
///     pop a task the stealer had already taken.
///   * `try_steal`: SeqCst fence between top-load and
///     bottom-load — mirrors pop_local's ordering so the
///     stealer observes any concurrent owner-side decrement.
///
/// **Slot storage**: each slot is an `AtomicInt` holding the
/// raw pointer of a `Heap<TaskEntry>` (`Heap::into_raw(...)` as
/// Int). Per-slot atomicity prevents torn reads under the C11
/// model when stealer-load races with owner-store.
public type ChaseLevDeque is {
    /// Owner-side bottom index. Owner reads/writes Relaxed;
    /// the SeqCst fence in `pop_local` orders the
    /// bottom-decrement relative to the top-load.
    bottom: AtomicInt,
    /// Stealer-side top index. Stealers load Acquire / CAS
    /// SeqCst-on-success / Relaxed-on-failure.
    top: AtomicInt,
    /// Per-slot atomic storage. Each entry holds a raw
    /// `Heap<TaskEntry>` pointer cast to Int.  AtomicInt
    /// because the stealer's slot-load races with the owner's
    /// slot-store; non-atomic access would tear under the C11
    /// memory model.
    slots: Heap<List<AtomicInt>>,
};

implement ChaseLevDeque {
    /// Construct a fresh empty deque with `CHASE_LEV_CAPACITY`
    /// pre-allocated slots.
    public fn new() -> ChaseLevDeque {
        let mut s: List<AtomicInt> = List.with_capacity(CHASE_LEV_CAPACITY);
        let mut i = 0;
        while i < CHASE_LEV_CAPACITY {
            s.push(AtomicInt.new(0));
            i = i + 1;
        }
        ChaseLevDeque {
            bottom: AtomicInt.new(0),
            top: AtomicInt.new(0),
            slots: Heap.new(s),
        }
    }

    /// Owner-only push. Returns `Ok(())` on success and
    /// `Err(task)` on capacity overflow — the caller
    /// (`AsyncRuntime.spawn`) re-routes the returned task to the
    /// global injector path so no task is lost.
    ///
    /// Returning the task on failure keeps the move-discipline
    /// sound: a Bool return would force the caller to drop
    /// `task` at the failure site, leaking the inner
    /// `future_ptr`'s heap-allocated TaskState (`Heap<TaskState>`
    /// has no Drop hook for the type-erased state).  The Result
    /// shape is the same pattern Tokio's `LocalQueue::push_back`
    /// uses for the identical failure mode.
    public fn push_local(
        &self,
        task: Heap<TaskEntry>,
    ) -> Result<(), Heap<TaskEntry>> {
        let b = self.bottom.load(MemoryOrdering.Relaxed);
        let t = self.top.load(MemoryOrdering.Acquire);
        // Reserve one extra slot so the empty/full disambiguation
        // (b == t means empty by convention) stays unambiguous.
        if b - t >= CHASE_LEV_CAPACITY - 1 {
            return Err(task);
        }
        let raw = Heap.into_raw(task) as Int;
        self.slots.index(b & CHASE_LEV_MASK).store(raw, MemoryOrdering.Relaxed);
        atomic_fence(MemoryOrder.Release);
        self.bottom.store(b + 1, MemoryOrdering.Relaxed);
        Ok(())
    }

    /// Owner-only pop (LIFO). Pops the most-recently pushed
    /// task. The single-element boundary races with stealers
    /// via CAS on `top`.
    public fn pop_local(&self) -> Maybe<Heap<TaskEntry>> {
        // Tentatively claim the bottom slot.
        let b = self.bottom.load(MemoryOrdering.Relaxed) - 1;
        self.bottom.store(b, MemoryOrdering.Relaxed);
        atomic_fence(MemoryOrder.SeqCst);
        let t = self.top.load(MemoryOrdering.Relaxed);

        if t > b {
            // Empty — restore the original bottom.
            self.bottom.store(b + 1, MemoryOrdering.Relaxed);
            return Maybe.None;
        }

        let raw_int = self.slots
            .index(b & CHASE_LEV_MASK)
            .load(MemoryOrdering.Relaxed);

        if t < b {
            // Multi-element — owner wins unconditionally.
            let raw_ptr = raw_int as &unsafe Byte;
            return Maybe.Some(unsafe { Heap.from_raw(raw_ptr as &mut TaskEntry) });
        }

        // t == b: last element — race with stealers via CAS.
        match self.top.compare_exchange(
            t, t + 1,
            MemoryOrdering.SeqCst,
            MemoryOrdering.Relaxed,
        ) {
            Ok(_) => {
                // Owner won.
                self.bottom.store(b + 1, MemoryOrdering.Relaxed);
                let raw_ptr = raw_int as &unsafe Byte;
                Maybe.Some(unsafe { Heap.from_raw(raw_ptr as &mut TaskEntry) })
            }
            Err(_) => {
                // Stealer won — empty deque, restore bottom.
                self.bottom.store(b + 1, MemoryOrdering.Relaxed);
                Maybe.None
            }
        }
    }

    /// Stealer-side pop (FIFO). Non-blocking — returns None
    /// on empty OR race-lost. Concurrent stealers race via the
    /// CAS; one wins per stolen task.
    public fn try_steal(&self) -> Maybe<Heap<TaskEntry>> {
        let t = self.top.load(MemoryOrdering.Acquire);
        atomic_fence(MemoryOrder.SeqCst);
        let b = self.bottom.load(MemoryOrdering.Acquire);
        if t >= b {
            return Maybe.None; // empty
        }
        let raw_int = self.slots
            .index(t & CHASE_LEV_MASK)
            .load(MemoryOrdering.Relaxed);
        match self.top.compare_exchange(
            t, t + 1,
            MemoryOrdering.SeqCst,
            MemoryOrdering.Relaxed,
        ) {
            Ok(_) => {
                let raw_ptr = raw_int as &unsafe Byte;
                Maybe.Some(unsafe { Heap.from_raw(raw_ptr as &mut TaskEntry) })
            }
            Err(_) => Maybe.None, // race lost
        }
    }

    /// Diagnostic — approximate count of in-flight tasks.
    /// May read stale values from concurrent operations; never
    /// used as a correctness gate, only for observability.
    public fn approx_len(&self) -> Int {
        let b = self.bottom.load(MemoryOrdering.Relaxed);
        let t = self.top.load(MemoryOrdering.Relaxed);
        let diff = b - t;
        if diff < 0 { 0 } else { diff }
    }
}

/// Phase 1B (#325) — holds the configured worker count, lifecycle
/// flag, the spawned join handles, and the park_mu / park_cv pair
/// workers wait on when their queues empty.
/// Phase 2 (#278): per-worker scheduling slot. Owns a local
/// deque that the slot's worker pushes to (LIFO, cache-hot for
/// recursive spawn) and pops from (LIFO). Foreign workers
/// (work-stealers) pop from the FRONT (FIFO) so they pick up
/// older tasks that the owner is least likely to re-touch —
/// minimises cache-line ping-pong vs. stealing LIFO-end where
/// the owner is currently working.
///
/// **Concurrency model — v3 (Phase 4 #280, Chase-Lev lock-free)**:
///   * Owner: `local_deque.push_local(task)` /
///     `local_deque.pop_local()` — pure atomic ops, no Mutex.
///   * Stealer: `local_deque.try_steal()` — single CAS, no
///     Mutex contention. Multiple thieves race via the CAS.
///
/// **API stability**: same surface as Phase 2's Mutex-backed
/// implementation; the v2→v3 backend swap is invisible to
/// `worker_main` / `AsyncRuntime.spawn` / `try_steal_for`.
///
/// **Phase 4 (#280) cache-line padding**: `@repr(align = 64)`
/// aligns each WorkerSlot to a 64-byte cache line boundary —
/// the typical L1d line size on x86_64 / aarch64 targets.
/// Without this, two adjacent WorkerSlots in `WorkerPool.slots`
/// could share a cache line; the owner of slot[0] writing
/// `bottom` and the owner of slot[1] writing its own `bottom`
/// would constantly invalidate each other's cache line —
/// "false sharing" — costing ~30 ns per write on modern CPUs.
/// Aligning to 64 bytes places each slot on its own cache line,
/// eliminating the false-sharing tax. Same trick Tokio's
/// `worker::Core` uses (`#[repr(align(128))]` on AMD Zen which
/// has 128-byte effective lines for some operations; 64 is the
/// safe industry default).
@repr(align = 64)
public type WorkerSlot is {
    /// Worker's id (index into `WorkerPool.slots`). Stable for
    /// the lifetime of the pool — assigned by `start_worker_pool`
    /// and observed via the `CURRENT_WORKER_ID` thread-local.
    worker_id: Int,
    /// LIFO local deque (Phase 4 lock-free Chase-Lev backend).
    /// Owner pushes/pops via `push_local` / `pop_local` — pure
    /// atomic ops. Foreign workers steal via `try_steal` —
    /// single CAS. `Heap` because the deque holds an inner
    /// `Heap<List<AtomicInt>>` and the WorkerSlot must be
    /// moveable into / out of the `WorkerPool.slots` list.
    local_deque: Heap<ChaseLevDeque>,
    /// Last-victim hint for the steal-rotation strategy. Workers
    /// keep this hint to retry the same victim that previously
    /// fed them (locality), and rotate only on steal failure.
    /// `AtomicInt` because reads are non-atomic-relevant (best-
    /// effort hint, not a correctness gate).
    steal_hint: AtomicInt,
};

implement WorkerSlot {
    /// Construct an empty slot for the given worker id.
    public fn empty(id: Int) -> WorkerSlot {
        WorkerSlot {
            worker_id: id,
            local_deque: Heap.new(ChaseLevDeque.new()),
            steal_hint: AtomicInt.new(0),
        }
    }

    /// Owner-side push (LIFO, cache-hot). Pure atomic op via
    /// the Chase-Lev backend — no Mutex acquire.  Forwards the
    /// `Result<(), Heap<TaskEntry>>` so the caller
    /// (`AsyncRuntime.spawn`) re-routes the task to the global
    /// injector on capacity overflow without leaking the inner
    /// future state.
    public fn push_local(
        &self,
        task: Heap<TaskEntry>,
    ) -> Result<(), Heap<TaskEntry>> {
        self.local_deque.push_local(task)
    }

    /// Owner-side pop (LIFO, cache-hot). Returns None when the
    /// local deque is empty; caller falls through to the global
    /// injector or steal path.
    public fn pop_local(&self) -> Maybe<Heap<TaskEntry>> {
        self.local_deque.pop_local()
    }

    /// Stealer-side pop (FIFO). Non-blocking — returns None on
    /// empty OR race-lost (concurrent stealer won the CAS).
    /// FIFO end is preferred to minimise cache-line ping-pong
    /// with the owner's LIFO-end activity.
    public fn try_steal(&self) -> Maybe<Heap<TaskEntry>> {
        self.local_deque.try_steal()
    }

    /// Diagnostic — approximate local-deque length. May read
    /// stale values from concurrent operations.
    public fn local_len(&self) -> Int {
        self.local_deque.approx_len()
    }
}

/// Phase 2 (#278): thread-local cell holding the calling
/// worker's slot id. `0` is reserved for "outside any worker"
/// (main thread / signal handler / FFI callback) so positive
/// ids 1..=num_workers map to slots[id-1]. Set by `worker_main`
/// before entering the poll loop.
@thread_local
static mut CURRENT_WORKER_ID: Int = 0;

/// Read the calling thread's worker id, or `Maybe.None` if not
/// running inside a worker. Used by `spawn` to dispatch the
/// affinity decision: inside a worker → push to local deque,
/// outside → push to global injector.
public fn current_worker_id() -> Maybe<Int> {
    let id = unsafe { CURRENT_WORKER_ID };
    if id == 0 {
        Maybe.None
    } else {
        Maybe.Some(id - 1) // map 1-indexed cell to 0-indexed slot.
    }
}

public type WorkerPool is {
    /// Number of workers configured for this pool (resolved from
    /// manifest `async_worker_threads`, or `num_cpus()-1` when the
    /// manifest sets 0 with explicit auto-detect intent).
    num_workers: Int,
    /// True once `start_worker_pool` has actually spawned the
    /// `num_workers` worker threads and they're polling the
    /// `task_queue` / `ready_queue`. False during Phase 1A
    /// foundation runs and during the brief window between
    /// `WorkerPool.empty(...)` construction and the spawn loop
    /// finishing in `start_worker_pool`.
    is_running: AtomicBool,
    /// Shutdown signal — set by `AsyncRuntime.shutdown()` to
    /// terminate workers. Workers re-check this flag at the top
    /// of every poll iteration and after every park-wake.
    shutdown_flag: AtomicBool,
    /// Diagnostic counter — number of workers currently parked
    /// on `park_cv`. Incremented immediately before each
    /// `park_cv.wait`, decremented immediately after.
    parked_count: AtomicInt,
    /// Phase 1B (#325): join handles for the spawned worker
    /// threads. Empty when start_worker_pool fell back to
    /// single-threaded mode (interpreter mode / spawn failure).
    /// `shutdown` extracts the entire WorkerPool via
    /// `Maybe::take` and joins handles AFTER releasing the
    /// `worker_pool` Mutex — Hazard 6 mitigation, prevents
    /// Drop-time deadlock when a worker tries to access
    /// `worker_pool` while shutdown holds the lock.
    handles: List<ThreadJoinHandle<()>>,
    /// Phase 1B (#325): mutex paired with `park_cv` for the
    /// classic monitor pattern. Workers acquire `park_mu`,
    /// re-check the queue emptiness predicate UNDER the lock
    /// (Hazard 2 — lost-wakeup race mitigation), then call
    /// `park_cv.wait(guard)` which atomically releases the lock
    /// and blocks. Producers (currently a periodic timeout
    /// rather than spawn-side notify; spawn-side notify is
    /// follow-up work) wake parked workers via `park_cv`.
    /// `Heap` because Mutex has no `Copy` and the WorkerPool
    /// must be moveable into / out of `Maybe<WorkerPool>`.
    park_mu: Heap<Mutex<()>>,
    /// Phase 1B (#325): condition variable workers wait on. See
    /// `park_mu` for the protocol.
    park_cv: Heap<Condvar>,
    /// Phase 2 (#278): per-worker scheduling slots, indexed by
    /// 0-based worker id. Allocated to length `num_workers` at
    /// `WorkerPool.empty(...)` time so `slots[id]` is always valid
    /// for any spawned worker. Each slot owns a local deque +
    /// steal-rotation hint; see [`WorkerSlot`].
    slots: List<WorkerSlot>,
};

implement WorkerPool {
    /// Construct a fresh pool with the given configured worker
    /// count. The pool is empty (no threads spawned, no handles)
    /// — `AsyncRuntime.start_worker_pool` populates `handles`
    /// after spawning.
    public fn empty(num: Int) -> WorkerPool {
        // Phase 2 (#278): allocate per-worker slots up-front so
        // `slots[id]` is always valid for any spawned worker.
        // Even when `num` is 0 (configured but disabled at runtime
        // — start_worker_pool will return 0), the empty list is
        // harmless: no worker is spawned, no slot is accessed.
        let mut slots: List<WorkerSlot> = List.with_capacity(num);
        let mut i = 0;
        while i < num {
            slots.push(WorkerSlot.empty(i));
            i = i + 1;
        }

        WorkerPool {
            num_workers: num,
            is_running: AtomicBool.new(false),
            shutdown_flag: AtomicBool.new(false),
            parked_count: AtomicInt.new(0),
            handles: List.new(),
            park_mu: Heap.new(Mutex.new(())),
            park_cv: Heap.new(Condvar.new()),
            slots: slots,
        }
    }

    /// Read the configured worker count.
    public fn size(&self) -> Int {
        self.num_workers
    }

    /// Read the shutdown flag (workers' poll-loop exit gate).
    public fn shutdown_requested(&self) -> Bool {
        self.shutdown_flag.load(MemoryOrdering.Acquire)
    }

    /// Signal workers to terminate. Idempotent. Pair with
    /// `notify_all()` to wake parked workers so they observe
    /// the flag and exit.
    public fn request_shutdown(&self) {
        self.shutdown_flag.store(true, MemoryOrdering.Release);
    }

    /// Wake one parked worker. Called by producers after pushing
    /// work onto `ready_queue` / `task_queue` so a parked worker
    /// can re-check the predicate and pick up the new task.
    public fn notify_one(&self) {
        self.park_cv.notify_one();
    }

    /// Wake all parked workers. Called by `shutdown` after
    /// setting `shutdown_flag` so every worker observes the
    /// flag promptly and exits.
    public fn notify_all(&self) {
        self.park_cv.notify_all();
    }

    /// Diagnostic — current parked-worker count. Useful for
    /// observability tests that want to assert the pool went
    /// idle after a workload.
    public fn parked(&self) -> Int {
        self.parked_count.load(MemoryOrdering.Relaxed)
    }

    /// Phase 2 (#278): borrow a specific worker's slot for
    /// owner-side push/pop. Returns `Maybe.None` when the worker
    /// id is out of range (defensive — production callers always
    /// pass `current_worker_id()` which is bounded by
    /// `num_workers`).
    public fn slot(&self, worker_id: Int) -> Maybe<&WorkerSlot> {
        if worker_id < 0 || worker_id >= self.slots.len() {
            return Maybe.None;
        }
        Maybe.Some(self.slots.index(worker_id))
    }

    /// Phase 2 (#278): pick a steal victim. Round-robins through
    /// peer workers starting from the caller's `steal_hint`. The
    /// caller's own slot is skipped. Returns the first victim
    /// whose `try_steal()` succeeded; otherwise None.
    ///
    /// **Strategy**: deterministic round-robin keyed by
    /// `steal_hint` is cheaper than a true random victim and
    /// preserves locality (a worker that previously stole from
    /// peer X is likely to steal from X again). On steal failure,
    /// `steal_hint` advances to (X+1) so the next attempt
    /// rotates.
    pub fn try_steal_for(&self, thief_id: Int) -> Maybe<Heap<TaskEntry>> {
        let n = self.slots.len();
        if n <= 1 {
            return Maybe.None; // nobody to steal from.
        }

        let thief_slot = match self.slot(thief_id) {
            Maybe.Some(s) => s,
            Maybe.None => return Maybe.None,
        };

        let start = thief_slot.steal_hint.load(MemoryOrdering.Relaxed);
        let mut tried = 0;
        while tried < n - 1 {
            let candidate = ((start + tried) % n);
            tried = tried + 1;
            if candidate == thief_id {
                continue;
            }
            let victim = match self.slot(candidate) {
                Maybe.Some(s) => s,
                Maybe.None => continue,
            };
            match victim.try_steal() {
                Maybe.Some(task) => {
                    // Successful steal — pin the hint to this
                    // victim so the next steal attempt retries
                    // it first (locality).
                    thief_slot.steal_hint.store(candidate, MemoryOrdering.Relaxed);
                    return Maybe.Some(task);
                }
                Maybe.None => {},
            };
        }

        // Every peer's steal attempt failed — advance hint by 1
        // so the next call starts from a different victim.
        thief_slot.steal_hint.store(
            (start + 1) % n,
            MemoryOrdering.Relaxed,
        );
        Maybe.None
    }
}

/// Phase 1B (#325): action a worker takes after returning from
/// `AsyncRuntime.try_park`. `Stop` exits the poll loop
/// (shutdown observed); `Continue` re-iterates (work arrived or
/// the park timed out).
type ParkAction is | Stop | Continue;

/// Phase 1B (#325): default park timeout when no producer-side
/// notify integration is in place. Workers wake every
/// `WORKER_PARK_TIMEOUT_MS` to re-check the queues and shutdown
/// flag, providing a safety net against any lost-wakeup edge
/// case AND giving graceful shutdown an upper bound on
/// worker-exit latency. 50 ms is a balance between idle-wake
/// overhead (~20 wakes/sec/worker) and shutdown responsiveness.
const WORKER_PARK_TIMEOUT_MS: Int = 50;

// =============================================================================
// AsyncRuntime
// =============================================================================

/// Native async runtime using V-LLSI infrastructure.
///

/// This runtime provides:
/// - Context propagation via native TLS slots (~2ns access)
/// - Completion-based I/O via IOEngine (io_uring/kqueue/IOCP)
/// - Lock-free task scheduling
/// - Native timer support
///

/// # Example
/// ```verum
/// let rt = AsyncRuntime.new();
/// rt.block_on(async {
///  let res = some_async_operation().await;
///  print(f"Result: {result}");
/// });
/// ```
public type AsyncRuntime is {
    config: AsyncRuntimeConfig,
    /// Number of active tasks
    task_count: AtomicInt,
    /// Is runtime running
    running: AtomicBool,
    /// Shutdown flag
    shutdown: AtomicBool,
    /// Task queue (pending tasks — awaiting wakeup or initial poll)
    task_queue: Mutex<List<Heap<TaskEntry>>>,
    /// Ready queue (woken tasks — ready to be polled)
    ready_queue: Mutex<List<Heap<TaskEntry>>>,
    /// Timer queue (pending timer-driven wakeups, sorted by deadline ascending).
    ///

    /// Replaces the busy-spin `cx.waker().wake_by_ref()` pattern that
    /// timer-bound futures (Sleep, SleepUntil, ExecutorTimeout,
    /// RateLimitedStream) historically used. When a future
    /// registers a timer here, the event loop:
    ///  1. Computes the IOEngine wait timeout as
    ///  `min(default_io_timeout, time_until_next_timer)`.
    ///  2. After `wait_for_events` returns, drains all entries
    ///  whose `deadline_ns <= now_ns` and wakes their wakers.
    ///

    /// Pre-fix every timer-bound poll burned ~1000 polls/sec on the
    /// brief_sleep loop; with this queue the loop parks for the
    /// exact remaining duration and wakes once.
    timer_queue: Mutex<List<TimerEntry>>,
    /// Next task ID
    next_task_id: AtomicInt,
    /// Pending I/O completion results buffer
    io_results: [CompletionResult; 64],
    /// Number of valid I/O results
    io_result_count: Int,
    /// Raw pointer to owned IOEngine (platform-specific type)
    io_engine_ptr: Int,
    /// Total number of executor ticks (event loop iterations)
    tick_count: AtomicInt,
    /// Total number of task polls performed
    total_polls: AtomicInt,
    /// Total number of tasks that completed
    total_completions: AtomicInt,
    /// Multi-threaded worker pool foundation (#271 Phase 1A).
    /// `Maybe.None` when `async_worker_threads = 0` (the default —
    /// zero-overhead single-threaded behaviour). `Maybe.Some(...)`
    /// when the manifest configures a non-zero count; the pool is
    /// constructed but no threads are spawned yet (Phase 1B will
    /// add `start_worker_pool` that actually spawns the workers).
    /// Held behind `Mutex` because `start_worker_pool` and
    /// `shutdown` need exclusive access during transition.
    worker_pool: Mutex<Maybe<WorkerPool>>,
};

/// A pending timer registration.
///

/// `deadline_ns` is the absolute monotonic instant (nanoseconds
/// since boot) at which `waker` should be invoked. Entries live in
/// `AsyncRuntime.timer_queue` sorted by deadline ascending.
public type TimerEntry is {
    /// Absolute deadline in nanoseconds (monotonic clock).
    deadline_ns: UInt64,
    /// Waker to invoke when the deadline passes.
    waker: Waker,
};

/// Internal task entry for executor scheduling.
///
/// **Phase 3 (#279) SAFETY contract for `future_ptr`**:
/// `future_ptr: &unsafe Byte` is a type-erased pointer to a
/// heap-allocated `TaskState<F>`. The pointer is moved between
/// threads when `AsyncRuntime.spawn` enqueues to a worker's
/// local deque OR when work-stealing transfers the task
/// from one worker to another. This is sound IFF the underlying
/// future is `Send`:
///   * `AsyncRuntime.spawn<F: Future + Send>` enforces the bound
///     at the typed entry point (Phase 3 — pre-fix only `F.Output:
///     Send` was required, allowing UB via `!Send` captures).
///   * `LocalExecutor.spawn_local<F>` does NOT add a `Send` bound
///     — its TaskEntries never leave the executor's owning thread,
///     so the pointer is single-threaded by construction.
/// Both paths preserve the invariant that any `TaskEntry` whose
/// `future_ptr` may cross threads carries a `Send` future.
type TaskEntry is {
    id: Int,
    /// Boxed future (type-erased). See struct-level SAFETY contract.
    future_ptr: &unsafe Byte,
    /// Poll function pointer
    poll_fn: fn(&unsafe Byte, &mut Context) -> Poll<()>,
    /// Drop function pointer
    drop_fn: fn(&unsafe Byte),
    /// Waker for this task
    waker: Maybe<Waker>,
    /// Is task completed
    completed: Bool,
};

implement AsyncRuntime {
    /// Create new runtime with default configuration.
    public fn new() -> AsyncRuntime {
        AsyncRuntime.with_config(AsyncRuntimeConfig.default())
    }

    /// Create runtime with custom configuration.
    public fn with_config(config: AsyncRuntimeConfig) -> AsyncRuntime {
        AsyncRuntime {
            config: config,
            task_count: AtomicInt.new(0),
            running: AtomicBool.new(false),
            shutdown: AtomicBool.new(false),
            task_queue: Mutex.new(List.new()),
            ready_queue: Mutex.new(List.new()),
            timer_queue: Mutex.new(List.new()),
            next_task_id: AtomicInt.new(1),
            io_results: [@zero<CompletionResult>(); 64],
            io_result_count: 0,
            io_engine_ptr: 0,
            tick_count: AtomicInt.new(0),
            total_polls: AtomicInt.new(0),
            total_completions: AtomicInt.new(0),
            // Phase 1A foundation (#271): worker pool is `Maybe.None`
            // until `start_worker_pool` is called. Default
            // `async_worker_threads = 0` keeps it None forever —
            // zero-overhead single-threaded path is bit-identical
            // to pre-#271 behaviour.
            worker_pool: Mutex.new(Maybe.None),
        }
    }

    /// Read the current worker-pool size — 0 when no pool is
    /// configured (the default) or when start_worker_pool has not
    /// yet been called for this `block_on` cycle, else the
    /// configured worker count.
    public fn worker_pool_size(&self) -> Int {
        match *self.worker_pool.lock() {
            Maybe.Some(ref pool) => pool.size(),
            Maybe.None => 0,
        }
    }

    /// Phase 1B (#325): spawn worker threads and start the pool.
    ///
    /// **Contract**:
    ///  * Idempotent — second call with an active pool returns
    ///  the existing worker count without re-spawning.
    ///  * Returns the actual number of workers spawned, which
    ///  may be 0 if the manifest sets `async_worker_threads`
    ///  to 0, or if `Thread.spawn` returned `Err` for the very
    ///  first worker (interpreter mode / OS resource pressure).
    ///  * **Graceful single-threaded fallback**: when any
    ///  spawn fails mid-loop, every already-spawned handle is
    ///  joined cleanly (shutdown_flag + notify_all + join) and
    ///  the function returns 0 with no `worker_pool` populated.
    ///  The runtime continues running on the existing
    ///  cooperative single-threaded loop in `block_on`.
    ///
    /// **Hazard 4 (Tier 0 / interpreter mode)**: this graceful-
    /// fallback path is what makes Phase 1B safe in interpreter
    /// mode — `Thread.spawn` may return `Err::SpawnFailed`
    /// (libffi pthread limitations under interpretation) and the
    /// runtime degrades silently to single-threaded behaviour.
    public fn start_worker_pool(&self) -> Int {
        let configured = self.config.async_worker_threads;
        if configured <= 0 {
            return 0;
        }

        // Idempotency check — if a pool is already running, no-op.
        {
            let guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
            if let Maybe.Some(ref existing) = *guard {
                if existing.is_running.load(MemoryOrdering.Acquire) {
                    return existing.num_workers;
                }
            }
        }

        let mut pool = WorkerPool.empty(configured);
        // SAFETY: `runtime_addr` is the runtime's `&self` pointer.
        // Workers cast back to `&AsyncRuntime` in `worker_main`.
        // The pointer remains valid for the entire worker
        // lifetime because `shutdown` (called by `Drop`) joins
        // every handle BEFORE the runtime can be dropped — see
        // Hazard 5 SAFETY block in worker_main.
        let runtime_addr: &unsafe Byte = self as &unsafe Byte;

        let mut spawned = 0;
        let mut spawn_failed = false;
        let mut i = 0;
        while i < configured {
            // Capture per-iteration values for the spawn closure —
            // each worker thread receives its OWN `worker_id` (Phase
            // 2 #278: used to set CURRENT_WORKER_ID + index into
            // `pool.slots`) plus the shared runtime pointer.
            let worker_id = i;
            let result = ThreadBuilder.new()
                .name(f"verum-worker-{worker_id}")
                .stack_size(self.config.task_stack_size)
                .spawn(fn() {
                    worker_main(runtime_addr, worker_id);
                });
            match result {
                Ok(handle) => {
                    pool.handles.push(handle);
                    spawned = spawned + 1;
                }
                Err(_) => {
                    spawn_failed = true;
                    break;
                }
            };
            i = i + 1;
        }

        if spawn_failed {
            // Hazard 4 graceful fallback: drain partial spawns
            // cleanly. Set shutdown_flag + notify so any
            // already-spawned worker exits, then join.
            pool.shutdown_flag.store(true, MemoryOrdering.Release);
            pool.notify_all();
            for h in pool.handles.into_iter() {
                let _ = h.join();
            }
            // Don't store the pool — runtime stays single-threaded.
            return 0;
        }

        pool.is_running.store(true, MemoryOrdering.Release);
        {
            let mut guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
            *guard = Maybe.Some(pool);
        }
        spawned
    }

    /// Phase 1B (#325): park the calling worker until either a
    /// queue becomes non-empty (re-checked after wake), shutdown
    /// is signalled, or `WORKER_PARK_TIMEOUT_MS` elapses.
    ///
    /// **Hazard 1 (lock ordering)**: this method acquires
    /// `worker_pool` briefly to read `park_cv` / `park_mu`
    /// pointers, then RELEASES the worker_pool lock BEFORE
    /// touching park_mu. Workers must NEVER hold worker_pool
    /// while waiting on park_cv (that would deadlock with
    /// `shutdown` which holds worker_pool while calling
    /// notify_all).
    ///
    /// **Hazard 2 (lost-wakeup race)**: the predicate (queues
    /// empty + not shut down) is re-checked UNDER park_mu before
    /// `park_cv.wait`. Combined with the timeout-based fallback
    /// (50 ms re-check), no producer-side notify is required for
    /// correctness in Phase 1B-1 — the production-grade
    /// `notify_one`-after-`spawn` integration is Phase 1B-2.
    fn try_park(&self) -> ParkAction {
        // Snapshot the cv / mu raw pointers under a brief
        // worker_pool lock — Hazard 1 lock ordering.
        let mut park_cv_ptr: &unsafe Byte = 0 as &unsafe Byte;
        let mut park_mu_ptr: &unsafe Byte = 0 as &unsafe Byte;
        let mut have_pool = false;
        {
            let guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
            match *guard {
                Maybe.Some(ref pool) => {
                    park_cv_ptr = (&*pool.park_cv) as &unsafe Byte;
                    park_mu_ptr = (&*pool.park_mu) as &unsafe Byte;
                    pool.parked_count.fetch_add(1, MemoryOrdering.Relaxed);
                    have_pool = true;
                }
                Maybe.None => {},
            }
        }
        if !have_pool {
            // Pool was extracted by shutdown — exit promptly.
            return ParkAction.Stop;
        }

        // SAFETY: park_cv / park_mu live inside the WorkerPool
        // owned by `self.worker_pool`. The pool is NOT dropped
        // until `shutdown` joins all workers; therefore the
        // pointers remain valid for the entire lifetime of the
        // calling worker. See Hazard 6 mitigation in `shutdown`.
        let park_cv = unsafe { &*(park_cv_ptr as &Condvar) };
        let park_mu = unsafe { &*(park_mu_ptr as &Mutex<()>) };

        let mu_guard = park_mu.lock().unwrap_or_else(|p| p.into_inner());

        // Hazard 2: re-check the predicate UNDER park_mu before
        // waiting. If work arrived between the worker's last
        // poll and the lock-acquire here, observe it now and
        // skip the wait.
        let queues_have_work = self.queues_nonempty();
        if queues_have_work {
            self.decrement_parked_count();
            return ParkAction.Continue;
        }
        if self.shutdown.load(MemoryOrdering.Acquire) {
            self.decrement_parked_count();
            return ParkAction.Stop;
        }

        // Park with timeout — bounded shutdown latency.
        let timeout = SysDuration.from_millis(WORKER_PARK_TIMEOUT_MS);
        let _woken_guard = park_cv
            .wait_timeout(mu_guard, timeout)
            .map(|(g, _)| g)
            .unwrap_or_else(|p| p.into_inner());

        self.decrement_parked_count();
        if self.shutdown.load(MemoryOrdering.Acquire) {
            ParkAction.Stop
        } else {
            ParkAction.Continue
        }
    }

    /// Cheap predicate — true iff either queue has at least one
    /// task. Acquires both locks briefly; never held across any
    /// other lock.
    fn queues_nonempty(&self) -> Bool {
        let r_empty = {
            let r = self.ready_queue.lock().unwrap_or_else(|p| p.into_inner());
            r.is_empty()
        };
        if !r_empty {
            return true;
        }
        let p_empty = {
            let p = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
            p.is_empty()
        };
        !p_empty
    }

    /// Decrement parked_count under a brief worker_pool lock.
    /// Idempotent — silently no-ops if the pool was extracted
    /// by shutdown between the increment and this call.
    fn decrement_parked_count(&self) {
        let guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
        if let Maybe.Some(ref pool) = *guard {
            pool.parked_count.fetch_sub(1, MemoryOrdering.Relaxed);
        }
    }

    // =========================================================================
    // Phase 2 (#278) — work-stealing helpers
    // =========================================================================

    /// Phase 2 (#278): pop a task from the calling worker's
    /// local deque (LIFO, cache-hot for recursive spawn).
    /// Returns Maybe.None when the local deque is empty OR the
    /// worker_pool has been extracted by shutdown.
    ///
    /// **Lock discipline**: holds `worker_pool` briefly to access
    /// `pool.slots[worker_id].local_deque`; releases before the
    /// caller polls. Matches Hazard 1 ordering — workers never
    /// hold worker_pool across `poll_one_task`.
    fn pop_local_task(&self, worker_id: Int) -> Maybe<Heap<TaskEntry>> {
        let guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
        match *guard {
            Maybe.Some(ref pool) => match pool.slot(worker_id) {
                Maybe.Some(slot) => slot.pop_local(),
                Maybe.None => Maybe.None,
            },
            Maybe.None => Maybe.None,
        }
    }

    /// Phase 2 (#278): try to steal a task from a peer worker's
    /// deque (FIFO, owner's least-recent task — minimises
    /// cache-line ping-pong). Returns Maybe.None when no peer
    /// has stealable work OR the worker_pool has been extracted.
    fn try_steal(&self, thief_id: Int) -> Maybe<Heap<TaskEntry>> {
        let guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
        match *guard {
            Maybe.Some(ref pool) => pool.try_steal_for(thief_id),
            Maybe.None => Maybe.None,
        }
    }

    /// Phase 2 (#278): poll a single TaskEntry. Mirrors the
    /// per-task body of `process_ready_tasks` so workers can
    /// drive both their local deque AND stolen tasks through
    /// the same waker / completion / re-park bookkeeping.
    fn poll_one_task(&self, mut entry: Heap<TaskEntry>) {
        if entry.completed {
            return;
        }

        // Create or reuse waker for this task.
        let waker = match &entry.waker {
            Some(w) => w.clone(),
            None => {
                let w = create_runtime_waker(entry.id, self);
                entry.waker = Some(w.clone());
                w
            }
        };
        let mut cx = Context.from_waker(&waker);

        let poll_result = (entry.poll_fn)(entry.future_ptr, &mut cx);
        self.total_polls.fetch_add(1, MemoryOrdering.Relaxed);

        match poll_result {
            Poll.Ready(()) => {
                entry.completed = true;
                self.task_count.fetch_sub(1, MemoryOrdering.Relaxed);
                self.total_completions.fetch_add(1, MemoryOrdering.Relaxed);
                (entry.drop_fn)(entry.future_ptr);
            }
            Poll.Pending => {
                // Re-enqueue to the global `task_queue` (the same
                // path single-threaded `process_ready_tasks` uses
                // for pending work). Stolen tasks DON'T return to
                // the original owner — they live on the global
                // queue until their waker fires, after which the
                // wake path puts them in `ready_queue` for the
                // next worker to pick up. Maintains the property
                // that no task is duplicated across deques.
                let mut queue = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
                queue.push(entry);
            }
        }
    }

    /// Get number of active tasks.
    public fn task_count(&self) -> Int {
        self.task_count.load(MemoryOrdering.Relaxed)
    }

    /// Check if runtime is currently running.
    public fn is_running(&self) -> Bool {
        self.running.load(MemoryOrdering.Relaxed)
    }

    /// Get the total number of event loop ticks since runtime creation.
    public fn tick_count(&self) -> Int {
        self.tick_count.load(MemoryOrdering.Relaxed)
    }

    /// Get the total number of task polls performed.
    public fn total_polls(&self) -> Int {
        self.total_polls.load(MemoryOrdering.Relaxed)
    }

    /// Get the total number of tasks that completed.
    public fn total_completions(&self) -> Int {
        self.total_completions.load(MemoryOrdering.Relaxed)
    }

    /// Snapshot the runtime's currently-tracked tasks as a List of
    /// `TaskInfo` records. Walks both the ready queue (Running)
    /// and the pending queue (Parked) under their respective locks
    /// to produce a consistent point-in-time view.
    ///

    /// # Concurrency
    ///

    /// Each queue lock is held only for the duration of the
    /// per-queue walk — no global runtime lock is held across both.
    /// A task that transitions between queues during the snapshot
    /// may appear in both, in neither, or in one — observers MUST
    /// treat the result as a best-effort point-in-time view, not a
    /// linearisation point.
    ///

    /// # Format-stable boundary
    ///

    /// Returns `List<TaskInfo>` (re-exported via core.diagnostics)
    /// so observers code against the umbrella surface and aren't
    /// coupled to TaskEntry's internal layout. Per-task metadata
    /// the executor doesn't currently track (poll_count, name,
    /// last_error) defaults to zero / empty Text — promoted to
    /// load-bearing fields when the executor adds tracking.
    ///

    /// # Performance
    ///

    /// O(active_tasks) atomic copies + 2 lock acquisitions.
    /// Typical: < 10 µs for 1000 tasks. Not on the spawn / poll
    /// hot path — observers call this from monitoring dashboards or
    /// panic post-mortem dumps.
    public fn snapshot_tasks(&self) -> List<TaskInfo> {
        let mut result: List<TaskInfo> = List.new();

        // Walk ready queue — these tasks have been woken and are
        // queued for the next poll cycle (Running state).
        {
            let ready = self.ready_queue.lock().unwrap_or_else(|p| p.into_inner());
            let mut i: Int = 0;
            while i < ready.len() {
                let entry = &ready[i];
                let state = if entry.completed {
                    TaskLifecycleState.Completed
                } else {
                    TaskLifecycleState.Running
                };
                result.push(TaskInfo.new(
                    TaskId { id: entry.id },
                    state,
                    Text.new(),       // name: not tracked yet
                    0,                // poll_count: not tracked yet
                    Text.new(),       // last_error: not tracked yet
                ));
                i = i + 1;
            }
        }

        // Walk pending queue — these tasks are awaiting external
        // wakeup (Parked state) or have not yet been polled (Pending).
        {
            let pending = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
            let mut i: Int = 0;
            while i < pending.len() {
                let entry = &pending[i];
                let state = if entry.completed {
                    TaskLifecycleState.Completed
                } else {
                    TaskLifecycleState.Parked
                };
                result.push(TaskInfo.new(
                    TaskId { id: entry.id },
                    state,
                    Text.new(),
                    0,
                    Text.new(),
                ));
                i = i + 1;
            }
        }

        result
    }

    /// Request shutdown.
    ///
    /// Phase 1B (#325): when a worker pool is active, this also
    /// drains workers cleanly:
    ///  1. Set the runtime-level `shutdown` flag (visible to
    ///  workers via Acquire load).
    ///  2. Extract the WorkerPool from `worker_pool` Mutex via
    ///  `Maybe::take` while holding the lock briefly. Set the
    ///  pool-level `shutdown_flag` and call `notify_all` to
    ///  wake every parked worker.
    ///  3. Release the worker_pool lock.
    ///  4. `into_iter` the extracted handles and `join()` each —
    ///  blocks until every worker has exited its poll loop.
    ///
    /// **Hazard 3 + 6**: steps 1-3 hold the worker_pool lock; the
    /// joins in step 4 are lock-free. This prevents:
    ///  * Hazard 3 — workers calling `worker_pool.lock()` (e.g.
    ///  in `try_park` / `decrement_parked_count`) deadlocking
    ///  with the join.
    ///  * Hazard 6 — `Drop for AsyncRuntime` calling shutdown
    ///  while a worker is mid-`worker_pool.lock()` blocking
    ///  the join indefinitely.
    public fn shutdown(&self) {
        self.shutdown.store(true, MemoryOrdering.Release);

        // Hazard 3 + 6: extract the pool atomically, notify, then
        // RELEASE the lock before joining.
        let pool_taken: Maybe<WorkerPool> = {
            let mut g = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
            let extracted = g.take();
            if let Maybe.Some(ref p) = extracted {
                p.shutdown_flag.store(true, MemoryOrdering.Release);
                p.notify_all();
            }
            extracted
        };
        // Lock released; safe to join lock-free.
        if let Maybe.Some(pool) = pool_taken {
            for h in pool.handles.into_iter() {
                let _ = h.join();
            }
        }
    }

    /// Spawn a future on the runtime.
    ///

    /// The spawned task inherits the current context via frame fork.
    /// This enables context propagation across task boundaries.
    ///

    /// # Performance
    /// - Target: <200ns spawn overhead (achieved: ~150ns without FFI)
    /// - Context fork: ~50ns (memcpy of 256 slots)
    ///

    /// # Example
    /// ```verum
    /// let handle = runtime.spawn(async {
    ///  // This task has access to parent's contexts
    ///  let logger = using Logger;
    ///  logger.log("Child task running");
    ///  42
    /// });
    /// let res = handle.await;
    /// ```
    /// Spawn a future on the multi-threaded runtime.
    ///
    /// **Phase 3 (#279) Send/Sync correctness pin**: BOTH `F: Send`
    /// AND `F.Output: Send` are required. Workers spawned by
    /// `start_worker_pool` may poll the future on a different thread
    /// than the spawning one — without `F: Send` the future could
    /// hold a `!Send` capture (e.g. `Rc<T>`, raw thread-local
    /// pointer) and the move-to-worker-thread is undefined behaviour.
    ///
    /// Programs that genuinely need `!Send` futures must use
    /// [`LocalExecutor.spawn_local`] instead — that path retains the
    /// single-threaded execution invariant and accepts `!Send`
    /// futures by construction.
    public fn spawn<F: Future + Send>(&self, future: F) -> JoinHandle<F.Output>
    where F.Output: Send
    {
        // Check shutdown
        if self.shutdown.load(MemoryOrdering.Acquire) {
            panic("Cannot spawn: runtime is shutting down");
        }

        // Check task limit
        let count = self.task_count.fetch_add(1, MemoryOrdering.Relaxed);
        if count >= self.config.max_tasks {
            self.task_count.fetch_sub(1, MemoryOrdering.Relaxed);
            panic("Cannot spawn: task limit reached");
        }

        // Create task with unique ID
        let task = Shared.new(Task {
            id: TaskId.new(),
            state: AtomicInt.new(0),  // Pending
            result: Mutex.new(None),
        });

        let task_id = self.next_task_id.fetch_add(1, MemoryOrdering.Relaxed);

        // Create task state wrapper
        let state = Heap.new(TaskState.new(future, task_id));
        let state_ptr = Heap.into_raw(state) as &unsafe Byte;

        // Define poll function (type-erased)
        let poll_fn: fn(&unsafe Byte, &mut Context) -> Poll<()> = |state_ptr: &unsafe Byte, cx: &mut Context| -> Poll<()> {
            let state = unsafe { &mut *(state_ptr as &mut TaskState<F>) };
            if state.completed {
                return Poll.Ready(());
            }

            match state.future.poll(cx) {
                Poll.Ready(res) => {
                    state.result = Some(res);
                    state.completed = true;
                    return Poll.Ready(());
                }
                Poll.Pending => {}
            };
            Poll.Pending
        };

        // Define drop function
        let drop_fn = |state_ptr: &unsafe Byte| {
            let _ = unsafe { Heap.from_raw(state_ptr as &mut TaskState<F>) };
        };

        // Create task entry
        // Note: In single-threaded executor, spawned tasks share the parent's
        // context (same thread = same TLS). No frame fork needed.
        // For multi-threaded executors, context snapshot should be captured
        // at spawn time and restored when the task runs on a worker thread.
        let entry = Heap.new(TaskEntry {
            id: task_id,
            future_ptr: state_ptr,
            poll_fn: poll_fn,
            drop_fn: drop_fn,
            waker: None,
            completed: false,
        });

        // Phase 2 (#278) — affine dispatch:
        //   * Inside a worker → push to that worker's local deque
        //     (LIFO). Recursive spawn stays cache-hot; the worker
        //     pops its own pushed task next iteration.
        //   * Outside a worker (main thread, signal handler, FFI
        //     callback) → push to the global injector
        //     (`task_queue`), which workers drain in tier 2 of the
        //     three-tier worker_main loop.
        // Also wakes one parked worker so the new task gets picked
        // up promptly even before the next 50 ms park-timeout fires
        // (Phase 1B-2's notify-after-spawn integration).
        //
        // Move-discipline: `entry_slot` holds the task in transit;
        // each push path consumes it via `take()`. The fall-through
        // path runs ONLY when the local-slot push path didn't fire,
        // so each task is enqueued exactly once.
        let mut entry_slot: Maybe<Heap<TaskEntry>> = Maybe.Some(entry);
        match current_worker_id() {
            Maybe.Some(wid) => {
                let guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
                if let Maybe.Some(ref pool) = *guard {
                    if let Maybe.Some(slot) = pool.slot(wid) {
                        // Phase 4 (#280): `push_local` returns
                        // `Result<(), Heap<TaskEntry>>`. On capacity
                        // overflow it returns `Err(task)` — re-store
                        // the task in `entry_slot` so the fall-through
                        // pushes it to the global injector. No task
                        // lost; no future-state leaked.
                        if let Maybe.Some(e) = entry_slot.take() {
                            match slot.push_local(e) {
                                Ok(()) => {},
                                Err(returned_task) => {
                                    // Capacity overflow — graceful
                                    // re-route to global injector.
                                    entry_slot = Maybe.Some(returned_task);
                                }
                            };
                        }
                    }
                }
            }
            Maybe.None => {},
        };
        if let Maybe.Some(e) = entry_slot.take() {
            // Fall-through to the global injector path.
            let mut queue = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
            queue.push(e);
        }
        // Wake one parked worker — covers the lost-wakeup window
        // between a producer pushing and a worker about to park.
        // No-op when no pool is configured.
        {
            let guard = self.worker_pool.lock().unwrap_or_else(|p| p.into_inner());
            if let Maybe.Some(ref pool) = *guard {
                pool.notify_one();
            }
        }

        JoinHandle { task: task }
    }

    /// Block on a future until it completes.
    ///

    /// This drives the future to completion on the current thread
    /// using the native V-LLSI event loop.
    ///

    /// # Warning
    /// Do NOT call this from within an async context - it will deadlock.
    ///

    /// # Example
    /// ```verum
    /// fn main() {
    ///  let rt = AsyncRuntime.new();
    ///  let res = rt.block_on(async {
    ///  fetch_data().await
    ///  });
    ///  print(f"Got: {result}");
    /// }
    /// ```
    public fn block_on<F: Future>(&self, future: F) -> F.Output {
        if self.running.swap(true, MemoryOrdering.AcqRel) {
            panic("AsyncRuntime already running - cannot nest block_on");
        }

        // Set runtime context
        ctx_set(SLOT_RUNTIME, self as &unsafe Byte);

        // Phase 1B (#325): start the worker pool if the manifest
        // configured `async_worker_threads > 0`. The call is
        // idempotent and gracefully falls back to single-threaded
        // mode under interpreter execution / spawn failure (returns
        // 0, leaves `worker_pool` empty). Either way the existing
        // single-threaded poll loop below remains the SAFETY net —
        // workers are parallel POLLERS of the same shared queues,
        // not a replacement for the main-thread loop.
        let _spawned = self.start_worker_pool();

        // Create IOEngine for this event loop if I/O is enabled
        if self.config.enable_io {
            match create_io_engine(self.config.io_sq_entries) {
                Ok(engine) => {
                    // Store IOEngine pointer both in AsyncRuntime (for wait_for_events)
                    // and in context slot (for async operations to submit I/O)
                    let engine_ptr = Heap.new(engine);
                    let raw_ptr = Heap.into_raw(engine_ptr);
                    self.io_engine_ptr = raw_ptr as Int;
                    ctx_set(SLOT_IO_ENGINE, raw_ptr as &unsafe Byte);
                }
                Err(_) => {
                    // IOEngine creation failed — fall back to poll-based
                }
            }
        }

        // Create task state with result storage
        let task_id = self.next_task_id.fetch_add(1, MemoryOrdering.Relaxed);
        let mut state = TaskState.new(future, task_id);

        // Create waker for this task
        let waker = create_runtime_waker(task_id, self);
        let mut cx = Context.from_waker(&waker);

        // Event loop - poll until completion
        //

        // The cooperative scheduling model:
        //  1. Poll the main future
        //  2. If pending, process spawned tasks (up to poll_budget per tick)
        //  3. Wait for I/O events or yield CPU
        //  4. Repeat
        //

        // Tasks yield at .await points. The executor never preempts a task
        // mid-execution -- cooperation is required for fairness.
        loop {
            // Increment tick counter
            self.tick_count.fetch_add(1, MemoryOrdering.Relaxed);

            // Poll the main future
            match state.future.poll(&mut cx) {
                Poll.Ready(res) => {
                    state.result = Some(res);
                    state.completed = true;
                    break;
                }
                Poll.Pending => {
                    // Process spawned tasks with cooperative budget.
                    // Each tick processes at most `poll_budget` tasks to
                    // ensure the main future gets re-polled promptly.
                    self.process_ready_tasks();

                    // Check if shutdown was requested
                    if self.shutdown.load(MemoryOrdering.Acquire) {
                        // Drain and drop remaining tasks
                        self.drain_all_tasks();
                        // Continue polling main future -- it should complete
                    }

                    // If we have I/O enabled, wait for events
                    if self.config.enable_io {
                        self.wait_for_events();
                    } else {
                        // No I/O - just yield CPU briefly
                        spin_hint();
                    }

                    // Drain any timers that expired during the wait.
                    // Runs unconditionally (whether I/O is enabled or
                    // not, whether wait returned early or via timeout)
                    // so registered timer wakers fire promptly.
                    self.drain_expired_timers(time_now_ns());
                }
            }
        }

        // Clean up IOEngine
        if self.io_engine_ptr != 0 {
            ctx_clear(SLOT_IO_ENGINE);
            // Reclaim and drop the IOEngine
            let _ = unsafe { Heap.from_raw(self.io_engine_ptr as &unsafe Byte) };
            self.io_engine_ptr = 0;
        }

        // Clear runtime context
        ctx_clear(SLOT_RUNTIME);
        self.running.store(false, MemoryOrdering.Release);

        // Extract the result
        state.take_result()
    }

    /// Process ready tasks from the queue.
    ///

    /// Polls tasks from both the ready queue (woken by waker) and the
    /// pending queue (newly spawned). Enforces the cooperative poll budget:
    /// at most `config.poll_budget` tasks are polled per call to prevent
    /// starvation of the main future and I/O event processing.
    ///

    /// Returns the number of tasks that completed during this tick.
    fn process_ready_tasks(&self) -> Int {
        let budget = self.config.poll_budget;
        let mut polled = 0;
        let mut completed = 0;
        let mut tasks_to_poll: List<Heap<TaskEntry>> = List.new();

        // Collect ready tasks (explicitly woken) -- these have priority
        {
            let mut ready = self.ready_queue.lock().unwrap_or_else(|p| p.into_inner());
            while !ready.is_empty() && tasks_to_poll.len() < budget {
                if let Some(task) = ready.pop() {
                    tasks_to_poll.push(task);
                }
            }
        }

        // Fill remaining budget with pending tasks (newly spawned, need initial poll)
        {
            let mut pending = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
            while !pending.is_empty() && tasks_to_poll.len() < budget {
                if let Some(task) = pending.pop() {
                    tasks_to_poll.push(task);
                }
            }
        }

        // Poll each task within budget
        for mut entry in tasks_to_poll.into_iter() {
            if entry.completed {
                continue;
            }

            // Create or reuse waker for this task
            let waker = match &entry.waker {
                Some(w) => w.clone(),
                None => {
                    let w = create_runtime_waker(entry.id, self);
                    entry.waker = Some(w.clone());
                    w
                }
            };
            let mut cx = Context.from_waker(&waker);

            // Poll the task -- this is where cooperative yielding happens.
            // The task runs until it hits an .await point and returns Pending,
            // or it completes and returns Ready.
            let poll_result = (entry.poll_fn)(entry.future_ptr, &mut cx);
            polled = polled + 1;

            match poll_result {
                Poll.Ready(()) => {
                    entry.completed = true;
                    completed = completed + 1;
                    self.task_count.fetch_sub(1, MemoryOrdering.Relaxed);
                    self.total_completions.fetch_add(1, MemoryOrdering.Relaxed);
                    // Drop the task state (frees the heap-allocated future)
                    (entry.drop_fn)(entry.future_ptr);
                }
                Poll.Pending => {
                    // Task yielded -- return to pending queue.
                    // It will be moved to the ready queue when its waker fires.
                    let mut queue = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
                    queue.push(entry);
                }
            }
        }

        // Update global poll counter
        self.total_polls.fetch_add(polled, MemoryOrdering.Relaxed);
        completed
    }

    /// Drain and drop all tasks from both queues.
    ///

    /// Called during shutdown to clean up remaining tasks.
    fn drain_all_tasks(&self) {
        // Drain ready queue
        {
            let mut ready = self.ready_queue.lock().unwrap_or_else(|p| p.into_inner());
            while !ready.is_empty() {
                if let Some(entry) = ready.pop() {
                    if !entry.completed {
                        (entry.drop_fn)(entry.future_ptr);
                    }
                }
            }
        }

        // Drain pending queue
        {
            let mut pending = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
            while !pending.is_empty() {
                if let Some(entry) = pending.pop() {
                    if !entry.completed {
                        (entry.drop_fn)(entry.future_ptr);
                    }
                }
            }
        }
    }

    /// Run spawned tasks until no more tasks are ready.
    ///

    /// Unlike `block_on`, this does not drive a main future. It processes
    /// the ready and pending queues until all tasks are either completed
    /// or waiting for wakeup, then returns.
    ///

    /// Useful for testing and for manually stepping the executor.
    ///

    /// Returns the total number of tasks that completed.
    public fn run_until_idle(&self) -> Int {
        let mut total_completed = 0;
        loop {
            let completed = self.process_ready_tasks();
            total_completed = total_completed + completed;

            // Check if there are any more ready tasks
            let has_ready = {
                let ready = self.ready_queue.lock().unwrap_or_else(|p| p.into_inner());
                !ready.is_empty()
            };
            let has_pending = {
                let pending = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
                !pending.is_empty()
            };

            // If nothing is ready and nothing is pending, we're idle
            if !has_ready && !has_pending {
                break;
            }

            // If we have pending but no ready tasks, the tasks are waiting
            // for external wakeup -- we're idle from the executor's perspective
            if !has_ready && has_pending && completed == 0 {
                break;
            }
        }
        total_completed
    }

    /// Wait for I/O events or briefly yield.
    ///

    /// Uses the IOEngine wait() if available for event-driven wakeups,
    /// otherwise falls back to a brief OS sleep to avoid busy-waiting.
    /// The platform-specific concrete-type cast is delegated to
    /// `engine_wait_active` (per-target @cfg-gated helper) so the
    /// type checker only sees the active platform's driver type —
    /// previously 3 inline @cfg blocks each named a different
    /// concrete driver, which forced the type checker to resolve
    /// `IoDriver` even when targeting macOS where it doesn't exist.
    ///
    /// **Phase 3 (#279) main-thread invariant**: `wait_for_events`
    /// must be called ONLY from the runtime-owning thread (i.e.
    /// the thread that called `block_on`). Worker threads spawned
    /// by `start_worker_pool` MUST NOT call this — IOEngine
    /// internals (kqueue/io_uring/IOCP fds) are not Sync and
    /// concurrent waiters would deadlock or corrupt the
    /// completion-queue state. Workers stick to draining tasks +
    /// parking on `park_cv`; the main thread is the sole I/O
    /// poller. `current_worker_id()` is `Maybe.None` only on the
    /// main thread, so a worker accidentally hitting this entry
    /// point would `panic` here.
    fn wait_for_events(&self) {
        // Phase 3 (#279) — debug-time main-thread guard.
        if let Maybe.Some(wid) = current_worker_id() {
            panic(f"wait_for_events called from worker thread {wid} — IOEngine is main-thread-only");
        }
        if self.io_engine_ptr != 0 {
            let zero_cr = CompletionResult { user_data: 0, result: 0, flags: 0 };
            let mut results: [CompletionResult; 64] = [zero_cr; 64];
            // Compute the wait timeout: with a pending timer, park
            // for at most `time_until_next_timer` so the IOEngine
            // returns in time to drain expired entries; otherwise
            // fall back to the default 1ms tick. Closes the
            // busy-spin gap that timer-bound futures historically
            // patched over with `cx.waker().wake_by_ref()`.
            let now_ns = time_now_ns();
            let timeout = match self.next_timer_deadline() {
                Some(deadline_ns) if deadline_ns > now_ns => {
                    let remaining_ns = deadline_ns - now_ns;
                    // Cap at 1ms — keeps responsiveness for newly
                    // arriving I/O events when timers are far out.
                    let one_ms_ns: UInt64 = 1_000_000;
                    let waitable_ns = if remaining_ns < one_ms_ns {
                        remaining_ns
                    } else {
                        one_ms_ns
                    };
                    Some(IoDuration.from_micros((waitable_ns / 1_000) as Int))
                }
                Some(_) => {
                    // Timer already expired — return immediately so
                    // the caller can drain it on the next iteration.
                    Some(IoDuration.from_millis(0))
                }
                None => Some(IoDuration.from_millis(1)),
            };

            match engine_wait_active(self.io_engine_ptr, &mut results, timeout) {
                Ok(count) => {
                    // Process completions — wake tasks whose I/O completed.
                    // Compare in UInt64 space — WAKE_TOKEN is
                    // UInt64 0xFFFF_FFFF_FFFF_FFFF (2^64-1) which
                    // doesn't representably cast to Int64; filter
                    // the sentinel before narrowing.
                    let mut i = 0;
                    while i < count {
                        let user_data = results[i].user_data;
                        if user_data > 0_u64 && user_data != WAKE_TOKEN {
                            self.wake_task(user_data as Int);
                        }
                        i = i + 1;
                    }
                }
                Err(_) => {
                    // IOEngine error — fall back to brief sleep.
                    self.brief_sleep();
                }
            }
        } else {
            self.brief_sleep();
        }
    }

    /// Brief OS sleep to yield CPU without burning cycles.
    fn brief_sleep(&self) {
        @cfg(target_os = "linux") {
            let _ = super.super.sys.linux.time.sleep(
                super.super.sys.linux.time.Duration.from_micros(100)
            );
        }
        @cfg(target_os = "macos") {
            let _ = super.super.sys.darwin.time.sleep(
                super.super.sys.darwin.time.Duration.from_micros(100)
            );
        }
        @cfg(target_os = "windows") {
            let _ = super.super.sys.windows.time.sleep(
                super.super.sys.windows.time.Duration.from_micros(100)
            );
        }
    }

    /// Register a timer-driven wakeup.
    ///

    /// `deadline_ns` is the absolute monotonic instant at which the
    /// `waker` should fire. The entry is inserted into
    /// `self.timer_queue` at its sorted position (earliest first)
    /// so the event-loop head-peek is O(1) and the IOEngine wait
    /// timeout can be computed without sorting.
    ///

    /// Replaces the busy-spin `cx.waker().wake_by_ref()` pattern.
    /// Pre-fix every timer-bound poll burned ~1000 polls/sec on
    /// the brief_sleep loop; with this entry the runtime parks
    /// for the exact remaining duration.
    pub fn register_timer(&self, deadline_ns: UInt64, waker: Waker) {
        let mut queue = self.timer_queue.lock().unwrap_or_else(|p| p.into_inner());
        // Sorted insert by deadline_ns ascending. Linear scan from
        // the end is O(n) worst-case but the queue is typically
        // shallow (~1–10 timers) so a heap would be overkill.
        let mut idx = queue.len();
        while idx > 0 {
            match queue.get(idx - 1) {
                Some(prev_entry) if prev_entry.deadline_ns > deadline_ns => {
                    idx -= 1;
                }
                _ => break,
            }
        }
        queue.insert(idx, TimerEntry {
            deadline_ns: deadline_ns,
            waker: waker,
        });
    }

    /// Peek the earliest pending timer deadline, if any.
    ///

    /// Used by the event loop to size the IOEngine wait timeout —
    /// returns `Some(deadline_ns)` when at least one timer is
    /// queued, `None` otherwise (in which case the loop falls back
    /// to the default `enable_io ? 1ms : brief_sleep_100us`).
    pub fn next_timer_deadline(&self) -> Maybe<UInt64> {
        let queue = self.timer_queue.lock().unwrap_or_else(|p| p.into_inner());
        match queue.get(0) {
            Some(entry) => Some(entry.deadline_ns),
            None => None,
        }
    }

    /// Drain all timer entries whose deadline has passed and wake
    /// their wakers.
    ///

    /// Called by the event loop after `wait_for_events` returns —
    /// processes every entry with `deadline_ns <= now_ns`. Wakers
    /// are dropped after invocation; clones-on-register-time keep
    /// the original future's waker live.
    fn drain_expired_timers(&self, now_ns: UInt64) {
        let mut expired: List<TimerEntry> = List.new();
        {
            let mut queue = self.timer_queue.lock().unwrap_or_else(|p| p.into_inner());
            // Pop from the front while the head is expired.
            while !queue.is_empty() {
                match queue.get(0) {
                    Some(head_entry) if head_entry.deadline_ns <= now_ns => {
                        if let Some(popped) = queue.remove(0) {
                            expired.push(popped);
                        }
                    }
                    _ => break,
                }
            }
        }
        // Wake outside the lock so wakers that re-enter the runtime
        // (e.g. a waker that schedules another timer) don't deadlock.
        for fired_entry in expired.into_iter() {
            fired_entry.waker.wake_by_ref();
        }
    }

    /// Wake a task by ID (called by waker).
    fn wake_task(&self, task_id: Int) {
        let mut task_to_wake: Maybe<Heap<TaskEntry>> = None;

        // Find and remove task from pending queue
        {
            let mut queue = self.task_queue.lock().unwrap_or_else(|p| p.into_inner());
            for i in range(0, queue.len()) {
                if queue.get(i).map(|e| e.id == task_id).unwrap_or(false) {
                    task_to_wake = Some(queue.remove(i));
                    break;
                }
            }
        }

        // Move to ready queue
        if let Some(task) = task_to_wake {
            let mut ready = self.ready_queue.lock().unwrap_or_else(|p| p.into_inner());
            ready.push(task);
        }
    }
}

implement Drop for AsyncRuntime {
    fn drop(&mut self) {
        self.shutdown();
    }
}

// =============================================================================
// Block On (Free Function)
// =============================================================================

/// Run a future to completion on the current thread.
///

/// Creates a temporary runtime && blocks until the future completes.
/// This is the simplest way to run async code from sync code.
///

/// # Example
/// ```verum
/// fn main() {
///  let res = block_on(async {
///  let data = fetch_data().await;
///  process(data)
///  });
///  print(f"Result: {result}");
/// }
/// ```
public fn block_on<F: Future>(future: F) -> F.Output {
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let mut fut = future;

    loop {
        match fut.poll(&mut cx) {
            Poll.Ready(res) => return res,
            Poll.Pending => {
                // Brief sleep to avoid CPU burn while polling
                @cfg(target_os = "linux") {
                    let _ = sys.linux.time.sleep(
                        sys.linux.time.Duration.from_micros(50)
                    );
                }
                @cfg(target_os = "macos") {
                    let _ = sys.darwin.time.sleep(
                        sys.darwin.time.Duration.from_micros(50)
                    );
                }
                @cfg(target_os = "windows") {
                    spin_hint();
                }
            }
        }
    }
}

// =============================================================================
// Builder Pattern
// =============================================================================

/// Builder for creating a AsyncRuntime with custom configuration.
public type RuntimeBuilder is {
    config: AsyncRuntimeConfig,
};

implement RuntimeBuilder {
    /// Create new builder with default config.
    public fn new() -> RuntimeBuilder {
        RuntimeBuilder {
            config: AsyncRuntimeConfig.default(),
        }
    }

    /// Set maximum number of tasks.
    public fn max_tasks(mut self, n: Int) -> RuntimeBuilder {
        self.config.max_tasks = n;
        self
    }

    /// Set task stack size.
    public fn stack_size(mut self, size: Int) -> RuntimeBuilder {
        self.config.task_stack_size = size;
        self
    }

    /// Enable work stealing.
    public fn enable_work_stealing(mut self) -> RuntimeBuilder {
        self.config.enable_work_stealing = true;
        self
    }

    /// Enable I/O driver.
    public fn enable_io(mut self) -> RuntimeBuilder {
        self.config.enable_io = true;
        self
    }

    /// Enable timer driver.
    public fn enable_time(mut self) -> RuntimeBuilder {
        self.config.enable_time = true;
        self
    }

    /// Build the runtime.
    public fn build(self) -> AsyncRuntime {
        AsyncRuntime.with_config(self.config)
    }
}

// =============================================================================
// LocalExecutor - Lightweight Single-Threaded Executor
// =============================================================================

/// A lightweight single-threaded executor for `!Send` futures.
///

/// Unlike `AsyncRuntime`, `LocalExecutor` does not use Mutex-protected queues.
/// All operations happen on a single thread, making it suitable for:
/// - `!Send` futures (e.g., futures capturing `Rc` or raw pointers)
/// - Minimal overhead when multi-threading is not needed
/// - Embedding an executor inside a library without global state
///

/// # Design
///

/// The executor maintains two lists:
/// - `ready`: tasks that have been woken and need polling
/// - `pending`: tasks waiting for external events
///

/// Each call to `tick()` polls all ready tasks once. Tasks that return
/// `Pending` are moved back to the pending list. Tasks that complete
/// are dropped. Wakers move tasks from pending to ready.
///

/// # Example
/// ```verum
/// let mut exec = LocalExecutor.new();
/// exec.spawn_local(async { compute_something() });
/// exec.spawn_local(async { compute_other() });
/// // Drive all tasks to completion
/// exec.run_until_complete();
/// ```
public type LocalExecutor is {
    /// Tasks ready to be polled
    ready: List<Heap<TaskEntry>>,
    /// Tasks waiting for wakeup
    pending: List<Heap<TaskEntry>>,
    /// Next task ID
    next_id: Int,
    /// Total polls performed
    polls: Int,
    /// Total tasks completed
    completions: Int,
};

implement LocalExecutor {
    /// Create a new local executor.
    public fn new() -> LocalExecutor {
        LocalExecutor {
            ready: List.new(),
            pending: List.new(),
            next_id: 1,
            polls: 0,
            completions: 0,
        }
    }

    /// Spawn a future on this local executor.
    ///

    /// The future does not need to be `Send` since it will only
    /// be polled on the current thread.
    public fn spawn_local<F: Future>(&mut self, future: F) {
        let task_id = self.next_id;
        self.next_id = self.next_id + 1;

        // Create task state wrapper
        let state = Heap.new(TaskState.new(future, task_id));
        let state_ptr = Heap.into_raw(state) as &unsafe Byte;

        // Define poll function (type-erased)
        let poll_fn: fn(&unsafe Byte, &mut Context) -> Poll<()> = |state_ptr: &unsafe Byte, cx: &mut Context| -> Poll<()> {
            let state = unsafe { &mut *(state_ptr as &mut TaskState<F>) };
            if state.completed {
                return Poll.Ready(());
            }

            match state.future.poll(cx) {
                Poll.Ready(res) => {
                    state.result = Some(res);
                    state.completed = true;
                    return Poll.Ready(());
                }
                Poll.Pending => {}
            };
            return Poll.Pending;
        };

        // Define drop function
        let drop_fn = |state_ptr: &unsafe Byte| {
            let _ = unsafe { Heap.from_raw(state_ptr as &mut TaskState<F>) };
        };

        let entry = Heap.new(TaskEntry {
            id: task_id,
            future_ptr: state_ptr,
            poll_fn: poll_fn,
            drop_fn: drop_fn,
            waker: None,
            completed: false,
        });

        // Newly spawned tasks go directly to ready queue for initial poll
        self.ready.push(entry);
    }

    /// Perform one tick of the executor.
    ///

    /// Polls all ready tasks once. Returns the number of tasks that
    /// completed during this tick.
    public fn tick(&mut self) -> Int {
        let mut completed = 0;

        // Take the ready list -- tasks woken during polling go back
        let mut to_poll = List.new();
        while !self.ready.is_empty() {
            if let Some(task) = self.ready.pop() {
                to_poll.push(task);
            }
        }

        // Also give pending tasks (newly spawned) their initial poll
        // on the first tick, then only woken tasks get polled.
        // Note: tasks in `pending` that haven't been polled yet
        // are moved to ready on spawn, so pending only has
        // tasks that returned Pending on a previous poll.

        let noop = noop_waker();

        for mut entry in to_poll.into_iter() {
            if entry.completed {
                continue;
            }

            let mut cx = Context.from_waker(&noop);
            let poll_result = (entry.poll_fn)(entry.future_ptr, &mut cx);
            self.polls = self.polls + 1;

            match poll_result {
                Poll.Ready(()) => {
                    entry.completed = true;
                    completed = completed + 1;
                    self.completions = self.completions + 1;
                    (entry.drop_fn)(entry.future_ptr);
                }
                Poll.Pending => {
                    // Move to pending -- will be re-added to ready when woken
                    self.pending.push(entry);
                }
            }
        }

        completed
    }

    /// Run the executor until all tasks have completed.
    ///

    /// Repeatedly calls `tick()` until both the ready and pending
    /// queues are empty. For tasks that depend on external wakeup,
    /// this will poll pending tasks each iteration as a fallback.
    ///

    /// Returns the total number of tasks that completed.
    public fn run_until_complete(&mut self) -> Int {
        let mut total = 0;
        loop {
            // Move all pending tasks to ready for re-polling
            // (In a full waker-based system, only woken tasks would move.
            //  For the local executor, we re-poll all pending tasks since
            //  there is no external event source to wake them.)
            while !self.pending.is_empty() {
                if let Some(task) = self.pending.pop() {
                    self.ready.push(task);
                }
            }

            if self.ready.is_empty() {
                break;
            }

            let completed = self.tick();
            total = total + completed;

            // Safety valve: if we polled but nothing completed and
            // nothing new was added, avoid infinite loop
            if completed == 0 && self.ready.is_empty() {
                break;
            }
        }
        total
    }

    /// Check if the executor has any tasks (ready or pending).
    public fn has_tasks(&self) -> Bool {
        !self.ready.is_empty() || !self.pending.is_empty()
    }

    /// Get the number of ready tasks.
    public fn ready_count(&self) -> Int {
        self.ready.len()
    }

    /// Get the number of pending tasks.
    public fn pending_count(&self) -> Int {
        self.pending.len()
    }

    /// Get total polls performed.
    public fn total_polls(&self) -> Int {
        self.polls
    }

    /// Get total completions.
    public fn total_completions(&self) -> Int {
        self.completions
    }
}

// =============================================================================
// ExecutorTimeout Support
// =============================================================================

// NOTE: Sleep future and sleep_ms/sleep_secs/sleep are defined in
// core/async/timer.vr as the canonical source. Use `mount async.timer.{Sleep, sleep, sleep_ms}`
// instead of duplicating here.

// =============================================================================
// ExecutorTimeout Combinator
// =============================================================================

/// ExecutorTimeout error when a future doesn't complete in time.
public type ExecutorTimeoutError is ();

implement Debug for ExecutorTimeoutError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("ExecutorTimeoutError")
    }
}

implement Display for ExecutorTimeoutError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("operation timed out")
    }
}

implement Eq for ExecutorTimeoutError {
    fn eq(&self, _other: &ExecutorTimeoutError) -> Bool {
        true
    }
}

/// Future that wraps another future with a timeout.
public type ExecutorTimeout<F: Future> is {
    future: F,
    timeout_ns: UInt64,
    /// Absolute deadline in nanoseconds since boot
    deadline_ns: UInt64,
    started: Bool,
};

/// Get current monotonic time in nanoseconds.
/// Uses native V-LLSI time functions instead of FFI.
@inline
fn time_now_ns() -> UInt64 {
    monotonic_nanos()
}

// =============================================================================
// Phase 1B (#325) — Worker main loop
// =============================================================================
//
// Each spawned worker thread runs `worker_main(runtime_ptr)`.
// The function casts the `&unsafe Byte` back to `&AsyncRuntime`
// and runs a poll-and-park loop until shutdown.
//
// SAFETY contract for the cast:
//
//   * `runtime_ptr` is a `&unsafe Byte` derived from
//     `(&AsyncRuntime) as &unsafe Byte` in `start_worker_pool`.
//   * The runtime outlives all spawned workers because:
//      1. `block_on` claims the `running` flag before calling
//         `start_worker_pool`, owning the runtime's stack frame
//         for the entire poll loop.
//      2. `shutdown` (called by `Drop for AsyncRuntime` at the
//         bottom of `block_on` AND by the runtime's user-facing
//         drop) extracts the WorkerPool and joins every handle
//         BEFORE the runtime can be dropped — Hazard 5 + 6.
//      3. The `pool_taken` local in `shutdown` keeps the
//         WorkerPool (and its `park_cv` / `park_mu`) alive
//         through the `into_iter().join()` loop, so workers
//         waking from a wait have valid park primitives until
//         the moment they exit `worker_main`.
//
// Therefore the unsafe deref is sound for the entire
// `worker_main` body.
//
// **Phase 2 (#278)**: each worker now also carries its own
// `worker_id` so the work-stealing scheduler can:
//   * stamp the `CURRENT_WORKER_ID` thread-local for affine
//     spawning (`spawn` reads this to decide local-deque vs.
//     global-injector dispatch).
//   * index into `WorkerPool.slots[worker_id]` to drain its
//     local deque LIFO before falling through to the global
//     queues, then to `try_steal_for(worker_id)` to take work
//     from a peer's deque FRONT.
fn worker_main(runtime_ptr: &unsafe Byte, worker_id: Int) {
    let runtime = unsafe { &*(runtime_ptr as &AsyncRuntime) };

    // Phase 2 (#278): publish the worker id to the thread-local
    // cell. Encoded as `id + 1` because `0` is reserved for "not
    // a worker" (main thread / FFI callback). Read back by
    // `current_worker_id()` from the `spawn` path to decide
    // local-vs-injector dispatch.
    unsafe {
        CURRENT_WORKER_ID = worker_id + 1;
    }

    loop {
        // Promptly check the shutdown flag at every iteration —
        // covers wake from `notify_all`, timeout expiry, and the
        // initial loop entry alike.
        if runtime.shutdown.load(MemoryOrdering.Acquire) {
            break;
        }

        // Phase 2 (#278) — three-tier drain order:
        //   1. Local deque LIFO (cache-hot for recursive spawn)
        //   2. Global injector / ready queues (existing path)
        //   3. Steal from a peer's deque FRONT
        // First non-None task is polled. When all three return
        // empty, the worker proceeds to `try_park`.
        let mut polled_any = false;

        // Tier 1: local deque LIFO drain (own worker's slot).
        loop {
            let task_opt = runtime.pop_local_task(worker_id);
            match task_opt {
                Maybe.Some(task) => {
                    runtime.poll_one_task(task);
                    polled_any = true;
                }
                Maybe.None => break,
            };
            if runtime.shutdown.load(MemoryOrdering.Acquire) {
                break;
            }
        }

        // Tier 2: global injector + ready queues. Same path the
        // single-threaded loop uses; thread-safe via per-queue
        // Mutex.
        let completed = runtime.process_ready_tasks();
        if completed > 0 {
            polled_any = true;
        }

        if runtime.shutdown.load(MemoryOrdering.Acquire) {
            break;
        }

        // Tier 3: steal from a peer worker. Only attempted when
        // tiers 1+2 produced nothing — opportunistic load
        // balance.
        if !polled_any {
            match runtime.try_steal(worker_id) {
                Maybe.Some(task) => {
                    runtime.poll_one_task(task);
                    polled_any = true;
                }
                Maybe.None => {},
            };
        }

        if runtime.shutdown.load(MemoryOrdering.Acquire) {
            break;
        }

        // All three tiers empty → park. `try_park` re-checks the
        // queues UNDER park_mu (Hazard 2 lost-wakeup mitigation)
        // and waits with a 50 ms timeout (Phase 1B-1 safety net
        // — Phase 1B-2 will replace with notify-after-spawn).
        if !polled_any {
            match runtime.try_park() {
                ParkAction.Stop => break,
                ParkAction.Continue => {},
            };
        }
    }

    // Clear the thread-local on exit for cleanliness — the OS
    // would zero the TLS slot when the thread joins anyway, but
    // explicit clear matches the pre-Phase-2 invariant that
    // `CURRENT_WORKER_ID == 0` outside any worker.
    unsafe {
        CURRENT_WORKER_ID = 0;
    }
}

// =============================================================================
// Platform-specific IOEngine wait dispatch
// =============================================================================
//

// `wait_for_events` previously embedded three near-identical inline
// `@cfg(target_os)` blocks, each casting the io_engine_ptr to that
// platform's concrete IOEngine implementation (KqueueDriver on
// macOS, IoDriver on Linux/Windows) and calling .wait(). The type
// checker resolved every block on every host — so a macOS check
// would fail with "type not found: IoDriver" because the linux
// branch's mount + cast were still on the resolution path.
//

// The fix is to define one fn per target where the @cfg gates the
// entire definition (signature + body). Verum then sees only the
// active platform's helper at type-check time; the call site
// (`wait_for_events`) is uniform.
//

// All three return a uniform `Result<Int, EngineIoError>` — Ok
// carries the completion count, Err falls through to brief_sleep
// in the caller.

@cfg(target_os = "macos")
fn engine_wait_active(
    io_engine_ptr: Int,
    results: &mut [CompletionResult; 64],
    timeout: Maybe<EngineDuration>,
) -> Result<Int, EngineIoError> {
    mount sys.darwin.io.{KqueueDriver};
    let engine = io_engine_ptr as &mut KqueueDriver;
    engine.wait(results, 0, timeout)
}

@cfg(target_os = "linux")
fn engine_wait_active(
    io_engine_ptr: Int,
    results: &mut [CompletionResult; 64],
    timeout: Maybe<EngineDuration>,
) -> Result<Int, EngineIoError> {
    mount sys.linux.io.{IoDriver};
    let engine = io_engine_ptr as &mut IoDriver;
    engine.wait(results, 0, timeout)
}

@cfg(target_os = "windows")
fn engine_wait_active(
    io_engine_ptr: Int,
    results: &mut [CompletionResult; 64],
    timeout: Maybe<EngineDuration>,
) -> Result<Int, EngineIoError> {
    mount sys.windows.io.{IoDriver};
    let engine = io_engine_ptr as &mut IoDriver;
    engine.wait(results, 0, timeout)
}

implement<F: Future> ExecutorTimeout<F> {
    public fn new(future: F, timeout_ns: UInt64) -> ExecutorTimeout<F> {
        ExecutorTimeout {
            future: future,
            timeout_ns: timeout_ns,
            deadline_ns: 0,  // Set on first poll
            started: false,
        }
    }
}

implement<F: Future> Future for ExecutorTimeout<F> {
    type Output = Result<F.Output, ExecutorTimeoutError>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<F.Output, ExecutorTimeoutError>> {
        // Initialize deadline on first poll
        if !self.started {
            let now = time_now_ns();
            self.deadline_ns = now + self.timeout_ns;
            self.started = true;
        }

        // Check if deadline has passed
        let now = time_now_ns();
        if now >= self.deadline_ns {
            return Poll.Ready(Err(ExecutorTimeoutError));
        }

        // Try to poll the inner future
        match self.future.poll(cx) {
            Poll.Ready(res) => Poll.Ready(Ok(res)),
            Poll.Pending => {
                // Park until the deadline so the runtime re-polls
                // exactly once when the timeout window closes — the
                // inner future will wake us earlier through its own
                // waker if it makes progress. Closes the busy-spin
                // gap (#243) for the timeout primitive: pre-fix the
                // comment said "the runtime will poll periodically
                // or use timer wheel" but neither was wired, so the
                // outer event loop just brief_slept and re-polled.
                match current_runtime() {
                    Some(rt) => {
                        rt.register_timer(self.deadline_ns, cx.waker().clone());
                    }
                    None => {
                        // No runtime in scope — fall back to
                        // historical Pending without registration;
                        // depends on outer waker activity to advance.
                    }
                }
                Poll.Pending
            }
        }
    }
}

/// Wrap a future with a timeout (raw milliseconds overload).
///

/// NOTE: Renamed from `timeout` to `timeout_ms_raw` to avoid collision with the
/// idiomatic `timer.timeout(Duration, Future)` (which is re-exported by
/// `core.async`). Prefer the Duration-based version for new code.
///

/// # Example
/// ```verum
/// let res = timeout_ms_raw(fetch_data(), 5000).await;
/// match result {
///  Ok(data) => print(f"Got: {data}"),
///  Err(ExecutorTimeoutError) => print("Request timed out"),
/// }
/// ```
public fn timeout_ms_raw<F: Future>(future: F, timeout_ms: UInt64) -> ExecutorTimeout<F> {
    ExecutorTimeout.new(future, timeout_ms * 1_000_000)
}

// =============================================================================
// Spawn Utilities
// =============================================================================

/// Spawn a blocking operation on a dedicated thread pool.
///

/// Use this for CPU-intensive || blocking I/O operations that would
/// otherwise block the async runtime. Routes through
/// `core.async.task::spawn_blocking` which submits to
/// `core.runtime.pool::ThreadPool` (distinct from the async
/// executor's worker pool) and returns a `JoinHandle` whose
/// underlying `BlockingFuture` polls a completion flag — async
/// workers stay free between polls.
///

/// Pre-fix this was the same `spawn(lazy(f))` placeholder as
/// `task.vr::spawn_blocking` (closed in commit 14ba223f); both
/// modules now share the same load-bearing implementation
/// rather than maintaining parallel stubs.
///

/// # Example
/// ```verum
/// let hash = spawn_blocking(|| {
///  compute_expensive_hash(data)
/// }).await;
/// ```
public fn spawn_blocking<T: Send, F: fn() -> T + Send>(f: F) -> JoinHandle<T> {
    // Delegate to the canonical implementation in task.vr —
    // single source of truth for the pool-routed BlockingFuture
    // pattern. Both spawn_blocking exports (this one and
    // task.vr::spawn_blocking) resolve to identical behaviour.
    core.async.task.spawn_blocking(f)
}

// =============================================================================
// Native Waker Implementation
// =============================================================================

/// Waker data for runtime integration.
type RuntimeWakerData is {
    task_id: Int,
    runtime: &AsyncRuntime,
};

/// Create a waker that wakes a task on the given runtime.
fn create_runtime_waker(task_id: Int, runtime: &AsyncRuntime) -> Waker {
    let data = Heap.new(RuntimeWakerData {
        task_id: task_id,
        runtime: runtime,
    });
    let data_ptr = Heap.into_raw(data) as &unsafe Byte;

    let raw = RawWaker.new(data_ptr, &RUNTIME_WAKER_VTABLE);
    unsafe { Waker.from_raw(raw) }
}

/// Clone waker data.
fn runtime_waker_clone(data: &unsafe Byte) -> RawWaker {
    let waker_data = unsafe { &*(data as &RuntimeWakerData) };
    let new_data = Heap.new(RuntimeWakerData {
        task_id: waker_data.task_id,
        runtime: waker_data.runtime,
    });
    let new_ptr = Heap.into_raw(new_data) as &unsafe Byte;
    RawWaker.new(new_ptr, &RUNTIME_WAKER_VTABLE)
}

/// Wake task (consume waker).
fn runtime_waker_wake(data: &unsafe Byte) {
    let waker_data = unsafe { Heap.from_raw(data as &mut RuntimeWakerData) };
    waker_data.runtime.wake_task(waker_data.task_id);
    // waker_data is dropped here
}

/// Wake task by reference (don't consume).
fn runtime_waker_wake_by_ref(data: &unsafe Byte) {
    let waker_data = unsafe { &*(data as &RuntimeWakerData) };
    waker_data.runtime.wake_task(waker_data.task_id);
}

/// Drop waker data.
fn runtime_waker_drop(data: &unsafe Byte) {
    let _ = unsafe { Heap.from_raw(data as &mut RuntimeWakerData) };
}

/// VTable for runtime wakers.
const RUNTIME_WAKER_VTABLE: RawWakerVTable = RawWakerVTable {
    clone: runtime_waker_clone,
    wake: runtime_waker_wake,
    wake_by_ref: runtime_waker_wake_by_ref,
    drop: runtime_waker_drop,
};

// =============================================================================
// Current-Runtime Accessor (Native Context System)
// =============================================================================
//

// Removed (2026-04-30): the `pub type AsyncExecutionEnv { id: Int,
// parent_id: Maybe<Int> }` + its sibling `pub fn current_env() ->
// Maybe<&AsyncExecutionEnv>` carried a latent UB landmine — the
// SLOT_RUNTIME TLS slot is populated at `block_on` (line 537) with
// `&AsyncRuntime` (a 13-field struct), but `current_env()` cast it
// to `&AsyncExecutionEnv` (a 2-field unrelated struct). Reading
// any field of the result returned garbage memory.
//

// Verified zero production callers via grep across `core/` +
// `crates/` before removal. The actually-used environment
// accessor lives in `core/runtime/mod.rs::current_env() ->
// &ExecutionEnv` (different namespace, different type — that's
// the one `core/runtime/spawn.vr:823` consumes). Async-side
// callers that need the runtime should use `current_runtime()`
// below, which projects the correct type.

/// Get the current `AsyncRuntime` from the TLS context slot.
///

/// Returns `None` outside an active `block_on` window — async
/// constructs that use this helper must already be running on a
/// runtime, so callers can typically `unwrap_or_else(|| panic!(…))`.
///

/// Use this from timer-bound futures (Sleep, SleepUntil,
/// ExecutorTimeout, RateLimitedStream, etc.) to register a wakeup
/// at a precise deadline:
/// ```verum
/// match current_runtime() {
///  Some(rt) => rt.register_timer(deadline_ns, cx.waker().clone()),
///  None => cx.waker().wake_by_ref(), // fallback: busy-spin
/// }
/// ```
///

/// SAFETY: SLOT_RUNTIME is set in `AsyncRuntime::block_on` before
/// any future polls, and cleared after the main future completes.
/// The `&AsyncRuntime` is valid for the entire `block_on` body —
/// the TLS slot stores the pointer received from `&self`, whose
/// lifetime is tied to the on-stack runtime in `block_on`.
public fn current_runtime() -> Maybe<&AsyncRuntime> {
    match ctx_get(SLOT_RUNTIME) {
        Some(ptr) => Some(unsafe { &*(ptr as &AsyncRuntime) }),
        None => None,
    }
}

/// Execute a closure with a forked context frame.
///

/// The forked environment inherits all contexts from the parent
/// but modifications don't affect the parent.
///

/// # Performance
/// - Fork: ~50ns (memcpy of context array)
public fn with_forked_env<T, F: fn() -> T>(f: F) -> T {
    // Push new context frame (inherits from parent)
    match ctx_push_frame() {
        Ok(_) => {}
        Err(_) => {
            // No context to fork, just run
            return f();
        }
    }

    // Run closure with forked context
    let res = f();

    // Pop context frame (restore parent)
    ctx_pop_frame();

    res
}

// =============================================================================
// Select & Join — Defined in Dedicated Modules
// =============================================================================
//

// Select expression support: see async/select.vr (612 LOC)
//  - select_either(), select_all(), race(), try_first()
//  - timeout(), select_with_default()
//  - Full Future-based implementation, no compiler magic needed
//

// Join combinators: see async/future.vr
//  - Select2, Join2, Join3, join(), join3()
//

// The `select { }` syntax expression is desugared by the compiler into
// calls to select_either/select_all from async/select.vr.
