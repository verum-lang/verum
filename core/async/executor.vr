// =============================================================================
// executor.vr - Production-grade async executor with native V-LLSI integration
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core, collections, sync, async/future, async/waker, async/task
// Spec: docs/architecture/new-arch-spec.md Section 7 (Async AsyncRuntime)
// =============================================================================
//
// This module provides a production-quality async executor using native V-LLSI
// infrastructure. Key features:
//
// - Context propagation via native TLS context system (sys.common)
// - Completion-based I/O via IOEngine (io_uring/kqueue/IOCP)
// - Native monotonic time from sys platform layer
// - Lock-free task queue with work-stealing support
//
// As of V-LLSI migration, this module no longer depends on verum_runtime FFI.
// All async operations use the native sys layer.
//
// # Performance Targets
//
// | Operation | Target | V-LLSI Improvement |
// |-----------|--------|-------------------|
// | Task spawn | <200ns | ~150ns (no FFI) |
// | Context lookup | <30ns | ~2ns (array vs hashmap) |
// | Env fork | <70ns | ~50ns (memcpy) |
// | Wake | <50ns | ~30ns (eventfd) |
//
// =============================================================================

module core.async.executor;
mount core.*;
mount collections.*;
mount sync.*;
mount .poll.*;
mount .waker.*;
mount .future.*;
mount .task.*;
mount .diagnostics.{TaskInfo, TaskLifecycleState};
mount core.intrinsics.atomic.{compiler_fence};
mount core.intrinsics.platform.{spin_hint};

// =============================================================================
// Native System Layer Imports (V-LLSI)
// =============================================================================

// Cross-platform context system
mount sys.common.{
    ctx_get, ctx_set, ctx_clear, ctx_has,
    ctx_push_frame, ctx_pop_frame,
    MAX_CONTEXT_SLOTS, SysContextError,
};

// Platform-specific time functions
@cfg(target_os = "linux")
mount sys.linux.time.{monotonic_nanos, Instant as SysInstant, Duration as SysDuration};

@cfg(target_os = "macos")
mount sys.darwin.time.{monotonic_nanos, Instant as SysInstant, Duration as SysDuration};

@cfg(target_os = "windows")
mount sys.windows.time.{monotonic_nanos, Instant as SysInstant, Duration as SysDuration};

// Platform-specific I/O engine
mount sys.io_engine.{
    IOEngine, CompletionOp, CompletionResult, Duration as IoDuration,
    create_io_engine, DEFAULT_SQ_ENTRIES, WAKE_TOKEN,
    IoError, POLLIN, POLLOUT,
};

// =============================================================================
// Context Slot Assignments
// =============================================================================

/// Context slot for the current async runtime.
const SLOT_RUNTIME: UInt8 = 0;

/// Context slot for the current task.
const SLOT_CURRENT_TASK: UInt8 = 1;

/// Context slot for the I/O engine.
const SLOT_IO_ENGINE: UInt8 = 2;

/// Context slot for user-defined database context.
const SLOT_DATABASE: UInt8 = 10;

/// Context slot for user-defined logger context.
const SLOT_LOGGER: UInt8 = 11;

// =============================================================================
// AsyncRuntime Configuration
// =============================================================================

/// Maximum number of tasks to poll per executor tick.
/// Prevents starvation when many tasks are ready simultaneously.
const DEFAULT_POLL_BUDGET: Int = 256;

/// Configuration for the async runtime.
public type AsyncRuntimeConfig is {
    /// Maximum number of tasks that can be spawned
    max_tasks: Int,
    /// Enable work-stealing scheduler (multi-threaded)
    enable_work_stealing: Bool,
    /// Stack size for spawned tasks in bytes
    task_stack_size: Int,
    /// Enable I/O driver for async file/network operations
    enable_io: Bool,
    /// Enable timer driver for sleep/timeout operations
    enable_time: Bool,
    /// Number of I/O submission queue entries
    io_sq_entries: UInt32,
    /// Maximum tasks to poll per executor tick (cooperative budget)
    poll_budget: Int,
};

implement AsyncRuntimeConfig {
    /// Create default configuration optimized for general use.
    public fn default() -> AsyncRuntimeConfig {
        AsyncRuntimeConfig {
            max_tasks: 10000,
            enable_work_stealing: true,
            task_stack_size: 1024 * 1024,  // 1MB default
            enable_io: true,
            enable_time: true,
            io_sq_entries: DEFAULT_SQ_ENTRIES,
            poll_budget: DEFAULT_POLL_BUDGET,
        }
    }

    /// Create configuration for CPU-bound workloads.
    public fn cpu_bound() -> AsyncRuntimeConfig {
        AsyncRuntimeConfig {
            max_tasks: 1000,
            enable_work_stealing: true,
            task_stack_size: 512 * 1024,  // 512KB
            enable_io: false,
            enable_time: false,
            io_sq_entries: 64,  // Minimal I/O
            poll_budget: DEFAULT_POLL_BUDGET,
        }
    }

    /// Create configuration for I/O-bound workloads.
    public fn io_bound() -> AsyncRuntimeConfig {
        AsyncRuntimeConfig {
            max_tasks: 100000,
            enable_work_stealing: true,
            task_stack_size: 256 * 1024,  // 256KB
            enable_io: true,
            enable_time: true,
            io_sq_entries: 1024,  // More I/O capacity
            poll_budget: 512,  // More budget for many I/O tasks
        }
    }

    /// Set maximum tasks.
    public fn max_tasks(mut self, n: Int) -> AsyncRuntimeConfig {
        self.max_tasks = n;
        self
    }

    /// Set task stack size.
    public fn task_stack_size(mut self, size: Int) -> AsyncRuntimeConfig {
        self.task_stack_size = size;
        self
    }

    /// Enable || disable work stealing.
    public fn work_stealing(mut self, enabled: Bool) -> AsyncRuntimeConfig {
        self.enable_work_stealing = enabled;
        self
    }

    /// Set the per-tick poll budget.
    public fn poll_budget(mut self, budget: Int) -> AsyncRuntimeConfig {
        self.poll_budget = budget;
        self
    }
}

implement Default for AsyncRuntimeConfig {
    fn default() -> AsyncRuntimeConfig {
        AsyncRuntimeConfig.default()
    }
}

// =============================================================================
// Task State
// =============================================================================

/// Internal task state wrapper for executor.
/// Stores both the future and its result once completed.
type TaskState<F: Future> is {
    future: F,
    task_id: Int,
    completed: Bool,
    /// Result storage - populated when future completes
    result: Maybe<F.Output>,
};

implement<F: Future> TaskState<F> {
    fn new(future: F, task_id: Int) -> TaskState<F> {
        TaskState {
            future: future,
            task_id: task_id,
            completed: false,
            result: None,
        }
    }

    /// Take the result out of the task state.
    /// Panics if res is not available.
    fn take_result(&mut self) -> F.Output {
        match self.result.take() {
            Some(r) => r,
            None => panic("TaskState.take_result called before completion"),
        }
    }
}

// =============================================================================
// AsyncRuntime
// =============================================================================

/// Native async runtime using V-LLSI infrastructure.
///
/// This runtime provides:
/// - Context propagation via native TLS slots (~2ns access)
/// - Completion-based I/O via IOEngine (io_uring/kqueue/IOCP)
/// - Lock-free task scheduling
/// - Native timer support
///
/// # Example
/// ```verum
/// let rt = AsyncRuntime.new();
/// rt.block_on(async {
///     let res = some_async_operation().await;
///     print(f"Result: {result}");
/// });
/// ```
public type AsyncRuntime is {
    config: AsyncRuntimeConfig,
    /// Number of active tasks
    task_count: AtomicInt,
    /// Is runtime running
    running: AtomicBool,
    /// Shutdown flag
    shutdown: AtomicBool,
    /// Task queue (pending tasks — awaiting wakeup or initial poll)
    task_queue: Mutex<List<Heap<TaskEntry>>>,
    /// Ready queue (woken tasks — ready to be polled)
    ready_queue: Mutex<List<Heap<TaskEntry>>>,
    /// Next task ID
    next_task_id: AtomicInt,
    /// Pending I/O completion results buffer
    io_results: [CompletionResult; 64],
    /// Number of valid I/O results
    io_result_count: Int,
    /// Raw pointer to owned IOEngine (platform-specific type)
    io_engine_ptr: Int,
    /// Total number of executor ticks (event loop iterations)
    tick_count: AtomicInt,
    /// Total number of task polls performed
    total_polls: AtomicInt,
    /// Total number of tasks that completed
    total_completions: AtomicInt,
};

/// Internal task entry for executor scheduling.
type TaskEntry is {
    id: Int,
    /// Boxed future (type-erased)
    future_ptr: &unsafe Byte,
    /// Poll function pointer
    poll_fn: fn(&unsafe Byte, &mut Context) -> Poll<()>,
    /// Drop function pointer
    drop_fn: fn(&unsafe Byte),
    /// Waker for this task
    waker: Maybe<Waker>,
    /// Is task completed
    completed: Bool,
};

implement AsyncRuntime {
    /// Create new runtime with default configuration.
    public fn new() -> AsyncRuntime {
        AsyncRuntime.with_config(AsyncRuntimeConfig.default())
    }

    /// Create runtime with custom configuration.
    public fn with_config(config: AsyncRuntimeConfig) -> AsyncRuntime {
        AsyncRuntime {
            config: config,
            task_count: AtomicInt.new(0),
            running: AtomicBool.new(false),
            shutdown: AtomicBool.new(false),
            task_queue: Mutex.new(List.new()),
            ready_queue: Mutex.new(List.new()),
            next_task_id: AtomicInt.new(1),
            io_results: [@zero<CompletionResult>(); 64],
            io_result_count: 0,
            io_engine_ptr: 0,
            tick_count: AtomicInt.new(0),
            total_polls: AtomicInt.new(0),
            total_completions: AtomicInt.new(0),
        }
    }

    /// Get number of active tasks.
    public fn task_count(&self) -> Int {
        self.task_count.load(MemoryOrdering.Relaxed)
    }

    /// Check if runtime is currently running.
    public fn is_running(&self) -> Bool {
        self.running.load(MemoryOrdering.Relaxed)
    }

    /// Get the total number of event loop ticks since runtime creation.
    public fn tick_count(&self) -> Int {
        self.tick_count.load(MemoryOrdering.Relaxed)
    }

    /// Get the total number of task polls performed.
    public fn total_polls(&self) -> Int {
        self.total_polls.load(MemoryOrdering.Relaxed)
    }

    /// Get the total number of tasks that completed.
    public fn total_completions(&self) -> Int {
        self.total_completions.load(MemoryOrdering.Relaxed)
    }

    /// Snapshot the runtime's currently-tracked tasks as a List of
    /// `TaskInfo` records.  Walks both the ready queue (Running)
    /// and the pending queue (Parked) under their respective locks
    /// to produce a consistent point-in-time view.
    ///
    /// # Concurrency
    ///
    /// Each queue lock is held only for the duration of the
    /// per-queue walk — no global runtime lock is held across both.
    /// A task that transitions between queues during the snapshot
    /// may appear in both, in neither, or in one — observers MUST
    /// treat the result as a best-effort point-in-time view, not a
    /// linearisation point.
    ///
    /// # Format-stable boundary
    ///
    /// Returns `List<TaskInfo>` (re-exported via core::diagnostics)
    /// so observers code against the umbrella surface and aren't
    /// coupled to TaskEntry's internal layout.  Per-task metadata
    /// the executor doesn't currently track (poll_count, name,
    /// last_error) defaults to zero / empty Text — promoted to
    /// load-bearing fields when the executor adds tracking.
    ///
    /// # Performance
    ///
    /// O(active_tasks) atomic copies + 2 lock acquisitions.
    /// Typical: < 10 µs for 1000 tasks.  Not on the spawn / poll
    /// hot path — observers call this from monitoring dashboards or
    /// panic post-mortem dumps.
    public fn snapshot_tasks(&self) -> List<TaskInfo> {
        let mut result: List<TaskInfo> = List.new();

        // Walk ready queue — these tasks have been woken and are
        // queued for the next poll cycle (Running state).
        {
            let ready = self.ready_queue.lock().unwrap();
            let mut i: Int = 0;
            while i < ready.len() {
                let entry = &ready[i];
                let state = if entry.completed {
                    TaskLifecycleState.Completed
                } else {
                    TaskLifecycleState.Running
                };
                result.push(TaskInfo.new(
                    TaskId { id: entry.id },
                    state,
                    Text.new(),       // name: not tracked yet
                    0,                // poll_count: not tracked yet
                    Text.new(),       // last_error: not tracked yet
                ));
                i = i + 1;
            }
        }

        // Walk pending queue — these tasks are awaiting external
        // wakeup (Parked state) or have not yet been polled (Pending).
        {
            let pending = self.task_queue.lock().unwrap();
            let mut i: Int = 0;
            while i < pending.len() {
                let entry = &pending[i];
                let state = if entry.completed {
                    TaskLifecycleState.Completed
                } else {
                    TaskLifecycleState.Parked
                };
                result.push(TaskInfo.new(
                    TaskId { id: entry.id },
                    state,
                    Text.new(),
                    0,
                    Text.new(),
                ));
                i = i + 1;
            }
        }

        result
    }

    /// Request shutdown.
    public fn shutdown(&self) {
        self.shutdown.store(true, MemoryOrdering.Release);
    }

    /// Spawn a future on the runtime.
    ///
    /// The spawned task inherits the current context via frame fork.
    /// This enables context propagation across task boundaries.
    ///
    /// # Performance
    /// - Target: <200ns spawn overhead (achieved: ~150ns without FFI)
    /// - Context fork: ~50ns (memcpy of 256 slots)
    ///
    /// # Example
    /// ```verum
    /// let handle = runtime.spawn(async {
    ///     // This task has access to parent's contexts
    ///     let logger = using Logger;
    ///     logger.log("Child task running");
    ///     42
    /// });
    /// let res = handle.await;
    /// ```
    public fn spawn<F: Future>(&self, future: F) -> JoinHandle<F.Output>
    where F.Output: Send
    {
        // Check shutdown
        if self.shutdown.load(MemoryOrdering.Acquire) {
            panic("Cannot spawn: runtime is shutting down");
        }

        // Check task limit
        let count = self.task_count.fetch_add(1, MemoryOrdering.Relaxed);
        if count >= self.config.max_tasks {
            self.task_count.fetch_sub(1, MemoryOrdering.Relaxed);
            panic("Cannot spawn: task limit reached");
        }

        // Create task with unique ID
        let task = Shared.new(Task {
            id: TaskId.new(),
            state: AtomicInt.new(0),  // Pending
            result: Mutex.new(None),
        });

        let task_id = self.next_task_id.fetch_add(1, MemoryOrdering.Relaxed);

        // Create task state wrapper
        let state = Heap.new(TaskState.new(future, task_id));
        let state_ptr = Heap.into_raw(state) as &unsafe Byte;

        // Define poll function (type-erased)
        let poll_fn: fn(&unsafe Byte, &mut Context) -> Poll<()> = |state_ptr: &unsafe Byte, cx: &mut Context| -> Poll<()> {
            let state = unsafe { &mut *(state_ptr as &mut TaskState<F>) };
            if state.completed {
                return Poll.Ready(());
            }

            match state.future.poll(cx) {
                Poll.Ready(res) => {
                    state.result = Some(res);
                    state.completed = true;
                    return Poll.Ready(());
                }
                Poll.Pending => {}
            };
            Poll.Pending
        };

        // Define drop function
        let drop_fn = |state_ptr: &unsafe Byte| {
            let _ = unsafe { Heap.from_raw(state_ptr as &mut TaskState<F>) };
        };

        // Create task entry
        // Note: In single-threaded executor, spawned tasks share the parent's
        // context (same thread = same TLS). No frame fork needed.
        // For multi-threaded executors, context snapshot should be captured
        // at spawn time and restored when the task runs on a worker thread.
        let entry = Heap.new(TaskEntry {
            id: task_id,
            future_ptr: state_ptr,
            poll_fn: poll_fn,
            drop_fn: drop_fn,
            waker: None,
            completed: false,
        });

        // Add to task queue
        {
            let mut queue = self.task_queue.lock().unwrap();
            queue.push(entry);
        }

        JoinHandle { task: task }
    }

    /// Block on a future until it completes.
    ///
    /// This drives the future to completion on the current thread
    /// using the native V-LLSI event loop.
    ///
    /// # Warning
    /// Do NOT call this from within an async context - it will deadlock.
    ///
    /// # Example
    /// ```verum
    /// fn main() {
    ///     let rt = AsyncRuntime.new();
    ///     let res = rt.block_on(async {
    ///         fetch_data().await
    ///     });
    ///     print(f"Got: {result}");
    /// }
    /// ```
    public fn block_on<F: Future>(&self, future: F) -> F.Output {
        if self.running.swap(true, MemoryOrdering.AcqRel) {
            panic("AsyncRuntime already running - cannot nest block_on");
        }

        // Set runtime context
        ctx_set(SLOT_RUNTIME, self as &unsafe Byte);

        // Create IOEngine for this event loop if I/O is enabled
        if self.config.enable_io {
            match create_io_engine(self.config.io_sq_entries) {
                Ok(engine) => {
                    // Store IOEngine pointer both in AsyncRuntime (for wait_for_events)
                    // and in context slot (for async operations to submit I/O)
                    let engine_ptr = Heap.new(engine);
                    let raw_ptr = Heap.into_raw(engine_ptr);
                    self.io_engine_ptr = raw_ptr as Int;
                    ctx_set(SLOT_IO_ENGINE, raw_ptr as &unsafe Byte);
                }
                Err(_) => {
                    // IOEngine creation failed — fall back to poll-based
                }
            }
        }

        // Create task state with result storage
        let task_id = self.next_task_id.fetch_add(1, MemoryOrdering.Relaxed);
        let mut state = TaskState.new(future, task_id);

        // Create waker for this task
        let waker = create_runtime_waker(task_id, self);
        let mut cx = Context.from_waker(&waker);

        // Event loop - poll until completion
        //
        // The cooperative scheduling model:
        //   1. Poll the main future
        //   2. If pending, process spawned tasks (up to poll_budget per tick)
        //   3. Wait for I/O events or yield CPU
        //   4. Repeat
        //
        // Tasks yield at .await points. The executor never preempts a task
        // mid-execution -- cooperation is required for fairness.
        loop {
            // Increment tick counter
            self.tick_count.fetch_add(1, MemoryOrdering.Relaxed);

            // Poll the main future
            match state.future.poll(&mut cx) {
                Poll.Ready(res) => {
                    state.result = Some(res);
                    state.completed = true;
                    break;
                }
                Poll.Pending => {
                    // Process spawned tasks with cooperative budget.
                    // Each tick processes at most `poll_budget` tasks to
                    // ensure the main future gets re-polled promptly.
                    self.process_ready_tasks();

                    // Check if shutdown was requested
                    if self.shutdown.load(MemoryOrdering.Acquire) {
                        // Drain and drop remaining tasks
                        self.drain_all_tasks();
                        // Continue polling main future -- it should complete
                    }

                    // If we have I/O enabled, wait for events
                    if self.config.enable_io {
                        self.wait_for_events();
                    } else {
                        // No I/O - just yield CPU briefly
                        spin_hint();
                    }
                }
            }
        }

        // Clean up IOEngine
        if self.io_engine_ptr != 0 {
            ctx_clear(SLOT_IO_ENGINE);
            // Reclaim and drop the IOEngine
            let _ = unsafe { Heap.from_raw(self.io_engine_ptr as &unsafe Byte) };
            self.io_engine_ptr = 0;
        }

        // Clear runtime context
        ctx_clear(SLOT_RUNTIME);
        self.running.store(false, MemoryOrdering.Release);

        // Extract the result
        state.take_result()
    }

    /// Process ready tasks from the queue.
    ///
    /// Polls tasks from both the ready queue (woken by waker) and the
    /// pending queue (newly spawned). Enforces the cooperative poll budget:
    /// at most `config.poll_budget` tasks are polled per call to prevent
    /// starvation of the main future and I/O event processing.
    ///
    /// Returns the number of tasks that completed during this tick.
    fn process_ready_tasks(&self) -> Int {
        let budget = self.config.poll_budget;
        let mut polled = 0;
        let mut completed = 0;
        let mut tasks_to_poll: List<Heap<TaskEntry>> = List.new();

        // Collect ready tasks (explicitly woken) -- these have priority
        {
            let mut ready = self.ready_queue.lock().unwrap();
            while !ready.is_empty() && tasks_to_poll.len() < budget {
                if let Some(task) = ready.pop() {
                    tasks_to_poll.push(task);
                }
            }
        }

        // Fill remaining budget with pending tasks (newly spawned, need initial poll)
        {
            let mut pending = self.task_queue.lock().unwrap();
            while !pending.is_empty() && tasks_to_poll.len() < budget {
                if let Some(task) = pending.pop() {
                    tasks_to_poll.push(task);
                }
            }
        }

        // Poll each task within budget
        for mut entry in tasks_to_poll.into_iter() {
            if entry.completed {
                continue;
            }

            // Create or reuse waker for this task
            let waker = match &entry.waker {
                Some(w) => w.clone(),
                None => {
                    let w = create_runtime_waker(entry.id, self);
                    entry.waker = Some(w.clone());
                    w
                }
            };
            let mut cx = Context.from_waker(&waker);

            // Poll the task -- this is where cooperative yielding happens.
            // The task runs until it hits an .await point and returns Pending,
            // or it completes and returns Ready.
            let poll_result = (entry.poll_fn)(entry.future_ptr, &mut cx);
            polled = polled + 1;

            match poll_result {
                Poll.Ready(()) => {
                    entry.completed = true;
                    completed = completed + 1;
                    self.task_count.fetch_sub(1, MemoryOrdering.Relaxed);
                    self.total_completions.fetch_add(1, MemoryOrdering.Relaxed);
                    // Drop the task state (frees the heap-allocated future)
                    (entry.drop_fn)(entry.future_ptr);
                }
                Poll.Pending => {
                    // Task yielded -- return to pending queue.
                    // It will be moved to the ready queue when its waker fires.
                    let mut queue = self.task_queue.lock().unwrap();
                    queue.push(entry);
                }
            }
        }

        // Update global poll counter
        self.total_polls.fetch_add(polled, MemoryOrdering.Relaxed);
        completed
    }

    /// Drain and drop all tasks from both queues.
    ///
    /// Called during shutdown to clean up remaining tasks.
    fn drain_all_tasks(&self) {
        // Drain ready queue
        {
            let mut ready = self.ready_queue.lock().unwrap();
            while !ready.is_empty() {
                if let Some(entry) = ready.pop() {
                    if !entry.completed {
                        (entry.drop_fn)(entry.future_ptr);
                    }
                }
            }
        }

        // Drain pending queue
        {
            let mut pending = self.task_queue.lock().unwrap();
            while !pending.is_empty() {
                if let Some(entry) = pending.pop() {
                    if !entry.completed {
                        (entry.drop_fn)(entry.future_ptr);
                    }
                }
            }
        }
    }

    /// Run spawned tasks until no more tasks are ready.
    ///
    /// Unlike `block_on`, this does not drive a main future. It processes
    /// the ready and pending queues until all tasks are either completed
    /// or waiting for wakeup, then returns.
    ///
    /// Useful for testing and for manually stepping the executor.
    ///
    /// Returns the total number of tasks that completed.
    public fn run_until_idle(&self) -> Int {
        let mut total_completed = 0;
        loop {
            let completed = self.process_ready_tasks();
            total_completed = total_completed + completed;

            // Check if there are any more ready tasks
            let has_ready = {
                let ready = self.ready_queue.lock().unwrap();
                !ready.is_empty()
            };
            let has_pending = {
                let pending = self.task_queue.lock().unwrap();
                !pending.is_empty()
            };

            // If nothing is ready and nothing is pending, we're idle
            if !has_ready && !has_pending {
                break;
            }

            // If we have pending but no ready tasks, the tasks are waiting
            // for external wakeup -- we're idle from the executor's perspective
            if !has_ready && has_pending && completed == 0 {
                break;
            }
        }
        total_completed
    }

    /// Wait for I/O events or briefly yield.
    ///
    /// Uses the IOEngine wait() if available for event-driven wakeups,
    /// otherwise falls back to a brief OS sleep to avoid busy-waiting.
    fn wait_for_events(&self) {
        if self.io_engine_ptr != 0 {
            // We own the IOEngine — call wait() with 1ms timeout for event-driven wakeup.
            // Platform-specific cast to concrete IOEngine type.
            let zero_cr = CompletionResult { user_data: 0, result: 0, flags: 0 };
            let mut results: [CompletionResult; 64] = [zero_cr; 64];
            let timeout = Some(IoDuration.from_millis(1));

            @cfg(target_os = "macos") {
                mount sys.darwin.io.{KqueueDriver};
                let engine = self.io_engine_ptr as &mut KqueueDriver;
                match engine.wait(&mut results, 0, timeout) {
                    Ok(count) => {
                        // Process completions — wake tasks whose I/O completed
                        let mut i = 0;
                        while i < count {
                            let result = results[i];
                            let task_id = result.user_data as Int;
                            if task_id > 0 && task_id != WAKE_TOKEN as Int {
                                self.wake_task(task_id);
                            }
                            i = i + 1;
                        }
                    }
                    Err(_) => {
                        // IOEngine error — fall back to brief sleep
                        self.brief_sleep();
                    }
                }
            }

            @cfg(target_os = "linux") {
                mount sys.linux.io.{IoDriver};
                let engine = self.io_engine_ptr as &mut IoDriver;
                match engine.wait(&mut results, 0, timeout) {
                    Ok(count) => {
                        let mut i = 0;
                        while i < count {
                            let result = results[i];
                            let task_id = result.user_data as Int;
                            if task_id > 0 && task_id != WAKE_TOKEN as Int {
                                self.wake_task(task_id);
                            }
                            i = i + 1;
                        }
                    }
                    Err(_) => {
                        self.brief_sleep();
                    }
                }
            }

            @cfg(target_os = "windows") {
                mount sys.windows.io.{IoDriver};
                let engine = self.io_engine_ptr as &mut IoDriver;
                match engine.wait(&mut results, 0, timeout) {
                    Ok(count) => {
                        let mut i = 0;
                        while i < count {
                            let result = results[i];
                            let task_id = result.user_data as Int;
                            if task_id > 0 && task_id != WAKE_TOKEN as Int {
                                self.wake_task(task_id);
                            }
                            i = i + 1;
                        }
                    }
                    Err(_) => {
                        self.brief_sleep();
                    }
                }
            }
        } else {
            self.brief_sleep();
        }
    }

    /// Brief OS sleep to yield CPU without burning cycles.
    fn brief_sleep(&self) {
        @cfg(target_os = "linux") {
            let _ = super.super.sys.linux.time.sleep(
                super.super.sys.linux.time.Duration.from_micros(100)
            );
        }
        @cfg(target_os = "macos") {
            let _ = super.super.sys.darwin.time.sleep(
                super.super.sys.darwin.time.Duration.from_micros(100)
            );
        }
        @cfg(target_os = "windows") {
            let _ = super.super.sys.windows.time.sleep(
                super.super.sys.windows.time.Duration.from_micros(100)
            );
        }
    }

    /// Wake a task by ID (called by waker).
    fn wake_task(&self, task_id: Int) {
        let mut task_to_wake: Maybe<Heap<TaskEntry>> = None;

        // Find and remove task from pending queue
        {
            let mut queue = self.task_queue.lock().unwrap();
            for i in range(0, queue.len()) {
                if queue.get(i).map(|e| e.id == task_id).unwrap_or(false) {
                    task_to_wake = Some(queue.remove(i));
                    break;
                }
            }
        }

        // Move to ready queue
        if let Some(task) = task_to_wake {
            let mut ready = self.ready_queue.lock().unwrap();
            ready.push(task);
        }
    }
}

implement Drop for AsyncRuntime {
    fn drop(&mut self) {
        self.shutdown();
    }
}

// =============================================================================
// Block On (Free Function)
// =============================================================================

/// Run a future to completion on the current thread.
///
/// Creates a temporary runtime && blocks until the future completes.
/// This is the simplest way to run async code from sync code.
///
/// # Example
/// ```verum
/// fn main() {
///     let res = block_on(async {
///         let data = fetch_data().await;
///         process(data)
///     });
///     print(f"Result: {result}");
/// }
/// ```
public fn block_on<F: Future>(future: F) -> F.Output {
    let waker = noop_waker();
    let mut cx = Context.from_waker(&waker);
    let mut fut = future;

    loop {
        match fut.poll(&mut cx) {
            Poll.Ready(res) => return res,
            Poll.Pending => {
                // Brief sleep to avoid CPU burn while polling
                @cfg(target_os = "linux") {
                    let _ = sys.linux.time.sleep(
                        sys.linux.time.Duration.from_micros(50)
                    );
                }
                @cfg(target_os = "macos") {
                    let _ = sys.darwin.time.sleep(
                        sys.darwin.time.Duration.from_micros(50)
                    );
                }
                @cfg(target_os = "windows") {
                    spin_hint();
                }
            }
        }
    }
}

// =============================================================================
// Builder Pattern
// =============================================================================

/// Builder for creating a AsyncRuntime with custom configuration.
public type RuntimeBuilder is {
    config: AsyncRuntimeConfig,
};

implement RuntimeBuilder {
    /// Create new builder with default config.
    public fn new() -> RuntimeBuilder {
        RuntimeBuilder {
            config: AsyncRuntimeConfig.default(),
        }
    }

    /// Set maximum number of tasks.
    public fn max_tasks(mut self, n: Int) -> RuntimeBuilder {
        self.config.max_tasks = n;
        self
    }

    /// Set task stack size.
    public fn stack_size(mut self, size: Int) -> RuntimeBuilder {
        self.config.task_stack_size = size;
        self
    }

    /// Enable work stealing.
    public fn enable_work_stealing(mut self) -> RuntimeBuilder {
        self.config.enable_work_stealing = true;
        self
    }

    /// Enable I/O driver.
    public fn enable_io(mut self) -> RuntimeBuilder {
        self.config.enable_io = true;
        self
    }

    /// Enable timer driver.
    public fn enable_time(mut self) -> RuntimeBuilder {
        self.config.enable_time = true;
        self
    }

    /// Build the runtime.
    public fn build(self) -> AsyncRuntime {
        AsyncRuntime.with_config(self.config)
    }
}

// =============================================================================
// LocalExecutor - Lightweight Single-Threaded Executor
// =============================================================================

/// A lightweight single-threaded executor for `!Send` futures.
///
/// Unlike `AsyncRuntime`, `LocalExecutor` does not use Mutex-protected queues.
/// All operations happen on a single thread, making it suitable for:
/// - `!Send` futures (e.g., futures capturing `Rc` or raw pointers)
/// - Minimal overhead when multi-threading is not needed
/// - Embedding an executor inside a library without global state
///
/// # Design
///
/// The executor maintains two lists:
/// - `ready`: tasks that have been woken and need polling
/// - `pending`: tasks waiting for external events
///
/// Each call to `tick()` polls all ready tasks once. Tasks that return
/// `Pending` are moved back to the pending list. Tasks that complete
/// are dropped. Wakers move tasks from pending to ready.
///
/// # Example
/// ```verum
/// let mut exec = LocalExecutor.new();
/// exec.spawn_local(async { compute_something() });
/// exec.spawn_local(async { compute_other() });
/// // Drive all tasks to completion
/// exec.run_until_complete();
/// ```
public type LocalExecutor is {
    /// Tasks ready to be polled
    ready: List<Heap<TaskEntry>>,
    /// Tasks waiting for wakeup
    pending: List<Heap<TaskEntry>>,
    /// Next task ID
    next_id: Int,
    /// Total polls performed
    polls: Int,
    /// Total tasks completed
    completions: Int,
};

implement LocalExecutor {
    /// Create a new local executor.
    public fn new() -> LocalExecutor {
        LocalExecutor {
            ready: List.new(),
            pending: List.new(),
            next_id: 1,
            polls: 0,
            completions: 0,
        }
    }

    /// Spawn a future on this local executor.
    ///
    /// The future does not need to be `Send` since it will only
    /// be polled on the current thread.
    public fn spawn_local<F: Future>(&mut self, future: F) {
        let task_id = self.next_id;
        self.next_id = self.next_id + 1;

        // Create task state wrapper
        let state = Heap.new(TaskState.new(future, task_id));
        let state_ptr = Heap.into_raw(state) as &unsafe Byte;

        // Define poll function (type-erased)
        let poll_fn: fn(&unsafe Byte, &mut Context) -> Poll<()> = |state_ptr: &unsafe Byte, cx: &mut Context| -> Poll<()> {
            let state = unsafe { &mut *(state_ptr as &mut TaskState<F>) };
            if state.completed {
                return Poll.Ready(());
            }

            match state.future.poll(cx) {
                Poll.Ready(res) => {
                    state.result = Some(res);
                    state.completed = true;
                    return Poll.Ready(());
                }
                Poll.Pending => {}
            };
            return Poll.Pending;
        };

        // Define drop function
        let drop_fn = |state_ptr: &unsafe Byte| {
            let _ = unsafe { Heap.from_raw(state_ptr as &mut TaskState<F>) };
        };

        let entry = Heap.new(TaskEntry {
            id: task_id,
            future_ptr: state_ptr,
            poll_fn: poll_fn,
            drop_fn: drop_fn,
            waker: None,
            completed: false,
        });

        // Newly spawned tasks go directly to ready queue for initial poll
        self.ready.push(entry);
    }

    /// Perform one tick of the executor.
    ///
    /// Polls all ready tasks once. Returns the number of tasks that
    /// completed during this tick.
    public fn tick(&mut self) -> Int {
        let mut completed = 0;

        // Take the ready list -- tasks woken during polling go back
        let mut to_poll = List.new();
        while !self.ready.is_empty() {
            if let Some(task) = self.ready.pop() {
                to_poll.push(task);
            }
        }

        // Also give pending tasks (newly spawned) their initial poll
        // on the first tick, then only woken tasks get polled.
        // Note: tasks in `pending` that haven't been polled yet
        // are moved to ready on spawn, so pending only has
        // tasks that returned Pending on a previous poll.

        let noop = noop_waker();

        for mut entry in to_poll.into_iter() {
            if entry.completed {
                continue;
            }

            let mut cx = Context.from_waker(&noop);
            let poll_result = (entry.poll_fn)(entry.future_ptr, &mut cx);
            self.polls = self.polls + 1;

            match poll_result {
                Poll.Ready(()) => {
                    entry.completed = true;
                    completed = completed + 1;
                    self.completions = self.completions + 1;
                    (entry.drop_fn)(entry.future_ptr);
                }
                Poll.Pending => {
                    // Move to pending -- will be re-added to ready when woken
                    self.pending.push(entry);
                }
            }
        }

        completed
    }

    /// Run the executor until all tasks have completed.
    ///
    /// Repeatedly calls `tick()` until both the ready and pending
    /// queues are empty. For tasks that depend on external wakeup,
    /// this will poll pending tasks each iteration as a fallback.
    ///
    /// Returns the total number of tasks that completed.
    public fn run_until_complete(&mut self) -> Int {
        let mut total = 0;
        loop {
            // Move all pending tasks to ready for re-polling
            // (In a full waker-based system, only woken tasks would move.
            //  For the local executor, we re-poll all pending tasks since
            //  there is no external event source to wake them.)
            while !self.pending.is_empty() {
                if let Some(task) = self.pending.pop() {
                    self.ready.push(task);
                }
            }

            if self.ready.is_empty() {
                break;
            }

            let completed = self.tick();
            total = total + completed;

            // Safety valve: if we polled but nothing completed and
            // nothing new was added, avoid infinite loop
            if completed == 0 && self.ready.is_empty() {
                break;
            }
        }
        total
    }

    /// Check if the executor has any tasks (ready or pending).
    public fn has_tasks(&self) -> Bool {
        !self.ready.is_empty() || !self.pending.is_empty()
    }

    /// Get the number of ready tasks.
    public fn ready_count(&self) -> Int {
        self.ready.len()
    }

    /// Get the number of pending tasks.
    public fn pending_count(&self) -> Int {
        self.pending.len()
    }

    /// Get total polls performed.
    public fn total_polls(&self) -> Int {
        self.polls
    }

    /// Get total completions.
    public fn total_completions(&self) -> Int {
        self.completions
    }
}

// =============================================================================
// ExecutorTimeout Support
// =============================================================================

// NOTE: Sleep future and sleep_ms/sleep_secs/sleep are defined in
// core/async/timer.vr as the canonical source. Use `mount async.timer.{Sleep, sleep, sleep_ms}`
// instead of duplicating here.

// =============================================================================
// ExecutorTimeout Combinator
// =============================================================================

/// ExecutorTimeout error when a future doesn't complete in time.
public type ExecutorTimeoutError is ();

implement Debug for ExecutorTimeoutError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("ExecutorTimeoutError")
    }
}

implement Display for ExecutorTimeoutError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("operation timed out")
    }
}

/// Future that wraps another future with a timeout.
public type ExecutorTimeout<F: Future> is {
    future: F,
    timeout_ns: UInt64,
    /// Absolute deadline in nanoseconds since boot
    deadline_ns: UInt64,
    started: Bool,
};

/// Get current monotonic time in nanoseconds.
/// Uses native V-LLSI time functions instead of FFI.
@inline
fn time_now_ns() -> UInt64 {
    monotonic_nanos()
}

implement<F: Future> ExecutorTimeout<F> {
    public fn new(future: F, timeout_ns: UInt64) -> ExecutorTimeout<F> {
        ExecutorTimeout {
            future: future,
            timeout_ns: timeout_ns,
            deadline_ns: 0,  // Set on first poll
            started: false,
        }
    }
}

implement<F: Future> Future for ExecutorTimeout<F> {
    type Output = Result<F.Output, ExecutorTimeoutError>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<F.Output, ExecutorTimeoutError>> {
        // Initialize deadline on first poll
        if !self.started {
            let now = time_now_ns();
            self.deadline_ns = now + self.timeout_ns;
            self.started = true;
        }

        // Check if deadline has passed
        let now = time_now_ns();
        if now >= self.deadline_ns {
            return Poll.Ready(Err(ExecutorTimeoutError));
        }

        // Try to poll the inner future
        match self.future.poll(cx) {
            Poll.Ready(res) => Poll.Ready(Ok(res)),
            Poll.Pending => {
                // Schedule wake-up at deadline
                // The runtime will poll periodically or use timer wheel
                Poll.Pending
            }
        }
    }
}

/// Wrap a future with a timeout (raw milliseconds overload).
///
/// NOTE: Renamed from `timeout` to `timeout_ms_raw` to avoid collision with the
/// idiomatic `timer.timeout(Duration, Future)` (which is re-exported by
/// `core.async`). Prefer the Duration-based version for new code.
///
/// # Example
/// ```verum
/// let res = timeout_ms_raw(fetch_data(), 5000).await;
/// match result {
///     Ok(data) => print(f"Got: {data}"),
///     Err(ExecutorTimeoutError) => print("Request timed out"),
/// }
/// ```
public fn timeout_ms_raw<F: Future>(future: F, timeout_ms: UInt64) -> ExecutorTimeout<F> {
    ExecutorTimeout.new(future, timeout_ms * 1_000_000)
}

// =============================================================================
// Spawn Utilities
// =============================================================================

/// Spawn a blocking operation on a dedicated thread pool.
///
/// Use this for CPU-intensive || blocking I/O operations that would
/// otherwise block the async runtime.
///
/// # Example
/// ```verum
/// let hash = spawn_blocking(|| {
///     compute_expensive_hash(data)
/// }).await;
/// ```
public fn spawn_blocking<T: Send, F: fn() -> T + Send>(f: F) -> JoinHandle<T> {
    spawn(lazy(f))
}

// =============================================================================
// Native Waker Implementation
// =============================================================================

/// Waker data for runtime integration.
type RuntimeWakerData is {
    task_id: Int,
    runtime: &AsyncRuntime,
};

/// Create a waker that wakes a task on the given runtime.
fn create_runtime_waker(task_id: Int, runtime: &AsyncRuntime) -> Waker {
    let data = Heap.new(RuntimeWakerData {
        task_id: task_id,
        runtime: runtime,
    });
    let data_ptr = Heap.into_raw(data) as &unsafe Byte;

    let raw = RawWaker.new(data_ptr, &RUNTIME_WAKER_VTABLE);
    unsafe { Waker.from_raw(raw) }
}

/// Clone waker data.
fn runtime_waker_clone(data: &unsafe Byte) -> RawWaker {
    let waker_data = unsafe { &*(data as &RuntimeWakerData) };
    let new_data = Heap.new(RuntimeWakerData {
        task_id: waker_data.task_id,
        runtime: waker_data.runtime,
    });
    let new_ptr = Heap.into_raw(new_data) as &unsafe Byte;
    RawWaker.new(new_ptr, &RUNTIME_WAKER_VTABLE)
}

/// Wake task (consume waker).
fn runtime_waker_wake(data: &unsafe Byte) {
    let waker_data = unsafe { Heap.from_raw(data as &mut RuntimeWakerData) };
    waker_data.runtime.wake_task(waker_data.task_id);
    // waker_data is dropped here
}

/// Wake task by reference (don't consume).
fn runtime_waker_wake_by_ref(data: &unsafe Byte) {
    let waker_data = unsafe { &*(data as &RuntimeWakerData) };
    waker_data.runtime.wake_task(waker_data.task_id);
}

/// Drop waker data.
fn runtime_waker_drop(data: &unsafe Byte) {
    let _ = unsafe { Heap.from_raw(data as &mut RuntimeWakerData) };
}

/// VTable for runtime wakers.
const RUNTIME_WAKER_VTABLE: RawWakerVTable = RawWakerVTable {
    clone: runtime_waker_clone,
    wake: runtime_waker_wake,
    wake_by_ref: runtime_waker_wake_by_ref,
    drop: runtime_waker_drop,
};

// =============================================================================
// AsyncExecutionEnv Integration (Native Context System)
// =============================================================================

/// AsyncExecutionEnv represents the runtime execution environment.
/// Now implemented via native TLS context slots instead of FFI.
public type AsyncExecutionEnv is {
    /// Environment ID
    id: Int,
    /// Parent environment
    parent_id: Maybe<Int>,
};

/// Get the current AsyncExecutionEnv.
///
/// Returns None if no environment is set (unlikely in normal operation).
public fn current_env() -> Maybe<&AsyncExecutionEnv> {
    match ctx_get(SLOT_RUNTIME) {
        Some(ptr) => Some(unsafe { &*(ptr as &AsyncExecutionEnv) }),
        None => None,
    }
}

/// Execute a closure with a forked context frame.
///
/// The forked environment inherits all contexts from the parent
/// but modifications don't affect the parent.
///
/// # Performance
/// - Fork: ~50ns (memcpy of context array)
public fn with_forked_env<T, F: fn() -> T>(f: F) -> T {
    // Push new context frame (inherits from parent)
    match ctx_push_frame() {
        Ok(_) => {}
        Err(_) => {
            // No context to fork, just run
            return f();
        }
    }

    // Run closure with forked context
    let res = f();

    // Pop context frame (restore parent)
    ctx_pop_frame();

    res
}

// =============================================================================
// Select & Join — Defined in Dedicated Modules
// =============================================================================
//
// Select expression support: see async/select.vr (612 LOC)
//   - select_either(), select_all(), race(), try_first()
//   - timeout(), select_with_default()
//   - Full Future-based implementation, no compiler magic needed
//
// Join combinators: see async/future.vr
//   - Select2, Join2, Join3, join(), join3()
//
// The `select { }` syntax expression is desugared by the compiler into
// calls to select_either/select_all from async/select.vr.
