// =============================================================================
// async/mod.vr - Asynchronous programming module
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core, collections, io, sync
// =============================================================================
//
// This module provides asynchronous programming support:
//
// - poll.vr: Poll state for futures
// - waker.vr: Waker and Context for async runtime
// - future.vr: Future protocol and combinators
// - task.vr: Task spawning and joining
// - channel.vr: Async MPSC channels
// - executor.vr: Simple async executor
// - select.vr: Select expression support
//
// =============================================================================

module async;

// =============================================================================
// Submodules
// =============================================================================

public module poll;
public module waker;
public module future;
public module task;
public module channel;
public module executor;
public module select;
public module stream;
public module nursery;
public module generator;
public module broadcast;
public module intrinsics;

// Timer and interval utilities
public module timer;

// Enhanced spawn with retry and circuit breaker
public module spawn_with;
// Spawn configuration types
public module spawn_config;

// Parallel collection processing
public module parallel;

// Cooperative cancellation tokens
public module cancellation;

// AsyncIterator protocol (for-await loop desugaring target)
public module async_iterator;

// Retry backoff policies (exponential / fibonacci / jittered).
public module backoff;

// Async concurrency-limiter semaphore — cooperative (task-based).
public module semaphore;

// =============================================================================
// Re-exports
// =============================================================================

// From poll
public mount .poll.Poll;
// Note: Ready/Pending are variant constructors - access via Poll.Ready/Poll.Pending

