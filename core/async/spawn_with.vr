// =============================================================================
// async/spawn_with.vr - Enhanced spawn with retry and circuit breaker
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core, spawn_config
// =============================================================================
//
// Provides execute_with_retry for fault-tolerant task execution with
// configurable retry counts and backoff delays.
//
// =============================================================================

module spawn_with;

mount super.spawn_config.{SpawnConfig, RecoveryStrategy, RetryConfig, CircuitBreakerConfig, RestartPolicy};
mount core.intrinsics.runtime.time.{monotonic_nanos};

// =============================================================================
// Retry Execution
// =============================================================================

/// Execute a function with retry policy.
///
/// Calls `f` up to `max_attempts` times. On failure, sleeps for
/// `backoff_ms * attempt_number` milliseconds before retrying.
/// Returns the first successful result or the last error.
///
/// Example:
///   let result = execute_with_retry(|| fetch_data(), 3, 100);
public fn execute_with_retry<T>(
    f: fn() -> Result<T, Text>,
    max_attempts: Int,
    backoff_ms: Int
) -> Result<T, Text> {
    let mut attempts = 0;
    let mut last_error = "";
    while attempts < max_attempts {
        match f() {
            Ok(val) => return Ok(val),
            Err(e) => {
                last_error = e;
                attempts = attempts + 1;
                if attempts < max_attempts {
                    sleep_ms(backoff_ms * attempts);
                }
            }
        }
    }
    Err(last_error)
}

/// Execute with retry using a RetryConfig.
///
/// Uses exponential backoff as configured in the RetryConfig:
/// delay = min(initial_delay_ms * backoff_factor^attempt, max_delay_ms)
public fn execute_with_retry_config<T>(
    f: fn() -> Result<T, Text>,
    config: RetryConfig
) -> Result<T, Text> {
    let mut attempts = 0;
    let mut delay = config.initial_delay_ms;
    let mut last_error = "";
    while attempts < config.max_retries {
        match f() {
            Ok(val) => return Ok(val),
            Err(e) => {
                last_error = e;
                attempts = attempts + 1;
                if attempts < config.max_retries {
                    sleep_ms(delay);
                    delay = delay * config.backoff_factor;
                    if delay > config.max_delay_ms {
                        delay = config.max_delay_ms;
                    }
                }
            }
        }
    }
    Err(last_error)
}

// =============================================================================
// Circuit Breaker
// =============================================================================

/// State of a circuit breaker.
public type CircuitState is
    Closed
    | Open
    | HalfOpen;

/// A circuit breaker that prevents repeated calls to a failing service.
///
/// - Closed: normal operation, failures counted
/// - Open: calls rejected immediately after failure_threshold reached
/// - HalfOpen: after reset_timeout, allow limited trial calls
public type CircuitBreaker is {
    config: CircuitBreakerConfig,
    state: CircuitState,
    failure_count: Int,
    last_failure_time_ms: Int,
};

implement CircuitBreaker {
    /// Create a new circuit breaker with the given config.
    public fn new(config: CircuitBreakerConfig) -> CircuitBreaker {
        CircuitBreaker {
            config: config,
            state: Closed,
            failure_count: 0,
            last_failure_time_ms: 0,
        }
    }

    /// Create a circuit breaker with default settings.
    public fn with_defaults() -> CircuitBreaker {
        CircuitBreaker.new(CircuitBreakerConfig.default())
    }

    /// Record a successful call — resets failure count and closes circuit.
    public fn record_success(&mut self) {
        self.failure_count = 0;
        self.state = Closed;
    }

    /// Record a failed call — increments failure count, may open circuit.
    /// Updates `last_failure_time_ms` so the Open→HalfOpen transition
    /// in `is_call_allowed` has a baseline to measure reset_timeout
    /// against. Earlier impl never wrote this field, so the breaker
    /// stayed Open forever once tripped — defeated the entire purpose
    /// of the circuit-breaker pattern.
    public fn record_failure(&mut self) {
        self.failure_count = self.failure_count + 1;
        self.last_failure_time_ms = (monotonic_nanos() / 1_000_000_u64) as Int;
        if self.failure_count >= self.config.failure_threshold {
            self.state = Open;
        }
    }

    /// Check whether a call is currently allowed.
    ///
    /// Drives the Open → HalfOpen transition based on the
    /// `reset_timeout_ms` elapsed since the last recorded failure —
    /// exactly the contract the docstring promises. Takes `&mut self`
    /// because the time-based transition is a state mutation; an
    /// `&self` view of the breaker would be a snapshot that's already
    /// stale by the time the caller acts on it.
    ///
    /// Without this transition the breaker was stuck Open forever
    /// once tripped (a real outage) — a dishonest implementation of
    /// the documented "after reset_timeout, allow limited trial
    /// calls" semantics.
    public fn is_call_allowed(&mut self) -> Bool {
        match self.state {
            Closed => true,
            HalfOpen => true,
            Open => {
                let now_ms = (monotonic_nanos() / 1_000_000_u64) as Int;
                if now_ms - self.last_failure_time_ms >= self.config.reset_timeout_ms {
                    // Cool-down elapsed — admit limited trial traffic.
                    self.state = HalfOpen;
                    true
                } else {
                    false
                }
            },
        }
    }
}
