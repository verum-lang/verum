// =============================================================================
// async/select.vr - Async Selection Combinators
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core, async/future, async/poll
// =============================================================================
//
// This module provides selection combinators for async operations:
//
// - select: Wait for the first of multiple futures to complete
// - select_all: Wait for any of a collection of futures
// - race: Race two futures, cancel the loser
// - join: Wait for all futures to complete
// - join_all: Wait for a collection of futures
// - timeout: Add timeout to a future
//
// These combinators enable structured concurrency patterns and efficient
// multiplexing of async operations.
//
// =============================================================================

module select;

mount core.{Maybe, Result, List};
mount super.future.{Future, FutureExt};
mount super.poll.Poll;
mount super.waker.Context;
mount time.{Duration, Instant};

// =============================================================================
// Select2 - Select between two futures
// =============================================================================

/// Result of a select operation between two futures.
///
/// Indicates which future completed first and its result.
public type Either<A, B> is
    | Left(A)
    | Right(B);

/// Select between two futures, returning when the first completes.
///
/// The non-completing future is NOT cancelled automatically.
/// Use `race` if you want automatic cancellation.
///
/// # Example
///
/// ```verum
/// let res = select(
///     async { fetch_from_cache().await },
///     async { fetch_from_network().await }
/// ).await;
///
/// match result {
///     Either.Left(cached) => println("Got from cache"),
///     Either.Right(network) => println("Got from network"),
/// }
/// ```
public async fn select_either<A, B, FA: Future<Output>, FB: Future<Output>>(
    fut_a: FA,
    fut_b: FB,
) -> Either<A, B> {
    SelectPair {
        fut_a: Some(fut_a),
        fut_b: Some(fut_b),
    }.await
}

/// Future that completes when either of two futures completes.
type SelectPair<A, B, FA: Future<Output>, FB: Future<Output>> is {
    fut_a: Maybe<FA>,
    fut_b: Maybe<FB>,
};

implement<A, B, FA: Future<Output>, FB: Future<Output>> Future for SelectPair<A, B, FA, FB> {
    type Output = Either<A, B>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Either<A, B>> {
        // Poll first future
        if let Some(ref mut a) = self.fut_a {
            match a.poll(cx) {
                Poll.Ready(val) => {
                    self.fut_a = None;
                    return Poll.Ready(Either.Left(val));
                }
                Poll.Pending => {}
            }
        }

        // Poll second future
        if let Some(ref mut b) = self.fut_b {
            match b.poll(cx) {
                Poll.Ready(val) => {
                    self.fut_b = None;
                    return Poll.Ready(Either.Right(val));
                }
                Poll.Pending => {}
            }
        }

        Poll.Pending
    }
}

// =============================================================================
// Race - Race with cancellation
// =============================================================================

/// Race two futures, cancelling the loser.
///
/// Unlike `select`, `race` will drop the losing future when the winner
/// completes. This is useful when the losing future's result is not needed.
///
/// # Example
///
/// ```verum
/// // Race cache lookup against network fetch
/// let data = race(
///     async { cache.get(key).await },
///     async { network.fetch(key).await }
/// ).await;
/// ```
public async fn race<T, FA: Future<Output>, FB: Future<Output>>(
    fut_a: FA,
    fut_b: FB,
) -> T {
    match select_either(fut_a, fut_b).await {
        Either.Left(a) => a,
        Either.Right(b) => b,
    }
}

// =============================================================================
// Select All - Select from collection
// =============================================================================

/// Errors raised by selection combinators.
///
/// These map cases that previously panicked (empty input list, exhausted
/// fallback chain) into typed error values so callers can handle them with
/// `?` instead of crashing the task.
public type SelectError is
    /// `select_all` / `race_all` / `try_first` was given an empty list.
    /// There is no future to wait on, so the call returns this error
    /// synchronously (no Pending hang, no panic).
    | EmptyInput;

implement Display for SelectError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            EmptyInput => f.write_str("select: empty input list"),
        }
    }
}

implement Debug for SelectError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            EmptyInput => f.write_str("EmptyInput"),
        }
    }
}

implement Eq for SelectError {
    fn eq(&self, other: &SelectError) -> Bool {
        match (self, other) {
            (EmptyInput, EmptyInput) => true,
        }
    }
}

/// Result of select_all operation.
public type SelectAllResult<T> is {
    /// The completed value
    value: T,
    /// Index of the future that completed
    index: Int,
    /// Remaining uncompleted futures
    remaining: List<T>,
};

/// Select from a collection of futures, completing when any one finishes.
///
/// Returns the result along with the index && remaining futures.
/// Returns `Err(SelectError.EmptyInput)` when the input list is empty
/// (instead of panicking, which the previous implementation did).
///
/// # Example
///
/// ```verum
/// let futures = List.from([
///     fetch_server_1(),
///     fetch_server_2(),
///     fetch_server_3(),
/// ]);
///
/// let res = select_all(futures).await?;
/// println(f"Server {res.index} responded first");
/// ```
public async fn select_all<T, F: Future<Output>>(
    mut futures: List<F>,
) -> Result<SelectAllResult<T>, SelectError> {
    SelectAll { futures: futures }.await
}

type SelectAll<T, F: Future<Output>> is {
    futures: List<F>,
};

implement<T, F: Future<Output>> Future for SelectAll<T, F> {
    type Output = Result<SelectAllResult<T>, SelectError>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<SelectAllResult<T>, SelectError>> {
        // Empty input → synchronous error (do this first so the for-loop
        // bound check below is a pure "all-pending" signal).
        if self.futures.is_empty() {
            return Poll.Ready(Err(SelectError.EmptyInput));
        }

        for i in 0..self.futures.len() {
            match self.futures[i].poll(cx) {
                Poll.Ready(val) => {
                    // Remove the completed future
                    let completed = self.futures.remove(i);
                    let remaining = self.futures.clone();

                    return Poll.Ready(Ok(SelectAllResult {
                        value: val,
                        index: i,
                        remaining: remaining,
                    }));
                }
                Poll.Pending => {}
            }
        }

        Poll.Pending
    }
}

// =============================================================================
// Join - Wait for all
// =============================================================================

/// Wait for both futures to complete, returning both results.
///
/// # Example
///
/// ```verum
/// let (user, posts) = join(
///     fetch_user(user_id),
///     fetch_posts(user_id),
/// ).await;
/// ```
public async fn join<A, B, FA: Future<Output>, FB: Future<Output>>(
    fut_a: FA,
    fut_b: FB,
) -> (A, B) {
    JoinPair {
        fut_a: Some(fut_a),
        fut_b: Some(fut_b),
        result_a: None,
        result_b: None,
    }.await
}

type JoinPair<A, B, FA: Future<Output>, FB: Future<Output>> is {
    fut_a: Maybe<FA>,
    fut_b: Maybe<FB>,
    result_a: Maybe<A>,
    result_b: Maybe<B>,
};

implement<A, B, FA: Future<Output>, FB: Future<Output>> Future for JoinPair<A, B, FA, FB> {
    type Output = (A, B);

    fn poll(&mut self, cx: &mut Context) -> Poll<(A, B)> {
        // Poll first future if !done
        if self.result_a.is_none() {
            if let Some(ref mut a) = self.fut_a {
                match a.poll(cx) {
                    Poll.Ready(val) => {
                        self.result_a = Some(val);
                        self.fut_a = None;
                    }
                    Poll.Pending => {}
                }
            }
        }

        // Poll second future if !done
        if self.result_b.is_none() {
            if let Some(ref mut b) = self.fut_b {
                match b.poll(cx) {
                    Poll.Ready(val) => {
                        self.result_b = Some(val);
                        self.fut_b = None;
                    }
                    Poll.Pending => {}
                }
            }
        }

        // Check if both done
        if self.result_a.is_some() && self.result_b.is_some() {
            let a = self.result_a.take()
                .expect("Join: result_a is_some by guard above");
            let b = self.result_b.take()
                .expect("Join: result_b is_some by guard above");
            Poll.Ready((a, b))
        } else {
            Poll.Pending
        }
    }
}

/// Wait for three futures to complete.
public async fn join3<A, B, C, FA: Future<Output>, FB: Future<Output>, FC: Future<Output>>(
    fut_a: FA,
    fut_b: FB,
    fut_c: FC,
) -> (A, B, C) {
    // First join A and B
    let ab: (A, B) = join(fut_a, fut_b).await;
    // Then wait for C
    let c: C = fut_c.await;
    (ab.0, ab.1, c)
}

/// Wait for four futures to complete.
public async fn join4<A, B, C, D,
    FA: Future<Output>,
    FB: Future<Output>,
    FC: Future<Output>,
    FD: Future<Output>>(
    fut_a: FA,
    fut_b: FB,
    fut_c: FC,
    fut_d: FD,
) -> (A, B, C, D) {
    // Join pairs concurrently
    let ab: (A, B) = join(fut_a, fut_b).await;
    let cd: (C, D) = join(fut_c, fut_d).await;
    (ab.0, ab.1, cd.0, cd.1)
}

/// Wait for five futures to complete.
public async fn join5<A, B, C, D, E,
    FA: Future<Output>,
    FB: Future<Output>,
    FC: Future<Output>,
    FD: Future<Output>,
    FE: Future<Output>>(
    fut_a: FA,
    fut_b: FB,
    fut_c: FC,
    fut_d: FD,
    fut_e: FE,
) -> (A, B, C, D, E) {
    let abcd: (A, B, C, D) = join4(fut_a, fut_b, fut_c, fut_d).await;
    let e: E = fut_e.await;
    (abcd.0, abcd.1, abcd.2, abcd.3, e)
}

/// Race three futures — returns the first one to complete.
public async fn race3<T,
    FA: Future<Output = T>,
    FB: Future<Output = T>,
    FC: Future<Output = T>>(
    fut_a: FA,
    fut_b: FB,
    fut_c: FC,
) -> T {
    // Pair-wise: race(a, race(b, c))
    race(fut_a, race(fut_b, fut_c)).await
}

/// Race two futures — alias for `race` to match the `race{N}` naming family.
public async fn race2<T,
    FA: Future<Output = T>,
    FB: Future<Output = T>>(
    fut_a: FA,
    fut_b: FB,
) -> T {
    race(fut_a, fut_b).await
}

/// Wait for all fallible futures in a collection; short-circuit on first error.
public async fn try_join_all<T, E, F: Future<Output = Result<T, E>>>(
    futures: List<F>,
) -> Result<List<T>, E> {
    let results = join_all(futures).await;
    let mut unwrapped: List<T> = List.new();
    for r in results.into_iter() {
        match r {
            Ok(v) => unwrapped.push(v),
            Err(e) => return Err(e),
        }
    }
    Ok(unwrapped)
}

/// Join two fallible futures. Short-circuits on first Err.
public async fn try_join<A, B, E,
    FA: Future<Output = Result<A, E>>,
    FB: Future<Output = Result<B, E>>>(
    fut_a: FA,
    fut_b: FB,
) -> Result<(A, B), E> {
    let a = fut_a.await?;
    let b = fut_b.await?;
    Ok((a, b))
}

/// Join three fallible futures. Short-circuits on first Err.
public async fn try_join3<A, B, C, E,
    FA: Future<Output = Result<A, E>>,
    FB: Future<Output = Result<B, E>>,
    FC: Future<Output = Result<C, E>>>(
    fut_a: FA,
    fut_b: FB,
    fut_c: FC,
) -> Result<(A, B, C), E> {
    let a = fut_a.await?;
    let b = fut_b.await?;
    let c = fut_c.await?;
    Ok((a, b, c))
}

/// Race a collection of futures — returns the first one to complete.
/// Alias for `select_all` that drops the index and the remaining futures.
///
/// Returns `Err(SelectError.EmptyInput)` when the input list is empty
/// (propagated from `select_all`).
public async fn race_all<T, F: Future<Output = T>>(
    futures: List<F>,
) -> Result<T, SelectError> {
    let r = select_all(futures).await?;
    Ok(r.value)
}

/// Wait for all futures and return their results; does NOT short-circuit
/// on error. Each element is the `Future`'s final output (typically a
/// `Result`), preserving the per-future outcome.
public async fn join_all_settled<T, F: Future<Output = T>>(
    futures: List<F>,
) -> List<T> {
    join_all(futures).await
}

// =============================================================================
// Join All - Wait for collection
// =============================================================================

/// Wait for all futures in a collection to complete.
///
/// Returns results in the same order as the input futures.
///
/// # Example
///
/// ```verum
/// let futures = urls.iter().map(|url| fetch(url)).collect();
/// let ress = join_all(futures).await;
/// ```
public async fn join_all<T, F: Future<Output>>(
    futures: List<F>,
) -> List<T> {
    JoinAll {
        futures: futures.iter().map(|f| Some(f)).collect(),
        results: List.with_capacity(futures.len()),
        completed: 0,
    }.await
}

type JoinAll<T, F: Future<Output>> is {
    futures: List<Maybe<F>>,
    results: List<Maybe<T>>,
    completed: Int,
};

implement<T, F: Future<Output>> Future for JoinAll<T, F> {
    type Output = List<T>;

    fn poll(&mut self, cx: &mut Context) -> Poll<List<T>> {
        // Initialize results if needed
        while self.results.len() < self.futures.len() {
            self.results.push(None);
        }

        // Poll all pending futures
        for i in 0..self.futures.len() {
            if self.results[i].is_none() {
                if let Some(ref mut fut) = self.futures[i] {
                    match fut.poll(cx) {
                        Poll.Ready(val) => {
                            self.results[i] = Some(val);
                            self.futures[i] = None;
                            self.completed = self.completed + 1;
                        }
                        Poll.Pending => {}
                    }
                }
            }
        }

        // Check if all done
        if self.completed == self.futures.len() {
            // Every result slot is Some by the time `completed`
            // counts up to `futures.len()` — each future-poll branch
            // above sets exactly one result slot before incrementing
            // `completed`.
            let ress = self.results.iter()
                .map(|opt| opt.take()
                    .expect("JoinAll: every result slot is_some when completed == futures.len()"))
                .collect();
            Poll.Ready(ress)
        } else {
            Poll.Pending
        }
    }
}

// =============================================================================
// Timeout
// =============================================================================

/// Error returned when a timeout expires.
public type SelectTimeoutError is ();

implement Display for SelectTimeoutError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("select: timeout")
    }
}

implement Debug for SelectTimeoutError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("SelectTimeoutError")
    }
}

implement Eq for SelectTimeoutError {
    fn eq(&self, _other: &SelectTimeoutError) -> Bool { true }
}

/// Add a timeout to a future.
///
/// If the future doesn't complete within the timeout, returns SelectTimeoutError.
///
/// # Example
///
/// ```verum
/// match timeout(Duration.from_secs(5), slow_operation()).await {
///     Ok(res) => println(f"Got: {result}"),
///     Err(_) => println("Operation timed out"),
/// }
/// ```
public async fn timeout<T, F: Future<Output>>(
    duration: Duration,
    future: F,
) -> Result<T, SelectTimeoutError> {
    let now = Instant.now();
    let deadline = now.checked_add(duration).unwrap_or(now);
    SelectTimeout {
        future: Some(future),
        deadline: deadline,
    }.await
}

type SelectTimeout<T, F: Future<Output>> is {
    future: Maybe<F>,
    deadline: Instant,
};

implement<T, F: Future<Output>> Future for SelectTimeout<T, F> {
    type Output = Result<T, SelectTimeoutError>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<T, SelectTimeoutError>> {
        // Check timeout first
        if Instant.now() >= self.deadline {
            return Poll.Ready(Err(SelectTimeoutError()));
        }

        // Poll the inner future
        if let Some(ref mut fut) = self.future {
            match fut.poll(cx) {
                Poll.Ready(val) => {
                    self.future = None;
                    return Poll.Ready(Ok(val));
                }
                Poll.Pending => {}
            }
        }

        // Register wake at deadline
        // Note: Real implementation would use timer registration
        Poll.Pending
    }
}

// =============================================================================
// First Successful
// =============================================================================

/// Try futures in order, returning the first successful result.
///
/// Unlike `race`, this tries futures sequentially && returns on first success.
///
/// Returns:
/// - `Ok(value)` — first future that succeeded
/// - `Err(LastError(e))` — every future errored; `e` is the last seen
///   error (preserves the existing per-future error type `E`)
/// - `Err(EmptyInput)` — input list was empty (previously panicked)
///
/// # Example
///
/// ```verum
/// let res = try_first(List.from([
///     || fetch_primary().await,
///     || fetch_secondary().await,
///     || fetch_fallback().await,
/// ])).await?;
/// ```
public type TryFirstError<E> is
    | EmptyInput
    | LastError(E);

public async fn try_first<T, E, F: Future<Output = Result<T, E>>>(
    futures: List<F>,
) -> Result<T, TryFirstError<E>> {
    TryFirst {
        futures: futures,
        current: 0,
    }.await
}

type TryFirst<T, E, F: Future<Output = Result<T, E>>> is {
    futures: List<F>,
    current: Int,
};

implement<T, E, F: Future<Output = Result<T, E>>> Future for TryFirst<T, E, F> {
    type Output = Result<T, TryFirstError<E>>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<T, TryFirstError<E>>> {
        // Synchronous EmptyInput: covers both the initial-empty-list
        // case and the post-drain case (current ≥ len with len == 0).
        if self.futures.is_empty() {
            return Poll.Ready(Err(TryFirstError.EmptyInput));
        }

        while self.current < self.futures.len() {
            match self.futures[self.current].poll(cx) {
                Poll.Ready(Ok(val)) => {
                    return Poll.Ready(Ok(val));
                }
                Poll.Ready(Err(e)) => {
                    self.current = self.current + 1;
                    if self.current >= self.futures.len() {
                        return Poll.Ready(Err(TryFirstError.LastError(e)));
                    }
                    // Continue to next future
                }
                Poll.Pending => {
                    return Poll.Pending;
                }
                // Exhaustiveness shim: Verum's checker can't prove
                // that `Result<T, E>` only inhabits Ok / Err, so this
                // arm is required even though it is provably dead by
                // construction.  We yield Pending instead of panicking
                // — if the unreachable ever fires, the executor will
                // simply re-poll, and the deadlock-detector surfaces
                // any hang.
                Poll.Ready(_) => return Poll.Pending,
            }
        }

        // Loop exit: only reachable when `current ≥ len` AND the list
        // is non-empty (the empty-list path returned earlier).  This
        // happens after every future errored: the final iteration
        // returned `LastError(e)`, so we can never actually reach
        // here.  Be defensive anyway with EmptyInput rather than a
        // panic — a hostile mutator that cleared `futures` mid-poll
        // is the only way to land here.
        Poll.Ready(Err(TryFirstError.EmptyInput))
    }
}

// =============================================================================
// Yield Now
// =============================================================================

/// Yield control back to the executor.
///
/// This allows other tasks to run before this task continues.
///
/// # Example
///
/// ```verum
/// for i in 0..1000000 {
///     // Yield periodically to avoid starving other tasks
///     if i % 1000 == 0 {
///         yield_now().await;
///     }
///     process(i);
/// }
/// ```
public async fn yield_now() {
    SelectYieldNow { yielded: false }.await
}

type SelectYieldNow is {
    yielded: Bool,
};

implement Future for SelectYieldNow {
    type Output = ();

    fn poll(&mut self, cx: &mut Context) -> Poll<()> {
        if self.yielded {
            Poll.Ready(())
        } else {
            self.yielded = true;
            cx.waker().wake_by_ref();
            Poll.Pending
        }
    }
}

// =============================================================================
// Pending Forever
// =============================================================================

/// A future that never completes.
///
/// Useful as a placeholder || for testing.
public fn pending_forever<T>() -> NeverFuture<T> {
    NeverFuture { _marker: () }
}

/// A future that never resolves.
type NeverFuture<T> is {
    _marker: (),
};

implement<T> Future for NeverFuture<T> {
    type Output = T;

    fn poll(&mut self, _cx: &mut Context) -> Poll<T> {
        Poll.Pending
    }
}

// =============================================================================
// Ready
// =============================================================================

/// Create a future that immediately returns a value.
///
/// # Example
///
/// ```verum
/// let fut = ready(42);
/// assert_eq(fut.await, 42);
/// ```
public fn ready<T>(value: T) -> SelectReadyFuture<T> {
    SelectReadyFuture { value: Some(value) }
}

public type SelectReadyFuture<T> is {
    value: Maybe<T>,
};

implement<T> Future for SelectReadyFuture<T> {
    type Output = T;

    /// Polls return `Ready(v)` exactly once; subsequent polls return
    /// `Pending` indefinitely (FusedFuture semantics).  This matches
    /// the convention used by `core/async/future.rs`'s NeverFuture
    /// and avoids panicking on the documented contract violation
    /// "don't poll after Ready" — instead the contract violation
    /// degrades to a clean hang that the executor's deadlock
    /// detector can surface.
    fn poll(&mut self, _cx: &mut Context) -> Poll<T> {
        match self.value.take() {
            Some(v) => Poll.Ready(v),
            None => Poll.Pending,
        }
    }
}

// =============================================================================
// Tests
// =============================================================================

@test
fn test_ready_future() {
    let fut = ready(42);
    // Would need executor to test properly
}

@test
fn test_either() {
    let left: Either<Int, Text> = Either.Left(42);
    let right: Either<Int, Text> = Either.Right("hello");

    match left {
        Either.Left(n) => assert_eq(n, 42),
        Either.Right(_) => panic("expected Left"),
    }

    match right {
        Either.Left(_) => panic("expected Right"),
        Either.Right(s) => assert_eq(s, "hello"),
    }
}
