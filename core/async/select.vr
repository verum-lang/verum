// Tests
// =============================================================================

@test
fn test_ready_future() {
    let fut = ready(42);
    // Would need executor to test properly
}

@test
fn test_either() {
    let left: Either<Int, Text> = Either.Left(42);
    let right: Either<Int, Text> = Either.Right("hello");

    match left {
        Either.Left(n) => assert_eq(n, 42),
        Either.Right(_) => panic("expected Left"),
    }

    match right {
        Either.Left(_) => panic("expected Right"),
        Either.Right(s) => assert_eq(s, "hello"),
    }
}
