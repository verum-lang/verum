// =============================================================================
// channel.vr - Async MPSC channels
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core, collections, sync
// =============================================================================
//
// Multi-producer, single-consumer channels for message passing.
// Provides both bounded and unbounded variants.
//
// =============================================================================

module core.async.channel;
mount core.*;
mount collections.*;
mount sync.*;
mount .poll.*;
mount .waker.*;
mount .future.*;
mount .stream.{Stream, StreamNext};
mount .async_iterator.{AsyncIterator};
mount .cancellation.{CancellationToken, CancellationError, CancelReason};

// Cross-platform futex for blocking recv
@cfg(target_os = "linux")
mount sys.linux.thread.{
    futex_wait as sys_futex_wait,
    futex_wake as sys_futex_wake,
};

@cfg(target_os = "macos")
mount sys.darwin.thread.{
    futex_wait as sys_futex_wait,
    futex_wake as sys_futex_wake,
};

// Synchronous sleep for the bounded-channel send/recv timeout
// busy-loops below.  Imported under the historic `sleep_millis` alias
// since that's the name the busy-loop sites use.
mount sys.time_ops.{sleep_ms as sleep_millis};

@cfg(target_os = "windows")
mount sys.windows.thread.{
    futex_wait as sys_futex_wait,
    futex_wake as sys_futex_wake,
};

// =============================================================================
// Channel<T> - Bounded channel for interpreter/AOT
// =============================================================================
//
// Simple bounded channel with ring buffer storage.
// In the interpreter/AOT, Channel.new(cap) is intercepted by the C runtime
// (verum_chan_new), and send/recv dispatch through CallM to C builtins.
//
// This implementation provides correct behavior when the stdlib is compiled
// natively (self-hosting), using a ring buffer with futex-based blocking.
//
// Layout: [len, cap, head, tail, buffer_ptr, closed, notify_seq]
//
public type Channel<T> is {
    len: AtomicInt,
    cap: Int,
    head: Int,
    tail: Int,
    data: &unsafe T,
    closed: AtomicInt,
    /// Notification counter for futex-based blocking
    notify_seq: AtomicInt,
    /// Lock for ring buffer mutations
    lock: FutexLock,
};

implement Channel<T> {
    public fn new(capacity: Int) -> Channel<T> {
        assert(capacity > 0, "Channel capacity must be positive");
        // Allocate backing ring buffer sized by T — not hardcoded to 8 bytes,
        // otherwise any T larger than an Int would overflow the buffer.
        let buf_size = capacity * T.size;
        let buf = alloc(buf_size) as &unsafe T;
        Channel {
            len: AtomicInt.new(0),
            cap: capacity,
            head: 0,
            tail: 0,
            data: buf,
            closed: AtomicInt.new(0),
            notify_seq: AtomicInt.new(0),
            lock: FutexLock.new(),
        }
    }

    /// Send a value into the channel. Returns false if closed or full.
    public fn send(&mut self, value: T) -> Bool {
        if self.closed.load(MemoryOrdering.Acquire) != 0 { return false; }

        self.lock.lock();
        if self.len.load(MemoryOrdering.Relaxed) >= self.cap {
            self.lock.unlock();
            return false;
        }
        // Store value at tail position in ring buffer
        let offset = self.tail * T.size;
        let dst = (self.data as Int + offset) as &mut T;
        *dst = value;
        self.tail = (self.tail + 1) % self.cap;
        self.len.fetch_add(1, MemoryOrdering.Release);
        self.lock.unlock();

        // Wake blocked receiver
        self.notify_seq.fetch_add(1, MemoryOrdering.Release);
        let _ = sys_futex_wake(&self.notify_seq.value, 1);
        true
    }

    /// Receive a value from the channel, blocking via futex if empty.
    public fn recv(&mut self) -> Maybe<T> {
        loop {
            let seq = self.notify_seq.load(MemoryOrdering.Acquire);

            self.lock.lock();
            if self.len.load(MemoryOrdering.Relaxed) > 0 {
                // Read value from head position
                let offset = self.head * T.size;
                let src = (self.data as Int + offset) as &T;
                let value = *src;
                self.head = (self.head + 1) % self.cap;
                self.len.fetch_sub(1, MemoryOrdering.Release);
                self.lock.unlock();
                return Some(value);
            }
            self.lock.unlock();

            // Check if closed
            if self.closed.load(MemoryOrdering.Acquire) != 0 {
                return None;
            }

            // Block until sender wakes us
            let _ = sys_futex_wait(&self.notify_seq.value, seq, None);
        }
    }

    /// Try to receive without blocking.
    public fn try_recv(&mut self) -> Maybe<T> {
        self.lock.lock();
        if self.len.load(MemoryOrdering.Relaxed) > 0 {
            let offset = self.head * T.size;
            let src = (self.data as Int + offset) as &T;
            let value = *src;
            self.head = (self.head + 1) % self.cap;
            self.len.fetch_sub(1, MemoryOrdering.Release);
            self.lock.unlock();
            return Some(value);
        }
        self.lock.unlock();
        None
    }

    public fn close(&mut self) {
        self.closed.store(1, MemoryOrdering.Release);
        // Wake any blocked receiver
        self.notify_seq.fetch_add(1, MemoryOrdering.Release);
        let _ = sys_futex_wake(&self.notify_seq.value, 1);
    }

    public fn is_closed(&self) -> Bool {
        self.closed.load(MemoryOrdering.Relaxed) != 0
    }

    public fn len(&self) -> Int {
        self.len.load(MemoryOrdering.Relaxed)
    }

    public fn is_empty(&self) -> Bool {
        self.len.load(MemoryOrdering.Relaxed) == 0
    }

    public fn is_full(&self) -> Bool {
        self.len.load(MemoryOrdering.Relaxed) >= self.cap
    }

    public fn capacity(&self) -> Int {
        self.cap
    }
}

// =============================================================================
// Channel Core (Internal MPSC implementation)
// =============================================================================

// Shared state for channel.
type ChannelInner<T> is {
    queue: Deque<T>,
    capacity: Maybe<Int>,  // None = unbounded
    closed: AtomicBool,
    sender_count: AtomicInt,
    receiver_waker: Mutex<Maybe<Waker>>,
    sender_wakers: Mutex<List<Waker>>,
    /// Notification counter — incremented by send(), waited on by recv()
    notify_seq: AtomicInt,
};

// =============================================================================
// Sender<T>
// =============================================================================

// Sending end of a channel. Can be cloned for multiple senders.
public type Sender<T> is {
    inner: Shared<ChannelInner<T>>,
};

implement<T> Sender<T> {
    // Send value synchronously. For unbounded — always succeeds immediately.
    // For bounded — if full, BLOCKS current thread via futex until a slot
    // frees (or channel closes). Use `send_async(value).await` for the
    // async equivalent that yields to the executor instead of blocking.
    public fn send(&self, value: T) -> Result<(), SendError<T>> {
        if self.inner.closed.load(MemoryOrdering.Acquire) {
            return Err(SendError(value));
        }

        loop {
            let seq = self.inner.notify_seq.load(MemoryOrdering.Acquire);

            let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
            // Bounded-capacity check under the same lock as the push — no TOCTOU.
            if let Some(cap) = self.inner.capacity {
                if guard.len() >= cap {
                    drop(guard);
                    if self.inner.closed.load(MemoryOrdering.Acquire) {
                        return Err(SendError(value));
                    }
                    // Wait until a receiver pops.
                    let _ = sys_futex_wait(&self.inner.notify_seq.value, seq, None);
                    continue;
                }
            }

            guard.push_back(value);
            drop(guard);

            self.inner.notify_seq.fetch_add(1, MemoryOrdering.Release);
            let _ = sys_futex_wake(&self.inner.notify_seq.value, 1);

            let waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
            if let Some(waker) = waker_guard.as_ref() {
                waker.wake_by_ref();
            }

            return Ok(());
        }
    }

    // Async send — returns a Future. On bounded-full, yields (Pending) and
    // registers caller waker; wakes when receiver pops.
    public fn send_async(&self, value: T) -> SendFut<T> {
        SendFut {
            inner: self.inner.clone(),
            value: Some(value),
            waker_registered: false,
        }
    }

    // Send honouring a cancellation token — resolves to Err(Cancelled) if
    // the token fires before send completes.
    public async fn send_cancellable(
        &self,
        value: T,
        token: &CancellationToken,
    ) -> Result<(), CancellableSendError<T>> {
        select {
            r = self.send_async(value).await => match r {
                Ok(()) => Ok(()),
                Err(e) => Err(CancellableSendError.Send(e)),
            },
            reason = token.cancelled().await => {
                Err(CancellableSendError.Cancelled(CancellationError.new(reason)))
            },
        }
    }

    // Send with a timeout — block up to `duration` waiting for a
    // bounded channel slot, then give up. Semantic mirror of
    // `recv_timeout`: on success returns `Ok(())`; on closed channel
    // returns `Err(SendError)`; on timeout returns `Err(SendError)`
    // with the unsent value preserved.
    //
    // For an unbounded channel this degenerates to `send` because
    // there is no capacity limit — the timeout only applies to the
    // wait-for-slot path.
    public fn send_timeout(&self, value: T, duration: Duration) -> Result<(), SendError<T>> {
        if self.inner.closed.load(MemoryOrdering.Acquire) {
            return Err(SendError(value));
        }
        // Unbounded: send succeeds immediately.
        if self.inner.capacity.is_none() {
            return self.send(value);
        }
        // Bounded: poll for slot availability up to `duration`. Phase 1
        // uses a spin-with-sleep loop against the queue length; a
        // futex-backed sender-side wait is a future replacement.
        let deadline = Instant.now().saturating_add(duration);
        loop {
            match self.try_send(value) {
                Ok(()) => return Ok(()),
                Err(TrySendError.Full(returned_value)) => {
                    if Instant.now() >= deadline {
                        return Err(SendError(returned_value));
                    }
                    // Short sleep to avoid busy-looping; the real
                    // wake-up path is the bounded-channel reader
                    // futex_wake on pop (reserved extension point).
                    sleep_millis(1);
                }
                Err(TrySendError.Disconnected(returned_value)) => {
                    return Err(SendError(returned_value));
                }
            }
        }
    }

    // Try to send without waiting. Capacity-check + push under one lock
    // to avoid TOCTOU between check and push.
    public fn try_send(&self, value: T) -> Result<(), TrySendError<T>> {
        if self.inner.closed.load(MemoryOrdering.Acquire) {
            return Err(TrySendError.Disconnected(value));
        }

        let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());

        if let Some(cap) = self.inner.capacity {
            if guard.len() >= cap {
                return Err(TrySendError.Full(value));
            }
        }

        guard.push_back(value);
        drop(guard);

        self.inner.notify_seq.fetch_add(1, MemoryOrdering.Release);
        let _ = sys_futex_wake(&self.inner.notify_seq.value, 1);

        let waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
        if let Some(waker) = waker_guard.as_ref() {
            waker.wake_by_ref();
        }

        Ok(())
    }

    // Alias for is_closed — matches tokio naming.
    public fn is_disconnected(&self) -> Bool {
        self.is_closed()
    }

    // Future that resolves when the channel closes (all senders or receiver
    // dropped). Composable with `select { ... }` on the sender side.
    public fn closed(&self) -> ChannelClosed<T> {
        ChannelClosed { inner: self.inner.clone() }
    }

    // Check if receiver has been dropped.
    public fn is_closed(&self) -> Bool {
        self.inner.closed.load(MemoryOrdering.Relaxed)
    }

    // Get number of messages in channel.
    public fn len(&self) -> Int {
        self.inner.queue.lock().unwrap_or_else(|p| p.into_inner()).len()
    }

    // Check if channel is empty.
    public fn is_empty(&self) -> Bool {
        self.inner.queue.lock().unwrap_or_else(|p| p.into_inner()).is_empty()
    }

    // Get capacity (None for unbounded).
    public fn capacity(&self) -> Maybe<Int> {
        self.inner.capacity
    }

    // Returns true iff the channel is bounded AND currently at capacity.
    // Unbounded channels always return false. Used by backpressure probes
    // and L2 rendezvous/bounded test scenarios that gate `send` on space.
    public fn is_full(&self) -> Bool {
        match self.inner.capacity {
            Some(cap) => self.inner.queue.lock().unwrap_or_else(|p| p.into_inner()).len() >= cap,
            None => false,
        }
    }

    // Send every item in `items` in order. Returns `Err(SendError(item))`
    // on the FIRST item that fails (closed channel or bounded-full after
    // blocking give-up); items already queued stay queued. This is the
    // natural counterpart to `Receiver.recv_many` on the send side —
    // useful for batched producers that want a single call-site.
    public fn send_all(&self, items: List<T>) -> Result<(), SendError<T>> {
        for item in items {
            self.send(item)?;
        }
        Ok(())
    }
}

implement<T> Clone for Sender<T> {
    fn clone(&self) -> Sender<T> {
        self.inner.sender_count.fetch_add(1, MemoryOrdering.Relaxed);
        Sender { inner: self.inner.clone() }
    }
}

implement<T> Debug for Sender<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("Sender { .. }")
    }
}

implement<T> Drop for Sender<T> {
    /// SOUNDNESS: previous revision used `Relaxed` on the fetch_sub,
    /// missing the Acquire-fence on the "last sender" path.  On
    /// weakly-ordered architectures (ARM / AArch64 / Apple Silicon),
    /// the last-sender thread could observe `count == 0` BEFORE
    /// concurrent siblings' Release-ordered writes were visible —
    /// close publication and waker-wake then ran against stale state.
    /// `AcqRel` encodes both halves: Release on the decrement, Acquire
    /// on the "I'm last" observation.
    fn drop(&mut self) {
        let count = self.inner.sender_count.fetch_sub(1, MemoryOrdering.AcqRel) - 1;
        if count == 0 {
            // Last sender dropped - close channel
            self.inner.closed.store(true, MemoryOrdering.Release);

            // Wake receiver via futex so it notices closure
            self.inner.notify_seq.fetch_add(1, MemoryOrdering.Release);
            let _ = sys_futex_wake(&self.inner.notify_seq.value, 1);

            // Also wake async receiver
            let waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
            if let Some(waker) = waker_guard.as_ref() {
                waker.wake_by_ref();
            }
        }
    }
}

// =============================================================================
// Receiver<T>
// =============================================================================

// Receiving end of a channel. Only one receiver per channel.
public type Receiver<T> is {
    inner: Shared<ChannelInner<T>>,
};

implement<T> Receiver<T> {
    // Receive value, blocking via futex if empty.
    public fn recv(&mut self) -> Maybe<T> {
        loop {
            // Snapshot notification counter before checking queue
            let seq = self.inner.notify_seq.load(MemoryOrdering.Acquire);

            let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
            if let Some(value) = guard.pop_front() {
                // Wake a waiting sender
                let mut wakers = self.inner.sender_wakers.lock().unwrap_or_else(|p| p.into_inner());
                if let Some(waker) = wakers.pop() {
                    waker.wake();
                }
                return Some(value);
            }

            // Check if closed
            if self.inner.closed.load(MemoryOrdering.Acquire) {
                return None;
            }

            // Release lock before blocking
            drop(guard);

            // Block until a sender increments notify_seq — real OS sleep
            let _ = sys_futex_wait(&self.inner.notify_seq.value, seq, None);
        }
    }

    // Try to receive without waiting.
    public fn try_recv(&mut self) -> Result<T, TryRecvError> {
        let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
        match guard.pop_front() {
            Some(value) => Ok(value),
            None => {
                if self.inner.closed.load(MemoryOrdering.Acquire) {
                    Err(TryRecvError.Disconnected)
                } else {
                    Err(TryRecvError.Empty)
                }
            }
        }
    }

    // Check if channel is closed && empty.
    public fn is_closed(&self) -> Bool {
        self.inner.closed.load(MemoryOrdering.Relaxed) && self.inner.queue.lock().unwrap_or_else(|p| p.into_inner()).is_empty()
    }

    // Get number of messages in channel.
    public fn len(&self) -> Int {
        self.inner.queue.lock().unwrap_or_else(|p| p.into_inner()).len()
    }

    // Check if channel is empty.
    public fn is_empty(&self) -> Bool {
        self.inner.queue.lock().unwrap_or_else(|p| p.into_inner()).is_empty()
    }

    // Close the channel, preventing further sends.
    public fn close(&mut self) {
        self.inner.closed.store(true, MemoryOrdering.Release);
    }
}

implement<T> Future for Receiver<T> {
    type Output = Maybe<T>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Maybe<T>> {
        // Try to receive
        let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
        if let Some(value) = guard.pop_front() {
            return Poll.Ready(Some(value));
        }

        // Check if closed
        if self.inner.closed.load(MemoryOrdering.Acquire) {
            return Poll.Ready(None);
        }

        // Register waker for when data arrives
        let mut waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
        *waker_guard = Some(cx.waker().clone());

        Poll.Pending
    }
}

implement<T> Drop for Receiver<T> {
    fn drop(&mut self) {
        // Close channel
        self.inner.closed.store(true, MemoryOrdering.Release);
    }
}

implement<T> Debug for Receiver<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("Receiver { .. }")
    }
}

implement<T> Receiver<T> {
    // Batch-drain up to `max` items in a single lock acquisition. Populates
    // `out` via push_back; returns number of items drained. Zero indicates
    // empty-and-still-open or closed — distinguish via `is_closed`.
    public fn recv_many(&mut self, out: &mut List<T>, max: Int) -> Int {
        let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
        let mut n = 0;
        while n < max {
            match guard.pop_front() {
                Some(value) => { out.push(value); n = n + 1; }
                None => break,
            }
        }
        n
    }

    // Async batch-receive: blocks until at least one item is available (via
    // the same futex as `recv`), then drains up to `max` under the same
    // queue lock and returns them as a fresh List. Returns an empty list
    // iff the channel closed with no items left.
    //
    // Use this over `recv_many` when you want to BLOCK rather than
    // best-effort drain — it wakes exactly once per batch rather than
    // spinning on an empty queue.
    public fn recv_batch(&mut self, max: Int) -> List<T> {
        let mut out: List<T> = List.new();
        if max <= 0 { return out; }
        loop {
            let seq = self.inner.notify_seq.load(MemoryOrdering.Acquire);
            let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
            if guard.len() > 0 {
                let mut n = 0;
                while n < max {
                    match guard.pop_front() {
                        Some(value) => { out.push(value); n = n + 1; }
                        None => break,
                    }
                }
                // Wake one waiting sender per popped item-class — same
                // policy as recv(): a single wake is sufficient because
                // futex_wake with count=1 is coalesced; the sender loop
                // re-snapshots on wake.
                let mut wakers = self.inner.sender_wakers.lock().unwrap_or_else(|p| p.into_inner());
                if let Some(waker) = wakers.pop() { waker.wake(); }
                return out;
            }
            if self.inner.closed.load(MemoryOrdering.Acquire) {
                return out;
            }
            drop(guard);
            let _ = sys_futex_wait(&self.inner.notify_seq.value, seq, None);
        }
    }

    // Explicit awaitable recv future (same semantics as using Receiver as
    // a Future directly, but more readable in select-bodies).
    public fn recv_fut(&mut self) -> RecvFut<T> {
        RecvFut { inner: self.inner.clone() }
    }

    // Async recv honouring a cancellation token.
    public async fn recv_cancellable(
        &mut self,
        token: &CancellationToken,
    ) -> Result<Maybe<T>, CancellationError> {
        select {
            v = self.recv_fut().await => Ok(v),
            reason = token.cancelled().await => Err(CancellationError.new(reason)),
        }
    }
}

// Stream<Item = T> impl — enables `for await msg in rx { ... }`.
implement<T> Stream for Receiver<T> {
    type Item = T;

    fn poll_next(&mut self, cx: &mut Context) -> Poll<Maybe<T>> {
        let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
        if let Some(value) = guard.pop_front() {
            let mut wakers = self.inner.sender_wakers.lock().unwrap_or_else(|p| p.into_inner());
            if let Some(waker) = wakers.pop() {
                waker.wake();
            }
            return Poll.Ready(Some(value));
        }

        if self.inner.closed.load(MemoryOrdering.Acquire) {
            return Poll.Ready(None);
        }

        let mut waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
        *waker_guard = Some(cx.waker().clone());
        Poll.Pending
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        let g = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
        (g.len(), self.inner.capacity)
    }
}

// AsyncIterator<Item = T> — for-await loop target. Stream ∘ StreamNext
// bridge; zero-extra allocation. (A blanket `impl<S: Stream> AsyncIterator
// for S` would collapse this, but current compiler can't project `S.Item`
// through blanket impls — see core/async/async_iterator.vr.)
implement<T> AsyncIterator for Receiver<T> {
    type Item = T;

    @inline
    async fn next(&mut self) -> Maybe<T> {
        StreamNext { stream: self }.await
    }
}

// =============================================================================
// SendFut<T> — async-backpressure future for bounded channels
// =============================================================================

public type SendFut<T> is {
    inner: Shared<ChannelInner<T>>,
    value: Maybe<T>,
    waker_registered: Bool,
};

implement<T> Future for SendFut<T> {
    type Output = Result<(), SendError<T>>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<(), SendError<T>>> {
        if self.inner.closed.load(MemoryOrdering.Acquire) {
            let v = self.value.take()
                .expect("SendFut::poll: self.value is_some until first successful poll consumes it");
            return Poll.Ready(Err(SendError(v)));
        }

        let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());

        if let Some(cap) = self.inner.capacity {
            if guard.len() >= cap {
                if !self.waker_registered {
                    let mut wakers = self.inner.sender_wakers.lock().unwrap_or_else(|p| p.into_inner());
                    wakers.push(cx.waker().clone());
                    self.waker_registered = true;
                }
                return Poll.Pending;
            }
        }

        let v = self.value.take()
            .expect("SendFut::poll: self.value is_some until first successful poll consumes it");
        guard.push_back(v);
        drop(guard);

        self.inner.notify_seq.fetch_add(1, MemoryOrdering.Release);
        let _ = sys_futex_wake(&self.inner.notify_seq.value, 1);

        let waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
        if let Some(waker) = waker_guard.as_ref() {
            waker.wake_by_ref();
        }

        Poll.Ready(Ok(()))
    }
}

// =============================================================================
// RecvFut<T> — explicit awaitable recv future
// =============================================================================

public type RecvFut<T> is {
    inner: Shared<ChannelInner<T>>,
};

implement<T> Future for RecvFut<T> {
    type Output = Maybe<T>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Maybe<T>> {
        let mut guard = self.inner.queue.lock().unwrap_or_else(|p| p.into_inner());
        if let Some(value) = guard.pop_front() {
            let mut wakers = self.inner.sender_wakers.lock().unwrap_or_else(|p| p.into_inner());
            if let Some(waker) = wakers.pop() {
                waker.wake();
            }
            return Poll.Ready(Some(value));
        }

        if self.inner.closed.load(MemoryOrdering.Acquire) {
            return Poll.Ready(None);
        }

        let mut waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
        *waker_guard = Some(cx.waker().clone());
        Poll.Pending
    }
}

// =============================================================================
// ChannelClosed<T> — sender-side awaitable for disconnect detection
// =============================================================================

public type ChannelClosed<T> is {
    inner: Shared<ChannelInner<T>>,
};

implement<T> Future for ChannelClosed<T> {
    type Output = ();

    fn poll(&mut self, cx: &mut Context) -> Poll<()> {
        if self.inner.closed.load(MemoryOrdering.Acquire) {
            return Poll.Ready(());
        }
        let mut waker_guard = self.inner.receiver_waker.lock().unwrap_or_else(|p| p.into_inner());
        *waker_guard = Some(cx.waker().clone());
        Poll.Pending
    }
}

// =============================================================================
// CancellableSendError<T> — error from send_cancellable
// =============================================================================

public type CancellableSendError<T> is
    | Send(SendError<T>)
    | Cancelled(CancellationError);

implement<T> Debug for CancellableSendError<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Send(_) => f.write_str("CancellableSendError.Send(..)"),
            Cancelled(_) => f.write_str("CancellableSendError.Cancelled(..)"),
        }
    }
}

// =============================================================================
// Error Types
// =============================================================================

// Error when sending fails because receiver was dropped.
public type SendError<T> is (T);

implement<T: Debug> Debug for SendError<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("SendError(..)")
    }
}

// Error when trying to send.
public type TrySendError<T> is
    | Full(T)           // Channel is full (bounded)
    | Disconnected(T);  // Receiver was dropped

implement<T: Debug> Debug for TrySendError<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Full(_) => f.write_str("TrySendError.Full"),
            Disconnected(_) => f.write_str("TrySendError.Disconnected"),
        }
    }
}

// Error when trying to receive.
public type TryRecvError is
    | Empty         // Channel is empty
    | Disconnected; // All senders dropped

// Error when receiving fails.
public type RecvError is ();

implement Debug for TryRecvError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Empty => f.write_str("TryRecvError.Empty"),
            Disconnected => f.write_str("TryRecvError.Disconnected"),
        }
    }
}

implement Debug for RecvError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("RecvError")
    }
}

implement<T> Display for SendError<T> {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("sending on a closed channel")
    }
}

implement<T> Display for TrySendError<T> {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Full(_) => f.write_str("sending on a full channel"),
            Disconnected(_) => f.write_str("sending on a disconnected channel"),
        }
    }
}

implement Display for TryRecvError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Empty => f.write_str("receiving on an empty channel"),
            Disconnected => f.write_str("receiving from a disconnected channel"),
        }
    }
}

implement Display for RecvError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("receiving on a closed channel")
    }
}

implement<T: Clone> Clone for SendError<T> {
    fn clone(&self) -> SendError<T> {
        SendError(self.0.clone())
    }
}

implement<T: Clone> Clone for TrySendError<T> {
    fn clone(&self) -> TrySendError<T> {
        match self {
            Full(v) => TrySendError.Full(v.clone()),
            Disconnected(v) => TrySendError.Disconnected(v.clone()),
        }
    }
}

implement Clone for TryRecvError {
    fn clone(&self) -> TryRecvError {
        match self {
            Empty => TryRecvError.Empty,
            Disconnected => TryRecvError.Disconnected,
        }
    }
}

implement Clone for RecvError {
    fn clone(&self) -> RecvError {
        RecvError
    }
}

fn try_recv_error_tag(e: &TryRecvError) -> Int {
    match e {
        Empty        => 0,
        Disconnected => 1,
    }
}

implement Eq for TryRecvError {
    fn eq(&self, other: &TryRecvError) -> Bool {
        try_recv_error_tag(self) == try_recv_error_tag(other)
    }
}

implement Eq for RecvError {
    fn eq(&self, _other: &RecvError) -> Bool {
        true
    }
}

// =============================================================================
// Channel Constructors
// =============================================================================

// Create unbounded channel.
public fn channel<T>() -> (Sender<T>, Receiver<T>) {
    let inner = Shared.new(ChannelInner {
        queue: Deque.new(),
        capacity: None,
        closed: AtomicBool.new(false),
        sender_count: AtomicInt.new(1),
        receiver_waker: sync.mutex.Mutex.new(None as Maybe<Waker>),
        sender_wakers: sync.mutex.Mutex.new(List.new() as List<Waker>),
        notify_seq: AtomicInt.new(0),
    });

    (Sender { inner: inner.clone() }, Receiver { inner: inner })
}

// Create bounded channel with capacity.
public fn bounded<T>(capacity: Int) -> (Sender<T>, Receiver<T>) {
    assert(capacity > 0, "Channel capacity must be positive");

    let inner = Shared.new(ChannelInner {
        queue: Deque.with_capacity(capacity),
        capacity: Some(capacity),
        closed: AtomicBool.new(false),
        sender_count: AtomicInt.new(1),
        receiver_waker: sync.mutex.Mutex.new(None as Maybe<Waker>),
        sender_wakers: sync.mutex.Mutex.new(List.new() as List<Waker>),
        notify_seq: AtomicInt.new(0),
    });

    (Sender { inner: inner.clone() }, Receiver { inner: inner })
}

// Alias for `bounded` — matches the tokio-idiomatic name used in
// async tests and user-facing docs. Both forms produce the same
// channel; this is a pure re-export with the alternative name.
public fn bounded_channel<T>(capacity: Int) -> (Sender<T>, Receiver<T>) {
    bounded(capacity)
}

// Alias for `channel` — matches the tokio-idiomatic name for an
// unbounded channel.
public fn unbounded_channel<T>() -> (Sender<T>, Receiver<T>) {
    channel()
}

// =============================================================================
// oneshot - Single value channel
// =============================================================================

// Shared inner state for oneshot channel.
type OneshotInner<T> is {
    sent: AtomicBool,
    value: Mutex<Maybe<T>>,
    waker: Mutex<Maybe<Waker>>,
};

// Sender for oneshot channel.
public type OneshotSender<T> is {
    inner: Shared<OneshotInner<T>>,
};

// Receiver for oneshot channel.
public type OneshotReceiver<T> is {
    inner: Shared<OneshotInner<T>>,
};

implement<T> Debug for OneshotSender<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("OneshotSender { .. }")
    }
}

implement<T> Debug for OneshotReceiver<T> {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("OneshotReceiver { .. }")
    }
}

implement<T> OneshotSender<T> {
    // Send value. Can only be called once.
    public fn send(self, value: T) -> Result<(), T> {
        if self.inner.sent.swap(true, MemoryOrdering.AcqRel) {
            return Err(value);
        }

        *self.inner.value.lock().unwrap_or_else(|p| p.into_inner()) = Some(value);

        // Wake receiver
        if let Some(waker) = self.inner.waker.lock().unwrap_or_else(|p| p.into_inner()).take() {
            waker.wake();
        }

        Ok(())
    }
}

implement<T> Future for OneshotReceiver<T> {
    type Output = Result<T, RecvError>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<T, RecvError>> {
        // Check if value is available
        let mut value_guard = self.inner.value.lock().unwrap_or_else(|p| p.into_inner());
        if let Some(value) = value_guard.take() {
            return Poll.Ready(Ok(value));
        }

        // Check if sender was dropped without sending
        if self.inner.sent.load(MemoryOrdering.Acquire) {
            return Poll.Ready(Err(RecvError()));
        }

        // Register waker
        *self.inner.waker.lock().unwrap_or_else(|p| p.into_inner()) = Some(cx.waker().clone());

        Poll.Pending
    }
}

// Create oneshot channel.
public fn oneshot<T>() -> (OneshotSender<T>, OneshotReceiver<T>) {
    let inner = Shared.new(OneshotInner {
        sent: AtomicBool.new(false),
        value: sync.mutex.Mutex.new(None as Maybe<T>),
        waker: sync.mutex.Mutex.new(None as Maybe<Waker>),
    });

    (
        OneshotSender { inner: inner.clone() },
        OneshotReceiver { inner: inner }
    )
}
