// =============================================================================
// async/diagnostics.vr - Read-only Introspection of Async Runtime State
// =============================================================================
// Layer: 4 (Async)
// Dependencies: async/task, async/poll
// =============================================================================
//
// This module exposes structural views of the async runtime — task identities,
// lifecycle states, and last-poll provenance — for post-mortem dumps,
// debugger / observer integrations, and live monitoring dashboards.
//
// Companion to `core::mem::diagnostics` (CBGR allocation introspection).
// Together they form the substrate of the user-facing
// `core::diagnostics` umbrella module mandated by the production-ready
// directive.
//
// # Anti-goals (mirroring core::mem::diagnostics)
//
// - No mutation surface.  Snapshots are read-only.
// - No reflection escape that would bypass async cancellation.
//   `TaskInfo` summarises identity + state, not the task's continuation.
// - Zero overhead when not subscribed: every method here is inlinable,
//   and the module is feature-gated via `@cfg(feature = "diagnostics")`
//   for builds that strip it (embedded targets).
//
// Spec: docs/architecture/observability.md (TODO)
// =============================================================================

module core.async.diagnostics;

mount core.{Maybe, Text};
mount super.task.TaskId;

// =============================================================================
// TaskLifecycleState — public projection of internal TaskState<T>
// =============================================================================

/// Coarse-grained lifecycle state of a task, independent of its
/// concrete output type T.  Shape:
///
///   Pending   — spawned but not yet polled
///   Running   — currently executing on an executor
///   Parked    — yielded to the executor (Pending Poll), waiting on a Waker
///   Completed — finished with a value (caller already joined or handle dropped)
///   Cancelled — explicitly cancelled, never produced a value
///   Failed    — panicked during execution; reason carried in `last_error`
///
/// The internal `TaskState<T>` (in `core/async/task.vr`) is generic over
/// the output type and includes the value in `Completed(T)`.  Surface
/// projection drops the value so the type can be used by heterogeneous
/// snapshot containers (e.g. a global task table indexed by TaskId).
public type TaskLifecycleState is
    | Pending
    | Running
    | Parked
    | Completed
    | Cancelled
    | Failed;

implement Display for TaskLifecycleState {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Pending   => f.write_str("pending"),
            Running   => f.write_str("running"),
            Parked    => f.write_str("parked"),
            Completed => f.write_str("completed"),
            Cancelled => f.write_str("cancelled"),
            Failed    => f.write_str("failed"),
        }
    }
}

// =============================================================================
// TaskInfo — snapshot of a single live task
// =============================================================================

/// Snapshot of a task's identity + state at observation time.  Does
/// NOT capture the task's continuation, future, or any user data —
/// the snapshot is a strict pass-through of metadata so it can cross
/// thread / executor boundaries safely.
public type TaskInfo is {
    /// Stable identity (atomic-counter allocated at spawn).
    id: TaskId,

    /// Coarse lifecycle state at observation time.  See
    /// `TaskLifecycleState` for the meaning of each variant.
    state: TaskLifecycleState,

    /// Task name, when supplied at spawn time.  Empty when no name
    /// was provided.  Useful for debugger UI grouping
    /// ("postgres-pool worker #3" vs raw `TaskId(42)`).
    name: Text,

    /// Number of times the task has been polled.  Used by
    /// monitoring dashboards to flag stuck-on-Pending tasks (high
    /// poll count + still Pending = livelocked or busy-waiting
    /// without progress).
    poll_count: Int,

    /// Last error message when `state == Failed`.  Empty otherwise.
    last_error: Text,
};

implement TaskInfo {
    /// Construct a snapshot from raw metadata.  The async runtime
    /// owns the source of truth (per-task atomic counters); this
    /// constructor is the format-stable boundary callers code
    /// against.
    public fn new(
        id: TaskId,
        state: TaskLifecycleState,
        name: Text,
        poll_count: Int,
        last_error: Text,
    ) -> TaskInfo {
        TaskInfo {
            id: id,
            state: state,
            name: name,
            poll_count: poll_count,
            last_error: last_error,
        }
    }

    /// True iff the task is in a terminal state (Completed, Cancelled,
    /// Failed).  Monitors use this to prune snapshots before
    /// rendering.
    public fn is_terminal(&self) -> Bool {
        match self.state {
            Completed | Cancelled | Failed => true,
            Pending | Running | Parked => false,
        }
    }

    /// Format as a panic-context block.  Two-space indented so it
    /// composes with multi-line panic messages.  Single allocation
    /// per call so OOM-path callers should prefer Display.
    public fn format_panic_context(&self) -> Text {
        let mut out: Text = "  Async task at panic site:\n".clone();
        out = out + f"    id:         {self.id.id}\n";
        out = out + f"    state:      {self.state}\n";
        out = out + f"    name:       {self.name}\n";
        out = out + f"    poll_count: {self.poll_count}";
        if !self.last_error.is_empty() {
            out = out + f"\n    last_error: {self.last_error}";
        }
        out
    }
}

implement Display for TaskInfo {
    /// Single-line summary suitable for log lines.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"task[id={self.id.id},state={self.state},polls={self.poll_count},name={self.name}]")
    }
}

implement Debug for TaskInfo {
    /// Multi-line dump suitable for panic post-mortems.
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("TaskInfo {\n")?;
        f.write_str(f"  id:         TaskId({self.id.id})\n")?;
        f.write_str(f"  state:      {self.state}\n")?;
        f.write_str(f"  name:       {self.name}\n")?;
        f.write_str(f"  poll_count: {self.poll_count}\n")?;
        f.write_str(f"  is_terminal: {self.is_terminal()}\n")?;
        if !self.last_error.is_empty() {
            f.write_str(f"  last_error: {self.last_error}\n")?;
        }
        f.write_str("}")
    }
}
