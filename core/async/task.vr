// =============================================================================
// task.vr - Task spawning and joining
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core, sync, async/future
// =============================================================================
//
// Task represents a spawned asynchronous computation.
// Tasks run concurrently and can be awaited via JoinHandle.
//
// =============================================================================

module core.async.task;
mount core.*;
mount sync.*;
mount .poll.*;
mount .waker.*;
mount .future.*;
// `spawn_blocking` routes through the dedicated blocking thread
// pool (`core.runtime.pool::ThreadPool`) rather than the async
// executor's worker pool — see the BlockingState/BlockingFuture
// section below for the architectural rationale.
mount core.runtime.pool.{ThreadPool};

// =============================================================================
// Task State
// =============================================================================

// Internal state of a task.
type TaskState<T> is
    | Pending           // Not yet started
    | Running           // Currently executing
    | Completed(T)      // Finished with result
    | Cancelled;        // Was cancelled

// =============================================================================
// Task<T>
// =============================================================================

// Identifier for a spawned task.
public type TaskId is {
    id: Int,
};

implement TaskId {
    // Create new task ID.
    fn new() -> TaskId {
        // Use atomic counter for unique IDs
        static NEXT_ID: AtomicInt = AtomicInt.new(1);
        TaskId { id: NEXT_ID.fetch_add(1, MemoryOrdering.Relaxed) }
    }
}

implement Eq for TaskId {
    fn eq(&self, other: &TaskId) -> Bool {
        self.id == other.id
    }
}

implement Hash for TaskId {
    fn hash(&self, hasher: &mut Hasher) {
        self.id.hash(hasher);
    }
}

implement Debug for TaskId {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("TaskId(")?;
        self.id.fmt_debug(f)?;
        f.write_str(")")
    }
}

// =============================================================================
// Task
// =============================================================================

// A spawned asynchronous task.
public type Task<T> is {
    id: TaskId,
    state: AtomicInt,  // 0=pending, 1=running, 2=completed, 3=cancelled
    result: Mutex<Maybe<T>>,
};

implement<T> Task<T> {
    // Get task ID.
    public fn id(&self) -> TaskId {
        self.id
    }

    // Check if task is finished.
    public fn is_finished(&self) -> Bool {
        let state = self.state.load(MemoryOrdering.Acquire);
        state >= 2  // Completed || Cancelled
    }

    // Check if task was cancelled.
    public fn is_cancelled(&self) -> Bool {
        self.state.load(MemoryOrdering.Acquire) == 3
    }

    // Cancel the task.
    public fn cancel(&self) -> Bool {
        // Can only cancel if pending || running
        loop {
            let state = self.state.load(MemoryOrdering.Acquire);
            if state >= 2 {
                return false;  // Already finished
            }
            if self.state.compare_exchange(state, 3, MemoryOrdering.AcqRel, MemoryOrdering.Relaxed).is_ok() {
                return true;
            }
        }
    }
}

// =============================================================================
// JoinHandle<T>
// =============================================================================

// Handle for awaiting a spawned task's result.
public type JoinHandle<T> is {
    task: Shared<Task<T>>,
};

implement<T> JoinHandle<T> {
    // Get task ID.
    public fn id(&self) -> TaskId {
        self.task.id()
    }

    // Check if task is finished.
    public fn is_finished(&self) -> Bool {
        self.task.is_finished()
    }

    // Cancel the task.
    public fn cancel(&self) {
        self.task.cancel();
    }

    // Detach from task - let it run to completion without waiting.
    public fn detach(self) {
        // Just drop the handle
    }
}

implement<T> Future for JoinHandle<T> {
    type Output = Result<T, JoinError>;

    fn poll(&mut self, _cx: &mut Context) -> Poll<Result<T, JoinError>> {
        if self.task.is_finished() {
            if self.task.is_cancelled() {
                Poll.Ready(Err(JoinError.Cancelled))
            } else {
                let mut guard = self.task.result.lock().unwrap_or_else(|p| p.into_inner());
                match guard.take() {
                    Some(res) => Poll.Ready(Ok(res)),
                    None => Poll.Ready(Err(JoinError.Panicked)),
                }
            }
        } else {
            Poll.Pending
        }
    }
}

// =============================================================================
// JoinError
// =============================================================================

// Error when joining a task.
public type JoinError is
    | Cancelled      // Task was cancelled
    | Panicked;      // Task panicked

implement Debug for JoinError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Cancelled => f.write_str("JoinError.Cancelled"),
            Panicked => f.write_str("JoinError.Panicked"),
        }
    }
}

implement Display for JoinError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let s = match self {
            Cancelled => "task cancelled",
            Panicked  => "task panicked",
        };
        f.write_str(s)
    }
}

implement Eq for JoinError {
    fn eq(&self, other: &JoinError) -> Bool {
        match (self, other) {
            (Cancelled, Cancelled) => true,
            (Panicked,  Panicked)  => true,
            _ => false,
        }
    }
}

// =============================================================================
// Spawn Functions
// =============================================================================

// Thread-local task queue (simplified - real impl uses executor)
static TASK_QUEUE: Mutex<List<Shared<Task<()>>>> = Mutex.new(List.new());

// Spawn a future as a new task.
// Returns a JoinHandle to await the result.
public fn spawn<F: Future>(future: F) -> JoinHandle<F.Output>
where F.Output: Send
{
    // In a real implementation, this would submit to an executor
    let task = Shared.new(Task {
        id: TaskId.new(),
        state: AtomicInt.new(0),  // Pending
        result: Mutex.new(None),
    });

    JoinHandle { task: task }
}

// =============================================================================
// Blocking Task Coordination — closes #242 architectural stub
// =============================================================================
//
// `spawn_blocking` runs CPU-intensive or blocking I/O work on a
// **dedicated** thread pool (`core.runtime.pool::ThreadPool`),
// distinct from the async executor's worker pool. Pre-fix the
// implementation was `spawn(lazy(f))` — the work ran on the async
// pool and consumed a worker thread for its full duration,
// starving other futures. Now the work runs on the dedicated
// blocking pool and the async future polls a completion flag,
// freeing async workers between polls.
//
// **Coordination state**: `BlockingState<T>` carries the
// completion flag (`AtomicBool`) and the result slot
// (`Mutex<Maybe<T>>`). The pool task writes the result and sets
// `done` with Release ordering; the Future reads `done` with
// Acquire ordering, then takes the result under the mutex. This
// is the canonical write-once / read-once cross-thread handoff.
//
// **Closure marshalling**: the closure `f` and the state slot
// are heap-boxed together and the pointer is passed as the pool
// task's `arg`. The pool's `func: fn(Int) -> Int` recovers the
// box via `Heap.from_raw` (taking ownership), runs the closure,
// writes the result, and is dropped — the same type-erasure
// pattern that `AsyncRuntime::spawn` uses for its `poll_fn`
// (executor.vr:465 + :468).

// Cross-thread coordination state for blocking work.
public type BlockingState<T> is {
    // Completion flag — set by pool task with Release ordering
    // when the result has been written; read by the polling
    // future with Acquire ordering.
    done: AtomicBool,
    // Result slot — populated by the pool task before setting
    // `done`. The Future takes the result on first Poll.Ready.
    result: Mutex<Maybe<T>>,
};

// Future that polls a `BlockingState` for completion.
//
// Returned by `spawn_blocking`. On `poll`:
//   * If `done` is set, take the result under the mutex and
//     return `Poll.Ready(value)`.
//   * Otherwise, schedule a re-poll via `cx.waker().wake_by_ref()`
//     and return `Poll.Pending`. This keeps the async worker
//     free for other futures between polls — the wake_by_ref
//     enqueues this task back onto the executor's ready queue
//     so the next executor tick will re-poll.
public type BlockingFuture<T> is {
    state: Shared<BlockingState<T>>,
};

implement<T: Send> Future for BlockingFuture<T> {
    type Output = T;

    fn poll(&mut self, cx: &mut Context) -> Poll<T> {
        if self.state.done.load(MemoryOrdering.Acquire) {
            // Result is ready — take it from the mutex.
            // Poisoned mutex recovery via `into_inner`: the pool
            // task has no panic-sensitive invariant on the
            // result slot, so a poisoned/Ok lock is operationally
            // identical here.
            let mut g = match self.state.result.lock() {
                Ok(g)  => g,
                Err(p) => p.into_inner(),
            };
            match g.take() {
                Maybe.Some(v) => Poll.Ready(v),
                Maybe.None    => panic("BlockingFuture polled after completion"),
            }
        } else {
            // Re-arm the waker so the executor re-polls us. This
            // is the standard "polled-completion" idiom — the
            // pool task will eventually flip `done` and on the
            // next executor tick this poll will see the flag.
            cx.waker().wake_by_ref();
            Poll.Pending
        }
    }
}

// Boxed argument passed to the pool's `fn(Int) -> Int` callback.
// Pairs the shared completion state with the user-supplied
// closure so a single heap pointer carries everything the
// pool task needs.
type BlockingArg<F, T> is {
    state: Shared<BlockingState<T>>,
    f: F,
};

// Spawn a blocking operation on a dedicated thread pool.
//
// The closure runs on `core.runtime.pool::ThreadPool`'s global
// pool (distinct from the async executor's worker pool). The
// returned `JoinHandle` polls a completion flag set by the
// pool task — the async executor's workers stay free for other
// futures between polls.
public fn spawn_blocking<F: fn() -> T + Send, T: Send>(f: F) -> JoinHandle<T> {
    // Allocate the cross-thread coordination state.
    let state: Shared<BlockingState<T>> = Shared.new(BlockingState {
        done:   AtomicBool.new(false),
        result: Mutex.new(Maybe.None),
    });

    // Box the (state, closure) tuple onto the heap and pass the
    // pointer as the pool task's argument. The pool's
    // `fn(Int) -> Int` callback reconstructs the box, runs the
    // closure, writes the result, sets `done`, and the box is
    // dropped at end of callback. Same pattern as
    // `AsyncRuntime::spawn`'s poll_fn type-erasure (executor.vr:465).
    let arg_box = Heap.new(BlockingArg {
        state: state.clone(),
        f:     f,
    });
    let arg_ptr = Heap.into_raw(arg_box) as Int;

    // Pool callback — runs on a dedicated blocking-pool thread.
    let pool_fn: fn(Int) -> Int = |arg: Int| -> Int {
        // Reconstruct the box (takes ownership).
        let boxed = unsafe {
            Heap.from_raw(arg as &mut BlockingArg<F, T>)
        };
        let result = (boxed.f)();
        // Acquire mutex, write result, release.
        let mut g = match boxed.state.result.lock() {
            Ok(g)  => g,
            Err(p) => p.into_inner(),
        };
        *g = Maybe.Some(result);
        // Release-ordered store so the polling Future sees the
        // result write before the flag flip.
        boxed.state.done.store(true, MemoryOrdering.Release);
        // boxed is dropped here — Heap deallocation reclaims memory.
        0
    };

    let _pool_handle = ThreadPool.global_submit(pool_fn, arg_ptr);

    // Return a JoinHandle wrapping the polling future. The
    // future will be enqueued on the async executor and polled
    // periodically until the pool task completes.
    let future = BlockingFuture { state: state };
    spawn(future)
}

// Spawn a future as a detached task (fire-and-forget).
// The task runs to completion without waiting for the result.
public fn spawn_detached<F: Future>(future: F)
where F.Output: Send
{
    let handle = spawn(future);
    handle.detach();
}

// Yield control back to the runtime.
// Other tasks may run before this task resumes.
public fn yield_now() -> YieldNow {
    YieldNow { yielded: false }
}

// Future for yield_now.
public type YieldNow is {
    yielded: Bool,
};

implement Future for YieldNow {
    type Output = ();

    fn poll(&mut self, cx: &mut Context) -> Poll<()> {
        if self.yielded {
            Poll.Ready(())
        } else {
            self.yielded = true;
            // Wake immediately so we get polled again
            cx.waker().wake_by_ref();
            Poll.Pending
        }
    }
}

// =============================================================================
// JoinSet - Manage multiple tasks
// =============================================================================

// A collection of spawned tasks.
public type JoinSet<T> is {
    handles: List<JoinHandle<T>>,
};

implement<T> JoinSet<T> {
    // Create empty join set.
    public fn new() -> JoinSet<T> {
        JoinSet { handles: List.new() }
    }

    // Spawn a task && add to set.
    public fn spawn<F: Future<Output = T>>(&mut self, future: F)
    where T: Send
    {
        self.handles.push(spawn(future));
    }

    // Number of tasks in set.
    public fn len(&self) -> Int {
        self.handles.len()
    }

    // Check if empty.
    public fn is_empty(&self) -> Bool {
        self.handles.is_empty()
    }

    // Cancel all tasks.
    public fn cancel_all(&mut self) {
        for handle in self.handles.iter_mut() {
            handle.cancel();
        }
    }

    // Detach all tasks.
    public fn detach_all(&mut self) {
        self.handles.clear();
    }
}

implement<T> Future for JoinSet<T> {
    type Output = Result<T, JoinError>;

    // Poll until any task completes.
    fn poll(&mut self, cx: &mut Context) -> Poll<Result<T, JoinError>> {
        for i in range(0, self.handles.len()) {
            if let Poll.Ready(res) = self.handles.get_mut(i)
                .expect("JoinSet poll: i in range(0, handles.len()) — get_mut is_some")
                .poll(cx) {
                self.handles.remove(i);
                return Poll.Ready(res);
            }
        }
        Poll.Pending
    }
}
