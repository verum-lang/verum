// =============================================================================
// waker.vr - Waker and Context for async runtime
// =============================================================================
// Layer: 4 (Async)
// Dependencies: core
// =============================================================================
//
// Waker is the foundational wake-up handle of the async runtime.  A
// task hands its current Waker to whatever it is waiting on; when
// progress is possible the waiter (channel, timer, IO event source,
// child task) calls `waker.wake()` (or `wake_by_ref()`) and the
// runtime re-polls the task.
//
// The Waker layout intentionally inlines the vtable BY VALUE rather
// than by reference.  The earlier `vtable: &RawWakerVTable` form
// required producers to either:
//   (1) store the vtable in a module-static so the `&` survives the
//       function-return that produced the Waker — but module-static
//       record literals with function-pointer fields are not yet
//       lowered to a runtime-resolvable form by the VBC interpreter
//       (`opcode 0x62 GetF` on the static fires on a null heap
//       payload), OR
//   (2) build the vtable as a stack-local and return `&vtable` along
//       with the Waker — a textbook use-after-free that produced
//       null-deref panics on the first wake / clone.
// Inlining the vtable (≈32 bytes for four `fn` slots) removes both
// hazards: every Waker fully owns its dispatch table; Clone is a
// straightforward field-copy; Drop has the right vtable in hand.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.async.waker;
mount core.*;

// =============================================================================
// RawWakerVTable — four fn slots that drive Clone / wake / wake_by_ref / drop
// =============================================================================

// Virtual table for raw waker operations. Stored BY VALUE inside
// RawWaker so producers never have to keep a separate vtable
// allocation alive — see the module-level comment for the rationale.
public type RawWakerVTable is {
    // Clone the waker data, returning a fresh RawWaker. The returned
    // RawWaker carries ITS OWN vtable (typically a value-copy of
    // self's vtable), so the clone semantics work uniformly for the
    // noop case and for user-supplied custom wakers.
    clone: fn(&unsafe Byte) -> RawWaker,

    // Wake by value (consumes the waker).
    wake: fn(&unsafe Byte),

    // Wake by reference (doesn't consume).
    wake_by_ref: fn(&unsafe Byte),

    // Drop the waker data.
    drop: fn(&unsafe Byte),
};

implement RawWakerVTable {
    // Create a new vtable.
    public fn new(
        clone: fn(&unsafe Byte) -> RawWaker,
        wake: fn(&unsafe Byte),
        wake_by_ref: fn(&unsafe Byte),
        drop: fn(&unsafe Byte),
    ) -> RawWakerVTable {
        RawWakerVTable {
            clone: clone,
            wake: wake,
            wake_by_ref: wake_by_ref,
            drop: drop,
        }
    }
}

// =============================================================================
// RawWaker — opaque data pointer paired with an inline vtable
// =============================================================================

// Low-level waker consisting of an opaque data pointer + the four-fn
// dispatch table that knows how to wake / clone / drop that data.
//
// The vtable is held **by value**, not by reference.  See the
// module-level comment for the design rationale.
public type RawWaker is {
    data: &unsafe Byte,
    vtable: RawWakerVTable,
};

implement RawWaker {
    // Create a new raw waker from a data pointer and an inline vtable.
    public fn new(data: &unsafe Byte, vtable: RawWakerVTable) -> RawWaker {
        RawWaker {
            data: data,
            vtable: vtable,
        }
    }
}

// =============================================================================
// Waker — public handle for waking up a task
// =============================================================================

// Handle for waking up a task. Carries an inline RawWaker (which
// carries its own inline vtable), so a Waker is self-contained: no
// dangling references, no separate vtable allocation, no static-init
// hazard.
public type Waker is {
    raw: RawWaker,
};

implement Waker {
    // Create waker from raw waker.  `unsafe` because the caller is
    // responsible for the data-pointer convention encoded in the
    // vtable's clone/wake/drop slots.
    public unsafe fn from_raw(raw: RawWaker) -> Waker {
        Waker { raw: raw }
    }

    // Wake the task associated with this waker. Consumes the waker.
    public fn wake(self) {
        let wake_fn = self.raw.vtable.wake;
        let data = self.raw.data;
        // Don't run drop since wake consumes
        forget(self);
        wake_fn(data);
    }

    // Wake by reference without consuming.
    public fn wake_by_ref(&self) {
        (self.raw.vtable.wake_by_ref)(self.raw.data);
    }

    // Check if two wakers will wake the same task.
    //
    // Identity contract: two wakers wake the same task iff their
    // data pointers AND wake/wake_by_ref vtable entries agree.
    // Comparing the vtable as a whole would over-reject — two
    // wakers built from independent value-copies of the same vtable
    // (no longer sharing one heap allocation under the by-value
    // layout) would compare unequal despite being semantically
    // identical.  Comparing the wake fn-pointer slots specifically
    // is the strongest semantic identity available: same wake
    // behaviour ⇒ same wake target.
    public fn will_wake(&self, other: &Waker) -> Bool {
        self.raw.data as Int == other.raw.data as Int
            && (self.raw.vtable.wake as Int) == (other.raw.vtable.wake as Int)
            && (self.raw.vtable.wake_by_ref as Int) == (other.raw.vtable.wake_by_ref as Int)
    }
}

implement Clone for Waker {
    fn clone(&self) -> Waker {
        // The vtable's `clone` function decides what data + vtable
        // the clone gets.  For the canonical noop case the clone
        // returns a fresh RawWaker carrying the same noop_* fn slots,
        // so will_wake against the source returns true.
        let raw = (self.raw.vtable.clone)(self.raw.data);
        Waker { raw: raw }
    }
}

implement Drop for Waker {
    fn drop(&mut self) {
        (self.raw.vtable.drop)(self.raw.data);
    }
}

implement Debug for Waker {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("Waker { .. }")
    }
}

// =============================================================================
// Context — what futures receive during polling
// =============================================================================

// Context passed to futures during polling. Contains the waker the
// future must capture before returning `Pending`, so the runtime
// has a way to re-poll it when progress is possible.
public type Context is {
    waker: &Waker,
};

implement Context {
    // Create context from waker.
    public fn from_waker(waker: &Waker) -> Context {
        Context { waker: waker }
    }

    // Get the waker from context.
    public fn waker(&self) -> &Waker {
        self.waker
    }
}

// =============================================================================
// Noop Waker — for synchronous polling and tests
// =============================================================================

// VTable functions for the noop waker.  Each is a deliberate no-op:
// noop_wake / noop_wake_by_ref discard the data pointer; noop_clone
// rebuilds the same vtable inline; noop_drop has nothing to release
// because noop_waker is constructed with a null data pointer.

// The four noop_* fn entries below are `public` even though
// users typically reach them only through `noop_waker()` —
// `public` ensures they survive Pass-1 stdlib precompile's
// dead-function pruning intact, so the function IDs encoded in
// the static NOOP_WAKER's vtable resolve at module load.

public fn noop_clone(data: &unsafe Byte) -> RawWaker {
    RawWaker.new(data, noop_vtable())
}

public fn noop_wake(_data: &unsafe Byte) {
    // Do nothing
}

public fn noop_wake_by_ref(_data: &unsafe Byte) {
    // Do nothing
}

public fn noop_drop(_data: &unsafe Byte) {
    // Do nothing
}

// Build a fresh noop vtable by value.  Cheap (just four fn-pointer
// stores) and side-steps the const/static-record-literal codegen gap
// described in the module comment.
public fn noop_vtable() -> RawWakerVTable {
    RawWakerVTable.new(noop_clone, noop_wake, noop_wake_by_ref, noop_drop)
}

// Create a waker that does nothing when woken. Useful for testing
// or simple synchronous polling contexts.
public fn noop_waker() -> Waker {
    let raw = RawWaker.new(0 as &unsafe Byte, noop_vtable());
    unsafe { Waker.from_raw(raw) }
}

// Module-static backing storage for the `&Waker` that `noop_context`
// returns.  The Waker (which now inlines its own vtable) carries no
// external references — its lifetime is purely structural.  The
// static gives the &Waker handed back from `noop_context()` a
// 'static-lived backing so the Context isn't dangling its `waker`
// field after the function returns.
static NOOP_WAKER: Waker = Waker {
    raw: RawWaker {
        data: 0 as &unsafe Byte,
        vtable: RawWakerVTable {
            clone: noop_clone,
            wake: noop_wake,
            wake_by_ref: noop_wake_by_ref,
            drop: noop_drop,
        },
    },
};

// Create a context with the noop waker. Useful for testing futures
// synchronously and for any context that need not propagate wake-ups.
//
// SOUNDNESS: returns a Context whose `&Waker` points at the
// module-static NOOP_WAKER, not a stack-local.  The earlier
// implementation captured `let waker = noop_waker()` and returned
// `&waker` — the local dropped at function exit, leaving callers
// with use-after-free on the first wake / clone attempt.
public fn noop_context() -> Context {
    Context.from_waker(&NOOP_WAKER)
}
