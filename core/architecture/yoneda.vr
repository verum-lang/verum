// =============================================================================
// core.architecture.yoneda — Yoneda-equivalence checker surface
// =============================================================================
//
// **Verum-native mirror of `verum_kernel::arch_yoneda`.**
//
// ## Yoneda equivalence
//
// Two architectures are equivalent iff every `Observer` in the
// canonical roster (EndUser / PeerCog / Stakeholder / Auditor /
// Adversary) projects the same observation.  This is the
// algorithmic Yoneda lemma applied to architecture: an object `X`
// of category `C` is uniquely determined by its representable
// functor `Hom(-, X) : C^op → Set`.  In ATS-V terms: a cog is
// uniquely determined by what every observer sees of it.
//
// ## Per-observer projection (what each Observer is sensitive to)
//
// | Observer    | Sees                                                    |
// |-------------|---------------------------------------------------------|
// | EndUser     | exposes + lifecycle (public-interface view)             |
// | PeerCog     | composes_with membership + boundary capabilities        |
// | Stakeholder | tier + foundation + lifecycle + persistence caps        |
// | Auditor     | full Shape projection (strictest observer)              |
// | Adversary   | attack_surface = exposes + outbound network/exec        |
//
// ## Engine guarantee
//
// A refactoring is **trivially safe** iff its before/after shapes
// are Yoneda-equivalent (every observer agrees).  The Auditor —
// strictest observer — agreeing alone is necessary but not
// sufficient: an attacker submitting a curated `agreements: [auditor_only]`
// would otherwise pass without testing the easier observers.  The
// red-team closure axiom `kernel_arch_yoneda_canonical_roster_complete`
// in `core.architecture.anti_patterns` requires the full 5-roster
// be walked before any equivalence verdict is binding.
//
// ## Self-attestation
//
// This cog is itself ATS-V-typed via the `@arch_module(...)`
// declaration below — dogfood for the architectural type system.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.architecture.yoneda;

mount core.prelude.{Bool, Int, List, Text};
mount super.types.{Capability, CveClosure, Foundation, Lifecycle, MsfsStratum, Tier};
mount super.mtac.Observer;

// =============================================================================
// ShapeObservation — what an observer sees
// =============================================================================

/// Projection of a `Shape` from a single `Observer`'s viewpoint.
/// Variants are per-observer-kind so each carries only the fields
/// that observer is sensitive to.  Equality of two observations
/// implies the observer cannot distinguish the two underlying
/// shapes.
public type ShapeObservation is
    | EndUserView {
        kind: Text,
        exposes: List<Capability>,
        lifecycle: Lifecycle,
      }
    | PeerCogView {
        module_path: Text,
        is_in_composition: Bool,
        requires: List<Capability>,
        exposes: List<Capability>,
      }
    | StakeholderView {
        role: Text,
        tier: Tier,
        foundation: Foundation,
        lifecycle: Lifecycle,
        persistence_capabilities: List<Capability>,
      }
    | AuditorView {
        audit_kind: Text,
        exposes: List<Capability>,
        requires: List<Capability>,
        foundation: Foundation,
        stratum: MsfsStratum,
        cve_closure: CveClosure,
        tier: Tier,
        lifecycle: Lifecycle,
        composes_with: List<Text>,
        strict: Bool,
      }
    | AdversaryView {
        threat_model: Text,
        attack_surface: List<Capability>,
        outbound_capabilities: List<Capability>,
      };

// =============================================================================
// AgreementStatus — per-observer agreement
// =============================================================================

public type AgreementStatus is
    | Agree
    | Disagree;

/// Per-observer agreement record.
public type ObserverAgreement is {
    observer: Observer,
    status: AgreementStatus,
    base_observation: ShapeObservation,
    alt_observation: ShapeObservation,
};

// =============================================================================
// YonedaVerdict — equivalence outcome
// =============================================================================

/// Aggregate Yoneda-equivalence verdict.  `equivalent` iff every
/// observer in the canonical 5-roster agrees AND `agreements` is
/// non-empty (refusal to claim equivalence from absence of
/// evidence).  The kernel-discharge axiom enforces full-roster
/// completeness so an attacker cannot fabricate equivalence by
/// submitting a single (e.g. auditor-only) agreement.
public type YonedaVerdict is {
    schema_version: Int,
    agreements: List<ObserverAgreement>,
    equivalent: Bool,
    disagreement_count: Int,
};

// =============================================================================
// Kernel-discharge bridge
// =============================================================================

/// **Yoneda-equivalence checker — algorithmic Yoneda lemma.**
///
/// Discharges the kernel-side Yoneda module's structural
/// guarantees:
///   * Each `Observer` projection is deterministic
///     (`Hom(-, X)(X) ≅ id_X` — observing a shape from itself
///     yields the identity observation).
///   * Two shapes are Yoneda-equivalent iff their projections
///     agree across every canonical observer.
///   * The verdict is sound only when the agreement list spans
///     the full canonical-5 roster — partial agreements cannot
///     fabricate equivalence (red-team closure
///     `kernel_arch_yoneda_canonical_roster_complete`).
@framework(ats_v, "ATS-V Yoneda-equivalence checker — two architectures equivalent iff every canonical Observer (EndUser / PeerCog / Stakeholder / Auditor / Adversary) projects the same observation.  Kernel implementation: crates/verum_kernel/src/arch_yoneda.rs.")
@kernel_discharge("kernel_arch_yoneda_equivalence")
public axiom kernel_arch_yoneda_equivalence() -> Bool
    ensures true;
