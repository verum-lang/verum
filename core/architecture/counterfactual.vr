// =============================================================================
// core.architecture.counterfactual — Counterfactual reasoning engine surface
// =============================================================================
//
// **Verum-native mirror of `verum_kernel::arch_counterfactual`.**
//
// ## What the counterfactual engine does
//
// The engine evaluates a cog's architectural Shape under base +
// alternative decisions WITHOUT actually switching the
// implementation.  Both decisions remain types; the engine
// performs comparative metric extraction at type level so a cog
// can be reasoned about as "would this property still hold if we
// had picked the other framework / database / encoding?"
//
// ## Pipeline
//
//   1. Caller supplies `(CounterfactualPair, base_shape, alt_shape)`.
//   2. `extract_metric` projects each Shape to typed `MetricValue`s
//      via the canonical 11-metric catalog (ExposedCapabilityCount,
//      ReadCapabilityCount, NetworkCapabilityCount, etc.).
//   3. `evaluate_invariant` walks each `ArchProposition` against
//      both shapes — returns `InvariantStatus` (HoldsBoth /
//      HoldsBaseOnly / HoldsAltOnly / HoldsNeither).
//   4. `CounterfactualReport` carries the comparative payload with
//      a stable `schema_version` field for agent surfaces under the
//      dual-audience contract (human review + machine pattern
//      matching share the same JSON shape).
//
// ## Soundness contract
//
// `overall_stable` iff every declared `stability_invariant`
// evaluates to `HoldsBoth`.  Empty invariants → unstable (the
// engine refuses to claim stability from absence of evidence).
// This pin closes a red-team vector: an attacker submitting a
// CounterfactualPair with `stability_invariants: []` cannot
// fabricate a "stable" verdict.
//
// ## Self-attestation
//
// This cog is itself ATS-V-typed via the `@arch_module(...)`
// declaration below — dogfood for the architectural type system.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.architecture.counterfactual;

mount core.prelude.{Bool, Float, Int, Maybe, List, Text};
mount super.mtac.{ArchProposition, CounterfactualPair};

// =============================================================================
// ArchMetric — canonical metric set
// =============================================================================

/// Architectural metric projectable from a `Shape`.  Baseline
/// set of 11 metrics; extending the catalog requires an ATS-V
/// RFC + a kernel-side `ArchMetric` enum bump + the cross-side
/// pin-test bump.  Stability versioning: existing variants never
/// renumber; deprecation requires ≥2 minor versions of dual
/// support.
public type ArchMetric is
    | ExposedCapabilityCount
    | RequiredCapabilityCount
    | ReadCapabilityCount
    | WriteCapabilityCount
    | NetworkCapabilityCount
    | BoundaryInvariantCount
    | CompositionDegree
    | LinearResourceCount
    | StratumOrdinal
    | CveCompleteness
    | StrictModeFlag
    | CustomMetric(Text);

// =============================================================================
// MetricValue — projection target
// =============================================================================

/// Result of projecting an `ArchMetric` from a `Shape`.
public type MetricValue is
    | IntegerMetric(Int)
    | FloatMetric(Float)
    | CategoricalMetric(Text)
    | UnknownMetric;

// =============================================================================
// InvariantStatus — relational evaluation outcome
// =============================================================================

/// Status of an `ArchProposition` under a counterfactual
/// evaluation.  Stability is a relational property: only
/// `HoldsBoth` satisfies counterfactual stability — `HoldsBaseOnly`
/// and `HoldsAltOnly` mean the proposition's truth depends on the
/// chosen decision, hence the architecture is brittle under that
/// decision.  `HoldsNeither` means the invariant simply fails in
/// both branches.
public type InvariantStatus is
    | HoldsBoth
    | HoldsBaseOnly
    | HoldsAltOnly
    | HoldsNeither;

// =============================================================================
// CounterfactualReport — engine output
// =============================================================================

/// Per-metric comparison entry.
public type MetricComparison is {
    metric: ArchMetric,
    base: MetricValue,
    alt: MetricValue,
    diverges: Bool,
};

/// Per-invariant evaluation entry.
public type InvariantEvaluation is {
    proposition: ArchProposition,
    status: InvariantStatus,
};

/// Counterfactual engine output — comparative payload with stable
/// JSON shape for agent / human dual-audience surfaces.
/// `overall_stable` iff every declared stability invariant evaluates
/// to `HoldsBoth`; `diverging_metric_count` records how many of the
/// 11 baseline metrics produced different values across the swap.
public type CounterfactualReport is {
    schema_version: Int,
    pair_name: Text,
    base_decision: Text,
    alt_decision: Text,
    metric_comparisons: List<MetricComparison>,
    invariant_evaluations: List<InvariantEvaluation>,
    overall_stable: Bool,
    diverging_metric_count: Int,
};

// =============================================================================
// Kernel-discharge bridge
// =============================================================================

/// **Counterfactual reasoning engine — non-destructive evaluation.**
///
/// Discharges the kernel-side counterfactual module's soundness
/// contracts:
///   * 4-arm `InvariantStatus` pins to four distinct relational
///     outcomes (HoldsBoth iff both shapes satisfy; HoldsBaseOnly
///     iff base satisfies but alt does not; symmetrically for
///     HoldsAltOnly; HoldsNeither otherwise).
///   * Empty stability invariants → `overall_stable: false` (the
///     engine refuses to claim stability from absence of evidence).
///   * 11-metric baseline catalog covers exposed/required
///     capability counts, network capability count, boundary
///     invariant count, composition degree, linear resource count,
///     stratum ordinal, CVE completeness, strict-mode flag plus
///     `Custom(name)` for user-defined metrics.
@framework(ats_v, "ATS-V counterfactual reasoning engine — non-destructive what-if evaluation at type level. Both decisions remain types; the engine performs comparative metric extraction across the 11-metric baseline catalog without ever switching implementations. Kernel implementation: crates/verum_kernel/src/arch_counterfactual.rs.")
@kernel_discharge("kernel_arch_counterfactual_engine")
public axiom kernel_arch_counterfactual_engine() -> Bool
    ensures true;
