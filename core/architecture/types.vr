// =============================================================================
// core.architecture.types — ATS-V architectural primitives
// =============================================================================
//
// **Verum-native mirror of `verum_kernel::arch`.**
//
// ## What ATS-V is
//
// The Architectural Type System for Verum (ATS-V) promotes
// architectural intent — *who can do what, across which boundary,
// under which discipline* — from prose into the type system.
// Eight primitives carry the load: Capability, Boundary,
// Composition, Lifecycle, Foundation, Tier, MsfsStratum,
// CveClosure.  Their aggregate is `Shape`, the typed fingerprint
// of every cog.
//
// ## Reuse-over-invention principle
//
// ATS-V introduces ZERO new grammar productions.  Every primitive
// is expressed via existing Verum syntax — variants, records,
// protocols, attributes:
//
//   * `type X is | A | B` — sum types carry Capability /
//     Lifecycle / Foundation / Tier / MsfsStratum / etc.
//   * `type X is { ... }` — records carry Boundary / CveClosure /
//     Shape / CapabilitySchema / etc.
//   * `@arch_module(...)` typed attribute — exactly one new
//     attribute name, parsed by the existing attribute mechanism.
//   * `@kernel_discharge(<intrinsic>)` axioms — bridge to kernel
//     side via the existing axiom-with-attribute pattern.
//   * Capability flavour (Linear / Affine / Relevant / Unrestricted)
//     attaches via the existing `@quantity(0|1|omega)` attribute
//     on the binding site, NOT via a parallel enum here.
//   * Verification routes (V-axis of CVE) reuse the existing
//     `@verify(strategy)` ladder.
//   * Foundation citation reuses existing `@framework(corpus, ...)`.
//   * Refinement predicates for anti-patterns reuse existing
//     `where` clauses.
//
// ## Cross-side pin (kernel ↔ Verum alignment)
//
// Every type, every variant, every helper function in this cog has
// a 1:1 counterpart in the Rust-side `verum_kernel::arch::*`
// module.  Drift in either direction breaks the architectural
// type-checker phase that walks `@arch_module(...)` declarations.
//
// The cross-side pin test in
// `crates/verum_kernel/tests/k_arch_v_alignment.rs` enumerates the
// canonical roster (variant count, variant tag, helper function
// presence) and fails CI on any divergence.  Adding a new variant
// requires updating BOTH sides AND the pin-test roster in the
// same change-set.
//
// ## Operationalisation
//
// Every methodological concept that is pure data is exposed as a
// `public fn` on the Verum side, not merely an axiom.  Verum
// cogs can compute lifecycle ranks, stratum admissibility,
// foundation subsumption, etc., without crossing the FFI
// boundary.  The kernel discharges only the non-decidable parts
// (e.g. capability-flow inference from cog source body).
//
// ## CVE — the seven-symbol taxonomy
//
// The Lifecycle variants below correspond to a seven-symbol
// canonical taxonomy used across the corpus to classify the
// epistemic state of every architectural artefact:
//
//   * `[H]` Hypothesis     — speculative; constructive partial,
//                            no verification, no execution.
//                            Must carry a maturation plan; without
//                            one it degrades to `[I]`.
//   * `[Plan]`             — ATS-V legacy "committed but not yet
//                            implemented" (TODO with a target
//                            completion date); distinct from `[P]`
//                            Postulate.
//   * `[P]` Postulate      — base assumption accepted without proof
//                            at this layer; constructive accepted,
//                            verifiable absent, executable accepted.
//                            Discharged by citation to a trusted
//                            external base.
//   * `[D]` Definition     — postulated by fiat; constructive
//                            present (the definition itself),
//                            verifiable trivial (definitions are not
//                            theorems), executable present.
//   * `[C]` Conditional    — proven under explicit assumptions;
//                            full CVE closure relative to those
//                            assumptions.  Reads as `[T]` in the
//                            context where the conditions hold.
//   * `[T]` Theorem        — fully proven, load-bearing; full CVE+
//                            triple closure (constructive +
//                            verifiable + executable).
//   * `[I]` Interpretation — CVE-violator; transitional only.  All
//                            three CVE axes absent AND no maturation
//                            plan.  Permitted ONLY in transitional
//                            corpus revisions; mature corpus must
//                            contain ZERO `[I]` entries.
//   * `[✗]` Retracted      — previously declared but withdrawn /
//                            refuted.  Removed from active corpus
//                            but record preserved as negative
//                            example in audit chronicle.
//   * `[O]` Obsolete       — deprecated, scheduled for removal;
//                            less strict than Retracted.
//
// Lifecycle ranks (used by AP-009 LifecycleRegression):
// `[T] > [D] = [C] > [P] > Plan > [H] > [I] > {[✗], Obsolete}`.
// Citing strictly-lower-rank artifacts from a higher-rank one is
// a defect; the check is transitive.
//
// ## Self-attestation
//
// This cog is itself ATS-V-typed via the `@arch_module(...)`
// declaration below — dogfood for the architectural type system.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.architecture.types;

mount core.prelude.{Bool, Int, Maybe, List, Text};

// =============================================================================
// Resource / target / realm tags
// =============================================================================

public type ResourceTag is
    | Database(Text)
    | File(Text)
    | Memory(Text)
    | Config(Text)
    | Logger
    | Random
    | CustomResource(Text);

public type ExecTarget is
    | Ffi(Text, Text)
    | Syscall(Int)
    | Program(Text)
    | CustomTarget(Text);

public type PrivilegeRealm is
    | Admin
    | Root
    | Audit
    | CustomRealm(Text);

public type TaskLifetime is
    | ScopedToParent
    | Detached
    | Deadlined(Int);

/// Expiration policy for `Capability.TimeBound`. Constructed
/// via the canonical variants OR ergonomic helpers (see
/// `expiration_after_duration`, `expiration_at_seconds`).
public type ExpirationPolicy is
    | AtUnixTime(Int)
    /// Capability lives `milliseconds` from issuance.
    | AfterDuration(Int)
    | OnEvent(Text);

/// Build an `AfterDuration` policy from a typed `Duration` —
/// ergonomic constructor preventing bare-millis literal-spam at
/// `@arch_module` declaration sites.
///
/// Composes `core.time.duration::Duration.as_millis`.
public fn expiration_after_duration(d: &core.time.duration.Duration) -> ExpirationPolicy {
    ExpirationPolicy.AfterDuration(d.as_millis())
}

/// Build an `AtUnixTime` policy from a Unix-epoch second count.
public fn expiration_at_seconds(unix_seconds: Int) -> ExpirationPolicy {
    ExpirationPolicy.AtUnixTime(unix_seconds)
}

public type PersistenceMedium is
    | Disk(Text)
    | DatabaseMedium(Text)
    | DistributedLog(Text);

/// Wire protocol carried by `Capability.Network`.
///
/// HTTP version distinctions are explicit because each version has
/// substantially different security and operational surfaces:
///   - `Http`  — HTTP/1.x (line-oriented, header-line attacks)
///   - `Http2` — binary framing, stream multiplexing
///               (Rapid-Reset CVE-2023-44487 surface)
///   - `Http3` — HTTP semantics over QUIC (0-RTT, conn migration)
/// Auditors check declarations against the deployed stack — a
/// mismatch triggers AP-016 WireEncodingMismatch.
public type NetProtocol is
    | Tcp
    | Udp
    | Unix
    | Tls
    | Quic
    | Http
    | Http2
    | Http3
    | Grpc
    | WebSocket
    | Mqtt
    | Amqp;

public type NetDirection is
    | Inbound
    | Outbound
    | Bidirectional;

// =============================================================================
// Capability — first-class possibility
// =============================================================================

/// First-class capability tracked at architecture level.  A
/// capability answers "what may this cog DO?" — read a resource,
/// write to one, execute an FFI/syscall/program, escalate
/// privilege, spawn a task, hold a time-bounded right, persist
/// state, or use a network endpoint.  Custom capabilities open
/// the catalog while preserving an explicit registry guard
/// (`core.architecture.capability_ontology`).
///
/// Substructural-logic flavour (Linear / Affine / Relevant /
/// Unrestricted) attaches via the existing `@quantity(0|1|omega)`
/// attribute at the binding site — NOT via a parallel enum here.
/// This keeps the capability *kind* and the capability *usage
/// discipline* in distinct, orthogonal type-system axes.
public type Capability is
    | Read(ResourceTag)
    | Write(ResourceTag)
    | Exec(ExecTarget)
    | Escalate(PrivilegeRealm)
    | Spawn(TaskLifetime)
    | TimeBound(ExpirationPolicy)
    | Persist(PersistenceMedium)
    | Network(NetProtocol, NetDirection)
    | CustomCapability(Text);

// =============================================================================
// Capability — ergonomic constructors
// =============================================================================
//
// Convenience builders that produce Capability values from typed
// `core.time.duration::Duration` and other natural inputs. Use these
// at `@arch_module` declaration sites to keep capability lists
// readable; the canonical variants above remain available for
// programmatic construction.

/// `Capability.TimeBound(...)` from a Duration. Equivalent to
/// `Capability.TimeBound(ExpirationPolicy.AfterDuration(d.as_millis()))`.
///
/// Example:
///   ```verum
///   exposes: [
///       Capability.time_bounded(Duration.from_hours(1)),
///       Capability.time_bounded(Duration.from_minutes(15)),
///   ],
///   ```
public fn capability_time_bounded(d: &core.time.duration.Duration) -> Capability {
    Capability.TimeBound(expiration_after_duration(d))
}

/// `Capability.Spawn(TaskLifetime.ScopedToParent)` — the canonical
/// "structured concurrency" lifetime. Most production cogs use
/// this; the bare variant is exposed for special cases (Detached
/// for daemons, Deadlined for explicit-deadline workers).
public fn capability_spawn_structured() -> Capability {
    Capability.Spawn(TaskLifetime.ScopedToParent)
}

/// `Capability.Spawn(TaskLifetime.Detached)` — for long-running
/// daemons with operator-controlled shutdown (NOT for ordinary
/// request handlers — those use structured spawn).
public fn capability_spawn_detached() -> Capability {
    Capability.Spawn(TaskLifetime.Detached)
}

/// `Capability.Spawn(TaskLifetime.Deadlined(d.as_millis()))` —
/// explicit-deadline worker.
public fn capability_spawn_deadlined(d: &core.time.duration.Duration) -> Capability {
    Capability.Spawn(TaskLifetime.Deadlined(d.as_millis()))
}

/// `Capability.Persist(PersistenceMedium.DatabaseMedium(tag))` —
/// the canonical persistence form for SQL connections. The `tag`
/// is the connection identifier (e.g., "postgres", "mysql/main").
public fn capability_persist_database(connection_tag: Text) -> Capability {
    Capability.Persist(PersistenceMedium.DatabaseMedium(connection_tag))
}

/// `Capability.Persist(PersistenceMedium.Disk(path))` — for
/// filesystem-backed persistence (CBOR archives, append-only
/// logs, S3-mounted FUSE, etc.). Object stores are also a `Disk`
/// medium with a URI-shaped path (`s3://bucket/prefix/`).
public fn capability_persist_disk(path: Text) -> Capability {
    Capability.Persist(PersistenceMedium.Disk(path))
}

/// `Capability.Persist(PersistenceMedium.DistributedLog(topic))` —
/// for Kafka / NATS JetStream / Redis Streams append-only
/// persistence (sumdb, audit ledger).
public fn capability_persist_log(topic: Text) -> Capability {
    Capability.Persist(PersistenceMedium.DistributedLog(topic))
}

/// `Capability.Network(protocol, direction)` constructors for the
/// most common shapes. The direct variants remain available for
/// uncommon protocol/direction combinations.

public fn capability_http_inbound() -> Capability {
    Capability.Network(NetProtocol.Http, NetDirection.Inbound)
}

public fn capability_http2_inbound() -> Capability {
    Capability.Network(NetProtocol.Http2, NetDirection.Inbound)
}

public fn capability_http3_inbound() -> Capability {
    Capability.Network(NetProtocol.Http3, NetDirection.Inbound)
}

public fn capability_http_outbound() -> Capability {
    Capability.Network(NetProtocol.Http, NetDirection.Outbound)
}

public fn capability_grpc_inbound() -> Capability {
    Capability.Network(NetProtocol.Grpc, NetDirection.Inbound)
}

public fn capability_websocket_inbound() -> Capability {
    Capability.Network(NetProtocol.WebSocket, NetDirection.Inbound)
}

// =============================================================================
// Boundary — cross-module typed traffic discipline
// =============================================================================

public type MessageType is
    | TypedMessage(Text, Text)
    | CapabilityTransfer(Text)
    | ControlFrame(Text)
    | RawMessage;

public type BoundaryInvariant is
    | AllOrNothing
    | DeterministicSerialisation
    | AuthenticatedFirst
    | BackpressureHonoured
    | CustomInvariant(Text);

public type WireEncoding is
    | VerumNative
    | ProtoBuf(Text)
    | JsonEncoding(Text)
    | MsgPack
    | RawBytes;

public type BoundaryPhysicalLayer is
    | Intracrate
    | Intracess
    | Ipc
    | NetworkLayer;

/// Cross-module / cross-cog boundary.  A `Boundary` carries the
/// **typed traffic discipline** at the cog's edge:
///   * what messages enter and leave (`messages_in`, `messages_out`)
///   * which capabilities transfer across the edge as values
///     (`capability_handoff`)
///   * what predicates both sides preserve at all times
///     (`invariants`)
///   * how the bytes are encoded on the wire (`wire_encoding`)
///   * where the boundary physically sits — same crate, IPC,
///     network — (`physical_layer`).
///
/// A Boundary makes cross-cog interaction structurally explicit:
/// raw byte streams, dangling message types, and unauthenticated
/// crossings each surface as distinct anti-patterns
/// (`DanglingMessageType`, `UnauthenticatedCrossing`,
/// `InvariantViolation`).
public type Boundary is {
    messages_in: List<MessageType>,
    messages_out: List<MessageType>,
    capability_handoff: List<Capability>,
    invariants: List<BoundaryInvariant>,
    wire_encoding: WireEncoding,
    physical_layer: BoundaryPhysicalLayer,
};

// =============================================================================
// Lifecycle — staged status
// =============================================================================

public type ConfidenceLevel is
    | Low
    | Medium
    | High;

/// Lifecycle stage — the maturation level of an architectural
/// artefact, encoded into the CVE seven-symbol taxonomy detailed
/// in this cog's header comment.  See the `lifecycle_rank` and
/// `lifecycle_cve_glyph` helpers below for the operational
/// projections used by AP-009 (LifecycleRegression).
///
/// Rank poset (used by AP-009 LifecycleRegression):
///   Theorem > {Definition, Conditional} > Postulate > Plan
///     > Hypothesis > Interpretation > {Retracted, Obsolete}
///
/// CVE-glyph mapping (single-character canonical codes used in
/// audit JSON, error messages, and dual-audience rendering):
///   Hypothesis     = H   speculative
///   Plan           = Plan (ATS-V legacy, no CVE glyph)
///   Postulate      = P   base assumption (kernel-discharge)
///   Definition     = D   by-fiat boundary
///   Conditional    = C   proven under explicit conditions
///   Theorem        = T   CVE⁺ full closure (load-bearing)
///   Interpretation = I   CVE-violator (transitional only)
///   Retracted      = ✗   explicitly withdrawn / refuted
///   Obsolete       = O   deprecated (legacy)
public type Lifecycle is
    | Hypothesis(ConfidenceLevel)
    | Plan(Text)
    | Postulate(Text)
    | Definition
    | Conditional(List<Text>)
    | Theorem(Text)
    | Interpretation(Text)
    | Retracted(Text, Maybe<Text>)
    | Obsolete(Text, Maybe<Text>);

// =============================================================================
// Foundation — meta-theoretic profile
// =============================================================================

/// Foundation profile — the meta-theoretic universe a cog's
/// proof corpus inhabits.  Composing two cogs whose foundations
/// differ without an explicit functor-bridge between them raises
/// `FoundationDrift` (ATS-V-AP-005): there is no canonical
/// translation that preserves the truth-values of refinement
/// predicates across the divide.
///
/// Canonical inclusions (no bridge required):
///   * `Mltt → Cic`     CIC subsumes Martin-Löf TT (CIC = MLTT
///                      + inductive families)
///   * `Hott → Cubical` cubical HoTT subsumes Book HoTT
///
/// Cross-paradigm pairs (e.g. ZFC ↔ HoTT) require an explicit
/// `@framework(bridge_corpus, ...)` declaration; otherwise AP-005
/// fires.
///
/// **Tag-usage convention** — when does a cog tag which Foundation?
///
/// The `Foundation` enum has seven inhabitants but only one
/// (`ZfcTwoInacc`) is in active use across the corpus.  This is
/// not an oversight; the others have a precise role defined by
/// the meta-theory:
///
///   * `ZfcTwoInacc` — DEFAULT.  Tag this when the cog's `.vr`
///     source is itself implemented in Verum's standard
///     meta-theory (ZFC + 2 strongly-inaccessibles).  Every
///     current cog in `core/` uses this tag, including
///     `core/math/hott.vr` and `core/math/cubical.vr` which
///     EXPOSE HoTT/cubical primitives but are themselves
///     implemented in ZFC (the Verum-source code uses standard
///     match expressions, refinement types, etc., not HoTT-native
///     constructs).
///
///   * `Hott` / `Cubical` / `Mltt` / `Cic` / `Eff` — RESERVED for
///     future cogs whose `.vr` source SEMANTICS requires the
///     named foundation to be sound.  Such a cog would (a) use
///     constructs unique to that foundation (e.g. univalence as a
///     definitional equality, not an axiom), and (b) have
///     refinement predicates whose truth values depend on the
///     foundation's own axioms.  No such cog exists in the
///     current corpus; the enum variants are kept for the
///     subsumption-graph testing visible through
///     `foundation_directly_subsumed_by` and for future
///     extensibility.
///
///   * `CustomFoundation(name, framework_corpus)` — for
///     user-defined foundations admitted via the
///     `@framework(corpus, ...)` registration mechanism.
///
/// **Important pin**: the operational `Foundation.Hott` /
/// `Foundation.Cubical` enum variant exists and is recognised
/// by the parser, but tagging it on a cog whose `.vr` source is
/// actually implemented in ZFC would be a `FoundationForgery`
/// (AP-023) — declared foundation does NOT match cited axioms.
/// The current `core/math/hott.vr` correctly tags `ZfcTwoInacc`
/// because its implementation is ZFC-sound; downstream cogs
/// CITING HoTT axioms would not change that.
public type Foundation is
    | ZfcTwoInacc
    | Hott
    | Cubical
    | Cic
    | Mltt
    | Eff
    | CustomFoundation(Text, Text);

// =============================================================================
// Tier — execution placement
// =============================================================================

/// Execution tier — where the cog runs.  Tier mismatches between
/// caller and callee without an explicit bridge raise `TierMixing`
/// (ATS-V-AP-004): a Tier-0 interpreter cannot transparently call
/// into a Tier-2 GPU kernel, etc.
///
/// Tiers:
///   * `Interp`    — Tier 0: VBC interpreter, fast startup.
///   * `Aot`       — Tier 1: AOT via LLVM, native speed.
///   * `Gpu`       — Tier 2: GPU compilation via MLIR.
///   * `Check`     — Type-checking only, no codegen, nothing runs.
///   * `MultiTier` — cog runs on any of the listed tiers.
///
/// **Variant naming pin**: `Check` (not `TierCheck`). Mirrors
/// `verum_kernel::arch::Tier::Check` — the kernel parser at
/// `arch_parse::parse_tier` accepts the bare segment `"Check"` and
/// rejects `"TierCheck"`. Any drift here breaks `@arch_module(at_tier
/// = Tier.Check)` declarations.
public type Tier is
    | Interp
    | Aot
    | Gpu
    | Check
    | MultiTier(List<Tier>);

// =============================================================================
// MsfsStratum — position in MSFS moduli space
// =============================================================================

/// MSFS stratum — position of the cog in the moduli space of the
/// Modular-Stratified Foundation reflection tower.  Three
/// admissible levels plus one canonically-empty level:
///
///   * `LFnd`    — foundation level, base of the tower.
///   * `LCls`    — classifier level, derives from LFnd.
///   * `LClsTop` — maximal classifier sub-class.
///   * `LAbs`    — empty by AFN-T α (boundary closure axiom);
///                 declaring it is a defect.
///
/// Any cog claiming `LAbs` triggers AP-011 `AbsoluteBoundaryAttempt`.
/// The accompanying soundness pin `stratum_l_abs_unique_inadmissible`
/// asserts admissibility is exactly the complement of `LAbs`.
public type MsfsStratum is
    | LFnd
    | LCls
    | LClsTop
    | LAbs;

// =============================================================================
// CveClosure — Constructive / Verifiable / Executable triple
// =============================================================================

/// Verification strategy — the level of discharge claimed for a
/// proposition.  Mirrors the existing `@verify(...)` attribute
/// ladder, NOT a parallel system.  The 9 strategies are strictly
/// ordered on the Diakrisis ν-ladder:
///
///   `Runtime < Static < Fast < Formal < Proof < Thorough <
///    Reliable < Certified < Synthesize`
///
/// Refining downward (e.g. `formal` to `runtime`) on an existing
/// proposition is itself a Diakrisis regression and an AP-009
/// candidate.
public type VerifyStrategy is
    | Runtime
    | Static
    | Fast
    | Formal
    | Proof
    | Thorough
    | Reliable
    | Certified
    | Synthesize;

/// CVE-closure triple — three orthogonal axes that, together,
/// constitute a fully discharged architectural claim:
///
///   * `constructive`         — Constructive witness: a function
///                              path or constructor that produces
///                              the artefact concretely.
///   * `verifiable_strategy`  — Verification route: which `@verify`
///                              ladder step discharges the claim.
///   * `executable`           — Executable artefact: an entry
///                              point or audit command that
///                              actually runs the witness.
///
/// In strict mode (`@arch_module(strict = true)`), all three axes
/// MUST be present; missing any axis is AP-010 (CveIncomplete).
/// Soft mode emits warnings instead of errors.  Per the
/// dual-audience contract, the resulting diagnostic surfaces
/// both human-readable text and machine-readable RFC codes so
/// reviewers and agents share a vocabulary.
public type CveClosure is {
    constructive: Maybe<Text>,
    verifiable_strategy: Maybe<VerifyStrategy>,
    executable: Maybe<Text>,
};

// =============================================================================
// CVE-architecture spec primitives — operationalisation of cve-architecture.md
// =============================================================================
//
// The CVE-architecture spec (`internal/cve/docs/cve-architecture.md`)
// declares a set of load-bearing concepts that ATS-V must operationalise:
//
//   * `ExecutabilitySense`   — §2.3.0: three senses of the E axis
//                              (structural readiness vs current
//                              execution vs post-factum chronicle);
//                              CVE-E refers exclusively to structural
//                              readiness.
//   * `CognitiveSubstrate`   — §1.5: the cognitive mode under which
//                              CVE operates (analytic-decompositional
//                              by default; alternative substrates are
//                              co-equal in their domains of validity).
//   * `FormalAnchoring`      — §4.5: the formal tradition in which the
//                              tri-axis closure is anchored. Curry-
//                              Howard-Lawvere is the most-developed
//                              anchoring; parallel anchorings exist
//                              in automata theory, control theory,
//                              distributed protocols, functional
//                              systems, and institutional design.
//   * `Purpose` + thresholds — §14.6: declared purpose terminates an
//                              audit. K/V/E thresholds specify the
//                              level sufficient for the role; the
//                              audit closes when configuration meets
//                              thresholds (no infinite polishing).
//   * `ArchitecturalDefect`  — §20.4: format for registering
//                              defects against the architecture
//                              itself, distinct from the L0..L5 audit
//                              chronicle. Resolves at L4 (revision)
//                              or L2 (refinement of methodology).
// =============================================================================

// ----- ExecutabilitySense (§2.3.0) -----

/// The three senses of executability that CVE-E disambiguates.
/// CVE-E refers EXCLUSIVELY to `StructuralReadiness`. The other two
/// are co-located concepts that audits frequently conflate:
///
///   * `StructuralReadiness`    — the artefact admits a working
///                                representation deployable in a
///                                suitable environment. THIS IS
///                                THE CONTENT OF THE E AXIS.
///   * `CurrentExecution`       — the artefact is, at this moment,
///                                running in production. Stronger
///                                than E; characterises L0 maturity
///                                in spec §3.5 [T] state, but is
///                                not what the E axis asks.
///   * `PostFactumChronicle`    — accumulated history of past
///                                execution. Material for
///                                antifragility chronicle (§15);
///                                NOT the content of the E axis.
///
/// A `[T]` Theorem cog requires `StructuralReadiness`. Citing past
/// execution (`PostFactumChronicle`) as evidence of E is the
/// `BoundlessAudit`/`ImplicitSubstrate` family of register collisions.
public type ExecutabilitySense is
    | StructuralReadiness
    | CurrentExecution
    | PostFactumChronicle;

/// Stable diagnostic tag for `ExecutabilitySense`. Used in audit
/// JSON, anti-pattern messages, dual-audience surfaces.
public fn executability_sense_tag(s: ExecutabilitySense) -> Text {
    match s {
        StructuralReadiness  => "structural_readiness",
        CurrentExecution     => "current_execution",
        PostFactumChronicle  => "post_factum_chronicle",
    }
}

/// True iff the sense is the canonical content of CVE-E. Soundness
/// pin: exactly one of three senses (`StructuralReadiness`) anchors
/// the E axis; the other two are co-located but not equivalent.
public fn executability_sense_is_canonical_e(s: ExecutabilitySense) -> Bool {
    match s {
        StructuralReadiness  => true,
        CurrentExecution     => false,
        PostFactumChronicle  => false,
    }
}

// ----- CognitiveSubstrate (§1.5) -----

/// The cognitive mode under which a knowledge artefact is
/// articulated. CVE itself operates under the
/// `AnalyticDecompositional` substrate; alternative substrates are
/// co-equal in their proper domains of validity, and the
/// architecture's self-disclosure of its own substrate is part of
/// operational hygiene per spec §1.5.
///
///   * `AnalyticDecompositional` — CVE's own substrate: the artefact
///                                  is decomposed into the three K/V/E
///                                  projections, each evaluated
///                                  separately, the verdict assembled.
///                                  Default for `@arch_module(...)`.
///   * `HolisticRelational`      — the artefact is evaluated as a
///                                  non-decomposable node in a network
///                                  of relations (e.g. living tradition,
///                                  network maturity).
///   * `ActionCentric`           — the primary object IS the action,
///                                  not the result; the artefact's
///                                  identity is in performance
///                                  (e.g. craft mastery, performance
///                                  disciplines).
///   * `TraditionTransmitting`   — the artefact's identity is in
///                                  multi-generational reproduction
///                                  through a transmission lineage.
///
/// CVE applies fully to the `AnalyticDecompositional` substrate;
/// for the others CVE captures the *transmissible articulable
/// contour* only, leaving non-articulable surface outside the
/// CVE-zone (spec §13.4).
public type CognitiveSubstrate is
    | AnalyticDecompositional
    | HolisticRelational
    | ActionCentric
    | TraditionTransmitting;

/// Stable diagnostic tag for `CognitiveSubstrate`.
public fn cognitive_substrate_tag(s: CognitiveSubstrate) -> Text {
    match s {
        AnalyticDecompositional  => "analytic_decompositional",
        HolisticRelational       => "holistic_relational",
        ActionCentric            => "action_centric",
        TraditionTransmitting    => "tradition_transmitting",
    }
}

/// Default substrate for ATS-V annotations: CVE's native mode.
/// A cog whose declared substrate is anything else and which
/// claims `[T]` Theorem in strict mode triggers AP-038
/// `ImplicitSubstrate` unless the substrate-mismatch is
/// explicitly bridged (spec §13.4).
public fn cognitive_substrate_default() -> CognitiveSubstrate {
    AnalyticDecompositional
}

// ----- FormalAnchoring (§4.5) -----

/// The formal tradition anchoring the tri-axis closure of an
/// architectural artefact. Curry-Howard-Lawvere is the eponym and
/// most-developed anchoring; the other variants register parallel
/// anchorings on different stages of formalisation, per spec §4.5.
///
///   * `CurryHowardLawvere`     — logic ↔ types ↔ categories;
///                                 the canonical anchoring for
///                                 mathematical and SE artefacts.
///   * `AutomataTheory`         — grammars ↔ automata ↔ languages;
///                                 the tri-register for formal
///                                 languages and parsers.
///   * `ControlTheory`          — state equations ↔ transfer
///                                 functions ↔ realisations;
///                                 the tri-register for dynamical
///                                 systems.
///   * `DistributedProtocols`   — specifications ↔ execution
///                                 models ↔ observable traces;
///                                 the tri-register for distributed
///                                 systems.
///   * `FunctionalSystems`      — afferent synthesis ↔ action
///                                 program ↔ result acceptor;
///                                 the tri-register for
///                                 behavioural biology and
///                                 cognitive physiology.
///   * `InstitutionalDesign`    — normative structure ↔ decision
///                                 procedure ↔ stabilised
///                                 practices; the tri-register for
///                                 social institutions.
///   * `CustomAnchoring(name)`  — user-registered anchoring (open
///                                 catalog, validated against the
///                                 anchoring registry).
///
/// A cog whose `Foundation` is mathematical/SE-style but which
/// makes claims in a non-CHL domain (e.g. an institutional protocol
/// described as a `[T]` Theorem with no anchoring declaration)
/// triggers AP-039 `AnchoringOverextension` in strict mode.
public type FormalAnchoring is
    | CurryHowardLawvere
    | AutomataTheory
    | ControlTheory
    | DistributedProtocols
    | FunctionalSystems
    | InstitutionalDesign
    | CustomAnchoring(Text);

/// Stable diagnostic tag for `FormalAnchoring`.
public fn formal_anchoring_tag(a: FormalAnchoring) -> Text {
    match a {
        CurryHowardLawvere    => "curry_howard_lawvere",
        AutomataTheory        => "automata_theory",
        ControlTheory         => "control_theory",
        DistributedProtocols  => "distributed_protocols",
        FunctionalSystems     => "functional_systems",
        InstitutionalDesign   => "institutional_design",
        CustomAnchoring(_)    => "custom_anchoring",
    }
}

/// Default anchoring for Verum-native artefacts: the CHL eponym.
/// Spec §4.5 identifies this as the most-developed anchoring; cogs
/// whose body inhabits CHL need not declare it explicitly.
public fn formal_anchoring_default() -> FormalAnchoring {
    CurryHowardLawvere
}

// ----- Purpose + K/V/E thresholds (§14.6) -----

/// Threshold on the K (Constructive) axis declared sufficient for
/// the artefact's role. A K-witness at or above the threshold
/// closes the K question of the audit; below, action A
/// (replenishment) is required, action B (status downgrade) is
/// permitted, action C (deletion) is the residual.
///
///   * `FullWitness`              — explicit, computable,
///                                  first-class witness; no holes.
///   * `TypedSchema`              — schema-with-typed-parameters
///                                  is sufficient (e.g. a generic
///                                  reference under a type-level
///                                  constraint).
///   * `ReferenceImplBounded`     — reference implementation
///                                  bounded to a stated domain
///                                  is sufficient.
public type CveThresholdK is
    | FullWitness
    | TypedSchema
    | ReferenceImplBounded;

/// Threshold on the V (Verifiable) axis.
///
///   * `FullFormalProof`        — kernel-checked machine proof
///                                in the chosen meta-theory.
///   * `TypecheckPlusTests`     — typechecker + named test battery
///                                with declared coverage.
///   * `NamedCertification`     — passage of a named certification
///                                (e.g. external audit, conformance
///                                suite) is sufficient.
public type CveThresholdV is
    | FullFormalProof
    | TypecheckPlusTests
    | NamedCertification;

/// Threshold on the E (Executable, in the `StructuralReadiness`
/// sense per `ExecutabilitySense`) axis.
///
///   * `StructurallyReady`         — deployable in any environment
///                                   of the declared class.
///   * `DeployedInOneEnv`          — one specific environment is
///                                   sufficient.
///   * `FunctorialOnly`            — a functor in a category is
///                                   sufficient (e.g. for purely
///                                   mathematical artefacts).
public type CveThresholdE is
    | StructurallyReady
    | DeployedInOneEnv
    | FunctorialOnly;

/// Stable diagnostic tags for the three threshold axes. Used in
/// audit JSON when a `Purpose` is rendered.
public fn cve_threshold_k_tag(t: CveThresholdK) -> Text {
    match t {
        FullWitness            => "full_witness",
        TypedSchema            => "typed_schema",
        ReferenceImplBounded   => "reference_impl_bounded",
    }
}

public fn cve_threshold_v_tag(t: CveThresholdV) -> Text {
    match t {
        FullFormalProof      => "full_formal_proof",
        TypecheckPlusTests   => "typecheck_plus_tests",
        NamedCertification   => "named_certification",
    }
}

public fn cve_threshold_e_tag(t: CveThresholdE) -> Text {
    match t {
        StructurallyReady   => "structurally_ready",
        DeployedInOneEnv    => "deployed_in_one_env",
        FunctorialOnly      => "functorial_only",
    }
}

/// Declared purpose of an architectural artefact, per spec §14.6.
/// The purpose terminates the audit: when configuration meets
/// thresholds, the audit closes (no infinite polishing). Without
/// a declared purpose AND a strict-mode audit invocation, AP-037
/// `BoundlessAudit` fires.
///
///   * `role`        — short label of the role the artefact serves.
///   * `k_min`       — minimum K threshold sufficient for the role.
///   * `v_min`       — minimum V threshold sufficient for the role.
///   * `e_min`       — minimum E threshold sufficient for the role.
public type Purpose is {
    role: Text,
    k_min: CveThresholdK,
    v_min: CveThresholdV,
    e_min: CveThresholdE,
};

/// A safe default purpose for cogs that genuinely have no
/// audit-bounding role declared. NOT recommended for `[T]` Theorem
/// or `[C]` Conditional cogs in strict mode — those should declare
/// purpose explicitly.
public fn purpose_default() -> Purpose {
    Purpose {
        role: "unspecified",
        k_min: CveThresholdK.FullWitness,
        v_min: CveThresholdV.TypecheckPlusTests,
        e_min: CveThresholdE.StructurallyReady,
    }
}

// ----- ArchitecturalDefect (§20.4) -----

/// Kind of architectural defect, per spec §20.4. Resolution path
/// depends on kind: `FalseRejection` and `FalseAcceptance` cluster
/// at L4 (architectural revision); `InterLayerLeak` may resolve
/// at L4 OR L2 (methodological refinement) depending on the leak's
/// origin.
public type DefectKind is
    | FalseRejection
    | FalseAcceptance
    | InterLayerLeak
    | OtherDefect(Text);

/// Resolution path for a registered architectural defect.
/// `L4Revision` modifies the architectural law itself (rare);
/// `L2Refinement` adjusts the methodology layer without touching
/// the architectural law (typical).
public type Resolution is
    | L4Revision
    | L2Refinement
    | OtherResolution(Text);

/// Stable diagnostic tags for `DefectKind` and `Resolution`.
public fn defect_kind_tag(k: DefectKind) -> Text {
    match k {
        FalseRejection      => "false_rejection",
        FalseAcceptance     => "false_acceptance",
        InterLayerLeak      => "inter_layer_leak",
        OtherDefect(_)      => "other_defect",
    }
}

public fn resolution_tag(r: Resolution) -> Text {
    match r {
        L4Revision           => "l4_revision",
        L2Refinement         => "l2_refinement",
        OtherResolution(_)   => "other_resolution",
    }
}

/// Architectural defect record, per spec §20.4. Every registered
/// defect carries a complete provenance chain: the version of the
/// architecture against which it was filed, the witness artefact,
/// the application context, the observed and expected results, the
/// proposed resolution. Self-application of CVE to the chronicle
/// itself: K — record format is specified; V — every revision
/// validates against the three §20.2 criteria; I — the resolution
/// procedure is executable.
public type ArchitecturalDefect is {
    short_name: Text,
    arch_version: Text,
    submitted_on: Text,
    submitter: Text,
    kind: DefectKind,
    witness_artefact: Text,
    application_context: Text,
    observed_result: Text,
    expected_result: Text,
    proposed_resolution: Resolution,
};

// ----- SelfReferenceWitness + FixpointClass (§16 articulation hygiene) -----

/// Class of fixed-point theorem under which a self-referential
/// construct admits a unique fixed point. Per cve-architecture spec
/// §16: «никогда «само-X», всегда «оператор `T_X` + неподвижная
/// точка `Fix(T_X)`».  A cog that asserts a self-referential
/// property MUST cite which fixed-point theorem discharges the
/// existence and (where applicable) uniqueness of `Fix(T_X)`.
///
///   * `Banach`           — Banach fixed-point theorem (contracting
///                          operator on complete metric space). The
///                          witness must ship a contraction-
///                          coefficient bound `k ∈ [0, 1)`.
///   * `Tarski`           — Tarski-Knaster theorem (monotone operator
///                          on complete lattice). The witness must
///                          ship a monotonicity proof.
///   * `Adamek`           — Adamek's theorem on initial algebras
///                          (continuous functor on cocomplete
///                          category). The witness must ship a
///                          continuity proof.
///   * `CustomFixpoint`   — user-cited theorem; the citation MUST
///                          appear in the cog's `@framework(...)`
///                          attribute and be enumerable by
///                          `verum audit --framework-axioms`.
///
/// **Universal-property characterisation.** Categorically, a
/// fixed-point theorem is the assertion that, in a chosen category
/// `C` and for a chosen class `E ⊆ End(C)` of endomorphisms, every
/// `T ∈ E` has a fixed point `Fix(T)`. The triple
/// `(category, endomorphism_class, theorem)` is the universal-property
/// classifier; concrete theorems (Banach, Tarski-Knaster, Adamek)
/// inhabit specific points of this classifier and are produced by the
/// smart constructors `fixpoint_class_banach`,
/// `fixpoint_class_tarski`, `fixpoint_class_adamek`.

/// The category `C` in which a fixed-point theorem is stated.
public type FixpointCategory is
    | CompleteMetricSpace
    | CompleteLattice
    | CocompleteCategory
    | CustomCategory(Text);

/// The class `E ⊆ End(C)` of endomorphisms admitted by a
/// fixed-point theorem.
public type EndomorphismClass is
    | Contracting
    | Monotone
    | ContinuousFunctor
    | CustomEndomorphismClass(Text);

/// The theorem citation discharging a fixed-point claim.
public type FixpointTheorem is
    | Banach
    | Tarski
    | Adamek
    | Custom(Text);

/// Universal-property classifier of a fixed-point theorem.
public type FixpointClass is {
    category: FixpointCategory,
    endomorphism_class: EndomorphismClass,
    theorem: FixpointTheorem,
};

/// Smart constructor for Banach's fixed-point theorem class.
public fn fixpoint_class_banach() -> FixpointClass {
    FixpointClass {
        category: FixpointCategory.CompleteMetricSpace,
        endomorphism_class: EndomorphismClass.Contracting,
        theorem: FixpointTheorem.Banach,
    }
}

/// Smart constructor for the Tarski-Knaster theorem class.
public fn fixpoint_class_tarski() -> FixpointClass {
    FixpointClass {
        category: FixpointCategory.CompleteLattice,
        endomorphism_class: EndomorphismClass.Monotone,
        theorem: FixpointTheorem.Tarski,
    }
}

/// Smart constructor for Adamek's initial-algebra theorem class.
public fn fixpoint_class_adamek() -> FixpointClass {
    FixpointClass {
        category: FixpointCategory.CocompleteCategory,
        endomorphism_class: EndomorphismClass.ContinuousFunctor,
        theorem: FixpointTheorem.Adamek,
    }
}

/// Smart constructor for a user-cited fixed-point theorem class.
/// The citation MUST be enumerable via
/// `verum audit --framework-axioms`.
public fn fixpoint_class_custom_fixpoint(citation: Text) -> FixpointClass {
    FixpointClass {
        category: FixpointCategory.CustomCategory(citation),
        endomorphism_class: EndomorphismClass.CustomEndomorphismClass(citation),
        theorem: FixpointTheorem.Custom(citation),
    }
}

/// Stable diagnostic tag for `FixpointClass`, dispatched on the
/// theorem citation.
public fn fixpoint_class_tag(f: FixpointClass) -> Text {
    match f.theorem {
        Banach     => "banach",
        Tarski     => "tarski",
        Adamek     => "adamek",
        Custom(_)  => "custom_fixpoint",
    }
}

/// Returns `true` when this class is one of the three canonical
/// (Banach / Tarski / Adamek); `false` for `Custom`.
public fn fixpoint_class_is_canonical(f: FixpointClass) -> Bool {
    match f.theorem {
        Banach | Tarski | Adamek  => true,
        Custom(_)                 => false,
    }
}

/// Self-reference witness, per cve-architecture spec §16. A cog
/// whose `Shape` exhibits a self-referential pattern (self in
/// `composes_with`, capability targeting the cog's own holon,
/// requires citing the cog itself) MUST declare this witness.
/// Absence triggers AP-040 `SelfReferenceWithoutOperator`.
///
///   * `operator`        — path to the cog implementing the
///                         operator `T_X` whose fixed point the
///                         self-referential cog inhabits. The
///                         operator cog MUST have lifecycle
///                         ≥ `Conditional`.
///   * `fixed_point`     — path to the cog implementing the fixed
///                         point `Fix(T_X)`. May coincide with the
///                         self-referential cog itself when the
///                         self-reference is constructive (the cog
///                         IS its own fixed point under `T_X`).
///   * `fixpoint_class`  — fixed-point theorem class discharging
///                         existence (and where applicable
///                         uniqueness) of `Fix(T_X)`.
public type SelfReferenceWitness is {
    operator: Text,
    fixed_point: Text,
    fixpoint_class: FixpointClass,
};

/// Default-constructor for SelfReferenceWitness. Used in tests
/// only; production cogs MUST supply a non-default witness with
/// concrete operator and fixed-point paths.
public fn self_reference_witness_unspecified() -> SelfReferenceWitness {
    SelfReferenceWitness {
        operator: "unspecified",
        fixed_point: "unspecified",
        fixpoint_class: fixpoint_class_custom_fixpoint("unspecified"),
    }
}

// ----- ShapeDeclarations — spec-load-bearing optional declarations -----

/// Optional declarations packaged into a `Shape`. Carries the
/// CVE-architecture spec concepts that are not yet load-bearing in
/// the canonical primitives but ARE load-bearing in the
/// architectural law: declared purpose (terminates audit), declared
/// cognitive substrate (CVE's mode of operation, defaults to
/// `AnalyticDecompositional`), declared formal anchoring (CHL by
/// default), declared executability sense (`StructuralReadiness`
/// by default), declared self-reference witness (operator + fixed
/// point + fixpoint class, per spec §16; required when the cog's
/// `Shape` exhibits self-referential patterns).
///
/// All five are `Maybe<...>` so `@arch_module(...)` need not declare
/// them explicitly; absent declarations default per the helpers
/// `cognitive_substrate_default`, `formal_anchoring_default`,
/// canonical `ExecutabilitySense.StructuralReadiness`,
/// `purpose_default()`, and `self_reference == None` (no
/// self-reference). In strict mode, absence triggers the CVE-AH
/// band anti-patterns (AP-037..AP-040).
public type ShapeDeclarations is {
    purpose: Maybe<Purpose>,
    substrate: Maybe<CognitiveSubstrate>,
    anchoring: Maybe<FormalAnchoring>,
    e_sense: Maybe<ExecutabilitySense>,
    self_reference: Maybe<SelfReferenceWitness>,
};

/// Empty declarations record — every field unspecified, the
/// architectural type-checker fills defaults at audit time.
public fn shape_declarations_empty() -> ShapeDeclarations {
    ShapeDeclarations {
        purpose: None,
        substrate: None,
        anchoring: None,
        e_sense: None,
        self_reference: None,
    }
}

// =============================================================================
// Shape — main carrier of @arch_module(...)
// =============================================================================

/// Main carrier of `@arch_module(...)` — the typed architectural
/// fingerprint of a cog.  The compiler builds a `Shape` from each
/// `@arch_module(...)` declaration; the ATS-V phase (Phase 6.5,
/// between type inference and VBC codegen) consumes it during
/// architectural type checking and produces the per-module
/// violation roster.
///
/// Field semantics (12 canonical fields the parser recognises):
///   * `exposes`          — capabilities surfacing externally
///   * `requires`         — capabilities the cog needs from peers
///   * `preserves`        — boundary invariants honoured by the
///                          cog at every internal call
///   * `consumes`         — linear/affine resources the cog uses
///                          up (canonical format
///                          `<resource>/<N> <unit>` — see AT-5
///                          closure axiom in anti_patterns.vr)
///   * `at_tier`          — execution tier constraint
///   * `foundation`       — meta-theoretic profile
///   * `stratum`          — MSFS moduli-space level
///   * `cve_closure`      — CVE-closure triple
///   * `lifecycle`        — maturation stage
///   * `composes_with`    — cogs/functions this one composes with
///   * `strict`           — strict-mode flag (errors vs warnings)
///   * `declarations`     — optional CVE-architecture spec
///                          declarations (purpose, substrate,
///                          anchoring, e_sense). Per spec §1.5,
///                          §2.3.0, §4.5, §14.6.
public type Shape is {
    exposes: List<Capability>,
    requires: List<Capability>,
    preserves: List<BoundaryInvariant>,
    consumes: List<Text>,
    at_tier: Tier,
    foundation: Foundation,
    stratum: MsfsStratum,
    cve_closure: CveClosure,
    lifecycle: Lifecycle,
    composes_with: List<Text>,
    strict: Bool,
    declarations: Maybe<ShapeDeclarations>,
};

// =============================================================================
// CapabilitySchema — inline metadata for Capability.Custom
// =============================================================================

/// Schema bundled into a `Capability.Custom` variant — mirrors
/// `verum_kernel::arch::CapabilitySchema`.  Distinct from
/// `core.architecture.capability_ontology.CapabilityRegistration`,
/// which is a registry-side record carrying `name` + `deprecation`;
/// `CapabilitySchema` is the inline payload the kernel constructs
/// at parse time when the cog source declares
/// `Capability.Custom { tag: "x", schema: CapabilitySchema { ... } }`.
public type CapabilitySchema is {
    description: Text,
    transfers_privilege: Bool,
    subsumed_by: List<Text>,
};

/// Default schema for a custom capability the kernel parser cannot
/// resolve to a registry entry.  Conservative: zero-priv by default,
/// no subsumption claims.  Matches kernel `arch_parse.rs` fallback.
public fn capability_schema_inferred_default() -> CapabilitySchema {
    CapabilitySchema {
        description: "<inferred at parse time>",
        transfers_privilege: false,
        subsumed_by: [],
    }
}

// =============================================================================
// Operationalisation — pure-data helpers (mirror kernel `impl` methods)
// =============================================================================
//
// Every helper here is a TOTAL, DECIDABLE function on pure data.
// No FFI, no kernel intrinsic — Verum cogs can call them directly.
// The kernel-side `impl` blocks compute the same values bit-for-bit;
// the cross-side pin test in `verum_kernel/tests/k_arch_v_alignment.rs`
// asserts every match arm here corresponds to a kernel match arm.
// =============================================================================

// ----- Tier -----

/// Stable diagnostic tag — single token used in audit JSON,
/// anti-pattern messages, dual-audience surfaces (spec §32.4).
/// Mirrors `verum_kernel::arch::Tier::tag`.
public fn tier_tag(t: Tier) -> Text {
    match t {
        Interp        => "interp",
        Aot           => "aot",
        Gpu           => "gpu",
        Check         => "check",
        MultiTier(_)  => "multi_tier",
    }
}

/// True iff `caller_tier` can call into `callee_tier` without
/// violating tier discipline (spec §4.7).  Mirrors
/// `verum_kernel::arch::Tier::compatible_with`.
///
/// **Soundness**: identity always; MultiTier is reflexive set-membership;
/// Check is incompatible with any executable tier (Check is type-check-only,
/// nothing runs).  Cross-tier pairs (Interp ↔ Aot ↔ Gpu) require an
/// explicit `@bridge_tier(...)` annotation — flagged by AP-004.
public fn tier_compatible_with(caller: Tier, callee: Tier) -> Bool {
    match (caller, callee) {
        (Check, _)          => false,
        (_, Check)          => false,
        (Interp, Interp)    => true,
        (Aot, Aot)          => true,
        (Gpu, Gpu)          => true,
        (MultiTier(allowed), other)  => tier_list_contains(allowed, other),
        (other, MultiTier(allowed))  => tier_list_contains(allowed, other),
        _                   => false,
    }
}

fn tier_list_contains(allowed: List<Tier>, target: Tier) -> Bool {
    let mut i: Int = 0;
    while i < allowed.len() {
        if tier_eq(allowed[i], target) {
            return true;
        }
        i = i + 1;
    }
    false
}

fn tier_eq(a: Tier, b: Tier) -> Bool {
    match (a, b) {
        (Interp, Interp)         => true,
        (Aot, Aot)               => true,
        (Gpu, Gpu)               => true,
        (Check, Check)           => true,
        (MultiTier(_), MultiTier(_)) => true, // structural equality is caller's job
        _                        => false,
    }
}

// ----- MsfsStratum -----

public fn stratum_tag(s: MsfsStratum) -> Text {
    match s {
        LFnd    => "l_fnd",
        LCls    => "l_cls",
        LClsTop => "l_cls_top",
        LAbs    => "l_abs",
    }
}

/// True iff the stratum is admissible — i.e. NOT `LAbs`.  AFN-T α
/// (MSFS Theorem 5.1) proves `L_Abs` is empty by construction;
/// declaring it triggers AP-011 `AbsoluteBoundaryAttempt`.
public fn stratum_is_admissible(s: MsfsStratum) -> Bool {
    match s {
        LAbs => false,
        _    => true,
    }
}

// ----- Foundation -----

public fn foundation_tag(f: Foundation) -> Text {
    match f {
        ZfcTwoInacc           => "zfc_two_inacc",
        Hott                  => "hott",
        Cubical               => "cubical",
        Cic                   => "cic",
        Mltt                  => "mltt",
        Eff                   => "eff",
        CustomFoundation(_,_) => "custom",
    }
}

/// True iff `self` is interpretable into `target` without an
/// explicit functor-bridge.  Canonical inclusions (spec §4.6):
///   * identity (any → itself)
///   * `Mltt → Cic`     — CIC subsumes MLTT (CIC = MLTT + inductive families)
///   * `Hott → Cubical` — cubical subsumes Book HoTT
///
/// Cross-paradigm pairs (e.g. ZFC ↔ HoTT) require explicit
/// `@framework(bridge_corpus, ...)`; otherwise AP-005 fires.
public fn foundation_directly_subsumed_by(src: Foundation, target: Foundation) -> Bool {
    match (src, target) {
        (ZfcTwoInacc, ZfcTwoInacc) => true,
        (Hott, Hott)               => true,
        (Cubical, Cubical)         => true,
        (Cic, Cic)                 => true,
        (Mltt, Mltt)               => true,
        (Eff, Eff)                 => true,
        (Mltt, Cic)                => true,
        (Hott, Cubical)            => true,
        _                          => false,
    }
}

// ----- Lifecycle -----

public fn lifecycle_tag(lc: Lifecycle) -> Text {
    match lc {
        Hypothesis(_)     => "hypothesis",
        Plan(_)           => "plan",
        Postulate(_)      => "postulate",
        Definition        => "definition",
        Conditional(_)    => "conditional",
        Theorem(_)        => "theorem",
        Interpretation(_) => "interpretation",
        Retracted(_,_)    => "retracted",
        Obsolete(_,_)     => "obsolete",
    }
}

/// CVE §3.5 single-character status code — for compact rendering
/// in cross-format outputs and stable error codes.  Mirrors
/// `verum_kernel::arch::Lifecycle::cve_glyph`.
public fn lifecycle_cve_glyph(lc: Lifecycle) -> Text {
    match lc {
        Hypothesis(_)     => "H",
        Plan(_)           => "Plan",  // ATS-V legacy — no CVE glyph
        Postulate(_)      => "P",
        Definition        => "D",
        Conditional(_)    => "C",
        Theorem(_)        => "T",
        Interpretation(_) => "I",
        Retracted(_,_)    => "✗",
        Obsolete(_,_)     => "O",
    }
}

/// Lifecycle ordering for AP-009 LifecycleRegression check.
/// `[T] > [D] = [C] > [P] > Plan > [H] > [I] > {[✗], Obsolete}`.
/// CVE §3.5 + §3.1: mature artifacts cite mature artifacts.
public fn lifecycle_rank(lc: Lifecycle) -> Int {
    match lc {
        Obsolete(_,_)     => 0,
        Retracted(_,_)    => 0,
        Interpretation(_) => 1,
        Hypothesis(_)     => 2,
        Plan(_)           => 3,
        Postulate(_)      => 4,
        Definition        => 5,
        Conditional(_)    => 5,
        Theorem(_)        => 6,
    }
}

/// True iff the lifecycle is forbidden in mature corpus per CVE §6.7
/// — `[I]` Interpretation without a maturation plan.  Used by the
/// future anti-pattern check `InterpretationInMatureCorpus`.
public fn lifecycle_is_mature_corpus_forbidden(lc: Lifecycle) -> Bool {
    match lc {
        Interpretation(_) => true,
        _                 => false,
    }
}

// ----- CveClosure -----

/// Number of CVE axes that discharge (0..=3).
public fn cve_closure_degree(cve: CveClosure) -> Int {
    let mut n: Int = 0;
    if cve.constructive is Some(_)         { n = n + 1; }
    if cve.verifiable_strategy is Some(_)  { n = n + 1; }
    if cve.executable is Some(_)           { n = n + 1; }
    n
}

/// True iff all three CVE axes are present (full CVE-closure).
public fn cve_closure_is_fully_closed(cve: CveClosure) -> Bool {
    cve_closure_degree(cve) == 3
}

// ----- VerifyStrategy -----

public fn verify_strategy_tag(s: VerifyStrategy) -> Text {
    match s {
        Runtime    => "runtime",
        Static     => "static",
        Fast       => "fast",
        Formal     => "formal",
        Proof      => "proof",
        Thorough   => "thorough",
        Reliable   => "reliable",
        Certified  => "certified",
        Synthesize => "synthesize",
    }
}

/// Strength rank — strictly increasing on the Diakrisis ν-ladder
/// (VVA §12).  Higher rank ≡ stronger discharge; ascending steps
/// only — refining a `formal` to `runtime` flag is a Diakrisis
/// regression and AP-009 candidate.
public fn verify_strategy_rank(s: VerifyStrategy) -> Int {
    match s {
        Runtime    => 0,
        Static     => 1,
        Fast       => 2,
        Formal     => 3,
        Proof      => 4,
        Thorough   => 5,
        Reliable   => 6,
        Certified  => 7,
        Synthesize => 8,
    }
}

// ----- Capability -----

public fn capability_tag(c: Capability) -> Text {
    match c {
        Read(_)              => "read",
        Write(_)             => "write",
        Exec(_)              => "exec",
        Escalate(_)          => "escalate",
        Spawn(_)             => "spawn",
        TimeBound(_)         => "time_bound",
        Persist(_)           => "persist",
        Network(_,_)         => "network",
        CustomCapability(_)  => "custom",
    }
}

// ----- Shape -----

/// Default shape for cogs without `@arch_module` per spec §6.1
/// (smart default inference).  Soft-mode trivial — vacuously
/// passes every anti-pattern check.  Mirrors
/// `verum_kernel::arch::Shape::default_for_unannotated`.
public fn shape_default_for_unannotated() -> Shape {
    Shape {
        exposes: [],
        requires: [],
        preserves: [],
        consumes: [],
        at_tier: Tier.MultiTier([Tier.Interp, Tier.Aot]),
        foundation: Foundation.ZfcTwoInacc,
        stratum: MsfsStratum.LFnd,
        cve_closure: CveClosure {
            constructive: None,
            verifiable_strategy: None,
            executable: None,
        },
        lifecycle: Lifecycle.Plan("unspecified"),
        composes_with: [],
        strict: false,
        declarations: None,
    }
}

// =============================================================================
// Soundness theorems — pure-data invariants provable from the helpers
// =============================================================================

/// **Soundness pin**: lifecycle ranks form a strict partial order
/// where `Theorem > Conditional > Plan > Hypothesis > Obsolete`.
/// Decidable from `lifecycle_rank` alone; mirrored by the kernel
/// pin test `lifecycle_rank_orders_correctly`.
public fn lifecycle_rank_strict_order_holds() -> Bool {
    lifecycle_rank(Lifecycle.Theorem("v0.1")) > lifecycle_rank(Lifecycle.Conditional([])) &&
    lifecycle_rank(Lifecycle.Conditional([])) > lifecycle_rank(Lifecycle.Plan("x")) &&
    lifecycle_rank(Lifecycle.Plan("x")) > lifecycle_rank(Lifecycle.Hypothesis(ConfidenceLevel.Medium)) &&
    lifecycle_rank(Lifecycle.Hypothesis(ConfidenceLevel.Medium)) > lifecycle_rank(Lifecycle.Obsolete("x", None))
}

/// **Soundness pin**: AFN-T α boundary closure — `LAbs` is the
/// unique inadmissible stratum.
public fn stratum_l_abs_unique_inadmissible() -> Bool {
    !stratum_is_admissible(MsfsStratum.LAbs) &&
    stratum_is_admissible(MsfsStratum.LFnd) &&
    stratum_is_admissible(MsfsStratum.LCls) &&
    stratum_is_admissible(MsfsStratum.LClsTop)
}

/// **Soundness pin**: Foundation subsumption is reflexive +
/// asymmetric on canonical inclusions (CIC ⊃ MLTT, Cubical ⊃ HoTT).
public fn foundation_canonical_inclusions_hold() -> Bool {
    foundation_directly_subsumed_by(Foundation.Mltt, Foundation.Cic) &&
    foundation_directly_subsumed_by(Foundation.Hott, Foundation.Cubical) &&
    !foundation_directly_subsumed_by(Foundation.Cic, Foundation.Mltt) &&
    !foundation_directly_subsumed_by(Foundation.ZfcTwoInacc, Foundation.Hott)
}

/// **Soundness pin**: Tier `Check` runs nothing — incompatible with
/// every executable tier.
public fn tier_check_runs_nothing() -> Bool {
    !tier_compatible_with(Tier.Check, Tier.Aot) &&
    !tier_compatible_with(Tier.Aot, Tier.Check) &&
    !tier_compatible_with(Tier.Check, Tier.Interp) &&
    !tier_compatible_with(Tier.Check, Tier.Gpu)
}

/// **Soundness pin** (spec §2.3.0): of the three executability
/// senses, exactly one (`StructuralReadiness`) is the canonical
/// content of the CVE-E axis. The other two are co-located but
/// distinct; conflating them is a register collision (§2.3.0).
public fn executability_sense_canonical_unique() -> Bool {
    executability_sense_is_canonical_e(ExecutabilitySense.StructuralReadiness) &&
    !executability_sense_is_canonical_e(ExecutabilitySense.CurrentExecution) &&
    !executability_sense_is_canonical_e(ExecutabilitySense.PostFactumChronicle)
}

/// **Soundness pin** (spec §1.5): the default cognitive substrate
/// for ATS-V annotations is `AnalyticDecompositional`. The other
/// substrates are co-equal in their proper domains but require
/// explicit declaration to be load-bearing.
public fn cognitive_substrate_default_is_analytic() -> Bool {
    match cognitive_substrate_default() {
        AnalyticDecompositional  => true,
        _                        => false,
    }
}

/// **Soundness pin** (spec §4.5): the default formal anchoring is
/// the eponymous Curry-Howard-Lawvere triad. Other anchorings are
/// co-equal where they apply but require explicit declaration.
public fn formal_anchoring_default_is_chl() -> Bool {
    match formal_anchoring_default() {
        CurryHowardLawvere  => true,
        _                   => false,
    }
}

/// **Soundness pin** (spec §14.6): a default purpose has all three
/// thresholds set; this enables vacuous audit termination for cogs
/// without an explicit purpose declaration. Strict-mode cogs SHOULD
/// override this default to bound the audit per their actual role.
public fn purpose_default_is_complete() -> Bool {
    let p = purpose_default();
    match p.k_min {
        FullWitness | TypedSchema | ReferenceImplBounded  => true,
    } &&
    match p.v_min {
        FullFormalProof | TypecheckPlusTests | NamedCertification  => true,
    } &&
    match p.e_min {
        StructurallyReady | DeployedInOneEnv | FunctorialOnly  => true,
    }
}

/// **Soundness pin** (CVE articulation hygiene §8): the four
/// canonical `FixpointClass` smart-constructors produce pairwise
/// distinct diagnostic tags.  Pin guards the AP-040 dispatch table
/// from silent collision on tag rendering.
public fn fixpoint_class_tags_distinct() -> Bool {
    fixpoint_class_tag(fixpoint_class_banach()) != fixpoint_class_tag(fixpoint_class_tarski()) &&
    fixpoint_class_tag(fixpoint_class_tarski()) != fixpoint_class_tag(fixpoint_class_adamek()) &&
    fixpoint_class_tag(fixpoint_class_adamek()) != fixpoint_class_tag(fixpoint_class_custom_fixpoint("any")) &&
    fixpoint_class_tag(fixpoint_class_banach()) != fixpoint_class_tag(fixpoint_class_custom_fixpoint("any"))
}

/// **Soundness pin** (CVE articulation hygiene §8 — universal-property
/// classifier): the three canonical smart constructors map to the
/// canonical `(category, endomorphism_class, theorem)` triples.
public fn fixpoint_class_canonical_triples() -> Bool {
    let b = fixpoint_class_banach();
    let t = fixpoint_class_tarski();
    let a = fixpoint_class_adamek();
    fixpoint_class_is_canonical(b) &&
    fixpoint_class_is_canonical(t) &&
    fixpoint_class_is_canonical(a) &&
    !fixpoint_class_is_canonical(fixpoint_class_custom_fixpoint("any"))
}

// ============================================================
// CVE seven-cell closure (seven-configurations §9).
// ============================================================

/// **CVE axis mode** — per-axis valuation in the closure analysis
/// of the seven-configurations truth-table. Three modes per axis,
/// 3³ = 27 cells in the configuration space `CveAxisMode³`.
///
/// - `Positive`  — axis clearly satisfied (witness present, decision
///                 procedure present, executable representation present).
/// - `Partial`   — axis satisfied with qualification: trivial-by-fiat
///                 (definition), conditional (under stated assumption),
///                 external (delegated via citation), or formulated
///                 but not realised.
/// - `Absent`    — axis not satisfied; no witness, no check, no
///                 executable representation.
///
/// The seven productive configurations of the seven-configurations
/// taxonomy (`[T]`, `[D]`, `[C]`, `[P]`, `[H]`, `[I]`, `[✗]`) are
/// the stable attractors of `CveAxisMode³`. The migration map from
/// each cell to a productive cell is given by
/// `seven_configurations_closure_witness`.
public type CveAxisMode is
    | Positive
    | Partial
    | Absent;

/// Stable diagnostic tag for `CveAxisMode`. Three values; pin-guarded
/// for cross-side alignment.
public fn cve_axis_mode_tag(m: CveAxisMode) -> Text {
    match m {
        Positive  => "positive",
        Partial   => "partial",
        Absent    => "absent",
    }
}

/// **Closure witness for the CVE seven-cell theorem** (seven-configurations
/// §9). For every (c, v, e) ∈ `CveAxisMode³` returns the canonical glyph
/// of the productive cell to which the configuration migrates under the
/// deciding rule (seven-configurations §10).
///
/// Glyph alphabet: `[T]` Theorem, `[D]` Definition, `[C]` Conditional,
/// `[P]` Postulate, `[H]` Hypothesis, `[I]` Interpretation. `[✗]`
/// Retracted is a meta-state outside `CveAxisMode³` (deliberate
/// withdrawal) and is not produced by this witness.
///
/// Default migration of V=Partial is to `[C]` Conditional. The
/// V-partial sub-classification (trivial → `[D]`, external → `[P]`,
/// conditional → `[C]`) is operational and lives at the call site;
/// the closure witness returns the most general migration target.
public fn seven_configurations_closure_witness(
    c: CveAxisMode,
    v: CveAxisMode,
    e: CveAxisMode,
) -> Text {
    match (c, v, e) {
        (Positive, Positive, Positive)  => "[T]",
        (Positive, Positive, Partial)   => "[C]",
        (Positive, Positive, Absent)    => "[C]",
        (Positive, Partial,  Positive)  => "[C]",
        (Positive, Partial,  Partial)   => "[C]",
        (Positive, Partial,  Absent)    => "[C]",
        (Positive, Absent,   Positive)  => "[H]",
        (Positive, Absent,   Partial)   => "[H]",
        (Positive, Absent,   Absent)    => "[H]",
        (Partial,  Positive, Positive)  => "[C]",
        (Partial,  Positive, Partial)   => "[C]",
        (Partial,  Positive, Absent)    => "[C]",
        (Partial,  Partial,  Positive)  => "[C]",
        (Partial,  Partial,  Partial)   => "[C]",
        (Partial,  Partial,  Absent)    => "[H]",
        (Partial,  Absent,   Positive)  => "[H]",
        (Partial,  Absent,   Partial)   => "[H]",
        (Partial,  Absent,   Absent)    => "[H]",
        (Absent,   Positive, Positive)  => "[I]",
        (Absent,   Positive, Partial)   => "[I]",
        (Absent,   Positive, Absent)    => "[I]",
        (Absent,   Partial,  Positive)  => "[I]",
        (Absent,   Partial,  Partial)   => "[I]",
        (Absent,   Partial,  Absent)    => "[I]",
        (Absent,   Absent,   Positive)  => "[I]",
        (Absent,   Absent,   Partial)   => "[I]",
        (Absent,   Absent,   Absent)    => "[I]",
    }
}

/// Predicate: glyph belongs to the productive alphabet (six base glyphs).
fn is_productive_glyph(g: Text) -> Bool {
    g == "[T]" || g == "[D]" || g == "[C]" ||
    g == "[P]" || g == "[H]" || g == "[I]"
}

/// **Soundness pin** (CVE seven-cell closure §9): every cell of
/// `CveAxisMode³` maps to a productive glyph. The 27-arm match
/// in `seven_configurations_closure_witness` is exhaustive by
/// pattern coverage; this pin re-asserts exhaustiveness operationally.
public fn seven_configurations_closure_exhaustive() -> Bool {
    is_productive_glyph(seven_configurations_closure_witness(Positive, Positive, Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Positive, Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Positive, Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Partial,  Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Partial,  Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Partial,  Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Absent,   Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Absent,   Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Positive, Absent,   Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Positive, Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Positive, Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Positive, Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Partial,  Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Partial,  Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Partial,  Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Absent,   Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Absent,   Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Partial,  Absent,   Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Positive, Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Positive, Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Positive, Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Partial,  Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Partial,  Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Partial,  Absent))   &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Absent,   Positive)) &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Absent,   Partial))  &&
    is_productive_glyph(seven_configurations_closure_witness(Absent,   Absent,   Absent))
}
