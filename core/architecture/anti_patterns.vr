/// Full canonical roster — exactly 39 entries.  Adding a 40th
/// requires RFC ATS-V-008 + kernel-side enum bump + pin-test bump.
/// Used by `verum audit --bundle` to walk every code at runtime.
public fn anti_pattern_full_roster() -> List<AntiPatternCode> {
    [
        AntiPatternCode.CapabilityEscalation,
        AntiPatternCode.CapabilityLeak,
        AntiPatternCode.DependencyCycle,
        AntiPatternCode.TierMixing,
        AntiPatternCode.FoundationDrift,
        AntiPatternCode.RegisterMixing,
        AntiPatternCode.TxStraddling,
        AntiPatternCode.ResourceStraddling,
        AntiPatternCode.LifecycleRegression,
        AntiPatternCode.CveIncomplete,
        AntiPatternCode.AbsoluteBoundaryAttempt,
        AntiPatternCode.InvariantViolation,
        AntiPatternCode.DanglingMessageType,
        AntiPatternCode.UnauthenticatedCrossing,
        AntiPatternCode.DeterministicViolation,
        AntiPatternCode.CapabilityDuplication,
        AntiPatternCode.OrphanCapability,
        AntiPatternCode.MissingHandoff,
        AntiPatternCode.FoundationDowngrade,
        AntiPatternCode.TimeBoundLeakage,
        AntiPatternCode.PersistenceMismatch,
        AntiPatternCode.CapabilityLaundering,
        AntiPatternCode.FoundationForgery,
        AntiPatternCode.TransitiveLifecycleRegression,
        AntiPatternCode.DeclarationDrift,
        AntiPatternCode.FoundationContentMismatch,
        AntiPatternCode.TemporalInconsistency,
        AntiPatternCode.CounterfactualBrittleness,
        AntiPatternCode.MissedAdjoint,
        AntiPatternCode.UniversalPropertyViolation,
        AntiPatternCode.PhantomEvolution,
        AntiPatternCode.YonedaInequivalentRefactor,
        AntiPatternCode.RetractedCitationUse,
        AntiPatternCode.HypothesisWithoutMaturationPlan,
        AntiPatternCode.InterpretationInMatureCorpus,
        AntiPatternCode.ObserverImpersonation,
        AntiPatternCode.BoundlessAudit,
        AntiPatternCode.ImplicitSubstrate,
        AntiPatternCode.AnchoringOverextension,
    ]
}

/// **Pin**: roster size is exactly 39.  Mirrors kernel-side test
/// `architectural_pin_anti_pattern_count`.
public fn anti_pattern_roster_size_invariant() -> Bool {
    anti_pattern_full_roster().len() == 39
}

// =============================================================================
// Severity — diagnostic level
// =============================================================================

/// Diagnostic severity for an `AntiPatternViolation`.  Maps onto
/// the host diagnostic system's three-level surface.  Mirrors
/// `verum_kernel::arch_anti_pattern::Severity`.
public type Severity is
    | Error    // Hard error — fails the audit; mature corpus must close
    | Warning  // Non-blocking; soft-mode default for not-yet-strict cogs
    | Hint;    // Gentle nudge for code that could be cleaner

public fn severity_tag(s: Severity) -> Text {
    match s {
        Error   => "error",
        Warning => "warning",
        Hint    => "hint",
    }
}

// =============================================================================
// AntiPatternViolation — structured diagnostic
// =============================================================================

/// Structured diagnostic produced when an anti-pattern check fails.
/// Per spec §32.4 — dual-audience: `human_message` for review,
/// `auto_fix_suggestion` for agent automated remediation.
/// Mirrors `verum_kernel::arch_anti_pattern::AntiPatternViolation`.
public type AntiPatternViolation is {
    code: AntiPatternCode,
    severity: Severity,
    summary: Text,
    human_message: Text,
    auto_fix_suggestion: Maybe<Text>,
};

// =============================================================================
// DiagnosticContext — caller-provided context for richer messages
// =============================================================================

/// Context the caller supplies to anti-pattern checkers so the
/// resulting diagnostics can reference the cog by name + cite the
/// surrounding module.  Mirrors
/// `verum_kernel::arch_anti_pattern::DiagnosticContext`.
public type DiagnosticContext is {
    cog_name: Text,
    parent_module: Maybe<Text>,
};

public fn diagnostic_context_default() -> DiagnosticContext {
    DiagnosticContext {
        cog_name: "<unknown>",
        parent_module: None,
    }
}

// =============================================================================
// Capability discipline (AP-001 + AP-002)
// =============================================================================

/// **ATS-V-AP-001 + ATS-V-AP-002: Capability discipline.**
///
/// Composes `CapabilityEscalation` (ATS-V-AP-001 — undeclared
/// capabilities) and `CapabilityLeak` (ATS-V-AP-002 — linear
/// capabilities escaping scope).
///
/// **Stable RFC codes**: ATS-V-AP-001, ATS-V-AP-002.
@framework(ats_v, "ATS-V Anti-pattern catalog — AP-001 CapabilityEscalation (cog uses an undeclared capability), AP-002 CapabilityLeak (linear/affine capability escapes its declared scope). Capability flavour Linear/Affine/Relevant/Unrestricted reuses the existing @quantity(0|1|omega) binding-site attribute, NOT a parallel enum.")
@kernel_discharge("kernel_arch_capability_discipline")
public axiom kernel_arch_capability_discipline() -> Bool
    ensures true;

// =============================================================================
// Boundary type check
// =============================================================================

/// **Boundary type check: cross-module messages + invariants.**
///
/// Verifies that messages crossing a boundary conform to the
/// declared `messages_in` / `messages_out` lists, capability
/// handoffs match `capability_handoff`, and BoundaryInvariants
/// hold.
@framework(ats_v, "ATS-V Boundary type check — cross-module traffic is typed at the cog edge: messages_in/messages_out enumerate allowed crossings, capability_handoff records value-level transfers, invariants pin two-sided predicates. Raw byte streams (RawBytes wire encoding without justification), dangling message types (Typed{name,schema_hash} without an entry in messages_*), and unauthenticated crossings (Network boundary without AuthenticatedFirst invariant) raise AP-013/AP-014/AP-012 respectively.")
@kernel_discharge("kernel_arch_boundary_check")
public axiom kernel_arch_boundary_check() -> Bool
    ensures true;

// =============================================================================
// Composition algebra
// =============================================================================

/// **Composition algebra: A ⊗ B per spec §5.3.**
///
/// Verifies that composition of cogs A and B satisfies the rules:
/// * Capability flow valid (B.requires ⊆ A.exposes).
/// * Foundations compatible (or explicit bridge).
/// * Tiers compatible.
/// * Resulting stratum is admissible (not LAbs).
/// * No dependency cycle (AP-003).
/// * Composition is associative + decidable (proved RT1.5).
@framework(ats_v, "ATS-V Composition algebra — A ⊗ B is well-formed iff: (1) capability flow valid (B.requires ⊆ A.exposes), (2) foundations compatible (equality OR canonical inclusion), (3) tiers compatible per tier_compatible_with, (4) neither stratum is LAbs, (5) the composition graph stays acyclic. Composition is associative ((A⊗B)⊗C ≡ A⊗(B⊗C)) and decidable in time linear in the union of capabilities. Detects AP-003 DependencyCycle, AP-004 TierMixing, AP-005 FoundationDrift, AP-018 MissingHandoff through this dispatch.")
@kernel_discharge("kernel_arch_composition_check")
public axiom kernel_arch_composition_check() -> Bool
    ensures true;

// =============================================================================
// Lifecycle integrity
// =============================================================================

/// **ATS-V-AP-009: LifecycleRegression.**
///
/// Verifies that a cog's lifecycle stage is `≥` every cited cog's
/// stage. `[Т]Theorem` cannot cite `[Г]Hypothesis` directly nor
/// transitively (the check is transitive per RT1.3 refinement).
///
/// **Stable RFC code**: ATS-V-AP-009.
@framework(ats_v, "ATS-V-AP-009 LifecycleRegression. Lifecycle rank poset: Theorem(6) > {Definition, Conditional}(5) > Postulate(4) > Plan(3) > Hypothesis(2) > Interpretation(1) > {Retracted, Obsolete}(0). A higher-rank cog citing a strictly-lower-rank one is a defect — load-bearing artefacts must rest on load-bearing dependencies. The check is transitive (AP-024 catches multi-hop regression chains).")
@kernel_discharge("kernel_arch_lifecycle_check")
public axiom kernel_arch_lifecycle_check() -> Bool
    ensures true;

// =============================================================================
// Foundation consistency
// =============================================================================

/// **ATS-V-AP-005: FoundationDrift.**
///
/// Verifies that composed cogs share a foundation, OR an explicit
/// `@framework(bridge_corpus, ...)` translates between them.
///
/// **Stable RFC code**: ATS-V-AP-005.
@framework(ats_v, "ATS-V-AP-005 FoundationDrift. Composing two cogs whose foundations differ without an explicit functor-bridge is a defect — there is no canonical translation that preserves refinement-predicate truth values across the divide. Canonical inclusions accepted without bridge: Mltt → Cic (CIC subsumes Martin-Löf TT), Hott → Cubical (cubical HoTT subsumes Book HoTT). Cross-paradigm pairs (e.g. ZFC + HoTT) require an explicit @framework(bridge_corpus, ...) declaration.")
@kernel_discharge("kernel_arch_foundation_consistency")
public axiom kernel_arch_foundation_consistency() -> Bool
    ensures true;

// =============================================================================
// Generic anti-pattern check
// =============================================================================

/// **Generic anti-pattern dispatcher.**
///
/// Walks the canonical 32-pattern roster (AP-001..032) and reports
/// any violations.  AP-001..010 are the base capability/lifecycle
/// patterns; AP-011..026 are boundary/composition extensions;
/// AP-027..032 are MTAC modal-temporal arms.
///
/// Each violation surfaces as `VerificationVerdict::Rejected` with
/// the pattern's stable code in the diagnostic metadata (per spec
/// §32.4 dual-audience design).
@framework(ats_v, "ATS-V anti-pattern catalog dispatcher — walks the full canonical 32-pattern roster: AP-001..010 capability/composition core (CapabilityEscalation, CapabilityLeak, DependencyCycle, TierMixing, FoundationDrift, RegisterMixing, TxStraddling, ResourceStraddling, LifecycleRegression, CveIncomplete), AP-011..026 boundary/lifecycle extensions (AbsoluteBoundaryAttempt, InvariantViolation, DanglingMessageType, UnauthenticatedCrossing, DeterministicViolation, CapabilityDuplication, OrphanCapability, MissingHandoff, FoundationDowngrade, TimeBoundLeakage, PersistenceMismatch, CapabilityLaundering, FoundationForgery, TransitiveLifecycleRegression, DeclarationDrift, FoundationContentMismatch), AP-027..032 MTAC modal-temporal arms (TemporalInconsistency, CounterfactualBrittleness, MissedAdjoint, UniversalPropertyViolation, PhantomEvolution, YonedaInequivalentRefactor). Each violation surfaces VerificationVerdict::Rejected with the stable RFC code in the diagnostic metadata.")
@kernel_discharge("kernel_arch_anti_pattern_check")
public axiom kernel_arch_anti_pattern_check() -> Bool
    ensures true;

// =============================================================================
// CVE-closure check (strict mode)
// =============================================================================

/// **ATS-V-AP-010: CveIncomplete.**
///
/// In strict mode (`@arch_module(strict = true)`), a public theorem
/// without complete CVE-closure (all three axes) is a defect.
///
/// **Stable RFC code**: ATS-V-AP-010.
@framework(ats_v, "ATS-V-AP-010 CveIncomplete. Every public artefact in strict mode must declare all three CVE axes: cve_closure_C (Constructive witness — function path or constructor), cve_closure_V_strategy (Verifiable — which step of the @verify ladder discharges the claim), cve_closure_E (Executable — entry point or audit command). Missing any axis with strict=true raises this pattern; soft-mode emits a warning. The companion red-team closure axiom kernel_arch_theorem_cve_required raises CveIncomplete to Error severity for Lifecycle.Theorem(...) regardless of strict-flag, since Theorem-status semantically implies full CVE+ closure.")
@kernel_discharge("kernel_arch_cve_closure")
public axiom kernel_arch_cve_closure() -> Bool
    ensures true;

// =============================================================================
// End-to-end soundness witness
// =============================================================================

/// **ATS-V soundness witness.**
///
/// Composes the 7 above kernel-discharge intrinsics into a single
/// end-to-end discharge. Per spec §9.2 soundness statement: when
/// `verum check` accepts a cog with `arch_type T`, all of:
/// * Capability discipline
/// * Composition correctness
/// * Foundation consistency
/// * CVE closure (strict mode)
/// * Lifecycle integrity
/// * Anti-pattern absence (39 canonical patterns)
/// hold.
@framework(ats_v, "ATS-V end-to-end soundness witness. Composes the 7 base dispatch intrinsics (capability_discipline, boundary_check, composition_check, lifecycle_check, foundation_consistency, anti_pattern_check, cve_closure) into a single discharge. Soundness statement: when `verum check` accepts a cog with arch_type T, all of capability discipline, composition correctness, foundation consistency, CVE closure (strict mode), lifecycle integrity, and absence of the 32 canonical anti-patterns hold simultaneously. Eventually self-hosted as a CVE-closed Verum cog itself.")
@kernel_discharge("kernel_arch_soundness_v0")
public axiom kernel_arch_soundness_v0() -> Bool
    ensures true;

// =============================================================================
// Red-team closure axioms — operationalising attack-vector checks
// =============================================================================

/// **AT-1 closure**: capability-ontology completeness check.
/// Every `Capability::Custom { tag, schema }` declared in any
/// `@arch_module(...)` MUST have its `tag` registered in
/// `core.architecture.capability_ontology.ATS_V_CANONICAL_CAPABILITIES`
/// (or in a corpus-extended registry).  Fires AP-001 / AP-005 (or
/// new code) on unregistered tags.
///
/// **Attack closed**: a malicious cog declaring `Capability.Custom("admin")`
/// with arbitrary `transfers_privilege: true` schema cannot inject a
/// fake high-privilege capability — the registry check rejects.
@framework(ats_v, "ATS-V capability-ontology completeness check. Closes attack-vector AT-1: a malicious cog declaring Capability.Custom { tag: \"admin\", schema: { transfers_privilege: true, ... } } cannot inject a fake high-privilege capability — the parser fallback fills schema with conservative defaults, and this gate rejects the cog at ATS-V phase if `tag` is absent from core.architecture.capability_ontology.ATS_V_CANONICAL_CAPABILITIES (or a corpus-extended registry).")
@kernel_discharge("kernel_arch_capability_ontology_check")
public axiom kernel_arch_capability_ontology_check() -> Bool
    ensures true;

/// **AT-3 closure**: Yoneda canonical-roster completeness.
/// Yoneda-equivalence verdict is sound iff the agreement list spans
/// EVERY observer in the canonical 5-roster (EndUser / PeerCog /
/// Stakeholder / Auditor / Adversary).  An adversary submitting a
/// verdict with only Auditor agreement (the strictest, hardest to
/// fake) would otherwise pass without testing the easy observers.
///
/// **Attack closed**: forged `YonedaVerdict { agreements: [auditor_agreed], equivalent: true }`
/// is rejected because its agreement count `< 5`.
@framework(ats_v, "ATS-V Yoneda canonical-roster completeness (spec §20.7 + §23). Closes attack-vector AT-3: a verdict claiming equivalence must walk the full canonical-5 roster, not a curated subset. Auditor alone is necessary but not sufficient.")
@kernel_discharge("kernel_arch_yoneda_canonical_roster_complete")
public axiom kernel_arch_yoneda_canonical_roster_complete() -> Bool
    ensures true;

/// **AT-2 closure**: theorem-status requires CVE-closure regardless
/// of strict mode.  AP-010 currently fires only when `strict = true`,
/// but `Lifecycle::Theorem` is a load-bearing claim — soft-mode bypass
/// of CVE-closure for `[T]`-status is itself a defect.
///
/// **Attack closed**: cog declaring `lifecycle: Lifecycle.Theorem("v1.0"), strict: false`
/// without any CVE axis is now flagged as `CveIncomplete` (Severity.Error)
/// even outside strict mode, because Theorem semantically REQUIRES the
/// triple irrespective of declaration-strictness flag.
@framework(ats_v, "ATS-V theorem-CVE coupling (spec §4.5 + §4.8). Closes attack-vector AT-2: Theorem lifecycle implies CVE⁺ closure by definition (CVE §3.5); `strict = false` cannot bypass this semantic constraint.")
@kernel_discharge("kernel_arch_theorem_cve_required")
public axiom kernel_arch_theorem_cve_required() -> Bool
    ensures true;

/// **AT-5 closure**: `consumes` field format validation.
/// The `consumes: List<Text>` field carries free-form strings like
/// `"randomness/16384 bytes"`.  Without grammar enforcement, any
/// string passes — including injection vectors for downstream gas
/// accounting.  This axiom requires each entry to match the canonical
/// pattern `<resource_kind>/<positive_int> <unit>` where `unit ∈ {bytes, ops, ms, ns}`.
///
/// **Attack closed**: cog declaring `consumes: ["'; DROP TABLE--"]`
/// is rejected at ATS-V phase, before reaching gas-table dispatch.
@framework(ats_v, "ATS-V consumes-format validation (spec §4.1 consumes field). Closes attack-vector AT-5: free-form Text field gains a canonical resource-grammar; format violations surface as DeclarationDrift (AP-025) at ATS-V phase.")
@kernel_discharge("kernel_arch_consumes_format_check")
public axiom kernel_arch_consumes_format_check() -> Bool
    ensures true;

// =============================================================================
// CVE articulation-hygiene band — kernel-discharge bridges (AP-033..039)
// =============================================================================
//
// One bridge per anti-pattern in the CVE-AH band.  The bridges
// operationalise the cve-architecture spec's load-bearing
// concepts (§§1.5, 2.3.0, 3.5, 4.5, 14.6, 16) via the same
// `@kernel_discharge(<intrinsic>)` pattern the base + red-team
// arms use, with one intrinsic per check.

/// **AP-033 closure**: citing a `[✗]` Retracted artefact from any
/// non-retracted lifecycle.  The discharge enumerates every
/// `composes_with` edge and every imported function and rejects
/// the build when any cited cog has `Lifecycle.Retracted(...)`.
/// Distinct from AP-009 LifecycleRegression: AP-009 fires on rank
/// regression (`[T]` → `[H]`); AP-033 specifically fires on `[✗]`
/// citation regardless of the rank of the citing artefact, because
/// `[✗]` carries an explicit retraction reason that the citing
/// artefact MUST acknowledge.
@framework(ats_v, "ATS-V retracted-citation closure (cve-architecture spec §3.5 [✗] discipline). Citing a `Lifecycle.Retracted(...)` cog from any active lifecycle is a defect even when the citing cog is itself low-rank — the retraction's reason field is meant to be load-bearing, and silent citation defeats the negative-example role of the audit chronicle.")
@kernel_discharge("kernel_arch_retracted_citation_check")
public axiom kernel_arch_retracted_citation_check() -> Bool
    ensures true;

/// **AP-034 closure**: a `Lifecycle.Hypothesis(...)` cog without a
/// `@plan(...)` attribute. Per spec §3.5 the `[H]` status carries
/// the structural commitment to an articulated maturation path;
/// without a plan it degrades to `[I]` Interpretation.  This
/// discharge rejects the cog at ATS-V phase when no plan is found.
@framework(ats_v, "ATS-V hypothesis-plan closure (cve-architecture spec §3.5 [H] discipline). A `[H]` Hypothesis without an articulated maturation plan is operationally an [I] Interpretation; the missing plan turns the cog into a hidden CVE-violator.  This discharge requires every `[H]` cog to carry a `@plan(target_completion: ..., milestones: ...)` attribute.")
@kernel_discharge("kernel_arch_hypothesis_plan_check")
public axiom kernel_arch_hypothesis_plan_check() -> Bool
    ensures true;

/// **AP-035 closure**: `Lifecycle.Interpretation(...)` in a cog
/// declared mature/strict.  Per spec §3.4, the `[I]` status is
/// PERMITTED only as a transitional marker; mature corpora must
/// contain ZERO `[I]` entries.  This discharge fires in every
/// `strict: true` cog whose lifecycle is `Interpretation`, and in
/// every cog within a mature corpus boundary (declared via
/// `@arch_corpus(maturity: Mature)`).
@framework(ats_v, "ATS-V interpretation-in-mature closure (cve-architecture spec §3.4 + §6.7 L6 register prohibition). The [I] status is the canonical CVE-violator: all three axes absent and no plan to formalise. Mature corpora must close it at every cog by one of three transformations — proof (→ [T]/[C]), downgrade (→ [H] with plan), removal.")
@kernel_discharge("kernel_arch_interpretation_in_mature_check")
public axiom kernel_arch_interpretation_in_mature_check() -> Bool
    ensures true;

/// **AP-036 closure**: an `Observer` role attached to an assertion
/// whose register does not match the role.  Per spec §16 + §6.7 L6,
/// register collisions across observer roles (e.g. an
/// `Observer.EndUser` assertion attached to an architectural-shape
/// claim that lives in `Observer.Architect` register) are silent
/// defects in the audit chronicle.  This discharge inspects every
/// `Observer`-tagged emit and confirms register alignment.
@framework(ats_v, "ATS-V observer-impersonation closure (cve-architecture spec §16 articulation hygiene + §6.7 L6 register prohibition). Distinct from AP-029 MissedAdjoint: AP-029 fires on architectural decisions; AP-036 fires on audit-chronicle prose where the observer register and the assertion content disagree.")
@kernel_discharge("kernel_arch_observer_impersonation_check")
public axiom kernel_arch_observer_impersonation_check() -> Bool
    ensures true;

/// **AP-037 closure**: a strict-mode audit invocation against a
/// `Shape` that has `declarations: None` or `declarations.purpose: None`.
/// Per spec §14.6, the audit terminates relative to a declared
/// purpose; without one the audit has no halting criterion and
/// degenerates into infinite polishing.  This discharge requires
/// every strict-mode `@arch_module(...)` to carry a `purpose: { ... }`
/// declaration.
@framework(ats_v, "ATS-V boundless-audit closure (cve-architecture spec §14.6 audit termination). An audit without a declared purpose tries to drive every artefact toward unattainable absolute closure — for Turing-complete systems forbidden by Rice's theorem, for trained models forbidden by the natural opacity of high-dimensional weights. Termination through declared purpose is load-bearing; without it, the protocol is not an audit but perennial critique.")
@kernel_discharge("kernel_arch_boundless_audit_check")
public axiom kernel_arch_boundless_audit_check() -> Bool
    ensures true;

/// **AP-038 closure**: a `Lifecycle.Theorem(...)` cog in strict
/// mode without a declared `CognitiveSubstrate` in its
/// `ShapeDeclarations`.  Per spec §1.5, declaring the cognitive
/// substrate is part of operational hygiene — CVE knows its mode
/// and does not masquerade as a universal neutral apparatus.  The
/// default substrate (`AnalyticDecompositional`) MUST be either
/// declared explicitly or accepted by the cog explicitly via
/// `Shape.declarations = Some(_)` even with substrate omitted; a
/// fully `None` declarations field on a strict `[T]` cog is the
/// implicit-substrate defect.
@framework(ats_v, "ATS-V implicit-substrate closure (cve-architecture spec §1.5 cognitive substrate disclosure). A strict-mode `[T]` cog must declare its operational mode; absence is operationally indistinguishable from a vacuous claim of universality.")
@kernel_discharge("kernel_arch_implicit_substrate_check")
public axiom kernel_arch_implicit_substrate_check() -> Bool
    ensures true;

/// **AP-039 closure**: a `Foundation` outside the CHL anchoring
/// domain (e.g. a cog whose foundation is `CustomFoundation(...)`
/// or whose body inhabits an institutional / control-theoretic /
/// distributed-protocol register) without a declared
/// `FormalAnchoring` in its `ShapeDeclarations`.  Per spec §4.5,
/// the architectural law applies in both regimes — methodological
/// CVE (before formal anchoring) and anchored-formal CVE (after) —
/// but the distinction must be explicit. AP-039 fires when an
/// artefact claims `[T]` Theorem under a non-CHL foundation
/// without naming its anchoring tradition.
@framework(ats_v, "ATS-V anchoring-overextension closure (cve-architecture spec §4.5 formal anchoring boundary). The CHL anchoring is the most-developed; extending the CVE law to other domains (automata theory, control theory, distributed protocols, functional systems, institutional design) requires explicit declaration of the parallel anchoring, otherwise the artefact silently inherits CHL semantics it does not satisfy.")
@kernel_discharge("kernel_arch_anchoring_overextension_check")
public axiom kernel_arch_anchoring_overextension_check() -> Bool
    ensures true;
