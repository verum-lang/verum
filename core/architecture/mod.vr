// =============================================================================
// core.architecture — ATS-V Architectural Type System library
// =============================================================================
//
// **Verum-native canonical types for the Architectural Type System.**
//
// Per `internal/specs/ats-v.md` §17.4 (Reuse compliance), the ATS-V
// extension is implemented as:
//
//   1. ONE typed attribute — `@arch_module(...)` — recognised by the
//      compiler-internal dispatch (V8.1 META1 architectural principle,
//      grammar/verum.ebnf generic `identifier(args)` form).
//
//   2. THIS library — Verum-native `type X is variant_list`
//      declarations that mirror the kernel-side `verum_kernel::arch*`
//      primitives.  Both sides stay in sync via cross-side pin tests
//      in `verum_kernel`'s test suite.
//
//   3. Per-module kernel-discharge bridges declared as
//      `@kernel_discharge(<intrinsic>)` axioms — one per architectural
//      sub-system.
//
// **Architectural alignment** mirrors `core.verify.separation_soundness`
// (#161) and `core.verify.codegen_soundness` (#162): kernel-discharge
// pattern with `@kernel_discharge(<intrinsic>)` annotations.
//
// **Module roster**:
//
//   1. `types.vr` — canonical primitives (Capability / Boundary /
//      Composition / Lifecycle / Foundation / Tier / MsfsStratum /
//      CveClosure / Shape).
//   2. `capability_ontology.vr` — registered Custom capability names.
//   3. `anti_patterns.vr` — 32-pattern canonical anti-pattern catalog
//      (ATS-V-AP-001..032) with kernel-discharge bridges.
//   4. `mtac.vr` — Modal-Temporal Architectural Calculus primitives
//      (TimePoint / Decision / Observer / ModalAssertion /
//      ArchProposition / ArchEvolution / CounterfactualPair /
//      AdjunctionWitness).
//   5. `counterfactual.vr` — non-destructive counterfactual
//      reasoning engine (ArchMetric / MetricValue / InvariantStatus /
//      CounterfactualReport).
//   6. `adjunction.vr` — adjunction analyzer for refactoring
//      (CanonicalAdjunction / Refactoring / AdjunctionAnalysis /
//      RefactoringChain).
//   7. `yoneda.vr` — Yoneda-equivalence checker
//      (ShapeObservation / AgreementStatus / YonedaVerdict).
// =============================================================================

module core.architecture.mod;

mount super.types.{
    Capability,
    Boundary,
    Lifecycle,
    Foundation,
    Tier,
    MsfsStratum,
    CveClosure,
    Shape,
};
mount super.anti_patterns.{
    kernel_arch_capability_discipline,
    kernel_arch_boundary_check,
    kernel_arch_composition_check,
    kernel_arch_lifecycle_check,
    kernel_arch_foundation_consistency,
    kernel_arch_anti_pattern_check,
    kernel_arch_cve_closure,
    kernel_arch_soundness_v0,
};
mount super.mtac.{
    TimePoint,
    Decision,
    DecisionOption,
    Observer,
    ArchProposition,
    ModalAssertion,
    ArchEvolution,
    ComplexityClass,
    Reversibility,
    CounterfactualPair,
    AdjunctionWitness,
    kernel_arch_mtac_calculus,
};
mount super.counterfactual.{
    ArchMetric,
    MetricValue,
    InvariantStatus,
    MetricComparison,
    InvariantEvaluation,
    CounterfactualReport,
    kernel_arch_counterfactual_engine,
};
mount super.adjunction.{
    CanonicalAdjunction,
    RefactoringDirection,
    Refactoring,
    AdjunctionVerdict,
    PreservedCoverage,
    GainedCoverage,
    AdjunctionAnalysis,
    RefactoringChain,
    ChainAnalysis,
    kernel_arch_adjunction_analyzer,
};
mount super.yoneda.{
    ShapeObservation,
    AgreementStatus,
    ObserverAgreement,
    YonedaVerdict,
    kernel_arch_yoneda_equivalence,
};
