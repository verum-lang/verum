    ArchPhaseReport,
    CompositionStep,
    CompositionVerificationReport,
    module_arch_result_is_load_bearing,
    arch_phase_report_empty,
    arch_phase_report_is_load_bearing,
    arch_phase_report_total_violations,
    arch_phase_report_total_parse_errors,
    arch_phase_report_annotated_count,
