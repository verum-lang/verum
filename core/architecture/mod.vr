    Capability,
    CapabilitySchema,
    Boundary,
    Lifecycle,
    Foundation,
    Tier,
    MsfsStratum,
    CveClosure,
    VerifyStrategy,
    Shape,
    ExecutabilitySense,
    CognitiveSubstrate,
    FormalAnchoring,
    CveThresholdK,
    CveThresholdV,
    CveThresholdE,
    Purpose,
    DefectKind,
    Resolution,
    ArchitecturalDefect,
    FixpointClass,
    SelfReferenceWitness,
    ShapeDeclarations,
    capability_schema_inferred_default,
    tier_tag,
    tier_compatible_with,
    stratum_tag,
    stratum_is_admissible,
    foundation_tag,
    foundation_directly_subsumed_by,
    lifecycle_tag,
    lifecycle_cve_glyph,
    lifecycle_rank,
    lifecycle_is_mature_corpus_forbidden,
    cve_closure_degree,
    cve_closure_is_fully_closed,
    verify_strategy_tag,
