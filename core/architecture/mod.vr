    executability_sense_tag,
    executability_sense_is_canonical_e,
    cognitive_substrate_tag,
    cognitive_substrate_default,
    formal_anchoring_tag,
    formal_anchoring_default,
    cve_threshold_k_tag,
    cve_threshold_v_tag,
    cve_threshold_e_tag,
    purpose_default,
    defect_kind_tag,
    resolution_tag,
    fixpoint_class_tag,
    self_reference_witness_unspecified,
    shape_declarations_empty,
    lifecycle_rank_strict_order_holds,
    stratum_l_abs_unique_inadmissible,
    foundation_canonical_inclusions_hold,
    tier_check_runs_nothing,
    executability_sense_canonical_unique,
    cognitive_substrate_default_is_analytic,
    formal_anchoring_default_is_chl,
    purpose_default_is_complete,
    fixpoint_class_tags_distinct,
};
mount super.anti_patterns.{
