// =============================================================================
// core.architecture.adjunction ŌĆö Adjunction analyzer for refactoring
// =============================================================================
//
// **Verum-native mirror of `verum_kernel::arch_adjunction`.**
//
// ## Refactoring as adjunction
//
// Every architectural refactoring is a pair of functors `(F, G)`
// where `F: Old ŌåÆ New` ŌŖŻ `G: New ŌåÆ Old` ŌĆö the left-adjoint
// notation that captures: "F goes one way, G undoes it, and the
// pair is canonical (universal up to isomorphism)."  ATS-V accepts
// a refactoring as a typed transformation only if a valid adjoint
// pair exists, eliminating anti-patterns like "split a module
// without declaring the inverse merge" (AP-029 MissedAdjoint).
//
// ## Canonical adjunctions (the four spec-stable recognisers)
//
// | Forward (F)  | Backward (G)  | Shape-delta recogniser           |
// |--------------|---------------|----------------------------------|
// | Inline       | Extract       | `composition_degree` decreases   |
// | Specialise   | Generalise    | foundation / stratum stable      |
// | Decompose    | Compose       | `composes_with` grows            |
// | Strengthen   | Weaken        | `preserves` grows                |
//
// User-declared refactorings outside this roster classify as
// `CustomAdjunction(<name>)` and are accepted iff the witness
// still forms a valid adjoint pair (the structural mirror check
// below).
//
// ## Pipeline (kernel side)
//
//   1. `classify_refactoring` ŌĆö dispatch on the before/after
//      shape-delta to one of the four canonical recognisers (or
//      Custom).
//   2. `verify_adjoint_pair` ŌĆö `is_adjoint_of` mirror equality
//      check (forward_name Ōåö backward_name).
//   3. `analyze_refactoring` ŌĆö walk preserved/gained propositions,
//      emit per-property coverage records, aggregate to verdict.
//   4. `analyze_chain` ŌĆö adjunctions compose: `(F Ōłś F') ŌŖŻ (G' Ōłś G)`,
//      so a chain of refactorings is accepted iff every step is
//      individually accepted.
//
// ## Self-attestation
//
// This cog is itself ATS-V-typed via the `@arch_module(...)`
// declaration below ŌĆö dogfood for the architectural type system.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.architecture.adjunction;

mount core.prelude.{Bool, Int, List, Text};
mount super.types.Shape;
mount super.mtac.{AdjunctionWitness, ArchProposition};

// =============================================================================
// CanonicalAdjunction ŌĆö the four spec-┬¦20.6 recognisers
// =============================================================================

/// Recognised canonical adjunction.  Four standard arms cover the
/// dominant refactoring shapes (InlineŌŖŻExtract, SpecialiseŌŖŻGeneralise,
/// DecomposeŌŖŻCompose, StrengthenŌŖŻWeaken).  `CustomAdjunction(name)`
/// captures user-declared refactorings outside the canonical
/// roster ŌĆö accepted iff the witness still forms a valid adjoint
/// pair under the `is_adjoint_of` mirror check.
public type CanonicalAdjunction is
    | InlineExtract
    | SpecialiseGeneralise
    | DecomposeCompose
    | StrengthenWeaken
    | CustomAdjunction(Text);

// =============================================================================
// RefactoringDirection ŌĆö F or G application
// =============================================================================

/// Which functor of the adjoint pair the refactoring applies.
public type RefactoringDirection is
    | Forward    // F: Old ŌåÆ New (left adjoint)
    | Backward;  // G: New ŌåÆ Old (right adjoint)

// =============================================================================
// Refactoring ŌĆö caller-supplied transformation
// =============================================================================

/// Concrete refactoring instance.  Carries before/after shapes +
/// the adjunction witness + direction (which leg of the adjoint
/// pair is being applied).
public type Refactoring is {
    name: Text,
    direction: RefactoringDirection,
    before_shape: Shape,
    after_shape: Shape,
    witness: AdjunctionWitness,
};

// =============================================================================
// AdjunctionVerdict ŌĆö final outcome
// =============================================================================

public type AdjunctionVerdict is
    | Accepted
    | BrokenAdjointPair
    | PreservationFailure
    | GainClaimFailure;

/// Per-preserved-property coverage entry.
public type PreservedCoverage is {
    proposition: ArchProposition,
    held_before: Bool,
    held_after: Bool,
    preserved_actual: Bool,
};

/// Per-gained-property coverage entry.
public type GainedCoverage is {
    proposition: ArchProposition,
    held_before: Bool,
    held_after: Bool,
    gained_actual: Bool,
};

/// Structured verdict from `analyze_refactoring`.
public type AdjunctionAnalysis is {
    schema_version: Int,
    refactoring_name: Text,
    canonical: CanonicalAdjunction,
    direction: RefactoringDirection,
    adjoint_pair_present: Bool,
    preserved_coverage: List<PreservedCoverage>,
    gained_coverage: List<GainedCoverage>,
    verdict: AdjunctionVerdict,
    diagnostics: List<Text>,
};

// =============================================================================
// RefactoringChain ŌĆö sequential composition
// =============================================================================

/// Sequence of refactorings.  Adjunctions compose:
/// `(F Ōłś F') ŌŖŻ (G' Ōłś G)`.  Chain accepted iff every step accepted.
/// Empty chain rejected (refusal to claim acceptance from absence
/// of evidence).
public type RefactoringChain is {
    steps: List<Refactoring>,
};

public type ChainAnalysis is {
    schema_version: Int,
    step_analyses: List<AdjunctionAnalysis>,
    chain_accepted: Bool,
};

// =============================================================================
// Kernel-discharge bridge
// =============================================================================

/// **Adjunction analyzer ŌĆö refactoring as typed transformation.**
///
/// Discharges the kernel-side adjunction module's soundness
/// contracts:
///   * Four canonical adjunction recognisers each pin a distinct
///     shape-delta pattern (composition-degree decrease for
///     InlineŌŖŻExtract, foundation/stratum stability for
///     SpecialiseŌŖŻGeneralise, etc.).
///   * Four-arm verdict (Accepted / BrokenAdjointPair /
///     PreservationFailure / GainClaimFailure) covers every
///     refactoring outcome ŌĆö there is no "ambiguous" residual
///     state.
///   * Chain composition is associative: a refactoring chain is
///     accepted iff every step is individually accepted; empty
///     chains rejected (refusal to claim acceptance from absence
///     of evidence).
@framework(ats_v, "ATS-V adjunction analyzer ŌĆö four canonical adjunctions InlineŌŖŻExtract / SpecialiseŌŖŻGeneralise / DecomposeŌŖŻCompose / StrengthenŌŖŻWeaken plus user-declared customs. Kernel implementation: crates/verum_kernel/src/arch_adjunction.rs.")
@kernel_discharge("kernel_arch_adjunction_analyzer")
public axiom kernel_arch_adjunction_analyzer() -> Bool
    ensures true;
