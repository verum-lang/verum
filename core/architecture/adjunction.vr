// =============================================================================
// core.architecture.adjunction — Adjunction analyzer for refactoring
// =============================================================================
//
// **Verum-native mirror of `verum_kernel::arch_adjunction`.**
//
// ## Refactoring as adjunction
//
// Every architectural refactoring is a pair of functors `(F, G)`
// where `F: Old → New` ⊣ `G: New → Old` — the left-adjoint
// notation that captures: "F goes one way, G undoes it, and the
// pair is canonical (universal up to isomorphism)."  ATS-V accepts
// a refactoring as a typed transformation only if a valid adjoint
// pair exists, eliminating anti-patterns like "split a module
// without declaring the inverse merge" (AP-029 MissedAdjoint).
//
// ## Canonical adjunctions (the four spec-stable recognisers)
//
// | Forward (F)  | Backward (G)  | Shape-delta recogniser           |
// |--------------|---------------|----------------------------------|
// | Inline       | Extract       | `composition_degree` decreases   |
// | Specialise   | Generalise    | foundation / stratum stable      |
// | Decompose    | Compose       | `composes_with` grows            |
// | Strengthen   | Weaken        | `preserves` grows                |
//
// User-declared refactorings outside this roster classify as
// `CustomAdjunction(<name>)` and are accepted iff the witness
// still forms a valid adjoint pair (the structural mirror check
// below).
//
// ## Pipeline (kernel side)
//
//   1. `classify_refactoring` — dispatch on the before/after
//      shape-delta to one of the four canonical recognisers (or
//      Custom).
//   2. `verify_adjoint_pair` — `is_adjoint_of` mirror equality
//      check (forward_name ↔ backward_name).
//   3. `analyze_refactoring` — walk preserved/gained propositions,
//      emit per-property coverage records, aggregate to verdict.
//   4. `analyze_chain` — adjunctions compose: `(F ∘ F') ⊣ (G' ∘ G)`,
//      so a chain of refactorings is accepted iff every step is
//      individually accepted.
//
// ## Self-attestation
//
// This cog is itself ATS-V-typed via the `@arch_module(...)`
// declaration below — dogfood for the architectural type system.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.architecture.adjunction;

mount core.prelude.{Bool, Int, List, Text};
mount super.types.Shape;
mount super.mtac.{AdjunctionWitness, ArchProposition};

// =============================================================================
// CanonicalAdjunction — the four spec-§20.6 recognisers
// =============================================================================

/// Recognised canonical adjunction.  Four standard arms cover the
/// dominant refactoring shapes (Inline⊣Extract, Specialise⊣Generalise,
/// Decompose⊣Compose, Strengthen⊣Weaken).  `CustomAdjunction(name)`
/// captures user-declared refactorings outside the canonical
/// roster — accepted iff the witness still forms a valid adjoint
/// pair under the `is_adjoint_of` mirror check.
public type CanonicalAdjunction is
    | InlineExtract
    | SpecialiseGeneralise
    | DecomposeCompose
    | StrengthenWeaken
    | CustomAdjunction(Text);

// =============================================================================
// RefactoringDirection — F or G application
// =============================================================================

/// Which functor of the adjoint pair the refactoring applies.
public type RefactoringDirection is
    | Forward    // F: Old → New (left adjoint)
    | Backward;  // G: New → Old (right adjoint)

// =============================================================================
// Refactoring — caller-supplied transformation
// =============================================================================

/// Concrete refactoring instance.  Carries before/after shapes +
/// the adjunction witness + direction (which leg of the adjoint
/// pair is being applied).
public type Refactoring is {
    name: Text,
    direction: RefactoringDirection,
    before_shape: Shape,
    after_shape: Shape,
    witness: AdjunctionWitness,
};

// =============================================================================
// AdjunctionVerdict — final outcome
// =============================================================================

public type AdjunctionVerdict is
    | Accepted
    | BrokenAdjointPair
    | PreservationFailure
    | GainClaimFailure;

/// Per-preserved-property coverage entry.
public type PreservedCoverage is {
    proposition: ArchProposition,
    held_before: Bool,
    held_after: Bool,
    preserved_actual: Bool,
};

/// Per-gained-property coverage entry.
public type GainedCoverage is {
    proposition: ArchProposition,
    held_before: Bool,
    held_after: Bool,
    gained_actual: Bool,
};

/// Structured verdict from `analyze_refactoring`.
public type AdjunctionAnalysis is {
    schema_version: Int,
    refactoring_name: Text,
    canonical: CanonicalAdjunction,
    direction: RefactoringDirection,
    adjoint_pair_present: Bool,
    preserved_coverage: List<PreservedCoverage>,
    gained_coverage: List<GainedCoverage>,
    verdict: AdjunctionVerdict,
    diagnostics: List<Text>,
};

// =============================================================================
// RefactoringChain — sequential composition
// =============================================================================

/// Sequence of refactorings.  Adjunctions compose:
/// `(F ∘ F') ⊣ (G' ∘ G)`.  Chain accepted iff every step accepted.
/// Empty chain rejected (refusal to claim acceptance from absence
/// of evidence).
public type RefactoringChain is {
    steps: List<Refactoring>,
};

public type ChainAnalysis is {
    schema_version: Int,
    step_analyses: List<AdjunctionAnalysis>,
    chain_accepted: Bool,
};

// =============================================================================
// Operationalisation — pure-data helpers
// =============================================================================

/// Stable diagnostic tag for `CanonicalAdjunction`.
public fn canonical_adjunction_tag(a: CanonicalAdjunction) -> Text {
    match a {
        InlineExtract        => "inline_extract",
        SpecialiseGeneralise => "specialise_generalise",
        DecomposeCompose     => "decompose_compose",
        StrengthenWeaken     => "strengthen_weaken",
        CustomAdjunction(_)  => "custom",
    }
}

/// Stable tag for `RefactoringDirection`.
public fn refactoring_direction_tag(d: RefactoringDirection) -> Text {
    match d {
        Forward  => "forward",
        Backward => "backward",
    }
}

/// Stable tag for `AdjunctionVerdict`.
public fn adjunction_verdict_tag(v: AdjunctionVerdict) -> Text {
    match v {
        Accepted             => "accepted",
        BrokenAdjointPair    => "broken_adjoint_pair",
        PreservationFailure  => "preservation_failure",
        GainClaimFailure     => "gain_claim_failure",
    }
}

/// True iff the verdict accepts the refactoring.
public fn adjunction_verdict_is_accepted(v: AdjunctionVerdict) -> Bool {
    match v {
        Accepted => true,
        _        => false,
    }
}

/// True iff EVERY preserved-coverage entry shows the property
/// genuinely survives (held_before ∧ held_after ∧ preserved_actual).
/// Used by `analyze_refactoring` to decide PreservationFailure.
public fn all_preservation_holds(coverages: List<PreservedCoverage>) -> Bool {
    let mut i: Int = 0;
    while i < coverages.len() {
        let c = coverages[i];
        if !(c.held_before && c.held_after && c.preserved_actual) {
            return false;
        }
        i = i + 1;
    }
    true
}

/// True iff EVERY gained-coverage entry shows the property is
/// genuinely new (¬held_before ∧ held_after ∧ gained_actual).
/// Used by `analyze_refactoring` to decide GainClaimFailure.
public fn all_gain_holds(coverages: List<GainedCoverage>) -> Bool {
    let mut i: Int = 0;
    while i < coverages.len() {
        let c = coverages[i];
        if !(!c.held_before && c.held_after && c.gained_actual) {
            return false;
        }
        i = i + 1;
    }
    true
}

/// True iff the chain is accepted — every step accepted AND
/// non-empty (refusal to claim acceptance from absence of evidence).
public fn chain_acceptance_predicate(c: &ChainAnalysis) -> Bool {
    if c.step_analyses.len() == 0 {
        return false;
    }
    let mut i: Int = 0;
    while i < c.step_analyses.len() {
        if !adjunction_verdict_is_accepted(c.step_analyses[i].verdict) {
            return false;
        }
        i = i + 1;
    }
    true
}

// =============================================================================
// Soundness pins
// =============================================================================

/// **Pin**: only `Accepted` verdict signals success.  The other three
/// (BrokenAdjointPair / PreservationFailure / GainClaimFailure) all
/// reject the refactoring.
public fn verdict_acceptance_uniqueness_pin() -> Bool {
    adjunction_verdict_is_accepted(AdjunctionVerdict.Accepted) &&
    !adjunction_verdict_is_accepted(AdjunctionVerdict.BrokenAdjointPair) &&
    !adjunction_verdict_is_accepted(AdjunctionVerdict.PreservationFailure) &&
    !adjunction_verdict_is_accepted(AdjunctionVerdict.GainClaimFailure)
}

/// **Pin**: empty chain rejected.  Chain composition discipline:
/// `(F ∘ F') ⊣ (G' ∘ G)` requires at least one factor.
public fn empty_chain_rejected_pin() -> Bool {
    let empty_chain = ChainAnalysis {
        schema_version: 1,
        step_analyses: [],
        chain_accepted: false,
    };
    !chain_acceptance_predicate(&empty_chain)
}

// =============================================================================
// Kernel-discharge bridge
// =============================================================================

/// **Adjunction analyzer — refactoring as typed transformation.**
///
/// Discharges the kernel-side adjunction module's soundness
/// contracts:
///   * Four canonical adjunction recognisers each pin a distinct
///     shape-delta pattern (composition-degree decrease for
///     Inline⊣Extract, foundation/stratum stability for
///     Specialise⊣Generalise, etc.).
///   * Four-arm verdict (Accepted / BrokenAdjointPair /
///     PreservationFailure / GainClaimFailure) covers every
///     refactoring outcome — there is no "ambiguous" residual
///     state.
///   * Chain composition is associative: a refactoring chain is
///     accepted iff every step is individually accepted; empty
///     chains rejected (refusal to claim acceptance from absence
///     of evidence).
@framework(ats_v, "ATS-V adjunction analyzer — four canonical adjunctions Inline⊣Extract / Specialise⊣Generalise / Decompose⊣Compose / Strengthen⊣Weaken plus user-declared customs. Kernel implementation: crates/verum_kernel/src/arch_adjunction.rs.")
@kernel_discharge("kernel_arch_adjunction_analyzer")
public axiom kernel_arch_adjunction_analyzer() -> Bool
    ensures true;
