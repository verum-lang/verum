// =============================================================================
// core.architecture.composition — ATS-V composition algebra surface
// =============================================================================
//
// **Verum-native mirror of `verum_kernel::arch_composition`.**
//
// Composition is a **typed operation**: `compose(A, B)` either
// yields a new `Shape` for the composed unit, or rejects with one
// or more structured `AntiPatternViolation`s.  The compiler
// refuses incompatible compositions at type-check time, never at
// runtime.
//
// ## Composition rules
//
// `A ⊗ B` is well-formed iff:
//
//   1. **Capability flow valid** — `B.requires ⊆ A.exposes`
//      (every capability B needs is provided by A).
//   2. **Foundation compatible** — equality OR
//      `foundation_directly_subsumed_by` holds in either direction
//      (canonical inclusions Mltt → Cic, Hott → Cubical).
//   3. **Tier compatible** — `tier_compatible_with(A.at_tier, B.at_tier)`
//      (identity, MultiTier set-membership, or explicit bridge).
//   4. **Stratum admissible** — neither side claims `LAbs` (AFN-T α
//      boundary closure), the meet stratum is admissible.
//   5. **No dependency cycle** — composition graph stays acyclic.
//
// ## Resulting Shape semantics
//
//   * `exposes`       = `A.exposes ∪ B.exposes` minus capabilities
//                       B consumed from A (those become internal
//                       handoffs, no longer surfaced externally).
//   * `requires`      = `A.requires ∪ (B.requires \ A.exposes)`.
//   * `foundation`    = the more-specific of the two when subsumption
//                       holds, else error.
//   * `tier`          = compatibility intersection; falls back to
//                       MultiTier when both sides accept the same set.
//   * `stratum`       = `min(A.stratum, B.stratum)` with LAbs
//                       preempted at any input.
//   * `composes_with` = union of the two lists.
//
// ## Associativity
//
// `(A ⊗ B) ⊗ C ≡ A ⊗ (B ⊗ C)` whenever all three are pairwise
// compatible.  Proven by kernel-side property test; mirrored by
// the `kernel_arch_composition_associative` soundness-pin axiom
// below.
//
// ## Self-attestation
//
// This cog is itself ATS-V-typed via the `@arch_module(...)`
// declaration below.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.architecture.composition;

mount core.prelude.{Bool, Int, List, Text};
mount super.types.Shape;
mount super.anti_patterns.AntiPatternViolation;

// =============================================================================
// CompositionResult — typed outcome of A ⊗ B
// =============================================================================

/// Outcome of composing two Shapes.  Mirrors
/// `verum_kernel::arch_composition::CompositionResult`.
public type CompositionResult is
    | Composed(Shape)
    | Rejected(List<AntiPatternViolation>);

/// True iff composition succeeded.
public fn composition_result_is_composed(r: CompositionResult) -> Bool {
    match r {
        Composed(_) => true,
        Rejected(_) => false,
    }
}

/// Stable diagnostic tag for audit reports.
public fn composition_result_tag(r: CompositionResult) -> Text {
    match r {
        Composed(_) => "composed",
        Rejected(_) => "rejected",
    }
}

/// Number of violations in a Rejected result; 0 for Composed.
public fn composition_result_violation_count(r: CompositionResult) -> Int {
    match r {
        Composed(_)  => 0,
        Rejected(vs) => vs.len(),
    }
}

// =============================================================================
// Kernel-discharge bridge — A ⊗ B engine
// =============================================================================

/// **Composition algebra dispatch.**
///
/// Discharges the kernel-side `arch_composition` module's
/// soundness contracts:
///   * Identity:   `A ⊗ unit ≡ A` for the trivial unit shape
///   * Associativity:  `(A ⊗ B) ⊗ C ≡ A ⊗ (B ⊗ C)` (RT1.5 refinement)
///   * Closure:    Rules 1-5 are jointly necessary AND sufficient
///   * Diagnostic completeness:  every rejection cites a stable
///     `AntiPatternCode` from the canonical 32-roster.
@framework(ats_v, "ATS-V composition engine — A ⊗ B is well-formed iff capability flow is valid (B.requires ⊆ A.exposes), foundations compatible (equality or canonical inclusion), tiers compatible, both strata admissible (no LAbs), and the composition graph stays acyclic. Composition is associative ((A⊗B)⊗C ≡ A⊗(B⊗C)) and decidable in time linear in the union of capabilities. Detects AP-003 DependencyCycle, AP-004 TierMixing, AP-005 FoundationDrift, AP-011 AbsoluteBoundaryAttempt, AP-018 MissingHandoff. Kernel implementation: crates/verum_kernel/src/arch_composition.rs.")
@kernel_discharge("kernel_arch_composition_engine")
public axiom kernel_arch_composition_engine() -> Bool
    ensures true;

/// **Soundness pin — associativity.**
///
/// `(A ⊗ B) ⊗ C ≡ A ⊗ (B ⊗ C)` whenever the triple is pairwise
/// compatible.  Asserted as kernel-discharge axiom because the
/// proof requires the kernel-side property test over the entire
/// triple-product space (RT1.5 refinement); cannot be discharged
/// at ATS-V phase alone.
@framework(ats_v, "ATS-V composition associativity — pairwise-compatible triples agree on the result regardless of bracketing: (A⊗B)⊗C ≡ A⊗(B⊗C). Witness: kernel proptest harness in crates/verum_kernel/src/arch_composition.rs randomly samples valid Shape triples and asserts left-fold ≡ right-fold over the entire input space.")
@kernel_discharge("kernel_arch_composition_associative")
public axiom kernel_arch_composition_associative() -> Bool
    ensures true;
