pub async fn mget(client: &RedisClient, keys: &[Text]) -> Result<List<Maybe<List<Byte>>>, RedisError> {
    if keys.is_empty() { return Ok(List.new()); }
    let mut a: List<Text> = List.with_capacity(keys.len() + 1);
    a.push("MGET".to_text());
    let mut i: Int = 0;
    while i < keys.len() { a.push(keys[i].clone()); i = i + 1; }
    match exec(client, a.as_slice()).await? {
        RespValue.Array(arr) => {
            let mut out: List<Maybe<List<Byte>>> = List.with_capacity(arr.len());
            let mut k: Int = 0;
            while k < arr.len() {
                match &arr[k] {
                    RespValue.NullBulk | RespValue.Nil_ => out.push(None),
                    RespValue.BulkString(b) => out.push(Some(b.clone())),
                    RespValue.SimpleString(s) => out.push(Some(s.as_bytes().to_list())),
                    _ => out.push(None),
                }
                k = k + 1;
            }
            Ok(out)
        }
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"MGET unexpected: {other:?}")),
    }
}

pub async fn mset(client: &RedisClient, pairs: &[(Text, List<Byte>)]) -> Result<(), RedisError> {
    if pairs.is_empty() { return Ok(()); }
    let mut a: List<List<Byte>> = List.with_capacity(1 + 2 * pairs.len());
    a.push("MSET".to_text().as_bytes().to_list());
    let mut i: Int = 0;
    while i < pairs.len() {
        a.push(pairs[i].0.as_bytes().to_list());
        a.push(pairs[i].1.clone());
        i = i + 1;
    }
    expect_simple_ok(exec_bytes(client, &a).await?, "MSET")
}

pub async fn getdel(client: &RedisClient, key: &Text) -> Result<Maybe<List<Byte>>, RedisError> {
    let mut a: List<Text> = List.new(); a.push("GETDEL".to_text()); a.push(key.clone());
