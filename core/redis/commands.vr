// =============================================================================
// redis/commands.vr — typed Redis command surface
// =============================================================================
// Layer: 4 (Redis subsystem)
//
// **Purpose.** Type-safe builders for Redis commands. Each command
// is a thin wrapper around `client::exec` that:
//   - Constructs the RESP argv from typed inputs.
//   - Decodes the reply into the canonical Verum type for the
//     command (Int, Text, Bytes, List<Text>, Map<Text, Text>, etc.).
//   - Maps "this key does not exist" replies (NullBulk / Nil) to
//     `Maybe::None` for read-side commands.
//
// Coverage (Redis ≥ 6.0):
//   * Strings    : GET / SET / SETEX / SETNX / DEL / EXISTS / INCR /
//                  DECR / INCRBY / DECRBY / APPEND / STRLEN / MGET / MSET / GETDEL
//   * Generic    : EXPIRE / PEXPIRE / PERSIST / TTL / PTTL / TYPE /
//                  KEYS / SCAN / RENAME / COPY / TOUCH / UNLINK
//   * Lists      : LPUSH / RPUSH / LPOP / RPOP / LRANGE / LLEN /
//                  LINDEX / LSET / LREM / LTRIM
//   * Hashes     : HSET / HGET / HMGET / HMSET / HDEL / HEXISTS /
//                  HKEYS / HVALS / HLEN / HGETALL / HINCRBY
//   * Sets       : SADD / SREM / SMEMBERS / SISMEMBER / SCARD /
//                  SINTER / SUNION / SDIFF / SPOP / SRANDMEMBER
//   * Sorted sets: ZADD / ZREM / ZRANGE / ZRANGEBYSCORE / ZSCORE /
//                  ZRANK / ZINCRBY / ZCARD / ZCOUNT
//   * Server     : PING / SELECT / FLUSHDB / DBSIZE / INFO / TIME / CLIENT
//
// Each command has a single canonical signature; binary-safe
// variants take `&[u8]` arguments and route through `exec_bytes`.
// =============================================================================

@arch_module(
    foundation:    Foundation.ZfcTwoInacc,
    stratum:       MsfsStratum.LCls,
    lifecycle:     Lifecycle.Theorem("v0.1"),
    declarations: ShapeDeclarations {
        purpose: Some(Purpose {
            role: "typed Redis command surface — strings/lists/hashes/sets/zsets/server".to_text(),
            k_min: CveThresholdK.FullWitness,
            v_min: CveThresholdV.NamedCertification,
            e_min: CveThresholdE.StructurallyReady,
        }),
        substrate:      Some(CognitiveSubstrate.AnalyticDecompositional),
        anchoring:      Some(FormalAnchoring.CurryHowardLawvere),
        e_sense:        Some(ExecutabilitySense.StructuralReadiness),
        self_reference: None,
    },
)
module core.redis.commands;

mount core.*;
mount base.{Result, Ok, Err, Maybe, Some, None, Text, Bool, Int, Float};
mount collections.{List, Map};

mount core.redis.client.{RedisClient, RedisError, exec, exec_bytes, exec_pipeline};
mount core.redis.protocol.RespValue;

// =============================================================================
// String commands
// =============================================================================

pub async fn get(client: &RedisClient, key: &Text) -> Result<Maybe<List<Byte>>, RedisError> {
    let mut a: List<Text> = List.new(); a.push("GET".to_text()); a.push(key.clone());
    match exec(client, a.as_slice()).await? {
        RespValue.NullBulk | RespValue.Nil_ => Ok(None),
        RespValue.BulkString(b) => Ok(Some(b)),
        RespValue.SimpleString(s) => Ok(Some(s.as_bytes().to_list())),
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"GET unexpected: {other:?}")),
    }
}

pub async fn get_text(client: &RedisClient, key: &Text) -> Result<Maybe<Text>, RedisError> {
    match get(client, key).await? {
        Some(b) => Text.from_utf8(b.as_slice())
            .map(Some).map_err(|e| RedisError.InvalidReply(f"utf8: {e}")),
        None => Ok(None),
    }
}

pub async fn set(client: &RedisClient, key: &Text, value: &[Byte]) -> Result<(), RedisError> {
    let mut a: List<List<Byte>> = List.new();
    a.push("SET".to_text().as_bytes().to_list());
    a.push(key.as_bytes().to_list());
    a.push(value.to_list());
    expect_simple_ok(exec_bytes(client, &a).await?, "SET")
}

/// SET with EX (seconds-precision TTL).
pub async fn set_ex(
    client: &RedisClient, key: &Text, value: &[Byte], ttl_seconds: Int,
) -> Result<(), RedisError> {
    let mut a: List<List<Byte>> = List.new();
    a.push("SET".to_text().as_bytes().to_list());
    a.push(key.as_bytes().to_list());
    a.push(value.to_list());
    a.push("EX".to_text().as_bytes().to_list());
    a.push(f"{ttl_seconds}".as_bytes().to_list());
    expect_simple_ok(exec_bytes(client, &a).await?, "SET EX")
}

/// SET with PX (millisecond-precision TTL).
pub async fn set_px(
    client: &RedisClient, key: &Text, value: &[Byte], ttl_ms: Int,
