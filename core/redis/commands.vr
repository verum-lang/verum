    let mut a: List<List<Byte>> = List.new();
    a.push("SET".to_text().as_bytes().to_list());
    a.push(key.as_bytes().to_list());
    a.push(value.to_list());
    a.push("PX".to_text().as_bytes().to_list());
    a.push(f"{ttl_ms}".as_bytes().to_list());
    expect_simple_ok(exec_bytes(client, &a).await?, "SET PX")
}

/// SET NX — set only if absent. Returns true iff the value was stored.
pub async fn set_nx(
    client: &RedisClient, key: &Text, value: &[Byte],
) -> Result<Bool, RedisError> {
    let mut a: List<List<Byte>> = List.new();
    a.push("SET".to_text().as_bytes().to_list());
    a.push(key.as_bytes().to_list());
    a.push(value.to_list());
    a.push("NX".to_text().as_bytes().to_list());
    match exec_bytes(client, &a).await? {
        RespValue.SimpleString(_) => Ok(true),
        RespValue.NullBulk | RespValue.Nil_ => Ok(false),
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"SET NX unexpected: {other:?}")),
    }
}

pub async fn del(client: &RedisClient, keys: &[Text]) -> Result<Int, RedisError> {
    if keys.is_empty() { return Ok(0); }
    let mut a: List<Text> = List.with_capacity(keys.len() + 1);
    a.push("DEL".to_text());
    let mut i: Int = 0;
    while i < keys.len() { a.push(keys[i].clone()); i = i + 1; }
    expect_int(exec(client, a.as_slice()).await?, "DEL")
}

