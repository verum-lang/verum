pub async fn hget(client: &RedisClient, key: &Text, field: &Text) -> Result<Maybe<List<Byte>>, RedisError> {
    let mut a: List<Text> = List.new();
    a.push("HGET".to_text()); a.push(key.clone()); a.push(field.clone());
    expect_optional_bulk(exec(client, a.as_slice()).await?, "HGET")
}

pub async fn hdel(client: &RedisClient, key: &Text, fields: &[Text]) -> Result<Int, RedisError> {
    if fields.is_empty() { return Ok(0); }
    let mut a: List<Text> = List.with_capacity(fields.len() + 2);
    a.push("HDEL".to_text()); a.push(key.clone());
    let mut i: Int = 0;
    while i < fields.len() { a.push(fields[i].clone()); i = i + 1; }
    expect_int(exec(client, a.as_slice()).await?, "HDEL")
}

pub async fn hgetall(client: &RedisClient, key: &Text) -> Result<Map<Text, List<Byte>>, RedisError> {
    let mut a: List<Text> = List.new(); a.push("HGETALL".to_text()); a.push(key.clone());
    match exec(client, a.as_slice()).await? {
        RespValue.Array(arr) => {
            let mut out: Map<Text, List<Byte>> = Map.new();
            let mut i: Int = 0;
            while i + 1 < arr.len() {
                let f = bulk_to_text(&arr[i])?;
                let v = bulk_to_bytes(&arr[i + 1])?;
                out.insert(f, v);
                i = i + 2;
            }
            Ok(out)
        }
        RespValue.MapValue(pairs) => {
            let mut out: Map<Text, List<Byte>> = Map.new();
            let mut i: Int = 0;
            while i < pairs.len() {
                let (k, v) = &pairs[i];
                out.insert(bulk_to_text(k)?, bulk_to_bytes(v)?);
                i = i + 1;
            }
            Ok(out)
        }
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"HGETALL unexpected: {other:?}")),
    }
}

