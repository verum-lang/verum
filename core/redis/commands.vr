pub async fn zscore(
    client: &RedisClient, key: &Text, member: &[Byte],
) -> Result<Maybe<Float>, RedisError> {
    let mut a: List<List<Byte>> = List.new();
    a.push("ZSCORE".to_text().as_bytes().to_list());
    a.push(key.as_bytes().to_list());
    a.push(member.to_list());
    match exec_bytes(client, &a).await? {
        RespValue.NullBulk | RespValue.Nil_ => Ok(None),
        RespValue.BulkString(b) => {
            let s = Text.from_utf8(b.as_slice())
                .map_err(|e| RedisError.InvalidReply(f"utf8: {e}"))?;
            Float.parse(&s).map(Some).map_err(|e| RedisError.InvalidReply(f"parse: {e}"))
        }
        RespValue.Double(d) => Ok(Some(d)),
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"ZSCORE unexpected: {other:?}")),
    }
}

// =============================================================================
// Server commands
// =============================================================================

pub async fn ping(client: &RedisClient) -> Result<(), RedisError> {
    let mut a: List<Text> = List.new(); a.push("PING".to_text());
    match exec(client, a.as_slice()).await? {
        RespValue.SimpleString(s) if s == "PONG" => Ok(()),
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        _ => Err(RedisError.InvalidReply("PING unexpected".to_text())),
    }
}

pub async fn flushdb(client: &RedisClient) -> Result<(), RedisError> {
    let mut a: List<Text> = List.new(); a.push("FLUSHDB".to_text());
    expect_simple_ok(exec(client, a.as_slice()).await?, "FLUSHDB")
}

pub async fn dbsize(client: &RedisClient) -> Result<Int, RedisError> {
    let mut a: List<Text> = List.new(); a.push("DBSIZE".to_text());
    expect_int(exec(client, a.as_slice()).await?, "DBSIZE")
}

// =============================================================================
// Reply decoders
// =============================================================================

fn expect_simple_ok(v: RespValue, cmd: &str) -> Result<(), RedisError> {
    match v {
        RespValue.SimpleString(_) => Ok(()),
        RespValue.NullBulk | RespValue.Nil_ => Ok(()),
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"{cmd} unexpected: {other:?}")),
    }
}

fn expect_int(v: RespValue, cmd: &str) -> Result<Int, RedisError> {
    match v {
        RespValue.Integer(n) => Ok(n),
        RespValue.Error_(m)  => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"{cmd} unexpected: {other:?}")),
    }
}

fn expect_int_bool(v: RespValue, cmd: &str) -> Result<Bool, RedisError> {
    expect_int(v, cmd).map(|n| n == 1)
}

fn expect_optional_bulk(v: RespValue, cmd: &str) -> Result<Maybe<List<Byte>>, RedisError> {
    match v {
        RespValue.NullBulk | RespValue.Nil_ => Ok(None),
        RespValue.BulkString(b) => Ok(Some(b)),
        RespValue.SimpleString(s) => Ok(Some(s.as_bytes().to_list())),
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"{cmd} unexpected: {other:?}")),
    }
}

fn expect_text_int(v: &RespValue) -> Result<Int, RedisError> {
    match v {
        RespValue.Integer(n) => Ok(*n),
        RespValue.BulkString(b) => {
            let s = Text.from_utf8(b.as_slice())
                .map_err(|e| RedisError.InvalidReply(f"utf8: {e}"))?;
            Int.parse(&s).map_err(|_| RedisError.InvalidReply(f"int parse: {s}"))
        }
        RespValue.SimpleString(s) => Int.parse(s).map_err(|_| RedisError.InvalidReply(f"int parse: {s}")),
        _ => Err(RedisError.InvalidReply("expected integer or text-int".to_text())),
    }
}

fn bulk_to_bytes(v: &RespValue) -> Result<List<Byte>, RedisError> {
    match v {
        RespValue.BulkString(b) => Ok(b.clone()),
        RespValue.SimpleString(s) => Ok(s.as_bytes().to_list()),
        RespValue.NullBulk | RespValue.Nil_ => Ok(List.new()),
        _ => Err(RedisError.InvalidReply(f"expected bulk, got: {v:?}")),
    }
}

fn bulk_to_text(v: &RespValue) -> Result<Text, RedisError> {
    let bytes = bulk_to_bytes(v)?;
    Text.from_utf8(bytes.as_slice())
        .map_err(|e| RedisError.InvalidReply(f"utf8: {e}"))
}

fn bulk_array_to_text_list(items: &List<RespValue>) -> Result<List<Text>, RedisError> {
    let mut out: List<Text> = List.with_capacity(items.len());
    let mut i: Int = 0;
    while i < items.len() { out.push(bulk_to_text(&items[i])?); i = i + 1; }
    Ok(out)
}

fn bulk_array_to_byte_list(items: &List<RespValue>) -> Result<List<List<Byte>>, RedisError> {
    let mut out: List<List<Byte>> = List.with_capacity(items.len());
    let mut i: Int = 0;
    while i < items.len() { out.push(bulk_to_bytes(&items[i])?); i = i + 1; }
    Ok(out)
}
