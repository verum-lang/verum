    let mut a: List<Text> = List.with_capacity(keys.len() + 1);
    a.push("UNLINK".to_text());
    let mut i: Int = 0;
    while i < keys.len() { a.push(keys[i].clone()); i = i + 1; }
    expect_int(exec(client, a.as_slice()).await?, "UNLINK")
}

/// SCAN — incremental key iteration.  Returns (cursor, keys);
/// a cursor of 0 indicates the iteration is complete.
pub async fn scan(
    client: &RedisClient,
    cursor: Int,
    match_pattern: Maybe<&Text>,
    count: Maybe<Int>,
) -> Result<(Int, List<Text>), RedisError> {
    let mut a: List<Text> = List.new();
    a.push("SCAN".to_text());
    a.push(f"{cursor}");
    if let Some(p) = match_pattern {
        a.push("MATCH".to_text()); a.push(p.clone());
    }
    if let Some(c) = count {
        a.push("COUNT".to_text()); a.push(f"{c}");
    }
    match exec(client, a.as_slice()).await? {
        RespValue.Array(arr) if arr.len() == 2 => {
            let next_cursor = expect_text_int(&arr[0])?;
            let keys = match &arr[1] {
                RespValue.Array(items) => bulk_array_to_text_list(items)?,
                _ => return Err(RedisError.InvalidReply("SCAN: keys not array".to_text())),
            };
            Ok((next_cursor, keys))
        }
        RespValue.Error_(m) => Err(RedisError.Backend(m)),
        other => Err(RedisError.InvalidReply(f"SCAN unexpected: {other:?}")),
    }
}

