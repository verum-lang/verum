// =============================================================================
// reflection.vr — Refinement Reflection
// =============================================================================
//
// Layer: Standard Library / Proof
//
// User-facing surface for the refinement-reflection analysis core
// (`verum_smt.refinement_reflection`). Pure, total user functions
// can be reflected into the Z3 context as universally-quantified
// equality axioms, so downstream proofs may *unfold* calls to
// `f(x)` instead of treating `f` as an uninterpreted symbol.
//
// This is the same technique Liquid Haskell calls *refinement
// reflection*: it makes user definitions visible to the SMT
// solver, dramatically expanding what auto-tactics can prove.
//
// ## Soundness gate
//
// A function may be reflected only if it is:
//
//   * **Pure** — no Mutates/IO/Async/Fallible properties
//   * **Total** — terminates on every input, no panic/unreachable
//   * **Closed** — body uses only its parameters and other already-
//     reflected functions
//
// The gate `is_reflectable` returns the appropriate verdict.
//
// =============================================================================

module core.proof.reflection;

// =============================================================================
// 0. SMT-LIB identifier validation
// =============================================================================
//
// `to_smtlib_axiom` and `to_smtlib_decl` substitute the function name
// and parameter names directly into the emitted S-expression. If a
// caller-supplied identifier contains parentheses, semicolons, the
// quoted-symbol delimiter `|`, or whitespace, the result is either
// malformed (best case: SMT solver rejects on parse) or, worse,
// a smuggled-in clause that the solver silently accepts — at which
// point the reflected axiom embeds attacker-controlled assertions
// into every downstream proof.
//
// Refinement reflection is SOUNDNESS-CRITICAL: a wrong axiom poisons
// every later verification. Pre-validate at the construction site so
// rendering is provably safe for the value range that reaches the
// renderer.
//
// SMT-LIB v2.6 simple-symbol grammar:
//
//     simple_symbol_first  ::= letter | "~" | "!" | "@" | "$" | "%"
//                            | "^" | "&" | "*" | "_" | "+" | "="
//                            | "<" | ">" | "." | "?" | "/" | "-"
//     simple_symbol_rest   ::= simple_symbol_first | digit
//
// We accept this grammar literally; quoted-symbol form (|foo bar|)
// is intentionally rejected because we do not need it for reflected
// function names, and accepting it would re-open the injection
// surface (a nested `|` could close the quote prematurely).

@inline
fn is_smt_id_first_char(b: Byte) -> Bool {
    let c = b as Int;
    // Letters (lower / upper)
    if c >= 0x61 && c <= 0x7A { return true; }   // a-z
    if c >= 0x41 && c <= 0x5A { return true; }   // A-Z
    // Allowed punctuation per SMT-LIB v2.6.
    c == 0x7E    // ~
        || c == 0x21    // !
        || c == 0x40    // @
        || c == 0x24    // $
        || c == 0x25    // %
        || c == 0x5E    // ^
        || c == 0x26    // &
        || c == 0x2A    // *
        || c == 0x5F    // _
        || c == 0x2B    // +
        || c == 0x3D    // =
        || c == 0x3C    // <
        || c == 0x3E    // >
        || c == 0x2E    // .
        || c == 0x3F    // ?
        || c == 0x2F    // /
        || c == 0x2D    // -
}

@inline
fn is_smt_id_rest_char(b: Byte) -> Bool {
    let c = b as Int;
    if c >= 0x30 && c <= 0x39 { return true; }   // 0-9
    is_smt_id_first_char(b)
}

/// Verifies that `s` is a syntactically valid SMT-LIB v2.6 simple
/// symbol. Reject empty strings, leading digits, and any byte not
/// matching the grammar above.
public fn is_smtlib_simple_symbol(s: &Text) -> Bool {
    let bytes = s.as_bytes();
    if bytes.len() == 0 { return false; }
    if !is_smt_id_first_char(bytes[0]) { return false; }
    let mut i: Int = 1;
    while i < bytes.len() {
        if !is_smt_id_rest_char(bytes[i]) { return false; }
        i = i + 1;
    }
    true
}

// =============================================================================
// 1. A reflected function definition
// =============================================================================

/// A single reflected user function. The `body_smtlib` field
/// carries the function body in SMT-LIB form, with parameters
/// referenced as bare identifiers (so `(* 2 n)` for `2 * n` etc.).
public type ReflectedFunction is {
    name: Text,
    parameters: List<Text>,
    body_smtlib: Text,
    return_sort: Text,
    parameter_sorts: List<Text>,
};

/// Build a reflected function record.
///
/// Panics if `parameters.len() != parameter_sorts.len()` — the two
/// lists must align position-for-position so `to_smtlib_axiom` can
/// emit `(x_i sort_i)` pairs. Without this guard a mismatched
/// pair would produce an out-of-bounds index in the rendering
/// loop, OR (worse) a silently-malformed SMT axiom that the
/// solver might accept and feed into later proofs.
public fn reflected_fn(
    name: Text,
    parameters: List<Text>,
    body_smtlib: Text,
    return_sort: Text,
    parameter_sorts: List<Text>,
) -> ReflectedFunction {
    if parameters.len() != parameter_sorts.len() {
        panic(f"reflected_fn(`{name}`): parameters.len()={parameters.len()} != parameter_sorts.len()={parameter_sorts.len()}; lists must align position-for-position");
    }
    if !is_smtlib_simple_symbol(&name) {
        panic(f"reflected_fn: function name `{name}` is not a valid SMT-LIB simple symbol; rejecting to prevent SMT injection into proof axioms");
    }
    let mut idx: Int = 0;
    while idx < parameters.len() {
        let p = &parameters[idx];
        if !is_smtlib_simple_symbol(p) {
            panic(f"reflected_fn(`{name}`): parameter[{idx}]=`{p}` is not a valid SMT-LIB simple symbol; rejecting to prevent SMT injection");
        }
        idx = idx + 1;
    }
    ReflectedFunction {
        name,
        parameters,
        body_smtlib,
        return_sort,
        parameter_sorts,
    }
}

/// Fallible constructor for `ReflectedFunction`. Returns `None`
/// when the parameter / parameter-sort list lengths disagree
/// instead of panicking, for callers building reflections from
/// untrusted input (e.g. external proof bundles, deserialized
/// metadata).
public fn try_reflected_fn(
    name: Text,
    parameters: List<Text>,
    body_smtlib: Text,
    return_sort: Text,
    parameter_sorts: List<Text>,
) -> Maybe<ReflectedFunction> {
    if parameters.len() != parameter_sorts.len() {
        return None;
    }
    if !is_smtlib_simple_symbol(&name) {
        return None;
    }
    let mut idx: Int = 0;
    while idx < parameters.len() {
        if !is_smtlib_simple_symbol(&parameters[idx]) {
            return None;
        }
        idx = idx + 1;
    }
    Some(ReflectedFunction {
        name,
        parameters,
        body_smtlib,
        return_sort,
        parameter_sorts,
    })
}

// =============================================================================
// 2. The soundness gate
// =============================================================================

/// Verdict from `is_reflectable`.
public type ReflectabilityVerdict is
    /// Function passes all three soundness checks.
    | Reflectable
    /// Function failed a check; reason is human-readable text.
    | NotReflectable { reason: Text };

/// Decide whether a function may be reflected. Callers supply
/// the three booleans derived from the type checker's analysis
/// (purity, totality, closedness).
public fn is_reflectable(
    name: Text,
    is_pure: Bool,
    is_total: Bool,
    is_closed: Bool,
) -> ReflectabilityVerdict {
    if !is_pure {
        return ReflectabilityVerdict.NotReflectable {
            reason: f"function `{name}` has side effects",
        };
    }
    if !is_total {
        return ReflectabilityVerdict.NotReflectable {
            reason: f"function `{name}` is not provably total",
        };
    }
    if !is_closed {
        return ReflectabilityVerdict.NotReflectable {
            reason: f"function `{name}` references unreflected symbols",
        };
    }
    ReflectabilityVerdict.Reflectable
}

// =============================================================================
// 3. SMT-LIB rendering
// =============================================================================

/// Render the universally-quantified axiom in SMT-LIB form:
/// `(assert (forall ((x₁ S₁) ... (xₙ Sₙ)) (= (f x₁ ... xₙ) body)))`.
///
/// Nullary functions (no parameters) emit a plain equality
/// without the forall binder.
public fn to_smtlib_axiom(f: ReflectedFunction) -> Text {
    if f.parameters.len() == 0 {
        return f"(assert (= ({f.name}) {f.body_smtlib}))";
    }
    let mut out: Text = "(assert (forall (";
    let mut i: Int = 0;
    while i < f.parameters.len() {
        if i > 0 { out = out + " "; }
        out = out + f"({f.parameters[i]} {f.parameter_sorts[i]})";
        i = i + 1;
    }
    out = out + ") (= (" + f.name;
    let mut j: Int = 0;
    while j < f.parameters.len() {
        out = out + " " + f.parameters[j];
        j = j + 1;
    }
    out = out + ") " + f.body_smtlib + ")))";
    out
}

/// Render the function declaration: `(declare-fun f (S₁ … Sₙ) S)`.
public fn to_smtlib_decl(f: ReflectedFunction) -> Text {
    let mut out: Text = "(declare-fun " + f.name + " (";
    let mut i: Int = 0;
    while i < f.parameter_sorts.len() {
        if i > 0 { out = out + " "; }
        out = out + f.parameter_sorts[i];
        i = i + 1;
    }
    out = out + ") " + f.return_sort + ")";
    out
}
