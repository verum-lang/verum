///
/// Kernel discharge:
/// `verum_kernel::reflective_subcategory::build_reflective_subcategory(...)`.
@framework(msfs, "Bridge — kernel reflective_subcategory::build_reflective_subcategory (HTT 5.2.7 + Lemma 10.3)")
public axiom kernel_reflective_subcategory_aft() -> Bool
    requires true
    ensures  true;

// =============================================================================
// 4. Whitehead criterion (HTT 1.2.4.3 generalised)
// =============================================================================

/// **Bridge: Whitehead promotion — TRUSTED-BASE-SHRINKAGE primitive.**
///
/// Discharges `msfs_id_x_violates_pi_4` at higher (∞,n)-levels by
/// replacing the bridge-audited equivalence claim with a per-level
/// `π_k`-iso-witness check.  Whitehead-promoted equivalences carry
/// EMPTY `BridgeAudit` — strictly shrinks the trusted boundary.
///
/// Kernel discharge:
/// `verum_kernel::whitehead::whitehead_promote(criterion, audit)`
/// produces an `InfinityEquivalence` without touching `audit`.
@framework(msfs, "Bridge — kernel whitehead::whitehead_promote (HTT 1.2.4.3, empty BridgeAudit)")
public axiom kernel_whitehead_promote() -> Bool
    requires true
    ensures  true;

