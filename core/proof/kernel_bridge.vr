@framework(msfs, "Bridge — kernel adjoint_functor::build_adjunction (HTT 5.5.2.9)")
public axiom kernel_saft_adjunction() -> Bool
    requires true
    ensures  true;

/// **Bridge: Reflective subcategory construction (HTT 5.2.7).**
///
/// Discharges `msfs_aft_iota_r`: the (ι, r) reflective subcategory
