// =============================================================================
// 10. Foundation primitives (ZFC self-recognition + Gödel coding + tactics)
// =============================================================================

/// **Bridge: Kernel rule ↔ ZFC + 2-inacc decomposition.**
///
/// For every kernel rule (K-Refine, K-Univ, K-Pos, K-Norm, K-FwAx,
/// K-Adj-Unit, K-Adj-Counit), the kernel exposes the precise ZFC
/// axioms + Grothendieck universes required to model it.
///
/// Kernel discharge:
/// `verum_kernel::zfc_self_recognition::required_meta_theory(rule)`
/// returns a `MetaTheoryRequirements` record.
@framework(diakrisis, "Bridge — kernel zfc_self_recognition::required_meta_theory (VVA §16.5 Phase 5)")
public axiom kernel_zfc_self_recognition() -> Bool
    requires true
    ensures  true;

/// **Bridge: Recursive functions + Gödel coding.**
///
/// Cantor pairing + primitive recursive function evaluation
/// (Zero/Succ/Proj/Comp/PrimRec) + bounded μ-recursion + recursive
/// AST encoding to ℕ.
///
/// Kernel discharge:
/// `verum_kernel::godel_coding::{cantor_pair, PrimitiveRecursive::eval,
/// MuRecursive::eval, GodelEncoding::encode}`.
@framework(diakrisis, "Bridge — kernel godel_coding (Yanofsky 2003 / Gödel 1931)")
public axiom kernel_godel_coding() -> Bool
    requires true
    ensures  true;

/// **Bridge: Industrial-grade tactics.**
///
/// Five deterministic decision-procedure tactics:
/// `tactic_lia` (LIA), `tactic_decide` (truth-table tautology),
/// `tactic_induction` (ℕ-induction), `tactic_congruence` (EUF),
/// `tactic_eauto` (depth-bounded back-chain).  Each returns a
/// re-checkable `TacticOutcome::{Closed, Open}`.
///
/// Kernel discharge:
/// `verum_kernel::tactics_industrial::{tactic_lia, tactic_decide,
/// tactic_induction, tactic_congruence, tactic_eauto}`.
@framework(verum, "Bridge — kernel tactics_industrial (5 deterministic tactics)")
public axiom kernel_tactics_industrial() -> Bool
    requires true
    ensures  true;

/// **Bridge: Cross-format CI hard gate.**
///
/// Verum proofs export to Coq / Lean 4 / Isabelle/HOL / Dedukti.
/// The hard gate decides whether a given artefact survives the
/// round-trip through every required backend.
///
/// Kernel discharge:
/// `verum_kernel::cross_format_gate::evaluate_gate(report)`.
@framework(verum, "Bridge — kernel cross_format_gate::evaluate_gate (4-format CI)")
public axiom kernel_cross_format_gate() -> Bool
    requires true
    ensures  true;

/// **Bridge: Mechanisation roadmap.**
///
/// HTT (Lurie 2009) + AR 1994 chapter-by-chapter mechanisation
/// status enumeration with `MechanisationStatus::{Mechanised,
/// Partial, AxiomCited, Pending}` per section.
///
/// Kernel discharge:
/// `verum_kernel::mechanisation_roadmap::{htt_roadmap,
/// adamek_rosicky_roadmap, CoverageReport::compute}`.
@framework(verum, "Bridge — kernel mechanisation_roadmap (HTT + AR 1994 coverage)")
public axiom kernel_mechanisation_roadmap() -> Bool
    requires true
    ensures  true;
