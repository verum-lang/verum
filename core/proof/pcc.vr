// =============================================================================
// pcc.vr — Proof-Carrying Code Bundles
// =============================================================================
//
// Layer: Standard Library / Proof
//
// Surface for `verum_smt.proof_carrying_code`. Necula-style PCC:
// formal proof certificates bundled with bytecode, content-
// addressed by goal hash, with audit-trail metadata.
//
// Trust relocates from the compiler pipeline to a small, auditable
// proof checker. The recipient verifies proofs rather than
// re-running analysis.
//
// ## Storage model
//
// Certificates are stored in a `Map<Text, ProofCertificate>` keyed
// by goal-hash digest. Lookup is O(1) amortised — the natural
// access pattern for content-addressed PCC where every recipient
// queries certificates by their goal hash. The previous
// `List<BundleCert>` storage was O(N) per lookup, putting an
// N²-shaped scan on the proof-checking hot path of every consumer.
//
// `bundle_add` is idempotent on `(hash, cert)` pairs: re-adding a
// certificate with the same goal hash replaces the prior entry and
// adjusts `total_duration_ms` by the delta. Catches duplicate-add
// in callers that batch-rebuild bundles across analysis re-runs.
//
// =============================================================================

module core.proof.pcc;

mount core.*;
mount core.collections.map.{Map};

/// A goal hash — content-addressed identifier of a verification
/// obligation. Computed from the textual representation of the
/// goal via a deterministic hash function.
public type GoalHash is { digest: Text };

public fn goal_hash(digest: Text) -> GoalHash {
    GoalHash { digest }
}

/// A proof certificate for a single verification obligation.
public type ProofCertificate is {
    goal_text: Text,
    solver: Text,
    proof_object: Text,
    duration_ms: Int{>= 0},
    timestamp: Text,
};

public fn proof_certificate(
    goal_text: Text,
    solver: Text,
    proof_object: Text,
    duration_ms: Int{>= 0},
    timestamp: Text,
) -> ProofCertificate {
    ProofCertificate { goal_text, solver, proof_object, duration_ms, timestamp }
}

/// Bundle metadata — audit trail for the whole compilation.
public type BundleMetadata is {
    compiler_version: Text,
    source_path: Text,
    certificate_count: Int{>= 0},
    total_duration_ms: Int{>= 0},
};

/// A complete proof bundle: certificates keyed by goal hash.
public type ProofBundle is {
    certificates: Map<Text, ProofCertificate>,
    metadata: BundleMetadata,
};

/// Build an empty proof bundle with initial metadata.
public fn empty_bundle(compiler: Text, source: Text) -> ProofBundle {
    ProofBundle {
        certificates: Map.new(),
        metadata: BundleMetadata {
            compiler_version: compiler,
            source_path: source,
            certificate_count: 0,
            total_duration_ms: 0,
        },
    }
}

/// Add (or replace) a certificate in the bundle.
///
/// Idempotent on goal-hash collision: re-adding the same hash
/// replaces the prior certificate and adjusts `total_duration_ms`
/// by `(new_dur - prior_dur)`; `certificate_count` stays unchanged.
/// Without this, a caller re-running analysis after a partial
/// proof attempt would silently double-count durations and report
/// inflated audit metadata.
public fn bundle_add(b: ProofBundle, h: GoalHash, c: ProofCertificate) -> ProofBundle {
    let mut certs = b.certificates;
    let prior_dur: Int = match certs.get_optional(h.digest.clone()) {
        Some(prior) => prior.duration_ms,
        None        => 0,
    };
    let new_count = if prior_dur == 0 && !certs.contains_key(h.digest.clone()) {
        b.metadata.certificate_count + 1
    } else {
        b.metadata.certificate_count
    };
    let new_dur = b.metadata.total_duration_ms + c.duration_ms - prior_dur;
    certs.insert(h.digest, c);
    ProofBundle {
        certificates: certs,
        metadata: BundleMetadata {
            compiler_version: b.metadata.compiler_version,
            source_path: b.metadata.source_path,
            certificate_count: new_count,
            total_duration_ms: new_dur,
        },
    }
}

/// Look up a certificate by its goal hash digest. O(1) amortised.
public fn bundle_lookup(b: &ProofBundle, digest: Text) -> Maybe<ProofCertificate> {
    b.certificates.get_optional(digest)
}

/// Number of distinct goal hashes in the bundle. O(1).
public fn bundle_size(b: &ProofBundle) -> Int {
    b.certificates.len()
}

// =============================================================================
// Foundation Protocol Impls — Display + Debug + Eq for GoalHash / ProofCertificate
// =============================================================================

implement Eq for GoalHash {
    fn eq(&self, other: &GoalHash) -> Bool {
        self.digest == other.digest
    }
}

implement Hash for GoalHash {
    fn hash(&self, hasher: &mut Hasher) {
        self.digest.hash(hasher);
    }
}

implement Clone for GoalHash {
    fn clone(&self) -> GoalHash {
        GoalHash { digest: self.digest.clone() }
    }
}

implement Display for GoalHash {
    /// Renders as the bare digest — content-addressed identifiers
    /// flow through logs and audit reports as-is, so `print(h)`
    /// produces a copy-paste-able key.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.digest.as_str())
    }
}

implement Debug for GoalHash {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"GoalHash({self.digest})".as_str())
    }
}

implement Eq for ProofCertificate {
    /// Structural equality on every field.  Two certificates are
    /// equal iff they were emitted by the same solver for the same
    /// goal text with the same proof object, duration, and
    /// timestamp — useful for re-running deterministic-proof
    /// regression tests.
    fn eq(&self, other: &ProofCertificate) -> Bool {
        self.goal_text == other.goal_text
            && self.solver == other.solver
            && self.proof_object == other.proof_object
            && self.duration_ms == other.duration_ms
            && self.timestamp == other.timestamp
    }
}

implement Display for ProofCertificate {
    /// Renders a single-line summary suitable for log lines:
    /// `<solver> proved <goal> in <Nms> at <timestamp>`.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"{self.solver} proved `{self.goal_text}` in {self.duration_ms}ms at {self.timestamp}".as_str())
    }
}

implement Debug for ProofCertificate {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"ProofCertificate {{ goal: {self.goal_text}, solver: {self.solver}, duration_ms: {self.duration_ms}, timestamp: {self.timestamp}, proof_object_len: {self.proof_object.len()} }}".as_str())
    }
}
