// =============================================================================
// contracts_old.vr — Dependent Contracts with old() Pre-State References
// =============================================================================
//
// Layer: Standard Library / Proof
//
// User-facing surface for the dependent-contracts analysis core
// (`verum_types.contracts_old`). Postconditions in mutating
// functions often need to refer to the *prior* value of state,
// not the current value. Eiffel, JML, Dafny, and SPARK use
// `old(expr)` for this.
//
// ## Example
//
// ```verum
// fn increment(self: &mut Counter)
//     ensures self.count == old(self.count) + 1
// { self.count = self.count + 1; }
// ```
//
// At verification time the analysis records which locations the
// `old(...)` clauses reference, takes a snapshot of those locations
// before the body runs, and substitutes the snapshot values into
// the postcondition for evaluation.
//
// ## Architecture: Map / Set, not List<entry>
//
// The pre-state snapshot is keyed by location name and queried
// per-postcondition-eval. Verification packages running a hundred
// contract sites issue O(N) lookups; backing the snapshot with a
// linear-scan list would put `O(M·N)` (M = locations per snapshot,
// N = lookups per session) on the proof hot path. We use
// `Map<Text, Text>` for snapshots and `Set<Text>` for frames so
// every lookup / contains-check is O(1) amortised.
//
// ## ContractsFrame property
//
// A function's *frame* is the set of locations it may modify.
// A clean contract:
//   * snapshots every location its postcondition references via
//     `old(...)`
//   * does not reference (via old) any location outside the frame
//     (such references are tautologically the post-value)
//
// =============================================================================

module core.proof.contracts_old;

mount core.*;
mount core.collections.map.{Map};
mount core.collections.set.{Set};

// =============================================================================
// 1. Pre-state snapshot
// =============================================================================

/// A pre-state snapshot — Map keyed by location name. O(1) lookup
/// regardless of snapshot size. Empty snapshot produces no
/// allocations until the first `snapshot_record` call.
public type ContractsSnapshot is { entries: Map<Text, Text> };

public fn snapshot_empty() -> ContractsSnapshot {
    ContractsSnapshot { entries: Map.new() }
}

/// Record that `loc` had value `value` before execution. Last write
/// wins for duplicate `loc` — matches the natural snapshot semantics
/// (re-snapshotting the same location updates to the latest pre-value
/// the contract references).
public fn snapshot_record(s: ContractsSnapshot, loc: Text, value: Text) -> ContractsSnapshot {
    let mut m = s.entries;
    m.insert(loc, value);
    ContractsSnapshot { entries: m }
}

/// Look up a snapshotted value. Returns `None` if `loc` was never
/// recorded — distinct from `Some("")` which indicates a snapshot of
/// the empty Text. The previous Text-returning variant collapsed
/// these two cases, leaving callers unable to distinguish "location
/// wasn't tracked" from "location had value `\"\"`" — soundness gap
/// for any postcondition that legitimately compares `old(loc) ==
/// "")`.
public fn snapshot_lookup(s: &ContractsSnapshot, loc: Text) -> Maybe<Text> {
    s.entries.get_optional(loc)
}

/// Number of distinct locations recorded. O(1).
public fn snapshot_size(s: &ContractsSnapshot) -> Int {
    s.entries.len()
}

// =============================================================================
// 2. Postconditions and frames
// =============================================================================

/// Abstract `old(expr)` reference — only the location name is
/// captured here; the full expression is opaque.
public type OldExpr is { location: Text };

public fn old_expr(location: Text) -> OldExpr {
    OldExpr { location }
}

/// A postcondition: the locations it references via `old(...)`
/// plus the locations it constrains in the post-state. Both sides
/// stored as Set<Text> so duplicate registrations don't bloat the
/// representation, and frame-cross-checking can use set ops in O(n).
public type Postcondition is {
    old_refs: Set<Text>,
    mentions_post: Set<Text>,
};

public fn postcondition_empty() -> Postcondition {
    Postcondition { old_refs: Set.new(), mentions_post: Set.new() }
}

public fn postcondition_with_old(p: Postcondition, loc: Text) -> Postcondition {
    let mut refs = p.old_refs;
    refs.insert(loc);
    Postcondition { old_refs: refs, mentions_post: p.mentions_post }
}

public fn postcondition_with_post(p: Postcondition, loc: Text) -> Postcondition {
    let mut posts = p.mentions_post;
    posts.insert(loc);
    Postcondition { old_refs: p.old_refs, mentions_post: posts }
}

/// A function's frame: the set of locations it may modify. O(1)
/// contains-check.
public type ContractsFrame is { modifies: Set<Text> };

public fn frame_empty() -> ContractsFrame {
    ContractsFrame { modifies: Set.new() }
}

public fn frame_with(f: ContractsFrame, loc: Text) -> ContractsFrame {
    let mut m = f.modifies;
    m.insert(loc);
    ContractsFrame { modifies: m }
}

public fn frame_contains(f: &ContractsFrame, loc: Text) -> Bool {
    f.modifies.contains(loc)
}

// =============================================================================
// 3. ContractsFrame analysis
// =============================================================================

/// Result of frame-property analysis.
public type FrameAnalysis is {
    /// Locations that must be snapshot pre-execution.
    locations_to_snapshot: List<Text>,
    /// Modified locations not constrained by old(...) — soundness warning.
    unconstrained_modifications: List<Text>,
    /// old(...) refs to non-modified locations — redundant.
    redundant_old_refs: List<Text>,
};

/// Compute snapshot obligations + soundness warnings from a
/// postcondition and its declared frame.
///
/// Complexity: O(|old_refs| + |modifies|), down from O(|old_refs| ×
/// |modifies|) in the prior list-backed version. Backing structures
/// are sets, so cross-membership checks short-circuit instead of
/// scanning.
public fn compute_frame_obligations(p: &Postcondition, f: &ContractsFrame) -> FrameAnalysis {
    // Locations that must be snapshot — every old() reference.
    let mut to_snap: List<Text> = [];
    for loc in p.old_refs.iter() {
        to_snap.push(loc.clone());
    }

    // Modified locations the postcondition never references via old().
    // O(|modifies|) — set lookup against old_refs is O(1) per call.
    let mut unconstrained: List<Text> = [];
    for loc in f.modifies.iter() {
        if !p.old_refs.contains(loc.clone()) {
            unconstrained.push(loc.clone());
        }
    }

    // old() refs to locations outside the frame — tautologically
    // equal to the post-value, so they're redundant. O(|old_refs|).
    let mut redundant: List<Text> = [];
    for loc in p.old_refs.iter() {
        if !f.modifies.contains(loc.clone()) {
            redundant.push(loc.clone());
        }
    }

    FrameAnalysis {
        locations_to_snapshot: to_snap,
        unconstrained_modifications: unconstrained,
        redundant_old_refs: redundant,
    }
}

/// Is the frame analysis clean (no warnings)?
public fn analysis_is_clean(a: &FrameAnalysis) -> Bool {
    a.unconstrained_modifications.len() == 0 && a.redundant_old_refs.len() == 0
}
