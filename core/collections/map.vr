implement<K: Hash + Eq, V> FusedIterator for MapDrain<K, V> {}
implement<K: Hash + Eq, V> FusedIterator for MapIntoIter<K, V> {}

// =============================================================================
// From conversions
// =============================================================================

implement<K: Hash + Eq, V> From<List<(K, V)>> for Map<K, V> {
    fn from(list: List<(K, V)>) -> Map<K, V> {
        let mut m = Map.with_capacity(list.len());
        for pair in list {
            m.insert(pair.0, pair.1);
        }
        m
    }
}

// =============================================================================
// Helper Functions
// =============================================================================

// Create map from pairs.
public fn map<K: Hash + Eq, V>(pairs: [(K, V); _]) -> Map<K, V> {
    let mut m = Map.with_capacity(pairs.len());
    for i in range(0, pairs.len()) {
        let pair = pairs[i];
        let k: K = pair.0;
        let v: V = pair.1;
        m.insert(k, v);
    }
    m
}

/// Create a Map from a list of keys, each mapped to the same default value.
public fn map_from_keys<K: Hash + Eq, V: Clone>(keys: &[K], default: V) -> Map<K, V>
where K: Clone
{
    let mut m: Map<K, V> = Map.with_capacity(keys.len());
    for i in range(0, keys.len()) {
        m.insert(keys[i].clone(), default.clone());
    }
    m
}

/// Count elements by a key function.
public fn count_by<T, K: Hash + Eq, I: Iterator<Item = T>>(iter: I, key_fn: fn(&T) -> K) -> Map<K, Int> {
    let mut counts: Map<K, Int> = Map.new();
    for item in iter {
        let k = key_fn(&item);
        let count = counts.entry(k).or_insert(0);
        *count = *count + 1;
    }
    counts
}

/// Group elements by a key function.
public fn group_by<T, K: Hash + Eq, I: Iterator<Item = T>>(iter: I, key_fn: fn(&T) -> K) -> Map<K, List<T>> {
    let mut groups: Map<K, List<T>> = Map.new();
    for item in iter {
        let k = key_fn(&item);
        let group = groups.get_or_insert_with(k, || List.new());
        group.push(item);
    }
    groups
}
