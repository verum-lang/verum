// =============================================================================
// Drain Iterator
// =============================================================================

/// Draining iterator that removes entries from the map.
/// Takes ownership of all entries, leaving the map empty but with capacity intact.
public type MapDrain<K: Hash + Eq, V> is {
    map: &mut Map<K, V>,
    idx: Int,
};

implement<K: Hash + Eq, V> Iterator for MapDrain<K, V> {
    type Item = (K, V);

    fn next(&mut self) -> Maybe<(K, V)> {
        while self.idx < self.map.cap {
            let entry = unsafe { &mut *self.map.entries.offset(self.idx) };
            self.idx = self.idx + 1;

            if (entry.hash > 0) {
                // Take ownership of key and value
                let key = entry.key;
                let value = entry.value;
                entry.hash = EMPTY;
                entry.psl = 0;
                self.map.len = self.map.len - 1;
                return Some((key, value));
            }
        }
        None
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        (self.map.len, Some(self.map.len))
    }
}

implement<K: Hash + Eq, V> IntoIterator for MapDrain<K, V> {
    type Item = (K, V);
    type IntoIter = MapDrain<K, V>;

    fn into_iter(self) -> MapDrain<K, V> {
        self
    }
}

implement<K: Hash + Eq, V> Drop for MapDrain<K, V> {
    fn drop(&mut self) {
        // Consume any remaining entries to ensure proper cleanup
        while self.next().is_some() {}
        // Reset tombstone count since we've cleaned everything
        self.map.tombstones = 0;
    }
}

// =============================================================================
// IntoIterator
// =============================================================================

implement<K: Hash + Eq, V> IntoIterator for Map<K, V> {
    type Item = (K, V);
    type IntoIter = MapIntoIter<K, V>;

    fn into_iter(self) -> MapIntoIter<K, V> {
        MapIntoIter {
            map: self,
            idx: 0,
        }
    }
}

// Owning iterator.
public type MapIntoIter<K, V> is {
    map: Map<K, V>,
    idx: Int,
};

implement<K: Hash + Eq, V> Iterator for MapIntoIter<K, V> {
    type Item = (K, V);

    fn next(&mut self) -> Maybe<(K, V)> {
        while self.idx < self.map.cap {
            let entry = unsafe { &*self.map.entries.offset(self.idx) };
            self.idx = self.idx + 1;

            if (entry.hash > 0) {
                self.map.len = self.map.len - 1;
                let key = entry.key;
                let value = entry.value;
                return Some((key, value));
            }
        }
        None
    }

    fn size_hint(&self) -> (Int, Maybe<Int>) {
        (self.map.len, Some(self.map.len))
    }
}

implement<K: Hash + Eq, V> Drop for MapIntoIter<K, V> {
    fn drop(&mut self) {
        // Drop remaining entries
        while self.next().is_some() {}
        // Map's drop will free memory but we've already consumed entries
        self.map.len = 0;
    }
}

// =============================================================================
// ExactSizeIterator for Drain and IntoIter
// =============================================================================

implement<K: Hash + Eq, V> ExactSizeIterator for MapDrain<K, V> {
    fn len(&self) -> Int { self.map.len }
}

implement<K: Hash + Eq, V> ExactSizeIterator for MapIntoIter<K, V> {
    fn len(&self) -> Int { self.map.len }
}

