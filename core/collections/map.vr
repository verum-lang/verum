implement<K, V> IntoIterator for MapIter<K, V> {
    type Item = (K, V);
    type IntoIter = MapIter<K, V>;

    fn into_iter(self) -> MapIter<K, V> {
        self
    }
}

implement<K, V> IntoIterator for MapKeys<K, V> {
    type Item = K;
    type IntoIter = MapKeys<K, V>;

    fn into_iter(self) -> MapKeys<K, V> {
        self
    }
}

implement<K, V> IntoIterator for MapValues<K, V> {
