// =============================================================================

implement<K: Ord, V> FusedIterator for BTreeMapIter<K, V> {}
implement<K: Ord, V> FusedIterator for BTreeMapKeys<K, V> {}
implement<K: Ord, V> FusedIterator for BTreeMapValues<K, V> {}
implement<K: Ord, V> FusedIterator for BTreeMapValuesMut<K, V> {}
implement<K: Ord, V> FusedIterator for BTreeMapIterMut<K, V> {}
implement<K: Ord, V> FusedIterator for BTreeMapRange<K, V> {}
implement<K: Ord, V> FusedIterator for BTreeMapDrain<K, V> {}
implement<T: Ord> FusedIterator for BTreeSetIter<T> {}
implement<T: Ord> FusedIterator for BTreeSetRange<T> {}
implement<T: Ord> FusedIterator for BTreeSetDrain<T> {}

// =============================================================================
// RangeBounds Protocol (simplified)
// =============================================================================

/// Protocol for range bounds.
public type RangeBounds<T> is protocol {
    fn start_bound(&self) -> Maybe<&T>;
    fn end_bound(&self) -> Maybe<&T>;
    fn start_is_inclusive(&self) -> Bool;
    fn end_is_inclusive(&self) -> Bool;
};

// =============================================================================
// FromIterator implementations
// =============================================================================

implement<K: Ord, V> FromIterator<(K, V)> for BTreeMap<K, V> {
    fn from_iter<I: Iterator<Item = (K, V)>>(mut iter: I) -> BTreeMap<K, V> {
        let mut map = BTreeMap.new();
        loop {
            match iter.next() {
                None => break,
                Some(pair) => {
                    let tuple: (K, V) = pair;
                    map.insert(tuple.0, tuple.1);
                }
            }
        }
        map
    }
}

implement<T: Ord> FromIterator<T> for BTreeSet<T> {
    fn from_iter<I: Iterator<Item = T>>(iter: I) -> BTreeSet<T> {
        let mut set = BTreeSet.new();
        for x in iter {
            set.insert(x);
        }
        set
    }
}

