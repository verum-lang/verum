    fn into_iter(self) -> BTreeSetIter<T> {
        self.iter()
    }
}

// =============================================================================
// Eq for BTreeMap and BTreeSet
// =============================================================================

implement<K: Ord + Eq, V: Eq> Eq for BTreeMap<K, V> {
    fn eq(&self, other: &BTreeMap<K, V>) -> Bool {
        if self.len() != other.len() {
            return false;
        }
        let mut it_self = self.iter();
        let mut it_other = other.iter();
        loop {
            match (it_self.next(), it_other.next()) {
                (None, None) => { return true; }
                (Some(a), Some(b)) => {
                    if !(a.0 == b.0 && a.1 == b.1) {
                        return false;
                    }
                }
                _ => { return false; }
            }
        }
    }
}

implement<T: Ord + Eq> Eq for BTreeSet<T> {
    fn eq(&self, other: &BTreeSet<T>) -> Bool {
        if self.len() != other.len() {
            return false;
        }
        let mut it_self = self.iter();
        let mut it_other = other.iter();
        loop {
            match (it_self.next(), it_other.next()) {
                (None, None) => { return true; }
                (Some(a), Some(b)) => {
                    if !(a == b) {
                        return false;
                    }
                }
                _ => { return false; }
            }
        }
    }
}

// =============================================================================
// Extend for BTreeMap and BTreeSet
// =============================================================================

implement<K: Ord, V> Extend<(K, V)> for BTreeMap<K, V> {
    fn extend<I: Iterator<Item = (K, V)>>(&mut self, iter: I) {
        for pair in iter {
            self.insert(pair.0, pair.1);
        }
    }
}

implement<T: Ord> Extend<T> for BTreeSet<T> {
    fn extend<I: Iterator<Item = T>>(&mut self, iter: I) {
        for x in iter {
            self.insert(x);
        }
    }
}

// =============================================================================
// BTreeSet Operator Overloads for set algebra
// =============================================================================

/// Union: a | b
implement<T: Ord + Clone> BitOr<BTreeSet<T>> for BTreeSet<T> {
    type Output = BTreeSet<T>;

    fn bitor(self, rhs: BTreeSet<T>) -> BTreeSet<T> {
        self.union(&rhs)
    }
}

/// Intersection: a & b
implement<T: Ord + Clone> BitAnd<BTreeSet<T>> for BTreeSet<T> {
    type Output = BTreeSet<T>;

    fn bitand(self, rhs: BTreeSet<T>) -> BTreeSet<T> {
        self.intersection(&rhs)
    }
}

/// Difference: a - b
implement<T: Ord + Clone> Sub<BTreeSet<T>> for BTreeSet<T> {
    type Output = BTreeSet<T>;

    fn sub(self, rhs: BTreeSet<T>) -> BTreeSet<T> {
        self.difference(&rhs)
    }
}

/// Symmetric difference: a ^ b
implement<T: Ord + Clone> BitXor<BTreeSet<T>> for BTreeSet<T> {
    type Output = BTreeSet<T>;

    fn bitxor(self, rhs: BTreeSet<T>) -> BTreeSet<T> {
        self.symmetric_difference(&rhs)
    }
}

/// In-place union: a |= &b
implement<T: Ord + Clone> BitOrAssign<&BTreeSet<T>> for BTreeSet<T> {
    fn bitor_assign(&mut self, other: &BTreeSet<T>) {
        self.extend_from_set(other);
    }
}

/// In-place intersection: a &= &b
implement<T: Ord + Clone> BitAndAssign<&BTreeSet<T>> for BTreeSet<T> {
    fn bitand_assign(&mut self, other: &BTreeSet<T>) {
        self.retain_from_set(other);
    }
}

/// In-place difference: a -= &b
implement<T: Ord + Clone> SubAssign<&BTreeSet<T>> for BTreeSet<T> {
    fn sub_assign(&mut self, other: &BTreeSet<T>) {
        self.remove_from_set(other);
    }
}

/// In-place symmetric difference: a ^= &b
implement<T: Ord + Clone> BitXorAssign<&BTreeSet<T>> for BTreeSet<T> {
    fn bitxor_assign(&mut self, other: &BTreeSet<T>) {
        self.symmetric_difference_update(other);
    }
}

// =============================================================================
// Entry API for BTreeMap
// =============================================================================

/// Entry in a BTreeMap for in-place operations.
public type BTreeEntry<K: Ord, V> is
    | Occupied(BTreeOccupiedEntry<K, V>)
    | Vacant(BTreeVacantEntry<K, V>);

public type BTreeOccupiedEntry<K: Ord, V> is {
    map: &mut BTreeMap<K, V>,
    key: K,
};

public type BTreeVacantEntry<K: Ord, V> is {
    map: &mut BTreeMap<K, V>,
    key: K,
};

implement<K: Ord, V> BTreeMap<K, V> {
    /// Get entry for in-place operations.
    public fn entry(&mut self, key: K) -> BTreeEntry<K, V> {
        if self.contains_key(&key) {
            BTreeEntry.Occupied(BTreeOccupiedEntry { map: self, key })
        } else {
            BTreeEntry.Vacant(BTreeVacantEntry { map: self, key })
        }
    }
}

implement<K: Ord, V> BTreeEntry<K, V> {
    /// Insert default value if vacant, return mutable reference.
    public fn or_insert(self, default: V) -> &mut V
    where K: Clone, V: Clone
    {
        match self {
            BTreeEntry.Occupied(entry) => entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some"),
            BTreeEntry.Vacant(entry) => {
                entry.map.insert(entry.key.clone(), default);
                entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some")
            }
        }
    }

    /// Insert with function if vacant, return mutable reference.
    public fn or_insert_with<F: fn() -> V>(self, f: F) -> &mut V
    where K: Clone, V: Clone
    {
        match self {
            BTreeEntry.Occupied(entry) => entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some"),
            BTreeEntry.Vacant(entry) => {
                entry.map.insert(entry.key.clone(), f());
                entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some")
            }
        }
    }

    /// Insert a value computed from the key if vacant, return mutable reference.
    public fn or_insert_with_key<F: fn(&K) -> V>(self, f: F) -> &mut V
    where K: Clone, V: Clone
    {
        match self {
            BTreeEntry.Occupied(entry) => entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some"),
            BTreeEntry.Vacant(entry) => {
                let value = f(&entry.key);
                entry.map.insert(entry.key.clone(), value);
                entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some")
            }
        }
    }

    /// Insert default value if vacant, return mutable reference.
    public fn or_default(self) -> &mut V
    where K: Clone, V: Clone + Default
    {
        match self {
            BTreeEntry.Occupied(entry) => entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some"),
            BTreeEntry.Vacant(entry) => {
                entry.map.insert(entry.key.clone(), V.default());
                entry.map.get_mut(&entry.key).expect("BTreeEntry: key invariant — Occupied or just-inserted Vacant guarantees get_mut is_some")
            }
        }
    }

    /// Provides in-place mutable access to an occupied entry before any
    /// potential inserts into the map.
    ///
    /// # Example
    ///
    /// ```verum
    /// map.entry("key")
    ///    .and_modify(|v| *v = *v + 1)
    ///    .or_insert(0);
    /// ```
    public fn and_modify<F: fn(&mut V)>(self, f: F) -> BTreeEntry<K, V>
    where K: Clone, V: Clone
    {
        match self {
            BTreeEntry.Occupied(entry) => {
                match entry.map.get_mut(&entry.key) {
                    Some(v) => f(v),
                    None => {}
                }
                BTreeEntry.Occupied(entry)
            }
            BTreeEntry.Vacant(entry) => BTreeEntry.Vacant(entry),
        }
    }

    /// Returns a reference to this entry's key.
    public fn key(&self) -> &K {
        match self {
            BTreeEntry.Occupied(entry) => &entry.key,
            BTreeEntry.Vacant(entry) => &entry.key,
        }
    }
}

// =============================================================================
// From conversions
// =============================================================================

implement<K: Ord, V> From<List<(K, V)>> for BTreeMap<K, V> {
    fn from(list: List<(K, V)>) -> BTreeMap<K, V> {
        let mut m = BTreeMap.new();
        for pair in list {
            m.insert(pair.0, pair.1);
        }
        m
    }
}

implement<T: Ord> From<List<T>> for BTreeSet<T> {
    fn from(list: List<T>) -> BTreeSet<T> {
        let mut s = BTreeSet.new();
        for item in list {
            s.insert(item);
        }
        s
    }
}

// =============================================================================
// Tests
// =============================================================================

@test
fn test_btreemap_basic() {
    let mut map = BTreeMap.new();
    assert(map.is_empty());

    map.insert(1, "one");
    map.insert(2, "two");
    map.insert(3, "three");

    assert_eq(map.len(), 3);
    assert_eq(map.get(&1), Some(&"one"));
    assert_eq(map.get(&2), Some(&"two"));
    assert_eq(map.get(&4), None);
}

@test
fn test_btreemap_iteration_order() {
    let mut map = BTreeMap.new();
    map.insert(5, "five");
    map.insert(1, "one");
    map.insert(3, "three");
    map.insert(2, "two");
    map.insert(4, "four");

    let keys: List<Int> = map.keys().cloned().collect();
    assert_eq(keys, List.from([1, 2, 3, 4, 5]));
}

@test
fn test_btreemap_remove() {
    let mut map = BTreeMap.new();
    map.insert(1, "one");
    map.insert(2, "two");

    assert_eq(map.remove(&1), Some("one"));
    assert_eq(map.len(), 1);
    assert_eq(map.get(&1), None);
}

@test
fn test_btreeset_basic() {
    let mut set = BTreeSet.new();
    assert(set.insert(3));
    assert(set.insert(1));
    assert(set.insert(2));
    assert(!set.insert(2));  // Duplicate

    assert_eq(set.len(), 3);
    assert(set.contains(&2));
    assert(!set.contains(&4));
}

@test
fn test_btreeset_iteration_order() {
    let mut set = BTreeSet.new();
    set.insert(5);
    set.insert(1);
    set.insert(3);

    let values: List<Int> = set.iter().cloned().collect();
    assert_eq(values, List.from([1, 3, 5]));
}

@test
fn test_btreemap_first_last() {
    let mut map = BTreeMap.new();
    map.insert(2, "two");
    map.insert(1, "one");
    map.insert(3, "three");

    assert_eq(map.first_key_value(), Some((&1, &"one")));
    assert_eq(map.last_key_value(), Some((&3, &"three")));
}
