// =============================================================================
// tracing/sampler.vr — Sampler protocol, standard samplers, and the
//                      SamplerHandle closed-world dispatch enum
// =============================================================================
// Head-based sampling decision. Consulted by Tracer.start_span() with the
// parent context and span attributes; returns RecordAndSample / RecordOnly /
// Drop plus an updated TraceState.
//

// The SDK dispatches through `SamplerHandle` — a closed variant enum
// with a `ShCustom(Shared<dyn Sampler>)` escape hatch for user-defined
// samplers, pending protocol-object dispatch support in the VBC
// interpreter.
// Spec: https://opentelemetry.io/docs/specs/otel/trace/sdk/#sampler
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.sampler;

mount core.*;
mount core.tracing.id.{TraceId};
mount core.tracing.context.{SpanContext, TraceState};
mount core.tracing.attribute.{AttributeSet};
mount core.tracing.data.{SpanKind};

// =============================================================================
// Types
// =============================================================================

public type SamplingDecision is
    /// Drop — span is not recorded nor sampled.
    | Drop
    /// Record but do not sample (local inspection only, never exported).
    | RecordOnly
    /// Record AND include in sampled output (sets the sampled flag).
    | RecordAndSample;

public type SamplingResult is {
    decision: SamplingDecision,
    /// TraceState for the new span's context (may clone / modify parent).
    trace_state: TraceState,
};

implement SamplingResult {
    public fn new(decision: SamplingDecision, trace_state: TraceState) -> SamplingResult {
        SamplingResult { decision: decision, trace_state: trace_state }
    }

    public fn decision(&self) -> SamplingDecision { self.decision }

    /// Owned copy — see the module note on reference-returning
    /// accessors and the AOT tier.
    public fn trace_state(&self) -> TraceState { self.trace_state.clone() }
}

// =============================================================================
// Protocol — the contract ShCustom samplers implement
// =============================================================================

public type Sampler is protocol {
    /// Decide whether to sample. Pure function — no side effects; runs
    /// inline on whatever thread starts the span.
    fn should_sample(
        &self,
        parent: &SpanContext,
        trace_id: &TraceId,
        name: &Text,
        kind: SpanKind,
        attributes: &AttributeSet,
    ) -> SamplingResult;

    /// Human-readable identifier for telemetry / diagnostics.
    fn description(&self) -> Text;
};

// =============================================================================
// AlwaysOn / AlwaysOff — protocol-form unit samplers
// =============================================================================

public type AlwaysOn is ();

implement AlwaysOn {
    public fn new() -> AlwaysOn { () }
}

implement Sampler for AlwaysOn {
    fn should_sample(
        &self,
        parent: &SpanContext,
        _trace_id: &TraceId,
        _name: &Text,
        _kind: SpanKind,
        _attributes: &AttributeSet,
    ) -> SamplingResult {
        SamplingResult.new(SamplingDecision.RecordAndSample, parent.trace_state())
    }

    fn description(&self) -> Text { "AlwaysOnSampler".into() }
}

public type AlwaysOff is ();

implement AlwaysOff {
    public fn new() -> AlwaysOff { () }
}

implement Sampler for AlwaysOff {
    fn should_sample(
        &self,
        parent: &SpanContext,
        _trace_id: &TraceId,
        _name: &Text,
        _kind: SpanKind,
        _attributes: &AttributeSet,
    ) -> SamplingResult {
        SamplingResult.new(SamplingDecision.Drop, parent.trace_state())
    }

    fn description(&self) -> Text { "AlwaysOffSampler".into() }
}

// =============================================================================
// TraceIdRatio — deterministic ratio sampling on the trace id's low bits
// =============================================================================
//

// Keyed on the LOW 8 bytes of the TraceId, masked to 63 bits, following
// the OTel consistent-probability guidance (the low bytes are the ones
// W3C Trace Context Level 2 designates as random). Sampled iff
// key < ratio · 2^63. The 63-bit domain makes ratio = 1.0 exact with no
// integer overflow: the bound 2^63 fits UInt64 and every masked key is
// strictly below it.
//

// Identical TraceIds always produce the same decision, so all services
// in a trace agree without coordination.

public type TraceIdRatio is {
    ratio: Float,
    /// Sampling bound in the 63-bit key domain: ratio · 2^63.
    bound: UInt64,
    /// r >= 1.0 — sample unconditionally (no 2^63 arithmetic: wide
    /// integer literals AND 63-bit shifts both mis-lower in baked
    /// stdlib modules).
    all: Bool,
};

implement TraceIdRatio {
    public fn new(ratio: Float) -> TraceIdRatio {
        let r = if ratio < 0.0 { 0.0 } else if ratio > 1.0 { 1.0 } else { ratio };
        let all = r >= 1.0;
        let bound = if all {
            0
        } else {
            (r * 9223372036854775808.0) as UInt64
        };
        TraceIdRatio { ratio: r, bound: bound, all: all }
    }

    /// Low 8 bytes of the trace id, big-endian, masked to 63 bits.
    fn trace_id_key(bytes: &[UInt8; 16]) -> UInt64 {
        let mut n: UInt64 = 0;
        let mut i = 8;
        while i < 16 {
            n = (n << 8) | (bytes[i] as UInt64);
            i = i + 1;
        }
        // 2^63-1 composed by shift — wide integer literals mis-lower
        // in baked stdlib modules.
        n & (((1 as UInt64) << 63) - 1)
    }

    public fn ratio(&self) -> Float { self.ratio }

    public fn clone(&self) -> TraceIdRatio {
        TraceIdRatio { ratio: self.ratio, bound: self.bound, all: self.all }
    }
}

implement TraceIdRatio {
    /// Uniquely-named decision worker so handle dispatch resolves on
    /// any receiver-tracking tier.
    public fn ratio_decide(&self, parent: &SpanContext, trace_id: &TraceId) -> SamplingResult {
        if self.all {
            return SamplingResult.new(SamplingDecision.RecordAndSample, parent.trace_state());
        }
        let key = TraceIdRatio.trace_id_key(trace_id.as_bytes());
        if key < self.bound {
            SamplingResult.new(SamplingDecision.RecordAndSample, parent.trace_state())
        } else {
            SamplingResult.new(SamplingDecision.Drop, parent.trace_state())
        }
    }

    public fn ratio_describe(&self) -> Text {
        f"TraceIdRatioSampler{{ratio={self.ratio}}}"
    }
}

implement Sampler for TraceIdRatio {
    fn should_sample(
        &self,
        parent: &SpanContext,
        trace_id: &TraceId,
        _name: &Text,
        _kind: SpanKind,
        _attributes: &AttributeSet,
    ) -> SamplingResult {
        self.ratio_decide(parent, trace_id)
    }

    fn description(&self) -> Text {
        self.ratio_describe()
    }
}

// =============================================================================
// ParentBased — defer to parent; fall back to `root` for missing parent
// =============================================================================

public type ParentBased is {
    root: SamplerHandle,
    remote_parent_sampled: SamplerHandle,
    remote_parent_not_sampled: SamplerHandle,
    local_parent_sampled: SamplerHandle,
    local_parent_not_sampled: SamplerHandle,
};

implement ParentBased {
    /// OTel default wiring: sampled parents → AlwaysOn, unsampled
    /// parents → AlwaysOff; `root` decides for parentless spans.
    public fn new(root: SamplerHandle) -> ParentBased {
        ParentBased {
            root: root,
            remote_parent_sampled: SamplerHandle.ShAlwaysOn,
            remote_parent_not_sampled: SamplerHandle.ShAlwaysOff,
            local_parent_sampled: SamplerHandle.ShAlwaysOn,
            local_parent_not_sampled: SamplerHandle.ShAlwaysOff,
        }
    }

    /// Uniquely-named decision worker so handle dispatch resolves on
    /// any receiver-tracking tier.
    public fn parent_decide(
        &self,
        parent: &SpanContext,
        trace_id: &TraceId,
        name: &Text,
        kind: SpanKind,
        attributes: &AttributeSet,
    ) -> SamplingResult {
        if !parent.is_valid() {
            return self.root.should_sample(parent, trace_id, name, kind, attributes);
        }
        let sampled = parent.is_sampled();
        let delegate = if parent.is_remote() {
            if sampled { &self.remote_parent_sampled } else { &self.remote_parent_not_sampled }
        } else {
            if sampled { &self.local_parent_sampled } else { &self.local_parent_not_sampled }
        };
        delegate.should_sample(parent, trace_id, name, kind, attributes)
    }

    public fn parent_describe(&self) -> Text {
        f"ParentBased{{root={self.root.description()}}}"
    }
}

// =============================================================================
// SamplerHandle — closed-world dispatch over the in-tree samplers
// =============================================================================

public type SamplerHandle is
    /// Sample everything.
    | ShAlwaysOn
    /// Sample nothing.
    | ShAlwaysOff
    /// Deterministic ratio on the trace id's low 63 bits.
    | ShRatio(TraceIdRatio)
    /// Follow the parent's decision; delegate to nested handles.
    | ShParentBased(Shared<ParentBased>)
    /// User-defined sampler behind the Sampler protocol. NOTE: invoking
    /// a custom sampler requires protocol-object dispatch, which the
    /// VBC interpreter does not implement yet — construction and
    /// configuration work, invocation panics until the language gap
    /// closes.
    | ShCustom(Shared<dyn Sampler>);

implement SamplerHandle {
    public fn should_sample(
        &self,
        parent: &SpanContext,
        trace_id: &TraceId,
        name: &Text,
        kind: SpanKind,
        attributes: &AttributeSet,
    ) -> SamplingResult {
        match self {
            SamplerHandle.ShAlwaysOn => {
                SamplingResult.new(SamplingDecision.RecordAndSample, parent.trace_state())
            }
            SamplerHandle.ShAlwaysOff => {
                SamplingResult.new(SamplingDecision.Drop, parent.trace_state())
            }
            SamplerHandle.ShRatio(r) => {
                r.ratio_decide(parent, trace_id)
            }
            SamplerHandle.ShParentBased(p) => {
                p.parent_decide(parent, trace_id, name, kind, attributes)
            }
            SamplerHandle.ShCustom(s) => {
                s.should_sample(parent, trace_id, name, kind, attributes)
            }
        }
    }

    public fn description(&self) -> Text {
        match self {
            SamplerHandle.ShAlwaysOn => "AlwaysOnSampler".into(),
            SamplerHandle.ShAlwaysOff => "AlwaysOffSampler".into(),
            SamplerHandle.ShRatio(r) => r.ratio_describe(),
            SamplerHandle.ShParentBased(p) => p.parent_describe(),
            SamplerHandle.ShCustom(s) => s.description(),
        }
    }

    public fn clone(&self) -> SamplerHandle {
        match self {
            SamplerHandle.ShAlwaysOn => SamplerHandle.ShAlwaysOn,
            SamplerHandle.ShAlwaysOff => SamplerHandle.ShAlwaysOff,
            SamplerHandle.ShRatio(r) => SamplerHandle.ShRatio(r.clone()),
            SamplerHandle.ShParentBased(p) => SamplerHandle.ShParentBased(p.clone()),
            SamplerHandle.ShCustom(s) => SamplerHandle.ShCustom(s.clone()),
        }
    }
}

// =============================================================================
// Factory functions — ready-to-install SamplerHandle values
// =============================================================================

public fn always_on() -> SamplerHandle {
    SamplerHandle.ShAlwaysOn
}

public fn always_off() -> SamplerHandle {
    SamplerHandle.ShAlwaysOff
}

public fn trace_id_ratio(ratio: Float) -> SamplerHandle {
    SamplerHandle.ShRatio(TraceIdRatio.new(ratio))
}

public fn parent_based(root: SamplerHandle) -> SamplerHandle {
    SamplerHandle.ShParentBased(Shared.new(ParentBased.new(root)))
}

public fn custom_sampler(sampler: Shared<dyn Sampler>) -> SamplerHandle {
    SamplerHandle.ShCustom(sampler)
}
