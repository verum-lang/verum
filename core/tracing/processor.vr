// =============================================================================
// tracing/processor.vr — re-export shim
// =============================================================================
// The implementation lives in tracing/data.vr (single-module core: see
// the note there on cross-module record-literal type-id collisions).
// This shim preserves the public module path.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.processor;

public mount core.tracing.data.SpanProcessor;
public mount core.tracing.data.ProcessorHandle;
public mount core.tracing.data.SimpleProcessor;
public mount core.tracing.data.BatchProcessor;
public mount core.tracing.data.BatchConfig;
public mount core.tracing.data.CompositeProcessor;
