// =============================================================================
// tracing/data.vr — the span-pipeline CORE: frozen data, exporters,
//                   processors, and the live Span handle
// =============================================================================
// One module by architectural necessity: record literals of IMPORTED
// types mis-allocate against colliding type ids in stdlib-baked code
// (SpanInner↔SpanData class), so every record that any pipeline stage
// CONSTRUCTS lives here, together with its constructors. The public
// module layout is preserved through thin re-export shims
// (tracing/span.vr, tracing/exporter.vr, tracing/processor.vr).
//

// Layering inside this module, top to bottom: value types (kinds,
// status, errors, events, links, SpanData) → exporters +
// ExporterHandle → processors + ProcessorHandle → the Span handle and
// its guarded state machine.
// Spec: https://opentelemetry.io/docs/specs/otel/trace/api/#span
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.data;

mount core.*;
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};
mount core.time.system_time.{SystemTime};
mount core.tracing.id.{SpanId};
mount core.tracing.context.{SpanContext};
mount core.tracing.attribute.{AttributeSet};
mount core.tracing.resource.{Resource};
mount core.sync.mutex.{Mutex};
mount core.tracing.attribute.{AttributeValue};
mount core.async.channel.{Sender, Receiver, bounded};
mount core.io.file.{read_to_string as file_read_to_string, write as file_write};
mount core.async.task.{spawn_detached};
mount core.async.timer.{sleep};
mount core.sync.atomic.{AtomicU64, MemoryOrdering};
mount core.time.{Time};
mount core.sync.atomic.{AtomicBool, MemoryOrdering};
mount core.tracing.attribute.{AttributeValue, AttributeSet};

// =============================================================================
// SpanKind — role of the span in the trace
// =============================================================================

public type SpanKind is
    /// Default — no specific role.
    | KindInternal
    /// Outgoing synchronous or async request.
    | KindClient
    /// Handling of an incoming request.
    | KindServer
    /// Producing a message for asynchronous delivery.
    | KindProducer
    /// Consuming a message from asynchronous delivery.
    | KindConsumer;

// =============================================================================
// SpanStatus — final status
// =============================================================================

public type SpanStatusCode is
    | Unset
    | Ok
    | Error;

public type SpanStatus is {
    code: SpanStatusCode,
    description: Maybe<Text>,
};

implement SpanStatus {
    public fn unset() -> SpanStatus {
        SpanStatus { code: SpanStatusCode.Unset, description: Maybe.None }
    }

    public fn ok() -> SpanStatus {
        SpanStatus { code: SpanStatusCode.Ok, description: Maybe.None }
    }

    public fn error(description: Text) -> SpanStatus {
        SpanStatus { code: SpanStatusCode.Error, description: Maybe.Some(description) }
    }

    public fn code(&self) -> SpanStatusCode { self.code }

    /// Owned copy — reference-returning accessors crash the AOT tier
    /// today (known compiler class), and status descriptions are tiny.
    public fn description(&self) -> Maybe<Text> {
        match &self.description {
            Maybe.Some(d) => Maybe.Some(d.clone()),
            Maybe.None => Maybe.None,
        }
    }

    public fn clone(&self) -> SpanStatus {
        SpanStatus {
            code: self.code,
            description: match &self.description {
                Maybe.Some(d) => Maybe.Some(d.clone()),
                Maybe.None => Maybe.None,
            }
        }
    }
}

// =============================================================================
// Structured pipeline errors — every stage (processor, exporter,
// provider) reports through TraceExportResult
// =============================================================================

public type ExportErrorKind is
    /// Deadline elapsed before the operation completed.
    | Timeout
    /// I/O or network failure while shipping spans.
    | Transport
    /// A span could not be encoded into the wire format.
    | Serialization
    /// A bounded pipeline queue rejected the payload.
    | QueueFull
    /// The component has already been shut down.
    | ShutDown
    /// Invariant violation inside the pipeline itself.
    | Internal;

public type ExportError is {
    kind: ExportErrorKind,
    message: Text,
    retryable: Bool,
};

implement ExportError {
    public fn new(kind: ExportErrorKind, message: Text, retryable: Bool) -> ExportError {
        ExportError { kind: kind, message: message, retryable: retryable }
    }

    /// Deadline elapsed. Retryable: the payload may still be exportable.
    public fn timeout(message: Text) -> ExportError {
        ExportError { kind: ExportErrorKind.Timeout, message: message, retryable: true }
    }

    /// Transport-level failure (connection refused, reset, DNS, ...).
    public fn transport(message: Text) -> ExportError {
        ExportError { kind: ExportErrorKind.Transport, message: message, retryable: true }
    }

    /// Encoding failure — retrying the same payload cannot succeed.
    public fn serialization(message: Text) -> ExportError {
        ExportError { kind: ExportErrorKind.Serialization, message: message, retryable: false }
    }

    /// Bounded queue full — the caller may retry after back-off.
    public fn queue_full() -> ExportError {
        ExportError {
            kind: ExportErrorKind.QueueFull,
            message: "bounded export queue is full".into(),
            retryable: true,
        }
    }

    /// Component already shut down — permanent.
    public fn shut_down() -> ExportError {
        ExportError {
            kind: ExportErrorKind.ShutDown,
            message: "exporter or processor already shut down".into(),
            retryable: false,
        }
    }

    /// Pipeline invariant violation — permanent, indicates a bug.
    public fn internal(message: Text) -> ExportError {
        ExportError { kind: ExportErrorKind.Internal, message: message, retryable: false }
    }

    public fn kind(&self) -> ExportErrorKind { self.kind }

    /// Owned copy (see SpanStatus.description).
    public fn message(&self) -> Text { self.message.clone() }

    public fn is_retryable(&self) -> Bool { self.retryable }

    public fn clone(&self) -> ExportError {
        ExportError {
            kind: self.kind,
            message: self.message.clone(),
            retryable: self.retryable,
        }
    }
}

implement Display for ExportError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let kind = match self.kind {
            ExportErrorKind.Timeout => "timeout",
            ExportErrorKind.Transport => "transport",
            ExportErrorKind.Serialization => "serialization",
            ExportErrorKind.QueueFull => "queue-full",
            ExportErrorKind.ShutDown => "shut-down",
            ExportErrorKind.Internal => "internal",
        };
        let retry = if self.retryable { "retryable" } else { "permanent" };
        f.write_str(f"export error [{kind}, {retry}]: {self.message}")
    }
}

public type TraceExportResult is
    | Success
    | Failure(ExportError);

implement TraceExportResult {
    public fn is_success(&self) -> Bool {
        match self {
            TraceExportResult.Success => true,
            TraceExportResult.Failure(_) => false,
        }
    }

    public fn is_failure(&self) -> Bool { !self.is_success() }

    /// First-failure composition: keeps an existing failure, otherwise
    /// adopts `other`. Used to aggregate multi-stage / multi-processor
    /// results without losing the earliest error.
    public fn combine(self, other: TraceExportResult) -> TraceExportResult {
        match self {
            TraceExportResult.Failure(e) => TraceExportResult.Failure(e),
            TraceExportResult.Success => other,
        }
    }

    public fn clone(&self) -> TraceExportResult {
        match self {
            TraceExportResult.Success => TraceExportResult.Success,
            TraceExportResult.Failure(e) => TraceExportResult.Failure(e.clone()),
        }
    }
}

// =============================================================================
// SpanEvent — timestamped annotation on the span
// =============================================================================

public type SpanEvent is {
    name: Text,
    timestamp: Instant,
    attributes: AttributeSet,
};

implement SpanEvent {
    public fn new(name: Text, timestamp: Instant, attributes: AttributeSet) -> SpanEvent {
        SpanEvent { name: name, timestamp: timestamp, attributes: attributes }
    }

    public fn name(&self) -> Text { self.name.clone() }
    public fn timestamp(&self) -> Instant { self.timestamp }
    public fn attributes(&self) -> AttributeSet { self.attributes.clone() }
}

// =============================================================================
// SpanLink — reference to another span (typically a different trace)
// =============================================================================

public type SpanLink is {
    context: SpanContext,
    attributes: AttributeSet,
};

implement SpanLink {
    public fn new(context: SpanContext, attributes: AttributeSet) -> SpanLink {
        SpanLink { context: context, attributes: attributes }
    }

    public fn context(&self) -> SpanContext { self.context.clone() }
    public fn attributes(&self) -> AttributeSet { self.attributes.clone() }
}

// =============================================================================
// SpanData — frozen exported form
// =============================================================================

public type SpanData is {
    name: Text,
    context: SpanContext,
    parent_span_id: Maybe<SpanId>,
    kind: SpanKind,
    start_time: Instant,
    /// Wall-clock at span start — the anchor exporters use to map the
    /// monotonic duration onto absolute (epoch) timestamps.
    start_system_time: SystemTime,
    end_time: Instant,
    attributes: AttributeSet,
    events: List<SpanEvent>,
    links: List<SpanLink>,
    status: SpanStatus,
    resource: Shared<Resource>,
    instrumentation_scope: Text,
    instrumentation_version: Text,
};

implement SpanData {
    public fn duration(&self) -> Duration {
        self.end_time - self.start_time
    }

    /// Wall-clock end derived from the start anchor + duration.
    public fn end_system_time(&self) -> SystemTime {
        match self.start_system_time.checked_add(self.duration()) {
            Maybe.Some(t) => t,
            Maybe.None => self.start_system_time,
        }
    }

    // Owned-copy accessors: reference-returning methods crash the AOT
    // tier today (known compiler class). SpanData is an export
    // artifact consumed once per stage — the copies are cheap and the
    // costs are documented in the module docs.
    public fn name(&self) -> Text { self.name.clone() }
    public fn context(&self) -> SpanContext { self.context.clone() }
    public fn parent_span_id(&self) -> Maybe<SpanId> { self.parent_span_id }
    public fn kind(&self) -> SpanKind { self.kind }
    public fn start_time(&self) -> Instant { self.start_time }
    public fn start_system_time(&self) -> SystemTime { self.start_system_time }
    public fn end_time(&self) -> Instant { self.end_time }
    public fn attributes(&self) -> AttributeSet { self.attributes.clone() }
    public fn events(&self) -> List<SpanEvent> { clone_event_list(&self.events) }
    public fn links(&self) -> List<SpanLink> { clone_link_list(&self.links) }
    public fn status(&self) -> SpanStatus { self.status.clone() }
    public fn resource(&self) -> Shared<Resource> { self.resource.clone() }
    public fn instrumentation_scope(&self) -> Text { self.instrumentation_scope.clone() }
    public fn instrumentation_version(&self) -> Text { self.instrumentation_version.clone() }

    /// Deep copy. Used by fan-out processors that hand each downstream
    /// processor its own instance.
    public fn clone(&self) -> SpanData {
        SpanData {
            name: self.name.clone(),
            context: self.context.clone(),
            parent_span_id: self.parent_span_id,
            kind: self.kind,
            start_time: self.start_time,
            start_system_time: self.start_system_time,
            end_time: self.end_time,
            attributes: self.attributes.clone(),
            events: clone_event_list(&self.events),
            links: clone_link_list(&self.links),
            status: self.status.clone(),
            resource: self.resource.clone(),
            instrumentation_scope: self.instrumentation_scope.clone(),
            instrumentation_version: self.instrumentation_version.clone(),
        }
    }
}

/// Deep-copy a list of events (SpanEvent has owned Text + AttributeSet).
public fn clone_event_list(src: &List<SpanEvent>) -> List<SpanEvent> {
    let mut out = List.with_capacity(src.len());
    let mut i = 0;
    while i < src.len() {
        out.push(SpanEvent {
            name: src[i].name.clone(),
            timestamp: src[i].timestamp,
            attributes: src[i].attributes.clone(),
        });
        i = i + 1;
    }
    out
}

/// Deep-copy a list of links.
public fn clone_link_list(src: &List<SpanLink>) -> List<SpanLink> {
    let mut out = List.with_capacity(src.len());
    let mut i = 0;
    while i < src.len() {
        out.push(SpanLink {
            context: src[i].context.clone(),
            attributes: src[i].attributes.clone(),
        });
        i = i + 1;
    }
    out
}

// =============================================================================
// Protocol — the contract EhCustom exporters implement
// =============================================================================

public type SpanExporter is protocol {
    /// Export a batch of spans. Called from a processor (the batch one,
    /// on its worker task). May block on I/O — the processor keeps it
    /// off the request path, not the exporter.
    fn export(&self, spans: &List<SpanData>) -> TraceExportResult;

    /// Flush any pending spans. Called on flush and during shutdown.
    fn force_flush(&self, timeout: Duration) -> TraceExportResult;

    /// Shutdown — release all resources. Exports after shutdown fail
    /// with ExportErrorKind.ShutDown.
    fn shutdown(&self, timeout: Duration) -> TraceExportResult;
};

// =============================================================================
// NoopExporter — discard everything
// =============================================================================

public type NoopExporter is ();

implement NoopExporter {
    public fn new() -> NoopExporter { () }
}

implement SpanExporter for NoopExporter {
    fn export(&self, _spans: &List<SpanData>) -> TraceExportResult { TraceExportResult.Success }
    fn force_flush(&self, _t: Duration) -> TraceExportResult { TraceExportResult.Success }
    fn shutdown(&self, _t: Duration) -> TraceExportResult { TraceExportResult.Success }
}

// =============================================================================
// StdoutExporter — human-readable line per span (dev / debugging)
// =============================================================================
//

// Line shape:
//   [<trace_id>:<span_id>] <name> kind=SERVER status=OK dur_ns=1523000 attrs={k=v, ...}
//

// A Mutex serialises whole batches so concurrent exports do not
// interleave partial lines.

public type StdoutExporter is {
    gate: StdoutGate,
};

/// Mutex as a DIRECT record field (the channel-module idiom), with a
/// per-operation method so the guard never crosses an expression
/// boundary.
type StdoutCell is {
    write_gate: Mutex<()>,
};

implement StdoutCell {
    public fn cell_write_batch(&self, spans: &List<SpanData>) {
        let _guard = self.write_gate.lock().unwrap_or_else(|p| p.into_inner());
        let mut i = 0;
        while i < spans.len() {
            let line = format_span_line(&spans[i]);
            print(&line);
            println("");
            i = i + 1;
        }
    }
}

/// Single-variant wrapper (see SpanBody in tracing/span.vr).
type StdoutGate is
    | Gate(Shared<StdoutCell>);

implement StdoutGate {
    public fn gate_write_batch(&self, spans: &List<SpanData>) {
        match self {
            StdoutGate.Gate(cell) => cell.cell_write_batch(spans),
        }
    }

    public fn gate_clone(&self) -> StdoutGate {
        match self {
            StdoutGate.Gate(cell) => StdoutGate.Gate(cell.clone()),
        }
    }
}

implement StdoutExporter {
    public fn new() -> StdoutExporter {
        StdoutExporter { gate: StdoutGate.Gate(Shared.new(StdoutCell { write_gate: Mutex.new(()) })) }
    }

    /// Share the same write lock under a second handle.
    public fn clone(&self) -> StdoutExporter {
        StdoutExporter { gate: self.gate.gate_clone() }
    }
}

implement StdoutExporter {
    /// Uniquely-named worker so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn stdout_export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.gate.gate_write_batch(spans);
        TraceExportResult.Success
    }
}

implement SpanExporter for StdoutExporter {
    fn export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.stdout_export(spans)
    }

    fn force_flush(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }

    fn shutdown(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }
}

// =============================================================================
// InMemoryExporter — collecting sink for tests and e2e verification
// =============================================================================
//

// Channel-backed: the exporter side holds a clone-able Sender (the one
// cross-handle shared primitive the runtime provides today); the test
// side holds the Receiver and drains it with take(). No shared mutable
// cell is involved, so no shared-identity support is required.

/// Guarded line store on the proven primitive set: single-variant
/// payload enums, Mutex as a direct record field, match-payload reads
/// (clone/primitive only), whole-value guard stores. The store is a
/// (count, joined-text) pair — no container manipulation crosses the
/// payload boundary.
type LineCell is {
    state: Mutex<LineState>,
};

/// Single-payload carrier record (the signal-registry idiom stores a
/// single payload; multi-field tuple variants are unproven).
type LineBuf is {
    count: Int,
    text: Text,
};

implement LineBuf {
    public fn buf_count(&self) -> Int { self.count }
    public fn buf_text(&self) -> Text { self.text.clone() }
    public fn buf_appended(&self, line: Text) -> LineBuf {
        let mut t = self.text.clone();
        t.push_str(&line);
        t.push('\n');
        LineBuf { count: self.count + 1, text: t }
    }
}

type LineState is
    | Lines(LineBuf);

implement LineCell {
    public fn line_cell_push(&self, line: Text) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let mut next: LineBuf = LineBuf { count: 0, text: "".into() };
        match &*guard {
            LineState.Lines(buf) => {
                next = buf.buf_appended(line);
            }
        }
        *guard = LineState.Lines(next);
    }

    public fn line_cell_take(&self) -> Text {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let mut out: Text = "".into();
        match &*guard {
            LineState.Lines(buf) => {
                out = buf.buf_text();
            }
        }
        *guard = LineState.Lines(LineBuf { count: 0, text: "".into() });
        out
    }

    public fn line_cell_len(&self) -> Int {
        let guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let mut n_out: Int = 0;
        match &*guard {
            LineState.Lines(buf) => {
                n_out = buf.buf_count();
            }
        }
        n_out
    }
}

public type InMemoryExporter is
    | MemLines(Shared<LineCell>);

implement InMemoryExporter {
    public fn new() -> InMemoryExporter {
        InMemoryExporter.MemLines(Shared.new(LineCell {
            state: Mutex.new(LineState.Lines(LineBuf { count: 0, text: "".into() })),
        }))
    }

    /// Additional handle onto the same buffer.
    public fn clone(&self) -> InMemoryExporter {
        match self {
            InMemoryExporter.MemLines(c) => InMemoryExporter.MemLines(c.clone()),
        }
    }

    /// Uniquely-named worker so handle dispatch resolves on any
    /// receiver-tracking tier. The payload is the rendered span line
    /// (see the StdoutExporter line shape).
    public fn mem_export(&self, spans: &List<SpanData>) -> TraceExportResult {
        match self {
            InMemoryExporter.MemLines(c) => {
                let mut i = 0;
                while i < spans.len() {
                    let line = format_span_line(&spans[i]);
                    c.line_cell_push(line);
                    i = i + 1;
                }
            }
        }
        TraceExportResult.Success
    }

    /// Drain: newline-joined rendered lines collected so far.
    public fn take_text(&self) -> Text {
        match self {
            InMemoryExporter.MemLines(c) => c.line_cell_take(),
        }
    }

    /// Test hook: push a raw line without going through export.
    public fn push_line_for_tests(&self, line: Text) {
        match self {
            InMemoryExporter.MemLines(c) => c.line_cell_push(line),
        }
    }

    /// Number of collected lines.
    public fn lines_len(&self) -> Int {
        match self {
            InMemoryExporter.MemLines(c) => c.line_cell_len(),
        }
    }
}

implement SpanExporter for InMemoryExporter {
    fn export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.mem_export(spans)
    }

    fn force_flush(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }

    fn shutdown(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }
}

// =============================================================================
// FileExporter — newline-delimited span lines appended to a file
// =============================================================================
//

// The observation channel is the FILESYSTEM: every export renders the
// batch into canonical span lines (the StdoutExporter shape) and
// appends them to `path`. Cross-handle and cross-process observation
// come for free — read the file. This is the same role the OTel spec's
// file exporter plays; a future revision moves to an O(1) append handle
// once buffered appends are proven across both tiers.

public type FileExporter is {
    path: Text,
};

implement FileExporter {
    public fn new(path: Text) -> FileExporter {
        FileExporter { path: path }
    }

    public fn clone(&self) -> FileExporter {
        FileExporter { path: self.path.clone() }
    }

    /// Uniquely-named worker so handle dispatch resolves on any
    /// receiver-tracking tier. Read-append-write per batch: correct and
    /// simple; suited to dev/test volumes, not production streams.
    public fn file_export(&self, spans: &List<SpanData>) -> TraceExportResult {
        let mut blob: Text = match file_read_to_string(&self.path) {
            Result.Ok(existing) => existing,
            Result.Err(_) => "".into(),
        };
        let mut i = 0;
        while i < spans.len() {
            let line = format_span_line(&spans[i]);
            blob.push_str(&line);
            blob.push('\n');
            i = i + 1;
        }
        match file_write(&self.path, &blob) {
            Result.Ok(_) => TraceExportResult.Success,
            Result.Err(_) => TraceExportResult.Failure(ExportError.transport(
                "file exporter: write failed".into(),
            )),
        }
    }
}

implement SpanExporter for FileExporter {
    fn export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.file_export(spans)
    }

    fn force_flush(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }

    fn shutdown(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }
}

// =============================================================================
// ExporterHandle — closed-world dispatch over the in-tree exporters
// =============================================================================

public type ExporterHandle is
    /// Discard everything.
    | EhNoop
    /// Human-readable stdout lines.
    | EhStdout(StdoutExporter)
    /// Collecting test sink.
    | EhInMemory(InMemoryExporter)
    /// Newline-delimited span lines appended to a file.
    | EhFile(FileExporter)
    /// Third-party exporter behind the SpanExporter protocol. NOTE:
    /// invoking a custom exporter requires protocol-object dispatch,
    /// which the VBC interpreter does not implement yet — construction
    /// and configuration work, invocation panics until the language
    /// gap closes.
    | EhCustom(Shared<dyn SpanExporter>);

implement ExporterHandle {
    public fn noop() -> ExporterHandle { ExporterHandle.EhNoop }

    public fn stdout() -> ExporterHandle {
        ExporterHandle.EhStdout(StdoutExporter.new())
    }

    public fn in_memory(exporter: InMemoryExporter) -> ExporterHandle {
        ExporterHandle.EhInMemory(exporter)
    }

    public fn file(path: Text) -> ExporterHandle {
        ExporterHandle.EhFile(FileExporter.new(path))
    }

    public fn custom(exporter: Shared<dyn SpanExporter>) -> ExporterHandle {
        ExporterHandle.EhCustom(exporter)
    }

    public fn export(&self, spans: &List<SpanData>) -> TraceExportResult {
        match self {
            ExporterHandle.EhNoop => TraceExportResult.Success,
            ExporterHandle.EhStdout(e) => e.stdout_export(spans),
            ExporterHandle.EhInMemory(e) => e.mem_export(spans),
            ExporterHandle.EhFile(e) => e.file_export(spans),
            ExporterHandle.EhCustom(e) => e.export(spans),
        }
    }

    public fn force_flush(&self, _timeout: Duration) -> TraceExportResult {
        match self {
            ExporterHandle.EhNoop => TraceExportResult.Success,
            ExporterHandle.EhStdout(_) => TraceExportResult.Success,
            ExporterHandle.EhInMemory(_) => TraceExportResult.Success,
            ExporterHandle.EhFile(_) => TraceExportResult.Success,
            ExporterHandle.EhCustom(e) => e.force_flush(_timeout),
        }
    }

    public fn shutdown(&self, timeout: Duration) -> TraceExportResult {
        match self {
            ExporterHandle.EhNoop => TraceExportResult.Success,
            ExporterHandle.EhStdout(_) => TraceExportResult.Success,
            ExporterHandle.EhInMemory(_) => TraceExportResult.Success,
            ExporterHandle.EhFile(_) => TraceExportResult.Success,
            ExporterHandle.EhCustom(e) => e.shutdown(timeout),
        }
    }

    public fn clone(&self) -> ExporterHandle {
        match self {
            ExporterHandle.EhNoop => ExporterHandle.EhNoop,
            ExporterHandle.EhStdout(e) => ExporterHandle.EhStdout(e.clone()),
            ExporterHandle.EhInMemory(e) => ExporterHandle.EhInMemory(e.clone()),
            ExporterHandle.EhFile(e) => ExporterHandle.EhFile(e.clone()),
            ExporterHandle.EhCustom(e) => ExporterHandle.EhCustom(e.clone()),
        }
    }
}

// =============================================================================
// Internal formatting helpers
// =============================================================================

fn format_span_line(s: &SpanData) -> Text {
    let ctx = s.context();
    let tid = ctx.trace_id().to_hex();
    let sid = ctx.span_id().to_hex();
    let status = match s.status().code() {
        SpanStatusCode.Unset => "UNSET",
        SpanStatusCode.Ok => "OK",
        SpanStatusCode.Error => "ERROR",
    };
    let dur_ns = s.duration().as_nanos();
    let kind = kind_name(s.kind());
    let sampled = if ctx.is_sampled() { "true" } else { "false" };
    let parent = match s.parent_span_id() {
        Maybe.Some(pid) => pid.to_hex(),
        Maybe.None => "-".into(),
    };
    let events_n = s.events().len();
    let attr_set = s.attributes();
    let entries = attr_set.entries();
    let attrs = format_attrs(&entries);
    let name = s.name();
    f"[{tid}:{sid}] {name} kind={kind} status={status} sampled={sampled} parent={parent} events={events_n} dur_ns={dur_ns} {attrs}"
}

fn kind_name(k: SpanKind) -> Text {
    match k {
        SpanKind.KindInternal => "INTERNAL".into(),
        SpanKind.KindClient => "CLIENT".into(),
        SpanKind.KindServer => "SERVER".into(),
        SpanKind.KindProducer => "PRODUCER".into(),
        SpanKind.KindConsumer => "CONSUMER".into(),
    }
}

fn format_attrs(entries: &List<(Text, AttributeValue)>) -> Text {
    if entries.is_empty() { return "".into(); }
    let mut out = Text.with_capacity(64);
    out.push_str("attrs={");
    let mut i = 0;
    while i < entries.len() {
        if i > 0 { out.push_str(", "); }
        out.push_str(&entries[i].0);
        out.push_str("=");
        out.push_str(&format_attr_value(&entries[i].1));
        i = i + 1;
    }
    out.push_str("}");
    out
}

fn format_attr_value(v: &AttributeValue) -> Text {
    match v {
        AttributeValue.Text(t) => f"\"{t}\"",
        AttributeValue.Bool(b) => f"{b}",
        AttributeValue.Int(i) => f"{i}",
        AttributeValue.Float(f) => f"{f}",
        AttributeValue.TextArray(xs) => f"[{xs.len()} strings]",
        AttributeValue.BoolArray(xs) => f"[{xs.len()} bools]",
        AttributeValue.IntArray(xs) => f"[{xs.len()} ints]",
        AttributeValue.FloatArray(xs) => f"[{xs.len()} floats]",
    }
}

// =============================================================================
// Protocol — the contract PhCustom processors implement
// =============================================================================
//

// NOTE: on_start receives the new span's CONTEXT (not the live Span
// handle). This keeps the module graph acyclic — the Span type lives
// above the processors, which sit directly on the frozen-data layer.

public type SpanProcessor is protocol {
    /// Called synchronously when a recording span starts.
    fn on_start(&self, context: &SpanContext, parent: &SpanContext);

    /// Called synchronously when a recording span ends — the processor
    /// takes ownership of the frozen SpanData.
    fn on_end(&self, span: SpanData);

    /// Flush any buffered spans. Blocks up to `timeout`.
    fn force_flush(&self, timeout: Duration) -> TraceExportResult;

    /// Drain remaining spans up to `timeout`, then release resources.
    fn shutdown(&self, timeout: Duration) -> TraceExportResult;
};

// =============================================================================
// SimpleProcessor — synchronous one-span-at-a-time
// =============================================================================

public type SimpleProcessor is {
    exporter: ExporterHandle,
};

implement SimpleProcessor {
    public fn new(exporter: ExporterHandle) -> SimpleProcessor {
        SimpleProcessor { exporter: exporter }
    }

    /// Uniquely-named workers so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn simple_on_end(&self, span: SpanData) {
        // Exporters receive sampled spans only; RecordOnly spans are
        // recorded (attributes work) but never exported.
        if !span.context().is_sampled() { return; }
        let mut buf: List<SpanData> = List.with_capacity(1);
        buf.push(span);
        // Fire-and-forget by design: a failed dev-exporter write must
        // never fail the traced request.
        let _ = self.exporter.export(&buf);
    }

    public fn simple_force_flush(&self, timeout: Duration) -> TraceExportResult {
        self.exporter.force_flush(timeout)
    }

    public fn simple_shutdown(&self, timeout: Duration) -> TraceExportResult {
        self.exporter.shutdown(timeout)
    }
}

// =============================================================================
// BatchConfig
// =============================================================================

public type BatchConfig is {
    max_queue_size: Int,
    scheduled_delay: Duration,
    max_export_batch_size: Int,
    export_timeout: Duration,
};

implement BatchConfig {
    public fn default() -> BatchConfig {
        BatchConfig {
            max_queue_size: 2048,
            scheduled_delay: Duration.from_secs(5),
            max_export_batch_size: 512,
            export_timeout: Duration.from_secs(30),
        }
    }

    public fn with_queue_size(mut self, n: Int) -> BatchConfig {
        self.max_queue_size = n; self
    }
    public fn with_scheduled_delay(mut self, d: Duration) -> BatchConfig {
        self.scheduled_delay = d; self
    }
    public fn with_max_export_batch_size(mut self, n: Int) -> BatchConfig {
        self.max_export_batch_size = n; self
    }
    public fn with_export_timeout(mut self, d: Duration) -> BatchConfig {
        self.export_timeout = d; self
    }

    public fn clone(&self) -> BatchConfig {
        BatchConfig {
            max_queue_size: self.max_queue_size,
            scheduled_delay: self.scheduled_delay,
            max_export_batch_size: self.max_export_batch_size,
            export_timeout: self.export_timeout,
        }
    }
}

// =============================================================================
// BatchProcessor — bounded queue + worker task
// =============================================================================
//

// Producers (on_end callers) do one non-blocking try_send. The single
// consumer task batches and exports. Control operations (flush /
// shutdown) send a sentinel carrying a reply channel and wait for the
// worker's confirmation up to the caller's timeout — they are drain
// barriers, not fire-and-forget signals.

public type BatchProcessor is {
    sender: Sender<BatchMessage>,
    config: BatchConfig,
    /// Spans dropped because the queue was full. Relaxed counter —
    /// observability, not synchronisation.
    dropped: AtomicU64,
};

type BatchMessage is
    | BatchSpan(SpanData)
    | BatchFlush(Sender<TraceExportResult>, Duration)
    | BatchShutdown(Sender<TraceExportResult>, Duration);

implement BatchProcessor {
    public fn new(exporter: ExporterHandle) -> BatchProcessor {
        BatchProcessor.with_config(exporter, BatchConfig.default())
    }

    /// Spawns the worker task — requires the async runtime.
    public fn with_config(exporter: ExporterHandle, config: BatchConfig) -> BatchProcessor {
        let (sender, receiver) = bounded<BatchMessage>(config.max_queue_size);
        let worker_config = config.clone();
        spawn_detached(async move {
            run_worker(receiver, exporter, worker_config).await;
        });
        BatchProcessor {
            sender: sender,
            config: config,
            dropped: AtomicU64.new(0),
        }
    }

    /// Number of spans dropped so far because the queue was full.
    public fn dropped_spans(&self) -> Int {
        self.dropped.load(MemoryOrdering.Relaxed) as Int
    }

    /// Uniquely-named workers so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn batch_on_end(&self, span: SpanData) {
        if !span.context().is_sampled() { return; }
        // Non-blocking: drop on full queue per OTel policy — losing a
        // span is preferred over stalling the request path.
        match self.sender.try_send(BatchMessage.BatchSpan(span)) {
            Result.Ok(_) => {}
            Result.Err(_) => {
                let _ = self.dropped.fetch_add(1, MemoryOrdering.Relaxed);
            }
        }
    }

    public fn batch_force_flush(&self, timeout: Duration) -> TraceExportResult {
        let (reply_tx, mut reply_rx) = bounded<TraceExportResult>(1);
        match self.sender.send_timeout(BatchMessage.BatchFlush(reply_tx, timeout), timeout) {
            Result.Ok(_) => {}
            Result.Err(_) => {
                return TraceExportResult.Failure(ExportError.queue_full());
            }
        }
        wait_reply(&mut reply_rx, timeout)
    }

    public fn batch_shutdown(&self, timeout: Duration) -> TraceExportResult {
        let (reply_tx, mut reply_rx) = bounded<TraceExportResult>(1);
        match self.sender.send_timeout(BatchMessage.BatchShutdown(reply_tx, timeout), timeout) {
            Result.Ok(_) => {}
            Result.Err(_) => {
                // Queue unreachable — worker already gone or hopelessly
                // backed up.
                return TraceExportResult.Failure(ExportError.shut_down());
            }
        }
        wait_reply(&mut reply_rx, timeout)
    }
}

/// Bounded wait for the worker's confirmation. Polls the reply channel
/// with a 1 ms sleep so the (sync) call never blocks past the caller's
/// deadline even if the worker hangs inside an exporter.
fn wait_reply(rx: &mut Receiver<TraceExportResult>, timeout: Duration) -> TraceExportResult {
    let deadline = Instant.now() + timeout;
    loop {
        match rx.try_recv() {
            Result.Ok(r) => return r,
            Result.Err(_) => {}
        }
        if Instant.now() >= deadline {
            return TraceExportResult.Failure(ExportError.timeout(
                "batch worker did not confirm within the deadline".into(),
            ));
        }
        Time.sleep_ms(1);
    }
}

// -------------------------------------------------------------------------
// Worker task — drains the channel, batches, enforces scheduled_delay
// -------------------------------------------------------------------------

type WorkerEvent is
    | EvMsg(Maybe<BatchMessage>)
    | EvTick;

async fn run_worker(
    mut receiver: Receiver<BatchMessage>,
    exporter: ExporterHandle,
    config: BatchConfig,
) {
    let mut batch: List<SpanData> = List.with_capacity(config.max_export_batch_size);
    // Deadline-based cadence: flush at fixed scheduled_delay intervals
    // regardless of message traffic (a per-iteration timer would reset
    // on every span and starve under steady load).
    let mut deadline = Instant.now() + config.scheduled_delay;
    loop {
        let wait = deadline.saturating_duration_since(Instant.now());
        let ev = select {
            m = receiver.recv_fut().await => WorkerEvent.EvMsg(m),
            _tick = sleep(wait).await => WorkerEvent.EvTick,
        };
        match ev {
            WorkerEvent.EvTick => {
                let _ = flush_batch(&exporter, &mut batch, config.max_export_batch_size);
                deadline = Instant.now() + config.scheduled_delay;
            }
            WorkerEvent.EvMsg(m) => {
                match m {
                    Maybe.None => {
                        // Channel closed — all senders gone. Final drain.
                        let _ = flush_batch(&exporter, &mut batch, config.max_export_batch_size);
                        return;
                    }
                    Maybe.Some(msg) => {
                        match msg {
                            BatchMessage.BatchSpan(s) => {
                                batch.push(s);
                                if batch.len() >= config.max_export_batch_size {
                                    let _ = flush_batch(&exporter, &mut batch, config.max_export_batch_size);
                                    deadline = Instant.now() + config.scheduled_delay;
                                }
                            }
                            BatchMessage.BatchFlush(reply, t) => {
                                let r = flush_batch(&exporter, &mut batch, config.max_export_batch_size)
                                    .combine(exporter.force_flush(t));
                                let _ = reply.try_send(r);
                                deadline = Instant.now() + config.scheduled_delay;
                            }
                            BatchMessage.BatchShutdown(reply, t) => {
                                let r = flush_batch(&exporter, &mut batch, config.max_export_batch_size)
                                    .combine(exporter.shutdown(t));
                                let _ = reply.try_send(r);
                                return;
                            }
                        }
                    }
                }
            }
        }
    }
}

fn flush_batch(
    exporter: &ExporterHandle,
    batch: &mut List<SpanData>,
    cap: Int,
) -> TraceExportResult {
    if batch.is_empty() { return TraceExportResult.Success; }
    let out = exporter.export(batch);
    *batch = List.with_capacity(cap);
    out
}

// =============================================================================
// CompositeProcessor — fans SpanData out to multiple processors
// =============================================================================

public type CompositeProcessor is {
    children: List<ProcessorHandle>,
};

implement CompositeProcessor {
    public fn new(children: List<ProcessorHandle>) -> CompositeProcessor {
        CompositeProcessor { children: children }
    }

    /// Uniquely-named workers so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn fanout_on_start(&self, context: &SpanContext, parent: &SpanContext) {
        let mut i = 0;
        while i < self.children.len() {
            self.children[i].on_start(context, parent);
            i = i + 1;
        }
    }

    public fn fanout_on_end(&self, span: SpanData) {
        // Each downstream processor owns its SpanData; the last one
        // takes the original to save a deep copy.
        let n = self.children.len();
        if n == 0 { return; }
        let mut i = 0;
        while i + 1 < n {
            self.children[i].on_end(span.clone());
            i = i + 1;
        }
        self.children[n - 1].on_end(span);
    }

    public fn fanout_force_flush(&self, timeout: Duration) -> TraceExportResult {
        let mut acc = TraceExportResult.Success;
        let mut i = 0;
        while i < self.children.len() {
            acc = acc.combine(self.children[i].force_flush(timeout));
            i = i + 1;
        }
        acc
    }

    public fn fanout_shutdown(&self, timeout: Duration) -> TraceExportResult {
        let mut acc = TraceExportResult.Success;
        let mut i = 0;
        while i < self.children.len() {
            acc = acc.combine(self.children[i].shutdown(timeout));
            i = i + 1;
        }
        acc
    }
}

// =============================================================================
// ProcessorHandle — closed-world dispatch over the in-tree processors
// =============================================================================

public type ProcessorHandle is
    /// Discard everything (detached spans, tests).
    | PhNoop
    /// Synchronous per-span export.
    | PhSimple(Shared<SimpleProcessor>)
    /// Bounded queue + worker task.
    | PhBatch(Shared<BatchProcessor>)
    /// Fan-out to several processors.
    | PhComposite(Shared<CompositeProcessor>)
    /// User-defined processor behind the SpanProcessor protocol. NOTE:
    /// invoking a custom processor requires protocol-object dispatch,
    /// which the VBC interpreter does not implement yet — construction
    /// and configuration work, invocation panics until the language
    /// gap closes.
    | PhCustom(Shared<dyn SpanProcessor>);

implement ProcessorHandle {
    public fn noop() -> ProcessorHandle { ProcessorHandle.PhNoop }

    public fn simple(exporter: ExporterHandle) -> ProcessorHandle {
        ProcessorHandle.PhSimple(Shared.new(SimpleProcessor.new(exporter)))
    }

    /// Spawns the worker task — requires the async runtime.
    public fn batch(exporter: ExporterHandle) -> ProcessorHandle {
        ProcessorHandle.PhBatch(Shared.new(BatchProcessor.new(exporter)))
    }

    /// Spawns the worker task — requires the async runtime.
    public fn batch_with(exporter: ExporterHandle, config: BatchConfig) -> ProcessorHandle {
        ProcessorHandle.PhBatch(Shared.new(BatchProcessor.with_config(exporter, config)))
    }

    public fn composite(children: List<ProcessorHandle>) -> ProcessorHandle {
        ProcessorHandle.PhComposite(Shared.new(CompositeProcessor.new(children)))
    }

    public fn custom(processor: Shared<dyn SpanProcessor>) -> ProcessorHandle {
        ProcessorHandle.PhCustom(processor)
    }

    public fn on_start(&self, context: &SpanContext, parent: &SpanContext) {
        match self {
            ProcessorHandle.PhNoop => {}
            ProcessorHandle.PhSimple(_) => {}
            ProcessorHandle.PhBatch(_) => {}
            ProcessorHandle.PhComposite(p) => p.fanout_on_start(context, parent),
            ProcessorHandle.PhCustom(p) => p.on_start(context, parent),
        }
    }

    public fn on_end(&self, span: SpanData) {
        match self {
            ProcessorHandle.PhNoop => {}
            ProcessorHandle.PhSimple(p) => p.simple_on_end(span),
            ProcessorHandle.PhBatch(p) => p.batch_on_end(span),
            ProcessorHandle.PhComposite(p) => p.fanout_on_end(span),
            ProcessorHandle.PhCustom(p) => p.on_end(span),
        }
    }

    public fn force_flush(&self, timeout: Duration) -> TraceExportResult {
        match self {
            ProcessorHandle.PhNoop => TraceExportResult.Success,
            ProcessorHandle.PhSimple(p) => p.simple_force_flush(timeout),
            ProcessorHandle.PhBatch(p) => p.batch_force_flush(timeout),
            ProcessorHandle.PhComposite(p) => p.fanout_force_flush(timeout),
            ProcessorHandle.PhCustom(p) => p.force_flush(timeout),
        }
    }

    public fn shutdown(&self, timeout: Duration) -> TraceExportResult {
        match self {
            ProcessorHandle.PhNoop => TraceExportResult.Success,
            ProcessorHandle.PhSimple(p) => p.simple_shutdown(timeout),
            ProcessorHandle.PhBatch(p) => p.batch_shutdown(timeout),
            ProcessorHandle.PhComposite(p) => p.fanout_shutdown(timeout),
            ProcessorHandle.PhCustom(p) => p.shutdown(timeout),
        }
    }

    public fn clone(&self) -> ProcessorHandle {
        match self {
            ProcessorHandle.PhNoop => ProcessorHandle.PhNoop,
            ProcessorHandle.PhSimple(p) => ProcessorHandle.PhSimple(p.clone()),
            ProcessorHandle.PhBatch(p) => ProcessorHandle.PhBatch(p.clone()),
            ProcessorHandle.PhComposite(p) => ProcessorHandle.PhComposite(p.clone()),
            ProcessorHandle.PhCustom(p) => ProcessorHandle.PhCustom(p.clone()),
        }
    }
}

// =============================================================================
// Span — handle the instrumenter uses
// =============================================================================
//

// Ownership model:
// - `context` is immutable and lives on the handle — propagation and
//   Debug/Display never touch the mutex.
// - `recording` is fixed at construction: non-recording spans (sampled
//   out / no-op) short-circuit every mutator before any lock.
// - `processor` is the delivery target `end()` hands the frozen
//   SpanData to; detached spans carry ProcessorHandle.noop().
//

// Invariants:
// - Mutation after `end()` is silently ignored (OTel frozen-after-end).
// - `ended_flag` is the lock-free fast path; the authoritative check is
//   `end_time` under the lock (end() may win the race between the
//   atomic load and the lock acquisition).

public const SPAN_EVENT_LIMIT: Int = 128;
public const SPAN_LINK_LIMIT: Int = 128;

public type Span is {
    context: SpanContext,
    recording: Bool,
    ended_flag: AtomicBool,
    inner: SpanBody,
    processor: ProcessorHandle,
};

public type SpanInner is {
    name: Text,
    parent_span_id: Maybe<SpanId>,
    kind: SpanKind,
    start_time: Instant,
    start_system_time: SystemTime,
    end_time: Maybe<Instant>,
    attributes: AttributeSet,
    events: List<SpanEvent>,
    links: List<SpanLink>,
    status: SpanStatus,
    resource: Shared<Resource>,
    instrumentation_scope: Text,
    instrumentation_version: Text,
};

/// Mutex as a DIRECT record field (the channel-module idiom), with
/// per-operation methods so the guard never crosses an expression
/// boundary: `Shared<SpanCell>` receivers dispatch methods correctly,
/// while field access through Shared and bare `Shared<Mutex<T>>`
/// locking both mis-lower in stdlib-baked code.
public type SpanCell is {
    state: Mutex<SpanState>,
};

/// Single-variant carrier: reads bind the inner record out as a match
/// payload (the one receiver form with proven-correct self binding);
/// writes replace the whole guarded value (`*guard = ...`, the
/// signal-registry idiom). Guard-METHOD calls mis-bind self in
/// stdlib-baked code and are not used anywhere in this module.
public type SpanState is
    | Live(SpanInner);

implement SpanCell {
    public fn cell_set_attribute(&self, key: Text, value: AttributeValue) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let next: Maybe<SpanInner> = match &*guard {
            SpanState.Live(inner) => inner.snapshot_set_attribute(key, value),
        };
        match next {
            Maybe.Some(n) => { *guard = SpanState.Live(n); }
            Maybe.None => {}
        }
    }

    public fn cell_add_event(&self, name: Text, attributes: AttributeSet) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let next: Maybe<SpanInner> = match &*guard {
            SpanState.Live(inner) => inner.snapshot_add_event(name, attributes),
        };
        match next {
            Maybe.Some(n) => { *guard = SpanState.Live(n); }
            Maybe.None => {}
        }
    }

    public fn cell_add_link(&self, link: SpanLink) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let next: Maybe<SpanInner> = match &*guard {
            SpanState.Live(inner) => inner.snapshot_add_link(link),
        };
        match next {
            Maybe.Some(n) => { *guard = SpanState.Live(n); }
            Maybe.None => {}
        }
    }

    public fn cell_set_status(&self, new_status: SpanStatus) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let next: Maybe<SpanInner> = match &*guard {
            SpanState.Live(inner) => inner.snapshot_set_status(new_status),
        };
        match next {
            Maybe.Some(n) => { *guard = SpanState.Live(n); }
            Maybe.None => {}
        }
    }

    public fn cell_update_name(&self, name: Text) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let next: Maybe<SpanInner> = match &*guard {
            SpanState.Live(inner) => inner.snapshot_update_name(name),
        };
        match next {
            Maybe.Some(n) => { *guard = SpanState.Live(n); }
            Maybe.None => {}
        }
    }

    /// Freeze + deliver + seal. No value crosses the payload-match
    /// boundary (checker types such crossings with sibling/payload
    /// types today): the frozen SpanData is built AND delivered inside
    /// the SpanInner method. Delivery therefore runs under the span
    /// lock — acceptable because in-tree processors never re-enter the
    /// span, and documented in the module notes.
    public fn cell_finish_deliver(&self, context: &SpanContext, ts: Instant, processor: &ProcessorHandle) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        match &*guard {
            SpanState.Live(inner) => {
                inner.finish_delivering(context, ts, processor);
            }
        }
        let sealed: SpanInner = match &*guard {
            SpanState.Live(inner) => inner.snapshot_sealed(ts),
        };
        *guard = SpanState.Live(sealed);
    }

    public fn cell_name(&self) -> Text {
        let guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        match &*guard {
            SpanState.Live(inner) => inner.snapshot_name(),
        }
    }
}

/// Single-variant wrapper: method calls through a Shared-typed FIELD
/// bind `self` to the outer record in stdlib-baked code, while
/// match-payload receivers bind correctly. Every access matches the
/// cell out first.
public type SpanBody is
    | Body(Shared<SpanCell>);

implement SpanBody {
    public fn body_set_attribute(&self, key: Text, value: AttributeValue) {
        match self {
            SpanBody.Body(cell) => cell.cell_set_attribute(key, value),
        }
    }

    public fn body_add_event(&self, name: Text, attributes: AttributeSet) {
        match self {
            SpanBody.Body(cell) => cell.cell_add_event(name, attributes),
        }
    }

    public fn body_add_link(&self, link: SpanLink) {
        match self {
            SpanBody.Body(cell) => cell.cell_add_link(link),
        }
    }

    public fn body_set_status(&self, new_status: SpanStatus) {
        match self {
            SpanBody.Body(cell) => cell.cell_set_status(new_status),
        }
    }

    public fn body_update_name(&self, name: Text) {
        match self {
            SpanBody.Body(cell) => cell.cell_update_name(name),
        }
    }

    public fn body_finish_deliver(&self, context: &SpanContext, ts: Instant, processor: &ProcessorHandle) {
        match self {
            SpanBody.Body(cell) => cell.cell_finish_deliver(context, ts, processor),
        }
    }

    public fn body_name(&self) -> Text {
        match self {
            SpanBody.Body(cell) => cell.cell_name(),
        }
    }
}

implement Span {
    /// Construct a recording span. Used by the SDK tracer; instrumenters
    /// obtain spans through `Tracer.start_span`.
    public fn recording(
        context: SpanContext,
        inner: SpanInner,
        processor: ProcessorHandle,
    ) -> Span {
        Span {
            context: context,
            recording: true,
            ended_flag: AtomicBool.new(false),
            inner: SpanBody.Body(Shared.new(SpanCell { state: Mutex.new(SpanState.Live(inner)) })),
            processor: processor,
        }
    }

    /// Construct a non-recording span that still carries a (possibly
    /// valid) context. Sampled-out spans use this so `traceparent`
    /// propagation keeps working across the dropped hop.
    public fn non_recording(context: SpanContext) -> Span {
        Span {
            context: context,
            recording: false,
            ended_flag: AtomicBool.new(false),
            inner: SpanBody.Body(Shared.new(SpanCell { state: Mutex.new(SpanState.Live(empty_inner())) })),
            processor: ProcessorHandle.noop(),
        }
    }

    /// Non-recording span with an invalid context — the "tracing is not
    /// configured at all" span.
    public fn noop() -> Span {
        Span.non_recording(SpanContext.invalid())
    }

    /// Copy of the SpanContext for propagation. Lock-free — the context
    /// is immutable on the handle.
    public fn context(&self) -> SpanContext {
        self.context.clone()
    }

    /// True while the span records mutations: constructed recording AND
    /// not yet ended. Lock-free. Branchy form: the fused
    /// `Bool && !atomic.load()` expression mis-lowers on the AOT tier.
    public fn is_recording(&self) -> Bool {
        if !self.recording { return false; }
        if self.ended_flag.load(MemoryOrdering.Relaxed) { return false; }
        true
    }

    public fn set_attribute(&self, key: Text, value: AttributeValue) {
        if !self.is_recording() { return; }
        self.inner.body_set_attribute(key, value);
    }

    public fn add_event(&self, name: Text, attributes: AttributeSet) {
        if !self.is_recording() { return; }
        self.inner.body_add_event(name, attributes);
    }

    public fn add_event_now(&self, name: Text) {
        self.add_event(name, AttributeSet.new());
    }

    public fn add_link(&self, link: SpanLink) {
        if !self.is_recording() { return; }
        self.inner.body_add_link(link);
    }

    public fn set_status(&self, new_status: SpanStatus) {
        if !self.is_recording() { return; }
        self.inner.body_set_status(new_status);
    }

    public fn update_name(&self, name: Text) {
        if !self.is_recording() { return; }
        self.inner.body_update_name(name);
    }

    /// Record an exception as an event "exception" with attributes
    /// exception.type and exception.message, per OTel semantic
    /// conventions.
    public fn record_exception(&self, type_name: &Text, message: &Text) {
        // Skip the AttributeSet allocations entirely on inactive spans.
        if !self.is_recording() { return; }
        let mut attrs = AttributeSet.new();
        let _ = attrs.set("exception.type".into(), AttributeValue.Text(type_name.clone()));
        let _ = attrs.set("exception.message".into(), AttributeValue.Text(message.clone()));
        self.add_event("exception".into(), attrs);
    }

    /// Finalise at the current instant. The frozen SpanData is delivered
    /// to the attached processor. Idempotent — subsequent calls are
    /// no-ops; mutations after `end()` are silently dropped.
    public fn end(&self) {
        self.finish(Instant.now());
    }

    /// End with an explicit timestamp (replay / test scenarios).
    public fn end_at(&self, ts: Instant) {
        self.finish(ts);
    }

    fn finish(&self, ts: Instant) {
        if !self.recording { return; }
        // Fast-path idempotency: already ended → skip the lock.
        if self.ended_flag.load(MemoryOrdering.Acquire) { return; }
        self.inner.body_finish_deliver(&self.context, ts, &self.processor);
        self.ended_flag.store(true, MemoryOrdering.Release);
    }
}

// Formatting — lock-free on the hoisted context; the name snapshot
// takes the inner lock only for recording spans.

implement Debug for Span {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let tid = self.context.trace_id().to_hex();
        let sid = self.context.span_id().to_hex();
        let name = span_name_snapshot(self);
        f.write_str(f"Span {{ trace_id: \"{tid}\", span_id: \"{sid}\", name: \"{name}\" }}")
    }
}

implement Display for Span {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let tid = self.context.trace_id().to_hex();
        let sid = self.context.span_id().to_hex();
        let name = span_name_snapshot(self);
        f.write_str(f"[{tid}:{sid}] {name}")
    }
}

fn span_name_snapshot(span: &Span) -> Text {
    if !span.recording { return "".into(); }
    span.inner.body_name()
}

// =============================================================================
// Snapshot mutators — copy-on-write over the guarded SpanInner
// =============================================================================
//

// Each mutator is a METHOD on the match-payload-bound SpanInner (the
// receiver form with proven-correct self binding). It returns the
// replacement record (Maybe.None = frozen / limit hit, nothing to
// write); the cell stores it back with a whole-value `*guard = ...`.
// Copy cost is bounded by the per-span limits and accepted until the
// guarded-mutation compiler gaps close.

implement SpanInner {
    public fn snapshot_set_attribute(&self, key: Text, value: AttributeValue) -> Maybe<SpanInner> {
        if self.end_time.is_some() { return Maybe.None; }
        let mut next = self.snapshot_copy();
        let _ = next.attributes.set(key, value);
        Maybe.Some(next)
    }

    public fn snapshot_add_event(&self, name: Text, attributes: AttributeSet) -> Maybe<SpanInner> {
        if self.end_time.is_some() { return Maybe.None; }
        if self.events.len() >= SPAN_EVENT_LIMIT { return Maybe.None; }
        let mut next = self.snapshot_copy();
        next.events.push(SpanEvent.new(name, Instant.now(), attributes));
        Maybe.Some(next)
    }

    public fn snapshot_add_link(&self, link: SpanLink) -> Maybe<SpanInner> {
        if self.end_time.is_some() { return Maybe.None; }
        if self.links.len() >= SPAN_LINK_LIMIT { return Maybe.None; }
        let mut next = self.snapshot_copy();
        next.links.push(link);
        Maybe.Some(next)
    }

    public fn snapshot_set_status(&self, new_status: SpanStatus) -> Maybe<SpanInner> {
        if self.end_time.is_some() { return Maybe.None; }
        // Per OTel spec §5.1.5: Ok can only be set from Unset; Error
        // wins over Ok; Error is final.
        let should_set = match self.status.code() {
            SpanStatusCode.Error => false,
            SpanStatusCode.Ok => match new_status.code() {
                SpanStatusCode.Error => true,
                _ => false,
            },
            SpanStatusCode.Unset => true,
        };
        if !should_set { return Maybe.None; }
        let mut next = self.snapshot_copy();
        next.status = new_status;
        Maybe.Some(next)
    }

    public fn snapshot_update_name(&self, name: Text) -> Maybe<SpanInner> {
        if self.end_time.is_some() { return Maybe.None; }
        let mut next = self.snapshot_copy();
        next.name = name;
        Maybe.Some(next)
    }

    /// Freeze this (still live) span into SpanData and hand it to the
    /// processor. No-op when already ended. The SpanData is built and
    /// consumed entirely inside this method — nothing value-typed
    /// crosses a payload/container boundary.
    public fn finish_delivering(&self, context: &SpanContext, ts: Instant, processor: &ProcessorHandle) {
        if self.end_time.is_some() { return; }
        let data: SpanData = SpanData {
            name: self.name.clone(),
            context: context.clone(),
            parent_span_id: self.parent_span_id,
            kind: self.kind,
            start_time: self.start_time,
            start_system_time: self.start_system_time,
            end_time: ts,
            attributes: self.attributes.clone(),
            events: clone_event_list(&self.events),
            links: clone_link_list(&self.links),
            status: self.status.clone(),
            resource: self.resource.clone(),
            instrumentation_scope: self.instrumentation_scope.clone(),
            instrumentation_version: self.instrumentation_version.clone(),
        };
        processor.on_end(data);
    }

    /// Copy with end_time stamped — the sealed replacement stored after
    /// a successful freeze.
    public fn snapshot_sealed(&self, ts: Instant) -> SpanInner {
        let mut next = self.snapshot_copy();
        next.end_time = Maybe.Some(ts);
        next
    }

    public fn snapshot_name(&self) -> Text {
        self.name.clone()
    }

    /// Field-by-field deep copy.
    public fn snapshot_copy(&self) -> SpanInner {
        SpanInner {
            name: self.name.clone(),
            parent_span_id: self.parent_span_id,
            kind: self.kind,
            start_time: self.start_time,
            start_system_time: self.start_system_time,
            end_time: self.end_time,
            attributes: self.attributes.clone(),
            events: clone_event_list(&self.events),
            links: clone_link_list(&self.links),
            status: self.status.clone(),
            resource: self.resource.clone(),
            instrumentation_scope: self.instrumentation_scope.clone(),
            instrumentation_version: self.instrumentation_version.clone(),
        }
    }
}

/// Minimal storage for non-recording spans — never mutated, never
/// frozen (every path gates on `recording` first).
fn empty_inner() -> SpanInner {
    SpanInner {
        name: "".into(),
        parent_span_id: Maybe.None,
        kind: SpanKind.KindInternal,
        start_time: Instant.now(),
        start_system_time: SystemTime.now(),
        end_time: Maybe.None,
        attributes: AttributeSet.new(),
        events: List.new(),
        links: List.new(),
        status: SpanStatus.unset(),
        resource: Shared.new(Resource.empty()),
        instrumentation_scope: "".into(),
        instrumentation_version: "".into(),
    }
}

// =============================================================================
// Tracer-side factory — constructs SpanInner + Span LOCALLY so callers
// never write literals of these records across a module boundary
// =============================================================================

public fn build_recording_span(
    context: SpanContext,
    name: Text,
    parent_span_id: Maybe<SpanId>,
    kind: SpanKind,
    attributes: AttributeSet,
    links: List<SpanLink>,
    resource: Shared<Resource>,
    instrumentation_scope: Text,
    instrumentation_version: Text,
    processor: ProcessorHandle,
) -> Span {
    let inner = SpanInner {
        name: name,
        parent_span_id: parent_span_id,
        kind: kind,
        start_time: Instant.now(),
        start_system_time: SystemTime.now(),
        end_time: Maybe.None,
        attributes: attributes,
        events: List.new(),
        links: links,
        status: SpanStatus.unset(),
        resource: resource,
        instrumentation_scope: instrumentation_scope,
        instrumentation_version: instrumentation_version,
    };
    Span.recording(context, inner, processor)
}
