// =============================================================================
// tracing/resource.vr — Resource (process-wide attributes)
// =============================================================================
// A Resource identifies the entity producing telemetry. In practice this
// is a container/process/pod name plus service.name + service.version,
// and is attached to every exported span / metric / log.
// Spec: https://opentelemetry.io/docs/specs/otel/resource/sdk/
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.resource;

mount core.*;
mount core.tracing.attribute.{AttributeValue, AttributeSet};

public type Resource is {
    attributes: AttributeSet,
    schema_url: Maybe<Text>,
};

implement Resource {
    public fn empty() -> Resource {
        Resource {
            attributes: AttributeSet.new(),
            schema_url: Maybe.None,
        }
    }

    /// Convenience — single (service.name, service.version) pair which
    /// is by far the most common resource shape.
    public fn service(name: &Text, version: &Text) -> Resource {
        let mut attrs = AttributeSet.new();
        let _ = attrs.set("service.name".into(), AttributeValue.Text(name.clone()));
        let _ = attrs.set("service.version".into(), AttributeValue.Text(version.clone()));
        Resource {
            attributes: attrs,
            schema_url: Maybe.None,
        }
    }

    public fn from_attributes(attributes: AttributeSet) -> Resource {
        Resource {
            attributes: attributes,
            schema_url: Maybe.None,
        }
    }

    public fn with_schema_url(mut self, url: Text) -> Resource {
        self.schema_url = Maybe.Some(url);
        self
    }

    public fn with_attribute(mut self, key: Text, value: AttributeValue) -> Resource {
        let _ = self.attributes.set(key, value);
        self
    }

    /// Merge — values from `other` take precedence on conflict
    /// (per OTel SDK spec — newer resources override older).
    public fn merge(&self, other: &Resource) -> Resource {
        let mut merged = self.attributes.clone();
        let entries = other.attributes.entries();
        let mut i = 0;
        while i < entries.len() {
            let _ = merged.set(entries[i].0.clone(), entries[i].1.clone());
            i = i + 1;
        }
        Resource {
            attributes: merged,
            schema_url: match &other.schema_url {
                Maybe.Some(u) => Maybe.Some(u.clone()),
                Maybe.None => match &self.schema_url {
                    Maybe.Some(u) => Maybe.Some(u.clone()),
                    Maybe.None => Maybe.None,
                }
            }
        }
    }

    /// Owned copies — see the module note on reference-returning
    /// accessors and the AOT tier.
    public fn attributes(&self) -> AttributeSet { self.attributes.clone() }

    public fn schema_url(&self) -> Maybe<Text> {
        match &self.schema_url {
            Maybe.Some(u) => Maybe.Some(u.clone()),
            Maybe.None => Maybe.None,
        }
    }

    /// Hot-path shortcut for `self.attributes().len()`. Avoids the
    /// two-step access through the AttributeSet borrow.
    public fn attributes_count(&self) -> Int {
        self.attributes.len()
    }

    public fn clone(&self) -> Resource {
        Resource {
            attributes: self.attributes.clone(),
            schema_url: match &self.schema_url {
                Maybe.Some(u) => Maybe.Some(u.clone()),
                Maybe.None => Maybe.None,
            }
        }
    }
}

implement Eq for Resource {
    /// Two resources compare equal iff their attribute sets compare
    /// equal (same keys AND values, in insertion order — delegated to
    /// AttributeSet's Eq) and their schema_url values match.
    fn eq(&self, other: &Resource) -> Bool {
        if !self.attributes.eq(&other.attributes) {
            return false;
        }
        match (&self.schema_url, &other.schema_url) {
            (Maybe.Some(u1), Maybe.Some(u2)) => u1 == u2,
            (Maybe.None, Maybe.None) => true,
            _ => false,
        }
    }
}
