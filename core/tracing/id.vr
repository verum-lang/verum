// =============================================================================
// tracing/id.vr — TraceId (128-bit) / SpanId (64-bit) + IdGenerator
// =============================================================================
// Opaque identifiers per OpenTelemetry + W3C Trace Context. Stored as
// fixed-size byte arrays for zero-copy hex encoding / decoding.
//

// Generation draws 64-bit words from the platform CSPRNG intrinsic, so
// identifiers are truly random — the property W3C Trace Context Level 2
// expects and TraceIdRatio sampling (keyed on the low 63 bits) depends
// on.
//

// The `IdGenerator` protocol makes the scheme pluggable: installations
// that need CSPRNG-grade ids (or vendor formats such as X-Ray) install
// their own generator on the TracerProvider.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.id;

mount core.*;

// =============================================================================
// TraceId — 16 bytes
// =============================================================================

/// 128-bit trace identifier per W3C Trace Context §2.2.2.
/// All-zero value is reserved as "invalid".
public type TraceId is {
    bytes: [UInt8; 16],
};

implement TraceId {
    /// Build from raw 16-byte array.
    public fn from_bytes(bytes: [UInt8; 16]) -> TraceId {
        TraceId { bytes: bytes }
    }

    /// The invalid all-zero TraceId.
    public fn invalid() -> TraceId {
        TraceId { bytes: [0; 16] }
    }

    /// True if all 16 bytes are zero.
    public fn is_invalid(&self) -> Bool {
        let mut i = 0;
        while i < 16 {
            if self.bytes[i] != 0 { return false; }
            i = i + 1;
        }
        true
    }

    /// Hex-encode into a 32-character lowercase buffer.
    public fn to_hex(&self) -> Text {
        let mut out = Text.with_capacity(32);
        let mut i = 0;
        while i < 16 {
            push_hex_byte(&mut out, self.bytes[i]);
            i = i + 1;
        }
        out
    }

    /// Decode from a 32-character hex string (case-insensitive digits).
    /// Returns Maybe.None if length is wrong or any byte is non-hex.
    public fn from_hex(hex: &[Byte]) -> Maybe<TraceId> {
        if hex.len() != 32 { return Maybe.None; }
        let mut bytes: [UInt8; 16] = [0; 16];
        let mut i = 0;
        while i < 16 {
            let hi = decode_hex_nibble(hex[i * 2])?;
            let lo = decode_hex_nibble(hex[i * 2 + 1])?;
            bytes[i] = (hi << 4) | lo;
            i = i + 1;
        }
        Maybe.Some(TraceId { bytes: bytes })
    }

    public fn as_bytes(&self) -> &[UInt8; 16] { &self.bytes }
}

implement Eq for TraceId {
    fn eq(&self, other: &TraceId) -> Bool {
        let mut i = 0;
        while i < 16 {
            if self.bytes[i] != other.bytes[i] { return false; }
            i = i + 1;
        }
        true
    }
}

implement Hash for TraceId {
    fn hash(&self, hasher: &mut Hasher) {
        hasher.write_int(read_u64_be(&self.bytes, 0) as Int);
        hasher.write_int(read_u64_be(&self.bytes, 8) as Int);
    }
}

implement Display for TraceId {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.to_hex())
    }
}

implement Debug for TraceId {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let hex = self.to_hex();
        f.write_str(f"TraceId({hex})")
    }
}

// =============================================================================
// SpanId — 8 bytes
// =============================================================================

/// 64-bit span identifier per W3C Trace Context §2.2.3.
/// All-zero value is reserved as "invalid".
public type SpanId is {
    bytes: [UInt8; 8],
};

implement SpanId {
    public fn from_bytes(bytes: [UInt8; 8]) -> SpanId {
        SpanId { bytes: bytes }
    }

    public fn invalid() -> SpanId {
        SpanId { bytes: [0; 8] }
    }

    public fn is_invalid(&self) -> Bool {
        let mut i = 0;
        while i < 8 {
            if self.bytes[i] != 0 { return false; }
            i = i + 1;
        }
        true
    }

    public fn to_hex(&self) -> Text {
        let mut out = Text.with_capacity(16);
        let mut i = 0;
        while i < 8 {
            push_hex_byte(&mut out, self.bytes[i]);
            i = i + 1;
        }
        out
    }

    public fn from_hex(hex: &[Byte]) -> Maybe<SpanId> {
        if hex.len() != 16 { return Maybe.None; }
        let mut bytes: [UInt8; 8] = [0; 8];
        let mut i = 0;
        while i < 8 {
            let hi = decode_hex_nibble(hex[i * 2])?;
            let lo = decode_hex_nibble(hex[i * 2 + 1])?;
            bytes[i] = (hi << 4) | lo;
            i = i + 1;
        }
        Maybe.Some(SpanId { bytes: bytes })
    }

    public fn as_bytes(&self) -> &[UInt8; 8] { &self.bytes }
}

implement Eq for SpanId {
    fn eq(&self, other: &SpanId) -> Bool {
        let mut i = 0;
        while i < 8 {
            if self.bytes[i] != other.bytes[i] { return false; }
            i = i + 1;
        }
        true
    }
}

implement Hash for SpanId {
    fn hash(&self, hasher: &mut Hasher) {
        hasher.write_int(read_u64_be(&self.bytes, 0) as Int);
    }
}

implement Display for SpanId {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.to_hex())
    }
}

implement Debug for SpanId {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        let hex = self.to_hex();
        f.write_str(f"SpanId({hex})")
    }
}

// =============================================================================
// Generation — platform CSPRNG via the `random_u64` intrinsic
// =============================================================================
//

// Identifiers draw from the same intrinsic `core.security.util.rng.
// fill_secure` uses for NIST DRBG output: `random_u64` returns 64 bits
// of platform randomness through the canonical value path — no buffer
// marshalling, no cross-module call, no FFI gate. Random ids satisfy
// the W3C Trace Context Level 2 randomness expectation and spread
// uniformly across the low 63 bits TraceIdRatio keys on.

@inline(always)
fn random_word() -> UInt64 {
    @intrinsic("random_u64")
}

/// Generate a new TraceId. Guaranteed non-zero.
public fn generate_trace_id() -> TraceId {
    let hi = random_word();
    let mut lo = random_word();
    // All-zero is the reserved invalid value (probability 2^-128).
    if hi == 0 && lo == 0 { lo = 1; }
    let mut bytes: [UInt8; 16] = [0; 16];
    write_u64_be(&mut bytes, 0, hi);
    write_u64_be(&mut bytes, 8, lo);
    TraceId { bytes: bytes }
}

/// Generate a new SpanId. Guaranteed non-zero.
public fn generate_span_id() -> SpanId {
    let mut w = random_word();
    if w == 0 { w = 1; }
    let mut bytes: [UInt8; 8] = [0; 8];
    write_u64_be(&mut bytes, 0, w);
    SpanId { bytes: bytes }
}

// =============================================================================
// IdGenerator protocol — pluggable id source for the SDK tracer
// =============================================================================

public type IdGenerator is protocol {
    /// Produce a new, valid (non-zero) TraceId.
    fn new_trace_id(&self) -> TraceId;

    /// Produce a new, valid (non-zero) SpanId.
    fn new_span_id(&self) -> SpanId;

    /// Human-readable identifier for diagnostics.
    fn description(&self) -> Text;
};

/// Default generator — the process-wide SplitMix64 stream above.
public type DefaultIdGenerator is ();

implement DefaultIdGenerator {
    public fn new() -> DefaultIdGenerator { () }
}

implement IdGenerator for DefaultIdGenerator {
    fn new_trace_id(&self) -> TraceId { generate_trace_id() }
    fn new_span_id(&self) -> SpanId { generate_span_id() }
    fn description(&self) -> Text { "DefaultIdGenerator".into() }
}

/// Closed-world dispatch over id generators. `IghCustom` carries a
/// user-defined generator behind the IdGenerator protocol — NOTE:
/// invoking a custom generator requires protocol-object dispatch,
/// which the VBC interpreter does not implement yet; construction and
/// configuration work, invocation panics until the language gap
/// closes.
public type IdGeneratorHandle is
    | IghDefault
    | IghCustom(Shared<dyn IdGenerator>);

implement IdGeneratorHandle {
    public fn new_trace_id(&self) -> TraceId {
        match self {
            IdGeneratorHandle.IghDefault => generate_trace_id(),
            IdGeneratorHandle.IghCustom(g) => g.new_trace_id(),
        }
    }

    public fn new_span_id(&self) -> SpanId {
        match self {
            IdGeneratorHandle.IghDefault => generate_span_id(),
            IdGeneratorHandle.IghCustom(g) => g.new_span_id(),
        }
    }

    public fn description(&self) -> Text {
        match self {
            IdGeneratorHandle.IghDefault => "DefaultIdGenerator".into(),
            IdGeneratorHandle.IghCustom(g) => g.description(),
        }
    }

    public fn clone(&self) -> IdGeneratorHandle {
        match self {
            IdGeneratorHandle.IghDefault => IdGeneratorHandle.IghDefault,
            IdGeneratorHandle.IghCustom(g) => IdGeneratorHandle.IghCustom(g.clone()),
        }
    }
}

/// Factory used by TracerProviderBuilder as the default.
public fn default_id_generator() -> IdGeneratorHandle {
    IdGeneratorHandle.IghDefault
}

/// Wrap a user-defined generator (see the IghCustom note above).
public fn custom_id_generator(generator: Shared<dyn IdGenerator>) -> IdGeneratorHandle {
    IdGeneratorHandle.IghCustom(generator)
}

// =============================================================================
// Internal helpers
// =============================================================================

@inline
fn push_hex_byte(out: &mut Text, b: UInt8) {
    let hi = (b >> 4) & 0x0F;
    let lo = b & 0x0F;
    out.push(hex_digit(hi));
    out.push(hex_digit(lo));
}

@inline
fn hex_digit(n: UInt8) -> Char {
    if n < 10 { (0x30 + n) as Char } else { (0x61 + n - 10) as Char }
}

@inline
fn decode_hex_nibble(b: Byte) -> Maybe<UInt8> {
    if b >= 0x30 && b <= 0x39 { Maybe.Some((b - 0x30) as UInt8) }
    else if b >= 0x61 && b <= 0x66 { Maybe.Some((b - 0x61 + 10) as UInt8) }
    else if b >= 0x41 && b <= 0x46 { Maybe.Some((b - 0x41 + 10) as UInt8) }
    else { Maybe.None }
}

@inline
fn write_u64_be(buf: &mut [UInt8], offset: Int, value: UInt64) {
    buf[offset + 0] = ((value >> 56) & 0xFF) as UInt8;
    buf[offset + 1] = ((value >> 48) & 0xFF) as UInt8;
    buf[offset + 2] = ((value >> 40) & 0xFF) as UInt8;
    buf[offset + 3] = ((value >> 32) & 0xFF) as UInt8;
    buf[offset + 4] = ((value >> 24) & 0xFF) as UInt8;
    buf[offset + 5] = ((value >> 16) & 0xFF) as UInt8;
    buf[offset + 6] = ((value >> 8) & 0xFF) as UInt8;
    buf[offset + 7] = (value & 0xFF) as UInt8;
}

@inline
fn read_u64_be(buf: &[UInt8], offset: Int) -> UInt64 {
    let mut n: UInt64 = 0;
    let mut i = 0;
    while i < 8 {
        n = (n << 8) | (buf[offset + i] as UInt64);
        i = i + 1;
    }
    n
}
