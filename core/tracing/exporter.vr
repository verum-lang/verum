// =============================================================================
// tracing/exporter.vr — re-export shim
// =============================================================================
// The implementation lives in tracing/data.vr (single-module core: see
// the note there on cross-module record-literal type-id collisions).
// This shim preserves the public module path.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.exporter;

public mount core.tracing.data.SpanExporter;
public mount core.tracing.data.ExporterHandle;
public mount core.tracing.data.NoopExporter;
public mount core.tracing.data.StdoutExporter;
public mount core.tracing.data.InMemoryExporter;
public mount core.tracing.data.FileExporter;
