// =============================================================================
// tracing/exporter.vr — SpanExporter protocol, in-tree exporters, and the
//                       ExporterHandle closed-world dispatch enum
// =============================================================================
// An exporter consumes a batch of SpanData and writes it somewhere.
// In-tree: Noop (discard), Stdout (human-readable lines), InMemory
// (test sink).
//

// The pipeline dispatches through `ExporterHandle` — a closed variant
// enum with an `EhCustom(Shared<dyn SpanExporter>)` escape hatch. The
// enum exists because protocol-object (dyn) dispatch is not yet
// operational in the VBC interpreter; when it lands, EhCustom carries
// third-party exporters (OTLP/gRPC, OTLP/HTTP, Jaeger, Zipkin cogs)
// through the same pipeline without any API change.
// Spec: https://opentelemetry.io/docs/specs/otel/trace/sdk/#span-exporter
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.exporter;

mount core.*;
mount core.sync.mutex.{Mutex};
mount core.time.duration.{Duration};
mount core.tracing.data.{SpanData, SpanKind, SpanStatusCode, TraceExportResult, ExportError};
mount core.tracing.attribute.{AttributeValue};

// =============================================================================
// Protocol — the contract EhCustom exporters implement
// =============================================================================

public type SpanExporter is protocol {
    /// Export a batch of spans. Called from a processor (the batch one,
    /// on its worker task). May block on I/O — the processor keeps it
    /// off the request path, not the exporter.
    fn export(&self, spans: &List<SpanData>) -> TraceExportResult;

    /// Flush any pending spans. Called on flush and during shutdown.
    fn force_flush(&self, timeout: Duration) -> TraceExportResult;

    /// Shutdown — release all resources. Exports after shutdown fail
    /// with ExportErrorKind.ShutDown.
    fn shutdown(&self, timeout: Duration) -> TraceExportResult;
};

// =============================================================================
// NoopExporter — discard everything
// =============================================================================

public type NoopExporter is ();

implement NoopExporter {
    public fn new() -> NoopExporter { () }
}

implement SpanExporter for NoopExporter {
    fn export(&self, _spans: &List<SpanData>) -> TraceExportResult { TraceExportResult.Success }
    fn force_flush(&self, _t: Duration) -> TraceExportResult { TraceExportResult.Success }
    fn shutdown(&self, _t: Duration) -> TraceExportResult { TraceExportResult.Success }
}

// =============================================================================
// StdoutExporter — human-readable line per span (dev / debugging)
// =============================================================================
//

// Line shape:
//   [<trace_id>:<span_id>] <name> kind=SERVER status=OK dur_ns=1523000 attrs={k=v, ...}
//

// A Mutex serialises whole batches so concurrent exports do not
// interleave partial lines.

public type StdoutExporter is {
    gate: StdoutGate,
};

/// Mutex as a DIRECT record field (the channel-module idiom), with a
/// per-operation method so the guard never crosses an expression
/// boundary.
type StdoutCell is {
    write_gate: Mutex<()>,
};

implement StdoutCell {
    public fn cell_write_batch(&self, spans: &List<SpanData>) {
        let _guard = self.write_gate.lock().unwrap_or_else(|p| p.into_inner());
        let mut i = 0;
        while i < spans.len() {
            let line = format_span_line(&spans[i]);
            print(&line);
            println("");
            i = i + 1;
        }
    }
}

/// Single-variant wrapper (see SpanBody in tracing/span.vr).
type StdoutGate is
    | Gate(Shared<StdoutCell>);

implement StdoutGate {
    public fn gate_write_batch(&self, spans: &List<SpanData>) {
        match self {
            StdoutGate.Gate(cell) => cell.cell_write_batch(spans),
        }
    }

    public fn gate_clone(&self) -> StdoutGate {
        match self {
            StdoutGate.Gate(cell) => StdoutGate.Gate(cell.clone()),
        }
    }
}

implement StdoutExporter {
    public fn new() -> StdoutExporter {
        StdoutExporter { gate: StdoutGate.Gate(Shared.new(StdoutCell { write_gate: Mutex.new(()) })) }
    }

    /// Share the same write lock under a second handle.
    public fn clone(&self) -> StdoutExporter {
        StdoutExporter { gate: self.gate.gate_clone() }
    }
}

implement StdoutExporter {
    /// Uniquely-named worker so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn stdout_export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.gate.gate_write_batch(spans);
        TraceExportResult.Success
    }
}

implement SpanExporter for StdoutExporter {
    fn export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.stdout_export(spans)
    }

    fn force_flush(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }

    fn shutdown(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }
}

// =============================================================================
// InMemoryExporter — collecting sink for tests and e2e verification
// =============================================================================
//

// Cloning the exporter shares the underlying buffer, so a test can keep
// one handle and give the pipeline another.

public type InMemoryExporter is {
    cell: MemBody,
};

/// Mutex as a DIRECT record field (the channel-module idiom), with
/// per-operation methods so the guard never crosses an expression
/// boundary.
type MemCell is {
    state: Mutex<InMemoryState>,
};

implement MemCell {
    public fn cell_len(&self) -> Int {
        let guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        guard.locked_sink_len()
    }

    public fn cell_take(&self) -> List<SpanData> {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        guard.locked_sink_take()
    }

    public fn cell_clear(&self) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        guard.locked_sink_clear();
    }

    public fn cell_export(&self, spans: &List<SpanData>) -> TraceExportResult {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        guard.locked_sink_export(spans)
    }

    public fn cell_shutdown(&self) {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        guard.locked_sink_shutdown();
    }
}

type InMemoryState is {
    spans: List<SpanData>,
    shut_down: Bool,
};

/// Single-variant wrapper (see SpanBody in tracing/span.vr).
type MemBody is
    | Mem(Shared<MemCell>);

implement MemBody {
    public fn mem_body_len(&self) -> Int {
        match self { MemBody.Mem(c) => c.cell_len() }
    }
    public fn mem_body_take(&self) -> List<SpanData> {
        match self { MemBody.Mem(c) => c.cell_take() }
    }
    public fn mem_body_clear(&self) {
        match self { MemBody.Mem(c) => c.cell_clear() }
    }
    public fn mem_body_export(&self, spans: &List<SpanData>) -> TraceExportResult {
        match self { MemBody.Mem(c) => c.cell_export(spans) }
    }
    public fn mem_body_shutdown(&self) {
        match self { MemBody.Mem(c) => c.cell_shutdown() }
    }
    public fn mem_body_clone(&self) -> MemBody {
        match self { MemBody.Mem(c) => MemBody.Mem(c.clone()) }
    }
}

implement InMemoryExporter {
    public fn new() -> InMemoryExporter {
        InMemoryExporter {
            cell: MemBody.Mem(Shared.new(MemCell {
                state: Mutex.new(InMemoryState {
                    spans: List.new(),
                    shut_down: false,
                }),
            })),
        }
    }

    /// Share the same buffer under a second handle.
    public fn clone(&self) -> InMemoryExporter {
        InMemoryExporter { cell: self.cell.mem_body_clone() }
    }

    /// Number of spans collected so far.
    public fn len(&self) -> Int {
        self.cell.mem_body_len()
    }

    /// Drain: return all collected spans, leaving the buffer empty.
    public fn take(&self) -> List<SpanData> {
        self.cell.mem_body_take()
    }

    /// Discard everything collected so far.
    public fn clear(&self) {
        self.cell.mem_body_clear();
    }

    /// Uniquely-named workers so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn mem_export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.cell.mem_body_export(spans)
    }

    public fn mem_shutdown(&self) -> TraceExportResult {
        self.cell.mem_body_shutdown();
        TraceExportResult.Success
    }
}

implement SpanExporter for InMemoryExporter {
    fn export(&self, spans: &List<SpanData>) -> TraceExportResult {
        self.mem_export(spans)
    }

    fn force_flush(&self, _t: Duration) -> TraceExportResult {
        TraceExportResult.Success
    }

    fn shutdown(&self, _t: Duration) -> TraceExportResult {
        self.mem_shutdown()
    }
}

// Locked state methods: every guarded access is a METHOD CALL on the
// mutex guard (auto-deref at dispatch time); the `locked_sink_` names
// are globally unique so the call resolves even for an untracked
// receiver.

implement InMemoryState {
    public fn locked_sink_len(&self) -> Int {
        self.spans.len()
    }

    public fn locked_sink_take(&mut self) -> List<SpanData> {
        let mut out = List.with_capacity(self.spans.len());
        let mut i = 0;
        while i < self.spans.len() {
            out.push(self.spans[i].clone());
            i = i + 1;
        }
        self.spans = List.new();
        out
    }

    public fn locked_sink_clear(&mut self) {
        self.spans = List.new();
    }

    public fn locked_sink_export(&mut self, spans: &List<SpanData>) -> TraceExportResult {
        if self.shut_down {
            return TraceExportResult.Failure(ExportError.shut_down());
        }
        let mut i = 0;
        while i < spans.len() {
            self.spans.push(spans[i].clone());
            i = i + 1;
        }
        TraceExportResult.Success
    }

    public fn locked_sink_shutdown(&mut self) {
        self.shut_down = true;
    }
}

// =============================================================================
// ExporterHandle — closed-world dispatch over the in-tree exporters
// =============================================================================

public type ExporterHandle is
    /// Discard everything.
    | EhNoop
    /// Human-readable stdout lines.
    | EhStdout(StdoutExporter)
    /// Collecting test sink.
    | EhInMemory(InMemoryExporter)
    /// Third-party exporter behind the SpanExporter protocol. NOTE:
    /// invoking a custom exporter requires protocol-object dispatch,
    /// which the VBC interpreter does not implement yet — construction
    /// and configuration work, invocation panics until the language
    /// gap closes.
    | EhCustom(Shared<dyn SpanExporter>);

implement ExporterHandle {
    public fn noop() -> ExporterHandle { ExporterHandle.EhNoop }

    public fn stdout() -> ExporterHandle {
        ExporterHandle.EhStdout(StdoutExporter.new())
    }

    public fn in_memory(exporter: InMemoryExporter) -> ExporterHandle {
        ExporterHandle.EhInMemory(exporter)
    }

    public fn custom(exporter: Shared<dyn SpanExporter>) -> ExporterHandle {
        ExporterHandle.EhCustom(exporter)
    }

    public fn export(&self, spans: &List<SpanData>) -> TraceExportResult {
        match self {
            ExporterHandle.EhNoop => TraceExportResult.Success,
            ExporterHandle.EhStdout(e) => e.stdout_export(spans),
            ExporterHandle.EhInMemory(e) => e.mem_export(spans),
            ExporterHandle.EhCustom(e) => e.export(spans),
        }
    }

    public fn force_flush(&self, _timeout: Duration) -> TraceExportResult {
        match self {
            ExporterHandle.EhNoop => TraceExportResult.Success,
            ExporterHandle.EhStdout(_) => TraceExportResult.Success,
            ExporterHandle.EhInMemory(_) => TraceExportResult.Success,
            ExporterHandle.EhCustom(e) => e.force_flush(_timeout),
        }
    }

    public fn shutdown(&self, timeout: Duration) -> TraceExportResult {
        match self {
            ExporterHandle.EhNoop => TraceExportResult.Success,
            ExporterHandle.EhStdout(_) => TraceExportResult.Success,
            ExporterHandle.EhInMemory(e) => e.mem_shutdown(),
            ExporterHandle.EhCustom(e) => e.shutdown(timeout),
        }
    }

    public fn clone(&self) -> ExporterHandle {
        match self {
            ExporterHandle.EhNoop => ExporterHandle.EhNoop,
            ExporterHandle.EhStdout(e) => ExporterHandle.EhStdout(e.clone()),
            ExporterHandle.EhInMemory(e) => ExporterHandle.EhInMemory(e.clone()),
            ExporterHandle.EhCustom(e) => ExporterHandle.EhCustom(e.clone()),
        }
    }
}

// =============================================================================
// Internal formatting helpers
// =============================================================================

fn format_span_line(s: &SpanData) -> Text {
    let ctx = s.context();
    let tid = ctx.trace_id().to_hex();
    let sid = ctx.span_id().to_hex();
    let status = match s.status().code() {
        SpanStatusCode.Unset => "UNSET",
        SpanStatusCode.Ok => "OK",
        SpanStatusCode.Error => "ERROR",
    };
    let dur_ns = s.duration().as_nanos();
    let kind = kind_name(s.kind());
    let attr_set = s.attributes();
    let entries = attr_set.entries();
    let attrs = format_attrs(&entries);
    let name = s.name();
    f"[{tid}:{sid}] {name} kind={kind} status={status} dur_ns={dur_ns} {attrs}"
}

fn kind_name(k: SpanKind) -> Text {
    match k {
        SpanKind.KindInternal => "INTERNAL".into(),
        SpanKind.KindClient => "CLIENT".into(),
        SpanKind.KindServer => "SERVER".into(),
        SpanKind.KindProducer => "PRODUCER".into(),
        SpanKind.KindConsumer => "CONSUMER".into(),
    }
}

fn format_attrs(entries: &List<(Text, AttributeValue)>) -> Text {
    if entries.is_empty() { return "".into(); }
    let mut out = Text.with_capacity(64);
    out.push_str("attrs={");
    let mut i = 0;
    while i < entries.len() {
        if i > 0 { out.push_str(", "); }
        out.push_str(&entries[i].0);
        out.push_str("=");
        out.push_str(&format_attr_value(&entries[i].1));
        i = i + 1;
    }
    out.push_str("}");
    out
}

fn format_attr_value(v: &AttributeValue) -> Text {
    match v {
        AttributeValue.Text(t) => f"\"{t}\"",
        AttributeValue.Bool(b) => f"{b}",
        AttributeValue.Int(i) => f"{i}",
        AttributeValue.Float(f) => f"{f}",
        AttributeValue.TextArray(xs) => f"[{xs.len()} strings]",
        AttributeValue.BoolArray(xs) => f"[{xs.len()} bools]",
        AttributeValue.IntArray(xs) => f"[{xs.len()} ints]",
        AttributeValue.FloatArray(xs) => f"[{xs.len()} floats]",
    }
}
