// =============================================================================
// tracing/propagation.vr — W3C Trace Context codec for traceparent / tracestate
// =============================================================================
// Encoding / decoding of the "traceparent" and "tracestate" HTTP headers
// per https://www.w3.org/TR/trace-context/
//
// traceparent = <version>-<trace-id>-<parent-id>-<flags>
//   version   = "00"      (only version currently defined)
//   trace-id  = 32 lowercase hex chars (16 bytes)
//   parent-id = 16 lowercase hex chars (8 bytes)
//   flags     = 2 lowercase hex chars  (1 byte)
//
// tracestate = <key1>=<val1>,<key2>=<val2>,...
// =============================================================================

module core.tracing.propagation;

mount core.*;
mount core.tracing.id.{TraceId, SpanId};
mount core.tracing.context.{SpanContext, TraceFlags, TraceState};

// =============================================================================
// TextMapPropagator protocol — pluggable propagation format
// =============================================================================

public type TextMapPropagator is protocol {
    /// Encode the given context into the key/value store supplied via
    /// setter.
    fn inject(
        &self,
        context: &SpanContext,
        headers: &mut List<(Text, Text)>,
    );

    /// Extract a context from the given store.
    fn extract(
        &self,
        headers: &List<(Text, Text)>,
    ) -> SpanContext;

    /// List of header names the propagator consumes.
    fn fields(&self) -> List<Text>;
};

// =============================================================================
// W3CTraceContext — canonical W3C implementation
// =============================================================================

public type W3CTraceContext is ();

const TRACEPARENT_FIELD: &'static Text = "traceparent";
const TRACESTATE_FIELD: &'static Text = "tracestate";
const TRACEPARENT_VERSION: &'static Text = "00";

/// Maximum number of tracestate list members. W3C Trace Context §3.3.1.4
/// specifies "MUST NOT include more than 32 list-members" — anything past
/// the cap MUST be dropped. We surface that as a hard parser cap so a
/// hostile upstream cannot smuggle unbounded entries past us.
const MAX_TRACESTATE_ENTRIES: Int = 32;

/// Maximum total length of the tracestate header. W3C §3.3.1.4 caps the
/// combined header at 512 bytes; we accept up to 4096 to tolerate
/// non-compliant clients while still bounding memory.
const MAX_TRACESTATE_HEADER_BYTES: Int = 4096;


implement W3CTraceContext {
    public fn new() -> W3CTraceContext { () }
}

implement TextMapPropagator for W3CTraceContext {
    fn inject(
        &self,
        context: &SpanContext,
        headers: &mut List<(Text, Text)>,
    ) {
        if !context.is_valid() { return; }
        let tp = encode_traceparent(context);
        headers.push((TRACEPARENT_FIELD.into(), tp));
        if !context.trace_state().is_empty() {
            let ts = encode_tracestate(context.trace_state());
            headers.push((TRACESTATE_FIELD.into(), ts));
        }
    }

    fn extract(&self, headers: &List<(Text, Text)>) -> SpanContext {
        let tp = find_header(headers, TRACEPARENT_FIELD);
        match tp {
            None => SpanContext.invalid(),
            Some(raw) => {
                match decode_traceparent(raw.as_bytes()) {
                    None => SpanContext.invalid(),
                    Some((trace_id, span_id, flags)) => {
                        let ts_raw = find_header(headers, TRACESTATE_FIELD);
                        let trace_state = match ts_raw {
                            Some(r) => decode_tracestate(r.as_bytes()),
                            None => TraceState.empty(),
                        };
                        SpanContext.new(trace_id, span_id, flags, trace_state, true)
                    }
                }
            }
        }
    }

    fn fields(&self) -> List<Text> {
        let mut out = List.with_capacity(2);
        out.push("traceparent".into());
        out.push("tracestate".into());
        out
    }
}

// =============================================================================
// Convenience free-functions — single-header operations
// =============================================================================

/// Inject a traceparent header; returns the encoded string (or empty
/// if the context is invalid).
public fn inject_traceparent(context: &SpanContext) -> Text {
    if !context.is_valid() { return "".into(); }
    encode_traceparent(context)
}

/// Extract a SpanContext from a single traceparent header value.
/// Returns invalid context on parse failure.
public fn extract_traceparent(raw: &Text) -> SpanContext {
    match decode_traceparent(raw.as_bytes()) {
        None => SpanContext.invalid(),
        Some((trace_id, span_id, flags)) => {
            SpanContext.new(trace_id, span_id, flags, TraceState.empty(), true)
        }
    }
}

// =============================================================================
// Internal codec
// =============================================================================

fn encode_traceparent(context: &SpanContext) -> Text {
    let mut out = Text.with_capacity(55);
    out.push_str(TRACEPARENT_VERSION);
    out.push('-');
    out.push_str(&context.trace_id().to_hex());
    out.push('-');
    out.push_str(&context.span_id().to_hex());
    out.push('-');
    push_byte_hex(&mut out, context.flags().to_byte());
    out
}

fn decode_traceparent(bytes: &[Byte]) -> Maybe<(TraceId, SpanId, TraceFlags)> {
    // Canonical length is exactly 55 bytes: "00-<32>-<16>-<2>".
    if bytes.len() != 55 { return None; }
    if bytes[0] != 0x30 || bytes[1] != 0x30 { return None; }
    if bytes[2] != 0x2D || bytes[35] != 0x2D || bytes[52] != 0x2D { return None; }
    let trace_id = TraceId.from_hex(&bytes[3..35])?;
    let span_id = SpanId.from_hex(&bytes[36..52])?;
    let flags_byte = decode_byte_hex(bytes[53], bytes[54])?;
    // "00" (invalid version) already rejected implicitly; v1-v255 are
    // reserved and we reject them per spec §3.2.2.2.
    Some((trace_id, span_id, TraceFlags.new(flags_byte)))
}

fn encode_tracestate(state: &TraceState) -> Text {
    let entries = state.entries();
    let mut out = Text.with_capacity(entries.len() * 16);
    let mut i = 0;
    while i < entries.len() {
        if i > 0 { out.push(','); }
        out.push_str(&entries[i].0);
        out.push('=');
        out.push_str(&entries[i].1);
        i = i + 1;
    }
    out
}

fn decode_tracestate(bytes: &[Byte]) -> TraceState {
    // Comma-separated k=v pairs; per spec trim OWS and skip malformed.
    // W3C §3.3.1.4: header capped at 32 list-members and 512 bytes;
    // we tolerate 4096 bytes but hard-cap entry count to 32 so a
    // hostile upstream can't smuggle unbounded tracestate fan-out.
    let mut state = TraceState.empty();
    if bytes.len() > MAX_TRACESTATE_HEADER_BYTES {
        return state;
    }
    let mut start = 0;
    let mut i = 0;
    let mut count = 0;
    while i <= bytes.len() && count < MAX_TRACESTATE_ENTRIES {
        if i == bytes.len() || bytes[i] == 0x2C /* ',' */ {
            if i > start {
                let segment = &bytes[start..i];
                let trimmed = trim_ows(segment);
                match split_kv(trimmed) {
                    Some((k, v)) => {
                        match (Text.from_utf8(k), Text.from_utf8(v)) {
                            (Ok(key), Ok(val)) => {
                                state = state.with(key, val);
                                count = count + 1;
                            }
                            _ => {}
                        }
                    }
                    None => {}
                }
            }
            start = i + 1;
        }
        i = i + 1;
    }
    state
}

fn find_header(headers: &List<(Text, Text)>, name: &Text) -> Maybe<&Text> {
    let mut i = 0;
    while i < headers.len() {
        if ascii_eq_ci_text(&headers[i].0, name) {
            return Some(&headers[i].1);
        }
        i = i + 1;
    }
    None
}

fn ascii_eq_ci_text(a: &Text, b: &Text) -> Bool {
    // ASCII case-insensitive byte-by-byte comparison. Naively OR-ing
    // 0x20 into both sides folds A-Z to a-z but ALSO mutates non-
    // alphabetic chars: e.g. '@' (0x40) | 0x20 == '`' (0x60), so
    // `ascii_eq_ci("@", "`")` would return true under that variant —
    // a real header-name comparator with a real bug. Fold only when
    // the byte is in the A-Z range so the equivalence respects ASCII
    // letter classes and nothing else.
    let ab = a.as_bytes();
    let bb = b.as_bytes();
    if ab.len() != bb.len() { return false; }
    let mut i = 0;
    while i < ab.len() {
        let ra = ab[i];
        let rb = bb[i];
        let ca = if ra >= 0x41_u8 && ra <= 0x5A_u8 { ra | 0x20_u8 } else { ra };
        let cb = if rb >= 0x41_u8 && rb <= 0x5A_u8 { rb | 0x20_u8 } else { rb };
        if ca != cb { return false; }
        i = i + 1;
    }
    true
}

fn trim_ows(bytes: &[Byte]) -> &[Byte] {
    let mut start = 0;
    let mut end = bytes.len();
    while start < end && (bytes[start] == 0x20 || bytes[start] == 0x09) { start = start + 1; }
    while end > start && (bytes[end - 1] == 0x20 || bytes[end - 1] == 0x09) { end = end - 1; }
    &bytes[start..end]
}

fn split_kv(bytes: &[Byte]) -> Maybe<(&[Byte], &[Byte])> {
    let mut i = 0;
    while i < bytes.len() {
        if bytes[i] == 0x3D /* '=' */ {
            return Some((&bytes[..i], &bytes[i + 1..]));
        }
        i = i + 1;
    }
    None
}

fn push_byte_hex(out: &mut Text, b: UInt8) {
    let hi = (b >> 4) & 0x0F;
    let lo = b & 0x0F;
    out.push(hex_digit(hi));
    out.push(hex_digit(lo));
}

fn hex_digit(n: UInt8) -> Char {
    if n < 10 { (0x30 + n) as Char } else { (0x61 + n - 10) as Char }
}

fn decode_byte_hex(hi: Byte, lo: Byte) -> Maybe<UInt8> {
    let hi_n = decode_nibble(hi)?;
    let lo_n = decode_nibble(lo)?;
    Some((hi_n << 4) | lo_n)
}

fn decode_nibble(b: Byte) -> Maybe<UInt8> {
    if b >= 0x30 && b <= 0x39 { Some((b - 0x30) as UInt8) }
    else if b >= 0x61 && b <= 0x66 { Some((b - 0x61 + 10) as UInt8) }
    else if b >= 0x41 && b <= 0x46 { Some((b - 0x41 + 10) as UInt8) }
    else { None }
}
