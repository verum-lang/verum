// =============================================================================
// tracing/tracer.vr — SdkTracer + TracerHandle + TracerProvider + global
//                     registry
// =============================================================================
// Entry point for instrumentation. Configure once at startup via
// `set_global_tracer_provider`; call `get_tracer(name, version)`
// anywhere thereafter to obtain a named TracerHandle.
// Spec: https://opentelemetry.io/docs/specs/otel/trace/api/#tracerprovider
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.tracing.tracer;

mount core.*;
mount core.sync.mutex.{Mutex};
mount core.time.instant.{Instant};
mount core.time.system_time.{SystemTime};
mount core.time.duration.{Duration};
mount core.tracing.id.{IdGeneratorHandle, default_id_generator};
mount core.tracing.context.{SpanContext, TraceFlags};
mount core.tracing.attribute.{AttributeSet};
mount core.tracing.resource.{Resource};
mount core.tracing.data.{SpanKind, SpanStatus, SpanLink, TraceExportResult};
mount core.tracing.sampler.{SamplerHandle, SamplingDecision, always_on, always_off, parent_based};
mount core.tracing.processor.{ProcessorHandle};
mount core.tracing.data.{build_recording_span};
mount core.tracing.span.{Span};

// =============================================================================
// Tracer protocol — the contract user-defined tracers implement
// =============================================================================

public type Tracer is protocol {
    fn start_span(
        &self,
        name: &Text,
        kind: SpanKind,
        attributes: AttributeSet,
        links: List<SpanLink>,
        parent: &SpanContext,
    ) -> Span;

    fn instrumentation_scope(&self) -> &Text;
    fn instrumentation_version(&self) -> &Text;
};

// =============================================================================
// NoopTracer — used when no provider / no processors are installed
// =============================================================================

public type NoopTracer is {
    scope: Text,
    version: Text,
};

implement NoopTracer {
    public fn new(scope: Text, version: Text) -> NoopTracer {
        NoopTracer { scope: scope, version: version }
    }

    public fn clone(&self) -> NoopTracer {
        NoopTracer { scope: self.scope.clone(), version: self.version.clone() }
    }

    /// Uniquely-named workers so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn noop_start_span(&self, parent: &SpanContext) -> Span {
        // Per OTel API: a no-op tracer still propagates a valid parent
        // context so downstream hops keep their traceparent.
        if parent.is_valid() {
            Span.non_recording(parent.clone())
        } else {
            Span.noop()
        }
    }

    public fn noop_scope_text(&self) -> Text { self.scope.clone() }
    public fn noop_version_text(&self) -> Text { self.version.clone() }
}

implement Tracer for NoopTracer {
    fn start_span(
        &self,
        _name: &Text,
        _kind: SpanKind,
        _attributes: AttributeSet,
        _links: List<SpanLink>,
        parent: &SpanContext,
    ) -> Span {
        // Per OTel API: a no-op tracer still propagates a valid parent
        // context so downstream hops keep their traceparent.
        if parent.is_valid() {
            Span.non_recording(parent.clone())
        } else {
            Span.noop()
        }
    }

    fn instrumentation_scope(&self) -> &Text { &self.scope }
    fn instrumentation_version(&self) -> &Text { &self.version }
}

// =============================================================================
// SdkTracer — production tracer: sampler + processor + id source + resource
// =============================================================================

public type SdkTracer is {
    scope: Text,
    version: Text,
    sampler: SamplerHandle,
    processor: ProcessorHandle,
    id_generator: IdGeneratorHandle,
    resource: Shared<Resource>,
};

implement SdkTracer {
    public fn new(
        scope: Text,
        version: Text,
        sampler: SamplerHandle,
        processor: ProcessorHandle,
        id_generator: IdGeneratorHandle,
        resource: Shared<Resource>,
    ) -> SdkTracer {
        SdkTracer {
            scope: scope,
            version: version,
            sampler: sampler,
            processor: processor,
            id_generator: id_generator,
            resource: resource,
        }
    }

    public fn start_span(
        &self,
        name: &Text,
        kind: SpanKind,
        attributes: AttributeSet,
        links: List<SpanLink>,
        parent: &SpanContext,
    ) -> Span {
        let trace_id = if parent.is_valid() {
            parent.trace_id()
        } else {
            self.id_generator.new_trace_id()
        };
        let span_id = self.id_generator.new_span_id();

        let result = self.sampler.should_sample(parent, &trace_id, name, kind, &attributes);
        let sampled = match result.decision() {
            SamplingDecision.RecordAndSample => true,
            _ => false,
        };
        let flags = TraceFlags.default().with_sampled(sampled);
        let context = SpanContext.new(
            trace_id, span_id, flags, result.trace_state(), false,
        );

        // Dropped spans stay non-recording but keep the VALID context —
        // traceparent continuity across a sampled-out hop is mandatory
        // (OTel SDK spec: sampler Drop yields a non-recording span with
        // the same SpanContext it would otherwise have).
        match result.decision() {
            SamplingDecision.Drop => {
                return Span.non_recording(context);
            }
            _ => {}
        }

        let parent_span_id = if parent.is_valid() {
            Maybe.Some(parent.span_id())
        } else {
            Maybe.None
        };

        let span = build_recording_span(
            context.clone(),
            name.clone(),
            parent_span_id,
            kind,
            attributes,
            links,
            self.resource.clone(),
            self.scope.clone(),
            self.version.clone(),
            self.processor.clone(),
        );
        self.processor.on_start(&context, parent);
        span
    }

    public fn instrumentation_scope(&self) -> &Text { &self.scope }
    public fn instrumentation_version(&self) -> &Text { &self.version }

    /// Uniquely-named workers so handle dispatch resolves on any
    /// receiver-tracking tier.
    public fn sdk_start_span(
        &self,
        name: &Text,
        kind: SpanKind,
        attributes: AttributeSet,
        links: List<SpanLink>,
        parent: &SpanContext,
    ) -> Span {
        self.start_span(name, kind, attributes, links, parent)
    }

    public fn sdk_scope_text(&self) -> Text { self.scope.clone() }
    public fn sdk_version_text(&self) -> Text { self.version.clone() }
}

// =============================================================================
// TracerHandle — closed-world dispatch over the in-tree tracers
// =============================================================================

public type TracerHandle is
    | ThSdk(Shared<SdkTracer>)
    | ThNoop(NoopTracer);

implement TracerHandle {
    public fn start_span(
        &self,
        name: &Text,
        kind: SpanKind,
        attributes: AttributeSet,
        links: List<SpanLink>,
        parent: &SpanContext,
    ) -> Span {
        match self {
            TracerHandle.ThSdk(t) => t.sdk_start_span(name, kind, attributes, links, parent),
            TracerHandle.ThNoop(t) => t.noop_start_span(parent),
        }
    }

    public fn instrumentation_scope(&self) -> Text {
        match self {
            TracerHandle.ThSdk(t) => t.sdk_scope_text(),
            TracerHandle.ThNoop(t) => t.noop_scope_text(),
        }
    }

    public fn instrumentation_version(&self) -> Text {
        match self {
            TracerHandle.ThSdk(t) => t.sdk_version_text(),
            TracerHandle.ThNoop(t) => t.noop_version_text(),
        }
    }

    public fn clone(&self) -> TracerHandle {
        match self {
            TracerHandle.ThSdk(t) => TracerHandle.ThSdk(t.clone()),
            TracerHandle.ThNoop(t) => TracerHandle.ThNoop(t.clone()),
        }
    }
}

// =============================================================================
// TracerProvider — owns sampler, processors, id source, resource
// =============================================================================

public type TracerProvider is {
    sampler: SamplerHandle,
    processors: List<ProcessorHandle>,
    id_generator: IdGeneratorHandle,
    resource: Shared<Resource>,
};

implement TracerProvider {
    public fn builder() -> TracerProviderBuilder {
        TracerProviderBuilder {
            has_sampler: false,
            sampler: always_off(),
            has_id_generator: false,
            id_generator: default_id_generator(),
            processors: List.new(),
            resource: Resource.empty(),
        }
    }

    public fn noop() -> TracerProvider {
        TracerProvider {
            sampler: always_off(),
            processors: List.new(),
            id_generator: default_id_generator(),
            resource: Shared.new(Resource.empty()),
        }
    }

    /// Obtain a tracer for the given instrumentation scope. Each call
    /// constructs a fresh handle over the provider's shared pipeline —
    /// resolve tracers once per component at startup, not per request.
    public fn tracer(&self, name: &Text, version: &Text) -> TracerHandle {
        // No processors installed — spans would go nowhere; hand out a
        // no-op tracer that still propagates parent contexts.
        if self.processors.is_empty() {
            return TracerHandle.ThNoop(NoopTracer.new(name.clone(), version.clone()));
        }
        let processor: ProcessorHandle = if self.processors.len() == 1 {
            self.processors[0].clone()
        } else {
            ProcessorHandle.composite(clone_proc_list(&self.processors))
        };
        let tracer = Shared.new(SdkTracer.new(
            name.clone(), version.clone(),
            self.sampler.clone(), processor,
            self.id_generator.clone(), self.resource.clone(),
        ));
        TracerHandle.ThSdk(tracer)
    }

    /// Flush every registered processor. First failure wins; all
    /// processors are still visited.
    public fn force_flush(&self, timeout: Duration) -> TraceExportResult {
        let mut acc = TraceExportResult.Success;
        let mut i = 0;
        while i < self.processors.len() {
            acc = acc.combine(self.processors[i].force_flush(timeout));
            i = i + 1;
        }
        acc
    }

    /// Drain and shut down every registered processor. Call before
    /// process exit — and before replacing the global provider — or
    /// buffered spans are lost.
    public fn shutdown(&self, timeout: Duration) -> TraceExportResult {
        let mut acc = TraceExportResult.Success;
        let mut i = 0;
        while i < self.processors.len() {
            acc = acc.combine(self.processors[i].shutdown(timeout));
            i = i + 1;
        }
        acc
    }
}

fn clone_proc_list(xs: &List<ProcessorHandle>) -> List<ProcessorHandle> {
    let mut out = List.with_capacity(xs.len());
    let mut i = 0;
    while i < xs.len() {
        out.push(xs[i].clone());
        i = i + 1;
    }
    out
}

// =============================================================================
// Builder
// =============================================================================

// Flat fields (Bool + value, no Maybe-of-enum) — optional-enum record
// fields are not construction-safe in the current interpreter.
public type TracerProviderBuilder is {
    has_sampler: Bool,
    sampler: SamplerHandle,
    has_id_generator: Bool,
    id_generator: IdGeneratorHandle,
    processors: List<ProcessorHandle>,
    resource: Resource,
};

implement TracerProviderBuilder {
    public fn with_sampler(mut self, sampler: SamplerHandle) -> TracerProviderBuilder {
        self.has_sampler = true;
        self.sampler = sampler;
        self
    }
    public fn with_id_generator(mut self, generator: IdGeneratorHandle) -> TracerProviderBuilder {
        self.has_id_generator = true;
        self.id_generator = generator;
        self
    }
    public fn with_resource(mut self, resource: Resource) -> TracerProviderBuilder {
        self.resource = resource; self
    }
    public fn with_processor(mut self, processor: ProcessorHandle) -> TracerProviderBuilder {
        self.processors.push(processor); self
    }

    public fn build(self) -> TracerProvider {
        TracerProvider {
            sampler: if self.has_sampler {
                self.sampler
            } else {
                // OTel default: follow the parent, sample all local roots.
                parent_based(always_on())
            },
            id_generator: if self.has_id_generator {
                self.id_generator
            } else {
                default_id_generator()
            },
            processors: self.processors,
            resource: Shared.new(self.resource),
        }
    }
}

// =============================================================================
// Global provider
// =============================================================================
//

// A mutex-guarded slot. Both set and get take the lock — acceptable
// because the intended pattern is "set once at startup, resolve tracers
// once per component"; per-request get_tracer calls are a misuse the
// docs warn about.

static GLOBAL_PROVIDER: Mutex<Maybe<Shared<TracerProvider>>> = Mutex.new(Maybe.None);

/// Install the global TracerProvider. Intended to be called once at
/// startup. Replaces any previous provider WITHOUT flushing it — call
/// `provider.shutdown(timeout)` on the old provider first if it could
/// hold buffered spans.
public fn set_global_tracer_provider(provider: TracerProvider) {
    // Poison-tolerant, whole-value store — the signal-registry idiom:
    // the guarded state is always either Maybe.None (uninstalled) or
    // Maybe.Some(provider); both observable values stay safe even if
    // an unrelated thread panicked.
    let mut guard = GLOBAL_PROVIDER.lock().unwrap_or_else(|p| p.into_inner());
    *guard = Maybe.Some(Shared.new(provider));
}

/// Return the installed provider, or a fresh no-op provider if none has
/// been installed — `get_tracer(...)` always succeeds, so instrumented
/// code never branches on "is tracing configured".
public fn global_tracer_provider() -> Shared<TracerProvider> {
    let guard = GLOBAL_PROVIDER.lock().unwrap_or_else(|p| p.into_inner());
    match &*guard {
        Maybe.Some(p) => p.clone(),
        Maybe.None => Shared.new(TracerProvider.noop()),
    }
}

/// Shorthand — `get_tracer(name, version)` = `global_tracer_provider().tracer(...)`.
public fn get_tracer(name: &Text, version: &Text) -> TracerHandle {
    let provider = global_tracer_provider();
    provider.tracer(name, version)
}
