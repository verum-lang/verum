// =============================================================================
// configuration/mod.vr — universal configuration subsystem entry point
// =============================================================================
// Layer: 4 (User API)
// Dependencies: all configuration submodules
// =============================================================================
//
// **The architecturally-impeccable configuration subsystem.** Provides a
// unified surface for parsing, serialising, validating, converting,
// merging, and interpolating configuration in any supported format.
//
// **Architecture summary** (see `value.vr`, `format.vr`, `convert.vr`,
// `error.vr` for foundational details):
//
//   ┌──────────────────────────────────────────────────────────┐
//   │ Layer 4 — this module: Configuration<T>::load*           │
//   ├──────────────────────────────────────────────────────────┤
//   │ Layer 3 — schema, path, merge, env, convert              │
//   ├──────────────────────────────────────────────────────────┤
//   │ Layer 2 — format protocol + registry, error              │
//   ├──────────────────────────────────────────────────────────┤
//   │ Layer 1 — format adapters (toml, yaml, ini, ...)         │
//   ├──────────────────────────────────────────────────────────┤
//   │ Layer 0 — value (ConfigValue ADT — categorical hub)      │
//   └──────────────────────────────────────────────────────────┘
//
// **Categorical position.** This module is the **slice category** over
// `ConfigValue` whose objects are typed records `T` and whose morphisms
// are refinement-preserving load/save adapters. The `Configuration<T>`
// type is the universal closure: any `T` admitting `@derive(ConfigSchema)`
// roundtrips through any format implementing `ConfigFormat`.
//
// **Public surface (the four primary verbs):**
//
//   * `load_text(text, format_id)`  — parse text → ConfigValue
//   * `load_typed<T>(text, format_id)` — parse + schema-validate → T
//   * `dump_text(value, format_id)`  — serialise ConfigValue → text
//   * `convert(text, src_id, dst_id)` — cross-format conversion
//
// Convenience overloads accept a file path with auto-detected format.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1"),
    declarations: ShapeDeclarations {
        purpose: Some(Purpose {
            role: "universal entry-point for the configuration subsystem",
            k_min: CveThresholdK.FullWitness,
            v_min: CveThresholdV.TypecheckPlusTests,
            e_min: CveThresholdE.StructurallyReady,
        }),
        substrate:      Some(CognitiveSubstrate.AnalyticDecompositional),
        anchoring:      Some(FormalAnchoring.CurryHowardLawvere),
        e_sense:        Some(ExecutabilitySense.StructuralReadiness),
        self_reference: None,
    },
)
module core.configuration;

mount core.*;
mount collections.{List, Map};
mount base.{Result, Ok, Err, Maybe, Some, None, Text};

// Re-export the universal types so callers `mount core.configuration.*`
// and have everything in scope.
public mount configuration.value.{
    ConfigValue,
    is_null, is_bool, is_int, is_float, is_number, is_string, is_bytes,
    is_datetime, is_duration, is_array, is_table, is_tagged,
    as_bool, as_int, as_float, as_string, as_bytes, as_array, as_table,
    type_name,
    null, bool_v, int_v, float_v, string_v, array_v, table_v,
    empty_table, empty_array,
};

public mount configuration.error.{
    ConfigError,
    ConfigErrorKind,
    ConfigErrorCategory,
    FormatId,
    config_err,
    with_path,
    category,
    format_id_toml, format_id_yaml, format_id_jsonc, format_id_json5,
    format_id_ini, format_id_properties, format_id_hcl, format_id_hocon,
    format_id_nestedtext, format_id_kdl, format_id_cue, format_id_dhall,
};

public mount configuration.format.{
    ConfigFormat,
    FormatOptions,
    FormatCapabilities,
    FormatRegistry,
    empty_options,
    default_capabilities,
    registry_new,
    register_format,
    get_format,
    detect_by_extension,
    detect_by_path,
    detect_by_mime,
    registered_ids,
};

public mount configuration.convert.{
    LossPolicy,
    ConversionWarning,
    ConvertedDocument,
    convert_value_to_text,
    convert_text,
    validate_conversion,
};

// =============================================================================
// Built-in registry — singleton populated on first access
// =============================================================================
//
// Lazy-initialised singleton holding all built-in format adapters.
// Custom formats are registered via `core.configuration.register_format`
// against this same registry.
const BUILTIN_REGISTRY: Lazy<FormatRegistry> = Lazy.new(|| {
    let reg = registry_new();
    // Built-in adapters self-register here:
    // configuration.toml.register(&reg);
    // configuration.yaml.register(&reg);
    // configuration.ini.register(&reg);
    // ... etc.
    // (Each format module exposes a `register(reg: &FormatRegistry)`
    // function that constructs its singleton adapter and inserts it.)
    reg
});

/// Access the global format registry. Built-in formats are registered
/// on first access; user code may register additional formats by calling
/// `register_format(&builtin_registry(), ...)`.
public fn builtin_registry() -> &'static FormatRegistry {
    BUILTIN_REGISTRY.get()
}

// =============================================================================
// Primary verbs
// =============================================================================

/// Parse `text` as the format identified by `format_id`, returning a
/// raw `ConfigValue`. Returns `Err` if the format is not registered or
/// the text is malformed.
public fn load_text(text: &Text, format_id: &FormatId) -> Result<ConfigValue, ConfigError> {
    match get_format(builtin_registry(), format_id) {
        Some(fmt) => fmt.parse(text),
        None      => Err(config_err(
            format_id.clone(),
            ConfigErrorKind.IoOther,
            0, 0, 0,
            "format not registered".to_text(),
        )),
    }
}

/// Parse `text` and auto-detect format from `filename` extension.
public fn load_text_for_path(text: &Text, filename: &Text) -> Result<ConfigValue, ConfigError> {
    match detect_by_path(builtin_registry(), filename) {
        Some(fmt) => fmt.parse(text),
        None      => Err(config_err(
            "unknown".to_text(),
            ConfigErrorKind.IoOther,
            0, 0, 0,
            "no registered format matches file extension of: ".to_text().concat(filename),
        )),
    }
}

/// Serialise a `ConfigValue` as the format identified by `format_id`.
public fn dump_text(value: &ConfigValue, format_id: &FormatId) -> Result<Text, ConfigError> {
    match get_format(builtin_registry(), format_id) {
        Some(fmt) => fmt.stringify(value),
        None      => Err(config_err(
            format_id.clone(),
            ConfigErrorKind.IoOther,
            0, 0, 0,
            "format not registered".to_text(),
        )),
    }
}

/// Cross-format conversion: parse with `src_id`, render with `dst_id`,
/// applying `policy` for any unsupported features.
public fn convert(
    text: &Text,
    src_id: &FormatId,
    dst_id: &FormatId,
    policy: LossPolicy,
) -> Result<ConvertedDocument, ConfigError> {
    let reg = builtin_registry();
    let src = match get_format(reg, src_id) {
        Some(f) => f,
        None    => return Err(config_err(
            src_id.clone(), ConfigErrorKind.IoOther, 0, 0, 0,
            "src format not registered".to_text(),
        )),
    };
    let dst = match get_format(reg, dst_id) {
        Some(f) => f,
        None    => return Err(config_err(
            dst_id.clone(), ConfigErrorKind.IoOther, 0, 0, 0,
            "dst format not registered".to_text(),
        )),
    };
    convert_text(text, &*src, &*dst, policy)
}

// =============================================================================
// Tests
// =============================================================================

#[cfg(test)]
mod tests {
    use super.*;

    #[test]
    fn test_registry_starts_with_builtins() {
        // Built-ins register on first access. After foundation phase we
        // expect at least the built-in formats to be present once their
        // adapters land. Currently the registry is empty (Phase 1 only
        // foundation modules); test asserts that `registered_ids` works.
        let ids = registered_ids(builtin_registry());
        let _ = ids;  // smoke-test, no specific count yet
    }
}
