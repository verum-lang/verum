// =============================================================================
// poly_kinds.vr — Polymorphic Kinds
// =============================================================================
// Layer: Standard Library / Types
//
// Source-level mirror of the compiler kernel's `verum_types.poly_kinds`,
// kept API-parallel so user-space tooling (macro libraries, typed DSLs,
// proof scaffolding) reasons about kinds with the same algebra the
// compiler uses. Kind-level Hindley-Milner: kind variables, kind
// constructors (`→`, `Type`, `Constraint`), Robinson unification.
//
// Practical use: heterogeneous containers, levitated functor
// combinators, type-class hierarchies parameterised by kind.
//
// ## Design rules
//
// * The kind algebra is exposed as free functions over immutable
//   values — the operations are symmetric mathematical relations
//   (`kind_unify(a, b)`, `kind_compose(s1, s2)`), not stateful
//   object behaviour, so method syntax would misrepresent them.
// * Failures are structured data (`KindError`), never `Text` —
//   callers pattern-match on the failure, diagnostics render it
//   through `Display`. Fallible operations return `Result`, the
//   language's canonical error channel.
// * Substitutions are `Map<Text, Kind>` keyed by kind-variable
//   name: O(1) amortised lookup, the hot operation of recursive
//   unification. `free_vars` returns `Set<Text>` — the honest
//   representation of "the names that occur freely".
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.types.poly_kinds;

mount core.*;
mount core.collections.map.{Map};
mount core.collections.set.{Set};

// =============================================================================
// 1. Kind algebra
// =============================================================================

/// A kind in the polymorphic-kind algebra.
public type Kind is
    /// `Type` — the kind of value-level types.
    | KType
    /// `Constraint` — the kind of typeclass constraints.
    | KConstraint
    /// `K₁ → K₂` — a type constructor's kind.
    | KArrow { domain: Heap<Kind>, codomain: Heap<Kind> }
    /// `κ` — a kind variable, identified by name.
    | KVar { name: Text };

public fn k_type() -> Kind { Kind.KType }
public fn k_constraint() -> Kind { Kind.KConstraint }
public fn k_arrow(a: Kind, b: Kind) -> Kind {
    Kind.KArrow { domain: Heap(a), codomain: Heap(b) }
}
public fn k_var(name: Text) -> Kind { Kind.KVar { name } }

/// A structured kind-inference failure. Carries the offending kinds
/// themselves so callers can match on the failure shape; rendering
/// for diagnostics goes through `Display`.
public type KindError is
    /// Structural mismatch: the two kinds have incompatible heads.
    | Mismatch { lhs: Kind, rhs: Kind }
    /// Occurs-check failure: binding `var ↦ in_kind` would build an
    /// infinite kind (`var` occurs free inside `in_kind`).
    | OccursCheck { var: Text, in_kind: Kind }
    /// A kind was applied to more arguments than its arrow spine has.
    | OverApplication { kind: Kind, arg: Kind };

// =============================================================================
// 2. Substitution
// =============================================================================

/// A substitution from kind-variable names to their resolved kinds.
public type KindSubst is { entries: Map<Text, Kind> };

/// Empty substitution.
public fn subst_empty() -> KindSubst {
    KindSubst { entries: Map.new() }
}

/// Single-binding substitution.
public fn subst_single(name: Text, kind: Kind) -> KindSubst {
    let mut m: Map<Text, Kind> = Map.new();
    m.insert(name, kind);
    KindSubst { entries: m }
}

/// Look up a binding for `var_name`.
public fn subst_lookup(s: &KindSubst, var_name: Text) -> Maybe<Kind> {
    s.entries.get(var_name)
}

/// Number of bindings in the substitution.
public fn subst_size(s: &KindSubst) -> Int {
    s.entries.len()
}

/// Apply a substitution to a kind, recursively.
///
/// `kind_apply([α↦Type, β↦α], KArrow(α, β))` walks the structure,
/// rewriting every `KVar` whose name has a binding. Idempotent
/// once the substitution itself is in normal form.
public fn kind_apply(s: &KindSubst, k: Kind) -> Kind {
    match k {
        Kind.KType => Kind.KType,
        Kind.KConstraint => Kind.KConstraint,
        Kind.KVar { name } => match subst_lookup(s, name.clone()) {
            Maybe.Some(replacement) => replacement,
            Maybe.None => Kind.KVar { name },
        },
        Kind.KArrow { domain, codomain } =>
            k_arrow(
                kind_apply(s, *domain),
                kind_apply(s, *codomain),
            ),
    }
}

/// Compose two substitutions: `s2 ∘ s1` means "apply s1, then s2".
/// Returns a substitution `s` such that `kind_apply(s, k) ==
/// kind_apply(s2, kind_apply(s1, k))` for every k.
///
/// Semantics: post-application of s2 to s1's range, then add s2's
/// own bindings for any keys s1 doesn't cover (s1 wins on shared
/// keys). Complexity: O(|s1| + |s2|) — Map iteration + insertion.
public fn kind_compose(s1: &KindSubst, s2: &KindSubst) -> KindSubst {
    let mut out: Map<Text, Kind> = Map.new();
    // Apply s2 to every range value of s1, then keep the binding.
    for (name, kind) in s1.entries.iter() {
        out.insert(name.clone(), kind_apply(s2, kind.clone()));
    }
    // Add bindings from s2 for keys s1 doesn't cover.
    for (name, kind) in s2.entries.iter() {
        if !out.contains_key(name.clone()) {
            out.insert(name.clone(), kind.clone());
        }
    }
    KindSubst { entries: out }
}

/// Does the named kind variable occur anywhere in this kind?
/// Used for the occurs check during unification.
public fn kind_occurs(k: Kind, var_name: Text) -> Bool {
    match k {
        Kind.KVar { name } => name == var_name,
        Kind.KArrow { domain, codomain } =>
            kind_occurs(*domain, var_name.clone()) || kind_occurs(*codomain, var_name),
        _ => false,
    }
}

// =============================================================================
// 3. Unification
// =============================================================================

/// Robinson-style first-order unification on kinds. Returns the
/// most-general substitution that makes `a` and `b` syntactically
/// identical, or a structured `KindError` on mismatch / occurs-
/// check failure.
///
/// ```text
///  KType ~ KType            ↦ ok, ∅
///  KConstraint ~ KConstraint ↦ ok, ∅
///  KArrow(d1, c1) ~ KArrow(d2, c2)
///                           ↦ unify(d1, d2) = s then
///                             unify(s(c1), s(c2)) ∘ s
///  KVar(α) ~ k (k ≠ KVar α) ↦ if α ∈ FV(k) then occurs-check fail
///                             else { α ↦ k }
///  k ~ KVar(α)              ↦ symmetric to the above
///  otherwise                ↦ structural mismatch
/// ```
public fn kind_unify(a: Kind, b: Kind) -> Result<KindSubst, KindError> {
    match (a, b) {
        (Kind.KType, Kind.KType) =>
            Result.Ok(subst_empty()),
        (Kind.KConstraint, Kind.KConstraint) =>
            Result.Ok(subst_empty()),
        (Kind.KArrow { domain: d1, codomain: c1 },
         Kind.KArrow { domain: d2, codomain: c2 }) => {
            let s1 = kind_unify(*d1, *d2)?;
            let s2 = kind_unify(
                kind_apply(&s1, *c1),
                kind_apply(&s1, *c2),
            )?;
            Result.Ok(kind_compose(&s1, &s2))
        },
        (Kind.KVar { name: a_name }, Kind.KVar { name: b_name }) => {
            if a_name == b_name {
                Result.Ok(subst_empty())
            } else {
                Result.Ok(subst_single(a_name, Kind.KVar { name: b_name }))
            }
        },
        (Kind.KVar { name }, k) => bind_var(name, k),
        (k, Kind.KVar { name }) => bind_var(name, k),
        (lhs, rhs) => Result.Err(KindError.Mismatch { lhs, rhs }),
    }
}

/// Bind `var_name ↦ k` after the occurs-check. Refuses self-
/// referential cycles (the classical infinite-type symptom).
fn bind_var(var_name: Text, k: Kind) -> Result<KindSubst, KindError> {
    if kind_occurs(k.clone(), var_name.clone()) {
        return Result.Err(KindError.OccursCheck { var: var_name, in_kind: k });
    }
    Result.Ok(subst_single(var_name, k))
}

// =============================================================================
// 4. Kind application + queries
// =============================================================================

/// The outcome of applying a kind to arguments: the residual kind
/// left after walking the arrow spine, plus the accumulated
/// unifying substitution.
public type KindApplication is {
    result: Kind,
    bindings: KindSubst,
};

/// Apply a kind to a list of argument kinds, walking the KArrow
/// spine left-to-right. Each step requires the head's domain to
/// unify with the next argument; on success the walk continues in
/// the codomain (under the unifying substitution).
///
/// Returns the residual kind and the accumulated substitution —
/// `apply_args(Type → Type, [Type])` yields `result: Type` — or a
/// `KindError` on over-application (more args than arrows) or any
/// pairwise unification failure.
public fn apply_args(k: Kind, args: List<Kind>) -> Result<KindApplication, KindError> {
    let mut current = k;
    let mut acc = subst_empty();
    let mut i: Int = 0;
    while i < args.len() {
        let arg = args[i].clone();
        match current {
            Kind.KArrow { domain, codomain } => {
                let s = kind_unify(*domain, arg)?;
                current = kind_apply(&s, *codomain);
                acc = kind_compose(&acc, &s);
            },
            other => {
                return Result.Err(KindError.OverApplication { kind: other, arg });
            },
        }
        i = i + 1;
    }
    Result.Ok(KindApplication { result: current, bindings: acc })
}

/// True iff every leaf of the kind is a constant (KType /
/// KConstraint), with no free `KVar` anywhere. A concrete kind is
/// what unification eventually produces; non-concrete kinds carry
/// inference unknowns.
public fn is_concrete(k: Kind) -> Bool {
    match k {
        Kind.KType => true,
        Kind.KConstraint => true,
        Kind.KVar { name: _ } => false,
        Kind.KArrow { domain, codomain } =>
            is_concrete(*domain) && is_concrete(*codomain),
    }
}

/// Arity of a kind: number of `KArrow` levels along the right
/// spine. `Type` has arity 0; `Type → Type` has arity 1;
/// `Type → Type → Type` has arity 2; etc.
public fn kind_arity(k: Kind) -> Int {
    match k {
        Kind.KArrow { domain: _, codomain } => 1 + kind_arity(*codomain),
        _ => 0,
    }
}

/// Free kind-variable set of a kind.
public fn free_vars(k: Kind) -> Set<Text> {
    let mut out: Set<Text> = Set.new();
    free_vars_into(k, &mut out);
    out
}

fn free_vars_into(k: Kind, out: &mut Set<Text>) {
    match k {
        Kind.KType => {},
        Kind.KConstraint => {},
        Kind.KVar { name } => { out.insert(name); },
        Kind.KArrow { domain, codomain } => {
            free_vars_into(*domain, out);
            free_vars_into(*codomain, out);
        },
    }
}

// =============================================================================
// Foundation Protocol Impls — Eq + Display + Debug for Kind / KindError
// =============================================================================

implement Eq for Kind {
    fn eq(&self, other: &Kind) -> Bool {
        match (self, other) {
            (Kind.KType, Kind.KType) => true,
            (Kind.KConstraint, Kind.KConstraint) => true,
            (Kind.KVar { name: a }, Kind.KVar { name: b }) => a == b,
            (Kind.KArrow { domain: da, codomain: ca },
             Kind.KArrow { domain: db, codomain: cb }) =>
                **da == **db && **ca == **cb,
            _ => false,
        }
    }
}

implement Display for Kind {
    /// Renders kinds in the standard kind-algebra notation:
    /// `Type`, `Constraint`, `K₁ -> K₂` (right-associated), `κ`.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Kind.KType        => f.write_str("Type"),
            Kind.KConstraint  => f.write_str("Constraint"),
            Kind.KVar { name } => f.write_str(name.as_str()),
            Kind.KArrow { domain, codomain } => {
                // Parenthesise the LHS when it itself is an arrow,
                // so `(K1 -> K2) -> K3` is unambiguous and the
                // default right-association of `->` survives the
                // round-trip.
                let lhs_is_arrow = match **domain {
                    Kind.KArrow { .. } => true,
                    _                  => false,
                };
                if lhs_is_arrow {
                    f.write_str("(")?;
                    (**domain).fmt(f)?;
                    f.write_str(") -> ")?;
                } else {
                    (**domain).fmt(f)?;
                    f.write_str(" -> ")?;
                }
                (**codomain).fmt(f)
            },
        }
    }
}

implement Debug for Kind {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Kind.KType        => f.write_str("KType"),
            Kind.KConstraint  => f.write_str("KConstraint"),
            Kind.KVar { name } =>
                f.write_str(f"KVar({name})".as_str()),
            Kind.KArrow { domain, codomain } => {
                f.write_str("KArrow(")?;
                (**domain).fmt_debug(f)?;
                f.write_str(", ")?;
                (**codomain).fmt_debug(f)?;
                f.write_str(")")
            },
        }
    }
}

implement Eq for KindError {
    fn eq(&self, other: &KindError) -> Bool {
        match (self, other) {
            (KindError.Mismatch { lhs: la, rhs: ra },
             KindError.Mismatch { lhs: lb, rhs: rb }) =>
                la == lb && ra == rb,
            (KindError.OccursCheck { var: va, in_kind: ka },
             KindError.OccursCheck { var: vb, in_kind: kb }) =>
                va == vb && ka == kb,
            (KindError.OverApplication { kind: ka, arg: aa },
             KindError.OverApplication { kind: kb, arg: ab }) =>
                ka == kb && aa == ab,
            _ => false,
        }
    }
}

implement Display for KindError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            KindError.Mismatch { lhs, rhs } =>
                f.write_str(f"kind mismatch: {lhs} ~ {rhs}".as_str()),
            KindError.OccursCheck { var, in_kind } =>
                f.write_str(f"occurs check: {var} ∈ {in_kind}".as_str()),
            KindError.OverApplication { kind, arg } =>
                f.write_str(f"kind over-application: {kind} applied to {arg}".as_str()),
        }
    }
}

implement Debug for KindError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            KindError.Mismatch { lhs, rhs } => {
                f.write_str("Mismatch(")?;
                lhs.fmt_debug(f)?;
                f.write_str(", ")?;
                rhs.fmt_debug(f)?;
                f.write_str(")")
            },
            KindError.OccursCheck { var, in_kind } => {
                f.write_str(f"OccursCheck({var}, ".as_str())?;
                in_kind.fmt_debug(f)?;
                f.write_str(")")
            },
            KindError.OverApplication { kind, arg } => {
                f.write_str("OverApplication(")?;
                kind.fmt_debug(f)?;
                f.write_str(", ")?;
                arg.fmt_debug(f)?;
                f.write_str(")")
            },
        }
    }
}
