// =============================================================================
// qtt.vr — Quantitative Type Theory Resource Tracking
// =============================================================================
//
// Layer: Standard Library / Types
//
// Surface for `verum_types.qtt_usage` + `verum_types.qtt_walker`.
// QTT assigns every binding a *quantity* describing how many
// times it may be used. The type system enforces these counts
// at compile time, preventing resource leaks (Linear used zero
// times) and aliasing violations (Linear used twice).
//
// ## Quantities
//
//   * `Zero`     — erased; usable only at the type level
//   * `One`      — linear; exactly once at runtime
//   * `Many`     — unrestricted; any number of times
//   * `AtMost(n)`— affine; at most n times
//
// =============================================================================

module core.types.qtt;

// =============================================================================
// 1. Quantity algebra
// =============================================================================

/// The quantitative resource annotation on a binding.
public type Quantity is
    | Zero
    | One
    | Many
    | AtMost { n: Int{>= 0} };

/// Saturation threshold for AtMost. Beyond this, `add_quantity` and
/// `mul_quantity` collapse to `Many` rather than computing a giant
/// number that wraps the Int{>= 0} refinement on overflow. 1 << 30 is
/// well past any practical resource count and leaves `na + nb`
/// representable as a positive Int even at the saturation edge.
public const QTT_SATURATION: Int = 1 << 30;

/// Normalise a quantity into canonical form:
///   * `AtMost { n: 0 }` ↔ `Zero` (zero uses allowed in either case)
///   * `AtMost { n: m }` for `m > QTT_SATURATION` collapses to `Many`
///
/// `AtMost { n: 1 }` is intentionally NOT normalised to `One` — they
/// differ semantically: `One` requires exactly one runtime occurrence,
/// `AtMost { n: 1 }` admits zero occurrences too. The lattice isn't
/// total around 1.
public fn normalize_quantity(q: Quantity) -> Quantity {
    match q {
        Quantity.AtMost { n } => {
            if n == 0 { Quantity.Zero }
            else if n > QTT_SATURATION { Quantity.Many }
            else { Quantity.AtMost { n } }
        },
        other => other,
    }
}

/// Does this quantity allow `uses` runtime occurrences?
public fn allows(q: Quantity, uses: Int{>= 0}) -> Bool {
    match q {
        Quantity.Zero => uses == 0,
        Quantity.One => uses == 1,
        Quantity.Many => true,
        Quantity.AtMost { n } => uses <= n,
    }
}

/// Additive composition (sequential composition).
///
/// `add_quantity(p, q)` is the cumulative count when one binding
/// is used `p` times and then `q` times — the natural pattern for
/// `let`-sequencing. Identity is `Zero`; absorbing element is
/// `Many`. SOUNDNESS: arithmetic saturates to `Many` at
/// `QTT_SATURATION` so the `Int{>= 0}` refinement on `AtMost.n` is
/// never violated by overflow on AtMost(big) + AtMost(big). Both
/// inputs and the output are run through `normalize_quantity` so
/// `AtMost(0) + One` correctly returns `One` (was `AtMost(1)` due
/// to skipped Zero-identity short-circuit).
public fn add_quantity(a: Quantity, b: Quantity) -> Quantity {
    let na = normalize_quantity(a);
    let nb = normalize_quantity(b);
    match (na, nb) {
        (Quantity.Zero, q) => q,
        (q, Quantity.Zero) => q,
        (Quantity.Many, _) => Quantity.Many,
        (_, Quantity.Many) => Quantity.Many,
        (Quantity.One, Quantity.One) => Quantity.AtMost { n: 2 },
        (Quantity.AtMost { n: nx }, Quantity.AtMost { n: ny }) =>
            normalize_quantity(saturating_at_most(nx, ny)),
        (Quantity.One, Quantity.AtMost { n }) =>
            normalize_quantity(saturating_at_most(1, n)),
        (Quantity.AtMost { n }, Quantity.One) =>
            normalize_quantity(saturating_at_most(n, 1)),
    }
}

/// `AtMost(a + b)` with saturation to `Many` if `a + b` would
/// exceed `QTT_SATURATION`. Used by `add_quantity`; the saturation
/// limit is well past any practical resource count, so legitimate
/// QTT analyses never hit it.
fn saturating_at_most(a: Int, b: Int) -> Quantity {
    if a > QTT_SATURATION || b > QTT_SATURATION || a > QTT_SATURATION - b {
        Quantity.Many
    } else {
        Quantity.AtMost { n: a + b }
    }
}

/// Multiplicative composition (scaling under a binder).
///
/// When a parameter `x: A` is used `outer` times in the function's
/// body, and `A` itself was bound with quantity `inner`, the
/// effective usage of `A` from the call site is `outer × inner`.
///
/// Identity is `One`. Absorbing element is `Zero`. `Many × q`
/// saturates to `Many` (positive q); `Many × Zero == Zero` because
/// "infinite uses of an erased value" is still erased.
///
/// ```text
///     One  × q     = q                           (identity)
///     q    × One   = q                           (identity)
///     Zero × q     = Zero                        (absorbing)
///     q    × Zero  = Zero                        (absorbing)
///     Many × Many  = Many
///     Many × AtMost(_)   = Many
///     AtMost(_) × Many   = Many
///     AtMost(a) × AtMost(b) = AtMost(a · b)
/// ```
public fn mul_quantity(a: Quantity, b: Quantity) -> Quantity {
    let na = normalize_quantity(a);
    let nb = normalize_quantity(b);
    match (na, nb) {
        (Quantity.Zero, _) => Quantity.Zero,
        (_, Quantity.Zero) => Quantity.Zero,
        (Quantity.One, q) => q,
        (q, Quantity.One) => q,
        (Quantity.Many, _) => Quantity.Many,
        (_, Quantity.Many) => Quantity.Many,
        (Quantity.AtMost { n: nx }, Quantity.AtMost { n: ny }) =>
            normalize_quantity(saturating_mul_at_most(nx, ny)),
    }
}

/// `AtMost(a · b)` with saturation to `Many` if the product would
/// exceed `QTT_SATURATION`. Mirrors `saturating_at_most` for the
/// multiplicative direction.
fn saturating_mul_at_most(a: Int, b: Int) -> Quantity {
    // Reject `a * b > QTT_SATURATION` without computing the product
    // (avoids the Int overflow itself).
    if a == 0 || b == 0 {
        return Quantity.Zero;   // multiplicative absorbing
    }
    if a > QTT_SATURATION / b {
        Quantity.Many
    } else {
        Quantity.AtMost { n: a * b }
    }
}

/// Most-permissive quantity. Convenient for inference initial
/// state ("this binding can be anywhere from never to many times")
/// and for default annotations.
public fn top_quantity() -> Quantity {
    Quantity.Many
}

/// Least-permissive non-vacuous quantity — `Zero` is "may not
/// appear at runtime". Useful as an `add_quantity` identity.
public fn bottom_quantity() -> Quantity {
    Quantity.Zero
}

/// Subquantity ordering: `is_sub(a, b)` is true iff every usage
/// pattern allowed by `a` is also allowed by `b`. The lattice is:
///
/// ```text
///     Zero  ≤  One  ≤  AtMost(n)  ≤  Many
///                         ⌣
///                  (AtMost(n) ≤ AtMost(m) when n ≤ m)
/// ```
///
/// Used by inference to decide when to promote a binding's
/// declared quantity to a more permissive one (e.g. coercing a
/// `One` argument into a `Many` parameter is sound, the other way
/// is not).
public fn is_sub(a: Quantity, b: Quantity) -> Bool {
    // Normalise so AtMost(0) is treated identically to Zero — the two
    // are semantically equivalent (both admit only zero uses) but the
    // raw match on the unnormalised pair would route AtMost(0) into
    // the AtMost arms and miss the obvious case `AtMost(0) ≤ Zero`.
    let na = normalize_quantity(a);
    let nb = normalize_quantity(b);
    match (na, nb) {
        (Quantity.Zero, _) => true,
        (_, Quantity.Many) => true,
        (Quantity.Many, _) => false,
        (Quantity.One, Quantity.Zero) => false,
        (Quantity.One, Quantity.One) => true,
        (Quantity.One, Quantity.AtMost { n }) => n >= 1,
        // AtMost(n) admits zero uses, so it's never ≤ Zero (n > 0
        // by post-normalisation) nor ≤ One (One forbids zero uses).
        (Quantity.AtMost { n: _ }, Quantity.Zero) => false,
        (Quantity.AtMost { n: _ }, Quantity.One) => false,
        (Quantity.AtMost { n: nx }, Quantity.AtMost { n: ny }) => nx <= ny,
    }
}

/// Equality on quantities — the partial-order's antisymmetry
/// witness. `quantity_eq(a, b)` iff `is_sub(a, b) && is_sub(b, a)`.
public fn quantity_eq(a: Quantity, b: Quantity) -> Bool {
    let na = normalize_quantity(a);
    let nb = normalize_quantity(b);
    match (na, nb) {
        (Quantity.Zero, Quantity.Zero) => true,
        (Quantity.One, Quantity.One) => true,
        (Quantity.Many, Quantity.Many) => true,
        (Quantity.AtMost { n: nx }, Quantity.AtMost { n: ny }) => nx == ny,
        _ => false,
    }
}

// =============================================================================
// 2. Usage tracking
// =============================================================================

/// Observed usage count for a single binding.
public type UsageCount is { runtime: Int{>= 0} };

/// A single usage-tracked binding and its declared quantity.
public type TrackedBinding is {
    name: Text,
    declared: Quantity,
};

// =============================================================================
// 3. Violation detection
// =============================================================================

/// A QTT violation: a binding used more (or fewer for Linear)
/// times than its quantity allows.
public type QttViolation is
    /// Used more times than allowed.
    | OverUse { binding: Text, observed: Int, declared: Quantity }
    /// Linear binding used zero times (resource leak).
    | UnderUse { binding: Text, declared: Quantity }
    /// Erased binding referenced at runtime.
    | ErasedUsedAtRuntime { binding: Text };

/// Check a single binding against its observed usage. Normalises
/// the declared quantity first so `AtMost(0)` collapses to the
/// `Zero` arm and produces `ErasedUsedAtRuntime` for any observed
/// runtime occurrence — was producing the more generic `OverUse`
/// for the same case.
public fn check_binding(name: Text, declared: Quantity, observed: Int{>= 0}) -> Maybe<QttViolation> {
    let normalized = normalize_quantity(declared);
    match normalized {
        Quantity.Zero => {
            if observed > 0 {
                Some(QttViolation.ErasedUsedAtRuntime { binding: name })
            } else { None }
        },
        Quantity.One => {
            if observed == 0 {
                Some(QttViolation.UnderUse { binding: name, declared: normalized })
            } else if observed > 1 {
                Some(QttViolation.OverUse { binding: name, observed, declared: normalized })
            } else { None }
        },
        Quantity.Many => None,
        Quantity.AtMost { n } => {
            if observed > n {
                Some(QttViolation.OverUse { binding: name, observed, declared: normalized })
            } else { None }
        },
    }
}
