// =============================================================================
// session.vr вЂ” Session-typed channel protocols
// =============================================================================
//
// Layer: Standard Library / Concurrency
//
// User-facing surface for the session-types analysis core
// (`verum_types.session_types`). A session type describes the
// sequence of sends, receives, and choices that two communicating
// parties must perform on a shared channel; the type system can
// statically rule out deadlocks, protocol mismatches, and
// linearity violations.
//
// ## Design
//
// Each protocol step is exposed as a value-level constructor on the
// `Protocol` type. A channel handle carries a *phantom protocol*
// type-parameter that advances after each operation, so the type
// system tracks remaining-protocol statically.
//
// ## Example
//
// ```verum
// // A simple echo protocol: client sends Int, server replies Int.
// let echo: Protocol = Protocol.send("Int", Protocol.recv("Int", Protocol.end()));
//
// // The dual is an automatic compute:
// let server: Protocol = echo.dual();
//
// // Compatibility is the deadlock-freedom predicate.
// assert(echo.compatible_with(server));
// ```
//
// =============================================================================

module core.concurrency.session;

// =============================================================================
// 1. The protocol algebra
// =============================================================================

/// A session-type protocol вЂ” a value-level reflection of the
/// remaining steps a channel end must perform. The type system
/// pairs this with a channel handle so that compile-time checking
/// can verify every send/recv matches the declared protocol.
public type Protocol is
    /// `!T. Rest` вЂ” send a value of type `T`, then continue as `Rest`.
    | Send { payload: Text, rest: Heap<Protocol> }
    /// `?T. Rest` вЂ” receive a value of type `T`, then continue as `Rest`.
    | Recv { payload: Text, rest: Heap<Protocol> }
    /// `Sв‚Ѓ вЉ• Sв‚‚` вЂ” offer the other party a choice between `left` and `right`.
    | Offer { left: Heap<Protocol>, right: Heap<Protocol> }
    /// `Sв‚Ѓ & Sв‚‚` вЂ” select between `left` and `right` ourselves.
    | Select { left: Heap<Protocol>, right: Heap<Protocol> }
    /// `end` вЂ” protocol complete.
    | End;

// =============================================================================
// 2. Smart constructors
// =============================================================================

/// Build a `Send` step.
public fn send(payload: Text, rest: Protocol) -> Protocol {
    Protocol.Send { payload, rest: Heap(rest) }
}

/// Build a `Recv` step.
public fn recv(payload: Text, rest: Protocol) -> Protocol {
    Protocol.Recv { payload, rest: Heap(rest) }
}

/// Build an `Offer` (external choice).
public fn offer(left: Protocol, right: Protocol) -> Protocol {
    Protocol.Offer { left: Heap(left), right: Heap(right) }
}

/// Build a `Select` (internal choice).
public fn select(left: Protocol, right: Protocol) -> Protocol {
    Protocol.Select { left: Heap(left), right: Heap(right) }
}

/// Terminated protocol.
public fn end() -> Protocol {
    Protocol.End
}

// =============================================================================
// 3. Duality
// =============================================================================

/// Return the *dual* protocol: sendв†”recv, offerв†”select, endв†”end.
/// `dual(dual(p)) == p` (involution).
public fn dual(p: Protocol) -> Protocol {
    match p {
        Protocol.Send { payload, rest } => Protocol.Recv {
            payload,
            rest: Heap(dual(*rest)),
        },
        Protocol.Recv { payload, rest } => Protocol.Send {
            payload,
            rest: Heap(dual(*rest)),
        },
        Protocol.Offer { left, right } => Protocol.Select {
            left: Heap(dual(*left)),
            right: Heap(dual(*right)),
        },
        Protocol.Select { left, right } => Protocol.Offer {
            left: Heap(dual(*left)),
            right: Heap(dual(*right)),
        },
        Protocol.End => Protocol.End,
    }
}

// =============================================================================
// 4. Compatibility (deadlock-freedom)
// =============================================================================

/// Two protocols are *compatible* iff one is the dual of the other.
/// When both ends of a channel use compatible protocols, the
/// channel is deadlock-free.
public fn compatible(a: Protocol, b: Protocol) -> Bool {
    let d = dual(a);
    protocols_equal(d, b)
}

/// Structural equality on protocols.
public fn protocols_equal(a: Protocol, b: Protocol) -> Bool {
    match (a, b) {
        (Protocol.Send { payload: pa, rest: ra },
         Protocol.Send { payload: pb, rest: rb }) =>
            pa == pb && protocols_equal(*ra, *rb),
        (Protocol.Recv { payload: pa, rest: ra },
         Protocol.Recv { payload: pb, rest: rb }) =>
            pa == pb && protocols_equal(*ra, *rb),
        (Protocol.Offer { left: la, right: ra },
         Protocol.Offer { left: lb, right: rb }) =>
            protocols_equal(*la, *lb) && protocols_equal(*ra, *rb),
        (Protocol.Select { left: la, right: ra },
         Protocol.Select { left: lb, right: rb }) =>
            protocols_equal(*la, *lb) && protocols_equal(*ra, *rb),
        (Protocol.End, Protocol.End) => true,
        (_, _) => false,
    }
}
