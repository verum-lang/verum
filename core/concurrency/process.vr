// =============================================================================
// process.vr — π-calculus Process Algebra
// =============================================================================
//
// Layer: Standard Library / Concurrency
//
// User-facing surface for the π-calculus analysis core
// (`verum_types.pi_calculus`). Milner's π-calculus models mobile
// concurrent processes where channels are first-class values that
// can be sent over other channels — modelling dynamic network
// topology, not just a fixed set of communication paths.
//
// Where `core/concurrency/session.vr` describes a *single channel's
// protocol*, this module describes the *entire interaction
// pattern* between concurrently executing parties.
//
// ## Syntax
//
// ```text
//     P, Q ::= 0                  (terminated process)
//            | P | Q              (parallel composition)
//            | (νx) P             (restriction: x is fresh in P)
//            | x⟨y⟩.P             (send y on x, continue as P)
//            | x(y).P             (recv on x, bind to y, continue as P)
//            | !P                 (replication: ∞ copies of P)
// ```
//
// ## COMM rule
//
// ```text
//     x⟨y⟩.P  |  x(z).Q   →   P  |  Q[y/z]
// ```
//
// =============================================================================

module core.concurrency.process;

mount core.*;
mount core.collections.set.{Set};
mount core.collections.map.{Map};

// =============================================================================
// 1. The process algebra
// =============================================================================

/// A π-calculus process.
public type Process is
    /// `0` — terminated.
    | Zero
    /// `P | Q` — parallel composition.
    | Par { left: Heap<Process>, right: Heap<Process> }
    /// `(νx) P` — restriction; `x` is bound and fresh in `P`.
    | Restrict { name: Text, body: Heap<Process> }
    /// `x⟨y⟩.P` — send `message` on `channel`, continue as `cont`.
    | Send { channel: Text, message: Text, cont: Heap<Process> }
    /// `x(z).P` — receive on `channel`, bind to `binder`, continue.
    | Recv { channel: Text, binder: Text, cont: Heap<Process> }
    /// `!P` — replication.
    | Replicate { inner: Heap<Process> };

// =============================================================================
// 2. Smart constructors
// =============================================================================

public fn proc_zero() -> Process {
    Process.Zero
}

public fn proc_par(p: Process, q: Process) -> Process {
    Process.Par { left: Heap(p), right: Heap(q) }
}

public fn proc_restrict(name: Text, body: Process) -> Process {
    Process.Restrict { name, body: Heap(body) }
}

public fn proc_send(channel: Text, message: Text, cont: Process) -> Process {
    Process.Send { channel, message, cont: Heap(cont) }
}

public fn proc_recv(channel: Text, binder: Text, cont: Process) -> Process {
    Process.Recv { channel, binder, cont: Heap(cont) }
}

public fn proc_replicate(inner: Process) -> Process {
    Process.Replicate { inner: Heap(inner) }
}

// =============================================================================
// 3. Capture-avoiding substitution
// =============================================================================

/// Collect free names of a process into `out`.
///
/// A name is *free* iff it occurs as a channel / message / object
/// position outside the scope of any (νx) or x(y) that binds it.
/// `substitute` uses this to detect — and α-rename around — binders
/// that would otherwise capture the substituted value.
public fn free_names(p: &Process, out: &mut Set<Text>) {
    match p {
        Process.Zero => {},
        Process.Par { left, right } => {
            free_names(left, out);
            free_names(right, out);
        },
        Process.Restrict { name, body } => {
            // Body's free names minus `name` (bound here).
            let mut body_fv: Set<Text> = Set.new();
            free_names(body, &mut body_fv);
            body_fv.remove(name.clone());
            for n in body_fv.iter() { out.insert(n.clone()); }
        },
        Process.Send { channel, message, cont } => {
            out.insert(channel.clone());
            out.insert(message.clone());
            free_names(cont, out);
        },
        Process.Recv { channel, binder, cont } => {
            out.insert(channel.clone());
            // Continuation's free names minus `binder`.
            let mut cont_fv: Set<Text> = Set.new();
            free_names(cont, &mut cont_fv);
            cont_fv.remove(binder.clone());
            for n in cont_fv.iter() { out.insert(n.clone()); }
        },
        Process.Replicate { inner } => free_names(inner, out),
    }
}

/// Pick a name based on `base` that is NOT in `avoid`. Appends
/// successive primes until a fresh candidate is found. Deterministic
/// — the same `(base, avoid)` always yields the same fresh name.
fn fresh_name(base: Text, avoid: &Set<Text>) -> Text {
    let mut candidate = base + "'";
    while avoid.contains(candidate.clone()) {
        candidate = candidate + "'";
    }
    candidate
}

/// Choose a fresh binder name that doesn't collide with `from`,
/// `to`, or any free name of `body`. Used by the α-rename branches
/// of `substitute`.
fn alpha_rename_avoiding(
    base: &Text,
    from: &Text,
    to:   &Text,
    body: &Process,
) -> Text {
    let mut avoid: Set<Text> = Set.new();
    free_names(body, &mut avoid);
    avoid.insert(from.clone());
    avoid.insert(to.clone());
    fresh_name(base.clone(), &avoid)
}

/// Substitute `from` with `to` in every free position of `p`.
///
/// SOUNDNESS: capture-avoiding. When a binder `(νx)` or `x(y)` would
/// otherwise capture a substituted occurrence (i.e. `binder == to`
/// and `binder != from`), the binder is α-renamed to a fresh name
/// before the substitution descends into its scope. Without this,
/// `substitute((νto) from.0, from, to)` would produce `(νto) to.0`
/// where the inner `to` is bound by the outer `(νto)` — silently
/// changing the process semantics. The α-rename preserves the
/// observational meaning of the bound subterm.
public fn substitute(p: Process, from: Text, to: Text) -> Process {
    match p {
        Process.Zero => Process.Zero,
        Process.Par { left, right } => proc_par(
            substitute(*left, from.clone(), to.clone()),
            substitute(*right, from, to),
        ),
        Process.Restrict { name, body } => {
            if name == from {
                // Binder shadows `from` — body has no free `from`.
                p
            } else if name == to {
                // Binder would capture: α-rename first.
                let fresh = alpha_rename_avoiding(&name, &from, &to, &*body);
                let renamed = substitute(*body, name, fresh.clone());
                proc_restrict(fresh, substitute(renamed, from, to))
            } else {
                proc_restrict(name, substitute(*body, from, to))
            }
        },
        Process.Send { channel, message, cont } => {
            let new_ch = if channel == from { to.clone() } else { channel };
            let new_msg = if message == from { to.clone() } else { message };
            proc_send(new_ch, new_msg, substitute(*cont, from, to))
        },
        Process.Recv { channel, binder, cont } => {
            let new_ch = if channel == from { to.clone() } else { channel };
            if binder == from {
                // Binder shadows `from` inside cont.
                proc_recv(new_ch, binder, *cont)
            } else if binder == to {
                // Binder would capture: α-rename first.
                let fresh = alpha_rename_avoiding(&binder, &from, &to, &*cont);
                let renamed = substitute(*cont, binder, fresh.clone());
                proc_recv(new_ch, fresh, substitute(renamed, from, to))
            } else {
                proc_recv(new_ch, binder, substitute(*cont, from, to))
            }
        },
        Process.Replicate { inner } => proc_replicate(substitute(*inner, from, to)),
    }
}

// =============================================================================
// 4. α-equivalence (proper notion of process equality)
// =============================================================================
//
// `Eq` (below) is structural / syntactic — `(νx) P` and `(νy) P[x:=y]`
// compare unequal even though they denote the same process. The
// canonical π-calculus equivalence is α-equivalence: two processes
// are equal iff they differ only in the choice of bound names.
//
// ## Algorithm
//
// De Bruijn levels by parallel walk: as the walker descends into
// `Restrict { name, body }` or `Recv { binder, cont }`, the binder
// in `p` and the binder in `q` are bound to the SAME fresh
// integer level (the current depth). Free names compare by
// identity (textual equality); bound names compare by their
// recorded depth. The two environments stay in step at every
// binder, so syntactically-different bound names that occupy
// the same de Bruijn position compare equal.
//
// ## Properties
//
//   * Reflexive:  `alpha_eq(p, p)`               for every `p`.
//   * Symmetric:  `alpha_eq(p, q) ↔ alpha_eq(q, p)`.
//   * Transitive: `alpha_eq(p, q) ∧ alpha_eq(q, r) → alpha_eq(p, r)`.
//   * Substitutive: `alpha_eq(p, substitute(p, b, fresh))` whenever
//     `b` is a binder in `p` and `fresh` is fresh for `p`.
//
// All four follow from the parallel-walk structure: every binder
// in either side gets the same depth, and every leaf compares the
// same depth-or-textual rule on both sides.
//
// ## Complexity
//
// O(min(|p|, |q|)) walks with O(d) per-binder cost where `d` is
// nesting depth — env extension is a `Map<Text, Int>` insert. No
// allocation beyond the per-binder cloning of the immutable env
// snapshots passed down to subterms.

/// Alpha-equivalence on π-calculus processes.
///
/// Returns `true` iff `p` and `q` denote the same process up to
/// renaming of bound names. Use this in preference to `==` when
/// comparing processes that may have been α-renamed by
/// `substitute`'s capture-avoiding logic, or when comparing
/// theorems / lemmas that quantify over processes.
///
/// # Examples
///
/// ```verum
/// // Different binder names, same denotation.
/// let p = proc_restrict("x", proc_send("x", "msg", proc_zero()));
/// let q = proc_restrict("y", proc_send("y", "msg", proc_zero()));
/// assert(alpha_eq(&p, &q));
/// assert(p != q); // structural Eq disagrees, as documented.
///
/// // Free names must still match textually.
/// let r = proc_send("free_chan", "msg", proc_zero());
/// let s = proc_send("other_chan", "msg", proc_zero());
/// assert(!alpha_eq(&r, &s));
/// ```
public fn alpha_eq(p: &Process, q: &Process) -> Bool {
    let env_p: Map<Text, Int> = Map.new();
    let env_q: Map<Text, Int> = Map.new();
    alpha_eq_inner(p, q, &env_p, &env_q, 0)
}

/// Internal walker — see the section header for the algorithm.
///
/// `env_p[name] = level` means `name` is bound in `p` at the given
/// de Bruijn level. Same for `env_q`. Levels are only meaningful
/// across MATCHING positions in the two terms — the parallel walk
/// invariant guarantees that any binder we reach in one side
/// corresponds to the binder at the same depth in the other.
fn alpha_eq_inner(
    p: &Process,
    q: &Process,
    env_p: &Map<Text, Int>,
    env_q: &Map<Text, Int>,
    depth: Int,
) -> Bool {
    match (p, q) {
        (Process.Zero, Process.Zero) => true,
        (Process.Par { left: la, right: ra },
         Process.Par { left: lb, right: rb }) => {
            alpha_eq_inner(la, lb, env_p, env_q, depth)
                && alpha_eq_inner(ra, rb, env_p, env_q, depth)
        },
        (Process.Restrict { name: na, body: ba },
         Process.Restrict { name: nb, body: bb }) => {
            // Bind both binders to the SAME level so leaf
            // references resolve identically inside the bodies.
            let mut new_env_p: Map<Text, Int> = clone_env(env_p);
            let mut new_env_q: Map<Text, Int> = clone_env(env_q);
            let _ = new_env_p.insert(na.clone(), depth);
            let _ = new_env_q.insert(nb.clone(), depth);
            alpha_eq_inner(ba, bb, &new_env_p, &new_env_q, depth + 1)
        },
        (Process.Send { channel: ca, message: ma, cont: ka },
         Process.Send { channel: cb, message: mb, cont: kb }) => {
            name_eq_under_env(ca, cb, env_p, env_q)
                && name_eq_under_env(ma, mb, env_p, env_q)
                && alpha_eq_inner(ka, kb, env_p, env_q, depth)
        },
        (Process.Recv { channel: ca, binder: bna, cont: ka },
         Process.Recv { channel: cb, binder: bnb, cont: kb }) => {
            // Channel resolves under the OUTER env; the binder
            // only enters scope inside the continuation.
            if !name_eq_under_env(ca, cb, env_p, env_q) {
                return false;
            }
            let mut new_env_p: Map<Text, Int> = clone_env(env_p);
            let mut new_env_q: Map<Text, Int> = clone_env(env_q);
            let _ = new_env_p.insert(bna.clone(), depth);
            let _ = new_env_q.insert(bnb.clone(), depth);
            alpha_eq_inner(ka, kb, &new_env_p, &new_env_q, depth + 1)
        },
        (Process.Replicate { inner: ia },
         Process.Replicate { inner: ib }) => {
            alpha_eq_inner(ia, ib, env_p, env_q, depth)
        },
        // Variant mismatch — different process shapes can't be
        // α-equivalent regardless of binders.
        _ => false,
    }
}

/// Compare two leaf names under the parallel walk's binding
/// environments.
///
///   * Both bound at same level → equal (the binders introduced
///     them at the same parallel depth).
///   * Both free (not in env)   → must match textually (free
///     names are a global namespace shared across both sides).
///   * One bound, one free      → unequal (different binding
///     status).
fn name_eq_under_env(
    a: &Text,
    b: &Text,
    env_a: &Map<Text, Int>,
    env_b: &Map<Text, Int>,
) -> Bool {
    match (env_a.get_optional(a.clone()), env_b.get_optional(b.clone())) {
        (Some(la), Some(lb)) => la == lb,
        (None, None)         => a == b,
        _                    => false,
    }
}

/// Snapshot the binding environment for descent into a binder's
/// scope. The snapshot allows the parent's env to remain
/// unchanged when the recursion returns — siblings don't share
/// the binder's scope.
fn clone_env(env: &Map<Text, Int>) -> Map<Text, Int> {
    let mut out: Map<Text, Int> = Map.new();
    let mut iter = env.iter();
    loop {
        match iter.next() {
            Some((k, v)) => { let _ = out.insert(k.clone(), *v); },
            None         => break,
        }
    }
    out
}

// =============================================================================
// 5. Foundation Protocol Impls — Display + Debug + Eq for Process
// =============================================================================

implement Eq for Process {
    /// Structural (syntactic) equality on π-calculus processes.
    /// Note: this is *not* α-equivalence — `(νx) P` and `(νy) P[x:=y]`
    /// compare unequal under this Eq even though they denote the
    /// same process.  Use `alpha_eq` (section 4 above) for the
    /// proper π-calculus equivalence; callers that need α-canonical
    /// form should normalise via `substitute` first.
    fn eq(&self, other: &Process) -> Bool {
        match (self, other) {
            (Process.Zero, Process.Zero) => true,
            (Process.Par { left: la, right: ra },
             Process.Par { left: lb, right: rb }) =>
                **la == **lb && **ra == **rb,
            (Process.Restrict { name: na, body: ba },
             Process.Restrict { name: nb, body: bb }) =>
                na == nb && **ba == **bb,
            (Process.Send { channel: ca, message: ma, cont: ka },
             Process.Send { channel: cb, message: mb, cont: kb }) =>
                ca == cb && ma == mb && **ka == **kb,
            (Process.Recv { channel: ca, binder: ba, cont: ka },
             Process.Recv { channel: cb, binder: bb, cont: kb }) =>
                ca == cb && ba == bb && **ka == **kb,
            (Process.Replicate { inner: ia },
             Process.Replicate { inner: ib }) =>
                **ia == **ib,
            _ => false,
        }
    }
}

implement Display for Process {
    /// Renders a process in standard π-calculus notation:
    ///   `0`           — terminated
    ///   `P | Q`       — parallel
    ///   `(νx)P`       — restriction
    ///   `x<y>.P`      — send
    ///   `x(z).P`      — receive
    ///   `!P`          — replication
    ///
    /// Parentheses are inserted around `Par` arguments to disambiguate
    /// from outer combinators; the default left-association of `|`
    /// is preserved.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Process.Zero => f.write_str("0"),
            Process.Par { left, right } => {
                f.write_str("(")?;
                (**left).fmt(f)?;
                f.write_str(" | ")?;
                (**right).fmt(f)?;
                f.write_str(")")
            },
            Process.Restrict { name, body } => {
                f.write_str(f"(ν{name})".as_str())?;
                (**body).fmt(f)
            },
            Process.Send { channel, message, cont } => {
                f.write_str(f"{channel}<{message}>.".as_str())?;
                (**cont).fmt(f)
            },
            Process.Recv { channel, binder, cont } => {
                f.write_str(f"{channel}({binder}).".as_str())?;
                (**cont).fmt(f)
            },
            Process.Replicate { inner } => {
                f.write_str("!")?;
                (**inner).fmt(f)
            },
        }
    }
}

implement Debug for Process {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Process.Zero => f.write_str("Zero"),
            Process.Par { left, right } => {
                f.write_str("Par(")?;
                (**left).fmt_debug(f)?;
                f.write_str(", ")?;
                (**right).fmt_debug(f)?;
                f.write_str(")")
            },
            Process.Restrict { name, body } => {
                f.write_str(f"Restrict({name}, ".as_str())?;
                (**body).fmt_debug(f)?;
                f.write_str(")")
            },
            Process.Send { channel, message, cont } => {
                f.write_str(f"Send({channel}, {message}, ".as_str())?;
                (**cont).fmt_debug(f)?;
                f.write_str(")")
            },
            Process.Recv { channel, binder, cont } => {
                f.write_str(f"Recv({channel}, {binder}, ".as_str())?;
                (**cont).fmt_debug(f)?;
                f.write_str(")")
            },
            Process.Replicate { inner } => {
                f.write_str("Replicate(")?;
                (**inner).fmt_debug(f)?;
                f.write_str(")")
            },
        }
    }
}
