// =============================================================================
// core.action.effects — Kleisli-category effect catalogue (Theorem 17.T1)
// =============================================================================
//
// Effects in Verum are postulated as projections of the linear-articulation
// 2-category Perf(α_linear) per Theorem 17.T1: every classical effect
// monad embeds into the Kleisli category of α_linear, and Verum's
// effect annotations are exactly that embedding read off in syntax.
//
// The catalogue below ships:
//
//   • A canonical Monad protocol with `pure` / `bind`.
//   • A StrongMonad protocol extending Monad with `strength`.
//   • A `Commutative` marker protocol (no extra methods) gating the
//     concurrent-coherence theorem (Theorem 17.C2).
//   • Eight standard effects with their classifications:
//
//     ┌──────────────────────────┬──────────────┬────────────────┐
//     │ Effect                   │ Classification│ ε-coordinate   │
//     ├──────────────────────────┼──────────────┼────────────────┤
//     │ Pure                     │ commutative  │ 0              │
//     │ Reader<R>                │ commutative  │ ω              │
//     │ Writer<W: Monoid>        │ commutative  │ ω              │
//     │ Probability<A>           │ commutative  │ ω              │
//     │ List<A>                  │ commutative  │ ω              │
//     │ State<S>                 │ NON-commute  │ ω + 1          │
//     │ Exception<E>             │ NON-commute  │ ω + 1          │
//     │ Io<A>                    │ NON-commute  │ ω + 1          │
//     └──────────────────────────┴──────────────┴────────────────┘
//
//   • Concurrent coherence theorem: parallel composition of
//     commutative-monad-only programs preserves the @verify(coherent)
//     verdict (Corollary 17.C2). Non-commutative effects require
//     explicit synchronization to retain coherence.
//
// V0 (this file) ships the protocol surface + 8 effect declarations;
// each effect has `pure` / `bind` signatures, with bodies as trusted-
// boundary placeholders. V1 wires concrete monad implementations
// (functor instances + monad laws) per the Kleisli construction.
// =============================================================================

mount core.action.articulation.{Articulation};
mount core.action.enactments.{Enactment};

// =============================================================================
// Monad / StrongMonad protocols
// =============================================================================

/// Standard monad protocol. Every effect type implements it.
public type Monad is protocol {
    /// Lift a pure value into the effect.
    fn pure<A>(self, a: A) -> Self;

    /// Sequence two effectful computations.
    fn bind<A, B>(self, f: fn(A) -> Self) -> Self;
};

/// Strong monad — extends Monad with strength operator allowing
/// commutation with cartesian products (canonical for any cartesian
/// monad; Moggi 1991 §2).
public type StrongMonad is protocol {
    /// Strength: tensor a pure value into an effectful one.
    fn strength<A, B>(self, a: A) -> Self;
};

/// Marker protocol — no methods. Tagging an effect type
/// `@derive(Commutative)` records that the monad satisfies the
/// commutativity law `T(A) ⊗ T(B) ≃ T(B) ⊗ T(A)` (Plotkin-Power
/// 2002), gating the concurrent-coherence corollary.
public type Commutative is protocol {};

// =============================================================================
// Eight standard effect declarations
// =============================================================================

/// **Note**: The eight per-effect commutativity / ε-coordinate
/// theorems below were V1 framework-citation axioms (`-> Bool ensures
/// true`); V2 promotes them to structural theorems whose ensures
/// clauses route through the `EffectKind` runtime classifier
/// (`is_commutative_effect` / `effect_epsilon_coord` defined below).
/// The classifier is the single source of truth for the Theorem 17.T1
/// commutativity assignments, so the theorems are decidable by
/// construction — each one asserts that the classifier returns the
/// spec-prescribed bucket for its specific `EffectKind`. The runtime
/// semantics drive the `@verify(coherent)` gate; the theorems pin
/// the framework-citation alignment.

/// **Pure — identity effect** (Theorem 17.T1, ν = 0): `is_commutative_effect(PureEffect) == true`.
@enact(epsilon = "0")
@framework(diakrisis, "Theorem 17.T1 (Pure: identity effect; ν = 0)")
public theorem effect_pure_is_commutative() -> Bool
    requires true
    ensures  is_commutative_effect(EffectKind.PureEffect)
          && effect_epsilon_coord(EffectKind.PureEffect) == Text.from("0")
{
    proof {
        // is_commutative_effect's PureEffect arm returns true;
        // effect_epsilon_coord's PureEffect arm returns "0".
        // Both decidable by structural pattern-match.
        true
    }
}

/// **Reader<R> — environment read** (Theorem 17.T1, ν = ω).
@enact(epsilon = "ω")
@framework(diakrisis, "Theorem 17.T1 (Reader<R>: commutative; ν = ω)")
public theorem effect_reader_is_commutative() -> Bool
    requires true
    ensures  is_commutative_effect(EffectKind.ReaderEffect)
          && effect_epsilon_coord(EffectKind.ReaderEffect) == Text.from("ω")
{
    proof { true }
}

/// **Writer<W: CommutativeMonoid>** (Theorem 17.T1, ν = ω):
/// commutative IFF the underlying monoid is. The classifier
/// returns the unconditional bucket (Writer is on the commutative
/// list); the conditional witness is the
/// `writer_commutativity_iff_monoid_commutative` theorem in
/// `core.action.monads.writer`.
@enact(epsilon = "ω")
@framework(diakrisis, "Theorem 17.T1 (Writer<W: CommutativeMonoid>: commutative; ν = ω)")
public theorem effect_writer_commutative_iff_monoid_commutative() -> Bool
    requires true
    ensures  is_commutative_effect(EffectKind.WriterEffect)
          && effect_epsilon_coord(EffectKind.WriterEffect) == Text.from("ω")
{
    proof { true }
}

/// **Probability<A>** (Theorem 17.T1, ν = ω): commutative under
/// independent tensor (Plotkin-Power 2002 Example 2.4).
@enact(epsilon = "ω")
@framework(diakrisis, "Theorem 17.T1 (Probability: commutative under independent tensor; ν = ω)")
public theorem effect_probability_is_commutative() -> Bool
    requires true
    ensures  is_commutative_effect(EffectKind.ProbabilityEffect)
          && effect_epsilon_coord(EffectKind.ProbabilityEffect) == Text.from("ω")
{
    proof { true }
}

/// **List<A>** (Theorem 17.T1, ν = ω): non-deterministic choice;
/// commutative under cartesian product.
@enact(epsilon = "ω")
@framework(diakrisis, "Theorem 17.T1 (List: commutative; ν = ω)")
public theorem effect_list_is_commutative() -> Bool
    requires true
    ensures  is_commutative_effect(EffectKind.ListEffect)
          && effect_epsilon_coord(EffectKind.ListEffect) == Text.from("ω")
{
    proof { true }
}

/// **State<S> — NON-commutative** (Theorem 17.T1, ν = ω + 1).
@enact(epsilon = "ω + 1")
@framework(diakrisis, "Theorem 17.T1 (State<S>: NON-commutative; ν = ω + 1)")
public theorem effect_state_is_not_commutative() -> Bool
    requires true
    ensures  !is_commutative_effect(EffectKind.StateEffect)
          && effect_epsilon_coord(EffectKind.StateEffect) == Text.from("ω + 1")
{
    proof {
        // is_commutative_effect's StateEffect arm returns false;
        // negation of the call equals true. Decidable by pattern-match.
        // The negative-commutativity SEPARATING WITNESS lives in
        // `core.action.monads.state::state_is_not_commutative`.
        true
    }
}

/// **Exception<E> — NON-commutative** (Theorem 17.T1, ν = ω + 1).
@enact(epsilon = "ω + 1")
@framework(diakrisis, "Theorem 17.T1 (Exception<E>: NON-commutative; ν = ω + 1)")
public theorem effect_exception_is_not_commutative() -> Bool
    requires true
    ensures  !is_commutative_effect(EffectKind.ExceptionEffect)
          && effect_epsilon_coord(EffectKind.ExceptionEffect) == Text.from("ω + 1")
{
    proof { true }
}

/// **Io<A> — NON-commutative** (Theorem 17.T1, ν = ω + 1).
@enact(epsilon = "ω + 1")
@framework(diakrisis, "Theorem 17.T1 (Io<A>: NON-commutative; ν = ω + 1)")
public theorem effect_io_is_not_commutative() -> Bool
    requires true
    ensures  !is_commutative_effect(EffectKind.IoEffect)
          && effect_epsilon_coord(EffectKind.IoEffect) == Text.from("ω + 1")
{
    proof { true }
}

// =============================================================================
// Concurrent-coherence corollary (Theorem 17.C2)
// =============================================================================

/// The parallel composition of two commutative-effect programs
/// preserves the @verify(coherent) verdict: if `p1 |> verify(coherent)
/// == OK` and `p2 |> verify(coherent) == OK` and both have only
/// commutative effects, then `parallel(p1, p2) |> verify(coherent)
/// == OK`.
///
/// Non-commutative effects break this invariant: `parallel(state_op_1,
/// state_op_2)` may have observable race conditions even when each
/// individual op verifies.
///
/// V2 form (this commit): structural theorem routing through
/// `parallel_coherent` — the runtime classifier gate that the
/// V1 axiom referenced indirectly. The theorem asserts: if every
/// effect in `kinds` is commutative, then the parallel composition
/// is `coherent`. Decidable by case analysis over EffectKind.
@framework(diakrisis, "Corollary 17.C2 (concurrent coherence under commutative effects)")
public theorem concurrent_coherence_under_commutativity(kinds: List<EffectKind>) -> Bool
    requires parallel_coherent(kinds.clone())
    ensures  parallel_coherent(kinds)
{
    proof {
        // The requires-clause is the ensures-clause — the theorem
        // documents the policy gate explicitly: under the hypothesis
        // that every effect commutes, the parallel composition
        // preserves @verify(coherent). The runtime gate
        // `parallel_coherent` decides this in O(|kinds|) by walking
        // each kind through is_commutative_effect.
        true
    }
}

// =============================================================================
// V8 (#244) — runtime-queryable effect classifier surface
//
// The eight axioms above record each effect's commutativity +
// ε-coordinate classification per Theorem 17.T1. Pre-#244 those
// classifications were trapped inside axiom *names* — user code
// that wanted to ask "is `Probability` commutative?" had no
// stable surface to query. The enum + predicates below close that
// gap: every effect maps to a single `EffectKind` value, and the
// classifier predicates return the spec-prescribed bucket.
// =============================================================================

/// The eight standard effects classified by Theorem 17.T1. Used by
/// concurrent-coherence audit (Corollary 17.C2 / verify(coherent))
/// and ε-coordinate-aware planners to interrogate an effect's
/// algebraic properties without re-parsing axiom names.
@derive(Clone)
public type EffectKind is
    PureEffect
  | ReaderEffect
  | WriterEffect
  | ProbabilityEffect
  | ListEffect
  | StateEffect
  | ExceptionEffect
  | IoEffect;

/// True iff the effect's monad is commutative under tensor
/// product. Per Theorem 17.T1: Pure / Reader / Writer (when
/// monoid is commutative) / Probability (under independent
/// tensor) / List (under cartesian product) all commute;
/// State / Exception / Io do not.
///
/// This is the gate for Corollary 17.C2 — parallel composition
/// preserves @verify(coherent) iff every effect in either branch
/// satisfies this predicate.
public fn is_commutative_effect(kind: EffectKind) -> Bool {
    match kind {
        PureEffect        => true,
        ReaderEffect      => true,
        WriterEffect      => true,
        ProbabilityEffect => true,
        ListEffect        => true,
        StateEffect       => false,
        ExceptionEffect   => false,
        IoEffect          => false,
    }
}

/// Diakrisis ε-coordinate for the effect, per Theorem 17.T1.
/// `Pure` lives at coordinate 0 (no observable enactment);
/// every other commutative effect lives at ω; non-commutative
/// effects (State / Exception / Io) live at ω + 1 because the
/// non-commutativity introduces ordinal-irreducible
/// dependency on action-order.
public fn effect_epsilon_coord(kind: EffectKind) -> Text {
    match kind {
        PureEffect        => "0",
        ReaderEffect      => "ω",
        WriterEffect      => "ω",
        ProbabilityEffect => "ω",
        ListEffect        => "ω",
        StateEffect       => "ω + 1",
        ExceptionEffect   => "ω + 1",
        IoEffect          => "ω + 1",
    }
}

/// Canonical name for audit / JSON-RPC emission.
public fn effect_kind_name(kind: EffectKind) -> Text {
    match kind {
        PureEffect        => "Pure",
        ReaderEffect      => "Reader",
        WriterEffect      => "Writer",
        ProbabilityEffect => "Probability",
        ListEffect        => "List",
        StateEffect       => "State",
        ExceptionEffect   => "Exception",
        IoEffect          => "Io",
    }
}

/// True iff a program composed entirely of `kinds` would preserve
/// the `@verify(coherent)` verdict under parallel composition
/// (Corollary 17.C2). Implementation: every kind must satisfy
/// `is_commutative_effect`. Empty input is vacuously coherent
/// (the trivial empty program parallels-composes with anything).
public fn parallel_coherent(kinds: List<EffectKind>) -> Bool {
    let mut i: Int = 0;
    while i < kinds.len() as Int {
        if !is_commutative_effect(*kinds.get(i as Int).unwrap()) {
            return false;
        }
        i = i + 1;
    }
    true
}

// =============================================================================
// Foundation Protocol Impls — Display + Debug + Eq for EffectKind
// =============================================================================

implement Eq for EffectKind {
    fn eq(&self, other: &EffectKind) -> Bool {
        match (self, other) {
            (EffectKind.PureEffect,        EffectKind.PureEffect)        => true,
            (EffectKind.ReaderEffect,      EffectKind.ReaderEffect)      => true,
            (EffectKind.WriterEffect,      EffectKind.WriterEffect)      => true,
            (EffectKind.ProbabilityEffect, EffectKind.ProbabilityEffect) => true,
            (EffectKind.ListEffect,        EffectKind.ListEffect)        => true,
            (EffectKind.StateEffect,       EffectKind.StateEffect)       => true,
            (EffectKind.ExceptionEffect,   EffectKind.ExceptionEffect)   => true,
            (EffectKind.IoEffect,          EffectKind.IoEffect)          => true,
            _ => false,
        }
    }
}

implement Copy for EffectKind {}

implement Display for EffectKind {
    /// Renders the effect with its algebraic family name in
    /// lowercase, suitable for audit logs and verify(coherent)
    /// diagnostic surfaces:
    ///   `PureEffect`        → `pure`
    ///   `ReaderEffect`      → `reader`
    ///   `WriterEffect`      → `writer`
    ///   `ProbabilityEffect` → `probability`
    ///   `ListEffect`        → `list`
    ///   `StateEffect`       → `state`
    ///   `ExceptionEffect`   → `exception`
    ///   `IoEffect`          → `io`
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            EffectKind.PureEffect        => f.write_str("pure"),
            EffectKind.ReaderEffect      => f.write_str("reader"),
            EffectKind.WriterEffect      => f.write_str("writer"),
            EffectKind.ProbabilityEffect => f.write_str("probability"),
            EffectKind.ListEffect        => f.write_str("list"),
            EffectKind.StateEffect       => f.write_str("state"),
            EffectKind.ExceptionEffect   => f.write_str("exception"),
            EffectKind.IoEffect          => f.write_str("io"),
        }
    }
}

implement Debug for EffectKind {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            EffectKind.PureEffect        => f.write_str("PureEffect"),
            EffectKind.ReaderEffect      => f.write_str("ReaderEffect"),
            EffectKind.WriterEffect      => f.write_str("WriterEffect"),
            EffectKind.ProbabilityEffect => f.write_str("ProbabilityEffect"),
            EffectKind.ListEffect        => f.write_str("ListEffect"),
            EffectKind.StateEffect       => f.write_str("StateEffect"),
            EffectKind.ExceptionEffect   => f.write_str("ExceptionEffect"),
            EffectKind.IoEffect          => f.write_str("IoEffect"),
        }
    }
}
