// =============================================================================
// core.action.primitives — eight primitive acts (Diakrisis Actic §1 + §21)
// =============================================================================
//
// Seven canonical Diakrisis Actic primitives + ε_classify (added per the
// Diakrisis ↔ Noesis ↔ Verum cross-audit recommendation #3 — needed by
// the OWL 2 V1 ecosystem for ontology classification / subsumption /
// instance-check obligations that don't fit cleanly into the original
// seven primitives).
//
// VVA §21.3 routes every OWL 2 reasoning task through `@verify(...)` —
// `ε_classify` lets the @enact attribute carry the Actic dual coordinate
// for the function performing that reasoning. Functions decorated with
// `@enact(epsilon = "ε_classify")` are recognised by `verum audit
// --epsilon` as ontology-classification work; downstream tooling
// (Noesis NP `ontology/classify` endpoint per audit recommendation #4)
// reads this distribution to gate which functions are surfaced as DL
// reasoners.
// =============================================================================

@derive(Clone)
public type Primitive is
    EpsilonMath
  | EpsilonCompute
  | EpsilonObserve
  | EpsilonProve
  | EpsilonDecide
  | EpsilonTranslate
  | EpsilonConstruct
  | EpsilonClassify;

public fn primitive_as_text(e: Primitive) -> Text {
    match e {
        EpsilonMath      => "ε_math",
        EpsilonCompute   => "ε_compute",
        EpsilonObserve   => "ε_observe",
        EpsilonProve     => "ε_prove",
        EpsilonDecide    => "ε_decide",
        EpsilonTranslate => "ε_translate",
        EpsilonConstruct => "ε_construct",
        EpsilonClassify  => "ε_classify",
    }
}

public fn is_observational(e: Primitive) -> Bool {
    match e {
        EpsilonObserve => true,
        _              => false,
    }
}

public fn is_constructive(e: Primitive) -> Bool {
    match e {
        EpsilonConstruct => true,
        EpsilonMath      => true,
        EpsilonCompute   => true,
        _                => false,
    }
}

public fn is_proof_producing(e: Primitive) -> Bool {
    match e {
        EpsilonProve => true,
        _            => false,
    }
}

public fn is_decision_point(e: Primitive) -> Bool {
    match e {
        EpsilonDecide => true,
        _             => false,
    }
}

public fn is_translation(e: Primitive) -> Bool {
    match e {
        EpsilonTranslate => true,
        _                => false,
    }
}

/// True iff the primitive is an *ontology-classification* act —
/// subsumption, instance check, classification hierarchy walk. The
/// Diakrisis Actic catalogue extension that pairs with the OWL 2
/// V1 ecosystem (VVA §21).
public fn is_classification(e: Primitive) -> Bool {
    match e {
        EpsilonClassify => true,
        _               => false,
    }
}

public fn primitive_eq(a: Primitive, b: Primitive) -> Bool {
    primitive_as_text(a).eq(primitive_as_text(b))
}

// =============================================================================
// Foundation Protocol Impls — Display + Debug + Eq + Copy for Primitive
// =============================================================================

implement Eq for Primitive {
    /// Variant-form equality across the 8-tag ε-primitive space.
    /// Wraps the existing `primitive_eq` standalone function so
    /// `==` works directly without forcing callers to import the
    /// free function.
    fn eq(&self, other: &Primitive) -> Bool {
        match (self, other) {
            (Primitive.EpsilonMath,      Primitive.EpsilonMath)      => true,
            (Primitive.EpsilonCompute,   Primitive.EpsilonCompute)   => true,
            (Primitive.EpsilonObserve,   Primitive.EpsilonObserve)   => true,
            (Primitive.EpsilonProve,     Primitive.EpsilonProve)     => true,
            (Primitive.EpsilonDecide,    Primitive.EpsilonDecide)    => true,
            (Primitive.EpsilonTranslate, Primitive.EpsilonTranslate) => true,
            (Primitive.EpsilonConstruct, Primitive.EpsilonConstruct) => true,
            (Primitive.EpsilonClassify,  Primitive.EpsilonClassify)  => true,
            _ => false,
        }
    }
}

implement Copy for Primitive {}

implement Display for Primitive {
    /// Renders as the canonical ε-tag (`ε_math`, `ε_compute`, …)
    /// matching `primitive_as_text` so audit logs and proof-
    /// coordinate diagnostics speak the literature's language.
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(primitive_as_text(*self).as_str())
    }
}

implement Debug for Primitive {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Primitive.EpsilonMath      => f.write_str("EpsilonMath"),
            Primitive.EpsilonCompute   => f.write_str("EpsilonCompute"),
            Primitive.EpsilonObserve   => f.write_str("EpsilonObserve"),
            Primitive.EpsilonProve     => f.write_str("EpsilonProve"),
            Primitive.EpsilonDecide    => f.write_str("EpsilonDecide"),
            Primitive.EpsilonTranslate => f.write_str("EpsilonTranslate"),
            Primitive.EpsilonConstruct => f.write_str("EpsilonConstruct"),
            Primitive.EpsilonClassify  => f.write_str("EpsilonClassify"),
        }
    }
}
