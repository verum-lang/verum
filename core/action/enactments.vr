// =============================================================================
// core.action.enactments — composition, activation modality A, α ⊣ ε
// =============================================================================
//
// Each Enactment carries the Articulation it enacts (VVA §11.3).  The
// adjunction α ⊣ ε is realised by the pair `epsilon : Articulation →
// Enactment` and `alpha_of : Enactment → Articulation`; for any
// articulation α we have `alpha_of(epsilon(α)) ≡ α`, witnessed by
// `is_adjoint(α, epsilon(α))`.
// =============================================================================

@derive(Clone)
public type Enactment is {
    name:            Text,
    steps:           List<Primitive>,
    activation_rank: Int,
    articulation:    Articulation,
};

public fn primitive_enact(e: Primitive) -> Enactment {
    let mut steps: List<Primitive> = List.new();
    steps.push(e);
    Enactment {
        name:            primitive_as_text(e),
        steps:           steps,
        activation_rank: 0,
        articulation:    primitive_articulation(e),
    }
}

public fn identity_enact() -> Enactment {
    Enactment {
        name:            "id_ε",
        steps:           List.new(),
        activation_rank: 0,
        articulation:    raw_actic_articulation(),
    }
}

public fn compose(a: Enactment, b: Enactment) -> Enactment {
    let mut joined: List<Primitive> = a.steps.clone();
    let mut i: Int = 0;
    while i < b.steps.len() as Int {
        joined.push(*b.steps.get(i as Int).unwrap());
        i = i + 1;
    }
    let rank: Int = if a.activation_rank >= b.activation_rank {
        a.activation_rank
    } else {
        b.activation_rank
    };
    // Composition keeps a's articulation when both are raw; if either
    // side carries a non-raw articulation, that one wins (Actic absorbs
    // into the articulated side).  When both are non-raw and distinct,
    // the result becomes raw to flag the gauge mismatch.
    let articulation: Articulation = if is_raw_actic(a.articulation.clone()) {
        b.articulation.clone()
    } else if is_raw_actic(b.articulation.clone()) {
        a.articulation.clone()
    } else if articulation_eq(a.articulation.clone(), b.articulation.clone()) {
        a.articulation.clone()
    } else {
        raw_actic_articulation()
    };
    Enactment {
        name:            a.name.concat(" ∘ ").concat(b.name.clone()),
        steps:           joined,
        activation_rank: rank,
        articulation:    articulation,
    }
}

public fn activation(e: Enactment) -> Enactment {
    Enactment {
        name:            e.name,
        steps:           e.steps,
        activation_rank: e.activation_rank + 1,
        articulation:    e.articulation,
    }
}

public fn activation_iterate(e: Enactment, k: Int) -> Enactment {
    if k <= 0 {
        return e.clone();
    }
    Enactment {
        name:            e.name.clone(),
        steps:           e.steps.clone(),
        activation_rank: e.activation_rank + k,
        articulation:    e.articulation.clone(),
    }
}

public let AUTOPOIETIC_THRESHOLD: Int = 64;

public fn is_autopoietic(e: Enactment) -> Bool {
    e.activation_rank >= AUTOPOIETIC_THRESHOLD
}

// -----------------------------------------------------------------------------
// α ⊣ ε adjunction (VVA §11.3)
// -----------------------------------------------------------------------------

/// `epsilon(α) = (F, Syn(F), id, id)` — syntactic self-enactment of an
/// articulation (Diakrisis 108.T auto-induced).
public fn epsilon(alpha: Articulation) -> Enactment {
    Enactment {
        name:            "ε(".concat(articulation_as_text(alpha.clone())).concat(")"),
        steps:           List.new(),
        activation_rank: 0,
        articulation:    alpha,
    }
}

/// `alpha_of(e) = e.articulation` — left adjoint to `epsilon`.
public fn alpha_of(e: Enactment) -> Articulation {
    e.articulation
}

/// Witness for the unit / counit of α ⊣ ε:
///   `is_adjoint(α, e)` ⇔ `alpha_of(e) ≡ α`.
public fn is_adjoint(alpha: Articulation, e: Enactment) -> Bool {
    articulation_eq(alpha, alpha_of(e))
}

// -----------------------------------------------------------------------------
// V8 (#234) — Round-trip witnesses for α ⊣ ε (VVA §11.3 + Diakrisis 108.T)
// -----------------------------------------------------------------------------

/// V8 (#234) — round-trip witness `α → ε(α) → α`.
///
/// Per Diakrisis 108.T (the AC ↔ OC duality theorem), the auto-induced
/// epsilon-functor + alpha-of-functor form an adjunction, so:
///
///     alpha_of(epsilon(α)) ≡ α   for every articulation α.
///
/// This function returns `true` iff that round-trip identity holds for
/// the supplied articulation. Used as a runtime invariant check and as
/// the unit-of-the-adjunction witness.
public fn alpha_epsilon_alpha_roundtrip(alpha: Articulation) -> Bool {
    let recovered: Articulation = alpha_of(epsilon(alpha.clone()));
    articulation_eq(alpha, recovered)
}

/// V8 (#234) — counit witness for the α ⊣ ε adjunction. Per
/// Diakrisis 108.T the counit `ε ∘ α → 1` is an isomorphism;
/// for the auto-induced ε this reduces to: every enactment
/// constructed via `epsilon(α)` satisfies `epsilon(alpha_of(e)) ≡ e`
/// when `e` originated from auto-induction (i.e., its activation_rank
/// is 0 and steps is empty — the canonical syntactic self-enactment
/// shape).
public fn epsilon_alpha_epsilon_roundtrip_for_auto_induced(e: Enactment) -> Bool {
    let recovered: Enactment = epsilon(alpha_of(e.clone()));
    // For auto-induced enactments the structural fields match exactly.
    e.activation_rank == recovered.activation_rank
        && articulation_eq(e.articulation, recovered.articulation)
}

// -----------------------------------------------------------------------------
// Canonical Diakrisis-spelling aliases (12-actic/09-verum-stdlib-sketch.md)
// -----------------------------------------------------------------------------
//
// The Diakrisis Verum-stdlib sketch (`12-actic/09-verum-stdlib-sketch.md` §2)
// prescribes the following names; we ship them as direct aliases of the
// existing operations so user code can be written against either Diakrisis-
// canonical names or Verum-historic ones. Comparison `enact_par` is new
// (Diakrisis prescribes it as parallel composition `A || B`).

/// Sequential composition: `A then B`.  Alias of `compose`.
public fn enact_then(a: Enactment, b: Enactment) -> Enactment {
    compose(a, b)
}

/// Parallel composition: `A || B`.  Both enactments contribute their
/// step-lists; activation rank is the maximum of both; articulations
/// follow the same absorption rule as `compose`.
///
/// At this stdlib layer parallelism is *structural* — there is no
/// process-calculus-style interleaving — so `enact_par` is currently
/// observationally identical to `compose`.  The two are kept as separate
/// public surface so future refinements (true CCS-style parallelism with
/// a different gauge canonicalisation) can specialise `enact_par` without
/// breaking call sites that already chose semantic intent.
public fn enact_par(a: Enactment, b: Enactment) -> Enactment {
    let merged: Enactment = compose(a.clone(), b.clone());
    Enactment {
        name:            a.name.clone().concat(" ∥ ").concat(b.name),
        steps:           merged.steps,
        activation_rank: merged.activation_rank,
        articulation:    merged.articulation,
    }
}

/// A-modality activation.  Alias of `activation`.
public fn activate(e: Enactment) -> Enactment {
    activation(e)
}

/// Transfinite-bounded activation by a finite step count.  Alias of
/// `activation_iterate`. The Diakrisis sketch types `n: Ordinal`; we
/// currently restrict to a finite Int so the kernel can decide
/// termination at compile time. Transfinite n requires an Ordinal
/// argument and is tracked as a follow-up to the §10.4 Ordinal-type
/// promotion.
public fn activate_n(e: Enactment, n: Int) -> Enactment {
    activation_iterate(e, n)
}

/// Autopoietic closure: the A^{ω²} fixed-point operation. For an
/// enactment past the autopoietic threshold (`is_autopoietic(e) == true`)
/// returns `canonicalise(e)` — the gauge-canonical representative which
/// witnesses the fixed-point.  Below the threshold returns `e` unchanged
/// so the operation is a closure on the autopoietic sub-class without
/// silently coercing partial enactments.
///
/// This pairs with the Diakrisis sketch's `verify_autopoiesis` (which
/// lives at the @verify-decorator layer); the closure operation is
/// *the operational* counterpart.
public fn autopoiesis(e: Enactment) -> Enactment {
    if is_autopoietic(e.clone()) {
        return canonicalise(e);
    }
    e
}
