// =============================================================================
// core.action.gauge — gauge freedom on enactments
// =============================================================================

fn sort_observational_runs(steps: List<Primitive>) -> List<Primitive> {
    let mut result: List<Primitive> = List.new();
    let mut i: Int = 0;
    while i < steps.len() as Int {
        let step: &Primitive = steps.get(i as Int).unwrap();
        let last_is_observe: Bool = if result.is_empty() {
            false
        } else {
            matches_observe(result.last().unwrap())
        };
        let this_is_observe: Bool = matches_observe(step);
        if last_is_observe && this_is_observe {
            // absorb duplicate observation
        } else {
            result.push(*step);
        }
        i = i + 1;
    }
    result
}

fn matches_observe(p: &Primitive) -> Bool {
    match p {
        EpsilonObserve => true,
        _              => false,
    }
}

public fn canonicalise(e: Enactment) -> Enactment {
    if e.steps.is_empty() {
        // Identity collapses into the canonical Actic identity but
        // preserves the originating articulation so α ⊣ ε is stable
        // across canonicalisation.
        return Enactment {
            name:            "id_ε",
            steps:           List.new(),
            activation_rank: 0,
            articulation:    e.articulation,
        };
    }
    let sorted: List<Primitive> = sort_observational_runs(e.steps.clone());
    Enactment {
        name:            "ε_canonical",
        steps:           sorted,
        activation_rank: e.activation_rank,
        articulation:    e.articulation,
    }
}

public fn gauge_equivalent(a: Enactment, b: Enactment) -> Bool {
    let ca: Enactment = canonicalise(a);
    let cb: Enactment = canonicalise(b);
    enactment_eq(ca, cb)
}

fn enactment_eq(a: Enactment, b: Enactment) -> Bool {
    if a.activation_rank != b.activation_rank { return false; }
    if a.steps.len() != b.steps.len() { return false; }
    let mut i: Int = 0;
    while i < a.steps.len() as Int {
        if !primitive_eq(*a.steps.get(i as Int).unwrap(),
                         *b.steps.get(i as Int).unwrap()) {
            return false;
        }
        i = i + 1;
    }
    true
}

// =============================================================================
// §11.4 (#243) — gauge invariants + audit helpers
//
// Invariants surfaced as predicates so callers can `assert(...)` them
// in tests without poking the internal canonical-form representation.
// All three are stable contracts that downstream code (CLI audit,
// IDE plugins, Noesis NP server) can depend on.
// =============================================================================

/// Number of steps in `e`'s canonical form. Used by the streaming
/// coherence monitor + audit reporters to track how much
/// observational redundancy a freshly-recorded enactment carries.
public fn canonical_size(e: Enactment) -> Int {
    canonicalise(e).steps.len() as Int
}

/// True iff `e` is already in canonical form (i.e. canonicalising it
/// is the identity). Equivalent to `gauge_equivalent(e, e) ∧
/// canonical_size(e) == e.steps.len()` but cheaper at one canonicalise
/// step instead of two.
public fn is_canonical(e: Enactment) -> Bool {
    let canonicalised: Enactment = canonicalise(e.clone());
    enactment_eq(canonicalised, e)
}

/// Idempotency witness — `canonicalise(canonicalise(e)) ≡
/// canonicalise(e)`. Returned as a Bool so test harnesses can pin it
/// without depending on the canonical-form's internal name field.
public fn canonicalise_idempotent(e: Enactment) -> Bool {
    let once: Enactment  = canonicalise(e);
    let twice: Enactment = canonicalise(once.clone());
    enactment_eq(once, twice)
}
