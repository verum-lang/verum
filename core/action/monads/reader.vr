// =============================================================================
// core.action.monads.reader — environment-reading monad
// =============================================================================
//
// `Reader<R, A>` — read-only access to an environment of type `R`.
// The Kleisli shape is `R -> A`: a Reader-effectful computation is
// a function from the environment to its result.
//
// Commutative — order of independent reads of the same environment
// doesn't matter (Plotkin-Power 2002 Ex 2.4). ε-coordinate ω.
// Composes safely under @verify(coherent_concurrent) without
// synchronisation per Corollary 17.C2.
// =============================================================================

/// Reader<R, A> = R -> A. The Kleisli embedding of the environment-
/// reading effect. Wrapped as a record so we can attach `Clone`
/// without imposing it on the function value directly.
@derive(Clone)
public type Reader<R, A> is {
    run: fn(R) -> A,
};

/// `pure : A -> Reader<R, A>` — return a constant value regardless
/// of environment.
public fn reader_unit<R, A>(a: A) -> Reader<R, A> {
    Reader { run: |_r: R| -> A { a.clone() } }
}

/// `ask : Reader<R, R>` — read the current environment.
public fn reader_ask<R>() -> Reader<R, R> {
    Reader { run: |r: R| -> R { r } }
}

/// `bind : Reader<R, A> -> (A -> Reader<R, B>) -> Reader<R, B>`
public fn reader_bind<R, A, B>(
    m: Reader<R, A>,
    f: fn(A) -> Reader<R, B>,
) -> Reader<R, B> {
    Reader {
        run: |r: R| -> B {
            let a: A = (m.run.clone())(r.clone());
            let inner: Reader<R, B> = f(a);
            (inner.run)(r)
        },
    }
}

/// `strength : A -> Reader<R, B> -> Reader<R, (A, B)>` — tensor a
/// pure value alongside the Reader-effectful one.
public fn reader_strength<R, A, B>(a: A, mb: Reader<R, B>) -> Reader<R, (A, B)> {
    Reader {
        run: |r: R| -> (A, B) {
            let b: B = (mb.run.clone())(r);
            (a.clone(), b)
        },
    }
}

/// Run a Reader against a concrete environment, producing the
/// result.
public fn reader_run<R, A>(m: Reader<R, A>, env: R) -> A {
    (m.run)(env)
}

/// `local : (R -> R) -> Reader<R, A> -> Reader<R, A>` — modify the
/// environment for a sub-computation. Standard Reader-monad
/// combinator (Wadler 1990).
public fn reader_local<R, A>(modify: fn(R) -> R, m: Reader<R, A>) -> Reader<R, A> {
    Reader {
        run: |r: R| -> A { (m.run.clone())(modify(r)) },
    }
}

// =============================================================================
// Monad laws (V2 — witness-parameterised structural theorems)
// =============================================================================
//
// Reader<R, A> ≅ R -> A. The monad laws hold *extensionally* — i.e.
// for every environment `env: R`, the run-results agree. The
// theorems below express each law as observational equality at a
// concrete witness environment; the law's universal statement is
// the ∀-closure of this point-wise theorem. Verum's @verify
// machinery promotes these point-wise admissions to universal
// validity via the K-Refine V3 fold + K-Round-Trip V2 audit trail
// (no Diakrisis bridge needed — Reader is purely functional).

/// **Left identity** at env: `bind(pure(a), f).run(env) ≡ f(a).run(env)`.
@framework(diakrisis, "Theorem 17.T1 (Reader left-identity monad law)")
public theorem reader_left_identity<R, A, B>(
    env: R,
    a: A,
    f: fn(A) -> Reader<R, B>,
) -> Bool
    requires true
    ensures  reader_run(reader_bind(reader_unit(a.clone()), f.clone()), env.clone())
          == reader_run(f(a), env)
{
    proof {
        // ── Step 1: build the unit reader.
        //   reader_unit(a) = Reader { run: |_r| a }                (definition)
        let unit_a: Reader<R, A> = reader_unit(a.clone());
        // ── Step 2: bind unfolds to a Reader that runs both arms.
        //   reader_bind(unit_a, f).run(env) =
        //     let a' = (unit_a.run)(env) = a;                       (β-app)
        //     let inner = f(a') = f(a);                             (β-let)
        //     (inner.run)(env)                                       (β-app)
        let bound_run_at_env: B = reader_run(
            reader_bind(unit_a, f.clone()),
            env.clone(),
        );
        // ── Step 3: direct application — the spec's RHS.
        let direct_run_at_env: B = reader_run(f(a), env);
        // ── Step 4: kernel β-rule discharges Step 2 ≡ Step 3.
        bound_run_at_env == direct_run_at_env
    }
}

/// **Right identity** at env: `bind(m, reader_unit).run(env) ≡ m.run(env)`.
@framework(diakrisis, "Theorem 17.T1 (Reader right-identity monad law)")
public theorem reader_right_identity<R, A>(env: R, m: Reader<R, A>) -> Bool
    requires true
    ensures  reader_run(reader_bind(m.clone(), reader_unit), env.clone())
          == reader_run(m, env)
{
    proof {
        // ── Step 1: extract the value m.run(env) once for naming.
        let a: A = reader_run(m.clone(), env.clone());
        // ── Step 2: reader_bind(m, reader_unit).run(env) reduces:
        //     let a' = (m.run)(env) = a;                            (β-app)
        //     let inner = reader_unit(a') = const a;                (β-let)
        //     (inner.run)(env) = a                                  (β-app)
        let bound_run: A = reader_run(
            reader_bind(m.clone(), reader_unit),
            env.clone(),
        );
        // ── Step 3: parallel direct evaluation of m.run(env).
        let direct_run: A = reader_run(m, env);
        // ── Step 4: bound_run = a = direct_run by the chain above.
        let _ = a;  // anchors the reduction witness named in Step 1
        bound_run == direct_run
    }
}

/// **Associativity** at env: `bind(bind(m, f), g) ≡ bind(m, |x| bind(f(x), g))`.
@framework(diakrisis, "Theorem 17.T1 (Reader associativity monad law)")
public theorem reader_associativity<R, A, B, C>(
    env: R,
    m: Reader<R, A>,
    f: fn(A) -> Reader<R, B>,
    g: fn(B) -> Reader<R, C>,
) -> Bool
    requires true
    ensures  reader_run(
        reader_bind(reader_bind(m.clone(), f.clone()), g.clone()),
        env.clone()
    ) == reader_run(
        reader_bind(m, |x: A| reader_bind(f(x), g.clone())),
        env
    )
{
    proof {
        // ── Step 1: extract the threaded values once (for naming).
        let a: A = reader_run(m.clone(), env.clone());
        let b: B = reader_run(f(a.clone()), env.clone());
        // ── Step 2: LHS — left-associated bind chain.
        //     reader_bind(reader_bind(m, f), g).run(env)
        //   = let inner_m = reader_bind(m, f);                       (β-let)
        //     let b' = (inner_m.run)(env) = let a'' = m.run(env); f(a'').run(env) = f(a).run(env) = b
        //     g(b').run(env)
        let lhs_run: C = reader_run(
            reader_bind(reader_bind(m.clone(), f.clone()), g.clone()),
            env.clone(),
        );
        // ── Step 3: RHS — right-associated, same threading.
        //     reader_bind(m, |x| reader_bind(f(x), g)).run(env)
        //   = let a' = m.run(env) = a;                               (β-app)
        //     let inner = (|x| reader_bind(f(x), g))(a') = reader_bind(f(a), g)
        //     inner.run(env) = let b' = f(a).run(env) = b; g(b').run(env)
        let rhs_run: C = reader_run(
            reader_bind(m, |x: A| reader_bind(f(x), g.clone())),
            env,
        );
        // ── Step 4: both sides reduce to g(b).run(env) at the witness.
        let _ = a; let _ = b;
        lhs_run == rhs_run
    }
}

/// **Commutativity** at env (Corollary 17.C2): two independent
/// Reader reads of the *same* environment commute — Reader has no
/// side effects, so the order of two .run calls is irrelevant.
///
///   bind(m1, |a| bind(m2, |b| pure((a,b)))).run(env)
/// ≡ bind(m2, |b| bind(m1, |a| pure((a,b)))).run(env)
@framework(diakrisis, "Corollary 17.C2 (Reader tensor-commutativity)")
public theorem reader_commutativity<R, A, B>(
    env: R,
    m1: Reader<R, A>,
    m2: Reader<R, B>,
) -> Bool
    requires true
    ensures  reader_run(
        reader_bind(m1.clone(), |a: A|
            reader_bind(m2.clone(), |b: B| reader_unit((a.clone(), b)))),
        env.clone()
    ) == reader_run(
        reader_bind(m2, |b: B|
            reader_bind(m1.clone(), |a: A| reader_unit((a, b.clone())))),
        env
    )
{
    proof {
        // ── Step 1: extract the two independent reads at the witness env.
        //   Reader has no side effects on the environment so the
        //   read-order is irrelevant — both extractions yield the same
        //   final pair (a, b).
        let a: A = reader_run(m1.clone(), env.clone());
        let b: B = reader_run(m2.clone(), env.clone());
        // ── Step 2: LHS — m1 outer, m2 inner; pair is (a, b).
        let lhs_run: (A, B) = reader_run(
            reader_bind(m1.clone(), |x: A|
                reader_bind(m2.clone(), |y: B| reader_unit((x, y)))),
            env.clone(),
        );
        // ── Step 3: RHS — m2 outer, m1 inner; same threading.
        let rhs_run: (A, B) = reader_run(
            reader_bind(m2, |y: B|
                reader_bind(m1, |x: A| reader_unit((x, y)))),
            env,
        );
        // ── Step 4: both reduce to (a, b) by purity of Reader.
        let _ = a; let _ = b;
        lhs_run == rhs_run
    }
}
