// =============================================================================
// core.action.monads.writer — append-only output monad
// =============================================================================
//
// `Writer<W, A>` — pair of an output buffer of type `W` (required to
// be a monoid via combine + zero) with a result of type `A`. The
// Kleisli shape is `(A, W)`: a Writer computation produces both a
// value and a side-output.
//
// Commutative *iff* the underlying monoid `W` is commutative
// (additive monoids over numeric types are; sequence concatenation
// is NOT). ε-coordinate ω. The protocol-level Commutative marker is
// instantiated only for the commutative-monoid case; non-commutative
// monoid Writer-effectful programs are NOT admitted under
// @verify(coherent_concurrent) without explicit synchronisation.
// =============================================================================

/// Writer<W, A> = (A, W). Pair of a result and an output log.
@derive(Clone)
public type Writer<W, A> is {
    value: A,
    output: W,
};

/// `pure : zero -> A -> Writer<W, A>` — wrap a value with the empty
/// output (the monoid identity). The caller supplies `zero`
/// explicitly because Verum's protocol surface for monoidal
/// identity is per-corpus rather than universal.
public fn writer_unit<W, A>(a: A, zero: W) -> Writer<W, A> {
    Writer {
        value: a,
        output: zero,
    }
}

/// `tell : W -> Writer<W, ()>` — append `w` to the output log,
/// producing a unit value.
public fn writer_tell<W>(w: W) -> Writer<W, ()> {
    Writer {
        value: (),
        output: w,
    }
}

/// `bind : Writer<W, A> -> (A -> Writer<W, B>) -> (W, W) -> W -> Writer<W, B>`
/// — sequence two writer computations, combining their outputs via
/// the supplied monoid operation `combine`.
///
/// V1 takes `combine` explicitly to avoid baking in a specific
/// monoid; V1.5 will introduce a `Monoid<W>` protocol that the
/// generic bind can resolve at elaboration time.
public fn writer_bind<W, A, B>(
    m: Writer<W, A>,
    f: fn(A) -> Writer<W, B>,
    combine: fn(W, W) -> W,
) -> Writer<W, B> {
    let inner: Writer<W, B> = f(m.value);
    Writer {
        value: inner.value,
        output: combine(m.output, inner.output),
    }
}

/// `strength : A -> Writer<W, B> -> Writer<W, (A, B)>` — tensor a
/// pure value alongside the Writer-effectful one. Output is
/// preserved unchanged.
public fn writer_strength<W, A, B>(a: A, mb: Writer<W, B>) -> Writer<W, (A, B)> {
    Writer {
        value: (a, mb.value),
        output: mb.output,
    }
}

/// `run : Writer<W, A> -> (A, W)` — extract the value-and-output pair.
public fn writer_run<W, A>(m: Writer<W, A>) -> (A, W) {
    (m.value, m.output)
}

/// `censor : (W -> W) -> Writer<W, A> -> Writer<W, A>` — apply a
/// transformation to the output log without changing the value.
/// Standard Writer combinator (Wadler 1990).
public fn writer_censor<W, A>(f: fn(W) -> W, m: Writer<W, A>) -> Writer<W, A> {
    Writer {
        value: m.value,
        output: f(m.output),
    }
}

// =============================================================================
// Monad laws (V2 — witness-parameterised structural theorems with monoid premises)
// =============================================================================
//
// Writer<W, A> = (A, W). Each law's STRUCTURAL part (value
// projection) reduces decidably; the OUTPUT part requires the
// monoid identity / associativity / commutativity hypothesis on W.
// V2 encodes those hypotheses as `requires` clauses checked by the
// caller, then ships a structural ensures clause expressing what
// the monad law actually claims.
//
// The output equality `==` on W is decidable for any concrete W;
// callers that instantiate with non-Eq output types pass an
// extensional equality witness (Diakrisis A-1).

/// **Left identity** (Theorem 17.T1, modulo monoid identity):
///   `bind(unit(a, zero), f, combine) ≡ f(a)`
/// requires `combine(zero, w) = w` for all w (left-identity of W).
@framework(diakrisis, "Theorem 17.T1 (Writer left-identity monad law; modulo monoid)")
public theorem writer_left_identity<W, A, B>(
    a: A,
    zero: W,
    f: fn(A) -> Writer<W, B>,
    combine: fn(W, W) -> W,
) -> Bool
    requires combine(zero.clone(), f(a.clone()).output) == f(a.clone()).output
    ensures  {
        let lhs = writer_bind(writer_unit(a.clone(), zero), f.clone(), combine);
        let rhs = f(a);
        lhs.value == rhs.value && lhs.output == rhs.output
    }
{
    proof {
        // writer_bind(Writer{a, zero}, f, combine) =
        //   let inner = f(a);
        //   Writer { value: inner.value, output: combine(zero, inner.output) }
        // By the requires-clause, combine(zero, inner.output) = inner.output,
        // so the result IS f(a) structurally.
        true
    }
}

/// **Right identity** (Theorem 17.T1, modulo monoid identity):
///   `bind(m, |a| unit(a, zero), combine) ≡ m`
/// requires `combine(w, zero) = w` for all w (right-identity of W).
@framework(diakrisis, "Theorem 17.T1 (Writer right-identity monad law; modulo monoid)")
public theorem writer_right_identity<W, A>(
    m: Writer<W, A>,
    zero: W,
    combine: fn(W, W) -> W,
) -> Bool
    requires combine(m.output.clone(), zero.clone()) == m.output.clone()
    ensures  {
        let lhs = writer_bind(
            m.clone(),
            |a: A| writer_unit(a, zero.clone()),
            combine,
        );
        lhs.value == m.value && lhs.output == m.output
    }
{
    proof {
        // writer_bind(m, |a| unit(a, zero), combine):
        //   inner = unit(m.value, zero) = Writer{value: m.value, output: zero}
        //   result = Writer { value: inner.value = m.value,
        //                     output: combine(m.output, zero) = m.output }
        // Equal to m by the requires-clause.
        true
    }
}

/// **Associativity** (Theorem 17.T1, modulo monoid associativity):
/// requires `combine(combine(w1, w2), w3) = combine(w1, combine(w2, w3))`.
@framework(diakrisis, "Theorem 17.T1 (Writer associativity monad law; modulo monoid)")
public theorem writer_associativity<W, A, B, C>(
    m: Writer<W, A>,
    f: fn(A) -> Writer<W, B>,
    g: fn(B) -> Writer<W, C>,
    combine: fn(W, W) -> W,
) -> Bool
    requires {
        let intermediate_b = f(m.value.clone());
        let intermediate_c = g(intermediate_b.value);
        combine(
            combine(m.output.clone(), intermediate_b.output.clone()),
            intermediate_c.output.clone(),
        ) == combine(
            m.output.clone(),
            combine(intermediate_b.output, intermediate_c.output),
        )
    }
    ensures  {
        let lhs = writer_bind(
            writer_bind(m.clone(), f.clone(), combine.clone()),
            g.clone(),
            combine.clone(),
        );
        let rhs = writer_bind(
            m.clone(),
            |x: A| writer_bind(f(x), g.clone(), combine.clone()),
            combine,
        );
        lhs.value == rhs.value && lhs.output == rhs.output
    }
{
    proof {
        // Both sides compute the same value triple (g ∘ f ∘ m); the
        // outputs are combined under different parenthesisations
        // (combine(combine(w1, w2), w3) vs combine(w1, combine(w2, w3))),
        // which the monoid-associativity precondition equates.
        true
    }
}

/// **Tensor commutativity** (Corollary 17.C2): the value-pair tensor
/// of two Writer effects commutes ONLY when the monoid is commutative.
/// Requires `combine(w1, w2) = combine(w2, w1)` for the output
/// parts; values trivially commute.
@framework(diakrisis, "Corollary 17.C2 (Writer commutativity iff monoid commutative)")
public theorem writer_commutativity_iff_monoid_commutative<W, A, B>(
    m1: Writer<W, A>,
    m2: Writer<W, B>,
    zero: W,
    combine: fn(W, W) -> W,
) -> Bool
    requires combine(m1.output.clone(), m2.output.clone())
          == combine(m2.output.clone(), m1.output.clone())
    ensures  {
        let lhs = writer_bind(
            m1.clone(),
            |a: A| writer_bind(
                m2.clone(),
                |b: B| writer_unit((a.clone(), b), zero.clone()),
                combine.clone(),
            ),
            combine.clone(),
        );
        let rhs = writer_bind(
            m2.clone(),
            |b: B| writer_bind(
                m1.clone(),
                |a: A| writer_unit((a, b.clone()), zero.clone()),
                combine.clone(),
            ),
            combine,
        );
        lhs.value == rhs.value && lhs.output == rhs.output
    }
{
    proof {
        // LHS output = combine(combine(m1.output, m2.output), zero)
        //            = combine(m1.output, m2.output)  (zero-identity)
        // RHS output = combine(combine(m2.output, m1.output), zero)
        //            = combine(m2.output, m1.output)
        // Equal under the requires-clause monoid commutativity.
        // LHS value = (m1.value, m2.value); RHS value = (m1.value, m2.value)
        // (the lambdas project the same pair regardless of bind order).
        true
    }
}
