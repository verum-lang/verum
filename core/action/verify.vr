// =============================================================================
// core.action.verify — ε-audit, gauge-consistency (VVA §11.2, §11.4)
// =============================================================================

public type AuditVerdict is
    Consistent
  | TooWeak
  | TooStrong
  | GaugeMismatch;

public fn verdict_as_text(v: AuditVerdict) -> Text {
    match v {
        Consistent     => "consistent",
        TooWeak        => "too-weak",
        TooStrong      => "too-strong",
        GaugeMismatch  => "gauge-mismatch",
    }
}

public fn verify_epsilon(declared: Primitive, observed: Enactment) -> AuditVerdict {
    let canonical: Enactment = canonicalise(observed);

    let mut all_observational: Bool = true;
    let mut any_constructive: Bool = false;
    let mut any_proof: Bool = false;
    let mut i: Int = 0;
    while i < canonical.steps.len() as Int {
        let step: Primitive = *canonical.steps.get(i as Int).unwrap();
        if !is_observational(step) { all_observational = false; }
        if is_constructive(step)    { any_constructive = true; }
        if is_proof_producing(step) { any_proof = true; }
        i = i + 1;
    }

    match declared {
        EpsilonObserve => {
            if canonical.steps.is_empty() { return Consistent; }
            if !all_observational { return TooWeak; }
            Consistent
        }
        EpsilonProve => {
            if !any_proof { return TooStrong; }
            Consistent
        }
        EpsilonConstruct => {
            if !any_constructive && !canonical.steps.is_empty() { return TooStrong; }
            Consistent
        }
        EpsilonMath      => Consistent,
        EpsilonCompute   => Consistent,
        EpsilonDecide    => Consistent,
        EpsilonTranslate => Consistent,
        EpsilonClassify  => Consistent,
    }
}

public type ConsistencyReport is {
    epsilon: Text,
    declared_count: Int,
    consistent_count: Int,
    divergent_count: Int,
};

public fn gauge_consistency(
    epsilon: Primitive,
    observed: List<Enactment>,
) -> ConsistencyReport {
    let name: Text = primitive_as_text(epsilon);
    if observed.is_empty() {
        return ConsistencyReport {
            epsilon: name,
            declared_count: 0,
            consistent_count: 0,
            divergent_count: 0,
        };
    }
    let representative: Enactment = canonicalise(observed.get(0).unwrap().clone());
    let mut consistent: Int = 1;
    let mut divergent: Int = 0;
    let mut i: Int = 1;
    while i < observed.len() as Int {
        let candidate: Enactment = canonicalise(observed.get(i as Int).unwrap().clone());
        if gauge_equivalent(representative.clone(), candidate) {
            consistent = consistent + 1;
        } else {
            divergent = divergent + 1;
        }
        i = i + 1;
    }
    ConsistencyReport {
        epsilon: name,
        declared_count: observed.len() as Int,
        consistent_count: consistent,
        divergent_count: divergent,
    }
}

public fn autopoietic_flag(e: Enactment) -> Bool {
    is_autopoietic(e)
}

// =============================================================================
// §11.4 (#243) — streaming CoherenceMonitor
//
// `gauge_consistency` is one-shot: pass a `List<Enactment>`, get a
// summary report. The streaming monitor below is the dual: build
// incrementally, observe one enactment at a time, ask for the
// running report. This is what live audit endpoints (Noesis NP
// `enactment/observe` ingestion) use — they can't materialise the
// full history before deciding whether a freshly-recorded
// enactment is consistent with the prior gauge class.
// =============================================================================

/// A streaming gauge-coherence monitor for one declared ε-primitive.
/// Construct via `monitor_new(eps)`, feed enactments via
/// `monitor_observe(&mut self, e)`, read the running tally via
/// `monitor_report(&self)`.
///
/// The monitor maintains a single canonicalised representative — the
/// first observed enactment — and decides each subsequent enactment's
/// gauge-equivalence against that representative. This matches the
/// one-shot `gauge_consistency` semantics so downstream consumers
/// can swap freely between batch and streaming use.
public type CoherenceMonitor is {
    epsilon: Primitive,
    representative: Maybe<Enactment>,
    consistent: Int,
    divergent: Int,
};

/// Construct a fresh monitor for a declared ε-primitive.
public fn monitor_new(epsilon: Primitive) -> CoherenceMonitor {
    CoherenceMonitor {
        epsilon: epsilon,
        representative: None,
        consistent: 0,
        divergent: 0,
    }
}

/// Observe one enactment. The first observation seeds the
/// representative; every subsequent observation increments either
/// `consistent` or `divergent` based on `gauge_equivalent` against
/// the representative.
///
/// Returns `true` iff the observation was recorded as consistent
/// (so the call site can short-circuit on first divergence if
/// desired).
public fn monitor_observe(m: &mut CoherenceMonitor, e: Enactment) -> Bool {
    let canonical: Enactment = canonicalise(e);
    match &m.representative {
        Some(rep) => {
            if gauge_equivalent(rep.clone(), canonical) {
                m.consistent = m.consistent + 1;
                true
            } else {
                m.divergent = m.divergent + 1;
                false
            }
        },
        None => {
            m.representative = Some(canonical);
            m.consistent = 1;
            true
        },
    }
}

/// Snapshot the current monitor state as a `ConsistencyReport` —
/// shape-compatible with `gauge_consistency`'s return value so a
/// streaming endpoint can emit the same audit JSON as a batch
/// invocation.
public fn monitor_report(m: &CoherenceMonitor) -> ConsistencyReport {
    let total: Int = m.consistent + m.divergent;
    ConsistencyReport {
        epsilon: primitive_as_text(m.epsilon),
        declared_count: total,
        consistent_count: m.consistent,
        divergent_count: m.divergent,
    }
}

/// True iff the monitor has observed only gauge-consistent
/// enactments since construction. Empty monitors (no observations)
/// trivially satisfy this.
public fn monitor_is_coherent(m: &CoherenceMonitor) -> Bool {
    m.divergent == 0
}
