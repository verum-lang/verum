// =============================================================================
// encoding/json_patch.vr — JSON Patch (RFC 6902)
// =============================================================================
// Layer: 1 (Encoding)
// Dependencies: core, core.collections, core.encoding.{json, json_pointer}
// =============================================================================
//
// RFC 6902 JSON Patch — the operational-transform format for JSON
// documents. Expressed as an array of operations, each with `op`,
// `path`, and operation-specific fields. Paths are RFC 6901 JSON
// Pointers.
//
// Used by Kubernetes strategic merge patch (for the primitive
// `json` strategy), OpenAPI schema-diff tooling, CRDT libraries
// emitting delta updates, VS Code's `jsonc-parser` edits API.
//
// # Operations (§4)
//
//   add     — insert / replace at `path`
//   remove  — delete value at `path`
//   replace — existing value at `path` is replaced
//   move    — remove `from` + add at `path`
//   copy    — add at `path` with value from `from`
//   test    — verify `path` holds `value`; fail the whole patch otherwise
//
// # API
//
// ```
// // Parse a JSON Patch document.
// let patch: JsonPatch = json_patch.parse(&patch_json)?;
//
// // Apply to a target; any failing op rolls the whole patch back.
// let mut doc = json.parse_value(&document)?;
// json_patch.apply(&mut doc, &patch)?;
// ```
//
// # Atomicity
//
// RFC 6902 §5 requires that the patch either apply in its
// entirety or not at all. We honour this by deep-cloning `doc`
// before applying; on error, the original is restored. The
// caller sees mutation only on complete success.
//
// =============================================================================

module core.encoding.json_patch;

mount core.*;
mount core.collections.List;
mount core.collections.map.{Map};
mount core.encoding.json.{JsonValue, JsonError, parse_value as json_parse};
mount core.encoding.json_pointer.{JsonPointer, parse as pointer_parse};

// =============================================================================
// Typed ops
// =============================================================================

public type JsonPatchOp is
      Add     { path: JsonPointer, value: JsonValue }
    | Remove  { path: JsonPointer }
    | Replace { path: JsonPointer, value: JsonValue }
    | Move    { from: JsonPointer, path: JsonPointer }
    | Copy    { from: JsonPointer, path: JsonPointer }
    | Test    { path: JsonPointer, value: JsonValue };

public type JsonPatch is {
    ops: List<JsonPatchOp>,
};

public type JsonPatchError is
      Malformed(Text)
    | BadPointer(Text)
    | MissingField(Text)
    | TargetNotFound(Text)
    | TestFailed(Text)
    | InvalidOp(Text);

implement Display for JsonPatchError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Malformed(reason)        => f.write_str(f"JSON Patch: malformed ({reason})".as_str()),
            BadPointer(reason)       => f.write_str(f"JSON Patch: bad pointer ({reason})".as_str()),
            MissingField(field)      => f.write_str(f"JSON Patch: missing field {field}".as_str()),
            TargetNotFound(path)     => f.write_str(f"JSON Patch: target not found at {path}".as_str()),
            TestFailed(path)         => f.write_str(f"JSON Patch: test op failed at {path}".as_str()),
            InvalidOp(op)            => f.write_str(f"JSON Patch: invalid op {op}".as_str()),
        }
    }
}

implement Debug for JsonPatchError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Malformed(reason)        => f.write_str(f"Malformed({reason})".as_str()),
            BadPointer(reason)       => f.write_str(f"BadPointer({reason})".as_str()),
            MissingField(field)      => f.write_str(f"MissingField({field})".as_str()),
            TargetNotFound(path)     => f.write_str(f"TargetNotFound({path})".as_str()),
            TestFailed(path)         => f.write_str(f"TestFailed({path})".as_str()),
            InvalidOp(op)            => f.write_str(f"InvalidOp({op})".as_str()),
        }
    }
}

implement Eq for JsonPatchError {
    fn eq(&self, other: &JsonPatchError) -> Bool {
        match (self, other) {
            (Malformed(a),       Malformed(b))       => a == b,
            (BadPointer(a),      BadPointer(b))      => a == b,
            (MissingField(a),    MissingField(b))    => a == b,
            (TargetNotFound(a),  TargetNotFound(b))  => a == b,
            (TestFailed(a),      TestFailed(b))      => a == b,
            (InvalidOp(a),       InvalidOp(b))       => a == b,
            _ => false,
        }
    }
}

// =============================================================================
// Parse
// =============================================================================

public fn parse(patch_text: &Text) -> Result<JsonPatch, JsonPatchError> {
    let v = json_parse(patch_text).map_err(|_| JsonPatchError.Malformed(
        Text.from("not valid JSON")))?;
    let arr = match v {
        JsonValue.JsonArray(a) => a,
        _ => return Err(JsonPatchError.Malformed(Text.from("patch must be array"))),
    };
    let mut ops: List<JsonPatchOp> = [];
    let mut i: Int = 0;
    while i < arr.len() {
        ops.push(parse_op(&arr[i])?);
        i = i + 1;
    }
    Ok(JsonPatch { ops: ops })
}

fn parse_op(v: &JsonValue) -> Result<JsonPatchOp, JsonPatchError> {
    let obj = match v {
        JsonValue.JsonObject(m) => m,
        _ => return Err(JsonPatchError.Malformed(Text.from("op must be object"))),
    };
    let op_str = match obj.get(&Text.from("op")) {
        Some(JsonValue.JsonString(s)) => s.clone(),
        _ => return Err(JsonPatchError.MissingField(Text.from("op"))),
    };

    let path_str = match obj.get(&Text.from("path")) {
        Some(JsonValue.JsonString(s)) => s.clone(),
        _ => return Err(JsonPatchError.MissingField(Text.from("path"))),
    };
    let path = pointer_parse(&path_str)
        .map_err(|_| JsonPatchError.BadPointer(path_str.clone()))?;

    let name = op_str.as_bytes();
    if name == b"add" {
        let value = get_required_value(obj)?;
        return Ok(JsonPatchOp.Add { path: path, value: value });
    }
    if name == b"remove" {
        return Ok(JsonPatchOp.Remove { path: path });
    }
    if name == b"replace" {
        let value = get_required_value(obj)?;
        return Ok(JsonPatchOp.Replace { path: path, value: value });
    }
    if name == b"test" {
        let value = get_required_value(obj)?;
        return Ok(JsonPatchOp.Test { path: path, value: value });
    }
    if name == b"move" || name == b"copy" {
        let from_str = match obj.get(&Text.from("from")) {
            Some(JsonValue.JsonString(s)) => s.clone(),
            _ => return Err(JsonPatchError.MissingField(Text.from("from"))),
        };
        let from = pointer_parse(&from_str)
            .map_err(|_| JsonPatchError.BadPointer(from_str))?;
        if name == b"move" {
            return Ok(JsonPatchOp.Move { from: from, path: path });
        }
        return Ok(JsonPatchOp.Copy { from: from, path: path });
    }
    Err(JsonPatchError.InvalidOp(op_str))
}

fn get_required_value(obj: &Map<Text, JsonValue>) -> Result<JsonValue, JsonPatchError> {
    match obj.get(&Text.from("value")) {
        Some(v) => Ok(clone_value(v)),
        None    => Err(JsonPatchError.MissingField(Text.from("value"))),
    }
}

// =============================================================================
// Apply
// =============================================================================

/// Apply the patch to `doc` atomically. On any failing op, the
/// whole patch is rolled back and `doc` is left unchanged.
public fn apply(doc: &mut JsonValue, patch: &JsonPatch) -> Result<(), JsonPatchError> {
    // Snapshot for atomic rollback.
    let snapshot = clone_value(doc);
    let mut i: Int = 0;
    while i < patch.ops.len() {
        match apply_op(doc, &patch.ops[i]) {
            Ok(_)  => {},
            Err(e) => {
                *doc = snapshot;
                return Err(e);
            },
        }
        i = i + 1;
    }
    Ok(())
}

fn apply_op(doc: &mut JsonValue, op: &JsonPatchOp) -> Result<(), JsonPatchError> {
    match op {
        JsonPatchOp.Add { path, value } => {
            set_at(doc, path, clone_value(value), /* replace_if_exists = */ true)
        },
        JsonPatchOp.Replace { path, value } => {
            if !exists_at(doc, path) {
                return Err(JsonPatchError.TargetNotFound(Text.from("replace target missing")));
            }
            set_at(doc, path, clone_value(value), true)
        },
        JsonPatchOp.Remove { path } => {
            if !exists_at(doc, path) {
                return Err(JsonPatchError.TargetNotFound(Text.from("remove target missing")));
            }
            remove_at(doc, path)
        },
        JsonPatchOp.Move { from, path } => {
            let val = take_at(doc, from)?;
            set_at(doc, path, val, true)
        },
        JsonPatchOp.Copy { from, path } => {
            let val = read_at(doc, from)?;
            set_at(doc, path, val, true)
        },
        JsonPatchOp.Test { path, value } => {
            let actual = read_at(doc, path)?;
            if !json_equal(&actual, value) {
                return Err(JsonPatchError.TestFailed(Text.from("test value mismatch")));
            }
            Ok(())
        },
    }
}

// =============================================================================
// JsonValue path primitives
// =============================================================================
//
// The MVP implementation re-clones the document for each walk — this
// trades linear memory during apply for code clarity. A follow-up
// will thread mutable cursors through `JsonValue.JsonObject` /
// `JsonValue.JsonArray` children once the stdlib exposes stable
// entry iterators.
//
// =============================================================================

fn exists_at(doc: &JsonValue, path: &JsonPointer) -> Bool {
    walk_path(doc, path).is_some()
}

fn read_at(doc: &JsonValue, path: &JsonPointer) -> Result<JsonValue, JsonPatchError> {
    match walk_path(doc, path) {
        Some(v) => Ok(v),
        None    => Err(JsonPatchError.TargetNotFound(Text.from("read"))),
    }
}

fn walk_path(doc: &JsonValue, path: &JsonPointer) -> Maybe<JsonValue> {
    let mut cursor = clone_value(doc);
    let mut i: Int = 0;
    while i < path.tokens.len() {
        let tok = &path.tokens[i];
        cursor = match cursor {
            JsonValue.JsonObject(m) => {
                match m.get(tok) {
                    Some(v) => clone_value(v),
                    None    => return None,
                }
            },
            JsonValue.JsonArray(arr) => {
                let idx = parse_array_index(tok);
                match idx {
                    Some(n) => {
                        if n < 0 || n >= arr.len() { return None; }
                        clone_value(&arr[n])
                    },
                    None => return None,
                }
            },
            _ => return None,
        };
        i = i + 1;
    }
    Some(cursor)
}

fn set_at(
    doc: &mut JsonValue, path: &JsonPointer, value: JsonValue, replace: Bool,
) -> Result<(), JsonPatchError> {
    if path.tokens.len() == 0 {
        // Replacing the document root.
        *doc = value;
        return Ok(());
    }
    // Clone-path-and-rebuild strategy.
    let replaced = rebuild_with_set(doc, &path.tokens, 0, value, replace)?;
    *doc = replaced;
    Ok(())
}

fn rebuild_with_set(
    cur: &JsonValue, tokens: &List<Text>, at: Int, value: JsonValue, replace: Bool,
) -> Result<JsonValue, JsonPatchError> {
    if at >= tokens.len() {
        return Ok(value);
    }
    let tok = &tokens[at];
    match cur {
        JsonValue.JsonObject(m) => {
            let mut out: Map<Text, JsonValue> = Map.new();
            let keys = m.keys();
            let mut iter = keys;
            loop {
                match iter.next() {
                    Some(k) => {
                        match m.get(k) {
                            Some(v) => { out.insert(k.clone(), clone_value(v)); },
                            None => {},
                        }
                    },
                    None => break,
                }
            }
            let child_base = match m.get(tok) {
                Some(v) => clone_value(v),
                None    => JsonValue.JsonNull,
            };
            let new_child = if at + 1 == tokens.len() {
                value
            } else {
                rebuild_with_set(&child_base, tokens, at + 1, value, replace)?
            };
            out.insert(tok.clone(), new_child);
            Ok(JsonValue.JsonObject(out))
        },
        JsonValue.JsonArray(arr) => {
            // Token must be a decimal index or "-" (append marker).
            let len = arr.len();
            let idx: Int = if tok.as_bytes() == b"-" {
                len
            } else {
                match parse_array_index(tok) {
                    Some(n) => n,
                    None    => return Err(JsonPatchError.BadPointer(tok.clone())),
                }
            };
            if idx < 0 || idx > len {
                return Err(JsonPatchError.TargetNotFound(tok.clone()));
            }
            let mut out: List<JsonValue> = [];
            let mut i: Int = 0;
            while i < idx {
                out.push(clone_value(&arr[i]));
                i = i + 1;
            }
            if at + 1 == tokens.len() {
                out.push(value);
                // For add/replace on existing index, skip the old value
                // when replace=true; for add (replace=true anyway per
                // RFC 6902 §4.1), we splice at idx so existing values
                // shift right unless idx == len (append).
                if idx < len {
                    // §4.1 "add" into an array inserts; §4.3 "replace"
                    // substitutes. Our `replace` flag distinguishes.
                    if replace {
                        // Replace — skip the old element.
                        i = idx + 1;
                    }
                }
                while i < arr.len() {
                    out.push(clone_value(&arr[i]));
                    i = i + 1;
                }
            } else {
                let child = if idx < len { clone_value(&arr[idx]) } else { JsonValue.JsonNull };
                let new_child = rebuild_with_set(&child, tokens, at + 1, value, replace)?;
                out.push(new_child);
                i = idx + 1;
                while i < arr.len() { out.push(clone_value(&arr[i])); i = i + 1; }
            }
            Ok(JsonValue.JsonArray(out))
        },
        _ => Err(JsonPatchError.TargetNotFound(tok.clone())),
    }
}

fn remove_at(doc: &mut JsonValue, path: &JsonPointer) -> Result<(), JsonPatchError> {
    if path.tokens.len() == 0 {
        *doc = JsonValue.JsonNull;
        return Ok(());
    }
    let rebuilt = rebuild_with_remove(doc, &path.tokens, 0)?;
    *doc = rebuilt;
    Ok(())
}

fn rebuild_with_remove(
    cur: &JsonValue, tokens: &List<Text>, at: Int,
) -> Result<JsonValue, JsonPatchError> {
    let tok = &tokens[at];
    match cur {
        JsonValue.JsonObject(m) => {
            let mut out: Map<Text, JsonValue> = Map.new();
            let keys = m.keys();
            let mut iter = keys;
            loop {
                match iter.next() {
                    Some(k) => {
                        if at + 1 == tokens.len() && k.as_bytes() == tok.as_bytes() {
                            // Skip this key — that's the removal.
                        } else {
                            match m.get(k) {
                                Some(v) => {
                                    if k.as_bytes() == tok.as_bytes() {
                                        let new_v = rebuild_with_remove(v, tokens, at + 1)?;
                                        out.insert(k.clone(), new_v);
                                    } else {
                                        out.insert(k.clone(), clone_value(v));
                                    }
                                },
                                None => {},
                            }
                        }
                    },
                    None => break,
                }
            }
            Ok(JsonValue.JsonObject(out))
        },
        JsonValue.JsonArray(arr) => {
            let idx = match parse_array_index(tok) {
                Some(n) => n,
                None    => return Err(JsonPatchError.BadPointer(tok.clone())),
            };
            if idx < 0 || idx >= arr.len() {
                return Err(JsonPatchError.TargetNotFound(tok.clone()));
            }
            let mut out: List<JsonValue> = [];
            let mut i: Int = 0;
            while i < arr.len() {
                if i == idx {
                    if at + 1 == tokens.len() {
                        // Skip — the removal.
                    } else {
                        let new_v = rebuild_with_remove(&arr[i], tokens, at + 1)?;
                        out.push(new_v);
                    }
                } else {
                    out.push(clone_value(&arr[i]));
                }
                i = i + 1;
            }
            Ok(JsonValue.JsonArray(out))
        },
        _ => Err(JsonPatchError.TargetNotFound(tok.clone())),
    }
}

fn take_at(doc: &mut JsonValue, path: &JsonPointer) -> Result<JsonValue, JsonPatchError> {
    let v = read_at(doc, path)?;
    remove_at(doc, path)?;
    Ok(v)
}

// =============================================================================
// Helpers
// =============================================================================

fn parse_array_index(s: &Text) -> Maybe<Int> {
    let b = s.as_bytes();
    if b.len() == 0 { return None; }
    if b.len() > 1 && b[0] == ('0' as Byte) { return None; }
    // SOUNDNESS: same overflow-defense recipe as the sibling
    // core/encoding/json_pointer.vr (#72). Int.MAX is 19 decimal
    // digits; any longer digit run necessarily overflows the
    // accumulator. Reject pre-loop, then guard each multiply.
    if b.len() > 19 { return None; }
    let mut v: Int = 0;
    let mut i: Int = 0;
    while i < b.len() {
        let c = b[i];
        if c < ('0' as Byte) || c > ('9' as Byte) { return None; }
        if v > 922_337_203_685_477_580 { return None; }   // Int.MAX / 10
        v = v * 10 + ((c - ('0' as Byte)) as Int);
        if v < 0 { return None; }                          // wrap-around guard
        i = i + 1;
    }
    Some(v)
}

fn clone_value(v: &JsonValue) -> JsonValue {
    match v {
        JsonValue.JsonNull        => JsonValue.JsonNull,
        JsonValue.JsonBool(b)     => JsonValue.JsonBool(*b),
        JsonValue.JsonInt(n)      => JsonValue.JsonInt(*n),
        JsonValue.JsonFloat(f)    => JsonValue.JsonFloat(*f),
        JsonValue.JsonString(s)   => JsonValue.JsonString(s.clone()),
        JsonValue.JsonArray(arr)  => {
            let mut out: List<JsonValue> = [];
            let mut i: Int = 0;
            while i < arr.len() { out.push(clone_value(&arr[i])); i = i + 1; }
            JsonValue.JsonArray(out)
        },
        JsonValue.JsonObject(m)   => {
            let mut out: Map<Text, JsonValue> = Map.new();
            let keys = m.keys();
            let mut iter = keys;
            loop {
                match iter.next() {
                    Some(k) => {
                        match m.get(k) {
                            Some(v) => { out.insert(k.clone(), clone_value(v)); },
                            None => {},
                        }
                    },
                    None => break,
                }
            }
            JsonValue.JsonObject(out)
        },
    }
}

fn json_equal(a: &JsonValue, b: &JsonValue) -> Bool {
    match (a, b) {
        (JsonValue.JsonNull, JsonValue.JsonNull) => true,
        (JsonValue.JsonBool(x), JsonValue.JsonBool(y)) => *x == *y,
        (JsonValue.JsonInt(x), JsonValue.JsonInt(y)) => *x == *y,
        (JsonValue.JsonFloat(x), JsonValue.JsonFloat(y)) => *x == *y,
        (JsonValue.JsonString(x), JsonValue.JsonString(y)) => x.as_bytes() == y.as_bytes(),
        (JsonValue.JsonArray(xs), JsonValue.JsonArray(ys)) => {
            if xs.len() != ys.len() { return false; }
            let mut i: Int = 0;
            while i < xs.len() {
                if !json_equal(&xs[i], &ys[i]) { return false; }
                i = i + 1;
            }
            true
        },
        (JsonValue.JsonObject(xm), JsonValue.JsonObject(ym)) => {
            if xm.len() != ym.len() { return false; }
            let keys = xm.keys();
            let mut iter = keys;
            loop {
                match iter.next() {
                    Some(k) => {
                        match (xm.get(k), ym.get(k)) {
                            (Some(vx), Some(vy)) => {
                                if !json_equal(vx, vy) { return false; }
                            },
                            _ => return false,
                        }
                    },
                    None => break,
                }
            }
            true
        },
        _ => false,
    }
}
