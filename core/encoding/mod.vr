// =============================================================================
// encoding/mod.vr - Data encoding / serialization
// =============================================================================
// Layer: 2 (Core, depends on base + text + collections)
// =============================================================================

module core.encoding;

public module json;
public module base64;
public module base32;
public module base58;
public module hex;
public module varint;
public module der;
public module cbor;
public module json_pointer;
public module msgpack;
public module pem;
public module jcs;

// Re-exports — JSON
public mount .json.Json;
public mount .json.JsonValue;
public mount .json.JsonError;
public mount .json.JsonErrorKind;
public mount .json.parse;
public mount .json.parse_value;
public mount .json.stringify;
public mount .json.stringify_pretty;

// Re-exports — Base64
public mount .base64.Base64Error;
public mount .base64.Base64ErrorKind;

// Re-exports — Base32
public mount .base32.Base32Error;

// Re-exports — Base58
public mount .base58.Base58Error;

// Re-exports — CBOR (RFC 8949)
public mount .cbor.{CborValue, CborError, MAX_CBOR_NESTING};

// Re-exports — Hex
public mount .hex.HexError;
public mount .hex.HexErrorKind;

// Re-exports — Varint (SQLite-style + QUIC-style; LEB128 lives in
// core.protobuf.wire — no duplication)
public mount .varint.VarintError;
public mount .varint.VarintErrorKind;
public mount .varint.QUIC_VARINT_MAX;

// Re-exports — DER (ASN.1 Distinguished Encoding Rules — X.509 / PKIX)
public mount .der.DerReader;
public mount .der.DerError;
public mount .der.DerErrorKind;
public mount .der.Tag;
public mount .der.TagClass;
public mount .der.BitString;
public mount .der.Time;
