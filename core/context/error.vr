// =============================================================================
// context/error.vr — Context System Error Types
// =============================================================================
// Spec: docs/detailed/16-context-system.md
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module error;

/// Error type for context system failures.
///

/// Returned when a context cannot be resolved or provided.
///

/// # Error Codes
///

/// | Code | Error |
/// |------|-------|
/// | E3050 | Direct negative context violation |
/// | E3051 | Transitive negative context violation |
/// | E3052 | Conflicting positive and negative constraints |
/// | E805 | Circular dependency in DI graph |
/// | E806 | Scope violation (Singleton depending on Request) |
/// | E807 | Missing @inject constructor |
/// | E808 | Constructor parameter mismatch |
public type ContextError is
    /// Context not found in the current environment.
    NotFound { context_name: Text }
    /// Context not provided before use.
    | NotProvided { context_name: Text, function_name: Text }
    /// Context type mismatch (provided value doesn't match).
    | TypeMismatch { context_name: Text, expected: Text, found: Text }
    /// Circular dependency detected in DI graph.
    | CircularDependency { chain: List<Text> }
    /// Scope violation: long-lived depends on short-lived.
    | ScopeViolation { dependent: Text, dependency: Text, dependent_scope: Text, dependency_scope: Text };

implement ContextError {
    fn message(&self) -> Text {
        // Qualify variants (task #17/#39 workaround) — bare-name
        // first-wins routes patterns to the wrong sibling-module
        // variant otherwise.
        match self {
            ContextError.NotFound { context_name } =>
                f"Context '{context_name}' not found in current environment",
            ContextError.NotProvided { context_name, function_name } =>
                f"Context '{context_name}' not provided before use in '{function_name}'",
            ContextError.TypeMismatch { context_name, expected, found } =>
                f"Context '{context_name}': expected type '{expected}', found '{found}'",
            ContextError.CircularDependency { chain } =>
                f"Circular dependency detected: {chain.join(\" -> \")}",
            ContextError.ScopeViolation { dependent, dependency, dependent_scope, dependency_scope } =>
                f"Scope violation: '{dependent}' ({dependent_scope}) cannot depend on '{dependency}' ({dependency_scope})",
        }
    }
}

implement Display for ContextError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.message().as_str())
    }
}

implement Debug for ContextError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        // Qualify variants (task #17/#39 workaround) — same root.
        match self {
            ContextError.NotFound { context_name } =>
                f.write_str(f"NotFound {{ context_name: {context_name} }}".as_str()),
            ContextError.NotProvided { context_name, function_name } =>
                f.write_str(f"NotProvided {{ context_name: {context_name}, function_name: {function_name} }}".as_str()),
            ContextError.TypeMismatch { context_name, expected, found } =>
                f.write_str(f"TypeMismatch {{ context_name: {context_name}, expected: {expected}, found: {found} }}".as_str()),
            ContextError.CircularDependency { chain } =>
                f.write_str(f"CircularDependency {{ chain: <{chain.len()} entries> }}".as_str()),
            ContextError.ScopeViolation { dependent, dependency, dependent_scope, dependency_scope } =>
                f.write_str(f"ScopeViolation {{ dependent: {dependent}, dependency: {dependency}, dependent_scope: {dependent_scope}, dependency_scope: {dependency_scope} }}".as_str()),
        }
    }
}

implement Eq for ContextError {
    fn eq(&self, other: &ContextError) -> Bool {
        // FUNDAMENTAL: qualify variants `ContextError.<Variant>` in
        // BOTH match-arm sides to avoid bare-name first-wins
        // collision (task #17/#39). Pre-fix `NotFound` / `NotProvided`
        // / `TypeMismatch` / `CircularDependency` / `ScopeViolation`
        // bare names resolved to the first sibling-module variant
        // registered with that name; the match arm then never fired
        // on a real ContextError value, falling through to `_ => false`.
        // Symptom: every `a == b` with same-variant + same-fields
        // returned `false` (audit.md §3.1 + scope/audit.md §3.2).
        match (self, other) {
            (ContextError.NotFound { context_name: a },
             ContextError.NotFound { context_name: b }) =>
                a == b,
            (ContextError.NotProvided { context_name: ca, function_name: fa },
             ContextError.NotProvided { context_name: cb, function_name: fb }) =>
                ca == cb && fa == fb,
            (ContextError.TypeMismatch { context_name: ca, expected: ea, found: fa },
             ContextError.TypeMismatch { context_name: cb, expected: eb, found: fb }) =>
                ca == cb && ea == eb && fa == fb,
            (ContextError.CircularDependency { chain: a },
             ContextError.CircularDependency { chain: b }) =>
                a == b,
            (ContextError.ScopeViolation { dependent: da, dependency: ya,
                                            dependent_scope: dsa, dependency_scope: ysa },
             ContextError.ScopeViolation { dependent: db, dependency: yb,
                                            dependent_scope: dsb, dependency_scope: ysb }) =>
                da == db && ya == yb && dsa == dsb && ysa == ysb,
            _ => false,
        }
    }
}
