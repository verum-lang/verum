public module pool;

/// Context bridge between runtime and context system
public module ctx_bridge;

/// Stack-based allocator for no-heap environments
@cfg(any(runtime = "no_heap", runtime = "embedded"))
public module stack_alloc;

/// Lock-free task queue for work-stealing scheduler
@cfg(any(runtime = "full", runtime = "single_thread"))
public module task_queue;

