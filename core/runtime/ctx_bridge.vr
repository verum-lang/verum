// =============================================================================
// runtime/ctx_bridge.vr — Bridge between AOT CtxGet/CtxProvide and core/sys TLS
// =============================================================================
// Layer: 1 (Runtime)
// Dependencies: sys.common (ctx_get, ctx_set)
// =============================================================================
//

// This module provides the bridge functions that AOT-compiled code calls for
// context operations. Instead of hardcoded LLVM IR in platform_ir.rs, the AOT
// pipeline calls these compiled .vr functions which delegate to the platform's
// TLS-based slot storage.
//

// Architecture:
//  CtxGet VBC opcode → instruction.rs → env_ctx_get() → ctx_get() → TLS slot
//  CtxProvide opcode → instruction.rs → env_ctx_provide() → ctx_set() → TLS slot
//  Spawn opcode → instruction.rs → fork_current_env() → shallow copy
//
// Store authority (CTX-STORE-AUTHORITY-1): `sys.common.ctx_*` is the ONE
// per-tier store seam.  Under Tier-1 AOT it reaches the platform TLS slot
// table; under the Tier-0 interpreter it reaches the interpreter's
// ContextStack — the SAME store the CtxProvide/CtxGet opcodes use — via
// the `__ctx_slot_*_raw` intrinsics in core/sys/common.vr.  These bridge
// functions therefore round-trip identically on both tiers and must never
// grow a parallel store.
//

// This eliminates hardcoded context logic from the compiler, routing all
// context operations through compiled Verum code.
// =============================================================================

@arch_module(
    requires: [Capability.Exec(ExecTarget.Syscall(0))],
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.runtime.ctx_bridge;
mount sys.common.{ctx_get, ctx_set, ctx_clear, CONTEXT_SLOT_COUNT};
mount core.intrinsics.runtime.mem_raw.{load_i64};

// =============================================================================
// Context Get/Set Bridge
// =============================================================================

/// Get a context value from the current execution environment by slot ID.
/// Returns the context value as Int (pointer), or 0 if not set or slot is
/// out of range.
/// Called by AOT-compiled CtxGet instruction.
public fn env_ctx_get(slot_id: Int) -> Int {
    if slot_id < 0 || slot_id >= CONTEXT_SLOT_COUNT {
        return 0;
    }
    match ctx_get(slot_id as UInt8) {
        Maybe.Some(ptr) => ptr as Int,
        Maybe.None => 0,
    }
}

/// Set a context value in the current execution environment.
/// Called by AOT-compiled CtxProvide instruction.
///
/// CTX-AOT-INCOHERENCE-1 leg 2: the AOT lowering assigns COMPACT dense
/// slot ids (0..CONTEXT_SLOT_COUNT, dynamic region from
/// CONTEXT_DYNAMIC_SLOT_BASE) — a slot outside the table can only mean
/// corrupted generated code or a caller bug, and silently dropping the
/// provide is the one forbidden state (the context would simply "not be
/// provided" much later, with no trace). Panic LOUDLY instead.
public fn env_ctx_set(slot_id: Int, value: Int) {
    if slot_id < 0 || slot_id >= CONTEXT_SLOT_COUNT {
        panic(f"env_ctx_set: context slot {slot_id} out of range 0..{CONTEXT_SLOT_COUNT} — dropped provide would be silent-wrong (CTX-AOT-INCOHERENCE-1)");
    }
    let bytes_ptr = unsafe { value as &unsafe Byte };
    ctx_set(slot_id as UInt8, bytes_ptr);
}

/// Remove a context value from the current execution environment.
/// Called by AOT-compiled CtxEnd instruction with the SAME slot id the
/// matching CtxProvide installed (slot-flat TLS semantics).
///
/// Out-of-range slots panic for the same reason as `env_ctx_set`: a
/// silently-skipped end leaks the provide past its scope.
public fn env_ctx_end(slot_id: Int) {
    if slot_id < 0 || slot_id >= CONTEXT_SLOT_COUNT {
        panic(f"env_ctx_end: context slot {slot_id} out of range 0..{CONTEXT_SLOT_COUNT} — skipped scope end would be silent-wrong (CTX-AOT-INCOHERENCE-1)");
    }
    ctx_clear(slot_id as UInt8);
}

// =============================================================================
// Environment Fork for Spawn
// =============================================================================

/// Get the number of active context slots in the current environment.
/// Used by spawn to know how many slots to copy to the child.
public fn env_active_slot_count() -> Int {
    let mut count = 0;
    let mut i: Int = 0;
    while i < CONTEXT_SLOT_COUNT {
        if ctx_get(i as UInt8).is_some() {
            count = count + 1;
        }
        i = i + 1;
    }
    count
}

/// Copy all active context slots from the current thread to a new thread.
/// Called by the spawn trampoline after thread creation.
/// Takes a packed array of (slot_id, value) pairs.
///

/// Defends against three classes of caller bug: negative count, integer
/// overflow on the offset computation, and out-of-range slot_id payloads
/// from a corrupted slots buffer.
public fn env_install_parent_contexts(slots_ptr: Int, count: Int) {
    if count <= 0 || slots_ptr == 0 {
        return;
    }
    // 16-byte stride per entry; reject counts that would overflow Int when
    // computing the buffer's last byte offset (`(count - 1) * 16 + 8`).
    if count > (Int.MAX - 8) / 16 {
        return;
    }
    let mut i: Int = 0;
    while i < count {
        // Each entry is 16 bytes: [slot_id: i64, value: i64].
        // `load_i64` is the `@intrinsic("load_i64")` raw-pointer load
        // exported from `core/mem/raw_ops.vr`.
        let slot_id = load_i64(slots_ptr + i * 16);
        let value = load_i64(slots_ptr + i * 16 + 8);
        if slot_id >= 0 && slot_id < CONTEXT_SLOT_COUNT {
            let bytes_ptr = unsafe { value as &unsafe Byte };
            ctx_set(slot_id as UInt8, bytes_ptr);
        }
        i = i + 1;
    }
}
