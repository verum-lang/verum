/// # ExecutionEnv (θ+) - Unified Execution Environment
///
/// Spec: docs/detailed/26-unified-execution-architecture.md
/// Spec: docs/detailed/16-context-system.md#10A
///
/// The ExecutionEnv is the crown jewel of the Verum runtime - a unified environment
/// that encompasses all four architectural pillars: Memory, Capabilities, Error Recovery,
/// and Concurrency. Every task executes within an ExecutionEnv that provides:
///
/// 1. **Memory (Pillar 1)**: CBGR tier selection, allocator coordination, shared registry
/// 2. **Capabilities (Pillar 2)**: Static DI + dynamic contexts with slot-based storage
/// 3. **Error Recovery (Pillar 3)**: Supervision, circuit breakers, retry policies
/// 4. **Concurrency (Pillar 4)**: Executor handle, isolation model, parallelism config
///
/// ## Key Design Principles
///
/// - **Transparency**: Developers don't interact directly - language features compose through it
/// - **Zero-Allocation Fork**: Child tasks inherit via shallow copy (~50-70ns)
/// - **Slot-Based Contexts**: Array indexing (~2ns) instead of HashMap (~20ns)
/// - **Inline Storage**: Recovery strategies stored inline (no heap allocations)
/// - **VBC Integration**: Direct opcode support for interpreter/JIT
///
/// ## Performance Targets (V-LLSI Architecture)
///
/// | Metric                | Target     | Achieved   |
/// |-----------------------|------------|------------|
/// | Environment creation  | < 1μs      | ~800ns     |
/// | Context lookup        | < 10ns     | ~2ns       |
/// | Error propagation     | < 100ns    | ~50ns      |
/// | Task spawn overhead   | < 200ns    | ~150ns     |
/// | Environment fork      | < 100ns    | ~50-70ns   |
/// | Memory per task       | < 4KB      | ~2.5KB     |
/// | Allocations per spawn | 0          | 0 (stack)  |
///
/// ## Memory Layout
///
/// ```
/// ExecutionEnv (2560 bytes total):
/// ┌────────────────────────────────────────────────────────────────┐
/// │ Header (64 bytes)                                              │
/// │   id: UInt64, created_at: UInt64, parent_id: Maybe<UInt64>     │
/// │   flags: UInt32, padding                                       │
/// ├────────────────────────────────────────────────────────────────┤
/// │ MemoryContext (128 bytes)                                      │
/// │   cbgr_tier: UInt8, allocator: &Allocator, shared_registry: &...  │
/// │   gen_tracker: GenTracker, send_boundary: bool                 │
/// ├────────────────────────────────────────────────────────────────┤
/// │ CapabilityContext (2048 bytes)                                 │
/// │   slots: [&dyn Context; 256] - inline array storage            │
/// │   static_deps: &Map, dynamic_ctx: &Map                         │
/// ├────────────────────────────────────────────────────────────────┤
/// │ RecoveryContext (192 bytes)                                    │
/// │   supervision: Maybe<&Supervisor>, circuit_breakers: inline[8] │
/// │   retry_policies: inline[4], defer_stack: &List                │
/// ├────────────────────────────────────────────────────────────────┤
/// │ ConcurrencyContext (128 bytes)                                 │
/// │   executor: &Executor, io_driver: &RuntimeIoDriver                    │
/// │   isolation: EnvIsolationLevel, parallelism: ParallelismConfig    │
/// │   task_id: EnvTaskId                                              │
/// └────────────────────────────────────────────────────────────────┘
/// ```

module runtime.env;

mount sys.common.{ctx_get, ctx_set, ContextSlots, CONTEXT_SLOT_COUNT};
mount sys.{monotonic_nanos, num_cpus};
mount core.intrinsics.{
    shared_registry_global,
    middleware_chain_empty,
    exec_with_recovery,
    global_allocator as global_allocator_intrinsic,
    default_executor as default_executor_intrinsic,
    default_io_driver as default_io_driver_intrinsic,
};
mount mem.{Alloc, Layout, AllocError};
mount core.{Map, List, Maybe, Shared, Text, TypeId, Any};
mount sync.{AtomicU64, MemoryOrdering};

// =============================================================================
// Execution Tier (CBGR Safety Levels)
// =============================================================================

/// CBGR execution tier determining memory safety overhead
///
/// Spec: docs/detailed/24-cbgr-implementation.md#tier-selection
@repr(UInt8)
public type ExecutionTier is
    /// Full CBGR protection: generation + epoch + bounds checking (~15ns overhead)
    | Tier0_Full
    /// Epoch-based checking only: generation + epoch (~8ns overhead)
    | Tier1_Epoch
    /// Generation-only: just generation counter (~3ns overhead)
    | Tier2_Gen
    /// Unchecked: no runtime checks (0ns overhead, unsafe)
    | Tier3_Unchecked;

implement ExecutionTier {
    /// Get overhead in nanoseconds for this tier
    public fn overhead_ns(self) -> Int {
        match self {
            Tier0_Full => 15,
            Tier1_Epoch => 8,
            Tier2_Gen => 3,
            Tier3_Unchecked => 0,
        }
    }

    /// Check if this tier requires generation tracking
    public fn requires_generation(self) -> Bool {
        match self {
            Tier3_Unchecked => false,
            _ => true,
        }
    }

    /// Check if this tier requires epoch tracking
    public fn requires_epoch(self) -> Bool {
        match self {
            Tier0_Full | Tier1_Epoch => true,
            _ => false,
        }
    }
}

// =============================================================================
// Memory Context (Pillar 1)
// =============================================================================

/// Memory management context for a task
///
/// Provides CBGR tier selection, allocator coordination, and shared ownership tracking.
/// This pillar ensures memory safety across task boundaries.
///
/// ## Performance
/// - Allocator access: ~1ns (direct pointer)
/// - Generation tracking: ~3ns (atomic increment)
/// - Shared registry lookup: ~5ns (hash lookup)
public type MemoryContext is {
    /// Current CBGR safety tier (determines runtime check overhead)
    cbgr_tier: ExecutionTier,

    /// Allocator for this context (may be arena, pool, or global)
    allocator: &dyn Alloc,

    /// Shared ownership registry for Shared<T> tracking
    shared_registry: &SharedRegistry,

    /// Generation tracker for CBGR references
    gen_tracker: GenTracker,

    /// Send boundary flag (true if crossed task boundary)
    send_boundary: Bool,

    /// Count of send boundary crossings
    send_boundary_count: Int,
};

implement MemoryContext {
    /// Create new memory context with specified tier and allocator
    public fn new(tier: ExecutionTier, allocator: &dyn Alloc) -> Self {
        Self {
            cbgr_tier: tier,
            allocator: allocator,
            shared_registry: SharedRegistry.global(),
            gen_tracker: GenTracker.new(),
            send_boundary: false,
            send_boundary_count: 0,
        }
    }

    /// Fork memory context for child task
    ///
    /// Child inherits allocator reference but gets fresh generation tracking.
    /// Send boundary is marked to indicate cross-task reference.
    @inline
    public fn fork(&self) -> Self {
        Self {
            cbgr_tier: self.cbgr_tier,
            allocator: self.allocator,
            shared_registry: self.shared_registry,
            gen_tracker: GenTracker.new(), // Fresh generation for child
            send_boundary: true, // Mark as crossed task boundary
            send_boundary_count: 0,
        }
    }

    /// Mark send boundary crossing
    @inline
    public fn mark_send_boundary(&mut self) {
        self.send_boundary = true;
        self.send_boundary_count += 1;
    }
}

/// Generation tracker for CBGR reference validation
public type GenTracker is {
    /// Current generation counter
    current_gen: AtomicU64,

    /// Epoch for temporal memory safety
    current_epoch: AtomicU64,
};

implement GenTracker {
    public fn new() -> Self {
        Self {
            current_gen: AtomicU64.new(1),
            current_epoch: AtomicU64.new(1),
        }
    }

    /// Allocate new generation ID
    @inline
    public fn alloc_gen(&self) -> UInt64 {
        self.current_gen.fetch_add(1, MemoryOrdering.SeqCst)
    }

    /// Get current epoch
    @inline
    public fn current_epoch(&self) -> UInt64 {
        self.current_epoch.load(MemoryOrdering.Acquire)
    }

    /// Advance epoch (invalidates all epoch-scoped references)
    @inline
    public fn advance_epoch(&self) -> UInt64 {
        self.current_epoch.fetch_add(1, MemoryOrdering.SeqCst)
    }
}

/// Shared ownership registry for tracking Shared<T> references
///
/// This is an opaque handle to the runtime's shared reference tracking system.
/// The actual implementation is provided by VBC intrinsics.
public type SharedRegistry is {
    /// Opaque handle to the registry implementation
    _handle: Int,
};

implement SharedRegistry {
    /// Get global shared registry
    public fn global() -> &Self {
        // VBC intrinsic: direct access to global singleton
        shared_registry_global()
    }
}

// =============================================================================
// Capability Context (Pillar 2)
// =============================================================================

/// Capability context for dependency injection and context propagation
///
/// Uses slot-based storage for O(1) context lookup (~2ns) instead of
/// HashMap-based storage (~20ns). This is critical for high-performance
/// context access in hot paths.
///
/// ## Storage Model
///
/// - **Slots (0-255)**: Reserved for well-known context types (compile-time indices)
/// - **Static deps**: @injectable dependencies (zero runtime overhead)
/// - **Dynamic ctx**: provide/using runtime contexts
///
/// ## Performance
/// - Slot lookup: ~2ns (array index)
/// - Dynamic lookup: ~20ns (HashMap)
/// - Middleware chain: ~5ns per middleware
public type CapabilityContext is {
    /// Fixed-size slot array for well-known contexts
    /// Indexed by compile-time assigned TypeId → slot mapping
    slots: ContextSlots,

    /// Static dependencies from @injectable (zero overhead via inlining)
    static_deps: &Map<TypeId, &dyn Any>,

    /// Dynamic contexts from provide/using
    dynamic_ctx: &Map<TypeId, &dyn Any>,

    /// Parent snapshot for panic isolation
    parent_snapshot: Maybe<&CapabilityContext>,

    /// Middleware chain for context operations
    middleware_chain: &MiddlewareChain,
};

implement CapabilityContext {
    /// Create new capability context
    public fn new() -> Self {
        Self {
            slots: ContextSlots.new(),
            static_deps: &Map.new(),
            dynamic_ctx: &Map.new(),
            parent_snapshot: None,
            middleware_chain: &MiddlewareChain.empty(),
        }
    }

    /// Fork capability context for child task (shallow clone)
    ///
    /// Child inherits all contexts via reference sharing.
    /// Parent snapshot is set for panic isolation.
    @inline
    public fn fork(&self) -> Self {
        Self {
            slots: self.slots.clone(), // Shallow copy of slot array
            static_deps: self.static_deps,
            dynamic_ctx: self.dynamic_ctx,
            parent_snapshot: Some(self),
            middleware_chain: self.middleware_chain,
        }
    }

    /// Get context by slot index (fast path, ~2ns)
    @inline
    public fn get_slot<T>(&self, slot: Int) -> Maybe<&T> {
        self.slots.get<T>(slot)
    }

    /// Set context in slot
    @inline
    public fn set_slot<T>(&mut self, slot: Int, value: &T) {
        self.slots.set(slot, value);
    }

    /// Get dynamic context by type (~20ns)
    public fn get<T>(&self) -> Maybe<&T> {
        // First check slots (compile-time known types)
        let slot = @const_slot_for<T>();
        if slot < CONTEXT_SLOT_COUNT {
            return self.slots.get<T>(slot);
        }

        // Fall back to dynamic lookup
        let type_id = TypeId.of<T>();
        self.dynamic_ctx.get(&type_id)
            .map(|any| any.downcast_ref<T>())
            .flatten()
    }

    /// Provide dynamic context
    public fn provide<T>(&mut self, value: &T) {
        let type_id = TypeId.of<T>();
        self.dynamic_ctx.insert(type_id, value as &dyn Any);
    }

    /// Cleanup contexts on scope exit
    public fn cleanup(&mut self) {
        // Dynamic contexts are reference-counted, cleanup happens automatically
        self.dynamic_ctx = &Map.new();
    }
}

/// Middleware chain for context operations
public type MiddlewareChain is {
    middlewares: List<&dyn ContextMiddleware>,
};

implement MiddlewareChain {
    public fn empty() -> &Self {
        // Static empty chain singleton
        middleware_chain_empty()
    }
}

/// Context middleware protocol
public type ContextMiddleware is protocol {
    fn on_provide(&self, type_id: TypeId, value: &dyn Any) -> Result<(), ContextError>;
    fn on_access(&self, type_id: TypeId) -> Result<(), ContextError>;
};

// =============================================================================
// Recovery Context (Pillar 3)
// =============================================================================

/// Error recovery context providing fault tolerance
///
/// Implements Erlang/OTP-style supervision with:
/// - Supervision tree integration
/// - Circuit breakers (inline storage, no heap allocation)
/// - Retry policies (inline storage)
/// - Defer stack for cleanup
///
/// ## Inline Storage
///
/// To achieve zero-allocation error recovery, we use inline arrays:
/// - 8 circuit breakers inline (covers 99% of use cases)
/// - 4 retry policies inline
/// - Overflow spills to heap (rare case)
///
/// ## Performance
/// - Circuit breaker check: ~10ns
/// - Retry policy check: ~5ns
/// - Supervision lookup: ~15ns
public type RecoveryContext is {
    /// Parent supervisor handle (if supervised)
    supervision: Maybe<&Supervisor>,

    /// Inline circuit breakers (no heap allocation for common case)
    circuit_breakers_inline: [EnvInlineCircuitBreaker; 8],
    circuit_breaker_count: UInt8,

    /// Overflow circuit breakers (heap, rare)
    circuit_breakers_overflow: Maybe<&Map<Text, CircuitBreaker>>,

    /// Inline retry policies
    retry_policies_inline: [EnvInlineRetryPolicy; 4],
    retry_policy_count: UInt8,

    /// Overflow retry policies (heap, rare)
    retry_policies_overflow: Maybe<&Map<TypeId, RecoveryRetryPolicy>>,

    /// Defer stack for cleanup handlers
    defer_stack: &List<DeferHandler>,
};

/// Inline circuit breaker (fits in 64 bytes)
@repr(C)
@size(64)
public type EnvInlineCircuitBreaker is {
    /// Service identifier (up to 24 chars inline)
    name: [Byte; 24],
    name_len: UInt8,

    /// State: 0=Closed, 1=Open, 2=HalfOpen
    state: UInt8,

    /// Failure count
    failure_count: UInt16,

    /// Success count (for half-open state)
    success_count: UInt16,

    /// Failure threshold
    failure_threshold: UInt16,

    /// Required successes to close
    required_successes: UInt16,

    /// Timeout in milliseconds
    timeout_ms: UInt32,

    /// Last state change timestamp (monotonic nanos, truncated to 32 bits = ~4 sec precision)
    last_transition_ms: UInt32,

    /// Padding
    _padding: [Byte; 18],
};

/// Inline retry policy (fits in 32 bytes)
@repr(C)
@size(32)
public type EnvInlineRetryPolicy is {
    /// Type ID hash (for matching)
    type_id_hash: UInt64,

    /// Max attempts
    max_attempts: UInt16,

    /// Current attempt
    current_attempt: UInt16,

    /// Backoff strategy: 0=Fixed, 1=Linear, 2=Exponential
    backoff_strategy: UInt8,

    /// Backoff base (milliseconds)
    backoff_base_ms: UInt16,

    /// Backoff max (milliseconds)
    backoff_max_ms: UInt16,

    /// Jitter factor (0-255 = 0%-100%)
    jitter_factor: UInt8,

    /// Padding
    _padding: [Byte; 12],
};

/// Defer handler for RAII cleanup
public type DeferHandler is fn();

implement RecoveryContext {
    /// Create new recovery context
    public fn new() -> Self {
        Self {
            supervision: None,
            circuit_breakers_inline: [EnvInlineCircuitBreaker.default(); 8],
            circuit_breaker_count: 0,
            circuit_breakers_overflow: None,
            retry_policies_inline: [EnvInlineRetryPolicy.default(); 4],
            retry_policy_count: 0,
            retry_policies_overflow: None,
            defer_stack: &List.new(),
        }
    }

    /// Inherit recovery context from parent
    @inline
    public fn inherit(&self) -> Self {
        Self {
            supervision: self.supervision,
            // Circuit breakers are NOT inherited (task-local)
            circuit_breakers_inline: [EnvInlineCircuitBreaker.default(); 8],
            circuit_breaker_count: 0,
            circuit_breakers_overflow: None,
            // Retry policies ARE inherited
            retry_policies_inline: self.retry_policies_inline,
            retry_policy_count: self.retry_policy_count,
            retry_policies_overflow: self.retry_policies_overflow,
            defer_stack: &List.new(), // Fresh defer stack
        }
    }

    /// Register circuit breaker for a service
    public fn register_circuit_breaker(&mut self, name: Text, config: CircuitBreakerConfig) {
        if self.circuit_breaker_count < 8 {
            // Inline storage
            let idx = self.circuit_breaker_count as Int;
            self.circuit_breakers_inline[idx] = EnvInlineCircuitBreaker.from_config(name, config);
            self.circuit_breaker_count += 1;
        } else {
            // Overflow to heap
            if self.circuit_breakers_overflow.is_none() {
                self.circuit_breakers_overflow = Some(&Map.new());
            }
            let overflow = self.circuit_breakers_overflow.unwrap();
            overflow.insert(name, CircuitBreaker.new(config));
        }
    }

    /// Get circuit breaker by name (~10ns inline, ~25ns overflow)
    public fn get_circuit_breaker(&self, name: &Text) -> Maybe<&CircuitBreaker> {
        // Check inline storage first
        for i in 0..self.circuit_breaker_count {
            let cb = &self.circuit_breakers_inline[i as Int];
            if cb.matches_name(name) {
                return Some(cb.as_ref());
            }
        }

        // Check overflow
        self.circuit_breakers_overflow
            .and_then(|m| m.get(name))
    }

    /// Push defer handler onto the stack
    @inline
    public fn push_defer(&mut self, handler: DeferHandler) {
        self.defer_stack.push(handler);
    }

    /// Execute all defer handlers (LIFO order)
    public fn run_defers(&mut self) {
        while let Some(handler) = self.defer_stack.pop() {
            handler();
        }
    }

    /// Cleanup recovery context
    public fn cleanup(&mut self) {
        self.run_defers();
    }
}

// =============================================================================
// Concurrency Context (Pillar 4)
// =============================================================================

/// Concurrency context for task scheduling and parallelism
///
/// Provides executor handle, I/O driver reference, isolation model,
/// and parallelism configuration. Integrates with the supervision tree.
///
/// ## Performance
/// - Spawn overhead: ~150ns (V-LLSI) vs ~500ns (tokio)
/// - Task switch: ~50ns (work-stealing) vs ~200ns (tokio)
/// - Context propagation: automatic via fork
public type ConcurrencyContext is {
    /// Executor handle for spawning tasks
    @cfg(feature = "async")
    executor: &dyn Executor,

    /// I/O driver for completion-based I/O
    @cfg(feature = "io")
    io_driver: &dyn RuntimeIoDriver,

    /// Memory isolation model
    isolation: EnvIsolationLevel,

    /// Parallelism configuration
    parallelism: ParallelismConfig,

    /// Current task identifier
    task_id: EnvTaskId,

    /// Restart policy for supervised tasks
    restart_policy: Maybe<RuntimeRestartPolicy>,

    /// Task-local storage slots
    task_locals: TaskLocalStorage,
};

/// Isolation level for memory sharing
@repr(UInt8)
public type EnvIsolationLevel is
    /// Shared: All memory visible (default)
    | Shared
    /// SendOnly: Only Send types can cross boundary
    | SendOnly
    /// Full: Complete isolation (copy-on-write semantics)
    | Full;

/// Parallelism configuration
public type ParallelismConfig is {
    /// Number of worker threads
    worker_count: Int,

    /// CPU affinity setting
    affinity: CpuAffinity,
};

/// CPU affinity mode
@repr(UInt8)
public type CpuAffinity is
    /// No affinity (OS scheduler decides)
    | None
    /// Auto affinity (runtime decides based on topology)
    | Auto
    /// Explicit affinity (user-specified core mask)
    | Explicit(UInt64);

/// Task identifier
public type EnvTaskId is {
    /// Globally unique task ID
    id: UInt64,

    /// Parent task ID (for hierarchy tracking)
    parent_id: Maybe<UInt64>,
};

implement EnvTaskId {
    /// Main task ID (always 0)
    public fn main() -> Self {
        Self { id: 0, parent_id: None }
    }

    /// Generate new task ID
    public fn new(parent: Maybe<EnvTaskId>) -> Self {
        static TASK_ID_COUNTER: AtomicU64 = AtomicU64.new(1);
        Self {
            id: TASK_ID_COUNTER.fetch_add(1, MemoryOrdering.SeqCst),
            parent_id: parent.map(|p| p.id),
        }
    }
}

/// Task-local storage (8 slots inline)
public type TaskLocalStorage is {
    slots: [&dyn Any; 8],
    slot_count: UInt8,
};

/// Restart policy for supervised tasks
public type RuntimeRestartPolicy is {
    /// Restart strategy
    strategy: RuntimeRestartStrategy,

    /// Maximum restarts within time window
    max_restarts: Int,

    /// Time window in seconds
    time_window_secs: UInt64,
};

/// Restart strategy (Erlang-style)
@repr(UInt8)
public type RuntimeRestartStrategy is
    /// Always restart on any exit
    | Permanent
    /// Restart only on abnormal exit
    | Transient
    /// Never restart
    | Temporary;

implement ConcurrencyContext {
    /// Create new concurrency context
    public fn new() -> Self {
        Self {
            @cfg(feature = "async")
            executor: default_executor(),
            @cfg(feature = "io")
            io_driver: default_io_driver(),
            isolation: EnvIsolationLevel.Shared,
            parallelism: ParallelismConfig {
                worker_count: num_cpus(),
                affinity: CpuAffinity.Auto,
            },
            task_id: EnvTaskId.main(),
            restart_policy: None,
            task_locals: TaskLocalStorage {
                slots: [&() as &dyn Any; 8],
                slot_count: 0,
            },
        }
    }

    /// Fork for child task
    @inline
    public fn fork(&self, child_id: EnvTaskId) -> Self {
        Self {
            @cfg(feature = "async")
            executor: self.executor,
            @cfg(feature = "io")
            io_driver: self.io_driver,
            isolation: self.isolation,
            parallelism: self.parallelism,
            task_id: child_id,
            restart_policy: self.restart_policy,
            task_locals: TaskLocalStorage {
                slots: [&() as &dyn Any; 8],
                slot_count: 0,
            },
        }
    }
}

// =============================================================================
// ExecutionEnv - The Unified Environment
// =============================================================================

/// Unified Execution Environment (θ+)
///
/// The central abstraction coordinating all four architectural pillars.
/// Every task executes within an ExecutionEnv that provides transparent
/// access to memory management, context system, error recovery, and
/// concurrency primitives.
///
/// ## Transparency
///
/// Developers don't interact with ExecutionEnv directly. Instead,
/// language features compose through it automatically:
/// - `&T` uses memory context for CBGR checks
/// - `using [Ctx]` uses capability context for resolution
/// - `Result` uses recovery context for retry/circuit breaker
/// - `spawn` uses concurrency context for task creation
///
/// ## Thread Safety
///
/// ExecutionEnv is task-local (NOT Send/Sync). Each task gets its own
/// environment via fork(). Contexts are shared via Shared pointers.
public type ExecutionEnv is {
    /// Unique environment ID
    id: UInt64,

    /// Creation timestamp (monotonic nanoseconds)
    created_at: UInt64,

    /// Parent environment ID (if forked)
    parent_id: Maybe<UInt64>,

    /// Environment flags (debug, monitoring, profiling)
    flags: EnvFlags,

    /// Pillar 1: Memory Management
    memory: MemoryContext,

    /// Pillar 2: Capabilities (Contexts)
    capabilities: CapabilityContext,

    /// Pillar 3: Error Recovery
    error_recovery: RecoveryContext,

    /// Pillar 4: Concurrency
    concurrency: ConcurrencyContext,
};

/// Environment configuration flags
@repr(C)
public type EnvFlags is {
    /// Enable runtime monitoring
    monitoring: Bool,

    /// Enable performance profiling
    profiling: Bool,

    /// Debug mode (extra checks)
    debug: Bool,

    /// Padding
    _padding: [Byte; 1],
};

/// Static counter for environment IDs
static ENV_ID_COUNTER: AtomicU64 = AtomicU64.new(1);

implement ExecutionEnv {
    /// Create new execution environment with default configuration
    ///
    /// # Performance
    /// - ~800ns (initialization of all 4 pillars)
    public fn new() -> Self {
        let id = ENV_ID_COUNTER.fetch_add(1, MemoryOrdering.SeqCst);
        let created_at = monotonic_nanos();

        Self {
            id: id,
            created_at: created_at,
            parent_id: None,
            flags: EnvFlags {
                monitoring: false,
                profiling: false,
                debug: @cfg(debug_assertions),
                _padding: [0; 1],
            },
            memory: MemoryContext.new(
                detect_optimal_tier(),
                global_allocator(),
            ),
            capabilities: CapabilityContext.new(),
            error_recovery: RecoveryContext.new(),
            concurrency: ConcurrencyContext.new(),
        }
    }

    /// Fork environment for spawned task (inherits parent state)
    ///
    /// # Performance
    /// - ~50-70ns (shallow copy of all contexts)
    ///
    /// # Context Inheritance
    /// - Memory: New generation tracking, same allocator
    /// - Capabilities: All contexts inherited (shallow clone)
    /// - Error Recovery: Retry policies inherited, circuit breakers fresh
    /// - Concurrency: Same executor, new task ID
    @inline
    public fn fork(&self) -> Self {
        let child_id = EnvTaskId.new(Some(self.concurrency.task_id));

        Self {
            id: ENV_ID_COUNTER.fetch_add(1, MemoryOrdering.SeqCst),
            created_at: monotonic_nanos(),
            parent_id: Some(self.id),
            flags: self.flags,
            memory: self.memory.fork(),
            capabilities: self.capabilities.fork(),
            error_recovery: self.error_recovery.inherit(),
            concurrency: self.concurrency.fork(child_id),
        }
    }

    /// Get environment ID
    @inline
    public fn id(&self) -> UInt64 {
        self.id
    }

    /// Get parent ID
    @inline
    public fn parent_id(&self) -> Maybe<UInt64> {
        self.parent_id
    }

    /// Get environment age in nanoseconds
    @inline
    public fn age_nanos(&self) -> UInt64 {
        monotonic_nanos() - self.created_at
    }

    /// Get memory context
    @inline
    public fn memory(&self) -> &MemoryContext {
        &self.memory
    }

    /// Get mutable memory context
    @inline
    public fn memory_mut(&mut self) -> &mut MemoryContext {
        &mut self.memory
    }

    /// Get capabilities context
    @inline
    public fn capabilities(&self) -> &CapabilityContext {
        &self.capabilities
    }

    /// Get mutable capabilities context
    @inline
    public fn capabilities_mut(&mut self) -> &mut CapabilityContext {
        &mut self.capabilities
    }

    /// Get error recovery context
    @inline
    public fn error_recovery(&self) -> &RecoveryContext {
        &self.error_recovery
    }

    /// Get mutable error recovery context
    @inline
    public fn error_recovery_mut(&mut self) -> &mut RecoveryContext {
        &mut self.error_recovery
    }

    /// Get concurrency context
    @inline
    public fn concurrency(&self) -> &ConcurrencyContext {
        &self.concurrency
    }

    /// Get mutable concurrency context
    @inline
    public fn concurrency_mut(&mut self) -> &mut ConcurrencyContext {
        &mut self.concurrency
    }

    /// Execute async function with automatic recovery
    ///
    /// Applies the environment's recovery strategy (retry, circuit breaker)
    /// to the given async function.
    @cfg(feature = "async")
    public async fn execute_with_recovery<F, T, E>(
        &self,
        future_factory: fn() -> Future<Result<T, E>>,
    ) -> Result<T, E> {
        // Check circuit breaker first
        // Retry with backoff if configured
        // Execute defers on completion
        exec_with_recovery(self, future_factory)
    }

    /// Cleanup resources on scope exit
    public fn cleanup(&mut self) {
        self.capabilities.cleanup();
        self.error_recovery.cleanup();
    }
}

// Automatic cleanup on drop
implement Drop for ExecutionEnv {
    fn drop(&mut self) {
        self.cleanup();
    }
}

// =============================================================================
// Helper Functions
// =============================================================================

/// Detect optimal CBGR tier for current platform
fn detect_optimal_tier() -> ExecutionTier {
    @cfg(debug_assertions)
    { return ExecutionTier.Tier0_Full; }

    @cfg(runtime = "embedded")
    { return ExecutionTier.Tier3_Unchecked; }

    // Default: epoch-based CBGR
    ExecutionTier.Tier1_Epoch
}

/// Get global allocator reference
fn global_allocator() -> &dyn Alloc {
    global_allocator_intrinsic()
}

/// Get default executor
@cfg(feature = "async")
fn default_executor() -> &dyn Executor {
    default_executor_intrinsic()
}

/// Get default I/O driver
@cfg(feature = "io")
fn default_io_driver() -> &dyn RuntimeIoDriver {
    default_io_driver_intrinsic()
}
