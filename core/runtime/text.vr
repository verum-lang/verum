@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LCls,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module runtime.text;

// RUNTIME-DUPLICATE-TREE-1 (task #5/#15): this module used to REDECLARE
// the runtime intrinsics under dead `@intrinsic("verum.runtime.*")` keys
// that no registry entry matched (calls resolved to nil).  It is now a
// thin re-export of the canonical, wired declarations in
// `core.intrinsics.runtime.text` — one source of truth, both tiers.
public mount core.intrinsics.runtime.text.{
    text_from_static,
    utf8_decode_char,
    utf8_decode_char_len,
    text_parse_int,
    text_parse_float,
    int_to_text,
    float_to_text,
    char_is_alphabetic,
    char_is_numeric,
    char_is_whitespace,
    char_is_control,
    char_is_uppercase,
    char_is_lowercase,
    char_to_uppercase,
    char_to_lowercase,
    char_encode_utf8,
    char_escape_debug,
    char_general_category,
};
