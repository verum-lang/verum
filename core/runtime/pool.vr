// =============================================================================
// runtime/pool.vr - Thread Pool for Lightweight Task Scheduling
// =============================================================================
// Layer: 4 (Runtime)
// Dependencies: core
// =============================================================================
//
// Provides a work-stealing thread pool backed by OS threads with a shared
// task queue. Unlike spawn (which creates 1 OS thread per task), the pool
// reuses a fixed set of worker threads.
//
// Usage:
//   let pool = ThreadPool.new(4);         // 4 workers
//   let h1 = pool.submit(compute, arg1);  // Submit tasks
//   let h2 = pool.submit(compute, arg2);
//   let r1 = h1.await();                  // Collect results
//   let r2 = h2.await();
//   pool.destroy();
//
//   // Or use the global pool:
//   let h = ThreadPool.global_submit(compute, arg);
//   let r = h.await();
//
// =============================================================================

module pool;

mount core.*;

// =============================================================================
// Thread Pool
// =============================================================================

/// A fixed-size thread pool for scheduling lightweight tasks.
///
/// Workers share a single bounded queue protected by a mutex+condvar.
/// Capacity: 4096 pending tasks, up to 64 worker threads.
public type ThreadPool is {
    handle: Int,
};

/// A handle to a submitted task, used to retrieve the result.
///
/// Drop drains the slot if the caller never awaited — keeps the
/// pool's handle table bounded under fire-and-forget submission.
public type PoolTaskHandle is {
    handle: Int,
    /// Tracks whether `await()` was called. Drop reads this so an
    /// awaited handle's drain is a no-op (the slot was already
    /// freed inside __pool_await_raw).
    awaited: Bool,
};

// Raw intrinsics (wired to C runtime)
@intrinsic("pool_create")
fn __pool_create_raw(num_workers: Int) -> Int;

@intrinsic("pool_submit")
fn __pool_submit_raw(pool: Int, func: Int, arg: Int) -> Int;

@intrinsic("pool_await")
fn __pool_await_raw(handle: Int) -> Int;

@intrinsic("pool_destroy")
fn __pool_destroy_raw(pool: Int) -> Int;

@intrinsic("pool_global_submit")
fn __pool_global_submit_raw(func: Int, arg: Int) -> Int;

implement ThreadPool {
    /// Create a new thread pool with the given number of worker threads.
    /// If num_workers <= 0, defaults to 4.
    public fn new(num_workers: Int) -> ThreadPool {
        let h = __pool_create_raw(num_workers);
        ThreadPool { handle: h }
    }

    /// Submit a task to the pool. Returns a PoolTaskHandle to await the result.
    public fn submit(&self, func: fn(Int) -> Int, arg: Int) -> PoolTaskHandle {
        let h = __pool_submit_raw(self.handle, func as Int, arg);
        PoolTaskHandle { handle: h, awaited: false }
    }

    /// Destroy the pool, joining all worker threads.
    ///
    /// Most callers should NOT call this directly — the `Drop` impl
    /// below releases the pool when the `ThreadPool` value goes out
    /// of scope. The explicit method is retained for cases where
    /// the caller needs to release resources before scope-exit
    /// (e.g. handing ownership across an FFI boundary, or shrinking
    /// pool count under memory pressure).
    public fn destroy(&self) {
        __pool_destroy_raw(self.handle);
    }

    /// Submit a task to the global (lazily initialized) thread pool.
    public fn global_submit(func: fn(Int) -> Int, arg: Int) -> PoolTaskHandle {
        let h = __pool_global_submit_raw(func as Int, arg);
        PoolTaskHandle { handle: h, awaited: false }
    }
}

// RAII: release the underlying pool when the ThreadPool value goes
// out of scope. Without this, callers had to remember to call
// destroy() manually — a classic resource-leak hazard in any
// long-running process where dozens of short-lived task-orchestration
// pools accumulate (HTTP server per-request pool, batch job pools,
// etc.). Mirrors the convention established by WaitGroup at
// core/sync/waitgroup.vr.
implement Drop for ThreadPool {
    fn drop(&mut self) {
        __pool_destroy_raw(self.handle);
    }
}

implement PoolTaskHandle {
    /// Block until the task completes and return its result. Marks
    /// the handle as awaited so the Drop impl knows the result has
    /// already been collected and the handle slot reused.
    public fn await(&mut self) -> Int {
        let result = __pool_await_raw(self.handle);
        self.awaited = true;
        result
    }
}

// RAII for the handle: if the caller never awaits, drain the slot
// on drop so the pool's handle table doesn't fill up with orphan
// entries. Awaited handles are no-ops here since __pool_await_raw
// already drained the slot.
implement Drop for PoolTaskHandle {
    fn drop(&mut self) {
        if !self.awaited {
            // Drain the result without surfacing it — the caller
            // discarded the handle so they have no expectation of
            // observing the value. Keeps the pool's handle table
            // bounded.
            let _ = __pool_await_raw(self.handle);
        }
    }
}
