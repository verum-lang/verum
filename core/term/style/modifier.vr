// =============================================================================
// style/modifier.vr - Text modifier bitfield
// =============================================================================
// Represents SGR (Select Graphic Rendition) text attributes as a compact
// bitfield. Supports composition via set operations (union, intersection,
// difference).
//
// Spec: docs/detailed/40-terminal-tui-architecture.md#6.2
// =============================================================================

module modifier;

// =============================================================================
// StyleModifier — bitfield for SGR text attributes
// =============================================================================

/// StyleModifier is a compact bitfield representing text rendering attributes.
/// Multiple modifiers can be combined via union: `StyleModifier.BOLD.union(StyleModifier.ITALIC)`.
///
/// Each constant corresponds to an SGR escape code:
///   BOLD       -> SGR 1     DIM          -> SGR 2
///   ITALIC     -> SGR 3     UNDERLINED   -> SGR 4
///   SLOW_BLINK -> SGR 5     RAPID_BLINK  -> SGR 6
///   REVERSED   -> SGR 7     HIDDEN       -> SGR 8
///   CROSSED_OUT -> SGR 9    OVERLINED    -> SGR 53
///   DOUBLE_UNDERLINED -> SGR 21          CURLY_UNDERLINED -> SGR 4:3
public type StyleModifier is {
    bits: UInt16,
};

implement StyleModifier {
    // Predefined modifier constants
    public const NONE:               StyleModifier = StyleModifier { bits: 0 };
    public const BOLD:               StyleModifier = StyleModifier { bits: 1 << 0 };
    public const DIM:                StyleModifier = StyleModifier { bits: 1 << 1 };
    public const ITALIC:             StyleModifier = StyleModifier { bits: 1 << 2 };
    public const UNDERLINED:         StyleModifier = StyleModifier { bits: 1 << 3 };
    public const SLOW_BLINK:         StyleModifier = StyleModifier { bits: 1 << 4 };
    public const RAPID_BLINK:        StyleModifier = StyleModifier { bits: 1 << 5 };
    public const REVERSED:           StyleModifier = StyleModifier { bits: 1 << 6 };
    public const HIDDEN:             StyleModifier = StyleModifier { bits: 1 << 7 };
    public const CROSSED_OUT:        StyleModifier = StyleModifier { bits: 1 << 8 };
    public const OVERLINED:          StyleModifier = StyleModifier { bits: 1 << 9 };
    public const DOUBLE_UNDERLINED:  StyleModifier = StyleModifier { bits: 1 << 10 };
    public const CURLY_UNDERLINED:   StyleModifier = StyleModifier { bits: 1 << 11 };

    /// Create an empty modifier set.
    public fn new() -> StyleModifier {
        StyleModifier.NONE
    }

    /// Return the union of two modifier sets (bitwise OR).
    /// Example: `StyleModifier.BOLD.union(StyleModifier.ITALIC)` -> bold + italic
    public fn union(self, other: StyleModifier) -> StyleModifier {
        StyleModifier { bits: self.bits | other.bits }
    }

    /// Return the intersection of two modifier sets (bitwise AND).
    /// Only modifiers present in both sets are retained.
    public fn intersection(self, other: StyleModifier) -> StyleModifier {
        StyleModifier { bits: self.bits & other.bits }
    }

    /// Return the difference of two modifier sets.
    /// Removes all modifiers in `other` from `self`.
    public fn difference(self, other: StyleModifier) -> StyleModifier {
        StyleModifier { bits: self.bits & (other.bits ^ 0xFFFF) }
    }

    /// Check whether this modifier set contains all bits in `flag`.
    /// Example: `mods.contains(StyleModifier.BOLD)` -> true if bold is set
    public fn contains(&self, flag: StyleModifier) -> Bool {
        (self.bits & flag.bits) == flag.bits
    }

    /// Check whether this modifier set is empty (no attributes set).
    public fn is_empty(&self) -> Bool {
        self.bits == 0
    }

    /// Return the symmetric difference of two modifier sets (bitwise XOR).
    /// Modifiers present in exactly one of the two sets are retained.
    public fn symmetric_difference(self, other: StyleModifier) -> StyleModifier {
        StyleModifier { bits: self.bits ^ other.bits }
    }

    /// Insert all modifiers from `other` into this set.
    /// Equivalent to union, but named for clarity in imperative contexts.
    public fn insert(self, other: StyleModifier) -> StyleModifier {
        self.union(other)
    }

    /// Remove all modifiers in `other` from this set.
    /// Equivalent to difference, but named for clarity.
    public fn remove(self, other: StyleModifier) -> StyleModifier {
        self.difference(other)
    }
}
