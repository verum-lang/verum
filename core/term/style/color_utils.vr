// =============================================================================
// style/color_utils.vr - Color utility helpers
// =============================================================================
// Quick RGB from hex, color blending, and palette generation utilities
// that wrap the core Rgb type with convenient one-liner APIs.
//
// Spec: docs/detailed/40-terminal-tui-architecture.md#16.3
// =============================================================================

module color_utils;

mount super.color.{Color, Rgb};

/// Quick RGB from hex string without Maybe (returns white on parse error).
/// Accepts "#FF8800" or "FF8800" formats.
public fn hex(h: Text) -> Color {
    match Rgb.from_hex(&h) {
        Some(rgb) => Color.Rgb(rgb),
        None => Color.White,
    }
}

/// Create an Rgb color from individual 0-255 channel values.
public fn rgb(r: Int, g: Int, b: Int) -> Color {
    Color.Rgb(Rgb.new(r as UInt8, g as UInt8, b as UInt8))
}

/// Create a grayscale Color from a single brightness value [0, 255].
public fn gray(brightness: Int) -> Color {
    let v = brightness.clamp(0, 255) as UInt8;
    Color.Rgb(Rgb.new(v, v, v))
}

/// Generate a list of Colors forming a gradient between two hex colors.
public fn hex_gradient(from_hex: Text, to_hex: Text, steps: Int) -> List<Color> {
    let from = match Rgb.from_hex(&from_hex) {
        Some(rgb) => rgb,
        None => Rgb.new(255, 255, 255),
    };
    let to = match Rgb.from_hex(&to_hex) {
        Some(rgb) => rgb,
        None => Rgb.new(255, 255, 255),
    };
    let rgbs = Rgb.gradient(from, to, steps);
    let mut colors = List.with_capacity(steps);
    for c in &rgbs {
        colors.push(Color.Rgb(c.clone()));
    }
    colors
}
