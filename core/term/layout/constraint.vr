// =============================================================================
// constraint.vr - LayoutConstraint types and TermLayout solver
// =============================================================================
// LayoutConstraint-based layout splitting for terminal areas. Supports exact lengths,
// min/max bounds, percentages, ratios, and weighted fill. The solver uses a
// greedy 5-pass algorithm with priority: Length > Min/Max > Percentage > Ratio > Fill.
//
// Spec: docs/detailed/40-terminal-tui-architecture.md#8.2
// =============================================================================

module constraint;

mount super.rect.{Rect, Margin};

/// LayoutConstraint on a single dimension (width or height).
public type LayoutConstraint is
    | Length(Int)        // Exact size in cells
    | Min(Int)          // Minimum size
    | Max(Int)          // Maximum size
    | Percentage(Int)   // Percentage of parent (0..100)
    | Ratio(Int, Int)   // Proportional ratio (numerator, denominator)
    | Fill(Int);        // Fill remaining space with weight (> 0)

/// Direction of layout splitting.
public type Direction is Horizontal | Vertical;

/// Distribution of free space among elements.
public type Flex is
    | Start          // Pack items to the start
    | Center         // Center items
    | End            // Pack items to the end
    | SpaceBetween   // Equal space between items
    | SpaceAround;   // Equal space around items

/// TermLayout solver: splits a Rect into sub-areas based on constraints.
/// Supports builder-pattern configuration.
public type TermLayout is {
    direction: Direction,
    constraints: List<LayoutConstraint>,
    margin: Margin,
    flex: Flex,
    spacing: Int,
};

implement TermLayout {
    /// Create a horizontal layout (splits width into columns).
    public fn horizontal() -> TermLayout {
        TermLayout {
            direction: Direction.Horizontal,
            constraints: List.new(),
            margin: Margin.uniform(0),
            flex: Flex.Start,
            spacing: 0,
        }
    }

    /// Create a vertical layout (splits height into rows).
    public fn vertical() -> TermLayout {
        TermLayout {
            direction: Direction.Vertical,
            constraints: List.new(),
            margin: Margin.uniform(0),
            flex: Flex.Start,
            spacing: 0,
        }
    }

    /// Set the constraints for this layout.
    public fn constraints(self, constraints: List<LayoutConstraint>) -> TermLayout {
        TermLayout { constraints: constraints, ..self }
    }

    /// Set the margin around the layout area.
    public fn margin(self, margin: Margin) -> TermLayout {
        TermLayout { margin: margin, ..self }
    }

    /// Set the flex distribution mode.
    public fn flex(self, flex: Flex) -> TermLayout {
        TermLayout { flex: flex, ..self }
    }

    /// Set spacing between items (in cells).
    public fn spacing(self, spacing: Int) -> TermLayout {
        TermLayout { spacing: spacing, ..self }
    }

    /// Split the given area into sub-areas according to constraints.
    /// Returns a list of Rects, one per constraint.
    public fn split(&self, area: Rect) -> List<Rect> {
        let inner = area.inner(self.margin);
        let total = match self.direction {
            Horizontal => inner.width,
            Vertical => inner.height,
        };

        // Subtract spacing between elements
        let n = self.constraints.len();
        if n == 0 { return List.new(); }

        let spacing_total = if n > 1 { self.spacing * (n - 1) } else { 0 };
        let available = (total - spacing_total).max(0);

        // Resolve constraint sizes
        let sizes = resolve_constraints(&self.constraints, available);

        // Apply flex distribution to remaining space
        let used = sum_list(&sizes);
        let remaining = (available - used).max(0);
        let adjusted_sizes = apply_flex(&self.flex, &sizes, remaining, n);

        // Build output rectangles along the chosen direction
        let mut result = List.with_capacity(n);
        let mut pos = match self.direction {
            Horizontal => inner.x,
            Vertical => inner.y,
        };

        for i in 0..n {
            let size = adjusted_sizes[i];
            let rect = match self.direction {
                Horizontal => Rect.new(pos, inner.y, size, inner.height),
                Vertical => Rect.new(inner.x, pos, inner.width, size),
            };
            result.push(rect);
            pos = pos + size + self.spacing;
        }

        result
    }
}

/// Resolve constraints using a greedy 5-pass algorithm.
/// Priority order: Length -> Min/Max -> Percentage -> Ratio -> Fill.
fn resolve_constraints(constraints: &List<LayoutConstraint>, available: Int) -> List<Int> {
    let n = constraints.len();
    let mut sizes = List.with_capacity(n);
    for _ in 0..n { sizes.push(0); }
    let mut remaining = available;

    // Pass 1: Exact lengths — highest priority, assigned first
    for i in 0..n {
        match constraints[i] {
            Length(v) => {
                let size = v.min(remaining).max(0);
                sizes[i] = size;
                remaining = remaining - size;
            }
            _ => {}
        }
    }

    // Pass 2: Min/Max bounds — enforce minimum and maximum constraints
    for i in 0..n {
        match constraints[i] {
            Min(v) => {
                if sizes[i] < v {
                    let add = (v - sizes[i]).min(remaining.max(0));
                    sizes[i] = sizes[i] + add;
                    remaining = remaining - add;
                }
            }
            Max(v) => {
                if sizes[i] > v {
                    let freed = sizes[i] - v;
                    sizes[i] = v;
                    remaining = remaining + freed;
                }
            }
            _ => {}
        }
    }

    // Pass 3: Percentages — computed from original available space
    for i in 0..n {
        match constraints[i] {
            Percentage(p) => {
                if sizes[i] == 0 {
                    let pct = p.clamp(0, 100);
                    let size = (available * pct / 100).min(remaining.max(0));
                    sizes[i] = size;
                    remaining = remaining - size;
                }
            }
            _ => {}
        }
    }

    // Pass 4: Ratios — proportional allocation from remaining space
    let mut ratio_total = 0;
    for i in 0..n {
        match constraints[i] {
            Ratio(num, _) => {
                if sizes[i] == 0 {
                    ratio_total = ratio_total + num;
                }
            }
            _ => {}
        }
    }
    if ratio_total > 0 {
        let ratio_pool = remaining;
        for i in 0..n {
            match constraints[i] {
                Ratio(num, den) => {
                    if sizes[i] == 0 && den > 0 {
                        let size = (ratio_pool * num / den).min(remaining.max(0));
                        sizes[i] = size;
                        remaining = remaining - size;
                    }
                }
                _ => {}
            }
        }
    }

    // Pass 5: Fill — distribute remaining space by weight
    let mut fill_total = 0;
    for i in 0..n {
        match constraints[i] {
            Fill(w) => { fill_total = fill_total + w; }
            _ => {}
        }
    }
    if fill_total > 0 && remaining > 0 {
        let fill_pool = remaining;
        let mut distributed = 0;
        let mut fill_count = 0;
        // Count how many fill items there are
        for i in 0..n {
            match constraints[i] {
                Fill(_) => { fill_count = fill_count + 1; }
                _ => {}
            }
        }
        let mut fill_idx = 0;
        for i in 0..n {
            match constraints[i] {
                Fill(w) => {
                    fill_idx = fill_idx + 1;
                    if fill_idx == fill_count {
                        // Last fill item gets all undistributed remainder (avoids rounding error)
                        sizes[i] = fill_pool - distributed;
                    } else {
                        let size = fill_pool * w / fill_total;
                        sizes[i] = size;
                        distributed = distributed + size;
                    }
                }
                _ => {}
            }
        }
    }

    sizes
}

/// Apply flex distribution: shift items based on remaining free space.
/// Returns the same sizes (flex affects positioning, not sizing for constraints).
/// For constraint layouts, flex is handled by adjusting start position.
fn apply_flex(flex: &Flex, sizes: &List<Int>, remaining: Int, n: Int) -> List<Int> {
    // For the constraint solver, flex distribution is handled in split()
    // by adjusting the starting position. The sizes themselves don't change.
    // We return a copy of sizes as-is.
    let mut result = List.with_capacity(n);
    for i in 0..n {
        result.push(sizes[i]);
    }
    result
}

/// Sum all elements in a list of integers.
fn sum_list(list: &List<Int>) -> Int {
    let mut total = 0;
    for i in 0..list.len() {
        total = total + list[i];
    }
    total
}
