// =============================================================================
// widget/mod.vr - Layer 5: Widget Library
// =============================================================================
// Composable, stateful/stateless terminal widgets.
// =============================================================================
module widget;

// Sub-modules
public module protocol;
public module block;
public module paragraph;
public module list;
public module table;
public module input;
public module gauge;
public module tabs;
public module scrollbar;

// Extended widgets
public module canvas;
public module sparkline;
public module barchart;
public module tree;
public module menu;
public module dialog;
public module spinner;
public module notification;

// Industrial-grade additions
public module textarea;
public module dropdown;
public module split;

// Re-exports — primitives
public mount .protocol.{Widget, StatefulWidget, Styled};
public mount .block.{Block, BorderType, BorderChars, Borders, Alignment};
public mount .paragraph.{Paragraph, Line, Span, Wrap};
public mount .list.{SelectableList, ListState};
public mount .table.{Table, Row, TableState};
public mount .input.{TextInput, TextInputState};
public mount .gauge.Gauge;
public mount .tabs.Tabs;
public mount .scrollbar.{Scrollbar, ScrollbarOrientation};

// Re-exports — extended
public mount .canvas.{
    Canvas, CanvasMode, Marker, Painter, PixelCanvas,
    Shape, LineShape, RectShape, CircleShape, LineSeries, ScatterPlot,
};
public mount .sparkline.{Sparkline, SparkDirection, BarSet};
public mount .barchart.{BarChart, BarGroup, Bar};
public mount .tree.{Tree, TreeItem, TreeState};
public mount .menu.{Menu, MenuItem, MenuState};
public mount .dialog.{Dialog, DialogButton, DialogState};
public mount .spinner.{Spinner, SpinnerFrames, SpinnerState};
public mount .notification.{Notification, NotificationLevel};

// Re-exports — industrial additions
public mount .textarea.{TextArea, TextAreaState, WrapMode, Pos};
public mount .dropdown.{Dropdown, DropdownState};
public mount .split.{Split, SplitState, SplitOrientation, SplitSize};
