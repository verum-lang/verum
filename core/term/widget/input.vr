// =============================================================================
// input.vr - Single-line text input widget (industrial grade)
// =============================================================================
// Layer: 5 (Widgets)
//
// Production-grade single-line editor:
//   * grapheme-cluster cursor movement (UAX #29 approximation via cell.vr
//     zero-width classification);
//   * word-wise movement (whitespace/punctuation boundaries);
//   * selection (anchor + cursor) with Shift+Arrow extensions;
//   * cut / copy / paste integration (widget-level clipboard hook — the app
//     is responsible for piping to OSC 52 if desired);
//   * bounded undo/redo history (default: 64 entries);
//   * placeholder + mask character (for password input);
//   * auto-scroll that keeps cursor visible in bounded width;
//   * `handle_key` dispatcher that implements the standard Emacs/readline
//     keybindings out of the box.
// =============================================================================
module input;

mount super.protocol.{StatefulWidget, Styled};
mount super.block.Block;
mount super.super.render.buffer.Buffer;
mount super.super.render.cell.grapheme_width;
mount super.super.render.frame.Frame;
mount super.super.layout.rect.Rect;
mount super.super.style.style.Style;
mount super.super.event.{KeyEvent, KeyCode, Modifiers};

// =============================================================================
// TextInput — the stateless widget (pure renderer / config)
// =============================================================================

/// Single-line text input with cursor.
public type TextInput is {
    block: Maybe<Block>,
    style: Style,
    cursor_style: Style,
    selection_style: Style,
    placeholder: Maybe<Text>,
    placeholder_style: Style,
    mask_char: Maybe<Char>,
};

implement TextInput {
    public fn new() -> TextInput {
        TextInput {
            block: None,
            style: Style.DEFAULT,
            cursor_style: Style.new().reversed(),
            selection_style: Style.new().reversed(),
            placeholder: None,
            placeholder_style: Style.new().dim(),
            mask_char: None,
        }
    }

    // -------- builder API ---------------------------------------------------
    public fn block(self, block: Block) -> TextInput {
        TextInput { block: Some(block), ..self }
    }

    public fn placeholder(self, text: Text) -> TextInput {
        TextInput { placeholder: Some(text), ..self }
    }

    public fn placeholder_style(self, style: Style) -> TextInput {
        TextInput { placeholder_style: style, ..self }
    }

    public fn cursor_style(self, style: Style) -> TextInput {
        TextInput { cursor_style: style, ..self }
    }

    public fn selection_style(self, style: Style) -> TextInput {
        TextInput { selection_style: style, ..self }
    }

    public fn mask(self, ch: Char) -> TextInput {
        TextInput { mask_char: Some(ch), ..self }
    }
}

implement Styled for TextInput {
    fn style(self, style: Style) -> TextInput {
        TextInput { style: style, ..self }
    }
}

// =============================================================================
// TextInputState — mutable state + editing operations
// =============================================================================

/// History snapshot — (value, cursor, anchor).
type Snapshot is (Text, Int, Int);

/// Bounded undo history (default capacity).
const DEFAULT_HISTORY_CAP: Int = 64;

/// State for the text input.
public type TextInputState is {
    value: Text,
    cursor: Int,             // byte offset
    anchor: Int,             // byte offset — equal to `cursor` when no selection
    scroll_offset: Int,      // byte offset of leftmost visible grapheme
    undo: List<Snapshot>,
    redo: List<Snapshot>,
    history_cap: Int,
};

implement TextInputState {
    public fn new() -> TextInputState {
        TextInputState {
            value: "",
            cursor: 0,
            anchor: 0,
            scroll_offset: 0,
            undo: List.new(),
            redo: List.new(),
            history_cap: DEFAULT_HISTORY_CAP,
        }
    }

    public fn with_value(value: Text) -> TextInputState {
        let len = value.len();
        TextInputState {
            value: value,
            cursor: len,
            anchor: len,
            scroll_offset: 0,
            undo: List.new(),
            redo: List.new(),
            history_cap: DEFAULT_HISTORY_CAP,
        }
    }

    /// Set the maximum number of undo snapshots kept.
    public fn history_cap(self, cap: Int) -> TextInputState {
        TextInputState { history_cap: cap.max(1), ..self }
    }

    // ---- selection ---------------------------------------------------------

    /// True iff there is a non-empty selection.
    public fn has_selection(&self) -> Bool {
        self.cursor != self.anchor
    }

    /// Return (start, end) byte offsets of the selection, cursor-first ordered.
    public fn selection_range(&self) -> (Int, Int) {
        if self.cursor <= self.anchor {
            (self.cursor, self.anchor)
        } else {
            (self.anchor, self.cursor)
        }
    }

    /// Text currently selected, or empty.
    public fn selected_text(&self) -> Text {
        let (s, e) = self.selection_range();
        if s == e { "" } else { self.value.slice(s, e) }
    }

    /// Collapse selection to the cursor.
    pub fn clear_selection(&mut self) {
        self.anchor = self.cursor;
    }

    /// Select the entire value.
    public fn select_all(&mut self) {
        self.anchor = 0;
        self.cursor = self.value.len();
    }

    // ---- history -----------------------------------------------------------

    /// Push the current state onto the undo stack (discarding redo).
    fn snapshot(&mut self) {
        if self.undo.len() >= self.history_cap {
            self.undo.remove(0);
        }
        self.undo.push((self.value.clone(), self.cursor, self.anchor));
        self.redo.clear();
    }

    public fn undo(&mut self) -> Bool {
        match self.undo.pop() {
            Some((v, c, a)) => {
                self.redo.push((self.value.clone(), self.cursor, self.anchor));
                self.value = v;
                self.cursor = c;
                self.anchor = a;
                true
            }
            None => false,
        }
    }

    public fn redo(&mut self) -> Bool {
        match self.redo.pop() {
            Some((v, c, a)) => {
                self.undo.push((self.value.clone(), self.cursor, self.anchor));
                self.value = v;
                self.cursor = c;
                self.anchor = a;
                true
            }
            None => false,
        }
    }

    // ---- mutation ----------------------------------------------------------

    /// Insert a char at cursor (replaces selection if any).
    public fn insert_char(&mut self, ch: Char) {
        self.insert_text(&ch.to_text());
    }

    /// Insert a text fragment at cursor (replaces selection if any).
    public fn insert_text(&mut self, text: &Text) {
        self.snapshot();
        if self.has_selection() {
            self.delete_selection_no_snapshot();
        }
        let before = self.value.slice(0, self.cursor);
        let after = self.value.slice(self.cursor, self.value.len());
        self.value = before + text + &after;
        self.cursor = self.cursor + text.len();
        self.anchor = self.cursor;
    }

    /// Delete the current selection without snapshotting (caller already did).
    fn delete_selection_no_snapshot(&mut self) {
        let (s, e) = self.selection_range();
        if s == e { return; }
        let before = self.value.slice(0, s);
        let after = self.value.slice(e, self.value.len());
        self.value = before + &after;
        self.cursor = s;
        self.anchor = s;
    }

    /// Delete the current selection (snapshots first). Returns the removed text.
    public fn delete_selection(&mut self) -> Text {
        if !self.has_selection() { return ""; }
        self.snapshot();
        let text = self.selected_text();
        self.delete_selection_no_snapshot();
        text
    }

    /// Backspace — remove the grapheme before cursor, or the selection.
    public fn delete_backward(&mut self) {
        if self.has_selection() {
            self.snapshot();
            self.delete_selection_no_snapshot();
            return;
        }
        if self.cursor == 0 { return; }
        let prev = grapheme_prev(&self.value, self.cursor);
        self.snapshot();
        let before = self.value.slice(0, prev);
        let after = self.value.slice(self.cursor, self.value.len());
        self.value = before + &after;
        self.cursor = prev;
        self.anchor = prev;
    }

    /// Delete — remove the grapheme after cursor, or the selection.
    public fn delete_forward(&mut self) {
        if self.has_selection() {
            self.snapshot();
            self.delete_selection_no_snapshot();
            return;
        }
        if self.cursor >= self.value.len() { return; }
        let next = grapheme_next(&self.value, self.cursor);
        self.snapshot();
        let before = self.value.slice(0, self.cursor);
        let after = self.value.slice(next, self.value.len());
        self.value = before + &after;
    }

    /// Delete word before cursor (Ctrl+W / Alt+Backspace).
    public fn delete_word_backward(&mut self) {
        if self.cursor == 0 && !self.has_selection() { return; }
        self.snapshot();
        if self.has_selection() { self.delete_selection_no_snapshot(); return; }
        let prev = word_prev(&self.value, self.cursor);
        let before = self.value.slice(0, prev);
        let after = self.value.slice(self.cursor, self.value.len());
        self.value = before + &after;
        self.cursor = prev;
        self.anchor = prev;
    }

    /// Delete word after cursor (Alt+D).
    public fn delete_word_forward(&mut self) {
        if self.cursor >= self.value.len() && !self.has_selection() { return; }
        self.snapshot();
        if self.has_selection() { self.delete_selection_no_snapshot(); return; }
        let next = word_next(&self.value, self.cursor);
        let before = self.value.slice(0, self.cursor);
        let after = self.value.slice(next, self.value.len());
        self.value = before + &after;
    }

    /// Delete from cursor to end of line (Ctrl+K).
    public fn kill_to_end(&mut self) -> Text {
        if self.cursor >= self.value.len() { return ""; }
        self.snapshot();
        let removed = self.value.slice(self.cursor, self.value.len());
        self.value = self.value.slice(0, self.cursor);
        removed
    }

    /// Delete from start of line to cursor (Ctrl+U).
    public fn kill_to_start(&mut self) -> Text {
        if self.cursor == 0 { return ""; }
        self.snapshot();
        let removed = self.value.slice(0, self.cursor);
        self.value = self.value.slice(self.cursor, self.value.len());
        self.cursor = 0;
        self.anchor = 0;
        removed
    }

    // ---- movement (caret) --------------------------------------------------

    /// Move cursor one grapheme left. If `extend_selection` is false, collapse.
    public fn move_left(&mut self, extend_selection: Bool) {
        if self.cursor > 0 {
            self.cursor = grapheme_prev(&self.value, self.cursor);
        }
        if !extend_selection { self.anchor = self.cursor; }
    }

    public fn move_right(&mut self, extend_selection: Bool) {
        if self.cursor < self.value.len() {
            self.cursor = grapheme_next(&self.value, self.cursor);
        }
        if !extend_selection { self.anchor = self.cursor; }
    }

    public fn move_word_left(&mut self, extend_selection: Bool) {
        self.cursor = word_prev(&self.value, self.cursor);
        if !extend_selection { self.anchor = self.cursor; }
    }

    public fn move_word_right(&mut self, extend_selection: Bool) {
        self.cursor = word_next(&self.value, self.cursor);
        if !extend_selection { self.anchor = self.cursor; }
    }

    public fn move_home(&mut self, extend_selection: Bool) {
        self.cursor = 0;
        if !extend_selection { self.anchor = 0; }
    }

    public fn move_end(&mut self, extend_selection: Bool) {
        self.cursor = self.value.len();
        if !extend_selection { self.anchor = self.cursor; }
    }

    // ---- clipboard helpers -------------------------------------------------

    /// Copy selection → returns the text (widget doesn't own a system clipboard).
    public fn copy(&self) -> Text {
        self.selected_text()
    }

    /// Cut selection → returns the text and removes it.
    public fn cut(&mut self) -> Text {
        if !self.has_selection() { return ""; }
        let text = self.selected_text();
        self.snapshot();
        self.delete_selection_no_snapshot();
        text
    }

    /// Paste replaces selection (or inserts at cursor).
    public fn paste(&mut self, text: &Text) {
        self.insert_text(text);
    }

    // ---- misc --------------------------------------------------------------

    /// Clear everything.
    public fn clear(&mut self) {
        self.snapshot();
        self.value = "";
        self.cursor = 0;
        self.anchor = 0;
        self.scroll_offset = 0;
    }

    /// Convenience: default key dispatcher. Returns `true` iff the key was
    /// handled. Unhandled keys bubble up to the application.
    public fn handle_key(&mut self, ke: KeyEvent) -> Bool {
        let ctrl = ke.modifiers.contains(Modifiers.CTRL);
        let shift = ke.modifiers.contains(Modifiers.SHIFT);
        let alt = ke.modifiers.contains(Modifiers.ALT);

        match ke.code {
            KeyCode.Char(c) => {
                if ctrl && !alt {
                    match c {
                        'a' | 'A' => { self.move_home(shift); true }
                        'e' | 'E' => { self.move_end(shift); true }
                        'b' | 'B' => { self.move_left(shift); true }
                        'f' | 'F' => { self.move_right(shift); true }
                        'k' | 'K' => { self.kill_to_end(); true }
                        'u' | 'U' => { self.kill_to_start(); true }
                        'w' | 'W' => { self.delete_word_backward(); true }
                        'd' | 'D' => { self.delete_forward(); true }
                        'h' | 'H' => { self.delete_backward(); true }
                        'z' | 'Z' => { self.undo(); true }
                        'y' | 'Y' => { self.redo(); true }
                        _ => false,
                    }
                } else if alt {
                    match c {
                        'b' | 'B' => { self.move_word_left(shift); true }
                        'f' | 'F' => { self.move_word_right(shift); true }
                        'd' | 'D' => { self.delete_word_forward(); true }
                        _ => false,
                    }
                } else {
                    self.insert_char(c);
                    true
                }
            }
            KeyCode.Backspace => {
                if ctrl { self.delete_word_backward(); } else { self.delete_backward(); }
                true
            }
            KeyCode.Delete => {
                if ctrl { self.delete_word_forward(); } else { self.delete_forward(); }
                true
            }
            KeyCode.Left => {
                if ctrl { self.move_word_left(shift); } else { self.move_left(shift); }
                true
            }
            KeyCode.Right => {
                if ctrl { self.move_word_right(shift); } else { self.move_right(shift); }
                true
            }
            KeyCode.Home => { self.move_home(shift); true }
            KeyCode.End => { self.move_end(shift); true }
            _ => false,
        }
    }
}

// =============================================================================
// Rendering
// =============================================================================

implement StatefulWidget for TextInput {
    type State = TextInputState;

    fn render(self, area: Rect, buf: &mut Buffer, state: &mut TextInputState) {
        let text_area = match self.block {
            Some(block) => {
                let inner = block.inner(area);
                block.render(area, buf);
                inner
            }
            None => area,
        };

        if text_area.width < 1 || text_area.height < 1 { return; }

        buf.set_style(text_area, self.style);

        // Derive displayable text (respecting mask_char).
        let display = match self.mask_char {
            Some(ch) => {
                let mut out = "";
                let mut i = 0;
                while i < state.value.len() {
                    let j = grapheme_next(&state.value, i);
                    out = out + &ch.to_text();
                    i = j;
                }
                out
            }
            None => state.value.clone(),
        };

        // Clamp scroll so cursor is visible.
        let cursor_col = column_at(&display, state.cursor);
        let scroll_col = column_at(&display, state.scroll_offset);

        if cursor_col < scroll_col {
            state.scroll_offset = state.cursor;
        } else if cursor_col >= scroll_col + text_area.width {
            // Walk scroll forward until cursor fits.
            let target = cursor_col - text_area.width + 1;
            state.scroll_offset = byte_at_column(&display, target);
        }

        if display.is_empty() {
            match self.placeholder {
                Some(ph) => {
                    buf.set_string(text_area.x, text_area.y, &ph, self.placeholder_style);
                }
                None => {}
            }
        } else {
            // Render visible slice, one grapheme at a time — wide graphemes
            // occupy two cells (second cell is marked `skip`).
            let start = state.scroll_offset;
            let mut byte = start;
            let mut col = 0;
            let (sel_s, sel_e) = state.selection_range();
            while byte < display.len() && col < text_area.width {
                let end = grapheme_next(&display, byte);
                let g = display.slice(byte, end);
                let w = grapheme_width(&g);
                let in_sel = byte >= sel_s && byte < sel_e;
                let st = if in_sel { self.selection_style } else { self.style };
                let cell = buf.get_mut(text_area.x + col, text_area.y);
                cell.set_char(&g, st);
                if w == 2 && col + 1 < text_area.width {
                    let next = buf.get_mut(text_area.x + col + 1, text_area.y);
                    next.set_char(" ", st);
                    next.skip = true;
                }
                col = col + w.max(1);
                byte = end;
            }
        }

        // Cursor overlay.
        let cursor_rel = cursor_col - column_at(&display, state.scroll_offset);
        let cursor_x = text_area.x + cursor_rel;
        if cursor_x >= text_area.x && cursor_x < text_area.right() {
            buf.get_mut(cursor_x, text_area.y).style = self.cursor_style;
        }
    }
}

// =============================================================================
// Internal helpers: grapheme & word boundaries, column bookkeeping
// =============================================================================

/// Byte offset of the next grapheme cluster boundary after `idx`.
/// Approximation: step over the base codepoint then any trailing zero-width
/// continuations (combining marks, ZWJ+linker, variation selectors).
pub fn grapheme_next(s: &Text, idx: Int) -> Int {
    let bytes = s.as_bytes();
    let n = bytes.len();
    if idx >= n { return n; }
    let mut i = idx + utf8_lead_len(bytes[idx] as Int);
    while i < n {
        let step = utf8_lead_len(bytes[i] as Int);
        let cp = decode_cp(bytes, i, step);
        if !is_grapheme_extender(cp) { break; }
        i = i + step;
    }
    i
}

/// Byte offset of the previous grapheme cluster boundary before `idx`.
pub fn grapheme_prev(s: &Text, idx: Int) -> Int {
    if idx == 0 { return 0; }
    let bytes = s.as_bytes();
    let mut i = idx - 1;
    // Walk back to the nearest lead byte.
    while i > 0 && (bytes[i] as Int & 0xC0) == 0x80 { i = i - 1; }
    // Walk further back while the preceding codepoints are extenders.
    while i > 0 {
        let step = utf8_lead_len(bytes[i] as Int);
        let cp = decode_cp(bytes, i, step);
        if !is_grapheme_extender(cp) { break; }
        // step to previous lead
        let mut j = i - 1;
        while j > 0 && (bytes[j] as Int & 0xC0) == 0x80 { j = j - 1; }
        i = j;
    }
    i
}

/// Byte offset of the next word boundary (whitespace→word or word→whitespace).
fn word_next(s: &Text, idx: Int) -> Int {
    let bytes = s.as_bytes();
    let n = bytes.len();
    let mut i = idx;
    // Skip whitespace first.
    while i < n && is_ws_byte(bytes[i]) { i = i + 1; }
    // Then advance over word chars.
    while i < n && !is_ws_byte(bytes[i]) { i = i + 1; }
    i
}

/// Byte offset of the previous word boundary.
fn word_prev(s: &Text, idx: Int) -> Int {
    let bytes = s.as_bytes();
    let mut i = idx;
    // Skip trailing whitespace backwards.
    while i > 0 && is_ws_byte(bytes[i - 1]) { i = i - 1; }
    // Then move back over word chars.
    while i > 0 && !is_ws_byte(bytes[i - 1]) { i = i - 1; }
    i
}

/// Column offset (display width) of a grapheme boundary `byte` into `s`.
fn column_at(s: &Text, byte: Int) -> Int {
    let bytes = s.as_bytes();
    let end = byte.min(bytes.len());
    let mut col = 0;
    let mut i = 0;
    while i < end {
        let j = grapheme_next(s, i);
        let g = s.slice(i, j.min(end));
        col = col + grapheme_width(&g).max(1);
        i = j;
    }
    col
}

/// Byte offset of the grapheme boundary with column >= `target`.
fn byte_at_column(s: &Text, target: Int) -> Int {
    if target <= 0 { return 0; }
    let mut col = 0;
    let mut i = 0;
    let n = s.len();
    while i < n && col < target {
        let j = grapheme_next(s, i);
        let g = s.slice(i, j);
        col = col + grapheme_width(&g).max(1);
        i = j;
    }
    i
}

// =============================================================================
// UTF-8 + codepoint classification helpers (local to input.vr)
// =============================================================================

fn utf8_lead_len(b: Int) -> Int {
    if b < 0x80 { 1 }
    else if b < 0xC0 { 1 }  // malformed — step 1 to resync
    else if b < 0xE0 { 2 }
    else if b < 0xF0 { 3 }
    else { 4 }
}

fn decode_cp(bytes: &[Byte], idx: Int, step: Int) -> Int {
    if step == 1 { return bytes[idx] as Int; }
    if step == 2 {
        let b0 = bytes[idx] as Int;
        let b1 = bytes[idx + 1] as Int;
        return ((b0 & 0x1F) << 6) | (b1 & 0x3F);
    }
    if step == 3 {
        let b0 = bytes[idx] as Int;
        let b1 = bytes[idx + 1] as Int;
        let b2 = bytes[idx + 2] as Int;
        return ((b0 & 0x0F) << 12) | ((b1 & 0x3F) << 6) | (b2 & 0x3F);
    }
    let b0 = bytes[idx] as Int;
    let b1 = bytes[idx + 1] as Int;
    let b2 = bytes[idx + 2] as Int;
    let b3 = bytes[idx + 3] as Int;
    ((b0 & 0x07) << 18) | ((b1 & 0x3F) << 12) | ((b2 & 0x3F) << 6) | (b3 & 0x3F)
}

/// UAX #29 approximation — extenders that attach to the previous grapheme.
/// Covers: combining marks (Mn/Me), ZWJ, variation selectors, BiDi format.
fn is_grapheme_extender(cp: Int) -> Bool {
    // Combining blocks.
    if cp >= 0x0300 && cp <= 0x036F { return true; }
    if cp >= 0x0483 && cp <= 0x0489 { return true; }
    if cp >= 0x0591 && cp <= 0x05BD { return true; }
    if cp == 0x05BF || cp == 0x05C1 || cp == 0x05C2 { return true; }
    if cp == 0x05C4 || cp == 0x05C5 || cp == 0x05C7 { return true; }
    if cp >= 0x0610 && cp <= 0x061A { return true; }
    if cp >= 0x064B && cp <= 0x065F { return true; }
    if cp == 0x0670 { return true; }
    if cp >= 0x06D6 && cp <= 0x06DC { return true; }
    if cp >= 0x06DF && cp <= 0x06E4 { return true; }
    if cp >= 0x06E7 && cp <= 0x06E8 { return true; }
    if cp >= 0x06EA && cp <= 0x06ED { return true; }
    if cp == 0x0711 { return true; }
    if cp >= 0x0730 && cp <= 0x074A { return true; }
    if cp >= 0x1AB0 && cp <= 0x1AFF { return true; }
    if cp >= 0x1DC0 && cp <= 0x1DFF { return true; }
    if cp >= 0x20D0 && cp <= 0x20FF { return true; }
    if cp >= 0xFE20 && cp <= 0xFE2F { return true; }

    // ZWJ, ZWNJ, BiDi controls, variation selectors.
    if cp == 0x200D { return true; }
    if cp >= 0x200B && cp <= 0x200F { return true; }
    if cp >= 0x202A && cp <= 0x202E { return true; }
    if cp >= 0x2060 && cp <= 0x206F { return true; }
    if cp >= 0xFE00 && cp <= 0xFE0F { return true; }
    if cp >= 0xE0100 && cp <= 0xE01EF { return true; }

    false
}

fn is_ws_byte(b: Byte) -> Bool {
    b == 0x20 || b == 0x09 || b == 0x0A || b == 0x0D
}
