// =============================================================================
// subscription.vr - External message sources for TEA applications
// =============================================================================
// Layer: 6 (Application Framework)
// Spec: docs/detailed/40-terminal-tui-architecture.md Section 12 (Subscriptions)
// =============================================================================
//
// In The Elm Architecture, Commands describe *outgoing* side effects (one-shot
// async tasks that produce a Msg), while Subscriptions describe *incoming*
// message streams from external sources: timers, OS signals, file watchers,
// custom async Streams.
//
// Each Subscription is hoisted to a detached task by the application
// runtime and produces Msg values into the application message channel.
// All subscription tasks observe a CancellationToken and terminate cleanly
// on Quit.
//
// =============================================================================

module subscription;

mount core.time.{Duration, Instant};
mount core.async.stream.Stream;
mount core.base.memory.Heap;

/// External message source that produces `Msg` values into the application
/// message channel. The runtime spawns a detached task for each subscription
/// and wires it to the global CancellationToken so cleanup is automatic.
///
/// Variants:
///   * `None`      — no subscription (identity element for combination).
///   * `Interval`  — fire Msg every `period` until cancelled.
///   * `Every`     — like Interval, but passes the tick timestamp.
///   * `Once`      — fire Msg exactly once after `delay`.
///   * `StreamSub` — wrap any `Stream<Item = Msg>` as a subscription.
///   * `Batch`     — run several subscriptions concurrently.
public type Subscription<Msg> is
    | None
    | Interval(Duration, fn() -> Msg)
    | Every(Duration, fn(Instant) -> Msg)
    | Once(Duration, fn() -> Msg)
    | StreamSub(Heap<dyn Stream<Item = Msg>>)
    | Batch(List<Subscription<Msg>>);

// =============================================================================
// Builders
// =============================================================================

/// No subscription — identity element.
public fn none<Msg>() -> Subscription<Msg> {
    Subscription.None
}

/// Fire `f()` every `period` (first fire after one `period`).
public fn interval<Msg>(period: Duration, f: fn() -> Msg) -> Subscription<Msg> {
    Subscription.Interval(period, f)
}

/// Fire `f(timestamp)` every `period` with the current monotonic timestamp.
public fn every<Msg>(period: Duration, f: fn(Instant) -> Msg) -> Subscription<Msg> {
    Subscription.Every(period, f)
}

/// Fire `f()` exactly once after `delay`.
public fn once<Msg>(delay: Duration, f: fn() -> Msg) -> Subscription<Msg> {
    Subscription.Once(delay, f)
}

/// Wrap an arbitrary `Stream<Item = Msg>` as a subscription.
/// The runtime pipes every produced item into the message channel.
public fn from_stream<Msg>(s: Heap<dyn Stream<Item = Msg>>) -> Subscription<Msg> {
    Subscription.StreamSub(s)
}

/// Combine several subscriptions into one. All run concurrently.
public fn batch<Msg>(subs: List<Subscription<Msg>>) -> Subscription<Msg> {
    Subscription.Batch(subs)
}
