// =============================================================================
// core.verify.codegen_soundness.ssa_construction — SSA construction preservation
// =============================================================================
//

// **CompCert-parity simulation theorem for the SSA construction pass.**
// Verum delegates SSA construction to LLVM's `mem2reg` pass via
// `crates/verum_codegen/src/llvm/`. This module records the
// kernel-discharge axiom that the lifting preserves the reaching-
// definition observability invariant.
//

// **Trust delegation**: admitted-with-IOU citing Beringer-Stark
// (CC 2002) for the constructive SSA equivalence proof, plus the
// canonical Cytron-Ferrante-Rosen-Wegman-Zadeck (TOPLAS 1991)
// algorithm specification.
//

// **The simulation invariant**: for every alloca site `a` lifted into
// an SSA value `v`, the loads dominated by `a`'s defining store
// evaluate to `store(v)` post-mem2reg.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.verify.codegen_soundness.ssa_construction;

mount core.prelude.{Bool};

/// **Kernel-discharge bridge: SSA construction preserves operational
/// semantics.**
///
/// Manifest entry: `CodegenPassId::SsaConstruction`. Status:
/// `AdmittedWithIou` citing Beringer-Stark + Cytron et al.
@framework(compcert, "Beringer, L. & Stark, K. (2002). A simple and efficient construction of Static Single Assignment form. Compiler Construction (CC 2002), LNCS 2304, 110-125. — §3 Semantic Equivalence Proof. Algorithm: Cytron, R., Ferrante, J., Rosen, B.K., Wegman, M.N., Zadeck, F.K. (1991). Efficiently computing static single assignment form. TOPLAS 13(4):451-490.")
@kernel_discharge("kernel_ssa_construction_preserves_semantics")
public axiom kernel_ssa_construction_preserves_semantics() -> Bool
    ensures true;
