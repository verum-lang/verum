// =============================================================================
// core.verify.codegen_soundness.llvm_emission — LLVM IR emission preservation
// =============================================================================
//

// **CompCert-parity simulation theorem for the post-regalloc → LLVM
// IR emission pass.** Verum's `crates/verum_codegen/src/llvm/`
// emits LLVM IR from the post-regalloc Verum IR. This module records
// the kernel-discharge axiom that the emission preserves operational
// semantics modulo LLVM-internal scheduling.
//

// **Trust delegation**: admitted-with-IOU citing Vellvm
// (Zhao et al, POPL 2012) — the canonical mechanised LLVM IR
// formalisation. Vellvm establishes the operational semantics for
// LLVM IR; Verum's emission targets that semantics.
//

// **The simulation invariant**: every Verum IR instruction `I` has
// a well-formed LLVM IR translation `tr(I)` such that
// `step(I) ⇒ step*(tr(I))` modulo LLVM-internal scheduling.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.verify.codegen_soundness.llvm_emission;

mount core.prelude.{Bool};

/// **Kernel-discharge bridge: LLVM IR emission preserves operational
/// semantics.**
///
/// Manifest entry: `CodegenPassId::LlvmEmission`. Status:
/// `AdmittedWithIou` citing Vellvm. The emitted LLVM module is
/// bisimilar to the input post-regalloc IR under Vellvm's operational
/// semantics.
@framework(vellvm, "Zhao, J., Nagarakatte, S., Martin, M.M.K., Zdancewic, S. (2012). Formalizing the LLVM intermediate representation for verified program transformations. POPL 2012, 427-440. — §4 Operational Semantics of LLVM IR; §5 Translation Validation.")
@kernel_discharge("kernel_llvm_emission_preserves_semantics")
public axiom kernel_llvm_emission_preserves_semantics() -> Bool
    ensures true;
