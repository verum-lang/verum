/// **IOU** (recorded in audit bundle `soundness-iou.json`):
/// κ-tower well-foundedness — the inaccessible-cardinal sequence
/// κ_0 < κ_1 < κ_2 < ... is a strict linear order, so the cumulative
/// hierarchy V_{κ_n} ⊆ V_{κ_m} whenever n ≤ m.  Provable in
/// ZFC + 2-inacc but not yet formalized in the kernel.
///
/// **Discharge target**: lemma `cumulative_universe_inclusion` in
/// `core/verify/kernel_v0/lemmas/sub.vr` (Phase-1 work, after
/// mathlib import in #155).
@verify(formal)
@kernel_discharge("kernel_sub_strict")
@admitted("κ-tower well-foundedness — Phase-1 sub.vr after mathlib import")
public theorem k_sub_sound(
    ctx: &Context,
    d: &Derivation,
)
    requires d is Derivation.Sub
    ensures true  // Conditional on κ-tower well-foundedness.
    proof {
        // ADMITTED — relies on ZFC + 2-inacc + cumulative-hierarchy.
        // Wired through `kernel_sub_strict` bridge.
    };
