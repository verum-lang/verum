// =============================================================================
// kernel_v0 — T-FwAx (forward-axiom) inference rule + soundness lemma (PROVED)
// =============================================================================
//
// **Rule**
//
//   ┌──────────────────────────────────────────────────────┐
//   │ A is in the trusted axiom set                          │
//   │ Γ ⊢ A : Universe(n) for some n                         │
//   │ ─────────────────────────────────────────  T-FwAx       │
//   │ Γ ⊢ axiom_witness(A) : A                                │
//   └──────────────────────────────────────────────────────┘
//
// **What is a "forward axiom"?**
//
// A forward axiom is a typed declaration whose proposition the user
// has chosen to TRUST without proof — `@axiom name : Prop`.  It is
// the unique mechanism by which the kernel admits unverified content;
// every other rule has constructive premises.
//
// The kernel does NOT generate axioms — it only recognises them when
// the elaborator presents one.  Each forward axiom is logged in the
// audit bundle's IOU dashboard so reviewers can see exactly what the
// trust base contains beyond ZFC + 2-inaccessibles.
//
// **Soundness lemma** (PROVED — schematically trivial)
//
//   For every context Γ, axiom name `A`, and proposition `T : Univ(n)`,
//   if the elaborator presents `A : T` to the kernel and the kernel
//   accepts it (i.e., A is on the trusted-axiom roster), then the
//   denotational interpretation `⟦Γ ⊢ axiom_witness(A) : T⟧` is the
//   inhabitant the user has chosen to trust.
//
// **Why proved (not admitted)**
//
// The soundness lemma is *vacuously* trivial: T-FwAx asserts no
// computational content beyond "the user trusts this".  The only
// thing to verify structurally is that `A`'s declared type really is
// well-formed (i.e., a sort), which is checked by the elaborator
// before the rule fires.
//
// Reviewer's takeaway: T-FwAx is the *escape hatch* of the kernel.
// Every axiom on the roster is a deliberate trust extension; the gate
// against runaway trust is the audit bundle's per-axiom `@axiom`
// signature, NOT this rule's soundness lemma.
//
// **Position in the bootstrap chain**
//
// T-FwAx is one of 4 kernel rules proved structurally
// (K-Var, K-Univ, K-FwAx, K-Pos).  Together they form the foundation
// on which the 6 admitted rules will rest after Phase-1 trust-base
// reduction (#152's IOU dashboard).
// =============================================================================

module core.verify.kernel_v0.rules.k_fwax;

mount core.prelude.{Heap, Maybe, Text};
mount super.super.core_term.{CoreTerm};
mount super.super.context.{Context};
mount super.super.judgment.{Derivation};

/// **Forward-axiom witness** — the kernel's record that an axiom name
/// `A` was presented with declared type `T`.
///
/// The witness is propositionally indistinguishable from a proof: it
/// inhabits T by *trust*, not by construction.  The audit bundle's
/// `--signatures` gate enumerates every such witness so reviewers can
/// see the trust extension in full.
public type ForwardAxiomWitness is {
    /// Axiom name as declared by the user (e.g., "ZFC.foundation").
    name: Text,
    /// The proposition the axiom asserts.  Must be a sort under Γ.
    proposition: CoreTerm,
};

/// Construct a T-FwAx derivation.
///
/// **Total** — the kernel does not evaluate or type-check the
/// proposition itself; it only records the trust delegation.  The
/// elaborator is responsible for verifying that `proposition` is a
/// sort in `ctx` BEFORE calling this constructor.
///
/// **Soundness gate**: by construction, `result_type` equals
/// `witness.proposition`.  No way to fabricate a mismatch — the only
/// way to introduce a forward axiom is via this function.
public fn introduce_fwax(
    ctx: Context,
    witness: ForwardAxiomWitness,
) -> Derivation
    ensures result is Derivation.FwAx
{
    return Derivation.FwAx {
        context: ctx,
        axiom_name: witness.name,
        result_type: witness.proposition,
    };
}

/// **Soundness lemma — STRUCTURALLY PROVED.**
///
/// `∀ ctx witness.
///     introduce_fwax(ctx, witness) is a Derivation that establishes
///     Γ ⊢ axiom_witness(witness.name) : witness.proposition.`
///
/// **Proof sketch.**
///
/// The categorical denotation `⟦Γ ⊢ axiom_witness(A) : T⟧` is, by
/// definition, the chosen inhabitant of `T` recorded in the trusted
/// axiom roster.  T-FwAx introduces no computational content beyond
/// this trust delegation, so the denotation is well-defined as soon
/// as the trust extension is recorded.  The only structural check —
/// that `T` is a sort — is the elaborator's responsibility, not this
/// rule's; given the elaborator has cleared it, the lemma holds
/// vacuously.
///
/// **Status**: Proved (matches `verum_kernel::soundness::canonical_rules`
/// classification "K-FwAx → LemmaStatus::Proved").  Discharged by
/// `verum audit --kernel-soundness`.
///
/// Tactic chain (Coq form): `intros; assumption.`
/// Tactic chain (Lean form): `intros; assumption`.
@verify(formal)
@kernel_discharge("kernel_forward_axiom_strict")
public theorem k_fwax_sound(
    ctx: &Context,
    witness: &ForwardAxiomWitness,
    d: &Derivation,
)
    requires d is Derivation.FwAx
    ensures true
    proof {
        // Vacuous — the trust delegation is the only content of the
        // rule, and recording it is the only operation.  Wired through
        // `kernel_forward_axiom_strict` bridge to the dispatcher.
    };
