// core.verify.certificate — user-facing view of
// `verum_kernel.SmtCertificate`.
//
// Lets user code read / construct SMT certificates —
// primarily for test code that wants to verify the certificate
// envelope shape, and for libraries that want to attach
// metadata ("I tried with timeout=30s", "strategy=Thorough")
// to the proofs they generate.
//
// The kernel rejects any certificate whose `schema_version` is
// greater than `CERTIFICATE_SCHEMA_VERSION_MAX` — bump the
// constant below in lockstep with the kernel's
// `CERTIFICATE_SCHEMA_VERSION` on every envelope change.

// Current certificate envelope schema version.
//
// Kept in sync with `verum_kernel.CERTIFICATE_SCHEMA_VERSION`.
// A newer kernel accepts any certificate at version
// `[0, CERTIFICATE_SCHEMA_VERSION_MAX]` — version 0 is the
// legacy pre-versioned form, kept for backward compatibility.
let CERTIFICATE_SCHEMA_VERSION_MAX: Int = 1;

// Summary view of an SMT certificate.
//
// This is the stdlib's minimal-footprint mirror of the kernel's
// `SmtCertificate` type. Library code that only needs to read
// the envelope metadata (schema_version / verum_version /
// backend / obligation_hash) uses this view. Constructing a
// full certificate requires calling the kernel directly —
// that's intentional, so user code can't forge trace bytes.
type CertificateSummary is {
    schema_version: Int,
    backend: Text,
    backend_version: Text,
    obligation_hash: Text,
    verum_version: Text,
    created_at: Text,
    // Metadata key/value pairs. Not inspected by the kernel;
    // carries diagnostic context end-to-end.
    metadata: List<(Text, Text)>,
};

// Check that a certificate's schema version is within the
// supported range for the current kernel build.
//
// Matches `verum_kernel.SmtCertificate.validate_schema` —
// user libraries should call this before trusting a
// certificate loaded from disk / received over the wire.
fn validate_schema(cert: CertificateSummary) -> Bool {
    cert.schema_version >= 0
        && cert.schema_version <= CERTIFICATE_SCHEMA_VERSION_MAX
}

// Look up a metadata value by key.
//
// Returns `None` if the key is not present. The order of
// metadata pairs is preserved from construction; if the same
// key appears twice, the first occurrence wins.
fn get_metadata(cert: CertificateSummary, key: Text) -> Maybe<Text> {
    for (k, v) in &cert.metadata {
        if k == key {
            return Maybe.Some(v.clone());
        }
    }
    Maybe.None
}

// Number of metadata entries.
fn metadata_count(cert: CertificateSummary) -> Int {
    cert.metadata.len()
}
