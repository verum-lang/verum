// =============================================================================
// core.verify.kernel_self_soundness — Meta-soundness escape hatch (#158)
// =============================================================================
//

// **The meta-theory layer for Verum's kernel.**
//

// Distinct from `core.verify.kernel_soundness/` (which contains the
// kernel's soundness theorem + 35 per-rule lemmas), THIS module
// records the META-theorem:
//
//   "Verum's kernel + its soundness corpus is sound under
//    Verum + κ_meta + ZFC + 2-inacc."
//
// The meta-theorem is the structured admission of Verum's
// Gödel-2nd-incompleteness escape: instead of pretending the kernel
// proves its own consistency, Verum is honest that the soundness
// claim relies on a stronger meta-theory.
//

// **Module roster**:
//
//   1. `predicative_reflection.vr` — MSFS-grounded reflection
//      tower. Four structural facts: REF^0 base footprint
//      (subsumes the rank-1 meta-soundness claim — kernel sound in
//      Verum + κ_meta), REF^≥1 theory-level idempotence (MSFS
//      Theorem 9.6(b)), REF^ω boundedness (MSFS Theorem 8.2),
//      REF^Abs absolute-boundary emptiness (MSFS Theorem 5.1,
//      AFN-T α). Each substantive theorem is machine-verified in
//      the MSFS corpus.
//
// **Architectural alignment**: mirrors `codegen_soundness/` (#162)
// and `separation_soundness/` (#161 V0). All three follow the same
// kernel-discharge pattern — declarations citing
// `@kernel_discharge(<intrinsic>)` + matching dispatcher arms +
// audit-gate visibility.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1"),
)
module core.verify.kernel_self_soundness.mod;

mount super.predicative_reflection.{
    kernel_reflection_tower_base,
    kernel_reflection_tower_stable,
    kernel_reflection_tower_omega_bounded,
    kernel_reflection_tower_absolute_boundary,
};
