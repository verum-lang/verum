// =============================================================================
// net/http3/frame.vr — HTTP/3 frame types (RFC 9114 §7)
// =============================================================================
// Each frame = varint(type) + varint(length) + payload. Unlike HTTP/2
// there is no fixed 9-byte header — length is a QUIC-style variable-
// length integer.
// =============================================================================

module core.net.http3.frame;

mount core.*;
mount core.encoding.varint.{quic_encode_into, quic_decode, VarintError, VarintErrorKind};
mount core.net.http3.error.{Http3Error, Http3ErrorCode};

public type H3FrameType is
    | Data            // 0x0
    | Headers         // 0x1
    | CancelPush      // 0x3
    | Settings        // 0x4
    | PushPromise     // 0x5
    | GoAway          // 0x7
    | MaxPushId       // 0xD
    | Reserved(UInt64);

implement H3FrameType {
    public fn to_u64(&self) -> UInt64 {
        match self {
            H3FrameType.Data         => 0x0,
            H3FrameType.Headers      => 0x1,
            H3FrameType.CancelPush   => 0x3,
            H3FrameType.Settings     => 0x4,
            H3FrameType.PushPromise  => 0x5,
            H3FrameType.GoAway       => 0x7,
            H3FrameType.MaxPushId    => 0xD,
            H3FrameType.Reserved(v)  => *v,
        }
    }

    public fn from_u64(v: UInt64) -> H3FrameType {
        match v {
            0x0 => H3FrameType.Data,
            0x1 => H3FrameType.Headers,
            0x3 => H3FrameType.CancelPush,
            0x4 => H3FrameType.Settings,
            0x5 => H3FrameType.PushPromise,
            0x7 => H3FrameType.GoAway,
            0xD => H3FrameType.MaxPushId,
            _   => H3FrameType.Reserved(v),
        }
    }
}

// SETTINGS identifiers (RFC 9114 §7.2.4.1)
public const H3_SETTINGS_QPACK_MAX_TABLE_CAPACITY: UInt64 = 0x01;
public const H3_SETTINGS_MAX_FIELD_SECTION_SIZE: UInt64   = 0x06;
public const H3_SETTINGS_QPACK_BLOCKED_STREAMS: UInt64    = 0x07;

public type Http3Frame is
    | DataFrame { stream_id: UInt64, data: List<Byte> }
    | HeadersFrame { stream_id: UInt64, encoded_headers: List<Byte> }
    | SettingsFrame { params: List<(UInt64, UInt64)> }
    | CancelPushFrame { push_id: UInt64 }
    | PushPromiseFrame { push_id: UInt64, encoded_headers: List<Byte> }
    | GoAwayFrame { stream_id: UInt64 }
    | MaxPushIdFrame { push_id: UInt64 }
    | UnknownFrame { type_: UInt64, payload: List<Byte> };

// =============================================================================
// Varint codec — thin re-export over core.encoding.varint.quic_*
// =============================================================================
//
// QUIC/H3 varint lives in `core.encoding.varint` so that the full QUIC
// transport stack (and other consumers like transport_parameters) can
// reach for it without importing an HTTP/3-internal module. The two
// wrappers below preserve the historical H3-level names + error type
// and should be considered deprecated for new call sites.

/// Encode `value` as a QUIC varint (1, 2, 4, or 8 bytes).
/// Deprecated: prefer `core.encoding.varint.quic_encode_into` directly.
public fn write_varint(out: &mut List<Byte>, value: UInt64) {
    let _ = quic_encode_into(out, value);
}

/// Decode a QUIC varint starting at `buf[pos]`, returning (value, next_pos).
/// Deprecated: prefer `core.encoding.varint.quic_decode` directly.
public fn read_varint(buf: &[Byte], pos: Int) -> Result<(UInt64, Int), Http3Error> {
    match quic_decode(buf, pos) {
        Ok((v, next)) => Ok((v, next)),
        Err(_)        => Err(Http3Error.NeedMore),
    }
}
