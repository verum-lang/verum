// =============================================================================
// net/http3/error.vr — HTTP/3 error codes (RFC 9114 §8.1)
// =============================================================================

module core.net.http3.error;

mount core.*;

public type Http3ErrorCode is {
    code: UInt64,
}

implement Http3ErrorCode {
    public const H3_NO_ERROR: UInt64                  = 0x100;
    public const H3_GENERAL_PROTOCOL_ERROR: UInt64    = 0x101;
    public const H3_INTERNAL_ERROR: UInt64            = 0x102;
    public const H3_STREAM_CREATION_ERROR: UInt64     = 0x103;
    public const H3_CLOSED_CRITICAL_STREAM: UInt64    = 0x104;
    public const H3_FRAME_UNEXPECTED: UInt64          = 0x105;
    public const H3_FRAME_ERROR: UInt64               = 0x106;
    public const H3_EXCESSIVE_LOAD: UInt64            = 0x107;
    public const H3_ID_ERROR: UInt64                  = 0x108;
    public const H3_SETTINGS_ERROR: UInt64            = 0x109;
    public const H3_MISSING_SETTINGS: UInt64          = 0x10A;
    public const H3_REQUEST_REJECTED: UInt64          = 0x10B;
    public const H3_REQUEST_CANCELLED: UInt64         = 0x10C;
    public const H3_REQUEST_INCOMPLETE: UInt64        = 0x10D;
    public const H3_MESSAGE_ERROR: UInt64             = 0x10E;
    public const H3_CONNECT_ERROR: UInt64             = 0x10F;
    public const H3_VERSION_FALLBACK: UInt64          = 0x110;

    // QPACK errors (RFC 9204 §6)
    public const QPACK_DECOMPRESSION_FAILED: UInt64   = 0x200;
    public const QPACK_ENCODER_STREAM_ERROR: UInt64   = 0x201;
    public const QPACK_DECODER_STREAM_ERROR: UInt64   = 0x202;

    public fn new(code: UInt64) -> Http3ErrorCode { Http3ErrorCode { code: code } }
    public fn value(&self) -> UInt64 { self.code }
}

public type Http3Error is
    | ConnectionError { code: Http3ErrorCode, reason: Text }
    | StreamError { stream_id: UInt64, code: Http3ErrorCode, reason: Text }
    | FrameError(Text)
    | QpackError(Text)
    | NeedMore
    | Closed;

implement Display for Http3ErrorCode {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"0x{self.code:x}".as_str())
    }
}

implement Debug for Http3ErrorCode {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"Http3ErrorCode(0x{self.code:x})".as_str())
    }
}

implement Eq for Http3ErrorCode {
    fn eq(&self, other: &Http3ErrorCode) -> Bool {
        self.code == other.code
    }
}

implement Display for Http3Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Http3Error.ConnectionError { code, reason } =>
                f.write_str(f"HTTP/3 connection error {code}: {reason}".as_str()),
            Http3Error.StreamError { stream_id, code, reason } =>
                f.write_str(f"HTTP/3 stream {stream_id} error {code}: {reason}".as_str()),
            Http3Error.FrameError(reason)  => f.write_str(f"HTTP/3 frame error: {reason}".as_str()),
            Http3Error.QpackError(reason)  => f.write_str(f"HTTP/3 QPACK error: {reason}".as_str()),
            Http3Error.NeedMore            => f.write_str("HTTP/3: need more bytes"),
            Http3Error.Closed              => f.write_str("HTTP/3: closed"),
        }
    }
}

implement Debug for Http3Error {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Http3Error.ConnectionError { code, reason } =>
                f.write_str(f"ConnectionError {{ code: {code:?}, reason: {reason} }}".as_str()),
            Http3Error.StreamError { stream_id, code, reason } =>
                f.write_str(f"StreamError {{ stream_id: {stream_id}, code: {code:?}, reason: {reason} }}".as_str()),
            Http3Error.FrameError(reason)  => f.write_str(f"FrameError({reason})".as_str()),
            Http3Error.QpackError(reason)  => f.write_str(f"QpackError({reason})".as_str()),
            Http3Error.NeedMore            => f.write_str("NeedMore"),
            Http3Error.Closed              => f.write_str("Closed"),
        }
    }
}

implement Eq for Http3Error {
    fn eq(&self, other: &Http3Error) -> Bool {
        match (self, other) {
            (Http3Error.ConnectionError { code: ca, reason: ra },
             Http3Error.ConnectionError { code: cb, reason: rb }) => ca == cb && ra == rb,
            (Http3Error.StreamError { stream_id: sa, code: ca, reason: ra },
             Http3Error.StreamError { stream_id: sb, code: cb, reason: rb }) => sa == sb && ca == cb && ra == rb,
            (Http3Error.FrameError(a),  Http3Error.FrameError(b))  => a == b,
            (Http3Error.QpackError(a),  Http3Error.QpackError(b))  => a == b,
            (Http3Error.NeedMore,       Http3Error.NeedMore)       => true,
            (Http3Error.Closed,         Http3Error.Closed)         => true,
            _ => false,
        }
    }
}
