// =============================================================================
// net/h3/error.vr — HTTP/3 error codes (RFC 9114 §8.1, RFC 9204 §6)
// =============================================================================

module core.net.h3.error;

mount core.*;

// =============================================================================
// HTTP/3 connection + stream error codes (RFC 9114 §8.1)
// =============================================================================

public type H3ErrorCode is {
    code: UInt64,
};

implement H3ErrorCode {
    // Core HTTP/3 codes
    public const H3_NO_ERROR:                       UInt64 = 0x0100;
    public const H3_GENERAL_PROTOCOL_ERROR:         UInt64 = 0x0101;
    public const H3_INTERNAL_ERROR:                 UInt64 = 0x0102;
    public const H3_STREAM_CREATION_ERROR:          UInt64 = 0x0103;
    public const H3_CLOSED_CRITICAL_STREAM:         UInt64 = 0x0104;
    public const H3_FRAME_UNEXPECTED:               UInt64 = 0x0105;
    public const H3_FRAME_ERROR:                    UInt64 = 0x0106;
    public const H3_EXCESSIVE_LOAD:                 UInt64 = 0x0107;
    public const H3_ID_ERROR:                       UInt64 = 0x0108;
    public const H3_SETTINGS_ERROR:                 UInt64 = 0x0109;
    public const H3_MISSING_SETTINGS:               UInt64 = 0x010A;
    public const H3_REQUEST_REJECTED:               UInt64 = 0x010B;
    public const H3_REQUEST_CANCELLED:              UInt64 = 0x010C;
    public const H3_REQUEST_INCOMPLETE:             UInt64 = 0x010D;
    public const H3_MESSAGE_ERROR:                  UInt64 = 0x010E;
    public const H3_CONNECT_ERROR:                  UInt64 = 0x010F;
    public const H3_VERSION_FALLBACK:               UInt64 = 0x0110;

    // QPACK codes (RFC 9204 §6)
    public const QPACK_DECOMPRESSION_FAILED:        UInt64 = 0x0200;
    public const QPACK_ENCODER_STREAM_ERROR:        UInt64 = 0x0201;
    public const QPACK_DECODER_STREAM_ERROR:        UInt64 = 0x0202;

    public fn new(code: UInt64) -> H3ErrorCode { H3ErrorCode { code: code } }
    public fn value(&self) -> UInt64 { self.code }
}

public type H3Error is
      ConnectionError { code: H3ErrorCode, reason: Text }
    | StreamError { stream_id: UInt64, code: H3ErrorCode }
    | FrameDecode(Text)
    | StreamTypeDecode
    | UnexpectedFrame { on_stream_kind: Text, frame_type: UInt64 }
    | MissingSettings
    | SettingsRepeat
    | ConnectionClosed
    /// Streaming-body error — peer sent STOP_SENDING or the
    /// surrounding nursery was cancelled mid-stream. Writers MUST
    /// propagate; the connection is responsible for emitting the
    /// RESET_STREAM that cleans up the half-state.
    | StreamCancelled
    /// Streaming-body error — caller invoked write() after finish().
    /// Indicates a state-machine bug in the user's writer; not
    /// recoverable without restarting the stream.
    | WriteAfterFinish
    /// Streaming-body error — connection-level outbound buffer
    /// exceeded its bound. Caller should slow producer.
    | SendBufferFull;
