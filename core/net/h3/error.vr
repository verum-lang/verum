// =============================================================================
// net/h3/error.vr — HTTP/3 error codes (RFC 9114 §8.1, RFC 9204 §6)
// =============================================================================

module core.net.h3.error;

mount core.*;

// =============================================================================
// HTTP/3 connection + stream error codes (RFC 9114 §8.1)
// =============================================================================

public type H3ErrorCode is {
    code: UInt64,
};

implement H3ErrorCode {
    // Core HTTP/3 codes
    public const H3_NO_ERROR:                       UInt64 = 0x0100;
    public const H3_GENERAL_PROTOCOL_ERROR:         UInt64 = 0x0101;
    public const H3_INTERNAL_ERROR:                 UInt64 = 0x0102;
    public const H3_STREAM_CREATION_ERROR:          UInt64 = 0x0103;
    public const H3_CLOSED_CRITICAL_STREAM:         UInt64 = 0x0104;
    public const H3_FRAME_UNEXPECTED:               UInt64 = 0x0105;
    public const H3_FRAME_ERROR:                    UInt64 = 0x0106;
    public const H3_EXCESSIVE_LOAD:                 UInt64 = 0x0107;
    public const H3_ID_ERROR:                       UInt64 = 0x0108;
    public const H3_SETTINGS_ERROR:                 UInt64 = 0x0109;
    public const H3_MISSING_SETTINGS:               UInt64 = 0x010A;
    public const H3_REQUEST_REJECTED:               UInt64 = 0x010B;
    public const H3_REQUEST_CANCELLED:              UInt64 = 0x010C;
    public const H3_REQUEST_INCOMPLETE:             UInt64 = 0x010D;
    public const H3_MESSAGE_ERROR:                  UInt64 = 0x010E;
    public const H3_CONNECT_ERROR:                  UInt64 = 0x010F;
    public const H3_VERSION_FALLBACK:               UInt64 = 0x0110;

    // QPACK codes (RFC 9204 §6)
    public const QPACK_DECOMPRESSION_FAILED:        UInt64 = 0x0200;
    public const QPACK_ENCODER_STREAM_ERROR:        UInt64 = 0x0201;
    public const QPACK_DECODER_STREAM_ERROR:        UInt64 = 0x0202;

    public fn new(code: UInt64) -> H3ErrorCode { H3ErrorCode { code: code } }
    public fn value(&self) -> UInt64 { self.code }
}

public type H3Error is
      ConnectionError { code: H3ErrorCode, reason: Text }
    | StreamError { stream_id: UInt64, code: H3ErrorCode }
    | FrameDecode(Text)
    | StreamTypeDecode
    | UnexpectedFrame { on_stream_kind: Text, frame_type: UInt64 }
    | MissingSettings
    | SettingsRepeat
    | ConnectionClosed
    /// Streaming-body error — peer sent STOP_SENDING or the
    /// surrounding nursery was cancelled mid-stream. Writers MUST
    /// propagate; the connection is responsible for emitting the
    /// RESET_STREAM that cleans up the half-state.
    | StreamCancelled
    /// Streaming-body error — caller invoked write() after finish().
    /// Indicates a state-machine bug in the user's writer; not
    /// recoverable without restarting the stream.
    | WriteAfterFinish
    /// Streaming-body error — connection-level outbound buffer
    /// exceeded its bound. Caller should slow producer.
    | SendBufferFull;

implement Display for H3ErrorCode {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"0x{self.code:x}".as_str())
    }
}

implement Debug for H3ErrorCode {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"H3ErrorCode(0x{self.code:x})".as_str())
    }
}

implement Eq for H3ErrorCode {
    fn eq(&self, other: &H3ErrorCode) -> Bool {
        self.code == other.code
    }
}

implement Display for H3Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ConnectionError { code, reason } =>
                f.write_str(f"HTTP/3 connection error {code}: {reason}".as_str()),
            StreamError { stream_id, code } =>
                f.write_str(f"HTTP/3 stream {stream_id} error {code}".as_str()),
            FrameDecode(msg) =>
                f.write_str(f"HTTP/3 frame decode error: {msg}".as_str()),
            StreamTypeDecode =>
                f.write_str("HTTP/3 stream type decode error"),
            UnexpectedFrame { on_stream_kind, frame_type } =>
                f.write_str(f"HTTP/3 unexpected frame type 0x{frame_type:x} on {on_stream_kind} stream".as_str()),
            MissingSettings =>
                f.write_str("HTTP/3 missing SETTINGS frame"),
            SettingsRepeat =>
                f.write_str("HTTP/3 SETTINGS frame repeated"),
            ConnectionClosed =>
                f.write_str("HTTP/3 connection closed"),
            StreamCancelled =>
                f.write_str("HTTP/3 stream cancelled (STOP_SENDING / nursery cancellation)"),
            WriteAfterFinish =>
                f.write_str("HTTP/3 write after finish"),
            SendBufferFull =>
                f.write_str("HTTP/3 outbound buffer full"),
        }
    }
}

implement Debug for H3Error {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ConnectionError { code, reason } =>
                f.write_str(f"ConnectionError {{ code: {code:?}, reason: {reason} }}".as_str()),
            StreamError { stream_id, code } =>
                f.write_str(f"StreamError {{ stream_id: {stream_id}, code: {code:?} }}".as_str()),
            FrameDecode(msg) =>
                f.write_str(f"FrameDecode({msg})".as_str()),
            StreamTypeDecode =>
                f.write_str("StreamTypeDecode"),
            UnexpectedFrame { on_stream_kind, frame_type } =>
                f.write_str(f"UnexpectedFrame {{ on_stream_kind: {on_stream_kind}, frame_type: 0x{frame_type:x} }}".as_str()),
            MissingSettings =>
                f.write_str("MissingSettings"),
            SettingsRepeat =>
                f.write_str("SettingsRepeat"),
            ConnectionClosed =>
                f.write_str("ConnectionClosed"),
            StreamCancelled =>
                f.write_str("StreamCancelled"),
            WriteAfterFinish =>
                f.write_str("WriteAfterFinish"),
            SendBufferFull =>
                f.write_str("SendBufferFull"),
        }
    }
}

implement Eq for H3Error {
    fn eq(&self, other: &H3Error) -> Bool {
        match (self, other) {
            (ConnectionError { code: ca, reason: ra },
             ConnectionError { code: cb, reason: rb }) => ca == cb && ra == rb,
            (StreamError { stream_id: sa, code: ca },
             StreamError { stream_id: sb, code: cb }) => sa == sb && ca == cb,
            (FrameDecode(a),       FrameDecode(b))       => a == b,
            (StreamTypeDecode,     StreamTypeDecode)     => true,
            (UnexpectedFrame { on_stream_kind: ka, frame_type: ta },
             UnexpectedFrame { on_stream_kind: kb, frame_type: tb }) => ka == kb && ta == tb,
            (MissingSettings,      MissingSettings)      => true,
            (SettingsRepeat,       SettingsRepeat)       => true,
            (ConnectionClosed,     ConnectionClosed)     => true,
            (StreamCancelled,      StreamCancelled)      => true,
            (WriteAfterFinish,     WriteAfterFinish)     => true,
            (SendBufferFull,       SendBufferFull)       => true,
            _ => false,
        }
    }
}
