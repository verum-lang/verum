// =============================================================================
// net/h3/qpack/dynamic_table.vr — QPACK dynamic table (RFC 9204 §3.2.2)
// =============================================================================
// Layer: 5 (Network — HTTP/3 / QPACK)
// Dependencies: core, collections, .static_table
// =============================================================================
//
// RFC 9204 §3.2: a QPACK dynamic table is a per-direction FIFO of
// (name, value) entries maintained in parallel on the encoder and
// decoder. Encoders add via Insert instructions (on the QPACK
// encoder stream); decoders acknowledge via Section Acknowledgment
// instructions (on the decoder stream).
//
// Size accounting (RFC 9204 §3.2.1):
//
//   entry_size = name.len() + value.len() + 32
//
// The capacity limit bounds cumulative entry sizes. Eviction is
// FIFO — when adding exceeds capacity, the oldest entries are
// dropped from the front. Inserts that would require evicting an
// entry still referenced by an unacknowledged section are forbidden
// and surface as QPACK_ENCODER_STREAM_ERROR on the encoder side.
//
// # Absolute vs relative indexing
//
// Entries are addressed two ways:
//   * Absolute index — monotonically-increasing ID assigned at insert
//     time (0, 1, 2, …). Never decreases; used in decoder state.
//   * Relative index — position from the current tail ("most-recently
//     inserted"), with 0 meaning the newest. Relative = absolute -
//     insert_count.
//
// On the encoder stream, inserts use relative-from-base referencing
// (Post-Base Index); on a request/response field section header,
// inserts use absolute indexing tied to a per-section "base".
//
// =============================================================================

module core.net.h3.qpack.dynamic_table;

mount core.*;
mount core.collections.List;
mount core.net.h3.qpack.static_table.{StaticEntry, find as static_find, find_name as static_find_name, STATIC_TABLE_SIZE};

public type DynEntry is {
    name:  Text,
    value: Text,
    /// Cached byte size per RFC 9204 §3.2.1.
    size:  UInt64,
    /// Number of live field sections that still reference this entry —
    /// entry cannot be evicted while > 0.
    refs:  UInt64,
};

impl DynEntry {
    public fn new(name: Text, value: Text) -> DynEntry {
        let size = (name.as_bytes().len() as UInt64) + (value.as_bytes().len() as UInt64) + 32_u64;
        DynEntry { name: name, value: value, size: size, refs: 0_u64 }
    }
}

public type DynamicTable is {
    /// FIFO of entries, newest at the tail.
    entries:          List<DynEntry>,
    /// Cumulative size of `entries`.
    current_size:     UInt64,
    /// Hard cap the peer advertised via SETTINGS_QPACK_MAX_TABLE_CAPACITY.
    max_capacity:     UInt64,
    /// The encoder's currently-active capacity ≤ max_capacity.
    /// Set via the "Set Dynamic Table Capacity" instruction.
    capacity:         UInt64,
    /// Total inserts made so far (RFC 9204 §4.3.1 — Insert Count).
    insert_count:     UInt64,
    /// Lowest absolute index still present. `dropped_count = insert_count
    /// - entries.len() when all drops were monotonic; used to convert
    /// absolute → FIFO slot.
    dropped_count:    UInt64,
}

impl DynamicTable {
    public fn new(max_capacity: UInt64) -> DynamicTable {
        DynamicTable {
            entries:       [],
            current_size:  0_u64,
            max_capacity:  max_capacity,
            capacity:      0_u64,
            insert_count:  0_u64,
            dropped_count: 0_u64,
        }
    }

    // ==================== capacity ====================

    /// Process a "Set Dynamic Table Capacity" instruction. New
    /// capacity MUST be ≤ max_capacity (peer-declared upper bound).
    /// Evicts entries until current_size ≤ new capacity.
    public fn set_capacity(&mut self, new_cap: UInt64) -> Result<(), DynamicTableError> {
        if new_cap > self.max_capacity {
            return Err(DynamicTableError.CapacityExceedsSettings);
        }
        self.capacity = new_cap;
        self.evict_to_fit(0_u64)?;
        Ok(())
    }

    /// Returns true if inserting `entry_size` additional bytes would
    /// fit — caller checks before emitting Insert instructions.
    public fn can_insert(&self, entry_size: UInt64) -> Bool {
        // Compute what we could evict (unreferenced FIFO prefix).
        let evictable_size = self.evictable_size();
        self.current_size + entry_size <= self.capacity + evictable_size
    }

    // ==================== inserts ====================

    /// Insert a fresh (name, value). Returns the absolute index of
    /// the new entry.
    public fn insert(&mut self, name: Text, value: Text) -> Result<UInt64, DynamicTableError> {
        let entry = DynEntry.new(name, value);
        if entry.size > self.capacity {
            // RFC 9204 §3.2.2: entries larger than current capacity are
            // rejected; encoder MUST NOT emit them.
            return Err(DynamicTableError.EntryTooLarge);
        }
        self.evict_to_fit(entry.size)?;
        self.entries.push(entry.clone());
        self.current_size = self.current_size + entry.size;
        let abs = self.insert_count;
        self.insert_count = self.insert_count + 1_u64;
        Ok(abs)
    }

    /// Insert with name reference — reuse an existing entry's name;
    /// useful when encoding headers that share the common set of
    /// static-table names with new values.
    public fn insert_with_name_ref(
        &mut self,
        is_static: Bool,
        name_idx: UInt64,
        value: Text,
    ) -> Result<UInt64, DynamicTableError> {
        let name = if is_static {
            match static_table_name(name_idx) {
                Some(n) => n,
                None    => return Err(DynamicTableError.InvalidNameRef),
            }
        } else {
            match self.get_by_absolute(name_idx) {
                Some(e) => e.name.clone(),
                None    => return Err(DynamicTableError.InvalidNameRef),
            }
        };
        self.insert(name, value)
    }

    /// Duplicate — clone an existing dynamic-table entry as the new
    /// tail. Useful for the encoder to keep frequently-used entries
    /// fresh against FIFO eviction.
    public fn duplicate(&mut self, abs_idx: UInt64) -> Result<UInt64, DynamicTableError> {
        let e = match self.get_by_absolute(abs_idx) {
            Some(x) => x,
            None    => return Err(DynamicTableError.InvalidNameRef),
        };
        self.insert(e.name.clone(), e.value.clone())
    }

    // ==================== ref counting ====================

    /// Increment the reference count for `abs_idx` — caller holds a
    /// live field section referencing this entry until decoder acks.
    public fn add_ref(&mut self, abs_idx: UInt64) -> Result<(), DynamicTableError> {
        let slot = self.absolute_to_slot(abs_idx)?;
        self.entries[slot].refs = self.entries[slot].refs + 1_u64;
        Ok(())
    }

    /// Decrement ref count (field section acknowledged / cancelled).
    public fn release_ref(&mut self, abs_idx: UInt64) -> Result<(), DynamicTableError> {
        let slot = self.absolute_to_slot(abs_idx)?;
        if self.entries[slot].refs == 0_u64 {
            return Err(DynamicTableError.RefUnderflow);
        }
        self.entries[slot].refs = self.entries[slot].refs - 1_u64;
        Ok(())
    }

    // ==================== lookups ====================

    public fn get_by_absolute(&self, abs_idx: UInt64) -> Maybe<DynEntry> {
        let slot = self.absolute_to_slot(abs_idx);
        match slot {
            Ok(i) => Some(self.entries[i].clone()),
            Err(_) => None,
        }
    }

    /// Find the most-recently-inserted entry matching (name, value).
    /// Returns the absolute index or None. Iterates tail-first so
    /// freshest matches win for better encoder efficiency.
    public fn find(&self, name: &Text, value: &Text) -> Maybe<UInt64> {
        let mut i: Int = self.entries.len() - 1;
        while i >= 0 {
            let e = &self.entries[i];
            if text_eq(&e.name, name) && text_eq(&e.value, value) {
                return Some((i as UInt64) + self.dropped_count);
            }
            i = i - 1;
        }
        None
    }

    /// Find by name only — used for "Insert with Name Reference" or
    /// "Literal Field Line with Name Reference" encoder choices.
    public fn find_name(&self, name: &Text) -> Maybe<UInt64> {
        let mut i: Int = self.entries.len() - 1;
        while i >= 0 {
            let e = &self.entries[i];
            if text_eq(&e.name, name) {
                return Some((i as UInt64) + self.dropped_count);
            }
            i = i - 1;
        }
        None
    }

    // ==================== accessors ====================

    public fn insert_count(&self) -> UInt64  { self.insert_count }
    public fn capacity(&self) -> UInt64      { self.capacity }
    public fn max_capacity(&self) -> UInt64  { self.max_capacity }
    public fn current_size(&self) -> UInt64  { self.current_size }
    public fn len(&self) -> Int              { self.entries.len() }

    // ==================== internals ====================

    fn absolute_to_slot(&self, abs_idx: UInt64) -> Result<Int, DynamicTableError> {
        if abs_idx < self.dropped_count {
            return Err(DynamicTableError.EntryEvicted);
        }
        let slot = (abs_idx - self.dropped_count) as Int;
        if slot >= self.entries.len() {
            return Err(DynamicTableError.InvalidAbsIndex);
        }
        Ok(slot)
    }

    /// Total size in bytes of the unreferenced (and therefore
    /// evictable) FIFO prefix.
    fn evictable_size(&self) -> UInt64 {
        let mut acc: UInt64 = 0_u64;
        let mut i: Int = 0;
        while i < self.entries.len() {
            if self.entries[i].refs > 0_u64 { break; }
            acc = acc + self.entries[i].size;
            i = i + 1;
        }
        acc
    }

    /// Evict oldest entries (no-ref FIFO prefix) until we have room
    /// for `incoming` additional bytes.
    fn evict_to_fit(&mut self, incoming: UInt64) -> Result<(), DynamicTableError> {
        while self.current_size + incoming > self.capacity {
            if self.entries.len() == 0 {
                return Err(DynamicTableError.EntryTooLarge);
            }
            if self.entries[0].refs > 0_u64 {
                // Newest in-flight reference is keeping us from
                // evicting — fail loud per RFC 9204 §3.2.2.
                return Err(DynamicTableError.EvictionBlocked);
            }
            let head = self.entries.remove(0);
            self.current_size = self.current_size - head.size;
            self.dropped_count = self.dropped_count + 1_u64;
        }
        Ok(())
    }
}

// =============================================================================
// Error type
// =============================================================================

public type DynamicTableError is
      CapacityExceedsSettings
    | EntryTooLarge
    | EvictionBlocked
    | InvalidAbsIndex
    | InvalidNameRef
    | EntryEvicted
    | RefUnderflow;

// =============================================================================
// Helpers
// =============================================================================

fn text_eq(a: &Text, b: &Text) -> Bool { a.as_bytes() == b.as_bytes() }

fn static_table_name(idx: UInt64) -> Maybe<Text> {
    if idx >= (STATIC_TABLE_SIZE as UInt64) { return None; }
    match core.net.h3.qpack.static_table.get(idx as Int) {
        Some(e) => Some(e.name),
        None    => None,
    }
}
