// =============================================================================
// tcp.vr - TCP streams and listeners
// =============================================================================
// Layer: 5 (Network)
// Dependencies: core, io, async, net/addr, sys/
// =============================================================================
//
// # V-LLSI Migration Status
//
// This module has been migrated to use native V-LLSI system interfaces:
// - Linux: Uses sys/linux/syscall.{socket, connect, bind, listen, accept, ...}
// - macOS: Uses sys/darwin/libsystem.{safe_socket, safe_connect, ...}
// - No FFI dependencies on verum_runtime or verum_bootstrap
//
// # Performance Characteristics
//
// - Zero-copy I/O via direct syscalls
// - Minimal allocations on hot path
// - ~2ns context access for async operations
// - Direct kernel interaction without FFI overhead
//
// =============================================================================
//
// TCP (Transmission Control Protocol) provides reliable, ordered, and
// error-checked delivery of a stream of bytes.
//
// # Example - Client
// ```verum
// let stream = TcpStream.connect("127.0.0.1:8080")?;
// stream.write_all(b"GET / HTTP/1.0\r\n\r\n")?;
// let response = stream.read_to_text()?;
// ```
//
// # Example - Server
// ```verum
// let listener = TcpListener.bind("127.0.0.1:8080")?;
// for stream in listener.incoming() {
//     spawn {
//         handle_client(stream?);
//     };
// }
// ```
//
// =============================================================================

module core.net.tcp;
mount core.*;
mount io.*;
mount .addr.*;

// =============================================================================
// V-LLSI Native Socket Imports
// =============================================================================

@cfg(target_os = "linux")
mount sys.linux.syscall.{
    // Socket operations
    socket, connect, bind, listen, accept, accept4,
    send, recv, sendto, recvfrom,
    shutdown, getsockname, getpeername,
    // Socket options
    setsockopt_int, getsockopt_error,
    set_nonblocking, set_reuseaddr, set_reuseport,
    set_tcp_nodelay, set_keepalive, set_socket_timeout,
    // File operations (sockets are fds)
    read, write, close, fcntl,
    // Types
    FileDesc, SockaddrIn, OSError,
    // Constants
    AF_INET, AF_INET6, SOCK_STREAM, SOCK_NONBLOCK, SOCK_CLOEXEC,
    SOL_SOCKET, SOL_TCP, SO_ERROR,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
};

@cfg(target_os = "windows")
mount sys.windows.winsock2.{
    // POSIX-compatible wrappers from winsock2.vr
    socket, connect, bind, listen, accept, accept4,
    send, recv, sendto, recvfrom,
    shutdown, getsockname, getpeername,
    // Socket options
    setsockopt_int, getsockopt_error,
    set_nonblocking, set_reuseaddr, set_reuseport,
    set_tcp_nodelay, set_keepalive, set_socket_timeout,
    // File operations
    read, write, close,
    // Types
    FileDesc, SockaddrIn, OSError,
    // Constants
    AF_INET, AF_INET6, SOCK_STREAM, SOCK_NONBLOCK, SOCK_CLOEXEC,
    SOL_SOCKET, SOL_TCP, SO_ERROR,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
};

@cfg(target_os = "macos")
mount sys.darwin.libsystem.{
    // Socket operations - aliased to sys_* for platform abstraction
    safe_socket as sys_socket,
    safe_connect as sys_connect,
    safe_bind as sys_bind,
    safe_listen as sys_listen,
    safe_accept as sys_accept,
    safe_send as sys_send,
    safe_recv as sys_recv,
    safe_shutdown as sys_shutdown,
    safe_getsockname,
    safe_getpeername,
    // Socket options
    safe_setsockopt_int,
    safe_getsockopt_error,
    safe_set_nonblocking,
    safe_set_reuseaddr,
    safe_set_tcp_nodelay,
    safe_set_keepalive,
    safe_set_nosigpipe,
    safe_set_socket_timeout,
    // File operations (sockets are fds)
    safe_close as sys_close,
    safe_fcntl,
    // Types
    SockaddrIn,
    // Constants
    AF_INET, AF_INET6, SOCK_STREAM,
    SOL_SOCKET, IPPROTO_TCP, SO_ERROR,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
};

@cfg(target_os = "macos")
mount sys.common.{FileDesc, OSError};

@cfg(target_os = "windows")
mount sys.windows.winsock2.{
    // Socket operations
    socket, connect, bind, listen, accept, accept4,
    send, recv, sendto, recvfrom,
    shutdown, getsockname, getpeername,
    // Socket options
    setsockopt_int, getsockopt_error,
    set_nonblocking, set_reuseaddr, set_reuseport,
    set_tcp_nodelay, set_keepalive, set_socket_timeout,
    // File operations (sockets map to these on Windows)
    read, write, close, fcntl,
    // Types
    FileDesc, OSError,
    // Constants
    AF_INET, AF_INET6, SOCK_STREAM, SOCK_NONBLOCK, SOCK_CLOEXEC,
    SOL_SOCKET, SOL_TCP, SO_ERROR,
    SHUT_RD, SHUT_WR, SHUT_RDWR,
};

@cfg(target_os = "windows")
mount sys.common.{FileDesc, OSError};

// Import I/O engine for async operations
mount sys.io_engine.{IOEngine, IOInterest, IoError};

// =============================================================================
// AsyncIoReady - Future for async I/O readiness
// =============================================================================

/// Future that completes when a file descriptor becomes ready for I/O.
///
/// Uses the native V-LLSI IOEngine (io_uring on Linux, kqueue on macOS)
/// for efficient event notification with minimal syscall overhead.
type AsyncIoReady is {
    fd: FileDesc,
    interest: IOInterest,
    registered: Bool,
};

implement AsyncIoReady {
    /// Create a new async I/O readiness future.
    fn new(fd: FileDesc, interest: IOInterest) -> AsyncIoReady {
        AsyncIoReady {
            fd: fd,
            interest: interest,
            registered: false,
        }
    }

    /// Create for read readiness.
    fn readable(fd: FileDesc) -> AsyncIoReady {
        AsyncIoReady.new(fd, IOInterest.Read)
    }

    /// Create for write readiness.
    fn writable(fd: FileDesc) -> AsyncIoReady {
        AsyncIoReady.new(fd, IOInterest.Write)
    }
}

implement Future for AsyncIoReady {
    type Output = ();

    fn poll(&mut self, cx: &mut Context) -> Poll<()> {
        // Get the I/O engine from runtime context
        let io_engine = IOEngine.current();

        if !self.registered {
            // Register interest with the I/O engine
            io_engine.register(self.fd, self.interest, cx.waker());
            self.registered = true;
            return Poll.Pending;
        }

        // Check if ready
        if io_engine.is_ready(self.fd, self.interest) {
            io_engine.unregister(self.fd, self.interest);
            Poll.Ready(())
        } else {
            // Re-register waker in case it changed
            io_engine.update_waker(self.fd, self.interest, cx.waker());
            Poll.Pending
        }
    }
}

implement Drop for AsyncIoReady {
    fn drop(&mut self) {
        if self.registered {
            let io_engine = IOEngine.current();
            io_engine.unregister(self.fd, self.interest);
        }
    }
}

// =============================================================================
// TcpStream
// =============================================================================

/// A TCP stream between a local and a remote socket.
///
/// After creating a TcpStream by either connecting to a remote host or
/// accepting a connection on a TcpListener, data can be transmitted using
/// the Read and Write protocols.
///
/// # Performance Characteristics
///
/// - Direct syscall access: ~50ns per operation (no FFI overhead)
/// - Zero-copy reads when using read_into()
/// - MSG_NOSIGNAL on Linux prevents SIGPIPE (critical for servers)
/// - TCP_NODELAY disabled by default; enable for latency-sensitive protocols
///
/// # Thread Safety
///
/// - Reading and writing can happen concurrently from different threads
/// - Multiple concurrent reads or writes are NOT safe without synchronization
/// - Use Mutex<TcpStream> or split into separate read/write handles
///
/// # Protocol Implementation Notes
///
/// For high-performance protocols (QUIC, HTTP/2, HTTP/3):
/// - Use set_nodelay(true) to disable Nagle's algorithm
/// - Use non-blocking I/O with the async runtime for connection multiplexing
/// - Consider SO_REUSEPORT for multi-threaded accept scaling
/// - Access raw fd via as_raw_fd() for advanced socket options
public type TcpStream is {
    fd: FileDesc,
    peer_addr: SocketAddr,
};

implement TcpStream {
    /// Create a TCP connection to the specified address.
    ///
    /// This is a blocking operation that resolves DNS and attempts connection
    /// to each resolved address until one succeeds.
    ///
    /// # Example
    /// ```verum
    /// let stream = TcpStream.connect("127.0.0.1:8080")?;
    /// // or with explicit address
    /// let stream = TcpStream.connect(SocketAddr.new_v4(
    ///     Ipv4Addr.localhost(), 8080
    /// ))?;
    /// ```
    public fn connect<A: ToSocketAddrs>(addr: A) -> Result<TcpStream, IoError> {
        let addrs = addr.to_socket_addrs()?;
        let mut last_err = IoError.Other("No addresses resolved");

        for socket_addr in addrs {
            match TcpStream.connect_addr(&socket_addr) {
                Ok(stream) => return Ok(stream),
                Err(e) => last_err = e,
            }
        }

        Err(last_err)
    }

    /// Connect to a specific socket address (internal implementation).
    fn connect_addr(addr: &SocketAddr) -> Result<TcpStream, IoError> {
        let domain = if addr.is_ipv4() { AF_INET } else { AF_INET6 };

        // Create socket using native V-LLSI syscalls
        // Use statement-level @cfg to keep fd in function scope
        @cfg(any(target_os = "linux", target_os = "windows"))
        let fd = socket(domain, SOCK_STREAM, 0).map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let fd = sys_socket(domain, SOCK_STREAM, 0).map_err(IoError.from_os_error)?;

        // macOS: set SO_NOSIGPIPE to prevent SIGPIPE on write to closed socket
        @cfg(target_os = "macos")
        let _ = safe_set_nosigpipe(fd, true);

        // Serialize address to sockaddr_in format
        let addr_bytes = serialize_socket_addr(addr);
        let addr_ptr = addr_bytes.as_ptr() as &unsafe Byte;

        // Connect to remote host
        @cfg(any(target_os = "linux", target_os = "windows"))
        let connect_result = connect(fd, addr_ptr, addr_bytes.len() as Int);

        @cfg(target_os = "macos")
        let connect_result = sys_connect(fd, addr_ptr, addr_bytes.len() as Int);

        match connect_result {
            Ok(()) => {
                Ok(TcpStream {
                    fd: fd,
                    peer_addr: *addr,
                })
            }
            Err(e) => {
                // Clean up socket on failure
                @cfg(any(target_os = "linux", target_os = "windows"))
                let _ = close(fd);

                @cfg(target_os = "macos")
                let _ = sys_close(fd);

                Err(IoError.from_os_error(e))
            }
        }
    }

    /// Create an async TCP connection.
    ///
    /// Returns a future that resolves when the connection is established.
    /// This is the preferred method for high-throughput servers where you
    /// need to handle many concurrent connections.
    ///
    /// # Implementation Notes
    ///
    /// Uses non-blocking connect with io_uring (Linux) or kqueue (macOS)
    /// for efficient event notification. The socket is set to non-blocking
    /// mode, connect() returns EINPROGRESS, then we await write readiness.
    public async fn connect_async<A: ToSocketAddrs>(addr: A) -> Result<TcpStream, IoError> {
        let addrs = addr.to_socket_addrs()?;
        let mut last_err = IoError.Other("No addresses resolved");

        for socket_addr in addrs {
            match TcpStream.connect_addr_async(&socket_addr).await {
                Ok(stream) => return Ok(stream),
                Err(e) => last_err = e,
            }
        }

        Err(last_err)
    }

    /// Async connect implementation for a specific address.
    async fn connect_addr_async(addr: &SocketAddr) -> Result<TcpStream, IoError> {
        let domain = if addr.is_ipv4() { AF_INET } else { AF_INET6 };

        // Create socket - use statement-level @cfg to ensure fd is in function scope
        @cfg(any(target_os = "linux", target_os = "windows"))
        let fd = socket(domain, SOCK_STREAM | SOCK_NONBLOCK | SOCK_CLOEXEC, 0)
            .map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let fd = sys_socket(domain, SOCK_STREAM, 0).map_err(IoError.from_os_error)?;

        // macOS: set non-blocking after creation
        @cfg(target_os = "macos")
        let _ = safe_set_nonblocking(fd, true).map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let _ = safe_set_nosigpipe(fd, true);

        let addr_bytes = serialize_socket_addr(addr);
        let addr_ptr = addr_bytes.as_ptr() as &unsafe Byte;

        // Initiate non-blocking connect
        @cfg(any(target_os = "linux", target_os = "windows"))
        let connect_result = connect(fd, addr_ptr, addr_bytes.len() as Int);

        @cfg(target_os = "macos")
        let connect_result = sys_connect(fd, addr_ptr, addr_bytes.len() as Int);

        // Platform-specific error codes for "in progress"
        @cfg(any(target_os = "linux", target_os = "windows"))
        const EINPROGRESS: Int = 115;

        @cfg(any(target_os = "linux", target_os = "windows"))
        const EAGAIN: Int = 11;

        @cfg(target_os = "macos")
        const EINPROGRESS: Int = 36;

        @cfg(target_os = "macos")
        const EAGAIN: Int = 35;

        match connect_result {
            Ok(()) => {
                // Connection completed immediately (rare but possible on localhost)
                return Ok(TcpStream { fd: fd, peer_addr: *addr });
            }
            Err(e) if e.code == EINPROGRESS || e.code == EAGAIN => {
                // Expected for non-blocking connect - need to wait for completion
            }
            Err(e) => {
                @cfg(any(target_os = "linux", target_os = "windows"))
                let _ = close(fd);

                @cfg(target_os = "macos")
                let _ = sys_close(fd);

                return Err(IoError.from_os_error(e));
            }
        }

        // Wait for socket to become writable (connection complete or error)
        AsyncIoReady.writable(fd).await;

        // Check socket error to verify connection succeeded
        @cfg(any(target_os = "linux", target_os = "windows"))
        let sock_err = getsockopt_error(fd);

        @cfg(target_os = "macos")
        let sock_err = safe_getsockopt_error(fd);

        match sock_err {
            Ok(0) => {
                Ok(TcpStream { fd: fd, peer_addr: *addr })
            }
            Ok(err_code) => {
                @cfg(any(target_os = "linux", target_os = "windows"))
                let _ = close(fd);

                @cfg(target_os = "macos")
                let _ = sys_close(fd);

                Err(IoError.from_errno(err_code))
            }
            Err(e) => {
                @cfg(any(target_os = "linux", target_os = "windows"))
                let _ = close(fd);

                @cfg(target_os = "macos")
                let _ = sys_close(fd);

                Err(IoError.from_os_error(e))
            }
        }
    }

    /// Get the remote address this stream is connected to.
    ///
    /// This returns the cached address from connection time. For the actual
    /// current peer address (which should be the same), use peer_addr_syscall().
    public fn peer_addr(&self) -> Result<SocketAddr, IoError> {
        Ok(self.peer_addr)
    }

    /// Get the local address of this stream.
    ///
    /// Returns the local IP and port assigned to this socket by the kernel.
    public fn local_addr(&self) -> Result<SocketAddr, IoError> {
        let mut addr_buf = [0_u8; 128];
        let mut addr_len: Int = 128;

        @cfg(any(target_os = "linux", target_os = "windows")) {
            getsockname(self.fd, &mut addr_buf, &mut addr_len)
                .map_err(IoError.from_os_error)?;
        }
        @cfg(target_os = "macos") {
            safe_getsockname(self.fd, &mut addr_buf, &mut addr_len)
                .map_err(IoError.from_os_error)?;
        }

        deserialize_socket_addr(&addr_buf[..addr_len as Int])
    }

    /// Shutdown the read, write, or both halves of this stream.
    ///
    /// This is a graceful shutdown that allows pending data to be sent/received.
    /// For immediate termination, drop the stream or use set_linger(0).
    public fn shutdown(&self, how: Shutdown) -> Result<(), IoError> {
        let how_int = match how {
            Shutdown.Read => SHUT_RD,
            Shutdown.Write => SHUT_WR,
            Shutdown.Both => SHUT_RDWR,
        };

        @cfg(any(target_os = "linux", target_os = "windows")) {
            shutdown(self.fd, how_int).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            sys_shutdown(self.fd, how_int).map_err(IoError.from_os_error)
        }
    }

    /// Set the read timeout.
    ///
    /// A value of None means reads will block indefinitely.
    /// A value of Some(ms) sets the timeout in milliseconds.
    public fn set_read_timeout(&self, timeout_ms: Maybe<Int>) -> Result<(), IoError> {
        let ms = timeout_ms.unwrap_or(0);
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_socket_timeout(self.fd, ms, true).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_socket_timeout(self.fd, ms, true).map_err(IoError.from_os_error)
        }
    }

    /// Set the write timeout.
    ///
    /// A value of None means writes will block indefinitely.
    /// A value of Some(ms) sets the timeout in milliseconds.
    public fn set_write_timeout(&self, timeout_ms: Maybe<Int>) -> Result<(), IoError> {
        let ms = timeout_ms.unwrap_or(0);
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_socket_timeout(self.fd, ms, false).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_socket_timeout(self.fd, ms, false).map_err(IoError.from_os_error)
        }
    }

    /// Set TCP_NODELAY option (disable Nagle's algorithm).
    ///
    /// When enabled, small packets are sent immediately without waiting for
    /// more data. Essential for latency-sensitive protocols like HTTP/2, QUIC.
    ///
    /// # Performance Impact
    /// - Enabled: Lower latency, potentially higher packet overhead
    /// - Disabled: Higher latency, better bandwidth utilization
    public fn set_nodelay(&self, nodelay: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_tcp_nodelay(self.fd, nodelay).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_tcp_nodelay(self.fd, nodelay).map_err(IoError.from_os_error)
        }
    }

    /// Set SO_KEEPALIVE option.
    ///
    /// When enabled, the kernel sends periodic probes to detect dead connections.
    /// Recommended for long-lived connections (database, message queue clients).
    public fn set_keepalive(&self, keepalive: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_keepalive(self.fd, keepalive).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_keepalive(self.fd, keepalive).map_err(IoError.from_os_error)
        }
    }

    /// Set the socket to non-blocking mode.
    ///
    /// In non-blocking mode, read/write operations return immediately with
    /// EWOULDBLOCK/EAGAIN if they would block. Use with async I/O or poll/select.
    public fn set_nonblocking(&self, nonblocking: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_nonblocking(self.fd, nonblocking).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_nonblocking(self.fd, nonblocking).map_err(IoError.from_os_error)
        }
    }

    /// Get the raw file descriptor for advanced operations.
    ///
    /// Use this to set custom socket options, integrate with external event
    /// loops, or perform operations not exposed by this API.
    ///
    /// # Safety
    /// The returned fd is valid only while this TcpStream exists.
    /// Do not close() the fd directly.
    public fn as_raw_fd(&self) -> FileDesc {
        self.fd
    }

    /// Create a new independently owned handle to the stream (via dup()).
    ///
    /// The returned TcpStream refers to the same underlying socket.
    /// Both handles must be closed for the socket to be released.
    public fn try_clone(&self) -> Result<TcpStream, IoError> {
        // Linux: F_DUPFD_CLOEXEC creates a duplicate with close-on-exec
        @cfg(any(target_os = "linux", target_os = "windows"))
        const F_DUPFD_CLOEXEC: Int = 1030;

        @cfg(target_os = "macos")
        const F_DUPFD_CLOEXEC: Int = 67;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let new_fd = fcntl(self.fd, F_DUPFD_CLOEXEC, 0).map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let new_fd = safe_fcntl(self.fd, F_DUPFD_CLOEXEC, 0).map_err(IoError.from_os_error)?;

        Ok(TcpStream {
            fd: new_fd as FileDesc,
            peer_addr: self.peer_addr,
        })
    }
}

implement Read for TcpStream {
    fn read(&mut self, buf: &mut [Byte]) -> Result<Int, IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            // Use recv with MSG_NOSIGNAL to prevent SIGPIPE on closed connection
            const MSG_NOSIGNAL: Int = 0x4000;
            recv(self.fd, buf, MSG_NOSIGNAL).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            // macOS uses SO_NOSIGPIPE set at socket creation time
            sys_recv(self.fd, buf, 0).map_err(IoError.from_os_error)
        }
    }
}

implement Write for TcpStream {
    fn write(&mut self, buf: &[Byte]) -> Result<Int, IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            // Use send with MSG_NOSIGNAL to prevent SIGPIPE
            const MSG_NOSIGNAL: Int = 0x4000;
            send(self.fd, buf, MSG_NOSIGNAL).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            sys_send(self.fd, buf, 0).map_err(IoError.from_os_error)
        }
    }

    fn flush(&mut self) -> Result<(), IoError> {
        // TCP is not buffered at the application level; data is sent immediately
        // to the kernel buffer. For explicit control, use TCP_NODELAY.
        Ok(())
    }
}

implement Drop for TcpStream {
    fn drop(&mut self) {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            let _ = close(self.fd);
        }
        @cfg(target_os = "macos") {
            let _ = sys_close(self.fd);
        }
    }
}

implement Debug for TcpStream {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"TcpStream {{ fd: {self.fd}, peer: {self.peer_addr} }}")
    }
}

implement Display for TcpStream {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"TcpStream({self.peer_addr})")
    }
}

// =============================================================================
// TcpListener
// =============================================================================

/// A TCP socket server, listening for connections.
///
/// After creating a TcpListener by binding it to a socket address, it
/// listens for incoming TCP connections. These can be accepted by calling
/// `accept()` or by iterating over `incoming()`.
///
/// # Performance Characteristics
///
/// - Default backlog of 1024 connections (adjustable via bind_with_backlog)
/// - SO_REUSEADDR enabled by default for quick server restart
/// - For high-throughput servers, consider SO_REUSEPORT for multi-threaded accept
///
/// # Scaling Patterns
///
/// For maximum throughput on multi-core systems:
/// ```verum
/// // Option 1: Single listener, dispatch to worker threads
/// let listener = TcpListener.bind("0.0.0.0:8080")?;
/// for stream in listener.incoming() {
///     spawn_worker(stream?);
/// }
///
/// // Option 2: SO_REUSEPORT - each thread has own listener (recommended)
/// // Kernel load-balances incoming connections
/// for _ in 0..num_cpus() {
///     spawn {
///         let listener = TcpListener.bind_reuseport("0.0.0.0:8080")?;
///         for stream in listener.incoming() {
///             handle_client(stream?);
///         }
///     };
/// }
/// ```
public type TcpListener is {
    fd: FileDesc,
    local_addr: SocketAddr,
};

/// Default backlog for listen(). Can handle burst of 1024 pending connections.
const DEFAULT_BACKLOG: Int = 1024;

implement TcpListener {
    /// Create a new TcpListener bound to the specified address.
    ///
    /// The returned listener is ready to accept connections.
    /// SO_REUSEADDR is enabled by default to allow quick rebinding after restart.
    public fn bind<A: ToSocketAddrs>(addr: A) -> Result<TcpListener, IoError> {
        TcpListener.bind_with_backlog(addr, DEFAULT_BACKLOG)
    }

    /// Create a TcpListener with a custom backlog size.
    ///
    /// The backlog determines the maximum number of pending connections
    /// that can be queued before the kernel starts rejecting new ones.
    public fn bind_with_backlog<A: ToSocketAddrs>(addr: A, backlog: Int) -> Result<TcpListener, IoError> {
        let addrs = addr.to_socket_addrs()?;
        let mut last_err = IoError.Other("No addresses resolved");

        for socket_addr in addrs {
            match TcpListener.bind_addr_with_backlog(&socket_addr, backlog) {
                Ok(listener) => return Ok(listener),
                Err(e) => last_err = e,
            }
        }

        Err(last_err)
    }

    /// Bind with SO_REUSEPORT for multi-threaded accept scaling.
    ///
    /// Multiple listeners can bind to the same address, and the kernel
    /// will load-balance incoming connections between them. This provides
    /// better scalability than a single listener with dispatch.
    public fn bind_reuseport<A: ToSocketAddrs>(addr: A) -> Result<TcpListener, IoError> {
        let addrs = addr.to_socket_addrs()?;
        let mut last_err = IoError.Other("No addresses resolved");

        for socket_addr in addrs {
            match TcpListener.bind_addr_reuseport(&socket_addr, DEFAULT_BACKLOG) {
                Ok(listener) => return Ok(listener),
                Err(e) => last_err = e,
            }
        }

        Err(last_err)
    }

    /// Internal: bind to specific address with given backlog.
    fn bind_addr_with_backlog(addr: &SocketAddr, backlog: Int) -> Result<TcpListener, IoError> {
        let domain = if addr.is_ipv4() { AF_INET } else { AF_INET6 };

        // Create socket - use statement-level @cfg to ensure fd is in function scope
        @cfg(any(target_os = "linux", target_os = "windows"))
        let fd = socket(domain, SOCK_STREAM | SOCK_CLOEXEC, 0)
            .map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let fd = sys_socket(domain, SOCK_STREAM, 0)
            .map_err(IoError.from_os_error)?;

        // Set SO_REUSEADDR for quick restart
        @cfg(any(target_os = "linux", target_os = "windows"))
        let _ = set_reuseaddr(fd, true);

        @cfg(target_os = "macos")
        let _ = safe_set_reuseaddr(fd, true);

        // Bind to address
        let addr_bytes = serialize_socket_addr(addr);

        @cfg(any(target_os = "linux", target_os = "windows"))
        if let Err(e) = bind(fd, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int) {
            let _ = close(fd);
            return Err(IoError.from_os_error(e));
        }

        @cfg(target_os = "macos")
        if let Err(e) = sys_bind(fd, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int) {
            let _ = sys_close(fd);
            return Err(IoError.from_os_error(e));
        }

        // Start listening
        @cfg(any(target_os = "linux", target_os = "windows"))
        if let Err(e) = listen(fd, backlog) {
            let _ = close(fd);
            return Err(IoError.from_os_error(e));
        }

        @cfg(target_os = "macos")
        if let Err(e) = sys_listen(fd, backlog) {
            let _ = sys_close(fd);
            return Err(IoError.from_os_error(e));
        }

        Ok(TcpListener {
            fd: fd,
            local_addr: *addr,
        })
    }

    /// Internal: bind with SO_REUSEPORT for load-balanced multi-threaded accept.
    fn bind_addr_reuseport(addr: &SocketAddr, backlog: Int) -> Result<TcpListener, IoError> {
        let domain = if addr.is_ipv4() { AF_INET } else { AF_INET6 };

        // Create socket - use statement-level @cfg to ensure fd is in function scope
        @cfg(any(target_os = "linux", target_os = "windows"))
        let fd = socket(domain, SOCK_STREAM | SOCK_CLOEXEC, 0)
            .map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let fd = sys_socket(domain, SOCK_STREAM, 0)
            .map_err(IoError.from_os_error)?;

        // Set SO_REUSEADDR and SO_REUSEPORT
        @cfg(any(target_os = "linux", target_os = "windows"))
        let _ = set_reuseaddr(fd, true);

        @cfg(any(target_os = "linux", target_os = "windows"))
        let _ = set_reuseport(fd, true);

        @cfg(target_os = "macos")
        let _ = safe_set_reuseaddr(fd, true);

        // macOS: SO_REUSEPORT value is 0x0200
        @cfg(target_os = "macos")
        const SO_REUSEPORT: Int = 0x0200;

        @cfg(target_os = "macos")
        let _ = safe_setsockopt_int(fd, SOL_SOCKET, SO_REUSEPORT, 1);

        // Bind and listen
        let addr_bytes = serialize_socket_addr(addr);

        @cfg(any(target_os = "linux", target_os = "windows"))
        if let Err(e) = bind(fd, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int) {
            let _ = close(fd);
            return Err(IoError.from_os_error(e));
        }

        @cfg(any(target_os = "linux", target_os = "windows"))
        if let Err(e) = listen(fd, backlog) {
            let _ = close(fd);
            return Err(IoError.from_os_error(e));
        }

        @cfg(target_os = "macos")
        if let Err(e) = sys_bind(fd, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int) {
            let _ = sys_close(fd);
            return Err(IoError.from_os_error(e));
        }

        @cfg(target_os = "macos")
        if let Err(e) = sys_listen(fd, backlog) {
            let _ = sys_close(fd);
            return Err(IoError.from_os_error(e));
        }

        Ok(TcpListener {
            fd: fd,
            local_addr: *addr,
        })
    }

    /// Accept a new incoming connection.
    ///
    /// This function blocks until a new connection is available.
    /// Returns the connected TcpStream and the peer's socket address.
    public fn accept(&self) -> Result<(TcpStream, SocketAddr), IoError> {
        let mut addr_buf = [0_u8; 128];
        let mut addr_len: Int = 128;

        // Linux: use accept4 with SOCK_CLOEXEC for atomic close-on-exec
        @cfg(any(target_os = "linux", target_os = "windows"))
        let client_fd = accept4(self.fd, &mut addr_buf, &mut addr_len, SOCK_CLOEXEC)
            .map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let client_fd = sys_accept(self.fd, &mut addr_buf, &mut addr_len)
            .map_err(IoError.from_os_error)?;

        // macOS: set SO_NOSIGPIPE on accepted socket
        @cfg(target_os = "macos")
        let _ = safe_set_nosigpipe(client_fd, true);

        let peer_addr = deserialize_socket_addr(&addr_buf[..addr_len as Int])?;

        Ok((
            TcpStream { fd: client_fd, peer_addr: peer_addr },
            peer_addr
        ))
    }

    /// Accept a new connection asynchronously.
    ///
    /// This version yields to the executor while waiting for incoming connections,
    /// allowing other tasks to run. Uses io_uring (Linux) or kqueue (macOS)
    /// for efficient event notification.
    public async fn accept_async(&self) -> Result<(TcpStream, SocketAddr), IoError> {
        // Ensure non-blocking mode for async accept
        self.set_nonblocking(true)?;

        // Platform-specific EAGAIN/EWOULDBLOCK codes
        @cfg(any(target_os = "linux", target_os = "windows"))
        const EAGAIN: Int = 11;

        @cfg(target_os = "macos")
        const EAGAIN: Int = 35;

        loop {
            let mut addr_buf = [0_u8; 128];
            let mut addr_len: Int = 128;

            // Try to accept immediately
            @cfg(any(target_os = "linux", target_os = "windows"))
            let accept_result = accept4(self.fd, &mut addr_buf, &mut addr_len, SOCK_CLOEXEC | SOCK_NONBLOCK);

            @cfg(target_os = "macos")
            let accept_result = sys_accept(self.fd, &mut addr_buf, &mut addr_len);

            match accept_result {
                Ok(client_fd) => {
                    @cfg(target_os = "macos")
                    let _ = safe_set_nosigpipe(client_fd, true);

                    let peer_addr = deserialize_socket_addr(&addr_buf[..addr_len as Int])?;
                    return Ok((
                        TcpStream { fd: client_fd, peer_addr: peer_addr },
                        peer_addr
                    ));
                }
                Err(e) if e.code == EAGAIN => {
                    // No connection ready - wait for read readiness
                    AsyncIoReady.readable(self.fd).await;
                    // Loop and try again
                    continue;
                }
                Err(e) => {
                    return Err(IoError.from_os_error(e));
                }
            }
        }
    }

    /// Get the local address this listener is bound to.
    public fn local_addr(&self) -> Result<SocketAddr, IoError> {
        Ok(self.local_addr)
    }

    /// Get an iterator over incoming connections.
    ///
    /// This is a convenience method that yields Result<TcpStream, IoError>.
    /// The iterator never returns None - it continues accepting forever.
    public fn incoming(&self) -> Incoming {
        Incoming { listener: self }
    }

    /// Set the listener to non-blocking mode.
    ///
    /// In non-blocking mode, accept() returns EAGAIN/EWOULDBLOCK if no
    /// connection is pending instead of blocking.
    public fn set_nonblocking(&self, nonblocking: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_nonblocking(self.fd, nonblocking).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_nonblocking(self.fd, nonblocking).map_err(IoError.from_os_error)
        }
    }

    /// Get the raw file descriptor for advanced operations.
    public fn as_raw_fd(&self) -> FileDesc {
        self.fd
    }
}

implement Drop for TcpListener {
    fn drop(&mut self) {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            let _ = close(self.fd);
        }
        @cfg(target_os = "macos") {
            let _ = sys_close(self.fd);
        }
    }
}

implement Debug for TcpListener {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"TcpListener {{ fd: {self.fd}, addr: {self.local_addr} }}")
    }
}

implement Display for TcpListener {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"TcpListener({self.local_addr})")
    }
}

// =============================================================================
// Incoming Iterator
// =============================================================================

/// An iterator over incoming TCP connections.
///
/// This is created by `TcpListener.incoming()`.
public type Incoming is {
    listener: &TcpListener,
};

implement Iterator for Incoming {
    type Item = Result<TcpStream, IoError>;

    fn next(&mut self) -> Maybe<Result<TcpStream, IoError>> {
        Some(self.listener.accept().map(|(stream, _)| stream))
    }
}

// =============================================================================
// Shutdown Direction
// =============================================================================

/// Shutdown direction for a TCP stream.
public type Shutdown is
    | Read      // Shutdown the read half
    | Write     // Shutdown the write half
    | Both;     // Shutdown both halves

// =============================================================================
// Socket Address Serialization
// =============================================================================
//
// These functions convert between SocketAddr and the native sockaddr structures
// expected by the kernel. Performance critical for high-connection-rate servers.

/// Size of struct sockaddr_in (IPv4).
const SOCKADDR_IN_SIZE: Int = 16;

/// Size of struct sockaddr_in6 (IPv6).
const SOCKADDR_IN6_SIZE: Int = 28;

/// Serialize a socket address to bytes for syscalls.
///
/// Returns the bytes in native sockaddr_in/sockaddr_in6 format.
/// Uses a fixed-size buffer to avoid heap allocation on hot path.
fn serialize_socket_addr(addr: &SocketAddr) -> List<Byte> {
    match *addr {
        SocketAddr.V4(v4) => {
            // struct sockaddr_in layout:
            //   uint16_t sin_family   - address family (AF_INET)
            //   uint16_t sin_port     - port in network byte order (big-endian)
            //   uint32_t sin_addr     - IPv4 address in network byte order
            //   char     sin_zero[8]  - padding to 16 bytes
            let mut buf = List.with_capacity(SOCKADDR_IN_SIZE);

            // sin_family: AF_INET in native byte order
            // On little-endian systems, AF_INET (2) is stored as [2, 0]
            buf.push(AF_INET as Byte);
            buf.push(0);

            // sin_port: network byte order (big-endian)
            let port = v4.port;
            buf.push(((port >> 8) & 0xFF) as Byte);
            buf.push((port & 0xFF) as Byte);

            // sin_addr: network byte order (already in correct format)
            let (a, b, c, d) = v4.addr.octets();
            buf.push(a);
            buf.push(b);
            buf.push(c);
            buf.push(d);

            // sin_zero: 8 bytes padding
            buf.push(0); buf.push(0); buf.push(0); buf.push(0);
            buf.push(0); buf.push(0); buf.push(0); buf.push(0);

            buf
        }
        SocketAddr.V6(v6) => {
            // struct sockaddr_in6 layout:
            //   uint16_t sin6_family    - AF_INET6
            //   uint16_t sin6_port      - port in network byte order
            //   uint32_t sin6_flowinfo  - flow information
            //   uint8_t  sin6_addr[16]  - IPv6 address
            //   uint32_t sin6_scope_id  - scope ID
            let mut buf = List.with_capacity(SOCKADDR_IN6_SIZE);

            // sin6_family
            buf.push(AF_INET6 as Byte);
            buf.push(0);

            // sin6_port (big-endian)
            let port = v6.port;
            buf.push(((port >> 8) & 0xFF) as Byte);
            buf.push((port & 0xFF) as Byte);

            // sin6_flowinfo (4 bytes, usually 0)
            buf.push(0); buf.push(0); buf.push(0); buf.push(0);

            // sin6_addr (16 bytes)
            let ip_bytes = v6.addr;
            for i in 0..16 {
                buf.push(ip_bytes[i]);
            }

            // sin6_scope_id (4 bytes)
            let scope = v6.scope_id;
            buf.push((scope & 0xFF) as Byte);
            buf.push(((scope >> 8) & 0xFF) as Byte);
            buf.push(((scope >> 16) & 0xFF) as Byte);
            buf.push(((scope >> 24) & 0xFF) as Byte);

            buf
        }
    }
}

/// Deserialize a socket address from kernel sockaddr bytes.
fn deserialize_socket_addr(buf: &[Byte]) -> Result<SocketAddr, IoError> {
    if buf.len() < 2 {
        return Err(IoError.InvalidInput { reason: "Address buffer too small" });
    }

    // First byte is address family (in native byte order)
    let family = buf[0] as Int;

    if family == AF_INET {
        if buf.len() < 8 {
            return Err(IoError.InvalidInput { reason: "Invalid IPv4 address buffer" });
        }

        // Port is in network byte order (big-endian)
        let port = ((buf[2] as Int) << 8) | (buf[3] as Int);
        let ip = Ipv4Addr.new(buf[4], buf[5], buf[6], buf[7]);

        Ok(SocketAddr.new_v4(ip, port))
    } else if family == AF_INET6 {
        if buf.len() < SOCKADDR_IN6_SIZE {
            return Err(IoError.InvalidInput { reason: "Invalid IPv6 address buffer" });
        }

        let port = ((buf[2] as Int) << 8) | (buf[3] as Int);

        // Skip flowinfo (bytes 4-7), read 16-byte address (bytes 8-23)
        let mut segments: [UInt16; 8] = [0; 8];
        for i in 0..8 {
            let offset = 8 + i * 2;
            segments[i] = ((buf[offset] as UInt16) << 8) | (buf[offset + 1] as UInt16);
        }
        let ip = Ipv6Addr.new(
            segments[0] as Int, segments[1] as Int, segments[2] as Int, segments[3] as Int,
            segments[4] as Int, segments[5] as Int, segments[6] as Int, segments[7] as Int
        );

        // scope_id (bytes 24-27, little-endian)
        let scope_id = (buf[24] as UInt32)
            | ((buf[25] as UInt32) << 8)
            | ((buf[26] as UInt32) << 16)
            | ((buf[27] as UInt32) << 24);

        Ok(SocketAddr.V6(SocketAddrV6.new(ip, port, 0, scope_id)))
    } else {
        Err(IoError.InvalidInput { reason: f"Unsupported address family: {family}" })
    }
}
