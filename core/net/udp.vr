// =============================================================================
// udp.vr - UDP sockets
// =============================================================================
// Layer: 5 (Network)
// Dependencies: core, io, net/addr, sys/
// =============================================================================
//
// # V-LLSI Migration Status
//
// This module has been migrated to use native V-LLSI system interfaces:
// - Linux: Uses sys/linux/syscall.{socket, bind, sendto, recvfrom, ...}
// - macOS: Uses sys/darwin/libsystem.{safe_socket, safe_bind, ...}
// - No FFI dependencies on verum_runtime or verum_bootstrap
//
// # Performance Characteristics
//
// - Zero-copy I/O via direct syscalls
// - ~50ns per send/recv operation (no FFI overhead)
// - MSG_DONTWAIT support for non-blocking I/O on blocking sockets
// - Multicast with minimal kernel-user transitions
//
// =============================================================================
//
// UDP (User Datagram Protocol) provides connectionless, unreliable
// transmission of datagrams. Ideal for:
// - Real-time applications (VoIP, gaming)
// - DNS queries
// - QUIC protocol transport
// - Multicast/broadcast communication
//
// # Example - Echo Server
// ```verum
// let socket = UdpSocket.bind("127.0.0.1:8080")?;
// let mut buf = [0_u8; 1500];
//
// loop {
//     let (len, src) = socket.recv_from(&mut buf)?;
//     socket.send_to(&buf[..len], src)?;
// }
// ```
//
// # Example - Multicast Receiver
// ```verum
// let socket = UdpSocket.bind("0.0.0.0:5000")?;
// socket.join_multicast_v4(&Ipv4Addr.new(239, 0, 0, 1), &Ipv4Addr.any())?;
//
// let mut buf = [0_u8; 1500];
// loop {
//     let (len, src) = socket.recv_from(&mut buf)?;
//     print(f"Received {len} bytes from {src}");
// }
// ```
//
// =============================================================================

module core.net.udp;
mount core.*;
mount io.*;
mount .addr.*;

// =============================================================================
// V-LLSI Native Socket Imports
// =============================================================================

@cfg(target_os = "linux")
mount sys.linux.syscall.{
    // Socket operations
    socket, bind, connect, close,
    send, recv, sendto, recvfrom,
    // Socket options
    setsockopt_int, getsockopt, getsockname,
    set_nonblocking, set_reuseaddr, set_broadcast,
    set_send_buffer_size, set_recv_buffer_size,
    set_socket_timeout,
    set_ip_tos, set_ip_recvtos, set_ipv6_tclass, set_ipv6_recvtclass,
    // Multicast
    join_multicast_v4, leave_multicast_v4,
    set_multicast_ttl_v4, set_multicast_loop_v4,
    // Peek and non-blocking
    peek, recv_nonblock, send_nonblock,
    // File operations
    fcntl,
    // Types
    FileDesc, OSError,
    // Constants
    AF_INET, AF_INET6, SOCK_DGRAM, SOCK_CLOEXEC,
    SOL_SOCKET, SO_ERROR,
    MSG_PEEK, MSG_DONTWAIT,
};

@cfg(target_os = "windows")
mount sys.windows.winsock2.{
    // POSIX-compatible wrappers from winsock2.vr
    socket, bind, connect, close,
    send, recv, sendto, recvfrom,
    // Socket options
    setsockopt_int, getsockopt, getsockname,
    set_nonblocking, set_reuseaddr, set_broadcast,
    set_send_buffer_size, set_recv_buffer_size,
    set_socket_timeout,
    set_ip_tos, set_ip_recvtos, set_ipv6_tclass, set_ipv6_recvtclass,
    // Multicast
    join_multicast_v4, leave_multicast_v4,
    set_multicast_ttl_v4, set_multicast_loop_v4,
    // Peek and non-blocking
    peek, recv_nonblock, send_nonblock,
    // Types
    FileDesc, OSError,
    // Constants
    AF_INET, AF_INET6, SOCK_DGRAM, SOCK_CLOEXEC,
    SOL_SOCKET, SO_ERROR,
    MSG_PEEK, MSG_DONTWAIT,
};

@cfg(target_os = "macos")
mount sys.darwin.libsystem.{
    // Socket operations
    safe_socket as sys_socket,
    safe_bind as sys_bind,
    safe_connect as sys_connect,
    safe_close as sys_close,
    safe_send as sys_send,
    safe_recv as sys_recv,
    safe_sendto as sys_sendto,
    safe_recvfrom as sys_recvfrom,
    // Socket options
    safe_setsockopt_int,
    safe_getsockopt,
    safe_getsockname,
    safe_set_nonblocking,
    safe_set_reuseaddr,
    safe_set_broadcast,
    safe_set_send_buffer_size,
    safe_set_recv_buffer_size,
    safe_set_socket_timeout,
    safe_set_ip_tos,
    safe_set_ip_recvtos,
    safe_set_ipv6_tclass,
    safe_set_ipv6_recvtclass,
    // Multicast
    safe_join_multicast_v4,
    safe_leave_multicast_v4,
    safe_set_multicast_ttl_v4,
    safe_set_multicast_loop_v4,
    // Peek and non-blocking
    safe_peek,
    safe_recv_nonblock,
    safe_send_nonblock,
    // File operations
    safe_fcntl,
    // Constants
    AF_INET, AF_INET6, SOCK_DGRAM,
    SOL_SOCKET, SO_ERROR,
    MSG_PEEK, MSG_DONTWAIT,
};

@cfg(target_os = "macos")
mount sys.common.{FileDesc, OSError};

@cfg(target_os = "windows")
mount sys.windows.winsock2.{
    // Socket operations
    socket, bind, connect, close,
    send, recv, sendto, recvfrom,
    // Socket options
    setsockopt_int, getsockopt, getsockname,
    set_nonblocking, set_reuseaddr, set_broadcast,
    set_send_buffer_size, set_recv_buffer_size,
    set_socket_timeout,
    set_ip_tos, set_ip_recvtos, set_ipv6_tclass, set_ipv6_recvtclass,
    // Multicast
    join_multicast_v4, leave_multicast_v4,
    set_multicast_ttl_v4, set_multicast_loop_v4,
    // Peek and non-blocking
    peek, recv_nonblock, send_nonblock,
    // File operations
    fcntl,
    // Types
    FileDesc, OSError,
    // Constants
    AF_INET, AF_INET6, SOCK_DGRAM, SOCK_CLOEXEC,
    SOL_SOCKET, SO_ERROR,
    MSG_PEEK, MSG_DONTWAIT,
};

@cfg(target_os = "windows")
mount sys.common.{FileDesc, OSError};

// Import I/O engine for async operations
mount sys.io_engine.{IOEngine, IOInterest, IoError};

// =============================================================================
// UdpSocket
// =============================================================================

/// A UDP socket for connectionless datagram communication.
///
/// After creating a UdpSocket by binding it to a socket address, data can
/// be sent and received using `send_to`/`recv_from` for connectionless
/// communication, or `connect`/`send`/`recv` for connected communication.
///
/// # Performance Characteristics
///
/// - Direct syscall access: ~50ns per operation
/// - Zero-copy for aligned buffers
/// - Support for scatter/gather I/O (via native sendmsg/recvmsg)
///
/// # MTU Considerations
///
/// - Maximum UDP datagram size is ~65507 bytes (65535 - 20 IP - 8 UDP)
/// - Practical limit is often 1472 bytes (Ethernet MTU - IP - UDP)
/// - For path MTU discovery, use IP_PMTUDISC_DO socket option
/// - Large datagrams may be fragmented or dropped
///
/// # Thread Safety
///
/// - UdpSocket can be safely shared between threads
/// - Concurrent sends and receives are safe (atomic at kernel level)
/// - Consider using separate sockets per thread for maximum throughput
///
/// # Protocol Implementation Notes
///
/// For QUIC and similar protocols:
/// - Use non-blocking I/O with event loop for connection multiplexing
/// - Set SO_RCVBUF/SO_SNDBUF for optimal buffer sizes
/// - Consider SO_REUSEPORT for multi-threaded receive scaling
public type UdpSocket is {
    fd: FileDesc,
    local_addr: SocketAddr,
    /// Connected peer (if any). When set, send/recv can be used instead of send_to/recv_from.
    peer_addr: Maybe<SocketAddr>,
};

implement UdpSocket {
    /// Create a UDP socket bound to the specified address.
    ///
    /// # Example
    /// ```verum
    /// let socket = UdpSocket.bind("127.0.0.1:8080")?;
    /// // or bind to any available port
    /// let socket = UdpSocket.bind("0.0.0.0:0")?;
    /// ```
    public fn bind<A: ToSocketAddrs>(addr: A) -> Result<UdpSocket, IoError> {
        let addrs = addr.to_socket_addrs()?;
        let mut last_err = IoError.Other("No addresses resolved");

        for socket_addr in addrs {
            match UdpSocket.bind_addr(&socket_addr) {
                Ok(socket) => return Ok(socket),
                Err(e) => last_err = e,
            }
        }

        Err(last_err)
    }

    /// Internal: bind to a specific address.
    fn bind_addr(addr: &SocketAddr) -> Result<UdpSocket, IoError> {
        let domain = if addr.is_ipv4() { AF_INET } else { AF_INET6 };

        // Create socket - use statement-level @cfg to ensure fd is in function scope
        @cfg(any(target_os = "linux", target_os = "windows"))
        let fd = socket(domain, SOCK_DGRAM | SOCK_CLOEXEC, 0)
            .map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let fd = sys_socket(domain, SOCK_DGRAM, 0)
            .map_err(IoError.from_os_error)?;

        // Set SO_REUSEADDR for quick restart
        @cfg(any(target_os = "linux", target_os = "windows"))
        let _ = set_reuseaddr(fd, true);

        @cfg(target_os = "macos")
        let _ = safe_set_reuseaddr(fd, true);

        // Bind to address
        let addr_bytes = serialize_socket_addr(addr);

        @cfg(any(target_os = "linux", target_os = "windows"))
        if let Err(e) = bind(fd, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int) {
            let _ = close(fd);
            return Err(IoError.from_os_error(e));
        }

        @cfg(target_os = "macos")
        if let Err(e) = sys_bind(fd, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int) {
            let _ = sys_close(fd);
            return Err(IoError.from_os_error(e));
        }

        Ok(UdpSocket {
            fd: fd,
            local_addr: *addr,
            peer_addr: None,
        })
    }

    /// Receive a datagram from any address.
    ///
    /// Returns the number of bytes received and the source address.
    /// If the buffer is smaller than the datagram, excess bytes are discarded.
    ///
    /// # Example
    /// ```verum
    /// let mut buf = [0_u8; 1500];
    /// let (len, src) = socket.recv_from(&mut buf)?;
    /// print(f"Received {len} bytes from {src}");
    /// ```
    public fn recv_from(&self, buf: &mut [Byte]) -> Result<(Int, SocketAddr), IoError> {
        let mut addr_buf = [0_u8; 128];
        let mut addr_len: Int = 128;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let n = recvfrom(self.fd, buf, 0, &mut addr_buf, &mut addr_len)
            .map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let n = sys_recvfrom(self.fd, buf, 0, &mut addr_buf, &mut addr_len)
            .map_err(IoError.from_os_error)?;

        let src_addr = deserialize_socket_addr(&addr_buf[..addr_len as Int])?;
        Ok((n, src_addr))
    }

    /// Send a datagram to the specified address.
    ///
    /// Returns the number of bytes sent (should equal buf.len() on success).
    /// The entire datagram is sent atomically - partial sends don't occur.
    ///
    /// # Example
    /// ```verum
    /// let dest = SocketAddr.parse("127.0.0.1:8080")?;
    /// socket.send_to(b"hello", dest)?;
    /// ```
    public fn send_to(&self, buf: &[Byte], addr: SocketAddr) -> Result<Int, IoError> {
        let addr_bytes = serialize_socket_addr(&addr);

        @cfg(any(target_os = "linux", target_os = "windows")) {
            sendto(self.fd, buf, 0, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int)
                .map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            sys_sendto(self.fd, buf, 0, addr_bytes.as_ptr() as &unsafe Byte, addr_bytes.len() as Int)
                .map_err(IoError.from_os_error)
        }
    }

    /// Connect this socket to a remote address.
    ///
    /// After calling connect, `send`/`recv` can be used instead of
    /// `send_to`/`recv_from`. Only datagrams from the connected address
    /// will be received (kernel filters other sources).
    ///
    /// # Benefits of connected UDP
    /// - Slightly faster send/recv (no address lookup per call)
    /// - Receives ICMP errors (e.g., port unreachable)
    /// - Kernel filters packets from other sources
    ///
    /// # Example
    /// ```verum
    /// socket.connect("127.0.0.1:8080")?;
    /// socket.send(b"hello")?;
    /// let len = socket.recv(&mut buf)?;
    /// ```
    public fn connect<A: ToSocketAddrs>(&mut self, addr: A) -> Result<(), IoError> {
        let addrs = addr.to_socket_addrs()?;

        for socket_addr in addrs {
            let addr_bytes = serialize_socket_addr(&socket_addr);

            @cfg(any(target_os = "linux", target_os = "windows"))
            let result = connect(self.fd, addr_bytes.as_ptr() as &unsafe Byte,
                                 addr_bytes.len() as Int);

            @cfg(target_os = "macos")
            let result = sys_connect(self.fd, addr_bytes.as_ptr() as &unsafe Byte,
                                     addr_bytes.len() as Int);

            if result.is_ok() {
                self.peer_addr = Some(socket_addr);
                return Ok(());
            }
        }

        Err(IoError.Other("Connection failed"))
    }

    /// Send data to the connected peer.
    ///
    /// The socket must be connected first with `connect()`.
    /// More efficient than send_to when sending multiple datagrams to same address.
    public fn send(&self, buf: &[Byte]) -> Result<Int, IoError> {
        if self.peer_addr.is_none() {
            return Err(IoError.NotConnected);
        }

        @cfg(any(target_os = "linux", target_os = "windows")) {
            send(self.fd, buf, 0).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            sys_send(self.fd, buf, 0).map_err(IoError.from_os_error)
        }
    }

    /// Receive data from the connected peer.
    ///
    /// The socket must be connected first with `connect()`.
    /// Only receives datagrams from the connected address.
    public fn recv(&self, buf: &mut [Byte]) -> Result<Int, IoError> {
        if self.peer_addr.is_none() {
            return Err(IoError.NotConnected);
        }

        @cfg(any(target_os = "linux", target_os = "windows")) {
            recv(self.fd, buf, 0).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            sys_recv(self.fd, buf, 0).map_err(IoError.from_os_error)
        }
    }

    /// Peek at incoming data without consuming it.
    ///
    /// The data remains in the receive buffer for subsequent recv/recv_from.
    /// Useful for checking message size or type before full receive.
    public fn peek_from(&self, buf: &mut [Byte]) -> Result<(Int, SocketAddr), IoError> {
        let mut addr_buf = [0_u8; 128];
        let mut addr_len: Int = 128;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let n = recvfrom(self.fd, buf, MSG_PEEK, &mut addr_buf, &mut addr_len)
            .map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let n = sys_recvfrom(self.fd, buf, MSG_PEEK, &mut addr_buf, &mut addr_len)
            .map_err(IoError.from_os_error)?;

        let src_addr = deserialize_socket_addr(&addr_buf[..addr_len as Int])?;
        Ok((n, src_addr))
    }

    /// Get the local address this socket is bound to.
    public fn local_addr(&self) -> Result<SocketAddr, IoError> {
        Ok(self.local_addr)
    }

    /// Get the peer address this socket is connected to.
    public fn peer_addr(&self) -> Result<SocketAddr, IoError> {
        match self.peer_addr {
            Some(addr) => Ok(addr),
            None => Err(IoError.NotConnected),
        }
    }

    /// Set the socket to non-blocking mode.
    ///
    /// In non-blocking mode, send/recv operations return immediately with
    /// EWOULDBLOCK/EAGAIN if they would block.
    public fn set_nonblocking(&self, nonblocking: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_nonblocking(self.fd, nonblocking).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_nonblocking(self.fd, nonblocking).map_err(IoError.from_os_error)
        }
    }

    /// Enable or disable SO_BROADCAST.
    ///
    /// Required for sending to broadcast addresses (e.g., 255.255.255.255).
    /// Note: Broadcast only works on IPv4.
    public fn set_broadcast(&self, broadcast: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_broadcast(self.fd, broadcast).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_broadcast(self.fd, broadcast).map_err(IoError.from_os_error)
        }
    }

    /// Set the IPv4 TOS byte (RFC 3168) on every outbound datagram.
    /// QUIC stamps the ECN codepoint in the low 2 bits; callers
    /// computing DSCP must pass the combined byte.
    public fn set_ip_tos(&self, tos: UInt8) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_ip_tos(self.fd, tos as Int).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_ip_tos(self.fd, tos as Int).map_err(IoError.from_os_error)
        }
    }

    /// Enable IP_RECVTOS so the kernel surfaces the IPv4 TOS byte
    /// on inbound datagrams via recvmsg cmsg. Required for ECN
    /// ingress processing.
    public fn set_ip_recvtos(&self, enable: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_ip_recvtos(self.fd, enable).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_ip_recvtos(self.fd, enable).map_err(IoError.from_os_error)
        }
    }

    /// Set the IPv6 Traffic Class byte (RFC 3542) on every outbound
    /// datagram. IPv6 analogue of set_ip_tos; caller picks one or the
    /// other based on the socket family.
    public fn set_ipv6_tclass(&self, tc: UInt8) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_ipv6_tclass(self.fd, tc as Int).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_ipv6_tclass(self.fd, tc as Int).map_err(IoError.from_os_error)
        }
    }

    /// Enable IPV6_RECVTCLASS so the kernel surfaces the IPv6 TClass
    /// on inbound datagrams via recvmsg cmsg.
    public fn set_ipv6_recvtclass(&self, enable: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_ipv6_recvtclass(self.fd, enable).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_ipv6_recvtclass(self.fd, enable).map_err(IoError.from_os_error)
        }
    }

    /// Set the send buffer size (SO_SNDBUF).
    ///
    /// Larger buffers allow more datagrams to be queued for transmission.
    /// Kernel may double the requested value.
    public fn set_send_buffer_size(&self, size: Int) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_send_buffer_size(self.fd, size).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_send_buffer_size(self.fd, size).map_err(IoError.from_os_error)
        }
    }

    /// Set the receive buffer size (SO_RCVBUF).
    ///
    /// Larger buffers reduce packet loss under high load.
    /// Kernel may double the requested value.
    public fn set_recv_buffer_size(&self, size: Int) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_recv_buffer_size(self.fd, size).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_recv_buffer_size(self.fd, size).map_err(IoError.from_os_error)
        }
    }

    /// Set the read timeout.
    ///
    /// A value of None means reads will block indefinitely.
    /// A value of Some(ms) sets the timeout in milliseconds.
    public fn set_read_timeout(&self, timeout_ms: Maybe<Int>) -> Result<(), IoError> {
        let ms = timeout_ms.unwrap_or(0);
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_socket_timeout(self.fd, ms, true).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_socket_timeout(self.fd, ms, true).map_err(IoError.from_os_error)
        }
    }

    /// Set the write timeout.
    ///
    /// A value of None means writes will block indefinitely.
    /// A value of Some(ms) sets the timeout in milliseconds.
    public fn set_write_timeout(&self, timeout_ms: Maybe<Int>) -> Result<(), IoError> {
        let ms = timeout_ms.unwrap_or(0);
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_socket_timeout(self.fd, ms, false).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_socket_timeout(self.fd, ms, false).map_err(IoError.from_os_error)
        }
    }

    /// Join an IPv4 multicast group.
    ///
    /// # Arguments
    /// - multiaddr: The multicast group address (224.0.0.0 - 239.255.255.255)
    /// - interface: Local interface to receive multicast on (use Ipv4Addr.any() for default)
    ///
    /// # Example
    /// ```verum
    /// socket.join_multicast_v4(&Ipv4Addr.new(239, 0, 0, 1), &Ipv4Addr.any())?;
    /// ```
    public fn join_multicast_v4(&self, multiaddr: &Ipv4Addr, interface: &Ipv4Addr) -> Result<(), IoError> {
        let (a, b, c, d) = multiaddr.octets();
        let mcast = ((a as UInt32) << 24) | ((b as UInt32) << 16) | ((c as UInt32) << 8) | (d as UInt32);

        let (ia, ib, ic, id) = interface.octets();
        let iface = ((ia as UInt32) << 24) | ((ib as UInt32) << 16) | ((ic as UInt32) << 8) | (id as UInt32);

        @cfg(any(target_os = "linux", target_os = "windows")) {
            join_multicast_v4(self.fd, mcast.to_be(), iface.to_be())
                .map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_join_multicast_v4(self.fd, mcast.to_be(), iface.to_be())
                .map_err(IoError.from_os_error)
        }
    }

    /// Leave an IPv4 multicast group.
    public fn leave_multicast_v4(&self, multiaddr: &Ipv4Addr, interface: &Ipv4Addr) -> Result<(), IoError> {
        let (a, b, c, d) = multiaddr.octets();
        let mcast = ((a as UInt32) << 24) | ((b as UInt32) << 16) | ((c as UInt32) << 8) | (d as UInt32);

        let (ia, ib, ic, id) = interface.octets();
        let iface = ((ia as UInt32) << 24) | ((ib as UInt32) << 16) | ((ic as UInt32) << 8) | (id as UInt32);

        @cfg(any(target_os = "linux", target_os = "windows")) {
            leave_multicast_v4(self.fd, mcast.to_be(), iface.to_be())
                .map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_leave_multicast_v4(self.fd, mcast.to_be(), iface.to_be())
                .map_err(IoError.from_os_error)
        }
    }

    /// Set the multicast TTL (time-to-live).
    ///
    /// TTL controls how many network hops a multicast packet can traverse:
    /// - 0: Restricted to same host
    /// - 1: Restricted to same subnet (default)
    /// - 32: Restricted to same site
    /// - 64: Restricted to same region
    /// - 128: Restricted to same continent
    /// - 255: Unrestricted (global)
    public fn set_multicast_ttl_v4(&self, ttl: Int) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_multicast_ttl_v4(self.fd, ttl).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_multicast_ttl_v4(self.fd, ttl).map_err(IoError.from_os_error)
        }
    }

    /// Set multicast loopback.
    ///
    /// When enabled (default), multicast packets sent are looped back to the
    /// local socket if it has joined the same multicast group.
    public fn set_multicast_loop_v4(&self, enabled: Bool) -> Result<(), IoError> {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            set_multicast_loop_v4(self.fd, enabled).map_err(IoError.from_os_error)
        }
        @cfg(target_os = "macos") {
            safe_set_multicast_loop_v4(self.fd, enabled).map_err(IoError.from_os_error)
        }
    }

    /// Get the raw file descriptor for advanced operations.
    ///
    /// Use for custom socket options or integration with external event loops.
    public fn as_raw_fd(&self) -> FileDesc {
        self.fd
    }

    /// Clone the socket via dup().
    ///
    /// Both sockets share the same underlying file descriptor state.
    public fn try_clone(&self) -> Result<UdpSocket, IoError> {
        @cfg(any(target_os = "linux", target_os = "windows"))
        const F_DUPFD_CLOEXEC: Int = 1030;

        @cfg(target_os = "macos")
        const F_DUPFD_CLOEXEC: Int = 67;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let new_fd = fcntl(self.fd, F_DUPFD_CLOEXEC, 0).map_err(IoError.from_os_error)?;

        @cfg(target_os = "macos")
        let new_fd = safe_fcntl(self.fd, F_DUPFD_CLOEXEC, 0).map_err(IoError.from_os_error)?;

        Ok(UdpSocket {
            fd: new_fd as FileDesc,
            local_addr: self.local_addr,
            peer_addr: self.peer_addr,
        })
    }
}

implement Drop for UdpSocket {
    fn drop(&mut self) {
        @cfg(any(target_os = "linux", target_os = "windows")) {
            let _ = close(self.fd);
        }
        @cfg(target_os = "macos") {
            let _ = sys_close(self.fd);
        }
    }
}

implement Debug for UdpSocket {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"UdpSocket {{ fd: {self.fd}, local: {self.local_addr}")?;
        if let Some(peer) = self.peer_addr {
            f.write_str(f", peer: {peer}")?;
        }
        f.write_str(" }")
    }
}

// =============================================================================
// Async UDP Operations (using IOEngine)
// =============================================================================

/// Future that completes when a UDP socket is ready for I/O.
type UdpIoReady is {
    fd: FileDesc,
    interest: IOInterest,
    registered: Bool,
};

implement UdpIoReady {
    fn readable(fd: FileDesc) -> UdpIoReady {
        UdpIoReady { fd: fd, interest: IOInterest.Read, registered: false }
    }

    fn writable(fd: FileDesc) -> UdpIoReady {
        UdpIoReady { fd: fd, interest: IOInterest.Write, registered: false }
    }
}

implement Future for UdpIoReady {
    type Output = ();

    fn poll(&mut self, cx: &mut Context) -> Poll<()> {
        let io_engine = IOEngine.current();

        if !self.registered {
            io_engine.register(self.fd, self.interest, cx.waker());
            self.registered = true;
            return Poll.Pending;
        }

        if io_engine.is_ready(self.fd, self.interest) {
            io_engine.unregister(self.fd, self.interest);
            Poll.Ready(())
        } else {
            io_engine.update_waker(self.fd, self.interest, cx.waker());
            Poll.Pending
        }
    }
}

implement Drop for UdpIoReady {
    fn drop(&mut self) {
        if self.registered {
            let io_engine = IOEngine.current();
            io_engine.unregister(self.fd, self.interest);
        }
    }
}

// Async methods for UdpSocket
implement UdpSocket {
    /// Receive a datagram asynchronously.
    ///
    /// Yields to the executor while waiting for data.
    public async fn recv_from_async(&self, buf: &mut [Byte]) -> Result<(Int, SocketAddr), IoError> {
        // Ensure non-blocking mode
        self.set_nonblocking(true)?;

        @cfg(any(target_os = "linux", target_os = "windows"))
        const EAGAIN: Int = 11;

        @cfg(target_os = "macos")
        const EAGAIN: Int = 35;

        loop {
            let mut addr_buf = [0_u8; 128];
            let mut addr_len: Int = 128;

            @cfg(any(target_os = "linux", target_os = "windows"))
            let result = recvfrom(self.fd, buf, 0, &mut addr_buf, &mut addr_len);

            @cfg(target_os = "macos")
            let result = sys_recvfrom(self.fd, buf, 0, &mut addr_buf, &mut addr_len);

            match result {
                Ok(n) => {
                    let src_addr = deserialize_socket_addr(&addr_buf[..addr_len as Int])?;
                    return Ok((n, src_addr));
                }
                Err(e) if e.code == EAGAIN => {
                    UdpIoReady.readable(self.fd).await;
                    continue;
                }
                Err(e) => {
                    return Err(IoError.from_os_error(e));
                }
            }
        }
    }

    /// Send a datagram asynchronously.
    ///
    /// Yields to the executor if the send buffer is full.
    public async fn send_to_async(&self, buf: &[Byte], addr: SocketAddr) -> Result<Int, IoError> {
        self.set_nonblocking(true)?;

        @cfg(any(target_os = "linux", target_os = "windows"))
        const EAGAIN: Int = 11;

        @cfg(target_os = "macos")
        const EAGAIN: Int = 35;

        let addr_bytes = serialize_socket_addr(&addr);

        loop {
            @cfg(any(target_os = "linux", target_os = "windows"))
            let result = sendto(self.fd, buf, 0,
                                addr_bytes.as_ptr() as &unsafe Byte,
                                addr_bytes.len() as Int);

            @cfg(target_os = "macos")
            let result = sys_sendto(self.fd, buf, 0,
                                    addr_bytes.as_ptr() as &unsafe Byte,
                                    addr_bytes.len() as Int);

            match result {
                Ok(n) => return Ok(n),
                Err(e) if e.code == EAGAIN => {
                    UdpIoReady.writable(self.fd).await;
                    continue;
                }
                Err(e) => {
                    return Err(IoError.from_os_error(e));
                }
            }
        }
    }
}

// =============================================================================
// Socket Address Serialization (shared with tcp.vr)
// =============================================================================

/// Serialize a socket address to bytes for syscalls.
fn serialize_socket_addr(addr: &SocketAddr) -> List<Byte> {
    match *addr {
        SocketAddr.V4(v4) => {
            let mut buf = List.with_capacity(16);

            // sin_family
            buf.push(AF_INET as Byte);
            buf.push(0);

            // sin_port (big-endian)
            let port = v4.port;
            buf.push(((port >> 8) & 0xFF) as Byte);
            buf.push((port & 0xFF) as Byte);

            // sin_addr
            let (a, b, c, d) = v4.addr.octets();
            buf.push(a);
            buf.push(b);
            buf.push(c);
            buf.push(d);

            // sin_zero (8 bytes padding)
            buf.push(0); buf.push(0); buf.push(0); buf.push(0);
            buf.push(0); buf.push(0); buf.push(0); buf.push(0);

            buf
        }
        SocketAddr.V6(v6) => {
            let mut buf = List.with_capacity(28);

            // sin6_family
            buf.push(AF_INET6 as Byte);
            buf.push(0);

            // sin6_port (big-endian)
            let port = v6.port;
            buf.push(((port >> 8) & 0xFF) as Byte);
            buf.push((port & 0xFF) as Byte);

            // sin6_flowinfo (4 bytes)
            buf.push(0); buf.push(0); buf.push(0); buf.push(0);

            // sin6_addr (16 bytes)
            let ip_bytes = v6.addr;
            for i in 0..16 {
                buf.push(ip_bytes[i]);
            }

            // sin6_scope_id (4 bytes, little-endian)
            let scope = v6.scope_id;
            buf.push((scope & 0xFF) as Byte);
            buf.push(((scope >> 8) & 0xFF) as Byte);
            buf.push(((scope >> 16) & 0xFF) as Byte);
            buf.push(((scope >> 24) & 0xFF) as Byte);

            buf
        }
    }
}

/// Deserialize a socket address from kernel sockaddr bytes.
fn deserialize_socket_addr(buf: &[Byte]) -> Result<SocketAddr, IoError> {
    if buf.len() < 2 {
        return Err(IoError.InvalidInput { reason: "Address buffer too small" });
    }

    let family = buf[0] as Int;

    if family == AF_INET {
        if buf.len() < 8 {
            return Err(IoError.InvalidInput { reason: "Invalid IPv4 address buffer" });
        }

        let port = ((buf[2] as Int) << 8) | (buf[3] as Int);
        let ip = Ipv4Addr.new(buf[4], buf[5], buf[6], buf[7]);

        Ok(SocketAddr.new_v4(ip, port))
    } else if family == AF_INET6 {
        if buf.len() < 28 {
            return Err(IoError.InvalidInput { reason: "Invalid IPv6 address buffer" });
        }

        let port = ((buf[2] as Int) << 8) | (buf[3] as Int);

        // Skip flowinfo (bytes 4-7), read 16-byte address (bytes 8-23)
        let mut segments: [UInt16; 8] = [0; 8];
        for i in 0..8 {
            let offset = 8 + i * 2;
            segments[i] = ((buf[offset] as UInt16) << 8) | (buf[offset + 1] as UInt16);
        }
        let ip = Ipv6Addr.new(
            segments[0] as Int, segments[1] as Int, segments[2] as Int, segments[3] as Int,
            segments[4] as Int, segments[5] as Int, segments[6] as Int, segments[7] as Int
        );

        // scope_id (bytes 24-27, little-endian)
        let scope_id = (buf[24] as UInt32)
            | ((buf[25] as UInt32) << 8)
            | ((buf[26] as UInt32) << 16)
            | ((buf[27] as UInt32) << 24);

        Ok(SocketAddr.V6(SocketAddrV6.new(ip, port, 0, scope_id)))
    } else {
        Err(IoError.InvalidInput { reason: f"Unsupported address family: {family}" })
    }
}
