// =============================================================================
// net/tls13/record/mod.vr — TLS 1.3 record layer (RFC 8446 §5)
// =============================================================================
// Layer: 5 (Network — TLS 1.3 core)
// =============================================================================
//
// Two shapes live on the wire:
//
//   TLSPlaintext   ::= struct {
//       ContentType      opaque_type;
//       ProtocolVersion  legacy_record_version;   // always 0x0303
//       uint16           length;                   // ≤ 2^14
//       opaque           fragment[TLSPlaintext.length];
//   };
//
//   TLSCiphertext  ::= struct {
//       ContentType      opaque_type = application_data;    // always 23
//       ProtocolVersion  legacy_record_version = 0x0303;
//       uint16           length;                             // ≤ 2^14 + 256
//       opaque           encrypted_record[TLSCiphertext.length];
//   };
//
//   TLSInnerPlaintext ::= struct {
//       opaque     content[TLSPlaintext.length];
//       ContentType type;
//       uint8      zeros[length_of_padding];
//   };
//
// The encrypted payload (`encrypted_record`) is the AEAD-seal of
// TLSInnerPlaintext. AAD is the 5-byte outer record header. Nonce is
// the traffic IV XORed with the big-endian sequence counter, per
// RFC 8446 §5.3.
//
// =============================================================================

module core.net.tls13.record;

public module content_type;
public module plaintext;
public module aead;

// Re-exports
public mount .content_type.ContentType;
public mount .plaintext.{TlsPlaintext, MAX_PLAINTEXT_SIZE, MAX_CIPHERTEXT_SIZE};
public mount .aead.{AeadState, RecordError};
