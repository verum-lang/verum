// =============================================================================
// net/tls13/keyschedule/derive_secret.vr — Derive-Secret (RFC 8446 §7.1)
// =============================================================================
// Layer: 5 (Network — TLS 1.3 core)
// =============================================================================
//
// Derive-Secret(Secret, Label, Messages) =
//     HKDF-Expand-Label(Secret, Label, Transcript-Hash(Messages), Hash.length)
//
// Every secret in the TLS 1.3 key schedule is produced by either
// HKDF-Extract (Early / Handshake / Master secrets — taking PSK /
// (EC)DHE / 0 as IKM) or Derive-Secret (traffic / binder / exporter
// / resumption secrets — binding to the transcript).
//
// `Messages` is the concatenation of all handshake messages from the
// first ClientHello through the indicated handshake message
// (inclusive). We don't re-hash each time: the caller passes the
// transcript hash as a byte slice (snapshot of an incremental Hasher
// in the handshake state machine).
//
// Beyond the RFC-spec helper, we also ship a convenience
// `derive_secret_with_empty_transcript` that hashes the empty input —
// used for the two "derived" Derive-Secret steps between the Extract
// stages (early → handshake, handshake → master).
//
// =============================================================================

module core.net.tls13.keyschedule.derive_secret;

mount core.*;
mount core.collections.List;
mount core.security.hash.sha256.{Sha256};
mount core.security.hash.sha384.{Sha384};
mount core.security.kdf.hkdf.{HkdfError};
mount core.net.tls13.cipher_suite.{HashKind};
mount core.net.tls13.keyschedule.hkdf_label.{hkdf_expand_label};

/// Derive-Secret as defined in RFC 8446 §7.1.
///
/// `secret` is the input PRK.
/// `label` is the ASCII label (without the "tls13 " prefix — HKDF-Expand-Label
/// adds that internally).
/// `messages_hash` is Transcript-Hash(Messages) — the running hash
/// snapshot from the handshake state machine.
public fn derive_secret(
    hash: HashKind,
    secret: &[Byte],
    label: &[Byte],
    messages_hash: &[Byte],
) -> Result<List<Byte>, HkdfError> {
    let out_len = match hash {
        HashKind.Sha256 => 32,
        HashKind.Sha384 => 48,
    };
    hkdf_expand_label(hash, secret, label, messages_hash, out_len)
}

/// Convenience: Derive-Secret with the transcript hash of the empty
/// string. Used for the "derived" transitions between
/// Early-Secret → Handshake-Secret and Handshake-Secret → Master-Secret.
///
/// The empty-transcript hash is identical for any fresh handshake
/// regardless of session parameters, so we bake it in as a constant
/// per hash family (RFC 8446 §7.1 "Empty transcript").
public fn derive_secret_with_empty_transcript(
    hash: HashKind,
    secret: &[Byte],
    label: &[Byte],
) -> Result<List<Byte>, HkdfError> {
    match hash {
        HashKind.Sha256 => {
            let empty = Sha256.digest(&[]);
            derive_secret(hash, secret, label, &empty)
        },
        HashKind.Sha384 => {
            let empty = Sha384.digest(&[]);
            derive_secret(hash, secret, label, &empty)
        },
    }
}

// =============================================================================
// Label constants — RFC 8446 §7.1 Figure 12
// =============================================================================

/// "derived" — used in the two "->Derive-Secret(., "derived", "")"
/// transitions between schedule stages.
public const LABEL_DERIVED: [Byte; 7] = [
    0x64_u8, 0x65_u8, 0x72_u8, 0x69_u8, 0x76_u8, 0x65_u8, 0x64_u8,   // "derived"
];

public const LABEL_EXT_BINDER: [Byte; 10] = [
    0x65_u8, 0x78_u8, 0x74_u8, 0x20_u8, 0x62_u8, 0x69_u8, 0x6E_u8, 0x64_u8, 0x65_u8, 0x72_u8,  // "ext binder"
];

public const LABEL_RES_BINDER: [Byte; 10] = [
    0x72_u8, 0x65_u8, 0x73_u8, 0x20_u8, 0x62_u8, 0x69_u8, 0x6E_u8, 0x64_u8, 0x65_u8, 0x72_u8,  // "res binder"
];

public const LABEL_CLIENT_EARLY_TRAFFIC: [Byte; 11] = [
    0x63_u8, 0x20_u8, 0x65_u8, 0x20_u8, 0x74_u8, 0x72_u8, 0x61_u8, 0x66_u8, 0x66_u8, 0x69_u8, 0x63_u8,  // "c e traffic"
];

public const LABEL_EARLY_EXPORTER_MASTER: [Byte; 12] = [
    0x65_u8, 0x20_u8, 0x65_u8, 0x78_u8, 0x70_u8, 0x20_u8, 0x6D_u8, 0x61_u8, 0x73_u8, 0x74_u8, 0x65_u8, 0x72_u8,  // "e exp master"
];

public const LABEL_CLIENT_HS_TRAFFIC: [Byte; 12] = [
    0x63_u8, 0x20_u8, 0x68_u8, 0x73_u8, 0x20_u8, 0x74_u8, 0x72_u8, 0x61_u8, 0x66_u8, 0x66_u8, 0x69_u8, 0x63_u8,  // "c hs traffic"
];

public const LABEL_SERVER_HS_TRAFFIC: [Byte; 12] = [
    0x73_u8, 0x20_u8, 0x68_u8, 0x73_u8, 0x20_u8, 0x74_u8, 0x72_u8, 0x61_u8, 0x66_u8, 0x66_u8, 0x69_u8, 0x63_u8,  // "s hs traffic"
];

public const LABEL_CLIENT_AP_TRAFFIC: [Byte; 12] = [
    0x63_u8, 0x20_u8, 0x61_u8, 0x70_u8, 0x20_u8, 0x74_u8, 0x72_u8, 0x61_u8, 0x66_u8, 0x66_u8, 0x69_u8, 0x63_u8,  // "c ap traffic"
];

public const LABEL_SERVER_AP_TRAFFIC: [Byte; 12] = [
    0x73_u8, 0x20_u8, 0x61_u8, 0x70_u8, 0x20_u8, 0x74_u8, 0x72_u8, 0x61_u8, 0x66_u8, 0x66_u8, 0x69_u8, 0x63_u8,  // "s ap traffic"
];

public const LABEL_EXPORTER_MASTER: [Byte; 10] = [
    0x65_u8, 0x78_u8, 0x70_u8, 0x20_u8, 0x6D_u8, 0x61_u8, 0x73_u8, 0x74_u8, 0x65_u8, 0x72_u8,  // "exp master"
];

public const LABEL_RESUMPTION_MASTER: [Byte; 10] = [
    0x72_u8, 0x65_u8, 0x73_u8, 0x20_u8, 0x6D_u8, 0x61_u8, 0x73_u8, 0x74_u8, 0x65_u8, 0x72_u8,  // "res master"
];

public const LABEL_TRAFFIC_UPD: [Byte; 11] = [
    0x74_u8, 0x72_u8, 0x61_u8, 0x66_u8, 0x66_u8, 0x69_u8, 0x63_u8, 0x20_u8, 0x75_u8, 0x70_u8, 0x64_u8,  // "traffic upd"
];

public const LABEL_FINISHED: [Byte; 8] = [
    0x66_u8, 0x69_u8, 0x6E_u8, 0x69_u8, 0x73_u8, 0x68_u8, 0x65_u8, 0x64_u8,   // "finished"
];

public const LABEL_KEY: [Byte; 3] = [
    0x6B_u8, 0x65_u8, 0x79_u8,   // "key"
];

public const LABEL_IV: [Byte; 2] = [
    0x69_u8, 0x76_u8,   // "iv"
];

public const LABEL_RESUMPTION: [Byte; 10] = [
    0x72_u8, 0x65_u8, 0x73_u8, 0x75_u8, 0x6D_u8, 0x70_u8, 0x74_u8, 0x69_u8, 0x6F_u8, 0x6E_u8,   // "resumption"
