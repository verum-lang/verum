// =============================================================================
// net/tls13/named_group.vr — TLS 1.3 key-share groups (RFC 8446 §4.2.7)
// =============================================================================
// Layer: 5 (Network)
// =============================================================================
//
// NamedGroup enumerates the EC / FFDHE / PQ curves a client advertises
// in the `supported_groups` + `key_share` extensions. Each entry is a
// 16-bit IANA code.
//
// Warp ships:
//   * x25519         (RFC 8446 §4.2.7 — mandatory MUST for 1.3)
//   * secp256r1      (RFC 8446 §4.2.7 — mandatory MUST for WebPKI)
//   * secp384r1      (optional but widely supported)
//
// X448 / secp521r1 / FFDHE / ML-KEM — not v1.
//
// =============================================================================

module core.net.tls13.named_group;

mount core.*;

public type NamedGroup is
      X25519           // 0x001D
    | Secp256r1        // 0x0017
    | Secp384r1        // 0x0018
    | Secp521r1        // 0x0019
    | X448             // 0x001E
    | Ffdhe2048        // 0x0100
    | Ffdhe3072        // 0x0101
    | Ffdhe4096        // 0x0102
    | Unknown(UInt16);

implement NamedGroup {
    public fn to_u16(&self) -> UInt16 {
        match self {
            NamedGroup.X25519        => 0x001D_u16,
            NamedGroup.Secp256r1     => 0x0017_u16,
            NamedGroup.Secp384r1     => 0x0018_u16,
            NamedGroup.Secp521r1     => 0x0019_u16,
            NamedGroup.X448          => 0x001E_u16,
            NamedGroup.Ffdhe2048     => 0x0100_u16,
            NamedGroup.Ffdhe3072     => 0x0101_u16,
            NamedGroup.Ffdhe4096     => 0x0102_u16,
            NamedGroup.Unknown(v)    => *v,
        }
    }

    public fn from_u16(v: UInt16) -> NamedGroup {
        match v {
            0x001D_u16 => NamedGroup.X25519,
            0x0017_u16 => NamedGroup.Secp256r1,
            0x0018_u16 => NamedGroup.Secp384r1,
            0x0019_u16 => NamedGroup.Secp521r1,
            0x001E_u16 => NamedGroup.X448,
            0x0100_u16 => NamedGroup.Ffdhe2048,
            0x0101_u16 => NamedGroup.Ffdhe3072,
            0x0102_u16 => NamedGroup.Ffdhe4096,
            _          => NamedGroup.Unknown(v),
        }
    }

    /// v1 supported groups — x25519 + P-256 + P-384.
    public fn is_supported(&self) -> Bool {
        match self {
            NamedGroup.X25519    => true,
            NamedGroup.Secp256r1 => true,
            NamedGroup.Secp384r1 => true,
            _                    => false,
        }
    }

    /// Length of the raw public-key share in bytes. For uncompressed EC
    /// points the format is 1 + 2*field_size; X25519/X448 are fixed
    /// 32 / 56 bytes.
    public fn public_key_len(&self) -> Int {
        match self {
            NamedGroup.X25519    => 32,
            NamedGroup.X448      => 56,
            NamedGroup.Secp256r1 => 65,  // 0x04 || X(32) || Y(32)
            NamedGroup.Secp384r1 => 97,
            NamedGroup.Secp521r1 => 133,
            _                    => 0,
        }
    }
}
