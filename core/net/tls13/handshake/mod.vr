// =============================================================================
// net/tls13/handshake/mod.vr — TLS 1.3 handshake layer (RFC 8446 §4)
// =============================================================================
// Layer: 5 (Network — TLS 1.3 core)
// Spec: internal/specs/tls-quic.md §6.2, §12 Phase 2 step 2
// =============================================================================
//
// Phase 2 step 2: wire-format handshake messages + extension ADT +
// transcript hash + typed client state machine. The server SM
// mirrors the client with roles swapped and lands in Phase 2 step 3.
//
// # Module layout
//
// ```
// core.net.tls13.handshake
// ├── mod.vr           ← this file (re-exports)
// ├── codec.vr         — big-endian u8/u16/u24/u32 + length-prefix helpers
// ├── extension.vr     — Extension ADT + per-context decode (RFC 8446 §4.2)
// ├── messages.vr      — ClientHello / ServerHello / EE / Cert / CV /
// │                      Finished / NST / KU / EndOfEarlyData / HRR
// ├── transcript.vr    — Transcript-Hash (RFC 8446 §4.4.1) with HRR reseed
// └── client_sm.vr     — Typed client state machine (Start → … → Connected)
// ```
//
// =============================================================================

module core.net.tls13.handshake;

public module codec;
public module extension;
public module messages;
public module transcript;
public module client_sm;
public module server_sm;
public module dhe_pool;
public module psk;
public module resumption;
public module early_data;
public module ticket_issuer;
public module resume_verify;
public module zero_rtt_antireplay;
public module sni_resolver;

// Re-exports — codec
public mount .codec.{Reader, CodecError};

// Re-exports — extensions
public mount .extension.{
    Extension, ExtensionContext,
    KeyShareEntry, ServerName,
    PskKeMode, EarlyDataIndication,
    encode_extensions_block, decode_extensions_block,
    encode_extension, decode_extension,
};

// Re-exports — messages
public mount .messages.{
    HandshakeMessage,
    ClientHello, ServerHello, EncryptedExtensions,
    CertificateMessage, CertificateEntry, CertificateRequest,
    CertificateVerify, Finished, NewSessionTicket,
    KeyUpdate, KeyUpdateRequest,
    encode_handshake, decode_handshake,
    is_hello_retry_request,
};

// Re-exports — transcript
public mount .transcript.{Transcript};

// Re-exports — client state machine
public mount .client_sm.{
    ClientConfig, ClientSm, StepOutput,
    WaitServerHello, WaitEncryptedExtensions, Connected,
};

// Re-exports — server state machine
public mount .server_sm.{
    ServerConfig, ServerSm, ServerStepOutput, ServerConnected,
    CertSigner,
    WaitClientHello, WaitClientFinished,
};

// Re-exports — DHE keypair pool
public mount .dhe_pool.{DhePool, LocalDhePool, DheKeyPair, generate_client_keyshares};

// Re-exports — PSK binder + OfferedPsks extension encoding
public mount .psk.{
    PskIdentity, OfferedPsks, BinderFlavor,
    encode_identities, encode_binders, encode_offered_psks,
    derive_binder_key, derive_binder_finished_key,
    compute_binder, verify_binder, obfuscated_ticket_age,
};

// Re-exports — session tickets + resumption cache
public mount .resumption.{
    ClientSession, SessionTicketKey, ServerTicketPlaintext,
    ClientSessionStore, TicketError,
    issue_ticket, decrypt_ticket, session_from_new_ticket,
    client_session_from_nst,
};

// Re-exports — 0-RTT early data
public mount .early_data.{
    EarlyKeys, EarlyDataBudget,
    derive as derive_early_keys,
    to_traffic_keys as early_traffic_keys,
    early_secret_from_psk,
};

// Re-exports — post-handshake session ticket issuance
public mount .ticket_issuer.{
    IssueOptions, IssueError,
    issue_post_handshake_ticket, issue_post_handshake_tickets,
};

// Re-exports — server-side PSK resumption verify
public mount .resume_verify.{
    ResumedSession, ResumeVerifyError,
    verify_offered_psks, DEFAULT_FRESHNESS_WINDOW_MS,
};

// Re-exports — 0-RTT replay cache (RFC 8446 §8)
public mount .zero_rtt_antireplay.{
    ReplayCache, ReplayConfig, ReplayStats,
    ReplayGuard, NoReplayGuard,
};

// Re-exports — SNI-driven cert/signer resolver (RFC 6066)
public mount .sni_resolver.{
    ServerNameResolver, ServerIdentity, SniResolveError,
    ExactMatchResolver,
};
