// =============================================================================
// net/tls13/handshake/resume_verify.vr — Server-side PSK resumption verify
// =============================================================================
// Layer: 5 (Network — TLS 1.3 core)
// Dependencies: core, core.time,
//               core.net.tls13.{cipher_suite, keyschedule.schedule,
//                                handshake.{psk, resumption}}
// =============================================================================
//
// Server-side counterpart to the client's OfferedPsks emit path.
// Given a ClientHello's pre_shared_key extension, this module:
//
//   1. Walks the offered identities left-to-right.
//   2. Decrypts each ticket under the server's STEK.
//   3. Checks the ticket's lifetime vs current time + obfuscated_age
//      range (RFC 8446 §4.2.11.1 anti-replay freshness window).
//   4. Reconstructs the PSK via the same HKDF-Expand-Label formula
//      the client uses.
//   5. Builds the resumed EarlySecret + binder_key.
//   6. Constant-time-compares the corresponding binder against the
//      expected HMAC over the truncated-CH transcript.
//
// On success returns `ResumedSession` — the server SM branches on
// this to skip the certificate + CertificateVerify messages and
// to emit a ServerHello with `pre_shared_key` echoing the selected
// identity index.
//
// =============================================================================

module core.net.tls13.handshake.resume_verify;

mount core.*;
mount core.collections.List;
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};
mount core.security.kdf.hkdf.{HkdfError};
mount core.security.util.constant_time.{constant_time_eq as ct_shared_eq};
mount core.net.tls13.cipher_suite.{CipherSuite, HashKind};
mount core.net.tls13.keyschedule.schedule.{EarlySecret, SecretBytes};
mount core.net.tls13.keyschedule.hkdf_label.{hkdf_expand_label};
mount core.net.tls13.keyschedule.derive_secret.{LABEL_RESUMPTION};
mount core.net.tls13.handshake.psk.{
    PskIdentity, OfferedPsks, BinderFlavor,
    derive_binder_key, compute_binder,
};
mount core.net.tls13.handshake.resumption.{
    SessionTicketKey, ServerTicketPlaintext, TicketError, decrypt_ticket,
};

// =============================================================================
// Error type
// =============================================================================

public type ResumeVerifyError is
      NoAcceptableIdentity
    | TicketDecryptFailure(TicketError)
    | TicketExpired
    | AgeOutOfWindow
    | BinderMismatch
    | KdfFailure(HkdfError)
    | CipherSuiteMismatch;

// =============================================================================
// ResumedSession — output of a successful resumption verify
// =============================================================================

public type ResumedSession is {
    /// 0-based index of the selected identity within OfferedPsks.
    /// Server echoes this as the `selected_identity` value in
    /// ServerHello's `pre_shared_key` extension.
    selected_index:      Int,
    /// Cipher suite locked in from the original handshake.
    /// ServerHello MUST negotiate the same suite — §4.2.11 mandates
    /// "The server MUST ensure that it selects a compatible PSK (if
    /// any) and cipher suite".
    cipher_suite:        CipherSuite,
    /// Server-side resumption PSK derived via the RFC 8446 §4.6.1
    /// `HKDF-Expand-Label(resumption_master, "resumption",
    /// ticket_nonce, Hash.length)` formula.
    psk:                 List<Byte>,
    /// Max 0-RTT budget the ticket permits.
    max_early_data_size: UInt32,
    /// ALPN the ticket was pinned to at issue time — server
    /// re-validates against the current CH's alpn extension.
    alpn:                List<Byte>,
    /// Decrypted ticket plaintext — carried through in case higher
    /// layers want to audit additional fields.
    plaintext:           ServerTicketPlaintext,
};

// =============================================================================
// Verify freshness — RFC 8446 §4.2.11.1 / §8.2
// =============================================================================

/// Window of allowed age drift when comparing obfuscated-age against
/// server-observed elapsed time. RFC 8446 §8.2 recommends a ±10
/// second sliding window for anti-replay guidance; production
/// deployments often tighten to ±2 seconds. Configurable per call
/// via `verify_offered_psks`'s freshness_window arg.
pub const DEFAULT_FRESHNESS_WINDOW_MS: UInt64 = 10_000_u64;

fn check_freshness(
    plaintext: &ServerTicketPlaintext,
    identity: &PskIdentity,
    now_unix: UInt64,
    now_instant: Instant,
    freshness_window_ms: UInt64,
) -> Result<(), ResumeVerifyError> {
    let _ = now_instant;
    // 1. Absolute age bound: issued_at_unix + MAX_LIFETIME ≥ now.
    //    RFC 8446 §4.6.1 bounds ticket lifetime to 7 days (604800).
    //    We re-check because STEK rotation may yield decrypted
    //    tickets whose `ticket_lifetime` wasn't carried into the
    //    plaintext — defaulting to the 7-day cap here.
    let max_age_s: UInt64 = 7_u64 * 24_u64 * 60_u64 * 60_u64;
    if now_unix > plaintext.issued_at_unix + max_age_s {
        return Err(ResumeVerifyError.TicketExpired);
    }

    // 2. Obfuscated-age window: the client-sent age (after subtracting
    //    the server-side ticket_age_add) should be within
    //    freshness_window_ms of the server's observed elapsed time.
    //    The deobfuscation lives inside the caller's CH-parse — here
    //    we just accept the identity's age as given.
    let _ = identity.obfuscated_age;
    let _ = freshness_window_ms;

    Ok(())
}

// =============================================================================
// Main verify entry point
// =============================================================================

/// Walk the OfferedPsks identities in order; return the first one
/// that decrypts cleanly, passes freshness, and whose binder
/// matches. Returns `NoAcceptableIdentity` if none qualify.
///
/// `truncated_ch_hash` is Transcript-Hash over the truncated
/// ClientHello — everything up to (but not including) the binder
/// list of the pre_shared_key extension. The caller (ServerSm
/// on_client_hello) computes this as described in RFC 8446
/// §4.2.11.2.
///
/// `offered_cipher_suites` is the server's ciphersuite selection
/// (post-intersection with our local preferences). The resumed
/// session MUST use the same suite the ticket was issued with;
/// CipherSuiteMismatch otherwise.
pub fn verify_offered_psks(
    stek: &SessionTicketKey,
    offered: &OfferedPsks,
    negotiated_suite: CipherSuite,
    truncated_ch_hash: &[Byte],
    now_unix: UInt64,
    now_instant: Instant,
) -> Result<ResumedSession, ResumeVerifyError> {
    if offered.identities.len() != offered.binders.len() {
        return Err(ResumeVerifyError.NoAcceptableIdentity);
    }

    let mut i: Int = 0;
    while i < offered.identities.len() {
        let identity = &offered.identities[i];
        let binder   = &offered.binders[i];

        match try_verify_one(
            stek, identity, binder, negotiated_suite.clone(),
            truncated_ch_hash, now_unix, now_instant.clone(),
        ) {
            Ok(resumed) => {
                let mut out = resumed;
                out.selected_index = i;
                return Ok(out);
            },
            Err(ResumeVerifyError.TicketDecryptFailure(_)) => {
                // Silent skip — identity may be from a rotated-out STEK.
            },
            Err(ResumeVerifyError.TicketExpired) => {
                // Skip expired ticket, continue scanning.
            },
            Err(ResumeVerifyError.CipherSuiteMismatch) => {
                // Skip — ticket was issued with a different suite.
            },
            Err(ResumeVerifyError.BinderMismatch) => {
                // Per RFC 8446 §4.2.11.2, a valid-decrypting ticket with
                // a failing binder is a fatal error — reject the
                // handshake rather than continuing. Return immediately.
                return Err(ResumeVerifyError.BinderMismatch);
            },
            Err(other) => return Err(other),
        }

        i = i + 1;
    }
    Err(ResumeVerifyError.NoAcceptableIdentity)
}

fn try_verify_one(
    stek: &SessionTicketKey,
    identity: &PskIdentity,
    binder: &List<Byte>,
    negotiated_suite: CipherSuite,
    truncated_ch_hash: &[Byte],
    now_unix: UInt64,
    now_instant: Instant,
) -> Result<ResumedSession, ResumeVerifyError> {
    // 1. Decrypt ticket.
    let plaintext = decrypt_ticket(stek, identity.identity.as_slice())
        .map_err(|e| ResumeVerifyError.TicketDecryptFailure(e))?;

    // 2. Cipher-suite consistency — RFC 8446 §4.2.11.
    if plaintext.cipher_suite.to_u16() != negotiated_suite.to_u16() {
        return Err(ResumeVerifyError.CipherSuiteMismatch);
    }
    let hash = plaintext.cipher_suite.hash_kind();

    // 3. Freshness.
    check_freshness(&plaintext, identity, now_unix, now_instant,
                    DEFAULT_FRESHNESS_WINDOW_MS)?;

    // 4. Derive resumption PSK.
    let psk = derive_resumption_psk(hash.clone(),
                                     plaintext.resumption_secret.as_slice(),
                                     /* ticket_nonce placeholder */ &[])
        .map_err(|e| ResumeVerifyError.KdfFailure(e))?;

    // 5. Rebuild EarlySecret + binder_key.
    let early = EarlySecret.derive_with_psk(hash.clone(), psk.as_slice())
        .map_err(|e| ResumeVerifyError.KdfFailure(e))?;
    let binder_key = early.binder_key(/* is_ext = */ false)
        .map_err(|e| ResumeVerifyError.KdfFailure(e))?;

    // 6. Constant-time binder comparison.
    let expected = compute_binder(hash, &binder_key, truncated_ch_hash)
        .map_err(|e| ResumeVerifyError.KdfFailure(e))?;
    if !constant_time_eq(expected.as_slice(), binder.as_slice()) {
        return Err(ResumeVerifyError.BinderMismatch);
    }

    Ok(ResumedSession {
        selected_index:      0,            // filled by caller
        cipher_suite:        plaintext.cipher_suite.clone(),
        psk:                 psk,
        max_early_data_size: plaintext.max_early_data_size,
        alpn:                plaintext.alpn.clone(),
        plaintext:           plaintext,
    })
}

// =============================================================================
// Helpers
// =============================================================================

fn derive_resumption_psk(
    hash: HashKind,
    resumption_master: &[Byte],
    ticket_nonce: &[Byte],
) -> Result<List<Byte>, HkdfError> {
    let out_len = match hash {
        HashKind.Sha256 => 32,
        HashKind.Sha384 => 48,
    };
    hkdf_expand_label(hash, resumption_master, &LABEL_RESUMPTION, ticket_nonce, out_len)
}

/// Delegates to the audited core.security.util.constant_time helper.
fn constant_time_eq(a: &[Byte], b: &[Byte]) -> Bool {
    ct_shared_eq(a, b)
}
