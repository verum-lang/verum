// =============================================================================
// net/http2/error.vr — Http2Error + ErrorCode (RFC 7540 §7)
// =============================================================================

module core.net.http2.error;

mount core.*;

// =============================================================================
// ErrorCode — 32-bit wire value (§7)
// =============================================================================

public type ErrorCode is {
    code: UInt32,
}

implement ErrorCode {
    public const NO_ERROR: UInt32           = 0x00;
    public const PROTOCOL_ERROR: UInt32     = 0x01;
    public const INTERNAL_ERROR: UInt32     = 0x02;
    public const FLOW_CONTROL_ERROR: UInt32 = 0x03;
    public const SETTINGS_TIMEOUT: UInt32   = 0x04;
    public const STREAM_CLOSED: UInt32      = 0x05;
    public const FRAME_SIZE_ERROR: UInt32   = 0x06;
    public const REFUSED_STREAM: UInt32     = 0x07;
    public const CANCEL: UInt32             = 0x08;
    public const COMPRESSION_ERROR: UInt32  = 0x09;
    public const CONNECT_ERROR: UInt32      = 0x0A;
    public const ENHANCE_YOUR_CALM: UInt32  = 0x0B;
    public const INADEQUATE_SECURITY: UInt32 = 0x0C;
    public const HTTP_1_1_REQUIRED: UInt32  = 0x0D;

    public fn new(code: UInt32) -> ErrorCode { ErrorCode { code: code } }
    public fn value(&self) -> UInt32 { self.code }
}

// =============================================================================
// Http2Error — protocol-level error with scope (connection vs stream)
// =============================================================================

public type Http2Error is
    /// Connection-level error — MUST emit GOAWAY and terminate the connection.
    | ConnectionError { code: ErrorCode, reason: Text }
    /// Stream-level error — MUST emit RST_STREAM on that stream only.
    | StreamError { stream_id: UInt32, code: ErrorCode, reason: Text }
    /// Wire buffer too short — caller should read more and retry.
    | NeedMore
    /// Client sent an invalid preface (not the 24-byte magic).
    | BadClientPreface
    /// Malformed frame header (reserved bits / unknown type in strict mode).
    | MalformedFrame(Text)
    /// HPACK decoding failed (RFC 7541 §4.4 / §8.2).
    | HpackError(Text)
    /// Frame exceeded the negotiated MAX_FRAME_SIZE.
    | FrameSizeExceeded { size: Int, limit: Int };

// Convenience constructors.
public fn connection_error(code: UInt32, reason: &Text) -> Http2Error {
    Http2Error.ConnectionError { code: ErrorCode.new(code), reason: reason.clone() }
}

public fn stream_error(stream_id: UInt32, code: UInt32, reason: &Text) -> Http2Error {
    Http2Error.StreamError {
        stream_id: stream_id,
        code: ErrorCode.new(code),
        reason: reason.clone(),
    }
}

implement Display for ErrorCode {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"0x{self.code:x}".as_str())
    }
}

implement Debug for ErrorCode {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(f"ErrorCode(0x{self.code:x})".as_str())
    }
}

implement Eq for ErrorCode {
    fn eq(&self, other: &ErrorCode) -> Bool {
        self.code == other.code
    }
}

implement Display for Http2Error {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Http2Error.ConnectionError { code, reason } =>
                f.write_str(f"HTTP/2 connection error {code}: {reason}".as_str()),
            Http2Error.StreamError { stream_id, code, reason } =>
                f.write_str(f"HTTP/2 stream {stream_id} error {code}: {reason}".as_str()),
            Http2Error.NeedMore =>
                f.write_str("HTTP/2 wire buffer needs more bytes"),
            Http2Error.BadClientPreface =>
                f.write_str("HTTP/2 invalid client preface"),
            Http2Error.MalformedFrame(reason) =>
                f.write_str(f"HTTP/2 malformed frame: {reason}".as_str()),
            Http2Error.HpackError(reason) =>
                f.write_str(f"HTTP/2 HPACK decode failed: {reason}".as_str()),
            Http2Error.FrameSizeExceeded { size, limit } =>
                f.write_str(f"HTTP/2 frame size {size} exceeds limit {limit}".as_str()),
        }
    }
}

implement Debug for Http2Error {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            Http2Error.ConnectionError { code, reason } =>
                f.write_str(f"ConnectionError {{ code: {code:?}, reason: {reason} }}".as_str()),
            Http2Error.StreamError { stream_id, code, reason } =>
                f.write_str(f"StreamError {{ stream_id: {stream_id}, code: {code:?}, reason: {reason} }}".as_str()),
            Http2Error.NeedMore =>
                f.write_str("NeedMore"),
            Http2Error.BadClientPreface =>
                f.write_str("BadClientPreface"),
            Http2Error.MalformedFrame(reason) =>
                f.write_str(f"MalformedFrame({reason})".as_str()),
            Http2Error.HpackError(reason) =>
                f.write_str(f"HpackError({reason})".as_str()),
            Http2Error.FrameSizeExceeded { size, limit } =>
                f.write_str(f"FrameSizeExceeded {{ size: {size}, limit: {limit} }}".as_str()),
        }
    }
}

implement Eq for Http2Error {
    fn eq(&self, other: &Http2Error) -> Bool {
        match (self, other) {
            (Http2Error.ConnectionError { code: ca, reason: ra },
             Http2Error.ConnectionError { code: cb, reason: rb }) => ca == cb && ra == rb,
            (Http2Error.StreamError { stream_id: sa, code: ca, reason: ra },
             Http2Error.StreamError { stream_id: sb, code: cb, reason: rb }) => sa == sb && ca == cb && ra == rb,
            (Http2Error.NeedMore,             Http2Error.NeedMore)             => true,
            (Http2Error.BadClientPreface,     Http2Error.BadClientPreface)     => true,
            (Http2Error.MalformedFrame(a),    Http2Error.MalformedFrame(b))    => a == b,
            (Http2Error.HpackError(a),        Http2Error.HpackError(b))        => a == b,
            (Http2Error.FrameSizeExceeded { size: sa, limit: la },
             Http2Error.FrameSizeExceeded { size: sb, limit: lb })             => sa == sb && la == lb,
            _ => false,
        }
    }
}
