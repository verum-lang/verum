// =============================================================================
// net/http2/static_table.vr — HPACK static table (RFC 7541 Appendix A)
// =============================================================================
// 61 well-known (name, value) pairs. Index 0 is reserved; entries are
// numbered 1..61. Indexes 62+ refer to the dynamic table in the
// combined index space.
// =============================================================================

module core.net.http2.static_table;

mount core.*;

public const STATIC_TABLE_SIZE: Int = 61;

public type HpackStaticEntry is {
    name: &'static Text,
    value: &'static Text,
}

/// Entry lookup — 1-indexed per RFC 7541 §2.3.3. Returns None for
/// index 0 or > STATIC_TABLE_SIZE.
public fn entry(index: Int) -> Maybe<HpackStaticEntry> {
    if index < 1 || index > STATIC_TABLE_SIZE { return None; }
    Some(ENTRIES[index - 1])
}

public const ENTRIES: [HpackStaticEntry; 61] = [
    HpackStaticEntry { name: ":authority",                  value: "" },
    HpackStaticEntry { name: ":method",                     value: "GET" },
    HpackStaticEntry { name: ":method",                     value: "POST" },
    HpackStaticEntry { name: ":path",                       value: "/" },
    HpackStaticEntry { name: ":path",                       value: "/index.html" },
    HpackStaticEntry { name: ":scheme",                     value: "http" },
    HpackStaticEntry { name: ":scheme",                     value: "https" },
    HpackStaticEntry { name: ":status",                     value: "200" },
    HpackStaticEntry { name: ":status",                     value: "204" },
    HpackStaticEntry { name: ":status",                     value: "206" },
    HpackStaticEntry { name: ":status",                     value: "304" },
    HpackStaticEntry { name: ":status",                     value: "400" },
    HpackStaticEntry { name: ":status",                     value: "404" },
    HpackStaticEntry { name: ":status",                     value: "500" },
    HpackStaticEntry { name: "accept-charset",              value: "" },
    HpackStaticEntry { name: "accept-encoding",             value: "gzip, deflate" },
    HpackStaticEntry { name: "accept-language",             value: "" },
    HpackStaticEntry { name: "accept-ranges",               value: "" },
    HpackStaticEntry { name: "accept",                      value: "" },
    HpackStaticEntry { name: "access-control-allow-origin", value: "" },
    HpackStaticEntry { name: "age",                         value: "" },
    HpackStaticEntry { name: "allow",                       value: "" },
    HpackStaticEntry { name: "authorization",               value: "" },
    HpackStaticEntry { name: "cache-control",               value: "" },
    HpackStaticEntry { name: "content-disposition",         value: "" },
    HpackStaticEntry { name: "content-encoding",            value: "" },
    HpackStaticEntry { name: "content-language",            value: "" },
    HpackStaticEntry { name: "content-length",              value: "" },
    HpackStaticEntry { name: "content-location",            value: "" },
    HpackStaticEntry { name: "content-range",               value: "" },
    HpackStaticEntry { name: "content-type",                value: "" },
    HpackStaticEntry { name: "cookie",                      value: "" },
    HpackStaticEntry { name: "date",                        value: "" },
    HpackStaticEntry { name: "etag",                        value: "" },
    HpackStaticEntry { name: "expect",                      value: "" },
    HpackStaticEntry { name: "expires",                     value: "" },
    HpackStaticEntry { name: "from",                        value: "" },
    HpackStaticEntry { name: "host",                        value: "" },
    HpackStaticEntry { name: "if-match",                    value: "" },
    HpackStaticEntry { name: "if-modified-since",           value: "" },
    HpackStaticEntry { name: "if-none-match",               value: "" },
    HpackStaticEntry { name: "if-range",                    value: "" },
    HpackStaticEntry { name: "if-unmodified-since",         value: "" },
    HpackStaticEntry { name: "last-modified",               value: "" },
    HpackStaticEntry { name: "link",                        value: "" },
    HpackStaticEntry { name: "location",                    value: "" },
    HpackStaticEntry { name: "max-forwards",                value: "" },
    HpackStaticEntry { name: "proxy-authenticate",          value: "" },
    HpackStaticEntry { name: "proxy-authorization",         value: "" },
    HpackStaticEntry { name: "range",                       value: "" },
    HpackStaticEntry { name: "referer",                     value: "" },
