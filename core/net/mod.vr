// =============================================================================
// net/mod.vr - Network module
// =============================================================================
// Layer: 5 (Network)
// Dependencies: core, io, async
// Spec: docs/new-model/RUNTIME_CONSOLIDATION_PLAN.md Appendix B.1
// =============================================================================
//
// This module provides networking primitives:
//
// - tcp.vr: TCP streams and listeners
// - udp.vr: UDP sockets
// - addr.vr: IP addresses and socket addresses
// - resolve.vr: DNS resolution
//
// # V-LLSI Architecture (Zero FFI)
//
// All networking modules use native V-LLSI syscalls with no FFI dependencies.
// This provides maximum control for building high-performance protocols (QUIC,
// HTTP/2, HTTP/3).
//
// ```
// Application Layer
//     │
//     ▼
// ┌─────────────────────────────────────────┐
// │           core/net/                    │
// │  TcpStream, TcpListener, UdpSocket      │
// │  dns.vr (pure DNS protocol over UDP)    │
// └─────────────────────────────────────────┘
//     │ V-LLSI
//     ▼
// ┌─────────────────────────────────────────┐
// │          sys/linux/syscall.vr           │   ← Linux: direct syscalls
// │        sys/darwin/libsystem.vr          │   ← macOS: libSystem.B.dylib
// └─────────────────────────────────────────┘
//     │
//     ▼
// ┌─────────────────────────────────────────┐
// │              OS Kernel                   │
// └─────────────────────────────────────────┘
// ```
//
// # Key Features
//
// - Platform-specific syscall implementations (Linux/macOS)
// - FileDesc type for type-safe file descriptors
// - SO_REUSEPORT for multi-threaded accept scaling
// - MSG_NOSIGNAL/SO_NOSIGPIPE for SIGPIPE prevention
// - SOCK_CLOEXEC/SOCK_NONBLOCK for atomic socket creation (Linux)
// - Native async I/O via IOEngine (io_uring/kqueue)
// - Pure DNS resolver (RFC 1035) without libc getaddrinfo
//
// =============================================================================

module net;

// =============================================================================
// Submodules
// =============================================================================

public module addr;
public module tcp;
public module udp;
public module unix;
public module dns;
public module http;
public module tls;
public module tls13;    // Pure-Verum TLS 1.3 (RFC 8446) — will replace .tls after Phase 2+
public module h3;       // Pure-Verum HTTP/3 (RFC 9114) + QPACK (RFC 9204)
public module url;
public module http_parser;
public module shutdown;
public module websocket;
public module http2;
public module quic;
public module http3;
public module content_negotiation;
public module http_range;
public module link_header;
public module http_cache;
public module uri_template;
public module ipv6_canonical;
public module cidr;

