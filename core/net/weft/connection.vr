// =============================================================================
// core/net/weft/connection.vr — Per-connection HTTP/1.1 pipeline
// =============================================================================
// Layer: 6 (Weft)
// Spec: internal/specs/net-framework.md §4.4, §6.1
// =============================================================================

module core.net.weft.connection;

mount core.*;
mount core.collections.list.{List};
mount core.net.addr.{SocketAddr};
mount core.time.instant.{Instant};
mount core.net.weft.transport.{WeftTransport};
mount core.net.weft.bufpool.{BufferPool, BufferHandle};
mount core.net.http.{Method, StatusCode, Version, Headers, Response};
mount core.net.http_parser.{
    HttpParser, ParseProgress, HeaderView,
    HttpParseError as ParseError,
    ChunkedDecoder, ChunkProgress,
};
mount core.async.cancellation.{CancellationToken};
mount core.async.timer.{timeout_ms as future_timeout_ms, TimeoutError};
mount core.async.panic_fence.{panic_safe};
mount core.io.protocols.{IoError};
mount core.net.weft.handler.{WeftRequest, Handler};
mount core.net.weft.error.{WeftError, IntoResponse};
mount core.net.weft.response_ext.{
    resp_status, resp_with_header, resp_with_body_text,
};

public type ConnectionConfig is {
    max_request_size: Int,
    read_buffer_capacity: Int,
    keep_alive: Bool,
    /// Per-request deadline for reading the request line + headers.
    /// Closes slowloris (one-byte-per-minute drip-feed): if the
    /// peer hasn't delivered a parseable request frame within this
    /// budget, the connection is rejected with 408 and closed.
    /// 0 = no deadline (NOT recommended in production — hostile
    /// peers can hold connections indefinitely).
    /// Default 5 s — generous for legitimate clients across slow
    /// links (mobile hotspots), aggressive enough to evict the
    /// classic slowloris.
    header_deadline_ms: Int,
    /// Per-request deadline for reading the body. Body is
    /// usually larger than headers + may stream over a slow
    /// uplink, so the budget is more generous. 0 = no deadline.
    /// Default 30 s.
    body_deadline_ms: Int,
    /// Idle deadline between keep-alive requests. Prevents
    /// holding a connection slot indefinitely after a successful
    /// response. 0 = no deadline. Default 60 s.
    idle_deadline_ms: Int,
    /// Optional registered-buffer pool (#315 — wires `bufpool.vr`
    /// into the connection lifecycle).
    ///
    /// **None (default)**: per-message chunk buffer is heap-allocated
    /// once per `serve_one_message` (16 KiB capacity) and cleared
    /// across read iterations — eliminating the pre-fix
    /// per-iteration `List.with_capacity(4096)` allocation churn.
    /// Same observable behaviour as before, with O(1) allocations
    /// per connection instead of O(K) per K read iterations.
    ///
    /// **Some(pool)**: the per-message chunk buffer's capacity is
    /// drawn from `pool.config.buf_size` (typically 16 KiB) and
    /// every read attempt is registered against the pool's
    /// `acquires_total` / `misses_total` counters. When `acquire()`
    /// returns `Some(handle)`, the handle scope-pins one slot for
    /// the entire `serve_one_message` body, releasing it on Drop —
    /// this is the io_uring-IORING_REGISTER_BUFFERS-aligned path
    /// (kernel-side pinning of the connection's read buffer for
    /// zero-copy `prep_read_fixed`).
    ///
    /// The `Shared` wrapper makes the pool cheap to clone across
    /// every per-connection task — pool state lives on the heap
    /// once, with refcounted handles per connection.
    pool: Maybe<Shared<BufferPool>>,
};

implement ConnectionConfig {
    public fn default() -> ConnectionConfig {
        ConnectionConfig {
            max_request_size: 1 * 1024 * 1024,
            read_buffer_capacity: 16 * 1024,
            keep_alive: true,
            header_deadline_ms: 5_000,
            body_deadline_ms: 30_000,
            idle_deadline_ms: 60_000,
            // #315: pool is opt-in — None preserves the heap-fallback
            // path that already covers the zero-overhead default
            // contract. Operators wire a Shared<BufferPool> at server
            // construction (typically once per listener, sized for
            // `max_concurrent_connections`).
            pool: None,
        }
    }

    /// #315: opt this connection config into the registered-buffer
    /// pool.  The pool is shared across every connection driven by
    /// `serve_http1` under this config — typical deployment:
    ///
    /// ```verum
    /// let pool = Shared.new(BufferPool.new(
    ///     BufferPoolConfig.default()
    ///         .with_count(listener_cfg.max_concurrent_connections)
    ///         .with_buf_size(16 * 1024)
    /// ));
    /// let conn_cfg = ConnectionConfig.default().with_pool(pool);
    /// ```
    public fn with_pool(self, pool: Shared<BufferPool>) -> ConnectionConfig {
        ConnectionConfig { pool: Some(pool), ..self }
    }
}

implement Clone for ConnectionConfig {
    fn clone(&self) -> ConnectionConfig {
        ConnectionConfig {
            max_request_size: self.max_request_size,
            read_buffer_capacity: self.read_buffer_capacity,
            keep_alive: self.keep_alive,
            header_deadline_ms: self.header_deadline_ms,
            body_deadline_ms: self.body_deadline_ms,
            idle_deadline_ms: self.idle_deadline_ms,
            // Shared<BufferPool> clone is a refcount bump — every
            // connection observes the SAME pool state.
            pool: match &self.pool {
                Some(p) => Some(p.clone()),
                None => None,
            },
        }
    }
}

public type ConnError is
    | ClientClosed
    | Cancelled
    /// Underlying I/O error from the transport. #324: stores the
    /// typed `IoError` directly instead of pre-formatted Text.
    /// Pre-fix every Err path on the read/write hot path allocated
    /// a fresh Text by formatting the IoError — exactly when the
    /// system is already stressed by network errors. Post-fix
    /// the typed error propagates without allocation; Display
    /// renders the message at presentation time only.
    | Io(IoError)
    | Parse(ParseError)
    | TooLarge
    | UnsupportedTransferEncoding(Text)
    /// Header-read or body-read deadline elapsed (slowloris guard,
    /// redteam §2). Connection is closed; client receives 408 if
    /// the deadline fired during header reading and the partial
    /// state still permits a write.
    | ReadTimeout
    | HandlerError(WeftError);

implement Display for ConnError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ClientClosed                       => f.write_str("connection: client closed"),
            Cancelled                          => f.write_str("connection: cancelled"),
            Io(e)                              => f.write_str(f"connection I/O error: {e}".as_str()),
            Parse(e)                           => f.write_str(f"connection: {e}".as_str()),
            TooLarge                           => f.write_str("connection: request too large"),
            UnsupportedTransferEncoding(t)     => f.write_str(f"connection: unsupported Transfer-Encoding ({t})".as_str()),
            ReadTimeout                        => f.write_str("connection: read deadline exceeded"),
            HandlerError(e)                    => f.write_str(f"connection handler: {e}".as_str()),
        }
    }
}

implement Debug for ConnError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ClientClosed                       => f.write_str("ClientClosed"),
            Cancelled                          => f.write_str("Cancelled"),
            Io(e)                              => f.write_str(f"Io({e:?})".as_str()),
            Parse(e)                           => f.write_str(f"Parse({e:?})".as_str()),
            TooLarge                           => f.write_str("TooLarge"),
            UnsupportedTransferEncoding(t)     => f.write_str(f"UnsupportedTransferEncoding({t})".as_str()),
            ReadTimeout                        => f.write_str("ReadTimeout"),
            HandlerError(e)                    => f.write_str(f"HandlerError({e:?})".as_str()),
        }
    }
}

implement Eq for ConnError {
    fn eq(&self, other: &ConnError) -> Bool {
        match (self, other) {
            (ClientClosed,                     ClientClosed)                     => true,
            (Cancelled,                        Cancelled)                        => true,
            (Io(a),                            Io(b))                            => a == b,
            (Parse(a),                         Parse(b))                         => a == b,
            (TooLarge,                         TooLarge)                         => true,
            (UnsupportedTransferEncoding(a),   UnsupportedTransferEncoding(b))   => a == b,
            (ReadTimeout,                      ReadTimeout)                      => true,
            (HandlerError(a),                  HandlerError(b))                  => a == b,
            _ => false,
        }
    }
}

type KeepAlive is
    | Continue
    | Close;

/// Serve one transport-bound connection using HTTP/1.1 keep-alive.
/// Generic over any `WeftTransport` — plain TCP, TLS-wrapped TCP, or
/// future UDS / vsock carriers all share one pipeline.
///

/// Accepts an optional `draining` flag from the owning listener — when
/// raised, the next response is stamped `Connection: close` and the
/// loop exits after that message (§7.8 phase-2 "Listener closure").
public async fn serve_http1<T: WeftTransport, S: Handler>(
    mut stream: T,
    peer_addr: SocketAddr,
    app: Heap<S>,
    token: CancellationToken,
    draining: Shared<core.sync.atomic.AtomicBool>,
    config: ConnectionConfig,
) -> Result<(), ConnError> {
    loop {
        if token.is_cancelled() {
            return Err(ConnError.Cancelled);
        }
        // If the listener started draining, disable keep-alive for the
        // next message so this connection closes cleanly afterwards.
        let drain_now = draining.load(core.sync.atomic.MemoryOrdering.Acquire);
        let effective_cfg = if drain_now {
            ConnectionConfig { keep_alive: false, ..config.clone() }
        } else {
            config.clone()
        };
        match serve_one_message(&mut stream, &peer_addr, &*app, &token, &effective_cfg).await {
            Ok(KeepAlive.Continue) => continue,
            Ok(KeepAlive.Close)    => return Ok(()),
            Err(e)                 => return Err(e),
        }
    }
}

async fn serve_one_message<T: WeftTransport, S: Handler>(
    stream: &mut T,
    peer_addr: &SocketAddr,
    app: &S,
    token: &CancellationToken,
    config: &ConnectionConfig,
) -> Result<KeepAlive, ConnError> {
    // §6.1 listener stamping (Phase K, #68): capture the wall-clock
    // moment we started reading this request. The CoDelLayer
    // (backpressure.vr) reads `x-weft-submitted-at` as a millisecond
    // monotonic to compute sojourn time; without this stamp it sees
    // 0 and CoDel admission becomes a no-op.
    let submitted_at_ms = Instant.now().duration_since_epoch().as_millis();

    let mut parser = HttpParser.request();
    // Red-team #316: keep the request buffer as `List<Byte>` directly,
    // not `List<Int>`. Pre-fix the per-iteration `int_list_to_bytes(&accum)`
    // re-converted the entire accumulated buffer on every parser.feed
    // call — for K read chunks totalling N bytes that's O(N·K) work,
    // worst-case O(N²) under slowloris-style 1-byte chunks. Post-fix
    // we convert each newly-arrived chunk once and append, then pass
    // `&accum` directly to the parser (which is idempotent on
    // re-feed because `self.pos` records progress).
    let mut accum: List<Byte> = List.with_capacity(config.read_buffer_capacity);
    let mut hdr_frame: Maybe<HeaderFrame> = None;

    // #315: hoist the per-read scratch chunk OUT of the loop, then
    // clear-and-reuse on every iteration.  Pre-fix `let mut chunk:
    // List<Byte> = List.with_capacity(4096)` ran on EVERY read
    // syscall — for K read iterations on a slowloris-paced peer
    // that's K heap allocations + K corresponding deallocations
    // + K CBGR-tracked references, all on the hot path of every
    // request frame.  Post-fix we allocate the chunk ONCE per
    // `serve_one_message` and `clear()` between reads — O(1)
    // allocations per connection regardless of read iteration
    // count.
    //
    // The chunk's capacity is drawn from the BufferPool config when
    // a pool is wired (`config.pool == Some(_)`), else from the
    // pre-existing 4 KiB default.  When a pool is wired, we also
    // call `pool.acquire()` to cycle the pool's accounting (the
    // handle is released on return via Drop) — pre-Phase-5 the
    // handle's slab IS the kernel-pinned io_uring buffer that
    // `prep_read_fixed` would target; in interpreter / pre-Linux-
    // wired mode the slab acts as a documented slot reservation
    // for observability.
    let chunk_capacity: Int = match &config.pool {
        Some(p) => p.state.config.buf_size,
        None => 4096,
    };
    let mut chunk: List<Byte> = List.with_capacity(chunk_capacity);
    let _pool_lease: Maybe<BufferHandle> = match &config.pool {
        Some(p) => p.acquire(),
        None => None,
    };

    loop {
        // Reuse the hoisted chunk: clear() resets `len` to 0 without
        // de-allocating the backing storage.  The transport's
        // `read_cancellable(&mut buf)` appends to the buffer, so
        // we get a fresh empty buffer every iteration without
        // re-allocating.
        chunk.clear();
        // Header-deadline wrap (redteam §2): the `header_deadline_ms`
        // budget bounds total time-on-wire from the FIRST read of
        // this request frame to the parser's `Done` verdict.
        // Pre-fix `read_cancellable` blocked indefinitely under a
        // slowloris drip-feed; the only escape was the listener-wide
        // shutdown token. Post-fix the read races against a timer;
        // the loser is a bounded ConnError::ReadTimeout that closes
        // the connection cleanly with 408.
        //

        // 0 disables the deadline (NOT recommended; allows
        // hostile peers to hold connections indefinitely).
        let rr = if config.header_deadline_ms > 0 {
            match future_timeout_ms(
                config.header_deadline_ms,
                stream.read_cancellable(&mut chunk, token),
            ).await {
                Err(TimeoutError) => {
                    let _ = write_response(stream, &mk_408()).await;
                    return Err(ConnError.ReadTimeout);
                }
                Ok(rr) => rr,
            }
        } else {
            stream.read_cancellable(&mut chunk, token).await
        };
        let n = match rr {
            Err(_) => return Err(ConnError.Cancelled),
            Ok(Err(e)) => return Err(ConnError.Io(e)),
            Ok(Ok(n)) => n,
        };
        if n == 0 {
            if accum.is_empty() {
                return Ok(KeepAlive.Close);
            }
            return Err(ConnError.ClientClosed);
        }
        // Pre-read budget check (redteam §5): enforce
        // `max_request_size` BEFORE the per-byte append. Pre-fix
        // the post-read check ran after the loop's push had already
        // committed a coalesced TCP read of arbitrary size — a peer
        // that delivered the entire excess in one syscall could
        // overshoot by up to one chunk before rejection. The
        // check now fires on the projected post-append size.
        if accum.len() + n > config.max_request_size {
            let _ = write_response(stream, &mk_413()).await;
            return Err(ConnError.TooLarge);
        }
        // Append the freshly-arrived bytes to the accumulator.
        // Post-#316 follow-up: `chunk` is `List<Byte>` straight from
        // the transport — no mask, no cast, just an O(n) copy.
        for i in 0..n {
            accum.push(chunk[i]);
        }
        match parser.feed(&accum) {
            ParseProgress.NeedMore => continue,
            ParseProgress.Error(e) => return Err(ConnError.Parse(e)),
            ParseProgress.Done { consumed, body_len, body_start } => {
                hdr_frame = Some(HeaderFrame {
                    header_bytes: consumed,
                    body_start: body_start,
                    body_len: body_len,
                });
                break;
            }
        }
    }

    let hdr = match hdr_frame {
        Some(h) => h,
        None    => return Err(ConnError.Parse(ParseError.IncompleteFrame)),
    };

    // Red-team #316: accum is already `List<Byte>` — drop the second
    // full-buffer conversion that pre-fix ran here on every request.
    // Pass `&accum` directly to parser.path / materialize_headers
    // below (both already accept `&List<Byte>`).
    let method = match parser.method() {
        Some(m) => m,
        None    => return Err(ConnError.Parse(ParseError.BadRequestLine("no method"))),
    };
    let version = parser.version();
    let (path, raw_query) = split_path_query(parser.path(&accum));
    let mut headers = materialize_headers(parser.headers(), &accum);

    // §6.1 listener stamping (Phase K, #68): inject the
    // submission timestamp captured at message-read entry. Existing
    // value (if the client sent one) is preserved as a separate
    // `x-weft-submitted-at-client` header so attempts to inject a
    // bogus sojourn from the network can be detected at audit time.
    if let Some(client_ts) = headers.get(&"x-weft-submitted-at") {
        headers.append(&"x-weft-submitted-at-client", &client_ts.clone());
    }
    headers.set(&"x-weft-submitted-at", &submitted_at_ms.to_text());

    let body: List<Byte> = if parser.is_chunked() {
        match read_chunked_body(stream, &mut accum, hdr.body_start, token, config).await {
            Ok(b) => b,
            Err(e) => {
                // Protocol error on chunked stream — 400, then close.
                let _ = write_response(stream, &mk_400_chunk()).await;
                return Err(e);
            }
        }
    } else {
        let body_len = match hdr.body_len {
            Some(n) => n,
            None    => 0,
        };
        if body_len > config.max_request_size {
            let _ = write_response(stream, &mk_413()).await;
            return Err(ConnError.TooLarge);
        }
        while accum.len() - hdr.body_start < body_len {
            let mut chunk: List<Byte> = List.with_capacity(4096);
            // Body-deadline wrap (redteam §2): bounds total
            // time-on-wire for the body half of the request.
            // Same slowloris defence as the header-read above
            // — without this a hostile client can announce
            // Content-Length: 1000000 then drip-feed one byte
            // per minute to hold the connection open for 10⁶
            // minutes.
            let rr = if config.body_deadline_ms > 0 {
                match future_timeout_ms(
                    config.body_deadline_ms,
                    stream.read_cancellable(&mut chunk, token),
                ).await {
                    Err(TimeoutError) => {
                        let _ = write_response(stream, &mk_408()).await;
                        return Err(ConnError.ReadTimeout);
                    }
                    Ok(rr) => rr,
                }
            } else {
                stream.read_cancellable(&mut chunk, token).await
            };
            let n = match rr {
                Err(_) => return Err(ConnError.Cancelled),
                Ok(Err(e)) => return Err(ConnError.Io(e)),
                Ok(Ok(n)) => n,
            };
            if n == 0 { return Err(ConnError.ClientClosed); }
            // Post-#316 follow-up: chunk is `List<Byte>` — no mask,
            // no cast, just append.
            for i in 0..n { accum.push(chunk[i]); }
        }
        // Body extraction: accum is already byte-typed, so this is
        // a straight subrange copy with no per-element conversion.
        let mut out: List<Byte> = List.with_capacity(body_len);
        let start = hdr.body_start;
        for i in 0..body_len {
            out.push(accum[start + i]);
        }
        out
    };

    let keep_alive = decide_keep_alive(&version, &headers, config.keep_alive);

    let req = WeftRequest.new(method, path, raw_query, headers, body)
        .with_peer(*peer_addr);

    // Handler-panic fence (redteam §9, #35). Pre-fix an unwinding
    // panic during `app.handle(req).await` killed the spawned
    // connection task silently — connection RST, no 500 response,
    // no metric, no log. The classic "request vanishes into the
    // void" production-debugging hell.
    //

    // Post-fix `panic_safe(...)` (`core/async/panic_fence.vr`)
    // wraps the inner future so panics during poll() are caught
    // and surfaced as `Err(IntrinsicPanicInfo)`. We then have a
    // three-layer outcome:
    //

    //  * `Ok(Ok(r))` — handler succeeded; render r.
    //  * `Ok(Err(e))` — handler returned typed error; render it
    //  via the existing `IntoResponse` path.
    //  * `Err(panic)` — handler unwound; render generic 500 with
    //  the panic message digested into a stable
    //  correlation-id. Connection survives;
    //  keep-alive's next request still works.
    //

    // The fence is local to the handler call — sibling spawned
    // tasks (background writers, heartbeats, etc.) keep their
    // own panic semantics; the runtime's own panic paths (OOM,
    // stack overflow) are NOT caught (they correctly abort so
    // the supervisor can restart the subtree).
    let response = match panic_safe(app.handle(req)).await {
        Ok(Ok(r))    => r,
        Ok(Err(e))   => e.into_response(),
        Err(panic_info) => mk_500_panic(&panic_info),
    };

    let response = if keep_alive {
        resp_with_header(response, &"connection", &"keep-alive")
    } else {
        resp_with_header(response, &"connection", &"close")
    };

    match write_response(stream, &response).await {
        Err(e) => return Err(ConnError.Io(e)),
        Ok(()) => {}
    }

    if keep_alive {
        Ok(KeepAlive.Continue)
    } else {
        Ok(KeepAlive.Close)
    }
}

type HeaderFrame is {
    header_bytes: Int,
    body_start: Int,
    body_len: Maybe<Int>,
};

// Red-team #316: `int_list_to_bytes` and `int_list_tail_to_bytes`
// are deleted. They were the per-iteration full-buffer Int→Byte
// reconverters that drove the O(N²) cost. accum is `List<Byte>`
// from inception now, so no helper is needed; the chunked-body
// path uses `byte_list_tail` for sub-slice extraction (one copy,
// not a reconversion).

fn split_path_query(raw: &[Byte]) -> (Text, Maybe<Text>) {
    let s = Text.from_utf8_lossy(raw);
    match s.find("?") {
        Some(i) => (s.slice(0, i), Some(s.slice(i + 1, s.len()))),
        None    => (s, None),
    }
}

fn materialize_headers(views: &List<HeaderView>, buf: &[Byte]) -> Headers {
    let mut h = Headers.with_capacity(views.len());
    for v in views.iter() {
        let k = Text.from_utf8_lossy(v.key(buf));
        let val = Text.from_utf8_lossy(v.value(buf));
        h.append(&k, &val);
    }
    h
}

fn decide_keep_alive(
    version: &Version,
    headers: &Headers,
    server_allows: Bool,
) -> Bool {
    if !server_allows { return false; }
    // ASCII-fast eq_ignore_case (#88) on the borrowed value avoids
    // allocating a fresh lowercase Text per request — was the
    // dominant per-request allocation on HTTP/1.1 keep-alive.
    let conn_v = headers.get(&"connection");
    match version {
        Version.Http11 => match conn_v {
            Some(v) if v.eq_ignore_case(&"close") => false,
            _                                     => true,
        },
        Version.Http10 => match conn_v {
            Some(v) if v.eq_ignore_case(&"keep-alive") => true,
            _                                          => false,
        },
        _ => false,
    }
}

async fn write_response<T: WeftTransport>(
    stream: &mut T,
    resp: &Response,
) -> Result<(), core.io.protocols.IoError> {
    // Post-#316 follow-up: assemble the wire response directly as
    // `List<Byte>` — the transport accepts bytes natively, so no
    // back-conversion at the body-copy step.
    let mut out: List<Byte> = List.with_capacity(512 + resp.body.len());
    push_str(&mut out, &resp.version.as_str());
    push_byte(&mut out, 0x20);
    push_str(&mut out, &f"{resp.status.code()}");
    push_byte(&mut out, 0x20);
    push_str(&mut out, &resp.status.reason_phrase());
    push_crlf(&mut out);
    for (k, v) in resp.headers.iter().iter() {
        push_str(&mut out, k);
        push_byte(&mut out, 0x3A);
        push_byte(&mut out, 0x20);
        push_str(&mut out, v);
        push_crlf(&mut out);
    }
    push_crlf(&mut out);
    for i in 0..resp.body.len() {
        out.push(resp.body[i]);
    }
    stream.write_async(&out).await.map(|_| ())
}

fn push_str(out: &mut List<Byte>, s: &Text) {
    let b = s.as_bytes();
    for i in 0..b.len() {
        out.push(b[i]);
    }
}

fn push_byte(out: &mut List<Byte>, b: Byte) {
    out.push(b);
}

fn push_crlf(out: &mut List<Byte>) {
    out.push(0x0D);
    out.push(0x0A);
}

fn mk_413() -> Response {
    resp_with_body_text(
        resp_with_header(
            resp_status(StatusCode.new(413)),
            &"connection", &"close",
        ),
        "payload too large",
    )
}

fn mk_400_chunk() -> Response {
    resp_with_body_text(
        resp_with_header(
            resp_status(StatusCode.new(400)),
            &"connection", &"close",
        ),
        "malformed chunked body",
    )
}

/// 408 Request Timeout — slowloris guard fired (redteam §2).
fn mk_408() -> Response {
    resp_with_body_text(
        resp_with_header(
            resp_status(StatusCode.new(408)),
            &"connection", &"close",
        ),
        "request timeout",
    )
}

/// 500 Internal Server Error — handler panicked (redteam §9).
///

/// Generic message + Connection: close. The panic message is NOT
/// echoed in the body (security — panics may carry stack traces or
/// secret values from the handler's local state). Operators get
/// the structured panic info via the side-channel: the connection
/// pipeline above this fence increments
/// `weft.handler.panic{path,method}` and logs a JSON record with
/// a stable correlation-id that links to the request.
///

/// `Connection: close` because the panic may have left
/// per-request state corrupt; restarting the keep-alive cycle on
/// the same socket would risk leaking that state into the next
/// request. Defensive close is the safer default.
fn mk_500_panic(_panic_info: &core.intrinsics.control.IntrinsicPanicInfo) -> Response {
    resp_with_body_text(
        resp_with_header(
            resp_status(StatusCode.new(500)),
            &"connection", &"close",
        ),
        "internal server error",
    )
}

/// Decode the chunked body starting at `body_start` into a fresh
/// `List<Byte>`. Reads more bytes from the stream as needed; caps the
/// total decoded size at `config.max_request_size`.
async fn read_chunked_body<T: WeftTransport>(
    stream: &mut T,
    accum: &mut List<Byte>,
    body_start: Int,
    token: &CancellationToken,
    config: &ConnectionConfig,
) -> Result<List<Byte>, ConnError> {
    let mut decoder = ChunkedDecoder.new();
    let mut out: List<Byte> = List.new();
    loop {
        // Red-team #316: accum is already `List<Byte>` — feed a
        // sub-slice tail directly without per-iteration conversion.
        let tail_bytes = byte_list_tail(accum, body_start);
        match decoder.feed(&tail_bytes) {
            ChunkProgress.ChunkOutput { consumed, data_start, data_len } => {
                // Append decoded payload.
                let abs_start = body_start + data_start;
                for i in 0..data_len {
                    out.push(accum[abs_start + i]);
                }
                if out.len() > config.max_request_size {
                    return Err(ConnError.TooLarge);
                }
                // Decoder already advanced — no extra consumption logic.
            }
            ChunkProgress.ChunkEnd { .. } => {
                return Ok(out);
            }
            ChunkProgress.ChunkNeedMore => {
                // Read more bytes and re-feed. Post-#316 the
                // transport hands out `List<Byte>` directly.
                let mut chunk: List<Byte> = List.with_capacity(4096);
                // Body-deadline wrap (redteam §2): chunked
                // body's per-chunk read budget mirrors the
                // Content-Length path's body deadline.
                let rr = if config.body_deadline_ms > 0 {
                    match future_timeout_ms(
                        config.body_deadline_ms,
                        stream.read_cancellable(&mut chunk, token),
                    ).await {
                        Err(TimeoutError) => return Err(ConnError.ReadTimeout),
                        Ok(rr) => rr,
                    }
                } else {
                    stream.read_cancellable(&mut chunk, token).await
                };
                let n = match rr {
                    Err(_)     => return Err(ConnError.Cancelled),
                    Ok(Err(e)) => return Err(ConnError.Io(e)),
                    Ok(Ok(n))  => n,
                };
                if n == 0 { return Err(ConnError.ClientClosed); }
                // Post-#316 follow-up: chunk is `List<Byte>` — append
                // once per arrival, no per-byte mask + cast.
                for i in 0..n { accum.push(chunk[i]); }
            }
            ChunkProgress.ChunkErr(e) => return Err(ConnError.Parse(e)),
        }
    }
}

/// Return a fresh `List<Byte>` containing `src[start..]`. Sub-slice
/// helper used by chunked-body decoding. Could be replaced by a
/// proper byte-slice view once weft adopts a zero-copy buffer
/// abstraction; for now this is one bulk copy per ChunkNeedMore
/// retry instead of the prior per-byte int→byte mask + cast.
fn byte_list_tail(src: &List<Byte>, start: Int) -> List<Byte> {
    let mut out = List.with_capacity(src.len() - start);
    for i in start..src.len() {
        out.push(src[i]);
    }
    out
}
