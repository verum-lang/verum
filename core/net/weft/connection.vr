// =============================================================================
// core/net/weft/connection.vr — Per-connection HTTP/1.1 pipeline
// =============================================================================
// Layer: 6 (Weft)
// Spec:  internal/specs/net-framework.md §4.4, §6.1
// =============================================================================

module core.net.weft.connection;

mount core.*;
mount core.collections.list.{List};
mount core.net.addr.{SocketAddr};
mount core.time.instant.{Instant};
mount core.net.weft.transport.{WeftTransport};
mount core.net.http.{Method, StatusCode, Version, Headers, Response};
mount core.net.http_parser.{
    HttpParser, ParseProgress, HeaderView,
    HttpParseError as ParseError,
    ChunkedDecoder, ChunkProgress,
};
mount core.async.cancellation.{CancellationToken};
mount core.net.weft.handler.{WeftRequest, Handler};
mount core.net.weft.error.{WeftError, IntoResponse};
mount core.net.weft.response_ext.{
    resp_status, resp_with_header, resp_with_body_text,
};

public type ConnectionConfig is {
    max_request_size: Int,
    read_buffer_capacity: Int,
    keep_alive: Bool,
};

implement ConnectionConfig {
    public fn default() -> ConnectionConfig {
        ConnectionConfig {
            max_request_size: 1 * 1024 * 1024,
            read_buffer_capacity: 16 * 1024,
            keep_alive: true,
        }
    }
}

implement Clone for ConnectionConfig {
    fn clone(&self) -> ConnectionConfig {
        ConnectionConfig {
            max_request_size: self.max_request_size,
            read_buffer_capacity: self.read_buffer_capacity,
            keep_alive: self.keep_alive,
        }
    }
}

public type ConnError is
    | ClientClosed
    | Cancelled
    | Io(Text)
    | Parse(ParseError)
    | TooLarge
    | UnsupportedTransferEncoding(Text)
    | HandlerError(WeftError);

implement Display for ConnError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ClientClosed                       => f.write_str("connection: client closed"),
            Cancelled                          => f.write_str("connection: cancelled"),
            Io(reason)                         => f.write_str(f"connection I/O error: {reason}".as_str()),
            Parse(e)                           => f.write_str(f"connection: {e}".as_str()),
            TooLarge                           => f.write_str("connection: request too large"),
            UnsupportedTransferEncoding(t)     => f.write_str(f"connection: unsupported Transfer-Encoding ({t})".as_str()),
            HandlerError(e)                    => f.write_str(f"connection handler: {e}".as_str()),
        }
    }
}

implement Debug for ConnError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            ClientClosed                       => f.write_str("ClientClosed"),
            Cancelled                          => f.write_str("Cancelled"),
            Io(reason)                         => f.write_str(f"Io({reason})".as_str()),
            Parse(e)                           => f.write_str(f"Parse({e:?})".as_str()),
            TooLarge                           => f.write_str("TooLarge"),
            UnsupportedTransferEncoding(t)     => f.write_str(f"UnsupportedTransferEncoding({t})".as_str()),
            HandlerError(e)                    => f.write_str(f"HandlerError({e:?})".as_str()),
        }
    }
}

implement Eq for ConnError {
    fn eq(&self, other: &ConnError) -> Bool {
        match (self, other) {
            (ClientClosed,                     ClientClosed)                     => true,
            (Cancelled,                        Cancelled)                        => true,
            (Io(a),                            Io(b))                            => a == b,
            (Parse(a),                         Parse(b))                         => a == b,
            (TooLarge,                         TooLarge)                         => true,
            (UnsupportedTransferEncoding(a),   UnsupportedTransferEncoding(b))   => a == b,
            (HandlerError(a),                  HandlerError(b))                  => a == b,
            _ => false,
        }
    }
}

type KeepAlive is
    | Continue
    | Close;

/// Serve one transport-bound connection using HTTP/1.1 keep-alive.
/// Generic over any `WeftTransport` — plain TCP, TLS-wrapped TCP, or
/// future UDS / vsock carriers all share one pipeline.
///
/// Accepts an optional `draining` flag from the owning listener — when
/// raised, the next response is stamped `Connection: close` and the
/// loop exits after that message (§7.8 phase-2 "Listener closure").
public async fn serve_http1<T: WeftTransport, S: Handler>(
    mut stream: T,
    peer_addr: SocketAddr,
    app: Heap<S>,
    token: CancellationToken,
    draining: Shared<core.sync.atomic.AtomicBool>,
    config: ConnectionConfig,
) -> Result<(), ConnError> {
    loop {
        if token.is_cancelled() {
            return Err(ConnError.Cancelled);
        }
        // If the listener started draining, disable keep-alive for the
        // next message so this connection closes cleanly afterwards.
        let drain_now = draining.load(core.sync.atomic.MemoryOrdering.Acquire);
        let effective_cfg = if drain_now {
            ConnectionConfig { keep_alive: false, ..config.clone() }
        } else {
            config.clone()
        };
        match serve_one_message(&mut stream, &peer_addr, &*app, &token, &effective_cfg).await {
            Ok(KeepAlive.Continue) => continue,
            Ok(KeepAlive.Close)    => return Ok(()),
            Err(e)                 => return Err(e),
        }
    }
}

async fn serve_one_message<T: WeftTransport, S: Handler>(
    stream: &mut T,
    peer_addr: &SocketAddr,
    app: &S,
    token: &CancellationToken,
    config: &ConnectionConfig,
) -> Result<KeepAlive, ConnError> {
    // §6.1 listener stamping (Phase K, #68): capture the wall-clock
    // moment we started reading this request. The CoDelLayer
    // (backpressure.vr) reads `x-weft-submitted-at` as a millisecond
    // monotonic to compute sojourn time; without this stamp it sees
    // 0 and CoDel admission becomes a no-op.
    let submitted_at_ms = Instant.now().duration_since_epoch().as_millis();

    let mut parser = HttpParser.request();
    let mut accum: List<Int> = List.with_capacity(config.read_buffer_capacity);
    let mut hdr_frame: Maybe<HeaderFrame> = None;

    loop {
        if accum.len() > config.max_request_size {
            let _ = write_response(stream, &mk_413()).await;
            return Err(ConnError.TooLarge);
        }
        let mut chunk: List<Int> = List.with_capacity(4096);
        let rr = stream.read_cancellable(&mut chunk, token).await;
        let n = match rr {
            Err(_) => return Err(ConnError.Cancelled),
            Ok(Err(e)) => return Err(ConnError.Io(f"{e}")),
            Ok(Ok(n)) => n,
        };
        if n == 0 {
            if accum.is_empty() {
                return Ok(KeepAlive.Close);
            }
            return Err(ConnError.ClientClosed);
        }
        for i in 0..n {
            accum.push(chunk[i]);
        }
        let bytes = int_list_to_bytes(&accum);
        match parser.feed(&bytes) {
            ParseProgress.NeedMore => continue,
            ParseProgress.Error(e) => return Err(ConnError.Parse(e)),
            ParseProgress.Done { consumed, body_len, body_start } => {
                hdr_frame = Some(HeaderFrame {
                    header_bytes: consumed,
                    body_start: body_start,
                    body_len: body_len,
                });
                break;
            }
        }
    }

    let hdr = match hdr_frame {
        Some(h) => h,
        None    => return Err(ConnError.Parse(ParseError.IncompleteFrame)),
    };

    let buf_bytes = int_list_to_bytes(&accum);
    let method = match parser.method() {
        Some(m) => m,
        None    => return Err(ConnError.Parse(ParseError.BadRequestLine("no method"))),
    };
    let version = parser.version();
    let (path, raw_query) = split_path_query(parser.path(&buf_bytes));
    let mut headers = materialize_headers(parser.headers(), &buf_bytes);

    // §6.1 listener stamping (Phase K, #68): inject the
    // submission timestamp captured at message-read entry. Existing
    // value (if the client sent one) is preserved as a separate
    // `x-weft-submitted-at-client` header so attempts to inject a
    // bogus sojourn from the network can be detected at audit time.
    if let Some(client_ts) = headers.get(&"x-weft-submitted-at") {
        headers.append(&"x-weft-submitted-at-client", &client_ts.clone());
    }
    headers.set(&"x-weft-submitted-at", &submitted_at_ms.to_text());

    let body: List<Byte> = if parser.is_chunked() {
        match read_chunked_body(stream, &mut accum, hdr.body_start, token, config).await {
            Ok(b) => b,
            Err(e) => {
                // Protocol error on chunked stream — 400, then close.
                let _ = write_response(stream, &mk_400_chunk()).await;
                return Err(e);
            }
        }
    } else {
        let body_len = match hdr.body_len {
            Some(n) => n,
            None    => 0,
        };
        if body_len > config.max_request_size {
            let _ = write_response(stream, &mk_413()).await;
            return Err(ConnError.TooLarge);
        }
        while accum.len() - hdr.body_start < body_len {
            let mut chunk: List<Int> = List.with_capacity(4096);
            let rr = stream.read_cancellable(&mut chunk, token).await;
            let n = match rr {
                Err(_) => return Err(ConnError.Cancelled),
                Ok(Err(e)) => return Err(ConnError.Io(f"{e}")),
                Ok(Ok(n)) => n,
            };
            if n == 0 { return Err(ConnError.ClientClosed); }
            for i in 0..n { accum.push(chunk[i]); }
        }
        let mut out: List<Byte> = List.with_capacity(body_len);
        let start = hdr.body_start;
        for i in 0..body_len {
            out.push((accum[start + i] & 0xFF) as Byte);
        }
        out
    };

    let keep_alive = decide_keep_alive(&version, &headers, config.keep_alive);

    let req = WeftRequest.new(method, path, raw_query, headers, body)
        .with_peer(*peer_addr);

    let response = match app.handle(req).await {
        Ok(r)  => r,
        Err(e) => e.into_response(),
    };

    let response = if keep_alive {
        resp_with_header(response, &"connection", &"keep-alive")
    } else {
        resp_with_header(response, &"connection", &"close")
    };

    match write_response(stream, &response).await {
        Err(e) => return Err(ConnError.Io(f"{e}")),
        Ok(()) => {}
    }

    if keep_alive {
        Ok(KeepAlive.Continue)
    } else {
        Ok(KeepAlive.Close)
    }
}

type HeaderFrame is {
    header_bytes: Int,
    body_start: Int,
    body_len: Maybe<Int>,
};

fn int_list_to_bytes(src: &List<Int>) -> List<Byte> {
    let mut out = List.with_capacity(src.len());
    for i in 0..src.len() {
        out.push((src[i] & 0xFF) as Byte);
    }
    out
}

fn split_path_query(raw: &[Byte]) -> (Text, Maybe<Text>) {
    let s = Text.from_utf8_lossy(raw);
    match s.find("?") {
        Some(i) => (s.slice(0, i), Some(s.slice(i + 1, s.len()))),
        None    => (s, None),
    }
}

fn materialize_headers(views: &List<HeaderView>, buf: &[Byte]) -> Headers {
    let mut h = Headers.with_capacity(views.len());
    for v in views.iter() {
        let k = Text.from_utf8_lossy(v.key(buf));
        let val = Text.from_utf8_lossy(v.value(buf));
        h.append(&k, &val);
    }
    h
}

fn decide_keep_alive(
    version: &Version,
    headers: &Headers,
    server_allows: Bool,
) -> Bool {
    if !server_allows { return false; }
    // ASCII-fast eq_ignore_case (#88) on the borrowed value avoids
    // allocating a fresh lowercase Text per request — was the
    // dominant per-request allocation on HTTP/1.1 keep-alive.
    let conn_v = headers.get(&"connection");
    match version {
        Version.Http11 => match conn_v {
            Some(v) if v.eq_ignore_case(&"close") => false,
            _                                     => true,
        },
        Version.Http10 => match conn_v {
            Some(v) if v.eq_ignore_case(&"keep-alive") => true,
            _                                          => false,
        },
        _ => false,
    }
}

async fn write_response<T: WeftTransport>(
    stream: &mut T,
    resp: &Response,
) -> Result<(), core.io.protocols.IoError> {
    let mut out: List<Int> = List.with_capacity(512 + resp.body.len());
    push_str(&mut out, &resp.version.as_str());
    push_byte(&mut out, 0x20);
    push_str(&mut out, &f"{resp.status.code()}");
    push_byte(&mut out, 0x20);
    push_str(&mut out, &resp.status.reason_phrase());
    push_crlf(&mut out);
    for (k, v) in resp.headers.iter().iter() {
        push_str(&mut out, k);
        push_byte(&mut out, 0x3A);
        push_byte(&mut out, 0x20);
        push_str(&mut out, v);
        push_crlf(&mut out);
    }
    push_crlf(&mut out);
    for i in 0..resp.body.len() {
        out.push(resp.body[i] as Int);
    }
    stream.write_async(&out).await.map(|_| ())
}

fn push_str(out: &mut List<Int>, s: &Text) {
    let b = s.as_bytes();
    for i in 0..b.len() {
        out.push(b[i] as Int);
    }
}

fn push_byte(out: &mut List<Int>, b: Byte) {
    out.push(b as Int);
}

fn push_crlf(out: &mut List<Int>) {
    out.push(0x0D);
    out.push(0x0A);
}

fn mk_413() -> Response {
    resp_with_body_text(
        resp_with_header(
            resp_status(StatusCode.new(413)),
            &"connection", &"close",
        ),
        "payload too large",
    )
}

fn mk_400_chunk() -> Response {
    resp_with_body_text(
        resp_with_header(
            resp_status(StatusCode.new(400)),
            &"connection", &"close",
        ),
        "malformed chunked body",
    )
}

/// Decode the chunked body starting at `body_start` into a fresh
/// `List<Byte>`. Reads more bytes from the stream as needed; caps the
/// total decoded size at `config.max_request_size`.
async fn read_chunked_body<T: WeftTransport>(
    stream: &mut T,
    accum: &mut List<Int>,
    body_start: Int,
    token: &CancellationToken,
    config: &ConnectionConfig,
) -> Result<List<Byte>, ConnError> {
    let mut decoder = ChunkedDecoder.new();
    let mut out: List<Byte> = List.new();
    loop {
        // Feed everything we have after body_start into the decoder.
        let tail_bytes = int_list_tail_to_bytes(accum, body_start);
        match decoder.feed(&tail_bytes) {
            ChunkProgress.ChunkOutput { consumed, data_start, data_len } => {
                // Append decoded payload.
                let abs_start = body_start + data_start;
                for i in 0..data_len {
                    out.push((accum[abs_start + i] & 0xFF) as Byte);
                }
                if out.len() > config.max_request_size {
                    return Err(ConnError.TooLarge);
                }
                // Decoder already advanced — no extra consumption logic.
            }
            ChunkProgress.ChunkEnd { .. } => {
                return Ok(out);
            }
            ChunkProgress.ChunkNeedMore => {
                // Read more bytes and re-feed.
                let mut chunk: List<Int> = List.with_capacity(4096);
                let rr = stream.read_cancellable(&mut chunk, token).await;
                let n = match rr {
                    Err(_)     => return Err(ConnError.Cancelled),
                    Ok(Err(e)) => return Err(ConnError.Io(f"{e}")),
                    Ok(Ok(n))  => n,
                };
                if n == 0 { return Err(ConnError.ClientClosed); }
                for i in 0..n { accum.push(chunk[i]); }
            }
            ChunkProgress.ChunkErr(e) => return Err(ConnError.Parse(e)),
        }
    }
}

/// Same as `int_list_to_bytes` but skips the first `start` entries.
fn int_list_tail_to_bytes(src: &List<Int>, start: Int) -> List<Byte> {
    let mut out = List.with_capacity(src.len() - start);
    for i in start..src.len() {
        out.push((src[i] & 0xFF) as Byte);
    }
    out
}
