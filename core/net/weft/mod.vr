// =============================================================================
// core/net/weft/mod.vr — Weft public surface
// =============================================================================
// Layer: 6 (Weft — server framework core)
// Spec: internal/specs/net-framework.md §10
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.net.weft;

public mount self.transport.*;
public mount self.response_ext.*;
public mount self.service.*;
public mount self.error.*;
public mount self.handler.*;
public mount self.router.*;
public mount self.connection.*;
public mount self.listener.*;
public mount self.io_uring_accept.*;
public mount self.tls.*;
public mount self.http2.*;
public mount self.websocket.*;
public mount self.rpc.*;
public mount self.http3.*;
public mount self.arena_pool.*;
public mount self.bufpool.*;
public mount self.refined_routes.*;
public mount self.spiffe.*;
public mount self.dst.*;
public mount self.wasm_filter.*;
public mount self.app.*;
public mount self.backpressure.*;
public mount self.adaptive.*;
public mount self.timeout.*;
public mount self.tracing.*;
public mount self.metrics.*;
public mount self.health.*;

// The following 5 files shipped production code but had no
// `public mount` here. `mount core.net.weft.<X>.*;` worked via
// direct file lookup but the umbrella's wildcard re-export
// (`mount core.net.weft.*;`) silently skipped them — handlers
// using `Json<T>` had to import the extractor by full path despite
// the umbrella convention of "import core.net.weft.* and get
// everything". Adding the missing forwards completes the surface.
public mount self.h3.*;              // HTTP/3 server adapter
public mount self.h3_priority.*;     // RFC 9218 priority extractor
public mount self.json_extractor.*;  // Json<T> handler-arg extractor
public mount self.metrics_otlp.*;    // OTLP/HTTP push exporter
public mount self.zero_rtt_gate.*;   // 0-RTT replay-defence gate

// Convenience re-exports of the http surface that user code uniformly
// expects to be available via the weft umbrella (Response builder,
// StatusCode constants, Method enum) without needing a parallel
// `mount core.net.http.{Response, StatusCode}` next to every weft
// import.
public mount core.net.http.{Response, StatusCode, Method, Headers, Version};
