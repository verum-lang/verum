// =============================================================================
// core/net/weft/backpressure.vr â€” Concurrency / rate / load-shed layers
// =============================================================================
// Layer: 6 (Weft)
// Spec:  internal/specs/net-framework.md Â§5.5
// =============================================================================
//
// Three production-grade backpressure primitives, each implementable as a
// Weft `Layer` that wraps any Handler:
//
//   * `ConcurrencyLimitLayer` â€” hard cap on in-flight handler calls via
//     a `core.sync.Semaphore`. Excess calls short-circuit to
//     `WeftError.Overloaded` (â†’ 503). Critical for bounding memory /
//     goroutine-style leaks on upstream stalls.
//
//   * `RateLimitLayer` â€” token bucket. Allows `burst` requests
//     instantaneously, then refills at `rate` per second. Clients that
//     exceed their quota get `WeftError.Overloaded` immediately.
//
//   * `LoadShedLayer` â€” semantic wrapper that turns any
//     "currently-unavailable" signal from a downstream service into
//     `WeftError.Overloaded`. Used to keep the client-facing behaviour
//     consistent (always 503 with Retry-After) regardless of which
//     internal limiter tripped.
//
// All three surface the same WeftErrorCategory.Transient-classed failure so
// higher-level retry middleware can back off uniformly.
//
// =============================================================================

module core.net.weft.backpressure;

mount core.*;
mount core.sync.semaphore.{Semaphore};
mount core.sync.atomic.{AtomicInt, MemoryOrdering};
mount core.time.{Instant};
mount core.net.http.{Response};
mount core.net.weft.service.{Layer};
mount core.net.weft.handler.{WeftRequest, Handler};
mount core.net.weft.error.{WeftError};

// =============================================================================
// ConcurrencyLimitLayer
// =============================================================================

/// Hard cap on the number of simultaneous in-flight `handle` calls.
/// Implementation uses `Semaphore.try_acquire()` â€” non-blocking fail-fast;
/// queueing live requests is intentionally NOT supported (that's what
/// `RateLimitLayer` is for at the bucket, or Nursery backpressure on
/// the connection reader).
public type ConcurrencyLimitLayer is {
    permits: Shared<Semaphore>,
};

implement ConcurrencyLimitLayer {
    public fn new(max_in_flight: Int) -> ConcurrencyLimitLayer {
        ConcurrencyLimitLayer {
            permits: Shared.new(Semaphore.new(max_in_flight)),
        }
    }
}

implement<H: Handler> Layer<H> for ConcurrencyLimitLayer {
    type Wrapped = ConcurrencyLimitHandler<H>;
    fn wrap(&self, inner: H) -> ConcurrencyLimitHandler<H> {
        ConcurrencyLimitHandler {
            inner: inner,
            permits: self.permits.clone(),
        }
    }
}

public type ConcurrencyLimitHandler<H> is {
    inner: H,
    permits: Shared<Semaphore>,
};

implement<H: Handler> Handler for ConcurrencyLimitHandler<H> {
    async fn handle(&self, req: WeftRequest) -> Result<Response, WeftError> {
        if !self.permits.try_acquire() {
            return Err(WeftError.Overloaded);
        }
        let result = self.inner.handle(req).await;
        self.permits.release();
        result
    }
}

// =============================================================================
// RateLimitLayer â€” token bucket
// =============================================================================

/// Token-bucket rate limiter shared across all calls to the wrapped
/// handler. Tokens refill at `rate` per second up to `burst` capacity;
/// each `handle` consumes one token. Empty bucket â†’ `Overloaded`.
///
/// Thread-safe via atomic integer ops + a single shared `last_refill`
/// timestamp; no lock on the hot path.
public type RateLimitLayer is {
    state: Shared<TokenBucket>,
};

type TokenBucket is {
    /// Current tokens Ă— 1000 (sub-token precision).
    tokens_millis: AtomicInt,
    /// Burst Ă— 1000.
    capacity_millis: Int,
    /// Tokens added per millisecond Ă— 1000.
    refill_per_ms_millis: Int,
    /// Last refill time (monotonic ms).
    last_refill_ms: AtomicInt,
};

implement RateLimitLayer {
    /// Allow `rate` requests per second, with up to `burst` in a single
    /// instant. Typical: `RateLimitLayer.new(1000, 100)` â€” 1k rps sustained,
    /// 100-burst tolerated.
    public fn new(rate_per_sec: Int, burst: Int) -> RateLimitLayer {
        let now = monotonic_ms();
        // Internal unit is 1/1000 of a token so refills can be fractional.
        let refill_per_ms = rate_per_sec;                 // Ă— 1 ms = 1000 ms/s scaled / 1000
        RateLimitLayer {
            state: Shared.new(TokenBucket {
                tokens_millis: AtomicInt.new(burst * 1000),
                capacity_millis: burst * 1000,
                refill_per_ms_millis: refill_per_ms,
                last_refill_ms: AtomicInt.new(now),
            }),
        }
    }

    /// Non-blocking attempt to consume one token. Returns true on
    /// success, false if the bucket is empty.
    public fn try_consume(&self) -> Bool {
        let bucket = &*self.state;
        let now = monotonic_ms();
        let last = bucket.last_refill_ms.load(MemoryOrdering.Relaxed);
        let elapsed = now - last;
        if elapsed > 0 {
            let add = elapsed * bucket.refill_per_ms_millis;
            if bucket.last_refill_ms.compare_exchange(
                last, now,
                MemoryOrdering.AcqRel, MemoryOrdering.Relaxed,
            ).is_ok() {
                let cap = bucket.capacity_millis;
                let current = bucket.tokens_millis.load(MemoryOrdering.Acquire);
                let new_val = if current + add > cap { cap } else { current + add };
                bucket.tokens_millis.store(new_val, MemoryOrdering.Release);
            }
        }
        // Attempt to take 1000 token-millis = 1 whole token.
        let current = bucket.tokens_millis.load(MemoryOrdering.Acquire);
        if current < 1000 { return false; }
        bucket.tokens_millis.compare_exchange(
            current, current - 1000,
            MemoryOrdering.AcqRel, MemoryOrdering.Relaxed,
        ).is_ok()
    }
}

implement<H: Handler> Layer<H> for RateLimitLayer {
    type Wrapped = RateLimitHandler<H>;
    fn wrap(&self, inner: H) -> RateLimitHandler<H> {
        RateLimitHandler {
            inner: inner,
            layer: RateLimitLayer { state: self.state.clone() },
        }
    }
}

public type RateLimitHandler<H> is {
    inner: H,
    layer: RateLimitLayer,
};

implement<H: Handler> Handler for RateLimitHandler<H> {
    async fn handle(&self, req: WeftRequest) -> Result<Response, WeftError> {
        if !self.layer.try_consume() {
            return Err(WeftError.Overloaded);
        }
        self.inner.handle(req).await
    }
}

// =============================================================================
// LoadShedLayer â€” normalise "temporarily-unavailable" into 503
// =============================================================================

/// Wraps a Handler and, if its response status is 503 or the error is
/// `WeftError.Overloaded`, adds a `Retry-After` header to guide the
/// client's backoff. The default hint is 1 second; tune based on the
/// measured recovery time of the shed load.
///
/// Â§5.5 specifies priority-aware shedding via a `x-priority` header;
/// phase-1 implementation treats all requests equally â€” priority-aware
/// shedding is a dedicated phase-3 item once the header-classification
/// plumbing lands.
public type LoadShedLayer is {
    retry_after_seconds: Int,
};

implement LoadShedLayer {
    public fn default() -> LoadShedLayer {
        LoadShedLayer { retry_after_seconds: 1 }
    }

    public fn with_retry_after(seconds: Int) -> LoadShedLayer {
        LoadShedLayer { retry_after_seconds: seconds }
    }
}

implement<H: Handler> Layer<H> for LoadShedLayer {
    type Wrapped = LoadShedHandler<H>;
    fn wrap(&self, inner: H) -> LoadShedHandler<H> {
        LoadShedHandler {
            inner: inner,
            retry_after_seconds: self.retry_after_seconds,
        }
    }
}

public type LoadShedHandler<H> is {
    inner: H,
    retry_after_seconds: Int,
};

implement<H: Handler> Handler for LoadShedHandler<H> {
    async fn handle(&self, req: WeftRequest) -> Result<Response, WeftError> {
        let retry = f"{self.retry_after_seconds}";
        match self.inner.handle(req).await {
            Err(WeftError.Overloaded) => Err(WeftError.Overloaded),
            Err(e) => Err(e),
            Ok(r) => {
                if r.status.code() == 503 {
                    Ok(core.net.weft.response_ext.resp_with_header(
                        r, &"retry-after", &retry,
                    ))
                } else {
                    Ok(r)
                }
            }
        }
    }
}

// =============================================================================
// CoDel â€” Controlled-Delay sojourn-time admission (Â§5.5)
// =============================================================================
//
// CoDel (RFC 8289) tracks the *sojourn time* of work items in the
// queue â€” the wait between submission and dispatch. When the minimum
// sojourn observed over a sliding window exceeds `target_ms`, CoDel
// drops admission until sojourn returns below target. Drop schedule
// is sub-linear: drop at intervals `interval / sqrt(count)` so a
// long-saturated queue sheds aggressively while a brief spike sheds
// gently.
//
// Defaults match Linux fq_codel:
//   target_ms   = 5    (5 ms â€” humans don't notice tail latency below)
//   interval_ms = 100  (sliding window for the min-sojourn observation)

public type CoDelLayer is {
    target_ms:    Int,
    interval_ms:  Int,
    state:        Shared<CoDelState>,
};

type CoDelState is {
    min_sojourn_ms:    AtomicInt,
    interval_end_ms:   AtomicInt,
    drop_count:        AtomicInt,
    dropping:          Shared<core.sync.atomic.AtomicBool>,
    next_drop_at_ms:   AtomicInt,
};

implement CoDelLayer {
    public fn new() -> CoDelLayer {
        CoDelLayer.with_target_interval(5, 100)
    }

    public fn with_target_interval(target_ms: Int, interval_ms: Int) -> CoDelLayer {
        let now = monotonic_ms();
        CoDelLayer {
            target_ms:    target_ms,
            interval_ms:  interval_ms,
            state: Shared.new(CoDelState {
                min_sojourn_ms:  AtomicInt.new(0x7FFFFFFF),
                interval_end_ms: AtomicInt.new(now + interval_ms),
                drop_count:      AtomicInt.new(0),
                dropping:        Shared.new(core.sync.atomic.AtomicBool.new(false)),
                next_drop_at_ms: AtomicInt.new(0),
            }),
        }
    }

    /// Per-request decision. Returns `true` when the request MUST
    /// be dropped, `false` to proceed.
    public fn should_drop(&self, sojourn_ms: Int) -> Bool {
        let now = monotonic_ms();
        let s = &*self.state;

        // Update min-sojourn observed in the current window.
        let cur = s.min_sojourn_ms.load(MemoryOrdering.Acquire);
        if sojourn_ms < cur {
            s.min_sojourn_ms.store(sojourn_ms, MemoryOrdering.Release);
        }

        // Close the window if expired.
        let win_end = s.interval_end_ms.load(MemoryOrdering.Acquire);
        if now >= win_end {
            let min = s.min_sojourn_ms.swap(0x7FFFFFFF, MemoryOrdering.AcqRel);
            s.interval_end_ms.store(now + self.interval_ms, MemoryOrdering.Release);
            if min > self.target_ms {
                s.dropping.store(true, MemoryOrdering.Release);
            } else {
                s.dropping.store(false, MemoryOrdering.Release);
                s.drop_count.store(0, MemoryOrdering.Release);
            }
        }

        if !s.dropping.load(MemoryOrdering.Acquire) {
            return false;
        }
        let next = s.next_drop_at_ms.load(MemoryOrdering.Acquire);
        if now < next {
            return false;
        }
        let cnt = s.drop_count.fetch_add(1, MemoryOrdering.AcqRel) + 1;
        let gap = drop_interval_ms(self.interval_ms, cnt);
        s.next_drop_at_ms.store(now + gap, MemoryOrdering.Release);
        true
    }
}

/// `interval / sqrt(count)` â€” the canonical CoDel control law.
fn drop_interval_ms(interval_ms: Int, count: Int) -> Int {
    if count <= 1 { return interval_ms; }
    let mut s = count;
    let mut i: Int = 0;
    while i < 6 { s = (s + count / s) / 2; i = i + 1; }
    let g = interval_ms / s;
    if g < 1 { 1 } else { g }
}

public type CoDelHandler<H> is {
    inner: H,
    layer: CoDelLayer,
};

implement<H: Handler> Layer<H> for CoDelLayer {
    type Wrapped = CoDelHandler<H>;
    fn wrap(&self, inner: H) -> CoDelHandler<H> {
        CoDelHandler {
            inner: inner,
            layer: CoDelLayer {
                target_ms:   self.target_ms,
                interval_ms: self.interval_ms,
                state:       self.state.clone(),
            },
        }
    }
}

implement<H: Handler> Handler for CoDelHandler<H> {
    async fn handle(&self, req: WeftRequest) -> Result<Response, WeftError> {
        let sojourn_ms = match req.headers.get(&"x-weft-submitted-at") {
            Some(t) => {
                let now = monotonic_ms();
                match t.parse_int() {
                    Ok(submitted) => {
                        let s = now - submitted;
                        if s < 0 { 0 } else { s }
                    },
                    Err(_) => 0,
                }
            },
            None => 0,
        };
        if self.layer.should_drop(sojourn_ms) {
            return Err(WeftError.Overloaded);
        }
        self.inner.handle(req).await
    }
}

// =============================================================================
// WFQ â€” Weighted Fair Queueing across tenants (Â§5.5)
// =============================================================================
//
// Deficit-round-robin (DRR) variant â€” O(1) admission decision per
// request. Each tenant has a `deficit_us` counter; on each admission
// every tenant accrues `quantum_us * weight` micro-credits. Admission
// is allowed when `deficit_us >= cost_us`.
//
// Tenant identity is read from the `x-weft-tenant` header. Requests
// without a tenant land in the `_default` class (caller registers it
// as needed). `x-weft-cost-us` overrides the default request cost.

public type WfqLayer is {
    quantum_us:  Int,
    state:       Shared<WfqState>,
};

type WfqState is {
    tenants: Shared<core.collections.map.Map<Text, TenantSlot>>,
};

type TenantSlot is {
    weight:     Int,
    deficit_us: Shared<AtomicInt>,
};

implement WfqLayer {
    public fn new() -> WfqLayer {
        WfqLayer.with_quantum_us(1000)
    }

    public fn with_quantum_us(quantum_us: Int) -> WfqLayer {
        WfqLayer {
            quantum_us: quantum_us,
            state: Shared.new(WfqState {
                tenants: Shared.new(core.collections.map.Map.new()),
            }),
        }
    }

    /// Register / re-register a tenant with its weight. Existing
    /// deficit is preserved on a re-register so config changes don't
    /// reset the fairness ledger.
    public fn register_tenant(&self, name: Text, weight: Int) {
        let s = &*self.state;
        let mut tenants = s.tenants.lock();
        match tenants.get(&name) {
            Some(slot) => {
                let preserved = slot.deficit_us.clone();
                tenants.insert(name, TenantSlot {
                    weight:     weight,
                    deficit_us: preserved,
                });
            },
            None => {
                tenants.insert(name, TenantSlot {
                    weight:     weight,
                    deficit_us: Shared.new(AtomicInt.new(0)),
                });
            },
        }
    }

    /// Per-request admission gate.
    public fn admit(&self, tenant: &Text, cost_us: Int) -> Bool {
        let s = &*self.state;
        let tenants = s.tenants.lock();
        let slot = match tenants.get(tenant) {
            Some(t) => t,
            None => match tenants.get(&"_default") {
                Some(d) => d,
                None    => return true,    // no policy â†’ allow
            }
        };
        let credits = self.quantum_us * slot.weight;
        let new_deficit = slot.deficit_us.fetch_add(credits, MemoryOrdering.AcqRel)
            + credits;
        if new_deficit >= cost_us {
            slot.deficit_us.fetch_sub(cost_us, MemoryOrdering.AcqRel);
            true
        } else {
            false
        }
    }
}

public type WfqHandler<H> is {
    inner: H,
    layer: WfqLayer,
};

implement<H: Handler> Layer<H> for WfqLayer {
    type Wrapped = WfqHandler<H>;
    fn wrap(&self, inner: H) -> WfqHandler<H> {
        WfqHandler {
            inner: inner,
            layer: WfqLayer {
                quantum_us: self.quantum_us,
                state:      self.state.clone(),
            },
        }
    }
}

implement<H: Handler> Handler for WfqHandler<H> {
    async fn handle(&self, req: WeftRequest) -> Result<Response, WeftError> {
        let tenant = match req.headers.get(&"x-weft-tenant") {
            Some(t) => t.clone(),
            None    => Text.from_str("_default"),
        };
        let cost_us = match req.headers.get(&"x-weft-cost-us") {
            Some(t) => match t.parse_int() {
                Ok(n)  => n,
                Err(_) => self.layer.quantum_us,
            },
            None => self.layer.quantum_us,
        };
        if !self.layer.admit(&tenant, cost_us) {
            return Err(WeftError.Overloaded);
        }
        self.inner.handle(req).await
    }
}

// =============================================================================
// Monotonic clock helper
// =============================================================================

fn monotonic_ms() -> Int {
    Instant.now().duration_since_epoch().as_millis()
}
