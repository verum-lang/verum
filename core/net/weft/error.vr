// =============================================================================
// core/net/weft/error.vr — Error model for Weft
// =============================================================================
// Layer: 6 (Weft)
// Spec:  internal/specs/net-framework.md §5.6
// =============================================================================

module core.net.weft.error;

mount core.*;
mount core.net.http.{Response, StatusCode};
mount core.net.weft.response_ext.{
    resp_status, resp_ok, resp_text, resp_with_body_text,
};

/// Turn a value into an HTTP Response. Every `Service.Error` in Weft must
/// implement this so the framework can always send a reply, even for
/// errors the handler didn't anticipate.
public type IntoResponse is protocol {
    fn into_response(self) -> Response;
};

implement IntoResponse for Response {
    fn into_response(self) -> Response { self }
}

implement IntoResponse for StatusCode {
    fn into_response(self) -> Response { resp_status(self) }
}

implement IntoResponse for Text {
    fn into_response(self) -> Response { resp_text(self) }
}

implement IntoResponse for () {
    fn into_response(self) -> Response { resp_ok() }
}

/// High-level classification used by retry / circuit-breaker middleware
/// to decide whether to retry an error (§5.6).
public type WeftErrorCategory is
    | ErrTransient
    | ErrPermanent
    | ErrSecurity
    | ErrClient
    | ErrUpstream;

implement WeftErrorCategory {
    public fn default_status(&self) -> StatusCode {
        match self {
            ErrTransient => StatusCode.new(503),
            ErrPermanent => StatusCode.new(500),
            ErrSecurity  => StatusCode.new(403),
            ErrClient    => StatusCode.new(400),
            ErrUpstream  => StatusCode.new(502),
        }
    }

    public fn is_retryable(&self) -> Bool {
        match self {
            ErrTransient => true,
            ErrUpstream  => true,
            _         => false,
        }
    }
}

implement Eq for WeftErrorCategory {
    fn eq(&self, other: &WeftErrorCategory) -> Bool {
        match (self, other) {
            (ErrTransient, ErrTransient) => true,
            (ErrPermanent, ErrPermanent) => true,
            (ErrSecurity,  ErrSecurity)  => true,
            (ErrClient,    ErrClient)    => true,
            (ErrUpstream,  ErrUpstream)  => true,
            _                      => false,
        }
    }
}

implement Copy for WeftErrorCategory {}
implement Clone for WeftErrorCategory {
    fn clone(&self) -> WeftErrorCategory { *self }
}

/// Base error taxonomy for framework-internal failures.
public type WeftError is
    | BadRequest(Text)
    | RouteNotFound
    | MethodNotAllowed
    | ExtractionRejected(Text)
    | Timeout
    | Overloaded
    | UpstreamIo(Text)
    | Internal(Text);

implement Display for WeftError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            BadRequest(reason)         => f.write_str(f"weft: bad request ({reason})".as_str()),
            RouteNotFound              => f.write_str("weft: route not found"),
            MethodNotAllowed           => f.write_str("weft: method not allowed"),
            ExtractionRejected(reason) => f.write_str(f"weft: extraction rejected ({reason})".as_str()),
            Timeout                    => f.write_str("weft: request timeout"),
            Overloaded                 => f.write_str("weft: server overloaded"),
            UpstreamIo(reason)         => f.write_str(f"weft: upstream I/O error ({reason})".as_str()),
            Internal(reason)           => f.write_str(f"weft: internal error ({reason})".as_str()),
        }
    }
}

implement Debug for WeftError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            BadRequest(reason)         => f.write_str(f"BadRequest({reason})".as_str()),
            RouteNotFound              => f.write_str("RouteNotFound"),
            MethodNotAllowed           => f.write_str("MethodNotAllowed"),
            ExtractionRejected(reason) => f.write_str(f"ExtractionRejected({reason})".as_str()),
            Timeout                    => f.write_str("Timeout"),
            Overloaded                 => f.write_str("Overloaded"),
            UpstreamIo(reason)         => f.write_str(f"UpstreamIo({reason})".as_str()),
            Internal(reason)           => f.write_str(f"Internal({reason})".as_str()),
        }
    }
}

implement Eq for WeftError {
    fn eq(&self, other: &WeftError) -> Bool {
        match (self, other) {
            (BadRequest(a),         BadRequest(b))         => a == b,
            (RouteNotFound,         RouteNotFound)         => true,
            (MethodNotAllowed,      MethodNotAllowed)      => true,
            (ExtractionRejected(a), ExtractionRejected(b)) => a == b,
            (Timeout,               Timeout)               => true,
            (Overloaded,            Overloaded)            => true,
            (UpstreamIo(a),         UpstreamIo(b))         => a == b,
            (Internal(a),           Internal(b))           => a == b,
            _ => false,
        }
    }
}

implement WeftError {
    public fn category(&self) -> WeftErrorCategory {
        match self {
            BadRequest(_)         => WeftErrorCategory.ErrClient,
            RouteNotFound         => WeftErrorCategory.ErrClient,
            MethodNotAllowed      => WeftErrorCategory.ErrClient,
            ExtractionRejected(_) => WeftErrorCategory.ErrClient,
            Timeout               => WeftErrorCategory.ErrTransient,
            Overloaded            => WeftErrorCategory.ErrTransient,
            UpstreamIo(_)         => WeftErrorCategory.ErrUpstream,
            Internal(_)           => WeftErrorCategory.ErrPermanent,
        }
    }

    public fn status(&self) -> StatusCode {
        match self {
            BadRequest(_)         => StatusCode.bad_request(),
            RouteNotFound         => StatusCode.not_found(),
            MethodNotAllowed      => StatusCode.new(405),
            ExtractionRejected(_) => StatusCode.bad_request(),
            Timeout               => StatusCode.new(504),
            Overloaded            => StatusCode.new(503),
            UpstreamIo(_)         => StatusCode.new(502),
            Internal(_)           => StatusCode.internal_server_error(),
        }
    }

    public fn public_message(&self) -> Text {
        match self {
            BadRequest(_)         => "bad request",
            RouteNotFound         => "not found",
            MethodNotAllowed      => "method not allowed",
            ExtractionRejected(_) => "request validation failed",
            Timeout               => "gateway timeout",
            Overloaded            => "service unavailable",
            UpstreamIo(_)         => "upstream unavailable",
            Internal(_)           => "internal error",
        }
    }
}

implement IntoResponse for WeftError {
    fn into_response(self) -> Response {
        let status = self.status();
        let msg = self.public_message();
        resp_with_body_text(resp_status(status), msg)
    }
}

implement Debug for WeftError {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        match self {
            BadRequest(m)         => f.write_str(f"WeftError.BadRequest({m})"),
            RouteNotFound         => f.write_str("WeftError.RouteNotFound"),
            MethodNotAllowed      => f.write_str("WeftError.MethodNotAllowed"),
            ExtractionRejected(m) => f.write_str(f"WeftError.ExtractionRejected({m})"),
            Timeout               => f.write_str("WeftError.Timeout"),
            Overloaded            => f.write_str("WeftError.Overloaded"),
            UpstreamIo(m)         => f.write_str(f"WeftError.UpstreamIo({m})"),
            Internal(m)           => f.write_str(f"WeftError.Internal({m})"),
        }
    }
}

implement Display for WeftError {
    fn fmt(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.public_message())
    }
}

/// Extractor rejection sum-type. Every `FromRequest` impl's `Rejection`
/// must implement `IntoResponse`; this one covers the common cases.
public type ExtractRejection is
    | MissingParam(Text)
    | InvalidParam { name: Text, value: Text, expected: Text }
    | MissingHeader(Text)
    | InvalidBody(Text)
    | PayloadTooLarge(Int)
    | MissingContext(Text);

implement ExtractRejection {
    public fn status(&self) -> StatusCode {
        match self {
            PayloadTooLarge(_) => StatusCode.new(413),
            _                  => StatusCode.bad_request(),
        }
    }

    public fn public_message(&self) -> Text {
        match self {
            MissingParam(name) =>
                f"missing required parameter: {name}",
            InvalidParam { name, value, expected } =>
                f"parameter `{name}` = `{value}` is not a valid {expected}",
            MissingHeader(name) =>
                f"missing required header: {name}",
            InvalidBody(reason) =>
                f"invalid request body: {reason}",
            PayloadTooLarge(limit) =>
                f"payload exceeds {limit} bytes",
            MissingContext(name) =>
                f"required context not provided: {name}",
        }
    }
}

implement IntoResponse for ExtractRejection {
    fn into_response(self) -> Response {
        let status = self.status();
        let msg = self.public_message();
        resp_with_body_text(resp_status(status), msg)
    }
}

implement Debug for ExtractRejection {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str(self.public_message())
    }
}
