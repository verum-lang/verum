// =============================================================================
// core/net/weft/service.vr — Service / Permit / Layer / ServiceBuilder
// =============================================================================
// Layer: 6 (Weft)
// Spec:  internal/specs/net-framework.md §5.1
// Spec:  docs/architecture/weft-redteam-2026-05-01.md §7
// =============================================================================
//
// # The Permit pattern — affine readiness capability
//
// Tower-style Services have a known foot-gun: callers must drive
// `poll_ready` to `Ready(Ok(()))` BEFORE invoking `call`.  Skipping
// that step silently bypasses backpressure: load-shedding,
// rate-limiting, and concurrency-bounding middleware all stop
// working with no diagnostic.  Tower-rs catches the error with a
// runtime debug-assert.  Verum makes it a compile-time invariant.
//
// `ready(&mut svc).await` yields
// `Result<Permit<S, Req, Resp>, S.Error>`.  A `Permit` is:
//
//   * Move-only (no Clone) — affine; consumed exactly once.
//   * Borrows `&mut self` — exclusion: the underlying service
//     cannot be touched while a permit is outstanding.
//   * Witnesses a successful readiness probe at the type level.
//
// Correct shape is forced by the type system:
//
// ```verum
// let permit = ready(&mut svc).await?;        // earn capability
// let resp   = permit.dispatch(req).await?;   // consume capability
// ```
//
// You cannot `dispatch` without a Permit.  You cannot construct a
// Permit without first awaiting readiness.  The borrow checker
// enforces at-most-one-outstanding-permit per service.  Backpressure
// correctness becomes a property the compiler observes, not a
// convention the developer must remember.
//
// # Why the low-level `poll_ready` / `call` pair stays on the protocol
//
// Implementers must still define `poll_ready` and `call` — the
// Permit pattern is a caller-side ergonomic + safety wrapper, not a
// replacement for the underlying state machine.  Library authors
// (middleware, executors, custom-Future combinators) sometimes need
// the raw poll-based interface.  Application code should reach for
// `ready()` + `Permit::dispatch` exclusively; the type system makes
// that the path of least resistance.

module core.net.weft.service;

mount core.*;
mount core.async.future.{Future};
mount core.async.poll.{Poll};
mount core.async.waker.{Context};

// =============================================================================
// Service — base protocol
// =============================================================================

/// Base protocol for every request-handling component in Weft.
/// `poll_ready` is mandatory — §5.1 rationale.
///
/// **Prefer `ready()` + `Permit::dispatch` for application code.**
/// The raw `poll_ready` / `call` pair is the implementer-facing
/// state machine; the Permit wrapper is the safe caller-facing
/// surface.
public type Service<Req, Resp> is protocol {
    type Error;

    /// Probe whether the service can accept a new request.
    ///
    /// Returns:
    ///   * `Poll.Pending` — not ready; the waker registered on
    ///     `cx` will be notified when readiness changes.
    ///   * `Poll.Ready(Ok(()))` — ready for exactly one `call`.
    ///   * `Poll.Ready(Err(e))` — service has failed terminally;
    ///     no further calls will succeed.
    fn poll_ready(&mut self, cx: &mut Context) -> Poll<Result<(), Self.Error>>;

    /// Dispatch a request.
    ///
    /// **Precondition** (uncheckable here): a prior `poll_ready`
    /// must have returned `Poll.Ready(Ok(()))` since the last
    /// `call`.  Application code should obtain a `Permit` via
    /// `ready()` instead — the Permit witnesses this precondition
    /// at the type level.
    async fn call(&mut self, req: Req) -> Result<Resp, Self.Error>;
}

// =============================================================================
// Permit<S, Req, Resp> — affine readiness capability
// =============================================================================

/// Capability token: holding a `Permit` proves the inner Service
/// has admitted exactly one upcoming `call`.
///
/// Permits are move-only — Verum's affine semantics (no Clone)
/// guarantee at-most-once consumption.  The struct holds `&mut S`,
/// so the borrow checker also guarantees no concurrent mutation
/// of the service while the permit is outstanding.
///
/// The only way to construct a `Permit` is through the `ready()`
/// free function, which awaits a successful `poll_ready`.  The
/// only way to use a `Permit` is `dispatch`, which moves it
/// (releasing the inner borrow) and forwards to `Service::call`.
public type Permit<S: Service<Req, Resp>, Req, Resp> is {
    /// Borrow of the underlying service.  The borrow's lifetime
    /// equals the Permit's lifetime; on `dispatch` the Permit is
    /// consumed and the borrow released.
    service: &mut S,
}

implement<S: Service<Req, Resp>, Req, Resp> Permit<S, Req, Resp> {
    /// Consume the Permit and dispatch the call.
    ///
    /// The Permit's affine nature ensures this method is invoked
    /// at most once per readiness probe.  After `dispatch`
    /// returns, the caller must obtain a fresh Permit via
    /// `ready()` before the next call.
    public async fn dispatch(self, req: Req) -> Result<Resp, S.Error> {
        self.service.call(req).await
    }
}

// =============================================================================
// ready() — earn a Permit
// =============================================================================

/// Future that pumps `Service::poll_ready` until it returns
/// `Ready(Ok(()))`, then resolves with a `Permit`.  Internal
/// driver for `ready()`.
type PollReadyFuture<S: Service<Req, Resp>, Req, Resp> is {
    /// `Some(svc)` while still polling; `None` once consumed.
    /// Encoding the lifecycle in `Maybe` makes "double poll
    /// after completion" a typed invariant.
    service: Maybe<&mut S>,
}

implement<S: Service<Req, Resp>, Req, Resp> Future for PollReadyFuture<S, Req, Resp> {
    type Output = Result<Permit<S, Req, Resp>, S.Error>;

    fn poll(&mut self, cx: &mut Context) -> Poll<Result<Permit<S, Req, Resp>, S.Error>> {
        let svc = match self.service.take() {
            Some(s) => s,
            None => panic("PollReadyFuture polled after completion"),
        };

        match svc.poll_ready(cx) {
            Poll.Pending => {
                // Not ready yet — restore the borrow and wait.
                self.service = Some(svc);
                Poll.Pending
            }
            Poll.Ready(Ok(())) => {
                // Readiness witnessed — mint the Permit.
                Poll.Ready(Ok(Permit { service: svc }))
            }
            Poll.Ready(Err(e)) => {
                // Terminal failure — surface the error.
                Poll.Ready(Err(e))
            }
        }
    }
}

/// Earn a `Permit` to call `service` exactly once.
///
/// Awaits `poll_ready` until it returns `Ready(Ok(()))` or fails.
/// On success, returns `Ok(permit)` — the caller now holds an
/// affine capability they can spend via `permit.dispatch(req)`.
///
/// # Examples
///
/// ```verum
/// // Backpressure-correct dispatch — the type system enforces
/// // poll_ready-before-call at compile time:
/// let permit = ready(&mut service).await?;
/// let response = permit.dispatch(request).await?;
/// ```
///
/// # Why this is safer than direct `call`
///
/// `service.call(req).await` skips the readiness probe.  In a
/// rate-limited or load-shed Service, this bypasses the bound and
/// can drive the service into overload.  `ready()` makes the
/// readiness probe unforgeable — you literally cannot reach
/// `call` without first awaiting readiness.
public fn ready<S: Service<Req, Resp>, Req, Resp>(
    service: &mut S
) -> PollReadyFuture<S, Req, Resp> {
    PollReadyFuture { service: Some(service) }
}

// =============================================================================
// Layer — middleware
// =============================================================================

/// Service transformer — middleware. Takes Inner, returns a wrapped Service.
public type Layer<Inner> is protocol {
    type Wrapped;
    fn wrap(&self, inner: Inner) -> Self.Wrapped;
}

/// Fluent composition of Layers around a root Service.
public type ServiceBuilder<S> is {
    inner: S,
}

implement<S> ServiceBuilder<S> {
    public fn new(svc: S) -> ServiceBuilder<S> {
        ServiceBuilder { inner: svc }
    }

    public fn layer<L: Layer<S>>(self, l: L) -> ServiceBuilder<L.Wrapped> {
        ServiceBuilder { inner: l.wrap(self.inner) }
    }

    public fn build(self) -> S {
        self.inner
    }
}

/// Identity Layer — passes Inner through unchanged. Useful for conditional
/// layering (`.layer(if cfg { real } else { Identity })`).
public type Identity is {}

implement Identity {
    public fn new() -> Identity { Identity {} }
}

implement<S> Layer<S> for Identity {
    type Wrapped = S;
    fn wrap(&self, inner: S) -> S { inner }
}
