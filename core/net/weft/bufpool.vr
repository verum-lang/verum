// =============================================================================
// core/net/weft/bufpool.vr — Registered I/O buffer pool
// =============================================================================
// Layer: 6 (Weft)
// Spec:  internal/specs/net-framework.md §4.2.1 / §6.17
// =============================================================================
//
// A fixed-size pool of pre-allocated byte buffers. On Linux with
// io_uring the backing memory is registered with the kernel
// (`IORING_REGISTER_BUFFERS`), turning each recv/send into a single
// syscall with zero page-pinning overhead per op. On kqueue / IOCP
// platforms we keep the same abstraction shape but the buffers are
// just plain pool slots — kernel-level registration has no direct
// analogue, so there's no additional win from the OS side there.
//
// Downstream consumer: a specialised `WeftTransport` impl that grabs
// a buffer on read, yields it (zero-copy) through the HTTP/1.1
// parser, then releases on response emit. Follow-up task #28 wires
// that into connection.vr behind a feature flag.
//
// Key invariants:
//
//   * Buffers are power-of-two sized (default 16 KiB). Matches the
//     page-pin granularity io_uring expects and keeps SIMD-scans in
//     `core/simd/bytes.vr` cache-friendly.
//
//   * Acquire is O(1) — Mutex-protected stack pop.
//
//   * On exhaustion the pool returns `None`; the caller falls back
//     to on-heap allocation. Never blocks the reactor thread.
//
//   * Pool bytes are NOT zeroed between reuses — they're always
//     overwritten before being observed. Safe under §4.3 arena
//     discipline (ThinRef generation check prevents re-reading old
//     contents from a previously leased buffer).
//
// Kernel-side registration:
//
//   * On Linux, registration is performed against an existing
//     `IoUringDriver` instance via `register_with_iouring(driver)`
//     (cfg-gated to `target_os = "linux"`). The pool's slab is split
//     into one `IOVec` per buffer slot; the kernel pins the pages and
//     downstream prep_read_fixed / prep_write_fixed reference each
//     buffer by its index (returned via `BufferHandle.fd_offset()`,
//     which IS the `IOSQE_BUFFER_SELECT` handle).
//
//   * macOS / Windows do not have a kernel-level analogue so the
//     method does not exist on those targets; `iouring_registered()`
//     stays false.
//
//   * The previous no-argument stub was architecturally wrong:
//     registration requires the same io_uring fd that the executor
//     uses, not a free-standing syscall. Removed.
//
// =============================================================================

module core.net.weft.bufpool;

mount core.*;
mount core.collections.list.{List};
mount core.sync.Mutex;
mount core.sync.atomic.{AtomicInt, AtomicBool, MemoryOrdering};
mount core.base.memory.{ptr_offset};
mount core.sys.common.{IOVec};

@cfg(target_os = "linux")
mount core.sys.linux.io.{IoUringDriver, LinuxIoDriverError};

// =============================================================================
// Configuration
// =============================================================================

public type BufferPoolConfig is {
    /// Number of buffers in the pool. 256 is a good default for a
    /// 10k-connection server: at most ~4 MiB of RSS dedicated to
    /// registered-buffer inventory.
    count: Int,
    /// Size of each buffer. Must be a power of two ≥ 4096.
    buf_size: Int,
    /// Try to register with io_uring on Linux. On other platforms a
    /// no-op. Disabled by default until the runtime intrinsic lands.
    try_register_iouring: Bool,
};

implement BufferPoolConfig {
    public fn default() -> BufferPoolConfig {
        BufferPoolConfig {
            count: 256,
            buf_size: 16 * 1024,
            try_register_iouring: false,
        }
    }

    public fn with_count(self, n: Int) -> BufferPoolConfig {
        BufferPoolConfig { count: n, ..self }
    }

    public fn with_buf_size(self, n: Int) -> BufferPoolConfig {
        BufferPoolConfig { buf_size: n, ..self }
    }

    public fn with_io_uring(self, enabled: Bool) -> BufferPoolConfig {
        BufferPoolConfig { try_register_iouring: enabled, ..self }
    }
}

implement Clone for BufferPoolConfig {
    fn clone(&self) -> BufferPoolConfig {
        BufferPoolConfig {
            count: self.count,
            buf_size: self.buf_size,
            try_register_iouring: self.try_register_iouring,
        }
    }
}

// =============================================================================
// Pool state
// =============================================================================

/// Pre-allocated slab: one contiguous byte block holding `count`
/// buffers of `buf_size` bytes each. `free_indices` holds the stack
/// of indices whose slice is currently available.
type BufferPoolState is {
    config: BufferPoolConfig,
    slab: List<Byte>,                  // contiguous backing memory
    free_indices: Mutex<List<Int>>,
    /// Cumulative acquire count — metric signal.
    acquires_total: AtomicInt,
    /// Acquire attempts that missed the pool (fell back to alloc).
    misses_total: AtomicInt,
    /// True iff io_uring registration succeeded. Stays false on
    /// macOS / Windows and on Linux until `register_with_iouring`
    /// is called against a driver. AtomicBool — the value flips
    /// post-construction when registration succeeds, and the pool is
    /// `Shared` across reactor threads.
    iouring_registered: AtomicBool,
};

// =============================================================================
// BufferPool
// =============================================================================

public type BufferPool is {
    state: Shared<BufferPoolState>,
};

implement BufferPool {
    public fn new(config: BufferPoolConfig) -> BufferPool {
        if config.count <= 0 || config.buf_size < 4096 {
            panic("BufferPool: count > 0 and buf_size >= 4096 required");
        }
        let total_bytes = config.count * config.buf_size;
        let mut slab: List<Byte> = List.with_capacity(total_bytes);
        let mut i: Int = 0;
        while i < total_bytes { slab.push(0); i = i + 1; }

        let mut free: List<Int> = List.with_capacity(config.count);
        let mut j: Int = 0;
        while j < config.count { free.push(j); j = j + 1; }

        // Kernel-side registration is performed post-construction
        // via `register_with_iouring(driver)` once the runtime layer
        // hands the pool an io_uring driver. `try_register_iouring`
        // on the config is a hint for the runtime layer; this module
        // no longer attempts a no-driver registration.
        BufferPool {
            state: Shared.new(BufferPoolState {
                config: config.clone(),
                slab: slab,
                free_indices: Mutex.new(free),
                acquires_total: AtomicInt.new(0),
                misses_total: AtomicInt.new(0),
                iouring_registered: AtomicBool.new(false),
            }),
        }
    }

    public fn default() -> BufferPool {
        Self.new(BufferPoolConfig.default())
    }

    /// Try to lease a buffer. Returns `None` if the pool is exhausted
    /// — caller is expected to fall back to on-heap List<Byte>.
    public fn acquire(&self) -> Maybe<BufferHandle> {
        self.state.acquires_total.fetch_add(1, MemoryOrdering.AcqRel);
        let mut free = self.state.free_indices.lock();
        match free.pop() {
            None => {
                self.state.misses_total.fetch_add(1, MemoryOrdering.AcqRel);
                None
            }
            Some(idx) => Some(BufferHandle {
                index: idx,
                pool: self.state.clone(),
            }),
        }
    }

    public fn iouring_registered(&self) -> Bool {
        self.state.iouring_registered.load(MemoryOrdering.Acquire)
    }

    /// Build the IOVec[] view over the slab — one entry per buffer
    /// slot. Kept public so non-Linux callers writing portable
    /// readv/writev paths can leverage the registered layout without
    /// depending on `IoUringDriver`.
    public fn build_iovecs(&self) -> List<IOVec> {
        let count = self.state.config.count;
        let buf_size = self.state.config.buf_size;
        let base: &unsafe Byte = self.state.slab.as_ptr();
        let mut iovecs: List<IOVec> = List.with_capacity(count);
        let mut i: Int = 0;
        while i < count {
            let entry_ptr = unsafe { ptr_offset(base, i * buf_size) };
            iovecs.push(IOVec.from_raw_parts(entry_ptr, buf_size));
            i = i + 1;
        }
        iovecs
    }

    public fn free_count(&self) -> Int {
        let free = self.state.free_indices.lock();
        free.len()
    }

    public fn acquires_total(&self) -> Int {
        self.state.acquires_total.load(MemoryOrdering.Acquire)
    }

    public fn misses_total(&self) -> Int {
        self.state.misses_total.load(MemoryOrdering.Acquire)
    }
}

implement Clone for BufferPool {
    fn clone(&self) -> BufferPool {
        BufferPool { state: self.state.clone() }
    }
}

// =============================================================================
// BufferHandle — RAII lease
// =============================================================================

public type BufferHandle is {
    index: Int,
    pool: Shared<BufferPoolState>,
};

implement BufferHandle {
    /// Returns (start, len) into the pool's slab for this buffer.
    /// Use with `slab_mut(pool)` for direct write access.
    public fn slot(&self) -> (Int, Int) {
        let size = self.pool.config.buf_size;
        (self.index * size, size)
    }

    /// Zero-based buffer index — this IS the `IOSQE_BUFFER_SELECT`
    /// handle that io_uring expects once the intrinsic path is
    /// wired up.
    public fn fd_offset(&self) -> Int {
        self.index
    }

    /// Write bytes into the buffer starting at offset 0. Returns the
    /// number actually written (capped at buf_size).
    public fn write_at(&mut self, data: &[Byte]) -> Int {
        let (start, size) = self.slot();
        let n = if data.len() < size { data.len() } else { size };
        // Mutex-lock slab only long enough to copy — low contention
        // because different leases address different ranges.
        let slab_state = &self.pool;
        // core.mem slab mutation needs raw access; Phase-5 skeleton
        // uses the already-allocated List<Byte>. A pointer-based
        // zero-copy variant is the io_uring-era follow-up.
        // NOTE: the pool's slab is Shared<Mutex<...>> in a fuller impl;
        // here the simple read-mostly pattern suffices because the
        // slab length never changes post-construction.
        let mut i: Int = 0;
        while i < n {
            slab_state.slab.set(start + i, data[i]);
            i = i + 1;
        }
        n
    }
}

implement Drop for BufferHandle {
    fn drop(&mut self) {
        // Return index to free list.
        let mut free = self.pool.free_indices.lock();
        free.push(self.index);
    }
}

// =============================================================================
// Kernel-side registration — io_uring REGISTER_BUFFERS
// =============================================================================

implement BufferPool {
    /// Register every slot in the pool with the supplied io_uring
    /// driver via `IORING_REGISTER_BUFFERS`. After success, callers
    /// may submit operations using `prep_read_fixed` /
    /// `prep_write_fixed` referencing each handle's `fd_offset()`.
    ///
    /// Idempotent — if the pool is already registered, returns Ok(())
    /// without re-issuing the syscall (the kernel rejects double
    /// registration with -EBUSY otherwise).
    ///
    /// The pool's slab pointers are pinned by the kernel for the
    /// registration's lifetime; releasing the pool without first
    /// calling `unregister_iouring` leaves the kernel-side pin in
    /// place until the io_uring fd is closed.
    @cfg(target_os = "linux")
    public fn register_with_iouring(
        &self,
        driver: &mut IoUringDriver,
    ) -> Result<(), LinuxIoDriverError> {
        if self.state.iouring_registered.load(MemoryOrdering.Acquire) {
            return Ok(());
        }
        let iovecs = self.build_iovecs();
        driver.register_buffers(iovecs.as_slice())?;
        self.state.iouring_registered.store(true, MemoryOrdering.Release);
        Ok(())
    }

    /// Release the kernel-side registration, allowing the pool to be
    /// freed or re-registered against a different driver. No-op when
    /// the pool isn't currently registered.
    @cfg(target_os = "linux")
    public fn unregister_iouring(
        &self,
        driver: &mut IoUringDriver,
    ) -> Result<(), LinuxIoDriverError> {
        if !self.state.iouring_registered.load(MemoryOrdering.Acquire) {
            return Ok(());
        }
        driver.unregister_buffers()?;
        self.state.iouring_registered.store(false, MemoryOrdering.Release);
        Ok(())
    }
}
