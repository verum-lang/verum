// =============================================================================
// core/net/weft/metrics.vr — MetricsLayer + Prometheus-style registry
// =============================================================================
// Layer: 6 (Weft)
// Spec: internal/specs/net-framework.md §7.2
// =============================================================================
//

// A minimal metrics registry that records per-request counters and
// latency histograms in a Prometheus-compatible shape. Phase 1 exports
// a text endpoint rendering (same as `/metrics` in a Prometheus job);
// OTLP push and exemplars arrive in phase 5 (§7.7).
//

// The registry itself is thread-safe via a single Mutex. Hot paths (the
// MetricsHandler below) take the lock only to update counters; for the
// baseline 4 metrics that each handler touches this is uncontended in
// practice. A future lock-free per-shard variant is straightforward.
//

// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.net.weft.metrics;

mount core.*;
mount core.text.builder.{TextBuilder};
mount core.collections.map.{Map};
mount core.collections.list.{List};
mount core.time.{Instant};
mount core.sync.Mutex;
mount core.sync.atomic.{AtomicInt, MemoryOrdering};
mount core.net.http.{Response};
mount core.net.weft.service.{Layer};
mount core.net.weft.handler.{WeftRequest, Handler};
mount core.net.weft.error.{WeftError};

// =============================================================================
// Metric types
// =============================================================================

/// Lock-free counter — single AtomicInt with `Relaxed` ordering on
/// the hot path. Pre-fix (#319) used `Mutex<Int>`, which forced
/// every `incr()` to take a system mutex (one cmpxchg + a syscall
/// in the contended path). Post-fix every increment is a single
/// fetch_add, ~2 ns on modern x86 / 10 ns on aarch64 — three
/// orders of magnitude better than the locked path under
/// contention.
///

/// `Relaxed` is sufficient: the metric value is read by Prometheus
/// scrape (eventual-consistency) and the increments don't need
/// happens-before with surrounding work. If a future scenario
/// needs a coherent multi-counter snapshot, a stronger ordering
/// can be added on-demand.
public type WeftCounter is {
    inner: AtomicInt,
};

implement WeftCounter {
    public fn new() -> WeftCounter { WeftCounter { inner: AtomicInt.new(0) } }

    public fn incr(&self) {
        let _ = self.inner.fetch_add(1, MemoryOrdering.Relaxed);
    }

    public fn add(&self, n: Int) {
        let _ = self.inner.fetch_add(n, MemoryOrdering.Relaxed);
    }

    public fn value(&self) -> Int {
        self.inner.load(MemoryOrdering.Relaxed)
    }
}

/// Fixed-bucket histogram. The default set of bucket boundaries is the
/// Prometheus client default (in ms — SLI-style), adjusted for web
/// handlers: 5 15 30 60 120 250 500 1000 2500 5000 10000.
///

/// Pre-fix (#319) `count` and `sum_ms` were each `Mutex<Int>` and
/// `counts` was `Mutex<List<Int>>` — a single observe_ms() took
/// THREE separate lock-acquire-release cycles. Worse, a reader
/// observing between the count-lock and sum_ms-lock could see
/// inconsistent ratios (count > sum_ms / count). Post-fix
/// `count` and `sum_ms` are AtomicInt (single fetch_add each, no
/// lock contention). `counts` retains a Mutex<List<Int>> for now
/// because Verum's List<AtomicInt> ergonomics are not yet
/// optimised — that follow-up is tracked but the high-impact
/// per-observation cost is already eliminated by the count+sum
/// atomic split.
public type WeftHistogram is {
    bounds_ms: List<Int>,
    counts: Mutex<List<Int>>,
    sum_ms: AtomicInt,
    count: AtomicInt,
};

implement WeftHistogram {
    public fn new() -> WeftHistogram {
        let bounds = List.from([5, 15, 30, 60, 120, 250, 500, 1000, 2500, 5000, 10000]);
        let mut zero = List.with_capacity(bounds.len() + 1);
        let mut i: Int = 0;
        while i <= bounds.len() { zero.push(0); i = i + 1; }
        WeftHistogram {
            bounds_ms: bounds,
            counts: Mutex.new(zero),
            sum_ms: AtomicInt.new(0),
            count: AtomicInt.new(0),
        }
    }

    public fn observe_ms(&self, ms: Int) {
        // Lock-free count + sum updates. Two atomic fetch_adds
        // (Relaxed) instead of two mutex lock-release cycles.
        let _ = self.count.fetch_add(1, MemoryOrdering.Relaxed);
        let _ = self.sum_ms.fetch_add(ms, MemoryOrdering.Relaxed);
        // Bucket update still requires a brief Mutex (List<Int>
        // doesn't yet have an atomic-element API). The lock is
        // held only for the bucket-find + single increment — no
        // I/O, no awaits. Tracked as a follow-up for
        // [AtomicInt; N] migration.
        let mut cs = self.counts.lock();
        let mut placed = false;
        let mut i: Int = 0;
        while i < self.bounds_ms.len() {
            if ms <= self.bounds_ms[i] {
                cs[i] = cs[i] + 1;
                placed = true;
                break;
            }
            i = i + 1;
        }
        if !placed {
            let last = cs.len() - 1;
            cs[last] = cs[last] + 1;
        }
    }
}

// =============================================================================
// WeftMetricsRegistry
// =============================================================================

public type WeftMetricsRegistry is {
    counters: Mutex<Map<Text, Shared<WeftCounter>>>,
    histograms: Mutex<Map<Text, Shared<WeftHistogram>>>,
};

implement WeftMetricsRegistry {
    public fn new() -> WeftMetricsRegistry {
        WeftMetricsRegistry {
            counters: Mutex.new(Map.new()),
            histograms: Mutex.new(Map.new()),
        }
    }

    /// Get-or-create a counter with the given name.
    public fn counter(&self, name: &Text) -> Shared<WeftCounter> {
        let mut m = self.counters.lock();
        match m.get(name) {
            Some(c) => c.clone(),
            None => {
                let c = Shared.new(WeftCounter.new());
                m.insert(name.clone(), c.clone());
                c
            }
        }
    }

    /// Get-or-create a histogram with the given name.
    public fn histogram(&self, name: &Text) -> Shared<WeftHistogram> {
        let mut m = self.histograms.lock();
        match m.get(name) {
            Some(h) => h.clone(),
            None => {
                let h = Shared.new(WeftHistogram.new());
                m.insert(name.clone(), h.clone());
                h
            }
        }
    }

    /// Snapshot every counter as `(name, value)` pairs. Order is
    /// deterministic — alphabetic by name. Used by the OTLP-push
    /// exporter to produce byte-stable wire output across runs.
    public fn counter_snapshot(&self) -> core.collections.list.List<(Text, Int)> {
        let mut out: core.collections.list.List<(Text, Int)> = [];
        let cs = self.counters.lock();
        for (name, counter) in cs.iter() {
            out.push((name.clone(), counter.value()));
        }
        // Stable order across runs — sort alphabetically.
        out.sort_by(|a, b| a.0.cmp(&b.0));
        out
    }

    /// Snapshot every histogram as `(name, OtlpHistogramSnapshot)` pairs.
    public fn histogram_snapshot(&self)
        -> core.collections.list.List<(Text, core.net.weft.metrics_otlp.OtlpHistogramSnapshot)>
    {
        let mut out = core.collections.list.List.new();
        let hs = self.histograms.lock();
        for (name, hist) in hs.iter() {
            let counts = hist.counts.lock().clone();
            // #319: count + sum_ms are now AtomicInt (lock-free
            // load) — was Mutex<Int> pre-fix.
            let total = hist.count.load(MemoryOrdering.Relaxed);
            let sum_ms = hist.sum_ms.load(MemoryOrdering.Relaxed);
            out.push((name.clone(), core.net.weft.metrics_otlp.OtlpHistogramSnapshot {
                bounds_ms:     hist.bounds_ms.clone(),
                bucket_counts: counts,
                total:         total,
                sum_ms:        sum_ms,
            }));
        }
        out.sort_by(|a, b| a.0.cmp(&b.0));
        out
    }

    /// Render in Prometheus text exposition format. Suitable for a
    /// `GET /metrics` handler.
    public fn render_prometheus(&self) -> Text {
        let mut out = TextBuilder.new();
        // Counters.
        let cs = self.counters.lock();
        for (name, counter) in cs.iter() {
            out.push_str(f"# TYPE {name} counter\n");
            out.push_str(f"{name} {counter.value()}\n");
        }
        // Histograms.
        let hs = self.histograms.lock();
        for (name, hist) in hs.iter() {
            out.push_str(f"# TYPE {name} histogram\n");
            let counts = hist.counts.lock();
            let mut cumulative: Int = 0;
            let mut i: Int = 0;
            while i < hist.bounds_ms.len() {
                cumulative = cumulative + counts[i];
                out.push_str(f"{name}_bucket{{le=\"{hist.bounds_ms[i]}\"}} {cumulative}\n");
                i = i + 1;
            }
            // #319: AtomicInt lock-free reads.
            let total = hist.count.load(MemoryOrdering.Relaxed);
            let sum_ms_val = hist.sum_ms.load(MemoryOrdering.Relaxed);
            out.push_str(f"{name}_bucket{{le=\"+Inf\"}} {total}\n");
            out.push_str(f"{name}_sum {sum_ms_val}\n");
            out.push_str(f"{name}_count {total}\n");
        }
        out.finish()
    }
}

// =============================================================================
// MetricsLayer
// =============================================================================

public type MetricsLayer is {
    registry: Shared<WeftMetricsRegistry>,
};

implement MetricsLayer {
    public fn new(registry: Shared<WeftMetricsRegistry>) -> MetricsLayer {
        MetricsLayer { registry: registry }
    }

    /// Convenience: wire up a fresh WeftMetricsRegistry and return both.
    public fn with_new_registry() -> (MetricsLayer, Shared<WeftMetricsRegistry>) {
        let reg = Shared.new(WeftMetricsRegistry.new());
        (MetricsLayer { registry: reg.clone() }, reg)
    }
}

implement<H: Handler> Layer<H> for MetricsLayer {
    type Wrapped = MetricsHandler<H>;
    fn wrap(&self, inner: H) -> MetricsHandler<H> {
        MetricsHandler {
            inner: inner,
            registry: self.registry.clone(),
        }
    }
}

public type MetricsHandler<H> is {
    inner: H,
    registry: Shared<WeftMetricsRegistry>,
};

implement<H: Handler> Handler for MetricsHandler<H> {
    async fn handle(&self, req: WeftRequest) -> Result<Response, WeftError> {
        let total = self.registry.counter(&Text.from_str("http_requests_total"));
        let latency = self.registry.histogram(&Text.from_str("http_request_duration_ms"));

        total.incr();
        let start = Instant.now();
        let result = self.inner.handle(req).await;
        let dt = Instant.now().duration_since(start).as_millis();
        latency.observe_ms(dt);

        match &result {
            Err(_) => self.registry.counter(&Text.from_str("http_requests_errors_total")).incr(),
            Ok(r) if r.status.is_server_error() =>
                self.registry.counter(&Text.from_str("http_requests_5xx_total")).incr(),
            Ok(r) if r.status.is_client_error() =>
                self.registry.counter(&Text.from_str("http_requests_4xx_total")).incr(),
            _ => {}
        }

        result
    }
}
