// =============================================================================
// core/net/weft/app.vr — WeftApp builder
// =============================================================================
// Layer: 6 (Weft)
// Spec:  internal/specs/net-framework.md §9.1 (Хellо-Workld), §4.5 (Supervisor)
// =============================================================================
//
// The top-level, user-facing entry point. Ties together:
//
//   Router / Service → Listener → Server
//
// and exposes a thin, fluent API so a minimal HTTP service fits in the
// §9.1 "20 строк" target:
//
//     mount core.net.weft.*;
//     mount core.net.http.{Request, Response};
//
//     async fn hello() -> Result<Response, WeftError> {
//         Ok(Response.text(Text.from_str("Hello from Weft!")))
//     }
//
//     fn main() {
//         let app = Router.new().get("/", HelloHandler {});
//         WeftApp.new(app)
//             .bind("0.0.0.0:8080")
//             .serve()
//             .await
//             .unwrap();
//     }
//
// Supervisor integration (§4.5) is exposed via `.into_child_spec(name)` —
// the returned `ChildSpec` can be dropped straight into a root supervisor.
//
// =============================================================================

module core.net.weft.app;

mount core.*;
mount core.net.weft.handler.{Handler};
mount core.net.weft.listener.{Server, ListenerConfig};
mount core.net.weft.connection.{ConnectionConfig};
mount core.runtime.supervisor.{ChildSpec};

// =============================================================================
// WeftApp
// =============================================================================

/// Builder wrapping a `Handler` (router or any Service) with bind-time
/// configuration. The builder is plain data until `.bind(...)` turns it
/// into a `Server` that owns the listening socket.
public type WeftApp<H> is {
    app: H,
    config: ListenerConfig,
};

implement<H: Handler + Send + Sync + 'static> WeftApp<H> {
    /// Start from a `Handler` (usually a `Router`). Default config.
    public fn new(handler: H) -> WeftApp<H> {
        WeftApp {
            app: handler,
            config: ListenerConfig.default(),
        }
    }

    /// Override listener-level settings (concurrency cap, per-conn cfg).
    public fn with_listener_config(self, cfg: ListenerConfig) -> WeftApp<H> {
        WeftApp { config: cfg, ..self }
    }

    /// Override per-connection settings without touching the listener cap.
    public fn with_connection_config(self, cfg: ConnectionConfig) -> WeftApp<H> {
        WeftApp {
            config: ListenerConfig { connection: cfg, ..self.config },
            ..self
        }
    }

    /// Set the concurrent-connection budget.
    public fn with_max_connections(self, max: Int) -> WeftApp<H> {
        WeftApp {
            config: ListenerConfig {
                max_concurrent_connections: max,
                ..self.config
            },
            ..self
        }
    }

    /// Bind the configured listener. Returns a `Server` ready to serve.
    public fn bind(self, addr: Text) -> Result<Server<H>, Text> {
        Server.bind(addr, self.app, self.config)
    }

    /// Build a `ChildSpec.permanent` for this app. Pair with a future
    /// factory to feed `supervisor.supervise(factory, spec)`. Callers
    /// build the factory themselves — `async` closures capturing owned
    /// state remain a Phase-3 ergonomics item.
    ///
    /// Example:
    /// ```verum
    /// let app    = WeftApp.new(router);
    /// let spec   = app.child_spec("http-listener");
    /// let addr   = Text.from_str("0.0.0.0:8080");
    /// supervisor.supervise(
    ///     fn() -> async {
    ///         WeftApp.new(router.clone())
    ///             .bind(addr.clone()).unwrap()
    ///             .serve().await
    ///     },
    ///     spec,
    /// ).await
    /// ```
    public fn child_spec(&self, name: Text) -> ChildSpec {
        ChildSpec.permanent(name)
            .with_shutdown_timeout_ms(30_000)
    }
}
