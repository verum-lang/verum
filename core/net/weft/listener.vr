// =============================================================================
// core/net/weft/listener.vr тАФ TCP listener + shared accept loop
// =============================================================================
// Layer: 6 (Weft)
// Spec:  internal/specs/net-framework.md ┬з4.2, ┬з4.4, ┬з7.8
// =============================================================================
//
// Owns the bind + accept lifecycle. The per-connection behaviour is
// pluggable through the `ConnectionRunner` protocol, so the same loop
// drives plain-TCP (`Server<H>`) and TLS-terminating (`TlsServer<H>`,
// see `tls.vr`) variants without duplicated code.
//
// Responsibilities:
//
//   * Lifecycle. Own the cancellation token + draining flag. One
//     `.shutdown()` triggers graceful drain; `.begin_drain()` stops
//     accepting while letting in-flight requests finish.
//
//   * Concurrency budget. `max_concurrent_connections` bounds total
//     in-flight connections; excess sockets are closed immediately via
//     the runner's `refuse_overloaded` hook тАФ TCP runners emit a 503
//     HTTP reply, TLS runners just drop (can't speak plaintext).
//
//   * Per-connection task isolation. Each connection is spawned into
//     its own task; the runner owns the lifecycle until return.
//
// Out of scope (phase 5):
//
//   * io_uring multi-shot accept / registered buffers (┬з4.2.1тАУ2).
//   * Kernel-bypass reactor (┬з6.8).
//
// =============================================================================

module core.net.weft.listener;

mount core.*;
mount core.net.tcp.{TcpListener, TcpStream};
mount core.net.addr.{SocketAddr, IpAddr};
mount core.async.cancellation.{CancellationToken};
mount core.async.task;
mount core.async.timer;
mount core.async.timer.{timeout_ms as future_timeout_ms};
mount core.sync.atomic.{AtomicBool, AtomicInt, MemoryOrdering};
mount core.net.weft.handler.{Handler};
mount core.net.weft.connection.{serve_http1, ConnectionConfig};
mount core.net.weft.io_uring_accept.{IoUringAcceptConfig};

// =============================================================================
// Config
// =============================================================================

public type ListenerConfig is {
    /// Soft cap on in-flight connections. Sockets accepted while at
    /// the cap are refused via the runner's overload hook.
    max_concurrent_connections: Int,
    /// Per-connection config handed to `serve_http1`.
    connection: ConnectionConfig,
    /// Maximum milliseconds `shutdown()` will wait for in-flight
    /// connections to finish before forcibly dropping them (┬з7.8
    /// phase-5 "Hard stop"). 30s matches the K8s default.
    drain_grace_ms: Int,
    /// Bind with SO_REUSEPORT тАФ enables seamless blue/green handoff
    /// at the OS level (┬з7.8 phase 4).
    reuseport: Bool,
    /// Per-peer-IP concurrent-connection cap (redteam ┬з10).
    /// Single attacker IPs cannot saturate the global slot pool;
    /// after `per_ip_max` concurrent connections from one address
    /// the listener emits 503 + closes for any further accept
    /// from that IP тАФ without consuming a global slot.
    /// 0 disables the per-IP throttle (NOT recommended in
    /// internet-exposed deployments).  Default 100.
    per_ip_max: Int,
    /// Optional io_uring multi-shot accept config (┬з6.17).  `None`
    /// keeps the existing `TcpListener::accept` path; `Some(cfg)`
    /// opts the listener into the strategy selected by
    /// `io_uring_accept.select_accept_strategy(target_triple, cfg)`.
    /// V0 (#316.3) accepts the field but the selector falls through
    /// to the blocking strategy on every platform; V1 (#316.4) wires
    /// in the liburing FFI and Linux callers transparently upgrade.
    io_uring_accept: Maybe<IoUringAcceptConfig>,
};

implement ListenerConfig {
    public fn default() -> ListenerConfig {
        ListenerConfig {
            max_concurrent_connections: 10_000,
            connection: ConnectionConfig.default(),
            drain_grace_ms: 30_000,
            reuseport: false,
            per_ip_max: 100,
            io_uring_accept: None,
        }
    }

    public fn with_drain_grace_ms(self, ms: Int) -> ListenerConfig {
        ListenerConfig { drain_grace_ms: ms, ..self }
    }

    public fn with_reuseport(self, enabled: Bool) -> ListenerConfig {
        ListenerConfig { reuseport: enabled, ..self }
    }

    public fn with_per_ip_max(self, max: Int) -> ListenerConfig {
        ListenerConfig { per_ip_max: max, ..self }
    }

    /// Opt the listener into io_uring multi-shot accept (Linux тЙе 6.11)
    /// per spec ┬з6.17.  The supplied `IoUringAcceptConfig` is handed
    /// to `select_accept_strategy()` at startup; on non-Linux targets
    /// or when V1 isn't yet wired the listener silently falls through
    /// to today's `TcpListener::accept` path тАФ caller-side behaviour
    /// is unchanged either way.  Default for new `ListenerConfig`s
    /// remains `None` (no behavioural change to existing call sites).
    public fn with_io_uring_strategy(self, cfg: IoUringAcceptConfig) -> ListenerConfig {
        ListenerConfig { io_uring_accept: Some(cfg), ..self }
    }
}

// =============================================================================
// ConnectionRunner тАФ per-connection lifecycle strategy
// =============================================================================

/// The pluggable piece that turns a freshly-accepted TCP socket into a
/// served HTTP/* connection. Implementations decide:
///
///   * Whether to wrap the socket in TLS (or any other transport).
///   * Which protocol to speak (HTTP/1.1, HTTP/2 via ALPN, WebSocket).
///   * What to say to a client refused for overload.
///
/// The two phase-3 implementors are `PlainHttp1Runner<H>` (defined
/// below) and `TlsHttp1Runner<H>` (`tls.vr`). Both ultimately drive
/// `serve_http1` but differ in the transport adapter.
public type ConnectionRunner is protocol {
    /// Drive one accepted connection to completion. Owns the stream.
    async fn run(&self, stream: TcpStream, peer: SocketAddr);

    /// Refuse a connection because the listener-level budget is
    /// exhausted. Invoked synchronously inside the accept loop; runs
    /// on the accept task, not a spawned one.
    async fn refuse_overloaded(&self, stream: TcpStream);
};

// =============================================================================
// PlainHttp1Runner тАФ runner for plaintext HTTP/1.1
// =============================================================================

public type PlainHttp1Runner<H> is {
    app: Heap<H>,
    token: CancellationToken,
    draining: Shared<AtomicBool>,
    connection_cfg: ConnectionConfig,
};

implement<H: Handler + Send + Sync + 'static> PlainHttp1Runner<H> {
    public fn new(
        app: Heap<H>,
        token: CancellationToken,
        draining: Shared<AtomicBool>,
        connection_cfg: ConnectionConfig,
    ) -> PlainHttp1Runner<H> {
        PlainHttp1Runner {
            app: app,
            token: token,
            draining: draining,
            connection_cfg: connection_cfg,
        }
    }
}

implement<H: Handler + Send + Sync + 'static> Clone for PlainHttp1Runner<H> {
    fn clone(&self) -> PlainHttp1Runner<H> {
        PlainHttp1Runner {
            app: self.app.clone(),
            token: self.token.clone(),
            draining: self.draining.clone(),
            connection_cfg: self.connection_cfg.clone(),
        }
    }
}

implement<H: Handler + Send + Sync + 'static> ConnectionRunner for PlainHttp1Runner<H> {
    async fn run(&self, stream: TcpStream, peer: SocketAddr) {
        let _ = serve_http1(
            stream, peer,
            self.app.clone(),
            self.token.clone(),
            self.draining.clone(),
            self.connection_cfg.clone(),
        ).await;
    }

    async fn refuse_overloaded(&self, mut stream: TcpStream) {
        // Best-effort minimal 503 before drop.  We do NOT go through
        // the full response pipeline тАФ the peer didn't yet finish a
        // request that Weft could parse.
        //
        // Pre-fix the write went through `await` directly on the
        // accept-loop's task тАФ a slow attacker (TCP-handshake-then-stall)
        // could stall the loop on its 503 response, blocking new
        // accepts.  Redteam ┬з6.
        //
        // Post-fix the write is fire-and-forget under a 1-second
        // deadline: spawn the write into its own task so the
        // accept-loop returns immediately; the deadline ensures the
        // spawned write doesn't dangle if the peer never reads.
        let msg = "HTTP/1.1 503 Service Unavailable\r\nconnection: close\r\ncontent-length: 11\r\n\r\noverloaded\n";
        // Post-#316: emit bytes straight into the byte buffer.
        let mut buf: List<Byte> = List.with_capacity(msg.len());
        for b in msg.as_bytes().iter() {
            buf.push(*b);
        }
        // Fire-and-forget тАФ accept loop continues immediately.
        // 1-second write deadline bounds the slow-consumer attack
        // surface on the 503 path itself.
        let _ = task.spawn(async move {
            let _ = future_timeout_ms(
                1_000,
                stream.write_async(&buf),
            ).await;
        });
    }
}

// =============================================================================
// accept_loop тАФ shared core for every Weft server variant
// =============================================================================

/// The heart of every Weft server. Consumes ownership of the listener,
/// runs until cancelled or drained, returns on clean shutdown.
///
/// Typed parameters:
///
///   * `R` тАФ the connection runner (zero-cost polymorphism via
///     monomorphisation; no `Box<dyn>` on the hot path).
public async fn accept_loop<R: ConnectionRunner + Clone + Send + Sync + 'static>(
    listener: TcpListener,
    config: ListenerConfig,
    token: CancellationToken,
    draining: Shared<AtomicBool>,
    runner: R,
) -> Result<(), Text> {
    // ConnectionLimiter + PerIpLimiter: shared atomic + RAII ticket
    // pattern.  The accept loop *acquires* a ticket before spawning
    // the per-conn task; the ticket's `Drop` impl decrements both
    // counters unconditionally тАФ whether the spawned future returned
    // normally, panicked, was cancelled, or got dropped at shutdown.
    //
    // Pre-fix the manual `counter.fetch_sub` after
    // `runner_c.run().await` ran ONLY in the happy-path return,
    // leaking the slot on every panic тАФ after
    // `max_concurrent_connections` panics the listener refused
    // every subsequent client with 503 (redteam ┬з1).  And the
    // global cap was the only DoS guard тАФ a single attacker IP
    // saturated all 10 000 slots in one box (redteam ┬з10).
    //
    // The RAII pattern uses Verum's existing primitives тАФ
    // `Shared<AtomicInt>` for the counters, language-level Drop
    // for the release.  No new runtime infrastructure; the type
    // system makes both leak classes impossible at compile time.
    let limiter = ConnectionLimiter.new(config.max_concurrent_connections);
    let per_ip = PerIpLimiter.new(config.per_ip_max);

    loop {
        if token.is_cancelled() { break; }
        if draining.load(MemoryOrdering.Acquire) { break; }

        match listener.accept_cancellable(&token).await {
            Err(_cancelled) => break,
            Ok(Err(_e)) => {
                // Back off briefly on listener-level errors (EMFILE
                // etc.) so we don't spin-burn the runtime.
                timer.sleep_ms(10).await;
                continue;
            }
            Ok(Ok((stream, peer))) => {
                // Per-IP throttle BEFORE global slot тАФ fail-fast on
                // hostile peers without burning a global slot.
                let peer_ip = peer.ip();
                let per_ip_slot = match per_ip.try_acquire(&peer_ip) {
                    Some(s) => s,
                    None => {
                        runner.refuse_overloaded(stream).await;
                        continue;
                    }
                };
                let global_slot = match limiter.try_acquire_with_per_ip(per_ip_slot) {
                    Some(t) => t,
                    None => {
                        runner.refuse_overloaded(stream).await;
                        continue;
                    }
                };

                let runner_c = runner.clone();
                let _ = task.spawn(async move {
                    // `_ticket` outlives `runner_c.run` and is dropped
                    // here тАФ even if `run` panics, even if the task is
                    // cancelled, even if a host shutdown unwinds the
                    // future.  The slot release is the type system's
                    // responsibility, not the developer's.
                    let _ticket = global_slot;
                    runner_c.run(stream, peer).await;
                });
            }
        }
    }

    // Graceful drain: wait for in-flight connections to complete up to
    // `drain_grace_ms`. Poll-based тАФ fine for 10k connections (~200
    // ticks/sec shared across one small wait).
    let mut elapsed: Int = 0;
    while limiter.in_flight() > 0 && elapsed < config.drain_grace_ms {
        timer.sleep_ms(50).await;
        elapsed = elapsed + 50;
    }
    Ok(())
}

// =============================================================================
// ConnectionLimiter тАФ RAII slot accounting for accept_loop
// =============================================================================
//
// The accept loop bounds in-flight connections via an atomic counter
// shared between the loop and every spawned per-connection task.
// The counter must decrement on EVERY exit path of the per-conn
// task тАФ return, panic, cancellation, host shutdown тАФ or the
// listener leaks slots and eventually refuses every new client
// with 503 (silent DoS).
//
// Pre-fix the decrement was a manual `counter.fetch_sub(...)` at
// the end of the spawned closure.  Panic paths skipped it.  A
// single panic-prone handler turned the listener into a slow-fuse
// DoS.
//
// Post-fix the counter is wrapped in a `ConnectionLimiter` whose
// `try_acquire` returns a `ConnectionTicket`.  The ticket's
// `Drop` impl unconditionally decrements the counter тАФ Verum's
// language-level Drop runs on every exit path, so the leak
// becomes impossible at compile time.

/// In-flight connection counter with RAII acquire/release.
public type ConnectionLimiter is {
    in_flight: Shared<AtomicInt>,
    max: Int,
};

implement ConnectionLimiter {
    /// Create a limiter that admits up to `max` concurrent connections.
    public fn new(max: Int) -> ConnectionLimiter {
        ConnectionLimiter {
            in_flight: Shared.new(AtomicInt.new(0)),
            max: max,
        }
    }

    /// Try to acquire a global slot.  Returns `None` when the
    /// limiter is at capacity тАФ caller emits a 503 / refuses the
    /// connection.  On `Some(ticket)`, the slot is reserved until
    /// the ticket is dropped.
    public fn try_acquire(&self) -> Maybe<ConnectionTicket> {
        let cur = self.in_flight.fetch_add(1, MemoryOrdering.AcqRel) + 1;
        if cur > self.max {
            // Race-loser: roll back the optimistic increment
            // immediately and reject.
            self.in_flight.fetch_sub(1, MemoryOrdering.AcqRel);
            None
        } else {
            Some(ConnectionTicket {
                in_flight: self.in_flight.clone(),
                per_ip_slot: None,
            })
        }
    }

    /// Try to acquire a global slot with a pre-acquired per-IP
    /// slot bundled in.  The ticket's Drop releases both тАФ global
    /// counter first, then per-IP тАФ atomically.  When the global
    /// acquire fails, the caller is responsible for releasing the
    /// already-acquired per-IP slot via `drop(per_ip_slot)`; we
    /// release it here on the race-loss path so callers don't
    /// have to thread the cleanup.
    public fn try_acquire_with_per_ip(
        &self,
        per_ip_slot: Shared<AtomicInt>,
    ) -> Maybe<ConnectionTicket> {
        let cur = self.in_flight.fetch_add(1, MemoryOrdering.AcqRel) + 1;
        if cur > self.max {
            self.in_flight.fetch_sub(1, MemoryOrdering.AcqRel);
            // Caller's per-IP slot was acquired before this call
            // тАФ release it on race-loss so the limiter doesn't
            // leak the per-IP entry.
            per_ip_slot.fetch_sub(1, MemoryOrdering.AcqRel);
            None
        } else {
            Some(ConnectionTicket {
                in_flight: self.in_flight.clone(),
                per_ip_slot: Some(per_ip_slot),
            })
        }
    }

    /// Current in-flight count тАФ for graceful-drain polling.
    public fn in_flight(&self) -> Int {
        self.in_flight.load(MemoryOrdering.Acquire)
    }
}

/// RAII guard for one occupied slot.  Dropping releases the slot.
/// Move-only by design тАФ cloning would double-release.
public type ConnectionTicket is {
    in_flight: Shared<AtomicInt>,
    /// Per-IP slot the ticket also owns (None if per-IP limit
    /// disabled).  The Drop impl releases both atomically тАФ global
    /// slot first, then per-IP тАФ so a panic between releases can
    /// never leak the global slot.
    per_ip_slot: Maybe<Shared<AtomicInt>>,
};

implement Drop for ConnectionTicket {
    fn drop(&mut self) {
        self.in_flight.fetch_sub(1, MemoryOrdering.AcqRel);
        if let Some(slot) = &self.per_ip_slot {
            slot.fetch_sub(1, MemoryOrdering.AcqRel);
        }
    }
}

// =============================================================================
// PerIpLimiter тАФ close redteam ┬з10 single-source DoS surface
// =============================================================================
//
// Pre-fix the listener had only a *global* `max_concurrent_connections`
// cap.  A single attacker IP could open all 10 000 slots from one
// box, shutting out every legitimate client.  The DoS surface
// included everyone NAT'd behind the same egress.
//
// Post-fix `PerIpLimiter` keys an `AtomicInt` per peer-IP via a
// `Shared<Map<IpAddr, Shared<AtomicInt>>>`.  The check fires
// BEFORE `task.spawn` so attackers can't even sustain the per-conn
// task-spawn cost.  Eviction: when the per-IP counter reaches 0,
// the map entry is reaped on next access (no background sweeper тАФ
// the lazy-evict pattern keeps the limiter zero-cost during steady
// state).
//
// `per_ip_max == 0` disables the limiter entirely тАФ recommended
// only on internal services where peer IPs are trusted.

public type PerIpLimiter is {
    counters: Shared<core.collections.map.Map<IpAddr, Shared<AtomicInt>>>,
    max: Int,
};

implement PerIpLimiter {
    /// Build a limiter with `max` concurrent slots per peer-IP.
    /// `max == 0` makes every `acquire` succeed unconditionally
    /// (limiter disabled).
    public fn new(max: Int) -> PerIpLimiter {
        PerIpLimiter {
            counters: Shared.new(core.collections.map.Map.new()),
            max: max,
        }
    }

    /// Try to acquire one slot for `peer`.  Returns `None` when
    /// the peer-IP has already saturated its budget; caller emits
    /// 503 + close.  On `Some(slot)` the caller stores the
    /// `Shared<AtomicInt>` inside the connection's `Ticket` so
    /// Drop releases it.
    public fn try_acquire(&self, peer: &IpAddr) -> Maybe<Shared<AtomicInt>> {
        if self.max <= 0 {
            // Disabled тАФ return a dummy slot the ticket will
            // decrement on Drop with no observable effect.
            return Some(Shared.new(AtomicInt.new(1)));
        }
        // Look up or create the counter for this IP.
        let mut map = self.counters.borrow_mut();
        let slot = match map.get(peer) {
            Some(s) => s.clone(),
            None => {
                let s = Shared.new(AtomicInt.new(0));
                map.insert(peer.clone(), s.clone());
                s
            }
        };
        let cur = slot.fetch_add(1, MemoryOrdering.AcqRel) + 1;
        if cur > self.max {
            // Race-loser: roll back the optimistic increment.
            slot.fetch_sub(1, MemoryOrdering.AcqRel);
            None
        } else {
            Some(slot)
        }
    }
}

// =============================================================================
// Server<H> тАФ plain TCP HTTP/1.1 server
// =============================================================================

/// Bound listener + shared `Handler`. Call `.serve().await` to run
/// until cancellation. Two-phase shutdown (┬з7.8):
///
///   1. `begin_drain()` тАФ stop accepting new connections, mark the
///      draining flag so existing keep-alive connections stamp
///      `Connection: close` on their next response.
///   2. `shutdown()`    тАФ both `begin_drain()` and token cancel;
///      after `drain_grace_ms` any still-running handler is dropped.
public type Server<H> is {
    listener: TcpListener,
    app: Heap<H>,
    config: ListenerConfig,
    token: CancellationToken,
    draining: Shared<AtomicBool>,
};

implement<H: Handler + Send + Sync + 'static> Server<H> {
    /// Bind a TCP listener and wrap it with the given handler
    /// (typically a `Router`). Honours `config.reuseport`.
    public fn bind(addr: Text, app: H, config: ListenerConfig) -> Result<Server<H>, Text> {
        let listener_res = if config.reuseport {
            TcpListener.bind_reuseport(addr)
        } else {
            TcpListener.bind(addr)
        };
        match listener_res {
            Err(e) => Err(f"bind failed: {e}"),
            Ok(listener) => Ok(Server {
                listener: listener,
                app: Heap.new(app),
                config: config,
                token: CancellationToken.new(),
                draining: Shared.new(AtomicBool.new(false)),
            }),
        }
    }

    public fn local_addr(&self) -> Result<SocketAddr, Text> {
        self.listener.local_addr().map_err(|e| f"{e}")
    }

    public fn shutdown_token(&self) -> CancellationToken {
        self.token.clone()
    }

    public fn drain_handle(&self) -> Shared<AtomicBool> {
        self.draining.clone()
    }

    /// Phase-1 shutdown: stop accepting new connections, signal
    /// keep-alive connections to stamp `Connection: close` next.
    public fn begin_drain(&self) {
        self.draining.store(true, MemoryOrdering.Release);
    }

    /// Full shutdown: drain + token cancel. Running handlers see
    /// cancellation on their next await point.
    public fn shutdown(&self) {
        self.begin_drain();
        self.token.cancel();
    }

    /// Run until the token fires or the listener drains.
    public async fn serve(self) -> Result<(), Text> {
        let Server { listener, app, config, token, draining } = self;
        let runner = PlainHttp1Runner.new(
            app,
            token.clone(),
            draining.clone(),
            config.connection.clone(),
        );
        accept_loop(listener, config, token, draining, runner).await
    }
}
