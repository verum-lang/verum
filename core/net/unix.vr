// =============================================================================
// net/unix.vr — AF_UNIX / Unix-domain sockets
// =============================================================================
// Layer: 5 (Network)
// Dependencies: core, io, net/addr, sys/{linux,darwin}
// =============================================================================
//
// POSIX Unix-domain sockets — local IPC via filesystem or abstract namespace.
// Zero-network overhead; per-process-credentials; fd-passing via SCM_RIGHTS.
//
// # Use cases
//
// - Sidecar IPC (SPIFFE spire-agent, Vault agent, Envoy admin API).
// - Database-local transport (PostgreSQL /var/run/postgresql/.s.PGSQL.5432,
//   MySQL /var/run/mysqld/mysqld.sock).
// - Systemd-socket-activation + FD handoff for zero-downtime reloads
//   (net-framework.md §7.8).
// - In-process process-separation (unit-test harness fork-and-communicate).
//
// # Platforms
//
// - Linux: full support including abstract namespace (`\0`-prefixed path),
//   SO_PEERCRED for peer UID/GID/PID.
// - macOS: filesystem paths only; LOCAL_PEERCRED for peer cred.
// - Windows: AF_UNIX supported since Windows 10 1803. Minimal support;
//   gated behind `@cfg(feature = "windows_unix_sockets")`.
//
// =============================================================================

module core.net.unix;

mount core.*;
mount io.*;
mount core.io.async_protocols.{AsyncRead, AsyncWrite};
mount core.async.poll.{Poll};
mount core.async.waker.{Context};
mount core.async.future.{Future};
mount core.async.stream.{Stream, StreamNext};
mount core.async.async_iterator.{AsyncIterator};
mount core.async.cancellation.{CancellationToken, CancellationError};
mount core.net.tcp.{AsyncIoReady};

@cfg(target_os = "linux")
mount core.sys.linux.syscall.{
    socket, connect, bind, listen, accept, accept4,
    send, recv, shutdown, close,
    set_nonblocking, set_reuseaddr,
    AF_UNIX, SOCK_STREAM, SOCK_CLOEXEC, SOCK_NONBLOCK,
};

@cfg(target_os = "macos")
mount core.sys.darwin.libsystem.{
    sys_socket, sys_connect, sys_bind, sys_listen, sys_accept,
    sys_send, sys_recv, sys_shutdown, sys_close,
    safe_set_nonblocking, safe_set_reuseaddr, safe_set_nosigpipe,
    AF_UNIX, SOCK_STREAM,
};

// =============================================================================
// Errors
// =============================================================================

/// Error from AF_UNIX operations.
public type UnixError is
    | IoError(Text)
    | PathTooLong { limit: Int, actual: Int }
    | InvalidPath(Text)
    | PermissionDenied
    | PathInUse(Text)
    | NotFound(Text)
    | PeerClosed;

implement UnixError {
    public fn from_os_error(e: OsError) -> UnixError {
        match e.code {
            1 => UnixError.PermissionDenied,           // EPERM
            2 => UnixError.NotFound(f"{e}"),           // ENOENT
            13 => UnixError.PermissionDenied,          // EACCES
            17 => UnixError.PathInUse(f"{e}"),         // EEXIST
            _ => UnixError.IoError(f"{e}"),
        }
    }
}

// =============================================================================
// sockaddr_un — POSIX Unix-domain address
// =============================================================================
//
// struct sockaddr_un {
//     sa_family_t sun_family;   // 2 bytes, AF_UNIX
//     char sun_path[108];       // Linux; macOS is 104
// };
//
// Total size differs per platform. Linux supports "abstract namespace" via a
// leading null byte in sun_path — not visible on filesystem, auto-cleaned on
// socket close. macOS does not support abstract namespace.

@cfg(target_os = "linux")
const SUN_PATH_MAX: Int = 108;

@cfg(target_os = "macos")
const SUN_PATH_MAX: Int = 104;

@cfg(target_os = "windows")
const SUN_PATH_MAX: Int = 108;

/// Serialize an AF_UNIX path to sockaddr_un bytes.
///
/// Supports:
/// - Filesystem path: `"/tmp/spire-agent.sock"` (null-terminated in sun_path)
/// - Linux abstract namespace: `"\0my-service"` (leading null byte)
fn serialize_unix_addr(path: &Text) -> Result<List<Byte>, UnixError> {
    let path_bytes = path.as_bytes();
    if path_bytes.len() >= SUN_PATH_MAX {
        return Err(UnixError.PathTooLong {
            limit: SUN_PATH_MAX,
            actual: path_bytes.len(),
        });
    }
    if path_bytes.len() == 0 {
        return Err(UnixError.InvalidPath("empty path".into()));
    }

    // struct sockaddr_un layout, platform-specific (task #5):
    //   Linux/Windows: { u16 sun_family_le; char sun_path[SUN_PATH_MAX]; }
    //   macOS (BSD):   { u8  sun_len; u8 sun_family; char sun_path[104]; }
    let mut buf = List.with_capacity(2 + path_bytes.len() + 1);

    @cfg(target_os = "macos")
    {
        // sun_len = 2-byte header + path bytes + null terminator.
        // The kernel's max sun_len is 255 (u8), and SUN_PATH_MAX=104
        // on macOS so path_bytes.len() < 104 is enforced above —
        // sun_len cannot exceed 2+104+1=107 < 255.
        let sun_len = (2 + path_bytes.len() + 1) as Byte;
        buf.push(sun_len);
        buf.push(AF_UNIX as Byte);
    }
    @cfg(any(target_os = "linux", target_os = "windows"))
    {
        // POSIX: sun_family is u16 little-endian — AF_UNIX = 1.
        buf.push(AF_UNIX as Byte);
        buf.push(0);
    }

    for b in path_bytes {
        buf.push(*b);
    }
    // Null-terminate filesystem paths. Abstract-namespace paths have
    // leading null byte, so null-termination is still useful (kernel
    // treats trailing null as end-of-name).
    buf.push(0);
    Ok(buf)
}

// =============================================================================
// UnixStream
// =============================================================================

/// A Unix-domain stream socket (SOCK_STREAM). Byte-stream IPC with
/// reliable, in-order delivery.
public type UnixStream is {
    fd: FileDesc,
    // Peer path captured at connect/accept-time for display/debugging.
    // None for socketpair(2)-constructed streams.
    peer_path: Maybe<Text>,
};

implement UnixStream {
    /// Connect to a Unix-domain server listening at `path`.
    ///
    /// Synchronous variant — blocks until connect completes or errors.
    /// Use `connect_async` in async contexts for non-blocking behavior.
    public fn connect(path: &Text) -> Result<UnixStream, UnixError> {
        let fd = create_unix_socket()?;
        let addr = serialize_unix_addr(path)?;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = connect(fd, addr.as_ptr() as &unsafe Byte, addr.len() as Int);
        @cfg(target_os = "macos")
        let r = sys_connect(fd, addr.as_ptr() as &unsafe Byte, addr.len() as Int);

        match r {
            Ok(()) => Ok(UnixStream { fd: fd, peer_path: Some(path.clone()) }),
            Err(e) => {
                close_fd(fd);
                Err(UnixError.from_os_error(e))
            }
        }
    }

    /// Async connect.
    pub async fn connect_async(path: &Text) -> Result<UnixStream, UnixError> {
        let fd = create_unix_socket_nonblocking()?;
        let addr = serialize_unix_addr(path)?;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = connect(fd, addr.as_ptr() as &unsafe Byte, addr.len() as Int);
        @cfg(target_os = "macos")
        let r = sys_connect(fd, addr.as_ptr() as &unsafe Byte, addr.len() as Int);

        // AF_UNIX connect is usually synchronous on the kernel side, but
        // on Linux EINPROGRESS is still possible under very high server
        // load — handle it by waiting for write-readiness.
        match r {
            Ok(()) => Ok(UnixStream { fd: fd, peer_path: Some(path.clone()) }),
            Err(e) if e.code == 115 /* EINPROGRESS */ => {
                AsyncIoReady.writable(fd).await;
                Ok(UnixStream { fd: fd, peer_path: Some(path.clone()) })
            }
            Err(e) => {
                close_fd(fd);
                Err(UnixError.from_os_error(e))
            }
        }
    }

    /// Peer path (from connect/accept) if known.
    public fn peer_addr(&self) -> Maybe<&Text> {
        self.peer_path.as_ref()
    }

    /// Underlying raw file descriptor for advanced operations
    /// (setsockopt, getsockopt, sendmsg, etc.).
    public fn as_raw_fd(&self) -> FileDesc {
        self.fd
    }

    /// Graceful shutdown of one or both directions.
    public fn shutdown(&self, how: ShutdownKind) -> Result<(), UnixError> {
        let how_int = match how {
            ShutdownKind.Read => 0,   // SHUT_RD
            ShutdownKind.Write => 1,  // SHUT_WR
            ShutdownKind.Both => 2,   // SHUT_RDWR
        };
        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = shutdown(self.fd, how_int);
        @cfg(target_os = "macos")
        let r = sys_shutdown(self.fd, how_int);
        r.map_err(UnixError.from_os_error)
    }
}

/// Direction for graceful shutdown.
public type ShutdownKind is
    | Read     // SHUT_RD
    | Write    // SHUT_WR
    | Both;    // SHUT_RDWR

// Sync Read/Write

implement Read for UnixStream {
    fn read(&mut self, buf: &mut [Byte]) -> Result<Int, IoError> {
        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = {
            const MSG_NOSIGNAL: Int = 0x4000;
            recv(self.fd, buf, MSG_NOSIGNAL).map_err(IoError.from_os)
        };
        @cfg(target_os = "macos")
        let r = sys_recv(self.fd, buf, 0).map_err(IoError.from_os);
        r
    }
}

implement Write for UnixStream {
    fn write(&mut self, buf: &[Byte]) -> Result<Int, IoError> {
        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = {
            const MSG_NOSIGNAL: Int = 0x4000;
            send(self.fd, buf, MSG_NOSIGNAL).map_err(IoError.from_os)
        };
        @cfg(target_os = "macos")
        let r = sys_send(self.fd, buf, 0).map_err(IoError.from_os);
        r
    }

    fn flush(&mut self) -> Result<(), IoError> {
        Ok(())   // no application-level buffering
    }
}

// Async Read/Write — mirrors TcpStream pattern.

implement AsyncRead for UnixStream {
    fn poll_read(&mut self, cx: &mut Context, buf: &mut List<Int>) -> Poll<Result<Int, IoError>> {
        let cap = buf.capacity();
        let mut byte_buf = [0_u8; 65536];
        let read_len = if cap < 65536 { cap } else { 65536 };
        if read_len == 0 {
            return Poll.Ready(Ok(0));
        }

        @cfg(any(target_os = "linux", target_os = "windows"))
        let result = {
            const MSG_NOSIGNAL: Int = 0x4000;
            const MSG_DONTWAIT: Int = 0x40;
            recv(self.fd, &mut byte_buf[..read_len], MSG_NOSIGNAL | MSG_DONTWAIT)
        };
        @cfg(target_os = "macos")
        let result = sys_recv(self.fd, &mut byte_buf[..read_len], 0x80);

        match result {
            Ok(n) => {
                for i in 0..n as Int { buf.push(byte_buf[i] as Int); }
                Poll.Ready(Ok(n as Int))
            }
            Err(e) if e.would_block() => {
                let io_engine = IOEngine.current();
                io_engine.register(self.fd, IOInterest.Read, cx.waker());
                Poll.Pending
            }
            Err(e) => Poll.Ready(Err(IoError.from_os(e))),
        }
    }
}

implement AsyncWrite for UnixStream {
    fn poll_write(&mut self, cx: &mut Context, buf: &List<Int>) -> Poll<Result<Int, IoError>> {
        if buf.is_empty() {
            return Poll.Ready(Ok(0));
        }

        let mut byte_buf = [0_u8; 65536];
        let write_len = if buf.len() < 65536 { buf.len() } else { 65536 };
        for i in 0..write_len { byte_buf[i] = (buf[i] & 0xFF) as u8; }

        @cfg(any(target_os = "linux", target_os = "windows"))
        let result = {
            const MSG_NOSIGNAL: Int = 0x4000;
            const MSG_DONTWAIT: Int = 0x40;
            send(self.fd, &byte_buf[..write_len], MSG_NOSIGNAL | MSG_DONTWAIT)
        };
        @cfg(target_os = "macos")
        let result = sys_send(self.fd, &byte_buf[..write_len], 0x80);

        match result {
            Ok(n) => Poll.Ready(Ok(n as Int)),
            Err(e) if e.would_block() => {
                let io_engine = IOEngine.current();
                io_engine.register(self.fd, IOInterest.Write, cx.waker());
                Poll.Pending
            }
            Err(e) => Poll.Ready(Err(IoError.from_os(e))),
        }
    }

    fn poll_flush(&mut self, _cx: &mut Context) -> Poll<Result<(), IoError>> {
        Poll.Ready(Ok(()))
    }

    fn poll_shutdown(&mut self, _cx: &mut Context) -> Poll<Result<(), IoError>> {
        match self.shutdown(ShutdownKind.Write) {
            Ok(()) => Poll.Ready(Ok(())),
            Err(e) => Poll.Ready(Err(IoError.Other(f"{e}"))),
        }
    }
}

// Ergonomic async wrappers + cancellable variants (mirror TcpStream).

implement UnixStream {
    pub async fn read_async(&mut self, buf: &mut List<Int>) -> Result<Int, IoError> {
        let mut fut = UnixReadFut { stream: self, buf: buf };
        fut.await
    }

    pub async fn write_async(&mut self, buf: &List<Int>) -> Result<Int, IoError> {
        let mut fut = UnixWriteFut { stream: self, buf: buf };
        fut.await
    }

    pub async fn read_cancellable(
        &mut self,
        buf: &mut List<Int>,
        token: &CancellationToken,
    ) -> Result<Result<Int, IoError>, CancellationError> {
        select {
            r = self.read_async(buf).await => Ok(r),
            reason = token.cancelled().await => Err(CancellationError.new(reason)),
        }
    }

    pub async fn write_cancellable(
        &mut self,
        buf: &List<Int>,
        token: &CancellationToken,
    ) -> Result<Result<Int, IoError>, CancellationError> {
        select {
            r = self.write_async(buf).await => Ok(r),
            reason = token.cancelled().await => Err(CancellationError.new(reason)),
        }
    }
}

public type UnixReadFut<'a> is {
    stream: &'a mut UnixStream,
    buf: &'a mut List<Int>,
};

implement<'a> Future for UnixReadFut<'a> {
    type Output = Result<Int, IoError>;
    fn poll(&mut self, cx: &mut Context) -> Poll<Result<Int, IoError>> {
        self.stream.poll_read(cx, self.buf)
    }
}

public type UnixWriteFut<'a> is {
    stream: &'a mut UnixStream,
    buf: &'a List<Int>,
};

implement<'a> Future for UnixWriteFut<'a> {
    type Output = Result<Int, IoError>;
    fn poll(&mut self, cx: &mut Context) -> Poll<Result<Int, IoError>> {
        self.stream.poll_write(cx, self.buf)
    }
}

implement Drop for UnixStream {
    fn drop(&mut self) {
        close_fd(self.fd);
    }
}

// =============================================================================
// UnixListener
// =============================================================================

const DEFAULT_BACKLOG: Int = 128;

/// Server-side listener bound to a filesystem or abstract path.
public type UnixListener is {
    fd: FileDesc,
    local_path: Text,
};

implement UnixListener {
    /// Bind a listener to `path`. Default backlog 128.
    ///
    /// For filesystem paths, the file at `path` must not pre-exist — call
    /// `std.fs.remove_file(path)` before bind if recovery-after-crash
    /// matters, or use the Linux abstract namespace (`"\0name"`) which
    /// auto-cleans on close.
    public fn bind(path: &Text) -> Result<UnixListener, UnixError> {
        UnixListener.bind_with_backlog(path, DEFAULT_BACKLOG)
    }

    public fn bind_with_backlog(path: &Text, backlog: Int) -> Result<UnixListener, UnixError> {
        let fd = create_unix_socket()?;
        let addr = serialize_unix_addr(path)?;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = bind(fd, addr.as_ptr() as &unsafe Byte, addr.len() as Int);
        @cfg(target_os = "macos")
        let r = sys_bind(fd, addr.as_ptr() as &unsafe Byte, addr.len() as Int);

        if let Err(e) = r {
            close_fd(fd);
            return Err(UnixError.from_os_error(e));
        }

        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = listen(fd, backlog);
        @cfg(target_os = "macos")
        let r = sys_listen(fd, backlog);

        if let Err(e) = r {
            close_fd(fd);
            return Err(UnixError.from_os_error(e));
        }

        Ok(UnixListener { fd: fd, local_path: path.clone() })
    }

    /// Synchronous accept (blocks).
    public fn accept(&self) -> Result<(UnixStream, Maybe<Text>), UnixError> {
        let mut addr_buf = [0_u8; SUN_PATH_MAX + 2];
        let mut addr_len: Int = SUN_PATH_MAX + 2;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = accept4(self.fd, &mut addr_buf, &mut addr_len, SOCK_CLOEXEC);
        @cfg(target_os = "macos")
        let r = sys_accept(self.fd, &mut addr_buf, &mut addr_len);

        match r {
            Ok(client_fd) => {
                let peer = deserialize_unix_path(&addr_buf[..addr_len as Int]);
                Ok((UnixStream { fd: client_fd, peer_path: peer.clone() }, peer))
            }
            Err(e) => Err(UnixError.from_os_error(e)),
        }
    }

    /// Async accept — awaits readability via I/O engine.
    pub async fn accept_async(&self) -> Result<(UnixStream, Maybe<Text>), UnixError> {
        loop {
            let mut addr_buf = [0_u8; SUN_PATH_MAX + 2];
            let mut addr_len: Int = SUN_PATH_MAX + 2;

            @cfg(any(target_os = "linux", target_os = "windows"))
            let r = accept4(self.fd, &mut addr_buf, &mut addr_len,
                            SOCK_CLOEXEC | SOCK_NONBLOCK);
            @cfg(target_os = "macos")
            let r = sys_accept(self.fd, &mut addr_buf, &mut addr_len);

            match r {
                Ok(client_fd) => {
                    @cfg(target_os = "macos")
                    let _ = safe_set_nonblocking(client_fd, true);

                    let peer = deserialize_unix_path(&addr_buf[..addr_len as Int]);
                    return Ok((UnixStream { fd: client_fd, peer_path: peer.clone() }, peer));
                }
                Err(e) if e.would_block() => {
                    AsyncIoReady.readable(self.fd).await;
                    continue;
                }
                Err(e) => return Err(UnixError.from_os_error(e)),
            }
        }
    }

    public fn local_addr(&self) -> &Text {
        &self.local_path
    }

    public fn as_raw_fd(&self) -> FileDesc {
        self.fd
    }

    /// Cancellable async accept.
    pub async fn accept_cancellable(
        &self,
        token: &CancellationToken,
    ) -> Result<Result<(UnixStream, Maybe<Text>), UnixError>, CancellationError> {
        select {
            r = self.accept_async().await => Ok(r),
            reason = token.cancelled().await => Err(CancellationError.new(reason)),
        }
    }

    /// Async-stream of incoming connections.
    public fn incoming_async(&self) -> UnixIncoming {
        UnixIncoming { listener: self }
    }
}

implement Drop for UnixListener {
    fn drop(&mut self) {
        close_fd(self.fd);
        // Note: filesystem-path sockets leave the inode behind after
        // close(); caller responsibility to unlink if needed. Abstract-
        // namespace paths (Linux) auto-clean on close — nothing to do.
    }
}

// =============================================================================
// UnixIncoming — Stream<Item = Result<UnixStream, UnixError>> + AsyncIterator
// =============================================================================

public type UnixIncoming<'a> is {
    listener: &'a UnixListener,
};

implement<'a> Stream for UnixIncoming<'a> {
    type Item = Result<UnixStream, UnixError>;

    fn poll_next(&mut self, cx: &mut Context) -> Poll<Maybe<Result<UnixStream, UnixError>>> {
        let mut addr_buf = [0_u8; SUN_PATH_MAX + 2];
        let mut addr_len: Int = SUN_PATH_MAX + 2;

        @cfg(any(target_os = "linux", target_os = "windows"))
        let r = accept4(self.listener.fd, &mut addr_buf, &mut addr_len,
                        SOCK_CLOEXEC | SOCK_NONBLOCK);
        @cfg(target_os = "macos")
        let r = sys_accept(self.listener.fd, &mut addr_buf, &mut addr_len);

        match r {
            Ok(client_fd) => {
                @cfg(target_os = "macos")
                let _ = safe_set_nonblocking(client_fd, true);
                let peer = deserialize_unix_path(&addr_buf[..addr_len as Int]);
                Poll.Ready(Some(Ok(UnixStream { fd: client_fd, peer_path: peer })))
            }
            Err(e) if e.would_block() => {
                let io_engine = IOEngine.current();
                io_engine.register(self.listener.fd, IOInterest.Read, cx.waker());
                Poll.Pending
            }
            Err(e) => Poll.Ready(Some(Err(UnixError.from_os_error(e)))),
        }
    }
}

implement<'a> AsyncIterator for UnixIncoming<'a> {
    type Item = Result<UnixStream, UnixError>;

    @inline
    async fn next(&mut self) -> Maybe<Result<UnixStream, UnixError>> {
        StreamNext { stream: self }.await
    }
}

// =============================================================================
// Internal helpers
// =============================================================================

fn create_unix_socket() -> Result<FileDesc, UnixError> {
    @cfg(any(target_os = "linux", target_os = "windows"))
    let fd = socket(AF_UNIX, SOCK_STREAM | SOCK_CLOEXEC, 0)
        .map_err(UnixError.from_os_error)?;
    @cfg(target_os = "macos") {
        let fd = sys_socket(AF_UNIX, SOCK_STREAM, 0).map_err(UnixError.from_os_error)?;
        let _ = safe_set_nosigpipe(fd, true);
        fd
    }
    Ok(fd)
}

fn create_unix_socket_nonblocking() -> Result<FileDesc, UnixError> {
    @cfg(any(target_os = "linux", target_os = "windows"))
    let fd = socket(AF_UNIX, SOCK_STREAM | SOCK_CLOEXEC | SOCK_NONBLOCK, 0)
        .map_err(UnixError.from_os_error)?;
    @cfg(target_os = "macos") {
        let fd = sys_socket(AF_UNIX, SOCK_STREAM, 0).map_err(UnixError.from_os_error)?;
        let _ = safe_set_nosigpipe(fd, true);
        let _ = safe_set_nonblocking(fd, true).map_err(UnixError.from_os_error)?;
        fd
    }
    Ok(fd)
}

@inline
fn close_fd(fd: FileDesc) {
    @cfg(any(target_os = "linux", target_os = "windows"))
    let _ = close(fd);
    @cfg(target_os = "macos")
    let _ = sys_close(fd);
}

/// Reconstruct the path from a sockaddr_un buffer. Returns None when the
/// peer is anonymous (e.g., socketpair peers have empty address).
fn deserialize_unix_path(buf: &[Byte]) -> Maybe<Text> {
    if buf.len() < 2 { return None; }
    let path_bytes = &buf[2..];
    // Find length: either null-terminated (filesystem) or whole buf
    // (abstract namespace, which starts with `\0`).
    if path_bytes.len() == 0 || (path_bytes[0] == 0 && path_bytes.len() == 1) {
        return None;
    }
    // Trim trailing nulls for filesystem paths.
    let mut end = path_bytes.len();
    while end > 0 && path_bytes[end - 1] == 0 { end = end - 1; }
    if end == 0 { return None; }
    match Text.from_utf8(&path_bytes[..end]) {
        Ok(t) => Some(t),
        Err(_) => None,
    }
}

// =============================================================================
// Peer credentials — SO_PEERCRED (Linux) / LOCAL_PEERCRED (macOS)
// =============================================================================
//
// Kernel-verified identity of the process on the other end. Useful for
// local-only authorization (e.g., "only accept from UID 0 for admin API").

/// Peer process identity from the kernel.
public type PeerCred is {
    pid: Int32,
    uid: UInt32,
    gid: UInt32,
};

implement UnixStream {
    /// Query the peer's kernel-verified (PID, UID, GID). Works only on
    /// AF_UNIX SOCK_STREAM connections; not available over socketpair or
    /// on Windows.
    @cfg(target_os = "linux")
    public fn peer_cred(&self) -> Result<PeerCred, UnixError> {
        // struct ucred { pid_t pid; uid_t uid; gid_t gid; }; — 12 bytes
        // SOL_SOCKET = 1, SO_PEERCRED = 17
        const SOL_SOCKET: Int = 1;
        const SO_PEERCRED: Int = 17;
        let mut buf = [0_u8; 12];
        let mut len: Int = 12;
        @intrinsic("libc.getsockopt")
        fn getsockopt(fd: Int, level: Int, optname: Int, val: &mut Byte, len: &mut Int) -> Int;
        let rc = getsockopt(self.fd, SOL_SOCKET, SO_PEERCRED,
                            &mut buf[0], &mut len);
        if rc != 0 {
            return Err(UnixError.IoError("SO_PEERCRED failed".into()));
        }
        let pid = ((buf[0] as Int32)
                 | ((buf[1] as Int32) << 8)
                 | ((buf[2] as Int32) << 16)
                 | ((buf[3] as Int32) << 24));
        let uid = ((buf[4] as UInt32)
                 | ((buf[5] as UInt32) << 8)
                 | ((buf[6] as UInt32) << 16)
                 | ((buf[7] as UInt32) << 24));
        let gid = ((buf[8] as UInt32)
                 | ((buf[9] as UInt32) << 8)
                 | ((buf[10] as UInt32) << 16)
                 | ((buf[11] as UInt32) << 24));
        Ok(PeerCred { pid: pid, uid: uid, gid: gid })
    }

    @cfg(target_os = "macos")
    public fn peer_cred(&self) -> Result<PeerCred, UnixError> {
        // macOS: LOCAL_PEERCRED returns struct xucred, shape differs.
        // Minimal-scope helper left to a follow-up.
        Err(UnixError.IoError("peer_cred: macOS impl deferred".into()))
    }

    @cfg(target_os = "windows")
    public fn peer_cred(&self) -> Result<PeerCred, UnixError> {
        Err(UnixError.IoError("peer_cred: not available on Windows".into()))
    }
}

// =============================================================================
// FD-passing via SCM_RIGHTS
// =============================================================================
//
// POSIX ancillary data sent alongside normal bytes over SOCK_STREAM. The
// kernel atomically installs the FD in the receiving process's file
// descriptor table. Used for:
//   - Graceful shutdown socket hand-off (Cloudflare / HAProxy pattern):
//     old process sends its listen-FD to the new process; new process
//     calls listen() on the inherited FD and accepts without dropping
//     in-flight connections.
//   - Privilege-separation IPC (one process opens /dev/...; passes FD to
//     unprivileged worker).
//   - systemd socket activation: systemd opens sockets; forked service
//     inherits them by FD number.
//
// NOTE — implementation pending: requires `extern "C" fn sendmsg/recvmsg`
// bindings with cmsghdr layout, which needs careful per-platform sizing
// of the cmsghdr structure (Linux cmsg_len is size_t vs ptr-alignment).
// Left as follow-up task; see net-framework.md §7.8.

public type FdPassingError is
    | NotImplemented(Text)
    | ControlBufferTooSmall { need: Int, have: Int }
    | Malformed(Text);

implement UnixStream {
    /// Send `buf` plus file descriptors `fds` over this stream. The
    /// receiving side retrieves them via `recv_fds`.
    ///
    /// Currently stubbed — returns `Err(NotImplemented)`. Tracked as
    /// follow-up (net-framework.md §7.8 graceful-shutdown FD handoff).
    public fn send_fds(&self, _buf: &[Byte], _fds: &[FileDesc])
        -> Result<Int, FdPassingError>
    {
        Err(FdPassingError.NotImplemented(
            "SCM_RIGHTS sendmsg implementation pending — see net-framework.md §7.8".into()
        ))
    }

    /// Receive bytes plus any file descriptors passed as SCM_RIGHTS.
    public fn recv_fds(&self, _buf: &mut [Byte], _fds: &mut List<FileDesc>)
        -> Result<Int, FdPassingError>
    {
        Err(FdPassingError.NotImplemented(
            "SCM_RIGHTS recvmsg implementation pending".into()
        ))
    }
}
