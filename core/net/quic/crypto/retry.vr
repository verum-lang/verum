// =============================================================================
// net/quic/crypto/retry.vr — Retry integrity tag (RFC 9001 §5.8)
// =============================================================================
// Layer: 5 (Network — QUIC)
// =============================================================================
//
// RFC 9001 §5.8:
//
//   Retry_Pseudo-Packet ::= {
//       ODCID Length (u8)
//       Original Destination Connection ID (0..160 bits)
//       Retry Packet (bytes without the integrity tag)
//   }
//
//   Retry_Integrity_Tag = AEAD_AES_128_GCM(
//       key   = retry_integrity_key_v1,
//       nonce = retry_integrity_nonce_v1,
//       aad   = Retry_Pseudo-Packet,
//       plaintext = empty,
//   ).tag                                    // 16 bytes
//
// Fixed key + nonce per QUIC version; version 1 values below.
//
// =============================================================================

module core.net.quic.crypto.retry;

mount core.*;
mount core.collections.List;
mount core.security.aead.aes_gcm.{aes128_gcm_seal, aes128_gcm_open, AesGcmError};

/// RFC 9001 §5.8 — key for QUIC v1 retry integrity tag.
public const RETRY_INTEGRITY_KEY_V1: [Byte; 16] = [
    0xbe_u8, 0x0c_u8, 0x69_u8, 0x0b_u8, 0x9f_u8, 0x66_u8, 0x57_u8, 0x5a_u8,
    0x1d_u8, 0x76_u8, 0x6b_u8, 0x54_u8, 0xe3_u8, 0x68_u8, 0xc8_u8, 0x4e_u8,
];

/// RFC 9001 §5.8 — nonce for QUIC v1 retry integrity tag.
public const RETRY_INTEGRITY_NONCE_V1: [Byte; 12] = [
    0x46_u8, 0x15_u8, 0x99_u8, 0xd3_u8, 0x5d_u8, 0x63_u8, 0x2b_u8, 0xf2_u8,
    0x23_u8, 0x98_u8, 0x25_u8, 0xbb_u8,
];

/// Compute the 16-byte retry integrity tag. `pseudo` is the
/// Retry pseudo-packet: ODCID length + ODCID bytes + the Retry
/// packet bytes excluding the integrity tag itself (i.e. all but
/// the last 16 bytes of the wire Retry packet).
public fn compute_retry_integrity_tag(pseudo: &[Byte]) -> Result<[Byte; 16], AesGcmError> {
    // AEAD over empty plaintext; the tag is the only output besides
    // zero-length ciphertext.
    let mut out: List<Byte> = [];
    aes128_gcm_seal(
        &RETRY_INTEGRITY_KEY_V1,
        &RETRY_INTEGRITY_NONCE_V1,
        pseudo,
        &[],          // empty plaintext
        &mut out,
    )?;
    // out = ciphertext (empty) || tag (16). Take the last 16 bytes.
    if out.len() != 16 {
        return Err(AesGcmError.InvalidTagLength { len: out.len() });
    }
    let mut tag: [Byte; 16] = [0_u8; 16];
    let mut i: Int = 0;
    while i < 16 { tag[i] = out[i]; i = i + 1; }
    Ok(tag)
}

/// Verify a Retry packet's integrity tag. `pseudo` is the Retry
/// pseudo-packet (without the tag); `wire_tag` is the 16 trailing
/// bytes taken off the wire.
public fn verify_retry_integrity_tag(pseudo: &[Byte], wire_tag: &[Byte; 16]) -> Bool {
    // Compose (empty ciphertext || wire_tag) and run open — a passing
    // open gives us empty plaintext; a failing tag returns error.
    let mut ciphertext: List<Byte> = [];
    let mut i: Int = 0;
    while i < 16 { ciphertext.push(wire_tag[i]); i = i + 1; }
    let mut out: List<Byte> = [];
    match aes128_gcm_open(
        &RETRY_INTEGRITY_KEY_V1,
        &RETRY_INTEGRITY_NONCE_V1,
        pseudo,
        ciphertext.as_slice(),
        &mut out,
    ) {
        Ok(()) => out.len() == 0,
        Err(_) => false,
    }
}
