// =============================================================================
// net/quic/crypto/labels.vr — QUIC HKDF-Expand-Label constants (RFC 9001)
// =============================================================================
// Layer: 5 (Network — QUIC)
// =============================================================================
//
// QUIC uses TLS 1.3's HKDF-Expand-Label ("tls13 " prefix) for its own
// labels:
//
//   * "client in" / "server in" — per-role initial secret derivation
//     from the top-level initial secret (RFC 9001 §5.2).
//   * "quic key" / "quic iv" — AEAD key / nonce for a given secret.
//   * "quic hp" — header-protection key.
//   * "quic ku" — key update.
//
// The salt for the initial HKDF-Extract is a fixed 20-byte constant
// per QUIC version (RFC 9001 §5.2 — version 1).
//
// =============================================================================

module core.net.quic.crypto.labels;

mount core.*;

/// RFC 9001 §5.2 — initial_salt for QUIC v1 (version 0x00000001).
/// Run through HKDF-Extract with the client Destination CID to
/// produce the initial secret from which per-role secrets derive.
public const QUIC_INITIAL_SALT_V1: [Byte; 20] = [
    0x38_u8, 0x76_u8, 0x2c_u8, 0xf7_u8, 0xf5_u8, 0x59_u8, 0x34_u8, 0xb3_u8,
    0x4d_u8, 0x17_u8, 0x9a_u8, 0xe6_u8, 0xa4_u8, 0xc8_u8, 0x0c_u8, 0xad_u8,
    0xcc_u8, 0xbb_u8, 0x7f_u8, 0x0a_u8,
];

/// "client in" — per-RFC 9001 §5.2, derives the client-side initial
/// secret from the top-level initial secret.
pub const LABEL_CLIENT_IN: [Byte; 9] = [
    0x63_u8, 0x6C_u8, 0x69_u8, 0x65_u8, 0x6E_u8, 0x74_u8, 0x20_u8, 0x69_u8, 0x6E_u8,  // "client in"
];

pub const LABEL_SERVER_IN: [Byte; 9] = [
    0x73_u8, 0x65_u8, 0x72_u8, 0x76_u8, 0x65_u8, 0x72_u8, 0x20_u8, 0x69_u8, 0x6E_u8,  // "server in"
];

/// "quic key" — per-direction AEAD key derivation.
pub const LABEL_QUIC_KEY: [Byte; 8] = [
    0x71_u8, 0x75_u8, 0x69_u8, 0x63_u8, 0x20_u8, 0x6B_u8, 0x65_u8, 0x79_u8,  // "quic key"
];

/// "quic iv" — per-direction AEAD nonce derivation.
pub const LABEL_QUIC_IV: [Byte; 7] = [
    0x71_u8, 0x75_u8, 0x69_u8, 0x63_u8, 0x20_u8, 0x69_u8, 0x76_u8,  // "quic iv"
];

/// "quic hp" — header-protection key derivation.
pub const LABEL_QUIC_HP: [Byte; 7] = [
    0x71_u8, 0x75_u8, 0x69_u8, 0x63_u8, 0x20_u8, 0x68_u8, 0x70_u8,  // "quic hp"
];

/// "quic ku" — key update.
pub const LABEL_QUIC_KU: [Byte; 7] = [
    0x71_u8, 0x75_u8, 0x69_u8, 0x63_u8, 0x20_u8, 0x6B_u8, 0x75_u8,  // "quic ku"
];

/// Initial secrets + derived keys always use SHA-256; Initial
/// packets are encrypted with AES-128-GCM — fixed by RFC 9001 §5.2
/// regardless of the cipher suite later negotiated for Handshake /
/// 1-RTT packets.
pub const INITIAL_KEY_LEN: Int = 16;        // AES-128
pub const INITIAL_IV_LEN:  Int = 12;
pub const INITIAL_HP_LEN:  Int = 16;        // AES-128-ECB for HP masks
