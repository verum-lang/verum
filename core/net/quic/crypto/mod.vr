// =============================================================================
// net/quic/crypto/mod.vr — QUIC-TLS crypto layer (RFC 9001)
// =============================================================================
// Layer: 5 (Network — QUIC)
// Dependencies: core.security.{kdf, aead, cipher}, core.net.tls13.keyschedule
// Spec: internal/specs/tls-quic.md §7.4, §12 Phase 3
// =============================================================================
//
// RFC 9001 binds TLS 1.3 to QUIC via four small protocol-specific
// crypto pieces that don't exist anywhere in the plain TLS stack:
//
//   §5.2  — Initial secret derivation from client Destination CID.
//           A fixed salt + the (plaintext) DCID run through HKDF-Extract
//           to produce per-role Initial secrets.
//
//   §5.4  — Header protection. The first byte's low 4/5 bits and the
//           packet-number bytes are XORed with a 5-byte mask computed
//           from an "HP key" and a 16-byte sample of the ciphertext.
//           Two mask primitives: AES-ECB (for AES-GCM suites) and
//           ChaCha20 (for ChaCha-Poly suites).
//
//   §5.8  — Retry integrity tag. A 16-byte AEAD_AES_128_GCM tag over
//           (original DCID || Retry pseudo-packet) under a fixed key
//           and nonce, per QUIC version.
//
//   §6.1  — Key update. Same HKDF-Expand-Label "traffic upd" as TLS
//           1.3, but applied in concert with QUIC's key-phase bit.
//           Key derivation delegates entirely to
//           core.net.tls13.keyschedule.
//
// # Module layout
//
// ```
// core.net.quic.crypto
// ├── mod.vr                  ← this file (re-exports + facade)
// ├── initial.vr              — RFC 9001 §5.2 initial secret derivation
// ├── header_protection.vr    — RFC 9001 §5.4 HP masks
// ├── retry.vr                — RFC 9001 §5.8 retry integrity
// └── labels.vr               — QUIC HKDF-Expand-Label "quic *" labels
// ```
//
// =============================================================================

module core.net.quic.crypto;

public module labels;
public module initial;
public module header_protection;
public module retry;

// Re-exports
public mount .labels.{
    QUIC_INITIAL_SALT_V1,
    LABEL_CLIENT_IN, LABEL_SERVER_IN,
    LABEL_QUIC_KEY, LABEL_QUIC_IV, LABEL_QUIC_HP, LABEL_QUIC_KU,
};
public mount .initial.{
    InitialSecrets, InitialKeys,
    derive_initial_secrets, derive_initial_keys,
};
public mount .header_protection.{
    HpKey, HpMask, compute_hp_mask,
};
public mount .retry.{
    compute_retry_integrity_tag, verify_retry_integrity_tag,
};
