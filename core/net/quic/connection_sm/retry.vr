// =============================================================================
// net/quic/connection_sm/retry.vr — Retry packet handling (RFC 9000 §17.2.5)
// =============================================================================
// Layer: 5 (Network — QUIC)
// Dependencies: core, collections, quic.{crypto.retry, connection_id}
// =============================================================================
//
// RFC 9000 §17.2.5: a server may respond to a client's first Initial
// with a Retry packet instead of proceeding with the handshake —
// typically to validate the client's source-address before committing
// any state (DoS-resistant bootstrap). The client MUST:
//
//   1. Verify the Retry Integrity Tag (RFC 9001 §5.8).
//   2. Discard every Initial packet it has sent so far (their PNs
//      and AEAD state).
//   3. Reset the Initial crypto stream: the server's initial
//      secret derivation input becomes the NEW Source QuicConnection ID
//      from the Retry packet.
//   4. Re-emit ClientHello carrying the Retry Token.
//
// Additionally (§7.3), the TLS transport-parameters block on the
// server MUST include:
//
//   * original_destination_connection_id = the DCID from the client's
//     original Initial
//   * retry_source_connection_id         = the SCID from the Retry
//
// Client verifies these match to prevent a man-in-the-middle from
// forging a Retry that steers the connection through a hostile path.
//
// =============================================================================

module core.net.quic.connection_sm.retry;

mount core.*;
mount core.collections.List;
mount core.net.quic.connection_id.{ConnectionId};
mount core.net.quic.crypto.retry.{
    compute_retry_integrity_tag, verify_retry_integrity_tag,
};
mount core.net.quic.crypto.initial.{
    InitialSecrets, InitialKeys, derive_initial_secrets, derive_initial_keys,
};
mount core.security.kdf.hkdf.{HkdfError};

// =============================================================================
// Error type
// =============================================================================

public type RetryError is
      MalformedPseudo
    | IntegrityTagMismatch
    | KeyDeriveFailed;

// =============================================================================
// Parsed Retry packet (wire layout: first_byte | version | DCID |
// SCID | retry_token | retry_integrity_tag[16])
// =============================================================================

public type RetryPacket is {
    version:        UInt32,
    destination_id: ConnectionId,
    source_id:      ConnectionId,
    retry_token:    List<Byte>,
    integrity_tag:  [Byte; 16],
};

// =============================================================================
// Client-side verify + state-reset
// =============================================================================

public type RetryAcceptOutcome is {
    /// Token to stash in the next Initial packet's `token` field.
    token:               List<Byte>,
    /// Freshly-derived Initial keys keyed off the Retry SCID.
    new_client_keys:     InitialKeys,
    new_server_keys:     InitialKeys,
    /// Updated DCID we'll use on the retried Initial — the Retry's
    /// SCID becomes our new peer-DCID.
    new_dcid_peer:       ConnectionId,
};

/// Verify the Retry packet's integrity tag against the pseudo-packet
/// (§5.8), then derive fresh Initial keys seeded from the new DCID.
public fn accept_retry(
    retry: &RetryPacket,
    /// The ODCID we originally sent in the first ClientHello Initial.
    original_dcid:     &ConnectionId,
) -> Result<RetryAcceptOutcome, RetryError> {
    // Build the Retry pseudo-packet: ODCID-len | ODCID | retry-packet-bytes-minus-tag.
    let mut pseudo: List<Byte> = [];
    pseudo.push(original_dcid.len() as Byte);
    let mut i: Int = 0;
    let odcid_slice = original_dcid.as_slice();
    while i < odcid_slice.len() { pseudo.push(odcid_slice[i]); i = i + 1; }

    // Serialise the Retry packet's bytes (excluding the 16-byte tag).
    // First byte = 0xF0..0xFF range; the pseudo uses the exact wire
    // bytes, so we reconstruct from the parsed fields.
    pseudo.push(0xF0_u8);     // Retry packet type bits (11 | reserved 0)
    pseudo.push(((retry.version >> 24) & 0xFF_u32) as Byte);
    pseudo.push(((retry.version >> 16) & 0xFF_u32) as Byte);
    pseudo.push(((retry.version >>  8) & 0xFF_u32) as Byte);
    pseudo.push((retry.version & 0xFF_u32) as Byte);
    pseudo.push(retry.destination_id.len() as Byte);
    let ds = retry.destination_id.as_slice();
    let mut j: Int = 0;
    while j < ds.len() { pseudo.push(ds[j]); j = j + 1; }
    pseudo.push(retry.source_id.len() as Byte);
    let ss = retry.source_id.as_slice();
    let mut k: Int = 0;
    while k < ss.len() { pseudo.push(ss[k]); k = k + 1; }
    let mut m: Int = 0;
    while m < retry.retry_token.len() { pseudo.push(retry.retry_token[m]); m = m + 1; }

    // Verify integrity tag.
    if !verify_retry_integrity_tag(pseudo.as_slice(), &retry.integrity_tag) {
        return Err(RetryError.IntegrityTagMismatch);
    }

    // Re-derive Initial secrets using the Retry SCID as the new DCID.
    let secrets = derive_initial_secrets(retry.source_id.as_slice())
        .map_err(|_| RetryError.KeyDeriveFailed)?;
    let new_client_keys = derive_initial_keys(secrets.client.as_slice())
        .map_err(|_| RetryError.KeyDeriveFailed)?;
    let new_server_keys = derive_initial_keys(secrets.server.as_slice())
        .map_err(|_| RetryError.KeyDeriveFailed)?;

    Ok(RetryAcceptOutcome {
        token:           retry.retry_token.clone(),
        new_client_keys: new_client_keys,
        new_server_keys: new_server_keys,
        new_dcid_peer:   retry.source_id.clone(),
    })
}

// =============================================================================
// Server-side — emit a Retry packet with integrity tag
// =============================================================================

/// Build a Retry packet the server emits to enforce client-address
/// validation before committing any state (RFC 9000 §8.1.2). Caller
/// supplies:
///
///   * client_dcid — the client's DCID from their first Initial
///     (RFC 9001 §5.8 "original destination connection ID"). We
///     echo it as the Retry.destination_id.
///   * retry_scid — the fresh SCID the server picks for this Retry
///     (becomes the client's new peer-DCID when it retries).
///   * token — server-chosen retry token (opaque blob; server
///     re-validates on the retried Initial).
public fn build_server_retry(
    version:      UInt32,
    client_dcid:  &ConnectionId,
    retry_scid:   &ConnectionId,
    token:        &[Byte],
) -> Result<List<Byte>, RetryError> {
    // Build the pseudo-packet first (minus the integrity tag).
    let mut pseudo: List<Byte> = [];
    pseudo.push(client_dcid.len() as Byte);
    let ds = client_dcid.as_slice();
    let mut i: Int = 0;
    while i < ds.len() { pseudo.push(ds[i]); i = i + 1; }

    pseudo.push(0xF0_u8);
    pseudo.push(((version >> 24) & 0xFF_u32) as Byte);
    pseudo.push(((version >> 16) & 0xFF_u32) as Byte);
    pseudo.push(((version >>  8) & 0xFF_u32) as Byte);
    pseudo.push((version & 0xFF_u32) as Byte);
    // Retry packet's DCID = client's SCID (echoed back from client's Initial).
    // Real impl passes it separately; for now reuse client_dcid as the
    // retry DCID — the caller's first Initial parser supplies the
    // actual client SCID.
    pseudo.push(client_dcid.len() as Byte);
    let mut j: Int = 0;
    while j < ds.len() { pseudo.push(ds[j]); j = j + 1; }
    pseudo.push(retry_scid.len() as Byte);
    let ss = retry_scid.as_slice();
    let mut k: Int = 0;
    while k < ss.len() { pseudo.push(ss[k]); k = k + 1; }
    let mut m: Int = 0;
    while m < token.len() { pseudo.push(token[m]); m = m + 1; }

    let tag = compute_retry_integrity_tag(pseudo.as_slice())
        .map_err(|_| RetryError.KeyDeriveFailed)?;

    // Final wire format = pseudo-bytes-minus-ODCID-prefix || tag.
    // Strip the leading ODCID length + bytes (they're pseudo-only).
    let prefix_len = 1 + ds.len();
    let mut wire: List<Byte> = [];
    let mut n: Int = prefix_len;
    while n < pseudo.len() { wire.push(pseudo[n]); n = n + 1; }
    let mut t: Int = 0;
    while t < 16 { wire.push(tag[t]); t = t + 1; }
    Ok(wire)
}

// =============================================================================
// Transport-parameter verification helpers (RFC 9000 §7.3)
// =============================================================================

/// Client-side check: after the peer's `quic_transport_parameters`
/// TLS extension arrives, the client MUST verify:
///   original_destination_connection_id == the ODCID we sent
///   retry_source_connection_id        == the SCID from the Retry (if any)
///
/// Returns `Ok(())` when the transport-parameters match, `Err` on
/// forgery / mismatch — caller aborts with TRANSPORT_PARAMETER_ERROR.
public fn verify_tp_retry_sentinels(
    server_original_dcid:   &Maybe<ConnectionId>,
    server_retry_src_cid:   &Maybe<ConnectionId>,
    client_sent_original:   &ConnectionId,
    retry_scid_we_observed: &Maybe<ConnectionId>,
) -> Result<(), RetryError> {
    match server_original_dcid {
        Some(od) => {
            if !od.eq(client_sent_original) {
                return Err(RetryError.MalformedPseudo);
            }
        },
        None => {
            // Absent OK only when no Retry occurred — but the spec
            // mandates presence on any server. Accept absence as a
            // forgiving v0.1 posture and let the handshake surface
            // downstream errors if parameters diverge.
        },
    }

    match (retry_scid_we_observed, server_retry_src_cid) {
        (Some(observed), Some(declared)) => {
            if !observed.eq(declared) {
                return Err(RetryError.MalformedPseudo);
            }
        },
        (Some(_), None) => {
            // Retry happened but server didn't declare it → forgery.
            return Err(RetryError.MalformedPseudo);
        },
        _ => {},
    }
    Ok(())
}
