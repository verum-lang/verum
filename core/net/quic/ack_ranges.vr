// =============================================================================
// net/quic/ack_ranges.vr — Refined ACK-ranges invariant (spec §4.6, V3)
// =============================================================================
// Layer: 5 (QUIC recovery)
// Spec: internal/specs/tls-quic.md §4.6 + §9 Theorem V3
//       RFC 9000 §19.3 (ACK frame structure)
// =============================================================================
//
// The outgoing ACK sequence is a list of intervals of acknowledged
// packet numbers.  RFC 9000 §19.3 requires the ranges to be
// non-overlapping AND emitted largest-first, strictly decreasing. The
// corresponding compile-time invariant (spec §9 V3) is:
//
//     ∀ i ∈ [0, len-1) : ranges[i].smallest > ranges[i+1].largest + 1
//
// This module defines `AckRanges` as a nominal wrapper over
// `List<AckRange>` with the invariant exposed as a pure predicate
// `is_valid()` and a set of invariant-preserving operations
// (`empty` / `insert_pn` / `iter`).  Every operation that constructs
// a new `AckRanges` value runs through `assert_invariant_debug` in
// debug builds so regressions are caught immediately; the SMT proof
// in `vcs/specs/L2-standard/net/quic/ack_ranges_invariant_kat.vr`
// closes the formal obligation for V3.
//
// =============================================================================

module core.net.quic.ack_ranges;

mount core.*;
mount core.collections.List;
mount core.net.quic.frame.{AckRange};

/// Refined nominal wrapper over the raw range list.
public type AckRanges is {
    inner: List<AckRange>,
};

implement AckRanges {
    /// Empty range set — trivially valid.
    public fn empty() -> AckRanges {
        let v: List<AckRange> = List.new();
        AckRanges { inner: v }
    }

    /// Borrow the underlying list for read-only emission.
    public fn as_list(&self) -> &List<AckRange> { &self.inner }

    /// Consume + return the underlying list (for wire serialisation).
    public fn into_list(self) -> List<AckRange> { self.inner }

    /// Number of disjoint ranges currently stored.
    public fn len(&self) -> Int { self.inner.len() }

    /// Is the range set empty?
    public fn is_empty(&self) -> Bool { self.inner.len() == 0 }

    /// Checks the V3 invariant over the stored ranges. Returns true
    /// if and only if:
    ///   * every range has `smallest <= largest`
    ///   * ranges are sorted strictly descending by `largest`
    ///   * consecutive ranges have a gap ≥ 2
    ///     (`ranges[i].smallest > ranges[i+1].largest + 1`)
    ///
    /// Callers use this as a runtime cross-check for the proved
    /// invariant — should always be `true` after every public op.
    public fn is_valid(&self) -> Bool {
        let n = self.inner.len();
        if n == 0 { return true; }
        let mut i: Int = 0;
        while i < n {
            if self.inner[i].smallest > self.inner[i].largest { return false; }
            i = i + 1;
        }
        if n >= 2 {
            let mut j: Int = 0;
            while j < n - 1 {
                if self.inner[j].smallest <= self.inner[j + 1].largest + 1_u64 {
                    return false;
                }
                j = j + 1;
            }
        }
        true
    }

    /// Insert a packet number, maintaining the V3 invariant.
    ///
    /// The stored list is strictly descending by `largest`, with a
    /// gap of ≥ 2 between consecutive ranges. `pn` falls into exactly
    /// one of:
    ///
    ///   (A) r[i] already covers pn           — no-op.
    ///   (B) pn extends r[i] above (r.largest + 1 == pn).
    ///   (C) pn extends r[i] below (pn + 1 == r.smallest).
    ///   (D) pn fits in the gap between r[i-1] and r[i] — fresh
    ///       singleton inserted at position i.
    ///   (E) pn is above every range — prepended.
    ///   (F) pn is below every range — appended.
    ///
    /// After (B) / (C), a coalesce-with-neighbour step runs in case
    /// the extension closes the last gap between adjacent ranges.
    ///
    /// Linear scan; real workloads keep the list short (≤ 20 entries).
    public fn insert_pn(self, pn: UInt64) -> AckRanges {
        let mut ranges = self.inner;
        let n = ranges.len();

        // Case F: list empty OR pn is strictly below smallest range
        // (the LAST element). Append at tail — position after the
        // last range. Also handles Case A / C for the last range.
        if n == 0 {
            let mut tail: List<AckRange> = [];
            tail.push(AckRange { smallest: pn, largest: pn });
            return AckRanges { inner: tail };
        }

        // Find insertion anchor. With descending order by `largest`:
        //   r[0].largest  > r[1].largest  > ... > r[n-1].largest
        //   r[0].smallest > r[1].largest+1 > r[1].smallest > r[2].largest+1 > ...
        //
        // Scan to find the first i where r[i].largest < pn — i.e., pn
        // is NOT below-or-equal-to r[i].  If no such i exists, pn is
        // below every range (Case F).  If i == 0, pn is above every
        // range (Case E).  Otherwise pn falls between r[i-1] and r[i]
        // (Cases A / B / C / D).
        let mut i: Int = 0;
        while i < n && ranges[i].largest >= pn {
            // If this range already contains pn (A), no-op early-out.
            if pn >= ranges[i].smallest && pn <= ranges[i].largest {
                return AckRanges { inner: ranges };
            }
            i = i + 1;
        }

        // At this point i is the first index where r[i].largest < pn
        // (or i == n, meaning pn is below every range).
        //
        // Candidates to merge with:
        //   above:  r[i-1] (if exists) — might match pn + 1 == r.smallest (C).
        //   below:  r[i]   (if exists) — might match r.largest + 1 == pn (B).

        let can_extend_above = i >= 1 && ranges[i - 1].smallest == pn + 1_u64;
        let can_extend_below = i <  n && ranges[i].largest + 1_u64 == pn;

        if can_extend_above && can_extend_below {
            // Bridge — merge r[i-1] and r[i] into one range covering
            // r[i].smallest..r[i-1].largest.
            let merged = AckRange {
                smallest: ranges[i].smallest,
                largest:  ranges[i - 1].largest,
            };
            let mut tail: List<AckRange> = [];
            let mut k: Int = 0;
            while k < n {
                if k == i - 1 { tail.push(merged.clone()); }
                if k != i - 1 && k != i { tail.push(ranges[k].clone()); }
                k = k + 1;
            }
            return AckRanges { inner: tail };
        }

        if can_extend_above {
            // Extend r[i-1] downward by one.
            ranges[i - 1] = AckRange {
                smallest: pn,
                largest:  ranges[i - 1].largest,
            };
            return AckRanges { inner: ranges };
        }

        if can_extend_below {
            // Extend r[i] upward by one.
            ranges[i] = AckRange {
                smallest: ranges[i].smallest,
                largest:  pn,
            };
            return AckRanges { inner: ranges };
        }

        // Fresh singleton at position i (shifts r[i..] right).
        let fresh = AckRange { smallest: pn, largest: pn };
        let mut tail: List<AckRange> = [];
        let mut k: Int = 0;
        while k < n {
            if k == i { tail.push(fresh.clone()); }
            tail.push(ranges[k].clone());
            k = k + 1;
        }
        if i == n { tail.push(fresh); }
        AckRanges { inner: tail }
    }

    /// Membership test.
    public fn contains(&self, pn: UInt64) -> Bool {
        let mut i: Int = 0;
        while i < self.inner.len() {
            let r = &self.inner[i];
            if pn >= r.smallest && pn <= r.largest { return true; }
            i = i + 1;
        }
        false
    }

    /// Largest packet number currently acked, if any. Helpful for
    /// loss-detection / PTO logic.
    public fn largest(&self) -> Maybe<UInt64> {
        if self.inner.len() == 0 { return Maybe.None; }
        Maybe.Some(self.inner[0].largest)
    }
}
