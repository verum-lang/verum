// =============================================================================
// net/quic/mod.vr — QUIC transport (RFC 9000 / RFC 9001 / RFC 9002)
// =============================================================================
// Layer: 5 (Network)
// Dependencies: core, core.time, core.net.addr, core.net.tls
// Spec: https://datatracker.ietf.org/doc/html/rfc9000
//
// QUIC is a UDP-based, multiplexed, secure transport. This module
// provides the Verum-level surface; the actual packet-processing
// pipeline is implemented in the runtime via the `verum.quic.*`
// intrinsic family (typically binding to a C implementation such as
// quiche, msquic, or lsquic).
//
// # Module layout
//
// ```
// core.net.quic
// ├── mod.vr          — this file (re-exports, Config types)
// ├── error.vr        — QuicError (transport + app error codes)
// ├── connection.vr   — QuicConnection handle, send/recv/close
// └── stream.vr       — QuicStream (send, recv, shutdown)
// ```
//
// # Minimal usage
//
// ```verum
// mount core.net.quic.*;
//
// // Client
// let config = QuicConfig.client(&"example.com".into())
//     .with_alpn(&["h3".into()])
//     .with_initial_max_data(1 << 20)
//     .with_initial_max_stream_data_bidi_local(1 << 16);
// let conn = QuicConnection.connect(&peer_addr, config).await?;
//
// // Server
// let listener = QuicListener.bind(&local_addr, server_config).await?;
// let (conn, peer) = listener.accept().await?;
//
// // Streams
// let stream = conn.open_bidi_stream().await?;
// stream.write_all(&request_bytes).await?;
// let n = stream.read(&mut buf).await?;
// ```
// =============================================================================

module core.net.quic;

public module error;
public module connection;
public module stream;

// Pure-Verum QUIC core (RFC 9000 + 9001) — sits under the intrinsic-
// backed connection surface; takes over fully once the connection SM
// lands (Phase 4). Until then, these modules ship as self-contained
// wire parsers + crypto primitives that the surrounding FFI shells
// and future pure-Verum transport both consume.
public module version;                 // RFC 9000 §15 version constants
public module connection_id;           // RFC 9000 §5.1 ConnectionId<0..=20>
public module crypto;                  // RFC 9001 crypto layer (landed)
public module frame;                   // RFC 9000 §19 frame codec
public module ack_ranges;              // Refined ACK-ranges invariant (spec §4.6 / V3)
public module packet;                  // RFC 9000 §17 packet headers
public module transport_params;        // RFC 9000 §18 transport parameters
public module recovery;                // RFC 9002 loss detection + NewReno
public module stream_sm;               // RFC 9000 §3/§4 stream state machines + FC
public module connection_sm;           // Typed connection SM (Initial → ... → OneRtt)
public module path;                    // RFC 9000 §8 path validation + migration
public module api;                     // High-level QuicClient / QuicServer facade
public module transport;               // UDP abstraction + ConnectionPump (end-to-end I/O)
public module stateless_reset;         // RFC 9000 §10.3 Stateless Reset tokens + detection
public module cid_pool;                // RFC 9000 §5.1 per-connection CID manager
public module key_update;              // RFC 9001 §6 key update state machine
public module stats;                   // Per-connection + endpoint observability
public module pacer;                   // RFC 9002 §7.7 token-bucket send pacer
public module stats_prometheus;        // Prometheus-format metrics exporter
public module address_token;           // RFC 9000 §8.1.3 address-validation tokens

// The following 4 sub-modules ship production code but had no
// `public module` here; pre-fix `mount core.net.quic.<X>;`
// worked via direct file lookup but the namespace was invisible.
public module idle_timeout;            // RFC 9000 §10.1 idle-timeout enforcement
public module lb_cid;                  // QUIC-LB connection-ID encoding (load-balancer routing)
public module multipath;               // draft-ietf-quic-multipath multi-path extension
public module path_mtu;                // RFC 9000 §14.3 path MTU discovery (DPLPMTUD)

mount core.*;
mount core.time.duration.{Duration};
mount core.net.addr.{SocketAddr};
mount core.net.tls.{Certificate, PrivateKey, TlsVersion};

// =============================================================================
// Re-exports
// =============================================================================

public mount .error.QuicError;
public mount .error.TransportErrorCode;
public mount .error.ApplicationErrorCode;

public mount .connection.QuicConnection;
public mount .connection.QuicListener;
public mount .connection.ConnectionEvent;

public mount .stream.QuicStream;
public mount .stream.StreamDirection;

// Re-exports — stateless reset
public mount .stateless_reset.{
    StatelessResetKey, ResetTokenSet,
    build_stateless_reset, try_match_stateless_reset,
    STATELESS_RESET_MIN_SIZE, STATELESS_RESET_RECOMMENDED_SIZE,
};

// Re-exports — CID pool (NEW/RETIRE CONNECTION_ID plumbing)
public mount .cid_pool.{
    CidPool, CidEntry, CidIssuer, CidPoolError,
};

// Re-exports — RFC 9001 §6 key update SM
public mount .key_update.{
    KeyUpdateSm, KeyUpdateError, KeyPhaseUsage, InboundPhaseAction,
    confidentiality_limit, integrity_limit,
};

// Re-exports — observability
public mount .stats.{QuicStats, EndpointStats};

// Re-exports — send pacer
public mount .pacer.{Pacer, PacerDecision};

// Re-exports — Prometheus exporter (callers: `mount core.net.quic.stats_prometheus.{...}`
// or use the short re-export names below)
public mount .stats_prometheus.{
    render_connection, render_endpoint,
};

// Re-exports — address-validation tokens
public mount .address_token.{
    AddressTokenKey, TokenKind, TokenPlaintext, TokenError,
    VerifyOptions,
    issue, verify, ip_bytes_from,
};

// =============================================================================
// QuicConfig
// =============================================================================

public type QuicConfig is {
    // TLS
    is_client: Bool,
    server_name: Maybe<Text>,
    alpn: List<Text>,
    certificates: List<Certificate>,
    private_key: Maybe<PrivateKey>,
    verify_peer: Bool,

    // Flow-control + stream limits (RFC 9000 §4, §18.2)
    initial_max_data: UInt64,
    initial_max_stream_data_bidi_local: UInt64,
    initial_max_stream_data_bidi_remote: UInt64,
    initial_max_stream_data_uni: UInt64,
    initial_max_streams_bidi: UInt64,
    initial_max_streams_uni: UInt64,

    // Timers
    max_idle_timeout: Duration,
    max_recv_udp_payload_size: UInt64,
    max_send_udp_payload_size: UInt64,

    // Congestion
    initial_congestion_window_packets: UInt64,

    // Feature flags
    enable_early_data: Bool,       // 0-RTT
    enable_datagrams: Bool,        // RFC 9221 unreliable datagrams
    enable_hystart: Bool,          // HyStart++ (RFC 9406)
}

implement QuicConfig {
    public fn client(server_name: &Text) -> QuicConfig {
        let mut c = QuicConfig.defaults();
        c.is_client = true;
        c.server_name = Some(server_name.clone());
        c.verify_peer = true;
        c
    }

    public fn server() -> QuicConfig {
        let mut c = QuicConfig.defaults();
        c.is_client = false;
        c.verify_peer = false;
        c
    }

    fn defaults() -> QuicConfig {
        QuicConfig {
            is_client: false,
            server_name: None,
            alpn: List.new(),
            certificates: List.new(),
            private_key: None,
            verify_peer: false,

            // Conservative defaults — tune per deployment.
            initial_max_data: 16 * 1024 * 1024,                       // 16 MiB conn window
            initial_max_stream_data_bidi_local: 1 * 1024 * 1024,
            initial_max_stream_data_bidi_remote: 1 * 1024 * 1024,
            initial_max_stream_data_uni: 1 * 1024 * 1024,
            initial_max_streams_bidi: 100,
            initial_max_streams_uni: 100,

            max_idle_timeout: Duration.from_secs(30),
            max_recv_udp_payload_size: 1350,  // conservative PMTU-friendly default
            max_send_udp_payload_size: 1350,

            initial_congestion_window_packets: 10,

            enable_early_data: false,
            enable_datagrams: false,
            enable_hystart: true,
        }
    }

    public fn with_alpn(mut self, alpn: &[Text]) -> QuicConfig {
        let mut i = 0;
        while i < alpn.len() { self.alpn.push(alpn[i].clone()); i = i + 1; }
        self
    }

    public fn with_certificate(mut self, cert: Certificate) -> QuicConfig {
        self.certificates.push(cert); self
    }

    public fn with_private_key(mut self, key: PrivateKey) -> QuicConfig {
        self.private_key = Some(key); self
    }

    public fn with_verify_peer(mut self, verify: Bool) -> QuicConfig {
        self.verify_peer = verify; self
    }

    public fn with_initial_max_data(mut self, n: UInt64) -> QuicConfig {
        self.initial_max_data = n; self
    }

    public fn with_initial_max_stream_data_bidi_local(mut self, n: UInt64) -> QuicConfig {
        self.initial_max_stream_data_bidi_local = n; self
    }

    public fn with_initial_max_streams_bidi(mut self, n: UInt64) -> QuicConfig {
        self.initial_max_streams_bidi = n; self
    }

    public fn with_max_idle_timeout(mut self, t: Duration) -> QuicConfig {
        self.max_idle_timeout = t; self
    }

    public fn with_early_data(mut self, enable: Bool) -> QuicConfig {
        self.enable_early_data = enable; self
    }

    public fn with_datagrams(mut self, enable: Bool) -> QuicConfig {
        self.enable_datagrams = enable; self
    }
}
