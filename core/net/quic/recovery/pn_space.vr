// =============================================================================
// net/quic/recovery/pn_space.vr — Per-space packet-number bookkeeping
// =============================================================================
// Layer: 5 (Network — QUIC)
// Dependencies: core, collections, core.time.instant, quic.frame.AckRange
// =============================================================================
//
// RFC 9000 §12.3 defines three independent packet-number spaces
// (Initial, Handshake, Application Data). Each has its own:
//
//   * Monotonic next-PN-to-send counter.
//   * Largest ACK-received tracking + time-of-arrival.
//   * In-flight packet table for retransmission + loss detection.
//   * Outgoing ACK range list.
//
// The ACK ranges are stored in descending order with no overlaps and
// gap > 1 between consecutive ranges (RFC 9000 §19.3.1 wire format
// requires this). `insert_ack_range` merges adjacent ranges to
// preserve the invariant.
//
// =============================================================================

module core.net.quic.recovery.pn_space;

mount core.*;
mount core.collections.List;
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};
mount core.net.quic.frame.{AckRange, Frame};
mount core.net.quic.ack_ranges.{AckRanges};

// =============================================================================
// Sent packet metadata — tracked for loss detection + retransmission
// =============================================================================

/// Metadata about a sent packet for loss-detection purposes.
public type SentPacketInfo is {
    packet_number:      UInt64,
    time_sent:          Instant,
    size_bytes:         UInt32,
    in_flight:          Bool,     // counts against CC window
    ack_eliciting:      Bool,     // triggers ACK by peer
    frames:             List<Frame>,   // frames to retransmit on loss
};

// =============================================================================
// PnSpaceKind
// =============================================================================

public type PnSpaceKind is Initial | Handshake | Application;

implement PnSpaceKind {
    public fn as_index(&self) -> Int {
        match self {
            PnSpaceKind.Initial     => 0,
            PnSpaceKind.Handshake   => 1,
            PnSpaceKind.Application => 2,
        }
    }
}

// =============================================================================
// PnSpace state
// =============================================================================

public type PnSpace is {
    kind:          PnSpaceKind,

    // Outbound
    next_pn:       UInt64,

    // Inbound — received packets
    largest_acked_received: Maybe<UInt64>,     // largest PN we have ACKed from peer
    /// Outgoing ACK set — desc-sorted, non-overlapping, gap ≥ 2 per
    /// RFC 9000 §19.3.1.  The `AckRanges` wrapper carries the V3
    /// invariant at type level (see core.net.quic.ack_ranges) — direct
    /// List<AckRange> mutation is no longer possible without going
    /// through insert_pn().
    ack_ranges:    AckRanges,
    ecn_ect0:      UInt64,
    ecn_ect1:      UInt64,
    ecn_ce:        UInt64,

    // Loss detection
    largest_acked_sent:     Maybe<UInt64>,      // largest PN peer has ACKed for us
    sent_packets:  List<SentPacketInfo>,         // outstanding in-flight packets

    discarded:     Bool,
};

implement PnSpace {
    public fn new(kind: PnSpaceKind) -> PnSpace {
        PnSpace {
            kind: kind,
            next_pn: 0_u64,
            largest_acked_received: None,
            ack_ranges: AckRanges.empty(),
            ecn_ect0: 0_u64, ecn_ect1: 0_u64, ecn_ce: 0_u64,
            largest_acked_sent: None,
            sent_packets: [],
            discarded: false,
        }
    }

    /// Allocate the next packet number. Monotonically increasing per
    /// RFC 9000 §12.3 ("Packet numbers in each packet-number space
    /// start at packet number 0. Subsequent packets sent in the same
    /// packet-number space MUST increase the packet number by at
    /// least one.").
    ///
    /// V4 obligation (spec §9): after this call, `self.next_pn` is
    /// strictly greater than the returned `pn`, and also strictly
    /// greater than `self.largest_acked_sent` (if any). `pn_monotonic_ok()`
    /// checks the invariant explicitly; regressions surface as a panic
    /// via `debug_assert_monotonic()` below.
    public fn next_packet_number(&mut self) -> UInt64 {
        let pn = self.next_pn;
        self.next_pn = pn + 1_u64;
        self.debug_assert_monotonic();
        pn
    }

    /// V4 theorem: `self.next_pn > self.largest_acked_sent` after every
    /// emit. Expressed as a predicate so the SMT layer can discharge
    /// the obligation symbolically + callers can assert empirically.
    public fn pn_monotonic_ok(&self) -> Bool {
        match self.largest_acked_sent {
            Some(v) => self.next_pn > v,
            None    => true,
        }
    }

    fn debug_assert_monotonic(&self) {
        if !self.pn_monotonic_ok() {
            panic("QUIC V4 invariant broken: next_pn <= largest_acked_sent");
        }
    }

    /// Record a freshly sent packet for loss tracking.
    public fn record_sent(&mut self, info: SentPacketInfo) {
        self.sent_packets.push(info);
    }

    /// Mark the space as discarded (RFC 9001 §4.9 — Initial / Handshake
    /// keys dropped). After this, no further sends or acks are accepted.
    public fn discard(&mut self) {
        self.discarded = true;
        self.sent_packets = [];
        self.ack_ranges = AckRanges.empty();
    }

    /// Incorporate an incoming packet's PN into our outgoing ACK set.
    /// Ensures descending order with no overlapping ranges; merges
    /// adjacent values into the same range.
    public fn on_packet_received(&mut self, pn: UInt64) {
        // Update peer-PN high-watermark.
        let should_update = match self.largest_acked_received {
            Some(v) => pn > v,
            None    => true,
        };
        if should_update { self.largest_acked_received = Some(pn); }

        // Invariant-preserving insert via AckRanges wrapper (V3).
        let taken = self.ack_ranges.clone();
        self.ack_ranges = taken.insert_pn(pn);
    }

    /// Incorporate an ACK received from the peer. Returns freshly-acked
    /// packet metadata so the caller can feed CC + RTT.
    public fn on_ack_received(
        &mut self,
        largest_acked: UInt64,
        ranges: &List<AckRange>,
    ) -> List<SentPacketInfo> {
        // Track highest PN the peer has ever ACKed for us.
        let prev = match self.largest_acked_sent { Some(v) => v, None => 0_u64 };
        if largest_acked > prev || self.largest_acked_sent.is_none() {
            self.largest_acked_sent = Some(largest_acked);
        }

        // Linear scan: retain not-acked, collect acked.
        let mut retained: List<SentPacketInfo> = [];
        let mut acked:    List<SentPacketInfo> = [];
        let mut i: Int = 0;
        while i < self.sent_packets.len() {
            let p = &self.sent_packets[i];
            let is_acked = ranges_contain(ranges, p.packet_number);
            if is_acked {
                acked.push(self.sent_packets[i].clone());
            } else {
                retained.push(self.sent_packets[i].clone());
            }
            i = i + 1;
        }
        self.sent_packets = retained;
        acked
    }

    /// Build an ACK frame ready to ship, or None if we have no
    /// outstanding received packets to acknowledge.
    public fn build_ack_frame(&self, ack_delay_us: UInt64) -> Maybe<Frame> {
        let largest = match self.largest_acked_received { Some(v) => v, None => return None };
        // Emit ECN counts only if any counter is non-zero. Some peers
        // require explicit ECN counts to be absent when none are seen.
        let ecn = if self.ecn_ect0 == 0_u64 && self.ecn_ect1 == 0_u64 && self.ecn_ce == 0_u64 {
            None
        } else {
            Some(crate_ecn_snapshot(self))
        };
        // The AckFrame wire variant still carries a plain List<AckRange>
        // (codec-friendly); we convert from the invariant-carrying
        // wrapper at the emission boundary. The V3 invariant therefore
        // witnesses the wire list is well-formed on exit.
        Some(Frame.AckFrame {
            largest_acked: largest,
            ack_delay:     ack_delay_us,
            ranges:        self.ack_ranges.as_list().clone(),
            ecn:           ecn,
        })
    }
}

fn crate_ecn_snapshot(s: &PnSpace) -> core.net.quic.frame.EcnCounts {
    core.net.quic.frame.EcnCounts {
        ect0: s.ecn_ect0, ect1: s.ecn_ect1, ce: s.ecn_ce,
    }
}

// =============================================================================
// Helpers
// =============================================================================

/// Membership test over a wire-ranges list (kept public for back-compat
/// with consumers outside this module that parse ACK frames coming from
/// the peer). Internal invariant-preserving insertion lives in
/// `core.net.quic.ack_ranges.AckRanges.insert_pn`.
public fn ranges_contain(ranges: &List<AckRange>, pn: UInt64) -> Bool {
    let mut i: Int = 0;
    while i < ranges.len() {
        let r = &ranges[i];
        if pn >= r.smallest && pn <= r.largest { return true; }
        i = i + 1;
    }
    false
}
