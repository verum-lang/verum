// =============================================================================
// net/quic/stream_sm/flow_control.vr — Connection-level flow control (RFC 9000 §4)
// =============================================================================
// Layer: 5 (Network — QUIC)
// =============================================================================
//
// RFC 9000 §4: QUIC enforces flow control at both the connection
// and per-stream levels. Stream FC lives inside SendStream/RecvStream;
// this module tracks the connection-level counters.
//
// Outgoing FC (what *we* have authorised the peer to send on this
// connection):
//   max_data_local      — total bytes the peer may send across all
//                         streams. We raise this via MAX_DATA frames
//                         as the app reads data.
//   bytes_recv          — total received so far.
//
// Incoming FC (what the peer has authorised *us* to send):
//   max_data_remote     — upper bound; the peer raises via MAX_DATA.
//   bytes_sent          — total sent so far.
//
// Stream-count FC (how many streams peer may open, symmetric both
// directions):
//   max_streams_{bidi,uni}_local  — we raise via MAX_STREAMS as streams close.
//   max_streams_{bidi,uni}_remote — peer raises; gates fresh opens.
//
// =============================================================================

module core.net.quic.stream_sm.flow_control;

mount core.*;

public type ConnFlowControl is {
    // Remote-side budget (we're sending)
    max_data_remote: UInt64,
    bytes_sent:      UInt64,

    // Local-side credit (we're receiving)
    max_data_local:  UInt64,
    bytes_recv:      UInt64,

    // Stream-count budgets — we request / peer grants.
    max_streams_bidi_remote: UInt64,
    max_streams_bidi_local:  UInt64,
    max_streams_uni_remote:  UInt64,
    max_streams_uni_local:   UInt64,

    // Stream counters for enforcement.
    next_stream_bidi_local:  UInt64,
    next_stream_uni_local:   UInt64,
    streams_bidi_remote_opened: UInt64,
    streams_uni_remote_opened:  UInt64,
};

implement ConnFlowControl {
    pub fn new(
        max_data_remote: UInt64,
        max_data_local:  UInt64,
        max_streams_bidi_remote: UInt64,
        max_streams_bidi_local:  UInt64,
        max_streams_uni_remote:  UInt64,
        max_streams_uni_local:   UInt64,
    ) -> ConnFlowControl {
        ConnFlowControl {
            max_data_remote: max_data_remote,
            bytes_sent:      0_u64,
            max_data_local:  max_data_local,
            bytes_recv:      0_u64,
            max_streams_bidi_remote: max_streams_bidi_remote,
            max_streams_bidi_local:  max_streams_bidi_local,
            max_streams_uni_remote:  max_streams_uni_remote,
            max_streams_uni_local:   max_streams_uni_local,
            next_stream_bidi_local:  0_u64,
            next_stream_uni_local:   0_u64,
            streams_bidi_remote_opened: 0_u64,
            streams_uni_remote_opened:  0_u64,
        }
    }

    /// Budget remaining for us to send new application data on this
    /// connection (bytes).
    pub fn send_budget(&self) -> UInt64 {
        if self.max_data_remote >= self.bytes_sent {
            self.max_data_remote - self.bytes_sent
        } else {
            0_u64
        }
    }

    /// Record bytes emitted. Caller MUST check `send_budget()` first.
    pub fn on_bytes_sent(&mut self, n: UInt64) {
        self.bytes_sent = self.bytes_sent + n;
    }

    /// Record bytes received (enforces the connection-level limit;
    /// violation → connection-level FLOW_CONTROL_ERROR).
    pub fn on_bytes_recv(&mut self, n: UInt64) -> Result<(), ()> {
        let new_total = self.bytes_recv + n;
        if new_total > self.max_data_local {
            return Err(());
        }
        self.bytes_recv = new_total;
        Ok(())
    }

    /// Peer raised MAX_DATA.
    pub fn on_peer_max_data(&mut self, new_limit: UInt64) {
        if new_limit > self.max_data_remote {
            self.max_data_remote = new_limit;
        }
    }

    /// Suggested new MAX_DATA we publish to peer — ≈ bytes_recv + window.
    pub fn suggested_max_data(&self, window: UInt64) -> UInt64 {
        self.bytes_recv + window
    }

    /// Raise our own publish-to-peer limit.
    pub fn update_max_data_local(&mut self, new_limit: UInt64) {
        if new_limit > self.max_data_local {
            self.max_data_local = new_limit;
        }
    }

    /// Can we open a new locally-initiated bidi stream?
    pub fn can_open_bidi(&self) -> Bool {
        self.next_stream_bidi_local < self.max_streams_bidi_remote
    }

    pub fn can_open_uni(&self) -> Bool {
        self.next_stream_uni_local < self.max_streams_uni_remote
    }

    /// Allocate a locally-initiated bidirectional stream id, returns
    /// the raw stream_id with the correct initiator/direction bits set.
    /// RFC 9000 §2.1: stream_id bit 0 = server, bit 1 = uni.
    pub fn alloc_stream_bidi(&mut self, is_server: Bool) -> Maybe<UInt64> {
        if !self.can_open_bidi() { return None; }
        let low_bits: UInt64 = if is_server { 0x01_u64 } else { 0x00_u64 };
        let sid = (self.next_stream_bidi_local << 2) | low_bits;
        self.next_stream_bidi_local = self.next_stream_bidi_local + 1_u64;
        Some(sid)
    }

    pub fn alloc_stream_uni(&mut self, is_server: Bool) -> Maybe<UInt64> {
        if !self.can_open_uni() { return None; }
        let low_bits: UInt64 = if is_server { 0x03_u64 } else { 0x02_u64 };
        let sid = (self.next_stream_uni_local << 2) | low_bits;
        self.next_stream_uni_local = self.next_stream_uni_local + 1_u64;
        Some(sid)
    }

    pub fn on_peer_max_streams_bidi(&mut self, new_limit: UInt64) {
        if new_limit > self.max_streams_bidi_remote {
            self.max_streams_bidi_remote = new_limit;
        }
    }

    pub fn on_peer_max_streams_uni(&mut self, new_limit: UInt64) {
        if new_limit > self.max_streams_uni_remote {
            self.max_streams_uni_remote = new_limit;
        }
    }
}
