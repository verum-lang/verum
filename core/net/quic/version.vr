// =============================================================================
// net/quic/version.vr — QUIC version constants (RFC 9000 §15)
// =============================================================================
// Layer: 5 (Network — QUIC)
// =============================================================================
//
// QUIC version number is a 32-bit integer on the wire (big-endian).
// RFC 9000 defines:
//
//   * Version 0x00000000         — reserved for Version Negotiation packets.
//   * Version 0x00000001         — QUIC v1 (current IETF standard).
//   * Version 0x6b3343cf         — QUIC v2 (RFC 9369).
//   * Versions matching pattern 0x?a?a?a?a (reserved for greasing).
//
// Warp ships only QUIC v1 in v1.0; the v2 constant is defined for
// version-negotiation parsing and future migration.
//
// =============================================================================

module core.net.quic.version;

mount core.*;

public const VERSION_NEGOTIATION: UInt32 = 0x00000000_u32;
public const VERSION_1:           UInt32 = 0x00000001_u32;
public const VERSION_2:           UInt32 = 0x6B3343CF_u32;

/// Is this a QUIC version recognised by warp? Currently v1 only.
public fn is_supported(v: UInt32) -> Bool {
    v == VERSION_1
}

/// Greasing pattern check — reserved versions that MUST be ignored
/// by implementations (RFC 8701). Any version matching 0x?a?a?a?a
/// is a greased version (byte mask: bits 0..4 == 0b1010).
public fn is_greased(v: UInt32) -> Bool {
    let b0 = ((v >> 24) & 0x0F_u32) == 0x0A_u32;
    let b1 = ((v >> 16) & 0x0F_u32) == 0x0A_u32;
    let b2 = ((v >>  8) & 0x0F_u32) == 0x0A_u32;
    let b3 = (v         & 0x0F_u32) == 0x0A_u32;
    b0 && b1 && b2 && b3
}
