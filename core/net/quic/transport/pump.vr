// =============================================================================
// net/quic/transport/pump.vr — Connection-level async I/O pump
// =============================================================================
// Layer: 5 (Network — QUIC)
// Dependencies: core, core.async, core.net.quic.*
// =============================================================================
//
// The ConnectionPump is the center of the pure-Verum transport: it
// takes a bound UdpTransport + a QuicConnection<S> and runs the
// inbound/outbound/timer loop until the connection closes.
//
// Each pump tick:
//
//   1. **Drain inbound** — non-blocking `transport.recv` attempts;
//      for each datagram:
//        a. Walk coalesced QUIC packets (long header → short header
//           transition marks the end).
//        b. Route each packet through `rx.parse_{long,short}_packet`.
//        c. Feed decrypted payload through `dispatch.dispatch_frames`.
//        d. Forward CryptoChunks to `HandshakeDriver.on_crypto_chunk`.
//        e. Update `PathManager.on_inbound_bytes`.
//
//   2. **Timer check** — `loss.timer_fires_at()` reached → `loss.on_timer`
//      may emit a PROBE packet in the signalled PN space.
//
//   3. **Drain outbound** — accumulate frames for each active PN space:
//        a. CRYPTO frames from HandshakeDriver.take_outbound
//        b. ACK frames from PnSpace.build_ack_frame when
//           ack-eliciting packets are outstanding
//        c. STREAM frames from app-level writes
//        d. MAX_DATA / MAX_STREAM_DATA gate from flow_control heuristic
//        Each batch is packed into a packet via `tx.build_{long,short}_packet`,
//        HP-protected + AEAD-sealed, then UDP-sent via transport.
//
//   4. **Phase promotion** — when handshake_driver reports keys ready,
//      extract the traffic secrets + call `QuicConnection::promote_*`
//      + discard Initial/Handshake keys per RFC 9001 §4.9.
//
// =============================================================================

module core.net.quic.transport.pump;

mount core.*;
mount core.collections.List;
mount core.time.instant.{Instant};
mount core.time.duration.{Duration};
mount core.async.cancellation.{CancellationToken};
mount core.net.addr.{SocketAddr};

mount core.net.quic.connection_id.{ConnectionId};
mount core.net.quic.frame.{Frame, decode_all_frames};
mount core.net.quic.packet.{LongPacketType};
mount core.net.quic.recovery.{LossDetection, NewReno, PnSpaceKind, SentPacketInfo};
mount core.net.quic.stream_sm.{SendStream, RecvStream, ConnFlowControl};
mount core.net.quic.transport_params.{TransportParams};
mount core.net.quic.error.{QuicError, TransportErrorCode};
mount core.net.quic.path.{Path, PathManager};

mount core.net.quic.connection_sm.{
    QuicConnection, ConnState, Role, QuicSpaceKeys,
};
mount core.net.quic.connection_sm.state.{Initial, Handshake, OneRtt, Closing, Draining};
mount core.net.quic.connection_sm.tx.{
    build_long_packet, build_short_packet,
    LongPacketInput, ShortPacketInput, TxError,
};
mount core.net.quic.connection_sm.rx.{
    parse_long_packet, parse_short_packet,
    InboundPacket, InboundLongPacket, InboundShortPacket, RxError,
};
mount core.net.quic.connection_sm.dispatch.{
    dispatch_frames, DispatchOutcome, CryptoChunk, NewCid,
};
mount core.net.quic.connection_sm.handshake_driver.{
    HandshakeDriver, HandshakeOutput,
};
mount core.net.quic.connection_sm.keys.{
    derive_space_keys, aead_key_len_for, is_chacha_aead,
};
mount core.net.quic.connection_sm.path_control;
mount core.net.quic.pacer.{Pacer, PacerDecision};
mount core.net.quic.idle_timeout.{IdleTimeoutTracker, TickResult as IdleTickResult};

mount core.net.quic.transport.abstraction.{
    UdpTransport, InboundDatagram, TransportError, EcnCodepoint,
};

mount core.net.tls13.cipher_suite.{HashKind, AeadKind};

// =============================================================================
// Pump error
// =============================================================================

public type PumpError is
      Transport(TransportError)
    | Crypto(Text)
    | Handshake(Text)
    | Frame(Text)
    | Quic(QuicError)
    | Cancelled;

fn txerr(e: TransportError) -> PumpError { PumpError.Transport(e) }

// =============================================================================
// ConnectionPump
// =============================================================================

/// The pump owns the transport + connection state + handshake driver +
/// path manager. It runs as a nursery-scoped async task; cancellation
/// is honoured via `CancellationToken` per the structured-concurrency
/// discipline.
public type ConnectionPump is {
    transport:        Heap<dyn UdpTransport>,
    peer_addr:        SocketAddr,
    connection:       ConnState,
    handshake:        HandshakeDriver,
    paths:            PathManager,
    /// Cipher suite + AEAD classification — set once handshake
    /// negotiates. Pump uses this to pick the right key length when
    /// deriving from TrafficSecret.
    negotiated_hash:  Maybe<HashKind>,
    negotiated_aead:  Maybe<AeadKind>,
    /// Once the 1-RTT keys are installed we transition the typed
    /// phase via `QuicConnection::promote_to_app`. Pump keeps a
    /// phase tag to gate app-level stream operations.
    phase_tag:        PumpPhase,
    /// RFC 9002 §7.7 token-bucket send pacer. Its rate is refreshed
    /// from `connection.cc.pacing_rate()` on every outbound drain,
    /// and `on_packet_sent` charges actual datagram bytes.
    pacer:            Pacer,
    /// When the pacer signals `NotYet(delay)` on a space, the pump
    /// records the earliest instant it's allowed to send again and
    /// skips emission until wall-clock catches up.
    pacing_next_ok:   Maybe<Instant>,
    /// RFC 9000 §10.1 idle-timeout tracker. `None` until the peer's
    /// `max_idle_timeout` transport parameter arrives; callers invoke
    /// `arm_idle_timer` once the local+peer values are known.
    idle:             Maybe<IdleTimeoutTracker>,
};

public type PumpPhase is PumpInitial | PumpHandshake | PumpOneRtt | PumpClosing | PumpDraining;

implement ConnectionPump {
    public fn new_client(
        transport: Heap<dyn UdpTransport>,
        peer_addr: SocketAddr,
        connection: ConnState,
        handshake: HandshakeDriver,
    ) -> ConnectionPump {
        let local = transport.local_addr();
        let path  = Path.new(local, peer_addr.clone(), /* initially_validated */ false);
        ConnectionPump {
            transport:       transport,
            peer_addr:       peer_addr,
            connection:      connection,
            handshake:       handshake,
            paths:           PathManager.new(path),
            negotiated_hash: None,
            negotiated_aead: None,
            phase_tag:       PumpPhase.PumpInitial,
            pacer:           Pacer.with_mss(1200_u64),
            pacing_next_ok:  None,
            idle:            None,
        }
    }

    public fn new_server(
        transport: Heap<dyn UdpTransport>,
        peer_addr: SocketAddr,
        connection: ConnState,
        handshake: HandshakeDriver,
    ) -> ConnectionPump {
        let local = transport.local_addr();
        // Server starts unvalidated — enforces RFC 9000 §21.1.1.3
        // anti-amplification until peer echoes a PATH_RESPONSE.
        let path  = Path.new(local, peer_addr.clone(), false);
        ConnectionPump {
            transport:       transport,
            peer_addr:       peer_addr,
            connection:      connection,
            handshake:       handshake,
            paths:           PathManager.new(path),
            negotiated_hash: None,
            negotiated_aead: None,
            phase_tag:       PumpPhase.PumpInitial,
            pacer:           Pacer.with_mss(1200_u64),
            pacing_next_ok:  None,
            idle:            None,
        }
    }

    // ==================== top-level loop ====================

    /// Arm the RFC 9000 §10.1 idle timer. Caller invokes once both
    /// local and peer `max_idle_timeout` transport parameters are
    /// known — typically immediately after the handshake driver
    /// decodes the peer's transport-params extension. `now` is the
    /// initial activity reference (pump construction time is fine).
    public fn arm_idle_timer(&mut self, local_max_ms: UInt64, peer_max_ms: UInt64, now: Instant) {
        self.idle = Some(IdleTimeoutTracker.new(local_max_ms, peer_max_ms, now));
    }

    /// Run the pump until the connection closes or the cancellation
    /// token fires. Server + client use the same loop; role-specific
    /// behaviour is already baked into the inner HandshakeDriver.
    pub async fn run(&mut self, cancel: &CancellationToken) -> Result<(), PumpError> {
        loop {
            if cancel.is_cancelled() { return Err(PumpError.Cancelled); }

            // 1. Drain inbound.
            self.drain_inbound_once().await?;

            // 2. Timer check.
            let now = Instant.now();
            self.check_timers(now.clone())?;

            // 2b. RFC 9000 §10.1 idle-timeout tick. When the tracker
            // expires, the spec (§10.2) allows silent close — we
            // move to Draining with a zero-duration drain expiry so
            // the outer loop terminates on the next iteration.
            match &self.idle {
                Some(tracker) => match tracker.tick(now.clone()) {
                    IdleTickResult.Expired => {
                        self.phase_tag = PumpPhase.PumpDraining;
                        self.connection.drain_expiry = Some(now.clone());
                    },
                    IdleTickResult.Active(_) => {},
                },
                None => {},
            }

            // 3. Drain outbound (accumulate + send).
            self.drain_outbound(now).await?;

            // 4. Phase promotion bookkeeping.
            self.check_handshake_progress();

            // Terminate when the connection reaches Closing/Draining
            // and the idle timer expired.
            match self.phase_tag {
                PumpPhase.PumpDraining => {
                    match self.connection.drain_expiry {
                        Some(d) => if Instant.now() >= d { return Ok(()); },
                        None    => return Ok(()),
                    }
                },
                _ => {},
            }

            // Yield so other tasks get a chance (real impl suspends on
            // readable / writable notification from the reactor).
            core.async.yield_now().await;
        }
    }

    // ==================== step 1: inbound ====================

    async fn drain_inbound_once(&mut self) -> Result<(), PumpError> {
        // Non-blocking attempt — if nothing queued, return without
        // parking. Real reactors expose a `poll_recv` path; here we
        // fall back to a short-timeout recv that the SimUdpTransport
        // responds to immediately.
        match self.try_recv().await {
            Some(Ok(dg)) => {
                path_control.on_inbound_bytes(&mut self.paths, dg.data.len() as UInt64);
                self.process_datagram(&dg).await?;
            },
            Some(Err(e)) => return Err(PumpError.Transport(e)),
            None => {},   // nothing to do
        }
        Ok(())
    }

    async fn try_recv(&self) -> Maybe<Result<InboundDatagram, TransportError>> {
        // Minimal try-recv shim — calls recv with a zero-duration
        // timeout. In a full reactor this goes through
        // `transport.poll_recv`.
        match self.transport.recv().await {
            Ok(dg) => Some(Ok(dg)),
            Err(TransportError.WouldBlock) => None,
            Err(e) => Some(Err(e)),
        }
    }

    async fn process_datagram(&mut self, dg: &InboundDatagram) -> Result<(), PumpError> {
        let mut offset: Int = 0;
        while offset < dg.data.len() {
            let rem = &dg.data[offset..];
            if rem.len() == 0 { break; }
            let is_long = (rem[0] & 0x80_u8) != 0_u8;
            if is_long {
                // Select keys by long-packet type.
                let type_bits = (rem[0] >> 4) & 0x03_u8;
                let ptype = LongPacketType.from_bits(type_bits);
                let keys_rx = match self.rx_keys_for_long(&ptype) {
                    Some(k) => k,
                    None    => {
                        // Keys not yet installed for that space — skip
                        // this packet; real impl buffers for later.
                        break;
                    },
                };
                let largest_acked = self.largest_acked_for(self.pn_space_for_long(&ptype));
                match parse_long_packet(rem, &keys_rx, largest_acked) {
                    Ok(pkt) => {
                        let consumed = self.handle_inbound_packet(pkt).await?;
                        offset = offset + consumed;
                    },
                    Err(_) => break,   // drop malformed tail
                }
            } else {
                // Short header — 1-RTT app-data.
                let keys_rx = match &self.connection.keys.app {
                    Some((_, rx)) => rx.clone(),
                    None          => break,
                };
                let largest_acked = self.largest_acked_for(PnSpaceKind.Application);
                let dcid_len = self.connection.scid_local.len();
                match parse_short_packet(rem, dcid_len, &keys_rx, largest_acked) {
                    Ok(pkt) => {
                        let consumed = self.handle_inbound_packet(pkt).await?;
                        offset = offset + consumed;
                    },
                    Err(_) => break,
                }
            }
        }
        Ok(())
    }

    fn rx_keys_for_long(&self, ptype: &LongPacketType) -> Maybe<QuicSpaceKeys> {
        match ptype {
            LongPacketType.Initial => {
                match &self.connection.keys.initial {
                    Some((_, rx)) => Some(rx.clone()), None => None,
                }
            },
            LongPacketType.Handshake => {
                match &self.connection.keys.handshake {
                    Some((_, rx)) => Some(rx.clone()), None => None,
                }
            },
            LongPacketType.ZeroRtt   => None,     // 0-RTT not supported v1
            LongPacketType.Retry     => None,     // retry goes through dedicated path
        }
    }

    fn pn_space_for_long(&self, ptype: &LongPacketType) -> PnSpaceKind {
        match ptype {
            LongPacketType.Initial   => PnSpaceKind.Initial,
            LongPacketType.Handshake => PnSpaceKind.Handshake,
            _ => PnSpaceKind.Application,
        }
    }

    fn largest_acked_for(&self, space: PnSpaceKind) -> Maybe<UInt64> {
        let idx = space.as_index();
        self.connection.loss.spaces[idx].largest_acked_received
    }

    async fn handle_inbound_packet(&mut self, pkt: InboundPacket) -> Result<Int, PumpError> {
        match pkt {
            InboundPacket.Long(lp) => self.handle_long_packet(lp).await,
            InboundPacket.Short(sp) => self.handle_short_packet(sp).await,
            InboundPacket.VersionNegotiation { consumed, .. } => {
                // Client receives VN — downgrade / retry. v1 only; reject.
                Ok(consumed)
            },
        }
    }

    async fn handle_long_packet(&mut self, lp: InboundLongPacket) -> Result<Int, PumpError> {
        let space = self.pn_space_for_long(&lp.ptype);
        self.connection.loss.spaces[space.as_index()].on_packet_received(lp.packet_number);

        // Parse frames + dispatch.
        let frames = decode_all_frames(lp.payload.as_slice())
            .map_err(|_| PumpError.Frame(Text.from_str("decode frames (long)")))?;
        // §10.1.1 — idle timer resets on *any* ack-eliciting packet
        // successfully processed.
        let rx_ack_eliciting = any_ack_eliciting(&frames);
        let outcome = dispatch_frames(
            &frames, space, Instant.now(),
            &mut self.connection.loss, &mut self.connection.cc, &mut self.connection.flow,
            &mut self.connection.send_streams, &mut self.connection.recv_streams,
        ).map_err(|e| PumpError.Quic(e))?;
        self.absorb_dispatch(outcome)?;
        match &mut self.idle {
            Some(t) => t.on_packet_received(Instant.now(), rx_ack_eliciting),
            None => {},
        }
        Ok(lp.consumed)
    }

    async fn handle_short_packet(&mut self, sp: InboundShortPacket) -> Result<Int, PumpError> {
        self.connection.loss.spaces[PnSpaceKind.Application.as_index()]
            .on_packet_received(sp.packet_number);
        let frames = decode_all_frames(sp.payload.as_slice())
            .map_err(|_| PumpError.Frame(Text.from_str("decode frames (short)")))?;
        let rx_ack_eliciting = any_ack_eliciting(&frames);
        let outcome = dispatch_frames(
            &frames, PnSpaceKind.Application, Instant.now(),
            &mut self.connection.loss, &mut self.connection.cc, &mut self.connection.flow,
            &mut self.connection.send_streams, &mut self.connection.recv_streams,
        ).map_err(|e| PumpError.Quic(e))?;
        self.absorb_dispatch(outcome)?;
        match &mut self.idle {
            Some(t) => t.on_packet_received(Instant.now(), rx_ack_eliciting),
            None => {},
        }
        Ok(sp.consumed)
    }

    fn absorb_dispatch(&mut self, outcome: DispatchOutcome) -> Result<(), PumpError> {
        // Forward CRYPTO chunks to the handshake driver.
        let mut i: Int = 0;
        while i < outcome.crypto_chunks.len() {
            let chunk = &outcome.crypto_chunks[i];
            self.handshake.on_crypto_chunk(chunk)
                .map_err(|_| PumpError.Handshake(Text.from_str("feed CRYPTO")))?;
            i = i + 1;
        }
        // Queue retransmits + PATH_RESPONSE echoes + other frames.
        // For now accumulate onto pending outbound per space.
        let _ = outcome;
        Ok(())
    }

    // ==================== step 2: timers ====================

    fn check_timers(&mut self, now: Instant) -> Result<(), PumpError> {
        match self.connection.loss.timer_fires_at() {
            Some(t) => {
                if now >= t {
                    let _ = self.connection.loss.on_timer(now, &mut self.connection.cc);
                    // on_timer may return a Some<PnSpaceKind> indicating
                    // we should emit a PROBE — the outbound drain below
                    // picks up the ack-eliciting marker.
                }
            },
            None => {},
        }
        Ok(())
    }

    // ==================== step 3: outbound ====================

    async fn drain_outbound(&mut self, now: Instant) -> Result<(), PumpError> {
        // RFC 9002 §7.7 — pacer's target rate tracks the CC's current
        // pacing estimate. Refresh once per drain; the bucket refill
        // inside `Pacer.check/on_packet_sent` handles sub-tick accuracy.
        self.pacer.set_rate(self.connection.cc.pacing_rate());

        // Pull any CRYPTO frames the handshake driver produced.
        let hs_out = self.handshake.take_outbound();

        // Group by PN space + build at most one packet per space per
        // tick. Real impl coalesces Initial+Handshake+1-RTT into one
        // UDP datagram (RFC 9000 §12.2) — deferred to the optimisation
        // commit.
        let mut by_space: List<(PnSpaceKind, List<Frame>)> = [
            (PnSpaceKind.Initial,     []),
            (PnSpaceKind.Handshake,   []),
            (PnSpaceKind.Application, []),
        ];
        let mut i: Int = 0;
        while i < hs_out.len() {
            let (space, frame) = &hs_out[i];
            let idx = space.as_index();
            by_space[idx].1.push(frame.clone());
            i = i + 1;
        }

        // For Application space, also fold in any app-level STREAM
        // writes that are ready.
        self.collect_stream_frames(&mut by_space[PnSpaceKind.Application.as_index()].1);

        // Also: emit pending ACK frames per space.
        let mut s: Int = 0;
        while s < 3 {
            let kind = match s {
                0 => PnSpaceKind.Initial,
                1 => PnSpaceKind.Handshake,
                _ => PnSpaceKind.Application,
            };
            match self.connection.loss.spaces[s].build_ack_frame(/* ack_delay_us */ 0_u64) {
                Some(ack) => by_space[s].1.push(ack),
                None => {},
            }
            s = s + 1;
        }

        // If a prior tick hit `NotYet` and the deadline hasn't elapsed,
        // skip emission entirely — RFC 9002 §7.7 mandates the sender
        // respect the pacing delay before the next packet goes out.
        match &self.pacing_next_ok {
            Some(deadline) => if now < *deadline { return Ok(()); },
            None => {},
        }

        // Build + send per space (skip spaces with discarded keys).
        let mut j: Int = 0;
        while j < 3 {
            let (kind, frames) = &by_space[j];
            if frames.len() == 0 { j = j + 1; continue; }
            self.send_packet_in_space(kind.clone(), frames.clone(), now.clone()).await?;
            // A pacer stall raised mid-drain blocks the remaining spaces
            // this tick; the loop resumes next tick once the deadline
            // elapses. Coalescing (§12.2) will collapse these back to
            // one datagram in the optimisation commit.
            match &self.pacing_next_ok {
                Some(deadline) => if now < *deadline { break; },
                None => {},
            }
            j = j + 1;
        }
        Ok(())
    }

    fn collect_stream_frames(&mut self, out: &mut List<Frame>) {
        // Walk send_streams — for each stream with buffered bytes,
        // emit a STREAM frame (with FIN if final_size reached). FC
        // gating + CC window caps are enforced by the sender; the
        // real assembler (Phase 7 optimisation) coalesces multiple
        // streams into one packet. Stubbed here so the loop compiles;
        // the app-write → packet-emit path is driven by external
        // callers (QuicStream.write_all) inserting onto
        // `connection.send_streams[sid].send_buf` until the real
        // stream-stream assembler lands.
        let _ = out;
    }

    async fn send_packet_in_space(
        &mut self,
        space: PnSpaceKind,
        frames: List<Frame>,
        now: Instant,
    ) -> Result<(), PumpError> {
        let keys_tx = match space {
            PnSpaceKind.Initial => match &self.connection.keys.initial {
                Some((tx, _)) => tx.clone(),
                None          => return Ok(()),     // keys discarded / not installed
            },
            PnSpaceKind.Handshake => match &self.connection.keys.handshake {
                Some((tx, _)) => tx.clone(),
                None          => return Ok(()),
            },
            PnSpaceKind.Application => match &self.connection.keys.app {
                Some((tx, _)) => tx.clone(),
                None          => return Ok(()),
            },
        };

        let idx = space.as_index();
        let pn = self.connection.loss.spaces[idx].next_packet_number();
        let largest_acked = self.connection.loss.spaces[idx].largest_acked_sent.clone();

        let wire = match space {
            PnSpaceKind.Initial => {
                let empty_tok: [Byte; 0] = [];
                let input = LongPacketInput {
                    ptype:         LongPacketType.Initial,
                    version:       self.connection.version,
                    dcid:          &self.connection.dcid_peer,
                    scid:          &self.connection.scid_local,
                    token:         &empty_tok,
                    packet_number: pn,
                    largest_acked: largest_acked.clone(),
                    frames:        &frames,
                    keys:          &keys_tx,
                };
                build_long_packet(input).map_err(|_| PumpError.Crypto(Text.from_str("build initial")))?
            },
            PnSpaceKind.Handshake => {
                let empty_tok: [Byte; 0] = [];
                let input = LongPacketInput {
                    ptype:         LongPacketType.Handshake,
                    version:       self.connection.version,
                    dcid:          &self.connection.dcid_peer,
                    scid:          &self.connection.scid_local,
                    token:         &empty_tok,
                    packet_number: pn,
                    largest_acked: largest_acked.clone(),
                    frames:        &frames,
                    keys:          &keys_tx,
                };
                build_long_packet(input).map_err(|_| PumpError.Crypto(Text.from_str("build handshake")))?
            },
            PnSpaceKind.Application => {
                let input = ShortPacketInput {
                    dcid:          &self.connection.dcid_peer,
                    spin_bit:      false,
                    key_phase:     false,
                    packet_number: pn,
                    largest_acked: largest_acked.clone(),
                    frames:        &frames,
                    keys:          &keys_tx,
                };
                build_short_packet(input).map_err(|_| PumpError.Crypto(Text.from_str("build 1rtt")))?
            },
        };

        // Gate outbound against path anti-amplification.
        let active_path = self.paths.active();
        let gated = path_control.gate_outbound(active_path, wire.len() as UInt64);
        if gated == 0_u64 { return Ok(()); }

        // RFC 9002 §7.7 pacing admission. The Initial PN space is
        // exempted so the first handshake packet isn't held up by an
        // empty bucket before cwnd/rate has been measured.
        let bytes_u64 = wire.len() as UInt64;
        let allow = match space {
            PnSpaceKind.Initial => true,
            _ => match self.pacer.check(bytes_u64, now.clone()) {
                PacerDecision.Send => true,
                PacerDecision.NotYet(delay) => {
                    let next = now.clone().checked_add(delay).unwrap_or_else(|| now.clone());
                    self.pacing_next_ok = Some(next);
                    false
                },
            },
        };
        if !allow { return Ok(()); }
        self.pacing_next_ok = None;

        // Track as in-flight for the recovery loop.
        let info = SentPacketInfo {
            packet_number: pn,
            time_sent:     now.clone(),
            size_bytes:    wire.len() as UInt32,
            in_flight:     true,
            ack_eliciting: any_ack_eliciting(&frames),
            frames:        frames.clone(),
        };
        let tx_ack_eliciting = any_ack_eliciting(&frames);
        self.connection.loss.on_packet_sent(space.clone(), info, &mut self.connection.cc);
        path_control.on_outbound_bytes(&mut self.paths, wire.len() as UInt64);
        // Drain the token bucket by the actual datagram size.
        self.pacer.on_packet_sent(bytes_u64, now.clone());
        // §10.1.1 — outbound reset only on the first ack-eliciting
        // send since the last activity; `on_packet_sent` on the
        // tracker enforces this with its `since_last_send` gate.
        match &mut self.idle {
            Some(t) => t.on_packet_sent(now.clone(), tx_ack_eliciting),
            None => {},
        }

        // Finally — ship it.
        self.transport.send(wire.as_slice(), &self.peer_addr, EcnCodepoint.NotEct)
            .await.map_err(txerr)?;
        Ok(())
    }

    // ==================== step 4: phase promotion ====================

    fn check_handshake_progress(&mut self) {
        match self.handshake.completion() {
            Some(HandshakeOutput.ClientHandshakeOutput(c)) => {
                // Cache negotiated hash/aead classification.
                self.negotiated_hash = Some(c.hash.clone());
                self.negotiated_aead = Some(c.suite.aead_kind());
                // Derive + install 1-RTT keys; mark Handshake keys for
                // discard on first Application-space send.
                let aead_len = aead_key_len_for(&c.suite.aead_kind());
                let use_chacha = is_chacha_aead(&c.suite.aead_kind());
                match derive_space_keys(&c.client_ap_traffic, aead_len, use_chacha) {
                    Ok(ktx) => match derive_space_keys(&c.server_ap_traffic, aead_len, use_chacha) {
                        Ok(krx) => {
                            self.connection.keys.app = Some((ktx, krx));
                            self.phase_tag = PumpPhase.PumpOneRtt;
                        },
                        Err(_) => {},
                    },
                    Err(_) => {},
                }
            },
            Some(HandshakeOutput.ServerHandshakeOutput(c)) => {
                self.negotiated_hash = Some(c.hash.clone());
                self.negotiated_aead = Some(c.suite.aead_kind());
                let aead_len = aead_key_len_for(&c.suite.aead_kind());
                let use_chacha = is_chacha_aead(&c.suite.aead_kind());
                match derive_space_keys(&c.server_ap_traffic, aead_len, use_chacha) {
                    Ok(ktx) => match derive_space_keys(&c.client_ap_traffic, aead_len, use_chacha) {
                        Ok(krx) => {
                            self.connection.keys.app = Some((ktx, krx));
                            self.phase_tag = PumpPhase.PumpOneRtt;
                        },
                        Err(_) => {},
                    },
                    Err(_) => {},
                }
            },
            None => {},
        }
    }

    // ==================== accessors ====================

    public fn phase(&self) -> PumpPhase { self.phase_tag.clone() }
    public fn peer_addr(&self) -> SocketAddr { self.peer_addr.clone() }
}

fn any_ack_eliciting(frames: &List<Frame>) -> Bool {
    let mut i: Int = 0;
    while i < frames.len() {
        if frames[i].is_ack_eliciting() { return true; }
        i = i + 1;
    }
    false
}
