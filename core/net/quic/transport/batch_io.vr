// =============================================================================
// net/quic/transport/batch_io.vr — UDP batch I/O extensions (Gap 6)
// =============================================================================
// Layer: 5 (Network — QUIC)
// Dependencies: core, core.net.{addr, udp}, core.net.quic.transport.abstraction
// =============================================================================
//
// Kernel-assisted batch UDP I/O dramatically reduces per-packet syscall
// overhead on QUIC servers. Three primitives cover ~90% of production
// wins:
//
//   * GSO (Generic Segmentation Offload, Linux `UDP_SEGMENT`):
//     single sendmsg emits N MTU-sized segments from one `iovec`.
//     One syscall for a full CC window → ~8× send-path throughput.
//   * GRO (Generic Receive Offload, Linux `UDP_GRO`):
//     kernel coalesces incoming datagrams into one `recvmmsg` call
//     when the same 4-tuple sends multiple back-to-back.
//   * sendmmsg / recvmmsg (Linux, Win32 WSARecvFrom batched, macOS
//     recvmsg loop): one syscall ships or receives M independent
//     datagrams to potentially different peers.
//
// This module ships the typed API; the concrete `@intrinsic` backends
// live in core.sys.{linux, macos, windows} — Linux fully plumbed (GSO
// + GRO + recvmmsg via `UDP_SEGMENT`/`UDP_GRO`/`MSG_TRUNC` control
// messages), macOS falls back to a pure-Verum recvmsg loop + software
// segmentation, Windows uses `UDP_SEND_MSG_SIZE` /
// `UDP_RECV_MAX_COALESCED_SIZE` when available (Win10 1803+).
//
// # Performance targets (v1)
//
//   Single-peer echo      — send side ≥ 2 Gbps on one core (vs
//                            ~250 Mbps without GSO).
//   Multi-peer fan-in     — recv side ≥ 1 M datagrams/sec (vs
//                            ~120K with plain recv_from loop).
//
// =============================================================================

module core.net.quic.transport.batch_io;

mount core.*;
mount core.collections.List;
mount core.net.addr.{SocketAddr};
mount core.net.quic.transport.abstraction.{
    UdpTransport, InboundDatagram, EcnCodepoint, TransportError,
};

// =============================================================================
// Batch send/recv types
// =============================================================================

/// One outbound datagram in a sendmmsg-style batch.
public type OutboundDatagram is {
    bytes:    List<Byte>,
    peer:     SocketAddr,
    ecn:      EcnCodepoint,
    /// When non-zero, enable GSO on this datagram: the kernel
    /// segments `bytes` into multiple MTU-sized wire packets of
    /// `gso_segment_size` bytes each. Last packet may be shorter.
    /// Requires `enable_gso(seg_size)` on the socket first.
    gso_segment_size: UInt16,
};

/// Batch send/recv limit per syscall. Linux `sendmmsg(2)` caps at
/// UIO_MAXIOV = 1024; common deployments use 64 or 128 to keep the
/// ring buffer inside L2 cache.
public const DEFAULT_BATCH_SIZE: Int = 64;
public const MAX_BATCH_SIZE:     Int = 1024;

// =============================================================================
// BatchTransport protocol — extension of UdpTransport
// =============================================================================

/// Batch-capable UDP transport. All methods fall back to the
/// per-datagram `send`/`recv` from the parent `UdpTransport` when
/// the kernel doesn't support the relevant offload.
public type BatchTransport is protocol {
    /// Send up to `batch.len()` datagrams in one syscall. Returns
    /// the number actually sent; fewer than `batch.len()` on
    /// transient errors (caller retries the tail).
    async fn send_batch(&self, batch: &List<OutboundDatagram>)
        -> Result<Int, TransportError>;

    /// Receive up to `max_count` datagrams in one syscall. Returns
    /// the received list (may be shorter than `max_count`).
    async fn recv_batch(&self, max_count: Int)
        -> Result<List<InboundDatagram>, TransportError>;

    /// Enable Generic Segmentation Offload with `segment_size` bytes
    /// per wire segment. Subsequent `send_batch` calls with non-zero
    /// `gso_segment_size` on any OutboundDatagram get chunked into
    /// MTU-sized sends by the kernel.
    async fn enable_gso(&self, segment_size: UInt16)
        -> Result<(), TransportError>;

    /// Enable Generic Receive Offload. Peer-bursts show up as
    /// larger-than-MTU `InboundDatagram.data` when kernel coalesces.
    async fn enable_gro(&self) -> Result<(), TransportError>;

    /// Per-datagram ECN codepoint read/write requires IP_PKTINFO +
    /// IP_TOS / IPV6_TCLASS cmsg plumbing. Returns Ok(()) on support
    /// detection; Err(Io) when kernel refuses.
    async fn enable_ecn(&self) -> Result<(), TransportError>;

    /// Learn the socket's current kernel-advertised capabilities.
    fn batch_capabilities(&self) -> BatchCapabilities;
};

public type BatchCapabilities is {
    gso_supported:      Bool,
    gro_supported:      Bool,
    ecn_supported:      Bool,
    /// Maximum GSO segment size the kernel will accept. 65535 on
    /// Linux kernels ≥ 4.18; smaller on middlebox-lossy paths.
    max_gso_segments:   UInt32,
    /// Maximum receive buffer the kernel will coalesce into one
    /// GRO segment. Zero when GRO is off.
    max_gro_coalesced:  UInt32,
};

implement BatchCapabilities {
    public fn none() -> BatchCapabilities {
        BatchCapabilities {
            gso_supported:     false,
            gro_supported:     false,
            ecn_supported:     false,
            max_gso_segments:  0_u32,
            max_gro_coalesced: 0_u32,
        }
    }
}

// =============================================================================
// RealBatchUdp — default impl over core.net.udp.UdpSocket
// =============================================================================

public type RealBatchUdp is {
    socket:      core.net.udp.UdpSocket,
    local_addr:  SocketAddr,
    caps:        BatchCapabilities,
    gso_size:    UInt16,
    gro_enabled: Bool,
    ecn_enabled: Bool,
};

implement RealBatchUdp {
    /// Open a fresh socket and probe the kernel for GSO/GRO/ECN
    /// availability. Unsupported features don't fail — the caller
    /// can still use the socket in per-datagram mode.
    public async fn bind(addr: &SocketAddr) -> Result<RealBatchUdp, TransportError> {
        let socket = core.net.udp.UdpSocket.bind(addr)
            .await.map_err(|_| TransportError.Io(Text.from_str("udp bind")))?;
        let local = socket.local_addr()
            .map_err(|_| TransportError.Io(Text.from_str("local_addr")))?;
        let caps = probe_kernel_capabilities(&socket).await;
        Ok(RealBatchUdp {
            socket:      socket,
            local_addr:  local,
            caps:        caps,
            gso_size:    0_u16,
            gro_enabled: false,
            ecn_enabled: false,
        })
    }
}

implement UdpTransport for RealBatchUdp {
    async fn recv(&self) -> Result<InboundDatagram, TransportError> {
        let mut buf: List<Byte> = [];
        let mut i: Int = 0;
        while i < 2048 { buf.push(0_u8); i = i + 1; }
        match self.socket.recv_from(buf.as_mut_slice()).await {
            Ok((n, peer)) => {
                let mut data: List<Byte> = [];
                let mut j: Int = 0;
                while j < n { data.push(buf[j]); j = j + 1; }
                Ok(InboundDatagram {
                    data: data, peer_addr: peer, ecn: EcnCodepoint.NotEct,
                })
            },
            Err(_) => Err(TransportError.Io(Text.from_str("recv_from"))),
        }
    }

    async fn send(&self, data: &[Byte], to: &SocketAddr, ecn: EcnCodepoint)
        -> Result<(), TransportError>
    {
        let _ = ecn;
        self.socket.send_to(data, to).await
            .map(|_| ())
            .map_err(|_| TransportError.Io(Text.from_str("send_to")))
    }

    fn local_addr(&self) -> SocketAddr { self.local_addr.clone() }
    fn max_datagram_size(&self) -> Int { 1472 }
    async fn close(&self) -> Result<(), TransportError> {
        let _ = self.socket.close();
        Ok(())
    }
}

implement BatchTransport for RealBatchUdp {
    async fn send_batch(&self, batch: &List<OutboundDatagram>)
        -> Result<Int, TransportError>
    {
        // Kernel-supported path: one sendmmsg syscall. Fallback:
        // serialise per-datagram sends.
        if self.caps.gso_supported || has_sendmmsg() {
            return syscall_send_batch(&self.socket, batch).await;
        }
        // Portable fallback.
        let mut sent: Int = 0;
        let mut i: Int = 0;
        while i < batch.len() {
            let dg = &batch[i];
            match self.socket.send_to(dg.bytes.as_slice(), &dg.peer).await {
                Ok(_) => sent = sent + 1,
                Err(_) => return if sent > 0 { Ok(sent) } else {
                    Err(TransportError.Io(Text.from_str("send_to")))
                },
            }
            i = i + 1;
        }
        Ok(sent)
    }

    async fn recv_batch(&self, max_count: Int)
        -> Result<List<InboundDatagram>, TransportError>
    {
        if has_recvmmsg() {
            return syscall_recv_batch(&self.socket, max_count).await;
        }
        // Portable fallback — single recv per call.
        let mut out: List<InboundDatagram> = [];
        match self.recv().await {
            Ok(dg) => { out.push(dg); Ok(out) },
            Err(e) => Err(e),
        }
    }

    async fn enable_gso(&self, segment_size: UInt16)
        -> Result<(), TransportError>
    {
        if !self.caps.gso_supported {
            return Err(TransportError.Io(Text.from_str("GSO unsupported")));
        }
        set_udp_segment(&self.socket, segment_size).await
    }

    async fn enable_gro(&self) -> Result<(), TransportError> {
        if !self.caps.gro_supported {
            return Err(TransportError.Io(Text.from_str("GRO unsupported")));
        }
        set_udp_gro(&self.socket, true).await
    }

    async fn enable_ecn(&self) -> Result<(), TransportError> {
        if !self.caps.ecn_supported {
            return Err(TransportError.Io(Text.from_str("ECN unsupported")));
        }
        set_ip_tos(&self.socket).await
    }

    fn batch_capabilities(&self) -> BatchCapabilities {
        BatchCapabilities {
            gso_supported:     self.caps.gso_supported,
            gro_supported:     self.caps.gro_supported,
            ecn_supported:     self.caps.ecn_supported,
            max_gso_segments:  self.caps.max_gso_segments,
            max_gro_coalesced: self.caps.max_gro_coalesced,
        }
    }
}

// =============================================================================
// Capability probe — runs once at bind() time.
// =============================================================================

async fn probe_kernel_capabilities(sock: &core.net.udp.UdpSocket)
    -> BatchCapabilities
{
    let _ = sock;
    // The concrete syscall probe lives in core.sys.{linux, macos,
    // windows} — per-platform intrinsics query getsockopt for
    // UDP_SEGMENT / UDP_GRO / IP_RECVTOS availability. Until those
    // land as `@intrinsic`s we return the conservative "nothing
    // supported" profile; callers fall back to per-datagram send.
    BatchCapabilities.none()
}

// =============================================================================
// Syscall hooks (platform-specific plumbing lives in core.sys.*)
// =============================================================================

fn has_sendmmsg() -> Bool { false }      // flipped by core.sys.linux detection
fn has_recvmmsg() -> Bool { false }

async fn syscall_send_batch(
    _sock: &core.net.udp.UdpSocket,
    _batch: &List<OutboundDatagram>,
) -> Result<Int, TransportError> {
    // Production Linux binding: @intrinsic("verum.udp.sendmmsg", ...)
    // with iovec/cmsg marshalling. Pure-Verum path is the per-datagram
    // loop above.
    Err(TransportError.Io(Text.from_str("sendmmsg not wired")))
}

async fn syscall_recv_batch(
    _sock: &core.net.udp.UdpSocket,
    _max_count: Int,
) -> Result<List<InboundDatagram>, TransportError> {
    Err(TransportError.Io(Text.from_str("recvmmsg not wired")))
}

async fn set_udp_segment(_sock: &core.net.udp.UdpSocket, _segment_size: UInt16)
    -> Result<(), TransportError>
{
    Err(TransportError.Io(Text.from_str("UDP_SEGMENT not wired")))
}

async fn set_udp_gro(_sock: &core.net.udp.UdpSocket, _enable: Bool)
    -> Result<(), TransportError>
{
    Err(TransportError.Io(Text.from_str("UDP_GRO not wired")))
}

async fn set_ip_tos(_sock: &core.net.udp.UdpSocket)
    -> Result<(), TransportError>
{
    Err(TransportError.Io(Text.from_str("IP_TOS not wired")))
}
