// =============================================================================
// core/intrinsics/atomic.vr - Atomic Operation Intrinsics
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: None (compiler-provided)
//
// This module provides atomic operation intrinsics that map directly to
// LLVM/CPU instructions. All operations are zero-allocation and VBC-compatible.
//
// # Memory Ordering
//
// All atomic operations require a memory ordering parameter:
// - Relaxed: No ordering constraints
// - Acquire: Subsequent loads see writes before matching Release
// - Release: Previous writes visible after matching Acquire
// - AcqRel: Both Acquire and Release
// - SeqCst: Full sequential consistency
//
// # Operations
//
// - Load/Store: atomic_load, atomic_store
// - Read-Modify-Write: atomic_add, atomic_sub, atomic_and, atomic_or, atomic_xor
// - Compare-and-Swap: atomic_cmpxchg, atomic_cmpxchg_weak
// - Exchange: atomic_xchg
// - Fences: atomic_fence, compiler_fence
//
// Spec: docs/detailed/05-syntax-grammar.md
// =============================================================================

module core.intrinsics.atomic;

// =============================================================================
// SECTION 1: Memory Ordering
// =============================================================================

/// Memory ordering for atomic operations
@repr(UInt8)
public type MemoryOrder is
    | Relaxed    // No ordering constraints
    | Acquire    // Subsequent loads see writes before Release
    | Release    // Previous writes visible after Acquire
    | AcqRel     // Both Acquire and Release
    | SeqCst;    // Full sequential consistency

// =============================================================================
// SECTION 2: Basic Atomic Operations
// =============================================================================

/// Atomic load
public fn atomic_load<T>(ptr: &T, order: MemoryOrder) -> T { @intrinsic("atomic_load", ptr, order) }

/// Atomic store
public fn atomic_store<T>(ptr: &mut T, val: T, order: MemoryOrder) { @intrinsic("atomic_store", ptr, val, order) }

/// Atomic exchange
public fn atomic_xchg<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_xchg", ptr, val, order)
}

// =============================================================================
// SECTION 3: Compare-and-Swap
// =============================================================================

/// Atomic compare-and-swap. Returns (old_value, success).
public fn atomic_cmpxchg<T>(
    ptr: &mut T,
    expected: T,
    desired: T,
    success: MemoryOrder,
    failure: MemoryOrder,
) -> (T, Bool) {
    @intrinsic("cmpxchg", ptr, expected, desired, success, failure)
}

/// Atomic compare-and-swap (weak). May fail spuriously.
public fn atomic_cmpxchg_weak<T>(
    ptr: &mut T,
    expected: T,
    desired: T,
    success: MemoryOrder,
    failure: MemoryOrder,
) -> (T, Bool) {
    @intrinsic("cmpxchg_weak", ptr, expected, desired, success, failure)
}

// =============================================================================
// SECTION 4: Atomic Arithmetic
// =============================================================================

/// Atomic add, returns old value
public fn atomic_add<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_add", ptr, val, order)
}

/// Atomic subtract, returns old value
public fn atomic_sub<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_sub", ptr, val, order)
}

/// Atomic maximum (signed), returns old value
public fn atomic_max<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_max", ptr, val, order)
}

/// Atomic minimum (signed), returns old value
public fn atomic_min<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_min", ptr, val, order)
}

/// Atomic maximum (unsigned), returns old value
public fn atomic_umax<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_umax", ptr, val, order)
}

/// Atomic minimum (unsigned), returns old value
public fn atomic_umin<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_umin", ptr, val, order)
}

// =============================================================================
// SECTION 5: Atomic Bitwise Operations
// =============================================================================

/// Atomic bitwise AND, returns old value
public fn atomic_and<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_and", ptr, val, order)
}

/// Atomic bitwise NAND, returns old value
public fn atomic_nand<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_nand", ptr, val, order)
}

/// Atomic bitwise OR, returns old value
public fn atomic_or<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_or", ptr, val, order)
}

/// Atomic bitwise XOR, returns old value
public fn atomic_xor<T>(ptr: &mut T, val: T, order: MemoryOrder) -> T {
    @intrinsic("atomicrmw_xor", ptr, val, order)
}

// =============================================================================
// SECTION 6: Memory Fences
// =============================================================================

/// Memory fence
public fn atomic_fence(order: MemoryOrder) { @intrinsic("fence", order) }

/// Compiler fence (prevents reordering, no CPU fence)
public fn compiler_fence(order: MemoryOrder) { @intrinsic("compiler_fence", order) }

// =============================================================================
// SECTION 7: VBC-Specific Size-Typed Atomic Operations
// =============================================================================
// These are retained for VBC bytecode compatibility where size-specific
// opcodes are needed. For generic atomic operations, use the generic functions above.
//
// VBC Opcodes: AtomicLoad (0x48), AtomicStore (0x49), AtomicCas (0x4A)
// =============================================================================

/// Memory ordering constants for atomic operations (VBC compatible).
public const ORDERING_RELAXED: UInt8 = 0;
public const ORDERING_ACQUIRE: UInt8 = 1;
public const ORDERING_RELEASE: UInt8 = 2;
public const ORDERING_ACQ_REL: UInt8 = 3;
public const ORDERING_SEQ_CST: UInt8 = 4;

/// Atomic load of UInt8 (VBC opcode: AtomicLoad 0x48 with size=1).
@intrinsic("atomic_load_u8")
@vbc_direct_lowering
public fn atomic_load_u8(ptr: *const UInt8, ordering: UInt8) -> UInt8;

/// Atomic load of UInt16 (VBC opcode: AtomicLoad 0x48 with size=2).
@intrinsic("atomic_load_u16")
@vbc_direct_lowering
public fn atomic_load_u16(ptr: *const UInt16, ordering: UInt8) -> UInt16;

/// Atomic load of UInt32 (VBC opcode: AtomicLoad 0x48 with size=4).
@intrinsic("atomic_load_u32")
@vbc_direct_lowering
public fn atomic_load_u32(ptr: *const UInt32, ordering: UInt8) -> UInt32;

/// Atomic load of UInt64 (VBC opcode: AtomicLoad 0x48 with size=8).
@intrinsic("atomic_load_u64")
@vbc_direct_lowering
public fn atomic_load_u64(ptr: *const UInt64, ordering: UInt8) -> UInt64;

/// Atomic load of Int32.
@intrinsic("atomic_load_i32")
@vbc_direct_lowering
public fn atomic_load_i32(ptr: *const Int32, ordering: UInt8) -> Int32;

/// Atomic load of pointer.
@intrinsic("atomic_load_ptr")
@vbc_direct_lowering
public fn atomic_load_ptr<T>(ptr: *const *const T, ordering: UInt8) -> *const T;

/// Atomic store of UInt8 (VBC opcode: AtomicStore 0x49 with size=1).
@intrinsic("atomic_store_u8")
@vbc_direct_lowering
public fn atomic_store_u8(ptr: *mut UInt8, value: UInt8, ordering: UInt8);

/// Atomic store of UInt16.
@intrinsic("atomic_store_u16")
@vbc_direct_lowering
public fn atomic_store_u16(ptr: *mut UInt16, value: UInt16, ordering: UInt8);

/// Atomic store of UInt32.
@intrinsic("atomic_store_u32")
@vbc_direct_lowering
public fn atomic_store_u32(ptr: *mut UInt32, value: UInt32, ordering: UInt8);

/// Atomic store of UInt64.
@intrinsic("atomic_store_u64")
@vbc_direct_lowering
public fn atomic_store_u64(ptr: *mut UInt64, value: UInt64, ordering: UInt8);

/// Atomic store of Int32.
@intrinsic("atomic_store_i32")
@vbc_direct_lowering
public fn atomic_store_i32(ptr: *mut Int32, value: Int32, ordering: UInt8);

/// Atomic store of pointer.
@intrinsic("atomic_store_ptr")
@vbc_direct_lowering
public fn atomic_store_ptr<T>(ptr: *mut *const T, value: *const T, ordering: UInt8);

