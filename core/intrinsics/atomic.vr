// -----------------------------------------------------------------------------
// 64-bit signed atomics (#100, task #24)
//
// Closes the asymmetry where signed 64-bit code rounded
// through `_u64` with `as UInt64` cast — the bit-pattern
// survived but the static type information was lost at
// every atomic operation. LLVM atomicrmw / load / store /
// cmpxchg don't care about signedness for these ops; the
// signed variants share the same opcode tree as unsigned.
// -----------------------------------------------------------------------------

/// Atomic load of Int64 (VBC opcode: AtomicLoad 0x48 with size=8).
@intrinsic("atomic_load_i64")
@vbc_direct_lowering
public fn atomic_load_i64(ptr: *const Int64, ordering: UInt8) -> Int64;

/// Atomic store of Int64.
@intrinsic("atomic_store_i64")
@vbc_direct_lowering
public fn atomic_store_i64(ptr: *mut Int64, value: Int64, ordering: UInt8);

/// Atomic compare-and-swap for Int64.
@intrinsic("atomic_cas_i64")
@vbc_direct_lowering
public fn atomic_cas_i64(
    ptr: *mut Int64,
    expected: Int64,
    desired: Int64,
    success_order: UInt8,
    failure_order: UInt8,
) -> (Int64, Bool);

/// Atomic fetch-and-add for Int64.
@intrinsic("atomic_fetch_add_i64")
@vbc_direct_lowering
public fn atomic_fetch_add_i64(ptr: *mut Int64, value: Int64, ordering: UInt8) -> Int64;

/// Atomic fetch-and-sub for Int64.
@intrinsic("atomic_fetch_sub_i64")
@vbc_direct_lowering
public fn atomic_fetch_sub_i64(ptr: *mut Int64, value: Int64, ordering: UInt8) -> Int64;

/// Atomic exchange for Int64.
@intrinsic("atomic_exchange_i64")
@vbc_direct_lowering
public fn atomic_exchange_i64(ptr: *mut Int64, value: Int64, ordering: UInt8) -> Int64;

// -----------------------------------------------------------------------------
// u8 atomic counters (#100, task #24)
//
// Enables race-hardening of single-byte counters such as
// the CBGR slot-generation rotation in heap.vr's
// free_block_xthread (currently uses non-atomic load+store
// because no UInt8 atomic fetch_add was available).
// -----------------------------------------------------------------------------

/// Atomic fetch-and-add for UInt8.
@intrinsic("atomic_fetch_add_u8")
@vbc_direct_lowering
public fn atomic_fetch_add_u8(ptr: *mut UInt8, value: UInt8, ordering: UInt8) -> UInt8;

/// Atomic fetch-and-sub for UInt8.
@intrinsic("atomic_fetch_sub_u8")
@vbc_direct_lowering
public fn atomic_fetch_sub_u8(ptr: *mut UInt8, value: UInt8, ordering: UInt8) -> UInt8;

// -----------------------------------------------------------------------------
// u8 RMW closure (#100, task #34) — bitwise + xchg + cas.
//
// Closes the gap that core/sync/atomic.vr's AtomicU8 was
// papering over with u32-aligned CAS-loop emulation
// (structurally unsound in mixed-field layouts — see
// commit 228ea664 for the full rationale).  Same compiler-
// side pattern as task #24's fetch_add_u8/sub_u8 closure.
// -----------------------------------------------------------------------------

/// Atomic fetch-and-and for UInt8.
@intrinsic("atomic_fetch_and_u8")
@vbc_direct_lowering
public fn atomic_fetch_and_u8(ptr: *mut UInt8, value: UInt8, ordering: UInt8) -> UInt8;

/// Atomic fetch-and-or for UInt8.
@intrinsic("atomic_fetch_or_u8")
@vbc_direct_lowering
public fn atomic_fetch_or_u8(ptr: *mut UInt8, value: UInt8, ordering: UInt8) -> UInt8;

/// Atomic fetch-and-xor for UInt8.
@intrinsic("atomic_fetch_xor_u8")
@vbc_direct_lowering
public fn atomic_fetch_xor_u8(ptr: *mut UInt8, value: UInt8, ordering: UInt8) -> UInt8;

/// Atomic exchange for UInt8.
@intrinsic("atomic_exchange_u8")
@vbc_direct_lowering
public fn atomic_exchange_u8(ptr: *mut UInt8, value: UInt8, ordering: UInt8) -> UInt8;

/// Atomic compare-and-swap for UInt8.
@intrinsic("atomic_cas_u8")
@vbc_direct_lowering
public fn atomic_cas_u8(
    ptr: *mut UInt8,
    expected: UInt8,
    desired: UInt8,
    success_order: UInt8,
    failure_order: UInt8,
) -> (UInt8, Bool);

// -----------------------------------------------------------------------------
// Symmetric coverage closure (#100, task #24)
// -----------------------------------------------------------------------------

/// Atomic fetch-and-sub for UInt16.
@intrinsic("atomic_fetch_sub_u16")
@vbc_direct_lowering
public fn atomic_fetch_sub_u16(ptr: *mut UInt16, value: UInt16, ordering: UInt8) -> UInt16;

/// Atomic fetch-and-or for UInt32.
@intrinsic("atomic_fetch_or_u32")
@vbc_direct_lowering
public fn atomic_fetch_or_u32(ptr: *mut UInt32, value: UInt32, ordering: UInt8) -> UInt32;

/// Atomic fetch-and-xor for UInt32.
@intrinsic("atomic_fetch_xor_u32")
@vbc_direct_lowering
public fn atomic_fetch_xor_u32(ptr: *mut UInt32, value: UInt32, ordering: UInt8) -> UInt32;

// =============================================================================
// SECTION 8: Int-sized Atomic Helpers
// =============================================================================
// Convenience wrappers that delegate to size-specific atomics.
//
// **Pointer-width assumption**: every helper here delegates
// to the `_u64` family, which is sound iff `Int` is 64-bit
// (i.e. `target_pointer_width = "64"`). Verum currently
// supports only 64-bit targets in the codegen pipeline, so
// the assumption holds for every shipping configuration.
// If the language ever grows a 32-bit target, these helpers
// must be split via @cfg(target_pointer_width) — the
// `as UInt64` round-trip silently sign-extends a 32-bit
// `Int`, then the `_u64` atomic operates on 8 bytes (one
// scalar past the actual storage), producing immediate
// memory corruption. The compiler-side gap (no
// `atomic_*_int_native` family that picks width at codegen
// time) is the right place to fix this; tracked as the
// follow-up to task #24.
// =============================================================================

/// Atomic load for Int (delegates to UInt64; assumes 64-bit Int).
@inline(always)
public fn atomic_load_int(ptr: *const Int, ordering: UInt8) -> Int {
    atomic_load_u64(ptr as *const UInt64, ordering) as Int
}

/// Atomic store for Int.
@inline(always)
public fn atomic_store_int(ptr: *mut Int, value: Int, ordering: UInt8) {
    atomic_store_u64(ptr as *mut UInt64, value as UInt64, ordering)
}

/// Atomic compare-exchange for Int.
@inline(always)
public fn atomic_cmpxchg_int(
    ptr: *mut Int,
    expected: Int,
    desired: Int,
    success_order: UInt8,
    failure_order: UInt8,
) -> (Int, Bool) {
    let (old, success) = atomic_cas_u64(
        ptr as *mut UInt64,
        expected as UInt64,
        desired as UInt64,
        success_order,
        failure_order,
    );
    (old as Int, success)
}

/// Atomic fetch-and-add for Int.
@inline(always)
public fn atomic_fetch_add_int(ptr: *mut Int, value: Int, ordering: UInt8) -> Int {
    atomic_fetch_add_u64(ptr as *mut UInt64, value as UInt64, ordering) as Int
}

// =============================================================================
// SECTION 9: Compatibility Aliases
// =============================================================================
// Aliases for backwards compatibility with code using old naming conventions.
// =============================================================================

/// Alias for atomic_cas_u32 (backwards compatibility).
@inline(always)
public fn atomic_compare_exchange_u32(
    ptr: *mut UInt32,
    expected: UInt32,
    desired: UInt32,
    success_order: UInt8,
    failure_order: UInt8,
) -> (UInt32, Bool) {
    atomic_cas_u32(ptr, expected, desired, success_order, failure_order)
}

/// Alias for atomic_cas_u64 (backwards compatibility).
@inline(always)
public fn atomic_compare_exchange_u64(
    ptr: *mut UInt64,
    expected: UInt64,
    desired: UInt64,
    success_order: UInt8,
    failure_order: UInt8,
) -> (UInt64, Bool) {
    atomic_cas_u64(ptr, expected, desired, success_order, failure_order)
}

/// Alias for atomic_cas_i32 (backwards compatibility).
@inline(always)
public fn atomic_compare_exchange_i32(
    ptr: *mut Int32,
    expected: Int32,
    desired: Int32,
    success_order: UInt8,
    failure_order: UInt8,
) -> (Int32, Bool) {
    atomic_cas_i32(ptr, expected, desired, success_order, failure_order)
}

/// Alias for atomic_cas_ptr (backwards compatibility).
@inline(always)
public fn atomic_cmpxchg_ptr<T>(
    ptr: *mut *const T,
    expected: *const T,
    desired: *const T,
    success_order: UInt8,
    failure_order: UInt8,
) -> (*const T, Bool) {
    atomic_cas_ptr(ptr, expected, desired, success_order, failure_order)
}
