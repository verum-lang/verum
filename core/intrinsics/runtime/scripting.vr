// =============================================================================
// core/intrinsics/runtime/scripting.vr - Embedded Scripting Intrinsics
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: VBC interpreter (Tier 0)
//
// Low-level intrinsics that expose the in-process scripting engine to Verum
// code.  They are the binding surface beneath the ergonomic `core.script`
// API (Engine / Script / Value); user code should prefer `core.script`.
//
// The engine is a thin wrapper over the VBC interpreter — compiling a Verum
// source string and running it on a fresh interpreter, sharing no second VM,
// heap, or sandbox.  See `crates/verum_vbc/src/interpreter/script_engine.rs`
// and `.../dispatch_table/handlers/script_runtime.rs`.
//
// Tier note: source evaluation requires an installed compiler hook (present
// whenever `verum_compiler` is linked — the CLI, the REPL, and any host app
// that embeds the compiler).  In a stripped AOT binary with no compiler the
// engine reports "source compilation unavailable" rather than mis-lowering.
//
// Spec: docs/detailed/05-syntax-grammar.md
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.intrinsics.runtime.scripting;

// =============================================================================
// SECTION 1: Opaque Handles
// =============================================================================
// Host-owned, heap-allocated Rust objects surfaced to Verum as opaque
// pointers (same pattern as the async runtime's Raw*Opaque handles).  Each is
// created by an intrinsic and must be released by the matching `*_free`
// intrinsic exactly once — the `core.script` wrappers do this from Drop.

/// Opaque handle to a host-owned `ScriptEngine`.
public type RawScriptEngine is (*const Byte);

/// Opaque handle to a host-owned `ScriptOutcome` (a script's result + stdout).
public type RawScriptOutcome is (*const Byte);

// =============================================================================
// SECTION 2: Engine Lifecycle
// =============================================================================

/// Create a new embedded script engine with default (permissive) limits.
@intrinsic("script_engine_new")
public fn script_engine_new() -> RawScriptEngine;

/// Destroy a script engine. The handle must not be used afterwards.
@intrinsic("script_engine_free")
public fn script_engine_free(engine: RawScriptEngine);

// =============================================================================
// SECTION 3: Evaluation
// =============================================================================

/// Compile and run `source` (entry `main`) on `engine`, returning an opaque
/// outcome handle carrying the result value, captured stdout, and any error.
@intrinsic("script_engine_eval")
public fn script_engine_eval(engine: RawScriptEngine, source: Text) -> RawScriptOutcome;

/// Compile `source` and run its named `fn_name` entry (rather than `main`) — the
/// host "call a script function" primitive. Arguments flow through the shared
/// globals (`script_engine_set_global_*` before the call; `script_global_*`
/// inside the entry); the marshaled result comes back in the outcome handle.
@intrinsic("script_engine_call")
public fn script_engine_call(engine: RawScriptEngine, source: Text, fn_name: Text) -> RawScriptOutcome;

/// Like `script_engine_call` but passes the `args` list's elements as the
/// entry's positional parameters (rather than via the shared globals).
@intrinsic("script_engine_call_args")
public fn script_engine_call_args<T>(engine: RawScriptEngine, source: Text, fn_name: Text, args: List<T>) -> RawScriptOutcome;

/// Opaque handle to a persistent linked session (zero-copy interop tier).
public type RawScriptSession is (*const Byte);

/// Merge two scripts into ONE module and open a persistent session over them:
/// both scripts' functions run on one interpreter (one heap), so a value one
/// call stores another reads back BY REFERENCE — no boundary copy, safe under
/// CBGR. Null handle on compile/link failure.
@intrinsic("script_engine_link2")
public fn script_engine_link2(engine: RawScriptEngine, source_a: Text, source_b: Text) -> RawScriptSession;

/// Merge N scripts (a list of sources) into a persistent session — the
/// zero-copy tier generalized to a whole set (e.g. loading many plugins into
/// one shared world).
@intrinsic("script_engine_link")
public fn script_engine_link(engine: RawScriptEngine, sources: List<Text>) -> RawScriptSession;

/// Run `fn_name` on the persistent session; state written by earlier calls is
/// visible (the zero-copy sharing).
@intrinsic("script_session_call")
public fn script_session_call(session: RawScriptSession, fn_name: Text) -> RawScriptOutcome;

/// Free a session handle.
@intrinsic("script_session_free")
public fn script_session_free(session: RawScriptSession);

// =============================================================================
// SECTION 4: Outcome Inspection
// =============================================================================

/// Whether the script succeeded (no compile/runtime error).
@intrinsic("script_outcome_is_ok")
public fn script_outcome_is_ok(outcome: RawScriptOutcome) -> Bool;

/// Dynamic-kind tag of the outcome's value. Canonical `ScriptValue` tag,
/// shared with `script_global_kind`:
/// `0`=Nil, `1`=Bool, `2`=Int, `3`=Float, `4`=Text, `5`=List, `6`=Map,
/// `7`=other/opaque.
@intrinsic("script_outcome_kind")
public fn script_outcome_kind(outcome: RawScriptOutcome) -> Int;

/// The outcome's value as `Int` (valid when `kind == 2`).
@intrinsic("script_outcome_as_int")
public fn script_outcome_as_int(outcome: RawScriptOutcome) -> Int;

/// The outcome's value as `Float` (valid when `kind == 3`).
@intrinsic("script_outcome_as_float")
public fn script_outcome_as_float(outcome: RawScriptOutcome) -> Float;

/// The outcome's value as `Bool` (valid when `kind == 1`).
@intrinsic("script_outcome_as_bool")
public fn script_outcome_as_bool(outcome: RawScriptOutcome) -> Bool;

/// The outcome's value as `Text` (valid when `kind == 4`); empty otherwise.
@intrinsic("script_outcome_as_text")
public fn script_outcome_as_text(outcome: RawScriptOutcome) -> Text;

/// The outcome's error message as `Text` (empty when the script succeeded).
@intrinsic("script_outcome_error")
public fn script_outcome_error(outcome: RawScriptOutcome) -> Text;

/// The outcome's captured stdout as `Text`.
@intrinsic("script_outcome_stdout")
public fn script_outcome_stdout(outcome: RawScriptOutcome) -> Text;

/// Destroy an outcome handle. The handle must not be used afterwards.
@intrinsic("script_outcome_free")
public fn script_outcome_free(outcome: RawScriptOutcome);

// =============================================================================
// SECTION 5: Sandboxed Engine
// =============================================================================

/// Create a sandboxed engine with resource limits (each `0` = unlimited):
/// `memory_limit` bytes, `instruction_limit` fuel, `time_limit_ms` wall-clock.
/// A script that exceeds a limit aborts and yields a failed outcome.
@intrinsic("script_engine_new_sandboxed")
public fn script_engine_new_sandboxed(
    memory_limit: USize,
    instruction_limit: UInt64,
    time_limit_ms: UInt64,
) -> RawScriptEngine;

// =============================================================================
// SECTION 6: Host <-> Script Data Exchange
// =============================================================================
// The host seeds typed globals on an engine; the next script run reads them
// via the `script_global_*` intrinsics (full host-function callbacks are a
// shared-world / later-phase feature).

/// Host: set an `Int` global on an engine (visible to the next script run).
@intrinsic("script_engine_set_global_int")
public fn script_engine_set_global_int(engine: RawScriptEngine, name: Text, value: Int);

/// Host: set a `Text` global on an engine.
@intrinsic("script_engine_set_global_text")
public fn script_engine_set_global_text(engine: RawScriptEngine, name: Text, value: Text);

/// Host: set a `Bool` global on an engine.
@intrinsic("script_engine_set_global_bool")
public fn script_engine_set_global_bool(engine: RawScriptEngine, name: Text, value: Bool);

/// Host: set a `Float` global on an engine.
@intrinsic("script_engine_set_global_float")
public fn script_engine_set_global_float(engine: RawScriptEngine, name: Text, value: Float);

/// Script: the dynamic-kind tag of a host/shared global (canonical
/// `ScriptValue` tag, see `script_outcome_kind`):
/// `0`=Nil, `1`=Bool, `2`=Int, `3`=Float, `4`=Text, `5`=List, `6`=Map,
/// `7`=other; `0` if absent.
@intrinsic("script_global_kind")
public fn script_global_kind(name: Text) -> Int;

/// Script: read a host global as `Int` (`0` if absent or not an Int).
@intrinsic("script_global_int")
public fn script_global_int(name: Text) -> Int;

/// Script: read a host global as `Text` (empty if absent).
@intrinsic("script_global_text")
public fn script_global_text(name: Text) -> Text;

/// Script: read a host global as `Bool` (`false` if absent or not a Bool).
@intrinsic("script_global_bool")
public fn script_global_bool(name: Text) -> Bool;

/// Script: read a host global as `Float` (`0.0` if absent or not a Float).
@intrinsic("script_global_float")
public fn script_global_float(name: Text) -> Float;

// =============================================================================
// SECTION 7: Host-Function Callbacks
// =============================================================================
// The host registers `fn(Int) -> Int` callbacks on an engine; scripts call
// them by name. The callback runs re-entrantly on the host interpreter, so it
// sees the host's state. (Richer signatures + shared-world callbacks are a
// later-phase feature.)

/// Host: register a `fn(Int) -> Int` callback on an engine under `name`.
@intrinsic("script_engine_register")
public fn script_engine_register(engine: RawScriptEngine, name: Text, f: fn(Int) -> Int);

/// Script: call a host-registered `Int -> Int` function by name (`0` if the
/// name is not registered).
@intrinsic("script_host_call_int")
public fn script_host_call_int(name: Text, arg: Int) -> Int;

// =============================================================================
// SECTION 8: Shared World (P2) — interop between scripts
// =============================================================================
// A `World` carries a persistent shared table across evals, so scripts running
// in the same world cooperate over shared data (the full zero-overhead tier
// links cooperating scripts into one module via the runtime linker so large
// structures share truly by-reference, CBGR-safe).

/// Opaque handle to a host-owned persistent `ScriptWorld`.
public type RawScriptWorld is (*const Byte);

/// Create a persistent shared world.
@intrinsic("script_world_new")
public fn script_world_new() -> RawScriptWorld;

/// Compile and run `source` on a world's persistent interpreter (shared heap).
@intrinsic("script_world_eval")
public fn script_world_eval(world: RawScriptWorld, source: Text) -> RawScriptOutcome;

/// Destroy a shared world.
@intrinsic("script_world_free")
public fn script_world_free(world: RawScriptWorld);

/// Script: write an `Int` into the shared-global table (visible to other
/// scripts in the same world).
@intrinsic("script_set_int")
public fn script_set_int(name: Text, value: Int);

/// Script: write a `Text` into the shared-global table (visible to other
/// scripts in the same world).
@intrinsic("script_set_text")
public fn script_set_text(name: Text, value: Text);

/// Script: write a `Bool` into the shared-global table.
@intrinsic("script_set_bool")
public fn script_set_bool(name: Text, value: Bool);

/// Script: write a `Float` into the shared-global table.
@intrinsic("script_set_float")
public fn script_set_float(name: Text, value: Float);

// Heap-collection globals (host→script seeding / script→world sharing). The
// host (or an earlier script) seeds a `List`/`Map`; `build_value` reconstructs
// it on this script's heap, and these read it back as a native collection. The
// element type is the caller's — inferred from the binding, as with `List.new`.
@intrinsic("script_global_list")
public fn script_global_list<T>(name: Text) -> List<T>;
@intrinsic("script_global_map")
public fn script_global_map<K, V>(name: Text) -> Map<K, V>;

/// Script: share a `List` / `Map` into the world/host table (read back by the
/// host or another script via `script_global_list` / `script_global_map`).
@intrinsic("script_set_list")
public fn script_set_list<T>(name: Text, value: List<T>);
@intrinsic("script_set_map")
public fn script_set_map<K, V>(name: Text, value: Map<K, V>);

// =============================================================================
// SECTION 9: Structural marshaling of a `List` outcome value
// =============================================================================
// When a script returns a `List` (`script_outcome_kind == 5`), these navigate
// its structurally-marshaled elements so the host can rebuild a typed value.
// Elements are addressed by index; an element's own kind tag selects which
// `*_elem_*` accessor to read (one level — a nested list surfaces as Unknown).

/// Host: element count of a `List` outcome value (`0` if not a list).
@intrinsic("script_outcome_list_len")
public fn script_outcome_list_len(outcome: RawScriptOutcome) -> Int;

/// Host: the kind tag of list element `i` (canonical `ScriptValue` tag).
@intrinsic("script_outcome_list_elem_kind")
public fn script_outcome_list_elem_kind(outcome: RawScriptOutcome, i: Int) -> Int;

/// Host: list element `i` as `Int` (valid when its kind is `2`).
@intrinsic("script_outcome_list_elem_int")
public fn script_outcome_list_elem_int(outcome: RawScriptOutcome, i: Int) -> Int;

/// Host: list element `i` as `Float` (valid when its kind is `3`).
@intrinsic("script_outcome_list_elem_float")
public fn script_outcome_list_elem_float(outcome: RawScriptOutcome, i: Int) -> Float;

/// Host: list element `i` as `Bool` (valid when its kind is `1`).
@intrinsic("script_outcome_list_elem_bool")
public fn script_outcome_list_elem_bool(outcome: RawScriptOutcome, i: Int) -> Bool;

/// Host: list element `i` as `Text` (valid when its kind is `4`).
@intrinsic("script_outcome_list_elem_text")
public fn script_outcome_list_elem_text(outcome: RawScriptOutcome, i: Int) -> Text;

// =============================================================================
// SECTION 10: Structural marshaling of a `Map` outcome value
// =============================================================================
// When a script returns a `Map` (`script_outcome_kind == 6`), these navigate
// its entries as `(key, value)` pairs by index; each side's own kind tag
// selects which typed accessor to read.

/// Host: entry count of a `Map` outcome value (`0` if not a map).
@intrinsic("script_outcome_map_len")
public fn script_outcome_map_len(outcome: RawScriptOutcome) -> Int;

/// Host: kind tag of entry `i`'s key / value (canonical `ScriptValue` tag).
@intrinsic("script_outcome_map_key_kind")
public fn script_outcome_map_key_kind(outcome: RawScriptOutcome, i: Int) -> Int;
@intrinsic("script_outcome_map_value_kind")
public fn script_outcome_map_value_kind(outcome: RawScriptOutcome, i: Int) -> Int;

/// Host: entry `i`'s key as a typed scalar.
@intrinsic("script_outcome_map_key_int")
public fn script_outcome_map_key_int(outcome: RawScriptOutcome, i: Int) -> Int;
@intrinsic("script_outcome_map_key_float")
public fn script_outcome_map_key_float(outcome: RawScriptOutcome, i: Int) -> Float;
@intrinsic("script_outcome_map_key_bool")
public fn script_outcome_map_key_bool(outcome: RawScriptOutcome, i: Int) -> Bool;
@intrinsic("script_outcome_map_key_text")
public fn script_outcome_map_key_text(outcome: RawScriptOutcome, i: Int) -> Text;

/// Host: entry `i`'s value as a typed scalar.
@intrinsic("script_outcome_map_value_int")
public fn script_outcome_map_value_int(outcome: RawScriptOutcome, i: Int) -> Int;
@intrinsic("script_outcome_map_value_float")
public fn script_outcome_map_value_float(outcome: RawScriptOutcome, i: Int) -> Float;
@intrinsic("script_outcome_map_value_bool")
public fn script_outcome_map_value_bool(outcome: RawScriptOutcome, i: Int) -> Bool;
@intrinsic("script_outcome_map_value_text")
public fn script_outcome_map_value_text(outcome: RawScriptOutcome, i: Int) -> Text;

// Nested-collection marshaling: a List/Map element that is itself a List
// (kind 5) or Map (kind 6) is wrapped in a fresh sub-outcome handle the host
// recurses on with `marshal_outcome`, then frees with `script_outcome_free`.
@intrinsic("script_outcome_list_elem_sub")
public fn script_outcome_list_elem_sub(outcome: RawScriptOutcome, i: Int) -> RawScriptOutcome;
@intrinsic("script_outcome_map_key_sub")
public fn script_outcome_map_key_sub(outcome: RawScriptOutcome, i: Int) -> RawScriptOutcome;
@intrinsic("script_outcome_map_value_sub")
public fn script_outcome_map_value_sub(outcome: RawScriptOutcome, i: Int) -> RawScriptOutcome;
