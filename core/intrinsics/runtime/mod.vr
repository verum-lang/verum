// =============================================================================
// core/intrinsics/runtime/mod.vr - Runtime-Dependent Intrinsics
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: Runtime system
//

// This module provides intrinsics that require runtime support:
// - async: Async runtime operations (spawn, await)
// - tls: Thread-local storage access
// - syscall: Direct kernel syscall interface
// - cbgr: CBGR memory safety validation
// - time: High-resolution timing (OS-dependent)
// - sync: Synchronization primitives (futex, spinlock)
// - text: Text/string operations (allocation-dependent)
// - tier: VBC tier management
//

// These intrinsics cannot run in bare-metal/no-std environments without
// the corresponding runtime support.
//

// # @requires_runtime Attribute
//

// Functions in these modules are implicitly @requires_runtime, meaning
// they need the Verum runtime to be available.
//

// Spec: docs/detailed/05-syntax-grammar.md
// =============================================================================

module core.intrinsics.runtime;

/// Async runtime intrinsics: spawn, executor, futures
public mount async_ops.*;

/// Thread-local storage intrinsics
public mount tls.*;

/// Direct syscall interface
public mount syscall.*;

/// CBGR memory safety validation
public mount cbgr.*;

/// High-resolution timing (OS-dependent)
public mount time.*;

/// Synchronization primitives
public mount sync.*;

/// Text/string operations (allocation-dependent)
public mount text.*;

/// VBC tier management
public mount tier.*;

/// OS kernel-boundary intrinsics — file I/O, networking, time, raw
/// allocation, process spawn, context system, defer, args, concurrency
/// primitives.  Migrated from `core/sys/raw.vr` (#61 Phase 1.1).
public mount os.*;

/// I/O engine + socket-option + async I/O intrinsics — kqueue/epoll/IOCP
/// readiness multiplexer, setsockopt helpers, async_accept/read/write.
/// Migrated from `core/io/engine.vr` (#63 Phase 1.3).
public mount io.*;

/// Raw memory operations — `Int`-pointer API for memcpy/memmove/memset/
/// memcmp/strlen/strcmp + scalar load/store (i32/i64/byte).  Migrated
/// from `core/mem/raw_ops.vr` (#64 Phase 1.4).
public mount mem_raw.*;
