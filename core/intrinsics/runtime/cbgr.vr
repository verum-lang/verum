// =============================================================================
// core/intrinsics/runtime/cbgr.vr - CBGR Memory Safety Intrinsics
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: CBGR runtime
//
// Memory safety validation intrinsics for Capability-Based Generational
// References (CBGR).
//
// VBC Opcode: ChkRef (0x74)
//
// Spec: docs/detailed/26-cbgr-implementation.md
// =============================================================================

module core.intrinsics.runtime.cbgr;

// =============================================================================
// SECTION 1: Reference Validation
// =============================================================================

/// Validate CBGR reference (Tier 0 check).
///
/// Performs full CBGR validation:
/// - Generation check
/// - Epoch check
/// - Capability check
///
/// Requires: CBGR runtime
@intrinsic("cbgr_validate")
public fn cbgr_validate<T>(reference: &T) -> Bool;

// =============================================================================
// SECTION 2: Epoch Management
// =============================================================================

/// Get current epoch.
///
/// Reads global epoch counter via TLS.
/// Requires: CBGR runtime
@intrinsic("cbgr_current_epoch")
public fn cbgr_current_epoch() -> UInt64;

/// Advance epoch.
///
/// Increments global epoch counter atomically.
/// Requires: CBGR runtime
@intrinsic("cbgr_advance_epoch")
public fn cbgr_advance_epoch();

// =============================================================================
// SECTION 3: Generation Access
// =============================================================================

/// Get generation counter for allocation.
///
/// Reads from allocation header.
/// Requires: CBGR runtime
@intrinsic("cbgr_get_generation")
public unsafe fn cbgr_get_generation(ptr: *const Byte) -> UInt32;
