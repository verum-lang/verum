// =============================================================================
// core/intrinsics/runtime/os.vr — Raw OS Syscall Intrinsics (centralised)
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: Operating system kernel
//
// Centralised home for all kernel-boundary intrinsics — file I/O, network,
// time, memory allocation, process spawn, context system, defer cleanup,
// command-line args, concurrency primitives.  Migrated from `core/sys/raw.vr`
// (#61 Phase 1.1) to satisfy the architectural invariant that all
// `@intrinsic` declarations live under `core/intrinsics/`.
//
// **Naming**: declarations preserve the historical `__xxx_raw` prefix from
// pre-migration code so downstream callers using `mount sys.raw.{__xxx_raw}`
// continue to resolve through the backwards-compat shim in `core/sys/raw.vr`.
// New code mounts directly from `core.intrinsics.runtime.os.{...}`.
//
// # Two-tier dispatch
//
// Each intrinsic name has TWO implementations selected by execution tier:
//   * Tier 0 (interpreter): handler in
//     `crates/verum_vbc/src/interpreter/dispatch_table/handlers/`
//     dispatches by intrinsic name (the string in `@intrinsic("...")`).
//   * Tier 1 (AOT): LLVM IR emitter in `crates/verum_codegen/src/llvm/*.rs`
//     emits target-specific syscall sequences.  Routes by
//     `module.get_triple()` (cross-compile-aware) — never by host
//     `#[cfg(target_os)]`.
//
// # Cross-compilation
//
// `verum --target T build x.vr` produces a target-T binary by emitting
// LLVM IR keyed off T:
//   * Linux: direct syscalls via `syscall` (x86_64) / `svc #0` (aarch64)
//   * macOS: libSystem.B.dylib calls (Apple-required boundary)
//   * Windows: kernel32.dll + ntdll.dll (no MSVC CRT)
//
// Zero libc on any target — `ldd`/`otool`/`dumpbin` verification.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.intrinsics.runtime.os;

// =============================================================================
// File I/O
// =============================================================================

/// Open a file. Returns fd on success, -1 on error.
/// flags: 0=read, 1=write, 2=read+write, 0x100=create, 0x200=truncate, 0x400=append
@intrinsic("file_open")
public fn __file_open_raw(path: Text, flags: Int, mode: Int) -> Int;

/// Close a file descriptor.
@intrinsic("file_close")
public fn __file_close_raw(fd: Int) -> Int;

/// Read from fd into buffer. Returns bytes read, 0=EOF, -1=error.
@intrinsic("file_read")
public fn __file_read_raw(fd: Int, buf: Int, len: Int) -> Int;

/// Write to fd from buffer. Returns bytes written, -1=error.
@intrinsic("file_write")
public fn __file_write_raw(fd: Int, buf: Int, len: Int) -> Int;

/// Seek within file. whence: 0=SET, 1=CUR, 2=END. Returns new offset.
@intrinsic("file_seek")
public fn __file_seek_raw(fd: Int, offset: Int, whence: Int) -> Int;

/// Get file size via fstat. Returns size or -1.
@intrinsic("file_size")
public fn __file_size_raw(fd: Int) -> Int;

/// Delete file (unlink).
@intrinsic("file_delete")
public fn __file_delete_raw(path: Text) -> Int;

/// Create directory.
@intrinsic("mkdir")
public fn __mkdir_raw(path: Text, mode: Int) -> Int;

/// Read entire file to Text (convenience).
@intrinsic("file_read_to_string")
public fn __file_read_to_string_raw(path: Text) -> Text;

/// Write Text to file (create/truncate).
@intrinsic("file_write_string")
public fn __file_write_string_raw(path: Text, content: Text) -> Int;

// =============================================================================
// Networking — TCP
// =============================================================================

/// Create TCP socket, connect to host:port. Returns fd or -1.
@intrinsic("tcp_connect")
public fn __tcp_connect_raw(host: Text, port: Int) -> Int;

/// Create TCP socket, bind to port, listen. Returns listen_fd or -1.
@intrinsic("tcp_listen")
public fn __tcp_listen_raw(port: Int) -> Int;

/// Rich-signature TCP listen intrinsic. Replaces `__tcp_listen_raw` for
/// the user-facing `core.net.tcp.TcpListener` surface — the older arity-1
/// form is preserved for the legacy `RawTcpListener` shim.
///
/// Parameters:
///  * `host` — IP literal (`"0.0.0.0"`, `"127.0.0.1"`, `"::"`, `"::1"`).
///  No DNS; resolution is the caller's job.
///  * `port` — `0..65535`. `0` asks the kernel to assign — pair with
///  `__tcp_local_port_raw(fd)` to recover the bound port.
///  * `backlog` — forwarded to `listen(2)` (kernel may cap to `somaxconn`).
///  * `flags` — bit-packed options:
///  * bit 0: `TCP_LISTEN_FLAG_REUSEPORT` (best-effort per-platform).
///
/// Returns `fd > 0` on success, or a negative `errno` on failure.
@intrinsic("tcp_listen_v2")
public fn __tcp_listen_v2_raw(host: Text, port: Int, backlog: Int, flags: Int) -> Int;

/// Bit-packed flag constants for [`__tcp_listen_v2_raw`].
public const TCP_LISTEN_FLAG_REUSEPORT: Int = 1;

/// Recover the OS-assigned local port of a listening / connected fd.
@intrinsic("tcp_local_port")
public fn __tcp_local_port_raw(fd: Int) -> Int;

/// Accept incoming connection. Returns new fd or -1.
@intrinsic("tcp_accept")
public fn __tcp_accept_raw(listen_fd: Int) -> Int;

/// Send text over TCP. Returns bytes sent or -1.
@intrinsic("tcp_send")
public fn __tcp_send_raw(fd: Int, data: Text) -> Int;

/// Receive text from TCP. Returns received Text.
@intrinsic("tcp_recv")
public fn __tcp_recv_raw(fd: Int, max_len: Int) -> Text;

/// Close TCP socket.
@intrinsic("tcp_close")
public fn __tcp_close_raw(fd: Int) -> Int;

// =============================================================================
// Networking — UDP
// =============================================================================

/// Create UDP socket, bind to port. Returns fd or -1.
@intrinsic("udp_bind")
public fn __udp_bind_raw(port: Int) -> Int;

/// Send UDP datagram.
@intrinsic("udp_send")
public fn __udp_send_raw(fd: Int, data: Text, host: Text, port: Int) -> Int;

/// Receive UDP datagram.
@intrinsic("udp_recv")
public fn __udp_recv_raw(fd: Int, max_len: Int) -> Text;

/// Close UDP socket.
@intrinsic("udp_close")
public fn __udp_close_raw(fd: Int) -> Int;

// =============================================================================
// Reactor-backed timeout-bound I/O (VBC-NET-RT-2)
//
// These intrinsics wait for socket readiness via the Tier-0 reactor
// (kqueue on macOS, epoll on Linux) before performing the I/O.  They
// are the host-side counterpart to the Tier-1 `core.sys.io_engine`
// IOEngine protocol implementations (`KqueueDriver`, `EpollDriver`,
// `IocpDriver`).
//
// Status convention for the entire family:
//   >0 = bytes transferred / new fd
//   0  = empty body or accept-with-zero-timeout-and-nothing-pending
//   -1 = EOF / closed
//   -2 = timeout (deadline elapsed before readiness)
//   -3 = reactor unhealthy
//   -4 = I/O error after the kernel signalled readiness
// =============================================================================

/// Wait for fd to become readable, up to `timeout_ms` milliseconds.
/// Returns 1 (ready), 0 (timeout), -1 (reactor error).
@intrinsic("io_wait_readable")
public fn __io_wait_readable_raw(fd: Int, timeout_ms: Int) -> Int;

/// Wait for fd to become writable.
@intrinsic("io_wait_writable")
public fn __io_wait_writable_raw(fd: Int, timeout_ms: Int) -> Int;

/// Accept a connection on `listen_fd` with timeout.
@intrinsic("tcp_accept_timeout")
public fn __tcp_accept_timeout_raw(listen_fd: Int, timeout_ms: Int) -> Int;

/// Send data with timeout.
@intrinsic("tcp_send_timeout")
public fn __tcp_send_timeout_raw(fd: Int, data: Text, timeout_ms: Int) -> Int;

/// Recv with timeout.
@intrinsic("tcp_recv_timeout")
public fn __tcp_recv_timeout_raw(fd: Int, max_len: Int, timeout_ms: Int) -> Text;

/// Connect with timeout.
@intrinsic("tcp_connect_timeout")
public fn __tcp_connect_timeout_raw(host: Text, port: Int, timeout_ms: Int) -> Int;

/// UDP recv with timeout.
@intrinsic("udp_recv_timeout")
public fn __udp_recv_timeout_raw(fd: Int, max_len: Int, timeout_ms: Int) -> Text;

// =============================================================================
// Time
// =============================================================================

/// Get monotonic time in nanoseconds.
@intrinsic("time_monotonic_nanos")
public fn __time_monotonic_nanos_raw() -> Int;

/// Sleep for specified nanoseconds.
@intrinsic("time_sleep_nanos")
public fn __time_sleep_nanos_raw(nanos: Int) -> Int;

/// Get wall-clock time in milliseconds since epoch.
@intrinsic("time_now_ms")
public fn __time_now_ms_raw() -> Int;

// =============================================================================
// Memory — raw allocation (used by higher-level allocators in `core/mem/`)
// =============================================================================

/// Allocate size bytes. Returns pointer or 0.
@intrinsic("alloc")
public fn __alloc_raw(size: Int) -> Int;

/// Allocate zeroed memory.
@intrinsic("alloc_zeroed")
public fn __alloc_zeroed_raw(size: Int) -> Int;

/// Free previously allocated memory.
@intrinsic("dealloc")
public fn __dealloc_raw(ptr: Int, size: Int) -> Int;

// =============================================================================
// Process spawn / wait
// =============================================================================

/// Spawn child process. Returns pid or -1.
@intrinsic("process_spawn")
public fn __process_spawn_raw(program: Text, args: List<Text>, capture_stdout: Int, capture_stderr: Int) -> Int;

/// Wait for child process. Returns status.
@intrinsic("process_wait")
public fn __process_wait_raw(pid: Int) -> Int;

/// Read all bytes from fd. Returns list header pointer.
@intrinsic("fd_read_all")
public fn __fd_read_all_raw(fd: Int) -> Int;

/// Close fd.
@intrinsic("fd_close")
public fn __fd_close_raw(fd: Int) -> Int;

// =============================================================================
// Context System
// =============================================================================

/// Get context value by type ID.
@intrinsic("ctx_get")
public fn __ctx_get_raw(type_id: Int) -> Int;

/// Provide context value.
@intrinsic("ctx_provide")
public fn __ctx_provide_raw(type_id: Int, value: Int) -> Int;

/// End context scope.
@intrinsic("ctx_end")
public fn __ctx_end_raw(type_id: Int) -> Int;

// =============================================================================
// Defer cleanup (RAII on unwind)
// =============================================================================

/// Push a defer cleanup callback.
@intrinsic("defer_push")
public fn __defer_push_raw(cleanup_fn: Int, arg: Int) -> Int;

/// Pop and execute the most recent defer.
@intrinsic("defer_pop")
public fn __defer_pop_raw() -> Int;

/// Run all defers down to target depth.
@intrinsic("defer_run_to")
public fn __defer_run_to_raw(target_depth: Int) -> Int;

/// Get current defer stack depth.
@intrinsic("defer_depth")
public fn __defer_depth_raw() -> Int;

// =============================================================================
// Command-line arguments
// =============================================================================

/// Get number of command-line arguments.
@intrinsic("args_count")
public fn __args_count_raw() -> Int;

/// Get argument at index.
@intrinsic("arg")
public fn __arg_raw(index: Int) -> Text;

// =============================================================================
// Concurrency primitives — mutex
// =============================================================================

/// Create a new mutex. Returns handle.
@intrinsic("mutex_new")
public fn __mutex_new_raw() -> Int;

/// Lock a mutex.
@intrinsic("mutex_lock")
public fn __mutex_lock_raw(mtx: Int) -> Int;

/// Unlock a mutex.
@intrinsic("mutex_unlock")
public fn __mutex_unlock_raw(mtx: Int) -> Int;

/// Try to lock a mutex. Returns 1 if acquired, 0 if not.
@intrinsic("mutex_trylock")
public fn __mutex_trylock_raw(mtx: Int) -> Int;

// =============================================================================
// Concurrency primitives — condition variable
// =============================================================================

/// Create a condition variable.
@intrinsic("cond_new")
public fn __cond_new_raw() -> Int;

/// Wait on a condition variable.
@intrinsic("cond_wait")
public fn __cond_wait_raw(cond: Int, mtx: Int) -> Int;

/// Wait on condvar with timeout (nanoseconds).
@intrinsic("cond_timedwait")
public fn __cond_timedwait_raw(cond: Int, mtx: Int, timeout_ns: Int) -> Int;

/// Signal one waiter on condvar.
@intrinsic("cond_signal")
public fn __cond_signal_raw(cond: Int) -> Int;

/// Broadcast to all waiters on condvar.
@intrinsic("cond_broadcast")
public fn __cond_broadcast_raw(cond: Int) -> Int;

// =============================================================================
// Generator handle
// =============================================================================

/// Close a generator handle.
@intrinsic("gen_close")
public fn __gen_close_raw(gen_handle: Int) -> Int;

// =============================================================================
// Panic primitives — migrated from `core/base/panic.vr` (#65 Phase 1.5)
// =============================================================================

/// Write a string to stderr using platform-specific syscalls.
/// Linux: write(2) syscall to fd=2; macOS: libSystem write; Windows:
/// WriteConsoleW or WriteFile to GetStdHandle(STD_ERROR_HANDLE).
@intrinsic("verum.io.write_stderr")
public fn write_stderr(s: &Text);

/// Exit the process with a status code.
/// Linux: exit_group syscall; macOS: libSystem _exit; Windows: ExitProcess.
@intrinsic("verum.process.exit")
public fn exit_process(code: Int) -> !;
