// =============================================================================
// SECTION 6: Comparison
// =============================================================================

/// Equality comparison
public fn eq<T>(a: T, b: T) -> Bool { @intrinsic("eq", a, b) }

/// Inequality comparison
public fn ne<T>(a: T, b: T) -> Bool { @intrinsic("ne", a, b) }

/// Less than comparison
public fn lt<T>(a: T, b: T) -> Bool { @intrinsic("lt", a, b) }

/// Less than or equal comparison
public fn le<T>(a: T, b: T) -> Bool { @intrinsic("le", a, b) }

/// Greater than comparison
public fn gt<T>(a: T, b: T) -> Bool { @intrinsic("gt", a, b) }

/// Greater than or equal comparison
public fn ge<T>(a: T, b: T) -> Bool { @intrinsic("ge", a, b) }

/// Minimum of two values
public fn min<T>(a: T, b: T) -> T { @intrinsic("minnum", a, b) }

/// Maximum of two values
public fn max<T>(a: T, b: T) -> T { @intrinsic("maxnum", a, b) }

/// Clamp value between min and max
public fn clamp<T>(x: T, min_val: T, max_val: T) -> T {
    min(max(x, min_val), max_val)
}

// =============================================================================
// SECTION 7: Wide/Extended Arithmetic
// =============================================================================

/// Full-width multiply: returns (low_bits, high_bits)
/// Unsigned full-width multiply: `(lo, hi)` halves of the 128-bit
/// product of the operands' 64-bit patterns.
///
/// ARITH-PURE-BODY-1 (2026-07-15): pure body via the textbook 32-bit
/// split (was an unregistered @intrinsic → LoadNil).  Every partial
/// product of two 32-bit halves fits in 64 bits, so the recomposition
/// is carry-exact with plain wrapping adds; LLVM folds this shape to a
/// single `umulh`/`mul` pair at Tier-1.
public fn widening_mul<T>(a: T, b: T) -> (T, T) {
    let mask = (0xFFFFFFFF) as T;
    let a_lo = a & mask;
    let a_hi = lshr(a, 32 as UInt32);
    let b_lo = b & mask;
    let b_hi = lshr(b, 32 as UInt32);

    let p_ll = wrapping_mul(a_lo, b_lo);
    let p_lh = wrapping_mul(a_lo, b_hi);
    let p_hl = wrapping_mul(a_hi, b_lo);
    let p_hh = wrapping_mul(a_hi, b_hi);

    // mid collects the two cross products plus ll's high half; each term
    // is < 2^32 (a 32×32 product's half), so the sum fits without carry.
    let mid = wrapping_add(wrapping_add(lshr(p_ll, 32 as UInt32), p_lh & mask), p_hl & mask);

    let lo = (p_ll & mask) | (mid << (32 as UInt32));
    let hi = wrapping_add(
        wrapping_add(p_hh, lshr(p_lh, 32 as UInt32)),
        wrapping_add(lshr(p_hl, 32 as UInt32), lshr(mid, 32 as UInt32)),
    );
    (lo, hi)
}

/// Signed full-width multiply: `(lo, hi)` of the 128-bit two's-complement
/// product.  Standard `mulh`-from-`mulhu` correction: subtract each
/// operand from the unsigned high half when the OTHER operand is
/// negative.  ARITH-PURE-BODY-1: pure body.
public fn widening_mul_signed<T>(a: T, b: T) -> (T, T) {
    let (lo, hi_u) = widening_mul(a, b);
    let mut hi = hi_u;
    if a < (0 as T) { hi = wrapping_sub(hi, b); }
    if b < (0 as T) { hi = wrapping_sub(hi, a); }
    (lo, hi)
}

/// Carrying add: (a + b + carry_in) -> (sum, carry_out).
///
/// ARITH-PURE-BODY-1 (2026-07-15): pure body (was an unregistered
/// @intrinsic → LoadNil).  Carry-out is the UNSIGNED wrap of the 64-bit
/// patterns — detected with the sign-bias compare (`x ^ 2^63` orders
/// bit patterns unsigned under the signed comparator).  LLVM folds the
/// chain to `adds`/`adcs` at Tier-1.
public fn carrying_add<T>(a: T, b: T, carry: Bool) -> (T, Bool) {
    let bias = (1 as T) << (63 as UInt32);
    let s1 = wrapping_add(a, b);
    let c1 = (s1 ^ bias) < (a ^ bias);
    let s2 = if carry { wrapping_add(s1, 1 as T) } else { s1 };
    let c2 = carry && s2 == (0 as T);
    (s2, c1 || c2)
}

/// Borrowing sub: (a - b - borrow_in) -> (diff, borrow_out).
/// Borrow-out is the unsigned underflow of the 64-bit patterns.
/// ARITH-PURE-BODY-1: pure body; see `carrying_add`.
public fn borrowing_sub<T>(a: T, b: T, borrow: Bool) -> (T, Bool) {
    let bias = (1 as T) << (63 as UInt32);
    let d1 = wrapping_sub(a, b);
    let b1 = (a ^ bias) < (b ^ bias);
    let d2 = if borrow { wrapping_sub(d1, 1 as T) } else { d1 };
    let b2 = borrow && d1 == (0 as T);
    (d2, b1 || b2)
}

// =============================================================================
// SECTION 8: Integer Utilities
// =============================================================================

/// Count leading sign bits (not including the sign bit itself) — the
/// number of redundant high bits equal to the sign bit; e.g. `0` and `-1`
/// give 63, `1` gives 62.
///
/// ARITH-PURE-BODY-1 (2026-07-15): pure body (was an unregistered
/// @intrinsic → LoadNil).  `x ^ (x >> 63)` clears every redundant sign
/// bit (arithmetic shift replicates the sign), so `clz` of that pattern
/// counts them plus the sign position itself.
public fn leading_sign_bits<T>(x: T) -> Int {
    clz(x ^ (x >> (63 as UInt32))) - 1
}

/// Integer log2 (floor)
public fn ilog2<T>(x: T) -> Int { @intrinsic("ilog2", x) }

/// Integer log10 (floor).  Panics on non-positive input (mirror of the
/// `ilog2` domain contract).  ARITH-PURE-BODY-1 (2026-07-15): pure body
/// (was an unregistered @intrinsic → LoadNil); ≤ 19 divisions for the
/// 64-bit domain.
public fn ilog10<T>(x: T) -> Int {
    if x <= (0 as T) { panic("ilog10: input must be positive"); }
    let mut v = x;
    let mut digits = 0;
    while v >= (10 as T) {
        v = v / (10 as T);
        digits = digits + 1;
    }
    digits
}

/// Check if value is a power of 2 (signed contract: positive with exactly
/// one bit set).  ARITH-PURE-BODY-1 (2026-07-15): pure body (was an
/// unregistered @intrinsic → LoadNil).
public fn is_power_of_two<T>(x: T) -> Bool {
    x > (0 as T) && (x & wrapping_sub(x, 1 as T)) == (0 as T)
}

/// Next power of 2 ≥ x (returns Maybe.None if unrepresentable — above
/// 2^62 for the signed 64-bit generic domain; `x <= 1` yields 1).
/// ARITH-PURE-BODY-1 (2026-07-15): pure body via `clz` (was an
/// unregistered @intrinsic → LoadNil).
public fn checked_next_power_of_two<T>(x: T) -> Maybe<T> {
    if x <= (1 as T) { return Maybe.Some(1 as T); }
    let max_pow = (1 as T) << (62 as UInt32);
    if x > max_pow { return Maybe.None; }
    let shift = 64 - clz(wrapping_sub(x, 1 as T));
    Maybe.Some((1 as T) << (shift as UInt32))
}

/// Next power of 2 (wraps on overflow)
public fn wrapping_next_power_of_two<T>(x: T) -> T { @intrinsic("wrapping_next_power_of_two", x) }
