// =============================================================================
// core/intrinsics/type_info.vr - Type Information Intrinsics
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: None (compiler-provided)
//
// # PREFERRED: Type Properties
//
// Verum provides compile-time type properties as the preferred way to access
// type information. Use these instead of function calls:
//
// | Property       | Description                    | Example          |
// |----------------|--------------------------------|------------------|
// | `T.size`       | Size in bytes                  | `Int.size` â†’ 8   |
// | `T.alignment`  | Memory alignment               | `Int.alignment`  |
// | `T.stride`     | Array element stride           | `T.stride`       |
// | `T.bits`       | Size in bits                   | `Int.bits` â†’ 64  |
// | `T.min`        | Minimum value (numeric)        | `Int.min`        |
// | `T.max`        | Maximum value (numeric)        | `Int.max`        |
// | `T.name`       | Type name as Text              | `Int.name`       |
// | `T.id`         | Unique type identifier (u64)   | `Int.id`         |
//
// # Legacy Functions
//
// The functions below are provided for compatibility. Prefer type properties:
// - `size_of<T>()` â†’ use `T.size` instead
// - `align_of<T>()` â†’ use `T.alignment` instead
// - `stride_of<T>()` â†’ use `T.stride` instead
// - `bits_of<T>()` â†’ use `T.bits` instead
// - `type_id<T>()` â†’ use `T.id` instead
// - `type_name<T>()` â†’ use `T.name` instead
//
// Spec: docs/detailed/17-meta-system.md
// =============================================================================

module core.intrinsics.type_info;

// =============================================================================
// SECTION 1: Size and Alignment (prefer T.size, T.alignment, T.stride, T.bits)
// =============================================================================

/// Size of type in bytes. Prefer: `T.size`
@deprecated("Use T.size type property instead")
public meta fn size_of<T>() -> USize { @intrinsic("size_of", T) }

/// Alignment of type in bytes. Prefer: `T.alignment`
@deprecated("Use T.alignment type property instead")
public meta fn align_of<T>() -> USize { @intrinsic("align_of", T) }

/// Stride of type (size rounded up to alignment). Prefer: `T.stride`
@deprecated("Use T.stride type property instead")
public meta fn stride_of<T>() -> USize { @intrinsic("stride_of", T) }

/// Size of type in bits. Prefer: `T.bits`
@deprecated("Use T.bits type property instead")
public meta fn bits_of<T>() -> USize { @intrinsic("bits_of", T) }

// =============================================================================
// SECTION 2: Type Identification (prefer T.id, T.name)
// =============================================================================

/// Type ID for runtime type identification. Prefer: `T.id`
@deprecated("Use T.id type property instead")
public meta fn type_id<T>() -> UInt64 { @intrinsic("type_id", T) }

/// Type name (compile-time only). Prefer: `T.name`
@deprecated("Use T.name type property instead")
public meta fn type_name<T>() -> Text { @intrinsic("type_name", T) }

// =============================================================================
// SECTION 3: Type Properties
// =============================================================================

/// Check if type needs drop
public meta fn needs_drop<T>() -> Bool { @intrinsic("needs_drop", T) }

/// Minimum alignment of all primitive types
public meta fn min_align() -> USize { @intrinsic("min_align") }
