// =============================================================================
// core/intrinsics/lowlevel/mmio.vr — MMIO + Memory Barrier Primitives
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: Maybe.None
//
// Migrated from `core/sys/mmio.vr` (#66 Phase 1.6).  Volatile memory
// access primitives + memory barriers — used by MmioRegister<T, MODE>
// in `core/sys/mmio.vr` for memory-mapped I/O on bare-metal / kernel
// drivers and by sync primitives that need explicit ordering control.
//
// **All declarations are `@llvm_only`** in spirit — they map directly
// to LLVM `load volatile` / `store volatile` / `fence` intrinsics with
// no interpreter fallback.  The interpreter doesn't have meaningful
// MMIO semantics; usage of these intrinsics from interpreter-mode
// code traps via the standard "no body for intrinsic" path.
// =============================================================================

@arch_module(
    foundation: Foundation.ZfcTwoInacc,
    stratum: MsfsStratum.LFnd,
    lifecycle: Lifecycle.Theorem("v0.1")
)
module core.intrinsics.lowlevel.mmio;

mount core.*;

// =============================================================================
// VOLATILE LOAD / STORE
// =============================================================================

/// Read from volatile memory location.
///
/// This is the primitive operation for MMIO reads. It:
/// - Prevents load elimination
/// - Emits a single memory read instruction
/// - Does NOT provide memory ordering (use with barriers if needed)
@inline(always)
@intrinsic("volatile_load")
public fn volatile_load<T: Copy>(ptr: *volatile T) -> T;

/// Write to volatile memory location.
///
/// This is the primitive operation for MMIO writes. It:
/// - Prevents store elimination
/// - Emits a single memory write instruction
/// - Does NOT provide memory ordering (use with barriers if needed)
@inline(always)
@intrinsic("volatile_store")
public fn volatile_store<T: Copy>(ptr: *volatile mut T, value: T);

/// Read with acquire semantics.
///
/// Ensures all subsequent reads and writes happen after this read.
/// Use for acquiring locks or reading synchronization flags.
@inline(always)
@intrinsic("volatile_load_acquire")
public fn volatile_load_acquire<T: Copy>(ptr: *volatile T) -> T;

/// Write with release semantics.
///
/// Ensures all previous reads and writes happen before this write.
/// Use for releasing locks or signaling completion.
@inline(always)
@intrinsic("volatile_store_release")
public fn volatile_store_release<T: Copy>(ptr: *volatile mut T, value: T);

// =============================================================================
// MEMORY BARRIERS
// =============================================================================

/// Memory barrier types for explicit ordering control.
///
/// **Defined here** — alongside `barrier`, its sole consumer — rather
/// than in `core/sys/mmio.vr`, to break the `core.sys.mmio` <->
/// `core.intrinsics.lowlevel.mmio` MODULE CYCLE. Previously `sys.mmio`
/// declared `BarrierKind` and this file mounted it back, while `sys.mmio`
/// mounts `barrier`/`dsb`/`isb` from here. That cycle left `barrier`
/// (param `kind: BarrierKind`) uncompilable during the stdlib precompile
/// — it became a `panic-stub: undefined function: barrier`, cascading to
/// its callers `compiler_barrier`/`dmb`. `core/sys/mmio.vr` re-exports
/// this type for the user-facing `core.sys.mmio.{BarrierKind}` API.
public type BarrierKind is
    | Compiler    // Prevent compiler reordering only
    | Acquire     // Load barrier (loads before this cannot move after)
    | Release     // Store barrier (stores after this cannot move before)
    | AcqRel      // Both acquire and release
    | SeqCst;     // Full sequential consistency

/// Insert a memory barrier.
///
/// Use barriers to enforce ordering between memory operations:
/// - Compiler: Prevents compiler reordering, no CPU fence
/// - Acquire: Ensures loads before are visible before loads/stores after
/// - Release: Ensures stores after are visible after loads/stores before
/// - AcqRel: Both acquire and release semantics
/// - SeqCst: Full sequential consistency (most expensive)
@inline(always)
public fn barrier(kind: BarrierKind) {
    // Host (interp + AOT): compiler/memory barriers are no-ops at the Verum
    // level — the host CPU memory model + LLVM codegen ordering cover the
    // conformance surface, and Verum concurrency uses atomics with explicit
    // ordering rather than raw fences. Kernel/embedded targets override with
    // the real fence via @cfg. Mirrors the kernel.vr safe-default discipline:
    // `@intrinsic("memory_barrier")` had no AOT codegen handler, leaving
    // `barrier` — and its callers `compiler_barrier`/`dmb` (core.sys.mmio) —
    // `unbound variable` under `--aot` while `--interp` resolved it.
    let _ = kind;
}

/// Data synchronization barrier (ARM terminology).
@inline(always)
@intrinsic("dsb")
public fn dsb();

/// Instruction synchronization barrier (ARM terminology).
@inline(always)
@intrinsic("isb")
public fn isb();
