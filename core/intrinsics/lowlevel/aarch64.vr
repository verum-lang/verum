@inline(always)
@llvm_only(reason = "inline assembly")
@asm("yield")
public fn yield_cpu();

/// Wait for interrupt (low-power wait).
@inline(always)
@llvm_only(reason = "inline assembly")
@asm("wfi")
public fn wfi();

/// Wait for event.
@inline(always)
@llvm_only(reason = "inline assembly")
@asm("wfe")
