// =============================================================================
// core/intrinsics/memory.vr - Memory Operation Intrinsics
// =============================================================================
// Layer: Stdlib (1)
// Dependencies: None (compiler-provided)
//
// This module provides memory operation intrinsics that map directly to
// LLVM/CPU instructions. All operations are zero-allocation and VBC-compatible.
//
// # Categories
//
// - Bulk memory: memcpy, memmove, memset, memcmp
// - Typed operations: copy, swap, replace, forget
// - Pointer operations: ptr_read, ptr_write, ptr_offset
// - Slice operations: slice_from_raw_parts, slice_len, slice_as_ptr
// - Uninitialized memory: uninit, zeroed
// - Volatile operations: volatile_load, volatile_store
//
// # Safety
//
// Most operations in this module are unsafe as they manipulate raw memory.
// Care must be taken to ensure memory validity, alignment, and lifetime.
//
// Spec: docs/detailed/05-syntax-grammar.md
// =============================================================================

module core.intrinsics.memory;

mount core.intrinsics.type_info.{size_of};

// =============================================================================
// SECTION 1: Bulk Memory Operations
// =============================================================================

/// Copy `count` bytes from `src` to `dst`, with overlapping ranges handled
/// safely (semantically equivalent to libc `memmove`).
///
/// # Safety
/// * Both `src` and `dst` must reference valid memory of at least `count`
///   bytes. The intrinsic does not bounds-check.
/// * `src` and `dst` MAY alias (overlap is well-defined for `memmove`).
/// * `count == 0` is a no-op even if either pointer is dangling — but
///   since `&mut Byte` is non-null in Verum, this is rarely relevant.
/// * No type-aware copy: the bytes are moved verbatim. Caller is
///   responsible for any drop/init invariants on typed values.
public fn memmove(dst: &mut Byte, src: &Byte, count: USize) { @intrinsic("memmove", dst, src, count) }

/// Copy `count` bytes from `src` to `dst`. The ranges MUST NOT overlap
/// (semantically equivalent to libc `memcpy`).
///
/// # Safety
/// * Both `src` and `dst` must reference valid memory of at least `count`
///   bytes.
/// * `src` and `dst` ranges MUST NOT overlap. If they might, use
///   `memmove`. Overlapping ranges produce unspecified output (LLVM
///   `memcpy` is undefined behaviour on overlap).
/// * Caller is responsible for drop/init invariants on typed values.
public fn memcpy(dst: &mut Byte, src: &Byte, count: USize) { @intrinsic("memcpy", dst, src, count) }

/// Fill `count` bytes at `dst` with `val`.
///
/// # Safety
/// * `dst` must reference valid memory of at least `count` bytes.
/// * Writing arbitrary bytes through a typed reference may violate
///   invariants — e.g. zeroing a `&mut Bool` produces a defined `false`,
///   but zeroing a `&mut NonNullPtr<T>` produces a UB-causing null.
public fn memset(dst: &mut Byte, val: Byte, count: USize) { @intrinsic("memset", dst, val, count) }

/// Compare `count` bytes at `a` and `b` lexicographically.
///
/// Returns 0 if equal, negative if `a < b`, positive if `a > b`.
///
/// # Safety
/// * Both `a` and `b` must reference valid memory of at least `count`
///   bytes.
///
/// # Note on timing
/// * `memcmp` may short-circuit on first difference and is therefore
///   NOT timing-safe. For comparing secret material (MAC tags, password
///   hashes), use `core.security.util.constant_time.constant_time_eq`
///   instead.
public fn memcmp(a: &Byte, b: &Byte, count: USize) -> Int { @intrinsic("memcmp", a, b, count) }

// =============================================================================
// SECTION 2: Typed Memory Operations
// =============================================================================

/// Copy typed value
public fn copy<T>(src: &T, dst: &mut T) { @intrinsic("memcpy", dst, src, T.size) }

/// Copy count typed values (non-overlapping)
public fn copy_nonoverlapping<T>(src: &T, dst: &mut T, count: USize) {
    @intrinsic("memcpy", dst, src, count * T.size)
}

/// Swap two values
public fn swap<T>(a: &mut T, b: &mut T) { @intrinsic("swap", a, b) }

/// Replace value, returning old
public fn replace<T>(dest: &mut T, src: T) -> T { @intrinsic("replace", dest, src) }

/// Forget value without running destructor
public fn forget<T>(value: T) { @intrinsic("forget", value) }

/// Transmute between types of same size (unsafe, use with care)
public fn transmute<S, D>(value: S) -> D { @intrinsic("transmute", value) }

// =============================================================================
// SECTION 3: Pointer Operations
// =============================================================================

/// Read a `T`-sized value from `ptr` by bitwise copy. Does NOT run any
/// destructor on the source.
///
/// # Safety
/// * `ptr` must be non-null and point to a valid initialised `T`.
/// * `ptr` must be aligned to `T.alignment`. For potentially-unaligned
///   reads, use `ptr_read_unaligned`.
/// * The pointee must remain valid for the lifetime of the returned `T`
///   if `T` carries references / pointers / file descriptors / etc.
/// * After this call, both the original location and the returned value
///   are considered to "own" the bits — caller is responsible for not
///   double-dropping (typically via `forget` on the source).
public unsafe fn ptr_read<T>(ptr: *const T) -> T { @intrinsic("ptr_read", ptr) }

/// Read a `T`-sized value from `ptr` without alignment requirement.
/// Slower on architectures where unaligned access traps; use only when
/// alignment can't be statically guaranteed (e.g. parsing wire formats).
///
/// # Safety
/// Same as `ptr_read` but `ptr` may be unaligned.
public unsafe fn ptr_read_unaligned<T>(ptr: *const T) -> T { @intrinsic("ptr_read_unaligned", ptr) }

/// Read a `T`-sized value from `ptr` with volatile semantics — the
/// compiler MUST emit the load and MUST NOT optimize it away or coalesce
/// it with adjacent reads. Used for memory-mapped I/O registers.
///
/// # Safety
/// Same as `ptr_read` plus: the pointee may be modified by hardware /
/// other threads concurrently with this read; caller's data race is on
/// them, not the language.
public unsafe fn ptr_read_volatile<T>(ptr: *const T) -> T { @intrinsic("ptr_read_volatile", ptr) }

/// Write `value` to `ptr` by bitwise copy. Does NOT run the destructor
/// of any prior occupant of `*ptr` — caller MUST ensure the destination
/// holds either uninitialised memory or a value whose drop has already
/// run, otherwise the prior value's resources leak.
///
/// # Safety
/// * `ptr` must be non-null, aligned to `T.alignment`, and point to
///   memory the caller is allowed to mutate.
/// * Caller is responsible for the prior-occupant drop discipline above.
public unsafe fn ptr_write<T>(ptr: *mut T, value: T) { @intrinsic("ptr_write", ptr, value) }

/// Write `value` to `ptr` without alignment requirement.
/// # Safety
/// Same as `ptr_write` but `ptr` may be unaligned.
public unsafe fn ptr_write_unaligned<T>(ptr: *mut T, value: T) { @intrinsic("ptr_write_unaligned", ptr, value) }

/// Write `value` to `ptr` with volatile semantics — compiler MUST emit
/// the store and MUST NOT optimize it away. Used for memory-mapped I/O.
/// # Safety
/// Same as `ptr_write`.
public unsafe fn ptr_write_volatile<T>(ptr: *mut T, value: T) { @intrinsic("ptr_write_volatile", ptr, value) }

/// Write `count * T.size` copies of byte `val` to `ptr`, treating the
/// pointee as a flat byte buffer.
///
/// # Safety
/// * `ptr` must reference at least `count * T.size` bytes of writable
///   memory.
/// * If `T` has any non-trivial drop or invariants, callers should
///   prefer typed initialisation. This intrinsic is for raw-buffer
///   patterns (zeroing fresh allocations, fill-pattern marker bytes).
public unsafe fn ptr_write_bytes<T>(ptr: *mut T, val: Byte, count: USize) {
    @intrinsic("memset", ptr, val, count * T.size)
}

/// Add `count * T.size` to the byte address of `ptr` (signed offset).
///
/// # Safety
/// * The resulting pointer must point INTO or one-past-the-end of the
///   same allocation as `ptr`. Crossing allocation boundaries is UB
///   even if the resulting address happens to be valid memory.
/// * The byte-offset `count * T.size` must not overflow `isize`.
public unsafe fn ptr_offset<T>(ptr: *const T, count: ISize) -> *const T { @intrinsic("ptr_offset", ptr, count) }

/// Mutable variant of `ptr_offset`. Same safety contract.
public unsafe fn ptr_offset_mut<T>(ptr: *mut T, count: ISize) -> *mut T { @intrinsic("ptr_offset_mut", ptr, count) }

/// Add unsigned offset to pointer
public unsafe fn ptr_add<T>(ptr: *const T, count: USize) -> *const T { @intrinsic("ptr_add", ptr, count) }

/// Subtract unsigned offset from pointer
public unsafe fn ptr_sub<T>(ptr: *const T, count: USize) -> *const T { @intrinsic("ptr_sub", ptr, count) }

/// Get null pointer of type T
public fn null_ptr<T>() -> *const T { @intrinsic("null_ptr") }

/// Get null mutable pointer of type T
public fn null_ptr_mut<T>() -> *mut T { @intrinsic("null_ptr_mut") }

/// Check if pointer is null
public fn ptr_is_null<T>(ptr: *const T) -> Bool { @intrinsic("ptr_is_null", ptr) }

/// Check if pointer is aligned
public fn ptr_is_aligned<T>(ptr: *const T) -> Bool { @intrinsic("ptr_is_aligned", ptr) }

/// Check if pointer is aligned to given alignment
public fn ptr_is_aligned_to<T>(ptr: *const T, align: USize) -> Bool { @intrinsic("ptr_is_aligned_to", ptr, align) }

/// Run destructor for value at pointer without deallocating
public unsafe fn drop_in_place<T>(ptr: *mut T) { @intrinsic("drop_in_place", ptr) }

// =============================================================================
// SECTION 4: Slice Operations
// =============================================================================

/// Create slice from raw parts (ptr, len)
public unsafe fn slice_from_raw_parts<T>(ptr: *const T, len: USize) -> &[T] {
    @intrinsic("slice_from_raw_parts", ptr, len)
}

/// Create mutable slice from raw parts
public unsafe fn slice_from_raw_parts_mut<T>(ptr: *mut T, len: USize) -> &mut [T] {
    @intrinsic("slice_from_raw_parts_mut", ptr, len)
}

/// Get length of slice
public fn slice_len<T>(slice: &[T]) -> USize { @intrinsic("slice_len", slice) }

/// Get raw pointer to slice data
public fn slice_as_ptr<T>(slice: &[T]) -> *const T { @intrinsic("slice_as_ptr", slice) }

/// Get mutable raw pointer to slice data
public fn slice_as_mut_ptr<T>(slice: &mut [T]) -> *mut T { @intrinsic("slice_as_mut_ptr", slice) }

/// Get element at index without bounds checking
public unsafe fn slice_get_unchecked<T>(slice: &[T], idx: USize) -> &T {
    @intrinsic("slice_get_unchecked", slice, idx)
}

/// Get mutable element at index without bounds checking
public unsafe fn slice_get_unchecked_mut<T>(slice: &mut [T], idx: USize) -> &mut T {
    @intrinsic("slice_get_unchecked_mut", slice, idx)
}

// =============================================================================
// SECTION 5: Uninitialized Memory
// =============================================================================

/// Create uninitialized memory for type T
/// Safety: Reading from the result is undefined behavior until initialized.
public unsafe fn uninit<T>() -> T { @intrinsic("uninit") }

/// Create zeroed memory for type T
/// Safety: Zero bits may not be valid for all types.
public unsafe fn zeroed<T>() -> T { @intrinsic("zeroed") }

/// Check if memory is definitely initialized
/// Note: This is conservative - may return false for initialized memory.
public fn maybe_uninit_is_init<T>(val: &T) -> Bool { @intrinsic("maybe_uninit_is_init", val) }

// =============================================================================
// SECTION 6: Volatile Operations
// =============================================================================

/// Volatile load (not optimized away, for memory-mapped I/O)
public fn volatile_load<T>(ptr: *const T) -> T { @intrinsic("volatile_load", ptr) }

/// Volatile store (not optimized away, for memory-mapped I/O)
public fn volatile_store<T>(ptr: *mut T, val: T) { @intrinsic("volatile_store", ptr, val) }

/// Volatile copy memory
public fn volatile_copy<T>(src: *const T, dst: *mut T, count: USize) {
    @intrinsic("volatile_copy", src, dst, count)
}

/// Volatile set memory
public fn volatile_set<T>(dst: *mut T, val: T, count: USize) {
    @intrinsic("volatile_set", dst, val, count)
}

// =============================================================================
// SECTION 7: Pointer Conversion
// =============================================================================

/// Convert raw pointer to immutable reference
/// Safety: Pointer must be valid, aligned, and point to initialized data.
public unsafe fn ptr_to_ref<T>(ptr: *const T) -> &T { @intrinsic("ptr_to_ref", ptr) }

/// Convert raw pointer to mutable reference
/// Safety: Pointer must be valid, aligned, point to initialized data, and be unique.
public unsafe fn ptr_to_mut_ref<T>(ptr: *mut T) -> &mut T { @intrinsic("ptr_to_mut_ref", ptr) }

/// Read value from raw pointer
public unsafe fn ptr_read<T>(ptr: *const T) -> T { @intrinsic("ptr_read", ptr) }

/// Write value to raw pointer
public unsafe fn ptr_write<T>(ptr: *mut T, val: T) { @intrinsic("ptr_write", ptr, val) }

/// Offset a raw const pointer by n elements
public unsafe fn ptr_offset<T>(ptr: *const T, n: Int) -> *const T { @intrinsic("ptr_offset", ptr, n) }

/// Offset a raw mut pointer by n elements
public unsafe fn ptr_offset_mut<T>(ptr: *mut T, n: Int) -> *mut T { @intrinsic("ptr_offset_mut", ptr, n) }

/// Drop value in place
public unsafe fn drop_in_place<T>(ptr: *mut T) { @intrinsic("drop_in_place", ptr) }

/// Create a slice from raw parts
public unsafe fn slice_from_raw_parts<T>(ptr: *const T, len: USize) -> &[T] { @intrinsic("slice_from_raw_parts", ptr, len) }

/// Create a mutable slice from raw parts
public unsafe fn slice_from_raw_parts_mut<T>(ptr: *mut T, len: USize) -> &mut [T] { @intrinsic("slice_from_raw_parts_mut", ptr, len) }

// =============================================================================
// SECTION 8: Slice Operations
// =============================================================================

/// Get unchecked element from slice
public unsafe fn slice_get_unchecked<T>(slice: &[T], index: USize) -> &T { @intrinsic("slice_get_unchecked", slice, index) }

/// Get unchecked mutable element from slice
public unsafe fn slice_get_unchecked_mut<T>(slice: &mut [T], index: USize) -> &mut T { @intrinsic("slice_get_unchecked_mut", slice, index) }

/// Get subslice (start..end)
public fn slice_subslice<T>(slice: &[T], start: USize, end: USize) -> &[T] { @intrinsic("slice_subslice", slice, start, end) }

/// Get mutable subslice (start..end)
public fn slice_subslice_mut<T>(slice: &mut [T], start: USize, end: USize) -> &mut [T] { @intrinsic("slice_subslice_mut", slice, start, end) }

/// Split slice at index
public fn slice_split_at<T>(slice: &[T], mid: USize) -> (&[T], &[T]) { @intrinsic("slice_split_at", slice, mid) }

/// Split mutable slice at index
public fn slice_split_at_mut<T>(slice: &mut [T], mid: USize) -> (&mut [T], &mut [T]) { @intrinsic("slice_split_at_mut", slice, mid) }
