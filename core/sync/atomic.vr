// =============================================================================
// AtomicBool
// =============================================================================

// Atomic boolean for lock-free concurrent access.
public type AtomicBool is {
    value: Byte,  // 0 = false, 1 = true
};

implement AtomicBool {
    // Create new atomic with initial value.
    public fn new(val: Bool) -> AtomicBool {
        AtomicBool { value: if val { 1 } else { 0 } }
    }

    // Load value with ordering.
    // Uses typed atomic_load_u8 intrinsic (Bool stored as Byte).
    public fn load(&self, order: MemoryOrdering) -> Bool {
        let ptr = &self.value as *const Byte as *const UInt8;
        atomic_load_u8(ptr, ordering_to_u8(order)) != 0
    }

    // Store value with ordering.
    // Uses typed atomic_store_u8 intrinsic.
    public fn store(&self, val: Bool, order: MemoryOrdering) {
        let ptr = &self.value as *const Byte as *mut UInt8;
        atomic_store_u8(ptr, if val { 1 } else { 0 }, ordering_to_u8(order));
    }

    // Swap value, returning old value.
    // Uses u32-aligned CAS loop for true atomicity.
    public fn swap(&self, val: Bool, order: MemoryOrdering) -> Bool {
        let order_u8 = ordering_to_u8(order);
        let byte_ptr = &self.value as *const Byte as Int;
        let aligned_ptr = (byte_ptr & !3) as *mut UInt32;
        let byte_offset = (byte_ptr & 3) as UInt32;
        let shift = byte_offset * 8;
        let mask: UInt32 = 0xFF << shift;
        let new_byte: UInt32 = if val { 1 } else { 0 };
        loop {
            let word = atomic_load_u32(aligned_ptr as *const UInt32, order_u8);
            let new_word = (word & !mask) | (new_byte << shift);
            let (old_word, success) = atomic_cas_u32(aligned_ptr, word, new_word, order_u8, ORDERING_RELAXED);
            if success {
                return ((old_word >> shift) & 0xFF) != 0;
            }
        }
    }

    // Compare && swap. Returns Ok(current) if successful, Err(actual) otherwise.
    // Uses u32-aligned word-level CAS for true atomicity.
    public fn compare_exchange(
        &self,
        current: Bool,
        new: Bool,
        success: MemoryOrdering,
        failure: MemoryOrdering
    ) -> Result<Bool, Bool> {
        let current_byte: UInt32 = if current { 1 } else { 0 };
        let new_byte: UInt32 = if new { 1 } else { 0 };
        let byte_ptr = &self.value as *const Byte as Int;
        let aligned_ptr = (byte_ptr & !3) as *mut UInt32;
        let byte_offset = (byte_ptr & 3) as UInt32;
        let shift = byte_offset * 8;
        let mask: UInt32 = 0xFF << shift;
        let success_u8 = ordering_to_u8(success);
        let failure_u8 = ordering_to_u8(failure);
        loop {
            let word = atomic_load_u32(aligned_ptr as *const UInt32, failure_u8);
            let actual_byte = (word >> shift) & 0xFF;
            if actual_byte != current_byte {
                return Err(actual_byte != 0);
            }
            let new_word = (word & !mask) | (new_byte << shift);
            let (_, did_swap) = atomic_cas_u32(aligned_ptr, word, new_word, success_u8, failure_u8);
            if did_swap {
                return Ok(current);
            }
        }
    }

    // Get mutable reference to underlying value.
    public fn get_mut(&mut self) -> &mut Bool {
        // Safe because we have exclusive access
        unsafe { &mut *(&mut self.value as *mut Byte as *mut Bool) }
    }
}

implement Default for AtomicBool {
    fn default() -> AtomicBool {
        AtomicBool.new(false)
    }
}

implement Debug for AtomicBool {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("AtomicBool(")?;
        self.load(MemoryOrdering.SeqCst).fmt_debug(f)?;
        f.write_str(")")
    }
}

// =============================================================================
// AtomicPtr<T>
// =============================================================================

// Atomic pointer for lock-free concurrent access.
public type AtomicPtr<T> is {
    ptr: Int,  // Pointer stored as integer
};

implement<T> AtomicPtr<T> {
    // Create new atomic pointer.
    public fn new(ptr: &unsafe T) -> AtomicPtr<T> {
        AtomicPtr { ptr: ptr as Int }
    }

    // Create null atomic pointer.
    public fn null() -> AtomicPtr<T> {
        AtomicPtr { ptr: 0 }
    }

    // Load pointer with ordering.
    // Uses typed atomic_load_u64 intrinsic (pointers are 64-bit).
    public fn load(&self, order: MemoryOrdering) -> &unsafe T {
        let ptr = &self.ptr as *const Int as *const UInt64;
        atomic_load_u64(ptr, ordering_to_u8(order)) as &unsafe T
    }

    // Store pointer with ordering.
    // Uses typed atomic_store_u64 intrinsic.
    public fn store(&self, ptr: &unsafe T, order: MemoryOrdering) {
        let storage_ptr = &self.ptr as *const Int as *mut UInt64;
        atomic_store_u64(storage_ptr, ptr as Int as UInt64, ordering_to_u8(order));
    }

    // Swap pointer, returning old value.
    // Implemented using CAS loop with typed atomic_cas_u64 intrinsic.
    public fn swap(&self, ptr: &unsafe T, order: MemoryOrdering) -> &unsafe T {
        let storage_ptr = &self.ptr as *const Int as *mut UInt64;
        let order_u8 = ordering_to_u8(order);
        loop {
            let current = atomic_load_u64(storage_ptr as *const UInt64, order_u8);
            let (old, success) = atomic_cas_u64(storage_ptr, current, ptr as Int as UInt64, order_u8, ORDERING_RELAXED);
            if success {
                return old as &unsafe T;
            }
        }
    }

    // Compare && swap. Returns Ok(current) if successful, Err(actual) otherwise.
    // Uses typed atomic_cas_u64 intrinsic.
    public fn compare_exchange(
        &self,
        current: &unsafe T,
        new: &unsafe T,
        success: MemoryOrdering,
        failure: MemoryOrdering
    ) -> Result<&unsafe T, &unsafe T> {
        let storage_ptr = &self.ptr as *const Int as *mut UInt64;
        let (actual, did_swap) = atomic_cas_u64(
            storage_ptr,
            current as Int as UInt64,
            new as Int as UInt64,
            ordering_to_u8(success),
            ordering_to_u8(failure)
        );
        if did_swap {
            Ok(current)
        } else {
            Err(actual as &unsafe T)
        }
    }

    // Check if pointer is null.
    public fn is_null(&self) -> Bool {
        self.load(MemoryOrdering.Relaxed) as Int == 0
    }
}

implement<T> Default for AtomicPtr<T> {
    fn default() -> AtomicPtr<T> {
        AtomicPtr.null()
    }
}

// =============================================================================
// SpinLock (low-level)
// =============================================================================

// Simple spinlock for bootstrap synchronization.
public type SpinLock is {
    locked: AtomicBool,
};

implement SpinLock {
    // Create new unlocked spinlock.
    public fn new() -> SpinLock {
        SpinLock { locked: AtomicBool.new(false) }
    }

    // Try to acquire lock without blocking.
    public fn try_lock(&self) -> Bool {
        self.locked.compare_exchange(false, true, MemoryOrdering.Acquire, MemoryOrdering.Relaxed).is_ok()
    }

    // Acquire lock, spinning until available.
    public fn lock(&self) {
        while !self.try_lock() {
            // Spin - in real code, use CPU pause instruction
            compiler_fence(MemoryOrdering.SeqCst);
        }
    }

    // Release lock.
    public fn unlock(&self) {
        self.locked.store(false, MemoryOrdering.Release);
    }

    // Check if locked.
    public fn is_locked(&self) -> Bool {
        self.locked.load(MemoryOrdering.Relaxed)
    }
}

implement Default for SpinLock {
    fn default() -> SpinLock {
        SpinLock.new()
    }
}

// =============================================================================
// FutexLock (OS-backed, doesn't busy-wait)
// =============================================================================

// Lock states for futex-based mutex
const FUTEX_UNLOCKED: Int = 0;
const FUTEX_LOCKED: Int = 1;
const FUTEX_LOCKED_CONTENDED: Int = 2;

// Futex-based lock that uses OS-level waiting instead of busy-waiting.
// This is more efficient than SpinLock under contention because threads
// sleep instead of consuming CPU cycles.
//
// Performance:
// - Uncontended: ~25ns (slightly slower than spinlock's ~10ns)
// - Contended: ~1-10μs (much better than spinlock's CPU waste)
//
// Spec: docs/audit1.md Section 11.5
public type FutexLock is {
    state: AtomicInt,
};

implement FutexLock {
    // Create new unlocked futex lock.
    public fn new() -> FutexLock {
        FutexLock { state: AtomicInt.new(FUTEX_UNLOCKED) }
    }

    // Try to acquire lock without blocking.
    public fn try_lock(&self) -> Bool {
        self.state.compare_exchange(FUTEX_UNLOCKED, FUTEX_LOCKED, MemoryOrdering.Acquire, MemoryOrdering.Relaxed).is_ok()
    }

    // Acquire lock, blocking if necessary using OS futex.
    // Does NOT busy-wait - threads sleep until woken.
    public fn lock(&self) {
        // Fast path: uncontended lock
        if self.try_lock() {
            return;
        }

        // Slow path: need to wait
        self.lock_slow();
    }

    // Slow path for lock acquisition - uses futex to sleep.
    fn lock_slow(&self) {
        loop {
            let mut state = self.state.load(MemoryOrdering.Relaxed);

            // If unlocked, try to lock
            if state == FUTEX_UNLOCKED {
                match self.state.compare_exchange(FUTEX_UNLOCKED, FUTEX_LOCKED, MemoryOrdering.Acquire, MemoryOrdering.Relaxed) {
                    Ok(_) => { return; },
                    Err(s) => { state = s; },
                }
            }

            // If locked (not contended), set to contended
            if state == FUTEX_LOCKED {
                state = self.state.swap(FUTEX_LOCKED_CONTENDED, MemoryOrdering.Acquire);
                if state == FUTEX_UNLOCKED {
                    // Got the lock while setting contended flag
                    return;
                }
            }

            // Wait on futex - this sleeps the thread (no CPU waste)
            // Linux: SYS_futex syscall, macOS: __ulock_wait
            @cfg(target_os = "linux")
            {
                let _ = sys_futex_wait(&self.state.value, FUTEX_LOCKED_CONTENDED, None);
            }

            @cfg(target_os = "macos")
            {
                let _ = sys_futex_wait(&self.state.value, FUTEX_LOCKED_CONTENDED, None);
            }

            // Windows: kernel-assisted sleep via WaitOnAddress
            @cfg(target_os = "windows")
            {
                let _ = sys_futex_wait(&self.state.value, FUTEX_LOCKED_CONTENDED, None);
            }
        }
    }

    // Release lock.
    public fn unlock(&self) {
        // Swap to unlocked and check if there were waiters
        let old = self.state.swap(FUTEX_UNLOCKED, MemoryOrdering.Release);

        if old == FUTEX_LOCKED_CONTENDED {
            // There were waiters, wake one
            @cfg(target_os = "linux") {
                let _ = sys_futex_wake(&self.state.value, 1);
            };
            @cfg(target_os = "macos") {
                let _ = sys_futex_wake(&self.state.value, 1);
            };
            @cfg(target_os = "windows") {
                let _ = sys_futex_wake(&self.state.value, 1);
            };
        }
    }

    // Check if locked.
    public fn is_locked(&self) -> Bool {
        self.state.load(MemoryOrdering.Relaxed) != FUTEX_UNLOCKED
    }
}

implement Default for FutexLock {
    fn default() -> FutexLock {
        FutexLock.new()
    }
}
