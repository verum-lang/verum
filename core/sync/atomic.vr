        let ptr = &self.value as *const UInt64 as *mut UInt64;
        let (actual, did_swap) = atomic_cas_u64(
            ptr,
            current,
            new,
            ordering_to_u8(success),
            ordering_to_u8(failure)
        );
        if did_swap {
            Ok(current)
        } else {
            Err(actual)
        }
