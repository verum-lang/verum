implement AtomicU64 {
    // Create new atomic with initial value.
    public fn new(val: UInt64) -> AtomicU64 {
        AtomicU64 { value: val }
    }

    // Load value with ordering.
    // Uses typed atomic_load_u64 intrinsic.
    public fn load(&self, order: MemoryOrdering) -> UInt64 {
        let ptr = &self.value as *const UInt64;
        atomic_load_u64(ptr, ordering_to_u8(order))
    }

    // Store value with ordering.
    // Uses typed atomic_store_u64 intrinsic.
    public fn store(&self, val: UInt64, order: MemoryOrdering) {
        let ptr = &self.value as *const UInt64 as *mut UInt64;
        atomic_store_u64(ptr, val, ordering_to_u8(order));
    }

    // Swap value, returning old value.
    // Implemented using CAS loop with typed atomic_cas_u64 intrinsic.
    public fn swap(&self, val: UInt64, order: MemoryOrdering) -> UInt64 {
        let ptr = &self.value as *const UInt64 as *mut UInt64;
        let order_u8 = ordering_to_u8(order);
        loop {
            let current = atomic_load_u64(ptr as *const UInt64, order_u8);
            let (old, success) = atomic_cas_u64(ptr, current, val, order_u8, ORDERING_RELAXED);
            if success {
                return old;
