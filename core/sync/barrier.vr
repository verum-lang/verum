// =============================================================================
// barrier.vr - Thread synchronization barrier
// =============================================================================
// Layer: 2.5 (Sync)
// Dependencies: core, sync/atomic, sync/mutex, sync/condvar
// =============================================================================
//
// A barrier enables multiple threads to synchronize at a specific point.
// All threads must reach the barrier before any of them can proceed.
//
// # Example
// ```verum
// let barrier = Shared.new(Barrier.new(3));
//
// for i in 0..3 {
//     let b = barrier.clone();
//     spawn {
//         // Phase 1 work
//         do_phase1_work(i);
//
//         // Wait for all threads
//         let res = b.wait();
//         if result.is_leader() {
//             print("All threads completed phase 1");
//         }
//
//         // Phase 2 work
//         do_phase2_work(i);
//     };
// }
// ```
//
// =============================================================================

module core.sync.barrier;
mount core.*;
mount .atomic.*;
mount .mutex.*;
mount .condvar.*;
mount core.intrinsics.runtime.time.{monotonic_nanos};

// =============================================================================
// Barrier
// =============================================================================

/// A synchronization primitive that blocks until N threads have reached it.
///
/// A barrier can be reused after all threads have synchronized - it
/// automatically resets for the next generation.
///
/// # Thread Safety
/// - Barrier is Sync && can be shared between threads
/// - Thread-safe for concurrent use
///
/// # Performance
/// - wait: O(1) amortized (last thread wakes all)
/// - Memory: O(1) constant overhead
public type Barrier is {
    /// Number of threads required to pass
    num_threads: Int,
    /// State protected by mutex
    state: Mutex<BarrierState>,
    /// Condition variable for waiting
    condvar: Condvar,
};

/// Internal state of the barrier.
type BarrierState is {
    /// Number of threads currently waiting
    count: Int,
    /// Generation counter (increments each time barrier is passed)
    generation: Int,
};

/// Result returned from `Barrier.wait()`.
///
/// Exactly one thread per barrier synchronization is designated as the
/// "leader". This is useful for performing one-time actions after all
/// threads have synchronized.
public type BarrierWaitResult is {
    /// True if this thread is the leader
    is_leader: Bool,
};

implement Barrier {
    /// Create a new barrier for `n` threads.
    ///
    /// # Panics
    /// Panics if `n` is 0.
    ///
    /// # Example
    /// ```verum
    /// let barrier = Barrier.new(4);  // Requires 4 threads
    /// ```
    public fn new(n: Int) -> Barrier {
        assert(n > 0, "Barrier requires at least 1 thread");

        Barrier {
            num_threads: n,
            state: Mutex.new(BarrierState {
                count: 0,
                generation: 0,
            }),
            condvar: Condvar.new(),
        }
    }

    /// Block until all threads have reached this barrier.
    ///
    /// Returns a `BarrierWaitResult` indicating whether this thread is
    /// the leader (exactly one thread per synchronization is the leader).
    ///
    /// # Example
    /// ```verum
    /// let res = barrier.wait();
    /// if result.is_leader() {
    ///     // Only one thread executes this
    ///     print("Barrier passed!");
    /// }
    /// ```
    public fn wait(&self) -> BarrierWaitResult {
        let mut guard = self.state.lock().unwrap_or_else(|p| p.into_inner());
        let my_generation = guard.generation;

        guard.count = guard.count + 1;

        if guard.count == self.num_threads {
            // We are the last thread - we're the leader
            // Reset for next generation
            guard.count = 0;
            guard.generation = guard.generation + 1;

            // Wake all waiting threads
            self.condvar.notify_all();

            return BarrierWaitResult { is_leader: true };
        }

        // Wait for other threads
        while guard.generation == my_generation {
            guard = self.condvar.wait(guard).unwrap();
        }

        BarrierWaitResult { is_leader: false }
    }

    /// Get the number of threads this barrier is configured for.
    public fn num_threads(&self) -> Int {
        self.num_threads
    }

    /// Get the number of threads currently waiting.
    ///
    /// Note: This is approximate due to concurrent modifications.
    public fn waiting_count(&self) -> Int {
        self.state.lock().unwrap_or_else(|p| p.into_inner()).count
    }

    /// Get the current generation number.
    ///
    /// The generation increments each time all threads pass the barrier.
    public fn generation(&self) -> Int {
        self.state.lock().unwrap_or_else(|p| p.into_inner()).generation
    }
}

implement BarrierWaitResult {
    /// Returns true if this thread is the leader.
    ///
    /// Exactly one thread per barrier synchronization is the leader.
    /// This is useful for performing actions that should only happen once.
    public fn is_leader(&self) -> Bool {
        self.is_leader
    }
}

implement Default for BarrierWaitResult {
    fn default() -> BarrierWaitResult {
        BarrierWaitResult { is_leader: false }
    }
}

implement Debug for Barrier {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("Barrier { num_threads: ")?;
        self.num_threads.fmt_debug(f)?;
        f.write_str(", waiting: ")?;
        self.waiting_count().fmt_debug(f)?;
        f.write_str(" }")
    }
}

implement Debug for BarrierWaitResult {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("BarrierWaitResult { is_leader: ")?;
        self.is_leader.fmt_debug(f)?;
        f.write_str(" }")
    }
}

// =============================================================================
// Phaser - Multi-phase barrier with dynamic registration
// =============================================================================

/// A flexible barrier supporting multiple phases && dynamic participants.
///
/// Unlike Barrier, Phaser allows:
/// - Threads to join/leave dynamically
/// - Multiple phases with callbacks between them
/// - Hierarchical organization for scalability
///
/// # Example
/// ```verum
/// let phaser = Phaser.new(0);  // Start with 0 parties
///
/// for i in 0..4 {
///     phaser.register();  // Dynamically add party
///     spawn {
///         // Work
///         phaser.arrive_and_await();
///         // More work
///         phaser.arrive_and_deregister();
///     };
/// }
/// ```
public type Phaser is {
    /// State packed into atomic for lock-free operations
    state: AtomicInt,
    /// Condition variable for waiting
    condvar: Condvar,
    /// Mutex for complex state changes
    mutex: Mutex<Bool>,
};

// State encoding (packed in i64, MUST avoid the sign bit):
//
//   Bit 63    — UNUSED (sign bit; storing 1 here corrupts every
//               arithmetic-shift right because i64 `>>` is
//               sign-extending; was previously TERMINATED_BIT
//               which silently broke phase decoding after
//               terminate() — see task #32).
//   Bit 62    — terminated flag
//   Bits 32-61 — phase number (30 bits = ~1.07 billion phases)
//   Bits 16-31 — arrived (≤ 0xFFFF parties per phase)
//   Bits  0-15 — parties (≤ 0xFFFF registered threads)
//
// The arithmetic-right-shift hazard: `state >> PHASE_SHIFT` on
// a signed i64 sign-extends the high bit.  If TERMINATED_BIT is
// the sign bit, every phase decode after terminate() reads
// `0xFFFF_FFFF_FFFF_FFFF as Int = -1`, then `(-1 + 1) << 32 = 0`
// in `arrive_and_await`'s phase-advance loop — the entire
// reconstructed state collapses to `0 | parties`, ALSO losing
// the TERMINATED_BIT itself.  Net effect: terminated phaser
// silently un-terminates the moment any thread arrives.
//
// Moving TERMINATED_BIT to bit 62 keeps the whole state
// non-negative regardless of termination state, so the
// arithmetic shift behaves identically to the logical shift on
// every architecture.

const PARTIES_MASK: Int = 0xFFFF;
const ARRIVED_SHIFT: Int = 16;
const ARRIVED_MASK: Int = 0xFFFF0000;
const PHASE_SHIFT: Int = 32;
// 30 bits available for the phase counter; mask used by all
// phase-decoding sites so the TERMINATED_BIT never bleeds into
// the phase value even if a code path forgets to strip it.
const PHASE_MASK_SHIFTED: Int = 0x3FFFFFFF;  // 30 bits == bits 32-61 once shifted right
const TERMINATED_BIT: Int = 1 << 62;

implement Phaser {
    /// Create a new phaser with initial parties.
    public fn new(parties: Int) -> Phaser {
        assert(parties >= 0 && parties <= 0xFFFF, "Invalid party count");

        Phaser {
            state: AtomicInt.new(parties),
            condvar: Condvar.new(),
            mutex: Mutex.new(false),
        }
    }

    /// Register a new party (thread).
    ///
    /// Returns the current phase number.
    public fn register(&self) -> Int {
        let _guard = self.mutex.lock().unwrap_or_else(|p| p.into_inner());

        let old_state = self.state.fetch_add(1, MemoryOrdering.SeqCst);
        // PHASE_MASK_SHIFTED guarantees the TERMINATED_BIT (now at
        // bit 62, but historically prone to bleed) never appears
        // in the returned phase number even under skew.
        ((old_state >> PHASE_SHIFT) & PHASE_MASK_SHIFTED) as Int
    }

    /// Arrive at the barrier && wait for others.
    ///
    /// Returns the phase number that was completed.
    ///
    /// **Phase-advance race fix**: when this thread is the
    /// last arrival, the phase-advance must use CAS to preserve
    /// concurrent `register()` / `arrive_and_deregister()`
    /// updates that may have run between our `fetch_add` and
    /// the advance. The earlier `state.store(new_state)`
    /// overwrote the entire packed atomic — silently dropping
    /// any concurrent party-count adjustment. The CAS loop
    /// retries with the latest observed `parties` value so
    /// concurrent registrations are preserved.
    public fn arrive_and_await(&self) -> Int {
        // Increment arrived count
        let old_state = self.state.fetch_add(1 << ARRIVED_SHIFT, MemoryOrdering.SeqCst);
        let parties = (old_state & PARTIES_MASK) as Int;
        let arrived = ((old_state & ARRIVED_MASK) >> ARRIVED_SHIFT) as Int + 1;
        let phase = ((old_state >> PHASE_SHIFT) & PHASE_MASK_SHIFTED) as Int;

        if arrived == parties {
            // We're the last — advance phase via CAS so any
            // concurrent register/deregister isn't lost.
            // Loop on observed-parties since concurrent
            // operations may have changed the count between
            // our fetch_add and our CAS.  We MUST preserve
            // TERMINATED_BIT in the new state (was lost in the
            // earlier reconstruction — terminated phaser silently
            // un-terminated on next arrival, see task #32).
            loop {
                let cur = self.state.load(MemoryOrdering.SeqCst);
                let cur_parties = (cur & PARTIES_MASK) as Int;
                let cur_phase = ((cur >> PHASE_SHIFT) & PHASE_MASK_SHIFTED) as Int;
                let cur_terminated = cur & TERMINATED_BIT;
                // Safety net: another thread may have already
                // advanced the phase (race with concurrent
                // last-arriver from a re-registration).  In
                // that case our work is done.
                if cur_phase != phase {
                    break;
                }
                let next_phase = ((phase + 1) & PHASE_MASK_SHIFTED) << PHASE_SHIFT;
                let new_state = next_phase | cur_parties | cur_terminated;
                if self.state.compare_exchange(cur, new_state, MemoryOrdering.SeqCst, MemoryOrdering.SeqCst).is_ok() {
                    break;
                }
                // CAS lost — reload and retry.  Bounded by
                // contention (typically 1-2 retries).
            }
            self.condvar.notify_all();
            return phase;
        }

        // Wait for phase to advance
        let mut guard = self.mutex.lock().unwrap_or_else(|p| p.into_inner());
        while self.get_phase() == phase {
            guard = self.condvar.wait(guard).unwrap();
        }

        phase
    }

    /// Arrive && deregister from the phaser.
    ///
    /// The calling thread will no longer participate in future phases.
    ///
    /// **Phase-advance race fix (task #32)**: the earlier
    /// implementation used `state.store(new_state)` to advance
    /// the phase while only holding `mutex` — that mutex is
    /// shared with `register()` but NOT with `arrive_and_await()`,
    /// so a concurrent `arrive_and_await` could `fetch_add`
    /// the arrived counter between our fetch_add and our store,
    /// and the store would silently overwrite the increment.
    /// Same data-loss class as the bug previously fixed in
    /// `arrive_and_await` itself.  We now use the same CAS-loop
    /// pattern with TERMINATED_BIT preservation.
    public fn arrive_and_deregister(&self) -> Int {
        let _guard = self.mutex.lock().unwrap_or_else(|p| p.into_inner());

        // Decrement parties && increment arrived
        let adjustment = (1 << ARRIVED_SHIFT) - 1;  // +1 arrived, -1 parties
        let old_state = self.state.fetch_add(adjustment, MemoryOrdering.SeqCst);

        let parties = ((old_state & PARTIES_MASK) - 1) as Int;
        let arrived = ((old_state & ARRIVED_MASK) >> ARRIVED_SHIFT) as Int + 1;
        let phase = ((old_state >> PHASE_SHIFT) & PHASE_MASK_SHIFTED) as Int;

        if arrived == parties + 1 {  // +1 because we decremented parties
            // Last one — advance phase via CAS preserving any
            // concurrent register/arrive_and_await + the
            // TERMINATED_BIT.  Loop on observed parties because
            // a concurrent register() under the mutex is impossible
            // (we hold it), but arrive_and_await is mutex-free and
            // can race the arrived counter forward.
            loop {
                let cur = self.state.load(MemoryOrdering.SeqCst);
                let cur_parties = (cur & PARTIES_MASK) as Int;
                let cur_phase = ((cur >> PHASE_SHIFT) & PHASE_MASK_SHIFTED) as Int;
                let cur_terminated = cur & TERMINATED_BIT;
                if cur_phase != phase {
                    break;  // someone else already advanced
                }
                let next_phase = ((phase + 1) & PHASE_MASK_SHIFTED) << PHASE_SHIFT;
                let new_state = next_phase | cur_parties | cur_terminated;
                if self.state.compare_exchange(cur, new_state, MemoryOrdering.SeqCst, MemoryOrdering.SeqCst).is_ok() {
                    break;
                }
            }
            self.condvar.notify_all();
        }

        phase
    }

    /// Get the current phase number.
    public fn get_phase(&self) -> Int {
        ((self.state.load(MemoryOrdering.SeqCst) >> PHASE_SHIFT) & PHASE_MASK_SHIFTED) as Int
    }

    /// Get the number of registered parties.
    public fn get_registered_parties(&self) -> Int {
        (self.state.load(MemoryOrdering.SeqCst) & PARTIES_MASK) as Int
    }

    /// Get the number of arrived parties in current phase.
    public fn get_arrived_parties(&self) -> Int {
        ((self.state.load(MemoryOrdering.SeqCst) & ARRIVED_MASK) >> ARRIVED_SHIFT) as Int
    }

    /// Check if the phaser is terminated.
    public fn is_terminated(&self) -> Bool {
        (self.state.load(MemoryOrdering.SeqCst) & TERMINATED_BIT) != 0
    }

    /// Terminate the phaser.
    public fn terminate(&self) {
        self.state.fetch_or(TERMINATED_BIT, MemoryOrdering.SeqCst);
        self.condvar.notify_all();
    }
}

// =============================================================================
// Latch - Single-use barrier
// =============================================================================

/// Internal state for CountDownLatch mutex.
type LatchState is {
    /// Dummy field to force type inference on MutexGuard
    dummy: Int,
};

/// A single-use synchronization barrier.
///
/// Threads block on `wait_for_zero()` until `count_down()` has been called N times.
/// Unlike Barrier, a Latch can only be used once.
///
/// # Example
/// ```verum
/// let latch = CountDownLatch.new(3);
///
/// for i in 0..3 {
///     spawn {
///         do_work(i);
///         latch.count_down();
///     };
/// }
///
/// // Block until all 3 tasks complete
/// latch.wait_for_zero();
/// print("All tasks done!");
/// ```
public type CountDownLatch is {
    count: AtomicInt,
    condvar: Condvar,
    latch_lock: Mutex<LatchState>,
};

implement CountDownLatch {
    /// Create a latch with the specified count.
    public fn new(count: Int) -> CountDownLatch {
        assert(count >= 0, "Latch count must be non-negative");

        CountDownLatch {
            count: AtomicInt.new(count),
            condvar: Condvar.new(),
            latch_lock: Mutex.new(LatchState { dummy: 0 }),
        }
    }

    /// Decrement the count by 1.
    ///
    /// If the count reaches zero, all waiting threads are released.
    public fn count_down(&self) {
        let prev = self.count.fetch_sub(1, MemoryOrdering.SeqCst);
        if prev == 1 {
            // Count reached zero - notify all waiters
            self.condvar.notify_all();
        }
    }

    /// Block until the count reaches zero.
    public fn wait_for_zero(&self) {
        if self.count.load(MemoryOrdering.SeqCst) == 0 {
            return;
        }

        let mut guard = self.latch_lock.lock().unwrap_or_else(|p| p.into_inner());
        while self.count.load(MemoryOrdering.SeqCst) > 0 {
            guard = self.condvar.wait(guard).unwrap();
        }
    }

    /// Block until count reaches zero || timeout expires.
    ///
    /// Returns true if count reached zero, false if timed out.
    ///
    /// **Correctness:** loops on the predicate (count > 0) under the
    /// mutex, recomputing remaining_ns against an absolute monotonic
    /// deadline each iteration. The earlier single-shot impl returned
    /// `false` on the first spurious condvar wake even when count was
    /// still > 0, and equivalently could wait for many multiples of
    /// `timeout_ns` if it naively re-passed the original duration on
    /// each retry. The deadline arithmetic keeps total elapsed time
    /// within the user-requested budget regardless of spurious wakes.
    public fn wait_for_zero_timeout(&self, timeout_ns: Int) -> Bool {
        if self.count.load(MemoryOrdering.SeqCst) == 0 {
            return true;
        }
        if timeout_ns <= 0 {
            return self.count.load(MemoryOrdering.SeqCst) == 0;
        }

        let deadline = monotonic_nanos() as Int + timeout_ns;
        let mut guard = self.latch_lock.lock().unwrap_or_else(|p| p.into_inner());
        while self.count.load(MemoryOrdering.SeqCst) > 0 {
            let remaining = deadline - (monotonic_nanos() as Int);
            if remaining <= 0 {
                return false;
            }
            let (next_guard, _timed_out) = self.condvar
                .wait_timeout(guard, remaining)
                .unwrap();
            guard = next_guard;
            // Re-check the predicate under the loop head — spurious
            // wakeup or the kernel-clock racing the user-supplied
            // budget both fall through to the next iteration where
            // the count load + deadline check decide the outcome.
        }
        true
    }

    /// Get the current count.
    public fn get_count(&self) -> Int {
        self.count.load(MemoryOrdering.Relaxed)
    }
}

implement Debug for CountDownLatch {
    fn fmt_debug(&self, f: &mut Formatter) -> Result<(), FormatError> {
        f.write_str("CountDownLatch { count: ")?;
        self.count.load(MemoryOrdering.Relaxed).fmt_debug(f)?;
        f.write_str(" }")
    }
}
